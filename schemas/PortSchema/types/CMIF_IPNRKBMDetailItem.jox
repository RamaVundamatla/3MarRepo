    <JadeMethod name="getBerth" id="6d327839-a4d6-4e1b-85e7-b4eb17dc776f">
        <source>getBerth() : HMS_Berth;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 August 2018	jlger1	Initial creation

*/

vars
	harbour : HMS_Harbour;
	term 	: CM_Terminal;
	berth : HMS_Berth;

begin
	if self.kade = null then
		return null;
	endif;
	
	term := app.myPassport.myTerminal;
	
	harbour := term.myHarbour;
	if harbour &lt;&gt; null then
		//berth := harbour.allBerths.getAtKey( _rawValue );
		foreach berth in harbour.allBerths discreteLock do
			if berth.externalReference2.trimBlanks = self.kade.trimBlanks or
				berth.code.trimBlanks=self.kade.trimBlanks or
				berth.description.trimBlanks = self.kade.trimBlanks then
				return berth;
			endif;
		endforeach;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="HMS_Berth"/>
    </JadeMethod>
    <JadeMethod name="getCargoType" id="43129550-2526-4e34-a999-0081d5305240">
        <source>getCargoType( _commodity : CM_Commodity output) : CM_CargoType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 July 2018	jlger1	Initial creation

*/

vars
	cargoType : CM_CargoType;
	cargoTypeStr : String;
	operator : CM_Operator;
	foundMatch : Boolean;
	commodityStr : String;
	temp 	: Real;
begin
	cargoType :=app.myRoot.getCargoTypeFromAbbrevOrDescr(self.namaBarang);
	
	if cargoType &lt;&gt; null then
		return cargoType;
	endif;
	operator :=app.myRoot.allOperators["PEL"];
	if operator &lt;&gt; null then
		cargoTypeStr := operator.getXlationSystemCode(self.namaBarang, XLATION_TYPE_CARGOTYPE_BYOP, foundMatch);
	endif;
	if cargoTypeStr &lt;&gt; null then
		cargoType := app.myRoot.getCargoTypeForID(cargoTypeStr.Integer);
	endif;
	
	_commodity:= app.myRoot.getCommodityByDesc(self.namaBarang);
	
	if _commodity = null then
		if operator &lt;&gt; null then
			commodityStr := operator.getXlationSystemCode_Commodity(self.namaBarang,  foundMatch,temp);
			if commodityStr &lt;&gt; null then
				_commodity:=app.myRoot.allCommodities[commodityStr];
			endif;
		endif;
	endif;
	if _commodity &lt;&gt; null then
		//at pelindo commodities only belong to one cargo type
		cargoType:=_commodity.allCargoTypes.first;
	endif;
	
	return cargoType;
epilog

end;</source>
        <Parameter name="_commodity" type="CM_Commodity" usage="output"/>
        <ReturnType type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="getConsignee" id="b7afa470-7e8c-478c-a5cc-10a2cf9a7220">
        <source>getConsignee() : CM_ConsigneeConsignor;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 August 2018	jlger1	Initial creation

*/

vars
	operator : CM_Operator;
	foundMatch : Boolean;
	systemCode : String;
	cons : CM_ConsigneeConsignor;
	consigneeCode : String;
begin
	//epr TFS 41758 5/11/18
	//consigneeCode:=self.consignee;
	//epr TFS 44657 9/5/19 
	consigneeCode:=self.npwpShipper;
	
	operator :=app.myRoot.allOperators["PEL"];
	if operator &lt;&gt; null then
		systemCode:= operator.getXlationSystemCode(consigneeCode, XLATION_TYPE_CONSIGNEE_BYOP, foundMatch);
		if foundMatch then
			consigneeCode :=systemCode;
		endif;
	endif;
	
	
	return app.myRoot.allConsigneeConsignors[consigneeCode];

epilog

end;</source>
        <ReturnType type="CM_ConsigneeConsignor"/>
    </JadeMethod>
    <JadeMethod name="getConsignor" id="db20917a-164f-4672-8067-1b48be127d35">
        <source>getConsignor() :  CM_ConsigneeConsignor;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 November 2018	jlger1	Initial creation 41758

*/

vars
	operator : CM_Operator;	
	systemCode : String;
	shipperCode : String;
	foundMatch : Boolean;
	
begin
	shipperCode:= self.shipper;
	//epr TFS 44657 9/5/19 
	shipperCode:=self.npwpShipper;
	if not self.isExport then
		return null;
	endif;
	if shipperCode = null then
		return null;
	endif;

	operator :=app.myRoot.allOperators["PEL"];
	if operator &lt;&gt; null then
		systemCode:= operator.getXlationSystemCode(shipperCode, XLATION_TYPE_CONSIGNEE_BYOP, foundMatch);
		if foundMatch then
			shipperCode :=systemCode;
		endif;
	endif;
	
	
	return app.myRoot.allConsigneeConsignors[shipperCode];

epilog

end;</source>
        <ReturnType type="CM_ConsigneeConsignor"/>
    </JadeMethod>
    <JadeMethod name="getOperator" id="44c07a4c-3c2b-4371-bb42-df0938e289ac">
        <source>getOperator() : CM_Operator;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 October 2018	jlger1	Initial creation 41626

*/

vars
	operator : CM_Operator;
	systemCode : String;
	foundMatch : Boolean;
begin
	//operator :=app.myRoot.allOperators["PEL"];
	//if operator &lt;&gt; null then
	//epr TFS 44657 9/5/19
	systemCode:= app.myRoot.getXlationSystemCode(self.npwpPbm, XLATION_TYPE_OPERATOR, foundMatch);
	if not foundMatch then
		systemCode :=null;
	endif;
	//endif;
	
	if systemCode &lt;&gt; null then
		return app.myRoot.allOperators[systemCode];
	else
		return app.myRoot.allOperators[self.npwpPbm];
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="getWorkPoint" id="a0254710-ca9c-4f58-9cdd-a564ccf215f0">
        <source>getWorkPoint(_terminal : CM_Terminal) : CM_WorkPoint;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 November 2018	jlger1	Initial creation 42095

*/

vars
	systemCode : String;
	foundMatch : Boolean;
begin
	
	
	if _terminal = null then
		return null;
	endif;
	
	systemCode:= _terminal.getXlationSystemCode(self.kade, XLATION_TYPE_WORKPOINT, foundMatch);
	if not foundMatch then
		systemCode :=null;
	endif;
	//endif;
	
	if systemCode &lt;&gt; null then
		return _terminal.allWorkPointsByCode[systemCode];
	else
		return _terminal.allWorkPointsByCode[self.kade];
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="CM_WorkPoint"/>
    </JadeMethod>
    <JadeMethod name="isExport" id="8140a832-ff82-4547-ab6f-9c12152fd84a">
        <source>isExport() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 October 2018	jlger1	Initial creation

*/

vars

begin
	return self.kegiatan.toUpper = "MUAT";
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateDetails" id="21ff810f-1c9b-41f1-8c6b-70a9d6c1e357">
        <source>validateDetails() ;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17/04/2018	jlgdap1		Initial creation TFS 38135 PEL1 Inaportnet Integration (Web Service Provider)
//
vars
	cargoTypeStr : String;
	cargoType : CM_CargoType;
	foundMatch : Boolean;
	consigneeStr : String;
	shipperStr : String;
	timeBongkar, timeMuat : TimeStamp;
	cons : CM_ConsigneeConsignor;
	voyageJobTransferType : CM_VoyageJobTransferType;
	commodity : CM_Commodity;
begin
	//6. namaBarang mandatory - name of goods
	if self.namaBarang = null then
		app.raiseCMException1(REQUIRED_FIELD, CMIF_IPNRKBMDetailItem::namaBarang.name, null, null);
	endif;

	cargoType := self.getCargoType(commodity);
	if cargoType = null then
		app.raiseCMException3(Value_field_not_resolve, self.namaBarang, CMIF_IPNRKBMDetailItem::namaBarang.name, app.getErrorString(CM_Cargo_Type), null, null);
	endif;	
	
	//7. bahaya mandatory - Danger "Y" or "N" (hazardous)
	if self.bahaya.toUpper &lt;&gt; "Y" and self.bahaya.toUpper &lt;&gt; "N" then
		app.raiseCMException3(Value_field_not_resolve, self.bahaya, CMIF_IPNRKBMDetailItem::bahaya.name, app.getErrorString(Value), null, null);
	endif;
	
	//8. ganggu mandatory - Disturb "Y" or "N"
	if self.ganggu.toUpper &lt;&gt; "Y" and self.ganggu.toUpper &lt;&gt; "N" then
		app.raiseCMException3(Value_field_not_resolve, self.ganggu, CMIF_IPNRKBMDetailItem::ganggu.name, app.getErrorString(Value), null, null);
	endif;
	
	//9. kegiatan mandatory - Activity - "BONGKAR" (unloading) or "MUAT" (loading) or "BM"
	if self.kegiatan.toUpper &lt;&gt; "BONGKAR" and self.kegiatan.toUpper &lt;&gt; "MUAT" and self.kegiatan.toUpper &lt;&gt; "BM" then
		app.raiseCMException3(Value_field_not_resolve, self.kegiatan, CMIF_IPNRKBMDetailItem::kegiatan.name, app.getErrorString(Value), null, null);
	endif;
	
	//epr TFS 42638 19/12/18
	//10. unit - optional
	if self.unit &lt;&gt; null and not self.unit.trimBlanks.isDecimal then
		app.raiseCMException1(Value_must_decimal, CMIF_IPNRKBMDetailItem::unit.name, null, null);
	endif;
	//11. ton - optional
	if self.ton &lt;&gt; null and not self.ton.trimBlanks.isDecimal then
		app.raiseCMException1(Value_must_decimal, CMIF_IPNRKBMDetailItem::ton.name, null, null);
	endif;
	//12. m3 - optional
	if self.m3 &lt;&gt; null and not self.m3.trimBlanks.isDecimal then
		app.raiseCMException1(Value_must_decimal, CMIF_IPNRKBMDetailItem::m3.name, null, null);
	endif;
	
	//13. penyaluran mandatory - Distribution - validate against transfer type in JMT
	voyageJobTransferType := app.myRoot.getVoyJobTransferTypeByCode(self.penyaluran);
	if voyageJobTransferType = null then
		app.raiseCMException3(Value_field_not_resolve, self.penyaluran, CMIF_IPNRKBMDetailItem::penyaluran.name, app.getErrorString(Transfer_type), null, null);
	endif;
	
	//14. kade mandatory - Quay area (workpoint)
	if self.kade = null then
		app.raiseCMException1(REQUIRED_FIELD, CMIF_IPNRKBMDetailItem::kade.name, null, null);
	endif;
	
	/*if app.myPassport.myTerminal.allWorkPointsByCode[self.kade] = null then
		app.raiseCMException3(Value_field_not_resolve, self.kade, CMIF_IPNRKBMDetailItem::kade.name, app.getErrorString(Workpoint), null, null);
	endif;*/
	
	//15. pbm optional - Loading/Unloading Company Names
	if self.pbm &lt;&gt; null then
		if self.getOperator = null then
			app.raiseCMException3(Value_field_not_resolve, self.pbm, CMIF_IPNRKBMDetailItem::pbm.name, app.getErrorString(Operator), null, null);
		endif;		
	endif;
	
	//16. npwpPbm mandatory - Taxpayer registration Number of the Loading/Unloading Company
	if self.npwpPbm = null then
		app.raiseCMException1(REQUIRED_FIELD, CMIF_IPNRKBMDetailItem::npwpPbm.name, null, null);
	endif;
	
	//17. consignee optional - possibly translated
	/* epr TFS 42604 17/12/18
	if self.consignee &lt;&gt; null then
		//consigneeStr := _voyage.myOperator.getXlationSystemCode(self.consignee, XLATION_TYPE_CONSIGNEE_BYOP, foundMatch);
		//if not foundMatch then
			cons := self.getConsignee();
			if cons = null or not cons.isConsignee then
				app.raiseCMException3(Value_field_not_resolve, self.consignee, CMIF_IPNRKBMDetailItem::consignee.name, app.getErrorString(Consignee), null, null);
			endif;
		//endif;
	endif;
	
	//epr TFS 42247 27/11/18
	if  self.isExport then
		if self.getConsignor = null then
			app.raiseCMException3(Value_field_not_resolve, self.shipper, CMIF_IPNRKBMDetailItem::shipper.name, app.getErrorString(Consignor), null, null);
		endif;
	endif;*/
	
	//18. shipper optional
	
	//19. npwpShipper mandatory - Taxpayer Registration Number of Shipper
	/*if self.npwpShipper = null then
		retValue := false;
		app.raiseCMException1(REQUIRED_FIELD, WS_DetailRKBM::npwpShipper.name, null, null);
	endif;*/
	
	//20. blNo optional - Bill of Lading
	
	//21. gang optional - Quantity of Gang (Work Team)
	if self.gang &lt;&gt; null and not self.gang.trimBlanks.isInteger then
		app.raiseCMException1(Value_must_integer, CMIF_IPNRKBMDetailItem::gang.name, null, null);
	endif;
	
	//22. palka optional - Hold
	if self.palka &lt;&gt; null and not self.palka.trimBlanks.isInteger then
		app.raiseCMException1(Value_must_integer, CMIF_IPNRKBMDetailItem::palka.name, null, null);
	endif;
	
	//23. noRkbmbongkar optional - Reference Number of RKBM Unloading
	
	//24. noRkbmMuat optional - Reference Number of RKBM Loading
	
	//25. rencanaBongcar optional - Loading Plan Date/Time
	if self.rencanaBongkar &lt;&gt; null then
		timeBongkar:= self.rencanaBongkar.asTimeStampFromInaportnet;
		if not timeBongkar.Date.isValid or not timeBongkar.Time.isValid then
			app.raiseCMException2(ErrInvalidRptTemplateDateStr, "yyyy-mm-dd hh:mm:ss", CMIF_IPNRKBMDetailItem::rencanaBongkar.name, null, null);
		endif;
	endif;
	
	//26. rencanaMuat optional - Unloading Plan Date/Time
	if self.rencanaMuat &lt;&gt; null then
		timeMuat:= self.rencanaMuat.asTimeStampFromInaportnet;
		if not timeMuat.Date.isValid or not timeMuat.Time.isValid then
			app.raiseCMException2(ErrInvalidRptTemplateDateStr, "yyyy-mm-dd hh:mm:ss", CMIF_IPNRKBMDetailItem::rencanaMuat.name, null, null);
		endif;
	endif;
	
epilog
	
end;</source>
    </JadeMethod>
</Class>
