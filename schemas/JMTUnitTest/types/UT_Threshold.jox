	//1 with stops
	ti := self.addCargo("THRS1110111",	//_id : String;
						isoType,	///_isoType: String;
						_mTGrade,	//_mtGrade : CM_MTGrade;
						_operator,	//_operator : CM_Operator;
						null,	//_toDo : CM_ToDoTaskDesc;
						_washTA	//_ta : CM_TerminalArea
