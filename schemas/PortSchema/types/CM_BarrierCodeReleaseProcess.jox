<Class name="CM_BarrierCodeReleaseProcess" id="480af353-7ae3-450f-ac9d-d05725a19bea">
    <superclass name="CM_OfflineFutureActor"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="backgroundprocess"/>
    <JadeMethod name="doAction" id="d7727dec-ebe7-4fb8-be13-53a7418c2a01">
        <updating/>
        <source>doAction(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2023	jlier1	Initial creation

*/

vars
	vvr : CM_VehicleVisitRecord;
	exOccured : Boolean;
begin

	self.getAndLockValidObject(vvr,Share_Lock,exOccured);
	if exOccured or vvr = null then
		//if returns true then dit deletes self
		return true;
	endif;
	
	//relese the barrier code from the terminal collection
	if vvr.myBarrierCodeIn &lt;&gt; null then
		vvr.myBarrierCodeIn.setMyTerminal(null);
	endif;
	
	if vvr.myBarrierCodeOut &lt;&gt; null then
		vvr.myBarrierCodeOut.setMyTerminal(null);
	endif;
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
