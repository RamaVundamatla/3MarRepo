    <JadeMethod name="doDeleteTCXlat" id="fbf68f0f-42e2-4f55-9f41-9d5c4de363b7">
        <source>doDeleteTCXlat();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
11 August 2023		jlizm1	Initial creation TFS 59549 Kiosk maintenance terms and conditions

*/

vars
	theForm 	: SOP_TableMaintForm;
	locale 			: CM_Locale;
	pxyKiosk	: CM_Kiosk;
	pxyTC 		: CM_KioskTermsAndConditions;
	pxyXlat		: CM_KioskTranslation;
	
begin
	theForm := self.myForm;
	
	if theForm.myProxyObject = null then
		return;
	endif;
	
	pxyKiosk := theForm.myProxyObject.CM_Kiosk;
	pxyTC := pxyKiosk.myTermsAndConditions;
	locale := theForm.cmbLocale2.listObject.CM_Locale;
	
	if locale = null then
		return;
	endif;
	
	pxyXlat := pxyTC.allTermsAndConditions[locale.localeId];
	
	pxyTC.removeTermsAndConditions(pxyXlat);
	delete pxyXlat;
	
	self.displayTermsAndConditions();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doLocaleChange" id="7dd4aba1-e79a-4682-9a8d-b4ac7e0e1e53">
        <updating/>
        <source>doLocaleChange() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
14 August 2023		jlizm1	Initial creation TFS 59549 Kiosk maintenance terms and conditions

*/

vars
	theForm	: SOP_TableMaintForm;
	locale	: CM_Locale;
begin
	
	theForm := self.myForm;

	if theForm.cmbLocale2.listObject &lt;&gt; null then
		locale := theForm.cmbLocale2.listObject.CM_Locale;
	else
		locale := null;
	endif;
	if locale = self.selectedLocale then
		return;
	endif;
	
	if theForm.mode &lt;&gt; theForm.Mode_View and self.termsAndConditionsChanged() then
		if app.msgBox(app.getErrorString(UnsavedChangesInView), app.getErrorString(ConfirmCancelHeading), MsgBox_Yes_No) = MsgBox_Return_No then
			theForm.cmbLocale2.listIndex := theForm.cmbLocale2.findObject(self.selectedLocale);
			return;
		endif;
	endif;
	
	self.selectedLocale := locale;
	self.displayTermsAndConditions();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doMoveAdditionalQuestion" id="1b44ea88-6411-4729-8cbf-3baf54169717">
        <source>doMoveAdditionalQuestion(_up : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
28 August 2023		jlizm1	Initial creation TFS 59551 Kiosk Additional Question

*/


vars
	theForm : SOP_TableMaintForm;
	question : CM_KioskAdditionalQuestion;
	theResult : Integer;
	
begin
	theForm := self.myForm;
	if (theForm.myCurrentObject = null) then
		return;
	endif;
	
	if (theForm.myCurrentObject.isKindOf(CM_Kiosk) = false) then
		return;
	endif;

	if theForm.lstSingleSelect3.listCount = 1 then
		return;
	endif;
	
	if theForm.lstSingleSelect3.listIndex &lt; 0 then
		return;
	endif;
	
	question := theForm.lstSingleSelect3.itemObject[theForm.lstSingleSelect3.listIndex].CM_KioskAdditionalQuestion;
	
	while true do
	
		app.myTrxUA.trxMoveKioskAdditionalQuestion(question, _up, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog(app.getErrorString(Additional_questions), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
	theForm.lstSingleSelect3.listCollection(theForm.myCurrentObject.CM_Kiosk.allAdditionalQuestions, true, 0);
	theForm.lstSingleSelect3.listObject := question;
	
epilog

end;</source>
        <Parameter name="_up" type="Boolean"/>
    </JadeMethod>
