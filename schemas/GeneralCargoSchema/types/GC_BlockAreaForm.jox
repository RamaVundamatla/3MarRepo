    <JadeMethod name="addToolbarControls" id="cd5fde6f-48bc-4331-91e0-9f50ae34e78a">
        <updating/>
        <source>addToolbarControls() updating, protected;

/*

Purpose:			


Return Value:		


Date		Who		Reason
16 May 2008	cnwkpd1	PAR #16753 - CCMS SFW 1003 - General Cargo Graphical Screens
20 May 2022	navtnr20	ChangeRequest 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
*/

vars
	toolbar		: CMUI_Toolbar;

begin
	inheritMethod();
		
	toolbar := self.frmToolbar;
	toolbar.addButton(self.btnSelectTAs, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addButton(self.btnViewDwell, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addFrame(self.frmDwellDays, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnViewShippingLine, CMUI_Toolbar.Control_Alignment_Left);	//19-may-2022 navtnr20 53204 
	toolbar.addButton(self.btnViewProduct, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnViewOperator, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnViewVoyage, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnViewCargoType, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnViewStockBRef, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnViewExpBRef, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnViewReleaseRq, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnViewYardAlloc, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton(self.btnMoveTopLeft, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnMoveTopRight, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnMoveBotLeft, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnMoveBotRight, CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addButton(self.btnRefresh, CMUI_Toolbar.Control_Alignment_Left);
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="btnMoveBotLeft_click" id="e62a7643-ef93-4d88-9cc3-4a826a543bd6">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnMoveBotLeft_click(btn: Button input) updating;

/*

Purpose:			


Return Value:		


Date		Who		Reason
16 May 2008	cnwkpd1	PAR #16753 - CCMS SFW 1003 - General Cargo Graphical Screens

*/

begin
	app.mousePointer	:=	Busy;
	self.doScrollToCorners(VIEW_LEFT_BOTTOM);
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
