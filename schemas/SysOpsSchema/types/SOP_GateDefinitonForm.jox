        <source>tblGateAreas_queryRowColChg(_table: CM_DataTable input; newSheet: Integer; newRow: Integer; newCol: Integer):Boolean updating;
// ---------------------------------------------------------------------------
// Created:     24 June 2009 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 16/02/2010	cnwcs5		par 22234 - moved proxy update code to change event
// ---------------------------------------------------------------------------
vars

begin 
	if newRow &lt;&gt; _table.row then
		// they are changing rows so gate lane table needs to be re-displayed
		self.setGateLaneTableNeedsRefresh (true);
	endif;
		
	return true;
epilog

