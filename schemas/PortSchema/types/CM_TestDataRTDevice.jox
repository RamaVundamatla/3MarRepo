<Class name="CM_TestDataRTDevice" id="5ced78ce-8956-4c1e-8e40-a3ce8d673407">
    <superclass name="CM_TestDataEntity"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="testData"/>
    <ImplicitInverseRef name="allRadioTelemetryDevices" id="6da83f35-9b2d-4285-9ec1-00e420e8b9e5">
        <memberTypeInverse/>
        <type name="CM_RadioTelemetryDeviceArray"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myTerminal" id="2532b381-9d47-4061-9cab-35f7714c49b3">
        <embedded/>
        <type name="CM_Terminal"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ExplicitInverseRef name="myTestDataRoot" id="59253b53-722e-41cc-b3ea-829add1451b2">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_TestDataRoot"/>
        <access>readonly</access>
        <Inverse name="CM_TestDataRoot::allTestDataRTDevices"/>
    </ExplicitInverseRef>
    <JadeMethod name="addRTDevices" id="07a2e569-9d1e-4b09-ace7-80f767bcc70a">
        <updating/>
        <source>addRTDevices() updating, protected;
// ---------------------------------------------------------------------------
// Created:     07 April 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if self.myTerminal = null then
		return;
	endif;
	if self.myTerminal.radioTelemetry = null then
		return;
	endif;
	self.myTerminal.radioTelemetry.allRTDevices.copy(self.allRadioTelemetryDevices);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getNextRTDevice" id="7a99e4b5-c0bb-4816-a462-b200ff269e47">
        <updating/>
        <source>getNextRTDevice() : CM_RadioTelemetryDevice updating;
// ---------------------------------------------------------------------------
// Created:     07 April 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	tmpDevice	: CM_RadioTelemetryDevice;
begin

	if self.allRadioTelemetryDevices.isEmpty then
		beginTransaction;
		self.addRTDevices();
		commitTransaction;
	endif;

	beginTransaction;
	exclusiveLock(self);
	tmpDevice := self.allRadioTelemetryDevices.first.CM_RadioTelemetryDevice;
	if tmpDevice &lt;&gt; null then
		exclusiveLock(tmpDevice);
		self.allRadioTelemetryDevices.removeAt(1);
		self.allRadioTelemetryDevices.add(tmpDevice);
	endif;
	commitTransaction;

	return tmpDevice;

end;</source>
        <ReturnType type="CM_RadioTelemetryDevice"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="a0f82198-5cf5-4160-894d-97302bd78937">
        <updating/>
        <source>setForCreate(_terminal : CM_Terminal; _root : CM_TestDataRoot) updating;
// ---------------------------------------------------------------------------
// Created:     07 April 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if _terminal = null then
		return;
	endif;
	
	self.myTerminal := _terminal;
	self.myTestDataRoot := _root;
	
	self.addRTDevices();
	
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_root" type="CM_TestDataRoot"/>
    </JadeMethod>
</Class>
