<GUIClass name="ListBox">
    <JadeMethod name="jssAddBranch" id="43edbb67-f259-421f-bb9d-086c152e3ce2">
        <source>jssAddBranch(pText : String; pPosition : Integer):Integer;
// --------------------------------------------------------------------------------
// Created:		25 January 2001 by cnwdad2
//
// Purpose:		Creates a new branch in the list hierarchy.  It's assumed that for
//				this method to be called then the "hasPictures" attribute for this
//				listbox will have been set.
//
//				NOTE - If a position is not passed in then an item will be simply added.
//
// Parameters:	pText - 
//				pPosition - 
//
// Returns:		The index of the newly created branch.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	newItemPointer	: Integer;

begin
	if pPosition = null then
		newItemPointer	:=	addItem(pText);
	else
		addItemAt(pText, pPosition);
		newItemPointer	:=	pPosition;
	endif;
	
	return newItemPointer;
end;</source>
        <Parameter name="pText" type="String"/>
        <Parameter name="pPosition" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jssAddLeaf" id="ac269ca4-9111-4f4f-a7a7-c1e00608bb21">
        <source>jssAddLeaf(pText : String; pPosition : Integer):Integer;
// --------------------------------------------------------------------------------
// Created:		25 January 2001 by cnwdad2
//
// Purpose:		Adds a new leaf to a branch of the list hierarchy.  Its assumed that for this method to be called then the "hasPictures" attribute for this listbox will have been set.
//
//				NOTE - If a position is not included then an item will be simply added.
//
// Parameters:	pText - 
//				pPosition - 
//
// Returns:		The index of the newly created leaf.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	newItemPointer	: Integer;

begin
	if pPosition = null then
		newItemPointer	:=	addItem(pText);
	else
		addItemAt(pText, pPosition);
		newItemPointer	:=	pPosition;
	endif;	

	self.itemPictureType[newItemPointer]	:=	ListBox.ItemPictureType_Leaf;
	return newItemPointer;
end;</source>
        <Parameter name="pText" type="String"/>
        <Parameter name="pPosition" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jssFindParent" id="49346c8f-4298-4469-a547-ecb9b680a8d3">
        <source>jssFindParent(pStartIndex:Integer):Integer;
// --------------------------------------------------------------------------------
// Created:		26 July 2000 by cnwdad1
//
// Purpose:		This method will search backwards through the listbox, and return
//				the parent list item in the list hierarchy.
//
//				The index position of the parent item will be returned.
//
//				If the starting index position (pStartIndex) is 0 or 1, then zero
//				will be returned.  Likewise, if a parent is not found, then a zero
//				will also be returned.
//
// Parameters:	pStartIndex (Integer) - The starting item index.
//
// Returns:		The item index of the parent.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	entryIndex	: Integer;	// Current list item index.
	entryLevel	: Integer;	// Current list item level.
	childLevel	: Integer;	// Item Level of the child list item.

begin
	if pStartIndex = 0 or pStartIndex = 1 or self.listCount() = 0 then
		return 0;
	endif;

	childLevel	:=	self.itemLevel[pStartIndex];
	entryIndex	:=	pStartIndex - 1;

	while entryIndex &gt; 0 do
		if (not entryLevel &gt; self.listCount()) then
			entryLevel		:=	self.itemLevel[entryIndex];

			if entryLevel = (childLevel - 1) then
				// The parent item level should be 1 less than that of it's child.
				return entryIndex;
			endif;
		endif;

		entryIndex	:=	entryIndex - 1;	// We're stepping backwards through the list.
	endwhile;

	return 0;
end;</source>
        <Parameter name="pStartIndex" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jssFindWhere" id="f805d7aa-a3ca-445c-b7ff-7f34190c6b80">
        <source>jssFindWhere(pString : String; pParent : Integer) : Integer;
// --------------------------------------------------------------------------------
// Created:		25 January 2001 by cnwdad2
//
// Purpose:		Find the right insertion point in listbox pTargetListbox for
//				pString.  If pParent = 0, the string is a Category (level 1) item.
//				If pParent not = 0, the string is a level 2 item and we need to
//				find the insertion point within its category, identified by location
//				pParent in the listbox.
//
// Parameters:	pString - 
//				pTargetListBox - 
//				pParent - 
//
// Returns:		The target list index.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	targetListSize	: Integer;
	lastLevel1Pos 	: Integer;

begin
	if pParent = 0 then													// It's a category item.
    	targetListSize	:=	self.listCount();
    	lastLevel1Pos	:=	targetListSize + 1;
    	
    	while targetListSize &gt; 0 do
    		if self.itemLevel[targetListSize] = 1 then
    			if self.itemText[targetListSize] &lt; pString then
    				return lastLevel1Pos;								// Found the right spot for it.
    			endif;
    			
    			lastLevel1Pos	:=	targetListSize;		
    		endif;
    		
    		targetListSize	:=	targetListSize - 1;						// Work backwards through listbox.
    	endwhile;
    	
		return 1;														// Needs to go at top of listbox.
	else
		targetListSize := pParent;										// An individual item - category address.
		
		while targetListSize &lt; self.listCount() do
			targetListSize := targetListSize + 1;						// Work forward through listbox.
			
			if self.itemLevel[targetListSize] = 1 then					// Reached next category ?
				return targetListSize;									// Then put at end of this category.
			elseif self.itemText[targetListSize] &gt; pString then
				return targetListSize;									// Found the spot.
			endif;
		endwhile;
		
		return targetListSize + 1;										// Put at end of listbox.
	endif;				
end;</source>
        <Parameter name="pString" type="String"/>
        <Parameter name="pParent" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jssMoveAll" id="b197ea4b-f97f-48eb-b59c-78b2ca9c9418">
        <updating/>
        <source>jssMoveAll(pTargetList:ListBox input) updating;
// --------------------------------------------------------------------------------
// Created:		26 July 2000 by cnwdad1
//
// Purpose:		Moves all items from the receiver listbox into the listbox
//				specified as the input parameter.
//
// Parameters:	pTargetList (ListBox) - The control to which the items will be moved.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	entryIndex	: Integer;

begin
	app.mousePointer	:=	Busy;
	entryIndex			:=	self.listCount();

	while entryIndex &gt; 0 do
		pTargetList.itemObject[pTargetList.addItem(self.itemText[entryIndex])]	:=	self.itemObject[entryIndex];
		self.removeItem(entryIndex);

		entryIndex	:=	entryIndex - 1;
	endwhile;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="pTargetList" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="jssMoveAllTreesByName" id="91d91321-56c3-4f81-8993-cabee9dd1966">
        <updating/>
        <source>jssMoveAllTreesByName(pTargetList:ListBox input) updating;
// --------------------------------------------------------------------------------
// Created:		26 July 2000 by cnwdad1
//
// Purpose:		Moves all items from the receiver listbox into the listbox
//				specified as the input parameter, using the tree names.
//
// Parameters:	pTargetList (ListBox) - The control to which the items will be moved.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	listPointer	: Integer;

begin
	listPointer			:=	listCount();

	while self.listCount() &gt; 0 do
		self.itemSelected[1]	:=	true;
		self.jssMoveTreeByName(pTargetList);
	endwhile;
end;</source>
        <Parameter name="pTargetList" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="jssMoveSelected" id="30d5513a-5b39-466e-bbf8-daa2b5ac80d3">
        <updating/>
        <source>jssMoveSelected(pTargetList:ListBox input) updating;
// --------------------------------------------------------------------------------
// Created:		26 July 2000 by cnwdad1
//
// Purpose:		Moves all selected items from the current listbox into the listbox
//				specified as the input parameter.
//
// Parameters:	pTargetList (ListBox) - The control to which the selected items will be moved.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	entryIndex	: Integer;

begin
	app.mousePointer	:=	Busy;
	entryIndex			:=	self.listCount();

	while entryIndex &gt; 0 do
		if self.itemSelected[entryIndex] then
			pTargetList.itemObject[pTargetList.addItem(self.itemText[entryIndex])]	:=	self.itemObject[entryIndex];
			self.removeItem(entryIndex);
		endif;

		entryIndex	:=	entryIndex - 1;
	endwhile;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="pTargetList" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="jssMoveTree" id="4db92ff8-81a3-4d54-a884-05c3a3624e9e">
        <source>jssMoveTree(pTargetControl:ListBox);
// --------------------------------------------------------------------------------
// Created:		26 July 2000 by cnwdad1
//
// Purpose:		Moves all selected tree items from current listbox into listbox
//				specified as input parameter
//
// Features:	- Handles multiselect list boxes
//				- Selecting a 'parent' item is equivalent to selecting all of the 'children' items
//
// Limitations:	- Handles only basic (two level deep) list tree
//				- Requires that itemObject pseudo array is populated
//				- Cannot handle duplicate item object references in a single list
//
// Parameters:	pTargetControl (ListBox) - The target listbox control.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	targetList		: ListBox;
	entryIndex		: Integer;
	subEntryIndex	: Integer;
	targetIndex		: Integer;
	parentIndex		: Integer;

begin
	app.mousePointer	:=	Busy;

	targetList	:=	pTargetControl;
	entryIndex	:=	self.listCount();

	while entryIndex &gt;= 1 and entryIndex &lt;= self.listCount() do
		if self.itemSelected[entryIndex] then
			if self.itemHasSubItems(entryIndex) then
				subEntryIndex := entryIndex + 1;

				while subEntryIndex &lt;= self.listCount() and self.itemLevel[subEntryIndex] &gt; self.itemLevel[entryIndex] do
					targetIndex	:=	targetList.findObject(self.itemObject[entryIndex]) + 1;

					if targetIndex = 0 then
						targetList.itemObject[targetList.addItem(self.itemText[entryIndex])] := self.itemObject[entryIndex];
						targetIndex	:=	targetList.newIndex() + 1;
					endif;

					while targetIndex &lt;= targetList.listCount() do
						if targetList.itemLevel[targetIndex] = 1 then
							break;
						endif;
						targetIndex	:=	targetIndex + 1;
					endwhile;

					if targetIndex &lt;= targetList.listCount() then
						targetList.addItemAt(self.itemText[subEntryIndex], targetIndex);
					else
						targetList.addItem(self.itemText[subEntryIndex]);
					endif;

					targetList.itemObject[targetList.newIndex()] := self.itemObject[subEntryIndex];
					targetList.itemLevel[targetList.newIndex()] := 2;
					subEntryIndex	:=	subEntryIndex + 1;
				endwhile;

                subEntryIndex := subEntryIndex - 1;

                while subEntryIndex &gt;= entryIndex do
					self.removeItem(subEntryIndex);
					subEntryIndex	:=	subEntryIndex - 1;
				endwhile;
			else
				parentIndex	:=	self.jssFindParent(entryIndex);
				targetIndex	:=	targetList.findObject(self.itemObject[parentIndex]) + 1;

				if targetIndex = 0 then
					targetList.itemObject[targetList.addItem(self.itemText[parentIndex])] := self.itemObject[parentIndex];
					targetIndex	:=	targetList.newIndex() + 1;
				endif;

				while targetIndex &lt;= targetList.listCount() do
					if targetList.itemLevel[targetIndex] = 1 then
						break;
					endif;
					targetIndex	:=	targetIndex + 1;
				endwhile;

				if targetIndex &lt;= targetList.listCount() then
					targetList.addItemAt(self.itemText[entryIndex], targetIndex);
				else
					targetList.addItem(self.itemText[entryIndex]);
				endif;

				targetList.itemObject[targetList.newIndex()] := self.itemObject[entryIndex];
				targetList.itemLevel[targetList.newIndex()] := 2;
				self.removeItem(entryIndex);

				if not self.itemHasSubItems(parentIndex) then
					self.removeItem(parentIndex);
				endif;
			endif;
		endif;

		entryIndex	:=	entryIndex - 1;
	endwhile;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="pTargetControl" type="ListBox"/>
    </JadeMethod>
    <JadeMethod name="jssMoveTreeByName" id="9932600c-6c61-4cda-9981-ab2fec257224">
        <updating/>
        <source>jssMoveTreeByName(pTargetList:ListBox) updating;
// --------------------------------------------------------------------------------
// Created:		25 January 2001 by cnwdad2
//
// Purpose:		Moves all selected tree items from the receiver listbox into 2nd
//				listbox.  Uses branch and leaf pictures!
//
// Features:	- Handles multiselect list boxes
//				- Selecting a 'parent' item is equivalent to selecting all of the 'children' items
//				- only moves a category when all its subitems can be updated
//
// Limitations:	- Handles only basic (two level deep) list tree
//				- Requires that itemObject pseudo array is populated
//				- Cannot handle duplicate item object references in a single list 
//
// Parameters:	pText - 
//				pPosition - 
//
// Returns:		The index of the newly created branch.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	fromListSize		: Integer;
	subItemPointer		: Integer;
	foundItemPointer	: Integer;
	parentItemPointer	: Integer;
	insertPointer		: Integer;

begin
	fromListSize	:=	self.listCount();
	
	while (fromListSize &gt;= 1 and fromListSize &lt;= self.listCount()) do
		if self.itemSelected[fromListSize] then
			if self.itemHasSubItems(fromListSize)then
			  	subItemPointer	:=	fromListSize + 1;
			  	
				while subItemPointer &lt;= self.listCount() and self.itemLevel[subItemPointer] &gt; self.itemLevel[fromListSize] do
//					foundItemPointer	:=	pTargetList.findObject(self.itemObject[fromListSize]);
					foundItemPointer	:=	pTargetList.findStringExact(1, self.itemText[fromListSize]);
					
					if foundItemPointer = JSS_NULL_INDEX then
                        insertPointer		:=	pTargetList.jssFindWhere(self.itemText[fromListSize], 0);  // where should it go?
               			pTargetList.jssAddBranch(self.itemText[fromListSize], insertPointer);     		    // was null
						pTargetList.itemObject[pTargetList.newIndex()]	:=	self.itemObject[fromListSize];
						foundItemPointer	:=	pTargetList.newIndex();
					endif;

					if foundItemPointer &lt;= pTargetList.listCount() then
						insertPointer	:=	pTargetList.jssFindWhere(self.itemText[subItemPointer], foundItemPointer);
						pTargetList.jssAddLeaf(self.itemText[subItemPointer], insertPointer);    // was intInd
					else
						insertPointer	:=	pTargetList.jssFindWhere(self.itemText[subItemPointer], pTargetList.listCount());
						pTargetList.jssAddLeaf(self.itemText[subItemPointer], insertPointer);    // was null
					endif;
					
					pTargetList.itemObject[pTargetList.newIndex()]	:=	self.itemObject[subItemPointer];
					pTargetList.itemLevel[pTargetList.newIndex()]	:=	2;
					pTargetList.itemText[pTargetList.newIndex()]	:=	pTargetList.itemText[pTargetList.newIndex()].jssStripAtEnd("Read Only");
					subItemPointer									:=	subItemPointer + 1;
				endwhile;
				
                subItemPointer := subItemPointer - 1;
                
                while subItemPointer &gt;= fromListSize do
                	self.removeItem(subItemPointer);
					subItemPointer := subItemPointer - 1;
				endwhile;
		   	else
				parentItemPointer	:=	self.jssFindParent(fromListSize);
//				foundItemPointer	:=	pTargetList.findObject(self.itemObject[parentItemPointer]);
				foundItemPointer	:=	pTargetList.findStringExact(1, self.itemText[parentItemPointer]);
				
				if foundItemPointer = JSS_NULL_INDEX then
					insertPointer		:=	pTargetList.jssFindWhere(self.itemText[parentItemPointer], 0);
					pTargetList.jssAddBranch(self.itemText[parentItemPointer], insertPointer);         // was null
					pTargetList.itemObject[pTargetList.newIndex()]	:=	self.itemObject[parentItemPointer];
					foundItemPointer	:=	pTargetList.newIndex();
				endif;

				if foundItemPointer &lt;= pTargetList.listCount() then
					insertPointer	:=	pTargetList.jssFindWhere(self.itemText[fromListSize], foundItemPointer);
					pTargetList.jssAddLeaf(self.itemText[fromListSize], insertPointer);  // was intInd
				else
					insertPointer	:=	pTargetList.jssFindWhere(self.itemText[fromListSize], pTargetList.listCount());
					pTargetList.jssAddLeaf(self.itemText[fromListSize], insertPointer);   // was null
				endif;
				
				pTargetList.itemObject[pTargetList.newIndex()]	:=	self.itemObject[fromListSize];
				pTargetList.itemLevel[pTargetList.newIndex()]	:=	2;
				pTargetList.itemText[pTargetList.newIndex()]	:=	pTargetList.itemText[pTargetList.newIndex()].jssStripAtEnd("Read Only");
				self.removeItem(fromListSize);
				
				if (not self.itemHasSubItems(parentItemPointer)) then
					self.removeItem(parentItemPointer);
					fromListSize	:=	fromListSize - 1;       /// XPOSE 1454 allow for removing parent
				endif;
			endif;
		endif;
		
		fromListSize	:=	fromListSize - 1;
	endwhile;
end;</source>
        <Parameter name="pTargetList" type="ListBox"/>
    </JadeMethod>
    <JadeMethod name="jssOpenDownTo" id="2aec6f25-f2dc-41ff-986a-ab65b31d0994">
        <source>jssOpenDownTo(pListIndex:Integer);
// --------------------------------------------------------------------------------
// Created:		24 November 2001 by cnwdad1
//
// Purpose:		Opens the receiver's tree nodes to reveal the node at the specified
//				item index.
//
// Parameters:	pListIndex - The index of the list item to reveal.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theListbox	: ListBox;
	parentIndex	: Integer;
	openedIndex	: Integer;
	
begin
	theListbox	:=	self;
	openedIndex	:=	pListIndex;
	
	while true do
		parentIndex	:=	theListbox.jssFindParent(openedIndex);
		
		if parentIndex = 0 then
			break;
		else
			theListbox.itemExpanded[parentIndex]	:=	true;
			openedIndex	:=	parentIndex;
		endif;
	endwhile;
end;</source>
        <Parameter name="pListIndex" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jssRemoveSubItems" id="7f0f4ec7-6c6f-4699-ad02-ce96090304f8">
        <source>jssRemoveSubItems(pParentIndex:Integer; pIsDeleteItemObjects:Boolean);
// --------------------------------------------------------------------------------
// Created:		19 August 2000 by cnwdad1
//
// Purpose:		Removes all subitems from a tree hierarchy in the listbox.
//
// Parameters:	pParentIndex (Integer) - The index of he parent item whose subitems
//					are to be removed.
//				pIsDeleteItemObjects (Boolean) - A flag used to indicate whether
//					any objects of the "itemObject" property of child list entries
//					are to be deleted when the child item entry is removed.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	parentIndex	: Integer;
	parentLevel	: Integer;
	entryCount	: Integer;
	childLevel	: Integer;
	childIndex	: Integer;
	theObject	: Object;
	
begin
	parentIndex	:=	pParentIndex;
	entryCount	:=	self.listCount();
	parentLevel	:=	self.itemLevel[parentIndex];
	
	if parentIndex &lt; entryCount then	// If parent is last, it mustn't have any children.
		childIndex	:=	parentIndex + 1;
		
		// Must use "listCount" here because the size of the list
		// items will be changing as list entries are removed.
		
		while childIndex &lt;= self.listCount() do
			childLevel	:=	self.itemLevel[childIndex];
			
			if childLevel &lt;= parentLevel then
				break;
			endif;
			
			if pIsDeleteItemObjects then
				theObject	:=	self.itemObject[childIndex];
				
				if theObject &lt;&gt; null then
					delete theObject;
				endif;
			endif;
			
			self.removeItem(childIndex);
		endwhile;
	endif;
end;</source>
        <Parameter name="pParentIndex" type="Integer"/>
        <Parameter name="pIsDeleteItemObjects" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jssSet" id="4118d4c5-9956-46cf-a3b3-e7fdf2362ac5">
        <updating/>
        <source>jssSet(pValue:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad1
//
// Purpose:		Updates the receiver's listIndex with the specified value.
//
// Parameters:	pValue - The string value to set the text to.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.listIndex &lt;&gt; pValue then
		self.listIndex	:=	pValue;
	endif;
end;</source>
        <Parameter name="pValue" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jssSetObjectIndex" id="17d9979f-f2c0-458c-8ddc-eb97b6cf931e">
        <updating/>
        <source>jssSetObjectIndex(pTheObject:Object) updating;
// --------------------------------------------------------------------------------
// Created:		25 January 2001 by cnwdad2
//
// Purpose:		Sets the list index of the receiver to the index that contains the
//				specified object.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.listIndex	:=	self.findObject(pTheObject);
end;</source>
        <Parameter name="pTheObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="jssSetTextIndex" id="4ee3c33e-2d42-41cf-8fb9-9db686325ea1">
        <updating/>
        <source>jssSetTextIndex(pTextValue:String) updating;
// --------------------------------------------------------------------------------
// Created:		25 January 2001 by cnwdad2
//
// Purpose:		Sets the list index of the receiver to the index that contains the
//				specified text.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.listIndex	:=	self.findString(1, pTextValue);
end;</source>
        <Parameter name="pTextValue" type="String"/>
    </JadeMethod>
</GUIClass>
