    </JadeMethod>
    <JadeMethod name="doSendToReport" id="ca964a3e-1300-40c3-b59f-d3c83b237f78">
        <source>doSendToReport(_objArray : ObjectArray);
//----------------------------------------------------------------------
// Created by 	cnwjre1
// Date 		Sept 2010 CCMS 1155 par 23583 Invoice rate reporting
vars
	jrwReportName	: String;
	selectedOnly,
	printPreview	: Boolean;
	arrayCheck		: ObjectArray;
	pathList		: StringArray;
	obj				: Object;
	outputType		: Integer;
	filePath		: String;
begin
	if _objArray.isEmpty() then
		app.msgBox(app.getErrorString(NoItemsSelected), app.getErrorString(NoItemsSelected), MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	endif;
	create pathList transient;
	pathList.add("allInvoiceRates.");
	//Get the report we want to send our invoice rate items to and find out whether we want a print preview.
	if app.getReportToSendItems(CM_InvoiceView, pathList, selectedOnly , jrwReportName, printPreview, outputType, filePath) then
		//Have to ensure we don't have multiples so check this out here.
		create arrayCheck transient;
		foreach obj in _objArray do
			if arrayCheck.includes(obj) then
				continue;
			endif;
			
			arrayCheck.add(obj);
		endforeach;
		
		app.sendItemsToReport(CM_JRWInvoiceRate, arrayCheck, jrwReportName, printPreview, outputType, filePath);
	endif;
epilog
	delete arrayCheck;
	delete pathList;
end;</source>
        <Parameter name="_objArray" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="doShowSearcherClick" id="989f3b11-c243-4952-a859-064274455d3f">
        <updating/>
        <source>doShowSearcherClick() updating;
//
// Changed On	By			Reason
// ----------	--------	-------------------------------------------
// 27/03/2018	jlgdap1		TFS 37794 PEL1 Vessel Rates
// 07 Jun 2018  cnwma1		ChangeRequest 38953: PEL1 - Berth Rates, Vessel Type Rates, Visit Types
vars

begin
	inheritMethod();

	//07.06.2018 cnwma1 ChangeRequest #38953
	if self.fldQuery.topSheet = self.shtQuery2 then
		self.cmbTrades.setFocus;
	else
		self.txtDateDebtor.setFocus;
	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="doTblDataContextMenu" id="72867ff3-fa63-4cf8-861a-c61238fafad6">
        <updating/>
        <source>doTblDataContextMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;

vars
	debtorRates	: Boolean;
begin
	// Sept 2010 CCMS 1155 par 23583 Invoice rate reporting
	debtorRates := (self.mode = self.Mode_Debtor);
	self.mnuSendReportMain.visible := debtorRates;
	self.mnuSendReportAll.visible := debtorRates;
	self.mnuSendReportSelected.visible := debtorRates;
	self.mnuSendReportSeparator.visible := debtorRates;
	self.mnuSendReportSelected.visible := debtorRates;

	return inheritMethod(cntrl, conwin, mouse, x, y);
end;
</source>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTblDataDBClick" id="8b5d1119-9180-4467-8035-8311970508d9">
        <updating/>
        <source>doTblDataDBClick(table: CM_DataTable input) updating;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theTI : CM_TrackedItem;
	theRow : Integer;
begin
	
	inheritMethod(table);
	
	if table.row &lt;= table.fixedRows then
		return;
	endif;
	if table.column &lt;= table.fixedColumns then
		return;
	endif;
	
	
	self.showHistoryForm(false);

end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTblDataMouseMove" id="245c90df-7977-4ce0-870e-b5d5262a1ada">
        <updating/>
        <source>doTblDataMouseMove(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		28 February 2006  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	row, col, idx : Integer;
	anObj : Object;
	tmpStr : String;
	aRate : Real;
	aRE : CM_RateEntry;
begin
	if button = Window.MouseButton_Left 
	and app.dragDetected(x, y, self.origXPos, self.origYPos) 
	and y &gt; 15 then
		if self.useCtrlScroll then
			if app.isControlKeyDown()
			and not app.isAltKeyDown()
			and not app.isShiftKeyDown()
			then
				self.dragMode := DragMode_Drag;
				self.dragCursor := self.picCtrlScroll.dragCursor;
			endif;
		endif;

	else
		table.getCellFromPosition(x,y, row,col);
		
		if (row &gt;= table.fixedRows and row &lt;= self.tblData.rows)
		and (col &gt;= 1 and col &lt;= self.tblData.columns) then
			anObj := self.tblData.accessCell(row,col).itemObject;

			if global.isValidObject(anObj) and anObj.isKindOf(CM_RateEntry) then
				aRE := anObj.CM_RateEntry;
				tmpStr := aRE.getBubbleHelp();
			endif;
		endif;
		self.tblData.bubbleHelp := tmpStr;
	endif;


end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doTblDataRowColChange" id="3a68ab2f-9622-4821-8b79-f9dddeb40c27">
        <updating/>
        <source>doTblDataRowColChange(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Chanegd On	By			Reason
// ----------	--------	--------------------------------------------------
// 27/03/2018	jlgdap1		TFS 37794 PEL1 Vessel Rates
// 07 Jun 2018  cnwma1		ChangeRequest 38953: PEL1 - Berth Rates, Vessel Type Rates, Visit Types
vars
	re : CM_RateEntry;
	anObject : Object;
	invalidRE : Boolean;
	savedChargedEffTS : TimeStamp;
begin

	//19 Sep 2012	NDL	Par 30375
	savedChargedEffTS := app.getChargeRateEffectiveDate();
	app.setChargeRateEffectiveDate( self.effectiveDate.TimeStamp );
	
	on Exception do app.handleDeletedObject(exception, re, invalidRE); // PAR 18489
	
	if table.row &gt; table.fixedRows then
		re := table.accessCell(table.row, table.column).itemObject.CM_RateEntry;
		if re &lt;&gt; null then
			self.myCurrentService := re.rate.service;
			if invalidRE then// PAR 18489
				table.accessCell(table.row, table.column).itemObject := null;// PAR 18489
				return;// PAR 18489
			endif;
		else
			self.myCurrentService := table.accessRow(table.row).itemObject.CM_Service; // PAR 11046
		endif;
		
		if re = null  or re.rate.isKindOf(CM_DebtorRate)  then // PAR 11046
			if self.mode = self.Mode_Debtor then
				if table.column &gt; table.fixedColumns then
					self.myCurrentDebtor := table.accessColumn(table.column).itemObject.CM_DebtorNode;
					self.myCurrentVessel := null;													// TFS 37794
					self.myCurrentVesselType := null;												//07.06.2018 cnwma1 ChangeRequest #38953
					self.myCurrentVisitType := null;												//07.06.2018 cnwma1 ChangeRequest #38953
					self.myCurrentBerth := null;													//07.06.2018 cnwma1 ChangeRequest #38953
				endif;
			elseif self.mode = self.Mode_Vessel then												// TFS 37794
				if table.column &gt; table.fixedColumns then											// TFS 37794
					self.myCurrentVessel := table.accessColumn(table.column).itemObject.CM_Vessel;	// TFS 37794
					self.myCurrentDebtor := null;													// TFS 37794
					self.myCurrentVesselType := null;												//07.06.2018 cnwma1 ChangeRequest #38953
					self.myCurrentVisitType := null;												//07.06.2018 cnwma1 ChangeRequest #38953
					self.myCurrentBerth := null;													//07.06.2018 cnwma1 ChangeRequest #38953
				endif;																				// TFS 37794
			elseif self.mode = self.Mode_VesselType then													//07.06.2018 cnwma1 ChangeRequest #38953
				if table.column &gt; table.fixedColumns then													//07.06.2018 cnwma1 ChangeRequest #38953
					self.myCurrentVesselType := table.accessColumn(table.column).itemObject.HMS_VesselType;	//07.06.2018 cnwma1 ChangeRequest #38953
					self.myCurrentDebtor := null;															//07.06.2018 cnwma1 ChangeRequest #38953
					self.myCurrentVessel := null;															//07.06.2018 cnwma1 ChangeRequest #38953
					self.myCurrentVisitType := null;														//07.06.2018 cnwma1 ChangeRequest #38953
					self.myCurrentBerth := null;															//07.06.2018 cnwma1 ChangeRequest #38953
				endif;
			elseif self.mode = self.Mode_VisitType then														//07.06.2018 cnwma1 ChangeRequest #38953
				if table.column &gt; table.fixedColumns then													//07.06.2018 cnwma1 ChangeRequest #38953
					self.myCurrentVisitType := table.accessColumn(table.column).itemObject.HMS_VisitType;	//07.06.2018 cnwma1 ChangeRequest #38953
					self.myCurrentDebtor := null;															//07.06.2018 cnwma1 ChangeRequest #38953
					self.myCurrentVesselType := null;														//07.06.2018 cnwma1 ChangeRequest #38953
					self.myCurrentVessel := null;															//07.06.2018 cnwma1 ChangeRequest #38953
					self.myCurrentBerth := null;															//07.06.2018 cnwma1 ChangeRequest #38953
				endif;
			elseif self.mode = self.Mode_Berth then															//07.06.2018 cnwma1 ChangeRequest #38953
				if table.column &gt; table.fixedColumns then													//07.06.2018 cnwma1 ChangeRequest #38953
					self.myCurrentBerth := table.accessColumn(table.column).itemObject.HMS_Berth;			//07.06.2018 cnwma1 ChangeRequest #38953
					self.myCurrentDebtor := null;															//07.06.2018 cnwma1 ChangeRequest #38953
					self.myCurrentVesselType := null;														//07.06.2018 cnwma1 ChangeRequest #38953
					self.myCurrentVisitType := null;														//07.06.2018 cnwma1 ChangeRequest #38953
					self.myCurrentVessel := null;															//07.06.2018 cnwma1 ChangeRequest #38953
				endif;
			elseif re &lt;&gt; null then // PAR 11046
				self.myCurrentDebtor := re.rate.CM_DebtorRate.debtorNode;
			endif;
			self.myCurrentLineGroupDebtor := null;
			
			if self.myCurrentDebtor.isKindOf(CM_RootDebtorGroup) 
			and self.mode = self.Mode_Trade then
				self.myCurrentDebtor := null;
				anObject := table.accessColumn(table.column).itemObject;
				self.myCurrentLineGroupDebtor := anObject.CM_LineGroupDebtor;
			endif;
		
		// TFS 37794 set current vessel from vessel rate
		elseif self.mode = self.Mode_Vessel and (re = null or re.rate.isKindOf(CM_VesselRate)) then
			if self.mode = self.Mode_Vessel then
				if table.column &gt; table.fixedColumns then
					self.myCurrentVessel := table.accessColumn(table.column).itemObject.CM_Vessel;
				endif;
			elseif re &lt;&gt; null then
				self.myCurrentVessel := re.rate.CM_VesselRate.myVessel;
			endif;
			self.myCurrentDebtor := null;
			self.myCurrentLineGroupDebtor := null;
			self.myCurrentVesselType := null;	//07.06.2018 cnwma1 ChangeRequest #38953
			self.myCurrentVisitType := null;	//07.06.2018 cnwma1 ChangeRequest #38953
			self.myCurrentBerth := null;		//07.06.2018 cnwma1 ChangeRequest #38953
		// TFS 37794 end
		
		//07.06.2018 cnwma1 ChangeRequest #38953
		elseif self.mode = self.Mode_VesselType and (re = null or re.rate.isKindOf(CM_VesselTypeRate)) then
			if self.mode = self.Mode_VesselType then
				if table.column &gt; table.fixedColumns then
					self.myCurrentVesselType := table.accessColumn(table.column).itemObject.HMS_VesselType;
				endif;
			elseif re &lt;&gt; null then
				self.myCurrentVesselType := re.rate.CM_VesselTypeRate.myVesselType;
			endif;
			self.myCurrentDebtor := null;
			self.myCurrentLineGroupDebtor := null;
			self.myCurrentBerth := null;		//07.06.2018 cnwma1 ChangeRequest #38953
			self.myCurrentVisitType := null;	//07.06.2018 cnwma1 ChangeRequest #38953
			self.myCurrentVessel := null;		//07.06.2018 cnwma1 ChangeRequest #38953
		
		//07.06.2018 cnwma1 ChangeRequest #38953
		elseif self.mode = self.Mode_VisitType and (re = null or re.rate.isKindOf(CM_VisitTypeRate)) then
			if self.mode = self.Mode_VisitType then
				if table.column &gt; table.fixedColumns then
					self.myCurrentVisitType := table.accessColumn(table.column).itemObject.HMS_VisitType;
				endif;
			elseif re &lt;&gt; null then
				self.myCurrentVisitType := re.rate.CM_VisitTypeRate.myVisitType;
			endif;
			self.myCurrentDebtor := null;
			self.myCurrentLineGroupDebtor := null;
			self.myCurrentVesselType := null;	//07.06.2018 cnwma1 ChangeRequest #38953
			self.myCurrentBerth := null;		//07.06.2018 cnwma1 ChangeRequest #38953
			self.myCurrentVessel := null;		//07.06.2018 cnwma1 ChangeRequest #38953
		
		//07.06.2018 cnwma1 ChangeRequest #38953
		elseif self.mode = self.Mode_Berth and (re = null or re.rate.isKindOf(CM_BerthRate)) then
			if self.mode = self.Mode_Berth then
				if table.column &gt; table.fixedColumns then
					self.myCurrentBerth := table.accessColumn(table.column).itemObject.HMS_Berth;
				endif;
			elseif re &lt;&gt; null then
				self.myCurrentBerth := re.rate.CM_BerthRate.myBerth;
			endif;
			self.myCurrentDebtor := null;
			self.myCurrentLineGroupDebtor := null;
			self.myCurrentVesselType := null;	//07.06.2018 cnwma1 ChangeRequest #38953
			self.myCurrentVisitType := null;	//07.06.2018 cnwma1 ChangeRequest #38953
			self.myCurrentVessel := null;		//07.06.2018 cnwma1 ChangeRequest #38953
		//07.06.2018 cnwma1 ChangeRequest #38953
		
		else
			self.myCurrentDebtor := null;
			self.myCurrentLineGroupDebtor := re.rate.CM_LineGroupDebtorRate.lineGroupDebtor;
		endif;
		// from 24052 set up lineGroupDebtor from null rate
		if self.mode = self.Mode_Trade and
		   self.myCurrentLineGroupDebtor = null and
		   table.columns &gt; 1 then		// i.e. not an empty table after an unsuccessful query
			self.myCurrentLineGroupDebtor := table.accessColumn(2).itemObject.CM_LineGroupDebtor;
		endif;
	endif;
	// July 2010 cnwjre1	24018 show macro info for rates
	self.displayExtraInfo();

	self.setEnableObjects();
epilog
	app.setChargeRateEffectiveDate( savedChargedEffTS );	//19 Sep 2012	NDL	Par 30375
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTblDataRowColChangeOLD" id="b49418ad-1ad2-477f-85a9-a6a0fcf7348e">
        <updating/>
        <source>doTblDataRowColChangeOLD(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	re : CM_RateEntry;
	anObject : Object;
begin
//	inheritMethod(table);
	if table.row &gt; table.fixedRows then
		re := table.accessCell(table.row, table.column).itemObject.CM_RateEntry;
		if re &lt;&gt; null then
			self.myCurrentService := re.rate.service;
			if re.rate.isKindOf(CM_DebtorRate) then
				if self.mode = self.Mode_Debtor then
					if table.column &gt; table.fixedColumns then
						self.myCurrentDebtor := table.accessColumn(table.column).itemObject.CM_DebtorNode;
					endif;
					if self.myCurrentDebtor = null then
						///self.myCurrentDebtor := self.cmbDebtor.listObject.CM_DebtorNode;
					endif;
				else
					self.myCurrentDebtor := re.rate.CM_DebtorRate.debtorNode;
				endif;
				self.myCurrentLineGroupDebtor := null;
				
				if self.myCurrentDebtor.isKindOf(CM_RootDebtorGroup) 
				and self.mode = self.Mode_Trade then
					self.myCurrentDebtor := null;
					anObject := table.accessColumn(table.column).itemObject;
					self.myCurrentLineGroupDebtor := anObject.CM_LineGroupDebtor;
				
				endif;
			else
				self.myCurrentDebtor := null;
				self.myCurrentLineGroupDebtor := re.rate.CM_LineGroupDebtorRate.lineGroupDebtor;
			endif;
		endif;
	endif;
	self.setEnableObjects();
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doUpdateFromDelete" id="246d9a17-84c8-422b-a7fb-d8448a81739c">
        <source>doUpdateFromDelete(_deletedObj : Object);
// ---------------------------------------------------------------------------
// Created:     18 November 2008 by cnwab1
//
// Purpose:      // PAR 18489
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lastRow, firstRow, firstCol, lastCol, col, row : Integer;
	cellObj : Object;
	savedChargedEffTS : TimeStamp;
begin
	//19 Sep 2012	NDL	Par 30375
	savedChargedEffTS := app.getChargeRateEffectiveDate();
	app.setChargeRateEffectiveDate( self.effectiveDate.TimeStamp );
	
	lastRow := self.tblData.rows;
	lastCol := self.tblData.columns;
	firstRow := self.tblData.fixedRows + 1;
	firstCol := self.tblData.fixedColumns + 1;
	
	// 24018 refresh macro info after edit
	self.displayExtraInfo();

	foreach row in firstRow to lastRow do : outerLoop
		foreach col in firstCol to lastCol do
			cellObj := self.tblData.accessCell(row,col).itemObject;
			if cellObj &lt;&gt; null and not global.isValidObject(cellObj) then
				self.loadRateTableByRow(row);
				return;
				
			endif;
		endforeach;
		
	endforeach;
epilog
	app.setChargeRateEffectiveDate( savedChargedEffTS );	//19 Sep 2012	NDL	Par 30375
end;</source>
        <Parameter name="_deletedObj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="getProgressCount" id="dbfb54ab-1f42-4fa9-968d-ac979b6f59f3">
        <source>getProgressCount() : Integer;
// 25273 total debtors only
vars

begin
	return self.allSelectedDebtors.size;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getRatesForReport" id="77f7adea-9efc-4938-b42c-31963490db7d">
        <source>getRatesForReport(_objArray : ObjectArray input; _selectedOnly : Boolean);
//----------------------------------------------------------------------
// Created by 	cnwjre1	Sept 2010 CCMS 1155 par 23583 Invoice rate reporting
vars
	fr, fc,
	rows, cols	: Integer;
	r, c		: Integer;
	re	: CM_RateEntry;
	dn	: CM_DebtorNode;
	oa	: ObjectArray;
	obj	: Object;
begin
	create oa transient;
	if _selectedOnly then
		re := self.tblData.accessCell(self.tblData.row, self.tblData.column).itemObject.CM_RateEntry;
		obj := self.tblData.accessColumn(self.tblData.column).itemObject;
		dn := self.tblData.accessColumn(self.tblData.column).itemObject.CM_DebtorNode;
		self.getReportableRates(re, dn, oa);
		oa.copy(_objArray);
	else
		fr := self.tblData.fixedRows + 1;
		rows := self.tblData.rows;
		fc := self.tblData.fixedColumns + 1;
		cols := self.tblData.columns;
		foreach r in fr to rows do
			foreach c in fc to cols do
				re := self.tblData.accessCell(r, c).itemObject.CM_RateEntry;
				dn := self.tblData.accessColumn(c).itemObject.CM_DebtorNode;
				oa.clear;
				self.getReportableRates(re, dn, oa);
				oa.copy(_objArray);
			
			endforeach;
		endforeach;
	endif;
epilog
	delete oa;
end;</source>
        <Parameter name="_objArray" type="ObjectArray" usage="input"/>
        <Parameter name="_selectedOnly" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getReportableRates" id="a23d15c6-f8b3-42fc-a990-9e9c9ae0677f">
        <source>getReportableRates(_rateEntry : CM_RateEntry; _debtor : CM_DebtorNode; _coll : ObjectArray input);
// Sept 2010 CCMS 1155 par 23583 Invoice rate reporting
vars
	service 		: CM_Service;
	company			: CM_Bank;
	rate			: Real;
	rateNode		: CM_DebtorNode;
	tmpInvRateIF 	: CMIF_InvRateReporter;
	costPerUnitLabels	: StringArray;
	costPerUnitLabel	: String;
	i				: Integer;
	decPlaces		: Integer;
	iter			: Iterator;
	calculationType : CM_CalculationType;	//29 Jun 2018	NDL	TFS 39338
	calcType : Integer;	//29 Jun 2018	NDL	TFS 39338
	subTerm : CM_SubTerminal;	//29 Jun 2018	NDL	TFS 39338
	tidalClass : HMS_TidalClass;	//29 Jun 2018	NDL	TFS 39338
begin
	if _rateEntry = null then
		return;
	endif;

	decPlaces := self.myTerminal.getConfig(FinancialRateDPlaces).Integer;
	rate := _rateEntry.getDerivedCostPerUnit(self.effectiveDate.TimeStamp);
	service := _rateEntry.rate.service;
	company := service.bank;
	if _rateEntry.rate.isKindOf(CM_DebtorRate) then
		rateNode := _rateEntry.rate.CM_DebtorRate.debtorNode;
	endif;
	
	//29 Jun 2018	NDL	TFS 39338
	if service &lt;&gt; null then
		calculationType := service.myCalculationType;
		if calculationType&lt;&gt; null then
			calcType := calculationType.calculationType;
		endif;
	endif;
	
	create costPerUnitLabels transient;
	_rateEntry.getCostPerUnitLabels(costPerUnitLabels);
	
	i := 1;
	iter	:=	costPerUnitLabels.createIterator();
	while iter.next(costPerUnitLabel) do	
			
		create tmpInvRateIF transient;
						
		if costPerUnitLabel = service.name then
			tmpInvRateIF.allUnitCost	:=	null;
		else
			tmpInvRateIF.allUnitCost :=	costPerUnitLabel;	// Non-null will indicate a multi-line rate.
		endif;
		
		if calcType = INV_CALC_TYPE_DAYSINCE_SUBTERM then	//29 Jun 2018	NDL	TFS 39338
			subTerm := self.myTerminal.allSubTerminals.getMatchingDesc( costPerUnitLabel );
			tmpInvRateIF.costPerUnit :=	_rateEntry.getCPUforObject( subTerm ).asStringJMTWithPrecision(decPlaces, false);
			
		elseif calcType = INV_CALC_TYPE_TIDAL_CLASS then	//29 Jun 2018	NDL	TFS 39338
			tidalClass := app.myRoot.allTidalClasses.getMatchingDesc( costPerUnitLabel );
			tmpInvRateIF.costPerUnit :=	_rateEntry.getCPUforObject( tidalClass ).asStringJMTWithPrecision(decPlaces, false);
			
		else
			// some instances have an older rate in the array - use costPerUnit instead
			if i = 1 and costPerUnitLabels.size =  1 then
				tmpInvRateIF.costPerUnit	:=	rate.asStringJMTWithPrecision(decPlaces, false);
			else			
				if _rateEntry.allCostPerUnits.size &lt; i then 
					tmpInvRateIF.costPerUnit	:=	"0";
				else
					tmpInvRateIF.costPerUnit	:=	_rateEntry.allCostPerUnits[i].asStringJMTWithPrecision(decPlaces, false);
				endif;
			endif;
			
		endif;
			
		if _debtor.isKindOf(CM_Debtor) then
			tmpInvRateIF.debtorCode			:=	_debtor.CM_Debtor.decfinName;
			tmpInvRateIF.debtorGroup := 'D';
		else
			tmpInvRateIF.debtorGroup := 'G';
		endif;
					
		tmpInvRateIF.debtorName := _debtor.getListName;								
		tmpInvRateIF.debtorGroup := 'D';
		tmpInvRateIF.effectiveTimestamp := _rateEntry.startTimestamp; 
		tmpInvRateIF.expiryTimestamp := _rateEntry.expiryTimestamp;
		if service.genLCode &lt;&gt; null then
			tmpInvRateIF.glCode := service.genLCode.code;
		endif;
		tmpInvRateIF.myBank := company;
		tmpInvRateIF.myDebtor := _debtor;
		tmpInvRateIF.myService := service;
		tmpInvRateIF.overrideFlag := (rateNode = _debtor) and not _debtor.isRootDebtorGroup;
		tmpInvRateIF.serviceName := service.name;
		i := i + 1;
		
		_coll.add(tmpInvRateIF);
	endwhile;
epilog
	delete costPerUnitLabels;
	delete iter;
end;
</source>
        <Parameter name="_rateEntry" type="CM_RateEntry"/>
        <Parameter name="_debtor" type="CM_DebtorNode"/>
        <Parameter name="_coll" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="haltProgress" id="2881d268-32df-4998-951e-2094d012ed7d">
        <source>haltProgress(pe : CM_ProgressException; _isQuery : Boolean; _ls : Boolean io) : Integer;
// either query or extract
vars
	wasSet : Boolean;
begin

	//19 Apr 2012	NDL	Par 27775
	wasSet := _ls;
	app.cmsEndLoad(_ls);

	if app.msgBox(self.myCurrentBank.getMsgString(WARN_CANCEL_PROGRESS ,
										"",
										"",""),
										"Cancel Progress",
										MsgBox_Exclamation_Mark_Icon + MsgBox_Yes_No) = MsgBox_Return_Yes then

		if _isQuery then
			self.tblData.columns := 1;
		endif;
		return Ex_Abort_Action;
	else
		if wasSet then
			app.cmsBeginLoad(_ls);
		endif;
		return Ex_Continue;
	endif;

end;</source>
        <Parameter name="pe" type="CM_ProgressException"/>
        <Parameter name="_isQuery" type="Boolean"/>
        <Parameter name="_ls" type="Boolean" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initBerthMSG" id="ce1c9d63-5ee6-469a-a9b7-1a0ce841f5fd">
        <source>initBerthMSG();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Jun 2018 cnwma1	ChangeRequest 38953: PEL1 - Berth Rates, Vessel Type Rates, Visit Types

*/

vars
	groupBox : CMUI_MultiSelectGroupBox;
	
begin
	groupBox := self.msgbBerths;
	groupBox.caption := null;
	groupBox.distanceFromBottom := 5;
	groupBox.distanceFromRight 	:= 5;
	groupBox.lockBottom 		:= false;
	groupBox.lockRight			:= false;
	groupBox.stretchHeight 		:= false;
	groupBox.stretchWidth 		:= true;
	groupBox.multiSelect 		:= ListBox.MultiSelect_Extended;
	groupBox.formDisplayEntryMethodName := "displayBerth";
	groupBox.availableHeading 	:= app.getErrorString(Available_berths);
	groupBox.selectedHeading 	:= app.getErrorString(Selected_berths);
	groupBox.myBaseForm			:= self;
	groupBox.mySelectedListBox.sorted := false;
	groupBox.cnEcResizeContents();
	groupBox.readOnly 			:= false;
epilog

end;</source>
    </JadeMethod>
