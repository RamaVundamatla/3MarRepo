Date		Who		Reason
20 January 2015	cnwmc5	Initial creation

*/

vars

begin
	if (not self.isTransient) or
	   (not _pxyVBTS.isTransient) then
		app.raiseUnexpectedProgramError(class.name, method.name, 'called for non transient');
		return;
	endif;

