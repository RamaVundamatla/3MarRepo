    <JadeMethod name="getGrossAboardHrs" id="6d91a617-29ad-483d-b318-c57790da71c2">
        <source>getGrossAboardHrs():Real;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 April 2012	cnwndl1	Initial creation	Par 29369

*/

vars

	relativeLabourAshore : TimeStamp;
	elapsed : TimeStampInterval; 

begin

	relativeLabourAshore := self.getRelativeLabourAshore;
	if relativeLabourAshore &lt; self.labourStart then
		return 0;
	endif;
	
	elapsed := relativeLabourAshore - self.labourStart;
	
	return elapsed.asHours();

epilog

end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getGrossExchangeHrs" id="f55a2e36-8060-4e4c-8bbf-bd746d7e3435">
