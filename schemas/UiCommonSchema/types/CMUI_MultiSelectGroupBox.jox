    <JadeMethod name="selectFirst" id="2074ac2d-fcfe-4e2b-9f7a-77fab1a3ef14">
        <updating/>
        <source>selectFirst(_isAvailable : Boolean) updating;

// cnwdvb1 06 December 2002 

vars

	count, max	: Integer;

begin

	if _isAvailable then
		if self.myAvailableListBox.listCount &gt; 0 then
			self.myAvailableListBox.itemSelected[1] := true;
			self.myAvailableListBox.listIndex := 1;
			self.myAvailableListBox.click(self.myAvailableListBox);
			max := self.mySelectedListBox.listCount;
			foreach count in 1 to max do
				self.mySelectedListBox.itemSelected[count] := false;
			endforeach;
		endif;
	 else
	 	if self.mySelectedListBox.listCount &gt; 0 then
			self.mySelectedListBox.itemSelected[1] := true;
			self.mySelectedListBox.listIndex := 1;
			self.mySelectedListBox.click(self.mySelectedListBox);
			max := self.myAvailableListBox.listCount;
			foreach count in 1 to max do
				self.myAvailableListBox.itemSelected[count] := false;
			endforeach;
	 	endif;
	 endif;

end;</source>
        <Parameter name="_isAvailable" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="selectItem" id="f3fbe8ec-0636-4de3-8289-63938d6435b8">
        <updating/>
        <source>selectItem(pIdx : Integer; pObj : Object) protected, updating;
// ---------------------------------------------------------------------------
// Created:     29 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	idx,
	origIdx: Integer;
	str : String;
	coll : Collection;
	itemBackColor : Integer;
begin

	if pIdx &gt; 0 and pObj &lt;&gt; null then
		
		// add into the selected list box
		if self.mySelectedListBox.formDisplayEntryMethodName &lt;&gt; null then
			// use listbox display entry as it can be different
			str := self.mySelectedListBox.displayEntry(self.mySelectedListBox, pObj, null);
		else
			str := self.displayEntry(pObj);
		endif;

		// check as displayEntry can return null if entry is not allowed
		if str &lt;&gt; null then
			// remove from the available list box
			//jlier1 TFS 53515 2/6/22
			itemBackColor:=self.myAvailableListBox.itemBackColor[pIdx];
			self.myAvailableListBox.removeItem(pIdx);
			//epr par 19579 1/5/09 changed from .class.implementsInterface to .respondsTo
			if self.myBaseForm &lt;&gt; null and  self.myBaseForm.respondsTo(IF_CMUI_MultiSelectGroupBox) and self.myBaseForm.IF_CMUI_MultiSelectGroupBox.getOriginalCollection &lt;&gt; null then
				coll :=self.myBaseForm.IF_CMUI_MultiSelectGroupBox.getOriginalCollection;
				origIdx:=coll.indexOf(pObj);
				idx:=origIdx-pIdx + 1;
			
				self.mySelectedListBox.addItemAt(str,idx);
			else
				idx := self.mySelectedListBox.addItem(str);
				if itemBackColor &gt; 0 then
					self.mySelectedListBox.itemBackColor[idx]:=itemBackColor;
				endif;
			endif;
			self.mySelectedListBox.itemObject[idx] := pObj;
		endif;
		
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="pIdx" type="Integer"/>
        <Parameter name="pObj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="selectTextMatches" id="28cc943d-fd71-454f-8858-ae67b3e8fcb2">
        <source>selectTextMatches(_searchStr : String) ;
/*
----------   ----------  --------------------------------------------------
Created:	06 August 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	idx,
	lstCount			: Integer;
	str					: String;
	str1				: String;
	lstBox				: CMUI_ListBox;
	
begin
	lstBox := self.myAvailableListBox;
	lstCount := lstBox.listCount;
	lstBox.clearAllSelected();
	//par 15655
	foreach idx in lstCount to 1 step -1 do
		str := lstBox.itemText[idx].trimBlanks.toUpper;
		if (str.pos(_searchStr, 1) &lt;= 0) then
			lstBox.removeItem(idx);
		endif;
	endforeach;
return;


end;</source>
        <Parameter name="_searchStr" type="String"/>
    </JadeMethod>
    <JadeMethod name="selectedHeading" id="118c71cc-b939-438d-811b-8b1ec6d12382">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>selectedHeading(set: Boolean; _value: String io) mapping, updating;
// ---------------------------------------------------------------------------
// Created:     28 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if set then
		self.selectedHeading := _value;
		if self.mySelectedLbl &lt;&gt; null then
			self.mySelectedLbl.caption := _value;
			if _value = null then
				self.mySelectedLbl.visible := false;
			else
				self.mySelectedLbl.visible := true;
			endif;
		endif;
	else
		_value := self.selectedHeading;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setAvailable" id="206d1c76-fcce-4034-9d15-ec9dc8965b6d">
        <updating/>
        <source>setAvailable(pAvailable : Collection; pClearSelectedFirst : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     28 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	obj		: Object;
	idx		: Integer;
	iter	: Iterator;
	include	: Boolean;
	tmpStr	: String;
	exOccurred : Boolean;
	
begin

	self.myAvailableListBox.clear;
	
	if pClearSelectedFirst then
		self.mySelectedListBox.clear;
	endif;
	
	if pAvailable = null then
		return;
	endif;
	
	on Exception do self.form.listBoxLimitException( exception, self.mySelectedListBox, exOccurred );	//11 Mar 2021	NDL	TFS 50937

	iter := pAvailable.createIterator();
	while (iter.next(obj)) do
		if self.mySelectedListBox.findObject(obj) = -1 then
			// only add into available if not in selected
			tmpStr := self.displayEntry(obj);
			if tmpStr &lt;&gt; null then
				idx := self.myAvailableListBox.addItem(tmpStr);
				//11 Mar 2021	NDL	TFS 50937
				if exOccurred then
					break;
				endif;
				self.myAvailableListBox.itemObject[idx] := obj;
			endif;
		endif;
	endwhile;
	
epilog
	delete iter;

end;</source>
        <Parameter name="pAvailable" type="Collection"/>
        <Parameter name="pClearSelectedFirst" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setAvailableHaz" id="2f816a1f-5193-4419-80f8-a06c00b78b96">
        <updating/>
        <source>setAvailableHaz(pAvailable : CM_HazardClassByCodeDict; pClearSelectedFirst : Boolean) updating;
//+cnwml2 PAR24472
vars
	idx		: Integer;
	haz		: CM_HazardClass;
	hazString : String;
	hazObj	: CMIF_Hazard;
	
begin

	self.myAvailableListBox.clear;
	
	if pClearSelectedFirst then
		self.mySelectedListBox.clear;
	endif;
	
	if pAvailable = null then
		return;
	endif;

	foreach haz in pAvailable do
		create hazObj transient;
		hazObj.code := haz.code;
		hazObj.description := haz.description;
		hazObj.limited := false;
		hazString := self.displayEntry(haz);
		idx := self.myAvailableListBox.addItem(hazString);
		self.myAvailableListBox.itemObject[idx] := hazObj;
		
		create hazObj transient;
		hazObj.code := haz.code &amp; "L";
		hazObj.description := haz.description;
		hazObj.limited := true;
		hazString := haz.code &amp; "L " &amp; haz.description;
		idx := self.myAvailableListBox.addItem(hazString);
		self.myAvailableListBox.itemObject[idx] := hazObj;

	endforeach;

epilog

end;</source>
        <Parameter name="pAvailable" type="CM_HazardClassByCodeDict"/>
        <Parameter name="pClearSelectedFirst" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setSelected" id="f3d2bcfc-5ca2-4b05-a347-db9ad5d4e69e">
        <updating/>
        <source>setSelected(pSelected : Collection) updating;
// ---------------------------------------------------------------------------
// Created:     28 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	obj		: Object;
	numItems,
	idx		: Integer;
	iter	: Iterator;
begin
	
	// first move any selected items back into the available listbox.
	numItems := self.mySelectedListBox.listCount;
	
	foreach idx in numItems to 1 step -1 do
		obj := self.mySelectedListBox.itemObject[idx];
		self.removeItem(idx, obj);
	endforeach;
	
	self.mySelectedListBox.clear;
	
	if pSelected &lt;&gt; null then
		// Add in the new entries
		iter := pSelected.createIterator();
		while (iter.next(obj)) do
			idx := self.myAvailableListBox.findObject(obj);			
			if idx &gt; 0 then
				self.selectItem(idx, obj);
			endif;
			//idx := self.mySelectedListBox.addItem(self.displayEntry(obj));
			//self.mySelectedListBox.itemObject[idx] := obj;
		endwhile;
	endif;
	
epilog
	delete iter;

end;</source>
        <Parameter name="pSelected" type="Collection"/>
    </JadeMethod>
    <JadeMethod name="setSelectedDisplayStringMatch" id="8363fb7f-315d-49bc-b0de-2678c5540ddf">
        <updating/>
        <source>setSelectedDisplayStringMatch(pSelected : Collection) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 September 2012	cnwer1	Initial creation SFW 1295

*/

vars
	obj		: Object;
	numItems,
	idx		: Integer;
	iter	: Iterator;
	displayStr : String;
begin
	
	// first move any selected items back into the available listbox.
	numItems := self.mySelectedListBox.listCount;
	
	foreach idx in numItems to 1 step -1 do
		obj := self.mySelectedListBox.itemObject[idx];
		self.removeItem(idx, obj);
	endforeach;
	
	self.mySelectedListBox.clear;
	
	if pSelected &lt;&gt; null then
		// Add in the new entries
		iter := pSelected.createIterator();
		while (iter.next(obj)) do
			displayStr:=self.displayEntry(obj);
			idx := self.myAvailableListBox.findStringExact(1,displayStr);
			if idx &gt; 0 then
				obj := self.myAvailableListBox.itemObject[idx];
				self.selectItem(idx, obj);
			endif;
			//idx := self.mySelectedListBox.addItem(self.displayEntry(obj));
			//self.mySelectedListBox.itemObject[idx] := obj;
		endwhile;
	endif;
	
epilog
	delete iter;


end;</source>
        <Parameter name="pSelected" type="Collection"/>
    </JadeMethod>
