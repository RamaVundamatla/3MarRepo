    <JadeMethod name="addError" id="8d0b2eff-74bb-4b81-84a2-d107be3d5df1">
        <updating/>
        <source>addError(newString : String) updating;
//PAR 2766 AJA 22/4/99: Prevent string too long by only adding error messages
//onto the error string if there is room for them. Nb we keep 75 characters
//free as protection against other misguided concatentations elsewhere.
//
//	08/02/2006	PAR 11351		JC		errorString changed to max length
//										Need to be able to show ALL discrepancies for the C&amp;H Summary in one go.
//
vars

begin

   errorString := errorString &amp; newString &amp; CrLf;

end;</source>
        <Parameter name="newString" type="String"/>
    </JadeMethod>
    <JadeMethod name="getSummaryTLG" id="360da01b-b851-41b5-9ab6-0872069a95f7">
        <source>getSummaryTLG(_shippingLine : CM_ShippingLine; _debtor : CM_DebtorNode;
				_shipPortGroup : CM_ShipPortGroup; 
				_createIfNotPresent : Boolean): CMIF_CandHTradeLineGeo;
// ---------------------------------------------------------------------------
// Created:     21 August 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	sumTLG	: CMIF_CandHTradeLineGeo;
	tmpSPG	: CM_ShipPortGroup;
begin
	if self.sumariseTo = CMIF_CandHRpt.SumariseTo_Debtor then
		tmpSPG := null;
	elseif self.sumariseTo = CMIF_CandHRpt.SumariseTo_ShipLinePortGroup then
		tmpSPG := _shipPortGroup;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 
				'Unhandled sumariseTo (' &amp; self.sumariseTo.String &amp; ')');
		return null;
	endif;

	sumTLG := self.allSummaryTLGColumns[_shippingLine, _debtor, tmpSPG];

	if sumTLG = null and _createIfNotPresent then
		create sumTLG transient;
		sumTLG.setForCreate(_shippingLine, _debtor, tmpSPG, self);
	endif;
	
	return sumTLG;

end;</source>
        <Parameter name="_shippingLine" type="CM_ShippingLine"/>
        <Parameter name="_debtor" type="CM_DebtorNode"/>
        <Parameter name="_shipPortGroup" type="CM_ShipPortGroup"/>
        <Parameter name="_createIfNotPresent" type="Boolean"/>
        <ReturnType type="CMIF_CandHTradeLineGeo"/>
    </JadeMethod>
    <JadeMethod name="getSummaryTLG_OLD" id="0871c7d8-edf5-45b1-8756-b432aace8713">
        <source>getSummaryTLG_OLD(_lineGroupDebtor: CM_LineGroupDebtor): CMIF_CandHTradeLineGeo;
//----------------------------------------------------------------
//	Created:	08 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------

// PRE CCMS 1468 version

vars
	code	: String;
begin
	if _lineGroupDebtor = null then
		app.raiseUnexpectedProgramError(class.name, method.name, "line group debtor is null");
		return null;
	endif;

	code := _lineGroupDebtor.getCandHCode(null);
	return self.allSummaryTLGColumnsByCode[code];

end;</source>
        <Parameter name="_lineGroupDebtor" type="CM_LineGroupDebtor"/>
        <ReturnType type="CMIF_CandHTradeLineGeo"/>
    </JadeMethod>
    <JadeMethod name="getSummaryTLGfromLGD" id="b611f8c9-688a-46fe-a9de-d0ac035d840a">
        <source>getSummaryTLGfromLGD(_lineGroupDebtor: CM_LineGroupDebtor;
						_createIfNotPresent : Boolean): CMIF_CandHTradeLineGeo;
// ---------------------------------------------------------------------------
// Created:     21 August 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if _lineGroupDebtor = null then
		return null;
	endif;
	
	return self.getSummaryTLG(_lineGroupDebtor.shipPortGroup.shippingLine,
								_lineGroupDebtor.debtor,
								_lineGroupDebtor.shipPortGroup, _createIfNotPresent);

end;</source>
        <Parameter name="_lineGroupDebtor" type="CM_LineGroupDebtor"/>
        <Parameter name="_createIfNotPresent" type="Boolean"/>
        <ReturnType type="CMIF_CandHTradeLineGeo"/>
    </JadeMethod>
    <JadeMethod name="updateForSnapShot" id="ef291a46-5156-4a7e-9bd5-30f32ff0b1b2">
        <source>updateForSnapShot(_snapShot: CM_TISnapShot; _updatedTLGs: CMIF_CandHTradeLineGeoByCodeDt input);
//----------------------------------------------------------------
//	Created:	11 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	summaryTLG	: CMIF_CandHTradeLineGeo;
begin

	foreach summaryTLG in self.allSummaryTLGColumns do
		if self.usePRE_CCMS1468 then
			if summaryTLG.updateForSnapShotOLD(_snapShot) then
				_updatedTLGs.add(summaryTLG);
			endif;
		else
			if summaryTLG.updateForSnapShot(_snapShot) then
				_updatedTLGs.add(summaryTLG);
			endif;
		endif;
	endforeach;

end;</source>
        <Parameter name="_snapShot" type="CM_TISnapShot"/>
        <Parameter name="_updatedTLGs" type="CMIF_CandHTradeLineGeoByCodeDt" usage="input"/>
    </JadeMethod>
</Class>
