/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 July 2010	cnwndl1	Initial creation		Par 25127	/ CCMS 1140	

*/

vars

	changed : Boolean;
	
begin

	// we don't get a lost focus when going straight to the update button.
	self.doUpdateDeckCellProxy( table, changed );
	
	if changed then
		self.anythingChanged := true;
