    <JadeMethod name="btnNew_click" id="9afa5595-06b1-4e76-b1a9-9d572cbc07a4">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>/*******************************************************
*
* Description : Allow user to create a new Linc System
*				definition.
*
* Parameters :	None
*
* Return :		None
*
* History :		rmb	10/12/96	Initial version
*
*******************************************************/
btnNew_click(btn: Button input) updating;

begin
	// Handle database create/update exceptions
	on SystemException do saveExceptionHandler(exception);
	on LockException   do saveExceptionHandler(exception);

	// Add new Linc system definition and set as currently selected system
	setCurrentLincSystem ( CnEcLincDefRoot.firstInstance.newLincSystemDef() );

	// Enable the delete button if Linc system definitionis valid
	if ( currentLincSystem &lt;&gt; null ) then
		btnDelete.enabled := true;
	endif;

	// Display the new Linc application configuration to the user
//	folderLincDef.paint ( folderLincDef );
	frameToolbar.paint ( frameToolbar );
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnOK_click" id="c4e33f88-ba74-4027-af85-730971557003">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnOK_click(btn: Button input) updating;

begin
	// need to update everything that needs updating

	if connChanged then 
		self.updateConnection();
	endif;

	if diagChanged then 
		self.updateDiagnostics();
	endif;

	 // everythings updated so set our booleans and buttons accordingly

    btnOK.enabled := false;
    connChanged := false;
    diagChanged := false;
end;</source>
