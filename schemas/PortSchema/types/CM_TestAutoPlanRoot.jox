    <JadeMethod name="addFailedResult" id="23d2a8ac-2b14-4f85-bc0d-2df9cef949d9">
        <source>addFailedResult(	_myTrackedItem : CM_TrackedItem;
					_cmifYAPlanScenario  : CMIF_YAAutoPlanSenario;
					_myPrimeYardAllocation : CM_YardAllocation;
					_log : StringArray512
					) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 February 2012	cnwndl1	Initial creation	Par 29195

*/

vars

	fail : CM_TestAutoPlanFailed;

begin

		create fail transient;
		fail.setBaseDetails(	_myTrackedItem,	//_myTrackedItem : CM_TrackedItem;
								_cmifYAPlanScenario,
								_myPrimeYardAllocation,	//_myPrimeYardAllocation : CM_YardAllocation;
								_log,	//_log : StringArray512;
								self	//_myTestAutoPlanRoot : CM_TestAutoPlanRoot
								);
		fail.setSpecific();

epilog

end;</source>
