        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doChangeAccessDirection" id="c850b278-3fd2-4a04-b41c-4e3befcf4cdd">
        <updating/>
        <source>doChangeAccessDirection(_value : Integer;
						_errorMsgs: DTO_HandHeldGateErrorDict input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 May 2010	cnwer1	Initial creation
23 Feb 2010 cnwer1	PAR 28126
*/

vars
	invalidObject : Boolean;
	edition 		: Integer;
	rtQueueTasks: CM_RTQueueTaskArray;
begin

	if _value &lt;&gt; CM_YABlock.SideAccess_Front and 
		_value &lt;&gt;  CM_YABlock.SideAccess_Back then
		return;
	endif;
	
	if self.currentAccessDirection = _value then
		return;
	endif;
	
	on Exception do app.handleDeletedObject(exception, self.currentOverstowedTask, invalidObject);
	
	
	if self.currentOverstowedTask = null then
		return;
	endif;
	
	edition:= self.currentOverstowedTask.edition;
	if invalidObject then
		self.resetMyOverstowRTEntry();
		return;
	endif;
	
	create rtQueueTasks transient;
	self.allOverstowedTasks.copy(rtQueueTasks);
	self.currentAccessDirection:=_value;
	
	if not self.getManualOverstowMoveCargo(rtQueueTasks) then
		self.resetMyOverstowRTEntry();
		self.currentAccessDirection:=_value;
		self.doAcceptTasks(rtQueueTasks,self.currentAccessDirection,rtQueueTasks.size &gt; 1,_errorMsgs);

	endif;
epilog
	delete rtQueueTasks;
end;</source>
        <Parameter name="_value" type="Integer"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMoveTI" id="8f313017-91a0-4c9d-8c65-4890c3d2d697">
        <updating/>
        <source>doMoveTI(_locId : String; _ti : CM_TrackedItem input)  updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 April 2010	cnwer1	Initial creation
23 Feb 2010 cnwer1	PAR 28126
*/

vars
	passport	: CM_Passport;
	toLocation	: CM_LocationsController;
	forcedMove,
	result		: Boolean;
	quantity  : Integer;
begin

	passport := app.myPassport;
	
	toLocation:=self.findLocationFromString(_locId);
	quantity:=self.myVMInterface.getTotalQuantity();
	
	
	if self.doesSeperatePickupSetdown then
		//if the ti is not on the machine the move it to machine
		if not self.myMachine.myMachineController.allTrackedItems.includes(_ti) then
			toLocation:=self.myMachine.myMachineController;
		endif;
		
		//if it is on the machine move it to the passed in Location
	
	endif;
	
	
	if toLocation = null then
		self.addError(ERR_INVALID_LOCN,app.getErrorString1(ERR_INVALID_LOCN,_locId),null);
		return;
	endif;
	
	forcedMove:=self.currentOverstowedTask &lt;&gt; null;
	
	app.myPassport.setupForDeadlockReplay(-100, 2000);
	
	while true do
		
		self.doMoveTIBody(_ti,toLocation,forcedMove,quantity,passport);
	
		if app.myPassport.noTrxReplayAllowed() then	//15 Jan 2013	NDL	Par 30920
			break;
		endif;
	endwhile;
	
epilog
	process.setPersistentDeadlockPriority(0);
	app.myPassport.replayingDeadlocks := false;
end;</source>
        <Parameter name="_locId" type="String"/>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMoveTIBody" id="079022ce-6423-424f-b022-f3936a33eef7">
        <source>doMoveTIBody(_ti : CM_TrackedItem input; _toLocation : CM_LocationsController input; _forcedMove: Boolean; _quantity : Integer; _passport : CM_Passport input) protected;
/*

Date		Who		Reason
06 January 2014	cnwer1	Initial creation PAR 31915

*/

vars
	result : Boolean;
begin
	while true do
		self.initialiseForNewRequest(null);
	
		app.myTrxRT.trxRTGMoveTI(self.getMoveMachine(), _ti, null, _toLocation, false, _forcedMove, null, null, null, null, _quantity, _passport); // extra parameter

		if app.myPassport.hadReplayableDeadlock() then	//15 Jan 2013	NDL	Par 30920
			break;
		endif;
		
		if app.myPassport.trxCompletedOK then
			break;
		endif;
		
		result:= self.createErrorsFromPassport(null);
		if result then
			break;
		else
			continue;
		endif;
	endwhile;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_toLocation" type="CM_LocationsController" usage="input"/>
        <Parameter name="_forcedMove" type="Boolean"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMoveTasks" id="cfe455e0-d5ad-475a-8394-bd328ff9c7db">
        <updating/>
        <source>doMoveTasks() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 April 2010	cnwer1	Initial creation

*/

vars	
	firstDTOEntry,
	twinDTOEntry 	 : DTO_RTQueueEntry;
	firstTask,
	twinTask		: CM_RTQueueTask;
	allSelectedTasks : CM_RTQueueTaskArray;
	setdownLocID,
	twinSetdownID: String;
	dtoRTQueueEntryArray : DTO_RTQueueEntryArray;
	moveQuantity : Integer;
	moveWeight  : Decimal[14,4];
	isDirector : Boolean;
	directorCargo,
	directorTwinCargo : CM_TrackedItem;
begin
	if self.myVMInterface = null then
		return;
	endif;
	
	//cnwrd1 par 32293 mixed pickup goes down director task path.
	isDirector := ( self.myMachine.currentQueueTask &lt;&gt; null and self.myMachine.currentQueueTask.taskType = TASK_DIRECTOR ) or ( self.myMachine.getCurrentTwinTask &lt;&gt; null and self.myMachine.getCurrentTwinTask.taskType = TASK_DIRECTOR);
//	self.resetMyOverstowRTEntry;
	create allSelectedTasks transient;
	if self.myMachine.currentQueueTask = null then
		if self.showingTaskList then
			//Acccept task
			self.myVMInterface.getSelectedTasks(allSelectedTasks);
			self.doAcceptTasks(allSelectedTasks,null,self.myVMInterface.isTandemLift(),null);
		else
			// get next task;
			self.doGetNextTask(null, true);
		endif;
			
	else
		self.resetMyOverstowRTEntry;
		if not self.showingTaskList then
			if self.myMachine.currentQueueTask.status = TASK_OFFERED then
				self.myMachine.allCurrentQueueTasks.copy(allSelectedTasks);
				self.doAcceptTasks(allSelectedTasks,null,false,null);	
				return;
			endif;
		endif;
		self.getRelatedTask();
				
		if self.doesSeperatePickupSetdown then
		
			//determine if we are picking up or setting down
			if self.myMachine.currentQueueTask.taskType = TASK_PICKUP and not isDirector then
				moveQuantity:=self.myVMInterface.getTotalQuantity();
				moveWeight := self.myVMInterface.getMoveWeight();
				self.doPickupTask(moveQuantity,moveWeight,null); //cnwrd1 ccms 2274 break bulk
				
			elseif isDirector then //cnwrd1 par 32293
			
				moveQuantity:=self.myVMInterface.getTotalQuantity();
				//14 Sep 2017 cnwer1	TFS 6863 changed to use objects instead of ids so break bulk works correctly
				directorCargo:=app.myPassport.getObjectOfTypeFromOid(self.myVMInterface.getDirectorCargoID,CM_TrackedItem).CM_TrackedItem; 
				directorTwinCargo :=app.myPassport.getObjectOfTypeFromOid(self.myVMInterface.getTandemCargoID,CM_TrackedItem).CM_TrackedItem; 			
				moveQuantity:=self.myVMInterface.getTotalQuantity();
				moveWeight := self.myVMInterface.getMoveWeight();
				//14 Sep 2017 cnwer1	TFS 6863 changed to use objects instead of ids so break bulk works correctly
				self.doActionDirectorTasks(directorCargo, directorTwinCargo ,moveQuantity, moveWeight,null);  //cnwrd1 5.7.2011  par 25048
			elseif self.myMachine.currentQueueTask.taskType = TASK_SETDOWN  then
				setdownLocID:=self.myVMInterface.getSetdownLocID;
				twinSetdownID:=self.myVMInterface.getSetdownTwinLocID;
				create  dtoRTQueueEntryArray transient;
				self.findWorkingDTORTEntries(dtoRTQueueEntryArray,null);
				
				firstDTOEntry:=dtoRTQueueEntryArray.first;
				firstTask:=firstDTOEntry.myRealQueueEntry.CM_RTQueueEntry.findTaskOfType(TASK_SETDOWN,TASK_WORKING);
			
				if dtoRTQueueEntryArray.size = 2 then
					twinDTOEntry:=dtoRTQueueEntryArray[2];
					if twinDTOEntry &lt;&gt; null then
						twinTask:=twinDTOEntry.myRealQueueEntry.CM_RTQueueEntry.findTaskOfType(TASK_SETDOWN,TASK_WORKING);
					endif;
				endif;
				
				//cnwrd1 par 30819
				if not self.checkTruckSwap(firstTask,twinTask,setdownLocID,twinSetdownID) then
					return;
				endif;
				
				self.doSetdownTask(firstTask,twinTask,setdownLocID,twinSetdownID,self.myVMInterface.isInterchangeAreaOverride,null);
			endif;
		else	
			if self.myMachine.currentQueueTask.taskType = TASK_DIRECTOR then
				//cnwjo3 par 26296.
				//14 Sep 2017 cnwer1	TFS 6863 changed to use objects instead of ids so break bulk works correctly
				directorCargo:=app.myPassport.getObjectOfTypeFromOid(self.myVMInterface.getDirectorCargoID,CM_TrackedItem).CM_TrackedItem; 
				directorTwinCargo :=app.myPassport.getObjectOfTypeFromOid(self.myVMInterface.getTandemCargoID,CM_TrackedItem).CM_TrackedItem; 
				moveQuantity:=self.myVMInterface.getTotalQuantity();
				moveWeight := self.myVMInterface.getMoveWeight();
				self.doActionDirectorTasks(directorCargo, directorTwinCargo, moveQuantity,moveWeight,null);   //cnwrd1 5.7.2011  par 25048
			else 
				setdownLocID:=self.myVMInterface.getSetdownLocID;
				self.doMoveCurrentTask(setdownLocID,null);
			endif;
		endif;
	endif;
epilog
	delete  allSelectedTasks;
	delete dtoRTQueueEntryArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="doPickupDirectorSingleTask" id="2609e22a-a99e-4df3-b187-8acfd3ecccf3">
        <source>doPickupDirectorSingleTask(_task : CM_RTQueueTask input;
							_ti : CM_TrackedItem input;
							_moveQuantity : Integer;
							_moveWeight : Decimal) : Boolean;
/*

Date		Who		Reason
14 August 2014	cnwer1	Initial creation PAR

*/

vars
	result : Boolean;
begin
	// PAR 20338 18807
	app.myPassport.setupForDeadlockReplay(-100, 2000);

	while true do

		result :=self.doPickupDirectorSingleTaskBody(_task,_ti,_moveQuantity,_moveWeight);
		
		if app.myPassport.noTrxReplayAllowed() then	//15 Jan 2013	NDL	Par 30920
			break;
		endif;

	endwhile;
	
	return result;
epilog
	process.setPersistentDeadlockPriority(0);
	app.myPassport.replayingDeadlocks := false;

end;</source>
        <Parameter name="_task" type="CM_RTQueueTask" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_moveQuantity" type="Integer"/>
        <Parameter name="_moveWeight" type="Decimal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPickupDirectorSingleTaskBody" id="7a2e2879-8fb5-49d9-bbbe-41d6cf0cac7a">
        <source>doPickupDirectorSingleTaskBody(_task : CM_RTQueueTask input;
							_ti : CM_TrackedItem input;
							_moveQuantity : Integer;
							_moveWeight : Decimal) : Boolean protected;
/*

Date		Who		Reason
14 August 2014	cnwer1	Initial creation PAR

*/

vars
	result : Boolean;
begin
	
	while true do
		self.initialiseForNewRequest(null);
	
		app.myTrxRT.trxPickupDirectorSingleTask(self.myMachine,_task,_ti ,_moveQuantity,_moveWeight, app.myPassport);
	
		if app.myPassport.hadReplayableDeadlock() then	//15 Jan 2013	NDL	Par 30920
			break;
		endif;
		
		if app.myPassport.trxCompletedOK then
			return true;
			break;
		endif;
		result:= self.createErrorsFromPassport(null);
		if result then
			break;
		else
			continue;
		endif;
	endwhile;
	
	return false;

epilog

end;</source>
