<ExternalCollClass name="EDB_TradeDict" id="34d798ab-84b4-471c-b597-ad3cbc9988d4">
    <externalDatabase name="EDB_PortDss"/>
    <includesPredicate>( ( trade."description" = ? ) AND ( trade."edition" = ? ) AND ( trade."oid" = ? ) AND ( trade."ordinal" = ? ) )</includesPredicate>
    <includesPredicateInfo>AQAAAAIAAAADAAAABAAAAA==</includesPredicateInfo>
    <keyEqPredicate>( trade."oid" = ? )</keyEqPredicate>
    <keyEqPredicateInfo>AQAAAA==</keyEqPredicateInfo>
