    <JadeMethod name="getReceivedCargoInYard" id="15158907-e250-48fa-bc19-3631b1fb9b13">
        <source>getReceivedCargoInYard(_allTIs : CM_TISet input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 July 2019	jlger1	Initial creation 44965

*/

vars
	allReceivedMoves : CM_TITransactionByIdTypeDict;
	move : CM_TITransaction;
begin
	create allReceivedMoves transient;
	self.getCargoMoves(allReceivedMoves,false);
	
	foreach move in allReceivedMoves discreteLock do
		if move.myTrackedItem &lt;&gt; null then
			_allTIs.addNoDuplicates(move.myTrackedItem,false);
		endif;
	endforeach;
epilog
	if allReceivedMoves &lt;&gt; null then
		allReceivedMoves.purge;
	endif;
	delete allReceivedMoves;
end;</source>
        <Parameter name="_allTIs" type="CM_TISet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getReceivedItemIds_JRW" id="7fef9587-b836-47a7-b7dc-e019f98f3ae7">
        <source>getReceivedItemIds_JRW() : String;
// par 26242
vars
	ids	: String;
	ti	: CM_TrackedItem;
begin
	foreach ti in self.allReceivedTrackedItems do
		if ids = null then
			ids := ti.id;
		else
			ids := ids &amp; ", " &amp; ti.id;
		endif;
	endforeach;

	return ids;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
