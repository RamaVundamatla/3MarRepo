	endif;
	self.topGridRowDraw := self.topGridRow;	
	
	// Adjust for partial scroll, where TOP row should be partially drawn
	self.yDrawOffset := 0;
	if self.vScrollOffset &gt; 0 then
		if self.topGridRowDraw &lt; self.maxGridRow then
			self.topGridRowDraw := self.topGridRowDraw + 1;
			self.yDrawOffset := (self.vScrollOffset - self.getGridHeight()).Integer;
		endif;
	elseif self.vScrollOffset &lt; 0 then
		self.yDrawOffset := self.vScrollOffset;
