    <JadeMethod name="clickTrackedItemButton" id="5e9b7531-d9d3-401e-b95b-61e2b17e7172">
        <updating/>
        <source>clickTrackedItemButton( _obj : Object ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 January 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

	ti : CM_TrackedItem;
	
begin
	
	if CM_TrackedItem.hasInstance( _obj ) then
		ti := _obj.CM_TrackedItem;
	endif;
	
	if ti &lt;&gt; null then
		self.myMobileGenericAgent.setMyNextTiToAction(ti);
		if self.myMobileGenericAgent.inward then
			self.myMobileGenericAgent.setChecksState(self.myMobileGenericAgent.GateReceipt);
		else
			self.myMobileGenericAgent.setChecksState(self.myMobileGenericAgent.GateRelease);
		endif;
		self.gotoForm( MOB_HHGateCheckCargo, false );
	endif;
	
epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="doCompleteOutward" id="16a8d4c9-2b28-4b49-b2e8-ca2755afd303">
        <source>doCompleteOutward():Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 February 2010	cnwndl1	Initial creation
15/12/2016 cnwns1 TFS 2867:PKT - Bulk Process - WeighBridge Integration
16 Feb 2024	navnk30	ChangeRequest 62414: EUP | Retrospective Operations - [54177.050] - Road Exit
*/

vars

	truck : CM_Vehicle;
	theRoadJob : CM_RoadJob;
	invalidJob : Boolean;
	errorMess : String;
	userResponse : Integer;
	visit : CM_VehicleVisitRecord;
	
	controller : CM_LaneController;
	thePrinter : CM_PrinterDef;
	printers : StringArray;
	printReceipt : Boolean;
	
begin

	if not self.myMobileGenericAgent.cargoIsAllConfirmed then
		self.btnOne.enabled := false;
		errorMess := app.getErrorString(Some_cargo_unconfirmed);
		self.msgBox(errorMess ,app.getErrorString(Error), MsgBox_OK_Only, true);
		return false;
	endif;
		

	truck := self.myMobileGenericAgent.myTruck;
	on Exception do app.handleDeletedObject(exception, theRoadJob, invalidJob);
	theRoadJob := truck.allRoadJobs.first.CM_RoadJob;
	
	
	//	15/12/2016 cnwns1 TFS 2867:PKT - Bulk Process - WeighBridge Integration
	if truck.getCurrentVisit.isBulkGateVVR() then
		app.raiseCMException1(Vehicle_visit_Bulk_Only,app.getErrorString(Bulk_gate_out),"wrongGate", null);
		//err you cant process bulk gate job here
		return false;
	endif;
	
	
	// Look thru all of its road jobs set and check if any of them still have any devices in their working devices IDs collection.
	if theRoadJob &lt;&gt; null and theRoadJob.status &lt;&gt; JOB_COMPLETE then
		if theRoadJob.allWorkingDeviceIDs.cnEcIsNotEmpty() then
			userResponse	:=	self.msgBox(	app.getErrorString (XLAT_RoadExit_Warning1), app.getString(Warning), MsgBox_Question_Mark_Icon + MsgBox_Yes_No, false);
			if userResponse &lt;&gt; MsgBox_Return_Yes then
				return false;
			endif;
		endif;
	endif;
	
	if not invalidJob and theRoadJob &lt;&gt; null then
		if theRoadJob.status &lt;&gt; JOB_COMPLETE then
			if theRoadJob.autoComplete then
				self.msgBox(app.getErrorString (XLAT_Road_Exit_Error1), app.getErrorString(Error), MsgBox_OK_Only, true);
				return false;
			else
				self.msgBox(app.getErrorString (XLAT_Road_Exit_Error2), app.getErrorString(Error), MsgBox_OK_Only, true);
				return false;	
			endif;
		endif;	
	endif;
	
	if not invalidJob and theRoadJob &lt;&gt; null then
		visit := theRoadJob.CM_RoadJob.myVehicleVisit;
	endif;

	if not invalidJob and theRoadJob &lt;&gt; null then
		// if the vehicle is going out a gate that has a p-check location then 
		if not self.doProcessRoadExit_CheckLocn (truck, false) then
			return false;
		endif;
		if theRoadJob.isTurnAroundJob and truck &lt;&gt; null then
			// if turnaround defferred update of deleted TIs transactions crashes
			app.myTrxDA.trxVehicleRoadExit(truck, app.myPassport);
		else	
			//app.myTrxDA.trxRoadExit(theRoadJob, app.myPassport);			//16.02.2024 navnk30 #62414
			app.myTrxDA.trxRoadExit(theRoadJob, null, app.myPassport);		//16.02.2024 navnk30 #62414
		endif;
		
	elseif not invalidJob and truck &lt;&gt; null then
		// if the vehicle is going out a gate that has a p-check location then 
		if not self.doProcessRoadExit_CheckLocn (truck, false) then
			return false;
		endif;
		
		app.myTrxDA.trxVehicleRoadExit(truck, app.myPassport);
	
	endif;
	
	if (not app.myPassport.trxCompletedOK) then
		//errorMess := app.myPassport.getErrorsAsString;
		errorMess := app.myPassport.getAllErrorsWarningsAsString;	// 24732 03/2011 show warnings as well as errors
		self.msgBox(errorMess, app.getErrorString(Error), MsgBox_OK_Only, true);
		return false;
	else
		//08 Mar 2010 NDL	Par 22680
		printReceipt := self.myTerminal.getConfig(GateReceiptRequired).Boolean;		// PAR 29603
		if visit &lt;&gt; null and printReceipt then
			controller := self.myMobileGenericAgent.myGateAreaLaneController;
			if controller &lt;&gt; null then
				thePrinter := controller.getPrinter();
			endif;
			
			if thePrinter = null then
				errorMess := app.getErrorString1(Need_Server_Printer, controller.getFullId);
				self.msgBox(errorMess, app.getErrorString(Printing_error), MsgBox_OK_Only, true);
			
			else
				create printers transient;
				self.getServerPrinters( printers );

				if not printers.includes( thePrinter.physicalPrinterName.trimBlanks ) then
					errorMess := app.getErrorString2(Unknown_Server_Printer, thePrinter.physicalPrinterName.trimBlanks, controller.getFullId);
					self.msgBox(errorMess, app.getErrorString(Printing_error), MsgBox_OK_Only, true);
						
				else
					 //epr TFS 2401 22/7/16 use physical name
					visit.printRoadReceipt(	null, null, thePrinter.physicalPrinterName );	//14 Dec 2013	NDL	Par 33184
					if (not app.myPassport.trxCompletedOK) then
						//errorMess := app.myPassport.getErrorsAsString;
						errorMess := app.myPassport.getAllErrorsWarningsAsString;	// 10 Aug 2012	NDL	Par 29885
						self.msgBox(errorMess, app.getErrorString(Error), MsgBox_OK_Only, true);
					endif;
					
				endif;
			
			endif;
			
		endif;
		
		return true;
		
	endif;
	
epilog

	delete printers;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doResizeControls" id="5060ee02-3cce-4eff-8d2d-820b752422c2">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 February 2015	cnwndl1	Initial creation

*/

vars

	index : Integer;
	menuButton : MOB_Button;
	buttonWidth : Real;
	buttonHeight : Integer;
	buttonTop : Integer;
	cTop : Real;
	stdWidth : Real;
	cHeight : Real;

begin

	self.setResizeableMarginAndFontSize();
	buttonHeight := self.getScrollingButtonHeight();
	
	cTop := self.resizedMargin;
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
	cHeight := (self.clientHeight - cTop - self.getCMDButtonsHeight() - self.resizedMargin - self.resizedMargin);
	
	self.frmCargo.move(	self.resizedMargin,
						cTop,
						stdWidth,
						cHeight
						);
						
	self.lblNoCargo.move(	self.resizedMargin,
							self.resizedMargin,
							self.frmCargo.width - self.resizedMargin - self.resizedMargin,
							buttonHeight - self.resizedMargin - self.resizedMargin
							);
	
	buttonWidth := getButtonWidthSetScrollBar( self.numButtons, self.frmCargo, buttonHeight, self.scrCargo );
	
	buttonTop := self.resizedMargin - 1;
	foreach index in 1 to self.numButtons do
		menuButton := self.btnMenuTemplate.getControl( index ).MOB_Button;
		if menuButton &lt;&gt; null then
			menuButton.width := buttonWidth;
			menuButton.height := buttonHeight;
			menuButton.top := buttonTop;
			menuButton.fontSize := self.btnMenuTemplate.fontSize;	//07 Apr 2015	NDL	Par 35990
			buttonTop := buttonTop + buttonHeight + self.resizedMargin;
		endif;
	endforeach;
						
	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getServerPrinters" id="60d175f2-9d06-41e4-96ee-c7e9d818a578">
        <executionLocation>server</executionLocation>
        <source>getServerPrinters( _printers : StringArray input ) serverExecution;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 March 2010	cnwndl1	Initial creation

*/

vars

begin

	app.printer.getAllPrinters(_printers);

epilog

end;</source>
        <Parameter name="_printers" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="handleBtnOne" id="dc7d0ed8-59d7-40fc-89c0-a2ef74cf76de">
        <updating/>
        <source>handleBtnOne() updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25/01/2010	cnwndl1	Initial creation	CCMS MES 1005
08/03/2010	cnwdap1	PAR #22656 retain gate lane controller so MOB_HHGateCheckTruck form redisplays the same lane
*/
vars

	errorMess : String;
		
begin
	// user clicked 'Yard';
	
	if self.myMobileGenericAgent.inward then
	
		if not self.myMobileGenericAgent.cargoIsAllConfirmed then
			self.btnOne.enabled := false;
			errorMess := app.getErrorString(Some_cargo_unconfirmed);
			self.msgBox(errorMess ,app.getErrorString(Error), MsgBox_OK_Only, true);
			return;
		endif;
		
		// now move truck to yard...
		if not self.myMobileGenericAgent.moveTruckToYard(errorMess) then
			self.msgBox(errorMess ,app.getErrorString(Error), MsgBox_OK_Only, true);
			return;
		endif;
	
	elseif not self.myMobileGenericAgent.inward then
	
		if not self.doCompleteOutward() then
			return;
		endif;
		
	endif;
	
	// if successfull 
	//self.myHandHeldCheckerAgent.setGateAreaLaneController( null, true ); // PAR #22656 leave lane controller so we redisplay the same lane on the gate form
	self.myMobileGenericAgent.allCargoCheckItemSelections.purge;
	self.doBackButtonClick();

epilog
	
end;</source>
        <access>protected</access>
    </JadeMethod>
