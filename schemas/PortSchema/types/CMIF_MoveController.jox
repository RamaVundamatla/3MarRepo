    <JadeMethod name="setHazardLocationsPreMove" id="3ca5cf04-17d9-4e39-a660-d40d8edcf987">
        <source>setHazardLocationsPreMove() protected;
/*
----------   ----------  --------------------------------------------------
Created:	23 November 2006 By cnwth2

Purpose:	gdansk hazardous move logic:
			allHazardLocations is inversed to CM_LocationsController.allHazardTIs to act 
			like a 'hazard footprint' for the TI, so clear it now as it's going somewhere else
			see setHazardLocationsPostMove for re-population

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	ti			: CM_TrackedItem;
begin
	//no check for isHazardous here. If the tracked item has been not non-hazardous
	//and this collection not updated for some reason when that happened, this will
	//mean moving it will provide a back-up means to clear it's hazard footprint.
	/*
	self.myTrackedItem.allHazardLocations.clear();
	foreach ti in self.allOtherTrackedItems do
		ti.allHazardLocations.clear();
	endforeach;
	*/
end;


</source>
