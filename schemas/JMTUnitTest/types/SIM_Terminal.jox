    <JadeMethod name="add" id="4bb2cdb5-52d7-4d77-8ca9-16dfcf59299f">
        <updating/>
        <source>add(_dsl: UT_DSL; _prefix: String; _maxRunMinutes: Integer; _logLevel: Integer) updating;

vars

begin
	self.myDSL := _dsl;
	self.mySIMTerminal := self;
	self.logLevel := _logLevel;
	self.logMessage(LOG_BRIEF, "Add Terminal");
	self.prefix := _prefix;
	self.maxRunMinutes := _maxRunMinutes;
	self.allOperators.add(self.dsl.getOperator(self.dsl.getProfileSetting(UT_Profile.P_OPERATOR).asString));

	self.dsl.setTerminalConfig(IsSubTerminalsOn, false);
epilog

end;</source>
        <Parameter name="_dsl" type="UT_DSL"/>
        <Parameter name="_prefix" type="String"/>
        <Parameter name="_maxRunMinutes" type="Integer"/>
        <Parameter name="_logLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addBlockStacks" id="b7743b62-7a20-45fe-879d-ec7cd61a4100">
        <updating/>
        <source>addBlockStacks(_name: String; _count: Integer; _capacity: Integer) updating;

vars
	i: Integer;
	name: String;
begin
	foreach i in 1 to _count do
		name := self.prefix&amp;_name&amp;i.String;
		self.allTerminalAreas[name] := self.dsl.addBlockStack(name, _capacity, null);
	endforeach;
epilog

end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_count" type="Integer"/>
        <Parameter name="_capacity" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addCranes" id="8e9bf230-b3e2-430c-beb0-8a4f1bdd499c">
        <source>addCranes(_name: String; _count, _min, _max: Integer);

vars
	i: Integer;
	crane: CM_Crane;
	simCrane: SIM_Crane;
	name: String;
begin
	foreach i in 1 to _count do
		name := _name&amp;i.String;
		crane := self.dsl.getCrane(name);
		create simCrane;
		simCrane.mySIMTerminal := self;
		simCrane.myMachine := crane;
		simCrane.minTravelTime := _min;
		simCrane.maxTravelTime := _max;
		simCrane.machineType := SIM_Machine.MACHINE_CRANE;
		self.allMachines[name] := simCrane;
		self.allTerminalAreas[crane.transferArea.id] := crane.transferArea;
	endforeach;
epilog

end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_count" type="Integer"/>
        <Parameter name="_min" type="Integer"/>
        <Parameter name="_max" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addForklifts" id="c617136a-2fbd-4349-b289-7dd7b20b5f10">
        <source>addForklifts(_name: String; _count, _min, _max: Integer);

vars
	i, device: Integer;
	tas: StringArray;
	ta: Object;
	name: String;
	simMachine: SIM_Machine;
begin
	create tas transient;
	foreach ta in self.allTerminalAreas do
		tas.add(ta.CM_TerminalArea.id);
	endforeach;

	device := 90 + allMachines.size;
	foreach i in 1 to _count do
		name := self.prefix&amp;_name&amp; i.String;
		create simMachine;
		simMachine.mySIMTerminal := self;
		simMachine.minTravelTime := _min;
		simMachine.maxTravelTime := _max;
		simMachine.machineType := SIM_Machine.MACHINE_LIFTER;
		simMachine.myMachine := self.dsl.addForkLift(name, device+i, tas, null);
		self.allMachines[name] := simMachine;
	endforeach;

epilog
	delete tas;

end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_count" type="Integer"/>
        <Parameter name="_min" type="Integer"/>
        <Parameter name="_max" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addIMVs" id="8755064e-1053-4f55-bcc9-0b7dbb3dc968">
        <source>addIMVs(_name: String; _count, _min, _max: Integer);

vars
	i, device: Integer;
	tas: StringArray;
	ta: Object;
	name: String;
	simMachine: SIM_Machine;
begin
	create tas transient;
	foreach ta in self.allTerminalAreas do
		tas.add(ta.CM_TerminalArea.id);
	endforeach;

	device := 90 + allMachines.size;
	foreach i in 1 to _count do
		name := self.prefix&amp;_name&amp; i.String;
		create simMachine;
		simMachine.mySIMTerminal := self;
		simMachine.minTravelTime := _min;
		simMachine.maxTravelTime := _max;
		simMachine.machineType := SIM_Machine.MACHINE_MOVER;
		simMachine.myMachine := self.dsl.addIMV(name, device+i, tas, null);
		self.allMachines[name] := simMachine;
	endforeach;

epilog
	delete tas;

end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_count" type="Integer"/>
        <Parameter name="_min" type="Integer"/>
        <Parameter name="_max" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addMachineRules" id="eea3d407-cefc-4300-aa2e-aa109d3bf2a1">
        <source>addMachineRules(_crane: String; _rule: String);

vars
	cranes: StringArray;
	crane: String;
	machine: SIM_Machine;
	ta: Object;
	craneTa: CM_TerminalArea;
	rule1, rule2: Integer;
begin

	if _rule = MACHINE_RULE_FORKLIFT then
		rule1 := RTMoveMethod_24;
		rule2 := RTMoveMethod_24;
	elseif _rule = MACHINE_RULE_IMV then
		rule1 := RTMoveMethod_7;
		rule2 := RTMoveMethod_1;
	endif;		
	
	cranes := _crane.getTokens();
	self.dsl.opts.addAssoc("FullMoveQueueing", true);
	foreach crane in cranes do
		machine := self.getMachine(crane);
		if machine.isCrane then
			craneTa := machine.myMachine.CM_Crane.transferArea;
			foreach ta in self.allTerminalAreas do
				if ta.CM_TerminalArea.isTransferArea then
					continue;
				endif;
				self.dsl.addMachineRule(craneTa, ta.CM_TerminalArea, rule1);
				self.dsl.addMachineRule(ta.CM_TerminalArea, craneTa, rule2);
			endforeach;
		endif;
	endforeach;
epilog
	delete cranes;
end;</source>
        <Parameter name="_crane" type="String"/>
        <Parameter name="_rule" type="String"/>
    </JadeMethod>
    <JadeMethod name="addTask" id="228f6268-03ce-4b2a-a288-5d5e3685f6e8">
        <source>addTask(_simTask: SIM_Task; _task: CM_RTQueueTask): Integer;
vars
begin
	if _task &lt;&gt; null then
		self.allTasksByTaskDict[_task] := _simTask;
	endif;
	self.allTasks.add(_simTask);
	return self.allTasks.size;
epilog

end;</source>
        <Parameter name="_simTask" type="SIM_Task"/>
        <Parameter name="_task" type="CM_RTQueueTask"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addWork" id="e255b6f5-3161-48fa-89ff-21f0151162f4">
        <source>addWork(_wle: CM_WorkListEntry);

vars
	queueEntry: CM_RTQueueEntry;
	task: CM_RTQueueTask;
	simTask, simPrevTask: SIM_Task;
	taskType: String;
	machineType: String;
	id: Integer;
	source, target: CM_LocationsController;
begin

	foreach queueEntry in _wle.allRTQueueEntries do
		source := queueEntry.allTasks.first.sourceLocation;
		if source &lt;&gt; null and source.isVoyageController then
			create simTask;
			id := self.addTask(simTask, null);
			simTask.add(self, id, SIM_Machine.MACHINE_CRANE, queueEntry.allTasks.first, SIM_Task.TASK_TYPE_PICKUP,  simPrevTask);
			simPrevTask := simTask;

			create simTask;
			id := self.addTask(simTask, null);
			simTask.add(self, id, SIM_Machine.MACHINE_CRANE, queueEntry.allTasks.first, SIM_Task.TASK_TYPE_SETDOWN, simPrevTask);
			simPrevTask := simTask;
		endif;

		foreach task in queueEntry.allTasks do
			create simTask;
			if task.isPickUp then
				taskType := SIM_Task.TASK_TYPE_PICKUP;
				machineType := SIM_Machine.MACHINE_LIFTER;
			elseif task.isSetDown then
				taskType := SIM_Task.TASK_TYPE_SETDOWN;
				machineType := SIM_Machine.MACHINE_LIFTER;
			else
				taskType := SIM_Task.TASK_TYPE_MOVE;
				machineType := SIM_Machine.MACHINE_MOVER;
			endif;
			
			id := self.addTask(simTask, task);
			simTask.add(self, id, machineType, task, taskType, simPrevTask);
			simPrevTask := simTask;
		endforeach;

		target := queueEntry.allTasks.first.targetLocation;
		if target &lt;&gt; null and target.isVoyageController then
			create simTask;
			id := self.addTask(simTask, null);
			simTask.add(self, id, SIM_Machine.MACHINE_CRANE, queueEntry.allTasks.first, SIM_Task.TASK_TYPE_PICKUP, simPrevTask);
			simPrevTask := simTask;

			create simTask;
			id := self.addTask(simTask, null);
			simTask.add(self, id, SIM_Machine.MACHINE_CRANE, queueEntry.allTasks.first, SIM_Task.TASK_TYPE_SETDOWN, simPrevTask);
			simPrevTask := simTask;
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="addWorkForVoyage" id="7b66fc5e-8412-439e-9a8e-3991a3584a46">
        <source>addWorkForVoyage(_voyage: SIM_Voyage);
vars
	wles: CM_WLEArray;
	wle: CM_WorkListEntry;
begin
	create wles transient;
	_voyage.myVoyage.getAllWLEs(wles);
	foreach wle in wles do
		self.addWork(wle);
	endforeach;
epilog
	delete wles;
end;</source>
        <Parameter name="_voyage" type="SIM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="delete" id="58564da2-7ec8-41ef-9b8e-2874311aaa7f">
        <updating/>
        <source>delete() updating;

vars
	taskArray: Object;
begin
	self.allMachines.purge;
	self.allTasks.purge;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="displayTasks" id="58ae1dc1-3cff-459b-90b5-882b6e3877db">
        <source>displayTasks();

vars
	task: Object;
begin
	foreach task in self.allTasks do
		self.logMessage(LOG_FULL, task.SIM_Task.getDisplay);
		if task.SIM_Task.isLast then
			self.logMessage(LOG_FULL, "");
		endif;
		
	endforeach;
epilog

end;</source>
    </JadeMethod>
