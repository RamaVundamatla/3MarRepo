    <JadeMethod name="alreadyIncludesTiTodo" id="21c7630f-e127-417f-bee0-649017349e67">
        <source>alreadyIncludesTiTodo( _ti : CM_TrackedItem; _toDoDesc : CM_ToDoTaskDesc ) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 March 2019	jlgndl1	Initial creation	TFS 43405
15 Mar 2023  	navhl20 ChangeRequest 56614:[56615] EUP - Allow Multi ToDo Tasks Description on Cargo ToDo Work Order
*/

vars

	wodToDo : CM_WodToDo;
	tiToDo : CM_TiToDoTask;

begin

	if not self.allToDoRequests.includesToDo( _toDoDesc ) then
		return false;
	endif;
	
	foreach wodToDo in self.allToDoRequests do
		//if wodToDo.myToDoTaskDesc &lt;&gt; _toDoDesc then					//15.3.2023 navhl20	#56614[56615]
		if not wodToDo.allToDoTasksDescs.includes(_toDoDesc) then		//15.3.2023 navhl20	#56614[56615]
			continue;
		endif;
		foreach tiToDo in wodToDo.allToDoTasks do
			if tiToDo.myTrackedItem = _ti then
				return true;
			endif;
		endforeach;
	endforeach;
	
	return false;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_toDoDesc" type="CM_ToDoTaskDesc"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
