    <JadeMethod name="getAuditForString" id="d7aa7072-ac08-4062-b42f-3723b0234406">
        <source>getAuditForString( _propertyName, _propertyValue : String ) : String;

/*

Purpose:			Format audit string for a property

Parameters:			Property name and value in string format

Return Value:		Audit string


Date			Who		Reason
04 August 2008	consw1	Initial creation

*/

vars

begin
	return _propertyName &amp; AuditStringSeparator &amp; _propertyValue.length.String &amp; AuditStringSeparator &amp; _propertyValue &amp; AuditStringSeparator;
epilog

end;</source>
        <Parameter name="_propertyName" type="String"/>
        <Parameter name="_propertyValue" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="f54b6019-2def-4711-9df2-ab7cf45c4c13">
        <source>getAuditText(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
01 August 2008	consw1	Initial creation

*/

vars
	ct : CM_YACriteriaType;
	i : Integer;
	pr : CM_YAPriority;
	txt	: String;
	txtDesc : String;
	
begin
	txt[10000] := '*';
	txt := null;
	txt := inheritMethod();
	
	txt := txt &amp; self.getAuditForString( AutoPlanAllowLogging, self.myTerminal.isAutoPlanAllowLogging().String);
	txt := txt &amp; self.getAuditForString( AutoPlanEnabled, self.myTerminal.isAutoPlanningEnabled().String);
	txt := txt &amp; self.getAuditForString( AutoPlanGenerateSwapForYardInt, self.myTerminal.isAutoPlanGenSwapForYardInt().String);
	txt := txt &amp; self.getAuditForString( AutoPlanGenerateSwapJob, self.myTerminal.isAutoPlanGenerateSwapJob().String);
	txt := txt &amp; self.getAuditForString( AutoPlanPreNotiEmail, self.myTerminal.getAutoPlanPreNotifyEmail());
	txt := txt &amp; self.getAuditForString( AutoPlanPreNotifications, self.myTerminal.isAutoPlanPreNotifications().String);
	txt := txt &amp; self.getAuditForString( AutoPlanUseOverstowRules, self.myTerminal.isAutoPlanUseOverstowRules().String);
	txt := txt &amp; self.getAuditForString( AutoPlanUserRestrictions, self.myTerminal.isAutoPlanUserRestrictions().String);
	txt := txt &amp; self.getAuditForString( AutoPlanYAGroupedBlocks, self.myTerminal.isAutoPlanYAGroupedBlocks().String);
	txt := txt &amp; self.getAuditForString( FillOption, app.yaFillOptionToString(self.myTerminal.getFillOption()) );
	txt := txt &amp; self.getAuditForString( UseBestPickDirector, self.myTerminal.isAutoPlanUseBestPickDirector().String ); //cnwrd1 par 28628
	
	//  Default Criteria for New Template
	
	foreach ct in self.allDefaultCriteriaTypes do
		if txtDesc &lt;&gt; null then
			txtDesc := txtDesc &amp; ", ";
		endif;
		txtDesc := txtDesc &amp; ct.description;
	endforeach;

	txt := txt &amp; 'Template Default Criteria ' &amp; AuditStringSeparator &amp; txtDesc.length.String &amp; AuditStringSeparator &amp; txtDesc &amp; AuditStringSeparator;

	//  Default Criteria for Search

	txtDesc := null;
	
	foreach ct in self.allDefaultSearchCriteriaTypes do
		if txtDesc &lt;&gt; null then
			txtDesc := txtDesc &amp; ", ";
		endif;
		txtDesc := txtDesc &amp; ct.description;
	endforeach;

	txt := txt &amp; 'Search Default Criteria ' &amp; AuditStringSeparator &amp; txtDesc.length.String &amp; AuditStringSeparator &amp; txtDesc &amp; AuditStringSeparator;

	//  RT Criteria

	txtDesc := null;
	
	foreach ct in self.myTerminal.allRTAllocationCriteriaTypes do
		if txtDesc &lt;&gt; null then
			txtDesc := txtDesc &amp; ", ";
		endif;
		txtDesc := txtDesc &amp; ct.description;
	endforeach;

	txt := txt &amp; 'Search Default Criteria ' &amp; AuditStringSeparator &amp; txtDesc.length.String &amp; AuditStringSeparator &amp; txtDesc &amp; AuditStringSeparator;

	//  Criteria Priorities

	foreach pr in self.myTerminal.allYAPriorities do
		i := i + 1;
		txtDesc := pr.getListDisplay;
		txt := txt &amp; 'Criteria Priority' &amp; i.padLeadingWith(" ",3) &amp; AuditStringSeparator &amp; txtDesc.length.String &amp; AuditStringSeparator &amp; txtDesc &amp; AuditStringSeparator;
	endforeach;

	return txt;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
