    <JadeMethod name="setInitialControlValues" id="8b3fec15-776f-4a1c-b086-ee23e8570019">
        <updating/>
        <source>setInitialControlValues() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 August 2012	cnwndl1	Initial creation
// 11 Apr 2017	cnwma1	TFS 3852 ADP - Negative Invoice Rate Lines
*/

vars

//	agent : CM_CashInvoiceProformaAgent;
//	availTrxTypes : CM_TransactionTypeByType;
	trxType : CM_TransactionType;
	index : Integer;
	manInvLine : CM_InvoiceLine;
	code : String;
	charge : CM_Charge;
begin
	// TFS 45953 deleted old code
	if self.myCashPayment &lt;&gt; null then // TFS 44275
//			self.lblExtras.caption := "Extra transactions for '" &amp; self.myCashPayment.myTrackedItem.id &amp; "' Pro Forma"; // TFS 44275
			self.lblExtrasManual.caption := "Update Extra Cash Payment '" &amp; self.myCashPayment.myTrackedItem.id &amp;"'";  // TFS 44275
	elseif self.myTrackedItem &lt;&gt; null then // TFS 44275
//			self.lblExtras.caption := "Extra transactions for '" &amp; self.myTrackedItem.id &amp; "' Pro Forma"; // TFS 44275
			self.lblExtrasManual.caption := "New Extra Cash Payment for '" &amp; self.myTrackedItem.id &amp;"'";  // TFS 44275

	endif;
	
	self.doBuildInvLineTypes();			  //13/04/2017 cnwma1 TFS #3852
	
	//29 Jan 2019	NDL	TFS 42940
	self.optQuantity.value := true;
	/* // TFS 45953
	if self.myProformaAgent &lt;&gt; null then // TFS 44275
		manInvLine:=self.myProformaAgent.getManualProforma();
		if manInvLine &lt;&gt; null then
			self.cmbInvLineType.listIndex := self.cmbInvLineType.findObject(manInvLine.invoiceLineDesc);
			self.txtNarration.text := manInvLine.remarks;
			charge := manInvLine.charges.first;
			if charge &lt;&gt; null then
				self.txtFinancial.text := charge.total.asStringJMT;
				self.txtQtyManual.text := manInvLine.quantity.asStringJMT;
				if charge.overridden then
					self.optFinancial.value := true;
				endif;
			endif;
		else
			self.changeOption( true );
		endif;
	else
	*/
	if self.myCashPayment &lt;&gt; null then // TFS 44275
		manInvLine:=self.myCashPayment.myInvoiceLine;
		if manInvLine &lt;&gt; null then
			self.cmbInvLineType.listIndex := self.cmbInvLineType.findObject(manInvLine.invoiceLineDesc);
			self.txtNarration.text := manInvLine.remarks;
			charge := manInvLine.charges.first;
			if charge &lt;&gt; null then
				self.txtFinancial.text := charge.total.asStringJMT;
				self.txtQtyManual.text := manInvLine.quantity.asStringJMT;
				if charge.overridden then
					self.optFinancial.value := true;
				endif;
			endif;
			self.changeOption( false );
		else
			self.changeOption( true );
		endif;
	else
		self.changeOption( true );
	endif;

	self.minimumHeight := 550; //13/04/2017 cnwma1 TFS #3852
	self.minimumWidth := 510; //13/04/2017 cnwma1 TFS #3852
	/*
	create agent transient;
	create availTrxTypes transient;
	agent.getAvailTrxTypesFromRoot(availTrxTypes);
	
	foreach trxType in availTrxTypes do
		index := self.lstAvail.addItem( trxType.description );
		self.lstAvail.itemObject[index] := trxType;
	endforeach;
	
	foreach trxType in self.selectedTransactions do
		if availTrxTypes.includes( trxType ) then
			index := self.lstSelected.addItem( trxType.description );
			self.lstSelected.itemObject[index] := trxType;
		endif;
	endforeach;
	*/


epilog

//	delete agent;
//	delete availTrxTypes;

end;</source>
    </JadeMethod>
