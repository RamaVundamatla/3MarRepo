    <JadeMethod name="scrollControls" id="c5aa8d7a-1709-4a06-84f8-f7a03d4ccf40">
        <source>scrollControls(pDirection: Integer; pValue: Integer);
//--------------------------------------------------
// Created:	06 August 2004 By: cnwgd1
//--------------------------------------------------
vars
	tmpWharfDrawControl	: HMS_WharfDrawControl;
begin
