    <JadeMethod name="doProcessEDIItem" id="ad8773d2-f154-40fc-a27c-ca075ad86dc8">
        <source>doProcessEDIItem() protected;
/*
Purpose;	Set status of selected EDI Tracked Item to Unprocessed

Date		Who		Reason
31 Jul 2013	cnwcs5	CCMS POL 2221 / par 32094(2)
*/
vars
	obj		:Object;
	ediTI : CM_EDITrackedItem;
	coll 	:CM_EDITISet;
	result	:Integer;
begin
	
	
	
	create coll transient;

	foreach obj in self.tblData.allSelectedObjects do
		if not obj.isKindOf (CM_EDITrackedItem) then
			continue;
		endif;
		
		coll.add (obj.CM_EDITrackedItem);
	endforeach;
		
	while true do
		app.myTrxUA.trxEDIProcessEDITrackedItem (coll, app.myPassport);
		
		if not app.myPassport.trxCompletedOK() then
			result := app.showErrorWarningDialog( app.getErrorString(Road_exit), app.myPassport, ErrWarnMode_AddUpdate+ ErrWarnMode_CanAckWarnings);
			
			if app.myPassport.noErrors and
				result = IDOK then
				
				app.myPassport.warningsAcknowledged     := true;
				continue;
			endif;
		endif;

		break;
	endwhile;
	
	
epilog
	delete coll;
end;</source>
        <access>protected</access>
    </JadeMethod>
