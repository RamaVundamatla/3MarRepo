    <JadeMethod name="getWodTotalRequested" id="8a8902d0-f991-4e3a-b96c-85df40d177da">
        <source>getWodTotalRequested(_qty : Boolean): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 Oct 2023	navrv30	ChangeRequest 60458: EUP - Change Work Order Progress to be based on QTY or WT
17 Apr 2024 navhl20 ChangeRequest 63251: FR | 53729 - Delivery Dispatch screen - Further issues and Remedial work
28 May 2024 navma1	Bug 64224: MTN - DeadLocks Caused by Future Actors
*/
vars
	qty 	: Integer;
	ti	 	: CM_TrackedItem;
	wt   	: Decimal[14,4];
	invalid	: Boolean;
begin
	on Exception do app.handleDeletedObject(exception, ti, invalid);
	if _qty then
		foreach  ti in self.allPackingTIs  discreteLock do  		//28.05.2024 navma1 #64224
			invalid := false;
			ti.edition;
			if invalid then
				continue;
			endif;
			
			qty := qty + ti.totalQuantity;
		endforeach;
		return qty;
	else
		foreach  ti in self.allPackingTIs discreteLock do  		//28.05.2024 navma1 #64224  	
			invalid := false;
			ti.edition;
			if invalid then
				continue;
			endif;
			
			wt := wt + ti.totalWeight;
		endforeach;
		return wt;
	endif;
epilog

end;</source>
        <Parameter name="_qty" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="isOKToDelete" id="6da3a58b-68d6-4192-9959-3b70ab4d8c4c">
        <source>isOKToDelete(): Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 19/06/2018	jlgdap1		Initial creation TFS 38560 PEL1 Voyage Work Orders fix ups
//12 Jan 2023	navma1  	ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
//
vars

begin
	return  self.requiredByDT = null     and 
			self.allPackingTIs.isEmpty   and 
			self.commodity = null 		 and 
			self.contentsStatus = null   and 
			self.imexStatus = null 		 and
			self.myBookingRef = null 	 and
			self.myConsignee = null 	 and 
			self.myConsignor = null 	 and 
			self.myContentsStatus = null and 
			self.myDischargePort = null  and 
			self.myOperator = null 		 and 
			//self.mySource = null 		 and					//12.01.2023 navma1 #56141 Task#56147
			self.mySubTerminal = null 	 and
			self.myVoyage = null;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
