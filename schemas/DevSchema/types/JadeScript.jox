    <JadeMethod name="kpdGenerateWSWrapperClass" id="d47fa8fb-0a59-4ad1-98d3-3783f73b6a11">
        <source>kpdGenerateWSWrapperClass();
/*

Purpose:			Generate the bones of a new wrapper class for interfacing with an external web service, based
					on an imported web service class.

Parameters:			None

Return Value:		None

Date		Who		Reason
05 Jun 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

constants
	// Modify these values per series of classes to control generation
	OutputDirectory	= "c:\temp\CodeGeneration\";
	InputSchema		= "PortSchema";
	OutputSchema	= "PortSchema";
	OutputSuperschema = "BaseSchema";
	
	// Modify these values per class to control generation
	InputClass		= "SAP19_DataKinerja_OB_DT_item";
	OutputClass		= "CMIF_SAPDataKinerjaItemX";
	OutputSuperclass = "CMIF_SAPWSProxyObject";
	UsedAsRequest	= true;						// true if this class is a request parameter

vars
	schemaFile		: File;
	scmContents		: String;
	user			: String;
	pos				: Integer;
	inputSchema		: Schema;
	inputClass		: Class;
	genTimestamp	: String;
	longDate		: String;
	attrDefinitions	: String;
	copyToRequest	: String;
	copyFromResponse : String;
	props			: PropertyColl;
	property		: Property;
	propName		: String;
	propCount		: Integer;
	
begin
	create schemaFile;
	schemaFile.openOutput(OutputDirectory &amp; OutputClass &amp; ".scm");
	
	if UsedAsRequest then
		scmContents := self.kpdGenerateWSGetReqTemplate();
	else
		scmContents := self.kpdGenerateWSGetRespTemplate();
	endif;
	
	// Set up variables for substitution
	pos := 1;
	user := process.userCode.scanUntil("_", pos);
	genTimestamp := app.actualTimeServer.literalFormat();
	longDate := app.actualTimeServer.date.format("dd MMM yyy");
	
	inputSchema := rootSchema.getSchema(InputSchema);
	if inputSchema = null then
		write "&gt;&gt;&gt;&gt; Error InputSchema not found";
		return;
	endif;
	
	inputClass := inputSchema.getClass(InputClass);
	if inputClass = null then
		write "&gt;&gt;&gt;&gt; Error InputClass not found";
		return;
	endif;
	
	write "Generating code for " &amp; OutputClass;
	
	props := inputClass.allProperties;
	foreach property in props where property.access = null do		// only public properties
		
		propName := property.name;
		if propName[1:1] = "_" then			// Ignore system properties
			continue;
		endif;
		
		if propName = "user" or				// Ignore user and password as these will be handled by the calling framework
		   propName = "password" then
			continue;
		endif;		
		
		if property.type.isKindOf(CollClass) then					// Assume collections are exclusive
			
			write "&gt;&gt;   " &amp; inputClass.name &amp; " has a collection property " &amp; propName &amp; " that requires manual conversion";
			
			copyToRequest := copyToRequest &amp; "// manual population of " &amp; propName &amp; " required" &amp; CrLf;
			copyFromResponse := copyFromResponse &amp; "// manual population of collection from " &amp; propName &amp; " required" &amp; CrLf;
			
		elseif property.type.inheritsFrom(ImportedWebServiceProxy) then

			write "&gt;&gt;   " &amp; inputClass.name &amp; " has an object property " &amp; propName &amp; " that requires manual conversion";

			copyToRequest := copyToRequest &amp; "// manual population of " &amp; propName &amp; " required" &amp; CrLf;
			copyFromResponse := copyFromResponse &amp; "// manual population of object created from " &amp; propName &amp; " required" &amp; CrLf;

		else
			propCount := propCount + 1;
			attrDefinitions := attrDefinitions &amp; propName &amp; ": " &amp; property.type.name;
			if property.type.name = String.name then
				attrDefinitions := attrDefinitions &amp; " subId = " &amp; propCount.String &amp; ",";
			endif;
			attrDefinitions := attrDefinitions &amp; " number = " &amp; propCount.String &amp;
							   ", ordinal = " &amp; propCount.String &amp; ";" &amp; CrLf;
			attrDefinitions := attrDefinitions &amp; 'setModifiedTimeStamp "' &amp; user &amp; '" "7.1.08" 7 ' &amp; 
							   genTimestamp &amp; ";" &amp; CrLf;
			
			copyToRequest := copyToRequest &amp; Tab &amp; "_realRequest." &amp; propName &amp; " := self." &amp; propName &amp; ";" &amp; CrLf;
			copyFromResponse := copyFromResponse &amp; Tab &amp; "self." &amp; propName &amp; " := _realWSObject." &amp; propName &amp; ";" &amp; CrLf;
		
		endif;
	endforeach;

	// Perform all the substitutions
	scmContents := scmContents.replace('&lt;&lt;OutputSchema&gt;&gt;', OutputSchema);
	scmContents := scmContents.replace('&lt;&lt;OutputSuperschema&gt;&gt;', OutputSuperschema);
	scmContents := scmContents.replace('&lt;&lt;OutputClass&gt;&gt;', OutputClass);
	scmContents := scmContents.replace('&lt;&lt;OutputSuperclass&gt;&gt;', OutputSuperclass);
	scmContents := scmContents.replace('&lt;&lt;GenerationTimestamp&gt;&gt;', genTimestamp);
	scmContents := scmContents.replace('&lt;&lt;User&gt;&gt;', user);
	scmContents := scmContents.replace('&lt;&lt;AttributeDefinitions&gt;&gt;', attrDefinitions);
	scmContents := scmContents.replace('&lt;&lt;InputClass&gt;&gt;', InputClass);
	scmContents := scmContents.replace('&lt;&lt;InputClass&gt;&gt;', InputClass);
	scmContents := scmContents.replace('&lt;&lt;LongDate&gt;&gt;', longDate);
	scmContents := scmContents.replace('&lt;&lt;CopyAttributesFromResponse&gt;&gt;', copyFromResponse);
	scmContents := scmContents.replace('&lt;&lt;CopyAttributesToRequest&gt;&gt;', copyToRequest);
	
	schemaFile.writeString(scmContents);
	schemaFile.close();
	
epilog
	delete schemaFile;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="kpdGenerateWSWrapperTest" id="c5186717-7590-4927-a2d6-14c01e049be9">
        <source>kpdGenerateWSWrapperTest();
/*

Purpose:			Testing of the mapping code generation

Parameters:			

Return Value:		

Date		Who		Reason
08 June 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars
	cmif : CMIF_SAPPostBillInvReq;
	wso : SAP17_PostBilllnvoiceRequest_DT;
	objects : ObjectSet;
	transients : ObjectArray;
	
begin
	create cmif;
	cmif.populateWithTestingData();
	
	write cmif.returnAsXMLString;
	
	create objects transient;
	create wso;
	cmif.copyToRealWSObject(wso, objects);
	
	write wso.returnAsXMLString;
	
	delete cmif;
	delete wso;
	if objects &lt;&gt; null then
		objects.purge();
		delete objects;
	endif;
	
	create transients transient;
	ObjectArray.allProcessTransientInstances(transients, 0, true);
	transients.inspectModal();
		
epilog
	delete cmif;
	delete wso;
	if objects &lt;&gt; null then
		objects.purge();
		delete objects;
	endif;
	delete transients;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="kpdGetExportValueFromTI" id="0c09ead0-96c5-4c21-8f58-89f6885fe83a">
        <source>kpdGetExportValueFromTI(_ti : CM_TrackedItem;
						_propName : String) : String;
/*

Purpose:			Get the export data property for the passed in EDI Field propName from 
					the passed in TI

Parameters:			Tracked Item, Property name

Return Value:		String value

Date		Who		Reason
28 Sep 2012	cnwkpd1	PAR #30400 - SFW 1290 - Transaction EDI file type

*/

vars
	prop			: Property;
	meth			: Method;
	returnVal		: String;
	
begin
	if _propName = 'messageMode' then
		return "A";
	endif;
	if _propName = 'bol' then
		return _ti.billOfLading;
	endif;
	if _propName = 'bookingRef' then
		return _ti.bookingReference;
	endif;
	if _propName = 'breakBulkType' then
		if _ti.isKindOf(CM_BreakBulkGeneric) then
			return _ti.CM_BreakBulkGeneric.type;
		else
			return null;
		endif;
	endif;
	if _propName = 'product' then
		return _ti.getProductDescription;
	endif;
	if _propName = 'carrierCode' then
		return _ti.carrier;
	endif;
	if _propName = 'colour' then
		return null;
	endif;
	if _propName = 'commodityDescription' then
		return _ti.getCommodityShortDesc;
	endif;
	if _propName = 'customsAgent' then
		return _ti.getDisplayStringForAttribute(ETRow_CustomsAgent, true);
	endif;
	if _propName = 'sealCustoms' then
		return _ti.getDisplayStringForAttribute(ETRow_SealNumCustoms, true);
	endif;
	if _propName = 'generatorID' then
		return _ti.generatorId;
	endif;
	if _propName = 'generatorType' then
		return _ti.getDisplayStringForAttribute(ETRow_MyGeneratorType, true);
	endif;
	if _propName = 'hasRadio' then
		return _ti.getDisplayStringForAttribute(ETRow_HasRadio, true);
	endif;
	if _propName = 'hazardous' then
		return _ti.getDisplayStringForAttribute(ETRow_IsHazardous, true);
	endif;
	if _propName = 'heightString' then
		return _ti.getDisplayStringForAttribute(ETRow_HeightString, true);
	endif;
	if _propName = 'lengthString' then
		return _ti.getDisplayStringForAttribute(ETRow_ActualLength, true);
	endif;
	if _propName = 'sealNum' then
		return _ti.getDisplayStringForAttribute(ETRow_SealNum, true);
	endif;
	if _propName = 'overLengthBack' then
		return null;
	endif;
	if _propName = 'parentCargoID' then
		if _ti.isChild then
			return _ti.getParent.id;
		else
			return null;
		endif;
	endif;
	if _propName = 'parentCargoType' then
		if _ti.isChild then
			return _ti.getParent.getDisplayStringForAttribute(ETRow_CargoType, true);
		else
			return null;
		endif;
	endif;
	if _propName = 'preSlung' then
		return null;
	endif;
	if _propName = 'receiveDate' then
		return _ti.getDisplayStringForAttribute(ETRow_ReceivedTimeStamp, true);
	endif;
	if _propName = 'selfPropelled' then
		return _ti.getDisplayStringForAttribute(ETRow_IsSelfPropelled, true);
	endif;
	if _propName = 'sealShipper' then
		return _ti.getDisplayStringForAttribute(ETRow_SealNumShippers, true);
	endif;
	if _propName = 'trailerType' then
		return null;
	endif;
	if _propName = 'undgCode' then
		return null;
	endif;
	if _propName = 'sealNumberVent' then
		return _ti.getDisplayStringForAttribute(ETRow_SealNumVent, true);
	endif;
	if _propName = 'vent' then
		return _ti.getDisplayStringForAttribute(ETRow_Ventilation, true);
	endif;
	if _propName = 'wet' then
		return null;
	endif;
	if _propName = 'widthString' then
		return _ti.getDisplayStringForAttribute(ETRow_WidthString, true);
	endif;
	if _propName = 'temperature' then
		return _ti.getDisplayTemperature(false, true);
	endif;
	if _propName = 'humidity' then
		return _ti.humidityString();
	endif;
	if _propName = 'oxygen' then
		if _ti.isKindOf(CM_Container) then
			return _ti.CM_Container.oxygenString();
		else
			return null;
		endif;
	endif;
	if _propName = 'carbonDioxide' then
		if _ti.isKindOf(CM_Container) then
			return _ti.CM_Container.carbonDioxideString();
		else
			return null;
		endif;
	endif;
	
	prop := _ti.class().getPropertyInHTree(_propName);
	if prop &lt;&gt; null then
		return _ti.getPropertyValue(_propName).String;
	endif;
	
	meth := _ti.class().getMethodInHTree(_propName);
	if meth &lt;&gt; null then
		return _ti.sendMsg(_propName).String;
	endif;	
		
	write "if _propName = '" &amp; _propName &amp; "' then";
	write Tab &amp; "return _ti." &amp; _propName &amp; ";";
	write "endif;";
	
	return null;
	
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_propName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="kpdGetExportValueFromTITrans" id="62b789b5-221c-4b52-bcf5-beecd70a2819">
        <source>kpdGetExportValueFromTITrans(_tiTrans : CM_TITransaction;
							 _propName : String) : String;
/*

Purpose:			Get the export data property for the passed in EDI Field propName from 
					the passed in TI Transaction

Parameters:			Transaction, Property name

Return Value:		String value

Date		Who		Reason
28 Sep 2012	cnwkpd1	PAR #30400 - SFW 1290 - Transaction EDI file type

*/

vars
	prop			: Property;
	meth			: Method;
	returnVal		: String;
	otherTI			: CM_TrackedItem;
	
begin
	if _propName = 'messageMode' then
		return "A";
	endif;
	if _propName = 'cargoTypeDescr' then
		return _tiTrans.myTrackedItem.cargoTypeDescr;
	endif;
	if _propName = 'chargeable' then
		return (not _tiTrans.noCharge).Boolean.getYesNo;
	endif;
	if _propName = 'customsAgent' then
		return _tiTrans.customsAgentCode;
	endif;
	if _propName = 'destination' then
		return _tiTrans.destinationPort;
	endif;
	if _propName = 'imexStatus' then
		return _tiTrans.imExStatus.String;
	endif;
	if _propName = 'orderNumber' then
		return _tiTrans.orderNo.String;
	endif;
	if _propName = 'otherCargoId' then
		otherTI := _tiTrans.getOtherTrackedItem();
		if otherTI &lt;&gt; null then
			return otherTI.id;
		else
			return null;
		endif;
	endif;
	if _propName = 'otherCargoTypeDescr' then
		otherTI := _tiTrans.getOtherTrackedItem();
		if otherTI &lt;&gt; null then
			return otherTI.cargoTypeDescr;
		else
			return null;
		endif;
	endif;
	if _propName = 'quantity' then
		return _tiTrans.totalQuantity.String;
	endif;

	if _propName = 'taskDescr' then
		if _tiTrans.class().getPropertyInHTree('todoTaskDesc') &lt;&gt; null then
			return _tiTrans.getPropertyValue('todoTaskDesc').String;
		else
			return null;
		endif;
	endif;
	if _propName = 'transactionTime' then
		return _tiTrans.dateTime.String;
	endif;
	if _propName = 'transactionType' then
		return _tiTrans.type.String;
	endif;
	if _propName = 'volume' then
		return _tiTrans.totalVolume.String;
	endif;
	if _propName = 'weight' then
		return _tiTrans.totalWeight.String;
	endif;
	if _propName = 'length' then
		return _tiTrans.totalLength.String;
	endif;
		
	prop := _tiTrans.class().getPropertyInHTree(_propName);
	if prop &lt;&gt; null then
		return _tiTrans.getPropertyValue(_propName).String;
	endif;
	
	meth := _tiTrans.class().getMethodInHTree(_propName);
	if meth &lt;&gt; null then
		return _tiTrans.sendMsg(_propName).String;
	endif;
	
	if _propName = 'sourceLocn' then
		return null;	// will have been picked up if it is valid
	endif;
	if _propName = 'targetLocn' then
		return null;	// will have been picked up if it is valid
	endif;
	
	write "if _propName = '" &amp; _propName &amp; "' then";
	write Tab &amp; "return _tiTrans." &amp; _propName &amp; ";";
	write "endif;";
	
	return null;
	
epilog

end;</source>
        <Parameter name="_tiTrans" type="CM_TITransaction"/>
        <Parameter name="_propName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="kpdGetLastMethodUpdateTime" id="73ed61b1-de5c-4376-a990-17bac96e15e7">
        <source>kpdGetLastMethodUpdateTime();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 Jul 2009	cnwkpd1	Initial creation

*/

constants
	SchemaName		= "JACBackup";
	
vars
	scm				: Schema;
	cls				: Class;
	meth,
	lastMeth		: Method;
	ts,
	lastTS			: TimeStamp;
	meths			: MethodNDict;
	
begin
	scm := rootSchema.getSchema(SchemaName);
	if scm = null then
		write "Schema " &amp; SchemaName &amp; " not found";
		return;
	endif;
	
	lastTS := null;
	create meths transient;
	
	foreach cls in scm.allClasses where cls.name[1:3] = "JAC" do
		meths.clear();
		cls.getMethods(meths);
		
		foreach meth in meths do
			ts := meth.getPropertyValue('modifiedTimeStamp').TimeStamp;
			if ts &gt; lastTS then
				lastTS := ts;
				lastMeth := meth;
			endif;
			write meth.qualifiedName &amp; Tab &amp; ts.String;
		endforeach;
	endforeach;
	
	write "";
	write "Last modified method = " &amp; lastMeth.qualifiedName &amp; Tab &amp; lastTS.String;
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="kpdGetSupportContractDetails" id="637745ae-4700-4997-acd5-b9eef40c5705">
        <source>kpdGetSupportContractDetails();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 March 2012	cnwkpd1	PAR #29165 - CCMS SFW 1272 - Reduce physical database size

*/

constants
	ContractStart	= "Contract ";
	NZDString		= "All Amounts shown in NZD";
	JMTAppSupport	= "JADE Master Application Support ";
	StaffCosts		= "Total Staff Utilisation Costs ";
	
vars
	cmd				: CMDFileOpen;
	inFile,
	outFile			: File;
	line,
	lastContract,
	outputString	: String;
	pos,
	len				: Integer;
	revenue,
	cost,
	revenueYTD,
	costYTD			: Integer;
	sa				: StringArray;
	
begin
	create inFile transient;
	inFile.kind := File.Kind_Unknown_Text;	// 29/2/16 cnwmp6 PAR 36286 unicode version
	inFile.openInput("c:\temp\1202 Master Cnstatus.txt");
	
	write "Customer" &amp; Tab &amp; 
		  "Revenue" &amp; Tab &amp; 
		  "Cost" &amp; Tab &amp; 
		  "Revenue YTD" &amp; Tab &amp; 
		  "Cost YTD";
	
	while not inFile.endOfFile() do
		line := inFile.readLine();
		
		if line.startsWith(ContractStart) then
			
			if line = lastContract then			// second or subsequent page for same contract
				continue;
			endif;
		
			if outputString &lt;&gt; null then
				write outputString &amp; Tab &amp; 
					  revenue.String &amp; Tab &amp;
					  cost.String &amp; Tab &amp;
					  revenueYTD.String &amp; Tab &amp;
					  costYTD.String;
				
			endif;
			
			pos := line.pos(NZDString, 1);
			if pos &lt;&gt; 0 then
				outputString := line[ContractStart.length() + 1:pos - ContractStart.length()];
				lastContract := line;
			else
				outputString := null;
			endif;

			revenue := 0;
			cost := 0;
			revenueYTD := 0;
			costYTD := 0;
			
		elseif line.startsWith(JMTAppSupport) and line.length() &gt; JMTAppSupport.length() then
			delete sa;
			sa := line[JMTAppSupport.length() + 1:end].getTokens();
			if sa.size &gt;= 1 then
				revenue := sa[1].Integer;
			endif;
			if sa.size &gt;= 2 then
				revenueYTD := sa[2].Integer;
			endif;
			
		elseif line.startsWith(StaffCosts) and line.length() &gt; StaffCosts.length() then
			delete sa;
			sa := line[StaffCosts.length() + 1:end].getTokens();
			if sa.size &gt;= 1 then
				cost := sa[1].Integer;
			endif;
			if sa.size &gt;= 3 then
				costYTD := sa[3].Integer;
			endif;
			
		endif;
	endwhile;
	
epilog
	delete sa;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="kpdGetTransientLeakInfo" id="9ebb2991-336d-4482-96d4-97abf0f9a9f1">
        <source>kpdGetTransientLeakInfo();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 Jul 2015	cnwkpd1	PAR #36286 - Changes for Unicode JADE


*/

constants
	FirstDate		= '29/07/2015'.Date;

vars
	fn				: FileNode;
	logFile,
	msgFile			: File;
	ff				: FileFolder;
	line			: String;
	pos				: Integer;
	count			: Integer;
	
begin
	app.initialize();
	
	create ff transient;
	ff.fileName := app.myCnCntrl.logPath;
	ff.usePresentationFileSystem := false;
	
	create msgFile transient;
	msgFile.openOutput("c:\temp\transient_analysis.txt");
	
	foreach fn in ff.files do
		if not fn.isKindOf(File) then
			continue;
		endif;
		
		if fn.lastModifiedTime.date &lt; FirstDate then
			continue;
		endif;
		
		delete logFile;
		create logFile transient;
		logFile.kind := File.Kind_Unknown_Text;	// 29/2/16 cnwmp6 PAR 36286 unicode version
		logFile.usePresentationFileSystem := false;
		logFile.maxRecordSize := 200000;
		logFile.openInput(fn.fileName);
		
		while not logFile.endOfFile() do
			line := logFile.readLine();
			
			pos := 1;
			if line.length &gt; 0 and line.scanUntil(" ", pos).Date &lt; FirstDate then
				continue;
			endif;
			
			pos := line.pos("process transients remaining.", 1);
			if pos &gt; 0 then
				pos := line.pos(" had ", 1);
				if pos &gt; 0 then
					pos := pos + 5;
					count := line.scanUntil(" ", pos).Integer;
					if count &gt; 10 then
						msgFile.writeLine(logFile.fileName &amp; " " &amp; line);
					endif;
				endif;
			endif;
		endwhile;
	endforeach;
	
	msgFile.close();
			
epilog
	delete msgFile;
	delete logFile;
	delete ff;
	
end;</source>
    </JadeMethod>
    <ExternalMethod name="kpdJomLogReinitAll" id="34d7678d-2f69-437c-b21d-2d24b23654e4">
