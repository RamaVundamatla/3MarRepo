    <JadeMethod name="setControlsForAddEdit" id="079c7b2a-0192-47d7-b56c-d5d9c5e9d0e7">
        <updating/>
        <source>setControlsForAddEdit() updating;
// ---------------------------------------------------------------------------
// Created:     12 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
	theForm : SOP_TableMaintForm;

begin
  	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
			
	if theForm.mode = theForm.Mode_Add then
		theForm.tblInput1.clearValues;
		theForm.tblInput1.enableRowByName(ETRow_Name);
		theForm.tblInput1.enableRowByName(ETRow_IsHatchType);
		theForm.tblInput1.setValueByName(ETRow_Colour, White.String);
		theForm.tblInput1.setFocus;
		theForm.tblInput1.moveFirst();
	else
		// refresh the data from the newly created proxy
		self.showThumbnail(theForm.myProxyObject.CM_JobType);
		// cannot update code
		theForm.tblInput1.enableRowByName(ETRow_Name);
		theForm.tblInput1.enableRowByName(ETRow_IsHatchType);
	endif;

	theForm.tblInput1.cnEcResizeContents();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="27dfbf63-8d6d-4118-9152-e4a0b2ab578e">
        <updating/>
        <source>setCtrlsForView() updating;
// ---------------------------------------------------------------------------
// Created:     12 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
	theForm : SOP_TableMaintForm;

begin
	//cnwmc5 - 17 Oct 2013 - PAR 32622
	inheritMethod();
	
	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := false;
	//theForm.tblInput1.showRowByName('ports',false);
	theForm.tblInput1.cnEcResizeContents();
end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="50d2e06c-5a4c-41ab-bec6-baf7cbd412cb">
        <updating/>
        <source>setupThumbnailDetails() updating;
// ---------------------------------------------------------------------------
// Created:     12 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
	theForm : SOP_TableMaintForm;

begin
  
  	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_JobTypeMaintTbl);
	//theForm.zAddColumn('JobType Id', 'code', Table.InputType_None, 30);
	//theForm.zAddColumn('Description', 'description', Table.InputType_None, 70);
	//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_Name, false);

	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_JobTypeMaint);
	theForm.shtTblInput1.visible := true;

  	theForm.tblData.userInputEnabled := false;

	theForm.mulSelect1.formDisplayEntryMethodName := null;
	theForm.mulSelect2.formDisplayEntryMethodName := null;
	
	self.colourColumn := theForm.tblData.getColumnByRowName(ETRow_Colour);
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="86b96d58-975c-4184-ae88-20c4d8884eb1">
        <updating/>
        <source>showThumbnail(pJobType: CM_JobType) updating;
// ---------------------------------------------------------------------------
// Created:     12 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars

	theForm : SOP_TableMaintForm;
	first:Boolean;
	list:String;	
begin
  
    theForm := self.myForm;
	theForm.tblInput1.clearValues;

	theForm.tblInput1.setValueByName(ETRow_Name, pJobType.name);
	theForm.tblInput1.setValueByName(ETRow_IsHatchType,	pJobType.isHatchType);
	theForm.tblInput1.setValueByName(ETRow_TimeToComplete,	pJobType.estimatedTimeToCompleteMins);
	theForm.tblInput1.setValueByName(ETRow_Colour,	pJobType.colour);
	first := false;
	
end;</source>
        <Parameter name="pJobType" type="CM_JobType"/>
    </JadeMethod>
    <JadeMethod name="tblDataShowDataSpecial" id="82cdccb4-bd3a-4a09-aaf7-2d4a9e232f13">
        <source>tblDataShowDataSpecial(_idxRow: Integer; _obj: Object);
/*

Purpose:			


Return Value:		


Date		Who		Reason
27 June 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	jobType:CM_JobType;
	cell : JadeTableCell;
begin
//	return inheritMethod(table, theSheet, pObj, theRow, bcontinue);

	jobType := _obj.CM_JobType;
	if(_idxRow &lt;&gt; 1) then
		if colourColumn &gt; 0 then	
			cell := myForm.tblData.accessCell(_idxRow,colourColumn);
			cell.text := null;			
			cell.backColor := jobType.colour;
		endif;
	endif;


epilog

end;</source>
        <Parameter name="_idxRow" type="Integer"/>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
</Class>
