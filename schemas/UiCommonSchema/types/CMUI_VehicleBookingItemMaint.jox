    <JadeMethod name="btnNext_click" id="4f050962-a5a8-4779-8532-7746f144c5fc">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnNext_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
12 July 2022	navcs2	53899 EUP - SD - VBS MTN - [3] - Maintaining VBS Slot
23 Dec 2022		navak20 Task 55979: EUP - VBS MTN - [3] - Maintaining VBS Slot - Review Changes
24 Apr 2023 	navhl20	ChangeRequest 57716:[57718] EUP - VBS changes MTN - Bulk Edit and Linking of slots [Refinement - 01]
*/

vars
	parentForm : CMUI_VehicleBookingAdvMaint;	// 23.12.2022 navak20 TFS 55979
begin
	// 23.12.2022 navak20 TFS 55979
	if self.myParentForm.isKindOf(CMUI_VehicleBookingAdvMaint) then
		parentForm := self.myParentForm.CMUI_VehicleBookingAdvMaint;
	endif;
	// 23.12.2022 navak20 TFS 55979
	
	self.validateSlotControls();
	self.saveProxyVBTimeSlotItem(self.myPxyVehicleBookTimeSlotItem);
	
	if not self.myPxyVehicleBookingSlot.allVehicleBookingItems.includes(myPxyVehicleBookTimeSlotItem) then
		self.myPxyVehicleBookingSlot.allVehicleBookingItems.add(myPxyVehicleBookTimeSlotItem);
	else
		self.myPxyVehicleBookTimeSlotItem := null;
		
		create	self.myPxyVehicleBookTimeSlotItem transient;									//24.4.2023 navhl20 #57716[57718]
		
		if parentForm &lt;&gt; null then		
			parentForm.populateTableBookingItems();		// 23.12.2022 navak20 TFS 55979
		endif;
		
		self.cmbCargo.removeObject(self.cmbCargo.listObject);
		self.cmbCargo_click(self.cmbCargo);
		
		self.clearControls();
		return;
	endif;
	
	if parentForm &lt;&gt; null then	
		parentForm.populateTableBookingItems();	
	endif;
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnOk_click" id="a26497d9-eb76-4c33-adc3-1a0209cbeb86">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnOk_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
12 July 2022	navcs2	53899 EUP - SD - VBS MTN - [3] - Maintaining VBS Slot
15 May 2023 	navhl20	Defect 57958:[57959] MTN - When bulk editing the carrier and sub-carrier, the VBS slot items are also getting changed.
23 Apr 2024 	navlc30 ChangeRequest 63581: FR - 53429 - VBS - Adding entire release with line items
*/

vars

begin
	self.validateSlotControls();
	if self.chkAddAllItems.value then																	//23.04.2024 navlc30 #63581
		self.saveProxyVBTimeSlotItemAddAll(self.myPxyVehicleBookTimeSlotItem);
	else
		self.saveProxyVBTimeSlotItem(self.myPxyVehicleBookTimeSlotItem);
	endif;
	self.isProxyUsed := true;																			//15.5.2023 navhl20	#57958[57959]
	
	if self.myParentForm.isKindOf(CMUI_VehicleBookingAdvMaint) then
		self.myParentForm.CMUI_VehicleBookingAdvMaint.populateTableBookingItems();
		self.myParentForm.CMUI_VehicleBookingAdvMaint.isVBSItemChanged := true;
	endif;
	
	self.unloadForm();
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
