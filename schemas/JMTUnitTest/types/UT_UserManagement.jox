    <JadeMethod name="checkForAltUserErrors" id="89cb255b-276b-45b9-aa53-0e3ae227ace2">
        <source>checkForAltUserErrors();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 October 2012	cnwmc5	Initial creation

*/

vars
	row 		: JadeTableRow;
	
	user		: UM_UserEmailAddress;
	user2		: UM_UserEmailAddress;
	
	userName 	: String;
	altUser		: String;
	rowNum		: Integer;
	rowNum2		: Integer;
	
	flag		: Boolean;
begin	
	flag := false;
	
	foreach user in self.myRoot.allUserEmailAddresses do
		///userName := user.user;
		userName := app.returnCorrectUserName(user.user, false);
		if self.cmbAltUsers.findString(1, userName) = -1 then
			foreach user2 in self.myRoot.allUserEmailAddresses do
				altUser := user2.altUser;
				if userName = altUser then
					foreach rowNum in 2 to self.tblUserData.rows do
						if self.tblUserData.accessCell(rowNum, 8).text = user.user then
							self.tblUserData.accessRow(rowNum).backColor := LightRed;
						endif;
					endforeach;
				endif;
			endforeach;
		endif;
	endforeach;
	
	foreach user in self.myRoot.allUserEmailAddresses do
		if user.altUser = null then
			continue;
		endif;
		altUser := user.altUser;
			foreach user2 in self.myRoot.allUserEmailAddresses do
				///userName := user2.user;
				userName := app.returnCorrectUserName(user2.user, false);
				if altUser = userName then
					break;
				endif;
				if user2 = self.myRoot.allUserEmailAddresses.last then
					if altUser &lt;&gt; userName then
						flag := true;
					endif;
				endif;
				if flag then
					foreach rowNum in 2 to self.tblUserData.rows do
						if self.tblUserData.accessCell(rowNum, 2).text = user.user then
							self.tblUserData.accessRow(rowNum).backColor := LightBlue;
							flag := false;
						endif;
					endforeach;
				endif;
			endforeach;
	endforeach;

epilog
	
end;</source>
    </JadeMethod>
