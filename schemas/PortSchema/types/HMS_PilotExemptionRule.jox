    <JadeMethod name="getCriteriaStr" id="84edf0e8-b29a-41e6-838f-d21aa7abd779">
        <source>getCriteriaStr():String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 April 2012	cnwndl1	Initial creation	Par 29496

*/

vars

begin

	if self.criteria = self.Criteria_Draft then
		return self.Criteria_Draft_Str;
	elseif self.criteria = self.Criteria_Length then
		return self.Criteria_Length_Str;
	elseif self.criteria = self.Criteria_Weight then
		return self.Criteria_Weight_Str;
	else
		return null;
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="1521a2a0-446c-4f97-9743-47603a785484">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 May 2012	cnwndl1	Initial creation

*/

vars

begin

	if _attrName = ETRow_Criteria then
		return self.getCriteriaStr;
	elseif _attrName = ETRow_Operator then
		return self.getOperatorStr;
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
