    <JadeMethod name="addActivityRecord" id="6b67b03b-b082-49ef-99bf-52c58930daf9">
        <source>addActivityRecord( _new : Boolean );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 March 2015	cnwndl1	Initial creation	Par 35816

*/

vars

	changeString	: String;
	changeName		: String;

begin

	if self.myTerminal &lt;&gt; null then
		changeName := self.myTerminal.code &amp; " / ";
	endif;
	changeName:= changeName &amp; self.getDisplayStringForId(self.idType);
	
	if _new then
		changeString := "Created Auto ID Config for " &amp; changeName;
	else
		changeString := "Updated Auto ID Config for " &amp; changeName;
	endif;
	
	app.createActivityHistory(	ActivityHistoryGeneralSys,	//_type : Integer;
						self.myTerminal,	//_terminal : CM_Terminal;
						null,	//_objectForExtraDetail : Object;
						changeString,	//_description : String;
						true,	//_insideTransaction : Boolean;
						false	//_temp: Boolean
						);

epilog

end;</source>
        <Parameter name="_new" type="Boolean"/>
    </JadeMethod>
