		sysSecRole.zfixupMaintViewPermission(PmAdmDBPurgeMaintMaint, PmAdmDBPurgeMaint, false);
		sysSecRole.zfixupMaintViewPermission(PmBkGrndProcessView,PmBkGrndProcessMaint, false);
		sysSecRole.zfixupMaintViewPermission(PmAdmEventEnquiryView, PmAdmEventEnquiryMaint, false);
		sysSecRole.zfixupMaintViewPermission(PmShpCraneMoveRatesView, PmShpCraneMoveRates, false);
		sysSecRole.zfixupMaintViewPermission(PmAdmPortCodeView , PmAdmPortCodeMaint, false);
		sysSecRole.zfixupMaintViewPermission(PmAdmSysAdminSpecView , PmAdmSysAdminSpec, false);
		sysSecRole.zfixupMaintViewPermission(PmCmpDrawingAttributesMaint, PmCmpDrawingAttributes, false);
		sysSecRole.zfixupMaintViewPermission(PmAdmContentStatView, PmAdmContentStatMaint, false);
		sysSecRole.zfixupMaintViewPermission(PmAdmIMEXStatusView, PmAdmIMEXStatusMaint, false);
		sysSecRole.zfixupMaintViewPermission(PmAdmTransitStatusView, PmAdmTransitStatusMaint, false);
		sysSecRole.zfixupMaintViewPermission(PmAdmPackageView, PmAdmPackageMaint, false);
		sysSecRole.zfixupMaintViewPermission(PmAdmSelectorQueryForRTMaint, PmAdmSelectorQueryForRT, false);
		sysSecRole.zfixupMaintViewPermission(PmAdmEDIFormatView, PmAdmEDIFormatMaint, false);
		sysSecRole.zfixupMaintViewPermission(PmAdmUserHookView, PmAdmUserHookMaint, false);
	commitTransaction;
	
	
	self.addScriptRun(method.name);
	
	app.writeLog(method.qualifiedName &amp; " Cleaning up View Only Maint Permissions complete", LogINFO);	


epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="migrateHHRootConfigToTerm" id="df0289f3-30ad-4f92-83d2-d227e8117a2a">
        <source>migrateHHRootConfigToTerm();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 December 2015	cnwndl1	Initial creation	Par 36866

*/

vars

	allowLoadMoreCargo : Boolean;
	allowPackMoreCargo : Boolean;
	allowUnloadMoreCargo : Boolean;
	allowUnpackMoreCargo : Boolean;
	term : CM_Terminal;

begin

	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; ": Migrating Hand Held configs, Root --&gt; Terminal ...", LogINFO);
	
	allowLoadMoreCargo := app.myRoot.getConfig(AllowLoadMoreCargo).Boolean;
	allowPackMoreCargo := app.myRoot.getConfig(AllowPackMoreCargo).Boolean;
	allowUnloadMoreCargo := app.myRoot.getConfig(AllowUnloadMoreCargo).Boolean;
	allowUnpackMoreCargo := true;	// new one, default to true so existing behaviour is not changed.
	
	foreach term in app.myRoot.allTerminals do
		beginTransaction;
		term.setConfig( AllowLoadMoreCargo, allowLoadMoreCargo );
		term.setConfig( AllowPackMoreCargo, allowPackMoreCargo );
		term.setConfig( AllowUnloadMoreCargo, allowUnloadMoreCargo );
		term.setConfig( AllowUnpackMoreCargo, allowUnpackMoreCargo );
		commitTransaction;
	endforeach;
	
	self.addScriptRun(method.name);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="rebuildCalculationTypeHookCode" id="b7b8ddc1-db87-4e0c-8f2f-5d14e32ecd92">
        <source>rebuildCalculationTypeHookCode();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 October 2015	cnwmc5	Initial creation

*/

vars
	pxyCalc,
	calcType			: CM_CalculationType;
	currentRateCode,
 	currentQuantCode,
	currentRemarksCode	: String;
	newRateCode,
	newQuantCode,
	newRemarksCode		: String;
	
	loadState 			: Boolean;
	line 				: String;
	pos 				: Integer;
	
	realQtyRange,
	pxyQtyRange			: CM_QuantityRange;
	
begin
	
	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; ": Rebuilding Calculation Type hook code...", LogINFO);
	
	app.initialize();
	
	// Loop through all CM_CalculationType's and update the Hook Code objects 
	// to work with the new signature.
	foreach calcType in CM_CalculationType.instances do
		if calcType.myHookCodeQuantity = null and calcType.myHookCodeRate = null then
			continue;
		endif;
		
		newQuantCode := null;
		newRateCode := null;
		currentRemarksCode := calcType.myHookCodeRemarks.getCurrentJadeCode();
		
		// Update the Hook Code for Quantity
		if calcType.myHookCodeQuantity &lt;&gt; null then
			currentQuantCode := calcType.myHookCodeQuantity.getCurrentJadeCode();
			
			// Modifiy the current code
			if currentQuantCode &lt;&gt; null then
				pos := 1;
				line := currentQuantCode.cnEcGetNextLine(pos);
				newQuantCode := "amendQuantity(_cmif : CMIF_CalcTypeQuantityHook) : Real;";
				while pos &lt;&gt; 0 do
					line := currentQuantCode.cnEcGetNextLine(pos);
					line.cnReplaceString("_tran", "_cmif.myTransaction");
					line.cnReplaceString("_origQty", "_cmif.origQty");
					newQuantCode := newQuantCode &amp; CrLf &amp; line;
				endwhile;
			endif;
		endif;
		
		// Update the Hook Code for Rates
		if calcType.myHookCodeRate &lt;&gt; null then
			currentRateCode := calcType.myHookCodeRate.getCurrentJadeCode();
			
			// Modifiy the current code
			if currentRateCode &lt;&gt; null then
				pos := 1;
				line := currentRateCode.cnEcGetNextLine(pos);
				newRateCode := "amendRate(_cmif : CMIF_CalcTypeRateHook) : Real;";
				while pos &lt;&gt; 0 do
					line := currentRateCode.cnEcGetNextLine(pos);
					line.cnReplaceString("_tran", "_cmif.myTransaction");
					line.cnReplaceString("_origRate", "_cmif.origRate");
					line.cnReplaceString("_invoiceLine", "_cmif.myInvoiceLine");
					newRateCode := newRateCode &amp; CrLf &amp; line;
				endwhile;
			endif;
		endif;
		
		app.cmsBeginLoad(loadState);
		pxyCalc := calcType.pxyCreateUpdateProxy();
		app.cmsEndLoad(loadState);
		
		foreach realQtyRange in calcType.allQuantityRanges do
			create pxyQtyRange transient;
			pxyQtyRange.setup(	realQtyRange.formula, 
								pxyCalc, 
								realQtyRange.daysIncrement, 
								realQtyRange.percentage, 
								realQtyRange.rangeStart, 
								realQtyRange.rangeEnd,
								realQtyRange.rangeType);
		endforeach;
		
		pxyCalc.setProxy(	calcType.booleanList,
							calcType.calculationType,
							calcType.code,
							calcType.description,
							calcType.hoursFree,
							calcType.hoursMax,
							calcType.hoursMin,
							calcType.hoursBlock,
							calcType.integerRange1,
							calcType.isNotAvailableForEntry,
							calcType.timeFrom,
							calcType.timeTo,
							calcType.amountMin,
							calcType.amountMax,
							calcType.theCalcTypeUnit,
							newQuantCode,
							newRateCode,
							currentRemarksCode,
							app.myPassport.getUserCode(),
							calcType.isCargoCalcType,
							calcType.isVoyageCalcType,
							calcType.isEventCalcType,
							calcType.isWorkOrderType, // TFS 39198
							calcType.myCalendarType1,
							calcType.myCalendarType2,
							calcType.myMeasurementType,
							calcType.rateType,	//22 Mar 2019	NDL	TFS 43687
							false, false, // ### TFS 51219 25MAY2021 NAVAB1
							calcType.weightOptionToUse //02/10/2025	navkc1 JIRA 36149
							); 
		
		app.myTrxUA.trxUpdateCalculationType(pxyCalc, app.myPassport);
		if not app.myPassport.trxCompletedOK then
			// SOMETHING WENT WRONG
			app.writeLog(method.qualifiedName &amp; ": " &amp; app.myPassport.getErrorsAndWarningsAsString(), LogINFO);
			break;
		endif;
		
		delete pxyCalc;
	endforeach;
	
	self.addScriptRun(method.name);
	
	app.writeLog(method.qualifiedName &amp; ": Rebuilding Calculation Type hook code complete.", LogINFO);
	
epilog
	delete pxyCalc;
	
	app.cmsEndLoad(loadState);
end;</source>
    </JadeMethod>
    <JadeMethod name="rebuildOperatorInvalidKey" id="e6c86938-1502-4759-a1ca-398dced73fac">
        <source>rebuildOperatorInvalidKey();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 September 2015	PAR #36424 Model issue in handling of Operator code change for Bookings

*/


vars
	t				: CM_Terminal;
	v				: CM_Voyage;
	c				: CM_ConsigneeConsignor;
	b				: CM_BookingRef;
	voyages,
	terminals,
	consignees		: ObjectArray;
	iter, iter2		: Iterator;
	codeKey			: String;
	refKey			: String;
	refVoy          : CM_Voyage;
	badOne			: Boolean;
	count           : Integer;

begin
	
	if self.hasScriptBeenRunThisRelease(method.name, null) then
		return;
	endif;
	///////////////////////////////////////////////////////////////CM_Terminal
	app.writeLog(method.qualifiedName &amp; "rebuild operator Invalid Keys from CM_Terminal.allBookingRefsByOperatorRef ", LogINFO);
	create terminals transient;
	CM_Terminal.allInstances(terminals, 0, true);
	delete iter;
	iter := terminals.createIterator();
	
	while iter.next(t) do
		delete iter2;
		iter2 := t.allBookingRefsByOperatorRef.createIterator();
		badOne := false;
		while iter2.next(b) do
			
			t.allBookingRefsByOperatorRef.getIteratorKeys(codeKey, refKey, refVoy,iter2);
			if b.bookingReference &lt;&gt; refKey then
				badOne := true;
				break;
			endif;
			if b.myOperator &lt;&gt; null and b.myOperator.code &lt;&gt; codeKey then
				badOne := true;
				break;
			endif;
			if b.myOperator = null and codeKey &lt;&gt; null then
				badOne := true;
				break;
			endif;
		
		endwhile;
			
		if badOne then
			beginTransaction;
			t.allBookingRefsByOperatorRef.rebuild;
			commitTransaction;
			count := count +1;
		endif;
	endwhile;
	app.writeLog(method.qualifiedName &amp; " Completed rebuild CM_Terminal.allBookingRefsByOperatorRef  from 8.4.2 , " &amp; count.String &amp; " Fixed", LogINFO);
	///////////////////////////////////////////////////////////////CM_Voyage
	app.writeLog(method.qualifiedName &amp; "rebuild operator Invalid Keys from CM_Voyage.allBookingRefs", LogINFO);
	count :=0;
	create voyages transient;
	CM_Voyage.allInstances(voyages, 0, true);
	delete iter;
	iter := voyages.createIterator();
	
	while iter.next(v) do
		delete iter2;
		iter2 := v.allBookingRefs.createIterator();
		
		badOne := false;

		while iter2.next(b) do
			v.allBookingRefs.getIteratorKeys(codeKey, refKey, iter2);
			
			if b.bookingReference &lt;&gt; refKey then
				badOne := true;
				break;
			endif;
			if b.myOperator &lt;&gt; null and b.myOperator.code &lt;&gt; codeKey then
				badOne := true;
				break;
			endif;
			if b.myOperator = null and codeKey &lt;&gt; null then
				badOne := true;
				break;
			endif;
		endwhile;
		
		if badOne then
			beginTransaction;
			v.allBookingRefs.rebuild;
			count := count+1;
			commitTransaction;
		endif;
	endwhile;
	app.writeLog(method.qualifiedName &amp; " Completed rebuild CM_Voyage.allBookingRefs  from 8.4.2 , " &amp; count.String &amp; " Fixed", LogINFO);

	///////////////////////////////////////////////////////////////CM_ConsigneeConsignor
	app.writeLog(method.qualifiedName &amp; "rebuild operator Invalid Keys from CM_ConsigneeConsignor.allBookingRefsByOperatorRef", LogINFO);
	count :=0;
	create consignees transient;
	CM_ConsigneeConsignor.allInstances(consignees, 0, true);
	delete iter;
	iter := consignees.createIterator();

	while iter.next(c) do
		delete iter2;
		iter2 := c.allBookingRefsByOperatorRef.createIterator();
		badOne := false;
		while iter2.next(b) do
			
			c.allBookingRefsByOperatorRef.getIteratorKeys(t,codeKey, refKey, refVoy,iter2);
			if b.bookingReference &lt;&gt; refKey then
				badOne := true;
				break;
			endif;

			if b.myOperator &lt;&gt; null and b.myOperator.code &lt;&gt; codeKey then
				badOne := true;
				break;
			endif;
			if b.myOperator = null and codeKey &lt;&gt; null then
				badOne := true;
				break;
			endif;
			
		endwhile;
		if badOne then
			beginTransaction;
			c.allBookingRefsByOperatorRef.rebuild;
			commitTransaction;
			count := count+1;
		endif;
	endwhile;
	app.writeLog(method.qualifiedName &amp; " Completed rebuild CM_ConsigneeConsignor.allBookingRefsByOperatorRef  from 8.4.2 , " &amp; count.String &amp; " Fixed", LogINFO);
	self.addScriptRun(method.name);
epilog
	delete voyages;
	delete terminals;
	delete consignees;
	delete iter;
	delete iter2;
end;</source>
    </JadeMethod>
    <JadeMethod name="setCashReceiptInvoiceOption" id="a7ba0e45-74b3-462b-b3e7-bc666ee85b41">
        <source>setCashReceiptInvoiceOption();
//
// Purpose:			Convert object extension data to new attribute on CM_CashReceipt
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 06/07/2015	cnwjre1		From 36485, hard-coded option for ADP is now a user option.  Set it for them only.
//
vars
	terminal	: CM_Terminal;
	finIO		: CM_ExtFinanceIO;
begin
	app.writeLog(method.qualifiedName &amp; " Upgrading cash invoice option for 8.4.2", LogINFO);
	
	beginTransaction;
	foreach terminal in CM_Terminal.instances do
		finIO := terminal.getConfig(FinancialIOClass).CM_ExtFinanceIO;
		if finIO &lt;&gt; null and finIO.class = CM_ADPInterface then
			terminal.setConfig(CashInvoiceEveryReceipt, true);
		endif;
	endforeach;
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Completed upgrading cash invoice option", LogINFO);	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="specificPostStandard" id="566a7d02-054f-4af4-9af8-1c81a44fbc2d">
        <updating/>
        <source>specificPostStandard(pControllerObj: CnEcReleaseController) updating;
/*
Purpose:			
Date		Who		Reason
28 April 2015	cnwab1	Initial creation
*/

vars

begin
	inheritMethod(pControllerObj);
	
	
	self.tfs189ADPFinancialInstance();
	
	self.convertGTETemperatures();					// PAR #36094
	
	self.convertFutureStorageMappings(); // PAR 36275
	
	self.clearHazardCodesFromUNDG();				// PAR #36421
	
	self.convertCashReceiptReleaseDate();			// par 36457
	
	self.setCashReceiptInvoiceOption();				// from 36485 done in 36476
	
	self.cleanUpOrphanedCMStrings();				// PAR #36578
	
	self.checkChilledTIsOffPowerSet();				// PAR #36041
	
	self.updateSuperuserTerminals(); 				//par 36624 16/7/15
	
	self.rebuildOperatorInvalidKey();				// PAR #36424 16/09/2015
	
	self.rebuildCalculationTypeHookCode();			// cnwmc5 - 14 Oct 2015 - PAR 36920
	
	self.updateOperatorRequiresRequest(); 			// 04/11/2015  cnwma1 PAR #37125 
	
	self.migrateHHRootConfigToTerm();	//04 Dec 2015	NDL	Par 36866
	
	self.fixInvoiceReportTemplates();	// 04 Dec 2015 cnwkpd1 PAR #36903
	
	self.updateCargoSubtypeEDIXlations();	//13 May 2016	cnwrs1	TFS 1987 CargoSubType EDI Xlation
	
	self.fixUserDefinedEDIMeasureTypes();		// 13/06/2016 TFS 2134 fix user-defined EDI file type measurement types which have default values after import
	
	self.fixCMQFinvalidObjs(); //18 Jul 2016	NDL	TFS 2329
epilog

end;</source>
        <Parameter name="pControllerObj" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="tfs189ADPFinancialInstance" id="b07476cf-2401-402f-a026-7c26ed660c51">
        <source>tfs189ADPFinancialInstance();
/*
Purpose:			
Date		Who		Reason
28 April 2015	cnwab1	Initial creation
*/

vars

	aFIO : CM_ADPInterface;
begin
	aFIO := CM_ADPInterface.firstInstance().CM_ADPInterface;
	if aFIO = null then
	app.writeLog( method.qualifiedName &amp; " Create single instance of ADP Interface class for 8.4.2", LogINFO);
		aFIO := app.myTrxCA.trxCreateExternalFinanceClass(CM_ADPInterface).CM_ADPInterface;
	endif;


epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="updateCargoSubtypeEDIXlations" id="1f2fa9fa-590f-4643-a188-fa5b0a4fd501">
        <source>updateCargoSubtypeEDIXlations();
//
//13 May 2016	cnwrs1	TFS 1987 CargoSubType EDI Xlation
//
//The old sub cargo subtype edi xlations did not have a cargoType so they are easy to identify
//
// multiple xlations may be on one xlationTable and they they need to be split up to different xlation Tables
//
//01 Jun 2016	cnwrs1	TFS 2083 fixup the Cargo subtype Xlation upgrade script
vars
	xlationTable : CM_XlationTable;
	newXlationTable : CM_XlationTable;
	xlation : CM_Xlation;
	xlation2 : CM_Xlation;
	cargoType : CM_CargoType;
	oldCargoType : CM_CargoType;
	operator : CM_Operator;
	cargoSubType : CM_Product;
begin

	beginTransaction;
	foreach xlationTable in CM_XlationTable.instances do
		if xlationTable.type = XLATION_TYPE_CARGOSUBTYPE_BYOP then
			if xlationTable.getMyCargoType = null then
				operator := xlationTable.myOperator;
				foreach xlation in xlationTable.allInwardTranslations do
					cargoSubType := xlation.getPropertyValue(CM_Xlation::mySystemObject.name).CM_Product;
					if (not global.isValidObject(cargoSubType)) or
					   cargoSubType = null then
						delete xlation;
					else
						cargoType := xlation.getPropertyValue(CM_Xlation::mySystemObject.name).CM_Product.myCargoType;
						if cargoType = null then
		
						else
							if oldCargoType = null then
								xlationTable.setMyCargoType(cargoType);
							else
								if oldCargoType = cargoType then
								else
									newXlationTable := operator.allXlationTables[XLATION_TYPE_CARGOSUBTYPE_BYOP, cargoType];
									if newXlationTable = null then
										create newXlationTable;
										newXlationTable.setProxy(xlationTable.type, xlationTable.myRoot, operator, xlationTable.myOperatorTerminal, cargoType,null);
									else
									endif;
									xlation.setXlationTable(newXlationTable);
									foreach xlation2 in xlationTable.allOutwardTranslations do
										cargoSubType := xlation2.getPropertyValue(CM_Xlation::mySystemObject.name).CM_Product;
										if cargoSubType = null then
											delete xlation2;
										else
											if cargoSubType.myCargoType = newXlationTable.getMyCargoType then
												xlation2.setXlationTable(newXlationTable);
											endif;
										endif;
									endforeach;	
								endif;
							endif;
							oldCargoType := cargoType;
						endif;
					endif;
				endforeach;
				foreach xlation in xlationTable.allInwardTranslations do
					cargoSubType := xlation.getPropertyValue(CM_Xlation::mySystemObject.name).CM_Product;
					if cargoSubType = null then
						delete xlation;
					else
						cargoType := cargoSubType.myCargoType;
						if cargoType &lt;&gt; xlationTable.getMyCargoType then
							newXlationTable := operator.allXlationTables[XLATION_TYPE_CARGOSUBTYPE_BYOP, cargoType];
							xlation.setXlationTable(newXlationTable);
						endif;
					endif;
				endforeach;
			endif;
		endif;
	endforeach;
	commitTransaction;
return;
	write(ETRow_CargoType);
	write(ETDef_EDIXlations);
end;
</source>
    </JadeMethod>
    <JadeMethod name="updateOperatorRequiresRequest" id="34600ff2-a7ab-43a2-816e-551052543b47">
        <source>updateOperatorRequiresRequest();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 November 2015	cnwma1	Initial creation PAR #37125
There was an issue raised bt Centre Port,
If an Operator is configured to "Require Import Operator PIN" 
Then the system will give an error if a user attempts to move an item of this operator onto a wagon 
if the item is not currently assigned to a rail release request.

The Script will updates Otago Env to Set operator.requiresRequestNumber to true if the operator have the "RequiresImportOperatorPIN" set to true
and will set for any other customer to false .
*/

vars
	etAgent		: EntTableAgent;
	array 		: StringArray;
	isOtago			: Boolean;
	opr 		 : CM_Operator;
	
begin
	
	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;
	
	app.initialize();
	isOtago := app.myRoot.isClientPortOtago;
	
	foreach opr  in app.myRoot.allOperators discreteLock do
		if opr.getRequiresImpOperatorPIN then
			if isOtago then
				beginTransaction;
				opr.setPropertyValue("requiresRequestNumber",true);
				commitTransaction;
			endif;
		endif;
	endforeach;
	
	foreach opr  in app.myRoot.allOperators discreteLock do
		if not isOtago then
			beginTransaction;
			opr.setPropertyValue("requiresRequestNumber",false);
			commitTransaction;
		endif;
	endforeach;
	
	create etAgent transient;
	create array transient;

	etAgent.myEntTableDataRoot := app.myRoot.myEntTableDataRoot;

	array.add ("ETRow_RequiresRequestNumber");
	etAgent.trxUpdateFromConstant(array);
	
	write ETRow_RequiresRequestNumber;
epilog
	
	delete etAgent;
	delete array;
end;</source>
    </JadeMethod>
    <JadeMethod name="updateSuperuserTerminals" id="775aabcb-7969-48d5-9629-502613ddd3c6">
        <source>updateSuperuserTerminals();
/*

Date		Who		Reason
16 July 2015	cnwer1	Initial creation PAR 36624

*/

vars
	r : CM_Root;
	t  : CM_Terminal;
	su, pxyUser : CM_User;
	pxyUserTerm : CM_UserTerminal;
	secRole : CM_SecurityRoleTerminal;
	doUpdate : Boolean;
begin
	r:= CM_Root.firstInstance;
	su :=	r.allUsers[SUPERUSER_Str];
	if su = null then
		return; //very unlikely
	endif;
	beginLoad;
	pxyUser:=su.pxyCreateUpdateProxy;
	endLoad;
	secRole := r.allRoles['Terminal Root'].CM_SecurityRoleTerminal;
	doUpdate:=false;
	app.writeLog(method.qualifiedName &amp; " Checking Superuser terminal access", LogINFO);
	foreach t in CM_Terminal.instances do
		if su.allUserTerminals[t] &lt;&gt; null then
			continue;
		endif;
		doUpdate:=true;
		create pxyUserTerm transient;
		pxyUserTerm.setForProxy(t,pxyUser,secRole,null,null,null);
	endforeach;
	
	if doUpdate then
		app.writeLog(method.qualifiedName &amp; " Updating Superuser terminal access", LogINFO);
		app.myTrxUA.trxUpdateUser(pxyUser,null,app.myPassport);
	else
		app.writeLog(method.qualifiedName &amp; "Superuser has access to all terminals", LogINFO);
	endif;
epilog
	delete pxyUser;
end;</source>
    </JadeMethod>
</Class>
