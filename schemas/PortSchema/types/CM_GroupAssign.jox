    <JadeMethod name="getDisplayStringForAttribute" id="8cd46dbc-695f-4789-9467-6483aa3d3d1d">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 June 2015	cnwndl1	Initial creation	Par 36338

*/

vars

	lDetail : String;
	otherTI : CM_TrackedItem;
	otherTIid : String;

begin
	
	if _attrName = ETRow_Details  then
	
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
			
		else
			otherTI := self.getOtherTrackedItem();
			if otherTI &lt;&gt; null then
				otherTIid := otherTI.id;
			else
				otherTIid := self.otherTrackedItemId;
			endif;
			
			if self.action = ACTION_ASSIGN_TI_TO_CG then
				if otherTIid &lt;&gt; null then
					lDetail := lDetail &amp; "Assigned to Cargo Group " &amp; otherTIid;
				endif;
			elseif self.action = ACTION_CG_ADDED_TI then
				if otherTIid &lt;&gt; null then
					lDetail := lDetail &amp; "Added " &amp; otherTIid;
				endif;
			endif;		
			
			return lDetail;
			
		endif;

	else
		return inheritMethod(_attrName, _short);
	
	endif;


epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEnquiryRow" id="72d14d38-f0a7-4785-9b3f-620dcdd391b5">
        <source>getEnquiryRow(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 June 2015	cnwndl1	Initial creation	Par 36338

*/

vars

	lDetail : String;
	otherTI : CM_TrackedItem;
	otherTIid : String;
	
begin

	otherTI := self.getOtherTrackedItem();
	if otherTI &lt;&gt; null then
		otherTIid := otherTI.id;
	else
		otherTIid := self.otherTrackedItemId;
	endif;
	
	lDetail := inheritMethod();

	if self.action = ACTION_ASSIGN_TI_TO_CG then
		if otherTIid &lt;&gt; null then
			lDetail := lDetail &amp; "Assigned to Cargo Group " &amp; otherTIid;
		endif;
	elseif self.action = ACTION_CG_ADDED_TI then
		if otherTIid &lt;&gt; null then
			lDetail := lDetail &amp; "Added " &amp; otherTIid;
		endif;
	endif;		
	
	return lDetail;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOtherTrackedItem" id="c0a49708-c319-4dad-b86c-a073ad0e67e7">
        <source>getOtherTrackedItem(): CM_TrackedItem;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 June 2015	cnwndl1	Initial creation	Par 36338

*/

vars
	invalidTI		: Boolean;
	id				: String;
	othTrackedItem	: CM_TrackedItem;
begin
	othTrackedItem := self.otherTrackedItem;
	if othTrackedItem &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, othTrackedItem, invalidTI);
		// Dereference TI to check it is valid
		id := othTrackedItem.id;
	endif;
	
	if invalidTI then
		return null;
	endif;

	return othTrackedItem;
	
end;</source>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
