    <JadeMethod name="scrCargoInYard_change" id="05b6e14c-9d6c-4e74-b5f0-42044f070c4b">
        <controlMethod name="ScrollBar::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>scrCargoInYard_change(scroll: ScrollBar input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 February 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

	size : Integer;
	
begin

	if self.isUnloaderForm then
		size := self.myMobileGenericAgent.allUnloadedTis.size;
		
	else
		size := self.getInYardButtonCount();	//05 Aug 2014	NDL	Par 34675
	endif;

	self.setMenuScrollStart( scroll, self.btnInYardTemp, self.frmCargoInYard, size );
	
epilog

end;</source>
        <Parameter name="scroll" type="ScrollBar" usage="input"/>
    </JadeMethod>
    <JadeMethod name="scrCargoOnTruck_change" id="3ebde1f6-09b9-41fe-914a-dcc34dcef56e">
        <controlMethod name="ScrollBar::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>scrCargoOnTruck_change(scroll: ScrollBar input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 February 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars
	
	size : Integer;
	infoSet : CM_ReceivalRequestInfoSet;
	
begin

	if self.isUnloaderForm then
		size := self.myMobileGenericAgent.allLoadedWles.size + 1;
		
		size := size + self.getMultiSize();
		
	else
		size := self.myMobileGenericAgent.allLoadedTis.size;
		
		//29 Mar 2010	NDL	Par 23454
		create infoSet transient;	
		self.myMobileGenericAgent.getAllReceivalRequestInfos( infoSet );
		size := size + infoSet.size;
		
		size := size.max( self.onTruckButtonCount );	//30 Nov 2015	NDL	Par 37153
		
	endif;

	self.setMenuScrollStart( scroll, self.btnOnTruckTemp, self.frmCargoOnTruck, size );
	
epilog

	delete infoSet;

end;</source>
        <Parameter name="scroll" type="ScrollBar" usage="input"/>
    </JadeMethod>
