    </JadeMethod>
    <JadeMethod name="translateForm" id="9db79186-c49a-4254-a78e-53ecb0808688">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 03 March 2016.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0021174, locale);
	lblDirection.translateCaption(Xlat_0021175, locale);
	lblROROArea.translateCaption(Xlat_0021176, locale);
	lblROROLane.translateCaption(Xlat_0021177, locale);
	optLeft.translateCaption(Xlat_0021178, locale);
	optRight.translateCaption(Xlat_0021179, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
</GUIClass>
