    <JadeMethod name="setProxyCollections" id="a042f5bf-ee74-4c3b-89b7-72406d161122">
        <updating/>
        <source>setProxyCollections(	_bookingRefs : CM_BookingRefSet;
						_bulkReleases : CM_BulkReleaseSet;
						_sourceWorkOrders : CM_WorkOrderSet;
						_woRequests : CM_WorkOrderRequestByTypeSet	) updating;
// -----------------------------------------------------------------------------
// Created:		05 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	proxyRequest : CM_WorkOrderRequestByType;
	
begin
	self.allBookings.clear(); 
	if _bookingRefs &lt;&gt; null  then
		_bookingRefs.copy( self.allBookings );
	endif;
	
	self.allBulkReleases.clear();
	if _bulkReleases &lt;&gt; null then
		_bulkReleases.copy( self.allBulkReleases );
	endif;
	
	self.allSourceWorkOrders.clear();
	if _sourceWorkOrders &lt;&gt; null then
		_sourceWorkOrders.copy( self.allSourceWorkOrders );
	endif;

	if _woRequests = null then
		self.allWORequestByType.purge();
	else
		foreach proxyRequest in self.allWORequestByType	where not _woRequests.includes( proxyRequest ) do
			self.proxyDeleteWoRequest( proxyRequest );
		endforeach;
		foreach proxyRequest in _woRequests	where not self.allWORequestByType.includes( proxyRequest ) do
			self.proxyAddWoRequest( proxyRequest );
		endforeach;
	endif;
	
epilog

end;</source>
        <Parameter name="_bookingRefs" type="CM_BookingRefSet"/>
        <Parameter name="_bulkReleases" type="CM_BulkReleaseSet"/>
        <Parameter name="_sourceWorkOrders" type="CM_WorkOrderSet"/>
        <Parameter name="_woRequests" type="CM_WorkOrderRequestByTypeSet"/>
    </JadeMethod>
    <JadeMethod name="validate" id="bf146efd-50f6-498a-bae0-d36c8fd39624">
        <source>validate();
// -----------------------------------------------------------------------------
// Created:		05 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
// 11/05/2018	jlgdap1		TFS 38501 PEL1 Work Order Changes
// 12/09/2018	jlgdap1		TFS 40157 PEL1 Change Voyage Work Order
// 10/09/2021   navma1 		ChangeRequest 51002: MTN - Web Portal Cargo Work Orders
// -----------------------------------------------------------------------------

vars
	terminal  : CM_Terminal;
	ti 		  : CM_TrackedItem;
	tiArray   : StringArray;
	tiId	  : String;
	tiList 	  : String;
	workOrder : CM_WorkOrder;
	woParent  : Object;
	
begin
	if self.tiTextList &lt;&gt; null then
		if self.cargoType = null then
			app.raiseCMException1(Input_required_field_Required, app.getErrorString(CargoType), null, null); // cnwdb2	PAR 35364
			return;
		endif;

		workOrder	 := self.getWorkOrder();
		woParent	 := self.myParent;           //10.09.2021 navma1 #51002
		
		if workOrder.taskStatus = WO_STATUS_APPROVED then
			tiList  := self.tiTextList;
			tiList.replaceChar(",", " ");
			tiArray := tiList.getTokens();
			
			terminal := workOrder.myTerminal;
			
			if woParent.isKindOf(CM_WorkOrder) then                  //10.09.2021 navma1 #51002              
				foreach tiId in tiArray do
					if self.myParent.CM_WorkOrder.isWorkOrderForReceival then														// TFS 38501
					ti := terminal.lookupTrackedItem(tiId.trimBlanks, null, TI_STATE_NOTIFIED, null, false);				// TFS 38501
					if ti = null then																						// TFS 38501
						app.raiseCMException1(ERR_TI_NOT_NOTIFIED, tiId, null, null);										// TFS 38501
					endif;																									// TFS 38501
					elseif self.myParent.CM_WorkOrder.isWorkOrderForRelease then														// TFS 38501
						ti := terminal.lookupTrackedItem(tiId.trimBlanks(), null, TI_STATE_NORMAL, null, false);			// TFS 38501
						if ti = null then																					// TFS 38501
							app.raiseCMException1(ERR_TI_NOT_ONSITE, tiId, null, null);										// TFS 38501
						endif;																								// TFS 38501
					elseif self.myParent.CM_WorkOrder.isWorkOrderForNullVoyage then											// TFS 40157
						ti := terminal.lookupTrackedItem(tiId.trimBlanks, null, TI_STATE_NORMAL, null, false);				// TFS 40157
						if ti = null then																					// TFS 40157
							ti := terminal.lookupTrackedItem(tiId.trimBlanks, null, TI_STATE_NOTIFIED, null, false);		// TFS 40157
						endif;																								// TFS 40157
						if ti = null then																					// TFS 40157
							app.raiseCMException1(Cargo_item_not_prenot_site, tiId, null, null);							// TFS 40157
						endif;																								// TFS 40157
					else																									// TFS 38501
						ti := terminal.lookupTrackedItem(tiId.trimBlanks(), self.cargoType, TI_STATE_NORMAL, null, false);
						if ti = null then
							app.raiseCMException1(ERR_TI_NOT_ONSITE, tiId, null, null);
						endif;
					endif;						
				endforeach;
			endif;
		endif;
	endif;

epilog
	delete tiArray;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="893b1917-291d-4612-9d80-5f913a96f887">
        <source>validateForCreate();
// -----------------------------------------------------------------------------
// Created:		05 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	proxyRequest : CM_WorkOrderRequestByType;
	
begin
	self.validate();

	//  Validate requests that are going to be added
	
	foreach proxyRequest in self.allWORequestByType do
		proxyRequest.validateForCreate();
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="c96691a1-b36b-45b3-b8a1-4a18157e417b">
        <source>validateForUpdate();
// -----------------------------------------------------------------------------
// Created:		05 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	bookingRef : CM_BookingRef;
	bulkRelease : CM_BulkRelease;
	len	: Integer;
	proxyRequest : CM_WorkOrderRequestByType;
	realRequest : CM_WorkOrderRequestByType;
	realTISource : CM_WorkOrderTISource;
	realWorkOrder : CM_WorkOrder;
	requestColl : CM_WorkOrderRequestByTypeSet;
	sourceRemoved : Boolean;
	sourceChanged : Boolean;
	workOrder : CM_WorkOrder;
	
begin
	self.validate();

	realTISource := self.pxyGetRealObject();
	realWorkOrder := realTISource.getWorkOrder();

	//  Validate requests that are going to be added/updated
	
	create requestColl transient;
	
	foreach proxyRequest in self.allWORequestByType do
		realRequest := proxyRequest.pxyGetRealObject();
		if realRequest = null then
			proxyRequest.validateForCreate();
			sourceChanged := true;
		else
			proxyRequest.validateForUpdate();
			requestColl.add(realRequest);
		endif;
	endforeach;
	
	//  Validate requests that are going to be deleted
	
	foreach realRequest in realTISource.allWORequestByType where not requestColl.includes(realRequest) do
		realRequest.validateForDelete();
		sourceRemoved := true;
	endforeach;

	//  Check Work Order state permits changes
	
	if not realWorkOrder.canSourcesBeRemoved() then
		if realTISource.tiTextList &lt;&gt; null and self.tiTextList &lt;&gt; realTISource.tiTextList then
			sourceChanged := true;
			len := realTISource.tiTextList.length;
			if self.tiTextList.length &lt; len
			or self.tiTextList[1:len] &lt;&gt; realTISource.tiTextList then
				sourceRemoved := true;
			elseif self.tiTextList[len+1:1] &lt;&gt; " " and self.tiTextList[len+1:1] &lt;&gt; "," then
				sourceRemoved := true;
			endif;
		endif;
		foreach bookingRef in realTISource.allBookings where not self.allBookings.includes(bookingRef) do
			sourceRemoved := true;
			break;
		endforeach;
		foreach bulkRelease in realTISource.allBulkReleases where not self.allBulkReleases.includes(bulkRelease) do
			sourceRemoved := true;
			break;
		endforeach;
		foreach workOrder in realTISource.allSourceWorkOrders where not self.allSourceWorkOrders.includes(workOrder) do
			sourceRemoved := true;
			break;
		endforeach;
	endif;	
	
	if sourceRemoved and not realWorkOrder.canSourcesBeRemoved() then
		app.raiseCMException2(ERR_CannotDelCargoSourceFromWO, realWorkOrder.id.asStringJMT(), realWorkOrder.getStatusString(), null, null);
	elseif not realWorkOrder.canSourcesBeAdded()  and sourceChanged  then
		app.raiseCMException2(ERR_CannotAddCargoSourcesToWO, realWorkOrder.id.asStringJMT(), realWorkOrder.getStatusString(), null, null);
	endif;
	
epilog
	delete requestColl;
end;</source>
    </JadeMethod>
</Class>
