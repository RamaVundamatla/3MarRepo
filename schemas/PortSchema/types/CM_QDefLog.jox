<Class name="CM_QDefLog" id="e6746c9c-a3dc-4701-84de-0718c8536654">
    <superclass name="CM_QDefBreakBulk"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="create" id="8121b1a7-741f-4856-9321-8708e390d0f2">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     24 November 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.className := 'CM_Log';

end;</source>
    </JadeMethod>
    <JadeMethod name="createProperties" id="a318ce5b-2fc2-40f1-b13a-623c0adc25ae">
        <source>createProperties();
// ---------------------------------------------------------------------------
// Created:     18 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
/****Changes

Date		Name	TFS#	Description
============================================================================
10/10/2018	jlgka1	40200	Add CM_QStrUserProperty	for "Scaler List".
20/12/2018	jlgka1	40200	Change the tmpProp to use class property instead
							of hardcoded name.						
============================================================================*/
vars
	tmpProp		: CM_QueryProperty;
begin
	
	inheritMethod();

	create tmpProp as CM_QDateProperty persistent;
	tmpProp.set('Fell Date', CM_Log::fellDate.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);

	create tmpProp as CM_QBooleanProperty persistent;
	tmpProp.set('Is Average Scaled', CM_Log::isAverageScaled.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);

	create tmpProp as CM_QBooleanProperty persistent;
	tmpProp.set('Is Unscaled', CM_Log::isUnscaled.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);

	create tmpProp as CM_QDecimalProperty persistent;
	tmpProp.set('JAS Volume', CM_Log::jasVolume.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);

	create tmpProp as CM_QRefLogSpeciesProperty persistent;
	tmpProp.set('Log Species', CM_Log::myLogSpecies.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QRefLogGradeProperty persistent;
	tmpProp.set('Log Grade', CM_Log::myLogGrade.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QRefLogTypeProperty persistent;
	tmpProp.set('Log Type', CM_Log::myLogType.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QRefLogTreatmentProperty persistent;
	tmpProp.set('Log Treatment', CM_Log::myLogTreatment.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QRefLogLengthProperty persistent;
	tmpProp.set('Log Length', CM_Log::myLogLength.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QDecimalProperty persistent;
	tmpProp.set('SED Max', CM_Log::sedMax.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QDecimalProperty persistent;
	tmpProp.set('SED Mean', CM_Log::sedMean.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QDecimalProperty persistent;
	tmpProp.set('SED Min', CM_Log::sedMin.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);

	create tmpProp as CM_QDecimalProperty persistent;
	tmpProp.set('Weight Tonnes', CM_Log::weightTonnes.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QStringProperty persistent;
	tmpProp.set('Scaler Code', CM_Log::scalerCode.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	//jlgka1 TFS 40200 10/10/2018 --&gt;
	create tmpProp as CM_QStrUserMethod persistent;
	tmpProp.set('Scaler List', CM_Log::getScalerCode.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	//jlgka1 TFS 40200 10/10/2018 &lt;--
end;</source>
    </JadeMethod>
</Class>
