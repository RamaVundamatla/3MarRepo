    <JadeMethod name="isJobTheSame" id="91498ae7-8eeb-4409-8134-fb2e3b2b54d0">
        <source>isJobTheSame(_isLoad : Boolean; _job : CM_Job) : Boolean;
// ---------------------------------------------------------------------------
// Created:     30 January 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theRequest	: CM_SlotRequest;
	theJob		: CM_Job;
	
begin

	if _isLoad then
		theRequest := self.mySlotRequestLoad;
	else
		theRequest := self.mySlotRequestDischarge;
	endif;
	
	if theRequest = null then
		return false;
	endif;
	
	theJob := theRequest.myJob;
	if theJob = null then
		return false;
	endif;
	
	return (_job = theJob); 
	

end;</source>
        <Parameter name="_isLoad" type="Boolean"/>
        <Parameter name="_job" type="CM_Job"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
