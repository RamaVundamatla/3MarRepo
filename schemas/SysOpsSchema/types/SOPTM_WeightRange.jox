    <JadeMethod name="loadDataForFirstTime" id="401f475a-9c67-48dd-931b-3b001c88f02a">
        <updating/>
        <source>loadDataForFirstTime() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Changed On	By			Reason
----------	--------	-----------------------------------------------------
30/04/2013	cnwdap1		Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
*/
vars
	form 	: SOP_TableMaintForm;
	measure : CM_MeasurementType;
	idx		: Integer;

begin
	inheritMethod();
	
	// show weight type combo and load its entries, and set to system default weight
	form := self.myForm;
	form.cmbWeightType.clear;
	form.cmbWeightType.visible := true;
	form.lblWeightType.visible := true;
	form.lblWeightType.move(form.cmbTable.left + form.cmbTable.width + 30, form.lblTable.top, form.lblWeightType.width, form.lblTable.height);
	form.cmbWeightType.move(form.lblWeightType.left + form.lblWeightType.width + 10, form.cmbTable.top, 150, form.cmbTable.height);
	foreach measure in app.myRoot.allMeasurementTypesByShortName where measure.measurementType = Type_Weight do
		idx := form.cmbWeightType.addItem(measure.name);
		form.cmbWeightType.itemObject[idx] := measure;
	endforeach;
	measure := app.getDefaultMeasurementForType(Type_Weight);
	form.cmbWeightType.setIndexFromObject(measure);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="46dd7f46-7c04-4849-8c60-0c33b2092c79">
        <updating/>
        <source>setControlsForAddEdit() updating;
//-----------------------------------------------------------------------
//
//  Created by: cnwsh3
//
//	Date: 25 September 2003
//
//-----------------------------------------------------------------------

vars
	theForm : SOP_TableMaintForm;

begin
  
	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;

	if theForm.mode = theForm.Mode_Add then
		theForm.tblInput1.clearValues;
		theForm.tblInput1.setValueByName(ETRow_Colour, White.String);
		theForm.tblInput1.setFocus;
		theForm.tblInput1.moveFirst();
	else
		// refresh the data from the newly created proxy
		self.showThumbnail(theForm.myProxyObject.CM_WeightRange);
		// cannot update code		
	endif;

	

end;</source>
    </JadeMethod>
