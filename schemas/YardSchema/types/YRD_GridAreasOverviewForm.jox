    <JadeMethod name="showLabourRestrictionForm" id="8541afe3-571c-42ea-a591-d3d66c9e7c6f">
        <source>showLabourRestrictionForm(_ta : CM_TerminalSubArea; _termArea : CM_TerminalArea);
// ---------------------------------------------------------------------------
// Created:     07 June 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin

	self.myAssistant.showLabourRestrictForm(_ta,_termArea, self.myMasterMenuAction);
