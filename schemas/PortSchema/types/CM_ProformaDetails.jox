    <JadeMethod name="createInvoiceLineFromProforma" id="b48f14d4-e054-4840-9650-d25f4fcf0d0e">
        <source>createInvoiceLineFromProforma(_inv : CM_Invoice; _useRate: Boolean) : CM_InvoiceLine;
/*

Purpose:			// TFS 37964 

Parameters:			

Return Value:		

Date			Who		Reason
10 July 2018	jlgab1	Initial creation
23 Oct 2024		navlw1 	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/

vars
	debtor : CM_Debtor;
	newLine : CM_InvoiceLine;
	seqNum : Integer;
	bank : CM_Bank;
	charge : CM_Charge;
	workOrder : CM_WorkOrder;	//12 Mar 2019	NDL	TFS 43405
	txnParams : CMIF_StorageTransController;	//12 Mar 2019	NDL	TFS 43405
	woTIDetail : CM_WorkOrderTIDtl;
	canLogExtra	: Boolean;	//27.02.2025 navah1	#34141
	theController : CMIF_InvoiceLineManual; //29/09/2025	navkc1 JIRA 35917
begin
	canLogExtra	:= app.canLogExtraDetail();				//27.02.2025 navah1	#34141
	if self.myInvoiceLineType = null then
		return null;
	endif;
	
	debtor := self.getDebtor();
	
	if debtor = null then
		return null;
	endif;
	
	bank := self.getBank();
	/*//29/09/2025	navkc1 JIRA 35917 - Change to use standard CMIF_InvoiceLineManual
	create newLine persistent;
	seqNum := app.getNextInvoiceSeqNumOnRootBank(SN_INVOICELINE);
	newLine.setForCreate(	seqNum,
							true,
							self.remarks,
							self.myInvoiceLineType,
							_inv,
							debtor,
							bank,
							self.quantity,
							app.actualTimeServer()
							);
							
	newLine.setTrackedItem(self.myTrackedItem); // TFS 39443
	
	newLine.createCharges();
	
	
	foreach charge in newLine.charges do
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog(method.qualifiedName &amp; " Calling CM_Charge.evaluateRate", LogINFO.String); // TFS 42084
		endif;
		charge.evaluateRate();
		charge.total := self.lineTotal;
// TFS 42084 charge.isTotalSetExplicitly := true; // should not have used isTotalSetExplicitly should have used overridden
		charge.setOverriden(); // TFS 42084
		
		if self.overridden then	//29 Jan 2019	NDL	TFS 42940
			charge.setRateForMinMax(self.rate);
		elseif _useRate then
			charge.setRateForMinMax(charge.getRate);		// 21/12/18 MAP TFS42646
		else
			charge.setRateForMinMax(charge.total);
		endif;
	endforeach;
	*/
	
	//29/09/2025	navkc1 JIRA 35917
	create theController transient;
	theController.remarks := self.remarks;
	theController.myInvoice := _inv;
	theController.quantity := self.quantity;
	theController.chargeTime := app.actualTimeServer();
	theController.isOverridden := true;
	theController.myTrackedItem := self.myTrackedItem;
	theController.totalAmount := self.lineTotal;
	if self.overridden then
		theController.rate := self.rate;
	elseif _useRate then
		theController.useChargeGetRate := true;
	else
		theController.rate := self.lineTotal;
	endif;
	
	newLine := self.myInvoiceLineType.createManualInvoiceLine(theController, self.myTrackedItem, false);
	
	//12 Mar 2019	NDL	TFS 43405
	if self.transactionType = TRANS_TYPE_STORAGE
	and self.myCashReceipt &lt;&gt; null
	and self.myTrackedItem &lt;&gt; null
	then
		workOrder := self.myCashReceipt.myWorkOrder;
		
		if workOrder.isWorkOrderForRelease() // TFS 43405 JLGAB1
		or workOrder.isWorkOrderForReleaseExtension() then // TFS 43405 JLGAB1
			woTIDetail := workOrder.allWoDtls.first.CM_WorkOrderTIDtl; // TFS 43405 JLGAB1
		endif;

		create txnParams transient;
		txnParams.type 			:= TRANS_TYPE_STORAGE;
		txnParams.dateTime 		:= workOrder.requiredByDT;
		txnParams.noCharge 		:= true;
		txnParams.createdByBGP	:= true; // kludge to ensure the dateTime above is actually used.
		txnParams.myWorkOrderDtl := woTIDetail; // TFS 43405 JLGAB1
		self.myTrackedItem.createTransaction( txnParams, app.myPassport );
	endif;
	
	//29/09/2025	navkc1 JIRA 35917 - Invoice Line is now created using the standard CMIF, it's already doing setTotalAmount;
	//newLine.setTotalAmount();  // ### JIRA 35502 21JUL2025 NAVAB1 if setting the total then set static value as well	
	
	return newLine;
epilog
	delete theController; //29/09/2025	navkc1 JIRA 35917
end;</source>
        <Parameter name="_inv" type="CM_Invoice"/>
        <Parameter name="_useRate" type="Boolean"/>
        <ReturnType type="CM_InvoiceLine"/>
    </JadeMethod>
    <JadeMethod name="getBank" id="515693f9-048d-4f3d-a63d-ce13a4c90c27">
        <source>getBank() : CM_Bank;
 /*

Purpose:		// TFS 37964 	

Parameters:			

Return Value:		

Date		Who		Reason
10 July 2018	jlgab1	Initial creation

*/

vars
	cashpay : CM_CashPayment;
begin

	cashpay := self.allCashPayments.first;
	
	if cashpay= null then
		return null;
	endif;
	
	return cashpay.getBank();

epilog

end;</source>
        <ReturnType type="CM_Bank"/>
    </JadeMethod>
