		resultStr := "Fail";
		tempStr := CrLf &amp; "The following Config (Terminal / System) values have changed during the unit test run:" &amp; CrLf;
		foreach str in detailsToOutput do
			tempStr := tempStr &amp; str;
		endforeach;
	else
		resultStr := "Pass";
	endif;
	
	// create a unit test record
	beginTransaction;
