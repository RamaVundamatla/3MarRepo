    <JadeMethod name="delete" id="6ad84caa-3eeb-460c-aa30-07a232ef4c72">
        <updating/>
        <source>delete() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 September 2008	cnwkao1	Initial creation

*/

vars

begin
	self.allSelectedRequestTypes.purge();
	self.allStopTables.purge();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="event" id="88722483-bcbb-40b2-8a7d-4de45573fd48">
        <methodInvocation>mapping</methodInvocation>
        <source>event(set : Boolean; _value : String io) mapping;

/*

Purpose: Mapping method to create event request objects			

Parameters:			

Return Value:		


Date		Who		Reason
28 August 2008	cnwcrs2	Initial creation
09 Sep 2008	cnwkao1	reworked
16 Feb 2009 cnwdz2 updated the delimiter to get the correct collection. 
*/

vars
	requestTypes: StringArray;
	str:		String;
	reqType:	WS_RequestType;
begin

	if set then
		create requestTypes transient;
		_value.getTokensForDelimiter("|", requestTypes);
		foreach str in requestTypes do
			create reqType transient;
			reqType.description := str;
			allSelectedRequestTypes.add(reqType);
		endforeach;	
	endif;	
epilog
	delete requestTypes;	
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
</Class>
