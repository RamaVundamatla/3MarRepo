<Class name="Process">
    <JadeMethod name="cnEcEvaluate" id="9effa38b-b0d1-4aea-aa67-7ca17fb75faa">
        <source>cnEcEvaluate(pExpression:String; pReturnType:Type; pReceiverObj:Object; pReturnValue:Any io):String;
// --------------------------------------------------------------------------------
// Created:		27 August 2001 by cnwdad1
//
// Purpose:		Evaluates an expression based upon JADE syntax.  The string to be
//				evaluated need only be expressed in simplistic terms, for example:
//
//					"(22/7) * 20 ^ 2"
//
//				...note that there is no need to append the expression with a
//				semi-colan (;).
//
//				Refer to the Process::cnEcExecute method for handling the execution
//				of full method source.
//
// Parameters:	None
//
// Returns:		The result of the evaluation is returned by the pReturnValue io
//				parameter.  The method itself will return a null value if the
//				expression is successfully evaluated, otherwise an error message
//				will be returned.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	methodObj		: JadeMethod;
	sourceCode		: String;
	errorCode		: Integer;
	errorPosition	: Integer;
	errorLength		: Integer;
	errorMessage	: String;

begin
	sourceCode	:=	"return " &amp; pExpression &amp; ";";
	methodObj	:=	process.createTransientMethod(	"evaluate",
													pReceiverObj.class(),
													currentSchema,
													sourceCode,
													true,
													pReturnType,
													errorCode,
													errorPosition,
													errorLength);
	
	if methodObj = null then
		errorMessage	:=	errorCode.String &amp;
							" - " &amp; process.getErrorText(errorCode) &amp;
							" (Position=" &amp; errorPosition.String &amp;
							":" &amp; errorLength.String &amp; ")";
		
		return errorMessage;
	else
		pReturnValue	:=	process.executeTransientMethod(methodObj, pReceiverObj);
		return null;
	endif;
epilog
	process.deleteTransientMethod(methodObj);
end;</source>
        <Parameter name="pExpression" type="String"/>
        <Parameter name="pReturnType" type="Type"/>
        <Parameter name="pReceiverObj" type="Object"/>
        <Parameter name="pReturnValue" type="Any" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcExecute" id="6500cdff-e791-4532-8fd9-c8cb9e4de86d">
        <source>cnEcExecute(pSource:String;
			pReturnType:Type;
			pReceiverObj:Object;
			pReturnValue:Any io
//			pAllParameters:ParamListType
			):String;
// --------------------------------------------------------------------------------
// Created:		27 August 2001 by cnwdad1
//
// Purpose:		Executes JADE source code based upon JADE syntax.
//
//				Refer to the Process::cnEcEvaluate method for handling the execution
//				of simple expressions.
//
// Parameters:	None
//
// Returns:		The result of the execution is returned by the pReturnValue io
//				parameter.  The method itself will return a null value if the
//				source is successfully executed, otherwise an error message will
//				be returned.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	methodObj		: JadeMethod;
	sourceCode		: String;
	errorCode		: Integer;
	errorPosition	: Integer;
	errorLength		: Integer;
	errorMessage	: String;

begin
	sourceCode	:=	"return " &amp; pSource &amp; ";";
	methodObj	:=	process.createTransientMethod(	"evaluate",
													pReceiverObj.class(),
													currentSchema,
													sourceCode,
													false,
													pReturnType,
													errorCode,
													errorPosition,
													errorLength);
	
	if methodObj = null then
		errorMessage	:=	errorCode.String &amp;
							" - " &amp; process.getErrorText(errorCode) &amp;
							" (Position=" &amp; errorPosition.String &amp;
							":" &amp; errorLength.String &amp; ")";
		
		return errorMessage;
	else
		pReturnValue	:=	process.executeTransientMethod(methodObj, pReceiverObj);
		return null;
	endif;
epilog
	process.deleteTransientMethod(methodObj);
end;</source>
        <Parameter name="pSource" type="String"/>
        <Parameter name="pReturnType" type="Type"/>
        <Parameter name="pReceiverObj" type="Object"/>
        <Parameter name="pReturnValue" type="Any" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetDisplay" id="18ffac7e-4f1a-4d9d-9481-82478c79dce2">
        <source>cnEcGetDisplay():String;
// --------------------------------------------------------------------------------
// Created:		19 April 2006 by cnwdad1
//
// Purpose:		Returns a display string of the receiver.
//
// Parameters:	None
//
// Returns:		The display string.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	displayValue	: String;
	signonCode		: String;

begin
	displayValue	:=	self.userCode;
	
	if self.signOnUserCode &lt;&gt; null
	and self.signOnUserCode &lt;&gt; displayValue
	then
		displayValue	:=	displayValue &amp; "/" &amp; self.signOnUserCode;
	endif;
	
	if self.userInfo &lt;&gt; null then
		displayValue	:=	displayValue &amp; "/" &amp; self.userInfo;
	endif;
	
	return displayValue;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetTableDisplay" id="45653b1e-3ae6-4372-85d5-b4faa0681d60">
        <source>cnEcGetTableDisplay():String;
// --------------------------------------------------------------------------------
// Created:		27 May 2000 by cnwdad1
//
// Purpose:		Returns a 5-column display of process information for a table control.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowDisplay	: String;
	signonCode	: String;

begin
	if self.signOnUserCode = null then
		signonCode	:=	null;
	else
		signonCode	:=	"/" &amp; self.signOnUserCode;
	endif;
	
	rowDisplay	:=	self.userCode &amp; signonCode &amp;
					Tab &amp; self.persistentApp.name &amp;
					Tab &amp; self.schema.name &amp;
					Tab &amp; self.signOnTime.String &amp;
					Tab &amp; self.userInfo;
epilog
	return rowDisplay;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetUserInfoFieldValue" id="8122ba75-b8ff-4bbc-938b-8bd2c26a128a">
        <source>cnEcGetUserInfoFieldValue(pFieldName:String):String;
// --------------------------------------------------------------------------------
// Created:		01 December 2000 by cnwdad1
//
// Purpose:		This method will fetch the value of a "field" within the UserInfo
//				property.
//
// Parameters:	pFieldName (String) - The name of the field whose value to return.
//
// Returns:		The string value of the requested field.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	userInfoData	: String;
	dataLength		: Integer;
	fieldPos		: Integer;
	nextFieldPos	: Integer;
	valuePos		: Integer;
	valueLength		: Integer;
	
begin
	userInfoData	:=	self.userInfo;
	
	fieldPos		:=	userInfoData.pos(pFieldName &amp; CNEC_PROCESS_FIELD_ASSIGNMENT, 1);
	
	if fieldPos &gt; 0 then
		dataLength	:=	userInfoData.length;
		valuePos	:=	fieldPos + (pFieldName.length + CNEC_PROCESS_FIELD_ASSIGNMENT.String.length);
		
		if valuePos &lt;= dataLength then
			nextFieldPos	:=	userInfoData.pos(CNEC_PROCESS_FIELD_DELIMITER, valuePos);
			
			if nextFieldPos = 0 then
				// There are no (more) fields, so return the remainder of the User Info data.
				return userInfoData[valuePos:end];
			else
				// Return the value for the field.
				valueLength	:=	nextFieldPos - valuePos;
				return userInfoData[valuePos:valueLength];
			endif;
		endif;
	endif;

	return null;
end;</source>
        <Parameter name="pFieldName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcSetUserInfoFieldValue" id="49817c7c-857f-439c-b3bf-7d98d2b7c12f">
        <updating/>
        <source>cnEcSetUserInfoFieldValue(pFieldName:String; pFieldValue:String) updating;
// --------------------------------------------------------------------------------
// Created:		01 December 2000 by cnwdad1
//
// Purpose:		This method will set the value of a "field" within the UserInfo
//				property.  It is assumed that the calling method has taken care
//				of obtaining a lock on this object, as well as the transaction.
//
// Parameters:	pFieldName (String) - The name of the field to update.
//				pFieldValue (String) - The value to et the field to.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	userInfoData	: String;
	dataLength		: Integer;
	newFieldValue	: String;
	fieldPos		: Integer;
	nextFieldPos	: Integer;
	valuePos		: Integer;
	fieldWithAssign	: String;
	fieldWithValue	: String;
	
begin
	userInfoData	:=	self.userInfo;
	newFieldValue	:=	pFieldValue;
	fieldWithAssign	:=	pFieldName &amp; CNEC_PROCESS_FIELD_ASSIGNMENT;
	fieldWithValue	:=	fieldWithAssign &amp; newFieldValue;

	fieldPos		:=	userInfoData.pos(pFieldName &amp; CNEC_PROCESS_FIELD_ASSIGNMENT, 1);
	
	if fieldPos = 0 then
		if userInfoData = null then
			userInfoData	:=	fieldWithValue;
		else
			userInfoData	:=	userInfoData &amp; CNEC_PROCESS_FIELD_DELIMITER &amp; fieldWithValue;
		endif;
	else
		// First, check whether the field needs to be updated.
		
		if self.cnEcGetUserInfoFieldValue(pFieldName) = newFieldValue then
			return;
		endif;
	
		// Proceed to update the field's value.
	
		dataLength	:=	userInfoData.length;
		valuePos	:=	fieldPos + (pFieldName.length + CNEC_PROCESS_FIELD_ASSIGNMENT.String.length);
		
		if valuePos &lt;= dataLength then
			nextFieldPos	:=	userInfoData.pos(CNEC_PROCESS_FIELD_DELIMITER, valuePos);
		endif;

		if nextFieldPos = 0 then
			userInfoData	:=	userInfoData.cnEcInsertInto(newFieldValue,
															valuePos,
															0);
		else
			userInfoData	:=	userInfoData.cnEcInsertInto(newFieldValue,
															valuePos,
															nextFieldPos);
		endif;
	endif;

	self.userInfo	:=	userInfoData;
end;</source>
        <Parameter name="pFieldName" type="String"/>
        <Parameter name="pFieldValue" type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcTraceMethods" id="6e38ec27-9dc1-4f7c-8777-77c85641b8f5">
        <source>cnEcTraceMethods(pIsStart:Boolean);
// --------------------------------------------------------------------------------
// Created:		20 August 2008 by cnwdad1
//
// Purpose:		Starts or stops method tracing programatically.
//
// NOTE: The external function called by this method is not supported by the Jade
// Plant, and is subject to change in any future release of Jade.
//
// Parameters:	pIsStart - If true, start tracing, otherwise stop tracing.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	MESSAGE_START	: Integer = 2;
	MESSAGE_STOP	: Integer = 3;
	
vars
	oid	: Binary[14];
	
begin
	oid		:=	Process.number.Binary[1:2] &amp; self.getInstanceIdForObject(process).Integer.Binary[1:4];
	oid[14]	:=	null;
	
	if pIsStart then
		call cnEcInterpreterSendMessage(oid.bufferAddress(), MESSAGE_START);
	else
		call cnEcInterpreterSendMessage(oid.bufferAddress(), MESSAGE_STOP);
	endif;
end;</source>
        <Parameter name="pIsStart" type="Boolean"/>
    </JadeMethod>
</Class>
