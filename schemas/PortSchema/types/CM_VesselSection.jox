    <JadeMethod name="setForUpdate" id="bc281f10-6549-4899-96b3-ce1ccfac7e4e">
        <updating/>
        <source>setForUpdate(_proxySelf : SelfType;_passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin
	self.code := _proxySelf.code;
	self.maxLoadAxel:=_proxySelf.maxLoadAxel;
	self.maxLoadM2:=_proxySelf.maxLoadM2;
	self.maxLoadStack:=_proxySelf.maxLoadStack;
	self.maxLoadTotal:=_proxySelf.maxLoadTotal;
	self.position:=_proxySelf.position;
	self.remarks := _proxySelf.remarks;
epilog

end;</source>
