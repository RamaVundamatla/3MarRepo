    <JadeMethod name="setProxy" id="50a22969-16a4-4855-a8cd-b1f729fcc91e">
        <updating/>
        <source>setProxy( _code, 
		  _description : String;
		  _isNotAvailableForEntry : Boolean;
		  _terminal : CM_Terminal) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 June 2022	navak20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details

*/

vars

begin
	self.raiseExceptionIfNotTransient(method);
	self.code 			:= _code;
	self.description 	:= _description;
	self.isNotAvalableForEntry := _isNotAvailableForEntry;
	self.myTerminal		:= _terminal;
epilog

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
