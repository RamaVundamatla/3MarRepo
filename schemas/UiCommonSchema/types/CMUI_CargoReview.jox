    <JadeMethod name="compareOperators" id="fa6839e2-52f6-42db-85af-effea5a1450c">
        <source>compareOperators(_operator : CM_Operator; _ti:CM_TrackedItem) : CM_Operator;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 July 2023 navmv20 CR 58239 Task 58241: UI- Open COO Maint in Update mode

*/

vars

begin
	if not(_operator = null or _ti.myOperator = _operator) then
		app.raiseCMException(Selec_items_shoul_have_same_op,null,null);
	endif;
	return _ti.myOperator;
epilog

end;</source>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="create" id="7acb59fb-85f7-4797-888b-d6503af811ab">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 May 2022	jlier1	Initial creation

*/

vars

begin
	
	self.permissionView  := PmYardCargoReviewView;
	self.permissionMaint := PmYardCargoReviewView;
	
	self.myQDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type,null];
	create self.myCargoGroupQuery transient;
	create self.allGroupingRows transient;
	create self.allAdditionalRows transient;
	create self.myCriteriaLineHolder transient;
	create self.myCMIFCustDocSummaryAgent transient; //02/10/2023	navkc1	CR 60423 Task 60764
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="createCriteriaLinesFromParent" id="09898bb3-0696-42b5-92c3-49ab5be1cd13">
        <updating/>
        <source>createCriteriaLinesFromParent(_allCriteriaLines : CM_SelectorCriteriaLineArray) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27/09/2023	navkc1	CR 60428 Task 60702: UI - Cargo Review Option in Transport UI

*/

vars
	criteriaLine			: CM_SelectorCriteriaLine;
	idx						: Integer;
begin
	
	// Clear all criteria lines, create default lines from parent;
	self.myCriteriaLineHolder.allCriteriaLines.purge();
	self.tblCriteria.rows := self.tblCriteria.fixedRows;
	
	// Always include terminal
	if self.myTerminal &lt;&gt; null then	
		criteriaLine:=self.myQDef.createCriteriaLine(CM_TrackedItem::myTerminal.name,  CM_QueryOperator.Operator_Equal, self.myTerminal);
		criteriaLine.setMyCriteriaLineHolder(self.myCriteriaLineHolder);
		idx := self.tblCriteria.addItemObject(criteriaLine, criteriaLine.getDescriptionString);
		self.tblCriteria.accessRow(idx).backColor := criteriaLine.getPerformanceColour;
	endif;
	
	// Criteria lines from parent
	foreach criteriaLine in _allCriteriaLines do
		criteriaLine.setMyCriteriaLineHolder(self.myCriteriaLineHolder);
		idx := self.tblCriteria.addItemObject(criteriaLine, criteriaLine.getDescriptionString);
		self.tblCriteria.accessRow(idx).backColor := criteriaLine.getPerformanceColour;
	endforeach;
	
	self.setCriteriaLabel();
	self.doSearch();
	
epilog
	
end;</source>
        <Parameter name="_allCriteriaLines" type="CM_SelectorCriteriaLineArray"/>
    </JadeMethod>
    <JadeMethod name="createCustomDocuments" id="15e90036-d432-4f0c-9003-3bf5ff862989">
        <updating/>
        <source>createCustomDocuments(_groupingSelected : Boolean) updating;
/*
Purpose - 	
Who - NAVAB1
Date - 15AUG2023
ADO - CR 59615 TASK 59620 	
*/

vars
	jdoArray  : ObjectArray;
	jdo       : JadeDynamicObject;
	tiSet     : CM_TISet;
	index 	  : Integer;
	type      : Type;
	value     : Any;
	tisInGrouping : CM_TIByCargoTypeIdDict;
	iter      : Iterator;
	ti,
	firstTi	 : CM_TrackedItem;
	cargoGroup : CM_CargoGroup;
begin
	create tiSet transient;

	jdoArray := self.tblCargoGrouped.allSelectedObjects;
	
	foreach jdo in jdoArray as JadeDynamicObject do
		if jdo.getPropertyInfoByName(CMIF_CargoReviewQuery.CargoReviewAllTrackedItems,index,type,value) then	
			tisInGrouping := value.CM_TIByCargoTypeIdDict;
			if  jdo.getPropertyInfoByName(ETRow_CargoGroupId,index,type,value) and _groupingSelected and value &lt;&gt; null then
				firstTi := tisInGrouping.first;
				cargoGroup := firstTi.myCargoGroup;
				if cargoGroup &lt;&gt; null then
					
					 // ### TFS BUG 62772 05MAR2024 NAVAB1
					 if tisInGrouping.size = cargoGroup.allAssignedTrackedItems.size then
						tiSet.addNoDuplicates(cargoGroup, false); // ### TFS BUG 62772 05MAR2024 NAVAB1 no dups
					 else
						iter:= tisInGrouping.createIterator;
						while iter.next(ti) do
							tiSet.add(ti);
						endwhile;
					 endif;
				endif;
				
				 
			elseif _groupingSelected then
				iter:= tisInGrouping.createIterator;
				while iter.next(ti) do
					tiSet.add(ti);
				endwhile;
			else
				iter := self.tblCargo.allSelectedObjects.createIterator;
				while iter.next(ti) do
					tiSet.add(ti);
				endwhile;
			endif;
		endif;
	endforeach;
	
	self.openCustDocMaintForm(tiSet); // ### TFS BUG 62772 05MAR2024 NAVAB1
epilog
	delete tiSet;
	
end;</source>
        <Parameter name="_groupingSelected" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createDefaultCriteriaLines" id="66268709-0043-4229-8251-ae1dde4765ce">
        <updating/>
        <source>createDefaultCriteriaLines() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 May 2022	jlier1	Initial creation
*/

vars
	criteriaLine			: CM_SelectorCriteriaLine;
	idx : Integer;
begin
	
	//has been created by the XML setup
	if self.myCriteriaLineHolder.allCriteriaLines.first &lt;&gt; null then
		return;
	endif;

	if self.myTerminal &lt;&gt; null then	
		criteriaLine:=self.myQDef.createCriteriaLine(CM_TrackedItem::myTerminal.name,  CM_QueryOperator.Operator_Equal, self.myTerminal);
		criteriaLine.setMyCriteriaLineHolder(self.myCriteriaLineHolder);
		idx := self.tblCriteria.addItemObject(criteriaLine, criteriaLine.getDescriptionString);
		self.tblCriteria.accessRow(idx).backColor := criteriaLine.getPerformanceColour;
	endif;

	criteriaLine:=self.myQDef.createCriteriaLine(CM_TrackedItem::site.name, CM_QueryOperator.Operator_Equal, TI_SITE_ONSITE_str);
	criteriaLine.setMyCriteriaLineHolder(self.myCriteriaLineHolder);
	idx := self.tblCriteria.addItemObject(criteriaLine, criteriaLine.getDescriptionString);
	self.tblCriteria.accessRow(idx).backColor := criteriaLine.getPerformanceColour;
	
epilog
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="createOwnershipChange" id="9d9b981d-57f6-4564-84a4-0ffb25a07507">
        <updating/>
        <source>createOwnershipChange(_groupingSelected : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 July 2023 navmv20 CR 58239 Task 58241: UI- Open COO Maint in Update mode
11 August 2023 navmv20 Bug 59697: EUP - Change of Ownership Cargo Review - Able to create COO for Offsite Cargo
15 December 2023	navkc1	Bug 61768: FR | 53382 - Change of Owner ship option on Cargo review screen
*/

vars
	jdoArray  : ObjectArray;
	jdo       : JadeDynamicObject;
	tiSet     : CM_TISet;
	index 	  : Integer;
	type      : Type;
	value     : Any;
	tisInGrouping : CM_TIByCargoTypeIdDict;
	iter      : Iterator;
	ti,
	firstTi	 : CM_TrackedItem;
	operator  : CM_Operator;
	pxyCOO,
	realCOO : CM_OwnershipChange;
	cmifOwnreshipDetails : CMIF_OwnershipChangeDetail;
	pxyOwnershipChangeDetail : CM_OwnershipChangeDetail;
	detailSet : CM_OwnershipChangeDetailSet;
	cargoGroup : CM_CargoGroup;
	form   : CMUI_OwnershipChangeMaint;
	obj : Object; //11/08/2023 navmv20 Bug 59697
	tisOnSiteOnShip : CM_TIByCargoTypeIdDict; //11/08/2023 navmv20 Bug 59697
	totalSelected,
	totalRelevant : Integer; //11/08/2023 navmv20 Bug 59697
	notAllOnSiteOnShip : Boolean; //11/08/2023 navmv20 Bug 59697
	
begin
	create tiSet transient;
	create detailSet transient;
	
	//15 December 2023	navkc1	Bug 61768
	if _groupingSelected then
		jdoArray := self.tblCargoGrouped.allSelectedObjects;
		foreach jdo in jdoArray as JadeDynamicObject do
			if jdo.getPropertyInfoByName(CMIF_CargoReviewQuery.CargoReviewAllTrackedItems,index,type,value) then	
				tisInGrouping := value.CM_TIByCargoTypeIdDict;
				if  jdo.getPropertyInfoByName(ETRow_CargoGroupId,index,type,value) and _groupingSelected and value &lt;&gt; null then
					firstTi := tisInGrouping.first;
					cargoGroup := firstTi.myCargoGroup;
					if cargoGroup &lt;&gt; null then
						// ### TFS BUG 64097 10MAY2024 NAVAB1
						if tisInGrouping.size = cargoGroup.allAssignedTrackedItems.size then
							if self.getTISet(tiSet,cargoGroup,operator,firstTi) and cargoGroup.hasNotOnSiteOnShip() then
								notAllOnSiteOnShip := true;
							endif;
						else
							iter:= tisInGrouping.createIterator;
							while iter.next(ti) do
								if ti.isOffSite() then
									notAllOnSiteOnShip := true;
								endif;
								tiSet.add(ti);
							endwhile;
						endif;
					endif;
				elseif _groupingSelected then
					iter:= tisInGrouping.createIterator;
					while iter.next(ti) do
						//11/08/2023 navmv20 Bug 59697 - start
						//operator:= self.compareOperators(operator,ti);
						//tiSet.add(ti);
						self.getTISet(tiSet,ti,operator,ti);
						//11/08/2023 navmv20 Bug 59697 -end
					endwhile;
					totalSelected := totalSelected + tisInGrouping.size; //11/08/2023 navmv20 Bug 59697
					totalRelevant := tiSet.size; //11/08/2023 navmv20 Bug 59697
				endif;
			endif;
		endforeach;
	else
		iter := self.tblCargo.allSelectedObjects.createIterator;
		while iter.next(ti) do
			//11/08/2023 navmv20 Bug 59697 - start
			//operator:= self.compareOperators(operator,ti);
			//tiSet.add(ti);
			self.getTISet(tiSet,ti,operator,ti);
			//11/08/2023 navmv20 Bug 59697 -end
		endwhile;
		totalSelected := totalSelected + self.tblCargo.allSelectedObjects.size; //11/08/2023 navmv20 Bug 59697
		totalRelevant := totalRelevant +tiSet.size; //11/08/2023 navmv20 Bug 59697
	endif;
	//11/08/2023 navmv20 Bug 59697 - start
	//if notAllOnSiteOnShip or (totalRelevant &gt; 0 and (totalRelevant &lt;&gt; totalSelected)) then
	
	// ### JIRA 34108 03MAR2025 NAVAB1
	//	if notAllOnSiteOnShip or (totalRelevant &gt; 0 and (totalRelevant &lt;&gt; totalSelected)) or tiSet.isEmpty then
	//		app.msgBox(app.getErrorString(Selec_items_not_onsit_onshi_th), app.getErrorString(Message),MsgBox_OK_Only);
	//	endif;

	// ### JIRA 34108 03MAR2025 NAVAB1
	if notAllOnSiteOnShip  then
		app.msgBox(app.getErrorString(Selec_items_not_onsit_onshi_th), app.getErrorString(Message),MsgBox_OK_Only);
	elseif (totalRelevant &gt; 0 and (totalRelevant &lt;&gt; totalSelected)) then
		app.msgBox(app.getErrorString(Only_onsite_onship_cargo_allow),app.getErrorString(Message),MsgBox_OK_Only);
	elseif tiSet.isEmpty then
		app.msgBox(app.getErrorString(Nothing_Selected),app.getErrorString(Message),MsgBox_OK_Only);
	endif;	
	
	if tiSet.isEmpty then
		return;
	endif;
	//11/08/2023 navmv20 Bug 59697 - end
	
	self.openOwnershipMaintForm(tiSet);
epilog

end;</source>
        <Parameter name="_groupingSelected" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createReleaseRequest" id="21dba7aa-5511-42c8-b48c-2a8c5b92d0e0">
        <source>createReleaseRequest(relType : Integer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 June 2022	jlier1	Initial creation 53678
14 June 2023 	navhl20 Bug 58634: MTN - Release by Type option should be disabled if there is no VAS subscription 
28 June 2023 navmv20 CR 58410 Task 58411: UI - Cargo Review - Release Request
*/

vars
	pxyBulkRelease	: CM_BulkRelease;	
	voyage 		: CM_Voyage;
	jdo 		: JadeDynamicObject;
	jdoArray    : ObjectArray;//28/06/2023 navmv20 CR 58410 Task 58411
begin
	//28/06/2023 navmv20 CR 58410 Task 58411 - START
	/*jdo:=self.tblCargoGrouped.allSelectedObjects.first.JadeDynamicObject;
	if jdo =null then
		return;
	endif;

	pxyBulkRelease:= self.myCargoGroupQuery.createReleaseReqForGroup(relType,jdo);*/
	jdoArray := self.tblCargoGrouped.allSelectedObjects;
	pxyBulkRelease:= self.myCargoGroupQuery.createReleaseRequestForGroup(relType,jdoArray);
	//28/06/2023 navmv20 CR 58410 Task 58411 - END
	
	if pxyBulkRelease = null then
		return;
	endif;
	self.myAssistant.releaseRequestAdd(pxyBulkRelease,relType,self.myMasterMenuAction,null);			//14.6.2023 navhl20 #58634
epilog
	
end;</source>
        <Parameter name="relType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="delete" id="c5c62e64-2701-406b-828f-c5f0b3e1df86">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>delete() updating, clientExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 May 2022	jlier1	Initial creation

*/

vars
	entTableRow : EntTableRow;
	deleteColl : EntTableRowSet;
begin
	self.endNotificationForSubscriber(self);
	
	delete self.myCriteriaLineHolder;
	delete self.allGroupingRows;
	delete self.allAdditionalRows;
	
	create deleteColl transient;
	
	if self.allGroupingRowsAvailable &lt;&gt; null then
		foreach entTableRow in self.allGroupingRowsAvailable discreteLock do
			if entTableRow.isKindOf(EntTableRowProxy) then
				deleteColl.add(entTableRow);
			endif;
		endforeach;
	endif;
	if self.allAdditionalRowsAvailable &lt;&gt; null then
		foreach entTableRow in self.allAdditionalRowsAvailable discreteLock do
			if entTableRow.isKindOf(EntTableRowProxy) then
				deleteColl.add(entTableRow);
			endif;
		endforeach;
	endif;
	
	deleteColl.purge;
	delete self.allGroupingRowsAvailable;
	delete self.allAdditionalRowsAvailable;
	delete self.myCargoGroupQuery;
	delete self.myCMIFCustDocSummaryAgent; //02/10/2023	navkc1	CR 60423 Task 60764
epilog
	delete deleteColl;
end;</source>
    </JadeMethod>
    <JadeMethod name="displayCargoGroupResults" id="c42f89f2-658b-4879-847f-4b86557268be">
        <source>displayCargoGroupResults() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 May 2022	jlier1	Initial creation

*/

vars
	attrName : String;
	queryProp		: CM_QueryProperty;
	critLine : CM_SelectorCriteriaLine ;
	currentCol : Integer;
	entRow : EntTableRow;
	iter : Iterator;
	partsDone,
	partsInJob : Integer;
	lastUpdated		: Decimal [20];	
	
	order,
	col			: Integer;
	colsToSort	: IntegerArray;
begin
	self.tblCargoGrouped.clear;
	self.tblCargoGrouped.rows := 0;
	self.tblCargoGrouped.allSelectedObjects.clear(); //01/11/2023	navkc1	Bug 61059
	
	//02/10/2023	navkc1	CR 60423 Task 60764
	self.tblCustomDocument.rows := self.tblCustomDocument.fixedRows;
	
	create colsToSort transient;
	
	self.tblCargo.rows:=self.tblCargo.fixedRows;
	if self.myCargoGroupQuery.allGroupings.size = null then
		return;
	endif;
		
	self.tblCargoGrouped.rows := 1;
	self.tblCargoGrouped.fixedRows := 1;
	
	self.tblCargoGrouped.rows:= self.tblCargoGrouped.fixedRows;
	iter:=self.myCargoGroupQuery.allGroupings.createIterator;
	partsInJob:=self.myCargoGroupQuery.allGroupings.size * ( self.myCriteriaLineHolder.allCriteriaLines.size + self.allGroupingRows .size + self.allAdditionalRows.size);
	//set columns for selector attributes
	foreach critLine in self.myCriteriaLineHolder.allCriteriaLines  discreteLock do							
		queryProp:=critLine.myQueryProperty;
		attrName:=critLine.propName;
		
		currentCol := currentCol + 1;
		self.tblCargoGrouped.columns := currentCol;
		self.tblCargoGrouped.accessColumn(currentCol).itemObject := queryProp;
		self.tblCargoGrouped.accessCell(1, currentCol); //02/10/2023	navkc1	CR 60423 Task 60764
		self.tblCargoGrouped.accessedCell.text := queryProp.niceName;
		self.tblCargoGrouped.accessedCell.backColor := 7894642;
		self.tblCargoGrouped.accessedCell.foreColor := self.tblCargoGrouped.accessedCell.backColor.getInverseColour();
		self.displayCargoResultsForAttr(attrName,currentCol,partsDone,partsInJob,lastUpdated);
	endforeach;
	
	self.tblCargoGrouped.row :=self.tblCargoGrouped.fixedRows;
	foreach entRow in  self.allGroupingRows discreteLock do							
		currentCol := currentCol + 1;
		self.tblCargoGrouped.columns := currentCol;
		self.tblCargoGrouped.accessColumn(currentCol).itemObject := entRow;
		self.tblCargoGrouped.accessCell(1, currentCol); //02/10/2023	navkc1	CR 60423 Task 60764
		self.tblCargoGrouped.accessedCell.text := entRow.getHeading(null,null,app.myCurrentLocale);
		self.tblCargoGrouped.accessedCell.backColor := 12105134;
		self.tblCargoGrouped.accessedCell.foreColor := self.tblCargoGrouped.accessedCell.backColor.getInverseColour();
		self.displayCargoResultsForAttr(entRow.name,currentCol,partsDone,partsInJob,lastUpdated);
		colsToSort.add(currentCol);
	endforeach;
	
	self.tblCargoGrouped.row :=self.tblCargoGrouped.fixedRows;
	foreach entRow in  self.allAdditionalRows discreteLock do							
		currentCol := currentCol + 1;
		self.tblCargoGrouped.columns := currentCol;
		self.tblCargoGrouped.accessColumn(currentCol).itemObject := entRow;
		self.tblCargoGrouped.accessCell(1, currentCol); //02/10/2023	navkc1	CR 60423 Task 60764
		self.tblCargoGrouped.accessedCell.text := entRow.getHeading(null,null,app.myCurrentLocale);
		self.displayCargoResultsForAttr(entRow.name,currentCol,partsDone,partsInJob,lastUpdated);
	endforeach;
	
	//02/10/2023	navkc1	CR 60423 Task 60763
	foreach col in colsToSort do
		order += 1;
		// JADE can only sort up to 6
		if order &gt; 6 then
			break;
		endif;
		self.tblCargoGrouped.sortColumn[order] := col;
		self.tblCargoGrouped.sortAsc[order] := true;
		self.tblCargoGrouped.sortCased[order]	:= false;
	endforeach;
	
	self.tblCargoGrouped.resort(); //02/10/2023	navkc1	CR 60423 Task 60763
	
	self.doTableFilter(self.tblCargoGrouped); //02/10/2023	navkc1	CR 60423 Task 60763
epilog
	delete colsToSort;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="displayCargoResults" id="d348336a-ec9e-4335-b0ad-bccf97e80aa8">
        <updating/>
        <source>displayCargoResults(_allCargo : CM_TIByCargoTypeIdDict input) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 May 2022	jlier1	Initial creation

*/
vars
	cargo				: CM_TrackedItem;
	partsDone,
	partsInJob		: Integer;
	monitor			: CMIF_Monitor;
	fixedRows		: Integer;
	lastUpdated		: Decimal [20];								// PAR #35843
	pendingQty,
	clearedQty,
	quantity		: Integer;
	pendingWeight,
	clearedWeight,
	weight,
	pendingVol,
	clearedVol,
	volume			: Decimal[23,4];
begin
	partsInJob := _allCargo.size;
	if not self.doMaxTableSizeCheck(partsInJob, null) then
		return;
	endif;
	
	self.modalDialogReturnValue := null;
	self.modalDialogShow(null, app.getErrorString(Cancel), null,null , app.getErrorString(CMUI_Displaying_Data), null);
	self.tblCargo.rows := self.tblCargo.fixedRows;
	self.tblCargo.allSelectedObjects.clear(); //01/11/2023	navkc1	Bug 61059
	
	self.pbProgressBar.partsInJob := partsInJob;
	self.pbProgressBar.visible := true;
	fixedRows := self.tblCargo.fixedRows;
	
	if app.myPassport.myCMIFMonitor = null then
		create monitor transient;
		app.myPassport.setMyCMIFMonitor(monitor);
	endif;	
	
	//foreach any in self.myEnqController.allObjects do
	foreach cargo in _allCargo discreteLock do
		if not checkProgress(partsDone,partsInJob,lastUpdated) then
			break;
		endif;
		
		self.tblCargo.updateItemObject(cargo,null,null,app.myPassport);
	
		partsDone := partsDone + 1;
		
		if partsDone + fixedRows &gt;= JadeTableRowLimit then
			//user agreed earlier they only want first NNN
			break;
		endif;
		
		quantity += cargo.totalQuantity;
		weight += cargo.totalWeight;
		volume += cargo.totalVolume;
		
		//06/03/2023	navkc1 CR 62396 Task 62398
		pendingQty += cargo.getCustDocsPendingQuantity();
		clearedQty += cargo.getCustDocsClearedQuantity();
		
		//06/03/2023	navkc1 CR 62396 Task 62398
		pendingVol += cargo.getCustDocsPendingVolume();
		clearedVol += cargo.getCustDocsClearedVolume();
		
		//06/03/2023	navkc1 CR 62396 Task 62398
		pendingWeight += cargo.getCustDocsPendingWeight();
		clearedWeight += cargo.getCustDocsClearedWeight();
		
	endforeach;
	
	self.displayStatusLine(quantity, pendingQty, clearedQty, weight, pendingWeight, clearedWeight, volume, pendingVol, clearedVol);
	self.doTableFilter(self.tblCargo);//02/10/2023	navkc1	CR 60423 Task 60763
epilog
	delete monitor;
	app.myPassport.setMyCMIFMonitor(null);
	self.frmModalDialog.visible := false;
end;</source>
        <access>protected</access>
        <Parameter name="_allCargo" type="CM_TIByCargoTypeIdDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="displayCargoResultsForAttr" id="9886ce92-7dda-47b6-b0f3-f8f63ad343fe">
        <source>displayCargoResultsForAttr(attrName : String; col ,  partsDone, partsInJob : Integer io; lastUpdated : Decimal io) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 May 2022	jlier1	Initial creation

*/

vars
	index: Integer ;
	type:  Type ;
	value: Any ;
	row : Integer;
	iter : Iterator;
	jdo : JadeDynamicObject;
begin
	iter:=self.myCargoGroupQuery.allGroupings.createIterator;
	row:=self.tblCargoGrouped.fixedRows +1;

	while iter.next(jdo) do	
		if not checkProgress(partsDone,partsInJob,lastUpdated) then
			break;
		endif;
		if self.tblCargoGrouped.rows &lt; row then
			self.tblCargoGrouped.rows:=row;
		endif;
		self.tblCargoGrouped.row:=row;	
		self.tblCargoGrouped.accessRow(row).itemObject:=jdo;
		if jdo.getPropertyInfoByName(attrName,index,type,value) then	

			self.tblCargoGrouped.accessCell(row,col).text:=value.asStringJMT; 
			
			self.tblCargoGrouped.accessColumn(col).maxColumnWidth:=300;
		endif;
		partsDone := partsDone + 1;
		row:=row+1;
	endwhile;
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="attrName" type="String"/>
        <Parameter name="col" type="Integer" usage="io"/>
        <Parameter name="partsDone" type="Integer" usage="io"/>
        <Parameter name="partsInJob" type="Integer" usage="io"/>
        <Parameter name="lastUpdated" type="Decimal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="displayCriteria" id="59eda443-478d-4264-b2cd-5d7c09bee6d4">
        <updating/>
        <source>displayCriteria()protected, updating;
// ---------------------------------------------------------------------------
// Created:     11 August 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
/*
Date		Who		Reason
08 Oct 2008	cnwkpd1	PAR #18009 - Prevent transient leaks
06 Mat 2013	cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements
*/

vars
	criteriaLine			: CM_SelectorCriteriaLine;
	queryProperty			: CM_QueryProperty;
	queryOperator			: CM_QueryOperator;
		
begin

	self.btnDown.enabled := false;	//02 Sep 2019	NDL	TFS 45891
	self.btnUp.enabled := false;	//02 Sep 2019	NDL	TFS 45891
	
	criteriaLine := self.tblCriteria.accessRow(self.tblCriteria.row).itemObject.CM_SelectorCriteriaLine;
	
	if criteriaLine = null then
		return;
	endif;
	
	queryProperty := self.myQDef.allQueryProperties[criteriaLine.myQueryProperty.propertyName];
	
	if queryProperty = null then
		//probably a deleted stop or todo task
		//query will still run but we can't set the controls below
		return;
	endif;
	
	queryOperator := queryProperty.allAllowedOperators[criteriaLine.myQueryOperator.description];


	self.tblCriteria.accessedRow.backColor := criteriaLine.getPerformanceColour;	//02 Sep 2019	NDL	TFS 45891

	self.cmbAttr.listObject := queryProperty;
	self.loadOperationCombo(queryProperty);
	self.cmbOperator.text := queryOperator.description;
	self.doCmbOperatorClick(criteriaLine.myQueryOperator);
	self.queryLineChanged := false;
	
	self.evaluateUpDown();	//02 Sep 2019	NDL	TFS 45891
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="displayStatusLine" id="e60b1186-c4ed-4b45-9575-f17ce58b6c75">
        <source>displayStatusLine(_qty, _pendingQty, _clearedQty : Integer; _weight, _pendingWeight, _clearedWeight, _vol, _pendingVol, _clearedVol : Decimal);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08/09/2023	navkc1	CR 60429 Task 60446: UI - Cargo Review UI Changes - FIlter and Totals

*/

vars
	displayString,
	pendingWeightStr,
	clearedWeightStr,
	weightStr,
	pendingVolStr,
	clearedVolStr,
	volStr			: String;
	
begin
	
	if _qty = null then
		self.staLine.caption := displayString;
		return;
	endif;
	
	weightStr := app.getWeightForDefaultDisplay(_weight);
	volStr := app.getVolumeForDefaultDisplay(_vol);
	
	//06/03/2023	navkc1 CR 62396 Task 62398
	pendingWeightStr := app.getWeightForDefaultDisplay(_pendingWeight);
	clearedWeightStr := app.getWeightForDefaultDisplay(_clearedWeight);
	pendingVolStr := app.getVolumeForDefaultDisplay(_pendingVol);
	clearedVolStr := app.getVolumeForDefaultDisplay(_clearedVol);
	
	displayString := "Selected - Total Quantity : " &amp; _qty.String &amp; ", Cleared Quantity : " &amp; _clearedQty.String &amp; ", Pending Quantity : " &amp; _pendingQty.String 
							&amp; ", Total Weight : " &amp; weightStr &amp; ", Cleared Weight : " &amp; clearedWeightStr &amp; ", Pending Weight : " &amp; pendingWeightStr 
							&amp; ", Total Volume : " &amp; volStr &amp; ", Cleared Volume : " &amp; clearedVolStr &amp; ", Pending Volume : " &amp; pendingVolStr;
	
	self.staLine.caption := displayString;
	
epilog

end;</source>
        <Parameter name="_qty" type="Integer"/>
        <Parameter name="_pendingQty" type="Integer"/>
        <Parameter name="_clearedQty" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_pendingWeight" type="Decimal"/>
        <Parameter name="_clearedWeight" type="Decimal"/>
        <Parameter name="_vol" type="Decimal"/>
        <Parameter name="_pendingVol" type="Decimal"/>
        <Parameter name="_clearedVol" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="doBtnSaveSelectorClick" id="7c20445b-f100-4ef3-b2d1-7aba670cf356">
        <source>doBtnSaveSelectorClick();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12/09/2023	navkc1	CR 60429 Task 60445: UI - Cargo Review UI Changes - Queries
02/10/2023	navkc1	CR 60423 Task 60763: UI - Cargo Review Ui changes
*/

vars
	clonedCriteria	: CM_QueryCriteriaLineHolder;
	
	saveSelector	: CMUI_SaveSelector;
begin
	
	create saveSelector transient;
	create clonedCriteria transient;
	
	self.myCriteriaLineHolder.cloneReferences(true, clonedCriteria);
	if self.cmbFolder.listIndex &gt; 0 then
		saveSelector.myFolderFromParent := self.cmbFolder.listObject.CM_MenuUserHdr;
	endif;
	
	if self.cmbQuery.listIndex &gt; 0 then
		saveSelector.myQueryFromParent := self.cmbQuery.listObject.CM_MenuUserQuery;
	endif;
	saveSelector.myQDef := self.myQDef;
	saveSelector.myCriteriaLineHolder := clonedCriteria;
	saveSelector.setParentForm(self);
	saveSelector.setMyTerminal(self.getMyTerminal());
	saveSelector.showModal();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBulkYardAllocations" id="e27e8360-6e5f-47d6-9450-d46cda10cd53">
        <source>doBulkYardAllocations(_imexStatus : Integer);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 10/09/2025	navdap1		Initial creation MTN-35615 ENS | Bulk Creation of Yard Allocations 
//
vars
	imexObject : CM_IMEXStatus;
	imexCode : Integer;
	imexDesc : String;
	jdo : JadeDynamicObject;
	index : Integer;
	type : Type;
	value : Any;
	tisInGrouping : CM_TIByCargoTypeIdDict;
	firstTi : CM_TrackedItem;
	tisForBulkYA : CM_TISet;
	bulkYAForm : CMUI_BulkYardAllocations;

begin
	// What's our imex status?
	if _imexStatus &lt;&gt; null then
		imexObject := app.myRoot.allImexStatuses[_imexStatus];
		if imexObject &lt;&gt; null then
			imexCode := imexObject.code;
			imexDesc := imexObject.description;
		else
			// No Imex? Don't know what to do
			return;
		endif;
	else
		return;
	endif;
	
	create tisForBulkYA transient;
	
	foreach jdo in self.tblCargoGrouped.allSelectedObjects as JadeDynamicObject do
		// The JadeDynamicObject has a allTrackedItems attribute
		// Get the first entry in this collection to see if it matches the imex status
		if jdo.getPropertyInfoByName(CMIF_CargoReviewQuery.CargoReviewAllTrackedItems, index, type, value) then
			tisInGrouping := value.CM_TIByCargoTypeIdDict;
			firstTi := tisInGrouping.first;
			if firstTi.getImExStatus = _imexStatus then
				tisInGrouping.copy(tisForBulkYA);
			endif;
		endif;
	endforeach;
	
	// Anything matching the selected imex status?
	if tisForBulkYA.isEmpty then
		app.raiseCMException1(No_Cargo_For_Imex_Status, imexDesc, null, null);
		return;
	endif;
	
	bulkYAForm := app.loadForm(CMUI_BulkYardAllocations, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_BulkYardAllocations;
	if bulkYAForm = null then
		return;
	endif;
	
	tisForBulkYA.copy(bulkYAForm.allTrackedItems);
	bulkYAForm.myImexStatus := imexObject;
	bulkYAForm.setParentForm(self);
	bulkYAForm.show();
	
epilog
	delete tisForBulkYA;
end;</source>
        <Parameter name="_imexStatus" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doCmbOperatorClick" id="6d262bf0-529b-4acd-be65-9b6f64313205">
        <updating/>
        <source>doCmbOperatorClick(_qOperator : CM_QueryOperator) protected, updating;
// ---------------------------------------------------------------------------
// Created:     11 August 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.queryLineChanged := true;
	self.setupArgumentView(_qOperator);

end;</source>
        <access>protected</access>
        <Parameter name="_qOperator" type="CM_QueryOperator"/>
    </JadeMethod>
    <JadeMethod name="doCreateCompanyCustDoc" id="37d45ab7-e67d-4812-bc19-9e1a8a6cd148">
        <source>doCreateCompanyCustDoc(_tiSet : CM_TISet);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17/10/2023	navkc1	CR 60422 Task 60917: JADE - Group Selected TIs by Transport

*/

vars
	form		: CMUI_CompanyCustDocCreate;
	autoId		: CM_AutoIdCustomDocs;
begin
	
	autoId := self.myTerminal.getMyAutoIdGenerator(CM_AutoIdCustomDocs).CM_AutoIdCustomDocs;
	
	if autoId = null then
		app.msgBox(app.getErrorString(Auto_gener_custo_docum_pleas_t), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	form := app.loadForm(CMUI_CompanyCustDocCreate, CMUI_Assistant, false, true, false, self.myTerminal, null).CMUI_CompanyCustDocCreate;
	
	if form = null then
		return;
	endif;
	
	form.cmifCompanyCustDocAgent.initialize(_tiSet, self.myTerminal);
	form.initDetailsFromFirstTI();
	
epilog

end;</source>
        <Parameter name="_tiSet" type="CM_TISet"/>
    </JadeMethod>
    <JadeMethod name="doCustDocSummary" id="4f87ea13-a524-436d-86b5-fbd38ff58488">
        <updating/>
        <source>doCustDocSummary(_tis : CM_TISet) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/10/2023	navkc1	CR 60423 Task 60764: UI - Cargo Review Cust Doc Summary
01/11/2023	navkc1	Bug 61059: FR | 53715 - EUP - Customs - Cargo review screen enhancements
*/

vars
	row			: Integer;
	agent		: CMIF_CargoReviewCustDocAgent;
	detail		: CMIF_CargoReviewCustDocDetail;
	tbl			: CM_DataTable;
	text		: String;
	custDocType	: CM_CustomDocumentType;
	terminal	: CM_Terminal;
begin

	
	agent := self.myCMIFCustDocSummaryAgent;
	tbl := self.tblCustomDocument;
	
	agent.initialize(_tis);
	agent.doSummary();
	
	tbl.rows := tbl.fixedRows;
	
	// Show/Hide Quantity
	if agent.displayQuantity then
		tbl.accessColumn(4).visible := true;
		tbl.accessColumn(10).visible := true;
	else
		tbl.accessColumn(4).visible := false;
		tbl.accessColumn(10).visible := false;
	endif;
	
	// Show/Hide Vol
	if agent.displayVolume then
		tbl.accessColumn(5).visible := true;
		tbl.accessColumn(11).visible := true;
	else
		tbl.accessColumn(5).visible := false;
		tbl.accessColumn(11).visible := false;
	endif;
	
	// Show/Hide Weight
	if agent.displayWeight then
		tbl.accessColumn(6).visible := true;
		tbl.accessColumn(12).visible := true;
	else
		tbl.accessColumn(6).visible := false;
		tbl.accessColumn(12).visible := false;
	endif;
	
	row := tbl.fixedRows;
	terminal := self.getMyTerminal();
	
	foreach detail in agent.allCargoReviewCustDocDetails do
		if detail.isZero() then
			continue;
		endif;
		text := detail.inwardDocTypeCode &amp; Tab &amp; detail.inwardDocCode &amp; Tab &amp; detail.inwardDateTime.asStringJMT() &amp; Tab &amp; 
				detail.pendingQuantity.asStringJMT() &amp; Tab &amp; app.getVolumeForDefault(detail.pendingVolume) &amp; Tab &amp; app.getWeightForDefault(detail.pendingWeight) &amp; Tab &amp;
				detail.outwardDocTypeCode &amp; Tab &amp; detail.outwardDocCode &amp; Tab &amp; detail.outwardDateTime.asStringJMT() &amp; Tab &amp;
				detail.clearedQuantity.asStringJMT() &amp; Tab &amp; app.getVolumeForDefault(detail.clearedVolume) &amp; Tab &amp; app.getWeightForDefault(detail.clearedWeight);
				
		row := tbl.addItem(text);
		
		custDocType := terminal.allCustomDocumentTypes[detail.inwardDocTypeCode];
		if custDocType &lt;&gt; null then
			tbl.accessCell(row, 1).backColor := custDocType.colour;
		endif;
		
		custDocType := terminal.allCustomDocumentTypes[detail.outwardDocTypeCode];
		if custDocType &lt;&gt; null then
			tbl.accessCell(row, 7).backColor := custDocType.colour;
		endif;
	endforeach;
	
	//23/02/2023	navkc1 CR 62580 Task 62581 - Show the Custom document table if it's not already visible
	if not self.btnShowTblSummary.value then
		self.btnShowTblSummary.value := true;
		self.dkcCustomDocument.visible := true;
	endif;
	
	self.hasAcknowledgedClearCustDoc := false; //01/11/2023	navkc1	Bug 61059
	
	self.doTableFilter(self.tblCustomDocument);
	
epilog

end;</source>
        <Parameter name="_tis" type="CM_TISet"/>
    </JadeMethod>
    <JadeMethod name="doDeselectOtherTables" id="01574211-def9-41a2-90cd-4287008c6440">
        <source>doDeselectOtherTables(_table : CM_DataTable);
/*

