    <JadeMethod name="executeDisplayNotesForMove" id="ef3d7726-3a18-47a7-bf31-77100eb9c020">
        <source>executeDisplayNotesForMove(_controller: CMIF_MoveController);

// Created by cnwdvb1 on 22 November 2006

vars

	theTerminal : CM_Terminal;
	theTI 	    : CM_TrackedItem;
	termArea    : CM_TerminalArea;
begin

	theTerminal := self.myTerminal;
	theTI 		:= _controller.myTrackedItem;
	termArea    := self.myTerminalArea;

	if self &lt;&gt; null and termArea &lt;&gt; null then
		app.myEventManager.createSingleObjInfoNoteEvt(termArea,	theTerminal.getTerminalEvent(EVENT_REFRESH_GRID_AREA),self);
	
		if  self = _controller.myOriginatingLocation then
			app.myEventManager.createSingleObjInfoNoteEvt(termArea, theTerminal.getTerminalEvent(EVENT_TI_MOVE_FROM_LOCATION),theTI);
			app.myEventManager.createSingleObjInfoNoteEvt(termArea, theTerminal.getTerminalEvent(EVENT_TI_MOVE_TO_LOCATION),theTI);
		elseif self = _controller.myToPrimaryLocation then
			app.myEventManager.createSingleObjInfoNoteEvt(termArea, theTerminal.getTerminalEvent(EVENT_TI_MOVE_TO_LOCATION),theTI);
		endif;
		app.myEventManager.createSingleObjInfoNoteEvt(termArea, theTerminal.getTerminalEvent(EVENT_TI_MOVE),self);
	endif;

	
	
	
end;</source>
        <Parameter name="_controller" type="CMIF_MoveController"/>
    </JadeMethod>
    <JadeMethod name="getCapacityPC" id="469d0191-b8f3-4552-9e4a-d65cccea0020">
        <source>getCapacityPC(_mode: Integer): Integer;

/*

Purpose:			TFS 49959

Parameters:			

Return Value:		


Date		Who		Reason
04 December 2020	jlgab1	Initial creation

*/

vars
	capacity, capacityPC : Integer;
	totAmount : Decimal[23,2];
	array : CM_TIArray; 
	ti : CM_TrackedItem;
	bulkWeight : Boolean;
begin

	capacity := self.getCurrentCapacity();
	if capacity = 0 then
		return 0;
	endif;
	
	create array transient;
	self.getTIs(array, _mode, true);
	
	bulkWeight := true;

	ti := array.first();
	if ti &lt;&gt; null and ti.isBulkByVolume() then
		bulkWeight := false;
	endif;
	
	foreach ti in array discreteLock do
		if bulkWeight then
			totAmount := totAmount + ti.totalWeight;
		else
			totAmount := totAmount + ti.totalVolume;
		endif;
	endforeach;
	
	capacityPC := ((totAmount / capacity) * 100).Integer;

	return capacityPC;
epilog
	delete array;
end;</source>
        <Parameter name="_mode" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getCurrentCapacity" id="072189f4-1533-402d-a32f-5c29287efa32">
        <source>getCurrentCapacity(): Integer;

/*

Purpose:			TFS 49959

Parameters:			

Return Value:		


Date		Who		Reason
04 December 2020	jlgab1	Initial creation

*/

vars
	minMax : CM_TerminalAreaProductMinMax;
	
	ti : CM_TrackedItem;
	bulkWeight : Boolean;
	array : CM_TIArray;
begin
	
	create array transient;
	self.getTIs(array, REAL_MODE, true);
	
	bulkWeight := true;

	ti := array.first();
	if ti &lt;&gt; null and ti.isBulkByVolume() then
		bulkWeight := false;
	endif;

	minMax := self.getMinMaxForFirstTI();
	if minMax &lt;&gt; null then
		if bulkWeight and minMax.maxWeight &gt; 0 then
			return minMax.maxWeight;
		elseif minMax.maxVolume &gt; 0 then
			return minMax.maxVolume.Integer;
		
		endif;
	endif;

	return self.myTerminalArea.getMaxCapacity();
	
	
epilog
	delete array;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
