    <JadeMethod name="sh3AmendQuantity" id="218e0c96-1fc3-4c39-bb01-d0135cb067c3">
        <source>sh3AmendQuantity(_cmif : CMIF_CalcTypeQuantityHook) : Real;
/*
Date		Who		Reason
21-05-2019	jlgsh3	Initial creation
23 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
*/
constants
	IMEX_Export = 2;
	IMEX_Import = 1;
	IMEX_Storage = 3; //We don't use this but have documented it for reference (21-05-2019)

vars
	tiTran 		: CM_TITransaction;
	dischPort,
	loadPort,
	operator	: String;
	
	newQty : Real;
	imex 	: Integer;
		
begin
	app.invLog("Logging for Hook Code - PNL ISPS - START", LogINFO.String);
	
	newQty := _cmif.origQty;
		
	tiTran := _cmif.myTransaction.CM_TITransaction;
	
	if tiTran = null then
		app.invLog("PNL ISPS - no Transaction located", LogINFO.String);
		return newQty;
	endif;
	
	dischPort := tiTran.dischargePort;
	loadPort := tiTran.loadPort;
	operator := tiTran.operatorCode;
	imex := tiTran.imExStatus;
	
	if not operator.isOneOf("MSK", "HSD") then
		if imex = IMEX_Export and dischPort[1:2] = "NZ" then
			app.invLog("Logging for Hook Code - PNL ISPS - Export, discharge port = NZ", LogINFO.String);
			newQty := 0;
		elseif imex = IMEX_Import and loadPort[1:2] = "NZ" then
			app.invLog("Logging for Hook Code - PNL ISPS - Import, load port = NZ", LogINFO.String);
			newQty := 0;
		endif;
	endif;
		
	app.invLog("Logging for Hook Code - PNL ISPS - END", LogINFO.String);
		
	
	return newQty;
end;	

</source>
        <Parameter name="_cmif" type="CMIF_CalcTypeQuantityHook"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="sh3AnalyzeDefaultCompanies" id="8c60f076-e856-4e79-9ab2-5e117e9b2cf0">
        <source>sh3AnalyzeDefaultCompanies();
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		14 April 2010
//
// Implemented version: JMT 7.8.2
// Date  		User  		Change
//----------------------------------------------------------------------
vars
	company : CM_Bank;
	strArr  : StringArray;
	code 	: String;
	int 	: Integer;
begin
	create strArr transient;
	write CM_Terminal.instances.size.String &amp; ' terminals';
	
	foreach company in CM_Bank.instances where company.code = "DFBU" do
		int := int + 1;
	
		if company.terminal &lt;&gt; null then
			code := company.terminal.code;
			write code;
		
			if strArr.includes(code) then
				write code &amp; ' has already been added.';
			else
				strArr.add(code);
			endif;
		else
			write "No Terminal";
		endif;
	endforeach;
	write int.String &amp; ' - Number of DFBUs';
epilog
	delete strArr;
	write 'Terminado';
end;</source>
    </JadeMethod>
    <JadeMethod name="sh3CMQFmyQryRefCheck" id="b583d07a-1a3f-4128-a9a7-1faa5a0e3ee5">
        <source>sh3CMQFmyQryRefCheck();
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		09 April 2010
//
// Implemented version: JMT 7.8.2
// Date  		User  		Change
//----------------------------------------------------------------------
constants
	Max : Integer = 50;
vars
	oa 						: CM_ObjectArray;
	schema 					: Schema;
	cls 					: Class;
	obj 					: Object;
	firstTime 				: Boolean;
	className 				: String;
	classInstancesCount,
	total,
	totalClasses, 
	huh 					: Integer;
	
	cmqf 					: CMQF_FilterReports;
	cmqfSummary				: String;
begin
	self.sh3StandardInitialize();
	firstTime := true;
	create oa transient;
	
	schema := app.getSchema();
	cls := schema.getClass("CMQF_FilterReports");
	
	cls.allInstances(oa, null, true);
	
	foreach obj in oa do
	
		if obj.isKindOf(CMQF_VoyageWeightSummary) then
			app.writeStatement("CNWSH3 " &amp; method.qualifiedName &amp; " 1. " );
		endif;
		if firstTime then
			className := obj.class.name;
			firstTime := false;
			totalClasses := 1;
		else
			if className &lt;&gt; obj.class.name then
				write "************* " &amp; className &amp; " ****************";
				write '----' &amp; classInstancesCount.String &amp; ' instances counted.';
				write '----Persistent reports using ' &amp; className;
				write cmqfSummary &amp; CrLf;
				cmqfSummary := null;
				//write totalClasses.String &amp; ' - Class Count';
				className := obj.class.name;
				totalClasses := totalClasses + 1;
				if classInstancesCount &gt; Max then
					write '------------------------------------------------------------------------------------------MORE THAN ' &amp; Max.String &amp; ' INSTANCES?????' &amp; CrLf;
					huh := huh +1;
				endif;
				classInstancesCount := null;
			endif;
		endif;
		classInstancesCount := classInstancesCount + 1;
		total := total + 1;
		
		cmqf := obj.CMQF_FilterReports;
		if cmqf.myQryReport &lt;&gt; null then
			cmqfSummary := cmqfSummary &amp; cmqf.myQryReport.heading &amp; CrLf;
		endif;
	endforeach;
	write total.String &amp; ' - Total Number of instances.';
	write totalClasses.String &amp; ' - Total Classes with instances.';
	write huh.String &amp; ' classes with more than ' &amp; Max.String &amp; ' instances.';
	
epilog
	delete oa;
end;</source>
    </JadeMethod>
    <JadeMethod name="sh3CQMFAnalyze" id="51ff0b62-2454-4180-a227-90343ccfcdee">
        <source>sh3CQMFAnalyze();
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		09 April 2010
//
// Implemented version: JMT 7.8.2
// Date  		User  		Change
//----------------------------------------------------------------------
constants
	Max : Integer = 50;
vars
	oa : CM_ObjectArray;
	schema : Schema;
	cls : Class;
	obj : Object;
	firstTime : Boolean;
	
	className : String;
	classInstancesCount : Integer;
	total : Integer;
	totalClasses : Integer;
	huh : Integer;
begin
	self.sh3StandardInitialize();
	firstTime := true;
	create oa transient;
	
	schema := app.getSchema();
	cls := schema.getClass("CMQF_FilterReports");
	
	cls.allInstances(oa, null, true);
	
	foreach obj in oa do
		if firstTime then
			className := obj.class.name;
			firstTime := false;
			totalClasses := 1;
		else
			if className &lt;&gt; obj.class.name then
				write "************* " &amp; className &amp; " ****************";
				write classInstancesCount.String &amp; ' instances counted.' &amp; CrLf;
				//write totalClasses.String &amp; ' - Class Count';
				className := obj.class.name;
				totalClasses := totalClasses + 1;
				if classInstancesCount &gt; Max then
					write '------------------------------------------------------------------------------------------MORE THAN ' &amp; Max.String &amp; ' INSTANCES?????' &amp; CrLf;
					huh := huh +1;
				endif;
				classInstancesCount := null;
			endif;
		endif;
		classInstancesCount := classInstancesCount + 1;
		total := total + 1;
	endforeach;
	write total.String &amp; ' - Total Number of instances.';
	write totalClasses.String &amp; ' - Total Classes with instances.';
	write huh.String &amp; ' classes with more than ' &amp; Max.String &amp; ' instances.';
	
epilog
	delete oa;
end;</source>
    </JadeMethod>
    <JadeMethod name="sh3CheckArchivedRows" id="d1a2dc58-d055-4178-b536-02467a3a1a69">
        <source>sh3CheckArchivedRows();
