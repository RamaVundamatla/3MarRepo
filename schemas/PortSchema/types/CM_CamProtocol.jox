    <JadeMethod name="checkForDuplicateFilePrefix" id="f89eab26-e87c-4543-8647-0b3aadc36552">
        <source>checkForDuplicateFilePrefix() protected;
/*
Purpose:	The File Prefix now has to be unique across all CAMS Protocols not just User Defined ones.

Date			Who		Reason
08 March 2010	cnwrl1	Initial creation as part of PAR 22836 - File Prefix must be unique within all Protocols.
04/06/2010		cnwdad1	PAR #24361 - Only check user-defined types for unique prefix.
*/
vars
	lFilePrefix		: String;
	camProtocol		: CM_CamProtocol;
	realCamProtocol : CM_CamProtocol;
	terminal		: CM_Terminal;
	
begin
	if self.filePrefix = null then
		if self.isFileTransferEnabled then
		//	app.raiseCMException1(REQUIRED_FIELD, app.getString(File_Prefix), null, null);
			app.raiseCMException1(Input_required_field_Required, app.getString(File_Prefix), null, null); // cnwdb2	PAR 35364
		endif;
		return;		// no point doing the rest of method if File Prefix is null.
	endif;
	
	// cnwrl1 28/06/2010 PAR 24498 - start of coding
	if self.protocolDesc = null then
		// If the users has not selected a CAMS Protocol Description, they will
		// get an error anyway - this return stops UE 1090 on statement below.
		return;
	endif;
	// cnwrl1 28/06/2010 PAR 24498 - end of coding
	
// cnwdad1 04/06/2010 - PAR #24361.
	if self.protocolDesc.type = EDIFileTypeCams_UserDef
	or self.protocolDesc.type = EDIFileTypeCams_UserDefEvent
	then
		terminal	:= self.terminal;
		lFilePrefix	:= self.filePrefix.toUpper();
		
		//Saves having to make other calls through the foreach loop.
		realCamProtocol := self.pxyGetRealObject();
		
		foreach camProtocol in terminal.camProtocols
		where not camProtocol = realCamProtocol do
			if camProtocol.filePrefix.toUpper() = lFilePrefix then
				app.raiseCMException2(FilePrefix_IsAlreadyBeingUsed, lFilePrefix, camProtocol.code, null, null);
			endif;
		endforeach;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="clearCoarriExportPorts" id="f3dcf5c9-b1ca-4162-ac60-ce993613bd0d">
        <source>clearCoarriExportPorts();

/*

Date		Who		Reason
22 Dec 2010	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/

vars
	iter:Iterator;
	port:CM_Port;
begin
	iter := self.allCoarriExportPorts.createIterator();
	while iter.next(port) do
		port.setMyCamProtocol(null);
	endwhile;
	
epilog
	delete iter;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="constructFileName" id="6f9dccae-7caa-4b15-86df-ec860e20412e">
        <source>constructFileName(_camAgent : CM_CamControllerAgent; _seqNumber : Integer) : String;
//constructFileName(_camTask : CM_CamTask) : String;	// cnwrl1 26/02/2010 PAR 22387 - what it was
// ---------------------------------------------------------------------------
// Created:		20 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
/*
	Purpose : filename construct depends on wether or not it use the daily file name or not.
	If not, it uses the processSeqNumber

	J Harliwich MES1011 Filenames for User defined will be csv or xml, change to default
	26/02/2010	cnwrl1		PAR 22387 - changed to make sure the "Single Transaction Per File"
							processing actually generates different file names.
*/
//18 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
//26 Apr 2023	navmd1	TFS 57678 Fix number and ID not being unique
//05 Sep 2025	navnk30 JIRA 35756: 8 - Create a new Cams protocol to handle Truck Departure events and generate "Ship Notice" Messages

vars
	fileName 		: String;
	padding 		: String;
	fileExt			: String;
	internalNumber	: Integer;
	seqNumber		: Integer;					// cnwrl1 26/02/2010 PAR 22387
	scheduleSize : Integer;
	
begin
	// We're already logging these External Web Service History, so no need to write to disk
	//if self.myExternalWebServiceDef &lt;&gt; null then							//05SEP2025 navnk30 JIRA-35756
	if self.myExternalWebServiceDef &lt;&gt; null and
			self.protocolDesc.type &lt;&gt; EDIFileTypeCams_AgGatewayXML  then	//05SEP2025 navnk30 JIRA-35756
		return null;
	endif;

	fileExt := self.fileSuffix.trimBlanks;
	
	if fileExt = null then
		fileExt := getDefaultFileSuffix;	// MES 1011 ,   was hardcoded to "dat";
	endif; 
	
	// cnwrl1 26/02/2010 PAR 22387 - start of coding
	if _seqNumber = null then
		// use what was being used before
		if _camAgent.processSeqNumber = Adhoc_Key then
			seqNumber	:= _camAgent.dailySeqNumber;
		elseif self.camGroup.useDailyFileName then
			seqNumber	:= _camAgent.getFileNameSeqNumber(self);
		else
			seqNumber	:= _camAgent.processSeqNumber;
		endif;
	else
		// use the value passed in.
		seqNumber	:= _seqNumber;
	endif;
	// cnwrl1 26/02/2010 PAR 22387 - end of coding
	
	if self.specialFileName then
		if self.protocolDesc.isOneStopXML then
			fileName := self.protocolDesc.CM_CamOneStopXML.generateFileName( _camAgent, self );
		else
			fileName := self.protocolDesc.specialFileName(self.camGroup, _camAgent.startDateTime, _camAgent.runDateTime);		//cnwmc5 - 24 Oct 2014 - CCMS 2380
		endif;
	endif;
	if _camAgent.processSeqNumber = Adhoc_Key then
//		fileName := self.filePrefix &amp; app.clock.String &amp; "_adhoc" &amp; _camTask.dailySeqNumber.String &amp; "." &amp; fileExt;	// cnwrl1 26/02/2010 PAR 22387 - what it was
		fileName := self.filePrefix &amp; app.clock.String &amp; "_adhoc" &amp; seqNumber.String &amp; "." &amp; fileExt;
	endif;
	if fileName = null then
		if self.camGroup.useDailyFileName = true then	// this is the CamGroup "File number by mmdd" setting
			padding := self.filePrefix[1:2];
/*			internalNumber := _camTask.getFileNameSeqNumber;	// cnwrl1 26/02/2010 PAR 22387 - what it was
			internalNumber := seqNumber;
			if internalNumber &lt; 10 then
				padding := padding &amp; "00000";
			elseif internalNumber &lt; 100 then
				padding := padding &amp; "0000";
			elseif internalNumber &lt; 1000 then
				padding := padding &amp; "000";
			elseif internalNumber &lt; 10000 then
				padding := padding &amp; "00";
			elseif internalNumber &lt; 100000 then
				padding := padding &amp; "0";
			endif;  */
			//11 Aug 2017	NDL	TFS 5802
			scheduleSize := self.scheduleTimes.size;	//The number of scheduled runs per day.
			internalNumber := _camAgent.getFileNameSeqNumber(self);
			if scheduleSize &gt;= 1000 then
				if internalNumber &lt; 10000000 then  //MMDDssss
					padding := padding &amp; "0";
				endif;
			elseif scheduleSize &gt;= 100 then
				if internalNumber &lt; 1000000 then	//MMDDsss
					padding := padding &amp; "0";
				endif;
			else
				if internalNumber &lt; 100000 then	//MMDDss
					padding := padding &amp; "0";
				endif;
			endif;
			
		else
			padding := self.filePrefix;
//			internalNumber := _camTask.processSeqNumber;		// cnwrl1 26/02/2010 PAR 22387 - what it was
			internalNumber := seqNumber;
			if internalNumber &lt; 10 then
				padding := padding &amp; "0000";
			elseif internalNumber &lt; 100 then
				padding := padding &amp; "000";
			elseif internalNumber &lt; 1000 then
				padding := padding &amp; "00";
			elseif internalNumber &lt; 10000 then
				padding := padding &amp; "0";
			endif;
		endif;
		fileName := padding.trimBlanks &amp; internalNumber.String &amp; "." &amp; fileExt;
	endif;
	return fileName;
	
end;
</source>
        <Parameter name="_camAgent" type="CM_CamControllerAgent"/>
        <Parameter name="_seqNumber" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="create" id="7dbf0b7b-b36d-49da-9c64-e15c986b6f1d">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     12 September 2002 by cnwdf1
//
// Purpose:
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 15 May 2014	cnwrs1	Par 34159 - include Chassis in Codeco
// ---------------------------------------------------------------------------
vars

begin
	if self.isTransient then
		create self.registeredTransactions transient;
		create self.allRegisteredCargoTypes	transient;
	else
		create self.registeredTransactions;
		create self.allRegisteredCargoTypes;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="decimalCharacter" id="851840f6-a7e7-40c6-81c5-617ab25b2087">
        <methodInvocation>mapping</methodInvocation>
        <source>decimalCharacter(set : Boolean; _value : Character io) mapping;
/*
Purpose:		Use default value if property blank

Date		Who		Reason
09 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
20 Feb 2015 cnwma1  PAR #35322 CAM Protocol default separator characters are not correct for X12
*/
vars

begin
	if not set then
		if _value = null then
			if self.isX12 then	 //20/02/2015 cnwma1 PAR # 35322
				_value := null;
			else
				_value := self.Default_DecimalCharacter;
			endif;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Character" usage="io"/>
    </JadeMethod>
    <JadeMethod name="delete" id="9b31964f-c183-43a8-a3fa-5a967b9836b7">
        <updating/>
        <source>delete() updating;
/* Changes

Date		Name	TFS#		Description
============================================================================
cnwrs1 june 2006 was missing
15 May 2014	cnwrs1	Par 34159 - include Chassis in Codeco
07 Jul 2023	jlika1	TFS 58636	EUP - Goods Receipt - Move Transaction area triggers
20/03/2024		navcs2		ChangeRequest 60397: EUP | FR 54085 - Load Confirmation / Goods Receipt - Multiple Move transaction criteria, Event Only Trigger
============================================================================*/

begin
	
	self.resetAuditsDuringDelete();	//21 Jan 2021	NDL	TFS 50152
	
	delete self.registeredTransactions;	//cnwrs1 unit test leakage 2 Feb 2011
	delete self.allRegisteredCargoTypes;	
	self.taskHistoryByProtocolSeq.purge();
	if not self.allMoveTrxCriteria.isEmpty then	// 20/03/2024		navcs2		ChangeRequest 60397
		self.allMoveTrxCriteria.purge();		// 20/03/2024		navcs2		ChangeRequest 60397
	endif;										// 20/03/2024		navcs2		ChangeRequest 60397
end;</source>
    </JadeMethod>
    <JadeMethod name="doNow" id="7b1017e9-420d-44e3-ae1a-b40e989b455e">
        <source>doNow();

vars
	now : TimeStamp;
begin
	if self.onHold then
		return;
	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="dueDateTimes" id="d8f0d07e-d920-489d-959e-2d959a99be0a">
        <source>dueDateTimes(_runDateTime :TimeStamp; _nextStartDateTime, _nextEndDateTime : TimeStamp output) protected;
// ---------------------------------------------------------------------------
// Created:		26 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
//
// Parameters:	_runDateTime		- the time this task wil be run - server time (generally)
//
// Returns:		_nextStartDateTime	- start of next CAMS interval
//				_nextEndDateTime	- end of next CAMS interval
/*

Date		Who		Reason
23 Nov 2010	cnwkpd1	PAR #26351 - Change array access to foreach to improve performance
					during "catch up" CAMS processing
11 Dec 2012	cnwcs5	PAR 30855 / ccms sfw 1294 - changed parameter usage
*/

vars
	firstOK, lastOK	: Boolean;
	firstTS, lastTS	: TimeStamp;
	date			: Date;
	time, startTime	: Time;
begin
	// if there is no schedule it will never be due
	if scheduleTimes.size = 0 then
		_nextStartDateTime 	:= _runDateTime; //cnwrs1 Feb 2008 null meant it was always due
		_nextEndDateTime 	:= _runDateTime; //cnwrs1 Feb 2008 null meant it was always due
		return;
	endif;
	
	firstOK := self.firstRunDTIsValid;
	lastOK	:= self.lastRunDTIsValid;
	firstTS	:= self.firstRunDateTime;
	lastTS	:= self.lastRunDateTime;
	
	if lastOK and firstOK then
		// take the latest of first and last run timestamps
		if lastTS.isValid() and firstTS.isLessThanOrEqualTo(lastTS) then
			_nextStartDateTime := lastTS;
		else
			_nextStartDateTime := firstTS;
		endif;
		
	elseif firstOK then
		// using first run timestamp
		_nextStartDateTime := firstTS;
		
	elseif lastOK then
		// using last run timestamp
		_nextStartDateTime := lastTS;
		
	else
		// nothing on protocol so use run timestamp (probably now)
		_nextStartDateTime 	:= _runDateTime; //cnwrs1 Feb 2008 null meant it was always due
		_nextEndDateTime 	:= _runDateTime; //cnwrs1 Feb 2008 null meant it was always due
		return;
	endif;

	_nextEndDateTime := _nextStartDateTime;
		
	// PAR #26351 - changed scheduledTimes access to foreach to speed up
	startTime := _nextStartDateTime.time;
	
	foreach time in self.scheduleTimes do
		if time &gt; startTime then
			// first scheduled time after our most recent run
			_nextEndDateTime.setTime(time);
			return;
		endif;
	endforeach;
	
	// if we get to here there were no later times for today so roll over to the next day
	date := _nextStartDateTime.date + 1;
	
	_nextEndDateTime.setDate(date);
	_nextEndDateTime.setTime(scheduleTimes[1]);
end;</source>
        <access>protected</access>
        <Parameter name="_runDateTime" type="TimeStamp"/>
        <Parameter name="_nextStartDateTime" type="TimeStamp" usage="output"/>
        <Parameter name="_nextEndDateTime" type="TimeStamp" usage="output"/>
    </JadeMethod>
    <JadeMethod name="elementSeparator" id="d674de8e-ccea-4093-accc-29570f4eecb6">
        <methodInvocation>mapping</methodInvocation>
        <source>elementSeparator(set : Boolean; _value : Character io) mapping;
/*
Purpose:		Use default value if property blank

Date		Who		Reason
09 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
20 Feb 2015 cnwma1  PAR #35322 CAM Protocol default separator characters are not correct for X12
*/
//
vars

begin
	if not set then
		if _value = null then
			if self.isX12 then   //20/02/2015 cnwma1 PAR # 35322
				_value := self.Default_ElementSeperator_X12;
			else
				_value := self.Default_ElementSeperator;
			endif;
			
		endif;
	endif;
epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Character" usage="io"/>
    </JadeMethod>
    <JadeMethod name="escapeCharacter" id="0251ce53-391f-4a56-a0b5-8be58f5de3a1">
        <methodInvocation>mapping</methodInvocation>
        <source>escapeCharacter(set : Boolean; _value : Character io) mapping;
/*
Purpose:		Use default value if property blank

Date		Who		Reason
09 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
20 Feb 2015 cnwma1  PAR #35322 CAM Protocol default separator characters are not correct for X12
*/
vars

begin
	if not set then
		if _value = null then
			if self.isX12 then   //20/02/2015 cnwma1 PAR # 35322
				_value := null;
			else
				_value := self.Default_EscapeCharacter;
			endif;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Character" usage="io"/>
    </JadeMethod>
    <JadeMethod name="firstRunDTIsValid" id="a2885ff0-96ed-4d91-b6e6-5120787d82f1">
        <source>firstRunDTIsValid(): Boolean protected;
//----------------------------------------------------------------
//	Created:	01 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	today	: Date;
begin

	if self.firstRunDateTime = null
	or (not self.firstRunDateTime.isValid)
	or self.firstRunDateTime.date.year &lt; today.year - 2 then
		//only go back two years at most
		return false;
	else
		return true;
	endif;

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="formatSeal" id="8fcfef06-ca2d-4296-8859-f3bd7438216c">
        <source>formatSeal(_sealNumber: String): String;
//----------------------------------------------------------------
//	Created:	11 August 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	sealStartPos	: Integer;
	sealNumb		: String;
begin
	sealNumb := _sealNumber.removeString(' ').trimBlanks; //par17959 cnwrs1 sept 2008
	
	//cnwmc5 - 24 April 2014 - PAR 33635
	if self.protocolDesc.isKindOf(CM_CamEDIFACTDesc) then
		sealNumb := sealNumb.escapeEDIInvalidChars(self.elementSeparator, self.subElementSeparator, self.escapeCharacter);
	endif;
	
	if self.camGroup &lt;&gt; null then
		sealStartPos := sealNumb.length - self.camGroup.maxSealLength;
	endif; 

	if sealStartPos &lt; 0 then
		sealStartPos := 0;
	endif;
	//added by cnwyl1 for PAR 12120
	sealNumb := sealNumb[sealStartPos+1:end].trimRight;

	if sealNumb &lt;&gt; null and sealNumb.length &gt; self.camGroup.maxSealLength then
		sealNumb := sealNumb[1:self.camGroup.maxSealLength];
	endif;
	//add end
	return sealNumb;

end;</source>
        <Parameter name="_sealNumber" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="46f87145-9e64-4c87-8801-b15d0448aa94">
        <source>getAuditText(): String;
/*

Date		Who		Reason
08 July 2014	cnwer1	Initial creation PAR 33271
// 07/04/2017 	cnwrh7  TFS3811 #Add Selected Cargo Audit; Inclusde Chassis
*/

vars
	txt,tmpStr : String;						//+TFS3811
	intCargoType : Integer;				//+TFS3811
	strCargoTypes : String;				//+TFS3811
	port : CM_Port;
	emails,
	editFields,
	coarriImportPorts : String;
	transaction,
	transactions,
	packConsignees,
	packOperators : String;
	trxType : CM_TransactionType;
	camProtocolField : CM_CamProtocolField;
	email : CM_EmailEntity;
	cargoType : CM_CargoType;
begin
	txt:= inheritMethod();
	
	foreach port in self.allCoarriExportPorts do
		if coarriImportPorts = null then
			coarriImportPorts:=port.code;
		else
			coarriImportPorts:=coarriImportPorts &amp; "," &amp; port.code;
		endif;
	endforeach;
	
	foreach transaction in self.registeredTransactions do
		trxType:=app.myRoot.allTransactionTypes[transaction.Integer];
		if trxType = null then
			continue;
		endif;
		if transactions = null then
			transactions:=trxType.description;
		else
			transactions:=transactions  &amp; "," &amp; trxType.description;
		endif;
	endforeach;
	
	foreach camProtocolField in self.allEditTriggerFields do
		if editFields = null then
			editFields:=camProtocolField.name;
		else
			editFields:=editFields &amp; "," &amp; camProtocolField.name;
		endif;
	endforeach;
	
	foreach email in self.allCopyEmailEntities do 
		if emails = null then
			emails:=email.name;
		else
			emails:=emails &amp; "," &amp; email.name;
		endif;	
	endforeach;
	
	foreach intCargoType in self.allRegisteredCargoTypes do 																																																				//+TFS3811
		cargoType := app.myRoot.allCargoTypesById[intCargoType];
		if cargoType &lt;&gt; null then
			if strCargoTypes  = null then
				strCargoTypes :=  cargoType.description;
			else
				strCargoTypes := strCargoTypes &amp; "," &amp; cargoType.description;
			endif;
		endif;
	endforeach;
	
	
	packOperators:=self.packOperators.getDisplayCodes(false);
	packConsignees:= self.packExportConsignees.getDisplayCodes();
	txt:= txt &amp; "Coarri Import Ports" &amp; AuditStringSeparator &amp; coarriImportPorts.length.String &amp; AuditStringSeparator &amp; coarriImportPorts &amp; AuditStringSeparator &amp;
			"Transactions"  &amp; AuditStringSeparator &amp; transactions.length.String &amp; AuditStringSeparator &amp; transactions &amp; AuditStringSeparator &amp;
			"Edit Settings"  &amp; AuditStringSeparator &amp; editFields.length.String &amp; AuditStringSeparator &amp; editFields &amp; AuditStringSeparator&amp;
			"Copy Email Addresses"  &amp; AuditStringSeparator &amp; emails.length.String &amp;  AuditStringSeparator &amp; emails &amp; AuditStringSeparator&amp;
			"Selected Cargo Types"  &amp; AuditStringSeparator &amp; strCargoTypes.length.String &amp;  AuditStringSeparator &amp; strCargoTypes &amp; AuditStringSeparator&amp;							//+TFS3811 Add Audit for Selected Cargo Types
			"Pack Operators"  &amp; AuditStringSeparator &amp; packOperators.length.String &amp; AuditStringSeparator &amp; packOperators &amp; AuditStringSeparator &amp;
			"Pack Consignees"  &amp; AuditStringSeparator &amp; packConsignees.length.String &amp; AuditStringSeparator &amp; packConsignees &amp; AuditStringSeparator;	
		
	tmpStr := self.getIncludeChassis.asStringJMT;																																																												//+TFS3811 Add Audit for "Include Chassis"
	txt := txt &amp; 'Include Chassis in Codeco' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	tmpStr := null;
	
	return txt;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
