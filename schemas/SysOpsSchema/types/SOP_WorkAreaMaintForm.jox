    <JadeMethod name="clickTerminalAreaExpand" id="358d42e1-6340-42fc-9bb2-e2aba066fb5d">
        <source>clickTerminalAreaExpand( _rowIndex : Integer ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Apr 2014	cnwndl1	Initial creation	Par 33995
25 Jun 2020	jlgdap1	TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
*/

vars

	expand : Boolean;
	ta : CM_TerminalArea;
	index : Integer;
	obj : Object;
	expandSubArea : Boolean;
	gridObject : CM_GridObject;
	locationControllerArray : ObjectArray;

begin

	expand := self.tblAreas.accessCell( _rowIndex, Col_Expand_TA).text = Exp_Expand;
	ta := self.tblAreas.accessRow( _rowIndex ).itemObject.CM_TerminalArea;
		
	if expand then
	
		if not ta.allLocationsControllers.isEmpty then
			if not self.allLoadedObjects.includes( ta.allLocationsControllers.first ) then
				self.loadTerminalAreaSubObjects( ta, _rowIndex );
			endif;
		endif;
		
		self.tblAreas.setCellText( _rowIndex,Col_Expand_TA,Exp_Contract);
		foreach index in _rowIndex + 1 to self.tblAreas.rows do
			obj := self.tblAreas.accessRow( index ).itemObject;
			if obj.isKindOf( CM_TerminalArea ) then
				//this is the next ta.
				break;
			elseif obj.isKindOf( CM_RoRoController ) then
				self.tblAreas.accessRow( index ).visible := true;
				continue;
			elseif obj.isKindOf( CM_GeneralCargoAllocGroup ) then		// TFS 49453
				self.tblAreas.accessRow( index ).visible := true;		// TFS 49453
				continue;												// TFS 49453
			elseif obj.isKindOf( CM_LocationsController ) then
				self.tblAreas.setCellText(index,Col_Incl_SubArea,' ');
				if not expandSubArea then
					continue;
				endif;
			elseif obj.isKindOf( CM_GridObject ) then
				expandSubArea := self.tblAreas.accessCell( index, Col_Expand_SubArea).text = Exp_Contract;
				if not expandSubArea then
					if self.tblAreas.accessCell( index, Col_Expand_SubArea).text.trimBlanks = null then
						gridObject := obj.CM_GridObject;
						create locationControllerArray transient;
						gridObject.getAllLocationsControllers( locationControllerArray, false );
						if locationControllerArray.size &gt; 1 then
							self.tblAreas.setCellText( index, Col_Expand_SubArea, Exp_Expand);
						endif;
						delete locationControllerArray;
					endif;
				endif;
			endif;
			self.tblAreas.accessRow( index ).visible := true;
		endforeach;
		
	else
		self.tblAreas.setCellText( _rowIndex,Col_Expand_TA,Exp_Expand);
		foreach index in _rowIndex + 1 to self.tblAreas.rows do
			obj := self.tblAreas.accessRow( index ).itemObject;
			if obj.isKindOf( CM_TerminalArea ) then
				//this is the next ta.
				break;
			endif;
			self.tblAreas.accessRow( index ).visible := false;
		endforeach;
	endif;
	
	self.refreshTableHighlighting();

epilog

	delete locationControllerArray;
	
end;</source>
        <access>protected</access>
        <Parameter name="_rowIndex" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="clickTerminalAreaInclude" id="67beae19-a4f6-4c6a-824e-2435de99fc51">
        <source>clickTerminalAreaInclude( _rowIndex : Integer ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 April 2014	cnwndl1	Initial creation	Par 33995

*/

vars

	selected : Boolean;
	ta : CM_TerminalArea;
	index : Integer;
	obj : Object;

begin

	selected := self.tblAreas.accessCell( _rowIndex, Col_Incl_TA).text = Item_Selected;

	if selected then
		//we are selecting the whole area
		//unselect any children objects
		//hide the children rows.
		//hide the expand/contract
		ta := self.tblAreas.accessRow( _rowIndex ).itemObject.CM_TerminalArea;
		self.tblAreas.setCellText( _rowIndex,Col_Expand_TA,Exp_Hide);
		
		foreach index in _rowIndex + 1 to self.tblAreas.rows do
			obj := self.tblAreas.accessRow( index ).itemObject;
			if obj.isKindOf( CM_TerminalArea ) then
				//this is the next ta.
				break;
			endif;
			if self.tblAreas.getCellText(index,Col_SubArea_Name).trimBlanks &lt;&gt; null then // Sub Area
				self.tblAreas.setCellText(index,Col_Incl_SubArea,Item_Unselected);
			else	// Sub Sub Area
				self.tblAreas.setCellText(index,Col_Incl_Location,Item_Unselected);
			endif;
			self.tblAreas.accessRow( index ).visible := false;
		endforeach;
		
	elseif not selected then
		//we are UN selecting the whole area
		//show the expand/contract if the area has child areas
		ta := self.tblAreas.accessRow( _rowIndex ).itemObject.CM_TerminalArea;
		if ta.allLocationsControllers.size &lt; 2 then
			self.tblAreas.setCellText( _rowIndex,Col_Expand_TA,Exp_Hide);
		else
			self.tblAreas.setCellText( _rowIndex,Col_Expand_TA,Exp_Expand);
		endif;
	endif;
	
	selectTerminalArea( ta, selected );

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rowIndex" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doColourLegendTable" id="c5753df0-afc6-4345-b276-20ceb7900cef">
