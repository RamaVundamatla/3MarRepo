    <JadeMethod name="doMnuAssignOutwardRailClick" id="ebb5050b-8998-4036-9681-3d272496b032">
        <updating/>
        <source>doMnuAssignOutwardRailClick(_railIORake : CM_RailJSInOutRake; _allBulkReleases : ObjectArray; _form : CM_BaseForm input) updating;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 19/10/2022	jlizm1	TFS 54118 Assigning Releases to Wagons
// ---------------------------------------------------------------------------

vars
	anObject : Object;
	theBR : CM_BulkRelease;
	theRes : CM_ReserveDetail;
	result	: Integer;
	intFaceBP		: CMIF_BuildPriority;
	cmifObjects : ObjectArray;
	qtyForm : GTE_ReleaseQuantityForm;
	cmif_Request : CMIF_Request;
	isRail : Boolean;
	cargoType : CM_CargoType;
begin

	// ### multi select send to BP
	create cmifObjects transient;
	foreach anObject in _allBulkReleases do
		create intFaceBP transient;
		cmifObjects.add(intFaceBP);
		intFaceBP.mode := 1; // Mode_add 

		if anObject.isKindOf(CM_BulkRelease) then
			theBR := anObject.CM_BulkRelease;
			isRail := theBR.type = BR_TYPE_RAIL;	//23 Feb 2017	NDL	TFS 3514
			if isRail then	////23 Feb 2017	NDL	TFS 3514
				foreach theRes in theBR.allReserveDetails do
					if theRes.isKindOf(CM_ReserveTI) then
						if not theRes.allRequests.isEmpty then
							continue;
						endif;
					endif;
					
					cargoType := theRes.getCargoType;
					if cargoType = null then
						continue;
					endif;
					if not self.myTerminal.getConfig(RailReleaseAssignEnhance).Boolean then	//03 Dec 2020	NDL	TFS 50164
						if cargoType.isBulkMulti or cargoType.isBreakBulkMulti then
							continue;
						endif;
					endif;
					intFaceBP.allReservesToProcess.add( theRes );
				endforeach;
			else
				theBR.allReserveDetails.copy(intFaceBP.allReservesToProcess);
			endif;
		elseif anObject.isKindOf(CM_ReserveDetail) then
			theRes := anObject.CM_ReserveDetail;
			theBR := theRes.myReserveHeader;
			intFaceBP.allReservesToProcess.add(theRes);
		elseif anObject.isKindOf(CM_TrackedItem) then
			// cnwdad1 28/05/2007 - PAR #14118.
			//theBR := anObject.CM_TrackedItem.allBulkReleasesAssigned[BR_TYPE_RAIL,null,null,null];
			theBR := anObject.CM_TrackedItem.allBulkReleasesAssigned.getAtKeyGeq(BR_TYPE_RAIL,null,null,null);
			if theBR &lt;&gt; null then				
				theBR.allReserveDetails.copy(intFaceBP.allReservesToProcess);
			endif;
		endif;

		if theBR &lt;&gt; null then //PAR 10935
			theBR.setInterfaceBP(intFaceBP, _railIORake); //PAR 19771
		endif;

	endforeach;

	// PAR 19710 CCMS SFW 1067
	qtyForm := app.loadForm(GTE_ReleaseQuantityForm, GTE_Assistant, false, false, false, self.myTerminal, _form.myMasterMenuAction).GTE_ReleaseQuantityForm;
	qtyForm.initialise(cmifObjects, _railIORake, (_railIORake=null), false, self.myTerminal, self);
	qtyForm.showModal();
	if qtyForm.modalResult &lt;&gt; IDOK then
		return;
	endif;
	
	while true do
	
		if self.myTrain &lt;&gt; null then
			app.myTrxUA.trxUpdateAssignOutwardTrain(cmifObjects, self.myTrain , app.myPassport); // PAR 19710
		else
			app.myTrxUA.trxUpdateAssignOutwardRail(cmifObjects, _railIORake, app.myPassport);
		endif;
		
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			_form.clearErrorWarnings();
			//global.beep; 
			break;
		else
			result := app.showErrorWarningDialog('Assign To Outward Rail', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			_form.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;
	
epilog
	if cmifObjects &lt;&gt; null then
		foreach anObject in cmifObjects do
			intFaceBP := anObject.CMIF_BuildPriority;
			
			delete intFaceBP.myProxyRailJob;
			intFaceBP.allCMIFRequests.purge;
			delete intFaceBP;
	
		endforeach;
		cmifObjects.purge;
	endif;
	delete cmifObjects;
	delete qtyForm;

end;</source>
        <Parameter name="_railIORake" type="CM_RailJSInOutRake"/>
        <Parameter name="_allBulkReleases" type="ObjectArray"/>
        <Parameter name="_form" type="CM_BaseForm" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAutoCompleteStatus" id="266fb320-c80f-4a0c-acfd-88c76b0b70c7">
        <source>getAutoCompleteStatus(_parentForm: CM_BaseForm input) : Boolean;
/*
Date		Who		Reason
21 September 2009	cnwas3	Initial creation

*/

vars

begin
	if _parentForm.isKindOf(GTE_FlexiGateForm) then
		return _parentForm.GTE_FlexiGateForm.chkAutoComplete.value;
	endif;
	
	if _parentForm.isKindOf(GTE_FlexiGateOutForm) then
		// When adding at gate complete always auto complete
		return true;
	endif;
	
	return false;
epilog

end;</source>
        <Parameter name="_parentForm" type="CM_BaseForm" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getIntFaceClass" id="a985b5ce-8ca6-467a-9df8-ff3a2c38f6f3">
        <source>getIntFaceClass(_code : String; pCargoDocketId : Integer; _mainTbl : CM_EntryTable) : Class;
// ---------------------------------------------------------------------------
// Created:     15 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	intFaceClass	: Class;
	
begin

	if _code = NavObj_GTE_In then
		if pCargoDocketId = BOLType_Log or
		   pCargoDocketId = BOLType_GeneralDocket then
			intFaceClass := GTEIF_BOLIn;
		else
			intFaceClass := CMIF_Receival;
		endif;
	elseif _code = NavObj_GTE_OutByType then
		intFaceClass := CMIF_ReleaseByType;
	elseif _code = NavObj_GTE_OutById then
		intFaceClass := CMIF_ReleaseById;
	elseif _code = NavObj_GTE_PreNote_TableView then
		intFaceClass := CMIF_PreNote;
	elseif _code = NavObj_GTE_Out then
		if pCargoDocketId = BOLType_Log or
		   pCargoDocketId = BOLType_GeneralDocket then
			intFaceClass := CMIF_BOLOut;
		elseif self.isReleaseByType(_mainTbl) then
			intFaceClass := CMIF_ReleaseByType;
		else
			intFaceClass := CMIF_ReleaseById;		
		endif;		
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'No CMIF class found for (' &amp; _code &amp; ')');
		intFaceClass := null;
	endif;
	
	return intFaceClass;

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="pCargoDocketId" type="Integer"/>
        <Parameter name="_mainTbl" type="CM_EntryTable"/>
        <ReturnType type="Class"/>
    </JadeMethod>
