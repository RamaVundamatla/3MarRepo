	elseif _sht.name = self.shtEdit8.name then
		return self.tblEdit8;
	elseif _sht.name = self.shtEdit9.name then
		return self.tblEdit9;
	elseif _sht.name = self.shtEdit10.name then
		return self.tblEdit10;
	endif;
	
