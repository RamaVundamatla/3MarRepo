    <JadeMethod name="selectYAForEdit" id="1d5f389c-d476-4898-bb46-2a734a3e4ad3">
        <updating/>
        <source>selectYAForEdit(_yaObj: Object) updating;
//04 November 2008	cnwdw1	
// Update the Satellite view with YA selected in YAM Table
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------------------------
// 17/11/2011	cnwdap1		PAR #28514 Don't default to the first block if we've only got a YA selected
//							- this does strange things to the drawing rectangles otherwise, and assumes 
//							we're going to edit a block when we don't have a block selected
vars
	ydc 	: YRD_ContainerDrawingController;
	obj		: Object;
	ya		: CM_YardAllocation;
	yaBlock	: CM_YABlock;
	invalid	: Boolean;
	edition : Integer;
	
begin
	on Exception do app.handleDeletedObject (exception, _yaObj, invalid);		// 14/03/2013 cnwar2 #30862
	edition := _yaObj.edition;
	if invalid then
		return;
	endif;
	
	foreach obj in self.allDrawingControllers do
		ydc := obj.YRD_ContainerDrawingController;
				
		if _yaObj.isKindOf(CM_YardAllocation) then
			ya := _yaObj.CM_YardAllocation;
			self.cmbYA.text := ya.code;
			ydc.getOverlayEditFrame().setCurrentEditYardAllocation(ya);
			ydc.getOverlayEditFrame().clearSelectedRectFrame();
			//yaBlock := ya.allYABlocksIn.first;								// PAR #28514
			//if yaBlock &lt;&gt; null then											// PAR #28514
			//	ydc.getOverlayEditFrame().selectRectFrameForYABlock(yaBlock);	// PAR #28514
			//else																// PAR #28514
			//	ydc.getOverlayEditFrame().clearYALocationText();				// PAR #28514
			//endif;															// PAR #28514
		elseif _yaObj.isKindOf(CM_YABlock) then
			ya := _yaObj.CM_YABlock.myYardAllocationIn;
			self.cmbYA.text := ya.code;
			ydc.getOverlayEditFrame().setCurrentEditYardAllocation(ya);
			ydc.getOverlayEditFrame().clearSelectedRectFrame();
			ydc.getOverlayEditFrame().selectRectFrameForYABlock(_yaObj.CM_YABlock);
		endif;
	endforeach;
end;</source>
        <Parameter name="_yaObj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="555eed76-6b60-4564-8f32-e69d4234aa6f">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
// --------------------------------------------------------------------------------
// Created:		20 November 2008 by cnwdad1
//
