    <JadeMethod name="populateTrackedItem" id="8e721d9a-96ec-4e99-9849-6151dcd9c6ff">
        <source>populateTrackedItem();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 May 2013	cnwndl1	Initial creation	CCMS 2274	Break-bulk
01 Apr 2014	NDl	CCMS 1366

*/

vars

begin

	if self.myTrackedItem &lt;&gt; null then
		self.txtCargoId.text := self.myTrackedItem.id;
		self.cmbOperator.listIndex := self.cmbOperator.findObject( self.myTrackedItem.myOperator );
		
		//01 Apr 2014	NDL	CCMS 1366
		if self.myTrackedItem.isBulkByQuantity then
			self.txtQuantity.visible := true;
			self.tblWeightVolume.visible := false;
			self.lblOptBB.visible := true;
			self.optNewBB.visible := true;
			self.lblOptPieceBB.visible := true;
			self.optNewPieceBB.visible := true;
			self.lblQuantity.caption := app.getErrorString(CM_Quantity) &amp; " (" &amp; self.myTrackedItem.totalQuantity.String &amp; ")";
			
		elseif self.myTrackedItem.isBulkByWeight or self.myTrackedItem.isBulkByVolume then
			self.txtQuantity.visible := false;
			self.optNewBB.value := true;
			self.lblOptBB.visible := false;
			self.optNewBB.visible := false;
			self.lblOptPieceBB.visible := false;
			self.optNewPieceBB.visible := false;
			self.setBulkWeightVolumeFields( self.myTrackedItem, self.tblWeightVolume, self.lblQuantity, 0.00 );
			
		endif;
		
	else
	
		//01 Apr 2014	NDL	CCMS 1366
		self.txtQuantity.visible := true;
		self.tblWeightVolume.visible := false;
		self.lblOptBB.visible := true;
		self.optNewBB.visible := true;
		self.lblOptPieceBB.visible := true;
		self.optNewPieceBB.visible := true;
		self.txtCargoId.text := self.lblCargoId.caption.toUpper;
		self.lblQuantity.caption := app.getErrorString(CM_Quantity);
		
		self.txtCargoId.text := self.lblCargoId.caption.toUpper;
		self.cmbOperator.listIndex := -1;
	endif;
	
	
	self.resetExample();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="resetExample" id="cf8e7f14-3419-4fda-b1ac-96e7de6ed557">
        <source>resetExample();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 May 2013	cnwndl1	Initial creation

*/

vars

	mainId : String;
	quantity : Integer;
	suffix : Integer;

begin

	self.lblExample.caption := null;
	
	if optNewPieceBB.value then

		quantity := self.txtQuantity.text.Integer;
		if quantity = 0 then
			return;
		endif;
		
		suffix := self.txtSuffix.text.Integer;
		if suffix = 0 then
			suffix := 1;
		endif;
		
		if self.txtSuffix.text.length &lt; quantity.String.length then
			self.txtSuffix.text := suffix.padLeadingWith( '0', quantity.String.length );
		endif;
		
		if self.txtNewCargoId.text.toUpper = self.lblNewCargoId.caption.toUpper then
			return;
		endif;
		mainId := self.txtNewCargoId.text.toUpper;
		if mainId = null then
			return;
		endif;
	
		self.lblExample.caption := mainId &amp; suffix.padLeadingWith( '0', quantity.String.length );
		
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="selectCargoItem" id="61243dbc-6095-4a95-b1b6-2dca2d44b066">
        <updating/>
        <source>selectCargoItem( _manual : Boolean ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 May 2013	cnwndl1	Initial creation	CCMS 2274 Break-bulk

*/

vars

	cargoId : String;
	term : CM_Terminal;
	firstTi : CM_TrackedItem;
	tiArray : CM_TIArray;
	iter : Iterator;
	ti : CM_TrackedItem;
	errMsg : String;
	
	revDict : CM_TIByIdCargoTypeDictRev;	
	cargoIdLength : Integer;	
	cargoIdReversed : String;
	
begin
	

	cargoId := txtCargoId.text.trimBlanks.toUpper;
	if cargoId = lblCargoId.caption.toUpper then
		cargoId := null;
	endif;
	
	self.setMyTrackedItem( null ); //epr par 32432 16/09/13
	
	term := self.myMobileDataAgent.myTerminal;
	
	create tiArray transient;
	
	if cargoId &lt;&gt; null then
	
		cargoIdLength := cargoId.length;	
		cargoIdReversed := cargoId.reverse;
		
		firstTi := term.allOnsiteTIsByIdCargoType.getAtKeyGeq(cargoId,null);
		if firstTi &lt;&gt; null and firstTi.id[1:cargoIdLength] = cargoId then	
			iter := term.allOnsiteTIsByIdCargoType.createIterator;
			iter.startAtObject(firstTi);
			while iter.next( ti ) do
				if ti.id[1:cargoIdLength] &lt;&gt; cargoId then
					break;
				endif;
				if not ti.canSplitTotalQuantity then
					continue;
				endif;
				tiArray.addExclusive(ti);
			endwhile;
			delete iter;
		endif;
		
		firstTi := term.allOnsiteTIsByIdCargoTypeRev.getAtKeyGeq(cargoIdReversed,null);
		if firstTi &lt;&gt; null and firstTi.idReversed[1:cargoIdLength] = cargoIdReversed then
			iter := term.allOnsiteTIsByIdCargoTypeRev.createIterator;
			iter.startAtObject(firstTi);
			while iter.next( ti ) do
				if ti.idReversed[1:cargoIdLength] &lt;&gt; cargoIdReversed then
					break;
				endif;
				if not ti.canSplitTotalQuantity then
					continue;
				endif;
				tiArray.addExclusive(ti);
			endwhile;
			delete iter;
		endif;
		
		
	endif;
		
	if tiArray.size = 1 then
		self.setMyTrackedItem( tiArray.first );
		self.populateTrackedItem();
		return;
		
	else
		app.myMobileCargoFindAgent.setID( cargoId );
		app.myMobileCargoFindAgent.setMyTrackedItemToProcess(null);
		app.myMobileCargoFindAgent.setDoSearchImmediate( true );
		app.myMobileCargoFindAgent.setSearchSite(TI_SITE_ONSITE);
		app.myMobileCargoFindAgent.setCanSplitOnly(true);
		
		self.gotoForm( MOB_HHCargoFind, false );
		return;
		
	endif;
	

epilog

	delete tiArray;
	delete iter;
	delete revDict;	

end;</source>
        <Parameter name="_manual" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMyTrackedItem" id="7191b4d1-595e-45de-9fac-bcecddd0012f">
        <updating/>
        <source>setMyTrackedItem( _ti : CM_TrackedItem ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 May 2013	cnwndl1	Initial creation	CCMS 2274 Break-bulk
01 Apr 2014	NDl	CCMS 1366

*/

vars

	errorMess : String;

begin

	if _ti &lt;&gt; null then
		if not _ti.canSplitTotalQuantity then
			errorMess := app.getErrorString1(Cargo_selecte_not_split,_ti.id);
			self.msgBox(errorMess ,app.getErrorString(Error), MsgBox_OK_Only, false);
			self.setMyTrackedItem( null );
			return;
		endif;
		
	endif;
	
	self.getSessionAgent().setMySelectedTI( _ti );
	app.myMobileCargoFindAgent.setMyTrackedItemToProcess( null );
	self.myTrackedItem := _ti;
	
	if _ti = null then
		self.txtCargoId.text := self.lblCargoId.caption.toUpper;
		self.lblQuantity.caption := app.getErrorString(CM_Quantity);
		return;
	endif;
	
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setupControls" id="6c8e79f2-0833-4375-adef-c262dc4090a5">
        <updating/>
        <source>setupControls() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 May 2013	cnwndl1	Initial creation	CCMS 2274	break-bulk
01 Apr 2014	NDl	CCMS 1366

*/

vars
	
	operator : CM_Operator;
	failedDAC  :CM_DataAccessController;

begin
	
	self.doResizeControls(true);
	
	self.cmbOperator.clear();
	foreach operator in app.myRoot.allOperators do
		if operator.isNotAvailableForEntry then
			continue;
		endif;
		if app.myPassport &lt;&gt; null and (not operator.canUserAccessSelf(null, failedDAC, app.myPassport)) then
			continue;
		endif;
		self.cmbOperator.itemObject[self.cmbOperator.addItem(operator.code &amp; Tab &amp; operator.description)] := operator;
	endforeach;
	
	self.optNewBB.value := true;
	self.changeOption();
	
	self.populateTrackedItem();	
	self.txtCargoId.setFocus;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="da39de06-a0c0-4175-9cad-9594c66b3f8b">
        <updating/>
        <source>setupForm() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 May 2013	cnwndl1	Initial creation	CCMS 2274 Break-bulk

*/

vars

	ti : CM_TrackedItem;
	
begin

	self.myHandHeldCheckerAgent := app.myHandHeldCheckerAgent;
	self.myMobileGenericAgent.clearAll(); // to reset 'terminal' on the agent..

	if app.myMobileCargoFindAgent = null then
		create app.myMobileCargoFindAgent transient;
	endif;
	
	ti := app.myMobileCargoFindAgent.myTrackedItemToProcess;
	if ti &lt;&gt; null then
		//returning from a specific search
		self.setMyTrackedItem(  app.myMobileCargoFindAgent.myTrackedItemToProcess );
	else
		// populated on one of the other maint forms
		self.setMyTrackedItem( self.getSessionAgent().mySelectedTI );
	endif;
	
	self.setupCmdButtons( 2, app.getErrorString(Split), app.getErrorString(Cancel), null, null, null );
	
	inheritMethod();
	
	self.setupControls();
	
	
epilog
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="0b1b0c46-21b2-4b37-84d1-2fafb6d5c125">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 11 March 2019 19:49:07.
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0023417, locale);
	lblCargoId.translateCaption(Xlat_0023424, locale);
	lblExample.translateCaption(Xlat_0023420, locale);
	lblNewCargoId.translateCaption(Xlat_0023422, locale);
	lblOptBB.translateCaption(Xlat_0023419, locale);
	lblOptPieceBB.translateCaption(Xlat_0023418, locale);
	lblQuantity.translateCaption(Xlat_0023423, locale);
	lblSuffix.translateCaption(Xlat_0023421, locale);
	optNewBB.translateCaption(Xlat_0023426, locale);
	optNewPieceBB.translateCaption(Xlat_0023425, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="txtCargoId_gotFocus" id="0a499251-44bc-49a8-905e-a85a21d24d6b">
        <controlMethod name="TextBox::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtCargoId_gotFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 May 2013	cnwndl1	Initial creation	CCMS 2274 Break-bulk

*/

vars

begin

	if self.txtCargoId.text = self.lblCargoId.caption.toUpper then
		self.txtCargoId.selStart := 0;
		self.txtCargoId.selLength := self.lblCargoId.caption.length;
	endif;

epilog

