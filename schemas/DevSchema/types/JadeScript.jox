    <JadeMethod name="ndl001" id="ce2a7fed-b1df-4a06-b18f-c9f95e87125c">
        <source>ndl001();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 December 2011	cnwndl1	Initial creation

*/

vars

	termRole	: CM_SecurityRoleTerminalRoot;
	sysRole		: CM_SecurityRoleSystemRoot;
	newPerms	: IntegerArray;
	srt : CM_SecurityRoleTerminal;
	hasCargoEnqView : Boolean;
	
begin

	create newPerms transient;

//	newPerms.add(PmAdmVoyageProcessView);	//system based
//	newPerms.add(PmAdmVoyageProcessMaint);	//system based
//	newPerms.add(PmInvInvoiceSignoffTypeView);	//terminal based
//	newPerms.add(PmInvInvoiceSignoffTypeMaint);	//terminal based
//	newPerms.add(PmAdmCGAView);	//terminal based
//	newPerms.add(PmAdmCGAMaint);	//terminal based
//	newPerms.add(PmAdmInvPayMapMaint);	//terminal based
//	newPerms.add(PmAdmInvPayMapView);	//terminal based
//	newPerms.add(PmInvSAPServiceMonView);	//terminal based
//	newPerms.add(PmAdmSnapShotEditMaint);	//terminal based
//	newPerms.add(PmAdmSnapShotEditView);	//terminal based

//	newPerms.add(PmWeighForm);	//terminal based
//	newPerms.add(PmGteCashConsolidationView);	//terminal based
//	newPerms.add(PmGteCashConsolidationMaint);	//terminal based
//	newPerms.add(PmInvSAPReprocess);	//terminal based
//	newPerms.add(PmAdmCashRecEnq);	//terminal based
	
//	newPerms.add(PmShipBargeCopy);	//terminal based
//	newPerms.add(PmShipBargeCreate);	//terminal based
//	newPerms.add(PmShipBargeChange);	//terminal based
//	newPerms.add(PmShipVoyageEnquiryDel);	//terminal based
	
//	newPerms.add(PmAdmReeferWalkView);	//terminal based
//	newPerms.add(PmAdmReeferWalkMaint);	//terminal based

//	newPerms.add(PmAdmReeferAutoMaint);	//terminal based
//	newPerms.add(PmAdmReeferAutoView);	//terminal based
//	newPerms.add(PmAdmReeferAddJob);	//terminal based
//	newPerms.add(PmAdmReeferMaintMaint);	//terminal based
//	newPerms.add(PmAdmReeferMaintView);	//terminal based

//	newPerms.add(PmAdmEnterVVR);	//terminal based
//	newPerms.add(PmAdmRoadProcessView);	//system based
//	newPerms.add(PmAdmRoadProcessMaint);	//system based
//	newPerms.add(PmGteVVInventMaint);	//terminal based
//	newPerms.add(PmGteVVInventView);	//terminal based

//	newPerms.add(PmAdmAuditConfigView);	//system based
//	newPerms.add(PmAdmAuditConfigMaint);	//system based
	
//	newPerms.add(PmAdmLocationActEnqView);	//terminal based
//	newPerms.add(PmAdmLocationActEnqMaint);	//terminal based
//	newPerms.add(PmAdmLocationInvView);	//terminal based
//	newPerms.add(PmAdmLocationInvMaint);	//terminal based
	
	newPerms.add(PmAdmBlendFormMaint);	//terminal based

	termRole := CM_SecurityRoleTerminalRoot.firstInstance;
	sysRole := CM_SecurityRoleSystemRoot.firstInstance;
	beginTransaction;
		//terminal based
		termRole.setPermissionsFromIntArray(newPerms,true);
		sysRole.setPermissionsFromIntArray(newPerms,false);
		//system based
	//	termRole.setPermissionsFromIntArray(newPerms,false);
	//	sysRole.setPermissionsFromIntArray(newPerms,true);
	commitTransaction;
	
/*	
	foreach srt in CM_SecurityRoleTerminal.instances do
		if srt.permissions.size &lt; PmAdmCargoEnquiryView then
			continue;
		endif;
		hasCargoEnqView := srt.permissions[PmAdmCargoEnquiryView];
		if hasCargoEnqView then
			beginTransaction;
			srt.setPermissionsFromIntArray(newPerms,true);
			commitTransaction;
		endif;
	endforeach; */
	
epilog

	delete newPerms;

end;</source>
    </JadeMethod>
