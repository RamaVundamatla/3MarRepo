    <JadeMethod name="translateForm" id="92b8bf4a-0581-4b7d-a5df-0c40ba8cdf47">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0017260, locale);
	btnCancel.translateCaption(Xlat_0015911, locale);
	btnClose.translateCaption(Xlat_0015912, locale);
	btnNew.translateCaption(Xlat_0015913, locale);
	btnRemove.translateCaption(Xlat_0015914, locale);
	btnSave.translateCaption(Xlat_0015915, locale);
	btnUpdate.translateCaption(Xlat_0015916, locale);
	lblCalendar.translateCaption(Xlat_0015917, locale);
	lblDate.translateCaption(Xlat_0015918, locale);
	lblDescription.translateCaption(Xlat_0015919, locale);
	lblEndTime.translateCaption(Xlat_0015920, locale);
	lblStartTime.translateCaption(Xlat_0015921, locale);
end;</source>
    </JadeMethod>
