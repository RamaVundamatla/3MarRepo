    <JadeMethod name="doSave" id="07942255-591f-437e-92c5-82d1c61dd8f7">
        <updating/>
        <source>doSave() : Boolean updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 July 2009	cnwdap1	Initial creation

*/

vars

begin
	if self.isFlexiGateForm and (self.hasBulkRelease() or self.hasPreNote() or self.hasBookingRef()) then
		// From was opened via a PIN Number, so give the PIN textbox focus, ready for more input
		//self.myAssistant.doFlexiGateFormPINFocus(self.myParentForm);
	endif;
	
	return true;

epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findPrenoteContainer" id="9ffd7111-70db-4365-bddd-cf158a0c73aa">
        <source>findPrenoteContainer(_id : String) : CM_Container  protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18/06/2009	cnwjk3	Initial creation
22/09/2016	cnwdap1	TFS 2651 If the returned container doesn't match the selected booking, return null
*/
vars
	container : CM_Container;

begin
	//return self.myTerminal.lookupTrackedItem(_id, TI_CargoType_Container, TI_STATE_NOTIFIED, null, false).CM_Container;		// TFS 2651
	container := self.myTerminal.lookupTrackedItem(_id, TI_CargoType_Container, TI_STATE_NOTIFIED, null, false).CM_Container;	// TFS 2651
	if container &lt;&gt; null and container.isPreNote and container.myBookingRefItem &lt;&gt; self.myBookingRefItem then					// TFS 2651
		container := null;																										// TFS 2651
	endif;																														// TFS 2651
	return container;																											// TFS 2651
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_id" type="String"/>
        <ReturnType type="CM_Container"/>
    </JadeMethod>
