    <JadeMethod name="setProxy" id="d65032f1-cdea-4046-8931-40d5797c6c47">
        <updating/>
        <source>setProxy(_code, _description : String; _notAvailableForEntry : Boolean; _colour: Integer; _debtor: CM_Debtor) updating;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//07-06-2022 	navtnr20 	53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
// 07/09/2022	navmd1		TFS 54664 Allow myDebtor to be set during creation/update
// 14 Aug 2023 	navhl20 	ChangeRequest 56642: MTN - Invoicing Shipping Line / Debtor Link
// ---------------------------------------------------------------------------

vars

begin

	self.raiseExceptionIfNotTransient(method);

	self.code := _code[1:4];
	self.description := _description[1:40];
	self.isNotAvailableForEntry := _notAvailableForEntry;
	self.colour := _colour;		//07-06-2022 navtnr20 53204
	
	self.myDebtor := _debtor;
	self.myRoot	:= app.myRoot;
	if _debtor = null then 										//14.8.2023 navhl20 #56642
		self.myDebtor := app.myRoot.myRootCompany.rootDebtor; 
	else 
		self.myDebtor := _debtor;
	endif; 
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_notAvailableForEntry" type="Boolean"/>
        <Parameter name="_colour" type="Integer"/>
        <Parameter name="_debtor" type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="26983de3-c950-4b43-93f7-7873fc76506c">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if app.myRoot.allShippingLines[code] &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.code, null, null);
	endif;

	self.validateMe;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="e664977c-b17f-4471-bba7-eaa3b995539d">
