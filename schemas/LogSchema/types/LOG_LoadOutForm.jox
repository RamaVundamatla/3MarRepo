        <source>cmbVoyage_displayEntry(combobox: ComboBox input; obj: Any; lstIndex: Integer):String updating;
//--------------------------------------------------------------
//Created: 11 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if obj.CM_Voyage.isClosedStatus() then
		return null;
	else
		return self.myAssistant.displayEntryVoyageObject(obj.CM_Voyage);
	endif;
end;</source>
