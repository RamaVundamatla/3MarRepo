    <JadeMethod name="setMembership" id="a9efb71d-9e77-4527-b0a6-b35d7fb5c20d">
        <lockReceiver/>
        <updating/>
        <source>setMembership(type: Class) updating, lockReceiver;
// ---------------------------------------------------------------------------
// Created:     08 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	propSet	: PropertySet;
	prop	: Property;
	ls		: Boolean;

begin
	inheritMethod(type);

	app.cmsBeginLoad(ls);
	
	self.allKeys.clear;
	self.allProperties.clear;
	self.myMemberClass := type;
	
	if type = null then
		return;
	endif;
	
	create propSet transient;
	
	type.allPropertiesInFullTreeUpTo(Object, propSet);
	
	foreach prop in propSet do
		if self.allProperties.getAtKey(prop.name) &lt;&gt; null then
			continue;
		endif;
		self.allProperties.add(prop);
	endforeach;

epilog
	delete propSet;
	app.cmsEndLoad(ls);
	
end;</source>
        <Parameter name="type" type="Class"/>
    </JadeMethod>
</CollClass>
