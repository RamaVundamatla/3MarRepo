    <JadeMethod name="getTaxForInvoice" id="71c7c9cf-688e-4920-a4d2-3fdaa6acdb4f">
        <source>getTaxForInvoice(_useSplitTax : Boolean; _codes : StringArray input; _rates  : RealArray input; _amounts : RealArray input);
// ---------------------------------------------------------------------------
// Created:		18 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 23/11/2018	jlgdap1		TFS 41949 PEL1 Tax Number and Stamps based on SKTD and BUT Certificates on a Voyagevars
// 13/10/2022   navmv20     ChangeRequest 55005: EUP - Invoicing - Invoice Line TAX Maintenance
//
vars
	effectiveDate	: TimeStamp;
	aService 		: CM_Service;
	charge			: CM_Charge;
	glSumm 			: CM_GLSummaryByGLCodeRateDict;
	glStat 			: CM_GLSummary;
	aLineDesc 		: CM_InvoiceLineDesc;
	theInvoiceLine 	: CM_InvoiceLine;
	taxCode 		: CM_TaxCode;
	pTaxCode 		: String;
	pTaxRate 		: Real;
	taxRate 		: CM_TaxRate;
	idx 			: Integer;
	theInvoice 		: CM_Invoice;
	debtor			: CM_Debtor;
	voyage 			: CM_Voyage;
	hookExempt,
	invalid 		: Boolean;
begin
	theInvoice := self.invoiceLine.invoice;
	debtor := theInvoice.debtor;
	if debtor &lt;&gt; null and debtor.isZeroRatedTax then		// 19/10/17 MAP TFS7357
		return;
	endif;
	
	on Exception do app.handleDeletedObject(exception, theInvoice, invalid);
	// TFS 37562 exempt by voyage
	if theInvoice &lt;&gt; null then
		voyage := theInvoice.myVoyage;
		if voyage &lt;&gt; null then
			if voyage.myHMSVoyageData &lt;&gt; null and voyage.myHMSVoyageData.isZeroRatedTax then	//12 Jun 2018	NDL	TFS 39141 
				if self.invoiceLine.isVoyageForProforma then
					return;
				endif;
			endif; 
			if voyage.myHMSVoyageData &lt;&gt; null and voyage.myHMSVoyageData.isZeroRatedTaxCargo then	// TFS 41949
				return;																				// TFS 41949
			endif; 																					// TFS 41949
			hookExempt := app.myRoot.getVoyageTaxExempt( voyage.myTerminal, voyage ).Boolean;
			if hookExempt then
				return;
			endif;
		endif;
	endif;
	effectiveDate := theInvoice.toDT;
	if not effectiveDate.isValid() then
		effectiveDate := theInvoice.postedDT;
	endif;
	if not effectiveDate.isValid() then
		effectiveDate := theInvoice.createdTime;
	endif;
	pTaxCode := self.bank.parentCompany.taxNumber;
	pTaxRate := self.bank.parentCompany.taxPercentageRate;
	
	if self.service &lt;&gt; null then			// 36965 handle null service
		// START - 13/10/2022 navmv20 TFS 55005
		// taxCode := self.service.myTaxCode;
		if self.myOverrideTaxCode&lt;&gt; null then
			taxCode := self.myOverrideTaxCode; 
		else 
			taxCode := self.service.myTaxCode;
		endif;
		// END - 13/10/2022 navmv20 TFS 55005
	endif;
	if taxCode &lt;&gt; null then
		idx := _codes.indexOf(taxCode.code);
		if idx = 0  then
			_codes.add(taxCode.code);
			idx := _codes.size;
			_amounts.add(0);
			
			taxRate := taxCode.getTimeRate(effectiveDate);
			if taxRate = null then
				_rates.add(0);
			else
				_rates.add(taxRate.rate);
			endif;
		endif;
		_amounts[idx] := _amounts[idx] + self.total;
		
	else
		idx := _codes.indexOf(pTaxCode);
		if idx = 0  then
			_codes.add(pTaxCode);
			idx := _codes.size;
			_rates.add(pTaxRate);
			_amounts.add(0);
		endif;

		_amounts[idx] := _amounts[idx] + self.total;

	endif;
end;</source>
        <Parameter name="_useSplitTax" type="Boolean"/>
        <Parameter name="_codes" type="StringArray" usage="input"/>
        <Parameter name="_rates" type="RealArray" usage="input"/>
        <Parameter name="_amounts" type="RealArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTaxGLCode" id="bbd05d94-63b8-47d7-9a14-41b8733f049e">
        <source>getTaxGLCode() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Nov 2018	jlgsl4	TFS 41230 - ADP - Invoice export
13 Oct 2022 navmv20 ChangeRequest 55005: EUP - Invoicing - Invoice Line TAX Maintenance
*/

vars
	taxGLCode : String;
	tc : CM_TaxCode;
begin	
	//START - 13/10/2022 navmv20 TFS 55005
	if self.myOverrideTaxCode &lt;&gt; null then
		if self.myOverrideTaxCode.myGLCode &lt;&gt; null then
			taxGLCode:=self.myOverrideTaxCode.myGLCode.code;
		endif;
	else
	//END - 13/10/2022 navmv20 TFS 55005
	
	/* // ### TFS CR 62992 TASK 62994 21MAR2024 NAVAB1
		if self.service &lt;&gt; null and self.service.genLCode &lt;&gt; null then
			taxGLCode := self.service.genLCode.code;
		endif;
		*/
		
		tc := self.getTaxCodeObject();
		if tc &lt;&gt; null and tc.myGLCode &lt;&gt; null then
			taxGLCode := tc.myGLCode.code;
		endif;
	endif;
	
	return taxGLCode;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTaxRateForCharge" id="a3720ac4-d1f6-4197-a2ae-ab530a7af097">
        <source>getTaxRateForCharge() : Real;
// ---------------------------------------------------------------------------
// Created:     September 2010 ANDREW BISHOP
// PAR 25720
// Changed On   Changed By  	Reason
// ----------   ----------  	--------------------------------------------------
// 23/11/2018	jlgdap1			TFS 41949 PEL1 Tax Number and Stamps based on SKTD and BUT Certificates on a Voyage
// 13/10/2022   navmv20         ChangeRequest 55005: EUP - Invoicing - Invoice Line TAX Maintenance
// ---------------------------------------------------------------------------

vars
	effectiveDate	: TimeStamp;
	taxCode : CM_TaxCode;
	taxRateAmount : Real;
	taxRateObject : CM_TaxRate;
	theInvoice : CM_Invoice;
	theBank : CM_Bank;
begin
	//epr 6/5/19 refactored part of TFS 44550
	if self.isTaxExempt(null) then
		return 0;
	endif;

	theBank := self.invoiceLine.bank;
	theInvoice := self.invoiceLine.invoice;
	
	if theBank = null and self.service &lt;&gt; null then
		theBank := self.service.bank;
	endif;
	
	if theBank.terminal.getConfig(InvoiceMultiTaxRates).Boolean then
		if self.service &lt;&gt; null then			// 36965 handle null service
			//START - 13/10/2022 navmv20 TFS 55005
			//taxCode := self.service.myTaxCode;
			if self.myOverrideTaxCode &lt;&gt; null then
				taxCode := self.myOverrideTaxCode; 
			else 
				taxCode := self.service.myTaxCode;
			endif; 
			//END - 13/10/2022 navmv20 TFS 55005
		endif;
		
		if taxCode &lt;&gt; null then
			if theInvoice = null or  not app.isValidObject( theInvoice) then	
				effectiveDate.setDate(self.invoiceLine.getChargeDate());
			else
				effectiveDate := theInvoice.toDT;
				if not effectiveDate.isValid() then
					effectiveDate := theInvoice.postedDT;
				endif;
				if not effectiveDate.isValid() then
					effectiveDate := theInvoice.createdTime;
				endif;
			endif;
			
			taxRateObject := taxCode.getTimeRate(effectiveDate);
			if taxRateObject &lt;&gt; null then
				taxRateAmount := taxRateObject.rate;
			else
				taxRateAmount := 0;
			endif;
		endif;
	else
		taxRateAmount := theBank.taxPercentageRate;
	endif;
	
	
	return taxRateAmount;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getWorkOrder" id="45424b2e-46ed-4fbc-92fe-f4d3b2a9cca7">
        <source>getWorkOrder() : CM_WorkOrderDtl;
/*
Purpose:			

Date		Who		Reason
// ### TFS 57512 12APR2023 NAVAB1
*/

vars

begin
	if self.invoiceLine = null then
		return null;
	endif;
	
	if self.invoiceLine.myTransactionWO = null then
		return null;
	endif;
	
	if self.invoiceLine.myTransactionWO.myWorkOrderDetail = null then
		return null;
	endif;

	return self.invoiceLine.myTransactionWO.myWorkOrderDetail;

end;
</source>
        <ReturnType type="CM_WorkOrderDtl"/>
    </JadeMethod>
    <JadeMethod name="glCode" id="5be2a750-a481-4267-bd75-6a26a21d6729">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>glCode(set: Boolean; value: String io) mapping, updating;
//
//14 Apr 2015	cnwrs1	Par 36043 handle a null self.service
begin

	if set then
		if self.invoiceLine &lt;&gt; null and
			self.invoiceLine.invoice &lt;&gt; null and
			//self.invoiceLine.invoice.status = CM_Invoice.INVOICE_POSTED
			self.invoiceLine.invoice.isPostedOrReversal	//04 Sep 2017	NDL	TFS 6759	
			then
			app.setContinueCMExceptions(false);
			app.raiseCMException(ERR_CHANGE_POSTED_NOTALLOWED, null, null);
			return;
		endif;
		self.glCode := value;
	else
		if self.invoiceLine &lt;&gt; null and
			self.invoiceLine.invoice &lt;&gt; null and
			//self.invoiceLine.invoice.status = CM_Invoice.INVOICE_POSTED
			self.invoiceLine.invoice.isPostedOrReversal	//04 Sep 2017	NDL	TFS 6759	
			then
			value := glCode;
		else
			if self.service = null or 
			   self.service.genLCode = null then
				value := null;
			else
				value := self.service.genLCode.code;
			endif;
		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="isTaxExempt" id="83cb806e-0eab-489f-a343-d875db2b5a54">
        <source>isTaxExempt(_workOrder : CM_WorkOrder) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 May 2019	jlger1	Initial creation refactored part of TFS 44550

*/

vars
	theInvoice : CM_Invoice;
	debtor: CM_Debtor;
	invalid : Boolean;
	voyage  : CM_Voyage;
begin
	theInvoice := self.invoiceLine.invoice;
	on Exception do app.handleDeletedObject(exception, theInvoice, invalid);
	if theInvoice &lt;&gt; null then
		voyage := theInvoice.myVoyage;
	endif;
	
	if theInvoice = null or  invalid then
		debtor := self.invoiceLine.debtor;
	else
		debtor := theInvoice.debtor;
	endif;
	
	if debtor &lt;&gt; null and debtor.isZeroRatedTax then		// 19/10/17 MAP TFS7357
		return true;
	endif;
	
	//07 May 2019	NDL	TFS 44651
	if self.invoiceLine.invoiceLineDesc.taxAlwaysCharged then
		return false;
	endif;
	
	//
	/*if self.invoiceLine.invoiceLineDesc.taxAlwaysCharged then
		return false;
	endif;
	*/
	
	if voyage &lt;&gt; null then
		if voyage.isTaxExempt(self.invoiceLine) then
			return true;
		endif;
	endif;
	
	if _workOrder &lt;&gt; null then	
		if _workOrder.isTaxExempt() then
			return true;
		endif;
	
	endif;
	
	return false;
epilog

end;</source>
        <Parameter name="_workOrder" type="CM_WorkOrder"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isVolumeBased" id="21265d93-51ca-4da7-b571-22e9d76d85c9">
        <source>isVolumeBased(): Boolean;
/*
Purpose:			

Date		Who		Reason
01 May 2023	navab1 TFS BUG 57729
*/

vars

begin
	// ### TFS BUG 61269 21NOV2023 NAVAB1
	if self.contractVBRangeFrom &lt;&gt; 0
	or self.contractVBRangeTo &lt;&gt; 0 then
		return true;
	endif;
	
	if self.contractVBAccumulatedWeight &lt;&gt; 0
	or self.contractVBAccumulatedTEU &lt;&gt; 0
	or self.contractVBAccumulatedVolume &lt;&gt; 0
	or self.contractVBAccumulatedQuantity &lt;&gt; 0 then
		return true;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadPropertyCol" id="60668a6e-0dbb-42d4-89d3-9439500779a4">
        <source>loadPropertyCol(t : Table io);
// 12/07/2017	cnwma1	TFS #4702:JMT - Invoice Line Date/Time not being displayed in local timezone
//20 Feb 2018	jlgmd1	TFS 36954 SNO - Error in SCT2 Rate Table  (Swap $CM_RateEntry.decimalPlaces for terminal config)
vars
	q,r : Real;
	str : String;

begin

	q := self.invoiceLine.quantity;
	r := self.rate;

	str := self.sequenceNum.String &amp; Tab &amp;
			q.asStringJMTWithPrecision($CM_InvoiceMoney.decimalPlaces, false) &amp; Tab &amp;
			self.units &amp; Tab &amp;
			//r.asStringJMTWithPrecision($CM_RateEntry) &amp; Tab;
			//th2 PAR 14632
			//r.asStringJMTWithPrecision($CM_RateEntry.decimalPlaces, true) &amp; Tab;
			r.asStringJMTWithPrecision(self.getRateEntryDecimalPlaces, true) &amp; Tab;	// TFS 36954 MPD 20 Feb 2018

	if invoiceLine.status = CM_InvoiceLine.STATUS_VOIDED then
		str := str &amp; (q*0).asStringJMTWithPrecision($CM_InvoiceMoney.decimalPlaces, false) &amp; Tab &amp;
				"Void" &amp; Tab;
	else
		str := str &amp; self.total.asStringJMTWithPrecision($CM_InvoiceMoney.decimalPlaces, false) &amp; Tab &amp;
			"Normal" &amp; Tab;
	endif;
	str := str &amp; "" &amp; Tab;
	str := str &amp; invoiceLine.debtor.name &amp; Tab;
	if self.service &lt;&gt; null then			// 36965 handle null service
		str := str &amp; service.name &amp; Tab;
	else
		str := str &amp; "" &amp; Tab;
	endif;
	str := str &amp; "" &amp; Tab;
	//str := str &amp; invoiceLine.getChargeTime.String &amp; Tab;   	//12.7.2017 cnwma1 TFS #4702
	str := str &amp; invoiceLine.getChargeTimeLocalTZ.String &amp; Tab;        //12.7.2017 cnwma1 TFS #4702
	str := str &amp; invoiceLine.remarks &amp; Tab;
	str := str &amp; invoiceLine.invoice.sequenceNum.String &amp; Tab;

	t.column := 1;
	t.text := str;


end;</source>
        <Parameter name="t" type="Table" usage="io"/>
    </JadeMethod>
    <JadeMethod name="overrideRate" id="49e24710-3886-48dc-8f61-04f2959d7dd1">
        <updating/>
        <source>overrideRate(newRate: Real) updating;
vars
	auditLine : Boolean;
	props : PropertyNDict;
	prop : Property;
begin
	// ### TFS BUG 62926 13MAR2024 NAVAB1
	create props transient;
	prop := CM_Charge::overridden;
	props.add(prop);
	prop := CM_Charge::rate;
	props.add(prop);
	
	if self.status = VOID
	or self.invoiceLine.invoice.isPostedOrReversal	//04 Sep 2017	NDL	TFS 6759	
	then
		if app.niceName &lt;&gt; self.OVERRIDEAPPNAME  then // this is added so that when the corruption script is run it will allow us to change the total AKB2003OCT
			return;
		endif;
	endif;

	app.myUtilityUA.myUpdateAuditAgent.audUpdateGenericKnownProperty(self,props, true);	// ### TFS BUG 62926 13MAR2024 NAVAB1
	if not overridden then
		self.overridden := true;
		auditLine := true; // ### TFS 55435 25NOV2022 NAVAB1
		 // ### TFS 55435 25NOV2022 NAVAB1 move to bottom so seperate audit     self.invoiceLine.incrementOverridenChargeCount();
	endif;

	self.doAuditRateHistoryCreate(newRate,self.rate,false,CM_AuditLineRateOverride.Status_Update);
	self.rate := newRate;
	self.isTotalSetExplicitly:=false; //epr TFS 42084 8/12/18
	 app.myUtilityUA.myUpdateAuditAgent.audUpdateGenericKnownProperty(self,props, false);	// ### TFS BUG 62926 13MAR2024 NAVAB1
	
	
	
	if auditLine then  // ### TFS 55435 25NOV2022 NAVAB1
		// ### TFS BUG 62926 13MAR2024 NAVAB1
		props.clear();
		prop := CM_InvoiceLine::overriddenChargeCount;
		props.add(prop);
	
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGenericKnownProperty(self.invoiceLine,props, true);	// ### TFS BUG 62926 13MAR2024 NAVAB1
		self.invoiceLine.incrementOverridenChargeCount(); // ### TFS 55435 25NOV2022 NAVAB1
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGenericKnownProperty(self.invoiceLine,props, false);	// ### TFS BUG 62926 13MAR2024 NAVAB1
	endif; // ### TFS 55435 25NOV2022 NAVAB1
	
epilog
	delete props; // ### TFS BUG 62926 13MAR2024 NAVAB1
end;</source>
        <Parameter name="newRate" type="Real"/>
    </JadeMethod>
    <JadeMethod name="overrideTax" id="3f824d01-4ffd-4424-99c2-7ba63c485558">
        <updating/>
        <source>overrideTax(_newTaxCode:CM_TaxCode) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 October 2022	navmv20	ChangeRequest 55005: EUP - Invoicing - Invoice Line TAX Maintenance
05 May 2023 navmv20 CR 57229 Task 57697: Jade - Include Charge Changes on Invoice Line Audit

*/

vars
	overriddenAgain : Boolean;
	auditLine : Boolean;
	invLineAuditAgent,	//05/05/2023 navmv20 CR 57229 Task 57697
	chargeAuditAgent	: CM_UpdateTransactionAuditAgent; //05/05/2023 navmv20 CR 57229 Task 57697
	props : PropertyNDict;
	prop : Property;
begin

	if self.status = VOID
	or self.invoiceLine.invoice.isPostedOrReversal	
	then
		if app.niceName &lt;&gt; self.OVERRIDEAPPNAME  then
			return;
		endif;
	endif;
	
	create invLineAuditAgent transient; //05/05/2023 navmv20 CR 57229 Task 57697
	create chargeAuditAgent transient; 	//05/05/2023 navmv20 CR 57229 Task 57697
	if self.myOverrideTaxCode &lt;&gt; null // ### TFS 55435 25NOV2022 NAVAB1
	and self.myOverrideTaxCode &lt;&gt; _newTaxCode then // ### TFS 55435 25NOV2022 NAVAB1
		overriddenAgain := true; // ### TFS 55435 25NOV2022 NAVAB1
	endif;
	
	//05/05/2023 navmv20 CR 57229 Task 57697 - START
	// ### TFS BUG 62926 13MAR2024 NAVAB1
	create props transient;
	prop := CM_Charge::overriddenTax;
	props.add(prop);
	prop := CM_Charge::overriddenTaxCount;
	props.add(prop);
	
	chargeAuditAgent.audUpdateGenericKnownProperty(self,props,true);// ### TFS BUG 62926 13MAR2024 NAVAB1

	//05/05/2023 navmv20 CR 57229 Task 57697 - END
	
	if not self.overriddenTax 
	or overriddenAgain then // ### TFS 55435 25NOV2022 NAVAB1
		self.overriddenTax := true;
		self.overriddenTaxCount:=self.overriddenTaxCount+1;
		
		auditLine := true;  // ### TFS 55435 25NOV2022 NAVAB1
	endif;
	
	self.myOverrideTaxCode:=_newTaxCode;

	chargeAuditAgent.audUpdateGenericKnownProperty(self,props,false);// ### TFS BUG 62926 13MAR2024 NAVAB1
	
	if auditLine then // ### TFS 55435 25NOV2022 NAVAB1
		props.clear();
		prop := CM_InvoiceLine::overriddenTaxCount;
		props.add(prop);
		invLineAuditAgent.audUpdateGenericKnownProperty(self.invoiceLine,props,true); // ### TFS BUG 62926 13MAR2024 NAVAB1
		self.invoiceLine.incrementOverridenTaxCount(); // ### TFS 55435 25NOV2022 NAVAB1
		invLineAuditAgent.audUpdateGenericKnownProperty(self.invoiceLine,props,false); // ### TFS BUG 62926 13MAR2024 NAVAB1
	endif; // ### TFS 55435 25NOV2022 NAVAB1
epilog
	delete invLineAuditAgent; //05/05/2023 navmv20 CR 57229 Task 57697
	delete chargeAuditAgent;  //05/05/2023 navmv20 CR 57229 Task 57697
	delete props; // ### TFS BUG 62926 13MAR2024 NAVAB1
end;</source>
        <Parameter name="_newTaxCode" type="CM_TaxCode"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="a9ac5ea2-fad2-4f60-b2e9-e0ca0c0501e9">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	pxyMe : SelfType;
	completedOK		: Boolean;
begin
	pxyMe := inheritMethod();

	pxyMe.service := self.service;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyMe;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyMe;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="releaseRate" id="f80546f8-550b-4e97-81f7-8d682c58ad6e">
        <updating/>
        <source>releaseRate() updating;
//
// Purpose:
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 18 Oct 2024	navlw1		JIRA-33107: Invoice Logging Use Levels
vars
	oldRate, newRate : Real;
	auditLine : Boolean;
	props : PropertyNDict;
	prop : Property;
begin
	create props transient;
	prop := CM_Charge::overridden;
	props.add(prop);
	prop := CM_Charge::rate;
	props.add(prop);

	if self.status = VOID
	or self.invoiceLine.invoice.isPostedOrReversal	//04 Sep 2017	NDL	TFS 6759	
	then
		return;
	endif;

	app.myUtilityUA.myUpdateAuditAgent.audUpdateGenericKnownProperty(self,props, true);	// ### TFS BUG 62926 13MAR2024 NAVAB1
	if self.overridden then
		self.overridden := false;
		auditLine := true; // ### TFS 55435 25NOV2022 NAVAB1
	endif;
	oldRate := self.rate;
	// TFS 42084
	app.invLog(method.qualifiedName &amp; " Calling CM_Charge.evaluateRate", LogINFO.String);

	self.evaluateRate();
	
	app.myUtilityUA.myUpdateAuditAgent.audUpdateGenericKnownProperty(self,props, false);	// ### TFS BUG 62926 13MAR2024 NAVAB1

	newRate := self.rate;
	self.doAuditRateHistoryCreate(newRate,oldRate,false,CM_AuditLineRateOverride.Status_Reset);
	
	if auditLine then // ### TFS 55435 25NOV2022 NAVAB1
		// ### TFS BUG 62926 13MAR2024 NAVAB1
		props.clear();
		prop := CM_InvoiceLine::overriddenChargeCount;
		props.add(prop);
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGenericKnownProperty(self.invoiceLine,props, true);	// ### TFS BUG 62926 13MAR2024 NAVAB1
		self.invoiceLine.decrementOverridenChargeCount; // ### TFS 55435 25NOV2022 NAVAB1
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGenericKnownProperty(self.invoiceLine,props, false);	// ### TFS BUG 62926 13MAR2024 NAVAB1
	
	endif;
epilog
	delete props; // ### TFS BUG 62926 13MAR2024 NAVAB1

end;</source>
    </JadeMethod>
    <JadeMethod name="releaseTax" id="6ffdad04-9936-49a5-a8e9-010069551284">
        <updating/>
        <source>releaseTax() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 October 2022	navmv20	ChangeRequest 55005: EUP - Invoicing - Invoice Line TAX Maintenance
05 May 2023 navmv20 CR 57229 Task 57697: Jade - Include Charge Changes on Invoice Line Audit
*/

vars
	oldTaxCode,
	newTaxCode : CM_TaxCode;
	auditLine : Boolean;
	invLineAuditAgent,	//05/05/2023 navmv20 CR 57229 Task 57697
	chargeAuditAgent	: CM_UpdateTransactionAuditAgent; //05/05/2023 navmv20 CR 57229 Task 57697
	props : PropertyNDict;
	prop : Property;
begin
	if self.status = VOID
	or self.invoiceLine.invoice.isPostedOrReversal	
	then
		return;
	endif;
	
	//05/05/2023 navmv20 CR 57229 Task 57697 - START
	create invLineAuditAgent transient;
	create chargeAuditAgent transient;
	
	// ### TFS BUG 62926 13MAR2024 NAVAB1
	create props transient;
	prop := CM_Charge::overriddenTax;
	props.add(prop);
	prop := CM_Charge::overriddenTaxCount;
	props.add(prop);
	chargeAuditAgent.audUpdateGenericKnownProperty(self,props,true);
	
	//05/05/2023 navmv20 CR 57229 Task 57697 - END
	if self.overriddenTax then
		self.overriddenTax := false;
		self.overriddenTaxCount := 0;
		self.myOverrideTaxCode := null; // ### TFS 55435 25NOV2022 NAVAB1
		auditLine := true;  // ### TFS 55435 25NOV2022 NAVAB1 moved to bottom so a seperate audit on the line   self.invoiceLine.decrementOverridenTaxCount(); // ### TFS 55435 25NOV2022 NAVAB1
	endif;
	
	chargeAuditAgent.audUpdateGenericKnownProperty(self,props,false); // ### TFS BUG 62926 13MAR2024 NAVAB1

	if auditLine then // ### TFS 55435 25NOV2022 NAVAB1
	// ### TFS BUG 62926 13MAR2024 NAVAB1
		props.clear();
		prop := CM_InvoiceLine::overriddenTaxCount;
		props.add(prop);
		invLineAuditAgent.audUpdateGenericKnownProperty(self.invoiceLine,props,true); // ### TFS BUG 62926 13MAR2024 NAVAB1
		self.invoiceLine.decrementOverridenTaxCount(); // ### TFS 55435 25NOV2022 NAVAB1
		invLineAuditAgent.audUpdateGenericKnownProperty(self.invoiceLine,props,false); // ### TFS BUG 62926 13MAR2024 NAVAB1
	endif; // ### TFS 55435 25NOV2022 NAVAB1
	
epilog
	delete invLineAuditAgent; //05/05/2023 navmv20 CR 57229 Task 57697
	delete chargeAuditAgent;  //05/05/2023 navmv20 CR 57229 Task 57697
	delete props; // ### TFS BUG 62926 13MAR2024 NAVAB1

end;</source>
    </JadeMethod>
    <JadeMethod name="resetTotal" id="64e2a868-7399-4b4a-83a2-49ee1a82e3c9">
        <updating/>
        <source>resetTotal() updating;
/*
Purpose:			

Date		Who		Reason
22 June 2023	navab1	 BUG 58785
*/

vars
	audit : CM_UpdateTransactionAuditAgent;
begin
	create audit transient;
	audit.audUpdateGeneric(self, true);
	 self.total := self.rate * self.invoiceLine.quantity;
	audit.audUpdateGeneric(self, false);
epilog
	delete audit;
end;</source>
    </JadeMethod>
    <JadeMethod name="restore" id="b2f22504-5682-403e-bb18-e0891bfd8822">
        <updating/>
        <source>restore() updating;
//
// Purpose:
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 18 Oct 2024	navlw1		JIRA-33107: Invoice Logging Use Levels
begin
	if overridden then
		invoiceLine.incrementOverridenChargeCount;
	endif;

	status := NORMAL;
	invoiceLine := voidedFrominvoiceLine;
	voidedFrominvoiceLine := null;
	 // TFS 42084
	app.invLog(method.qualifiedName &amp; " Calling CM_Charge.evaluateRate", LogINFO.String);
	evaluateRate();
end;</source>
    </JadeMethod>
