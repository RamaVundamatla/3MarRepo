    <JadeMethod name="doBaseFormCancel" id="1aa57b6a-8f64-48e1-a406-703e8b24067c">
        <updating/>
        <source>doBaseFormCancel() updating, protected;
//--------------------------------------------------
// Created:	05 April 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.setToViewMode(); 
	
	delete self.myProxyMovement;
	self.myCurrentMovement := null;
				
	if self.cmbMovements.listObject &lt;&gt; null then
		self.setMyCurrentMovement(self.cmbMovements.listObject.HMS_VoyageMovement);
	else
		self.setMyCurrentMovement(null);	
	endif;
	
end;</source>
