<Class name="WS_WorkOrderDetailResponse" id="21160a72-0d33-400a-9864-ac54644b08b4">
    <superclass name="WS_Response"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="allWorkOrderDetails" id="9ecaea83-d3f7-4936-8674-227865d6ae4f">
        <memberTypeInverse/>
        <type name="WS_WorkOrderDetailArray"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="createWsDetails" id="3b59e18b-9632-49e3-932b-12b1ad974d2e">
        <source>createWsDetails(_workOrderDtl : CM_WorkOrderDtl ;_context : Integer) : WS_WorkOrderDetail;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 Oct 2019 cnwma1	Bug 46917: PEL1 - [Top Urgent] - No WO Additional Cargo appears on The Web Portal
31 May 2021 navma1  ChangeRequest 51002: MTN - Web Portal Cargo Work Orders
*/

vars
	wsDetail        : WS_WorkOrderDetail;
begin
	
	if _workOrderDtl.isKindOf(CM_WorkOrderVoyageDtl) then
		
		if _workOrderDtl.isKindOf(CM_WodCargoRequest) then			                 //01			
			create wsDetail as WS_WorkOrderCargoRequest transient;
		elseif _workOrderDtl.isKindOf(CM_WodExtension) then                          //02
			create wsDetail as WS_WorkOrderExtension transient;	
		elseif _workOrderDtl.isKindOf(CM_WodHMSRequestCancel) then                   //03
			create wsDetail as WS_WorkOrderCancelRequest transient;
		elseif _workOrderDtl.isKindOf(CM_WodMarineServicesDepart) then  		     //04 
			create wsDetail as WS_WorkOrderDMSR transient;
		elseif _workOrderDtl.isKindOf(CM_WodMarineServicesInitial) then		 	     //05
			create wsDetail as WS_WorkOrderIMSR transient;	
		elseif _workOrderDtl.isKindOf(CM_WodPermitRequest) then                      //06
			if _context = 1 then
				create wsDetail as WS_WorkOrderPermitRequest transient;
			else
				if _workOrderDtl.CM_WodPermitRequest.isAdditionalCargo then		
					create wsDetail as WS_WorkOrderPermitRequest transient;	
				endif;		
			endif;	
		elseif _workOrderDtl.isKindOf(CM_WodShiftMovement) then					     //07
			create wsDetail as WS_WorkOrderShiftMovement transient;
		elseif _workOrderDtl.isKindOf(CM_WodTimeChange) then
			create wsDetail as WS_WorkOrderTimeChange transient;
		elseif _workOrderDtl.isKindOf(CM_WodVoyageCargoRequest) then                 //08
			if _context = 1 then
				create wsDetail as WS_WorkOrderVoyageCargoRequest transient;
			else
				create wsDetail as WS_WorkOrderCargoRequest transient;
			endif;
		elseif _workOrderDtl.isKindOf(CM_WodVoyageRequest) then                      //09
			create wsDetail as WS_WorkOrderVoyageRequest transient;	  
		elseif _workOrderDtl.isKindOf(CM_WodWaterRequest) then					     //10
			create wsDetail as WS_WorkOrderWaterRequest transient;		
		endif;
		
	elseif _workOrderDtl.isKindOf(CM_WorkOrderTIDtl) then
		
		if _workOrderDtl.isKindOf(CM_WodExportReturn) then             				 //01
			create wsDetail as WS_WorkOrderCancelLoad transient;
		elseif _workOrderDtl.isKindOf(CM_WodMove) then                  			 //02
			create wsDetail as WS_WorkOrderMove transient;
		elseif _workOrderDtl.isKindOf(CM_WodNullVoyage) then          			     //03
			create wsDetail as WS_WorkOrderChangeVoyage transient;
		elseif _workOrderDtl.isKindOf(CM_WodReceive) then	           				 //04
			create wsDetail as WS_WorkOrderReceive transient;
		elseif _workOrderDtl.isKindOf(CM_WodRelease) then	           				 //05
			create wsDetail as WS_WorkOrderRelease transient;
		elseif _workOrderDtl.isKindOf(CM_WodReleaseExtension) then	   				 //06
			create wsDetail as WS_WorkOrderReleaseExt transient;
		elseif _workOrderDtl.isKindOf(CM_WodToDo) then				  				 //07
			create wsDetail as WS_WorkOrderToDo transient;
		elseif _workOrderDtl.isKindOf(CM_WodUnpack) then				  		 	 //08  //31.05.2021 navma1 #51002
			create wsDetail as WS_WorkOrderUnPack transient;
		elseif _workOrderDtl.isKindOf(CM_WodPack) then				  		 	 	 //09  //10.09.2021 navma1 #51002
			create wsDetail as WS_WorkOrderPack transient;
		endif;
		
	endif;
	
	//epr TFS 48179 30/1/20 
	if wsDetail &lt;&gt;  null then
		wsDetail.setProxyFromObject(_workOrderDtl);
		self.allWorkOrderDetails.add(wsDetail);
	
	endif;
	
	return wsDetail;
epilog

end;</source>
        <Parameter name="_workOrderDtl" type="CM_WorkOrderDtl"/>
        <Parameter name="_context" type="Integer"/>
        <ReturnType type="WS_WorkOrderDetail"/>
    </JadeMethod>
    <JadeMethod name="createWsWorkOrderDtl" id="efc1293d-052f-460d-ace9-3f199f98cf31">
        <source>createWsWorkOrderDtl(_workOrder : CM_WorkOrder io ;_request :WS_WorkOrderDetailQueryRequest ;_context : Integer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Oct 2019	cnwma1	Bug 46917: PEL1 - [Top Urgent] - No WO Additional Cargo appears on The Web Portal
19 Nov 2019 cnwma1	Bug 47571: JMT - Web Portal - Voyages Edit Cargo Request no longer displays previously entered details
*/

vars
	workOrderDtl    : CM_WorkOrderDtl;
	wsDetail        : WS_WorkOrderDetail;
	wodCargoRequest : CM_WodCargoRequest;
begin
	foreach workOrderDtl in _workOrder.allWoDtls  discreteLock do
	
		if _context &lt;&gt; 1 then
			//epr TFS 48179 29/1/2020
			if not workOrderDtl.canAccessOnWeb then
				continue;
			endif;
		endif;
		
		if  workOrderDtl.isKindOf(CM_WodVoyageCargoRequest) and _context &lt;&gt; 1 then   //19.11.2019 cnwma1 #47571
			foreach wodCargoRequest in  workOrderDtl.CM_WodVoyageCargoRequest.allCargoDetails  discreteLock do
				if not  wodCargoRequest.canAccessOnWeb() then
					continue;
				endif;
				create wsDetail as WS_WorkOrderCargoRequest transient;
				wsDetail.setProxyFromObject(wodCargoRequest);
				self.allWorkOrderDetails.add(wsDetail);
			
			endforeach;
		else
			self.createWsDetails(workOrderDtl,_context);	
			
		endif;
		
	endforeach;
	
epilog

end;</source>
        <Parameter name="_workOrder" type="CM_WorkOrder" usage="io"/>
        <Parameter name="_request" type="WS_WorkOrderDetailQueryRequest"/>
        <Parameter name="_context" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="delete" id="a4091676-3c1a-4c74-9bc9-91ac51a4fd8d">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 May 2018	jlger1	Initial creation 38520

*/

vars

begin
	self.allWorkOrderDetails.purge;
epilog

end;</source>
    </JadeMethod>
</Class>
