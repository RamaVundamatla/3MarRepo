    <JadeMethod name="btnColorSave_click" id="1bea9313-8a53-4d8f-bdd5-35a3d59aaa35">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnColorSave_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:		05 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	self.xmlColourBay := self.clrBay.backColor;
	self.xmlColourCell := self.clrCell.backColor;
	self.xmlColourRow := self.clrRow.backColor;
	
	self.doQuery();
end;</source>
