    <JadeMethod name="getMeasurementStringForAttrib" id="9443fa60-eefd-428b-b6d8-d19f3d1c1fc7">
        <source>getMeasurementStringForAttrib(_attrName: String; _measureType: String; _short: Boolean): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
/* Changes

Date		Name	TFS#		Description
============================================================================
23/04/2014	cnwdap1	PAR #33005 	CCMS SFW 1381 Imperial measurements for EDI user defined layouts. Initial creation 
14 Aug 2017	cnwma1	TFS #5695	STWO - Re-Calculate Volumes on Forms and EDI
12 Jun 2019	jlgka1	TFS 44416 	PNL Loading Default Cargo Type Settings via EDI
============================================================================*/
vars
	cargoType : CM_CargoType;
	product	  : CM_Product;
	calcVolume : Decimal[16,4];
begin
	if _attrName = ETRow_TotalWeight then
		return app.convertMeasurementForDisplay(_measureType, self.weight);
	elseif _attrName = ETRow_TareWeight then	//15 Nov 2016	NDL	TFS 2959 / 2420
		return app.convertMeasurementForDisplay(_measureType, self.tareWeight);
	elseif _attrName = ETRow_CargoWeight then	//15 Nov 2016	NDL	TFS 2959 / 2420
		return app.convertMeasurementForDisplay(_measureType, self.cargoWeight);
	elseif _attrName = ETRow_OverHeight and self.overHeight = NULL_INTEGER then
		return null;
	elseif _attrName = ETRow_OverLengthFront and self.overLengthFront = NULL_INTEGER then
		return null;
	elseif _attrName = ETRow_OverLengthBack and self.overLengthBack = NULL_INTEGER then
		return null;
	elseif _attrName = ETRow_OverWidthLeft and self.overWidthLeft = NULL_INTEGER then
		return null;
	elseif _attrName = ETRow_OverWidthRight and self.overWidthRight = NULL_INTEGER then
		return null;
	
	// 14.8.2017 cnwma1 TFS #5695
	elseif _attrName = ETRow_Volume then
		if self.volume = NULL_VOLUME then
			cargoType := self.getCargoTypeObj();
			if cargoType &lt;&gt; null then
				product := cargoType.allProducts[null,self.product];
			else
				//jlgka1 TFS 44416 --&gt;
				product := self.getProduct(self.operatorCode, self.product);  // 14.8.2017 cnwma1 TFS #5695				
				//jlgka1 TFS 44416 &lt;--
			endif;
			
			if cargoType&lt;&gt; null 
			and (cargoType.isBreakBulk or cargoType.isBulk) 
			and cargoType.allowAutoVolumeCalc then
				if product &lt;&gt; null and not product.autoVolumeCalculate then
					if  self.width &gt; 0 or   self.length &gt; 0 or  self.height &gt; 0 then
						calcVolume := (self.height/100 * self.width/100 * self.length/100) * self.totalQuantity.max(1) * self.quantity.max(1);
						return app.convertMeasurementForDisplay(_measureType, calcVolume);
					endif;
				endif;
			endif;
		endif;
		
		return app.convertMeasurementForDisplay(_measureType, self.volume);
	// 14.8.2017 cnwma1 TFS #5695
	endif;
	
	return inheritMethod(_attrName, _measureType, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_measureType" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
