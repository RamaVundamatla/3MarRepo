    <JadeMethod name="buildBerthArrayHotspots" id="b4c8d7dc-d3ba-47d7-8afc-882dbccec622">
        <updating/>
        <source>buildBerthArrayHotspots()updating, protected;

vars
	harbour : HMS_Harbour;
	wharf : HMS_Wharf;
	berth : HMS_Berth;
begin
	self.picBackground.clearGraphics();
	harbour := self.myTerminal.myHarbour;
	if harbour = null then
		return;
	endif;
	// setup the hotspots - note that this kludge should be replaced when the generic hotspot/berth/map editor is built
	foreach wharf in harbour.allWharves do
		if wharf.isLogicalWharf = false then
			foreach berth in wharf.allBerths do
				if berth.description.Integer 		= 1 then
					buildHotspot(berth,433,235);
				elseif berth.description.Integer 	= 2 then
					buildHotspot(berth,410,240);
				elseif berth.description.Integer 	= 3 then
					buildHotspot(berth,387,245);
				elseif berth.description.Integer 	= 4 then					
					buildHotspot(berth,361,248);	
				elseif berth.description.Integer 	= 5 then					
					buildHotspot(berth,335,252);
				elseif berth.description.Integer 	= 6 then					
					buildHotspot(berth,308,253);
				elseif berth.description.Integer 	= 7 then					
					buildHotspot(berth,285,249);
				elseif berth.description.Integer 	= 8 then					
					buildHotspot(berth,260,246);
				elseif berth.description.Integer 	= 9 then					
					buildHotspot(berth,235,241);
				elseif berth.description.Integer 	= 10 then					
					buildHotspot(berth,208,237);
				elseif berth.description.Integer 	= 11 then					
					buildHotspot(berth,179,232);
				elseif berth.description.Integer 	= 16 then					
					buildHotspot(berth,89,220);
				elseif berth.description.Integer 	= 23 then					
					buildHotspot(berth,144,183);
				elseif berth.description.Integer 	= 24 then					
					buildHotspot(berth,117,178);
				elseif berth.description.Integer 	= 25 then					
					buildHotspot(berth,90,174);					
				endif;
			endforeach;
		endif;
	endforeach;	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="buildHotspot" id="2654c907-3ce2-4266-b440-e28f41eeb3eb">
        <updating/>
        <source>buildHotspot(pBerth:HMS_Berth;pX,pY:Real)updating, protected;

vars
	p : Picture;
begin
	currentIndex := currentIndex + 1;
	p := defHotspot.loadControl(currentIndex).Picture;
	p.userObject := pBerth;
	p.visible := true;
	p.move(pX,pY,20,20);
end;</source>
        <access>protected</access>
        <Parameter name="pBerth" type="HMS_Berth"/>
        <Parameter name="pX" type="Real"/>
        <Parameter name="pY" type="Real"/>
    </JadeMethod>
