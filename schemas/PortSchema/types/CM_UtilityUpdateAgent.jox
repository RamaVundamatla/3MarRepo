    <JadeMethod name="utlUpdateMoveMenuItem" id="c0482b61-55bc-4144-8d2b-8ee3b092735e">
        <source>utlUpdateMoveMenuItem(	_oldParent:CM_MenuEntity input;
						_newParent:CM_MenuEntity input;
						_pickupEntity:CM_MenuEntity input;
						_hoverObject:CM_MenuEntity;
						_isUnopenedFolder:Boolean;
						_passport:CM_Passport input);
// --------------------------------------------------------------------------------
// Created:		27 October 2005 by cnwdad1
//
// Purpose:		Moves a Menu Entity object from one parent entity to another.
//
// Parameters:	_oldParent - A reference to the Menu entity's old parent entity.
//				_newParent - A reference to the Menu entity's new parent entity.
//				_pickupEntity - A reference to the Menu Entity that is being moved.
//				_hoverObject - A reference to the Menu entity which the "pickup"
//					entity is being inserted over (i.e. the hover object will move
//					down one slot).
//				_isUnopenedFolder - True if, on the GUI where the user is dragging
//					the Menu entity being moved), the menu tree is expanded.
//				_passport - A reference to the user passport thingy.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
//	cancelSave:Boolean;
//	realMenuUserItem:CM_MenuUserItem;
//	expectedEdition:Integer;
	arrayPointer	: Integer;
	
begin
	self.initialiseActivity();

//	_theProxyMenuItem.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

//	_theProxyMenuItem.pxyGetRealObjectAndEdition(realMenuUserItem, expectedEdition);
	
	if _oldParent = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_MenuUserItem.name, "Old Parent", null);
		return;
	endif;
	
	if _newParent = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_MenuUserItem.name, "New Parent", null);
		return;
	endif;
	
	_pickupEntity.validateNewParent( _newParent );	//06 Nov 2015	NDL	Par 36718
	
//	app.myValUA.valMenuUserItem(realMenuUserItem, pProxyMenuUserItem);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(_oldParent);
	exclusiveLock(_newParent);

//	if _passport.noErrors and realMenuUserItem.edition &lt;&gt; expectedEdition then
//		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'MenuUserItem', null, null);
//		return;
//	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(_oldParent, true);
		self.myUpdateAuditAgent.audUpdateGeneric(_newParent, true);
	endif;
	
	if _passport.noErrors then
		_oldParent.allChildren.remove(_pickupEntity);
		
		//get the position of the hoverobject child in the parent.allChildren array
		if (_hoverObject.isKindOf(CM_MenuRoot))
		or (_hoverObject.isKindOf(CM_MenuUserHdr)
		and (not _isUnopenedFolder))
		then
			arrayPointer	:=	1;	
		else
			foreach arrayPointer in 1 to _newParent.allChildren.size do
				if _newParent.allChildren[arrayPointer] = _hoverObject then
					break;
				endif;
			endforeach;
		endif;	
		
		//in either of these following situation the user has dropped the detail onto a folder or root, so make idx := 1
		if _newParent.isKindOf(CM_MenuRoot) then
			_pickupEntity.CM_MenuUserItem.setLevel(2);
		elseif _newParent.isKindOf(CM_MenuUserHdr) then
			_pickupEntity.CM_MenuUserItem.setLevel(_newParent.getLevel() + 1);
		endif;
		
		_newParent.allChildren.insert(arrayPointer, _pickupEntity);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(_oldParent, false);
		self.myUpdateAuditAgent.audUpdateGeneric(_newParent, false);
	endif;
end;</source>
        <Parameter name="_oldParent" type="CM_MenuEntity" usage="input"/>
        <Parameter name="_newParent" type="CM_MenuEntity" usage="input"/>
        <Parameter name="_pickupEntity" type="CM_MenuEntity" usage="input"/>
        <Parameter name="_hoverObject" type="CM_MenuEntity"/>
        <Parameter name="_isUnopenedFolder" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateMoveTIUndo" id="4d8df694-8487-4926-9668-372e8de4184c">
        <source>utlUpdateMoveTIUndo(control : CMIF_MoveController input; _passport : CM_Passport input);
/*
 ------------------------------------------------------------------------
Created:			28 February 2002 by cnwdwq1
Purpose:			Performs an UNDO move
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
12 Jul 2022		navsrk20		Bug 53905: EUP - Planning issues for Cargo Groups in Voyage Operations screen
09/11/2022		navkc1			Bug 55382: MTN - Cargo Group Details recalculated after each change to TI when bulk editing
---------------------------------------------------------------------------
*/
vars
	ed				: Integer;
	invalidObject	: Boolean;
	aRequest	: CM_Request;
	linkedRequest : CM_Request;
	aWLE		: CM_WorkListEntry;
	aFM			: CM_FutureMove;
	rtQueueEntry: CM_RTQueueEntry;
	tiSet		: CM_TISet;
	aFQM		: CM_FutureMoveQueued;
	cargoGroupSiteTrxAction :  CMIF_TrxActionCargoGroup;	//12.07.2022 navsrk20 TFS 53905
	
begin

	self.initialiseActivity();
	
	//07 Apr 2011	NDL	Par 27273
	if control.myTrackedItem &lt;&gt; null then
		exclusiveLock(control.myTrackedItem);
	endif;

	// TFS 2521 Aug 2016 something is deleting the WLE from ship ops Unplan All
	on Exception do app.handleDeletedObject( exception, aWLE, invalidObject );
	aWLE := control.myWorkListEntry;
	if aWLE &lt;&gt; null then
		ed := aWLE.edition;
	endif;
	if invalidObject then
		aWLE := null;
		invalidObject := false;
	endif;
	
	// if we are unplanning then reset the sequenced flag on the slot request
	if control.moveMode = PLANNING_MODE then
		if aWLE &lt;&gt; null then
			aRequest := aWLE.myRequest;
			if CM_SlotRequest.hasInstance(aRequest) or CM_VoyageRequest.hasInstance(aRequest) then
				aRequest.setSequenced(false);
				aWLE.setLocations(aWLE.locationSource,null);
				
				// PAR 16346
				if aWLE.myTrackedItem &lt;&gt; null 
				and aWLE.myTrackedItem.isSOB then // PAR 17826
					linkedRequest := aWLE.myTrackedItem.getMatchingDLRSOBSlotRequest(aRequest);
					if linkedRequest &lt;&gt; null then
						linkedRequest.setSequenced(false);
					endif;
				endif;
				
				// Remove any release that has been assigned to the slot PAR 17327
				if aWLE.isBulkRelease() then 
					if not aWLE.isKindOf(CM_VoyageWLE) then // par 29286 cnwrd1 
						aRequest.setMyBulkReleaseReserveDetail(null);
					endif;
					aWLE.setMyTrackedItem(null);
				endif;
			endif;

		elseif control.moveIndex &gt; 0 and
		   	   control.moveIndex &lt;= control.myTrackedItem.allPlannedFutureMoves.size then
			aFM := control.myTrackedItem.allPlannedFutureMoves[control.moveIndex];
			if aFM &lt;&gt; null then
				aWLE := aFM.myWorkListEntry;
				// TFS 2521 Aug 2016 check this WLE as well just in case
				invalidObject := false;
				if aWLE &lt;&gt; null then
					ed := aWLE.edition;
				endif;
				if invalidObject then
					aWLE := null;
				endif;
				if aWLE &lt;&gt; null then
					control.setMyWorkListEntry(aWLE);
					aRequest := aWLE.myRequest;
//	PAR 27749 RORO				if CM_SlotRequest.hasInstance(aRequest) then
//						aRequest.CM_SlotRequest.setSequenced(false);
//					endif;
					aRequest.setSequenced(false);
				endif;
			endif;
		endif;
		
	elseif control.moveMode = QUEUE_MODE then
	
		//25 Mar 2011	NDL - Check for queued moves munted by dev scripts and spurious zaps. 
		if aWLE = null and control.myTrackedItem &lt;&gt; null then
			foreach aFM in control.myTrackedItem.allQueuedFutureMoves where aFM.isFutureMoveQueued do
				aFQM := aFM.CM_FutureMoveQueued;
				if aFQM.allRTQueueEntries.size = 0 then	// has no RTQ entries - probably zapped.
					if aFQM.myTrackedItem.myPrimaryActualLocation = null then
						continue;
					endif;
					if aFQM.myTrackedItem.myPrimaryQueuedLocation = null then
						continue;
					endif;
					if aFQM.myTrackedItem.myPrimaryActualLocation.isKindOf(CM_MachineController) then
						continue;
					endif;
					delete aFQM;
					return;
				endif;
			endforeach;
		endif;
		
		if aWLE &lt;&gt; null then
			rtQueueEntry := aWLE.getMyQueueEntry();
			if rtQueueEntry &lt;&gt; null then
				create tiSet transient;
				rtQueueEntry.getOverstowingTis(tiSet);
				if not tiSet.isEmpty then
					tiSet.copy(control.allOtherTrackedItems);
					control.isOverstowMoveSecondary := true;
				endif;
			endif;
		endif;
	elseif control.moveMode = QUEUE_PLAN_ON_PICKUP then //cnwrd1 par 26734 CCMS 2014 plan on pickup
		if aWLE &lt;&gt; null then
			rtQueueEntry := aWLE.getMyQueueEntry();
			if rtQueueEntry &lt;&gt; null then
				create tiSet transient;
				rtQueueEntry.getOverstowingTis(tiSet);
				if not tiSet.isEmpty then
					tiSet.copy(control.allOtherTrackedItems);
					control.isOverstowMoveSecondary := true;
				endif;
			endif;
		endif;	
		
	endif;
	// ### do the unplan
	control.setIsUndoMove(true);
	control.executeUndoMove(_passport);

	if _passport.hasErrorsOrWarnings 
	and not _passport.warningsAcknowledged 
	and not _passport.warningsIgnored then // AKB2003MAY added or warnings and warningsAcknowledged
		return;
	endif;

	control.executePostUndoMove(_passport);
	
	CMIF_TrxActionCargoGroup@createAction(control.myTrackedItem, null, _passport); //10/11/2022	navkc1	#55382
	
	/*	//10/11/2022	navkc1	#55382 Moved to CMIF_TrxActionCargoGroup@createAction
	//12.07.2022 navsrk20 TFS 53905 Start
	if _passport.noErrors() and control.myTrackedItem &lt;&gt; null and control.myTrackedItem.myCargoGroup &lt;&gt; null then
		create cargoGroupSiteTrxAction transient;
		cargoGroupSiteTrxAction.setMyCargoGroup(control.myTrackedItem.myCargoGroup);
		_passport.addTrxPostAction(cargoGroupSiteTrxAction);
	endif;
	//12.07.2022 navsrk20 TFS 53905 End
	*/	//10/11/2022	navkc1	#55382
epilog
	delete tiSet;
end;</source>
        <Parameter name="control" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateMoveTIsInOrder" id="9dc4f4ec-d1fb-4a06-b0de-4b2fc876fa92">
        <source>utlUpdateMoveTIsInOrder(_tis : CM_TIArray; control : CMIF_MoveController input; _plannedLoc : CM_LocationsController input; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 June 2021	navndl1	Initial creation	TFS 51231 - Essentially a copy of 'utlUpdateMoveTrackedItems' using an Array
														so that the moves are performed in the order requested.

*/

vars
	ti		: CM_TrackedItem;
	isNonCraneVoyageMove : Boolean;								
	dischargeWLE : CM_WorkListEntry;
	useDischargeWleIfPoss : Boolean;
	planControl : CMIF_MoveController;

begin

	self.initialiseActivity();
	isNonCraneVoyageMove := control.isNonCraneVoyageMove;
	
	useDischargeWleIfPoss := (	isNonCraneVoyageMove
								and not control.allOtherWLEs.isEmpty
								and control.myOriginatingForm &lt;&gt; null
								and control.myOriginatingForm.class.name = "SHP_VoyageOpsForm" );
								
	if _plannedLoc &lt;&gt; null then
		create planControl transient;
		planControl.setMoveMode(PLANNING_MODE);
		planControl.setMyToPrimaryLocation( _plannedLoc );	
		planControl.isNonCraneVoyageMove := true; 
		
		foreach ti in _tis do
			planControl.setMyTrackedItem(ti);
			planControl.setMyWorkListEntry( null );
			planControl.setWeight(0);
			planControl.setQuantity(0);
			
			self.utlUpdateMoveTrackedItem(planControl, _passport);
			if _passport.hasErrors then
				break;
			endif;
		endforeach;	
	endif;
	
	if _passport.hasErrors then
		return;
	endif;
	
	foreach ti in _tis do
		control.setMyTrackedItem(ti);
		control.setMyWorkListEntry( null );
		
		if useDischargeWleIfPoss then
			dischargeWLE := control.getWLEForTI( ti );
			control.setMyWorkListEntry( dischargeWLE );
			control.isNonCraneVoyageMove := dischargeWLE = null;
		else
			control.isNonCraneVoyageMove := isNonCraneVoyageMove;
		endif;
		
		control.setWeight(0);
		control.setQuantity(0);
		
		self.utlUpdateMoveTrackedItem(control, _passport);
		if _passport.hasErrors then
			break;
		endif;
		
	endforeach;
	
epilog

	delete planControl;

end;</source>
        <Parameter name="_tis" type="CM_TIArray"/>
        <Parameter name="control" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_plannedLoc" type="CM_LocationsController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateMoveTrackedItem" id="b6273ed7-65a1-401b-a946-08287b4e9db6">
        <source>utlUpdateMoveTrackedItem(control : CMIF_MoveController input; _passport : CM_Passport input);
/* ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     Performs a move. NOTE : Validation is performed within the methods themselves
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------

27 Oct 2011		cnwer1		PAR 28529
02 Apr 2012		cnwrs1		Par 29077 - EDI RORO Stowage Advice errors
17 Jan 2018		jlgdap1		TFS 36658 STWR Cargo Scanning Enhancements
12/11/2018		jlgdap1		TFS 41300 PEL1 Unable to load to vessel from truck in Job Lander
28 Nov 2018		jlgrs1		TFS 41659 STWR Make EDI MultiThreaded Stage 7
29/11/2018		jlgdap1		TFS 42109 PEL1 Hold Job Ops Issue
28 Nov 2018		jlgrs1		TFS 42276 STWR Make EDI MultiThreaded Stage 7
15 Oct 2021		navdap1		TFS 51935 SAL Direct Loading Partial Prenoted Cargo from Truck to Vessel
15 Nov 2021		navdap1		TFS 52360 SAL Direct Prenote to Voyage Incorrect Job Values
06 Dec 2021		navdap1		TFS 52293 SAL Direct Loading - Marking Job as Direct Delivery
19 Feb 2022		navdap1		TFS 52801 SAL Direct Delivery - End of Shift Job Transfer
09 Nov 2022		navkc1		Bug 55382: MTN - Cargo Group Details recalculated after each change to TI when bulk editing
08 Sep 2023 	navhl20 	ChangeRequest 59121: EUP | Handle Work orders Packing  By Type
13 Nov 2023		navdap1		TFS 59458 EUP | EDI Specific Performance
05 Dec 2023 	navhl20 	ChangeRequest 58400:[61617] EUP | Ship Operations in DD - [54176.050] Mobile App changes
21 Dec 2023 	navhl20 	ChangeRequest 61092:[61621] EUP | Ship Operations in DD - [54176.050] Mobile App changes - Pack Load by Request
04 Jan 2023 	navhl20 	ChangeRequest 61092:[61621] EUP | Ship Operations in DD - [54176.050] Mobile App changes - Pack Load by Request
17 May 2024 	navhl20 	Bug 64191: EUP - Lock and Freeze issue
09 Dec 2024		navhl20 	Bug MTN-33643: EUP - Partial move by weight is not working in Work Order Operation screen
06 Mar 2025		jlizm1		MTN 23109 Deadlock between Truck Loader and Work Order Operations
*/
vars
	origWLE 	: CM_WorkListEntry;
	origTI 		: CM_TrackedItem;
	cargoGroup  : CM_CargoGroup;								
	invalidWLE  : Boolean;
	voyage 		: CM_Voyage;						
	prenote, 
	ti 			: CM_TrackedItem;			
	voyageWle, 
	newWle 		: CM_WorkListEntry;	
	voyageJob 	: CM_VoyageJob;			
	invalidObj 	: Boolean;
	job 		: CM_Job;
	fm 			: CM_FutureMove;			
	onsiteTI 	: CM_TrackedItem;		
	onsiteWLE 	: CM_WorkListEntry;	
	directToShipMoves : Boolean;	
	iter 		: Iterator;			
	term		: CM_Terminal;
	isShipWoWle : Boolean;
	wod			: CM_WorkOrderTIDtl;
	transport	: Integer;	
begin

	self.initialiseActivity();

	origTI	:= control.myTrackedItem;
	origWLE := control.myWorkListEntry;

	// TFS 36658 Cargo Group planned move - just update the default location on the cargo group object and get out
	if origTI.isCargoGroupItem then
		if control.moveMode = PLANNING_MODE then
			cargoGroup := origTI.CM_CargoGroup;
			cargoGroup.setDefaultLocation(control.myToPrimaryLocationString);	//01 Oct 2018	TFS 39186
		endif;
		return;
	endif;
	// TFS 36658 end
	
	// TFS 41300 Special case of a prenote planned to a voyage hold - we need to keep track of 
	// three WLEs in this case. The origial Voyage WLE for the planned prenote, the Road WLE
	// for moving the TI from the truck to the voyage, and a new voyage WLE to represent the 
	// partial move of the original planned Voyage WLE. We also need to make sure we complete 
	// the original prenote's planned voyage wle when we're moving the last of the cargo
	ti := control.myTrackedItem;
	//directToShipMoves := ti.myTerminal.getConfig(DirectTruck2VesselMult).Boolean;						// TFS 51935	// TFS 52293
	directToShipMoves := origWLE &lt;&gt; null and origWLE.job &lt;&gt; null and origWLE.job.isDirectDeliveryJob;	// TFS 51935	// TFS 52293
	if control.myToPrimaryLocation.isKindOf(CM_GeneralCargoController) and ti &lt;&gt; null and ti.wasPrenotified then
		voyage := control.myToPrimaryLocation.CM_GeneralCargoController.myGCVoyage.myVoyage;
		prenote := voyage.allNotifiedTIsByIdCargoType[ti.id, ti.cargoType];
		//if prenote &lt;&gt; null and not prenote.allPlannedFutureMoves.isEmpty then												// TFS 51935
		if (prenote &lt;&gt; null and not prenote.allPlannedFutureMoves.isEmpty) or (prenote = null and ti.wasPrenotified) then	// TFS 51935
			// TFS 51935 If we're configured to do direct truck to ship moves, look for a voyage WLE 
			// on a truck on site. If none found, look for a prenote future move with an unactioned WLE
			if directToShipMoves then
				if prenote &lt;&gt; null then
					// TFS 52801 cater for more than 1 onsite cargo item for this prenote
					//onsiteTI := prenote.myTerminal.allOnsiteTIsByCargoTypeId[prenote.cargoType, prenote.id];
					iter := prenote.myTerminal.allOnsiteTIsByCargoTypeId.createIterator;
					prenote.myTerminal.allOnsiteTIsByCargoTypeId.startKeyGeq(prenote.cargoType, prenote.id, iter);
					while iter.next(onsiteTI) do
						if onsiteTI.cargoType &lt;&gt; prenote.cargoType or onsiteTI.id &lt;&gt; prenote.id then
							onsiteTI := null;
							break;
						endif;
						if onsiteTI.locationId = control.myOriginatingLocationString then
							break;
						endif;
					endwhile;
					// TFS 52801 end
				else
					onsiteTI := ti;
				endif;
				if onsiteTI &lt;&gt; null and onsiteTI.myPrimaryActualLocation.isVehicle then
					foreach onsiteWLE in onsiteTI.allWorklistEntries do
						if (onsiteWLE.job.status.isOneOf(JOB_PART_COMPLETE, JOB_UNACTIONED) or onsiteWLE.status = WLE_UNACTIONED)
						and onsiteWLE.isKindOf(CM_VoyageWLE) 
						and onsiteWLE.locationTarget = control.myToPrimaryLocationString then
							voyageWle := onsiteWLE;
							break;
						endif;
					endforeach;
				endif;
				if voyageWle = null and prenote &lt;&gt; null then
					foreach fm in prenote.allPlannedFutureMoves where fm.myWorkListEntry.status &lt;&gt; WLE_COMPLETED do
						voyageWle := fm.myWorkListEntry;
						break;
					endforeach;
				endif;
			else
			// TFS 51935 end of this bit
				if prenote &lt;&gt; null then																	// TFS 51935
					voyageWle := prenote.allPlannedFutureMoves.first.CM_FutureMovePlanned.myWorkListEntry;
				endif;																					// TFS 51935
			endif;
			//For relase ship workorder wle's
			if ti &lt;&gt; null  and origWLE &lt;&gt; null and control.moveMode = REAL_MODE and origWLE.isKindOf(CM_WOReleaseCargoWLE) then	//18.12.2023 navhl20 #58400[61617]
				isShipWoWle := true;
			endif;
			//if voyageWle &lt;&gt; null then												// TFS 42109
			if voyageWle &lt;&gt; null and control.myDDWorkListEntry &lt;&gt; null then			// TFS 42109
				voyageJob := voyageWle.job.CM_VoyageJob;
				if not directToShipMoves then															// TFS 51935
					newWle := voyageWle.cloneSelf(voyageWle.isTransient);
					newWle.setJob(voyageJob);
					newWle.setMyTrackedItem(ti);
					//voyageJob.allReleaseTrackeditems.addNoDuplicates(ti, false);
					newWle.setLocations(control.myWorkListEntry.locationSource, voyageWle.locationTarget);
					newWle.updateRequest(voyageWle.myRequest);
				endif;																					// TFS 51935
				
				// TFS 51935 We may have the situation where the road WLE quantity/weight is larger than any existing voyage WLE
				// In this case we need to transfer the excess amount to another (existing) voyage WLE
				if directToShipMoves and control.myOriginatingLocation.isVehicle then 
					control.setDirectExcessIfReqd(prenote, ti, voyageWle.CM_VoyageWLE);		// TFS 52360
				endif;
				// TFS 51935 end of this bit
				if ti.isBulkByQuantity then
					if newWle &lt;&gt; null then																// TFS 51935
						newWle.setQuantity(control.quantity);
						voyageWle.setQuantity(voyageWle.quantity - control.quantity);
					endif;																				// TFS 51935
				else
					if newWle &lt;&gt; null then																// TFS 51935
						newWle.setWeight(control.weight);
						voyageWle.setWeight(voyageWle.weight - control.weight);
					endif;																				// TFS 51935
				endif;
				
				// if we've already set the voyage WLE as the DD wle on the move controller,
				// need to swap this out for the new wle just created - so the voyage wle
				// doesn't get completed, and our newly-created wle does get completed
				//if control.myDDWorkListEntry = voyageWle then											// TFS 51935
				if control.myDDWorkListEntry = voyageWle and newWle &lt;&gt; null then						// TFS 51935
					control.myDDWorkListEntry := newWle;
					control.myDDJob := newWle.job;
				elseif control.myDDWorkListEntry.myTrackedItem.isNotified and directToShipMoves	then	// TFS 51935
					control.myDDWorkListEntry := voyageWle;												// TFS 51935
					control.myDDJob := voyageWle.job;													// TFS 51935
				endif;
			endif;
		elseif not ti.allPlannedFutureMoves.isEmpty and control.myDDWorkListEntry = null then
			voyageWle := ti.allPlannedFutureMoves.first.CM_FutureMovePlanned.myWorkListEntry;
			if voyageWle &lt;&gt; null then	//04 Jan 2019	NDL	TFS 42731
				if (ti.isBulkByQuantity and voyageWle.quantity &gt; ti.totalQuantity) 
				or ((ti.isBulkByWeight or ti.isBulkByVolume) and voyageWle.weight &gt; ti.totalWeight) then
					control.myDDWorkListEntry := voyageWle;
					control.myDDJob := voyageWle.job;
				endif;
			endif;
		endif;
	//10 Dec 2019	NDL	TFS 46875 - split the rail wle we are only planning the move for part of it
	elseif	ti &lt;&gt; null and ti.myPrimaryActualLocation &lt;&gt; null then
		if ti.myPrimaryActualLocation.isKindOf(CM_WagonController) and control.moveMode = PLANNING_MODE then
			if ti.myCargoType.isBulkByQuantity then
				if control.quantity &lt;&gt; 0 and control.quantity &lt; origWLE.quantity then
					//We are planning part of some break bulk from a wagon.
					newWle := origWLE.cloneSelf(origWLE.isTransient);
					newWle.setJob(origWLE.job);
					newWle.setMyTrackedItem(ti);
					newWle.setLocations(origWLE.locationSource, null);
					newWle.updateRequest(origWLE.myRequest);
					newWle.setQuantity(origWLE.quantity - control.quantity);
					origWLE.setQuantity(control.quantity);
				endif;
			endif;
		//23 July 2020	NDL	TFS 49775
		elseif ti &lt;&gt; null  and origWLE &lt;&gt; null and ti.canSplitTotalQuantity and control.isMultiRangeMove and control.moveMode = QUEUE_MODE then 
			//We are queuing part of some break bulk from a YA autoplan that was forced to do a split queue
			//i.e. One BreakBulk or Bulk Cargo items to multiple locations due to space limitations.
			if control.quantity &lt;&gt; 0 and control.quantity &lt; origWLE.quantity then
				newWle := origWLE.cloneSelf(origWLE.isTransient);
				newWle.setJob(origWLE.job);
				newWle.setMyTrackedItem(ti);
				newWle.setLocations(origWLE.locationSource, control.myToPrimaryLocationString);
				newWle.updateRequest(origWLE.myRequest);
				origWLE.setQuantity(origWLE.quantity - control.quantity);
				newWle.setQuantity(control.quantity);
				control.setMyWorkListEntry( newWle );
			elseif control.weight &lt;&gt; 0 and control.weight &lt; origWLE.weight then
				newWle := origWLE.cloneSelf(origWLE.isTransient);
				newWle.setJob(origWLE.job);
				newWle.setMyTrackedItem(ti);
				newWle.setLocations(origWLE.locationSource, control.myToPrimaryLocationString);
				newWle.updateRequest(origWLE.myRequest);
				origWLE.setWeight(origWLE.weight - control.weight);
				newWle.setWeight(control.weight);
				control.setMyWorkListEntry( newWle );
			endif;
		elseif ti &lt;&gt; null  and origWLE &lt;&gt; null and ti.canSplitTotalQuantity and control.moveMode = REAL_MODE then	//08.9.2023 navhl20 #59121
			if origWLE.isKindOf(CM_WOWLE) then
				//for receive ship wle's
				wod := origWLE.job.myWODtl;																			//18.12.2023 navhl20 #58400[61617]																		
				if wod &lt;&gt; null then																					//18.12.2023 navhl20 #58400[61617]
					transport := wod.getTransport();
				endif;
				if transport = TI_TRANSMODE_SHIP then																//18.12.2023 navhl20 #58400[61617]
					isShipWoWle := true;
				else
					if control.quantity &lt;&gt; 0 and control.quantity &lt; origWLE.quantity then
						newWle := origWLE.cloneSelf(origWLE.isTransient);
						newWle.setJob(origWLE.job);
						newWle.setMyTrackedItem(ti);
						origWLE.setMyTrackedItem(null);
						newWle.setLocations(origWLE.locationSource, control.myToPrimaryLocationString);
						newWle.updateRequest(origWLE.myRequest);
						origWLE.setQuantity(origWLE.quantity - control.quantity);
						newWle.setQuantity(control.quantity);
						control.setMyWorkListEntry( newWle );
					elseif control.weight &lt;&gt; 0 and control.weight &lt; origWLE.weight then								//09.12.2024 navhl20 #33643
						newWle := origWLE.cloneSelf(origWLE.isTransient);
						newWle.setJob(origWLE.job);
						newWle.setMyTrackedItem(ti);
						origWLE.setMyTrackedItem(null);
						newWle.setLocations(origWLE.locationSource, control.myToPrimaryLocationString);
						newWle.updateRequest(origWLE.myRequest);
						origWLE.setWeight(origWLE.weight - control.weight);
						newWle.setWeight(control.weight);
						control.setMyWorkListEntry( newWle );
					endif;
				endif;
			endif;
		endif;
	endif;
	
	if isShipWoWle then																									//18.12.2023 navhl20 #58400[61617]
		if control.quantity &lt;&gt; 0 and control.quantity &lt; origWLE.quantity then
			newWle := origWLE.cloneSelf(origWLE.isTransient);
			newWle.setJob(origWLE.job);
			newWle.setMyTrackedItem(ti);
			newWle.setLocations(origWLE.locationSource, control.myToPrimaryLocationString);
			newWle.updateRequest(origWLE.myRequest);
			origWLE.setQuantity(origWLE.quantity - control.quantity);
			newWle.setQuantity(control.quantity);
			control.setMyWorkListEntry( newWle );
		elseif control.weight &lt;&gt; 0 and control.weight &lt; origWLE.weight then												//09.12.2024 navhl20 #33643
			newWle := origWLE.cloneSelf(origWLE.isTransient);
			newWle.setJob(origWLE.job);
			newWle.setMyTrackedItem(ti);
			newWle.setLocations(origWLE.locationSource, control.myToPrimaryLocationString);
			newWle.updateRequest(origWLE.myRequest);
			origWLE.setWeight(origWLE.weight - control.weight);
			newWle.setWeight(control.weight);
			control.setMyWorkListEntry( newWle );
		else																											//21.12.2023 navhl20 #61092[61621]
			origWLE.setMyTrackedItem(ti);
			control.setMyWorkListEntry( origWLE );
		endif;
	endif;
	
	if control.myVoyageWPJob &lt;&gt; null 																					//04.01.2023 navhl20 #61092[61621]
	and app.isWebApp then																								//17.05.2024 navhl20 #64191
		control.myVoyageWPJob.setPlannedLocation(control.myToPrimaryLocation);
	endif;
	
	// TFS 41300 end
	// 28 Nov 2018	jlgrs1	TFS 42276 STWR Make EDI MultiThreaded Stage 7
	//	if _passport.useTITransactionDeferUpdate then
	term := ti.myTerminal;													//11.9.2023 navma1 #59121
	if app.isFromEDIviaWeb and _passport.useTITransactionDeferUpdate then	//06 Mar 2020	NDL	TFS 48776
		if not self.tryLock(term.allTITransactions, Exclusive_Lock, Transaction_Duration, LockTimeout_Server_Defined) then
			self.exclusiveLock(term.allTITransactions);
		endif;
		if not self.tryLock(term.allTITransactionsByTypeDate, Exclusive_Lock, Transaction_Duration, LockTimeout_Server_Defined) then
			self.exclusiveLock(term.allTITransactionsByTypeDate);
		endif;
		if not self.tryLock(term.allTITransactionsByCamsTS, Exclusive_Lock, Transaction_Duration, LockTimeout_Server_Defined) then
			self.exclusiveLock(term.allTITransactionsByCamsTS);
		endif;
	endif;
	//	if _passport.useTIDictDeferUpdate then
	if app.isFromEDIviaWeb and _passport.useTIDictDeferUpdate then	//06 Mar 2020	NDL	TFS 48776
		if ti.state = TI_STATE_NOTIFIED then
			if not self.tryLock(term.allNotifiedTIsByIdCargoType, Exclusive_Lock, Transaction_Duration, LockTimeout_Server_Defined) then
				self.exclusiveLock(term.allNotifiedTIsByIdCargoType);
			endif;
		elseif ti.state = TI_STATE_NORMAL then
			if not self.tryLock(term.allOnsiteTIsByIdCargoType, Exclusive_Lock, Transaction_Duration, LockTimeout_Server_Defined) then
				self.exclusiveLock(term.allOnsiteTIsByIdCargoType);
			endif;
		endif;
	endif;
	
	control.doToLocationColLock();
	
	control.executeMove(_passport);

	//epr par 28529 - only return if errors do not want warnings to stop the post move . Especially if the 
	// utl is called in a trx that calls multiple utils
	//if not app.myPassport.checkValidation() then
	if not app.myPassport.checkValidation() and not control.isLogMovement then // ### TFS 52572 24Jan2022 NAVPW1
		if control.myTrackedItem &lt;&gt; origTI then
			control.setMyTrackedItem(origTI);
		endif;
		
		on Exception do app.handleDeletedObject(exception,origWLE,invalidWLE);
		
		if control.myWorkListEntry &lt;&gt; origWLE then
			control.setMyWorkListEntry(origWLE);
		endif;
		return;
	endif;

	control.executePostMove(_passport);
	
	//05 Aug 2019	NDL	TFS 42876
	if _passport.noErrors  and ti &lt;&gt; null and  ( control.moveMode = PLANNING_MODE or control.moveMode = QUEUE_MODE ) then
		on Exception do app.handleDeletedObject( exception, origWLE, invalidObj );
		if origWLE &lt;&gt; null then
			job := origWLE.job;
			on Exception do app.handleDeletedObject( exception, job, invalidObj );
			if job &lt;&gt; null
			//and ( job.isKindOf(CM_RailJob) or job.isKindOf(CM_RoadJob) )
			and job.canBeDirectRelease // TFS 42878 jlgzm1 04/09/2019
			and not job.isVoyageHoldJob
			then
				ti.autoSetDirectReleaseWLE( origWLE, control, false );
			endif;
		endif;
	endif;
	
	
	// ### TFS BUG 59900 23AUG2023 NAVAB1 - if we have just done a merge, we need a cargo group for the cargo group details; so use the TI that the zombie was merged into
	if ti.isZombie() then
		ti := ti.allSplitChildrenTis.first;
	endif;
	
	// TFS 59458 Suppress Cargo Group Detail updates for Transport Manifest Ship EDI TIs
	if not control.suppressCargoGroupDetailUpdate then
		CMIF_TrxActionCargoGroup@createAction(ti, null, _passport); // 10/11/2022	navkc1	#55382
	endif;

epilog
	delete iter;			// TFS 52801
end;</source>
        <Parameter name="control" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateMoveTrackedItems" id="5757ed8b-f1b5-4482-b303-27956173ca2e">
        <source>utlUpdateMoveTrackedItems(_tis : CM_TISet; control : CMIF_MoveController input; _passport : CM_Passport input); 
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     Performs a move. NOTE : Validation is performed within the methods themselves
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 25/08/2017	jlgdap1		TFS 6687 STWR If we started with isNonCraneVoyageMove set to true,
//							make sure it's set to true for every TI (utlUpdateMoveTrackedItem
//							resets it to false).
// 09/11/2022	navkc1		Bug 55382: MTN - Cargo Group Details recalculated after each change to TI when bulk editing
// ---------------------------------------------------------------------------
vars
	ti		: CM_TrackedItem;
//	tiSet	: CM_TISet;
	isNonCraneVoyageMove : Boolean;									// TFS 6687
	dischargeWLE : CM_WorkListEntry;	//07 Sep 2018	NDL	TFS 39972
	useDischargeWleIfPoss : Boolean;	//07 Sep 2018	NDL	TFS 39972
	cargoGroupSiteTrxAction  : CMIF_TrxActionCargoGroup;	//TFS 53390

begin

	self.initialiseActivity();
	isNonCraneVoyageMove := control.isNonCraneVoyageMove;			// TFS 6687
	
	//07 Sep 2018	NDL	TFS 39972
	useDischargeWleIfPoss := (	isNonCraneVoyageMove
								and not control.allOtherWLEs.isEmpty
								and control.myOriginatingForm &lt;&gt; null
								and control.myOriginatingForm.class.name = "SHP_VoyageOpsForm" );
								
	foreach ti in _tis do
	
		control.setMyTrackedItem(ti);
		
		
		if useDischargeWleIfPoss then	//07 Sep 2018	NDL	TFS 39972
			dischargeWLE := control.getWLEForTI( ti );
			control.setMyWorkListEntry( dischargeWLE );
			control.isNonCraneVoyageMove := dischargeWLE = null;
			control.setWeight(0);
			control.setQuantity(0);	
			
		else
			control.isNonCraneVoyageMove := isNonCraneVoyageMove;		// TFS 6687
			//19 Sep 2017	NDL	TFS 7016
			//epr TFS 8220 6/12/17 always do this
			control.setWeight(0);
			control.setQuantity(0);
		
		endif;
		
		self.utlUpdateMoveTrackedItem(control, _passport);
		if _passport.hasErrors then
			break;
		endif;
		
		CMIF_TrxActionCargoGroup@createAction(ti, null, _passport); // 10/11/2022	navkc1	#55382
		
		/* // 10/11/2022	navkc1	#55382 Moved to CMIF_TrxActionCargoGroup@createAction
		//TFS 53390, AjitM, navam1
		if ti.myCargoGroup &lt;&gt; null then 
			create cargoGroupSiteTrxAction transient;
			cargoGroupSiteTrxAction.setMyCargoGroup(ti.myCargoGroup);
			_passport.addTrxPostAction(cargoGroupSiteTrxAction);
		endif;
		*/ // 10/11/2022	navkc1	#55382
	endforeach;

end;</source>
        <Parameter name="_tis" type="CM_TISet"/>
        <Parameter name="control" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateMoveTrackedItemsDifCs" id="5f4a8102-9a28-41d0-8bd9-b2dd30435cd8">
        <source>utlUpdateMoveTrackedItemsDifCs(_tis : CM_TIArray; _lcs : CM_LCArray; control : CMIF_MoveController input; _passport : CM_Passport input); 
// ---------------------------------------------------------------------------
// Created:		July 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	ti		: CM_TrackedItem;
	idx : Integer;
begin

	self.initialiseActivity();
	foreach ti in _tis do
		idx := idx + 1;
		control.setMyTrackedItem(ti);
		if _lcs.size &lt; idx then
			break;
		endif;
		
		control.setMyToPrimaryLocation(_lcs[idx]);
		self.utlUpdateMoveTrackedItem(control, _passport);
		if _passport.hasErrors then
//			break;
		endif;
	endforeach;

end;</source>
        <Parameter name="_tis" type="CM_TIArray"/>
        <Parameter name="_lcs" type="CM_LCArray"/>
        <Parameter name="control" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateMovementPath" id="3a4c56ed-e84f-4a74-908d-7b901f78a9b2">
        <updating/>
        <source>utlUpdateMovementPath(_pxyMovementPath : HMS_MovementPath; _passport : CM_Passport input) updating;
//-----------------------------------------
//Created: July 2003 By: cnwgd1
//-----------------------------------------
vars
	realMovementPath : HMS_MovementPath;
	expectedEdition : Integer;
begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);
	_pxyMovementPath.raiseExceptionIfNotProxy(method);
	_pxyMovementPath.validateMe(_passport);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	_pxyMovementPath.pxyGetRealObjectAndEdition(realMovementPath, expectedEdition);
	app.setContinueCMExceptions(true);

	if realMovementPath = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, _pxyMovementPath.code, null, null);
		return;
	endif;
	
	exclusiveLock(realMovementPath);

	if _passport.noErrors and realMovementPath.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'MovementPath', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realMovementPath, true);
	endif;
	
	if _passport.noErrors then
		realMovementPath.setForUpdate(_pxyMovementPath, _passport);
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realMovementPath, false);
	endif;
	
end;</source>
        <Parameter name="_pxyMovementPath" type="HMS_MovementPath"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateMovementsOrientation" id="ae99321d-4129-4fb0-86a6-c7ecb5b1473f">
        <updating/>
        <source>utlUpdateMovementsOrientation(	_allMovements : HMS_VoyageMovementSet input;
								_isStarboardBerthed : Boolean;
								_passport : CM_Passport) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 September 2009	cnwer1	Initial creation PAR#20191 updating the voyage orientation then update movement orientation

*/

vars
	hmsVoyageMovement : HMS_VoyageMovement;
	sideTo : Integer;
begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(false);
	
	if _isStarboardBerthed then
		sideTo:=OrientStarboardSideTo;
	else
		sideTo:=OrientPortSideTo;
	endif;
	
	foreach hmsVoyageMovement in _allMovements do
		hmsVoyageMovement.setSideTo(sideTo);
		if _passport.hasErrorsOrWarnings then
			break;
		endif;
	endforeach;
	
epilog

end;</source>
        <Parameter name="_allMovements" type="HMS_VoyageMovementSet" usage="input"/>
        <Parameter name="_isStarboardBerthed" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateMultipleEDITrans" id="83f91f53-a755-4f52-89a1-3af23a304de5">
        <source>utlUpdateMultipleEDITrans(_voyage : CM_Voyage input;_translations : CM_XlationSet; _customsManifest: String; _passport : CM_Passport input);
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 30 March 2022
TFS#		: 53181
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	pxyXlationIn, realXlationIn, xlationIn		: CM_Xlation_In;
	pxyXlationOut, xlationOut		: CM_Xlation_Out;
	xlationTable					: CM_XlationTable;
	opTerm, pxyOpTerm				: CM_OperatorTerminal;
	expectedEdition					: Integer;	
	xlation							: CM_Xlation;		
	proxyXlationTable				: CM_XlationTable;
	operatorTerminal 	: CM_OperatorTerminal;
	operator			: CM_Operator;
	realOpterm		: CM_OperatorTerminal;
begin	
	foreach xlation in _translations discreteLock do
		realXlationIn := null;
		xlationOut := null;
		if xlation.isKindOf (CM_Xlation_In) then			
			proxyXlationTable := xlation.myXlationTable;
			pxyXlationIn := proxyXlationTable.allInwardTranslations.first;
			pxyXlationOut := proxyXlationTable.allOutwardTranslations.first;
		endif;
		
		proxyXlationTable.raiseExceptionIfNotTransient(method);
		// xlationTable may also have an inward and outward translation to be maintained
		if proxyXlationTable.allInwardTranslations.size &gt; 1 then
			app.raiseUnexpectedProgramError (self.class.name, method.name, 'Too may inward translations');
		endif;

		if proxyXlationTable.allOutwardTranslations.size &gt; 1 then
			app.raiseUnexpectedProgramError (self.class.name, method.name, 'Too may outward translations');
		endif;	
		
		self.initialiseActivity();

		app.setContinueCMExceptions(true);
		
		opTerm := proxyXlationTable.myOperatorTerminal;
				
		if opTerm.isTransient then
			pxyOpTerm := opTerm;
			// avoid timing hole if opTerm created since we created the proxy			
			opTerm := pxyOpTerm.myOperator.allOperatorTerminals[pxyOpTerm.myTerminal];
						
			if opTerm = null then
				// need to create one
				xlationTable := null;
			else
				xlationTable := opTerm.allXlationTables[XLATION_TYPE_VOYAGETERMINAL, null];
			endif;					
		else	
			xlationTable := opTerm.allXlationTables[XLATION_TYPE_VOYAGETERMINAL, null];
		endif;
		
		if pxyXlationIn &lt;&gt; null then
			if pxyXlationIn.pxyIsProxy then
				pxyXlationIn.pxyGetRealObjectAndEdition(realXlationIn, expectedEdition);
				
				if realXlationIn = null then	
					app.raiseCMException1(ProxyMgrCannotLocateReal, CM_Xlation_In.name, null, null);
					return;
				endif;
				
				self.exclusiveLock(realXlationIn);

				if _passport.noErrors and realXlationIn.edition &lt;&gt; expectedEdition then
					app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Xlation In', null, null);
					return;
				endif;
				
			endif;

			app.myValUA.valXlation(pxyXlationIn);
		endif;
			
		if (not self.checkValidationWithPassport(_passport)) then
			return;		
		endif;

		if pxyXlationOut &lt;&gt; null then
			if pxyXlationOut.pxyIsProxy then
				pxyXlationOut.pxyGetRealObjectAndEdition (xlationOut, expectedEdition);
				
				if xlationOut = null then	
					app.raiseCMException1(ProxyMgrCannotLocateReal, CM_Xlation_Out.name, null, null);
					return;
				endif;
				
				self.exclusiveLock(xlationOut);
			
				if _passport.noErrors and xlationOut.edition &lt;&gt; expectedEdition then
					app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Xlation Out', null, null);
					return;
				endif;
				
				if xlationOut.systemCode &lt;&gt; pxyXlationOut.systemCode or
					xlationOut.foreignCode &lt;&gt; pxyXlationOut.foreignCode then
					// only validate if something has changed
					app.myValUA.valXlation(pxyXlationOut);
				endif;
			else
				app.myValCA.valXlation(pxyXlationOut);
			endif;
		endif;
			
		if (not self.checkValidationWithPassport(_passport)) then
			return;		
		endif;
		
		app.setContinueCMExceptions(false);

		if xlationTable = null then
			create xlationTable persistent;
			
			xlationTable.setForCreate(proxyXlationTable);			
			
			if opTerm = null then
				create opTerm persistent;
				
				opTerm.setMyOperator (pxyOpTerm.myOperator);
				opTerm.setMyTerminal (pxyOpTerm.myTerminal);				
			endif;
			xlationTable.setMyOperatorTerminal (opTerm);
			
		endif;
		

		if _passport.noErrors then
			if pxyXlationIn &lt;&gt; null then
				if realXlationIn = null then
					create realXlationIn persistent;
					
					realXlationIn.setForCreate (pxyXlationIn, xlationTable); 
					
					if _passport.noErrors then
						app.myUtilityCA.myCreateAuditAgent.audCreateGeneric(pxyXlationIn);
					endif;		
				else
					if _passport.noErrors then
						// This is only required if the class is being auditted
						self.myUpdateAuditAgent.audUpdateGeneric(pxyXlationIn, true);
					endif;
					
					realXlationIn.setForUpdate(pxyXlationIn);
					
					if _passport.noErrors then
						// This is only required if the class is being auditted
						self.myUpdateAuditAgent.audUpdateGeneric(pxyXlationIn, false);
					endif;
				endif;
			endif;
		endif;
		
		if _passport.noErrors then
			if pxyXlationOut &lt;&gt; null then
				if xlationOut = null then
					create xlationOut persistent;
					
					xlationOut.setForCreate (pxyXlationOut, xlationTable); 
					
					if _passport.noErrors then
						app.myUtilityCA.myCreateAuditAgent.audCreateGeneric(xlationOut);
					endif;		
				else
					if _passport.noErrors then
						// This is only required if the class is being auditted
						self.myUpdateAuditAgent.audUpdateGeneric(xlationOut, true);
					endif;
					
					xlationOut.setForUpdate(pxyXlationOut);
					
					if _passport.noErrors then
						// This is only required if the class is being auditted
						self.myUpdateAuditAgent.audUpdateGeneric(xlationOut, false);
					endif;
				endif;
			endif;
		endif;
		
		if xlationOut &lt;&gt; null then
			foreach xlationIn in xlationOut.myXlationTable.allInwardTranslations discreteLock do
				if xlationIn.systemCode = xlationOut.systemCode and xlationIn &lt;&gt; realXlationIn then
					// there is a 1:m between out and in translations so
					// we want each inward to cause a notification event
					self.updateObjectEdition (xlationIn);
				endif;
			endforeach;
		endif;
	endforeach;
epilog
	
	
end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
        <Parameter name="_translations" type="CM_XlationSet"/>
        <Parameter name="_customsManifest" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateObjMatchCrit" id="6eac41b3-cdff-4db3-86be-913a13b81eab">
        <updating/>
        <source>utlUpdateObjMatchCrit(_pxyObjMatch : CM_ObjectMatchCriteria input; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 December 2013	cnwndl1	Initial creation	Par 33184

*/

vars
	realObjMatch : CM_ObjectMatchCriteria;
	expectedEdition : Integer;
begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);
	_pxyObjMatch.raiseExceptionIfNotProxy(method);
	_pxyObjMatch.validateForUpdate();

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	_pxyObjMatch.pxyGetRealObjectAndEdition(realObjMatch, expectedEdition);
	app.setContinueCMExceptions(true);

	if realObjMatch = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, _pxyObjMatch.priority.String, null, null);
		return;
	endif;
	
	exclusiveLock(realObjMatch);

	if _passport.noErrors and realObjMatch.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Object Match Criteria', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realObjMatch, true);
	endif;
	
	if _passport.noErrors then
		realObjMatch.setForUpdate(_pxyObjMatch);
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realObjMatch, false);
	endif;
	
end;</source>
        <Parameter name="_pxyObjMatch" type="CM_ObjectMatchCriteria" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateOnePortStatuses" id="19ef79ec-18c2-42c3-a43b-5def6ac3fdbf">
        <updating/>
        <source>utlUpdateOnePortStatuses(_terminal : CM_Terminal input; _statuses : CM_NameValuePairDict; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17/11/2025	navkc1 JIRA 36176 NSW | OnePort API - Change voyage creation criteria DB / UI / Process changes

*/

vars
	
begin
	self.initialiseActivity();
	
	if _statuses = null then
		return;
	endif;
	
	app.setContinueCMExceptions(true);
	
	// Validate
	app.myValUA.valUpdateOnePortStatuses(_terminal, _statuses);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	exclusiveLock(_terminal);
	
	if _passport.noErrors() then
		self.myUpdateAuditAgent.audUpdateGeneric(_terminal, true);
	endif;
	
	// Action
	_terminal.addOrRemoveOnePortStatus(_statuses);
	
	if _passport.noErrors() then
		self.myUpdateAuditAgent.audUpdateGeneric(_terminal, false);
	endif;
	
epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal" usage="input"/>
        <Parameter name="_statuses" type="CM_NameValuePairDict"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateOpBookingDiscrep" id="0df35c7c-8a2f-4da5-95bb-8dba608a0af1">
        <source>utlUpdateOpBookingDiscrep(_operator : CM_Operator input; _allBookingRefDiscreps : StringArray; _passport : CM_Passport input);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 16/08/2019	jlgdap1		Initial creation TFS 45836 PEN Approved Carrier for ISO Type and Trailer Type
//
vars
	expectedEdition	: Integer;

begin
	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	
	app.myValUA.valUpdateOperatorAdvSettings(_operator, null, _allBookingRefDiscreps, _passport);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	expectedEdition	:= _operator.edition();
	app.setContinueCMExceptions(true);

	if _operator = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, app.getString(Operator), null, null);
		return;
	endif;
	
	exclusiveLock(_operator);
	
	if _passport.noErrors() and _operator.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, app.getString(Operator), null, null);
		return;
	endif;
	
	if _passport.noErrors() then
		self.myUpdateAuditAgent.audUpdateGeneric(_operator, true);
	endif;
	
	if _passport.noErrors() then
		if _allBookingRefDiscreps &lt;&gt; null then
			_operator.allAttribForBookingRefDiscrep.clear;
			if not _allBookingRefDiscreps.isEmpty then
				_allBookingRefDiscreps.copy(_operator.allAttribForBookingRefDiscrep);
			endif;
		endif;
	endif;
	
	if _passport.noErrors() then
		self.myUpdateAuditAgent.audUpdateGeneric(_operator, false);
	endif;
epilog

end;</source>
        <Parameter name="_operator" type="CM_Operator" usage="input"/>
        <Parameter name="_allBookingRefDiscreps" type="StringArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateOpCarrierCrit" id="9f08c45f-79fe-4b54-9c80-bce3866266c3">
        <updating/>
        <source>utlUpdateOpCarrierCrit(_pxyOpCrit : CM_OperatorCarrierCriteria input; _passport : CM_Passport input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 22/08/2019	jlgdap1		Initial creation TFS 45836 PEN Approved Carrier for ISO Type and Trailer Type
//
vars
	realOpCrit : CM_OperatorCarrierCriteria;
	expectedEdition : Integer;
	
begin
	self.initialiseActivity();

	app.setContinueCMExceptions(true);
	_pxyOpCrit.raiseExceptionIfNotProxy(method);
	_pxyOpCrit.validateForUpdate();

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	_pxyOpCrit.pxyGetRealObjectAndEdition(realOpCrit, expectedEdition);
	app.setContinueCMExceptions(true);

	if realOpCrit = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, _pxyOpCrit.priority.String, null, null);
		return;
	endif;
	
	exclusiveLock(realOpCrit);

	if _passport.noErrors and realOpCrit.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Operator Carrier Criteria', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realOpCrit.myOperator, true);
	endif;
	
	if _passport.noErrors then
		realOpCrit.setForUpdate(_pxyOpCrit);
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realOpCrit.myOperator, false);
	endif;
epilog

end;</source>
        <Parameter name="_pxyOpCrit" type="CM_OperatorCarrierCriteria" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateOpFreightFwdrs" id="d887b3b4-a9c6-4176-a63a-43604b5a917c">
        <source>utlUpdateOpFreightFwdrs(_operator : CM_Operator input; _allFreightForwarders : CM_ConsigneeConsignorSet; _passport : CM_Passport input);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 16/08/2019	jlgdap1		Initial creation TFS 45836 PEN Approved XCarrier fror ISO Type and Trailer Type
//
vars
	expectedEdition	: Integer;

begin
	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	
	app.myValUA.valUpdateOperatorAdvSettings(_operator, _allFreightForwarders, null, _passport);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	expectedEdition	:= _operator.edition();
	app.setContinueCMExceptions(true);

	if _operator = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, app.getString(Operator), null, null);
		return;
	endif;
	
	exclusiveLock(_operator);
	
	if _passport.noErrors() and _operator.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, app.getString(Operator), null, null);
		return;
	endif;
	
	if _passport.noErrors() then
		self.myUpdateAuditAgent.audUpdateGeneric(_operator, true);
	endif;
	
	if _passport.noErrors() then
		if _allFreightForwarders &lt;&gt; null then
			_operator.allFFsForBookRefUpdate.clear();
			_allFreightForwarders.copy(_operator.allFFsForBookRefUpdate);
		endif;
	endif;
	
	if _passport.noErrors() then
		self.myUpdateAuditAgent.audUpdateGeneric(_operator, false);
	endif;
epilog

end;</source>
        <Parameter name="_operator" type="CM_Operator" usage="input"/>
        <Parameter name="_allFreightForwarders" type="CM_ConsigneeConsignorSet"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateOpTerminalConfig" id="92162cec-3a3a-4d1e-8835-3724f7936455">
        <source>utlUpdateOpTerminalConfig(_cmif	: CMIF_OperatorTerminalConfig; _operator : CM_Operator; _passport : CM_Passport input);

vars

	realOperator 	: CM_Operator;
	expectedEdition	: Integer;
	terminal		: CM_Terminal;

begin

	self.initialiseActivity();
	_operator.raiseExceptionIfNotTransient(method);
	_operator.pxyGetRealObjectAndEdition(realOperator, expectedEdition);
	self.exclusiveLock(_operator);
	terminal := _cmif.myTerminal;
	app.myValUA.valOpTerminalConfig(realOperator, terminal);
	if (not self.checkValidationWithPassport(_passport)) then
		return;
	endif;	
	
	realOperator.setConfigForTerminal(_cmif, terminal);
	

end;</source>
        <Parameter name="_cmif" type="CMIF_OperatorTerminalConfig"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateOperator" id="97ea00d7-ad2e-4c7f-b014-f615f9d10b27">
        <source>utlUpdateOperator(pProxyOperator:CM_Operator; _cmifConfigOperator : CMIF_ConfigOperator input; 
		_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 21 Sep 2020 cnwma1 ChangeRequest 49906: MTN - Ops View External Webservice
// ---------------------------------------------------------------------------
vars
	cancelSave:Boolean;
	realOperator:CM_Operator;
	expectedEdition:Integer;
	codeChanged:Boolean;
	eventStr : String;
	theTerminal : CM_Terminal;
	
begin

	self.initialiseActivity();

	pProxyOperator.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	pProxyOperator.pxyGetRealObjectAndEdition(realOperator, expectedEdition);
	
	if realOperator = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_Operator.name, null, null);
		return;
	endif;

	app.myValUA.valOperator(realOperator, pProxyOperator);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;


	app.setContinueCMExceptions(false);

	exclusiveLock(realOperator);

	if _passport.noErrors and realOperator.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Operator', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realOperator, true);
	endif;
	
	if _passport.noErrors then
		if realOperator.colour &lt;&gt; pProxyOperator.colour then
			codeChanged := true;
		endif;
		realOperator.setForUpdate(pProxyOperator);
	endif;
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realOperator, false);
	endif;

	if _passport.noErrors and _cmifConfigOperator &lt;&gt; null then
		if codeChanged then
			eventStr := eventStr &amp;  "&lt;" &amp; GridXML_ColourCode &amp; "&gt;" &amp; realOperator.code  &amp; "&lt;/" &amp; GridXML_ColourCode &amp; "&gt;";
			eventStr := eventStr &amp;  "&lt;" &amp; GridXML_Colour &amp; "&gt;" &amp; realOperator.colour.String  &amp; "&lt;/" &amp; GridXML_Colour &amp; "&gt;";
			realOperator.causeEvent(EVENT_CODE_COLOUR_CHANGE, false, eventStr);
		endif;
		_cmifConfigOperator.updatePersistentObject(realOperator, _passport);
	endif;

	//21.09.2020 cnwma1 TFS #49906
	if _passport.isOpsViewEnabled(null) then
		realOperator.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_UPDATE,
											 BGP_OpsViewWSRequest.OPS_TYPE_OPERATOR,
											 realOperator);
										 
	endif;
	//21.09.2020 cnwma1 TFS #49906
epilog
	
	
end;</source>
        <Parameter name="pProxyOperator" type="CM_Operator"/>
        <Parameter name="_cmifConfigOperator" type="CMIF_ConfigOperator" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateOperatorAdvSettings" id="d8f0d07e-5ca1-470a-ab2b-ca6c43e920d6">
        <updating/>
        <source>utlUpdateOperatorAdvSettings(_operatorObj:CM_Operator input; _allForwardersObj:CM_ConsigneeConsignorSet; _allBookingRefDiscreps : StringArray; _passportObj:CM_Passport input) updating;
// --------------------------------------------------------------------------------
// Created:		25 August 2008 by cnwdad1
//
// Purpose:		Adds/Removes Freight Fordarder objects to/from the specified Operator's
//				collection of Forwarders for Booking Ref updates.
//
// Parameters:	_operatorObj - A reference to the Operator object to update.
//				_allForwardersObj - A set of Freight Forwarder objects.
//				_passportObj - A reference to the user's Passport object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// 14 Aug 2018	jlgrs1	TFS 39619 PEN - Approved Carriers For Operator 
// 21/08/2019	jlgdap1		TFS 45836 PEN Approved Carrier for ISO Type and Trailer Type
//								Removed carrier updates from this method and parameters
// --------------------------------------------------------------------------------
vars
	expectedEdition	: Integer;
	forwarderObj	: CM_ConsigneeConsignor;
	carrier : CM_Carrier;
	obj : Object;
	carrierSet : CM_CarrierSet;
	newCarrierSet : Boolean;
begin
	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	
	app.myValUA.valUpdateOperatorAdvSettings(_operatorObj, _allForwardersObj, _allBookingRefDiscreps, _passportObj);
	
	if not self.checkValidationWithPassport(_passportObj) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	expectedEdition	:=	_operatorObj.edition();
	app.setContinueCMExceptions(true);

	if _operatorObj = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, app.getString(Operator), null, null);
		return;
	endif;
	
	exclusiveLock(_operatorObj);
	
	if _passportObj.noErrors() and _operatorObj.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, app.getString(Operator), null, null);
		return;
	endif;
	
	if _passportObj.noErrors() then
		self.myUpdateAuditAgent.audUpdateGeneric(_operatorObj, true);
	endif;
	
	if _passportObj.noErrors() then
		if _allForwardersObj &lt;&gt; null then
			_operatorObj.allFFsForBookRefUpdate.clear();
			_allForwardersObj.copy(_operatorObj.allFFsForBookRefUpdate);
		endif;
		if _allBookingRefDiscreps &lt;&gt; null then
			//25 Aug 2009	NDL CCMS 1609 Par 20521
			_operatorObj.allAttribForBookingRefDiscrep.clear;
			if not _allBookingRefDiscreps.isEmpty then
				_allBookingRefDiscreps.copy(_operatorObj.allAttribForBookingRefDiscrep);
			endif;
		endif;
		// TFS 45836 removed - now updated in their own trx and utl
		/*if _carrierSet &lt;&gt; null and
		   _carrierCargoType &lt;&gt; null then
			obj := _operatorObj.allCarriersByCargoTypeId.getAtKey(_carrierCargoType);
			if obj &lt;&gt; null then
				carrierSet := obj.CM_CarrierSet;
				carrierSet.clear();
				newCarrierSet := false;
			else
				create carrierSet persistent;
				newCarrierSet := true;
			endif;
			_carrierSet.copy(carrierSet);
			if not carrierSet.isEmpty and
			   newCarrierSet then
				_operatorObj.allCarriersByCargoTypeId.putAtKey(_carrierCargoType, carrierSet);
			endif;
		endif;*/
// The following was only required for the 7.5.3 and 7.6.2 hotfixes.
//		forwarderObj	:=	_allForwardersObj.first();
//		_operatorObj.setConfig(OperatorForwarder, forwarderObj);
	endif;
	
	if _passportObj.noErrors() then
		self.myUpdateAuditAgent.audUpdateGeneric(_operatorObj, false);
	endif;
end;</source>
        <Parameter name="_operatorObj" type="CM_Operator" usage="input"/>
        <Parameter name="_allForwardersObj" type="CM_ConsigneeConsignorSet"/>
        <Parameter name="_allBookingRefDiscreps" type="StringArray"/>
        <Parameter name="_passportObj" type="CM_Passport" usage="input"/>
    </JadeMethod>
