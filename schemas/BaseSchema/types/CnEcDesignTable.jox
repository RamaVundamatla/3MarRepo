    <JadeMethod name="hideColumnByHeading" id="7f4b921d-a284-45a2-9b83-aeff997733b3">
        <updating/>
        <source>hideColumnByHeading(columnHeading : String) updating;

vars
	loopIndex			: Integer;
	heading				: String;
begin
	loopIndex	:= 1;
	foreach heading in columnHeadingArray do
		loopIndex := loopIndex + 1;
		if heading = columnHeading then
			self.columnVisible[loopIndex] := false;
			break;
		endif;
	endforeach;
end;</source>
