    <JadeMethod name="loadDataForFirstTime" id="88e4b840-4170-44f2-ac1a-c5fe0580191f">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
// ---------------------------------------------------------------------------
// Created:     27 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	taType	: CM_TerminalAreaType;
begin
	
	inheritMethod();
	self.loadTATypes();
	taType := cmbTAType.listObject.CM_TerminalAreaType;
	self.loadLocations(taType);
	self.getAvailableToLocations(taType);
	self.setNavigatorHeading(self.caption);
	if (not app.getMyUser.canDo(self.myTerminal, Mod_GeneralCargo)) then
		self.optDocket.visible := false;
		self.optLocation.left := self.optDocket.left;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadTATypes" id="9d78d5e4-2c60-49e1-b793-51c624db2921">
        <source>loadTATypes();
// ---------------------------------------------------------------------------
// Created:     27 September 2002 by cnwth2
//
// Purpose:		loads terminal area types into the cmbTAType     
//
// ----------   ----------  --------------------------------------------------
/*

Date		Who		Reason
10 Jun 2008	cnwkpd1	PAR #16753 - CCMS SFW 1003 - General Cargo Graphical Screens

*/

vars
	taDict		: CM_TATypeByTypeDict;
	taType		: CM_TerminalAreaType;
begin
	taDict := app.myRoot.allTerminalAreaTypes;
	if not taDict.isEmpty then
		self.cmbTAType.listCollection(taDict, true, 0);
		self.cmbTATypeTo.listCollection(taDict, true, 0);
		
		taType := taDict[TA_TYPE_IRREGULAR_BLOCK_AREA];			// was TA_TYPE_GENERAL_CARGO_AREA
		if taType = null then
			return;
		endif;
		self.cmbTAType.listObject := taType;
		self.cmbTATypeTo.listObject := taType;
		self.tblActionData.setValueByName(ETRow_TaTypeTo, taType.description);
		self.tblSelection.setValueByName(ETRow_TaType, taType.description);
	
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="saveTrackedItems" id="4874bb45-1024-442e-9b08-8ac8b1ceb030">
        <updating/>
        <source>saveTrackedItems(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	moveController	: CMIF_MoveController;
	rtnValue		: Boolean;
	cancelSave		: Boolean;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin

	if self.cmbToLocation.listObject &lt;&gt; null then
		create moveController transient;
		moveController.setMoveMode(REAL_MODE);
		moveController.isSystemMove := true;
		moveController.setMyToPrimaryLocation(self.cmbToLocation.listObject.CM_LocationsController);
		
		//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			app.myTrxUA.trxMoveTrackedItems(self.allTrackedItems, moveController, app.myPassport);
		
			if app.myPassport.trxCompletedOK then
				rtnValue := true;
				break;
			else
				theResult := app.showErrorWarningDialog('Transfer Items', app.myPassport, ErrWarnMode_Update);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			rtnValue := false;
			break;
			
		endwhile;

	else
		app.msgBox('You must select a "To Location" to proceed','Error',0);
	endif;
epilog
	self.allTrackedItems.clear;
	delete moveController;
	return rtnValue;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setActionTableView" id="b03c28d8-fe9d-49dc-a6e3-2603d9bff3b0">
