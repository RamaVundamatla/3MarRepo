    <JadeMethod name="utlDeletePreNote" id="c83749fd-6be4-49d5-b51d-2573bc3507f4">
        <updating/>
        <source>utlDeletePreNote(_intFaceObject : CMIF_PreNote io; _validateOnly : Boolean; _isInitialise : Boolean; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     Jan 2010 cnwrs1 par 21329
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 28/07/2010	cnwdad1		PAR #25120, added parameter for calling "initialiseActivity".
// ---------------------------------------------------------------------------
vars
	preNote : CM_TrackedItem;
	expectedEdition	: Integer;
begin
	if _isInitialise then
		self.initialiseActivity();
	endif;

	app.setContinueCMExceptions(true);

	preNote := _intFaceObject.myPersistentTrackedItem;
	expectedEdition	:=	preNote.edition;

	if preNote = null then
		app.raiseCMException2(Object_DoesNotExist_Too_Delete, app.getErrorString(CargoItem_Name), _intFaceObject.id, null, null);
		return;
	endif;

	exclusiveLock(preNote);

	if _passport.noErrors() and preNote.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'tracked item', null, null);
		return;
	endif;
	
	if (not self.checkValidationWithPassport(_passport)) then // Show any Errors and Warnings in a list
		return;
	endif;
	app.setContinueCMExceptions(false);

	if _passport.noErrors() then
		self.myDeleteAuditAgent.audDeleteGeneric(preNote);
	endif;

	if _passport.noErrors() and not _validateOnly then
		preNote.erase(NORMAL_ERASE);
	endif;
epilog
	return;
end;</source>
        <Parameter name="_intFaceObject" type="CMIF_PreNote" usage="io"/>
        <Parameter name="_validateOnly" type="Boolean"/>
        <Parameter name="_isInitialise" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
