    <JadeMethod name="pxyCreateUpdateProxy" id="fb73d62f-4977-47fe-8e43-2693c599725d">
        <source>pxyCreateUpdateProxy(): SelfType;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
18 February 2010	cnwjk3	Initial creation
20/04/2011			cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
							trying to create the proxy
*/

vars
	pxyRequest 		: SelfType;
	realReceivalInfo, 
	pxyReceivalInfo	: CM_ReceivalRequestInfo;
	completedOK		: Boolean;
begin
	pxyRequest := inheritMethod();
	foreach realReceivalInfo in self.allReceivalInfo do
		pxyReceivalInfo := realReceivalInfo.pxyCreateUpdateProxy();
		pxyReceivalInfo.setParent(pxyRequest);
	endforeach;
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyRequest;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyRequest;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="2464811e-dc7a-4ef4-916b-d2d2cc723f26">
        <updating/>
        <source>setForCreate(pxyRequest: CM_ReceivalRequest) updating;
//15 February 2010	cnwdw1	
//
vars

begin
	inheritMethod(pxyRequest);
	self.setForUpdate(pxyRequest);
	self.isReceipt :=true;

end;</source>
        <Parameter name="pxyRequest" type="CM_ReceivalRequest"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="cb63b508-ef89-442a-82db-96f82ea7c1ed">
        <updating/>
        <source>setForUpdate(pxyRequest: CM_ReceivalRequest) updating;
//15 February 2010	cnwdw1	
//
vars
	pxyReceivalInfo, receivalInfo: CM_ReceivalRequestInfo;
begin
	inheritMethod(pxyRequest);
	
	// Loop though real to find receival infos that do not have a proxy
	foreach receivalInfo in self.allReceivalInfo do
		pxyReceivalInfo := receivalInfo.pxyGetProxyObject();
		if pxyReceivalInfo = null then
			// This has been deleted in the proxy so delete from real
			delete receivalInfo;
		endif;
	endforeach;
		
	// Now do creates and updates	
	foreach pxyReceivalInfo in pxyRequest.allReceivalInfo do
		receivalInfo := pxyReceivalInfo.pxyGetRealObject();
		if receivalInfo = null then
			// new so create 
			create receivalInfo persistent;
			receivalInfo.setForCreate(pxyReceivalInfo, self);
		else
			// update so modify exisitng
			receivalInfo.setForUpdate(pxyReceivalInfo, self);
		endif;
	endforeach;
end;</source>
        <Parameter name="pxyRequest" type="CM_ReceivalRequest"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="35fae9b2-504a-44b2-bf7b-5567163d1ef3">
        <updating/>
        <source>setProxy(_receivalInfo: CM_GTEReceivalInfo) updating;
/* This method exists to set up a proxy request.

*/
vars
	receivalInfo: CM_ReceivalRequestInfo;
begin
	if not self.isTransient then
		return;
	endif;
	
	create receivalInfo transient;
	
	receivalInfo.setProxy(_receivalInfo.myBooking, _receivalInfo.myBookingItem, _receivalInfo.myCargoType, _receivalInfo.myCargoSubtype,
		_receivalInfo.commodity, _receivalInfo.quantity);
	receivalInfo.setParent(self);	// link to parent
	receivalInfo.setGTEReceivalInfo(_receivalInfo); // link CM_ReceivalRequestInfo to CM_GTEReceivalInfo
end;</source>
        <Parameter name="_receivalInfo" type="CM_GTEReceivalInfo"/>
    </JadeMethod>
</Class>
