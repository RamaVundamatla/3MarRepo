<Class name="CM_Xlation_In" id="8042f4c8-2881-4060-a83f-401e547c54b9">
    <superclass name="CM_Xlation"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="terminal"/>
    <ExplicitInverseRef name="myXlationCriteria" id="b8b62c90-747b-48ef-8818-798bd7ee456f">
        <kind>parent</kind>
        <updateMode>automatic</updateMode>
        <embedded/>
        <type name="CM_XlationCriteria"/>
        <access>readonly</access>
        <Inverse name="CM_XlationCriteria::myXlation"/>
    </ExplicitInverseRef>
    <JadeMethod name="canHaveCriteria" id="bc5c2927-f3ad-4a31-b3a5-d1aa534d4186">
        <source>canHaveCriteria():Boolean;
/*
Date		Who		Reason
12 March 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
19 Feb 2024	jlirs1	TFS 57192 - 57193 Pen Support Import Voyage Translation
*/
vars
	type :Integer;
begin
	type := self.myXlationTable.type;
	
	return type = XLATION_TYPE_COMMODITY_BYOP or 
		   type = XLATION_TYPE_MTGRADE_BYOP or
		   type = XLATION_TYPE_VOYAGETERMINAL;		//19 Feb 2024	jlirs1	TFS 57192 - 57193 Pen Support Import Voyage Translation
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="erase" id="0971a63c-13bd-46f7-8417-1dcc7f4c0ece">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
/*
Date		Who		Reason
12 Mar 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
*/
vars
	xlationTable	:CM_XlationTable;
	xlationIn		:CM_Xlation_In;
	xlationOut		:CM_Xlation_Out;
	count			:Integer;
begin
	self.exclusiveLock(self);
	
	xlationTable := self.myXlationTable;
	
	if xlationTable &lt;&gt; null then
		self.exclusiveLock(xlationTable);
		
		if _eraseLevel = NORMAL_ERASE then
			// if I am the last inward translation for this system code then
			// delete the outward translation
			foreach xlationIn in xlationTable.allInwardTranslations where xlationIn.systemCode = self.systemCode do
				count := count + 1;
			endforeach;
			
			if count = 1 then
				// last inward xlation for system code
				xlationOut := self.getXlationOut;
				
				if xlationOut &lt;&gt; null then
					xlationOut.erase (_eraseLevel);
				endif;
			endif;
		endif;


		if _eraseLevel = NORMAL_ERASE and
			xlationTable.allInwardTranslations.size = 1 and		// I am the last inward translation
			xlationTable.allOutwardTranslations.size = 0 then	// there are no outward translations
			
			// if last sibling in parent(xlationTable) then nuke the olds who will nuke me
			xlationTable.erase(NORMAL_ERASE);
		else
			// parent still has other children just nuke myself
			inheritMethod(_eraseLevel);
		endif;
	else
		inheritMethod(_eraseLevel);
	endif;
epilog

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getCriteriaDisplay" id="2e0c8b9d-edd1-4cee-bb1a-3bfe8d3454dc">
        <source>getCriteriaDisplay(_short :Boolean):String;
/*
Date		Who		Reason
12 March 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
*/
vars
	criteria	:CM_XlationCriteria;
begin
	criteria := self.myXlationCriteria;
	
	if criteria = null then
		if not _short and self.canHaveCriteria then
			return app.getErrorString1 (Xlation_No_Criteria, self.foreignCode);
		else
			return null;
		endif;
	endif;
	
	return criteria.getCriteriaDisplay (_short);
epilog

end;</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="82af0e97-4078-4380-959c-fd2ff870196d">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*
Date		Who		Reason
11 Mar 2013	cnwcs5	Initial Creation - CCMS PNL 2243 / par 31185 
03 Jul 2013	cnwcs5	par 31261 - remove redundant propertyies/ETRow_ constants

*/
vars
	xlation		: CM_Xlation;
begin
	if _attrName = ETRow_Criteria then
		return self.getCriteriaDisplay (true);
			
	elseif _attrName = 	ETRow_ForeignIn then
		return self.foreignCode;
		
	elseif _attrName = ETRow_ForeignOut then
		// can only be one outward
		xlation := self.getXlationOut;
		
		if xlation &lt;&gt; null then
			return xlation.foreignCode;
		endif;
		
	else
		return inheritMethod(_attrName, _short);
	endif;
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXlationOut" id="7d2c8417-b1d9-4f18-bec2-627cced0bfa0">
        <source>getXlationOut():CM_Xlation_Out;
/*
Date		Who		Reason
20 March 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
*/
vars
	xlationOut	:CM_Xlation_Out;
begin
	xlationOut := self.myXlationTable.allOutwardTranslations[self.systemCode];
	
	return xlationOut;
epilog

end;</source>
        <ReturnType type="CM_Xlation_Out"/>
    </JadeMethod>
    <JadeMethod name="isCriteriaMatch" id="e17694d6-fcd6-4767-9fac-beba5aae29ed">
        <source>isCriteriaMatch(_score :Integer output; _params :ParamListType):Boolean;
/*
Date		Who		Reason
02 Apr 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
*/
vars
	criteria	:CM_XlationCriteria;
begin
	if not self.canHaveCriteria then
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Method called for incorrect translation type');
	endif;
	
	criteria 	:= self.myXlationCriteria;
	
	if criteria = null then
		// no criteria so everything matches
		return true;
	endif;
	
	return criteria.isCriteriaMatch (_score, _params);
epilog

end;</source>
        <Parameter name="_score" type="Integer" usage="output"/>
        <Parameter name="_params" type="ParamListType"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isSameAs" id="39567ba3-8a0a-4bc0-868c-e125fc71c1ea">
        <source>isSameAs(_xlation: CM_Xlation_In): Boolean;
/*
Date		Who		Reason
03 Apr 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
*/
vars
	criteria1, criteria2	:CM_XlationCriteria;
begin
	if not inheritMethod(_xlation) then
		return false;
	endif;
	
	criteria1 := self.myXlationCriteria;
	criteria2 := _xlation.myXlationCriteria;
	
	if criteria1 = null and criteria2 = null then
		return true;
	endif;
	
	if criteria1 &lt;&gt; null and criteria2 &lt;&gt; null then
		return criteria1.isSameAs(criteria2);
	endif;
	
	return false;
epilog

end;</source>
        <Parameter name="_xlation" type="CM_Xlation_In"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="049d8f3a-410f-4897-8c63-9d59175ff3c4">
        <source>pxyCreateUpdateProxy(): SelfType;
/*
Date		Who		Reason
26 March 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
*/
vars
	proxy				:CM_Xlation_In;
	xlationCriteria, 
	pxyXlationCriteria	:CM_XlationCriteria;
	completedOK			:Boolean;
begin
	proxy := inheritMethod();
	
	xlationCriteria := self.myXlationCriteria;
	
	if xlationCriteria &lt;&gt; null then
		pxyXlationCriteria := xlationCriteria.pxyCreateUpdateProxy;
		
		pxyXlationCriteria.setMyXlation (proxy);
	endif;

	completedOK := true;
	
	return proxy;
epilog
	if not completedOK then			
		delete proxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="d0df26f6-50a5-4393-a73f-3dead99147e7">
        <updating/>
        <source>setForCreate(_proxy: CM_Xlation_In; _xlationTable: CM_XlationTable) updating;
/*
Date		Who		Reason
26 Mar 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
*/
vars
	pxyXlationCriteria,
	xlationCriteria		:CM_XlationCriteria;
begin
	inheritMethod(_proxy, _xlationTable);
	
	pxyXlationCriteria := _proxy.myXlationCriteria;
	
	if pxyXlationCriteria &lt;&gt; null then
		create xlationCriteria  as pxyXlationCriteria.class persistent;
		
		xlationCriteria.setForCreate (pxyXlationCriteria);
		
		xlationCriteria.setMyXlation (self);
	endif;

epilog

end;</source>
        <Parameter name="_proxy" type="CM_Xlation_In"/>
        <Parameter name="_xlationTable" type="CM_XlationTable"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="63c84ce8-a64a-4c6b-a35a-1a30aec765ec">
        <updating/>
        <source>setForUpdate(_proxy: CM_Xlation_In) updating;
/*
Date		Who		Reason
26 Mar 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
*/
vars
	pxyXlationCriteria,
	xlationCriteria		:CM_XlationCriteria;
begin
	inheritMethod(_proxy);
	
	pxyXlationCriteria 	:= _proxy.myXlationCriteria;
	xlationCriteria 	:= self.myXlationCriteria;

	if pxyXlationCriteria &lt;&gt; null then
		if xlationCriteria = null then
			// adding criteria
			create xlationCriteria  as pxyXlationCriteria.class persistent;
		
			xlationCriteria.setForCreate (pxyXlationCriteria);
			
			xlationCriteria.setMyXlation (self);
		else
			xlationCriteria.setForUpdate (pxyXlationCriteria);
		endif;
	else
		// are we deleting criteria		
		if xlationCriteria &lt;&gt; null then
			delete xlationCriteria;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_proxy" type="CM_Xlation_In"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="94b9a027-84b4-44d4-82dc-f41b1e6909cd">
        <source>validateMe();
/*
Date		Who		Reason
25 Mar 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
27 May 2013	cnwcs5	par 31259 - add error message for duplicate translation
*/
vars
	xlationTable, pxyXlationTable	: CM_XlationTable;
	realXlation, xlationIn			: CM_Xlation_In;
	pxyXlationCriteria				: CM_XlationCriteria;
	type							: Integer;
begin
	inheritMethod();

	pxyXlationTable 	:= self.myXlationTable;
	type				:= pxyXlationTable.type;
	pxyXlationCriteria 	:= self.myXlationCriteria;
	
	if pxyXlationCriteria &lt;&gt; null then
		// GUI should have taken care of all this
		if type = XLATION_TYPE_COMMODITY_BYOP and not pxyXlationCriteria.isKindOf (CM_XlCriteria_Commodity) then
			app.raiseUnexpectedProgramError (self.class.name, method.name, "Expecting commodity criteria");
		endif;
		
		if type = XLATION_TYPE_MTGRADE_BYOP and not pxyXlationCriteria.isKindOf (CM_XlCriteria_MTGrade) then
			app.raiseUnexpectedProgramError (self.class.name, method.name, "Expecting availability grade criteria");
		endif;
		
		if type &lt;&gt; XLATION_TYPE_COMMODITY_BYOP and type &lt;&gt; XLATION_TYPE_MTGRADE_BYOP and type &lt;&gt; XLATION_TYPE_VOYAGETERMINAL then		//19 Feb 2024	jlirs1	TFS 57192 - 57193 Pen Support Import Voyage Translation
			app.raiseUnexpectedProgramError (self.class.name, method.name, "Not expecing criteria");
		endif;
		
		pxyXlationCriteria.validateMe;
	endif;
	
	xlationTable	:= pxyXlationTable.pxyGetRealObject;
	
	
	//  there should be no other xlation out there for the same system code
	if xlationTable &lt;&gt; null then
		realXlation := self.pxyGetRealObject;
		
		if realXlation &lt;&gt; null and realXlation.foreignCode = self.foreignCode then
			// we are not changing foreign code so don't bother checking for duplicates
			
		else
			// ok to have same foreignCode for multiple system codes if voyage/terminal rtanslation
			if xlationTable.type &lt;&gt; XLATION_TYPE_VOYAGETERMINAL and self.myXlationCriteria = null then
				// for other types it does not make sense to have the same foreign code more than once 
				// as it will never be used
				foreach xlationIn in xlationTable.allInwardTranslations where xlationIn.foreignCode = self.foreignCode do
					if realXlation &lt;&gt; null and xlationIn = realXlation then
						// OK 
						continue;
					endif;
					
					if xlationIn.myXlationCriteria &lt;&gt; null then
						// duplicates OK if there is criteria
						continue;
					endif;
					// there is another outward translations for this system code - we don't allow duplicates
					app.raiseCMException (DUPLICATE_XLATION, null, null);
				endforeach;

			endif;
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
</Class>
