<CollClass name="CM_ISOTypeGroupByCodeDict" id="94fb06fc-2adb-4f62-95ae-9ba2135ee4e7">
    <memberType name="CM_ISOTypeGroup"/>
    <superclass name="CM_MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="terminal"/>
    <MemberKey>
        <property name="CM_Group::code"/>
    </MemberKey>
    <JadeMethod name="getDisplayCodes" id="6835086b-4862-4f80-b523-7b828e5ea2b3">
        <source>getDisplayCodes(_short : Boolean) : String;
// ---------------------------------------------------------------------------
// Created:		13 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance

*/
vars
	aCT : CM_ISOTypeGroup;
	line : String;
	invalid : Boolean;
	
begin
	on Exception do app.handleDeletedObject(exception, aCT, invalid);
	
	foreach aCT in self discreteLock do
//		if not global.isValidObject(aCT) then
//			continue;
//		endif;
		if line = null then
			line := aCT.code;
		else
			line := line &amp; ", " &amp; aCT.code;
		endif;
	endforeach;
	
	return line;
end;</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
</CollClass>
