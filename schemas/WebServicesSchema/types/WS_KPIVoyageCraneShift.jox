<Class name="WS_KPIVoyageCraneShift" id="a4f365ce-d15a-4da3-92d1-270910f5c80d">
    <superclass name="WS_KPIVoyage"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="restwebservice"/>
    <PrimAttribute name="craneCode" id="bb66b4e3-f560-426c-a104-c4ae268bf999">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="shiftCode" id="a41bae56-8050-4c4d-a760-30d3737efdd7">
        <length>101</length>
        <embedded/>
