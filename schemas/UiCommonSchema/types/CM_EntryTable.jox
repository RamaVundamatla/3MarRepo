    <JadeMethod name="setChangeMode" id="d1cb7327-e03c-4c54-bf1a-a2457cdde1db">
        <updating/>
        <source>setChangeMode(_mode : Integer) updating;
//-----------------------------------------------------------------------
//
//  Created by: cnwsh3
//
//	Date: 16 September 2003
//
//-----------------------------------------------------------------------

vars

begin
	if self.changeMode &lt;&gt; _mode then
		self.changeMode := _mode;
	endif;
end;</source>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setColumnHeadings" id="a4bf8ff0-a00d-4290-b424-485690705e0b">
        <updating/>
        <source>setColumnHeadings(pAttrHead, pValueHead : String) updating;
// ---------------------------------------------------------------------------
// Created:     03 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	entRowTrans			: EntTableRowTransient;

begin

	if (not self.hasHeading) then
		self.hasHeading := true;
	endif;

	if self.rows &gt;= 1 then
		self.accessCell(1,ColumnHeading).text := pAttrHead;
		self.accessCell(1,ColumnValue).text := pValueHead;
		create entRowTrans transient;
		self.allEntRowTransients.add(entRowTrans);
		self.accessRow(1).itemObject := entRowTrans;
		entRowTrans.setBasicDetails(pAttrHead, pValueHead, null, false, true);
		
	endif;

end;</source>
        <Parameter name="pAttrHead" type="String"/>
        <Parameter name="pValueHead" type="String"/>
    </JadeMethod>
    <JadeMethod name="setComboValues" id="bdcf413b-4123-4e3c-b50d-281534fbf26f">
        <updating/>
        <source>setComboValues(pRow : Integer; pValues : String) updating;
// ---------------------------------------------------------------------------
// Created:     03 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	cell	: JadeTableCell;
begin

	if self.isValidRow(pRow) then
		cell := self.accessCell(pRow, ColumnValue);
		if cell.inputType = Table.InputType_ComboBox then
			self.accessCell(pRow, ColumnValue).comboList := pValues;
		else
			if self.warningMethod &lt;&gt; null then
				self.form.sendMsgWithParams(self.warningMethod, self.name, method.name,
						'Cell for attribute (' &amp; self.getAttrName(pRow) &amp; ') is not setup as a comboBox');
			endif;
		endif;
	else
		if self.warningMethod &lt;&gt; null then
			self.form.sendMsgWithParams(self.warningMethod, self.name, method.name,
					'Row (' &amp; pRow.String &amp; ') is not a valid row - values (' &amp; pValues &amp; ')');
		endif;
	endif;

end;</source>
        <Parameter name="pRow" type="Integer"/>
        <Parameter name="pValues" type="String"/>
    </JadeMethod>
    <JadeMethod name="setComboValuesByName" id="30164b42-806d-42c3-b989-a5a44cf668d1">
        <updating/>
        <source>setComboValuesByName(pRowName : String; pValues : String) updating;
// ---------------------------------------------------------------------------
// Created:     03 November 2000 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpRow	: Integer;
begin
	tmpRow := self.getRowByName(pRowName);
	if tmpRow &gt; 0 then
		self.setComboValues(tmpRow, pValues);
	endif;

end;</source>
        <Parameter name="pRowName" type="String"/>
        <Parameter name="pValues" type="String"/>
    </JadeMethod>
    <JadeMethod name="setControl" id="55d95f70-2716-4172-909a-c7b5be1b3dea">
        <updating/>
        <source>setControl(pRow : Integer; pControl : Control input) updating;
// ---------------------------------------------------------------------------
// Created:     03 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	entRowTrans	: EntTableRowTransient;
	cntrlName	: String;

begin

	if self.isValidRow(pRow) then
		self.accessCell(pRow, ColumnValue).cellControl := pControl;
		entRowTrans := self.accessRow(pRow).itemObject.EntTableRowTransient;
		cntrlName := pControl.name;
		if entRowTrans &lt;&gt; null and cntrlName &lt;&gt; entRowTrans.controlName then
			entRowTrans.setControlName(cntrlName);
		endif;
		pControl.parent := self;
	else
		if self.warningMethod &lt;&gt; null then
			self.form.sendMsgWithParams(self.warningMethod, self.name, method.name, 'Cannot set control for row (' &amp; pRow.String &amp; ') - invalid row');
		endif;
	endif;

end;</source>
        <Parameter name="pRow" type="Integer"/>
        <Parameter name="pControl" type="Control" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setEntTableDef" id="9d696ea2-7d3f-478b-a4bf-5b50cadc1718">
        <updating/>
        <source>setEntTableDef(pDef : EntTableDef; pGetControlMethod, pWarningMethod : String) updating;
// ---------------------------------------------------------------------------
// Created:     11 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  pDef				- the definition to setup
//				pGetControlMethod	- a method on the form to return the correct control.  This is not
//									generally required but can be used if the controls are cloned so
//									that there are several controls with the same name.
//									Signature of the method is "xxxxx(pControlName : String) : Control"
//				pWarningMethod		- a method on the form to display any warning messages.  If null then
//									no warnings are given.
//									Signature of the method is "xxxxx(pTableName, pDefName, pControlName, pMsg : String)"
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin
	self.myEntTableDef := pDef;

	self.clearValues();
	self.rows := self.fixedRows;

	if pDef = null then
		return;
	endif;
	self.allEntRowTransients.purge();
	self.loadEntRowTransients(pDef.name, pDef.allEntTableRows, pGetControlMethod, pWarningMethod);

end;</source>
        <Parameter name="pDef" type="EntTableDef"/>
        <Parameter name="pGetControlMethod" type="String"/>
        <Parameter name="pWarningMethod" type="String"/>
    </JadeMethod>
    <JadeMethod name="setEntTableDefByName" id="ba0ede0f-ec0b-4177-a919-d60f746063d9">
        <updating/>
        <source>setEntTableDefByName(_entTableDefName : String) updating;
// ---------------------------------------------------------------------------
// Created:     12 May 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	entTableDef	: EntTableDef;

begin

	entTableDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[_entTableDefName];

	if entTableDef = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'EntTableDef (' &amp; _entTableDefName &amp; ') not found');
		return;
	endif;
	
	self.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');

end;</source>
        <Parameter name="_entTableDefName" type="String"/>
    </JadeMethod>
    <JadeMethod name="setEntTableFromView" id="b57c7f6a-9f30-4545-b205-c25f48c8f073">
        <updating/>
        <source>setEntTableFromView(pDef : EntTableDef;_view : EntTableView; pGetControlMethod, pWarningMethod : String) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17/08/2009	cnwer1	Initial creation
08/11/2015	cnwdap1	PAR #37149 Avoid 1090 purging oldEntRowTransients if we have a view or no ent def
*/

vars
oldEntRowTransients : CM_ObjectArray;
	obj 				: Object;
	entRowTransient : EntTableRowTransient;
	theRow 			: Integer;
begin
	if _view = null then
		self.setEntTableDef(pDef, pGetControlMethod, pWarningMethod);
		return;
	endif;
	self.myEntTableDef := pDef;

	
	self.clearEntTableRowTransients();
	self.rows := self.fixedRows;
	
	if pDef = null then
		return;
	endif;
	
	
	//want to keep old table values 
	create oldEntRowTransients transient;
	self.allEntRowTransients.copy(oldEntRowTransients);
	self.allEntRowTransients.clear();

	self.loadEntRowTransients(pDef.name, _view.allEntTableRows, pGetControlMethod, pWarningMethod);
	
	foreach obj in oldEntRowTransients do
		entRowTransient:=obj.EntTableRowTransient;
		theRow:=self.getRow(entRowTransient.name);
		if theRow &lt;&gt; null then
		
			self.setValue(theRow,entRowTransient.originalValue);
		endif;
	endforeach;
	
epilog
	if oldEntRowTransients &lt;&gt; null then						// PAR #37149
		oldEntRowTransients.purge;
	endif;													// PAR #37149
	delete oldEntRowTransients; //epr leaking transient

end;</source>
        <Parameter name="pDef" type="EntTableDef"/>
        <Parameter name="_view" type="EntTableView"/>
        <Parameter name="pGetControlMethod" type="String"/>
        <Parameter name="pWarningMethod" type="String"/>
    </JadeMethod>
    <JadeMethod name="setHeading" id="08db824a-d313-40d6-b881-710a0bc837a5">
        <updating/>
        <source>setHeading(pRow : Integer; pHeading : String) updating;
// ---------------------------------------------------------------------------
// Created:     09 November 2000 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	jadeCell	: JadeTableCell;

begin

	if self.isValidRow(pRow) then
		jadeCell := self.accessCell(pRow, ColumnHeading);
		jadeCell.text := pHeading;
		jadeCell.alignment := Alignment_Left_Top;
	else
		if self.warningMethod &lt;&gt; null then
			self.form.sendMsgWithParams(self.warningMethod, self.name, method.name, 'Cannot set heading for row (' &amp; pRow.String &amp; ') - invalid row');
		endif;
	endif;

end;</source>
        <Parameter name="pRow" type="Integer"/>
        <Parameter name="pHeading" type="String"/>
    </JadeMethod>
    <JadeMethod name="setHeadingByName" id="dbd2f7cc-dad1-40d1-b731-15480290b4d7">
        <updating/>
        <source>setHeadingByName(pName : String; pHeading : String) : Integer updating;
// ---------------------------------------------------------------------------
// Created:     09 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theRow	: Integer;

begin
	theRow := getRow(pName);
	
	if theRow &lt;&gt; 0 then
		setHeading(theRow, pHeading);
	else
		if self.warningMethod &lt;&gt; null then
			self.form.sendMsgWithParams(self.warningMethod, self.name, method.name, 'Cannot set heading for row (' &amp; pName &amp; ') - not found on table');
		endif;
	endif;
	
	return theRow;

end;</source>
        <Parameter name="pName" type="String"/>
        <Parameter name="pHeading" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setHeadingColumn" id="7a4dddc5-d6b4-4ee7-8eb1-6ab8d27e4e1e">
        <updating/>
        <source>setHeadingColumn(pForeColor, pBackColor : Integer; pBold, pItalic : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     06 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if pForeColor &lt;&gt; 0 then
		self.accessColumn(ColumnHeading).foreColor := pForeColor;
	endif;

	if pBackColor &lt;&gt; 0 then
		self.accessColumn(ColumnHeading).backColor := pBackColor;
	endif;
	
	self.accessColumn(ColumnHeading).fontBold 	:= pBold;
	self.accessColumn(ColumnHeading).fontItalic := pItalic;

end;</source>
        <Parameter name="pForeColor" type="Integer"/>
        <Parameter name="pBackColor" type="Integer"/>
        <Parameter name="pBold" type="Boolean"/>
        <Parameter name="pItalic" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setHeadingRow" id="a0b866ea-4ac8-4b92-9300-1ca15502fd06">
        <updating/>
        <source>setHeadingRow(pForeColor, pBackColor : Integer; pBold, pItalic : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     06 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if (not self.hasHeading) then
		self.hasHeading := true;
	endif;

	if pForeColor &lt;&gt; null then
		self.accessCell(1,ColumnHeading).foreColor := pForeColor;
		self.accessCell(1,ColumnValue).foreColor := pForeColor;
	endif;

	if pBackColor &lt;&gt; null then
		self.accessCell(1,ColumnHeading).backColor := pBackColor;
		self.accessCell(1,ColumnValue).backColor := pBackColor;
	endif;
	
	self.accessCell(1,ColumnHeading).fontBold 	:= pBold;
	self.accessCell(1,ColumnValue).fontBold 	:= pBold;

	self.accessCell(1,ColumnHeading).fontItalic := pItalic;
	self.accessCell(1,ColumnValue).fontItalic := pItalic;

end;</source>
        <Parameter name="pForeColor" type="Integer"/>
        <Parameter name="pBackColor" type="Integer"/>
        <Parameter name="pBold" type="Boolean"/>
        <Parameter name="pItalic" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMyEntTableDef" id="93125272-ff63-4772-a025-8526e2b8ef9b">
        <updating/>
        <source>setMyEntTableDef(_entTableDef : EntTableDef) updating;
// ---------------------------------------------------------------------------
// Created:     20 October 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.myEntTableDef := _entTableDef;

end;</source>
        <Parameter name="_entTableDef" type="EntTableDef"/>
    </JadeMethod>
    <JadeMethod name="setObjectFromTable" id="b571f962-75a0-431a-b626-4c702f25a643">
        <updating/>
        <source>setObjectFromTable(obj : Object; _callBackMethod : String;
				_changedRowsOnly : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     12 December 2000 by cnwrs2
//
// Purpose:     NB The changed rows only param will only be effective if you
//				are setting the EntTableRow::hasChanged property during the edit session
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	propCol		: PropertyColl;
	propDict	: PropertyNDict;
begin

	create propDict transient;
	
	//added for par 16806 by cnwyl 23/05/2008
	if obj = null then
		return;
	endif;
	
	propCol := obj.class.allProperties();
	propCol.copy(propDict);

	self.setObjectFromTableWithProps(obj, _callBackMethod, _changedRowsOnly, propDict);

epilog
	delete propDict; 
	delete propCol;
	
end;</source>
        <Parameter name="obj" type="Object"/>
        <Parameter name="_callBackMethod" type="String"/>
        <Parameter name="_changedRowsOnly" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setObjectFromTableExHandler" id="2ac00c23-fa17-4c82-9be2-b7c704135360">
        <source>setObjectFromTableExHandler(e : Exception; _obj : Object; pAttrName : String; pStrValue : String) : Integer protected;
// ---------------------------------------------------------------------------
// Created:     12 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
constants
	String_To_Long		: Integer = 1035;	// String to long
	Prop_Not_Defined	: Integer = 1011;	// The requested property is not defined for this object class

vars
	prop	: Property;
	len		: Integer;
	class	: Class;
	obj: Object;
begin

	if _obj = null or				// exception must have occured prior to tmData being created
	   (e.errorCode &lt;&gt; String_To_Long and
	   e.errorCode &lt;&gt; Prop_Not_Defined) then
		return Ex_Pass_Back;
	endif;
	obj := _obj;
	class := obj.class;

	if e.errorCode = String_To_Long then
		//prop := class.getProperty(pAttrName);
		prop := class.getPropertyInHTree(pAttrName);	//26 Mar 2012	NDL	Par 29194 
		if prop &lt;&gt; null then
			len := prop.getLength -1;		// length allows for null terminator (I presume)
			if len &gt; 0 then					// length of -1 is for max-length strings
				obj.setPropertyValue(pAttrName, pStrValue[1:len]);
				if self.warningMethod &lt;&gt; null then
					self.form.sendMsgWithParams(self.warningMethod, self.name, method.name,
							'Attribute (' &amp; pAttrName &amp; ') on class (' &amp; class.name &amp; ') truncated ' &amp; pStrValue);
				endif;
				return Ex_Resume_Next;
			endif;
		endif;
	endif;

	if e.errorCode = Prop_Not_Defined then
		if self.warningMethod &lt;&gt; null then
			self.form.sendMsgWithParams(self.warningMethod, self.name, method.name,
						'Attribute (' &amp; pAttrName &amp; ') not found on class (' &amp; class.name &amp; ')');
		endif;
		return Ex_Resume_Next;
	endif;

	return Ex_Pass_Back;

end;</source>
        <access>protected</access>
        <Parameter name="e" type="Exception"/>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="pAttrName" type="String"/>
        <Parameter name="pStrValue" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setObjectFromTableWithProps" id="5a352918-f94f-4d8e-9474-2b03df011e1a">
        <updating/>
        <source>setObjectFromTableWithProps(_obj : Object; _callBackMethod : String;
				_changedRowsOnly : Boolean;
				_propDict : PropertyNDict) updating;
// ---------------------------------------------------------------------------
// Created:     12 December 2000 by cnwrs2
//
// Purpose:     NB The changed rows only param will only be effective if you
//				are setting the EntTableRow::hasChanged property during the edit session
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 05/10/2009	cnwdad1		PAR #20766.
// ---------------------------------------------------------------------------
vars
	numRows,
	tabPos,
	i,
	propLength			: Integer;
	propName			: String;
	tmpStr,
	strValue			: String;
	inType				: Integer;
	entRow 				: EntTableRow;
	property			: Property;
	propType			: Type;
	cntrl				: Control;
	cell				: JadeTableCell;
	cellBackColor		: Integer;
	theTime				: Time;
	theDate				: Date;
	changed,
	isVisible,
	changedRowsOnly		: Boolean;
	entRowTrans			: EntTableRowTransient;
	valueObj,
	targetObj			: Object;

	
begin
	on Exception do setObjectFromTableExHandler(exception, _obj, propName, strValue);
	
	//if _propDict.isEmpty then // Removed PAR 17591 cnwgb1 23 July 2008
	//	return;
	//endif;
	
	targetObj	:=	_obj;
	numRows		:=	self.rows;

	foreach i in self.fixedRows + 1 to numRows do

		entRowTrans := self.accessRow(i).itemObject.EntTableRowTransient;
		
		if entRowTrans = null then
			continue;
		endif;
		
		if entRowTrans.name = ETRow_HouseBillOfLading then
			write"";
			endif;
		
		if _changedRowsOnly then
			if not entRowTrans.hasChanged then
				continue;
			endif;
		endif;

		isVisible := self.accessedRow.visible;
		cell 		:= self.accessCell(i, ColumnValue);
		inType   	:= entRowTrans.inputType;
		
		//epr par 32357 16/9/13 needed to change because I had a ent table row that changed input type depending on its state
		if cell.inputType = Table.InputType_None then
			// ignore rows where inputType not allowed
			continue;
		endif;

		strValue 	:= cell.text.trimRight;
		cntrl 	 	:= cell.cellControl;
		if cntrl &lt;&gt; null and cntrl.name[1] = '_' then
			// this is a system control and not one of our custom controls
			cntrl := null;
		endif;

		cellBackColor := cell.backColor;


		if strValue &lt;&gt; null then
			// when using automaticCellControl and a combobox has a tab in the text
			// then this is copied into the cell.  We want just the first part
			tabPos := strValue.pos(Tab, 1);
			if tabPos &gt; 0 then
				if tabPos = 1 then
					strValue := null;
				else
					strValue := strValue[1:tabPos-1];
				endif;
			endif;
		endif;
		propName := entRowTrans.name;
		

		//call back method for rows that need to handled specially
		if _callBackMethod &lt;&gt; null then
			if self.form.sendMsgWithParams(_callBackMethod, propName, strValue, targetObj, self).Boolean then
				continue;
			endif;
		endif;
		if _propDict = null or _propDict.isEmpty then //PAR 17591 cnwgb1 23 July 2008
			continue;
		endif;
		// get the property from the object with the same name as the row attribute name
		property := _propDict[propName];
		
	
		if property = null then
			continue;
		endif;

		if property.virtual then
			// Added 31 Jan 2003 as problem if trying to set a virtual
			continue;
		endif;
		propLength:= property.getLength;
		propType := property.type;
		
			//if (not entRowTrans.visible) then	// this is
		if (not isVisible) then
			// set value to null for rows which are not visible
			if propType = Boolean then
				targetObj.setPropertyValue(propName, null.Boolean);
			elseif propType = Decimal then
				targetObj.setPropertyValue(propName, null.Decimal);
			elseif propType = Integer then
				targetObj.setPropertyValue(propName, null.Integer);
			elseif propType = Real then
				targetObj.setPropertyValue(propName, null.Real);
			elseif propType = String then
				targetObj.setPropertyValue(propName, null.String);
			elseif propType = Date then
				targetObj.setPropertyValue(propName, null.Date);
			elseif propType = Time then
				targetObj.setPropertyValue(propName, null.Time);
//			elseif propType = Binary then
//				obj.setPropertyValue(propName, null.Binary);
			else
				// unkown type so do nothing
				//obj.setPropertyValue(propName, null);
				if self.setObjectWarningMethod &lt;&gt; null then
					self.form.sendMsgWithParams(self.setObjectWarningMethod, self.name, propName,
							'Unhandled propType (' &amp; propType.name &amp; ') for property ' &amp; propName &amp; ' - cannot set to null as non-visible');
				endif;
			endif;
			continue;
		endif;
		
		if cntrl &lt;&gt; null then
			// this cell has a custom control
			if ComboBox.hasInstance(cntrl) and Reference.hasInstance(property) then
				// This is a custom control so see if the property is a reference
				// and try to set this reference to the currently selected object
				// in the combo box.
				if CMUI_ComboBoxObject.hasInstance(cntrl) then
					valueObj := cntrl.CMUI_ComboBoxObject.myObject;
					
// cnwdad1 05/10/20096 - PAR #20766.
					if valueObj = null and cntrl.ComboBox.listObject &lt;&gt; null then
						valueObj := cntrl.ComboBox.listObject;
					endif;
				else
					valueObj := cntrl.ComboBox.listObject;
				endif;
				if valueObj = null then
					targetObj.setPropertyValue(propName, null);
					continue;
				elseif valueObj.class = propType or valueObj.class.inheritsFrom(propType) then
				//changed by cnwyl1 for par 12194
				//it was..
				//elseif valueObj.class = propType
					targetObj.setPropertyValue(propName, valueObj);
					continue;
				endif;
			elseif CMUI_ComboPorts.hasInstance(cntrl) and propType = String then
				// If the code is not in the combo-list then it displays on the screen but
				// will get set to null when saved.  This preserves the existing value
				// refer PAR-13226
				tmpStr := cntrl.CMUI_ComboPorts.getCode();
				if tmpStr &lt;&gt; null then
					targetObj.setPropertyValue(propName, tmpStr);
				else
					//26 Mar 2012	NDL	Par 29194 - Null is valid, but no point in adding a value that is not a valid code...
					if strValue = null then
						targetObj.setPropertyValue(propName, strValue);
					endif;
					//targetObj.setPropertyValue(propName, strValue);				//-cnwml2 PAR22433
					//targetObj.setPropertyValue(propName, null);						//+cnwml2 PAR22433
				endif;
				continue;
			elseif ComboBox.hasInstance(cntrl) and propType = Integer then
				if cntrl.ComboBox.listIndex &gt; 0 then
					targetObj.setPropertyValue(propName, cntrl.ComboBox.itemData[cntrl.ComboBox.listIndex].Integer);
				endif;
				continue;
			endif;
			
//			if CMUI_TimeEntry.hasInstance(cntrl) and propType = Time then
//				obj.setPropertyValue(propName, cntrl.CMUI_TimeEntry.time);
//				continue;
//			endif;
		endif;

		// set value from celltype
		
		if inType = InputType_CheckBox and propType = Boolean then
			if strValue.length &gt; 0 and strValue[1] = '1' then
				targetObj.setPropertyValue(propName, true);
			else
				targetObj.setPropertyValue(propName, false);
			endif;

		elseif inType = InputType_ComboBox and propType = Boolean then
			if strValue = app.getYesNo(true) then
				targetObj.setPropertyValue(propName, true);
			elseif strValue = app.getYesNo(false) then
				targetObj.setPropertyValue(propName, false);
			endif;

		elseif propType = Binary then
			targetObj.setPropertyValue(propName, self.getPictureByName(propName));
			
		elseif propType = Integer then
			if inType = InputType_ColourSelection then
				targetObj.setPropertyValue(propName, cellBackColor);
			else
				//if strValue.Decimal &lt; 2147483647 then
				if strValue.asDecimalJMT &lt; 2147483647 then	//22 Oct 2015	NDL	Par 36655
					targetObj.setPropertyValue(propName, strValue.Integer);
				endif;
			endif;

		elseif propType = Decimal then
			//targetObj.setPropertyValue(propName, strValue.Decimal);
			targetObj.setPropertyValue(propName, strValue.asDecimalJMT);	//12 Sep 2012	NDL	Par 30350

		elseif propType = Real then
			//targetObj.setPropertyValue(propName, strValue.Real);
			targetObj.setPropertyValue(propName, strValue.asRealJMT);	//22 Oct 2015	NDL	Par 36655
		
		elseif propType = Date then
			theDate := strValue.asDateJMT();
			targetObj.setPropertyValue(propName, theDate);

		elseif propType = Time then
			theTime	:=	strValue.asTimeJMT();
			targetObj.setPropertyValue(propName, theTime);
			
		elseif propType = String then
			//if strValue.length &gt; propLength and propLength &gt; 1 then
			if strValue.length &gt; propLength-1 and propLength &gt; 1 then	// PAR 22399 18/02/2010
				targetObj.setPropertyValue(propName, strValue[1:propLength-1]);
			else
				targetObj.setPropertyValue(propName, strValue);
			endif;
		else
			if self.setObjectWarningMethod &lt;&gt; null then
				self.form.sendMsgWithParams(self.setObjectWarningMethod, self.name, propName,
						'Unhandled InputType/PropType (' &amp; inType.String &amp; '/' &amp; propType.name &amp; '::' &amp; propType.String &amp; ') for property ' &amp; propName &amp; ' - cannot set value');
			endif;
		endif;
  
	endforeach;

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_callBackMethod" type="String"/>
        <Parameter name="_changedRowsOnly" type="Boolean"/>
        <Parameter name="_propDict" type="PropertyNDict"/>
    </JadeMethod>
    <JadeMethod name="setOrigValueByName" id="fc10046c-a22e-45d7-a911-59a789259a51">
        <updating/>
        <source>setOrigValueByName(_attrName : String; _value : String) updating;
// TFS 2417 restore the ent row transient originalValue after it gets set incorrectly from table gotFocus after going to a separate form to create a cargo group
vars
	theRow	: Integer;
	entRowTrans	: EntTableRowTransient;
begin

	theRow := self.getRow(_attrName);
	if theRow &lt;&gt; 0 then
		entRowTrans := self.accessRow(theRow).itemObject.EntTableRowTransient;
		entRowTrans.originalValue := _value;
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="setPictureByName" id="2a743500-4837-4209-a4a6-9f8ac4df2509">
        <updating/>
        <source>setPictureByName(pName : String; pPicture : Binary) : Integer updating;
// ---------------------------------------------------------------------------
// Created:     09 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theRow	: Integer;
	cell	: JadeTableCell;
	
begin

	theRow := getRow(pName);
	
	if self.isValidRow(theRow) then
		cell := self.accessCell(theRow, ColumnValue);
		cell.picture := pPicture;
	else
		if self.warningMethod &lt;&gt; null then
			self.form.sendMsgWithParams(self.warningMethod, self.name, method.name, 'Cannot set picture for row (' &amp; pName &amp; ') - not found on table');
		endif;
	endif;

	return theRow;

end;</source>
        <Parameter name="pName" type="String"/>
        <Parameter name="pPicture" type="Binary"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromMeasureTables" id="3ae9e5d2-5d00-42b0-aa5b-6616f73cc85c">
        <updating/>
        <source>setProxyFromMeasureTables(_pxyObject : Object input) updating;
/*
Purpose:			Read collectinos of transient ent table rows, extracting value from table
					for those rows that are measurement-type rows

Parameters:			_pxyObject - proxy of the object being updated

Return Value:		Updated proxy object

Date		Who		Reason
05/03/2013	cnwdap1	Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
13/11/2013	cnwdap1	PAR #32960 Wasn't resetting valueStr, so if any subsequent measurements were null, they were being set to the first measurement
11/03/2014	cnwdap1	PAR #33603 Correct measurement handling for locales - can't use Comma as a delimiter, as some locales (e.g. Italian) use this
					as a decimal separator, can't cast as Decimal otehrwise we lose locale-based information
*/
vars
	obj					: Object;
	row 				: EntTableRowTransient;
	tableValue			: String;
	pos					: Integer;
	measureCode			: String;
	value				: Decimal [23, 10];
	valueStr			: String;
	rowName, measure	: String;
	//commaPos, endPos		: Integer;		// PAR #33603
	semiColonPos, endPos	: Integer;		// PAR #33603

begin
	foreach obj in self.allEntRowTransients do
		row := obj.EntTableRowTransient;
		if not row.name.isMeasurementType then
			continue;
		endif;
		row.name.getRowNameMeasureType(rowName, measure);
		tableValue := self.getValueByName(row.name).String;
		pos := tableValue.pos(Space, 1);
		//commaPos := tableValue.pos(Comma, 1);				// PAR #33603
		//if commaPos &lt;&gt; null then							// PAR #33603
		//	endPos := commaPos - pos - 1;					// PAR #33603
		semiColonPos := tableValue.pos(SemiColon, 1);		// PAR #33603
		if semiColonPos &lt;&gt; null then						// PAR #33603
			endPos := semiColonPos - pos - 1;				// PAR #33603
		else
			endPos := tableValue.length;
		endif;
		if pos &lt;&gt; null then
			valueStr := tableValue[1:pos-1];
			measureCode := tableValue[pos+1:endPos];
		else
			if tableValue[1:6] = Prefix_Weight then
				value := NULL_WEIGHT;
			elseif tableValue[1:6] = Prefix_Volume then
				value := NULL_VOLUME;
			else
				value := null;
			endif;
			valueStr := null;								// PAR #32960
		endif;
		if measureCode = null then
			measureCode := measureCode;
		endif;
		//value := app.convertMeasurementForStorage(measureCode, valueStr.Decimal);			// PAR #33603
		value := app.convertMeasurementForStorage(measureCode, valueStr.asDecimalJMT);		// PAR #33603
		_pxyObject.setMeasurementValue(rowName, value);
	endforeach;
		
epilog

end;</source>
        <Parameter name="_pxyObject" type="Object" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setRowNamesFromTerminology" id="8e5b39f3-3eb0-4e61-9ee8-e8aaf622e370">
        <updating/>
        <source>setRowNamesFromTerminology()updating;
// ---------------------------------------------------------------------------
// Created:     06 May 2005	cnwhjg1
//
// Purpose:     To get gateIn screen working. - works differently due to cloned 
//				sheets. This method changes the row headings depending on 
//				termnology set on table. Using other method loadEntRowTransients() 
// 				reformats table and can cause problem if changing table on cloned 
//				sheet. If cargo or terminal is beeing changed then need to call 
//				set termnology method for table before calling this. 
// ----------   ----------  --------------------------------------------------
vars
	entRowTrans 	: EntTableRowTransient;
	entRow,entRow2	: EntTableRow;
	rows, row 		: Integer;
	jadeRow 		: JadeTableRow;
	str 			: String;
	entRows			: EntTableRowArray;
begin

	// get entRows from def so can use for current Terminology
	entRows := self.myEntTableDef.allEntTableRows;
	
	rows := self.rows;
	row := 1;

	// go through each row of the table and change the terminology
	while row &lt;= rows do 
		jadeRow := self.accessRow(row);
	
// Do for all rows as some may be hidden/shown at later date without cargo type change
//		if jadeRow.visible = true then 
	
		if not jadeRow.itemObject.isKindOf(EntTableRowTransient) then 
			return; 
		endif;	
		
		// Terminology comes off entTableRow so need to get entRowTransient 
		// to find matching entRow off myEntTableDef . 
		entRowTrans := jadeRow.itemObject.EntTableRowTransient;
			
		// quick check: Highly likely that array on entDef and Table are in same order
		if row &lt;= entRows.size then  // make sure check is in array bounds
			entRow := entRows[row];
		endif;
							
		if entRow &lt;&gt; null and entRow.name = entRowTrans.name then //They match!
			str := entRow.getHeading(self.myTerminologyCargoBOLType, self.myTerminologyTerminal, app.myCurrentLocale);
			entRowTrans.setBasicDetails(entRow.name, str, entRow.inputType, true, entRow.visible);
			self.accessCell(row, ColumnHeading).text := str;
		else
		// if didnt find straight match then search through array for match
			foreach entRow in entRows do 
				if entRow.name = entRowTrans.name then // match!
					str := entRow.getHeading(self.myTerminologyCargoBOLType, self.myTerminologyTerminal, app.myCurrentLocale);
					entRowTrans.setBasicDetails(entRow.name, str, entRow.inputType, true, entRow.visible);
					self.accessCell(row, ColumnHeading).text := str;
					break; // found match so leave foreach 
				endif;
			endforeach;
				// if no match then no change to terminology	
		endif;
		row := row +1;
		entRow := null; // reset for next loop through
	endwhile;
end;</source>
    </JadeMethod>
    <JadeMethod name="setRowReadOnly" id="60a43def-7fb3-4f44-8fa5-be356a4931c9">
        <updating/>
        <source>setRowReadOnly(_entRowName : String) updating;
/*
Set read only like on the Cargo Enquiry screen

Date		Who		Reason
05 April 2016	cnwer1	Initial creation TFS 1707

*/

vars		
	theRow	: Integer;
	
begin
	theRow := self.getRow(_entRowName);
	
	if theRow &lt;&gt; 0 then
		self.disableRow(theRow);
	
		self.accessedCell.backColor := self.ReadOnlyRowColour;
	endif;
epilog

end;</source>
        <Parameter name="_entRowName" type="String"/>
    </JadeMethod>
    <JadeMethod name="setSelectionStyle" id="fb37b32b-7d9f-4b44-a917-14cf0a645346">
        <updating/>
        <source>setSelectionStyle(theRow : Integer; _selectAll : Boolean) updating;

vars
	ctrl 	: Control;
	txtBox	: TextBox;
begin

	if theRow = 0 or theRow &gt; self.rows then
		return;
	endif;

	ctrl := self.accessCell(theRow, ColumnValue).cellControl;
	
	if ctrl &lt;&gt; null then
		if TextBox.hasInstance(ctrl) then
			txtBox := ctrl.TextBox;
			txtBox.selectionStyle := TextBox.SelectionStyle_SelectAll;
			if _selectAll then
				txtBox.selStart 	:= 0;
				txtBox.selLength	:= -1;	// select all
			endif;
			txtBox.case := TextBox.Case_None;	//21 Feb 2019	NDL	TFS 43527
		elseif JadeEditMask.hasInstance(ctrl) then
		   	ctrl.JadeEditMask.selectionStyle := JadeEditMask.SelectionStyle_Select;
		endif;
	endif;

end;</source>
        <Parameter name="theRow" type="Integer"/>
        <Parameter name="_selectAll" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setTableFromCM_Object" id="247202fe-a0c2-4238-b6ec-97b04ef05f27">
        <updating/>
        <source>setTableFromCM_Object(_obj : CM_Object; _specialsMethodName : String) updating;
/*
----------   ----------  --------------------------------------------------
Created:	02 May 2007 By cnwth2

Purpose:	as per setTableFromObject but uses getDisplayStringForAttribute - why the original
			setTableFromObject method does not do this is beyond me, as getDisplayStringForAttribute
			eventually does a getPropertyValue at the CM_Object level anyway.

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	numRows,
	i			: Integer;
	propName	: String;	
	property	: Property;
	propType	: Type;
	cellCntrl	: Control;
	jCell		: JadeTableCell;
	entRowTrans	: EntTableRowTransient;
	valueStr	: String;
begin
	on Exception do setObjectFromTableExHandler(exception, _obj, propName, propName);

	numRows := self.rows;
	foreach i in self.fixedRows + 1 to numRows do
		
		
		entRowTrans := self.accessRow(i).itemObject.EntTableRowTransient;
		if entRowTrans = null then
			continue;
		endif;

		propName := entRowTrans.name;
		if _specialsMethodName &lt;&gt; null then
			if self.form.sendMsgWithParams(_specialsMethodName, self, propName, i, _obj).Boolean then
				continue;
			endif;
		endif;
		// get the property from the object with the same name as the row attribute name
		valueStr := _obj.getDisplayStringForAttribute(propName, false);
		
		self.setValue(i, valueStr);  		
  	endforeach;
 
end;</source>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_specialsMethodName" type="String"/>
    </JadeMethod>
    <JadeMethod name="setTableFromObject" id="8353388b-86ff-4b08-90b1-73e9a127f768">
        <updating/>
        <source>setTableFromObject(obj : Object; pSpecialsMethodName : String) updating;
// ---------------------------------------------------------------------------
// Created:     12 December 2000 by cnwrs2
//
// Purpose:     Looks at the attributes in the table and if a property
//				with the same attribute name exists on the object
//				then sets this to the table.
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	numRows,
	i			: Integer;
	propName	: String;	
	property	: Property;
	propType	: Type;
	cntrl		: Control;
	cell		: JadeTableCell;
	entRowTrans		: EntTableRowTransient;
	tmpValue	: Any;
	invalidObj  : Boolean;
begin
	on Exception do setObjectFromTableExHandler(exception, obj, propName, propName);
	
	on Exception do app.handleDeletedObject(exception, obj, invalidObj);
	
	/*
		Date		      Who		Reason
		31 July 2008	cnwdz2	    Par16856 
	*/

	if obj = null then		
		return;
	endif;
	
	numRows := self.rows;
	foreach i in self.fixedRows + 1 to numRows do
		entRowTrans := self.accessRow(i).itemObject.EntTableRowTransient;
		if entRowTrans = null then
			continue;
		endif;

		propName := entRowTrans.name;
		if pSpecialsMethodName &lt;&gt; null then
			if self.form.sendMsgWithParams(pSpecialsMethodName, self, propName, i, obj).Boolean then
				continue;
			endif;
		endif;
		
		// get the property from the object with the same name as the row attribute name
		property := obj.class.getPropertyInHTree(propName);				
		
		if property = null then
				if self.setObjectWarningMethod &lt;&gt; null then
				self.form.sendMsgWithParams(self.setObjectWarningMethod, self.name, propName,
						'Property (' &amp; propName &amp; ') not found on ' &amp; obj.class.name);
			endif;
			continue;
		endif;
		if Reference.hasInstance(property) then
			if self.setObjectWarningMethod &lt;&gt; null then
				self.form.sendMsgWithParams(self.setObjectWarningMethod, self.name, propName,
						'Property (' &amp; propName &amp; ') is a reference - cannot set');
			endif;
			continue;
		endif;
		cell := self.accessCell(i, ColumnValue);
		cntrl 	 := cell.cellControl;

		propType := property.type;
		
		if cntrl &lt;&gt; null and cntrl.name[1] = '_' then
			// this is a system control and not one of our custom controls
			cntrl := null;
		endif;

		

		tmpValue := obj.getPropertyValue(propName);


		if cntrl &lt;&gt; null then
			// this cell has a custom control
//			if CMUI_TimeEntry.hasInstance(cntrl) and propType = Time then
//				cntrl.CMUI_TimeEntry.time := tmpValue.Time;
//				self.setValue(i, tmpValue.Time);
//				continue;
//			endif;
		endif;
		// set value from celltype
		self.setValue(i, tmpValue);
  		
  	endforeach;
 
end;</source>
        <Parameter name="obj" type="Object"/>
        <Parameter name="pSpecialsMethodName" type="String"/>
    </JadeMethod>
    <JadeMethod name="setTableFromSelector" id="0d82378f-5a92-4621-997a-22cfded75ba0">
        <updating/>
        <source>setTableFromSelector( _lineHolder : CM_QueryCriteriaLineHolder input;
					   _context : String;
						_multiSelectFrame : CMUI_Frame;
					   _eventMapping : Method input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 December 2019	jlger1	Initial creation 47132

*/
constants
	CmbPrefix = "cmbQ";
vars
	criteriaLine : CM_SelectorCriteriaLine;
	newRow, controlType : Integer;
	row : JadeTableRow;
	jadeCell	: JadeTableCell;
	newCombo : CMUI_ComboBox;
	niceName  : String;
	timeRange : CM_QTimeRange;
	dateRange : CM_QDateRange;
	dateDayRange : CM_QDateDayRange;
begin
	if _lineHolder = null then
		return;
	endif;
	if _lineHolder.allCriteriaLines = null then
		return;
	endif;

	_lineHolder.context:=_context;

	self.clear;
	self.rows:=0;
	self.accessedSheet.itemObject:=_lineHolder;

	
	foreach criteriaLine in _lineHolder.allCriteriaLines discreteLock do
		if criteriaLine.myQueryProperty = null or
			 criteriaLine.myQueryOperator = null then
			continue;
		endif;
		
		if criteriaLine.propName = CM_TrackedItem::myTerminal.name then
			continue;
		endif;
		if criteriaLine.isUnavailableAtRunTime  then
			continue;
		endif;
	
		newRow := self.addItem('');
		self.accessRow(newRow).itemObject:=criteriaLine;
		jadeCell:=self.accessCell(newRow, CM_EntryTable.ColumnHeading);
		niceName:=null;
		if _context = CM_ContainerEnqForm.name and self.form &lt;&gt; null then
			niceName:=self.form.CM_ContainerEnqForm.getColHeadingForQueryProperty(criteriaLine.myQueryProperty.propertyName);
		endif;
		if niceName = null then
			niceName:= criteriaLine.myQueryProperty.niceName;
		endif;
		
		jadeCell.text := niceName;
		jadeCell.alignment := CM_EntryTable.Alignment_Left_Top;
		
		controlType := criteriaLine.getControlType();
		jadeCell := self.accessCell(newRow,CM_EntryTable.ColumnValue);
		if controlType  = QueryControl_TextBox then
			 jadeCell.inputType:= Table.InputType_TextBox;
			 jadeCell.text:=criteriaLine.myQueryOperator.getSearchValueStr(criteriaLine.myQueryProperty);
			if jadeCell.cellControl &lt;&gt; null then
				jadeCell.cellControl.TextBox.case := TextBox.Case_Upper;
			endif;
			jadeCell.alignment := Table.Alignment_Left_Top;
			if _context = CM_ContainerEnqForm.name and  criteriaLine.propName = CM_TrackedItem::id.name then
				row :=self.accessedRow;
				
				if row &lt;&gt; null then	
					row.height := row.height * 3;
				endif;
			endif;
		elseif controlType = QueryControl_ComboBox then
			jadeCell.inputType:= Table.InputType_TextBox;
			// need to add cloned combobox with 
			newCombo:= self.form.getControlByName(CmbPrefix &amp; criteriaLine.propName).CMUI_ComboBox;
			if newCombo = null then
				create newCombo transient;
				newCombo.name:=CmbPrefix &amp; criteriaLine.propName;
				if app.doNotFIlterCombos then // ### TFS 55105 07NOV2022 NAVAB1
					newCombo.style:=ComboBox.Style_DropDownComboList;
				endif;
				self.form.addControl(newCombo);
				newCombo.setEventMappingEx(ComboBox::lostFocus,_eventMapping);
			else
				newCombo.listIndex:=-1;
				newCombo.text:=null;
			endif;
			newCombo.tag:=newRow.String;
			newCombo.sorted:=true;
			//epr TFS 47132 29/1/19 noticed combos not sorting - but wanted site to not be sorted and have a **anywhere** entry like it used to 
			if _context = CM_ContainerEnqForm.name  and criteriaLine.propName = CM_TrackedItem::site.name then
				newCombo.sorted:=false;	
			endif;
			
			if _context = CM_ContainerEnqForm.name  and self.form &lt;&gt; null  and   criteriaLine.propName = CM_TrackedItem::voyageCode.name then
				self.form.CM_ContainerEnqForm.loadVoyageCombo(newCombo, criteriaLine);
			else
						
				criteriaLine.myQueryProperty.setComboValues(newCombo,_lineHolder,criteriaLine.myQueryOperator,app.myPassport);
				if _context = CM_ContainerEnqForm.name  and criteriaLine.propName = CM_TrackedItem::site.name then
					newCombo.addItemAt(CM_ContainerEnqForm.ANYSITE_STRING,1);
					newCombo.listIndex:=2;
				endif;
			endif;
			
			
			jadeCell.cellControl:=newCombo;
			jadeCell.text:=newCombo.text;
			
			if newCombo.listIndex &lt;= 0 then
				criteriaLine.myQueryOperator.setSearchValue(null);
			endif;
		elseif controlType = QueryControl_MultiSelect  then			
			jadeCell.inputType:= Table.InputType_TextBox;
			jadeCell.cellControl:=_multiSelectFrame;
			jadeCell.itemObject:=criteriaLine;
			jadeCell.text:=criteriaLine.myQueryOperator.getSearchValueStr(criteriaLine.myQueryProperty);
			if _multiSelectFrame &lt;&gt; null then
				self.accessRow(newRow).height:=_multiSelectFrame.clientHeight + 5;
			endif;
		elseif controlType = QueryControl_Date then
			self.initCellForDate(jadeCell);
			jadeCell.text:=criteriaLine.myQueryOperator.getSearchValueStr(criteriaLine.myQueryProperty);
		elseif controlType = QueryControl_DateRange then
		//	CMUI_Date
			dateRange:=criteriaLine.myQueryOperator.CM_QDateRange;
			self.accessCell(newRow, CM_EntryTable.ColumnHeading).text:= self.accessCell(newRow, CM_EntryTable.ColumnHeading).text &amp; Space &amp; app.getErrorString(From);
			jadeCell := self.accessCell(newRow,CM_EntryTable.ColumnValue);
			self.initCellForDate(jadeCell);
			jadeCell.text:=dateRange.fromDate.asStringJMT;
			
			newRow := self.addItem('');
			self.accessRow(newRow).itemObject:=criteriaLine;
			jadeCell:=self.accessCell(newRow, CM_EntryTable.ColumnHeading);
			jadeCell.text := criteriaLine.myQueryProperty.niceName &amp; Space &amp; app.getErrorString(To);
			jadeCell.alignment := CM_EntryTable.Alignment_Left_Top;
			jadeCell := self.accessCell(newRow,CM_EntryTable.ColumnValue);
			self.initCellForDate(jadeCell);
			jadeCell.text:=dateRange.toDate.asStringJMT;				
		elseif controlType = QueryControl_Time then
			self.initCellForTime(jadeCell);
			jadeCell.text:=criteriaLine.myQueryOperator.getSearchValueStr(criteriaLine.myQueryProperty);
		elseif controlType = QueryControl_TimeRange then
			timeRange:=criteriaLine.myQueryOperator.CM_QTimeRange;
			
			self.accessCell(newRow, CM_EntryTable.ColumnHeading).text:= self.accessCell(newRow, CM_EntryTable.ColumnHeading).text &amp; Space &amp; app.getErrorString(From);
			jadeCell := self.accessCell(newRow,CM_EntryTable.ColumnValue);
			self.initCellForTime(jadeCell);
			jadeCell.text:=timeRange.fromTime.asStringJMT;
			
			newRow := self.addItem('');
			self.accessRow(newRow).itemObject:=criteriaLine;
			jadeCell:=self.accessCell(newRow, CM_EntryTable.ColumnHeading);
			jadeCell.text := criteriaLine.myQueryProperty.niceName &amp; Space &amp; app.getErrorString(To);
			jadeCell.alignment := CM_EntryTable.Alignment_Left_Top;
			jadeCell := self.accessCell(newRow,CM_EntryTable.ColumnValue);
			self.initCellForTime(jadeCell);
			jadeCell.text:=timeRange.toTime.asStringJMT;
		elseif controlType = QueryControl_NumTextBoxRange then
			dateDayRange:=criteriaLine.myQueryOperator.CM_QDateDayRange;
			self.accessCell(newRow, CM_EntryTable.ColumnHeading).text:= self.accessCell(newRow, CM_EntryTable.ColumnHeading).text &amp; Space &amp; app.getErrorString(From)  ;
			jadeCell := self.accessCell(newRow,CM_EntryTable.ColumnValue);
			jadeCell.inputType :=Table.InputType_TextNumeric;
			jadeCell.text:=dateDayRange.fromNumDays.asStringJMT;
			
			newRow := self.addItem('');
			self.accessRow(newRow).itemObject:=criteriaLine;
			jadeCell:=self.accessCell(newRow, CM_EntryTable.ColumnHeading);
			jadeCell.text := criteriaLine.myQueryProperty.niceName &amp; Space &amp; app.getErrorString(To);
			jadeCell.alignment := CM_EntryTable.Alignment_Left_Top;
			jadeCell := self.accessCell(newRow,CM_EntryTable.ColumnValue);
			jadeCell.inputType :=Table.InputType_TextNumeric;
			jadeCell.text:=dateDayRange.toNumDays.asStringJMT;
		endif;
		
		
		
		if not criteriaLine.showCriteria(_lineHolder) then
			self.hideRow(newRow);
		endif;
	endforeach;
	
	self.optimiseHeadingColumn;

epilog

end;</source>
        <Parameter name="_lineHolder" type="CM_QueryCriteriaLineHolder" usage="input"/>
        <Parameter name="_context" type="String"/>
        <Parameter name="_multiSelectFrame" type="CMUI_Frame"/>
        <Parameter name="_eventMapping" type="Method" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setValue" id="a5466498-e81f-404e-a2d3-924b9f2781dd">
        <updating/>
        <source>setValue(pRow : Integer; pValue : Any) updating;
// ---------------------------------------------------------------------------
// Created:     09 November 2000 by cnwrs2
//
// Purpose:     
//
// Changed On	By			Reason
// ---------------------------------------------------------------------------
// 26/10/2012	cnwdap1		PAR #30247 Correct date handling for different locales
// 23 May 2016	cnwns1	TFS 488 - Multi Timezone Support

vars
	cell				: JadeTableCell;
	entRowInputType,
	cellInputType,
	numDecimals,
	startPos			: Integer;
	valueStr,
	noTabString			: String;
	entRowTrans			: EntTableRowTransient;
	obj					: Object;
	ctrl				: Control;
	
begin

	if self.isValidRow(pRow) then
		obj := self.accessRow(pRow).itemObject;
		
		if (obj = null) or (not EntTableRowTransient.hasInstance(obj)) then
			return;
		endif;
		entRowTrans := obj.EntTableRowTransient;
		
		cell := self.accessCell(pRow, ColumnValue);
		
//		if (not entRowTrans.isOriginalValueSet) then
//			entRowTrans.originalValue := pValue.String;
//		endif;

		entRowInputType := entRowTrans.inputType;
		cellInputType	:= cell.inputType;
		if entRowInputType = InputType_CheckBox then
			if pValue.isKindOf(String) and 
			    (pValue.String[1] = '1' or pValue.String = app.getYesNo(true)) then // par 17461 display yes for the inoput string "Yes". --cnwdz2  
				// if value sometimes comes through as number
				cell.text := '1';
			else
				cell.text := pValue.Boolean.cnEcGetTableCheckBoxValue;	
			endif;
						
		elseif entRowInputType = InputType_Date then
		//epr par 12833 19/10/06 changed from and to or
			// PAR #30247 if locale has mm/dd date format, casting pValue as a Date below
			// was defaulting the date to dd/mm format, and screwing up the date processing
			//if (pValue.isKindOf(Date) or pValue.Date.isValid) then					// PAR #30247
			if pValue.isKindOf(Date) then												// PAR #30247
				cell.text := pValue.Date.shortFormatJMT();
			// PAR #30247 so do the string processing separately, ensuring we use JMT date methods
			// to convert each way
			elseif pValue.isKindOf(String) and pValue.String.asDateJMT.isValid() then	// PAR #30247
				cell.text := pValue.String.asDateJMT.shortFormatJMT();					// PAR #30247
			elseif pValue.isKindOf(String) then
				cell.text := pValue.String;
			else
				cell.text := null;
			endif;

		elseif entRowInputType = InputType_Time then
			if (pValue.isKindOf(Time) or pValue.isKindOf(String)) and 
			   pValue.Time.isValid then
// cnwdad1 17/06/2009 - PAR #19942.
				//cell.text := pValue.Time.currentLocaleFormatJMT();
				cell.text := pValue.Time.format(app.getTimeShortFormat(false));
			else
				cell.text := null;
			endif;
		//elseif (pValue.isKindOf(TimeStamp) or pValue.isKindOf(String)) and 	// 13/06/2016 TFS 2145 terminal area staggering heights of 3,3,3,3,3 was being displayed as a TimeStamp
		elseif pValue.isKindOf(TimeStamp) and 
			   pValue.TimeStamp.isValid then
				cell.text := pValue.TimeStamp.shortCurrentLocaleFormat();	// 23 May 2016	cnwns1	TFS 488 - Multi Timezone Support  - TFS 2679:Multi-timezone issues
		
		elseif (cellInputType = InputType_ComboBox) and (entRowInputType = InputType_ColourSelection) then
			cell.backColor := pValue.Integer;
			cell.foreColor := pValue.Integer.getInverseColour();

		elseif entRowInputType = InputType_Picture then
			//Check we can accommodate the type as .gifs are not yet supported by Jade.
			if pValue.Binary.isPictureValid then
				cell.picture := pValue.Binary;
			endif;

		else
			if cellInputType = Table.InputType_TextNumeric or 
			   cellInputType = Table.InputType_SignedNumeric then

				if pValue = null and entRowTrans.displayNullIfZero then
					valueStr := null;
				elseif pValue.isKindOf(String) and
					   pValue.String = null then
					   /*and
					   (entRowTrans.name = ETRow_CarriageTempF or
					   entRowTrans.name = ETRow_CarriageTempC or
					   entRowTrans.name = ETRow_PackTempF or
					   entRowTrans.name = ETRow_PackTempC)
					   then
					   */
					valueStr := null;
				else
					numDecimals := cell.decimals;
					if pValue.isKindOf(Real) then
						valueStr := pValue.Real.roundedTo(numDecimals).asStringJMT;
					elseif pValue.isKindOf(Decimal) then
						valueStr := pValue.Decimal.roundedTo(numDecimals).asStringJMT();
					elseif pValue.isKindOf(String) then						
						valueStr := pValue.String.asDecimalJMT.roundedTo(numDecimals).asStringJMT;	//asStringJMT();
					else
						valueStr := pValue.Decimal.roundedTo(numDecimals).asStringJMT;	//asStringJMT();
						// PAR 13701
						// Need to assume a decimal and roundedTo will return a
						// decimal of the precision indicated by numDecimals so
						// we get the correct trailing zeros.
						//valueStr := pValue.Real.roundedTo(numDecimals).String;
					endif;
				endif;
			
			elseif pValue = null then
				valueStr := null;					
			
			elseif pValue.isKindOf(Date) then
				valueStr := pValue.Date.shortFormatJMT();
			elseif pValue.isKindOf(Decimal) then
				valueStr := pValue.Decimal.asStringJMT();
			else
				valueStr := pValue.String;
			endif;

			if cell.text &lt;&gt; valueStr then 		
				//ctrl := cell.cellControl;
				//if ctrl &lt;&gt; null
				//and ComboBox.hasInstance(ctrl) or  TextBox.hasInstance(ctrl) and valueStr &lt;&gt; null then
					cell.text := valueStr;
					cell.alignment := Alignment_Left_Top;
					if self.optimiseRowHeight then
						// PAR 9317 
						self.optimiseHeightForRow(cellInputType, pRow, valueStr);
					endif;
				//endif;
			endif;
			
			if pValue = null then
				// we are clearing the values
				ctrl := cell.cellControl;
				if ctrl &lt;&gt; null
				and ctrl.name[1] &lt;&gt; '_' then // This is NOT one of our controls.
				   	// this is one of our controls
				   	if ComboBox.hasInstance(ctrl) then
				   		ctrl.ComboBox.listObject := null;
				   	elseif TextBox.hasInstance(ctrl) then
				   		ctrl.TextBox.text := null;
				   	endif;
				endif;
			endif;
		endif;

		//+cnwml2 PAR24259
		if not entRowTrans.isOriginalValueSet then//entRowTrans.originalValue = null then //06/01/2011 cnwdz2 26620 self.loadEntRowTransients
		                                                                                  //set entRowTrans.originalValue and then set entRowTrans.isOriginalValueSet to true;
			if not entRowTrans.hasChanged then
				entRowTrans.originalValue := cell.text;
				entRowTrans.isOriginalValueSet := true;
			endif;
		endif;
		//entRowTrans.isOriginalValueSet := true;
		
	else
		if self.warningMethod &lt;&gt; null then
			self.form.sendMsgWithParams(self.warningMethod, self.name, method.name, 'Cannot set value for row (' &amp; pRow.String &amp; ') - invalid row');
		endif;
	endif;
end;</source>
        <Parameter name="pRow" type="Integer"/>
        <Parameter name="pValue" type="Any"/>
    </JadeMethod>
    <JadeMethod name="setValueByControlName" id="d9c530c0-94df-47ad-a758-b2690286dfbd">
        <updating/>
        <source>setValueByControlName(pControlName : String; pValue : Any) : Integer updating;
/* ---------------------------------------------------------------------------
Created:     19 January 2001 by cnwrs2

Purpose:     

Parameters:  None

Returns:     Nothing

Changed On  By  	TFS		Reason
----------  ------  ------	-----------------------------------------------
26 Nov 2019	jlgdi1	47736	Efficiently identify the corresponding row number on the table using the control name 
							to deal with entries with no equivalent form controls like separator rows
--------------------------------------------------------------------------- */
vars
	maxRows,
	idx,
	theRow	: Integer;
	entRowTrans : EntTableRowTransient;
		
begin
	/* don't require a def to do this - just check the entRowTransients
	if self.myEntTableDef = null then
		if self.warningMethod &lt;&gt; null then
			self.form.sendMsgWithParams(self.warningMethod, self.name, method.name, 'Cannot set value by controlName (' &amp; pControlName &amp; ') - myEntTableDef is null');
		endif;
		return 0;
	endif;
	
	theRow := self.myEntTableDef.getRowByControlName(pControlName);
	*/
	
	maxRows := self.allEntRowTransients.size;
	foreach idx in 1 to maxRows do
		entRowTrans := self.allEntRowTransients[idx].EntTableRowTransient;
		if entRowTrans.controlName = pControlName then
			theRow := idx;
			//+cnwml2 PAR26402
			if entRowTrans.originalValue &lt;&gt; pValue.asStringJMT() then
				entRowTrans.hasChanged := true;
			endif;
			break;
		endif;
	endforeach;
		
	if theRow &lt;&gt; 0 then
		// identify the corresponding row number in the table using the control name (attribute name) due to scenario
		// that table grid may have entry with no corresponding form controls like separator row (ex. Selector query that has multiple sheets)
		theRow := self.getRowByName(entRowTrans.name);
	
		self.setValue(theRow, pValue);
	else
		if self.warningMethod &lt;&gt; null then
			self.form.sendMsgWithParams(self.warningMethod, self.name, method.name, 'Cannot set value by controlName (' &amp; pControlName &amp; ') - not found on table');
		endif;
	endif;
	
	return theRow;

end;</source>
        <Parameter name="pControlName" type="String"/>
        <Parameter name="pValue" type="Any"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setValueByName" id="ed766c6e-b976-43e0-870c-3026ae8e4f64">
        <updating/>
        <source>setValueByName(pName : String; pValue : Any) : Integer updating;
// ---------------------------------------------------------------------------
// Created:     09 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theRow	: Integer;

begin
	
	theRow := self.getRow(pName);

	if theRow &lt;&gt; 0 then
		self.setValue(theRow, pValue);
	else
		if self.warningMethod &lt;&gt; null then
			self.form.sendMsgWithParams(self.warningMethod, self.name, method.name, 'Cannot set value by name (' &amp; pName &amp; ') - not found on table');
		endif;
	endif;

	return theRow;

end;</source>
        <Parameter name="pName" type="String"/>
        <Parameter name="pValue" type="Any"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setValueByNameTemplate" id="5b28969e-f6d3-48ae-ba68-c7d073d5e88c">
        <updating/>
        <source>setValueByNameTemplate(pName : String; pValue : String) : Integer updating;
// ---------------------------------------------------------------------------
// Created:     09 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theRow	: Integer;
	cell	: JadeTableCell;
	ctrl	: Control;

begin

	theRow := self.getRow(pName);
	
	if theRow &lt;&gt; 0 then
		if self.isValidRow(theRow)  then
			cell := self.accessCell(theRow, ColumnValue);
			if cell.text &lt;&gt; pValue then
				cell.text := pValue.String;
				cell.alignment := Alignment_Left_Top;
				if self.optimiseRowHeight then
					// PAR 9317 
					self.optimiseHeightForRow(InputType_TextBox, theRow, pValue);
				endif;
			endif;
			
			if pValue &lt;&gt; null then
				// we are clearing the values
				ctrl := cell.cellControl;
				if ctrl &lt;&gt; null
				and ctrl.name[1] &lt;&gt; '_' then // This is NOT one of our controls.
				   	// this is one of our controls
				   	if ComboBox.hasInstance(ctrl) then
				   		ctrl.ComboBox.listIndex := ctrl.ComboBox.findString(1, pValue); 
				   endif;
				endif;
			endif;
		endif;
	else
		if self.warningMethod &lt;&gt; null then
			self.form.sendMsgWithParams(self.warningMethod, self.name, method.name, 'Cannot set value by name (' &amp; pName &amp; ') - not found on table');
		endif;
	endif;

	return theRow;

end;</source>
        <Parameter name="pName" type="String"/>
        <Parameter name="pValue" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setValueColumn" id="ca20cb44-d9b8-4816-8f95-cff2be1630b3">
        <updating/>
        <source>setValueColumn(pForeColor, pBackColor : Integer; pBold, pItalic : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     06 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if pForeColor &lt;&gt; 0 then
		self.accessColumn(ColumnValue).foreColor := pForeColor;
	endif;

	if pBackColor &lt;&gt; 0 then
		self.accessColumn(ColumnValue).backColor := pBackColor;
	endif;
	
	self.accessColumn(ColumnHeading).fontBold 	:= pBold;
	self.accessColumn(ColumnHeading).fontItalic := pItalic;

end;</source>
        <Parameter name="pForeColor" type="Integer"/>
        <Parameter name="pBackColor" type="Integer"/>
        <Parameter name="pBold" type="Boolean"/>
        <Parameter name="pItalic" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setValueColumnWidth" id="676aaf57-cd75-4da0-bbb6-ca35410435fd">
        <updating/>
        <source>setValueColumnWidth() updating;
// ---------------------------------------------------------------------------
// Created:     09 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpVal	: Integer;

begin

	if self.columns &lt; ColumnValue then
		return;
	endif;

	tmpVal := (self.width - self.accessColumn(ColumnHeading).width).Integer;
	
	if self.parentAspect &lt;&gt; Control.ParentAspect_None then
		self.accessColumn(ColumnValue).width := 2000;
		return;
	endif;
	if tmpVal &gt; 0 then
		self.accessColumn(ColumnValue).width := tmpVal;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="setValueForMeasurement" id="e1af4310-eb34-473b-81b4-c36824384424">
        <updating/>
        <source>setValueForMeasurement(_entRowName : String; _value : String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 February 2019	jlger1	Initial creation 41398

*/

vars
	measureTable : CMUI_MeasurementTable;
	measureToUse : CM_MeasurementType;
	prefix  : String;
	rowName : String;
begin
	measureTable:=self.getMeasurementTableForRowName(_entRowName);
	if measureTable = null then
		return;
	endif;
	measureToUse:=measureTable.getMeasurementType;
	if measureToUse = null then
		return;
	endif;
	prefix := app.getMeasurementPrefixFromType(measureToUse.measurementType);
	rowName := prefix &amp; _entRowName &amp; "_" &amp; measureToUse.shortName;
	self.setValueByName(rowName,_value);
	measureTable.setValues(_value);
epilog

end;</source>
        <Parameter name="_entRowName" type="String"/>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromOtherTable" id="b730d608-0353-4ba3-8ff4-61b879c51856">
        <updating/>
        <source>setValuesFromOtherTable(pCopyFrom : CM_EntryTable input; _callbackMethod : String) updating;
// ---------------------------------------------------------------------------
// Created:     24 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 26/10/2012	cnwdap1		PAR #30247 Correct date handling for different locales
// ---------------------------------------------------------------------------
vars
	tmpIdx,
	newIdx,
	oldIdx		: Integer;
	oldCntrl,
	newCntrl	: Control;
	strValue	: String;
	entTblRow	: EntTableRowTransient;
	obj			: Object;
	tmpCmb		: CMUI_ComboBox;
	oldValue	: Any;					// PAR #30247
begin
	
	foreach obj in self.allEntRowTransients do
		entTblRow := obj.EntTableRowTransient;

		newIdx := self.getRowByName(entTblRow.name);
		if newIdx &gt; 0 then
			newCntrl := self.accessCell(newIdx, CM_EntryTable.ColumnValue).cellControl;
		endif;
		
		oldIdx := pCopyFrom.getRowByName(entTblRow.name);
		if oldIdx &gt; 0 then
			// PAR #30247 casting getValue as a String when pValue is a date was ignoring
			// any locale settings locally, so screwing up date displays
			//strValue := pCopyFrom.getValue(oldIdx).String;	// PAR #30247
			oldValue := pCopyFrom.getValue(oldIdx);				// PAR #30247
			if oldValue.isKindOf(Date) then						// PAR #30247
				strValue := oldValue.asStringJMT;				// PAR #30247
			else												// PAR #30247
				strValue := oldValue.String;					// PAR #30247
			endif;												// PAR #30247
			oldCntrl := pCopyFrom.accessCell(oldIdx, CM_EntryTable.ColumnValue).cellControl;
		endif;
								
		if _callbackMethod &lt;&gt; null then
			if self.form.sendMsgWithParams(_callbackMethod, self, oldCntrl, newCntrl, entTblRow.name, newIdx, strValue).Boolean then
				continue;
			endif;
		endif;
		
		self.setValue(newIdx, strValue);

		if oldCntrl = null then
			continue;
		endif;
		if oldCntrl.name[1] = '_' then
			// Ignore Jades controls
			continue;
		endif;
		if newCntrl = null then
			continue;
		endif;

		if CMUI_ListTable.hasInstance(oldCntrl) then
			newCntrl.CMUI_ListTable.setSelected(oldCntrl.CMUI_ListTable.allSelectedObjects);

		elseif CMUI_ComboBox.hasInstance(oldCntrl) then
			tmpCmb := newCntrl.CMUI_ComboBox;
			obj := oldCntrl.CMUI_ComboBox.listObject;
						
			if CMUI_ComboBoxObject.hasInstance(tmpCmb) then
				//Par 9435 set object will initialise control to populate collection
				tmpCmb.CMUI_ComboBoxObject.setObject(obj);
				if obj &lt;&gt; null then
					tmpCmb.lostFocus(tmpCmb);
				endif;
			else
				if obj &lt;&gt; null then
					tmpIdx := tmpCmb.findObject(obj);
				else
					tmpIdx := tmpCmb.findStringExact(0, oldCntrl.CMUI_ComboBox.text);
				endif;
				if tmpIdx &gt; -1 then
					tmpCmb.CMUI_ComboBox.listIndex := tmpIdx;
					tmpCmb.lostFocus(tmpCmb);
				endif;
			endif;
		endif;
	endforeach;

end;</source>
        <Parameter name="pCopyFrom" type="CM_EntryTable" usage="input"/>
        <Parameter name="_callbackMethod" type="String"/>
    </JadeMethod>
    <JadeMethod name="sheets" id="250a069f-cb62-45dd-916d-1dd4dfe0ad39">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>sheets(set: Boolean; value: Integer io) updating, mapping;
// delete when able
vars
	
begin

	inheritMethod(set, value);
	
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="showHideRowsByList" id="41fa33b9-28d2-4162-a4e4-9c4b55a4f776">
        <updating/>
        <source>showHideRowsByList(pSa : StringArray; pAction : Integer; pSort : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     20 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	idx				: Integer;
	maxRows			: Integer;
	tmpRow			: Integer;
	attrName		: String;
	entRowTrans		: EntTableRowTransient;
begin
	if pSa = null then	// PAR 4632
		return;
	endif;
	
	if pSort and pAction &lt;&gt; ShowHideRows then
		// not so friendly warning if called incorrectly
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid option - sorting where not ShowHideRows');
	endif;

	maxRows := self.rows;

	foreach idx in topNonHeadingRow to maxRows do
		entRowTrans := self.accessRow(idx).itemObject.EntTableRowTransient;
		attrName := entRowTrans.name;
		if pSa &lt;&gt; null and pSa.includes(attrName) then
			if pAction = ShowRowsOnly or pAction = ShowHideRows then
				self.showRow(idx);
			elseif pAction = HideRowsOnly then
				self.hideRow(idx);
			endif;
		else
			if pAction = ShowHideRows then
				self.hideRow(idx);
			endif;
		endif;
	endforeach;
	
	if pSort and pAction = ShowHideRows then
		foreach idx in 1 to pSa.size do
			// find what row the item is in
			tmpRow := self.getRowByName(pSa[idx]);
			if tmpRow &lt;&gt; 0 and // 10/11/2023	navkc1 Bug 61004
				tmpRow &lt;&gt; idx then
				// we need to move the item
				self.moveRow(tmpRow, idx);
			endif;
		endforeach;
	endif;

end;</source>
        <Parameter name="pSa" type="StringArray"/>
        <Parameter name="pAction" type="Integer"/>
        <Parameter name="pSort" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showHideRowsByListSel" id="fccdbee0-3f5d-4d90-a023-632ac4a9e76e">
        <updating/>
        <source>showHideRowsByListSel(_sa : StringArray; _action : Integer; _sort : Boolean) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 04/04/2022	navdap1		Initial creation TFS 53304 C3L Show Docket for Cargo returns 1086 Error
//
vars
	idx : Integer;
	maxRows : Integer;
	tmpRow : Integer;
	attrName : String;
	critLine : CM_SelectorCriteriaLine;
	
begin
	if _sa = null then
		return;
	endif;
	
	if _sort and _action &lt;&gt; ShowHideRows then
		// not so friendly warning if called incorrectly
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid option - sorting where not ShowHideRows');
	endif;

	maxRows := self.rows;

	foreach idx in topNonHeadingRow to maxRows do
		critLine := self.accessRow(idx).itemObject.CM_SelectorCriteriaLine;
		attrName := critLine.propName;
		if _sa &lt;&gt; null and _sa.includes(attrName) then
			if _action = ShowRowsOnly or _action = ShowHideRows then
				self.showRow(idx);
			elseif _action = HideRowsOnly then
				self.hideRow(idx);
			endif;
		else
			if _action = ShowHideRows then
				self.hideRow(idx);
			endif;
		endif;
	endforeach;
	
	if _sort and _action = ShowHideRows then
		foreach idx in 1 to _sa.size do
			// find what row the item is in
			tmpRow := self.getRowByName(_sa[idx]);
			if tmpRow &lt;&gt; idx then
				// we need to move the item
				self.moveRow(tmpRow, idx);
			endif;
		endforeach;
	endif;
epilog

end;</source>
        <Parameter name="_sa" type="StringArray"/>
        <Parameter name="_action" type="Integer"/>
        <Parameter name="_sort" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showHideRowsByView" id="9f8b1108-137e-4d99-939b-978cd5c8e37a">
        <updating/>
        <source>showHideRowsByView(pView : EntTableView; pAction : Integer; pSort : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     16 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	sa		: StringArray;

begin

	create sa transient;
	
	pView.getRowNameArray(sa);
	self.showHideRowsByList(sa, pAction, pSort);

epilog
	delete sa;
end;</source>
        <Parameter name="pView" type="EntTableView"/>
        <Parameter name="pAction" type="Integer"/>
        <Parameter name="pSort" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showHideRowsByViewName" id="d9477e48-89f5-4187-b6aa-bb3b72b7a179">
        <updating/>
        <source>showHideRowsByViewName(pViewName : String; pAction : Integer; pSort : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     16 February 2001 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	view	: EntTableView;
	sa		: StringArray;
begin

	create sa transient;
	
	if self.myEntTableDef &lt;&gt; null then
		view := self.myEntTableDef.allEntTableViews[pViewName];
		if view &lt;&gt; null then
			view.getRowNameArray(sa);
		else
			if self.warningMethod &lt;&gt; null then
				self.form.sendMsgWithParams(self.warningMethod, self.name, method.name, 
											'View (' &amp; pViewName &amp; ' not found for entTableDef (' &amp; self.myEntTableDef.name &amp; ')');
			endif;
		endif;
	else
		if self.warningMethod &lt;&gt; null then
			self.form.sendMsgWithParams(self.warningMethod, self.name, method.name, 'Cannot show by View as myEntTableDef is null');
		endif;
	endif;

	self.showHideRowsByList(sa, pAction, pSort);
	
epilog
	delete sa;
end;</source>
        <Parameter name="pViewName" type="String"/>
        <Parameter name="pAction" type="Integer"/>
        <Parameter name="pSort" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showRow" id="771a089c-714e-4000-adc7-b60e56f14a7f">
        <updating/>
        <source>showRow(pRow : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     09 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpRow	: JadeTableRow;
	
begin

	if self.isValidRow(pRow) then
		tmpRow := self.accessRow(pRow);
		if tmpRow.visible then
			return;
		endif;
		
		tmpRow.visible := true;
		if pRow &lt; topEntryRow or topEntryRow = 0 then
			topEntryRow := pRow;
		endif;
		if pRow &gt; bottomEntryRow or bottomEntryRow = 0 then
			bottomEntryRow := pRow;
		endif;
	else
		if self.warningMethod &lt;&gt; null then
			self.form.sendMsgWithParams(self.warningMethod, self.name, method.name, 'Cannot show row (' &amp; pRow.String &amp; ') - invalid row');
		endif;
	endif;

end;</source>
        <Parameter name="pRow" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showRowByName" id="166a0c84-931e-471d-9e02-ba599ac43969">
        <updating/>
        <source>showRowByName(pName : String; pGiveWarning : Boolean) : Integer updating;
// ---------------------------------------------------------------------------
// Created:     09 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 15/03/2013	cnwdap1		PAR #31155 CCNS SFW 1321 Imperial Measurements
//							Show associated measurement type rows as well
// ---------------------------------------------------------------------------
vars
	tmpRow		: Integer;
	obj			: Object;				// PAR #31155
	entRow		: EntTableRowTransient;	// PAR #31155
	rowName		: String;				// PAR #31155
	type		: String;				// PAR #31155
	isMeasure	: Boolean;				// PAR #31155
	row			: Integer;				// PAR #31155
	
begin
	tmpRow := getRow(pName);

	if tmpRow &gt; 0 then
		// PAR #31155 If this row represents a measurement type row, 	// PAR #31155
		// show the measurement rows and don't actually show this one	// PAR #31155
		foreach obj in self.allEntRowTransients do						// PAR #31155
			entRow := obj.EntTableRowTransient;							// PAR #31155
			if entRow.name.isMeasurementType then						// PAR #31155
				entRow.name.getRowNameMeasureType(rowName, type);		// PAR #31155
				if rowName = pName then									// PAR #31155
					row := self.getRow(entRow.name);					// PAR #31155
					if row &gt; 0 then										// PAR #31155
						self.showRow(row);								// PAR #31155
						isMeasure := true;								// PAR #31155
					endif;												// PAR #31155
				endif;													// PAR #31155
			endif;														// PAR #31155
		endforeach;														// PAR #31155
		if not isMeasure then											// PAR #31155
			showRow(tmpRow);
		endif;															// PAR #31155
	else
		if pGiveWarning and self.warningMethod &lt;&gt; null then
			self.form.sendMsgWithParams(self.warningMethod, self.name, method.name, 'Cannot show row (' &amp; pName &amp; ') - not found on table');
		endif;
	endif;
		
	return tmpRow;

end;</source>
        <Parameter name="pName" type="String"/>
        <Parameter name="pGiveWarning" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="userInputEnabled" id="a5046651-920a-4d0e-8769-4eed9cd21766">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>userInputEnabled(set: Boolean; value: Boolean io) updating, mapping;
// ---------------------------------------------------------------------------
// Created:     11 September 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theRow		: Integer;
	entRowTrans	: EntTableRowTransient;

begin
	inheritMethod(set, value);

	if (not set) or (self.changeMode = ChangeMode_None) then
		return;
	endif;
	
	if (not value) then
		self.clearHasChanged();
		self.previousRow := -1;
	else
		//CNWTH2 sets the original value of the current row
		// this is because the table may already have focus so the orig value
		// is not set in the handleCellGotFocus as this is not called.
		theRow := self.row;
		if theRow &gt; self.fixedRows then
			entRowTrans := self.accessRow(theRow).itemObject.EntTableRowTransient;
			if entRowTrans &lt;&gt; null then
				entRowTrans.originalValue := self.accessCell(theRow, ColumnValue).text;
			endif;
		endif;
	endif;
	
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="3e0b0728-f042-42ad-9de4-48e123ad814d">
        <updating/>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating;

vars
	jadeCol	: JadeTableColumn;
	
begin

	inheritMethod(cntrl, persistCntrl);
	
	self.columns := ColumnValue;
	
	if hasHeading then
		self.rows := 1;
		self.fixedRows := 1;
		self.topNonHeadingRow := 2;
	else
		self.rows := 0;
		self.fixedRows := 0;
		self.topNonHeadingRow := 1;
	endif;
	
	self.resetTopEntryRow();
	self.resetBottomEntryRow();
	
	self.fixedColumns := ColumnHeading;

	jadeCol := self.accessColumn(ColumnHeading);
	jadeCol.width := (self.width / 2).Integer;
	jadeCol.alignment := Alignment_Left_Top;
	
	jadeCol := self.accessColumn(ColumnValue);
	jadeCol.width := (self.width - self.accessColumn(ColumnHeading).width).Integer;
	jadeCol.alignment := Alignment_Left_Top;
	
	self.setMargins();
	self.partialTextIndication := true;
	
	self.column := ColumnValue;
	
	self.hasChangedColor := self.ROWCHANGED_COLOUR;
end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
