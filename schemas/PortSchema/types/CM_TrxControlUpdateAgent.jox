    <JadeMethod name="trxUpdateEDITIs" id="1b848e08-af64-414b-b95e-902aa41e764f">
        <updating/>
        <source>trxUpdateEDITIs(_ediTIs: CM_EDITIById; _passport: CM_Passport input)updating;
//----------------------------------------------------------------
//	Created:	08 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 23 Feb 2018	jlgrs1	TFS 36963 - add tranlog timings
vars
	ti			: CM_EDITrackedItem;
	nullObject	: CM_Object;
	tmpStr : String;
	tmpId : Integer;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	ti := _ediTIs.first;
	if ti &lt;&gt; null then
		tmpStr := method.qualifiedName;
		app.writeLog(tmpStr&amp;' '&amp;ti.getVoyageCode, LogINFO);	//25 Nov 2019	NDL	TFS 47053
		
		tmpId := self.cnStartTransaction(tmpStr[1:50]);
	endif;
	beginTransaction;
	
	foreach ti in _ediTIs do
		app.myUtilityUA.utlUpdateEDITI(ti, _passport);
		if (not _passport.noErrors) then
			break;
		endif;
	endforeach;

epilog
	if tmpId &lt;&gt; null then
		self.cnEndTransactionEx(tmpId);
	endif;
	self.finaliseActivityWithPassport(_passport);	
end;</source>
        <Parameter name="_ediTIs" type="CM_EDITIById"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateEDITransformRule" id="48e47a81-ed42-4b3a-938b-70a7824d9710">
        <updating/>
        <source>trxUpdateEDITransformRule(_proxyEDITransformRule : CM_EDITransformRule; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 December 2022	jlier1	Initial creation 56234

*/

vars
	realEDITransformRule : CM_EDITransformRule; 
	expectedEdition : Integer;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	beginTransaction;
	
	_proxyEDITransformRule.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	_proxyEDITransformRule.pxyGetRealObjectAndEdition(realEDITransformRule, expectedEdition);
	
	if realEDITransformRule = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_EDITransformRule.name, null, null);
		return;
	endif;


	app.setContinueCMExceptions(false);
	
	realEDITransformRule.setForUpdate(_proxyEDITransformRule);
	
epilog	
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_proxyEDITransformRule" type="CM_EDITransformRule"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateEDIVGMTI" id="febde5da-30c0-4a50-9414-c78eaef949f8">
        <updating/>
        <source>trxUpdateEDIVGMTI(_validateOnly : Boolean; _ediTI : CM_EDIVGMTI io; _proxyTI : CM_TrackedItem input; _passport: CM_Passport input) updating;
//
//19 Apr 2016	cnwrs1	TFS 1600 VERMAS EDI
//
vars
	status : Integer;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(true);
	_passport.warningsAcknowledged := true;
	
	beginTransaction;
	
	//22 Mar 2021	NDL	TFS 50917 - try deferred updating to reduce locks.
	_passport.useTIDictDeferUpdate := true;
	_passport.useTITransactionDeferUpdate := true;

	//complete the update of the real ti
	app.myUtilityUA.utlUpdateEDIVGMTI(_ediTI, _proxyTI, _passport);
	if _validateOnly and _passport.noErrors then
		// sucessful validate - abort then update status in new transaction
		// we need to abort here as it won't get done for us in self.finaliseActivityWithPassport
		app.cmsAbortTransaction();
		return;
	else
		_passport.doDeferredUpdates();	//22 Mar 2021	NDL	TFS 50917 
	//	app.cmsCommitTransaction(_passport);
	endif;
epilog
	self.finaliseActivityWithPassport(_passport);

end;
</source>
        <Parameter name="_validateOnly" type="Boolean"/>
        <Parameter name="_ediTI" type="CM_EDIVGMTI" usage="io"/>
        <Parameter name="_proxyTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
