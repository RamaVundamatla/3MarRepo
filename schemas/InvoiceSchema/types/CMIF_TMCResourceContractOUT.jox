<Class name="CMIF_TMCResourceContractOUT" id="dd5d182b-959f-4f8a-9e01-a7cf23806c75">
    <superclass name="CMIF_TMCResourceContractGroup"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="invoice"/>
    <JadeMethod name="getItemName" id="93f54cec-0c4c-4968-9ee4-e85dad6ecc9a">
        <source>getItemName() : String;
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
