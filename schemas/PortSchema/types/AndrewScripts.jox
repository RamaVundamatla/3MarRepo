	toArrary[3] := RoadStr;
	toArrary[4] := VesselStr;
	toArrary[5] := YardStr;
	

	foreach idxa in 1 to 5 do
		foreach idxb in 1 to 5 do
			//write fromArray[idxa] &amp; " " &amp;  toArrary[idxb];
			
			
//				write "_yaIdentifiers.add(app.getErrorString(LocnActMoveStr_" &amp; fromArray[idxa] &amp; "To" &amp; toArrary[idxb] &amp; "));";
		//		app.getErrorString(LocnActMoveStr_BargeToBarge);
		write 'allstr := allstr &amp; ", "' &amp; " &amp; app.getErrorString(LocnActMoveStr_" &amp; fromArray[idxa] &amp;"To" &amp;toArrary[idxb] &amp; ");";

		endforeach;
	
