    <JadeMethod name="getExtraInfo" id="1c2e81e2-ce61-4fa3-9c79-b0ad08bf5763">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
// ---------------------------------------------------------------------------
// Created:		April 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	block : CM_DataContainerBlock;

	str : String;
begin

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Delivery_Number), DC_Label, 1, null);
	block.addNewItem(self.deliveryNumber, DC_Data, 1, null);
	
	//epr TFS 36605 15/1/17 making it clearing that they are any id and any amount
	if self.isAnyAmount then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(IS_ANY_AMOUNT), DC_Label, 1, null);
		block.addNewItem(true.getYesNo(), DC_Data, 1, null);	
	endif;
	
	if self.isAnyId then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(IS_ANY_ID), DC_Label, 1, null);
		block.addNewItem(true.getYesNo(), DC_Data, 1, null);	
	endif;
	
	inheritMethod(_dataContainer);

	

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Equipment_Interchange), DC_Label, 1, null);
	block.addNewItem(self.eirNumber, DC_Data, 1, null);





	if self.needCOU then
		str := app.getErrorString(CM_Clip_On_Unit); 
	elseif self.needGenerator then
		str := app.getErrorString(CM_Generator_GC); 
	else
		str := app.getErrorString(None);
	endif;

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Power_Requirements), DC_Label, 1, null);
	block.addNewItem(str, DC_Data, 1, null);

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Request_Remarks), DC_Label, 1, null);
	block.addNewItem(self.getRemarks() &amp; CrLf, DC_Data, 1, null);						//cnwas3 par 25420

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Doors_Direction), DC_Label, 1, null);
	block.addNewItem(self.doorsDirectionString(), DC_Data, 1, null);

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getOperatorCode" id="21ba8051-9b71-4bba-92dd-eb6b72ff5d57">
        <source>getOperatorCode(): String;
/*

Purpose:			

