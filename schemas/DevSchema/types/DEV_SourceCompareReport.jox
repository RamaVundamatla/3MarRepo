				endif;
				
				concatenatedString &amp;= CrLf &amp; devSchema.name &amp; "::" &amp; devClass.name &amp; "::" &amp; devConstant.name &amp; " - " &amp; devConstant.modifiedBy &amp;  " | " &amp; devConstant.modifiedTimeStamp.String;
				constantsMissingCount += 1;
			endforeach;
		endforeach;
	endforeach;
	
	if constantsMissingCount &lt;&gt; 0 then
		concatenatedString &amp;= CrLf &amp; "Missing Constants Count: " &amp; constantsMissingCount.String;
	endif;
	
	concatenatedString &amp;= CrLf;
	
	wroteHeaderLine := false;
	foreach devSchema in self.allSchemas do
		foreach devClass in devSchema.allClasses where devClass.reason = DEV_SourceCompareReportAgent.Object_Link do
			foreach devConstant in devClass.allConstants where devConstant.reason = DEV_SourceCompareReportAgent.Object_Different do
				if not wroteHeaderLine then
					concatenatedString &amp;= CrLf &amp; "Differing Constants:";
					wroteHeaderLine := true;
				endif;
				
				concatenatedString &amp;= CrLf &amp; devSchema.name &amp; "::" &amp; devClass.name &amp; "::" &amp; devConstant.name &amp; " - " &amp; devConstant.modifiedBy &amp;  " | " &amp; devConstant.modifiedTimeStamp.String;
				constantsDifferentCount += 1;
			endforeach;
		endforeach;
	endforeach;
	
	if constantsDifferentCount &lt;&gt; 0 then
		concatenatedString &amp;= CrLf &amp; "Differing Constants Count: " &amp; constantsDifferentCount.String;
	endif;
	
	concatenatedString &amp;= CrLf;
	
	wroteHeaderLine := false;
	foreach devSchema in self.allSchemas do
		foreach devClass in devSchema.allClasses where devClass.reason = DEV_SourceCompareReportAgent.Object_Link do
			foreach devReference in devClass.allReferences where devReference.reason = DEV_SourceCompareReportAgent.Object_Missing do
				if not wroteHeaderLine then
					concatenatedString &amp;= CrLf &amp; "Missing References:";
					wroteHeaderLine := true;
				endif;
				
				concatenatedString &amp;= CrLf &amp; devSchema.name &amp; "::" &amp; devClass.name &amp; "::" &amp; devReference.name &amp; " - " &amp; devReference.modifiedBy &amp;  " | " &amp; devReference.modifiedTimeStamp.String;
				referencesMissingCount += 1;
			endforeach;
		endforeach;
	endforeach;
	
	if referencesMissingCount &lt;&gt; 0 then
		concatenatedString &amp;= CrLf &amp; "Missing References Count: " &amp; referencesMissingCount.String;
	endif;
	
	concatenatedString &amp;= CrLf;
	
	wroteHeaderLine := false;
	foreach devSchema in self.allSchemas do
		foreach devClass in devSchema.allClasses where devClass.reason = DEV_SourceCompareReportAgent.Object_Link do
			foreach devReference in devClass.allReferences where devReference.reason = DEV_SourceCompareReportAgent.Object_Different do
				if not wroteHeaderLine then
					concatenatedString &amp;= CrLf &amp; "Differing References:";
					wroteHeaderLine := true;
				endif;
				
				concatenatedString &amp;= CrLf &amp; devSchema.name &amp; "::" &amp; devClass.name &amp; "::" &amp; devReference.name &amp; " - " &amp; devReference.modifiedBy &amp;  " | " &amp; devReference.modifiedTimeStamp.String;
				referencesDifferentCount += 1;
			endforeach;
		endforeach;
	endforeach;

	if referencesDifferentCount &lt;&gt; 0 then
		concatenatedString &amp;= CrLf &amp; "Differing References Count: " &amp; referencesDifferentCount.String;
	endif;
	
	concatenatedString &amp;= CrLf;
	
	return concatenatedString;

end;</source>
