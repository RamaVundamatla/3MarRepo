    <JadeMethod name="doMultiSelect" id="5ba6b2e2-3bf2-4ab8-9e13-901a31e18069">
        <updating/>
        <source>doMultiSelect() updating;

vars
	start,
	finish,
	rownum,
	stepinc					: Integer;
	endObj					: Object;
	obj						: Object;	
	wasInLoadState			: Boolean;	
	iter					: Iterator;	
begin
	// Clear the currently selected objects 
	selectedObjects.clear();

	// Decide if we are using iterator (listCollection) or have added rows manually
	if myIterator &lt;&gt; null then
		// If shift is down and we've already got a start then go from start to finish (inclusive)
		// First set the ending points and clear existing selections
		start:=myIterator.getCollection.indexOf(selectedStart);
		finish:=myIterator.getCollection.indexOf(self.itemObject);

		// Do this in load state to reduce loacking
		wasInLoadState := process.isInLoadState;
		if not wasInLoadState then
			beginLoad;
		endif;

		// Create a new iterator and set the start point and end object
		iter := myIterator.getCollection.createIterator();
		if start &lt; finish then
			iter.startAtIndex(start);
			endObj:=self.itemObject;
		else
			iter.startAtIndex(finish);
			endObj:=selectedStart;
		endif;

		// Iterate through until we meet the end object
		while iter.next(obj) do
			selectedObjects.add(obj);
			// Check to see if we've reached the end and drop out of the loop
			if obj = endObj then
				break;
			endif;
		endwhile;
	else
		// We just use the table 'naturally'
		finish:=self.row;	
		start:=self.getThisObjectsRow(selectedStart);
		if finish &gt;= start then
			stepinc:=1;
		else
			stepinc:=-1;
		endif;
		foreach rownum in start to finish step stepinc do
			row:=rownum;
			selectedObjects.add(self.getRowObject());
		endforeach;		

		// reset the current row to where we clicked
		self.row	:=	finish;
	endif;
epilog
	delete iter;

	if not wasInLoadState then
		endLoad;
	endif;
end;</source>
    </JadeMethod>
    <ExternalMethod name="excludeObject" id="b1d0ed71-5f3e-4619-8c83-6ea2338355a9">
        <updating/>
