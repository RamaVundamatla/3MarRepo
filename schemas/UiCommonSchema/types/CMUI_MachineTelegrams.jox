    <JadeMethod name="initTblData" id="882c2b92-896e-4991-9df9-b9b7c8eedb9e">
        <source>initTblData();
//--------------------------------------------------
// Created:	13 April 2005 By: cnwgd1
//--------------------------------------------------
vars
	rtCol : Integer;
begin

	self.tblTelegrams.setTblDataEntRowsFromDef(app.myController.getEntTableDef((ETDef_MachineTelegram)));	

	self.tblTelegrams.setMyDataClass(CM_RTGTelegram);
	self.tblTelegrams.userInputEnabled := false;
	self.tblTelegrams.selectMode := Table.SelectMode_CurrentRow;
	self.tblTelegrams.selectionType := CM_DataTable.SelectionType_Row;
	self.tblTelegrams.multiSelect := self.tblTelegrams.MultiSelect_Simple;
	
	self.tblTelegrams.zRemoveSortColumn(ETRow_XmlHeight);	
	rtCol := self.tblTelegrams.getColumnByRowName(ETRow_CreatedTime);
	tblTelegrams.sortColumn[1]:=rtCol;
	tblTelegrams.sortAscending:=true;
	self.tblTelegrams.resortTableByColumn(rtCol);


end;</source>
    </JadeMethod>
