    <JadeMethod name="makeSealSectXML" id="6d87ebc1-2a21-4d9b-987e-0b2e056708de">
        <source>makeSealSectXML( _ti : CM_TrackedItem; _parentElem : JadeXMLElement input ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 August 2016	cnwndl1	Initial creation	TFS 2561 / 2277

*/

vars

	rootElem : JadeXMLElement;
	xmlElem : JadeXMLElement;
	seal : CM_SealTI;
	workStr : String;
	
begin

	if _ti = null then
		return;
	endif;

	foreach seal in _ti.allSeals do
	
		rootElem := _parentElem.addElement('Seal');
		
		xmlElem := rootElem.addElement('Type');
		xmlElem.setText( 'X' );
		
		xmlElem := rootElem.addElement('Number');
		xmlElem.setText( seal.getSealValueAsString );
		
		workStr := null;
		xmlElem := rootElem.addElement('IntactIndicator');
		xmlElem.setText( workStr );
		
		workStr := null;
		xmlElem := rootElem.addElement('Condition');
		xmlElem.setText( workStr );
		
		xmlElem := rootElem.addElement('Description');
		xmlElem.setText( seal.sealType );
	
	endforeach;
	
epilog

end;</source>
        <access>protected</access>
