    <JadeMethod name="displayDimensions" id="2e6b0cdf-ae2d-4f20-8a97-b357b530333c">
        <source>displayDimensions();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 May 2014	cnwndl1	Initial creation

*/

vars

	cargoType : CM_CargoType;
	measureType : CM_MeasurementType;

begin

	self.tblLeft.setup(Type_Length, self.backColor);
	self.tblLeft.tabKey := J_key_Tab;
	self.tblLeft.visible := false;
	self.lblLeft.visible := false;
	
	self.tblRight.setup(Type_Length, self.backColor);
	self.tblRight.tabKey := J_key_Tab;
	self.tblRight.visible := false;
	self.lblRight.visible := false;
	
	self.tblBack.setup(Type_Length, self.backColor);
	self.tblBack.tabKey := J_key_Tab;
	self.tblBack.visible := false;
	self.lblBack.visible := false;
	
	self.tblFront.setup(Type_Length, self.backColor);
	self.tblFront.tabKey := J_key_Tab;
	self.tblFront.visible := false;
	self.lblFront.visible := false;
	
	self.tblHeight.setup(Type_Length, self.backColor);
	self.tblHeight.tabKey := J_key_Tab;
	self.tblHeight.visible := false;
	self.lblHeight.visible := false;
	
	self.tblLength.setup(Type_Length, self.backColor);
	self.tblLength.tabKey := J_key_Tab;
	self.tblLength.visible := false;
	self.lblLength.visible := false;
	
	self.tblWidth.setup(Type_Length, self.backColor);
	self.tblWidth.tabKey := J_key_Tab;
	self.tblWidth.visible := false;
	self.lblWidth.visible := false;

	if self.myTrackedItem &lt;&gt; null then
		cargoType := self.myTrackedItem.myCargoType;
		measureType := cargoType.getMeasurementTypeFor(Type_Length,false);
		if cargoType.id = TI_CargoType_Container then
			self.tblLeft.visible := true;
			self.tblRight.visible := true;
			self.tblBack.visible := true;
			self.tblFront.visible := true;
			self.tblHeight.visible := true;
			self.lblLeft.visible := true;
			self.lblRight.visible := true;
			self.lblBack.visible := true;
			self.lblFront.visible := true;
			self.lblHeight.visible := true;
			
			self.tblLeft.setValues(app.convertMeasurementForDisplay(measureType.shortName, self.myTrackedItem.CM_Container.overWidthLeft) &amp; Space &amp; measureType.shortName);
			self.tblRight.setValues(app.convertMeasurementForDisplay(measureType.shortName, self.myTrackedItem.CM_Container.overWidthRight) &amp; Space &amp; measureType.shortName);
			self.tblBack.setValues(app.convertMeasurementForDisplay(measureType.shortName, self.myTrackedItem.CM_Container.overLengthRear) &amp; Space &amp; measureType.shortName);
			self.tblFront.setValues(app.convertMeasurementForDisplay(measureType.shortName, self.myTrackedItem.CM_Container.overLengthFront) &amp; Space &amp; measureType.shortName);
			self.tblHeight.setValues(app.convertMeasurementForDisplay(measureType.shortName, self.myTrackedItem.CM_Container.overHeight) &amp; Space &amp; measureType.shortName);
		else
			self.tblLength.visible := true;
			self.tblWidth.visible := true;
			self.tblHeight.visible := true;
			self.lblLength.visible := true;
			self.lblWidth.visible := true;
			self.lblHeight.visible := true;
			
			self.tblLength.setValues(app.convertMeasurementForDisplay(measureType.shortName, self.myTrackedItem.length) &amp; Space &amp; measureType.shortName);
			self.tblWidth.setValues(app.convertMeasurementForDisplay(measureType.shortName, self.myTrackedItem.width) &amp; Space &amp; measureType.shortName);
			self.tblHeight.setValues(app.convertMeasurementForDisplay(measureType.shortName, self.myTrackedItem.height) &amp; Space &amp; measureType.shortName);
		endif;
		
	elseif self.myGTEReceival &lt;&gt; null then
		cargoType := app.myRoot.allCargoTypesById[self.myGTEReceival.cargoType];
		measureType := cargoType.getMeasurementTypeFor(Type_Length,false);		
		if cargoType.id = TI_CargoType_Container then
			self.tblLeft.visible := true;
			self.tblRight.visible := true;
			self.tblBack.visible := true;
			self.tblFront.visible := true;
			self.tblHeight.visible := true;
			self.lblLeft.visible := true;
			self.lblRight.visible := true;
			self.lblBack.visible := true;
			self.lblFront.visible := true;
			self.lblHeight.visible := true;
			
			self.tblLeft.setValues(app.convertMeasurementForDisplay(measureType.shortName, self.myGTEReceival.dimWidthLeft) &amp; Space &amp; measureType.shortName);
			self.tblRight.setValues(app.convertMeasurementForDisplay(measureType.shortName, self.myGTEReceival.dimWidthRight) &amp; Space &amp; measureType.shortName); 
			self.tblBack.setValues(app.convertMeasurementForDisplay(measureType.shortName, self.myGTEReceival.dimLenRear) &amp; Space &amp; measureType.shortName);
			self.tblFront.setValues(app.convertMeasurementForDisplay(measureType.shortName, self.myGTEReceival.dimLenFront) &amp; Space &amp; measureType.shortName);
			self.tblHeight.setValues(app.convertMeasurementForDisplay(measureType.shortName, self.myGTEReceival.height) &amp; Space &amp; measureType.shortName);
		else
			self.tblLength.visible := true;
			self.tblWidth.visible := true;
			self.tblHeight.visible := true;
			self.lblLength.visible := true;
			self.lblWidth.visible := true;
			self.lblHeight.visible := true;
			
			self.tblLength.setValues(app.convertMeasurementForDisplay(measureType.shortName, self.myGTEReceival.length) &amp; Space &amp; measureType.shortName);
			self.tblWidth.setValues(app.convertMeasurementForDisplay(measureType.shortName, self.myGTEReceival.width) &amp; Space &amp; measureType.shortName);
			self.tblHeight.setValues(app.convertMeasurementForDisplay(measureType.shortName, self.myGTEReceival.height) &amp; Space &amp; measureType.shortName);
		endif;
		
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="displaySpecialLifts" id="6f6c1643-a47f-45dc-8296-525d060a89fe">
