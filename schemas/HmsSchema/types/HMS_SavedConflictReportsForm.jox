    <JadeMethod name="displayConflicts" id="4d88f9c9-ff6b-4bbd-a265-ad371990c002">
        <updating/>
        <source>displayConflicts( _hmsSavedConflictReport : HMS_SavedConflictReport) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
08 Mar 2008	cnwer1	Initial creation - PAR#xxxx
11 Mar 2015	cnwkpd1	PAR #35843 - Make progress bar updates time-based, not object counts

*/
vars
	passport		: CM_Passport;
	cmifMonitor		: CMIF_Monitor;
	obj				: Object;
	partsInJob,
	partsDone,
	idx: Integer;
	str				: String;
	hmsConflict : HMS_Conflict;
	lastUpdate		: Decimal[20];
	
begin
	if _hmsSavedConflictReport = null then
		return;
	endif;
	app.mousePointer := self.MousePointer_HourGlass;				
	passport := app.myPassport;
	self.tblConflicts.rows := self.tblConflicts.fixedRows;
	self.tblConflicts.clearAllSelected();

	cmifMonitor := passport.myCMIFMonitor;
	if cmifMonitor &lt;&gt; null then
		delete cmifMonitor;
	endif;
	create cmifMonitor transient;
	cmifMonitor.myParent := self;
	passport.setMyCMIFMonitor(cmifMonitor);

	self.modalDialogReturnValue := self.ModalDialogReturn_Null;	
	self.modalDialogShow(null, 'Cancel' , null, null, 'Loading Rules',  'Please Wait....');
	self.pbProgressBar.visible := true;
	
	partsInJob := self.myTerminal.allHMSSavedConflictReports.size;
	
	foreach hmsConflict in _hmsSavedConflictReport.allHMSConflicts discreteLock do
		partsDone := partsDone + 1;
		str := hmsConflict.getAttributeStringForDefArray(self.tblConflicts.allTblDataEntRows);
		idx := self.tblConflicts.addItemObject(hmsConflict, str);
		if (app.relativeMachineTime() - lastUpdate) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then
			if (not cmifMonitor.updateProgress(cmifMonitor.message, partsInJob, partsDone)) then
				break;
			endif;
			lastUpdate := app.relativeMachineTime();
		endif;
	endforeach;
	

epilog
	app.mousePointer := self.MousePointer_Default;									
	delete cmifMonitor;
	app.myPassport.setMyCMIFMonitor(null);
	self.frmModalDialog.visible:=false;


end;</source>
        <Parameter name="_hmsSavedConflictReport" type="HMS_SavedConflictReport"/>
    </JadeMethod>
    <JadeMethod name="displaySavedConflictReports" id="b6b9de37-6577-46d6-9fbb-baf4f0dc9a65">
        <updating/>
        <source>displaySavedConflictReports() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
08 March 2008	cnwer1	Initial creation - PAR#xxxx
11 Mar 2015	cnwkpd1	PAR #35843 - Make progress bar updates time-based, not object counts

*/
vars
	passport		: CM_Passport;
	cmifMonitor		: CMIF_Monitor;
	partsInJob,
	partsDone,
	idx: Integer;
	str				: String;
	hmsSavedReport : HMS_SavedConflictReport;
	lastUpdate		: Decimal[20];
	
begin
	app.mousePointer := self.MousePointer_HourGlass;				
	passport := app.myPassport;
	self.tblConflicts.rows := self.tblConflicts.fixedRows;
	self.tblConflicts.clearAllSelected();
	
	self.tblSavedReports.rows := self.tblSavedReports.fixedRows;
	self.tblSavedReports.clearAllSelected();

	cmifMonitor := passport.myCMIFMonitor;
	if cmifMonitor &lt;&gt; null then
		delete cmifMonitor;
	endif;
	create cmifMonitor transient;
	cmifMonitor.myParent := self;
	passport.setMyCMIFMonitor(cmifMonitor);

	self.modalDialogReturnValue := self.ModalDialogReturn_Null;	
	self.modalDialogShow(null, 'Cancel' , null, null, 'Loading Rules',  'Please Wait....');
	self.pbProgressBar.visible := true;
	
	partsInJob := self.myTerminal.allHMSSavedConflictReports.size;
	
	
	foreach hmsSavedReport in self.myTerminal.allHMSSavedConflictReports discreteLock do
		partsDone := partsDone + 1;
		str := hmsSavedReport.getAttributeStringForDefArray(self.tblSavedReports.allTblDataEntRows);
		idx := self.tblSavedReports.addItemObject(hmsSavedReport, str);
		if (app.relativeMachineTime() - lastUpdate) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then
			if (not cmifMonitor.updateProgress(cmifMonitor.message, partsInJob, partsDone)) then
				break;
			endif;
			lastUpdate := app.relativeMachineTime();
		endif;
	endforeach;
	

epilog
	app.mousePointer := self.MousePointer_Default;									
	delete cmifMonitor;
	app.myPassport.setMyCMIFMonitor(null);
	self.frmModalDialog.visible:=false;

end;</source>
    </JadeMethod>
