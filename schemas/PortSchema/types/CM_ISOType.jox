    <JadeMethod name="buildTypeDescr" id="3a36f345-efbb-4adf-ad59-0cde12727f89">
        <source>buildTypeDescr(pIsType : Boolean; pTypeDescr : String; pResult : String io) protected;
// ---------------------------------------------------------------------------
// Created:     27 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if not pIsType then
		return;
	endif;
	
	if pResult &lt;&gt; null then
		pResult := pResult &amp; ', ';
	endif;
	
	pResult := pResult &amp; pTypeDescr;

end;</source>
        <access>protected</access>
        <Parameter name="pIsType" type="Boolean"/>
        <Parameter name="pTypeDescr" type="String"/>
        <Parameter name="pResult" type="String" usage="io"/>
    </JadeMethod>
