    <JadeMethod name="getQueryDefinition" id="a1e108c8-d857-4fb0-9ad0-e3936242ac8e">
        <updating/>
        <source>getQueryDefinition( _queryOid : String ) updating;
// -------------------------------------------
// Created 07 may 2008 by cnwvu1
// -------------------------------------------

vars
	terminal	: CM_Terminal;
	querySet	: CM_SelectorQueryAccess;
	query,
	queryToRun	: CM_MenuUserQuery;
	
begin

	terminal	:= app.getMyTerminalDO_NOT_USE();
	querySet	:= terminal.myRTVehicleConfig.myQueriesForDrivers;// epr 25/5/10 ccms 1099   getConfig(SelectorQueriesForRT).CM_SelectorQueryAccess;
	if querySet = null then // normaly it shouldn't happen if notification works well
		app.raiseCMException( ERR_RTQueryAccessDeleted, null, null );
		return;
	endif;

	foreach query in querySet.allSelectedQueries do
		if query.getOidString = _queryOid then
			queryToRun := query;
			break;
		endif;
	endforeach;
	
	if queryToRun = null then
		app.raiseCMException( ERR_RTQueryDeleted, null, null );
		return;
	endif;
	
	self.setForCreateForRT( queryToRun );

end;
</source>
        <Parameter name="_queryOid" type="String"/>
    </JadeMethod>
    <JadeMethod name="setForCreateForRT" id="51e800a1-5ea7-4222-8e5e-5bde13511139">
        <updating/>
        <source>setForCreateForRT( _menuUserQuery : CM_MenuUserQuery ) updating;
// -------------------------------------------
// Created 06 may 2008 by cnwvu1
// -------------------------------------------

vars
	criteriaLineHolder		: CM_QueryCriteriaLineHolder;
	dtoCriteriaLineHolder	: DTO_QueryCriteriaLineHolderRT;
begin
	
	self.setFromPersistent( _menuUserQuery );
	self.setName( _menuUserQuery.heading );
	
	// to create all QueryCriteriaLineHoldersRT
	foreach criteriaLineHolder in _menuUserQuery.allCriteriaLineHolders do
		create dtoCriteriaLineHolder transient;
		dtoCriteriaLineHolder.setForCreateForRT( self, criteriaLineHolder );
	endforeach;
	
end;
</source>
        <Parameter name="_menuUserQuery" type="CM_MenuUserQuery"/>
    </JadeMethod>
