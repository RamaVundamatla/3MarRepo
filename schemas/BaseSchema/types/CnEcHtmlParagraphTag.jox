    <DbClassMap file="basehtml"/>
    <PrimAttribute name="paragraphAlign" id="00728ee4-57fd-46e1-87d7-996577f844da">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="paragraphValue" id="bc8a13df-4b35-4fab-9b83-9b5a7df3d725">
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="buildTagBody" id="c742d3aa-d020-4ef2-b4c2-823df865dbc7">
        <source>buildTagBody(): String protected;
// --------------------------------------------------------------------------------
// Created:		02 December 2001 by cnwdad1
//
// Purpose:		Refer to the CnEcHtmlTagObject implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	htmlString	: String;
	
begin
	if self.paragraphAlign &lt;&gt; null then
		htmlString	:=	' ALIGN="' &amp; self.paragraphAlign &amp; '"';
	endif;
	
	htmlString	:=	htmlString &amp; '&gt;' &amp; CrLf &amp; self.paragraphValue &amp; inheritMethod() &amp; self.buildChildTags();
	
	return htmlString;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getHtml" id="9231eda1-14bd-4ccb-87b0-c56d6969c389">
        <source>getHtml(): String;
// --------------------------------------------------------------------------------
// Created:		02 December 2001 by cnwdad1
//
// Purpose:		Refer to the CnEcHtmlTagObject implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return '&lt;P' &amp; self.buildTagBody() &amp; '&lt;/P&gt;' &amp; CrLf;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isValidAlign" id="788684f4-5f8f-41eb-aa52-bb8787720911">
        <source>isValidAlign(pAlign: String): Boolean protected;
// --------------------------------------------------------------------------------
// Created:		29 April 2000 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pAlign = self.ALIGN_CENTER
	or pAlign = self.ALIGN_LEFT
	or pAlign = self.ALIGN_RIGHT
	then
		return true;
	else
		CnEcBaseHtmlException.raise_(CNEC_X_22000, '"' &amp; pAlign &amp; '" is not a valid Paragraph tag alignment');
	endif;

	return false;
end;</source>
        <access>protected</access>
        <Parameter name="pAlign" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setParagraphAlign" id="348bac66-2e92-4104-81c6-4dc82c67f7d7">
        <updating/>
        <source>setParagraphAlign(pAlign: String) updating;
// --------------------------------------------------------------------------------
// Created:		29 April 2000 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.isValidAlign(pAlign) then
		self.paragraphAlign	:=	pAlign;
	endif;
end;</source>
        <Parameter name="pAlign" type="String"/>
    </JadeMethod>
</Class>
