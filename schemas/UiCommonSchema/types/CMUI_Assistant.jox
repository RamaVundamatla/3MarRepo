        <source>comboBoxMachInteractionType(_cmb : CMUI_ComboBox input; _interactionType : Integer);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 August 2009	cnwer1	Initial creation

*/

vars

