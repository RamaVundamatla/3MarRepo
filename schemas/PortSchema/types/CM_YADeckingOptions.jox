    <JadeMethod name="getStringForPicture" id="4a8851f9-9bb0-420d-8b09-e37e8b675909">
        <source>getStringForPicture(): String;
//10 February 2009	cnwwc2	Initial creation
// this method returns the decking opting in a format of in/filling/out, eg 1/2/3. It will be used to 
// decide which picture to display on the satellite screen
vars
	rule: CM_YADeckingRule;	
	optIn, optFilling, optOut : Integer;
begin
	if self.isAdvanced(DeckingDirectionIn) then
		rule := self.getAdvancedRule(DeckingDirectionIn); 
		if rule.areaRule = DeckingRule_ByStack or rule.areaRule = DeckingRule_ByStackFill then		
			optIn := rule.stackRule;
			optFilling := rule.patternRule;
			optOut := rule.rowRule; 
		else
			optIn := rule.rowRule;
			optFilling := rule.patternRule;
			optOut := rule.stackRule; 		
		endif;
	else
		optFilling := DeckingRule_Custom;
	endif;

	
	return optIn.String &amp; "/" &amp; optFilling.String &amp; "/" &amp; optOut.String;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getStringFromConstant" id="dbe3cb3e-6c5c-44b8-a4e5-d3e36a15f5dc">
        <source>getStringFromConstant(_constant : Integer):String;
//11 February 2009	cnwwc2	Initial creation

vars

begin
	if _constant = DeckingRule_Increasing then
		return app.getErrorString(DeckingIncreasing);
	elseif _constant = DeckingRule_Decreasing then
		return app.getErrorString(DeckingDecreasing);
	elseif _constant = DeckingRule_MiddleOut then
		return app.getErrorString(DeckingMiddleOut);	
	elseif _constant = DeckingRule_Pyramid then
		return app.getErrorString(DeckingPyramid);	
	elseif _constant = DeckingRule_Random then
		return app.getErrorString(DeckingRandom);	
	elseif _constant = DeckingRule_Columnwise then
		return app.getErrorString(DeckingColumnwise);
	elseif _constant = DeckingRule_Tierwise then
		return app.getErrorString(DeckingTierwise);
	elseif _constant = DeckingRule_Topup then
		return app.getErrorString(DeckingTopup);
	elseif _constant = DeckingRule_SideToSide then
		return app.getErrorString(DeckingSideToSide);
	elseif _constant = DeckingRule_Custom then
		return app.getErrorString(DeckingCustom);
	elseif _constant = DeckingRule_ReverseOfOther then
		return app.getErrorString(DeckingOutReverse);
	endif;
end;</source>
        <Parameter name="_constant" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
