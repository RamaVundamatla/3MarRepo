    <JadeMethod name="getObjectAndPointsForPosition" id="4e3076d7-8eea-485d-bdc4-e28864e9a653">
        <source>getObjectAndPointsForPosition(x, y : Integer; xy1, xy2 : Point output) : Object;
// ---------------------------------------------------------------------------
// Created:     27 January 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpDrawingController	: SHP_BayDrawingController;
begin

	tmpDrawingController := self.myBayDrawingController;
	if tmpDrawingController = null then
		return null;
	endif;
	
	if y &lt;= tmpDrawingController.yHatchPos then
		return self.allObjectsOnDeck.findObjectInDict(x, y, xy1, xy2);
	elseif y &lt;= tmpDrawingController.yUnderDeckPos then
		return self.allHatches.findObjectInDict(x, y, xy1, xy2);
	endif;
	
	return self.allObjectsUnderDeck.findObjectInDict(x, y, xy1, xy2);

end;</source>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <Parameter name="xy1" type="Point" usage="output"/>
        <Parameter name="xy2" type="Point" usage="output"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="getObjectForPosition" id="1fff249e-983f-4679-9de4-ce7f27c1682d">
        <source>getObjectForPosition(x, y : Integer) : Object;
// ---------------------------------------------------------------------------
// Created:     27 January 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	xy1, xy2	: Point;
begin

	return self.getObjectAndPointsForPosition(x, y, xy1, xy2);

end;</source>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="getOnDeckOffset" id="e59f19eb-f689-4c4e-b758-768a79636a28">
        <source>getOnDeckOffset(_bay : CM_Bay; _bayDrawingController : SHP_BayDrawingController) : Integer;
// ---------------------------------------------------------------------------
// Created:     13 January 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpTier				: CM_TierDefn;
	wasLastUnavailable	: Boolean;
	maxTiersVisible		: Integer;
begin
	//cnwmc5 - 25 Oct 2013 - PAR 32847 - major changes to draw hatch lids correctly
	if _bay &lt;&gt; null then
		wasLastUnavailable := true;
		
		foreach tmpTier in _bay.allTiersOnDeck do
			if wasLastUnavailable then
				if _bayDrawingController.displayMode &lt;&gt; ShpDisplayMode_Defn 
				and tmpTier.isTotallyUnavailable() then
					wasLastUnavailable := true;
					maxTiersVisible := maxTiersVisible + 2;
					continue;
				endif;
				maxTiersVisible := maxTiersVisible + 1;
				wasLastUnavailable := false;
			else
				maxTiersVisible := maxTiersVisible + 1;
			endif;			
		endforeach;
		
		return _bayDrawingController.yOnDeckPos + (maxTiersVisible * _bayDrawingController.rowHeight).Integer;
	else
		return _bayDrawingController.yOnDeckPos + (_bayDrawingController.maxTiersOnDeck * _bayDrawingController.rowHeight).Integer;
	endif;
end;</source>
        <Parameter name="_bay" type="CM_Bay"/>
        <Parameter name="_bayDrawingController" type="SHP_BayDrawingController"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getPointsForObject" id="b13ef627-3b07-4d66-a969-d00becc5c63f">
        <source>getPointsForObject(_obj: Object; _x1: Integer output; _y1: Integer output; _x2: Integer output; _y2: Integer output) : Boolean;
// ---------------------------------------------------------------------------
// Created:     29 January 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	iter	: Iterator;
	tmpObj	: Object;	
	found	: Boolean;
begin

	if _obj = null then
		return false;
	endif;

	if _obj.isKindOf(CM_SlotController) or 
	   _obj.isKindOf(CM_SlotDefn) then
		iter := self.myObjectsOnDeckIterator;
		iter.reset;
		while iter.next(tmpObj) do
			if tmpObj = _obj then
				found := true;
				break;
			endif;
		endwhile;
		
		if (not found) then
			iter := self.myObjectsUnderDeckIterator;
			iter.reset;
			while iter.next(tmpObj) do
				if tmpObj = _obj then
					found := true;
					break;
				endif;
			endwhile;
		endif;

	elseif _obj.isKindOf(CM_HatchLid) then
		iter := self.myHatchesIterator;
		iter.reset;
		while iter.next(tmpObj) do
			if tmpObj = _obj then
				found := true;
				break;
			endif;
		endwhile;
	else
		app.writeStatement(class.name &amp; '::' &amp; method.name &amp; '  unhandled object ' &amp; _obj.String);
	endif;

	if found then
		iter.getCollection.ExtKeyDictionary.getIteratorKeys(_x1, _y1, _x2, _y2, iter);
	endif;

	return found;

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_x1" type="Integer" usage="output"/>
        <Parameter name="_y1" type="Integer" usage="output"/>
        <Parameter name="_x2" type="Integer" usage="output"/>
        <Parameter name="_y2" type="Integer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getRightLabelPosOD" id="8bf55b7a-e6d0-4443-b0ef-5e07668901c5">
        <source>getRightLabelPosOD() : Integer;
// ---------------------------------------------------------------------------
// Created:     05 July 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
begin
//app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' 1. self.leftSideMargin: ' &amp; self.leftSideMargin.String &amp; "  self.endPosOD: " &amp;  self.endPosOD.String );

	return (self.width - 30).Integer;
	// PAR 26760 return self.leftSideMargin + self.endPosOD + 3;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
