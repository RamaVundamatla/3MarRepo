    <JadeMethod name="changeOptions" id="fac0b82e-385a-4f85-8f04-161a645cec2e">
        <source>changeOptions() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 December 2011	cnwndl1	Initial creation

*/

vars

begin

	if self.optTableData.value then
		self.txtFilter.visible := false;
		self.tblFilterValues.visible := true;
		self.btnClear.visible := true;
		self.btnSelect.visible := true;
	elseif self.optUserData.value then
		self.tblFilterValues.visible := false;
		self.btnClear.visible := false;
		self.btnSelect.visible := false;
		self.txtFilter.visible := true;
	else
		self.tblFilterValues.visible := false;
		self.btnClear.visible := false;
		self.btnSelect.visible := false;
		self.txtFilter.visible := false;
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBtnClear" id="20a8a1f3-00b6-45e8-a424-6e4f06ef16ac">
        <source>doBtnClear() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 December 2011	cnwndl1	Initial creation

*/

vars

	index : Integer;
	startRow : Integer;
	endRow : Integer;

begin

	startRow := self.tblFilterValues.fixedRows + 1;
	endRow := self.tblFilterValues.rows;

	if endRow &gt;= startRow then
		foreach index in startRow to endRow do
			self.tblFilterValues.setCellText(index, 1, "0");
		endforeach;
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBtnSelectAll" id="35f0ba25-ca0b-4839-8ece-18a2dea7c5d9">
        <source>doBtnSelectAll() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 December 2011	cnwndl1	Initial creation

*/

vars

	index : Integer;
	startRow : Integer;
	endRow : Integer;

begin

	startRow := self.tblFilterValues.fixedRows + 1;
	endRow := self.tblFilterValues.rows;

	if endRow &gt;= startRow then
		foreach index in startRow to endRow do
			self.tblFilterValues.setCellText(index, 1, "1");
		endforeach;
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFilterSourceTable" id="0aba1514-e4f6-4559-982d-c02cd09ec4af">
        <source>doFilterSourceTable() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 December 2011	cnwndl1	Initial creation

*/

vars

	rowIndex : Integer;
	str : String;
	includeNull : Boolean;
	userEntered : Boolean;
	userEnteredValue : String;

begin

	if self.allSelected then
		foreach rowIndex in startRow to endRow do
			self.mySourceTable.accessRow(rowIndex).visible := true;
		endforeach;
		
	else
		includeNull := self.filterStrings.includes(CM_ColumnFilter.NullString);
		userEntered := self.optUserData.value;
		if userEntered then
			userEnteredValue := self.filterStrings.first;
		endif;
		foreach rowIndex in self.startRow to self.endRow do
			str := self.mySourceTable.getCellText( rowIndex, self.column ).trimBlanks[1:50];
			if ( str = null and includeNull ) then
				self.mySourceTable.accessRow(rowIndex).visible := true;
			elseif self.filterStrings.includes( str ) then
				self.mySourceTable.accessRow(rowIndex).visible := true;
			elseif userEntered and str.pos(userEnteredValue,1) &gt; 0 then
				self.mySourceTable.accessRow(rowIndex).visible := true;
			else
				self.mySourceTable.accessRow(rowIndex).visible := false;
			endif;
		endforeach;
		
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doOK" id="590e6e76-adac-46e1-8f30-f5ead1e0b742">
        <updating/>
        <source>doOK() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 December 2011	cnwndl1	Initial creation

*/

vars

	index : Integer;
	valuesStartRow : Integer;
	valuesEndRow : Integer;
	
	noneSelected : Boolean;
	str : String;
	msg : String;

begin

	app.mousePointer	:=	Busy;

	valuesStartRow := self.tblFilterValues.fixedRows + 1;
	valuesEndRow := self.tblFilterValues.rows;
	
	self.filterStrings.clear();
	self.allSelected := true;
	noneSelected := true;

	if self.optTableData.value then
		if endRow &gt;= startRow then
			foreach index in valuesStartRow to valuesEndRow do
				if self.tblFilterValues.getCellText(index, 1) = "1" then
					//selected item
					noneSelected := false;
					str := self.tblFilterValues.getCellText(index, 2);
					self.filterStrings.add(str);
				else
					//unselected item
					self.allSelected := false;
				endif;
			endforeach;
		endif;
		
		if noneSelected then
			msg := "You must select at least one item to include!";
			app.msgBox( msg, "Warning", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
		
	elseif self.optUserData.value then
		self.allSelected := false;
		str := self.txtFilter.text.trimBlanks;
		if str = null then
			self.filterStrings.add('"null"');
		else
			self.filterStrings.add(str);
		endif;
	
	endif;

	self.doFilterSourceTable();

	inheritMethod();

epilog

	app.mousePointer :=	Idle;

end;</source>
    </JadeMethod>
    <JadeMethod name="getFilterValuesFromSource" id="9defed8c-0a30-4284-a50b-7f2565a3a1e6">
        <source>getFilterValuesFromSource(  _strArray : StringArray io;  _intArray : IntegerArray io ) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 December 2011	cnwndl1	Initial creation

*/

vars

	rowIndex : Integer;
	str : String;
	includedPos : Integer;

begin

	if self.endRow &gt; self.startRow then
		foreach rowIndex in self.startRow to self.endRow do
			str := self.mySourceTable.getCellText( rowIndex, self.column ).trimBlanks;
			if str = null then
				str := '"null"';
			endif;
			if str.length &gt; 50 then
				str := str[1:50] &amp; "...";
			endif;
			if _strArray.isEmpty then
				includedPos := 0;
			else
				includedPos := _strArray.indexOf(str);
			endif;
			if includedPos = 0 then
				_strArray.add( str );
				_intArray.add( 1 );
			else
				_intArray[includedPos] := _intArray[includedPos] + 1;
			endif;
		endforeach;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_strArray" type="StringArray" usage="io"/>
        <Parameter name="_intArray" type="IntegerArray" usage="io"/>
    </JadeMethod>
