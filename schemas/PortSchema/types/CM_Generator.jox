    <JadeMethod name="wasContainerReceived" id="c4d463b3-9cf6-46ec-8612-9cbfe1c52d4c">
        <source>wasContainerReceived(_camsDateTime : TimeStamp) : Boolean;
//
// 29 Jun 2017	cnwrs1	TFS 4259 _ Penn Seaboard implimentation
//
vars
	vvr : CM_VehicleVisitRecord;
	ti : CM_TrackedItem;
	tr : CM_TITransaction;
	result : Boolean;
begin
	foreach vvr in self.allVisitRecords reversed do
		if vvr.allReceivedTrackedItems.includes(self) then
			foreach ti in vvr.allReceivedTrackedItems do
				if ti.cargoType = TI_CargoType_Container then
					foreach tr in ti.allTransactions do
						if tr.isCamsRoadReceiveType then
							if tr.camsTimeStamp = _camsDateTime then
								result := true;
								break;
							endif;
						endif;
					endforeach;
				endif;
			endforeach;
		endif;
	endforeach;
	return result;
end;

</source>
        <Parameter name="_camsDateTime" type="TimeStamp"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="wasContainerReleased" id="8ed584d5-e8a2-4ff7-97e2-98395f8a221a">
        <source>wasContainerReleased(_camsDateTime : TimeStamp) : Boolean;
//
// 29 Jun 2017	cnwrs1	TFS 4259 _ Penn Seaboard implimentation
//
vars
	vvr : CM_VehicleVisitRecord;
	ti : CM_TrackedItem;
	tr : CM_TITransaction;
	result : Boolean;
begin
	foreach vvr in self.allVisitRecords reversed do
		if vvr.allReleasedTrackedItems.includes(self) then
			foreach ti in vvr.allReleasedTrackedItems do
				if ti.cargoType = TI_CargoType_Container then
					foreach tr in ti.allTransactions do
						if tr.isCamsRoadReleaseType then
							if tr.camsTimeStamp = _camsDateTime then
								result := true;
								break;
							endif;
						endif;
					endforeach;
				endif;
			endforeach;
		endif;
	endforeach;
	return result;
end;
</source>
        <Parameter name="_camsDateTime" type="TimeStamp"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
