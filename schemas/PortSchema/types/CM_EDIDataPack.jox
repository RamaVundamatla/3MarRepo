    <JadeMethod name="loadDB" id="c2149cdc-4e12-4659-b8c1-7ae400e1f27e">
        <updating/>
        <source>loadDB(_mergeCargo: Boolean; _passport: CM_Passport input) updating;
//
// ccms 1976 01 dec 2010 cnwrs1
//
vars

begin
	on Exception do validationExceptionHandler(exception, _passport); //jlgzm1 tfs41747 11/12/2018
	app.setContinueCMExceptions(true);
	app.myTrxUA.trxUpdateEDITIPackComplete(self, false, _passport);
	//self.processEDITIs(false, _passport); //cnwrs1 par 26223 10 nov 2010
end;</source>
        <Parameter name="_mergeCargo" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="processEDITIs" id="d7e13fe8-cc2e-4b20-8208-a675f92ec3af">
        <updating/>
        <source>processEDITIs(_verifyOnly : Boolean; _passport: CM_Passport input) protected, updating;
//
// ccms 1976 01 dec 2010 cnwrs1
//
// 08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
//08 Oct 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// 07 Nov 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
// 11 Dec 2018 	jlgzm1	TFS 41747 Moved into CM_TrxControlUpdateAgent::trxUpdateEDITIPackComplete
constants
	ProgressBarRefresh	: Integer = 2000;	
vars
	pxyCargoItem : CM_TrackedItem;
	realCargoItem : CM_TrackedItem;
	ediTI : CM_EDITrackedItem;
	ediPackTI : CM_EDIPackTI;
	updCntrl : CMIF_TIUpdateController;
	tiSet : CM_TISet;
	terminal : CM_Terminal;
	updateMon : Boolean;
	done, todo : Integer;
	skipCount	: Integer;
	errorSet : CM_ErrorSet;
	progressInt	: TimeStampInterval;
	progressTS : TimeStamp;
begin
	/*
	// Arm our base exception handlers
	on Exception do validationExceptionHandler(exception, _passport);
	
	progressTS := app.actualTimeServer();// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	app.setContinueCMExceptions(true);
	create tiSet transient;
	terminal := self.getMyTerminal();
	if terminal = null then
		app.raiseCMException1(Err_InvalidTerminal, 'null', null, null);
		return;
	endif;
	create errorSet transient;
	updateMon := (_passport.myCMIFMonitor &lt;&gt; null);	
	todo := self.allEDITrackedItems.size;
	beginLoad;
	foreach ediTI in self.allEDITrackedItems do
		ediPackTI := ediTI.CM_EDIPackTI;
	
		done := done + 1;
		progressInt := app.actualTimeServer() - progressTS;// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		if updateMon and ((progressInt.getMilliseconds &gt;= ProgressBarRefresh) or (todo = done)) then
			_passport.myCMIFMonitor.updateProgress("Loading into JMT...", todo, done);
			progressTS := app.actualTimeServer();// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		endif;
		// 34574 check the status which may have been set in Fonterra hook code
		if ediPackTI.status = CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING then
			skipCount := skipCount + 1;
			continue;
		endif;
		if ediPackTI.messageMode = CM_EDITrackedItem.EDI_ACTION_ADD or ediPackTI.messageMode = CM_EDITrackedItem.EDI_ACTION_UPDATE then		//cnwmc5 - 4 Sep 2015 - PAR 36764
			if ediPackTI.id.trimBlanks = null then
				app.raiseCMException2(ERR_FIELD_ID, ediPackTI.id, 'ID', ETRow_Id, ediPackTI);
				continue;
			endif;
			realCargoItem := terminal.allOnsiteTIsByCargoTypeId[ediPackTI.cargoType, ediPackTI.id];
			if realCargoItem = null then
				app.raiseCMException2(ERR_FIELD_ID, ediPackTI.id, 'ID', ETRow_Id, ediPackTI);
				continue;
			endif;
			if not realCargoItem.isEmpty then
				app.raiseCMException5(ERR_NotEmpty, ediPackTI.id, null, ediPackTI.id, realCargoItem.commodity, null, ETRow_Commodity, ediPackTI);
			endif;
			//14 Apr 2014	NDL	Par 33978
			if  ediPackTI.operatorCode &lt;&gt; realCargoItem.operatorCode then
				app.raiseCMException2(Conta_opera_does_not_match_ope, realCargoItem.operatorCode, ediPackTI.operatorCode, ETRow_Operator, ediPackTI);
				continue;
			endif;
			pxyCargoItem := realCargoItem.pxyCreateUpdateProxy();
			tiSet.add(pxyCargoItem);
			pxyCargoItem.setPxyFromEDIPackTI(ediPackTI, updCntrl, _passport);
			pxyCargoItem.setSubTerminal(null);
		else
			app.raiseCMException1(EDI_Action_Is_Invalid, ediPackTI.messageMode, ETRow_MessageMode, null);			//cnwmc5 - 4 Sep 2015 - PAR 36764
		endif;
	endforeach;
	endLoad;
	if tiSet.isEmpty then
		// 34574 if all skipped, log this and continue into the update code to set the processed status
		if skipCount &gt; 0 and todo &gt; 0 and skipCount = todo then
			app.writeLog(class.name &amp; " " &amp; method.name &amp;  " all TIs marked to be skipped", LogAlways);
		else
			app.writeLog(class.name &amp; " " &amp; method.name &amp;  " no TIs found to load", LogAlways);
			return;
		endif;
	endif;
	
	updCntrl := app.createTIUpdateControl(TI_UPDMODE_NORMAL, null, null);
	updCntrl.setMyUserObject(self);
	updCntrl.setMyTransientTIs(tiSet);
	_passport.warningsAcknowledged := true;
	_passport.moveErrorsToSet(errorSet); //save off all current errors
	app.myTrxUA.trxUpdateEDITIPackComplete(_verifyOnly, updCntrl, self, _passport); //ccms1845
	_passport.addErrorsFromSet(errorSet);	//restore current errors back to
	*/
epilog
	/*
	endLoad;				// 08/04/2011 cnwmh5 #27347
	delete updCntrl;
	if _verifyOnly then
		tiSet.purge;	//clear out the unused proxies
	endif;
	delete tiSet;
	delete errorSet;
	*/
end;</source>
        <access>protected</access>
        <Parameter name="_verifyOnly" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
