        <Parameter name="_attrName" type="String"/>
        <ReturnType type="CM_TIArray"/>
    </JadeMethod>
    <JadeMethod name="getTotalTIRequests" id="74677927-3973-43f8-bd3f-2573741ab6d2">
        <source>getTotalTIRequests( _type : Integer ):Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 June 2011	cnwndl1	Initial creation

*/

vars

	outstanding : Integer;
	tmpBR : CM_BulkRelease;
	total : Integer;
	
begin

	if _type = BR_TYPE_ROAD or _type = -1 then
		foreach tmpBR in self.allRoadReqs do
			outstanding := tmpBR.getTotalStorageEmpties;
			total := total + outstanding;
		endforeach;
	endif;
	if _type = BR_TYPE_RAIL or _type = -1 then
		foreach tmpBR in self.allRailReqs do
			outstanding := tmpBR.getTotalStorageEmpties;
			total := total + outstanding;
		endforeach;
	endif;
	if _type = BR_TYPE_SHIP or _type = -1 then	
		foreach tmpBR in self.allShipReqs do
			outstanding := tmpBR.getTotalStorageEmpties;
			total := total + outstanding;
		endforeach;
	endif;
	if _type = BR_TYPE_PACKING or _type = -1 then	
		foreach tmpBR in self.allPackReqs do
			outstanding := tmpBR.getTotalStorageEmpties;
			total := total + outstanding;
		endforeach;
	endif;
	if _type = BR_PENDING or _type = -1 then	
		foreach tmpBR in self.allPendReqs do
			outstanding := tmpBR.getTotalStorageEmpties;
			total := total + outstanding;
		endforeach;
	endif;
	
	return total;

epilog

end;</source>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="isMaxBreached" id="c4f6d9ac-5908-4a19-baf3-ef0344821034">
        <source>isMaxBreached():Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 June 2011	cnwndl1	Initial creation	Par 27731

*/

vars

begin

	if self.myMTThreshold.maxThresholdLevel &lt; 1 then
		return false;
	endif;
	
	return self.allAvailable.size &gt; self.myMTThreshold.maxThresholdLevel;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isMinBreached" id="8afef838-b0ab-4220-bdc4-5604051d9196">
        <source>isMinBreached():Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 June 2011	cnwndl1	Initial creation	Par 27731

*/

vars

begin

	if self.myMTThreshold.minThresholdLevel &lt; 1 then
		return false;
	endif;

	return self.allAvailable.size &lt; self.myMTThreshold.minThresholdLevel;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="populateCell" id="6043fc4a-ccd6-4c51-8673-6aeea5988de3">
        <source>populateCell( _cell : JadeTableCell io; _entTableRow : EntTableRow );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 June 2011	cnwndl1	Initial creation	Par 27731

*/

vars

	attrName : String;
	cellText : String;
	cellObj : Object;
	colour : Integer;
	align : Integer;

begin

	attrName := _entTableRow.name;
	cellText := self.getDisplayStringForAttribute( attrName, false );
	cellObj := self.getCellObjectForAttribute( attrName );
		
	colour := Black;	//default value
	
	if attrName = ETRow_Balance then
		if cellText.Integer &lt; 0 then
			colour := Red;
		endif;
		
	elseif attrName = ETRow_MinThreshold then
		if not self.myMTThreshold.isActive then
			colour := Grey;
		elseif self.isMinBreached() then
			colour := Red;
		endif;
		
	elseif attrName = ETRow_MaxThreshold then
		if not self.myMTThreshold.isActive then
			colour := Grey;
		elseif self.isMaxBreached() then
			colour := Red;
		endif;
		
	endif;
	
	
	align := Table.Alignment_Right;	//default value
	
	if attrName = ETRow_Operator
	or attrName = ETRow_IsoGroup
	or attrName = ETRow_Grade
	then
		align := Table.Alignment_Left;
	endif;
	
	_cell.text := cellText;
	_cell.itemObject := cellObj;
	_cell.foreColor := colour;
	_cell.alignment := align;

epilog

end;</source>
        <Parameter name="_cell" type="JadeTableCell" usage="io"/>
        <Parameter name="_entTableRow" type="EntTableRow"/>
    </JadeMethod>
    <JadeMethod name="setBaseData" id="f846b23e-9170-409a-b5d0-2608c21e71c8">
        <updating/>
        <source>setBaseData(	_myMTThreshold : CM_MTThreshold;
				_myMTThresholdAgent : CM_MTThresholdAgent
				) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 June 2011	cnwndl1	Initial creation

*/

vars

begin

	self.myMTThreshold := _myMTThreshold;
	self.priority := myMTThreshold.processingPriority;
	self.myMTThresholdAgent := _myMTThresholdAgent;

epilog

end;</source>
        <Parameter name="_myMTThreshold" type="CM_MTThreshold"/>
        <Parameter name="_myMTThresholdAgent" type="CM_MTThresholdAgent"/>
    </JadeMethod>
</Class>
