    <JadeMethod name="tblGateLanes_cellInputReady" id="2438c174-e1ae-4c40-935c-bd05d03e3941">
        <controlMethod name="Table::cellInputReady"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblGateLanes_cellInputReady(table: Table input; inputControl: Control input; cleft: Real io; ctop: Real io; cwidth: Real io; cheight: Real io) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 November 2009	cnwjk3	Initial creation

*/

vars
	col : Integer;
begin
	self.tblGateLanes.getEntRowColumnByRowName(ETRow_NumberingDirection, col);
	if table.column = col then
		self.onNumDirectionClick(self.cmbNumDir);
	endif;
	self.tblGateLanes.getEntRowColumnByRowName(ETRow_ParkDirection, col);
	if table.column = col then
		self.onParkDirectionClick(self.cmbParkDir);
	endif;
	self.tblGateLanes.getEntRowColumnByRowName(ETRow_AccessDirection, col);
	if table.column = col then
		self.onAccessDirectionClick(self.cmbAccessDir);
	endif;
epilog

end;</source>
