    <JadeMethod name="setProxy" id="b0548a0d-d982-4ec1-a273-3831698b7d5c">
        <updating/>
        <source>setProxy(pCode, pDescription : String;_notAvailableForEntry :Boolean; pSpecies : CM_LogSpecies;
		_lengths: CM_ObjectSet; _treatments, _types : ObjectSet; _colour : Integer;
		_minSED, _maxSED, _minMeanSED, _maxMeanSED : Decimal) updating;
//--------------------------------------------------------------
//Created: 08 January 2002 By: cnwgd1
//--------------------------------------------------------------

vars
	theLengths	: CM_ObjectSet;
begin

	theLengths := _lengths;
	
	self.setSuperClassDetailsForProxy(pCode, pDescription, _notAvailableForEntry,null);
	
	self.minSED			:= _minSED;
	self.maxSED			:= _maxSED;
	self.minMeanSED		:= _minMeanSED;
	self.maxMeanSED		:= _maxMeanSED;
	
	theLengths.copy(self.allLogLengths);
	theLengths.copyNoDuplicates(self.allLogLengthsBySortOrder, true);
	_treatments.copy(self.allLogTreatments);
	_types.copy(self.allLogTypes);
	
	self.myLogSpecies	:= pSpecies;
	self.colour := _colour;
end;</source>
        <Parameter name="pCode" type="String"/>
        <Parameter name="pDescription" type="String"/>
        <Parameter name="_notAvailableForEntry" type="Boolean"/>
        <Parameter name="pSpecies" type="CM_LogSpecies"/>
        <Parameter name="_lengths" type="CM_ObjectSet"/>
        <Parameter name="_treatments" type="ObjectSet"/>
        <Parameter name="_types" type="ObjectSet"/>
        <Parameter name="_colour" type="Integer"/>
        <Parameter name="_minSED" type="Decimal"/>
        <Parameter name="_maxSED" type="Decimal"/>
        <Parameter name="_minMeanSED" type="Decimal"/>
        <Parameter name="_maxMeanSED" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="setRealLogSpecs" id="acd2c693-3ea0-4215-ad6d-ed96dd55c180">
        <source>setRealLogSpecs(_realCodeGroup : CM_CodeGroupLogSpecs);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 December 2014	cnwmc5	Initial creation

*/

vars
	pxyLength,
	length				: CM_LogLength;
	pxySpecies,
	species				: CM_LogSpecies;
	pxyTreatment,
	treatment			: CM_LogTreatment;
	pxyType,
	type				: CM_LogType;
	
	allRealLengths,
	allRealTreatments,
	allRealTypes		: CM_ObjectSet;
begin
	create allRealLengths transient;
	create allRealTreatments transient;
	create allRealTypes transient;
	
	foreach pxyLength in self.allLogLengths do
		length := _realCodeGroup.allLogLengths[pxyLength.code];
		if length &lt;&gt; null then
			allRealLengths.add(length);
		endif;
	endforeach;
	
	foreach pxyTreatment in self.allLogTreatments do
		treatment := _realCodeGroup.allLogTreatments[pxyTreatment.code];
		if treatment &lt;&gt; null then
			allRealTreatments.add(treatment);
		endif;
	endforeach;
	
	foreach pxyType in self.allLogTypes do
		type := _realCodeGroup.allLogTypes[pxyType.code];
		if type &lt;&gt; null then
			allRealTypes.add(type);
		endif;
	endforeach;
	
	self.allLogLengths.purge();
	self.allLogTreatments.purge();
	self.allLogTypes.purge();
	
	allRealLengths.copy(self.allLogLengths);
	allRealTreatments.copy(self.allLogTreatments);
	allRealTypes.copy(self.allLogTypes);
	
epilog
	delete allRealLengths;
	delete allRealTreatments;
	delete allRealTypes;
end;</source>
        <Parameter name="_realCodeGroup" type="CM_CodeGroupLogSpecs"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="717e5608-fa05-423f-ba3b-9bd087d72a71">
        <source>validateForCreate();
//--------------------------------------------------------------
//Created: 08 January 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	if self.myLogSpecies &lt;&gt; null and
	   self.myLogSpecies.allLogGrades.includesKey(code) then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.code, null, null);
	endif;

	self.validateMe;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="86cd35c8-f45c-4617-aac6-1127286bf35f">
        <source>validateForDelete();
//--------------------------------------------------------------
//Created: 08 January 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	if (not self.allLocationRestrictions.isEmpty) then
		app.raiseCMException2(ObjectStillHasEntries, 'Log Grade ' &amp; self.code, 
							  self.allLocationRestrictions.size.String &amp; ' Log Rows', null, null);
	endif;

	if (not self.allProducts.isEmpty) then
		app.raiseCMException2(ObjectStillHasEntries, 'Log Grade ' &amp; self.code, 
							  self.allProducts.size.String &amp;' '&amp; app.getErrorString(Cargo_subtype_data), null, null);
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="validateMe" id="ed7940ae-713b-477e-bb8c-edf174ad73bb">
        <source>validateMe() protected;
//--------------------------------------------------------------
//Created: 08 January 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	tmpType		: CM_LogType;
	tmpTreat	: CM_LogTreatment;
	tmpLen		: CM_LogLength;
	tmpCodeGrp	: CM_CodeGroupLogSpecs;
begin

	inheritMethod();
	
	if self.myLogSpecies = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'Log Species', null, null);
		app.raiseCMException(Input_required_field_logSpecie, null, null); // cnwdb2	PAR 35364


	else
		// do not check for null as if null we want an error!
		tmpCodeGrp := self.myLogSpecies.myCodeGroup.CM_CodeGroupLogSpecs;
		
		// Having a problem with data getting out of sync and a code for another
		// supplier getting assigned to a product.  Put in belts and braces check here
		// to ensure codes assigned are always in the code group.
		
		foreach tmpType in self.allLogTypes do
			if (not tmpCodeGrp.allLogTypes.includes(tmpType)) then
				app.raiseUnexpectedProgramError(class.name, method.name,
					'Invalid Log Type (' &amp; tmpType.String &amp; ') for Code Group ' &amp; tmpCodeGrp.String);
			endif;
		endforeach;

		foreach tmpTreat in self.allLogTreatments do
			if (not tmpCodeGrp.allLogTreatments.includes(tmpTreat)) then
				app.raiseUnexpectedProgramError(class.name, method.name,
					'Invalid Log Treatment (' &amp; tmpTreat.String &amp; ') for Code Group ' &amp; tmpCodeGrp.String);
			endif;
		endforeach;

		foreach tmpLen in self.allLogLengths do
			if (not tmpCodeGrp.allLogLengths.includes(tmpLen)) then
				app.raiseUnexpectedProgramError(class.name, method.name,
					'Invalid Log Length (' &amp; tmpLen.String &amp; ') for Code Group ' &amp; tmpCodeGrp.String);
			endif;
		endforeach;

	endif;
	
	
	
end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
