    <JadeMethod name="tblMeasurement_gotFocus" id="236820a7-b80f-40c7-a4ca-1bf97b9de713">
        <controlMethod name="Table::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblMeasurement_gotFocus(table: Table input) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13/02/2013	cnwdap1	Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
*/
vars
	editTable 	: CM_EntryTable;
	row			: Integer;
	str			: String;

begin
	editTable := self.getEntryTableForRow(table.CMUI_MeasurementTable.rowName);
	if editTable &lt;&gt; null then
		row := editTable.getRowByControlName(table.name);
		str := editTable.accessCell(row, editTable.ColumnValue).text;	
	endif;
	table.CMUI_MeasurementTable.setValues(str);	
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblMeasurement_lostFocus" id="55547657-9d74-499c-be71-f45d3a8c6e0e">
        <controlMethod name="Table::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblMeasurement_lostFocus(table: Table input) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03/03/2013	cnwdap1	Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
*/
vars
	tbl : CM_EntryTable;
	height : Integer;
	rowHeight : Real;

begin	
	tbl := self.getEntryTableForRow(table.CMUI_MeasurementTable.rowName);
	if tbl &lt;&gt; null then
		height := tbl.accessRow(1).height;
		rowHeight := height.Real;
	endif;
	self.myAssistant.measurementTableLostFocus(tbl, rowHeight, table.CMUI_MeasurementTable);
	if tbl &lt;&gt; null then
		tbl.cnEcResizeContents();
	endif;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
