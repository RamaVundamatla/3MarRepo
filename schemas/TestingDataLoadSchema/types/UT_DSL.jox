    <JadeMethod name="doQueueUnplannedUnworkedCargo" id="5c00e2ef-5ec1-42be-9eac-5449aeb8def8">
        <source>doQueueUnplannedUnworkedCargo(  _ti : CM_TrackedItem; _job : CM_VoyageJob output; _wle : CM_WorkListEntry output );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 May 2010	cnwndl1	Initial creation	Par 23603

*/

vars

	targetLocn : CM_LocationsController;
	moveController : CMIF_MoveController;
	tiArray	: CM_TIArray;
	params : CMIF_AutoplanParams;
	
begin

	//establish our target location
	if _ti.myPrimaryQueuedLocation &lt;&gt; null then
		targetLocn := _ti.myPrimaryQueuedLocation;
	elseif _ti.myPrimaryPlannedLocation &lt;&gt; null then
		targetLocn := _ti.myPrimaryPlannedLocation;
	else
		// no target known, do an autoplan
		create tiArray transient;
		create params transient;
		params.allTrackedItems.add(_ti);
		params.moveMode := PLANNING_MODE;
		params.myTerminalArea := null;
		params.showWarningWhenNoPlan := false;
		app.myTrxUA.trxUpdateAutoplanTrackedItems(params, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
		if _ti.myPrimaryPlannedLocation &lt;&gt; null then
			targetLocn := _ti.myPrimaryPlannedLocation;
		endif;
	endif;

	// set up the move controller for a queued move
	create moveController transient;
	moveController.setMyTrackedItem(_ti);
	moveController.setMyOriginatingLocation(_ti.myPrimaryActualLocation);
	moveController.setMoveMode(QUEUE_MODE);	
	moveController.setMyToPrimaryLocation(targetLocn);
	moveController.transferType := VESSEL_TYPE_RORO; // CNWAB1 MAY17 1; // 0 = LOLO 1 = RORO  TFS 4435
	moveController.isNonCraneVoyageMove := true; 

	// update the cargo item with the queued move
	app.myPassport.setWarningsIgnored(true);
	app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	//return the job that was created.
	if moveController.myWorkListEntry &lt;&gt; null then
		_wle := moveController.myWorkListEntry;
		_job := _wle.job.CM_VoyageJob;
	endif;

epilog

	delete moveController;
	delete tiArray;
	delete params;
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_job" type="CM_VoyageJob" usage="output"/>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="output"/>
    </JadeMethod>
    <JadeMethod name="doStwStageCargo" id="993ee322-6058-4b55-923a-842b9b8729c1">
        <source>doStwStageCargo(	_ti : CM_TrackedItem;
					_reserveDetail : CM_ReserveDetail input;
					_targetLocation : CM_LocationsController );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 May 2017	cnwndl1	Initial creation	TFS 4016

*/

vars

	moveController : CMIF_MoveController;
	quantity : Integer;
	weight : Decimal [16,4];

begin

	create moveController transient;
	moveController.setMyTrackedItem( _ti );
	moveController.setMoveMode( REAL_MODE );
	if _ti.isBulkByQuantity then	
		if quantity &lt;&gt; 0 then
			moveController.setQuantity(quantity);
		elseif _ti.totalQuantity &lt;&gt; 0 then
			moveController.setQuantity(_ti.totalQuantity);
		endif;
	elseif _ti.isBulkByWeight or _ti.isBulkByVolume then
		if weight &lt;&gt; 0 then
			moveController.setWeight(weight);
		elseif _ti.totalWeight &lt;&gt; 0 then
			moveController.setWeight(_ti.totalWeight);
		endif;
	endif;
		
	moveController.setMyToPrimaryLocation( _targetLocation );
		
	app.myPassport.setWarningsIgnored(true);
	app.myTrxUA.trxStageCargoForRelease(moveController, _reserveDetail, false, app.myPassport);

epilog

	delete moveController;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_reserveDetail" type="CM_ReserveDetail" usage="input"/>
        <Parameter name="_targetLocation" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="ediDBLoad" id="d4f0073a-f310-42b8-9023-c21e64c4e14a">
        <source>ediDBLoad(_ediFile: CM_EDIFile);
//17 December 2008	cnwdw1	
//
vars
	ediAgent: CM_EDIControllerAgent;
	ediData: CM_EDIData;
	ediTi	: CM_EDITrackedItem;
	remarks : String;
	setRemarks	: Boolean;
	createdBy   : String;
	ediFile		: CM_EDIFile;
begin
	create ediAgent transient;
	ediAgent.setTerminal(self.getTerminal());
	
	ediData := _ediFile.ediData;

	ediAgent.verifyEdiData(ediData);
	
	ediFile := _ediFile;
	
	setRemarks := true;
	if self.opts.includesKey("SetRemarks") then
		setRemarks := self.opts.bool("SetRemarks");
	endif;
	if setRemarks then
		self.updateEDITIRemarks(ediFile);
	endif;
		
	ediAgent.loadEdiDb(null, ediData, false);
	/////self.assertNoTrxErrorsOrWarnings();								// 08/04/2013 cnwmh5
	
epilog
	delete ediAgent;
end;</source>
        <Parameter name="_ediFile" type="CM_EDIFile"/>
    </JadeMethod>
    <JadeMethod name="ediDeleteUserDefinedDefinition" id="39e2a46a-05eb-4fcf-accc-39f2c16b4049">
        <source>ediDeleteUserDefinedDefinition(_userDefinedName: String; _fileType: Integer);
//22 December 2008	cnwdw1	
//
vars
	fileType: CM_EDIFileTypeUser;
begin
	fileType := app.myRoot.allEDIFileTypes[_fileType, _userDefinedName].CM_EDIFileTypeUser;
	if fileType &lt;&gt; null then
		app.myTrxDA.trxDeleteEDIFileTypeUser(fileType, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;
end;</source>
