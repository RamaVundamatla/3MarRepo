    <JadeMethod name="tblView2_dblClick" id="49193b7d-354e-40bb-b59f-cf5a6b57eedf">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblView2_dblClick(table: CM_DataTable input) updating;
// ---------------------------------------------------------------------------
// Created:     05 April 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	obj : Object;
begin
	if table.row = 1 then
		if self.filterCargoTypeId = BOLType_Log then  //ref: Par 9917 HJG
			self.columnTblView2 := table.column;
			self.sortAscendingTblView2 := table.sortAscending;
		endif;
		
		table.resortTableByColumn(table.column);
		table.colourRows(self.colorRow1, self.colorRow2);
	else
		obj := table.accessRow(table.row).itemObject;
		if CM_TrackedItem.hasInstance(obj) then
			self.myAssistant.showCargoEnquiry(obj.CM_TrackedItem);
		endif;		
	endif;

end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
