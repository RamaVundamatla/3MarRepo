    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>TFS 1904 (980) Bill of Lading multiple split reporting</text>
    <DbClassMap file="query"/>
    <ImplicitInverseRef name="myBOLIn" id="bf027973-e76e-40c3-851d-f7d98083889f">
        <embedded/>
        <type name="CM_BOLIn"/>
        <access>protected</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myVoyage" id="6ded3351-04fc-4573-bfb3-ed154f7b62ed">
