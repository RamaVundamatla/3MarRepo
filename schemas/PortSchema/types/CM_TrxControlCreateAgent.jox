    <JadeMethod name="trxCreateOwnershipChange" id="9627f787-16e9-4e77-bcbc-4105a34816e3">
        <updating/>
        <source>trxCreateOwnershipChange(_pxyOwnerShipChange : CM_OwnershipChange input;
					  _realOwnerShipChange : CM_OwnershipChange output;
					  _passport : CM_Passport input)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 May 2023 navtnr20	TFS CR 58507	Task 58209: Jade - TRX CM_OwnershipChange

*/

vars
	theTerminal : CM_Terminal;
begin
// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;

	app.myUtilityCA.utlCreateOwnershipChange(_pxyOwnerShipChange,  _realOwnerShipChange,  _passport);
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_pxyOwnerShipChange" type="CM_OwnershipChange" usage="input"/>
        <Parameter name="_realOwnerShipChange" type="CM_OwnershipChange" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCreateOwnershipChangeAndDtl" id="74412bd0-b893-45c5-9ff2-c56d003881de">
        <updating/>
        <source>trxCreateOwnershipChangeAndDtl(_pxyOwnerShipChange : CM_OwnershipChange input;
					  _realOwnerShipChange : CM_OwnershipChange output;
					  _cmifOwnershipDetails : CMIF_OwnershipChangeDetail io;
					  _passport : CM_Passport input)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 July 2023 navmv20 CR 58239 Task 58241: UI- Open COO Maint in Update mode
23 August 2023	navmv20	CR 59440 Task 59441: Jade - Ownership Change Release Request Validation

*/

vars
	theTerminal : CM_Terminal;
	pxyOwnershipDetail,
	realOwnnershipDetail, pxySubDetail, realSubDetail: CM_OwnershipChangeDetail;
begin
// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;

	app.myUtilityCA.utlCreateOwnershipChange(_pxyOwnerShipChange,  _realOwnerShipChange,  _passport);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	foreach pxyOwnershipDetail in _cmifOwnershipDetails.allPxyOwnershipChangeDetails do
		pxyOwnershipDetail.setOwnershipChange(_realOwnerShipChange);
		app.myUtilityCA.utlCreateOwnershipChangeDetail(pxyOwnershipDetail,  realOwnnershipDetail,  _passport);

		// ### TFS BUG 64115 13MAY2024 NAVAB1
		if _passport.hasErrors then
			return;
		endif;
		
		if not self.checkValidationWithPassport(_passport) then
			return;
		endif;

		// ### TFS BUG 64115 13MAY2024 NAVAB1
		foreach pxySubDetail in pxyOwnershipDetail.allSubDetails discreteLock do
			pxySubDetail.setMyParent(realOwnnershipDetail);
			app.myUtilityCA.utlCreateOwnershipChangeDetail(pxySubDetail,  realSubDetail,  _passport);

			if not self.checkValidationWithPassport(_passport) then
				return;
			endif;
		
		endforeach;
		
		_cmifOwnershipDetails.allRealOwnershipChangeDtls.add(realOwnnershipDetail);
	endforeach;
	
	_cmifOwnershipDetails.postValidateAvailability(); //21/05/2024	navkc1 Bug 64182
	
	_realOwnerShipChange.setOrigOperatorFreeDays(); // ### TFS BUG 64126 16MAY2024 NAVAB1
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_pxyOwnerShipChange" type="CM_OwnershipChange" usage="input"/>
        <Parameter name="_realOwnerShipChange" type="CM_OwnershipChange" usage="output"/>
        <Parameter name="_cmifOwnershipDetails" type="CMIF_OwnershipChangeDetail" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCreateOwnershipChangeDtl" id="c468fa79-3655-44aa-9ca9-b31dc7db0511">
