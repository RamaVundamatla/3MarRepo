    <JadeMethod name="inScrollZone" id="ed963558-6676-4b45-9140-804d6c501af3">
        <source>inScrollZone(x, y : Real) : Boolean protected;
// ---------------------------------------------------------------------------
// Created:     13 July 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
constants
	ScrollMargin	: Integer = 25;
vars

begin

	if x &lt;= ScrollMargin or y &lt; ScrollMargin then
		return true;
	endif;
	
	if x &gt;= (self.clientWidth - ScrollMargin) or
	   y &gt;= (self.clientHeight - ScrollMargin) then
		return true;
	endif;
	  
	return false;
end;</source>
        <access>protected</access>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="labels" id="24b006ba-456b-477e-802c-2b69482f76bc">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>labels(set: Boolean; _value: Integer io) updating, mapping;
// ---------------------------------------------------------------------------
// Created:     29 January 2002 by cnwrs2
//
// Purpose:     Uses the same constant values as for Scroll Bars
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if (not set) then
		_value := self.labels;
		return;
	endif;
	
	self.labels := _value;
	
	if _value = ScrollBars_None then
		self.hideControl(self.myHLabels);
		self.hideControl(self.myVLabels);
		
	elseif _value = ScrollBars_Horizontal then
		self.showControl(self.myHLabels);
		self.hideControl(self.myVLabels);

	elseif _value = ScrollBars_Vertical then
		self.hideControl(self.myHLabels);
		self.showControl(self.myVLabels);

	elseif _value = ScrollBars_Both then
		self.showControl(self.myHLabels);
		self.showControl(self.myVLabels);
		self.showControl(self.myTopLeftFillerFrame);
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="positionHScrollBar" id="624d2de0-f94c-4cf3-a5f4-9c187054740f">
        <source>positionHScrollBar() protected;
// ---------------------------------------------------------------------------
// Created:     15 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	verticalScrollBar		: Integer;
	tmpLeft,
	tmpWidth,tmpTop				: Real;
begin
	if self.scrollsVertically() then
		verticalScrollBar := ScrollBarWidth;
	endif;
	tmpWidth := self.clientWidth;

	if self.myHScroll &lt;&gt; null then
		if self.vLabelsAlignLeft then
			tmpLeft := self.myBottomRightFillerFrame.width;
		endif;
		tmpTop := self.clientHeight - ScrollBarWidth;
		//self.myHScroll.move(tmpLeft, self.clientHeight - ScrollBarWidth, self.width - verticalScrollBar, ScrollBarWidth);
		
		self.myHScroll.move(tmpLeft+self.leftLabelMargin, tmpTop, self.width - verticalScrollBar-self.leftLabelMargin, ScrollBarWidth);
		self.myHScroll.zOrder(1);								
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="positionVScrollBar" id="752c2fc5-26f6-4c10-a1cf-de438884ed70">
        <source>positionVScrollBar() protected;
// ---------------------------------------------------------------------------
// Created:     15 January 2002 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	horizontalScrollBar		: Integer;
	tmpLeft,
	tmpHeight				: Real;
begin

	if self.scrollsHorizontally() then
		horizontalScrollBar := ScrollBarWidth;
	endif;
	tmpHeight := self.clientHeight - self.bottomLabelMargin;

	if self.myVScroll &lt;&gt; null  then
		if (not self.vLabelsAlignLeft) then
			tmpLeft := (self.clientWidth - ScrollBarWidth);
		endif;
		self.myVScroll.move(tmpLeft, 0, ScrollBarWidth, tmpHeight - horizontalScrollBar);						
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="repositionAfterResize" id="5ac4c3d9-3e49-4724-a13c-d9af91435381">
        <updating/>
        <source>repositionAfterResize() updating;
// ---------------------------------------------------------------------------
// Created:     30 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	inheritMethod();

	if self.myHLabels &lt;&gt; null then
		self.myHLabels.repositionAfterResize();
	endif;		
	if self.myVLabels &lt;&gt; null then
		self.myVLabels.repositionAfterResize();
	endif;
	self.positionHScrollBar();
	self.positionVScrollBar();
	if self.myBottomRightFillerFrame &lt;&gt; null then
		self.myBottomRightFillerFrame.repositionAfterResize();
		self.myTopLeftFillerFrame.repositionAfterResize();
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="repositionScrollBars" id="080bfefe-7702-407a-9b72-96b644f60662">
        <source>repositionScrollBars();
// ---------------------------------------------------------------------------
// Created:     29 January 2002 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
24 Jun 2008	cnwkpd1	PAR #17214 - Rework visibility of top left filler frame to handle no labels

*/

vars
	tmpClientWidth,
	tmpClientHeight,
	newTop,
	newLeft		: Integer;
	hScrollMax	: Integer;
	isHScrollVisible,
	isVScrollVisible	: Boolean;
	tmpHScroll	: CMUI_ScrollableHScroll;
	tmpVScroll	: CMUI_ScrollableVScroll;
begin

	tmpClientWidth 	:= self.clientWidth;
	tmpClientHeight	:= self.clientHeight;

   	tmpHScroll	:= self.myHScroll;
   	tmpVScroll	:= self.myVScroll;

	isHScrollVisible	:= tmpHScroll.visible;
	isVScrollVisible	:= tmpVScroll.visible;

 	tmpHScroll.min		:= 1;
   	tmpVScroll.min		:= 1;

   	if self.myScrollingFrame &lt;&gt; null then
		tmpHScroll.max		:= self.myScrollingFrame.width.Integer;
		tmpVScroll.max		:= self.getVerticalHeight().Integer;
	else
		tmpHScroll.max		:= tmpClientWidth;
		tmpVScroll.max		:= tmpClientHeight - self.bottomLabelMargin.Integer;
	endif;
	
   	tmpHScroll.smallChange	:= (tmpClientWidth / 3).Integer;
   	tmpVScroll.smallChange	:= (tmpClientHeight / 3).Integer;

   	tmpHScroll.largeChange 	:= tmpClientWidth - 20;
   	tmpVScroll.largeChange 	:= tmpClientHeight - 20;

	if self.scrollsHorizontally() then
		self.positionHScrollBar();
		tmpHScroll.visible := true;
		if self.hasVLabels then
			tmpHScroll.max := (self.myScrollingFrame.width - tmpClientWidth + self.myVLabels.width).Integer;
		else
			tmpHScroll.max := (self.myScrollingFrame.width - tmpClientWidth).Integer;
		endif;
		newLeft := tmpHScroll.value;
	else
		self.hideControl(tmpHScroll);
		newLeft := 0;
	endif;

	if self.scrollsVertically() then
		self.positionVScrollBar();
		newTop := tmpVScroll.value;
		if self.hasHLabels then
			tmpVScroll.max := (self.getVerticalHeight() - tmpClientHeight + self.myHLabels.height + self.bottomLabelMargin).Integer;
		else
			tmpVScroll.max := (self.getVerticalHeight() - tmpClientHeight + self.bottomLabelMargin).Integer;
		endif;
		tmpVScroll.visible := true;
	else
		self.hideControl(tmpVScroll);
		newTop := 0;
	endif;

	if self.hLabelsAlignBottom then
		// change in visible of scrollbar so need to
		// move labels if they are present.
		if tmpHScroll.visible then
			// H scroll is now visible so
			self.myHLabels.top := self.clientHeight - self.myHLabels.height - tmpHScroll.height;
		else
			// H scroll is now NOT visible so
			self.myHLabels.top := self.clientHeight - self.myHLabels.height;
		endif;
		self.myTopLeftFillerFrame.top := self.myHLabels.top - self.bottomLabelMargin;			
		self.myVScroll.zOrder(1);
	endif;

	if (not self.vLabelsAlignLeft) then
		if tmpVScroll.visible then
			// V scroll is now visible so
			self.myVLabels.top := self.clientWidth - self.myVLabels.width - tmpVScroll.width;
		else
			// V scroll is now NOT visible so
			self.myVLabels.top := self.clientWidth - self.myVLabels.width;
		endif;
	endif;

	if tmpHScroll.visible and 
	   tmpVScroll.visible then
		tmpHScroll.max := tmpHScroll.max + ScrollBarWidth;
		tmpVScroll.max := tmpVScroll.max + ScrollBarWidth;
	   	self.myBottomRightFillerFrame.repositionAfterResize();		
	   	self.myBottomRightFillerFrame.visible := true;
	else
	   	self.myBottomRightFillerFrame.visible := false;
	endif;

	if newTop &lt;&gt; self.myScrollingFrame.top or 
	   newLeft &lt;&gt; self.myScrollingFrame.left then
		self.scrollControl(ScrollBar_Horizontal, newLeft);
		self.scrollControl(ScrollBar_Vertical, newTop);
	endif;

	self.myBottomRightFillerFrame.zOrder(1);		// send to the front
	self.myTopLeftFillerFrame.visible := (tmpHScroll.visible or tmpVScroll.visible) and 
										 (self.myHLabels.visible or self.myVLabels.visible) or // PAR #17214
										 (self.myHLabels.visible and self.myVLabels.visible);	// 10 SEP 2008 CNWDZ2 par 17914 should be visible if labels are visible.	
	self.myTopLeftFillerFrame.zOrder(1);		// send to the front
	
end;</source>
    </JadeMethod>
    <JadeMethod name="resizeScrollingFrame" id="17bb27b7-8381-4bb1-835a-fd97589ed330">
        <source>resizeScrollingFrame(pWidth, pHeight : Real);
// ---------------------------------------------------------------------------
// Created:     29 January 2002 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if self.myScrollingFrame &lt;&gt; null then
		self.myScrollingFrame.width := pWidth;
		self.myScrollingFrame.height := pHeight;
	endif;

// not sure if want to touch the label heights here as
// these should have been updated outside here ???
// Leave as an increase if not long enough
	if self.hasHLabels and
	   self.myHLabels &lt;&gt; null and
	   self.myHLabels.width &lt; pWidth then
		self.myHLabels.width := pWidth;
	endif;
	
	if self.hasVLabels and
	   self.myVLabels &lt;&gt; null and
	   self.myVLabels.height &lt; pHeight - self.bottomLabelMargin then
		self.myVLabels.height := pHeight - self.bottomLabelMargin;
	endif;

	self.repositionScrollBars();

end;</source>
        <Parameter name="pWidth" type="Real"/>
        <Parameter name="pHeight" type="Real"/>
    </JadeMethod>
    <JadeMethod name="scrollBars" id="6489fabc-5bea-4b2a-a707-c0f5f031c5bd">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>scrollBars(set: Boolean; _value: Integer io) updating, mapping;
// ---------------------------------------------------------------------------
// Created:     29 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if (not set) then
		_value := self.scrollBars;
		return;
	endif;
	
	self.scrollBars := _value;
	
	if _value = ScrollBars_None then
		self.hideControl(self.myHScroll);
		self.hideControl(self.myVScroll);
		
	elseif _value = ScrollBars_Horizontal then
		self.showControl(self.myHScroll);
		self.hideControl(self.myVScroll);

	elseif _value = ScrollBars_Vertical then
		self.hideControl(self.myHScroll);
		self.showControl(self.myVScroll);

	elseif _value = ScrollBars_Both then
		self.showControl(self.myHScroll);
		self.showControl(self.myVScroll);
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="scrollBottomLeft" id="00679fa7-17fa-41f3-b16b-85b263cbfd45">
        <source>scrollBottomLeft();
// ---------------------------------------------------------------------------
// Created:     08 March 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	app.mousePointer := Window.MousePointer_HourGlass;
	self.scrollTo(1, self.myVScroll.max);
	
epilog 
	app.mousePointer := Window.MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="scrollBottomRight" id="afa91dee-2b03-41f4-b96d-fe60ad0d1bc0">
