    <JadeMethod name="setInvLineTypeCollection" id="18b5bacc-6a0a-471c-9c02-dab11aa53181">
        <updating/>
        <source>setInvLineTypeCollection() updating;
/*
Purpose:			

Date		Who		Reason
30 December 2022	navab1	TFS CR 55622 TASK 55690
*/

vars
	mapping : CM_InvoiceShipTermMapping;
	invLineType : CM_InvoiceLineDesc;
begin
	self.allShipTermMappingsByInvLnType.clear();
	
	
	foreach mapping in self.allShipTermMappings discreteLock do
		foreach invLineType in mapping.allInvoiceLineTypes discreteLock do
			self.allShipTermMappingsByInvLnType.tryPutAtKey(invLineType,mapping);
		endforeach;
	endforeach;
	
epilog

end;</source>
    </JadeMethod>
