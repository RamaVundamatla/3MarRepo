    <JadeMethod name="btnConfig_click" id="42dcd997-aa62-469c-a84e-9fe57e2b2509">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnConfig_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 October 2019	jlgndl1	Initial creation	TFS 46911

*/

vars
	obj : Object;
	theForm : CMUI_ObjectCriteriaLineForm;
begin

	obj := self.myTerminal.myRoadGateCargoCheckCriteria;

	create theForm transient;

	theForm.setMyTerminal(self.myTerminal);
	
	theForm.setBaseData(	CM_ObjectMatchCriteria.RoadGateCargoCheckInt,	//_context : Integer;
							null,	//_contextObj : CM_Object;
							obj.CM_ObjectMatchCriteria,	//_myObjectMatchCriteria : CM_ObjectMatchCriteria;
							null,	//_myListForm : CMUI_ObjectCriteriaListForm
							self	//_myParentForm: CM_BaseForm
							);
	theForm.showModal();
	
	self.setConfigButton();
	
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnUseInJob_click" id="1b24522f-3302-42b1-ac7e-e51778e3a264">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnUseInJob_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 October 2019	jlgndl1	Initial creation	TFS 46911

*/

vars

begin

	if self.myParentForm &lt;&gt; null and self.myParentForm.isKindOf(CMUI_ReleaseCargoForm) then
		self.myParentForm.CMUI_ReleaseCargoForm.cmbVoyageCode.setObject( self.selectedVoyage );
		self.myParentForm.CMUI_ReleaseCargoForm.cmbConsignee.setForObject( self.selectedConsignee );
	endif;
	self.btnCancel.click( self.btnCancel );
	
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="populateTblInventory" id="5b7cc1c1-91b0-4404-9c63-8cbb3149eaac">
        <source>populateTblInventory();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Mar 2019	jlgdi1	TFS# 41721 Initial creation

*/

constants
	BY_VOLUME : Integer = 1;
	BY_WEIGHT : Integer = 2;

vars
	iterator : Iterator;
	cmifCargoAvailability : CMIF_CargoAvailability;
	row : String;
	quantityAvailable : Integer;
	volumeAvailable : Decimal[16,4];
	weightAvailable : Decimal[16,4];
	sign : String;
	rowIndex : Integer;
	
begin
	self.setTblInventory();
	
	if self.myCollection &lt;&gt; null then
		iterator := self.myCollection.createIterator();
		while iterator.next(cmifCargoAvailability) do	
			quantityAvailable := 0;
			sign := "";
			row := cmifCargoAvailability.voyageCode &amp; Tab &amp; 
				   cmifCargoAvailability.operatorCode &amp; Tab &amp;
				   cmifCargoAvailability.cargoTypeDesc &amp; Tab &amp; 
				   cmifCargoAvailability.cargoSubType &amp; Tab &amp; 
				   cmifCargoAvailability.consignee &amp; Tab ;
				   
			
			if cmifCargoAvailability.showByType = BY_WEIGHT then
				weightAvailable := cmifCargoAvailability.totalWeight - 
								   cmifCargoAvailability.totalWeightLeaving;	
				if cmifCargoAvailability.totalWeightLeaving &gt; 0 then 
					sign := "-";
				endif;
								   
				row := row &amp; 
						cmifCargoAvailability.totalWeight.asStringJMT &amp; Tab &amp; 
						sign &amp; cmifCargoAvailability.totalWeightLeaving.asStringJMT &amp; Tab &amp;
						weightAvailable.asStringJMT &amp; Tab ;
						
			elseif cmifCargoAvailability.showByType = BY_VOLUME then 
				volumeAvailable := cmifCargoAvailability.totalVolume - 
								   cmifCargoAvailability.totalVolumeLeaving;
								   
				if cmifCargoAvailability.totalVolumeLeaving &gt; 0 then 
					sign := "-";
				endif;
								   
				row := row &amp; 
						cmifCargoAvailability.totalVolume.asStringJMT &amp; Tab &amp; 
						sign &amp; cmifCargoAvailability.totalVolumeLeaving.asStringJMT &amp; Tab &amp;
						volumeAvailable.asStringJMT &amp; Tab ;
						
			else
				quantityAvailable := cmifCargoAvailability.totalQuantity - cmifCargoAvailability.totalQuantityLeaving;
				
				if cmifCargoAvailability.totalQuantityLeaving &gt; 0 then 
					sign := "-";
				endif;
				
				row := row &amp; 
						cmifCargoAvailability.totalQuantity.asStringJMT &amp; Tab &amp; 
						sign &amp; cmifCargoAvailability.totalQuantityLeaving.asStringJMT &amp; Tab &amp;
						quantityAvailable.asStringJMT &amp; Tab ;
						
			endif;
			
			rowIndex := tblInventory.addItem(row);
			self.tblInventory.accessRow( rowIndex ).itemObject := cmifCargoAvailability;	//21 Oct 2019	NDL	TFS 46911
		endwhile;
	endif;
	
epilog
	delete iterator;
end;</source>
    </JadeMethod>
    <JadeMethod name="setConfigButton" id="4e29f743-276c-4fcc-9c52-8dccd8a8accd">
        <source>setConfigButton();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 October 2019	jlgndl1	Initial creation	TFS 46911

*/

vars

begin

	if self.myTerminal.myRoadGateCargoCheckCriteria &lt;&gt; null
	and not self.myTerminal.myRoadGateCargoCheckCriteria.allCriteria.isEmpty
	then
		self.btnConfig.buttonPicture := 1; //tick
		self.btnConfig.bubbleHelp := app.getErrorString1( Is_Configured, CM_ObjectMatchCriteria.RoadGateCargoCheckName );
	else
		self.btnConfig.buttonPicture := 2; // cross
		self.btnConfig.bubbleHelp := app.getErrorString1( Not_configured, CM_ObjectMatchCriteria.RoadGateCargoCheckName );
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setTblInventory" id="1778bb61-8693-4560-bf60-1f9f55be2899">
        <source>setTblInventory();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Mar 2019	jlgdi1	tfs# 41721 Initial creation

*/

constants
	TOTAL_COLUMNS : Integer = 8;
	COL_VOYAGE : Integer = 1;
	COL_OPERATOR : Integer = 2;
	COL_CARGO_TYPE : Integer = 3;
	COL_CARGO_SUBTYPE : Integer = 4;
	COL_CONSIGNEE : Integer = 5;
	COL_CARGO_ON_SITE : Integer = 6;
	COL_LEAVING_SITE : Integer = 7;
	COL_AVAILABLE : Integer = 8;

begin
	tblInventory.selectMode := CM_BaseTable.SelectionType_Row;
	tblInventory.autoSize := Table.AutoSize_Column;
//	tblInventory.multiSelect := CM_DataTable.MultiSelect_Simple;
	tblInventory.multiSelect := CM_DataTable.MultiSelect_None;	//21 Oct 2019	NDL	TFS 46911
	tblInventory.selectionType := CM_DataTable.SelectionType_Row;	//21 Oct 2019	NDL	TFS 46911
	tblInventory.selectMode := Table.SelectMode_CurrentRow;	//21 Oct 2019	NDL	TFS 46911
	
	tblInventory.columns := TOTAL_COLUMNS;
	tblInventory.rows := 1;	
	tblInventory.fixedRows := 1;
	tblInventory.fixedColumns := 0;
	tblInventory.leftColumn := 1;
	
	tblInventory.accessRow(1).alignment := Table.Alignment_Left_Middle;	
	tblInventory.setCellText(1,COL_VOYAGE,app.getErrorString(Voyage));
	tblInventory.setCellText(1,COL_OPERATOR,app.getErrorString(Operator));	
	tblInventory.setCellText(1,COL_CARGO_TYPE,app.getErrorString(CM_Cargo_Type));
	tblInventory.setCellText(1,COL_CARGO_SUBTYPE,app.getErrorString(Cargo_subtype));
	tblInventory.setCellText(1,COL_CONSIGNEE,app.getErrorString(Consignee));
	tblInventory.setCellText(1,COL_CARGO_ON_SITE,"Amount On Site");
	tblInventory.setCellText(1,COL_LEAVING_SITE,"Cargo Leaving Site");
	tblInventory.setCellText(1,COL_AVAILABLE,app.getErrorString(Available_cargo));
end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="1dd3b13b-e3d5-4043-bbf2-d49d4520b24a">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Mar 2019	jlgdi1	TFS# 41721 Initial creation
23 Apr 2019	jlgdi1	Use existing constant 'Close' rather than hard coded text
*/

begin
	inheritMethod();

	self.populateTblInventory();
	self.btnCancel.caption := app.getErrorString(Close);
	self.btnOk.visible := false;
	
	//21 Oct 2019	NDL	TFS 46911
	self.btnUseInJob.enabled := false;	
	self.setConfigButton();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tblInventory_mouseUp" id="06688dd2-1294-4952-be3f-9db42577d576">
        <controlMethod name="CM_DataTable::mouseUp"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblInventory_mouseUp(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 October 2019	jlgndl1	Initial creation	TFS 46911

*/

vars

	rowIndex : Integer;
	cmifCargoAvailability : CMIF_CargoAvailability;

begin

	self.selectedVoyage := null;
	self.selectedConsignee := null;

	rowIndex := self.tblInventory.row;
	if rowIndex &gt; self.tblInventory.fixedRows and rowIndex &lt;= self.tblInventory.rows then
		cmifCargoAvailability := self.tblInventory.accessRow(rowIndex).itemObject.CMIF_CargoAvailability;
		if cmifCargoAvailability &lt;&gt; null then
			self.selectedVoyage := cmifCargoAvailability.myVoyage;
			if cmifCargoAvailability.consignee.trimBlanks &lt;&gt; null then
				self.selectedConsignee := app.myRoot.allConsigneeConsignors[cmifCargoAvailability.consignee.trimBlanks];
			endif;
		endif;
	endif;
	
	self.btnUseInJob.enabled := self.selectedVoyage &lt;&gt; null or self.selectedConsignee &lt;&gt; null;
	
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="e7d652f4-c109-4455-b52c-c4fa7d190f97">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 23 October 2019 08:17:41.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0023568, locale);
	btnConfig.translateCaption(Xlat_0023766, locale);
	btnUseInJob.translateCaption(Xlat_0023767, locale);
end;</source>
    </JadeMethod>
</GUIClass>
