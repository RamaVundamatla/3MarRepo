    <JadeMethod name="showGraphicalViewWithTime" id="9de7fc47-e068-4ed6-b162-24e16441d162">
        <source>showGraphicalViewWithTime(_terminal : CM_Terminal; ts : TimeStamp);
//-----------------------------------------------------------------------
//	Created:	22 November 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars
	subSystem			: CMUI_SubSystem;
	formName			: String;
	assistantClass,
	formClass			: Class;
	frm					: Form;
	menuAction 			: CMUI_MenuAction;
begin
	//here we are getting a form from a sub schema (Yard schema) using literals
	subSystem := app.myController.allSubSystems['HmsSchema'];	
	if subSystem = null then
		return;
	endif;
	formName := 'HMS_GraphicalViewX';
	
	subSystem.getFormDetails(formName, formClass, assistantClass);	
	frm := app.loadForm(formClass, assistantClass, false, true, false, _terminal, menuAction).CM_BaseForm;

	frm.sendMsgWithParams ("doCentreAtTime", ts);
		
epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="ts" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="showHelp" id="a79d199f-c2f5-46b5-80a6-5be2e108f41e">
        <source>showHelp(_hwnd : Integer; _helpFileName : String);
// ---------------------------------------------------------------------------
// Created:     30 March 2004 by cnwth2
//
// Purpose:     N.B file name passed in is expected to be the string value of one of the HelpFile_Constants
//				in the HelpFileNameCostants category - it's now appended etc. 
//
// ----------   ----------  --------------------------------------------------
/*

Date		Who		Reason
27 May 2014	cnwkpd1	PAR #34210 - CCMS SFW 1350 - Online Documentation
10 Oct 2016	cnwkpd1	TFS JMT 2805 - JADE 7.1.08 upgrade
	
*/

constants
	NoFileAssociation 	= 31;
	GeneralOpenError	= 32;	// Any result &lt;= this indicates an error
	
vars
	helpFileName,
	localDocoPath,
	serverDocoPath,
	localFile,
	serverFile	: String;
	serverSize,
	fileStatus,
	result		: Integer;
	doDownload	: Boolean;
	
begin
	// PAR #34210 - Do nothing if HTML format is enabled
	if self.helpIsHTMLFormat() then
		return;
	endif;
	
	app.mousePointer := Window.MousePointer_HourGlass;

	if _helpFileName = HelpFile_Index then
		helpFileName := _helpFileName &amp; HelpFile_IndexExtension;
	else
		helpFileName := _helpFileName &amp; HelpFile_Extension;	
	endif;

	localDocoPath := global.getJMTDocumentationDir();
	localFile	:= localDocoPath &amp; helpFileName;
	
	serverDocoPath := global.getJMTDocumentationDirServer();
	serverFile	:= serverDocoPath &amp; helpFileName;
	
	fileStatus := self.getFileStatus(helpFileName, localDocoPath, serverDocoPath, serverSize);
	
	//check folder JMTIndex folder exists : par 11711 cnwjo3
	if _helpFileName = HelpFile_Index then
		getJMTIndex(localDocoPath, serverDocoPath, serverSize);
	endif;
	
	
	if fileStatus = FileStatus_OutOfDate then
		if app.msgBox("There is a more recent version of the " &amp; helpFileName &amp; " help file available." &amp; CrLf &amp;
					"Press OK to download it, or Cancel to abandon the download.", "Download Help", MsgBox_OK_Cancel + MsgBox_Question_Mark_Icon) = MsgBox_Return_OK then
			doDownload := true;
		endif;
	elseif fileStatus = FileStatus_AbsentClient then
		if app.msgBox('You do not have a local copy of the ' &amp; helpFileName &amp; ' help file.' &amp; CrLf &amp;
					'Press OK to download it, or Cancel to abandon the download.',
				"Download JMT Help", MsgBox_OK_Cancel + MsgBox_Question_Mark_Icon) = MsgBox_Return_OK then
			doDownload := true;
		else
			// cannot show as no file to show and user does not want to download
			return;
		endif;
	elseif fileStatus = FileStatus_AbsentEverywhere then
		app.msgBox('The file "' &amp; serverFile &amp; '" could not be located locally, or on the server',
					'Unable to find help file anywhere...', MsgBox_OK_Only + MsgBox_Stop_Icon);
		return;
	endif;
	
	if doDownload then
		// need to check that local dir exists and create if not there
		global.checkFileFolderExists(localDocoPath, true, true);
		global.copyServerFileToClient(serverFile, localFile, null);
	endif;

	//result := call _shellExecute(_hwnd, "open", localFile, null, null, 1);
	//"open" verb is surprisingly not the best verb. par 11711 cnwjo3
	result := call _shellExecute(null, null, localFile, null, null, 1);
	
	if result = NoFileAssociation then
		app.msgBox("Could not open file " &amp; localFile &amp;
				".  This is most likely because there is no " &amp;
				"program associated with files of this extension.",
				"File Open Failed", MsgBox_OK_Only + MsgBox_Stop_Icon);
	elseif result &lt;= GeneralOpenError then
		app.msgBox("Could not open file " &amp; localFile &amp; '.',
				"File Open Failed", MsgBox_OK_Only + MsgBox_Stop_Icon);
	endif;

epilog
	app.mousePointer := Window.MousePointer_Default;
	
end;</source>
        <Parameter name="_hwnd" type="Integer"/>
        <Parameter name="_helpFileName" type="String"/>
    </JadeMethod>
    <JadeMethod name="showHelpFileVersionChecker" id="05583314-2d1d-40b3-b94c-7eee4498a0e3">
