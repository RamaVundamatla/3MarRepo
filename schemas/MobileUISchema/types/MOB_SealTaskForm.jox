    <JadeMethod name="doResizeControls" id="4a1bf369-64ec-4b70-b444-3a3a4fa15a18">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 February 2015	cnwndl1	Initial creation	Par 35604

*/

vars
	stdLeft : Real;
	top : Real;
	stdWidth : Real;

	tblHeight : Real;
	tabIndex : Integer;

begin

	self.setResizeableMarginAndFontSize();
	tabIndex := 4000;
	stdLeft :=  self.resizedMargin;
	top := self.resizedMargin;
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin  ;

	if _initialSetup then
		self.caption := app.getErrorString(Seals);
		if self.myTrackedItem &lt;&gt; null then
			self.caption := self.caption &amp; " " &amp; self.myTrackedItem.id;
		endif;
	endif;
	

	tblHeight := self.clientHeight - top - ( 3 * self.resizedMargin ) - self.getCMDButtonsHeight();
	if _initialSetup then
		self.tblSeals.setAndIncrementTabIndex( tabIndex );
		self.tblSeals.visible := true;
	endif;
	self.tblSeals.move(	stdLeft,
						top,
						stdWidth,
						tblHeight );
						
	self.tblSeals.cnAdjustColumnWidths();
						
	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="handleBtnOne" id="cdd35f39-a01f-41bf-bb55-74874b3eaebd">
        <updating/>
        <source>handleBtnOne() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 February 2012	cnwrd1	Initial creation
03 Aug 2015	NDL	Par 36658 

*/

vars

	pxyTiSet : CM_TISet;
	result : Integer;
	row 		: Integer;
	obj 		: Object;
	sealTI		: CM_SealTI;
	sealType	: CM_SealType;
	sealValue 	: String;
	sealObj		: CM_SealObject;
	pxyWagonSeal : CM_WagonSeal;
	realWagonSeal : CM_WagonSeal;
	pxyWagonSealDict : CM_SealObjectBySealTypeDict;
	load : Boolean;
	
begin

	if self.myWagon &lt;&gt; null then
		create pxyWagonSealDict transient;
	elseif self.pxyTrackedItem = null and self.myTrackedItem &lt;&gt; null then
		self.pxyTrackedItem := app.createUpdateProxy(self.myTrackedItem).CM_TrackedItem;							
	endif;
	
	row := 1;
	while row &lt; self.tblSeals.rows do
		row := row +1;
		obj := self.tblSeals.accessRow(row).itemObject;
		if obj = null then
			continue;
		endif;
		
		sealValue := self.tblSeals.accessCell(row,2).text.trimBlanks;
		
		if obj.isKindOf(CM_WagonSeal) then
			realWagonSeal := obj.CM_WagonSeal;
			
			if not realWagonSeal.matchesValueFromUser(sealValue) then
				app.cmsBeginLoad(load);
				pxyWagonSeal := realWagonSeal.pxyGetProxyObject();
				if pxyWagonSeal = null then
					pxyWagonSeal := realWagonSeal.pxyCreateUpdateProxy();
				endif;
				pxyWagonSealDict.add( pxyWagonSeal );
				app.cmsEndLoad(load);
				//existing seal being updated.
				pxyWagonSeal.setProxy(	sealValue.trimBlanks,	//_sealNum : String;
										realWagonSeal.getSealValueAsString(),	//_prevSeal : String;
										realWagonSeal.sealType,	//_sealType : String;
										app.actualTimeServer(),	//_sealedDT : TimeStamp;
										self.myWagon	//_mySealedObject : CM_Object
										); 
			endif;
			
		elseif obj.isKindOf(CM_SealTI) then
			sealTI := obj.CM_SealTI;
			if not sealTI.matchesValueFromUser(sealValue) then
				//updating existing ti seal;
				sealTI.setProxy(	sealValue.trimBlanks[1:62],	//_sealNum : String;
									null,	//_sealNumArray : StringArray;
									sealTI.getSealValueAsString(),	//_prevSeal : String;
									sealTI.sealType,	//_sealType : String;
									app.actualTimeServer(),	//_sealedDT : TimeStamp;
									sealTI.myTrackedItem	//_myTrackedItem : CM_TrackedItem
									);
			endif;
			
		elseif obj.isKindOf(CM_SealType) then
			sealType := obj.CM_SealType;
			if self.myWagon &lt;&gt; null then
				if sealValue &lt;&gt; null then
					//adding new wagon seal
					create pxyWagonSeal transient;
					pxyWagonSeal.setProxy(	sealValue.trimBlanks,	//_sealNum : String;
											null,	//_prevSeal : String;
											sealType.sealType,	//_sealType : String;
											app.actualTimeServer(),	//_sealedDT : TimeStamp;
											self.myWagon	//_mySealedObject : CM_Object
											); 
					pxyWagonSealDict.add( pxyWagonSeal );
				endif;
				
			else
				//adding new ti seal
				self.pxyTrackedItem.setSealNumberValueDirect(sealType,sealValue,null);
				
			endif;
		else
			//?
		endif;	
		
	endwhile;

	if self.myWagon &lt;&gt; null then
		foreach sealObj in pxyWagonSealDict do
			pxyWagonSeal := sealObj.CM_WagonSeal;
			realWagonSeal := pxyWagonSeal.pxyGetRealObject(); // may be null and this is OK
			while true do
				app.myTrxUA.trxUpdateWagonSeal(pxyWagonSeal, realWagonSeal, app.myPassport);
			
				if app.myPassport.trxCompletedOK then
					app.myPassport.clearErrorsWarnings();
					break;
				else
					result := app.showErrorWarningDialog("", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
					if app.myPassport.noErrors and result = IDOK then
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					endif;
				endif;
				if not pxyWagonSealDict.isEmpty then
					pxyWagonSealDict.purge();
				endif;
				return;
			endwhile;
		endforeach;
		
		if not pxyWagonSealDict.isEmpty then
			pxyWagonSealDict.purge();
		endif;
		
		if not self.myWagon.isSealed then
			//presumably removed seals to work the cargo, just go back to that screen
			self.doBackButtonClick();
		else
			//presumably added a seal, so finished with this wagon, 
			//return to where they can choose another wagon.
			self.gotoForm(MOB_HHLanderTrainWagon,true);
		endif;
		
	elseif self.pxyTrackedItem &lt;&gt; null then
	
		//20 Apr 2015	NDL	Par 36095
		if self.myToDoTask = null then
			while true do
				app.myTrxUA.trxUpdateTrackedItem(pxyTrackedItem, null, TI_UPDMODE_NORMAL, null, app.myPassport);
				if app.myPassport.trxCompletedOK then
					app.myPassport.clearErrorsWarnings();
				else
					result := app.showErrorWarningDialog("", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
					if app.myPassport.noErrors and result = IDOK then
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					endif;
				endif;
				break;
			endwhile;
			self.handleBtnTwo();
			
		else
			create pxyTiSet transient;
			pxyTiSet.add(self.pxyTrackedItem);
			if self.getSessionAgent.updateTIToDoTaskCmpltBulk(self.myToDoTask, pxyTiSet, null) then
				self.unloadForm();
			endif;
		
		endif;
		
	endif;

epilog
	delete pxyTiSet;
	delete pxyWagonSealDict;
	app.cmsEndLoad(load);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="handleBtnTwo" id="e48f7ca8-1b0e-4850-86c4-1156f748f917">
        <updating/>
        <source>handleBtnTwo() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 February 2012	cnwrd1	Initial creation

*/

vars

begin

	if self.myWagon &lt;&gt; null then
		self.doBackButtonClick();
	
	//20 Apr 2015	NDL	Par 36095
	elseif self.pxyTrackedItem &lt;&gt; null and self.myToDoTask = null then
		self.doBackButtonClick();
		
	else
		self.unloadForm();
	
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateTblSeals" id="02847d88-9819-46b9-a2ee-5a20b2aa0b74">
        <source>populateTblSeals();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 February 2012	cnwrd1	Initial creation

*/

vars

	ti : CM_TrackedItem;
	cargoType : CM_CargoType;
	sealType : CM_SealType;
	allSealTypes : CM_SealTypeSet;
	sealTi : CM_SealTI;
	index : Integer;
	sealObj : CM_SealObject;	//12 Mar 2015	NDL	Par 35828

begin

	tblSeals.clear();
	create allSealTypes transient;
	
	if self.myWagon &lt;&gt; null then
		self.myWagon.getSelectableSealTypes( allSealTypes );
	
	elseif self.pxyTrackedItem &lt;&gt; null then
		ti := self.pxyTrackedItem;	
		cargoType := ti.myCargoType;
		foreach sealType in cargoType.allSealTypes do
			if sealType.notAvailableForEntry then
				continue;
			endif;
			allSealTypes.add(sealType);
		endforeach;
	
	endif;
	
	if allSealTypes.isEmpty then
		return;
	endif;
	
	tblSeals.selectMode := Table.SelectMode_None;
	tblSeals.columns := 2;
	tblSeals.rows := 1;
	
	tblSeals.fixedRows := 1;
	tblSeals.fixedColumns := 1;
	
	tblSeals.accessRow(1).alignment := Table.Alignment_Left_Middle;
	tblSeals.accessRow(1).fontBold := true;
	tblSeals.setCellText(1,1,app.getErrorString(CM_Type) );
	tblSeals.setCellText(1,2,app.getErrorString(Value) );
	
	if self.myWagon &lt;&gt; null then
		foreach sealType in allSealTypes do
		
			index := tblSeals.addItem(sealType.description);
			sealObj := self.myWagon.getWagonSeal(sealType);
			
			if sealObj = null then
				tblSeals.accessRow(index).itemObject := sealType;
			else
				tblSeals.setCellText(index,2,sealObj.getSealValueAsString);
				tblSeals.accessRow(index).itemObject := sealObj;
			endif;
			tblSeals.accessCell(index,2).inputType := Table.InputType_TextBox;
			
		endforeach;
	
	elseif self.pxyTrackedItem &lt;&gt; null then
		foreach sealType in allSealTypes do
		
			index := tblSeals.addItem(sealType.description);
			sealTi := ti.getSealTI(sealType);
			
			if sealTi = null then
				tblSeals.accessRow(index).itemObject := sealType;
			else
				tblSeals.setCellText(index,2,sealTi.getSealValueAsString);
				tblSeals.accessRow(index).itemObject := sealTi;
			endif;
			tblSeals.accessCell(index,2).inputType := Table.InputType_TextBox;
			
		endforeach;
	
	endif;

epilog

	delete allSealTypes;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setupControls" id="7cb9aef8-d55f-4db1-9347-bb65a8357d43">
        <updating/>
        <source>setupControls() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 February 2012	cnwrd1	Initial creation

*/

vars
	
begin

	self.doResizeControls(true);
											
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="54aefacd-14e5-4c59-9622-c1c29f5d029b">
        <updating/>
        <source>setupForm() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 February 2012	cnwrd1	Initial creation

*/

vars

begin

	self.myHandHeldCheckerAgent := app.myHandHeldCheckerAgent;

	inheritMethod();
	
	self.setupCmdButtons(2, app.getErrorString(Save), app.getErrorString(Back), null,null,null);
	
	if self.myTrackedItem &lt;&gt; null then
		if self.pxyTrackedItem = null then
			self.pxyTrackedItem := app.createUpdateProxy(self.myTrackedItem).CM_TrackedItem;		// deleted in "unloadForm"	
		endif;
		
	elseif self.myMobileGenericAgent.myCurrentWagon &lt;&gt; null then
		self.myWagon := self.myMobileGenericAgent.myCurrentWagon;
		
	//20 Apr 2015	NDL	Par 36095
	elseif self.myMobileGenericAgent.myPackTi &lt;&gt; null then
		self.myTrackedItem := self.myMobileGenericAgent.myPackTi;
		self.pxyTrackedItem := app.createUpdateProxy(self.myTrackedItem).CM_TrackedItem;
	
	else
		self.msgBox("Unknown object to seal", app.getErrorString(Error), MsgBox_OK_Only, false );
		self.unloadForm();
		return;
		
	endif;
	
	self.populateTblSeals();
	
	self.setupControls();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="2d743298-6b0c-41f1-ac9d-93a83524a92a">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0018499, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
