    <JadeMethod name="queueMoveExpect" id="cfc2e5d9-3b6a-4ee2-92cc-4bf4bb6da2aa">
        <source>queueMoveExpect( _ti: CM_TrackedItem; _lc : CM_LocationsController; expectedResult : Boolean; _number : Integer ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 April 2014	cnwndl1	Initial creation	Par 33995

*/

vars

	moveController	: CMIF_MoveController;

begin

	create moveController transient;
	moveController.setMyTrackedItem(_ti);
	moveController.setMyToPrimaryLocation(_lc);
	moveController.setMoveMode(QUEUE_MODE);
	
	app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	
	if expectedResult = true then
		self.assertTrueMsg( _ti.myPrimaryQueuedLocation = _lc, "Failed to Plan " &amp; _ti.id &amp; " to " &amp; _lc.getFullId &amp; ".  Test " &amp; _number.String );
	else
		self.assertTrueMsg( _ti.myPrimaryQueuedLocation &lt;&gt; _lc, "Should not have planned " &amp; _ti.id &amp; " to " &amp; _lc.getFullId &amp; ".  Test " &amp; _number.String );
	endif;

epilog

	delete moveController;

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <Parameter name="expectedResult" type="Boolean"/>
        <Parameter name="_number" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tLabourWorkAreaBasicTest" id="3e20c951-66e9-4907-8535-21bdb846a74d">
        <source>tLabourWorkAreaBasicTest();
//cnwndl1
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 April 2014	cnwndl1	Initial creation	Par 33995

*/
constants
	BlockStackId1 : String = "BSWA";
	BlockStackId2 : String = "BSNON";
	StraddleStackId1 : String = "SSWA";
	LabourWorkAreaName : String = "LWA1";
	BS1_TI1 : String = "UTWA5555501";
	BS1_TI2 : String = "UTWA5555502";
	BS1_TI3 : String = "UTWA5555503";
	BS2_TI4 : String = "UTWA5555504";
	BS2_TI5 : String = "UTWA5555505";
	BS2_TI6 : String = "UTWA5555506";
	SS1_TI7 : String = "UTWA5555507";
	SS1_TI8 : String = "UTWA5555508";
	SS1_TI9 : String = "UTWA5555509";
	SS1_TI10 : String = "UTWA5555510";
vars

	bs1 : CM_BlockStack;
	bs2 : CM_BlockStack;
	ss1 : CM_StraddleStack;
	
	pxyLabourWorkArea : CM_LabourWorkArea;
	allSelectedObjects : ObjectSet;
	realLabourWorkArea : CM_LabourWorkArea;
	delObject : CM_Object;
	
	bs1_ti1 : CM_TrackedItem;
	bs1_ti2 : CM_TrackedItem;
	bs1_ti3 : CM_TrackedItem;
	bs2_ti4 : CM_TrackedItem;
	bs2_ti5 : CM_TrackedItem;
	bs2_ti6 : CM_TrackedItem;
	ss1_ti7 : CM_TrackedItem;
	ss1_ti8 : CM_TrackedItem;
	ss1_ti9 : CM_TrackedItem;
	ss1_ti10 : CM_TrackedItem;
	lc : CM_LocationsController;
	lcArray : CM_LCArray;
	
	proxyLabourRestriction : CM_LabourRestriction;
	realLabourRestriction : CM_LabourRestriction;
	
	org : CM_Organisation;
	restrictOrg : CM_Organisation;
	load : Boolean;

begin

	//Create a 2x BS and a Straddle Stack
	bs1 := self.addBlockStack(BlockStackId1, 99, null);
	bs2 := self.addBlockStack(BlockStackId2, 99, null);
	ss1 := self.addStraddleStack(StraddleStackId1,4,4,1);
	
	self.assertTrueMsg( bs1 &lt;&gt; null, "Block Stack 1 not created");
	self.assertTrueMsg( bs2 &lt;&gt; null, "Block Stack 2 not created");
	self.assertTrueMsg( ss1 &lt;&gt; null, "Straddle Stack 1 not created");
	
	
	//Create a Labour Work Area that includes all of the Straddle Stack and all of one of the BS.
	
	self.deleteLabourWorkArea( LabourWorkAreaName );
	
	create allSelectedObjects transient;
	allSelectedObjects.add(bs1);
	allSelectedObjects.add(ss1);
	
	create pxyLabourWorkArea transient;
	pxyLabourWorkArea.setProxy(	LabourWorkAreaName,	//_code : String;
								"Unit Test Labour Work Area",	//_description : String;
								false,	//_notAvailable : Boolean;
								allSelectedObjects,	//_allSelectedObjects : ObjectSet;
								self.getTerminal	//_myTerminal : CM_Terminal
								);
								
	app.myTrxCA.trxCreateLabourWorkArea(pxyLabourWorkArea, realLabourWorkArea, app.myPassport);
	self.assertTrueMsg( realLabourWorkArea &lt;&gt; null, "Labour Work Area not created. " &amp; app.myPassport.getAllErrorsWarningsAsString );
	delete pxyLabourWorkArea;
	
	//Create Cargo in all three areas
	
	bs1_ti1 := self.addContainer(BS1_TI1,self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), "2200","MT",TI_IMEX_STATUS_EXPORT).CM_Container;
	bs1_ti2 := self.addContainer(BS1_TI2,self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), "2200","MT",TI_IMEX_STATUS_EXPORT).CM_Container;
	bs1_ti3 := self.addContainer(BS1_TI3,self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), "2200","MT",TI_IMEX_STATUS_EXPORT).CM_Container;
	bs2_ti4 := self.addContainer(BS2_TI4,self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), "2200","MT",TI_IMEX_STATUS_EXPORT).CM_Container;
	bs2_ti5 := self.addContainer(BS2_TI5,self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), "2200","MT",TI_IMEX_STATUS_EXPORT).CM_Container;
	bs2_ti6 := self.addContainer(BS2_TI6,self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), "2200","MT",TI_IMEX_STATUS_EXPORT).CM_Container;
	ss1_ti7 := self.addContainer(SS1_TI7,self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), "2200","MT",TI_IMEX_STATUS_EXPORT).CM_Container;
	ss1_ti8 := self.addContainer(SS1_TI8,self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), "2200","MT",TI_IMEX_STATUS_EXPORT).CM_Container;
	ss1_ti9 := self.addContainer(SS1_TI9,self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), "2200","MT",TI_IMEX_STATUS_EXPORT).CM_Container;
	ss1_ti10 := self.addContainer(SS1_TI10,self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), "2200","MT",TI_IMEX_STATUS_EXPORT).CM_Container;
	
	lc := bs1.allLocationsControllers.first;
	self.move(bs1_ti1, lc);
	self.move(bs1_ti2, lc);
	self.move(bs1_ti3, lc);
	lc := bs2.allLocationsControllers.first;
	self.move(bs2_ti4, lc);
	self.move(bs2_ti5, lc);
	self.move(bs2_ti6, lc);
	create lcArray transient;
	ss1.allLocationsControllers.copy(lcArray);
	self.move(ss1_ti7, lcArray[1]);
	self.move(ss1_ti8, lcArray[2]);
	self.move(ss1_ti9, lcArray[15]);
	self.move(ss1_ti10, lcArray[16]);
	
	//Create a Labour Restriction for just the BS in the Labour Work Area
	
	foreach org in app.myRoot.allOrganisations do
		if org.isAvailableForLabourRestiction then
			restrictOrg := org;
			break;
		endif;
	endforeach;
	
	self.assertTrueMsg( restrictOrg &lt;&gt; null, "No Organisation found.");
	
	lcArray.clear();
	lcArray.add( bs1.allLocationsControllers.first );
	create proxyLabourRestriction transient;
	proxyLabourRestriction.setProxy(	Red,	//_colour : Integer; 
										app.getMyUserCode,	//_userCode,
										"No comment",	//_comment : String; 
										null,	//_durationHrs : Time;
										1,	//_durationDays : Integer;
										CM_LabourRestrictionReasonCode.firstInstance,	//_reason : CM_LabourRestrictionReasonCode;
										lcArray,	//_allLocations : CM_LCArray;
										"UTLR1",	//_id : String;
										false,	//_ignoreLights : Boolean;
										restrictOrg,	//_organisation : CM_Organisation;
										null,	//_email : CM_EmailEntity;
										null,					//_emails : CM_EmailAddressByAddressDict;
										bs1	//_theTerminal : CM_TerminalArea
										);
										
	app.myTrxCA.trxCreateRestrictionLabour(proxyLabourRestriction, realLabourRestriction, app.myPassport);
	self.assertTrueMsg( realLabourRestriction &lt;&gt; null, "Labour Restriction not created. (test 1) " &amp; app.myPassport.getAllErrorsWarningsAsString );
	delete proxyLabourRestriction;
			
	//Check that the Labour Restriction also includes the Straddle stack because they share a Labour Work Area.
	self.assertTrueMsg( not realLabourRestriction.allChildLabourRestrictions.isEmpty, "Labour Restriction should include child restrict for Straddle Stack (Test 2)");
	
	//Attempt a move of cargo to the the Labour Work Area BS - should fail
	lc := bs1.allLocationsControllers.first;
	self.queueMoveExpect( bs2_ti4,  lc, false , 3 );
	
	//Attempt a move of cargo to the Straddle Stack - should fail
	lcArray.clear();
	ss1.allLocationsControllers.copy(lcArray);
	lc := lcArray[1];
	self.queueMoveExpect( bs1_ti2,  lc, false , 4 );
	lc := lcArray[16];
	self.queueMoveExpect(bs2_ti5,  lc, false , 5 );
	
	//Attempt a move of cargo from the the Labour Work Area BS - should fail
	lc := bs2.allLocationsControllers.first;
	self.queueMoveExpect( bs1_ti3,  lc, false , 6 );
	
	//Attempt a move of cargo from the Straddle Stack - should fail
	lc := bs2.allLocationsControllers.first;
	self.queueMoveExpect( ss1_ti7,  lc, false , 7 );
	
	//Delete the Labour restriction
	app.myTrxDA.trxDeleteRestrictionLabour(realLabourRestriction, app.myPassport);
	self.assertTrueMsg( not app.myPassport.hasErrors, "Labour Restriction not deleted. (Test 8) " &amp; app.myPassport.getAllErrorsWarningsAsString );
	realLabourRestriction := null;
	
	//Update the Labour Work Area to only contain half of the Straddle Stack ( some cargo in each.)
	app.cmsBeginLoad( load );
	pxyLabourWorkArea := realLabourWorkArea.pxyCreateUpdateProxy();
	app.cmsEndLoad( load );
	
	allSelectedObjects.clear;
	allSelectedObjects.add(bs1);
	allSelectedObjects.add(lcArray[1]);
	allSelectedObjects.add(lcArray[2]);
	
	pxyLabourWorkArea.setProxy(	"LWA1",	//_code : String;
								"Unit Test Labour Work Area",	//_description : String;
								false,	//_notAvailable : Boolean;
								allSelectedObjects,	//_allSelectedObjects : ObjectSet;
								self.getTerminal	//_myTerminal : CM_Terminal
								);
								
	app.myTrxUA.trxUpdateLabourWorkArea(pxyLabourWorkArea, app.myPassport);
	self.assertTrueMsg( realLabourWorkArea &lt;&gt; null, "Labour Work Area not updated. (Test 9)" &amp; app.myPassport.getAllErrorsWarningsAsString );
	delete pxyLabourWorkArea;
	
	//Add a new Labour Restriction against a position within the half of the straddle stack that is in the Labour Work Area.
	lc := lcArray[2];
	lcArray.clear();
	lcArray.add( lc );
	create proxyLabourRestriction transient;
	proxyLabourRestriction.setProxy(	Red,	//_colour : Integer; 
										app.getMyUserCode,	//_userCode,
										"No comment",	//_comment : String; 
										null,	//_durationHrs : Time;
										1,	//_durationDays : Integer;
										CM_LabourRestrictionReasonCode.firstInstance,	//_reason : CM_LabourRestrictionReasonCode;
										lcArray,	//_allLocations : CM_LCArray;
										"UTLR1",	//_id : String;
										false,	//_ignoreLights : Boolean;
										restrictOrg,	//_organisation : CM_Organisation;
										null,	//_email : CM_EmailEntity;
										null,					//_emails : CM_EmailAddressByAddressDict;
										lc.myTerminalArea	//_theTerminal : CM_TerminalArea
										);
										
	app.myTrxCA.trxCreateRestrictionLabour(proxyLabourRestriction, realLabourRestriction, app.myPassport);
	self.assertTrueMsg( not app.myPassport.hasErrors, "New Labour Restriction not created. (Test 10.)" &amp; app.myPassport.getAllErrorsWarningsAsString );
	delete proxyLabourRestriction;
	
	//Check that the Labour Restriction includes the whole Labour Work Area.
	self.assertTrueMsg( not realLabourRestriction.allChildLabourRestrictions.isEmpty, "Labour Restriction should include child restrict for BS1 (Test 11)");
	
	//Attempt a move of cargo to the the Labour Work Area BS - should fail
	lc := bs1.allLocationsControllers.first;
	self.queueMoveExpect( bs2_ti6,  lc, false , 12 );
	
	//Attempt a move of cargo to a position in the Straddle Stack included in the Labour Work Area - should fail
	lcArray.clear();
	ss1.allLocationsControllers.copy(lcArray);
	lc := lcArray[1];
	self.queueMoveExpect( bs1_ti2,  lc, false , 13 );
	
	//Attempt a move of cargo from the the Labour Work Area BS - should fail
	lc := bs2.allLocationsControllers.first;
	self.queueMoveExpect( bs1_ti3,  lc, false , 14 );
	
	//Attempt a move of cargo from the Straddle Stack included in the Labour Work Area - should fail
	lc := bs1.allLocationsControllers.first;
	self.queueMoveExpect( ss1_ti10,  lc, false , 15 );
	
	//Attempt a move of cargo from the excluded BS to a position in the Straddle Stack NOT in the Labour Work Area - should be Ok
	lc := lcArray[14];
	self.queueMoveExpect(bs2_ti5,  lc, true , 16 );
	
	//Attempt a move of cargo from the Straddle Stack NOT in the Labour Work Area to the excluded BS- should be OK
	lc := bs2.allLocationsControllers.first;
	self.queueMoveExpect( ss1_ti10,  lc, true , 17 );
	
	//Delete the Labour restriction
	app.myTrxDA.trxDeleteRestrictionLabour(realLabourRestriction, app.myPassport);
	self.assertTrueMsg( not app.myPassport.hasErrors, "Labour Restriction not deleted. (Test 18) " &amp; app.myPassport.getAllErrorsWarningsAsString );
	realLabourRestriction := null;									// 01/05/2014 cnwmh5
	
	//Delete the Labour Work Area
	delObject := realLabourWorkArea;
	app.myTrxDA.trxDeleteCMObject( delObject, app.myPassport );
	self.assertTrueMsg( not app.myPassport.hasErrors, "Labour Work Area not deleted. (Test 19) " &amp; app.myPassport.getAllErrorsWarningsAsString );
		
	
epilog

	app.cmsEndLoad( load );
	
	self.deleteTrackedItem( bs1_ti1, true);
	self.deleteTrackedItem( bs1_ti2, true);
	self.deleteTrackedItem( bs1_ti3, true);
	self.deleteTrackedItem( bs2_ti4, true);
	self.deleteTrackedItem( bs2_ti5, true);
	self.deleteTrackedItem( bs2_ti6, true);
	self.deleteTrackedItem( ss1_ti7, true);
	self.deleteTrackedItem( ss1_ti8, true);
	self.deleteTrackedItem( ss1_ti9, true);
	self.deleteTrackedItem( ss1_ti10, true);

	delete allSelectedObjects;
	delete pxyLabourWorkArea;
	delete lcArray;
	delete proxyLabourRestriction;
	if realLabourRestriction = null then
	endif;
	if realLabourRestriction &lt;&gt; null then
		app.myTrxDA.trxDeleteRestrictionLabour(realLabourRestriction, app.myPassport);	
		self.assertNoTrxErrorsOrWarnings();							// 01/05/2014 cnwmh5
	endif;
	self.deleteLabourWorkArea( LabourWorkAreaName );
	

	self.deleteTerminalArea(BlockStackId1);
	self.deleteTerminalArea(BlockStackId2);
	self.deleteTerminalArea(StraddleStackId1);
	
end;</source>
    </JadeMethod>
</Class>
