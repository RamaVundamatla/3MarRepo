    <JadeMethod name="setStatus" id="2de27c53-ff5d-4c7c-93ae-53bd596cfab1">
        <updating/>
        <source>setStatus(_status: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     Aug 2004 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' OldStatus='&amp;self.status.String&amp;'('&amp;self.myBackup.getDisplayStatus(self.status)&amp;')'&amp;' NewStatus='&amp;_status.String&amp;'('&amp;self.myBackup.getDisplayStatus(_status)&amp;')', LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	self.status := _status;
end;</source>
        <Parameter name="_status" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="statusDisplay" id="660c403e-61f2-4854-81cb-e9827143d643">
