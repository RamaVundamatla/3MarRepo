    <JadeMethod name="xRemoveCargoFromSlot" id="2a99630e-b76b-4c64-a7d7-44850c6b4b95">
        <source>xRemoveCargoFromSlot(_voyage : CM_Voyage; _locnDefnId : String);

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
16 January 2013	cnwmh5	Initial creation

*/

vars

	roroStructure 				: CM_ROROVoyageStructure;
	deck 						: CM_DeckVoyage;
	locnDefn					: CM_ROROLocnDefn;
	locnDefnTemp				: CM_ROROLocnDefn;
	tempTI						: CM_TrackedItem;
	cargo 						: CM_TrackedItem;
	operator					: CM_Operator;
	
	tiArray						: CM_TIArray;
	
	count						: Integer;
	isoTypeStr					: String;
	cargoId						: String;
	dischargePort				: String;
	found						: Boolean;

begin

	// set up the details for the voyage, rotations, containers, etc.
	roroStructure := _voyage.myROROStructure;
	self.assertNotNull(roroStructure);

	found := false;
	foreach deck in _voyage.myROROStructure.allDecksByCode do
	
		foreach locnDefn in deck.allROROLocnDefnByCode do
		
			if locnDefn.code = _locnDefnId then
				
				create tiArray transient;
				locnDefn.getAllTIs(REAL_MODE, tiArray, true);
				foreach tempTI in tiArray do
					self.deleteTrackedItem(tempTI, false);
				endforeach;
			
				found := true;
				break;
			endif;
		
		
		endforeach;
	
		if found then
			break;
		endif;
	
	endforeach;
	
epilog

	delete tiArray;

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_locnDefnId" type="String"/>
    </JadeMethod>
    <JadeMethod name="xSetup31119InboundCargo" id="afb20f81-c680-4992-8385-6a6f5879f203">
        <source>xSetup31119InboundCargo(_voyageIn : CM_Voyage; _transhipTIArray : CM_TIArray io);

/*

Purpose:			

Date			Who		Reason
08 February 2013	cnwmh5	Initial creation

*/
constants

	CargoID						: String = "UTMDHG000";

vars

	roroStructure 				: CM_ROROVoyageStructure;
	deck						: CM_DeckVoyage;
	operator					: CM_Operator;
	location					: CM_LocationsController;
	locnDefn					: CM_ROROLocnDefn;
	locnDefnGC					: CM_ROROGCDefn;
	tempTI						: CM_TrackedItem;
	cargoType					: CM_CargoType;
	locnDefnGC1					: CM_ROROGCDefnVoyage;
	
	locationArray				: StringArray;
	tiArray						: CM_TIArray;
	
	cargoCount					: Integer;
	locationStr					: String;
	rand						: Integer;

begin

	cargoCount := 1;

	operator := app.myRoot.allOperators["MSL"];
	self.assertNotNull(operator);

	roroStructure := _voyageIn.myROROStructure;
	self.assertNotNull(roroStructure);
	
	deck := roroStructure.allDecksByCode["2"];
	self.assertNotNull(deck);
	
	cargoType := self.getCargoType("CANNONBALL");
	self.assertNotNull(cargoType);
	
	create locationArray transient;
	create tiArray transient;
	
	// create non rotated 20' OOTLs
	//roroStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(roroStructure, locnDefn, false, 112.6, 0.8, deck, 1); 
	self.assertNoTrxErrorsOrWarnings();
	
	//roroStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(roroStructure, locnDefn, false, 112.6, 3.8, deck, 1); 
	self.assertNoTrxErrorsOrWarnings();
	
	//roroStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(roroStructure, locnDefn, false, 112.6, 7.8, deck, 1); 
	self.assertNoTrxErrorsOrWarnings();
	
	// create non rotated 40' OOTLs
	//roroStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(roroStructure, locnDefn, true, 78.6, 1.8, deck, 1); 
	self.assertNoTrxErrorsOrWarnings();
	
	//roroStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(roroStructure, locnDefn, true, 78.6, 5.8, deck, 1); 
	self.assertNoTrxErrorsOrWarnings();

	//roroStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(roroStructure, locnDefn, true, 78.6, 10.8, deck, 1); 
	self.assertNoTrxErrorsOrWarnings();

	// create rotated 20' OOTLs
	//roroStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(roroStructure, locnDefn, false, 102.6, 8.8, deck, 1); 
	self.assertNoTrxErrorsOrWarnings();
	
	//roroStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(roroStructure, locnDefn, false, 105.6, 8.8, deck, 1); 
	self.assertNoTrxErrorsOrWarnings();
	
	//roroStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(roroStructure, locnDefn, false, 108.6, 8.8, deck, 1); 
	self.assertNoTrxErrorsOrWarnings();
	

	// create rotated 40' OOTLs
	//roroStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(roroStructure, locnDefn, true, 87.6, 10.8, deck, 1); 
	self.assertNoTrxErrorsOrWarnings();

	//roroStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(roroStructure, locnDefn, true, 90.6, 10.8, deck, 1); 
	self.assertNoTrxErrorsOrWarnings();
	
	//roroStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(roroStructure, locnDefn, true, 93.6, 10.8, deck, 1); 
	self.assertNoTrxErrorsOrWarnings();
	
	// remove all containers from the OOTL's and create them with correct id's
	locationArray.clear();
	locationArray.add("D2359O");
	locationArray.add("D2360O");
	locationArray.add("D2361O");
	locationArray.add("D2362O");
	locationArray.add("D2365O");
	locationArray.add("D2366O");
	locationArray.add("D2372O");
	locationArray.add("D2374O");
	locationArray.add("D2376O");
	locationArray.add("D2368O");
	locationArray.add("D2369O");
	locationArray.add("D2370O");
	
	foreach locationStr in locationArray do
		locnDefn := deck.allROROLocnDefnByCode[locationStr];
		tiArray.clear();
		locnDefn.getAllTIs(REAL_MODE, tiArray, true);
		///app.writeLog('locationStr: ' &amp; locationStr &amp; Tab &amp; locnDefn.String &amp; Tab &amp; tiArray.size.String, LogAlways);
		foreach tempTI in tiArray do
			self.deleteTrackedItem(tempTI, false);
		endforeach;		
	endforeach;

	// rotate the following containers
	locationArray.clear();
	locationArray.add("D2372O");
	locationArray.add("D2374O");
	locationArray.add("D2376O");
	locationArray.add("D2368O");
	locationArray.add("D2369O");
	locationArray.add("D2370O");
	foreach locationStr in locationArray do
		locnDefn := deck.allROROLocnDefnByCode[locationStr];
		app.myTrxUA.trxUpdateROROLocnDefnRotate(locnDefn, 1, 1, false, app.myPassport, false);
		self.assertNoTrxErrorsOrWarnings();
	endforeach;
	
	// create the 20' containers
	locationArray.clear();
	locationArray.add("D21211");
	locationArray.add("D21212");
	locationArray.add("D21081");
	locationArray.add("D21082");
	locationArray.add("D21091");
	locationArray.add("D21092");
	locationArray.add("D2359O");
	locationArray.add("D2360O");
	locationArray.add("D2361O");
	locationArray.add("D2368OR");
	locationArray.add("D2369OR");
	locationArray.add("D2370OR");
	
	foreach locationStr in locationArray do
		location := _voyageIn.getLocationByID(locationStr);
		if location &lt;&gt; null then
			locnDefn := location.CM_ROROSlotController.mySlotDefn.myROROLocnDen;
		else
			locnDefn := deck.allROROLocnDefnByCode[locationStr];
		endif;
		///app.writeLog('locationStr: ' &amp; locationStr &amp; Tab &amp; location.String &amp; Tab &amp; locnDefn.String, LogAlways);
		self.xCreateCargoAtShipLocation(CargoID &amp; cargoCount.stringWithLeadingZeros(2), operator, "2200", _voyageIn, "NZAKL", locnDefn);
					
		cargoCount := cargoCount + 1;
	endforeach;
	
	// create the 40' containers
	locationArray.clear();
	locationArray.add("D21071");
	locationArray.add("D21072");
	locationArray.add("D21111");
	locationArray.add("D21112");
	locationArray.add("D21101");
	locationArray.add("D21102");
	locationArray.add("D2363O");
	locationArray.add("D2365O");
	locationArray.add("D2367O");
	locationArray.add("D2372OR");
	locationArray.add("D2374OR");
	locationArray.add("D2376OR");
	
	foreach locationStr in locationArray do
		location := _voyageIn.getLocationByID(locationStr);
		if location &lt;&gt; null then
			locnDefn := location.CM_ROROSlotController.mySlotDefn.myROROLocnDen;
		else
			locnDefn := deck.allROROLocnDefnByCode[locationStr];
		endif;
		///app.writeLog('locationStr: ' &amp; locationStr &amp; Tab &amp; location.String &amp; Tab &amp; locnDefn.String, LogAlways);
		self.xCreateCargoAtShipLocation(CargoID &amp; cargoCount.stringWithLeadingZeros(2), operator, "4200", _voyageIn, "NZAKL", locnDefn);
		cargoCount := cargoCount + 1;
	endforeach;
	
	// create GC Areas
	//roroStructure.createQuickCargoGC(null, cargoType, 40.0, -10.0, deck, 15); 
	self.createQuickCargoGC(roroStructure, locnDefnGC1, cargoType, 40.0, -10.0, deck, 15);						// 27/08/2015 cnwmh5
	self.assertNoTrxErrorsOrWarnings();
	
	//roroStructure.createQuickCargoGC(null, cargoType, 40.0, 2.0, deck, 15); 
	self.createQuickCargoGC(roroStructure, locnDefnGC1, cargoType, 40.0, 2.0, deck, 15); 			// 27/08/2015 cnwmh5
	self.assertNoTrxErrorsOrWarnings();
	
	self.opts.purge();
	self.opts.addAssoc(UTTI_DischargePort, "NZAKL");
	
	foreach tempTI in _voyageIn.allOnshipTIsByCargoTypeId where tempTI.cargoType = cargoType.id do
		self.updateTI(tempTI);
	endforeach;

	locationArray.clear();
	locationArray.add("D2001G");
	foreach locationStr in locationArray do
		locnDefnGC := deck.allROROGCDefnByCode[locationStr];
		locnDefnGC.getAllTIs(REAL_MODE, _transhipTIArray, true);
	endforeach;
		
epilog

	delete locationArray;
	delete tiArray;
	
end;</source>
        <Parameter name="_voyageIn" type="CM_Voyage"/>
        <Parameter name="_transhipTIArray" type="CM_TIArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="xSetupDeck2_30863" id="40fceea2-5547-4beb-a3ed-ea9e55e40e09">
        <updating/>
        <source>xSetupDeck2_30863(_voyage : CM_Voyage io; _cargoId : String; _cargoCount : Integer io) updating;

/*

Purpose:		Setup the details for deck 2 which will be a load deck	

Date			Who		Reason
24/01/2013		cnwmh5	Initial creation

*/

constants

	BlockStackName				: String = "UTMHBS7";
	
vars
	
	roroStructure 				: CM_ROROVoyageStructure;
	deck						: CM_DeckVoyage;
	location					: CM_ROROLocnDefn;
	location2					: CM_ROROSlotDefn;
	tempTI						: CM_TrackedItem;
	operator					: CM_Operator;
	realAlloc 					: CM_VoyageAllocation;
	voyageJob 					: CM_VoyageJob;
	bs							: CM_BlockStack;
	container					: CM_Container;
	moveController 				: CMIF_MoveController;
	lc							: CM_LocationsController;
	
	tiArray						: CM_TIArray;
	tisToPlanArray				: CM_TIArray;
	locationArray				: StringArray;
	roro20FTLCs 				: CM_LCArray;
	roro40FTLCs 				: CM_LCArray;
	roroLCs						: CM_LCArray;
	altRoroLCs					: CM_LCArray;
	slotsToLoadCC				: StringArray;
	
	str							: String;
	count						: Integer;
	index						: Integer;

begin

	operator := app.myRoot.allOperators["MSL"];
	self.assertNotNull(operator);

	roroStructure := _voyage.myROROStructure;
	self.assertNotNull(roroStructure);
	
	deck := roroStructure.allDecksByCode["4"];
	self.assertNotNull(deck);

	// create cargo to load
	// setup block stack
	bs := self.getTerminal().allTerminalAreas[BlockStackName].CM_BlockStack;
	self.assertNotNull(bs);
	
	self.opts.purge();
	self.opts.addAssoc("Voyage", _voyage);
	
	create tisToPlanArray transient;
	
	foreach index in 1 to 35 do
		container := self.addContainerAtLocation(_cargoId &amp; _cargoCount.padLeadingWith("0", 2), operator, "2200", "GENL", 3, bs);
		self.assertNotNull(container);
		self.updateTI(container);
		tisToPlanArray.add(container);
		_cargoCount := _cargoCount + 1;
	endforeach;
	
	foreach index in 1 to 5 do
		container := self.addContainerAtLocation(_cargoId &amp; _cargoCount.padLeadingWith("0", 2), operator, "4200", "GENL", 3, bs);
		self.assertNotNull(container);
		self.updateTI(container);
		tisToPlanArray.add(container);
		_cargoCount := _cargoCount + 1;
	endforeach;
	
	app.myTrxUA.trxUpdateTIsReadyToShip(tisToPlanArray, true, app.myPassport);
	
	
	// create the rotated non OOTL cells
	location := deck.allROROLocnDefnByCode['D4029'];
	app.myTrxUA.trxUpdateROROLocnDefnRotate(location, 10, 2, true, app.myPassport, true);
	self.assertNoTrxErrorsOrWarnings();
	
	location := deck.allROROLocnDefnByCode['D4039'];
	app.myTrxUA.trxUpdateROROLocnDefnRotate(location, 10, 2, true, app.myPassport, true);
	self.assertNoTrxErrorsOrWarnings();
	
	location := deck.allROROLocnDefnByCode['D4083'];
	app.myTrxUA.trxUpdateROROLocnDefnRotate(location, 5, 1, true, app.myPassport, true);
	self.assertNoTrxErrorsOrWarnings();
	
	location := deck.allROROLocnDefnByCode['D4088'];
	app.myTrxUA.trxUpdateROROLocnDefnRotate(location, 5, 1, true, app.myPassport, true);
	self.assertNoTrxErrorsOrWarnings();

	location := deck.allROROLocnDefnByCode['D4103'];
	app.myTrxUA.trxUpdateROROLocnDefnRotate(location, 3, 1, true, app.myPassport, true);
	self.assertNoTrxErrorsOrWarnings();

	location := deck.allROROLocnDefnByCode['D4108'];
	app.myTrxUA.trxUpdateROROLocnDefnRotate(location, 3, 1, true, app.myPassport, true);
	self.assertNoTrxErrorsOrWarnings();

	location := deck.allROROLocnDefnByCode['D4127'];
	app.myTrxUA.trxUpdateROROLocnDefnRotate(location, 6, 2, true, app.myPassport, true);
	self.assertNoTrxErrorsOrWarnings();

	location := deck.allROROLocnDefnByCode['D4147'];
	app.myTrxUA.trxUpdateROROLocnDefnRotate(location, 6, 2, true, app.myPassport, true);
	self.assertNoTrxErrorsOrWarnings();
	
	
	// create the non rotated OOTL cells - with cargo in	
	//roroStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(roroStructure, location, true, 140.4, -10.6, deck, 1); 	
	self.assertNoTrxErrorsOrWarnings();
	
	//roroStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(roroStructure, location, true, 140.4, -7.1, deck, 1); 
	self.assertNoTrxErrorsOrWarnings();
	
	//roroStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(roroStructure, location, true, 140.4, -2.7, deck, 1); 
	self.assertNoTrxErrorsOrWarnings();
		
	//roroStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(roroStructure, location, false, 153.4, -7.1, deck, 1); 
	self.assertNoTrxErrorsOrWarnings();
		
	//roroStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(roroStructure, location, false, 153.4, -2.7, deck, 1); 
	self.assertNoTrxErrorsOrWarnings();
	
	create tiArray transient;
	create locationArray transient;
	locationArray.add("D4460O");
	locationArray.add("D4462O");
	locationArray.add("D4464O");
	locationArray.add("D4465O");
	locationArray.add("D4466O");
	
	foreach str in locationArray do
		location := deck.allROROLocnDefnByCode[str];
		tiArray.clear();
		location.getAllTIs(REAL_MODE, tiArray, true);
		foreach tempTI in tiArray do
			self.deleteTrackedItem(tempTI, false);
		endforeach;		
	endforeach;
	
	
	// create rotated OOTL's
	//roroStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(roroStructure, location, true, 117.6, 2.7, deck, 1); 
	self.assertNoTrxErrorsOrWarnings();
	
	//roroStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(roroStructure, location, true, 125.6, 2.7, deck, 1); 
	self.assertNoTrxErrorsOrWarnings();
		
	//roroStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(roroStructure, location, false, 126.7, 2.7, deck, 1); 
	self.assertNoTrxErrorsOrWarnings();
	
	//roroStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(roroStructure, location, false, 129.2, 2.7, deck, 1); 
	self.assertNoTrxErrorsOrWarnings();
	
	//roroStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(roroStructure, location, true, 113.2, 2.7, deck, 1); 
	self.assertNoTrxErrorsOrWarnings();
	
	//roroStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(roroStructure, location, true, 109.2, 2.7, deck, 1); 
	self.assertNoTrxErrorsOrWarnings();
	
	//roroStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(roroStructure, location, true, 105.3, 2.7, deck, 1); 
	self.assertNoTrxErrorsOrWarnings();
	
	
	locationArray.clear();
	locationArray.add("D4470O");
	locationArray.add("D4471O");
	locationArray.add("D4472O");
	locationArray.add("D4468O");
	locationArray.add("D4474O");
	locationArray.add("D4476O");
	locationArray.add("D4478O");
	
	foreach str in locationArray do
		location := deck.allROROLocnDefnByCode[str];
		tiArray.clear();
		location.getAllTIs(REAL_MODE, tiArray, true);
		foreach tempTI in tiArray do
			self.deleteTrackedItem(tempTI, false);
		endforeach;		
		app.myTrxUA.trxUpdateROROLocnDefnRotate(location, 1, 1, false, app.myPassport, false);
		self.assertNoTrxErrorsOrWarnings();
	endforeach;
	
	
	// setup load colour coding for 20' containers
	create altRoroLCs transient;
	altRoroLCs.clear();
	
	create roro20FTLCs transient;
	roro20FTLCs.clear();
	
	create slotsToLoadCC transient;
	slotsToLoadCC.add("D40071");
	slotsToLoadCC.add("D40072");
	slotsToLoadCC.add("D40121");
	slotsToLoadCC.add("D40122");
	slotsToLoadCC.add("D40061");
	slotsToLoadCC.add("D40062");
	slotsToLoadCC.add("D40111");
	slotsToLoadCC.add("D40112");
	slotsToLoadCC.add("D40171");
	slotsToLoadCC.add("D40221");
	slotsToLoadCC.add("D40161");
	slotsToLoadCC.add("D40211");
	slotsToLoadCC.add("D40212");
	slotsToLoadCC.add("D40151");
	slotsToLoadCC.add("D40152");
	slotsToLoadCC.add("D4465O1");
	slotsToLoadCC.add("D4465O2");
	slotsToLoadCC.add("D4477O1");
	slotsToLoadCC.add("D4477O2");
	slotsToLoadCC.add("D4476O1R");
	slotsToLoadCC.add("D4476O2R");
	slotsToLoadCC.add("D4471O1R");
	slotsToLoadCC.add("D4471O2R");
	slotsToLoadCC.add("D4472O1R");
	slotsToLoadCC.add("D4472O2R");
	slotsToLoadCC.add("D4466O1");
	slotsToLoadCC.add("D4466O2");
	slotsToLoadCC.add("D4474O1R");
	slotsToLoadCC.add("D4474O2R");
	slotsToLoadCC.add("D4461O1");
	slotsToLoadCC.add("D4461O2");
	slotsToLoadCC.add("D40581");
	slotsToLoadCC.add("D40582");
	slotsToLoadCC.add("D40591");
	slotsToLoadCC.add("D40592");
	slotsToLoadCC.add("D40331R");
	slotsToLoadCC.add("D40332R");
	slotsToLoadCC.add("D40261R");
	slotsToLoadCC.add("D40262R");
	slotsToLoadCC.add("D40831R");
	slotsToLoadCC.add("D40832R");
	slotsToLoadCC.add("D40811R");
	slotsToLoadCC.add("D40812R");
	slotsToLoadCC.add("D41071R");
	slotsToLoadCC.add("D41072R");
	slotsToLoadCC.add("D41451R");
	slotsToLoadCC.add("D41452R");
	slotsToLoadCC.add("D41521R");
	slotsToLoadCC.add("D41522R");
	slotsToLoadCC.add("D41511R");
	slotsToLoadCC.add("D41512R");
	slotsToLoadCC.add("D40801R");
	slotsToLoadCC.add("D40802R");
	slotsToLoadCC.add("D40311R");
	slotsToLoadCC.add("D40312R");
	slotsToLoadCC.add("D40471");
	slotsToLoadCC.add("D40472");
	
	foreach str in slotsToLoadCC do
		//app.writeLog(str, LogAlways);
		self.getJobROROControllerByID(_voyage.code, deck.code, null, str, roro20FTLCs, true, 1);
	endforeach;
	
	realAlloc := self.addVoyageAllocation(_voyage, "NZAKL", "GEN2", "", 1, false, false);	
	self.assertNotNull(realAlloc);
	self.addLCsToROROAllocation(true, realAlloc, roro20FTLCs, altRoroLCs, 1);
	
	
	
	// setup load colour coding for 40' containers
	create roro40FTLCs transient;
	roro40FTLCs.clear();
	
	altRoroLCs.clear();
	
	slotsToLoadCC.clear();
	slotsToLoadCC.add("D40101");
	slotsToLoadCC.add("D40102");
	slotsToLoadCC.add("D40091");
	slotsToLoadCC.add("D40092");
	slotsToLoadCC.add("D40222");
	slotsToLoadCC.add("D40191");
	
	foreach str in slotsToLoadCC do
		//app.writeLog(str, LogAlways);
		self.getJobROROControllerByID(_voyage.code, deck.code, null, str, roro40FTLCs, true, 1);
	endforeach;
	
	realAlloc := self.addVoyageAllocation(_voyage, "NZAKL", "GEN4", "", 1, false, false);	
	self.assertNotNull(realAlloc);
	self.addLCsToROROAllocation(true, realAlloc, roro40FTLCs, altRoroLCs, 1);
	
	// setup the job
	create roroLCs transient;
	roro20FTLCs.copy(roroLCs);
	roro40FTLCs.copy(roroLCs);
	
	voyageJob := self.addVoyageROROJob(_voyage, deck, "UT_30863Job1", roroLCs, false);
	assertTrue(voyageJob &lt;&gt; null);
	
	
	// plan the cargo to the respective slots
	locationArray.clear();
	locationArray.add("D40071");
	locationArray.add("D40072");
	locationArray.add("D40121");
	locationArray.add("D40122");
	locationArray.add("D40061");
	locationArray.add("D40062");
	locationArray.add("D40111");
	locationArray.add("D40112");
	locationArray.add("D40171");
	locationArray.add("D40221");
	locationArray.add("D40161");
	locationArray.add("D40211");
	locationArray.add("D40151");
	locationArray.add("D40471");
	locationArray.add("D40472");
	locationArray.add("D40581");
	locationArray.add("D40331R");
	locationArray.add("D40332R");
	locationArray.add("D40261R");
	locationArray.add("D40831R");
	locationArray.add("D40832R");
	locationArray.add("D40801R");
	locationArray.add("D4477O1");
	locationArray.add("D4477O2");
	locationArray.add("D4474O1R");
	locationArray.add("D4471O1R");
	locationArray.add("D4471O2R");
	locationArray.add("D4472O1R");
	locationArray.add("D4461O1");
	locationArray.add("D4465O1");
	locationArray.add("D4465O2");
	locationArray.add("D4466O1");
	locationArray.add("D41511R");
	locationArray.add("D41512R");
	locationArray.add("D41521R");
	locationArray.add("D40101");
	locationArray.add("D40102");
	locationArray.add("D40091");
	locationArray.add("D40191");
	
	roroLCs.clear();
	foreach str in locationArray do
		lc := _voyage.getLocationByID(str);
		roroLCs.add(lc);
	endforeach;
	
	realAlloc := roroLCs.first.getRequest(true).getVoyageAllocations().first.CM_VoyageAllocation;
	self.planTIsRORO(tisToPlanArray, roroLCs, realAlloc.allRequests.first.CM_RORORequest);
	self.assertNoTrxErrorsOrWarnings();
	
	// move ti's to voyage
	locationArray.clear();
	locationArray.add("D40102");
	locationArray.add("D40121");
	locationArray.add("D40122");
	locationArray.add("D40151");
	locationArray.add("D40472");
	locationArray.add("D4465O1");
	locationArray.add("D4465O2");
	locationArray.add("D4474O1R");
	
	roroLCs.clear();
	tisToPlanArray.clear();
	foreach str in locationArray do
		lc := _voyage.getLocationByID(str);
		roroLCs.add(lc);
		lc.getTIs(tisToPlanArray, PLANNING_MODE, false);
	endforeach;
		
	foreach index in 1 to roroLCs.size do
		tempTI := tisToPlanArray[index];
		self.unplanTI(tempTI);
		self.assertNoTrxErrorsOrWarnings();
		self.deleteStops(tempTI);
		self.move(tempTI, roroLCs[index]);
		self.assertNoTrxErrorsOrWarnings();
	endforeach;
	
epilog

	delete roro20FTLCs;
	delete roro40FTLCs;
	delete roroLCs;
	delete altRoroLCs;
	delete slotsToLoadCC;
	delete locationArray;
	delete tiArray;
	delete tisToPlanArray;
	delete moveController;
	
end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="io"/>
        <Parameter name="_cargoId" type="String"/>
        <Parameter name="_cargoCount" type="Integer" usage="io"/>
