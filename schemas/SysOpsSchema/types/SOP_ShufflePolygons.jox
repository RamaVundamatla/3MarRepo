    <JadeMethod name="displayStuff" id="c2fe4b49-6f03-4204-a423-2495526b5e1c">
        <source>displayStuff(_theObject : Object) : String;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	aBay : CM_Bay;
	aLayoutGraphic : CM_LayoutGraphic;
	theString : String;
begin
	
	if _theObject &lt;&gt; null then
		aLayoutGraphic := _theObject.CM_LayoutGraphic;
		theString := aLayoutGraphic.label;
		return  theString;
	else
		return "Null Object";
	endif;

end;</source>
        <Parameter name="_theObject" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doBtnCloseClick" id="75740576-dce4-4c7d-851f-9e5b8a4ca43a">
        <updating/>
        <source>doBtnCloseClick() updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	pxyTerminal : CM_Terminal;
	pxyGraphic : CM_LayoutGraphic;
begin
	pxyGraphic := self.allLayoutGraphics.first.CM_LayoutGraphic;
	if pxyGraphic = null then
		return;
	endif;

	pxyTerminal := pxyGraphic.myTerminal;
	if pxyTerminal = null then
		return;
	endif;
	// put the graphics back into the original order
	pxyTerminal.doOrderLayoutGraphics(self.allLayoutGraphics);
	self.unloadForm();
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnSaveClick" id="78b49572-c82a-4ba2-bbba-770e1e03eeaa">
        <updating/>
        <source>doBtnSaveClick() updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	theGraphics : CM_GraphicArray;
begin
	create theGraphics transient;
	self.magPolygons.getItemsOnRightSide(theGraphics);
	
	myPxyTerminal.doOrderLayoutGraphics(theGraphics);
	
	global.beep;
	self.unloadForm();
epilog
	delete theGraphics;
end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="c9e79e9d-1c6a-43d9-9779-d1fa5a7a5bb3">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
begin
	self.width := 260;
	self.height := 225;

	self.btnSave.move(5,165, 70,25);
	self.btnClose.move(self.btnSave.left + self.btnSave.width + 5,self.btnSave.top, 70,25);

	self.lblPolygons.move(5,5,self.clientWidth - 10, 15 );
	self.magPolygons.move(0, self.lblPolygons.top + self.lblPolygons.height + 5,self.clientWidth - 10, 140);
	self.magPolygons.cnEcResizeContents();
	self.magPolygons.move(0, self.lblPolygons.top + self.lblPolygons.height + 5,self.clientWidth - 10, 140);


end;</source>
    </JadeMethod>
    <JadeMethod name="initGroupBox" id="61ccf4cc-b5df-465d-94d5-a25b12b8a372">
        <source>initGroupBox();
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

begin
	self.magPolygons.caption := null;
	self.magPolygons.distanceFromBottom 	:= 5;
	self.magPolygons.distanceFromRight 		:= 5;
	self.magPolygons.lockBottom 				:= false;
	self.magPolygons.lockRight				:= false;
	self.magPolygons.stretchHeight 			:= true;
	self.magPolygons.stretchWidth 			:= true;
	self.magPolygons.multiSelect 	:= ListBox.MultiSelect_Extended;
	self.magPolygons.borderStyle := Frame.BorderStyle_None;
	
	self.magPolygons.availableHeading := app.getErrorString(SHP_Graphics);	//cnwmc5 

	self.magPolygons.selectedHeading := app.getErrorString(SHP_Graphics);	//cnwmc5 

	self.magPolygons.displayAddRemoveBtns(false, false);	//cnwmc5
	self.magPolygons.displayOrderBtns(true, true);	//cnwmc5
	self.magPolygons.myBaseForm	:= self;
	self.magPolygons.mySelectedListBox.sorted := false;
	self.magPolygons.cnEcResizeContents();
	self.magPolygons.readOnly := false;
	self.magPolygons.myAvailableListBox.listObject := null;
	self.magPolygons.setAsAlignOnly();
end;</source>
    </JadeMethod>
    <JadeMethod name="setCollections" id="94a80831-468a-42c0-aa37-0abc0c9146af">
        <source>setCollections(_theRightPolygon: CM_GraphicArray) : Boolean;
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
begin
	self.magPolygons.setItemsOnRightSide(_theRightPolygon, true);
	_theRightPolygon.copy(self.allLayoutGraphics);
	return true;
epilog
end;</source>
        <Parameter name="_theRightPolygon" type="CM_GraphicArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="fd501f40-f77a-4fcd-a4b5-2a5d5ad9cad8">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
// ---------------------------------------------------------------------------
// Created:		August 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod(_colorControl);
	self.lblPolygons.backColor := self.backColor;
	self.magPolygons.backColor := self.backColor;

end;</source>
        <Parameter name="_colorControl" type="CM_ColorController"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="c00af2c7-59bb-44ba-aed9-78b56ce0f543">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

begin
	app.mousePointer := Window.MousePointer_Default;
	self.centreWindow();
	self.initGroupBox();
	
	inheritMethod();

	//self.doResize();
epilog
	app.mousePointer := Window.MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="786e5aa3-cafd-4f46-a6c5-c7dccb5c60c6">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0007071, locale);
	btnClose.translateCaption(Xlat_0003946, locale);
	btnSave.translateCaption(Xlat_0003947, locale);
	lblPolygons.translateCaption(Xlat_0003948, locale);
	magPolygons.translateCaption(Xlat_0003949, locale);
end;</source>
    </JadeMethod>
</GUIClass>
