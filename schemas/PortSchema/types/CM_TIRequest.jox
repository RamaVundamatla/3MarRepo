    <JadeMethod name="setProxyFromFlexiGate" id="544f3269-ffbf-4336-bdfa-5d266d718701">
        <updating/>
        <source>setProxyFromFlexiGate(
		_clean : Boolean; 
		_consignorVoyageCode : String; 
		_eirNumber : String; 
		_consignee : String; 
		_doorsDirection : Integer; 
		_deliveryNumber : String;
		_freightForwarderCode, 
		_freightPayeeCode : String; 
		_isReceipt : Boolean; 
		_isoType : String; 
		_operator : String; 
		_numRequested : Integer; 
		_reasonCode : Integer; 
		_heavy : Boolean; 
		_mask : String; 
		_needCOU : Boolean; 
		_needGenerator : Boolean; 
		_date : Date; 
		_voyageCode : String; 
		_checkISO : Boolean; 
		_job : CM_Job; 
		_pinNo : String; 
		_avg : Integer;  
		_removeStops : Boolean; 
		_reasonCodeDescr,pRemarks : String;
		_ti : CM_TrackedItem;
		_userCode : String; 
		_transToTerminal: CM_Terminal;
		_customEntryNumber: String;
		_bulkRelease : CM_BulkRelease;
		_reserveDetail : CM_ReserveDetail ) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 September 2009	cnwjk3	sfw1035

*/

vars

begin
	self.customEntryNumber := _customEntryNumber;
	if _bulkRelease &lt;&gt; null then
		self.setMyOriginatingBulkRelease(_bulkRelease);
	endif;
	self.myReserveDetail := _reserveDetail;
	
	self.setProxy(
		_clean, 
		_consignorVoyageCode, 
		_eirNumber, 
		_consignee, 
		_doorsDirection, 
		_deliveryNumber,
		_freightForwarderCode, 
		_freightPayeeCode, 
		_isReceipt, 
		_isoType, 
		_operator, 
		_numRequested, 
		_reasonCode, 
		_heavy, 
		_mask, 
		_needCOU, 
		_needGenerator, 
		_date, 
		_voyageCode, 
		_checkISO, 
		_job, 
		_pinNo, 
		_avg,  
		_removeStops, 
		_reasonCodeDescr,
		pRemarks,
		_ti,
		_userCode, 
		_transToTerminal
	);

epilog

end;</source>
