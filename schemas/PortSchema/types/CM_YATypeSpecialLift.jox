<Class name="CM_YATypeSpecialLift" id="a536cb86-8017-4242-ad27-14ad17c46114">
    <superclass name="CM_YACriteriaType"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="yardAllocations"/>
    <JadeMethod name="getAllCriteriaValues" id="d6b88ff6-086b-4517-8e1b-66b8461e247d">
        <source>getAllCriteriaValues(_terminalObj:CM_Terminal; _allCriteriaValues: ObjectSet input; _filter : Integer; _allDependentObjs : CM_ObjectArray);
// --------------------------------------------------------------------------------
// Created:		24 November 2009 by cnwjo3
//
// Purpose:		Populate the collection parameter with instances of the CM_SpecialStow
//				class.  CCMS 1028
//
// Parameters:	pAllCriteriaValues - A reference to the object set to populate.
//
//17 September 2013	cnwmc5	PAR 31255 - allowing dependent objects the criteria is based on.
//
begin
	app.myRoot.allSpecialLifts.copy(_allCriteriaValues);
end;</source>
        <Parameter name="_terminalObj" type="CM_Terminal"/>
        <Parameter name="_allCriteriaValues" type="ObjectSet" usage="input"/>
        <Parameter name="_filter" type="Integer"/>
        <Parameter name="_allDependentObjs" type="CM_ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="getDataDisplay" id="14b59e08-6efd-48df-8f40-3eceb2be99e4">
        <source>getDataDisplay(pDataObj: CM_YAData): String;
//24 November 2009 cnwjo3 CCMS 1028
begin
	return pDataObj.CM_YADataObjects.getDataDisplay(self);
end;</source>
        <Parameter name="pDataObj" type="CM_YAData"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDescriptionWithData" id="63a8a03d-8dfc-4a5f-9a82-616f87ae1ca0">
        <source>getDescriptionWithData(_dataObj: CM_YAData): String;
// --------------------------------------------------------------------------------
// Created:		24 November 2009 by cnwjo3
//
// Purpose:		return a display string of both the Criteria Type and a specified object of the type of
//				data which the new Criteria Type deals with.  CCMS 1028
//
begin
	//return self.getTypeName() &amp; ": " &amp; self.getDataDisplay(_dataObj);
	return self.description &amp; ": " &amp; self.getDataDisplay(_dataObj);	//09 Oct 2013	NDL	Par 32456
end;</source>
        <Parameter name="_dataObj" type="CM_YAData"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplay" id="f011ed7c-f565-44c9-950d-4a054bcc3f59">
        <source>getDisplay(dataObj : Object) : String;
//24 November 2009 cnwjo3 CCMS 1028
begin
	return dataObj.CM_SpecialLift.code;
end;</source>
        <Parameter name="dataObj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getObjects" id="c606dc5c-9d67-4699-aae8-b158170e45b5">
        <source>getObjects(objects: ObjectLongNameDict input);
//24 November 2009 cnwjo3 CCMS 1028
// Return a dict of objects for this criteria type
vars
	ss: CM_SpecialLift;
begin
	foreach ss in app.myRoot.allSpecialLifts do
		objects[ss.getYAIdentifier] := ss;
	endforeach;
end;</source>
        <Parameter name="objects" type="ObjectLongNameDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTypeName" id="f57d0c0f-70ea-40d4-86b2-9a07ab65e0d2">
        <source>getTypeName(): String;
// --------------------------------------------------------------------------------
// Created:		24 November 2009 cnwjo3 CCMS 1028
//
begin
	return "Special Lift";
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isCMIFDataMatch" id="2abcf44e-169c-4f6c-bd00-65edc43ded38">
        <source>isCMIFDataMatch(_cmifAutoPlan: CMIF_YAAutoPlan; _yaData: CM_YADataObjects): Boolean;
// -------------------------------------------
// Created: 24 November 2009 cnwjo3 CCMS 1028
// _yaData was originally CM_YAData.  Changed to CM_YADataObjects
// -------------------------------------------
vars

begin
	return _cmifAutoPlan.isSpecialLift_Match(_yaData);
end;</source>
        <Parameter name="_cmifAutoPlan" type="CMIF_YAAutoPlan"/>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isStorageDetailMatch" id="f67bfb05-0e59-4be9-9ca3-328d1578a4bd">
        <source>isStorageDetailMatch(_criteria: CM_YACriteria; _ti: CM_TrackedItem; _tiTrx: CM_TITransaction): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2023	navmk20	Task 57998: JADE - Storage Config - YA Criteria Storage Matching

*/

vars
	sepcialLift	: CM_SpecialLift;
	yaData		: CM_YAData;
	mySepcialLift : String;
begin

	if _tiTrx &lt;&gt; null and _tiTrx.myTrackedItem &lt;&gt; null then 
		mySepcialLift	:= _tiTrx.myTrackedItem.getSpecialLiftsCodes();
	elseif _ti&lt;&gt; null then
		mySepcialLift := _ti.getSpecialLiftsCodes();
	endif;
	
	if mySepcialLift &lt;&gt; null then
		sepcialLift := app.myRoot.allSpecialLifts[mySepcialLift];
	endif;
	
	yaData := _criteria.myYAData;
	
	if yaData.CM_YADataObjects.matchesStorage(sepcialLift) then
		return true;
	endif;
	
	if yaData.isKindOf(CM_YADataPattern) and
	   yaData.CM_YADataPattern.pattern = null then
		return true;
	endif;
	
	return false;
end;
</source>
        <Parameter name="_criteria" type="CM_YACriteria"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_tiTrx" type="CM_TITransaction"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
