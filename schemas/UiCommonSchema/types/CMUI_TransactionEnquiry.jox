    <JadeMethod name="doTblTransactionsSelect" id="a88f1df3-7281-4760-83dd-f03a4b7f5563">
        <updating/>
        <source>doTblTransactionsSelect() updating, protected;

vars
	trans		: CM_Transaction;
begin
	if self.tblTransactions.row &gt; self.tblTransactions.fixedRows then
		trans := self.tblTransactions.accessRow(self.tblTransactions.row).itemObject.CM_Transaction;
		self.showTransactionCharges(trans);
