Return Value:		

Date		Who		Reason
03 February 2023	navmk3	Initial creation

*/
constants
	Input				:String='&lt;?xml version="1.0" encoding="utf-8"?&gt;&lt;soap:Envelope xmlns:soap="http://www.w3.org/2003/05/soap-envelope" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema"&gt;&lt;soap:Body&gt;&lt;GetVoyageExportDataByDomainAndDatesResponse xmlns="http://kleinsystem.com/webservices/"&gt;&lt;GetVoyageExportDataByDomainAndDatesResult&gt;&lt;xs:schema id="NewDataSet" xmlns="" xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:msdata="urn:schemas-microsoft-com:xml-msdata" xmlns:msprop="urn:schemas-microsoft-com:xml-msprop"&gt;&lt;xs:element name="NewDataSet" msdata:IsDataSet="true" msdata:UseCurrentLocale="true"&gt;&lt;xs:complexType&gt;&lt;xs:choice minOccurs="0" maxOccurs="unbounded"&gt;&lt;xs:element name="VOYAGEJOBEXPORT" msprop:TOTAL_COUNT="72" msprop:SRC="VOYAGE_JOB_EXPORT_VIEW"&gt;&lt;xs:complexType&gt;&lt;xs:sequence&gt;&lt;xs:element name="id" msdata:Caption=" ID" msprop:MaxLength="9" msprop:WrapText="False" msprop:Order="-2147483648" msprop:DecimalLength="0" msprop:Default_Visible="False" msprop:AllowDBNull="False" msprop:Visible="True" msprop:ReadOnlyWeb="False" msprop:ReadOnly="False" type="xs:int" minOccurs="0" /&gt;&lt;xs:element name="voyage_id" msdata:Caption="Voyage ID" msprop:MaxLength="9" msprop:WrapText="False" msprop:Order="-2147483648" msprop:DecimalLength="0" msprop:Default_Visible="False" msprop:AllowDBNull="False" msprop:Visible="True" msprop:ReadOnlyWeb="False" msprop:ReadOnly="False" type="xs:int" minOccurs="0" /&gt;&lt;xs:element name="rank" msdata:Caption="Rank" msprop:MaxLength="9" msprop:WrapText="False" msprop:Order="-2147483648" msprop:DecimalLength="0" msprop:Default_Visible="False" msprop:AllowDBNull="True" msprop:Visible="True" msprop:ReadOnlyWeb="False" msprop:ReadOnly="False" type="xs:int" minOccurs="0" /&gt;&lt;xs:element name="job_type" msdata:Caption="Job Type" msprop:MaxLength="9" msprop:WrapText="False" msprop:Order="-2147483648" msprop:DecimalLength="0" msprop:Default_Visible="False" msprop:AllowDBNull="False" msprop:Visible="True" msprop:ReadOnlyWeb="False" msprop:ReadOnly="False" type="xs:int" minOccurs="0" /&gt;&lt;xs:element name="JOB_TYPE_NAME" msdata:Caption="Job Type Name" msprop:MaxLength="50" msprop:WrapText="False" msprop:Order="-2147483648" msprop:DecimalLength="0" msprop:Default_Visible="False" msprop:AllowDBNull="True" msprop:Visible="True" msprop:ReadOnlyWeb="False" msprop:ReadOnly="False" type="xs:string" minOccurs="0" /&gt;&lt;xs:element name="status_type" msdata:Caption="Status Type" msprop:MaxLength="9" msprop:WrapText="False" msprop:Order="-2147483648" msprop:DecimalLength="0" msprop:Default_Visible="False" msprop:AllowDBNull="False" msprop:Visible="True" msprop:ReadOnlyWeb="False" msprop:ReadOnly="False" type="xs:int" minOccurs="0" /&gt;&lt;xs:element name="STATUS_TYPE_NAME" msdata:Caption="Status Type Name" msprop:MaxLength="50" msprop:WrapText="False" msprop:Order="-2147483648" msprop:DecimalLength="0" msprop:Default_Visible="False" msprop:AllowDBNull="True" msprop:Visible="True" msprop:ReadOnlyWeb="False" msprop:ReadOnly="False" type="xs:string" minOccurs="0" /&gt;&lt;xs:element name="dead_ship" msdata:Caption="Dead Ship" msprop:MaxLength="1" msprop:WrapText="False" msprop:Order="-2147483648" msprop:DecimalLength="0" msprop:Default_Visible="False" msprop:AllowDBNull="True" msprop:Visible="True" msprop:ReadOnlyWeb="False" msprop:ReadOnly="False" type="xs:boolean" minOccurs="0" /&gt;&lt;xs:element name="hazardous" msdata:Caption="Hazardous" msprop:MaxLength="1" msprop:WrapText="False" msprop:Order="-2147483648" msprop:DecimalLength="0" msprop:Default_Visible="False" msprop:AllowDBNull="True" msprop:Visible="True" msprop:ReadOnlyWeb="False" msprop:ReadOnly="False" type="xs:boolean" minOccurs="0" /&gt;&lt;xs:element name="midships_draft" msdata:Caption="Midships Draft" msprop:MaxLength="18" msprop:WrapText="False" msprop:Order="-2147483648" msprop:DecimalLength="4" msprop:Default_Visible="False" msprop:AllowDBNull="True" msprop:Visible="True" msprop:ReadOnlyWeb="False" msprop:ReadOnly="False" type="xs:decimal" minOccurs="0" /&gt;&lt;xs:element name="fore_draft" msdata:Caption="Fore Draft" msprop:MaxLength="18" msprop:WrapText="False" msprop:Order="-2147483648" msprop:DecimalLength="4" msprop:Default_Visible="False" msprop:AllowDBNull="True" msprop:Visible="True" msprop:ReadOnlyWeb="False" msprop:ReadOnly="False" type="xs:decimal" minOccurs="0" /&gt;&lt;xs:element name="aft_draft" msdata:Caption="Aft Draft" msprop:MaxLength="18" msprop:WrapText="False" msprop:Order="-2147483648" msprop:DecimalLength="4" msprop:Default_Visible="False" msprop:AllowDBNull="True" msprop:Visible="True" msprop:ReadOnlyWeb="False" msprop:ReadOnly="False" type="xs:decimal" minOccurs="0" /&gt;&lt;xs:element name="remarks" msdata:Caption="Remarks" msprop:MaxLength="1000" msprop:WrapText="False" msprop:Order="-2147483648" msprop:DecimalLength="0" msprop:Default_Visible="False" msprop:AllowDBNull="True" msprop:Visible="True" msprop:ReadOnlyWeb="False" msprop:ReadOnly="False" type="xs:string" minOccurs="0" /&gt;&lt;xs:element name="ETD" msprop:MaxLength="23" msprop:WrapText="False" msprop:Order="-2147483648" msprop:DecimalLength="3" msprop:Default_Visible="False" msprop:AllowDBNull="True" msprop:Visible="True" msprop:ReadOnlyWeb="False" msprop:ReadOnly="False" type="xs:dateTime" minOccurs="0" /&gt;&lt;xs:element name="ATD" msdata:Caption="Atd" msprop:MaxLength="23" msprop:WrapText="False" msprop:Order="-2147483648" msprop:DecimalLength="3" msprop:Default_Visible="False" msprop:AllowDBNull="True" msprop:Visible="True" msprop:ReadOnlyWeb="False" msprop:ReadOnly="False" type="xs:dateTime" minOccurs="0" /&gt;&lt;xs:element name="ETA" msprop:MaxLength="23" msprop:WrapText="False" msprop:Order="-2147483648" msprop:DecimalLength="3" msprop:Default_Visible="False" msprop:AllowDBNull="True" msprop:Visible="True" msprop:ReadOnlyWeb="False" msprop:ReadOnly="False" type="xs:dateTime" minOccurs="0" /&gt;&lt;xs:element name="ATA" msdata:Caption="Ata" msprop:MaxLength="23" msprop:WrapText="False" msprop:Order="-2147483648" msprop:DecimalLength="3" msprop:Default_Visible="False" msprop:AllowDBNull="True" msprop:Visible="True" msprop:ReadOnlyWeb="False" msprop:ReadOnly="False" type="xs:dateTime" minOccurs="0" /&gt;&lt;xs:element name="agent_voyage_number" msdata:Caption="Agent Voyage Number" msprop:MaxLength="50" msprop:WrapText="False" msprop:Order="-2147483648" msprop:DecimalLength="0" msprop:Default_Visible="False" msprop:AllowDBNull="True" msprop:Visible="True" msprop:ReadOnlyWeb="False" msprop:ReadOnly="False" type="xs:string" minOccurs="0" /&gt;&lt;xs:element name="visit_number" msdata:Caption="Visit Number" msprop:MaxLength="50" msprop:WrapText="False" msprop:Order="-2147483648" msprop:DecimalLength="0" msprop:Default_Visible="False" msprop:AllowDBNull="True" msprop:Visible="True" msprop:ReadOnlyWeb="False" msprop:ReadOnly="False" type="xs:string" minOccurs="0" /&gt;&lt;xs:element name="VESSEL_ID" msdata:Caption="Vessel ID" msprop:MaxLength="9" msprop:WrapText="False" msprop:Order="-2147483648" msprop:DecimalLength="0" msprop:Default_Visible="False" msprop:AllowDBNull="True" msprop:Visible="True" msprop:ReadOnlyWeb="False" msprop:ReadOnly="False" type="xs:int" minOccurs="0" /&gt;&lt;xs:element name="VESSEL_NAME" msdata:Caption="Vessel Name" msprop:MaxLength="50" msprop:WrapText="False" msprop:Order="-2147483648" msprop:DecimalLength="0" msprop:Default_Visible="False" msprop:AllowDBNull="True" msprop:Visible="True" msprop:ReadOnlyWeb="False" msprop:ReadOnly="False" type="xs:string" minOccurs="0" /&gt;&lt;xs:element name="VESSEL_LRN" msdata:Caption="Vessel Lrn" msprop:MaxLength="9" msprop:WrapText="False" msprop:Order="-2147483648" msprop:DecimalLength="0" msprop:Default_Visible="False" msprop:AllowDBNull="True" msprop:Visible="True" msprop:ReadOnlyWeb="False" msprop:ReadOnly="False" type="xs:int" minOccurs="0" /&gt;&lt;xs:element name="VESSEL_MMSI" msprop:Visible="False" ty