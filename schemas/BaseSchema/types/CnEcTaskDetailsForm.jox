        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doFormLoad" id="95fbb415-9827-4e24-b3db-c7e965a031ec">
        <updating/>
        <source>doFormLoad() updating, protected;
// -----------------------------------------------------------------------------
// Created:		17 June 2003 by cnwdad1
//
// Purpose:		Standard form load method.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
// 17/06/2003	cnwdad1		When editing an existing task, the schedule options
//							(run once, re-schedule etc.) were not being correctly
//							set up.
// -----------------------------------------------------------------------------
vars
	taskObj		: CnEcBackShedTask;
	timeNow		: TimeStamp;
	
begin
	self.centreWindow();
	taskObj	:=	self.aMyTask;
	self.populateCmbNewTask();

	if self.aMyTask = null then
		self.caption	:=	$CNEC_NEW("Task");
		btnNext.enabled	:=	true;
		timeNow			:=	app.actualTimeServer();
		txtSchedDate.setDate(timeNow.Date);
		txtSchedTime.setTime(timeNow.Time);
		txtEveryMinutes.setMinValue(0);
		txtEveryMinutes.setMaxValue(99999);
	else
		self.caption			:=	$CNEC_EDIT("Task");
		btnNext.enabled			:=	false;
		cmbNewTask.listIndex	:=	cmbNewTask.findStringExact(1, taskObj.class().name);
		txtTaskId.text			:=	taskObj.taskName;
		txtSchedDate.setDate(taskObj.scheduleTimeStamp.date);
		txtSchedTime.setTime(taskObj.scheduleTimeStamp.time);
		chkReStartFail.value	:=	taskObj.isRestartOnFailure;

// cnwdad1 17/06/2003 - These options were not being correctly set up when editing an existing task.		
//		if taskObj.isOneTimeOnly then
//			optRunOnceOnly.value	:=	true;
//			optRunDaily.value		:=	false;
//		else
//			optRunOnceOnly.value	:=	false;
//			optRunDaily.value		:=	true;
//		endif;
		if taskObj.isOneTimeOnly then
			optRunOnceOnly.value		:=	true;
		elseif taskObj.isRescheduleDaily then
			optRunDaily.value			:=	true;
		elseif taskObj.isRunEveryNMinutes then
			optRunMinutes.value			:=	true;
		elseif taskObj.isCustomSchedule then
			optRunCustom.value			:=	true;
		endif;
		
		chkMon.value	:=	taskObj.isRunMonday();
		chkTue.value	:=	taskObj.isRunTuesday();
		chkWed.value	:=	taskObj.isRunWednesday();
		chkThu.value	:=	taskObj.isRunThursday();
		chkFri.value	:=	taskObj.isRunFriday();
		chkSat.value	:=	taskObj.isRunSaturday();
		chkSun.value	:=	taskObj.isRunSunday();
		
		if taskObj.daysToExecuteTime.isValid then
			txtDailyTime.setTime(taskObj.daysToExecuteTime);
		endif;
		
		txtEveryMinutes.setValue(taskObj.minsBetweenExecution);
		
		optRunCustom.value	:= taskObj.isCustomSchedule;
	endif;
	
	self.setVisibility();
	
	self.resynchObjectAndSetEdition(taskObj);
	self.modalResult	:=	self.CNEC_MODAL_CANCEL;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormUpdate" id="3c494fc7-84d6-4bd5-bfd5-a93b0f9de4c0">
        <source>doFormUpdate():Boolean protected;
// -----------------------------------------------------------------------------
// Created:		17 June 2003 by cnwdad1
//
// Purpose:		Standard form update method.
//
// Parameters:	None
//
// Returns:		True if the update was successful, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
// 17/06/2003	cnwdad1		Added the isRescheduleDaily and isRunEveryNMinutes
//							to the CnEcBackShedTask class.
// -----------------------------------------------------------------------------
vars
	taskObj		: CnEcBackShedTask;
	managerObj	: CnEcBackShedManager;
	classObj	: Class;
	timeStamp	: TimeStamp;
	daysToExe	: String[7];
	
begin
	taskObj		:=	self.aMyTask;
	
	if not self.doFormValidate() then
		return false;
	endif;
	
	managerObj	:=	app.myBackShedManager;
	classObj	:=	cmbNewTask.listObject.Class;		
	timeStamp.setDate(txtSchedDate.cnEcDate());
	timeStamp.setTime(txtSchedTime.getTime());
	
	daysToExe	:=	chkMon.value.cnEcFormat("Y", "N") &amp;
					chkTue.value.cnEcFormat("Y", "N") &amp;
					chkWed.value.cnEcFormat("Y", "N") &amp;
					chkThu.value.cnEcFormat("Y", "N") &amp;
					chkFri.value.cnEcFormat("Y", "N") &amp;
					chkSat.value.cnEcFormat("Y", "N") &amp;
					chkSun.value.cnEcFormat("Y", "N");
	
	if taskObj = null then
		managerObj.createTask(	classObj,	//taskType : Class;
								txtTaskId.cnEcString(),	//taskName : String;
								timeStamp,	//startTime : TimeStamp
								optRunOnceOnly.value, //isOneTimeOnly : Boolean
								optRunDaily.value,	// isRescheduleDaily
								optRunMinutes.value,	// isRunEveryNMinutes
								chkReStartFail.value,	//doRestartOnFailure : Boolean
								daysToExe,	//daysToExecute : String;
								txtDailyTime.cnEcTime(),	//daysToExecuteTime : Time;
								txtEveryMinutes.getValue(),	//minsBetweenExecution : Integer;
								optRunCustom.value//pUseCustomSchedule : Boolean;
							);
	else
		taskObj.updateMe(		txtTaskId.text,	//taskName : String;
								timeStamp,	//startTime : TimeStamp
								optRunOnceOnly.value, //isOneTimeOnly : Boolean
								optRunDaily.value,	// isRescheduleDaily
								optRunMinutes.value,	// isRunEveryNMinutes
								chkReStartFail.value,	//doRestartOnFailure : Boolean
								daysToExe,	//daysToExecute : String;
								txtDailyTime.cnEcTime(),	//daysToExecuteTime : Time;
								txtEveryMinutes.getValue(),	//minsBetweenExecution : Integer;
								optRunCustom.value//pUseCustomSchedule : Boolean;
						);
	endif;
	
	return true;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doFormValidate" id="44eaaed6-a75f-4f3e-8870-d6f4a9147cc8">
        <source>doFormValidate():Boolean protected;
// -----------------------------------------------------------------------------
// Created:		15 December 2001 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	managerObj		: CnEcBackShedManager;
	classObj		: Class;
	scheduleDate	: Date;
	scheduleTime	: Time;
	
begin
	managerObj	:=	app.myBackShedManager;
	
	if managerObj = null then	
		app.msgBox("No CnEcBackShedMgr set up.", "Error", MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
	endif;
	
	if cmbNewTask.listObject = null then	
		app.msgBox("Must select a Task Type.", "Error", MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		cmbNewTask.setFocus();
		return false;
	else
		classObj := cmbNewTask.listObject.Class;		
	endif;
	
	scheduleDate	:=	txtSchedDate.cnEcDate();
	
	if not scheduleDate.isValid() then
		app.msgBox("Must select a valid Date.", "Error", MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		txtSchedDate.setFocus();
		return false;
// cnwdad1 01/10/2003 - Added check to prevent a schedule date prior to the current date.
	elseif scheduleDate &lt; app.actualTimeServer().date() then
		app.msgBox("The Schedule Date cannot be in the past.", "Error", MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		txtSchedDate.setFocus();
		return false;
	endif;
	
	scheduleTime	:=	txtSchedTime.getTime();
	
	if not scheduleTime.isValid then
		app.msgBox("Must select a valid Time.", "Error", MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		txtSchedTime.setFocus();
		return false;
	endif;
	
	return true;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="load" id="2462ab3f-7506-4a21-a75d-c190929832da">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

begin
	app.mousePointer	:=	Busy;
	inheritMethod();
	self.doFormLoad();
epilog
	app.mousePointer	:=	Idle;
end;</source>
    </JadeMethod>
