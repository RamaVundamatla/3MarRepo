    <JadeMethod name="translateForm" id="ae6cb909-bf21-4619-bc7f-9f359d309475">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 26 September 2024 10:18:42.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0026975, locale);
	btnBrowse.translateCaption(Xlat_0026976, locale);
	btnCancel.translateCaption(Xlat_0026977, locale);
	btnOK.translateCaption(Xlat_0026978, locale);
	lblFileName.translateCaption(Xlat_0026979, locale);
	lblFileType.translateCaption(Xlat_0026980, locale);
	lblReportName.translateCaption(Xlat_0026981, locale);
end;</source>
    </JadeMethod>
</GUIClass>
