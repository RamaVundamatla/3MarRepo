    <JadeMethod name="createProperties" id="a0d03ab1-26ca-4704-b354-8bad528aceb2">
        <source>createProperties();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Dec 2022	navhl20	ChangeRequest 54350:[54269] EUP - VAS Work Orders Selector Query
07 Jul 2023 navhl20 Bug 59042: EUP | Pack Release Request is Missing From Work Order Selector Query
07 Aug 2023	navlw1	ChangeRequest 59284:[59664] EUP | FR - VAS Work Order Transactions - Fixing Selector Query
20 Jun 2024 navhl20 Bug 64718: EUP | 53812 - VAS Work Order - WO Transactions Report issues
*/

vars
	qProp		: CM_QueryProperty;
begin
	inheritMethod(); //Terminal

	// CM_WOTransaction properties
	create qProp as CM_QDateProperty persistent;
	qProp.set('Transaction Date', CM_WOTransaction::dateTime.name, self.className);
	qProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(qProp);
	
	create qProp as CM_QRefTransactionTypeMethod persistent;
	qProp.set('Transaction Type', CM_WOTransaction::getTransactionType.name, self.className);
	qProp.setPerformanceRating( CM_QueryProperty.CollKey );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	qProp.CM_QRefTransactionTypeMethod.setType( TRANS_TYPE_GROUP_WO );
	self.allQueryProperties.add(qProp);
	
	/*create qProp as CM_QRefTransactionTypeMethod persistent;
	qProp.set('Transaction Details', CM_WOTransaction::getTranTypeString.name, self.className);
	qProp.setPerformanceRating( CM_QueryProperty.CollKey );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	qProp.CM_QRefTransactionTypeMethod.setType( TRANS_TYPE_GROUP_WO );
	self.allQueryProperties.add(qProp);*/
	
	create qProp as CM_QStringProperty persistent;
	qProp.set('User Code', CM_WOTransaction::userCode.name, self.className);
	qProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(qProp);

	create qProp as CM_QBooleanProperty persistent;
	qProp.set('Is No Charge', CM_WOTransaction::noCharge.name, self.className);
