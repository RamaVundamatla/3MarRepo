    <JadeMethod name="doImportTrx" id="9209c560-d5df-411f-881a-49d735bb586d">
        <source>doImportTrx(_impFile: File) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 August 2009	cnwjmn1	Initial creation

*/

vars

begin
	app.myTrxCA.trxImportISOTypeFromFile(_impFile, app.myPassport);

epilog

end;</source>
