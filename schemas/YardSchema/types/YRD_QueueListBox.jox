    </JadeMethod>
    <JadeMethod name="getListIndexOver" id="11742e3e-eee3-4d62-b3e1-4a0636163051">
        <source>getListIndexOver(pXPos : Real) : Integer;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lLineHeight : Integer;
begin

	lLineHeight := self.defaultLineHeight;
	
	return pXPos.Integer div lLineHeight;
end;</source>
        <Parameter name="pXPos" type="Real"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getParentIndex" id="0d926af9-5457-4e53-9f0b-571543c220e5">
        <source>getParentIndex(pChild : Integer) : Integer;
// ---------------------------------------------------------------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	lListCount : Integer;
	lLevel : Integer;
begin

	if pChild &lt; 0 then
		return null;
	endif;
	
	lListCount := self.listCount;
	lLevel := self.itemLevel[pChild];
	
	if pChild &lt;= lListCount then
		lListCount := pChild;
		while true do
			// go back up the tree until we find a parent
			if self.itemLevel[lListCount] &lt; lLevel then
				break;
			endif;
			lListCount := lListCount - 1;
			if lListCount = 0 then
				break;
			endif;
		endwhile;
	endif;


	return lListCount;


end;</source>
        <Parameter name="pChild" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="moveItem" id="d9b7f434-c9fc-4a79-aee8-1261074b708c">
        <source>moveItem(pFrom, pTo : Integer);
// ---------------------------------------------------------------------------
// Created:     05 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpNum	: Integer;
	
begin

	// not implemented

	tmpNum := self.listCount;
	if pFrom &lt;= 0 or pTo &lt;= 0 or pFrom &gt; tmpNum or pTo &gt; tmpNum then
		app.raiseUnexpectedProgramError(class.name, method.name, 'From/To outside valid limits');
		return;
	endif;

end;</source>
        <Parameter name="pFrom" type="Integer"/>
        <Parameter name="pTo" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="pictureClick" id="8bbd75d0-ed51-4686-abed-ed01f19c8de4">
        <updating/>
        <source>pictureClick(listbox: ListBox input; picIndex: Integer; whatClicked: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     04 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if listbox.itemHasSubItems(picIndex) then
		listbox.itemExpanded[picIndex] := (not listbox.itemExpanded[picIndex]);
	endif;

end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="picIndex" type="Integer"/>
        <Parameter name="whatClicked" type="Integer"/>
    </JadeMethod>
