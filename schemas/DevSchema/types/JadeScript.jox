    <JadeMethod name="eprTestWagonId" id="135cf8cd-e863-47ec-86f7-b6e79431b75a">
        <source>eprTestWagonId();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 June 2019	jlger1	Initial creation

*/

vars
	lc: CM_LocationsController;
terminal : CM_Terminal;
	c : CM_TrackedItem;
	ti : CM_TrackedItem;
	wagon : CM_Wagon;
