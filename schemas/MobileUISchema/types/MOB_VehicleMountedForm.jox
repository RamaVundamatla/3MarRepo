        </interfaceImplements>
        <source>getCargoID() : String;

	/*
		this method stub has been automatically generated by Jade to satisfy interface implementation requirements
	*/
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 April 2010	cnwer1	Initial creation

*/

vars
	row : Integer;	
	accessCell : JadeTableCell;
begin
	self.myMoveTableDetails.setDataColumn(DataColumn);
	// epr par 34603 CCMS 2404 4/8/14
	row:=self.myMoveTableDetails.findRowWithEntRowName(ETRow_CargoID);
	if row &gt;  0 then
		accessCell:=self.myMoveTableDetails.myTable.accessCell(row,self.myMoveTableDetails.dataColumn);
		if accessCell &lt;&gt; null then
			if accessCell.itemObject &lt;&gt; null then
				return accessCell.itemObject.getOidString(); //epr TFS 6863 14/9/17 so breakbulk works correctly
			endif;
		endif;
	endif;
	return null;

epilog
	


end;</source>
