    <JadeMethod name="getAllPaths" id="a0f5a0b4-a4fc-45af-ac2f-8d121426dfb8">
        <source>getAllPaths(_child : CM_FinancialObject; _paths : HugeStringArray input; _items : ObjectArray input);
// 32311 return the path text and tran map item for each tran map entry, other than the entered one in _child, at the same level
vars
	commodityMap		: CM_CommodityMap;
begin
	if _child.isKindOf(CM_CommodityMap) then
		_paths.add(self.getPath());
		_items.add(self);
		return;
	endif;

	foreach commodityMap in self.commoditiesMap do
		commodityMap.getAllPaths(_child, _paths, _items);
	endforeach;

end;</source>
        <Parameter name="_child" type="CM_FinancialObject"/>
        <Parameter name="_paths" type="HugeStringArray" usage="input"/>
        <Parameter name="_items" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllPaths2" id="2f987c5c-eebe-401d-9a42-3cf33dc2636d">
        <source>getAllPaths2(_child : CM_FinancialObject; _paths : HugeStringArray input; _items : ObjectArray input);
// 32311 return the path text and tran map item for each tran map entry, other than the entered one in _child, at the same level
vars
	commodityMap		: CM_CommodityMap;
begin
	if _child.isKindOf(CM_CommodityMap) then
		_paths.add(self.getPath2());
		_items.add(self);
		return;
	endif;

	foreach commodityMap in self.commoditiesMap do
		commodityMap.getAllPaths2(_child, _paths, _items);
	endforeach;

end;</source>
        <Parameter name="_child" type="CM_FinancialObject"/>
        <Parameter name="_paths" type="HugeStringArray" usage="input"/>
        <Parameter name="_items" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="d72ed3e8-93b3-474d-a58b-1e533199e6b4">
        <source>getAuditText(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 December 2016	cnwma1	Initial creation

*/

vars
	txt,
	tmpStr	: String;
begin
	txt[10000] 	:= '*';
	txt 		:= null;
	txt 		:= inheritMethod();
	tmpStr := self.getTranMapBreadCrumb;
	txt := txt &amp; 'Item Path' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	
	tmpStr := null;
	if self.contentsName &lt;&gt; null then
		tmpStr := self.contentsName;
		txt := txt &amp; app.getErrorString(Contents_statuses) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	if self.imexMap &lt;&gt; null then
		tmpStr := self.imexMap.imexStatusString;
		txt := txt &amp; app.getErrorString(Imex_status) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	if self.getMyTerminal &lt;&gt; null then
		tmpStr := self.getMyTerminal.name;
		txt := txt &amp; app.getErrorString(Terminal) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	if self.imexMap.getBank &lt;&gt; null then
		tmpStr := self.imexMap.getBank.mailingName;
		txt := txt &amp; app.getErrorString(CM_Business_Unit) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	return txt;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
