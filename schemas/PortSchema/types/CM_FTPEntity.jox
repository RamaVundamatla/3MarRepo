    <JadeMethod name="getServerNameForConnect" id="5b4cbb3b-c1e3-4720-8795-077f67b68520">
        <source>getServerNameForConnect() : String;
/*

Purpose:			Return the server name to use in the FTP connect command.  This will return the
					receiver serverName stripped of any optional port number used.

Parameters:			None

Return Value:		FTP server name to connect to

Date		Who		Reason
15 Nov 2017	jlgkpd1	Initial creation - TFS 7462

*/

constants
	PortDelimiter	= ":";
	
vars
	pos				: Integer;
	
begin
	pos := self.serverName.pos(PortDelimiter, 1);
	if pos = 0 then
		return self.serverName;
	else
		return self.serverName[1:pos-1];
	endif;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
