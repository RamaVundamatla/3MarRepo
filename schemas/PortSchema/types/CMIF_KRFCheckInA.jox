<Class name="CMIF_KRFCheckInA" id="b745b79c-25dd-462e-993b-6c288509c847">
    <superclass name="CMIF_KRFWSProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="allEquipment" id="ee0a9dfb-d391-476e-8f6e-9e207498c690">
        <memberTypeInverse/>
        <type name="CMIF_KRFCheckInEquipmentArray"/>
    </ImplicitInverseRef>
    <PrimAttribute name="bookingID" id="742cba96-e0fd-44a0-8533-1c6c096fdfcc">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="checkInLocation" id="53fffbc3-2272-4f37-b122-e5773bd6131e">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="commodityCode" id="e166e8fb-a9b6-4315-a1d5-185052a6fab3">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="customerReference" id="0f6c418d-34b4-4dfa-82dd-5dcdbf50fdfb">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="freightPayerCode" id="6ddbaa56-6f0b-4f4d-9097-4dc0bc104fdd">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="railDestination" id="4054cf46-8b04-4aaf-bb28-22aa62ca987f">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="senderCode" id="e5c12a3b-1a5e-4779-b843-b9049215a66f">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="timestamp" id="008213a0-796b-4892-9203-720b62f5516c">
        <embedded/>
        <type name="TimeStamp"/>
    </PrimAttribute>
    <JadeMethod name="copyToRealWSObject" id="acea86c1-31d3-468d-8972-2c7d929bb1ec">
        <source>copyToRealWSObject(_realRequest: KRF_CheckInA input;
				   _createdObjects : ObjectSet input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Feb 2019	jlgsl4	TFS 40360 - KiwiRail EDI message

*/

vars
	equipment : CMIF_KRFCheckInEquipment;
	realEquipment : KRF_CheckInEquipment;
	
begin
	inheritMethod(_realRequest, _createdObjects);
	
	_realRequest.bookingID := self.bookingID;
	_realRequest.checkInLocation := self.checkInLocation;
	_realRequest.commodityCode := self.commodityCode;
	_realRequest.customerReference := self.customerReference;
	_realRequest.freightPayerCode := self.freightPayerCode;
	_realRequest.railDestination := self.railDestination;
	_realRequest.senderCode := self.senderCode;
	_realRequest.timestamp := self.timestamp;

	// manual population of equipment required
	foreach equipment in self.allEquipment do
		create realEquipment transient;
		_createdObjects.add(realEquipment);
		equipment.copyToRealWSObject(realEquipment, _createdObjects);
		_realRequest.equipment.add(realEquipment);
	endforeach;

epilog

end;</source>
        <Parameter name="_realRequest" type="KRF_CheckInA" usage="input"/>
        <Parameter name="_createdObjects" type="ObjectSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="populateBookingID" id="c07c4a85-8fbc-4821-8d54-a0652a62fe42">
        <updating/>
        <source>populateBookingID(_container : CM_Container) updating;
/*

Purpose:	Set message BookingID - assumption is the container's assigned to
			one booking only, eg. 'Allow Cargo On Multiple Releases' is 'No'

Parameters:			

Return Value:		

Date		Who		Reason
06 Mar 2019	jlgsl4	TFS 40360 - NXL - KiwiRail EDI message
*/

vars
	bulkRelease : CM_BulkRelease;
begin
	if _container.allBulkReleasesAssigned.size &lt;&gt; 0 then
		self.bookingID := _container.allBulkReleasesAssigned.first.code;
	endif;
epilog

end;</source>
        <Parameter name="_container" type="CM_Container"/>
    </JadeMethod>
    <JadeMethod name="setFromWSDef" id="6c1578ee-ba4f-4da6-9a52-2d2b03d8dc3e">
        <updating/>
        <source>setFromWSDef(_wsDefinition : CM_KiwiRailCheckInWSDef) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Mar 2019	jlgsl4	TFS 40360 - NXL - KiwiRail EDI message
*/

vars
	timeStamp : TimeStamp;
begin
	self.railDestination := _wsDefinition.railDestination;
	self.freightPayerCode := _wsDefinition.freightPayerCode;
	self.senderCode := _wsDefinition.senderCode;
	self.timestamp := timeStamp.localToUTCTime(); // current time GMT/UTC
epilog

end;</source>
        <Parameter name="_wsDefinition" type="CM_KiwiRailCheckInWSDef"/>
    </JadeMethod>
</Class>
