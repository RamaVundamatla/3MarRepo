    <JadeMethod name="shortFormatJMT" id="6e5f08e2-8367-492e-b82e-22ba2bc4ddcd">
        <source>shortFormatJMT() : String;
// ---------------------------------------------------------------------------
// Created:     25 February 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// Extra info: if format changes then you may have to change primitiveType String.convertToDate();
vars
//	yearStr		: String;
//	sep			: String;
//	str			: String;

begin

/*
	sep := app.currentLocaleInfo.dateInfo.separator;
	
