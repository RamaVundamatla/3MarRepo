    <JadeMethod name="populateCmbRakePos" id="eae192e3-b16d-40b0-910f-c6cb5e118eb5">
        <source>populateCmbRakePos();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 August 2010	cnwndl1	Initial creation	Par 25215

*/

vars
	railLine : CM_RailLine;
	pos : Integer;
	index : Integer;
	displayId : String;
begin

	self.cmbRakePos.clear();
	
	railLine := self.myMobileGenericAgent.myCurrentRailLine;
	
	if railLine &lt;&gt; null then
		displayId := railLine.getDisplayDetails(false);
		foreach pos in 1 to railLine.maximumWagons do
			index := self.cmbRakePos.addItem( displayId &amp; " " &amp; pos.padLeadingWith('0',2) );
			self.cmbRakePos.itemData[index] := pos;
		endforeach;
		if self.cmbRakePos.listCount &gt; 0 then
			if self.myMobileGenericAgent.forward then
				self.cmbRakePos.listIndex := 1;
			else
				self.cmbRakePos.listIndex := self.cmbRakePos.listCount;
			endif;
		endif;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateCmbWagon" id="8359620d-d6e8-4c60-83da-afddbe27aa58">
        <updating/>
        <source>populateCmbWagon()updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 August 2010	cnwndl1	Initial creation	Par 25215

*/

vars

	railLine : CM_RailLine;
	wagon : CM_Wagon;
	index : Integer;
	rakePos : Integer;

begin

	self.cmbWagon.clear();
	
	railLine := self.myMobileGenericAgent.myCurrentRailLine;
	
	if railLine &lt;&gt; null then
		foreach wagon in railLine.allWagonsById do
			index := self.cmbWagon.addItem(wagon.id);
			self.cmbWagon.itemObject[index] := wagon;
			if not self.checkWagonIsForTrain(wagon,false) then
				self.cmbWagon.itemEnabled[index] := false;
			endif;
		endforeach;
		if cmbRakePos.listIndex &gt; 0 then
			rakePos := self.cmbRakePos.itemData[self.cmbRakePos.listIndex];
		endif;
		if rakePos &gt; 0 and railLine.allWagons.size &gt;= rakePos then
			wagon := railLine.allWagons[rakePos];
		else
			wagon := null;
		endif;
		if wagon &lt;&gt; null then
			self.cmbWagon.listIndex := self.cmbWagon.findObject(wagon);
		else
			self.cmbWagon.listIndex := -1;
		endif;
	endif;
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setColours" id="0844b030-e906-4115-9eb8-5c426227ca6b">
        <updating/>
        <source>setColours() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 August 2010	cnwndl1	Initial creation	Par 25215

*/

vars

	screenConfig	: CM_RTScreenConfig;
	
begin

	if myTerminal.myRTVehicleConfig &lt;&gt; null then
		screenConfig :=	myTerminal.myRTVehicleConfig.myNightScreenConfig;
	endif;
	
	if screenConfig &lt;&gt; null then	
		colourUnConfirmed := screenConfig.tableBackColour;
	else
		colourUnConfirmed := LightBlue;
	endif;
	
	if myTerminal.myRTVehicleConfig &lt;&gt; null then
		screenConfig :=	myTerminal.myRTVehicleConfig.myDayScreenConfig;
	endif;
	if screenConfig &lt;&gt; null then
		colourConfirmed := screenConfig.tableBackColour;
	else
		colourConfirmed := LightGreen;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setConfirmWagonBtn" id="6878c4a6-db8f-4cd9-a5f1-4c7f2dc90147">
        <updating/>
        <source>setConfirmWagonBtn() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 August 2010	cnwndl1	Initial creation	Par 25215

*/

vars

	confirmed : Boolean;
	wagon : CM_Wagon;

begin
	
	wagon := cmbWagon.listObject.CM_Wagon;
	
	if wagon &lt;&gt; null then
		confirmed := false; // default value.
		if self.checkWagonIsForTrain( wagon, false ) then
			confirmed :=  self.isWagonConfirmed(wagon);
		else
			btnConfirmWagon.enabled := false;
			return;
		endif;
		if confirmed then
			self.hideAllPosButtons( wagon );
		endif;
		btnConfirmWagon.enabled := not confirmed;
		
	else
		btnConfirmWagon.enabled := false;
		
	endif;
	
epilog

end;</source>
    </JadeMethod>
