    </JadeMethod>
    <JadeMethod name="setKPIForDelays" id="71c67f45-130c-4a49-9250-cd58a5df6c27">
        <updating/>
        <source>setKPIForDelays(_hoursDelay : Real; _delays : CM_DelayByStartDTDict) updating;
// ---------------------------------------------------------------------------
// Created:		03 January 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	self.allDelays.clear;
	_delays.copy(self.allDelays);
	self.hoursDelay := _hoursDelay;
	self.hoursNet := (self.hoursGross - self.hoursDelay);
	//04 Apr 2012	NDL	Par 29369
	self.setHoursDown();
end;</source>
        <Parameter name="_hoursDelay" type="Real"/>
        <Parameter name="_delays" type="CM_DelayByStartDTDict"/>
    </JadeMethod>
    <JadeMethod name="zGetTotalByAttribute" id="e4c94bec-dd5b-4e7d-85c5-06b7ec0e311c">
        <source>zGetTotalByAttribute(_attr : Attribute; _coll :MemberKeyDictionary) : Integer;
// ---------------------------------------------------------------------------
// Created:     08 June 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 08/08/2011		cnwcs5			CCMS 1033 - RORO KPI
// 31 Mar 2014	cnwrs1	Par 33805 send max integer on invalid precision
// ---------------------------------------------------------------------------
vars
	kpiDetail 						: CM_KPIVoyageMoveDtl; 
	result							: Decimal [12,2];
	keyImex, keyLen, keyCont 		: Integer;
	isNumTI, isNumTEU, isNumReefer, 
	isNumOD, isNumTwin, isNumSingle,
	isArea, isLM, isQty, isVolume, 
	isWeight						:Boolean;
	coll							:MemberKeyDictionary;
	obj								:Object;
	int : Integer;
	precisionError : Boolean;
begin
	on Exception do app.handlePrecisionError(exception, precisionError);
	// don't use &lt;class&gt;::&lt;property&gt; in loop as it generates it's own code so not efficient
	isNumTI 	:= (_attr = CM_KPIVoyageMoveDtl::numTIs);
	isNumReefer := (_attr = CM_KPIVoyageMoveDtl::numReefer);

	isNumTEU	:= (_attr = CM_KPIVoyageMoveDtl_Container::numTEU);
	isNumOD		:= (_attr = CM_KPIVoyageMoveDtl_Container::numOverdimension);
	isNumTwin	:= (_attr = CM_KPIVoyageMoveDtl_Container::numLiftTwin);
	isNumSingle := (_attr = CM_KPIVoyageMoveDtl_Container::numLiftSingle);
	
	isArea		:= (_attr = CM_KPIVoyageMoveDtl_GC::area);
	isLM		:= (_attr = CM_KPIVoyageMoveDtl_GC::linearMetres);
	isQty 		:= (_attr = CM_KPIVoyageMoveDtl_GC::quantity);
	isVolume 	:= (_attr = CM_KPIVoyageMoveDtl_GC::volume);
	isWeight 	:= (_attr = CM_KPIVoyageMoveDtl_GC::totalWeight);
	
	if isNumTEU or isNumOD or isNumTwin or isNumSingle then
		// no need to read through them all
		coll := self.allKPIVoyageMoveDtls_Container;
	elseif isArea or isLM or isQty or isVolume or isWeight then
		// only general cargo have these things
		coll := self.allKPIVoyageMoveDtls_GC;
	else
		coll := _coll;
	endif;
	
	foreach obj in coll discreteLock do
		kpiDetail := obj.CM_KPIVoyageMoveDtl;
		
		if isNumTI then
			result := result +  kpiDetail.numTIs;
		elseif isNumReefer then
			result := result +  kpiDetail.numReefer;
		elseif isNumTEU then
			result := result +  kpiDetail.CM_KPIVoyageMoveDtl_Container.numTEU;
		elseif isNumOD then
			result := result +  kpiDetail.CM_KPIVoyageMoveDtl_Container.numOverdimension;
		elseif isNumTwin then
			result := result +  kpiDetail.CM_KPIVoyageMoveDtl_Container.numLiftTwin;
		elseif isNumSingle then
			result := result +  kpiDetail.CM_KPIVoyageMoveDtl_Container.numLiftSingle;
		elseif isArea then
			result := result +  kpiDetail.CM_KPIVoyageMoveDtl_GC.area;
		elseif isLM then
			result := result +  kpiDetail.CM_KPIVoyageMoveDtl_GC.linearMetres;
		elseif isQty then
			result := result +  kpiDetail.CM_KPIVoyageMoveDtl_GC.quantity;
		elseif isVolume then
			result := result +  kpiDetail.CM_KPIVoyageMoveDtl_GC.volume;
		elseif isWeight then
			result := result +  kpiDetail.CM_KPIVoyageMoveDtl_GC.totalWeight;
		endif;
	endforeach;
	
	int := result.rounded;
	if precisionError then
		int := 2147483647;
	endif;
	return int;
epilog

end;</source>
        <Parameter name="_attr" type="Attribute"/>
        <Parameter name="_coll" type="MemberKeyDictionary"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="zGetTotalByMoveType" id="b55c1047-0c80-4375-9d25-b9039fca0160">
        <source>zGetTotalByMoveType(_moveType : Integer; _attr : Attribute; _coll :MemberKeyDictionary) : Integer;
// ---------------------------------------------------------------------------
// Created:     08 June 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 10/08/2011		cnwcs5			CCMS MES 1033 - RORO KPI
// ---------------------------------------------------------------------------

vars
	isNumTI, isNumReefer, isNumTEU, isNumOD,
	isArea, isLM, isQty, isVolume, 
	isWeight	:Boolean;
	kpiDetail 	: CM_KPIVoyageMoveDtl; 
	iter 		: Iterator;
	coll 		: Dictionary;
	result		: Decimal [12,2]; 
	keyMoveType : Integer;
begin
	// don't use &lt;class&gt;::&lt;property&gt; in loop as it generates it's own code so not efficient
	isNumTI 	:= (_attr = CM_KPIVoyageMoveDtl::numTIs);
	isNumReefer := (_attr = CM_KPIVoyageMoveDtl::numReefer);
	isNumTEU	:= (_attr = CM_KPIVoyageMoveDtl_Container::numTEU);
	isNumOD		:= (_attr = CM_KPIVoyageMoveDtl_Container::numOverdimension);
	
	isArea		:= (_attr = CM_KPIVoyageMoveDtl_GC::area);
	isLM		:= (_attr = CM_KPIVoyageMoveDtl_GC::linearMetres);
	isQty 		:= (_attr = CM_KPIVoyageMoveDtl_GC::quantity);
	isVolume 	:= (_attr = CM_KPIVoyageMoveDtl_GC::volume);
	isWeight 	:= (_attr = CM_KPIVoyageMoveDtl_GC::totalWeight);

	
	if isNumTEU or isNumOD then
		// only containers can be OD or have TEU so don't bother reading through the general cargo items
		coll := self.allKPIVoyageMoveDtls_Container;
	elseif isArea or isLM or isQty or isVolume or isWeight then
		// only general cargo have these things
		coll := self.allKPIVoyageMoveDtls_GC;
	else
		coll := _coll;
	endif;
	
	iter 	:= coll.createIterator();
	
	coll.startKeyGeq(_moveType, null, null, null, iter);	// lucky both coll classes have same number of keys
	
	while iter.next(kpiDetail) do
		keyMoveType := iter.getCurrentKey (1).Integer;

		if keyMoveType &lt;&gt; _moveType then
			break;
		endif;
		
		if isNumTI then
			result := result +  kpiDetail.numTIs;
		elseif isNumTEU then
			result := result +  kpiDetail.CM_KPIVoyageMoveDtl_Container.numTEU;
		elseif isNumReefer then
			result := result +  kpiDetail.numReefer;
		elseif isNumOD then
			result := result +  kpiDetail.CM_KPIVoyageMoveDtl_Container.numOverdimension;
		elseif isArea then
			result := result +  kpiDetail.CM_KPIVoyageMoveDtl_GC.area;
		elseif isLM then
			result := result +  kpiDetail.CM_KPIVoyageMoveDtl_GC.linearMetres;
		elseif isQty then
			result := result +  kpiDetail.CM_KPIVoyageMoveDtl_GC.quantity;
		elseif isVolume then
			result := result +  kpiDetail.CM_KPIVoyageMoveDtl_GC.volume;
		elseif isWeight then
			result := result +  kpiDetail.CM_KPIVoyageMoveDtl_GC.totalWeight;
		endif;
	endwhile;
	
	return result.rounded;
epilog
	delete iter;
end;</source>
        <Parameter name="_moveType" type="Integer"/>
        <Parameter name="_attr" type="Attribute"/>
        <Parameter name="_coll" type="MemberKeyDictionary"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="zGetTotalByMoveTypeCargoType" id="3d96985b-d4c7-4533-b647-9e0025a08692">
        <source>zGetTotalByMoveTypeCargoType(_moveType : Integer; _cargoType :CM_CargoType; _attr : Attribute) : Integer;
/*
Date		Who		Reason
09 August 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/
vars
	isNumTI, isNumReefer,
	isArea, isLM, isQty, isVolume, 
	isWeight	: Boolean;
	kpiDetail 	: CM_KPIVoyageMoveDtl_GC; 
	iter 		: Iterator;
	coll 		: Dictionary;
	result		: Decimal [12, 2];
	keyMoveType	: Integer;
	keyCargoType	:CM_CargoType;
	keyCargoSubType	:CM_Product;
	keyTranship	:Boolean;
begin
	if _cargoType.id = TI_CargoType_Container then
		return self.zGetTotalByMoveType (_moveType, _attr, self.allKPIVoyageMoveDtls_Container);
	endif;
	
	// don't use &lt;class&gt;::&lt;property&gt; in loop as it generates it's own code so not efficient
	isNumTI 	:= (_attr = CM_KPIVoyageMoveDtl::numTIs);
	isNumReefer := (_attr = CM_KPIVoyageMoveDtl::numReefer);
	
	isArea		:= (_attr = CM_KPIVoyageMoveDtl_GC::area);
	isLM		:= (_attr = CM_KPIVoyageMoveDtl_GC::linearMetres);
	isQty 		:= (_attr = CM_KPIVoyageMoveDtl_GC::quantity);
	isVolume 	:= (_attr = CM_KPIVoyageMoveDtl_GC::volume);
	isWeight 	:= (_attr = CM_KPIVoyageMoveDtl_GC::totalWeight);
	
	coll := self.allKPIVoyageMoveDtls_GC;
	
	iter := coll.createIterator();
	
	coll.startKeyGeq(_moveType, _cargoType, null, null, iter);
	
	while iter.next(kpiDetail) do

		coll.getIteratorKeys(keyMoveType, keyCargoType, keyCargoSubType, keyTranship, iter);
		
		if keyMoveType &lt;&gt; _moveType then
			break;
		endif;
		
		if keyCargoType &lt;&gt; _cargoType then
			break;
		endif;
		
		if isNumTI then
			result := result +  kpiDetail.numTIs;
		elseif isNumReefer then
			result := result +  kpiDetail.numReefer;
		elseif isArea then
			result := result +  kpiDetail.CM_KPIVoyageMoveDtl_GC.area;
		elseif isLM then
			result := result +  kpiDetail.CM_KPIVoyageMoveDtl_GC.linearMetres;
		elseif isQty then
			result := result +  kpiDetail.CM_KPIVoyageMoveDtl_GC.quantity;
		elseif isVolume then
			result := result +  kpiDetail.CM_KPIVoyageMoveDtl_GC.volume;
		elseif isWeight then
			result := result +  kpiDetail.CM_KPIVoyageMoveDtl_GC.totalWeight;
		endif;
	endwhile;
	// we use a decimal to accumulate the values but these methods seem to return Integers
	return result.rounded;
epilog
	delete iter;
end;</source>
        <Parameter name="_moveType" type="Integer"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_attr" type="Attribute"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="zGetTotalByMoveTypeLen" id="6b26a4d5-527d-4d07-b327-d9688a0f9c5b">
        <source>zGetTotalByMoveTypeLen(_moveType : Integer; _len : Integer; _attr : Attribute) : Integer;
// ---------------------------------------------------------------------------
// Created:     08 June 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 09/08/2011		cnwcs5			CCMS MES 1033 - RORO KPI Changed to use allKPIVoyageMoveDtls_Container
// ---------------------------------------------------------------------------

vars
	isNumTI, isNumReefer, isNumTEU, isNumOD	:Boolean;
	kpiDetail 	: CM_KPIVoyageMoveDtl; // PAR 25001 CM_KPIDtlEntity;
	iter 		: Iterator;
	coll 		: Dictionary;
	result		:Decimal [12, 2];
	keyMoveType, keyLen, keyCont : Integer;
	keyTrans 	: Boolean; //cnwas3 par 24309
begin
	// don't use &lt;class&gt;::&lt;property&gt; in loop as it generates it's own code so not efficient
	isNumTI 	:= (_attr = CM_KPIVoyageMoveDtl::numTIs);
	isNumReefer := (_attr = CM_KPIVoyageMoveDtl::numReefer);
	isNumTEU	:= (_attr = CM_KPIVoyageMoveDtl_Container::numTEU);
	isNumOD		:= (_attr = CM_KPIVoyageMoveDtl_Container::numOverdimension);
	
	coll := self.allKPIVoyageMoveDtls_Container;
	
	iter 	:= coll.createIterator();
	
	coll.startKeyGeq(_moveType, _len, null, null, iter);
	
	while iter.next(kpiDetail) do

		coll.getIteratorKeys(keyMoveType, keyLen, keyCont, keyTrans, iter);
		
		if keyMoveType &lt;&gt; _moveType then
			break;
		endif;
		
		if keyLen &lt;&gt; _len then
			break;
		endif;
		
		if isNumTI then
			result := result +  kpiDetail.numTIs;
		elseif isNumTEU then
			result := result +  kpiDetail.CM_KPIVoyageMoveDtl_Container.numTEU;
		elseif isNumReefer then
			result := result +  kpiDetail.numReefer;
		elseif isNumOD then
			result := result +  kpiDetail.CM_KPIVoyageMoveDtl_Container.numOverdimension;
		endif;
	endwhile;
	
	return result.rounded;
epilog
	delete iter;
end;</source>
        <Parameter name="_moveType" type="Integer"/>
        <Parameter name="_len" type="Integer"/>
        <Parameter name="_attr" type="Attribute"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="zGetTotalByMoveTypeLenTS" id="4ab39cef-4c38-477f-af91-4e4b14ab2307">
        <source>zGetTotalByMoveTypeLenTS(_moveType : Integer; _len : Integer; _ts :Boolean; _attr : Attribute) : Integer;
/*
Date		Who		Reason
09 August 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/
vars
	isNumTI, isNumReefer, isNumTEU, isNumOD	:Boolean;
	kpiDetail 	: CM_KPIVoyageMoveDtl_Container; 
	iter 		: Iterator;
	coll 		: Dictionary;
	result		: Decimal [12,2]; 
	keyMoveType, keyLength, keyContents : Integer;
	keyTranship	: Boolean; 
begin
	// don't use &lt;class&gt;::&lt;property&gt; in loop as it generates it's own code so not efficient
	isNumTI 	:= (_attr = CM_KPIVoyageMoveDtl::numTIs);
	isNumReefer := (_attr = CM_KPIVoyageMoveDtl::numReefer);
	isNumTEU	:= (_attr = CM_KPIVoyageMoveDtl_Container::numTEU);
	isNumOD		:= (_attr = CM_KPIVoyageMoveDtl_Container::numOverdimension);
	
	coll := self.allKPIVoyageMoveDtls_Container;
	iter := coll.createIterator();
	
	coll.startKeyGeq(_moveType, _len, null, null, iter);
	
	while iter.next(kpiDetail) do

		coll.getIteratorKeys(keyMoveType, keyLength, keyContents, keyTranship, iter);
		
		if keyMoveType &lt;&gt; _moveType then
			break;
		endif;
		
		if keyLength &lt;&gt; _len then
			break;
		endif;
		
		if keyTranship &lt;&gt; _ts then
			continue;
		endif;
		
		if isNumTI then
			result := result +  kpiDetail.numTIs;
		elseif isNumTEU then
			result := result +  kpiDetail.numTEU;
		elseif isNumReefer then
			result := result +  kpiDetail.numReefer;
		elseif isNumOD then
			result := result +  kpiDetail.numOverdimension;
		endif;
	endwhile;
	// we use a decimal to accumulate the values but these methods seem to return Integers
	return result.rounded();
epilog
	delete iter;
end;</source>
        <Parameter name="_moveType" type="Integer"/>
        <Parameter name="_len" type="Integer"/>
        <Parameter name="_ts" type="Boolean"/>
        <Parameter name="_attr" type="Attribute"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="zzGenerateMethodOutput1" id="82a42522-8d46-44c4-973d-2e3f51843346">
        <source>zzGenerateMethodOutput1(_methodName : String; _keyMoveType : String; 
			_keyLen : Integer; _keyTS, _keyContents, _fieldName : String) protected;
/* ---------------------------------------------------------------------------
Created:     06 July 2010 by cnwrs2

Purpose:     
        
Change Date	Who		Reason
09/08/2011	cnwcs5	CCMS MES 1033 - RORO KPI Changed to use allKPIVoyageMoveDtls_Container
------------------------------------------------------------------------------*/
vars

begin

	if _methodName.length &gt; 30 then
		write '###################################  ' &amp; _methodName.length.String;
	endif;
	
	

write _methodName &amp; '() : Integer;

// This method is auto-generated.  Refer CM_KPIVoyageEntity::zzGenerateMethods

vars
	kpiDetail : CM_KPIDtlEntity;
begin
	kpiDetail := self.allKPIVoyageMoveDtls_Container[' &amp; _keyMoveType &amp; ', ' &amp; _keyLen.String &amp; ', ' &amp; _keyContents &amp; ', ' &amp; _keyTS &amp; '];
	
	if kpiDetail &lt;&gt; null then
		return kpiDetail.CM_KPIVoyageMoveDtls_Container.' &amp; _fieldName &amp; ';
	endif;
	
	return 0;
epilog

end;
';
	

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_methodName" type="String"/>
        <Parameter name="_keyMoveType" type="String"/>
        <Parameter name="_keyLen" type="Integer"/>
        <Parameter name="_keyTS" type="String"/>
        <Parameter name="_keyContents" type="String"/>
        <Parameter name="_fieldName" type="String"/>
    </JadeMethod>
    <JadeMethod name="zzGenerateMethodOutputLen" id="3ee42011-d164-499c-a9b3-5bb23fb05e7f">
        <source>zzGenerateMethodOutputLen(_methodName : String; _keyMoveType : String; 
			_keyLen : Integer; _fieldName : String) protected;
/* ---------------------------------------------------------------------------
Created:     06 July 2010 by cnwrs2

Purpose:     
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	if _methodName.length &gt; 30 then
		write '###################################  ' &amp; _methodName.length.String;
	endif;	

write _methodName &amp; '() : Integer;

// This method is auto-generated.  Refer CM_KPIVoyageEntity::zzGenerateMethods

vars
	
begin
	return self.zGetTotalByMoveTypeLen(' &amp; _keyMoveType &amp; ', ' &amp; _keyLen.String &amp; ', CM_KPIVoyageMoveDtl::' &amp; _fieldName &amp; ');
epilog

end;
';

	

epilog

end;</source>
        <access>protected</access>
