    <JadeMethod name="addDecksColumn" id="2ae328d5-f471-466d-9ea0-dc37c7acc8b9">
        <source>addDecksColumn(_column : Integer);
/*
Date		    Who			Reason
19 September 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

