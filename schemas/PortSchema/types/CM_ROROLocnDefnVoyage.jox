    <JadeMethod name="pxyCreateUpdateProxy" id="e9607af9-ed9a-4701-b9b8-00869b7f8f7c">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

	pxyMe : SelfType;
	pxyVoyage : CM_ROROVoyageStructure;
	completedOK		: Boolean;

begin
	pxyMe :=  inheritMethod();

	pxyVoyage := self.myVoyageStructure.pxyGetProxyObject();
	pxyMe.myVoyageStructure := pxyVoyage;
	
	completedOK := true;			
	return pxyMe;
epilog
	if not completedOK then			
		delete pxyMe;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="restoreRemarksFromVessel" id="b1cac316-3fa8-451c-a612-c7fc8bcc5904">
        <updating/>
        <source>restoreRemarksFromVessel() updating;
/*
Purpose:			
Date		Who		Reason
20 August 2012	cnwab1	Initial creation
*/

vars
	ves : CM_Vessel;
	vesLocn : CM_ROROLocnDefnVessel;
begin
	ves := self.myVoyageStructure.myVoyage.getMyVessel();
	
	if ves = null then
		return;
	endif;
	
	vesLocn := ves.getLocnDefnByCode(self.code);
	
	if vesLocn = null then
		return;
	endif;

	self.remarks := vesLocn.remarks;
	self.myLayout.setRemarks(vesLocn.myLayout.remarks);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setDeckOnSlots" id="798b8d2f-7039-416a-8043-17f5d9f6e485">
        <source>setDeckOnSlots();
/*
Purpose:			
Date		Who		Reason
24 February 2012	cnwab1	Initial creation
*/

vars
	slotDefn : CM_ROROSlotDefn;
begin
	foreach slotDefn in self.allROROSlotDefnByOrdinal discreteLock do
		slotDefn.CM_ROROSlotDefnVoyage.mySlotController.setFromROROSlotDefn();
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="18289875-ba5e-467c-9151-dc2fb9ebfe14">
        <updating/>
        <source>setForCreate(_proxyDeckItem: SelfType; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars
	theCargoLayer : CM_DeckLayerLayout;
begin

	self.myVoyageStructure := _proxyDeckItem.myVoyageStructure;
	inheritMethod(_proxyDeckItem, _passport);
	
	theCargoLayer := self.myDeck.myDeckLayout.getCargoLayer();
	
	if theCargoLayer &lt;&gt; null then
		if self.myLayout.isOnLayerCargo // PAR 30264
		or self.myLayout.isOnLayerOOTL then // PAR 30265
			theCargoLayer.hideContainerPositionsUnderGA(self.myLayout); // PAR 29079
			theCargoLayer.hideContainerPositionsUnderGC(self.myLayout); // PAR 29079
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_proxyDeckItem" type="SelfType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMyVoyageStructure" id="c7c09deb-b1e3-488a-9844-f1369e788f1d">
        <updating/>
        <source>setMyVoyageStructure(_value : CM_ROROVoyageStructure ) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

begin
	self.myVoyageStructure:=_value;
epilog

end;</source>
        <Parameter name="_value" type="CM_ROROVoyageStructure"/>
