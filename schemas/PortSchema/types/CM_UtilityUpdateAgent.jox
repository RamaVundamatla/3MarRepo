    <JadeMethod name="utlUpdateToDoTaskDesc" id="c54d70f7-3112-49de-8265-f313c6f01b3d">
        <source>utlUpdateToDoTaskDesc(_proxy:CM_ToDoTaskDesc; _passport : CM_Passport input);

// 14/11/2011	cnwcs5	par 28574
vars
	todoTaskDesc		:CM_ToDoTaskDesc;
	expectedEdition		:Integer;
	doQueryPropertyChg	:Boolean;	
begin

	self.initialiseActivity();

	_proxy.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_proxy.pxyGetRealObjectAndEdition(todoTaskDesc, expectedEdition);
	
	if todoTaskDesc = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_ToDoTaskDesc.name, null, null);
		return;
	endif;

	app.myValUA.valToDoTaskDesc(todoTaskDesc, _proxy);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;


	app.setContinueCMExceptions(false);

	exclusiveLock(todoTaskDesc);

	if _passport.noErrors and todoTaskDesc.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'ToDoTaskDesc', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(todoTaskDesc, true);
	endif;
	
	doQueryPropertyChg := todoTaskDesc.shortDescription &lt;&gt; _proxy.shortDescription;
	
	if _passport.noErrors then
		todoTaskDesc.setForUpdate(_proxy);
	endif;
	
	// update selector query properties
	if doQueryPropertyChg and _passport.noErrors then
		app.myRoot.todoTaskQueryPropertyUpdate (todoTaskDesc);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(todoTaskDesc, false);
	endif;

epilog
	
end;</source>
        <Parameter name="_proxy" type="CM_ToDoTaskDesc"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
