    <JadeMethod name="cleanupPxyReferences" id="9e34ea44-5185-4539-ac85-be0c290ed717">
        <updating/>
        <source>cleanupPxyReferences() updating;
/*
Purpose:			
Date		Who		Reason
21 April 2011	cnwab1	Initial creation
*/

vars
	anItem : CM_DeckItem;
	invalid : Boolean;
begin
	self.raiseExceptionIfNotTransient(method);
	on Exception do app.handleDeletedObject(exception, anItem, invalid);
	
	anItem := self.myDeckItem;
	
	if anItem &lt;&gt; null then
	if anItem.isTransient then
		delete anItem;
	endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="cloneMySelf" id="79f26982-736b-4385-ac00-98ba043dc125">
        <source>cloneMySelf(_newDeckItem : CM_DeckItem; _newLayer : CM_DeckLayerLayout; _copy : Boolean) : CM_DeckItemLayout;
/*
Purpose:			
Date		Who		Reason
29 April 2011	cnwab1	Initial creation
*/

vars

	newMe : SelfType;
begin
	newMe := self.cloneSelf(_copy);

	newMe.myDeckItem := _newDeckItem;
	newMe.myDeckLayer := _newLayer;
	
	
	
	return newMe;

epilog

end;</source>
        <Parameter name="_newDeckItem" type="CM_DeckItem"/>
        <Parameter name="_newLayer" type="CM_DeckLayerLayout"/>
        <Parameter name="_copy" type="Boolean"/>
        <ReturnType type="CM_DeckItemLayout"/>
    </JadeMethod>
    <JadeMethod name="convertMetresToPoints" id="8a97aaba-1ae4-4696-ba10-f98ee7ea9d83">
        <source>convertMetresToPoints( _metrePoints : DecimalArray; _newPoints : PointArray input);
/*
Purpose:	CCMS 1009 28479		
Date				Who			Reason
OCTOBER 2011		CNWAB1		Initial creation
*/


vars
	pointCM,
	pointX,
	pointY : Decimal[12,2];
	aPoint : Point;
	xP, yP : Integer;
	newPoint : Boolean;
begin
	if _metrePoints = null then
		return;
	endif;
		
	_newPoints.clear;
	newPoint := true; // PAR 29905. a zero decimal is actually stored as a null in a decimal array. We were using a null to switch

	// ### CONVERT
	foreach pointCM in _metrePoints discreteLock do
		 // PAR 29905 if 	pointX = null then
		if newPoint then // PAR 29905
			pointX:= pointCM;
			newPoint := false;
			continue;
		else
			pointY:=pointCM;
		endif;
		
		//1 m = 10 pixel
		xP := (pointX * ROROStructurePixelsPerMetre).Integer;
		xP := xP + ROROStructureRearLine;
		yP := (pointY * ROROStructurePixelsPerMetre).Integer;
		yP := yP + ROROStructureCentreLine;
		
		aPoint.setX(xP);
		aPoint.setY(yP);
		
		
		_newPoints.add(aPoint);
		
		newPoint := true; // PAR 29905
		 // PAR 29905 pointX:=null;
		 // PAR 29905 pointY:=null;
	endforeach;
epilog

end;</source>
        <Parameter name="_metrePoints" type="DecimalArray"/>
        <Parameter name="_newPoints" type="PointArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doCopyPxyItem" id="6620a10f-f5d8-47fc-b6b0-8d5e3a94f404">
        <source>doCopyPxyItem(_layer : CM_DeckLayerLayout; _offset : Integer);
// ---------------------------------------------------------------------------
// Created:     24 March 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------
// assume SELF is a proxy. Assume that passed in proxy has been closed.
// ---------------------------------------------------------------------------

vars
	xyPoint : Point;
	x1, y1 : Integer;
	newPoints : PointArray;
	newPxyMe :  CM_DeckItemLayout;
	pxyLane : CM_ROROLaneDefn;
	pxyLocn : CM_ROROLocnDefn;
begin
	self.raiseExceptionIfNotTransient(method);
	
	// PAR 27528 
	// ### LANE
	if self.myDeckItem &lt;&gt; null then
		if self.myDeckItem.isKindOf(CM_ROROLaneDefn) then
			pxyLane := self.myDeckItem.CM_ROROLaneDefn.cloneMySelf(_layer,true,true); // true = transient, true = new ordinal
			newPxyMe := pxyLane.myLayout; // ME is cloned in deck item clone
	
		// ### LOCATION
		elseif self.myDeckItem.isKindOf(CM_ROROLocnDefn) then
			pxyLocn := self.myDeckItem.CM_ROROLocnDefn.cloneMySelf(_layer,true,true); // true = transient, true = new ordinal
			newPxyMe := pxyLocn.myLayout; // ME is cloned in deck item clone
		else
			newPxyMe := self.cloneMySelf(self.myDeckItem.cloneSelf(true),_layer,true); // NOT USED
		endif;
	else
		newPxyMe := self.cloneMySelf(null,_layer,true);
	endif;
	

	create newPoints transient;
	foreach xyPoint in self.myPolygonPixels do
		x1 := xyPoint.x;
		y1 := xyPoint.y;
		
		x1 := x1 + _offset;
		y1 := y1 + _offset;
		
		xyPoint.setX(x1);
		xyPoint.setY(y1);
		
		newPoints.add(xyPoint);
	endforeach;
	
	newPxyMe.setPointsPolygon(newPoints);
	
	newPxyMe.label := self.label;

	// ### LANE
	if newPxyMe.myDeckItem &lt;&gt; null and newPxyMe.myDeckItem.isKindOf(CM_ROROLaneDefn) then
		newPxyMe.myDeckLayer.myDeckLayout.myDeck.setLabelsOnAllLanes();	
	// ### LOCATION
	elseif newPxyMe.myDeckItem &lt;&gt; null and newPxyMe.myDeckItem.isKindOf(CM_ROROLocnDefn) then
		newPxyMe.myDeckLayer.myDeckLayout.myDeck.setLabelsOnAllLocations();	
	endif;

	
epilog
	delete newPoints;
end;</source>
        <Parameter name="_layer" type="CM_DeckLayerLayout"/>
        <Parameter name="_offset" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doInsertNewPoint" id="7e7cf8e9-cd48-4610-9633-cc33614627f6">
        <updating/>
        <source>doInsertNewPoint(_thePoint : Point; _insertBefore : Boolean) updating; 
/*
Purpose:			
Date				Who			Reason
AUGUST 2011		CNWAB1		Initial creation
*/

vars
	newPoints : PointArray;
	myDeck : CM_Deck;
begin
	inheritMethod(_thePoint, _insertBefore);

	create newPoints transient;
	self.pointsPolygon.copy(newPoints);
	self.setPointsPolygon(newPoints);
	
	myDeck := self.getMyDeck();//	 PAR 28920
	if self.isTransient() 
	or (myDeck &lt;&gt; null and myDeck.isVoyageDeck()) then //	 PAR 28920
		self.causeEvent(EVENT_RORO_ITEM_UPDATE,true,null);	// from 28764 to refresh Deck Layer form after change
	endif;
epilog
	delete newPoints;
end;</source>
        <Parameter name="_thePoint" type="Point"/>
        <Parameter name="_insertBefore" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doRemovePoint" id="5b3a6101-21d0-4556-a5ee-18fcb8854d11">
