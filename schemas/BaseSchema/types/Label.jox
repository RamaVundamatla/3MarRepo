<GUIClass name="Label">
    <JadeMethod name="cnEcCenterOnParentHorizontal" id="e9bdecbe-957e-4cba-8c4d-8e8f078ac63c">
        <updating/>
        <source>cnEcCenterOnParentHorizontal() updating;
// --------------------------------------------------------------------------------
// Created:		05 April 2006 by cnwdad1
//
// Purpose:		Horizontally centers the receiver on its parent.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.parent &lt;&gt; null then 
		self.left	:=	(self.parent.width - self.width) / 2;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="cnEcCenterOnParentVertical" id="9901106d-a4f6-4f77-b128-e502ce765310">
        <updating/>
        <source>cnEcCenterOnParentVertical() updating;
// --------------------------------------------------------------------------------
// Created:		05 April 2006 by cnwdad1
//
// Purpose:		Vertically centers the receiver on its parent.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.parent &lt;&gt; null then 
		self.top	:=	(self.parent.height - self.height) / 2;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="cnEcDate" id="3c4d090f-d296-44a4-b133-97096ff7b015">
        <source>cnEcDate():Date;
// --------------------------------------------------------------------------------
// Created:		20 December 2000 by cnwdad1
//
// Purpose:		Returns the text value of the receiver's caption as a Date value.
//
// Parameters:	None
//
// Returns:		Date - the trimmed caption cast to a Date value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.caption.trimBlanks().Date;
end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="cnEcDecimal" id="e4d385bc-0b89-447e-9499-ecffb778b84a">
        <source>cnEcDecimal():Decimal;
// --------------------------------------------------------------------------------
// Created:		20 December 2000 by cnwdad1
//
// Purpose:		Returns the text value of the receiver's caption as a Decimal value.
//
// Parameters:	None
//
// Returns:		Decimal - the trimmed caption cast to a Decimal value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.caption.trimBlanks().cnEcRemoveSubstring(app.currentLocaleInfo.numericInfo.thousandSeparator).Decimal;
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="cnEcInteger" id="18c56f52-7e80-4d7b-87d9-bd4e20a4719a">
        <source>cnEcInteger():Integer;
// --------------------------------------------------------------------------------
// Created:		20 December 2000 by cnwdad1
//
// Purpose:		Returns the text value of the receiver's caption as a Integer value.
//
// Parameters:	None
//
// Returns:		Integer - the trimmed caption cast to a Integer value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.caption.trimBlanks().cnEcRemoveSubstring(app.currentLocaleInfo.numericInfo.thousandSeparator).Integer;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcReal" id="f6ce6fa8-cca6-4d6a-ac03-9870a138b118">
        <source>cnEcReal():Real;
// --------------------------------------------------------------------------------
// Created:		20 December 2000 by cnwdad1
//
// Purpose:		Returns the text value of the receiver's caption as a Real value.
//
// Parameters:	None
//
// Returns:		Real - the trimmed caption cast to a Real value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.caption.trimBlanks().Real;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="cnEcSet" id="803c9a7f-dbca-4ed4-a154-610b07007eaf">
        <updating/>
        <source>cnEcSet(pValue:String) updating;
// --------------------------------------------------------------------------------
// Created:		13 August 2002 by cnwdad1
//
// Purpose:		Updates the receiver's caption with the specified value.
//
// Parameters:	pValue - The string value to set the text to.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.caption &lt;&gt; pValue then
		self.caption	:=	pValue;
	endif;
end;</source>
        <Parameter name="pValue" type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcString" id="754154a7-4de3-46b0-99e8-cf070b9f37e0">
        <source>cnEcString():String;
// --------------------------------------------------------------------------------
// Created:		20 December 2000 by cnwdad1
//
// Purpose:		Returns the (trimmed) text value of the receiver's caption.
//
// Parameters:	None
//
// Returns:		String - the trimmed caption value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.caption.trimBlanks();
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcStripAmpersands" id="7b61e2c4-1d8d-4b0f-b6ce-186a32f9cb43">
        <updating/>
        <source>cnEcStripAmpersands() updating;
// --------------------------------------------------------------------------------
// Created:		15 August 2006 by cnwdad1
//
// Purpose:		To handle ampersands in the receiver (which is to be displayed in
//				the caption of a label or button) where the default action of
//				underlining the following character is not required.
//
//				Any ampersand followed by a space, or at the end of the string, is
//				replaced by "&amp;&amp;".  Other ampersands are removed.
//
// Parameters:	None
//
// Returns:		The receiver string, with ampersands transformed as described above.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.caption	:=	self.caption.cnEcStripAmpersands();
end;</source>
    </JadeMethod>
    <JadeMethod name="cnEcTime" id="13113ff4-69d1-4ed9-992e-b52f54a40a7d">
        <source>cnEcTime():Time;
// --------------------------------------------------------------------------------
// Created:		20 December 2000 by cnwdad1
//
// Purpose:		Returns the text value of the receiver's caption as a Time value.
//
// Parameters:	None
//
// Returns:		Time - the trimmed caption cast to a Time value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.caption.trimBlanks().Time;
end;</source>
        <ReturnType type="Time"/>
    </JadeMethod>
    <JadeMethod name="cnEcTimeStamp" id="39fe4a1a-532c-46a3-983e-56f58929b986">
        <source>cnEcTimeStamp():TimeStamp;
// --------------------------------------------------------------------------------
// Created:		20 December 2000 by cnwdad1
//
// Purpose:		Returns the text value of the receiver's caption as a TimeStamp value.
//
// Parameters:	None
//
// Returns:		TimeStamp - the trimmed caption cast to a TimeStamp value.
