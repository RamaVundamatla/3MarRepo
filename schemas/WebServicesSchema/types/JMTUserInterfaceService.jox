        <usesRPC>default</usesRPC>
        <source>getOperatorsForSearch() : WS_OperatorsResponse webService;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 September 2008	cnwkao1	Initial creation

*/

vars
	operatorReq : WS_OperatorsRequest;
	
begin
	create operatorReq transient;
	operatorReq.voyageCode := null;
	return self.getOperators(operatorReq);	
epilog
