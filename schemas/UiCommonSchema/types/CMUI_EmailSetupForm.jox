    <JadeMethod name="addToolbarControls" id="88cea84d-5b70-4a1f-8919-9c23b20b96dd">
        <updating/>
        <source>addToolbarControls() updating, protected;
// -------------------------------------------
// Created 28 August 2003 by cnwdvb1
// -------------------------------------------
vars

	toolbar	: CMUI_Toolbar;
	
begin
	inheritMethod();

	toolbar := self.frmToolbar;
	
	toolbar.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
	
	
	

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="adjustFromSelected" id="3127d7f2-4a9f-43a5-8e8f-691a604e9bef">
        <updating/>
        <source>adjustFromSelected(_row : Integer) : CM_EmailEntityByTypeNameDict protected, updating;
// -------------------------------------------
// Created 06 November 2003 by cnwdvb1
// -------------------------------------------
vars

	rowName,
	str,
	freeText	: String;
	addresses	: CM_EmailEntityByTypeNameDict;
	strArray	: StringArray;
	entity		: CM_EmailEntity;

begin

	create strArray transient;
	addresses := self.getRowName(_row, rowName);
	addresses.clear();
	str := self.tblEmail.getValueByName(rowName).String;
	self.getAddresses(str, strArray);
	foreach str in strArray do
		entity := self.findEmail(str, true);
		if entity &lt;&gt; null and not addresses.includes(entity) then
			addresses.add(entity);
		else
			freeText := freeText &amp; ';' &amp; str;
		endif;
	endforeach;
	if freeText.length &gt; 0 then
		self.setFreeText(_row, freeText[2:end]);
	else
		self.setFreeText(_row, null);
	endif;
	return addresses;

epilog
	delete strArray;
end;</source>
        <access>protected</access>
        <Parameter name="_row" type="Integer"/>
        <ReturnType type="CM_EmailEntityByTypeNameDict"/>
    </JadeMethod>
    <JadeMethod name="btnClose_click" id="675488e4-68b0-401d-a2ed-363c7196b83f">
