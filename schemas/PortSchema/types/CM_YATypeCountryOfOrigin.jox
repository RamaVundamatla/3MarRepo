    <JadeMethod name="getObjects" id="1247a862-26a9-4c7b-8159-3d02e7de51ac">
        <source>getObjects(objects: ObjectLongNameDict input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 March 2023	navmv20 TFS 56216 Task 56217: Jade - New YA Criteria

*/
vars
	country : CM_Country;
begin
	foreach country in app.myRoot.allCountries do
		objects[country.getYAIdentifier] := country;
	endforeach;
end;</source>
        <Parameter name="objects" type="ObjectLongNameDict" usage="input"/>
    </JadeMethod>
