    <JadeMethod name="deleteLogSpecs" id="26599c72-0b62-44eb-befc-6316ef15d48c">
        <source>deleteLogSpecs(_logSpecsName: String);
//03 September 2010	by cnwvu1

vars
	logSpecs	: CM_CodeGroupLogSpecs;
	codeGroup	: CM_CodeGroup;
	tmpCode,
	tmpCode2	: CM_Code;
	logType		: CM_LogType;
	logTreatment: CM_LogTreatment;
	logLen		: CM_LogLength;
	logSpecies	: CM_LogSpecies;
	logGrade	: CM_LogGrade;
	obj			: CM_Object;
	
begin

	//-----------------------------------------------------------------------------------
	//							Log Specs Deletion
	//-----------------------------------------------------------------------------------
	logSpecs := self.getLogSpecs(_logSpecsName);
	if logSpecs = null then
		return;
	endif;

	// log species
	foreach tmpCode in logSpecs.allCodes do
	
		logSpecies := tmpCode.CM_LogSpecies;
		// delete all log grades on this log species
		foreach tmpCode2 in logSpecies.allLogGrades do
			logGrade := tmpCode2.CM_LogGrade;
			// 14/12/2016 cnwmh5
			beginTransaction;
			foreach obj in logGrade.allLocationRestrictions do
				delete obj;
			endforeach;
			commitTransaction;
			app.myTrxDA.trxDeleteLogGrade(logGrade, app.myPassport);
			self.assertNoTrxErrorsOrWarnings();
		endforeach;
		
		app.myTrxDA.trxDeleteLogSpecies(logSpecies, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
		
	endforeach;

	// log type
	foreach logType in logSpecs.allLogTypes do
		app.myTrxDA.trxDeleteLogType(logType, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endforeach;
	// log treatment
	foreach logTreatment in logSpecs.allLogTreatments do
		app.myTrxDA.trxDeleteLogTreatment(logTreatment, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endforeach;
	// log length
	foreach logLen in logSpecs.allLogLengths do
		app.myTrxDA.trxDeleteLogLength(logLen, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endforeach;

	//log specs deletion
	codeGroup := logSpecs;
	app.myTrxDA.trxDeleteCodeGroup(codeGroup,app.myPassport);

	self.assertNoTrxErrorsOrWarnings();
	
	
end;</source>
        <Parameter name="_logSpecsName" type="String"/>
    </JadeMethod>
