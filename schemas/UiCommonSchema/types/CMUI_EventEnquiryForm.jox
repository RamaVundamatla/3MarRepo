    <JadeMethod name="doDelete" id="4d4e3229-47a3-4701-84c1-ce528265bd4c">
        <updating/>
        <source>doDelete(): Boolean updating;
/*
----------   ----------  --------------------------------------------------
Created:	16 July 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	selectedEvents			: CM_EventTransByTypeDateTime;
	result					: Integer;
begin
	create selectedEvents transient;
	self.tblData.allSelectedObjects.copy(selectedEvents);
	
	while true do
		app.myTrxDA.trxDeleteEventTransactions(selectedEvents, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			return true;
		else
			result := app.showErrorWarningDialog('Event Transaction delete', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		
		break;
	endwhile;
	
	return false;
epilog
	delete selectedEvents;
end;

</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
