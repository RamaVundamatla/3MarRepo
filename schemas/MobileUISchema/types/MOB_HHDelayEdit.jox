    <JadeMethod name="cmbDriver_displayEntry" id="7124d406-8ca2-4bd2-8b0f-d2284014ad48">
        <controlMethod name="ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbDriver_displayEntry(combobox: ComboBox input; obj: Any; lstIndex: Integer):String updating;

vars
	user : CM_User;
begin
	
	if obj = null then
		return self.lblDriver.caption;
	endif;
	user := obj.CM_User;
	if user.code.trimBlanks.toUpper = 'SUPERUSER' then
		return null;
	endif;

	if user.isNotAvailableForEntry then
		return null;
	endif;
		
	return user.userName &amp; ' (' &amp; user.code &amp; ')';
	
end;
</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="obj" type="Any"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doDelete" id="6830be65-32b5-49dd-b753-d8ece76f3ade">
        <updating/>
        <source>doDelete() : Boolean updating, protected;
// 'Delete' button click
vars
	result			: Integer;
	msgStr			: String;
	
begin

	
	if self.myDelay &lt;&gt; null then
		msgStr := app.getErrorString2(ConfirmDelete, app.getErrorString(TheSelected), app.getErrorString(Delay));
	else
		app.msgBox(app.getErrorString(Please_Select_An_Item_Fiirst), self.caption, MsgBox_OK_Only+MsgBox_Stop_Icon);
		return false;	
	endif;

	if app.msgBox(msgStr, self.caption, MsgBox_Yes_No + MsgBox_Question_Mark_Icon + MsgBox_Default_Second) = MsgBox_Return_No then
		return false;
	endif;	
	
	app.myTrxDA.trxDeleteDelay(self.myDelay, app.myPassport);

	if not app.myPassport.trxCompletedOK then
		//msgStr := app.myPassport.getErrorsAsString;
		msgStr := app.myPassport.getAllErrorsWarningsAsString;	// 10 Aug 2012	NDL	Par 29885
		self.msgBox( msgStr, app.getErrorString(Error), MsgBox_OK_Only, true );
		return false;
	endif;

	return true;
end;
</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doResizeControls" id="a010c71a-dcb9-49a9-bf2c-cd84c04555f5">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 February 2015	cnwndl1	Initial creation	Par 35604

*/

vars

	cTop : Real;
	stdWidth : Real;
	cWidth : Real;
	stdHeight : Real;
	cHeight : Real;
	cLeft : Real;
	tabIndex : Integer;
	labelsWidth : Integer;
	dateWidth : Integer;
	timeWidth : Integer;
	hrsMinsWidth : Integer;
	hrsWidth : Integer;
	minsWidth : Integer;
	
	gridSize : Integer;

begin

	self.setResizeableMarginAndFontSize();
	
	cLeft := self.resizedMargin;
	cTop := self.resizedMargin;
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
	stdHeight := self.getStdControlHeight;
	labelsWidth := ( self.lblEstEndTime.getTextExtent( self.lblEstEndTime.caption ) + stdHeight ).Integer;
	dateWidth := ( self.txtStartDate.getTextExtent( "DD/MM/YY" ) + ( self.resizedMargin * 2 ) ).Integer;
	timeWidth := ( self.txtStartTime.getTextExtent( "HH:MM" ) + ( self.resizedMargin * 2 ) ).Integer;
	hrsMinsWidth := self.txtPlusHrs.getTextExtent( "000" ).Integer + ( self.resizedMargin * 2 );
	hrsWidth := ( self.lblPlusHrs.getTextExtent( self.lblPlusHrs.caption ) + ( self.resizedMargin * 2 ) ).Integer;
	minsWidth := ( self.lblPlusMins.getTextExtent( self.lblPlusMins.caption )+ ( self.resizedMargin * 2 ) ).Integer;
	
	tabIndex := 4000;
	
	gridSize := 24;
	
	self.lblVoyageMachine.move(	cLeft,
								cTop,
								stdWidth,
								stdHeight
								);
								
	cTop := cTop + self.lblVoyageMachine.height + self.resizedMargin;
	self.cmbDelayType.move(	cLeft,
							cTop,
							stdWidth,
							stdHeight
							);
	if _initialSetup then
		self.cmbDelayType.setAndIncrementTabIndex( tabIndex );
	endif;
	cTop := cTop + self.cmbDelayType.height + self.resizedMargin;
	self.cmbDriver.move(	cLeft,
							cTop,
							stdWidth,
							stdHeight
							);
	if _initialSetup then
		self.cmbDriver.setAndIncrementTabIndex( tabIndex );
	endif;
	
	cTop := cTop + self.cmbDriver.height + self.resizedMargin;
	self.cmbWorkPoint.move(	cLeft,
							cTop,
							stdWidth,
							stdHeight
							);
	if _initialSetup then
		self.cmbWorkPoint.setAndIncrementTabIndex( tabIndex );
	endif;
	
	cTop := cTop + self.cmbWorkPoint.height + self.resizedMargin;
	self.lblStartTime.move(	cLeft,
							cTop,
							labelsWidth,
							stdHeight
							);
							
	cLeft := self.lblStartTime.left + self.lblStartTime.width + self.resizedMargin;
	self.txtStartDate.move(	self.lblStartTime.left + self.lblStartTime.width,
							cTop,
							dateWidth,
							stdHeight
							);
	if _initialSetup then
		self.txtStartDate.setAndIncrementTabIndex( tabIndex );
	endif;
	cLeft := self.txtStartDate.left + self.txtStartDate.width + self.resizedMargin;
	self.txtStartTime.move(	self.txtStartDate.left + self.txtStartDate.width + 2 * self.resizedMargin,
							cTop,
							timeWidth,
							stdHeight
							);
	if _initialSetup then
		self.txtStartTime.setAndIncrementTabIndex( tabIndex );
	endif;
	
	cTop := cTop + self.txtStartDate.height + self.resizedMargin;
	self.txtPlusHrs.move(	self.txtStartDate.left,
							cTop,
							hrsMinsWidth,
							stdHeight
							);
							
	if _initialSetup then
		self.txtPlusHrs.setAndIncrementTabIndex( tabIndex );
	endif;
	cLeft := self.resizedMargin;
	self.lblPlus.move(	cLeft,
						cTop,
						labelsWidth,
						stdHeight
						);
						
	self.lblPlusHrs.move(	self.txtPlusHrs.left + self.txtPlusHrs.width + self.resizedMargin,
							cTop,
							hrsWidth,
							stdHeight
							);
							
	self.txtPlusMins.move(	self.lblPlusHrs.left + self.lblPlusHrs.width + 2 * self.resizedMargin,
							cTop,
							hrsMinsWidth,
							stdHeight
							);
							
	if _initialSetup then
		self.txtPlusMins.setAndIncrementTabIndex( tabIndex );
	endif;
	self.lblPlusMins.move(	self.txtPlusMins.left + self.txtPlusMins.width + 2 * self.resizedMargin,
							cTop,
							minsWidth,
							stdHeight
							);

	cTop := cTop + self.txtPlusHrs.height + self.resizedMargin;
	self.lblEstEndTime.move(	self.resizedMargin,
								cTop,
								labelsWidth,
								stdHeight
								);
								
	self.txtEstEndDate.move(	self.txtStartDate.left,
								cTop,
								dateWidth,
								stdHeight
								);
								
	self.txtEstEndTime.move(	self.txtEstEndDate.left + self.txtEstEndDate.width + 2 * self.resizedMargin,
								cTop,
								timeWidth,
								stdHeight
								);

	cTop := cTop + self.txtEstEndDate.height + self.resizedMargin;
	self.lblEndTime.move(	self.resizedMargin,
							cTop,
							labelsWidth,
							stdHeight
							);
							
	self.txtEndDate.move(	self.txtStartDate.left,
							cTop,
							dateWidth,
							stdHeight
							);
							
	if _initialSetup then
		self.txtEndDate.setAndIncrementTabIndex( tabIndex );
	endif;
	
	self.txtEndTime.move(	self.txtEndDate.left + self.txtEndDate.width + 2 * self.resizedMargin,
							cTop,
							timeWidth,
							stdHeight
							);
							
	if _initialSetup then
		self.txtEndTime.setAndIncrementTabIndex( tabIndex );
	endif;

	cTop := cTop + self.txtEndDate.height + self.resizedMargin;
	self.txtRemarks.move(	self.resizedMargin,
							cTop,
							stdWidth,
							stdHeight
							);
	if _initialSetup then
		self.txtRemarks.setAndIncrementTabIndex( tabIndex );
	endif;
	
	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="47c3c4f6-3b13-4026-ab57-12f9a880534e">
        <updating/>
        <source>doSave() : Boolean updating, protected;
// 'Save' button click
vars
	errMess		: String;
	result		: Integer;
	delayProxy  : CM_Delay;
	theReturn 	: Integer;
	selectedObj : CM_Delay;
begin
	app.mousePointer := Window.MousePointer_HourGlass;
	
	delayProxy  := app.createUpdateProxy(self.myDelay).CM_Delay;
	
	// method returns false on invalid date/time entry
	if not self.populateDelayForSave(delayProxy) then
		return false;
	endif;
	
	while true do
		app.myTrxUA.trxUpdateDelay(delayProxy, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			return true;
		else
			//If there were warnings, give the user a chance to see them. If there are no errors they may decide to acknowledge
			//them and update anyway.
			result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		return false;
	endwhile;
	return true;
epilog	
	delete delayProxy;
	app.mousePointer := Window.MousePointer_Default;
end;
</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="handleBtnOne" id="3642d8e4-a4ae-4e49-a3ba-f92ca39fa565">
        <updating/>
        <source>handleBtnOne() updating, protected;
// Save
vars

begin
	if not self.doSave() then
		return;
	endif;
	
	if self.myDelay.myMachine = null then
		self.myMobileGenericAgent.setStringField1(null);
	else
		self.myMobileGenericAgent.setStringField1(self.myDelay.myMachine.getOidString());
	endif;

	self.doBackButtonClick();
end;
</source>
        <access>protected</access>
    </JadeMethod>
