/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 November 2019	jlgndl1	Initial creation	TFS 47727

*/

vars

	bolTrx : CM_BOLTransaction;

begin

	_invLineDict.clear();

	foreach bolTrx in self.allBOLTransactions do
		bolTrx.allInvoiceLines.copyNoDuplicates( _invLineDict, false );
	endforeach;

epilog

end;</source>
