    <JadeMethod name="setCEDOAppliesEmptyCargoType" id="8fb0cb79-dbd8-468f-b489-e43bf90bcbd7">
        <updating/>
        <source>setCEDOAppliesEmptyCargoType()updating, protected;
//--------------------------------------------------
// Created:	17 February 2004 By: cnwgd1
//--------------------------------------------------
// Date			Who		Reason
// 01 Oct 2008	consw1	Par 17090 Replace app.getMyTerminal with self.myTerminal
// 27 Jul 2022 navsj20 	TFS ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details

vars
	tmpStops 	: IntegerArray;
	stopTbl		: CM_StopsTable;
	//cargoType	: CM_CargoBOLType;	// 27 Jul 2022 navsj20 TFS 53862
	cargoType	: Object;			// 27 Jul 2022 navsj20 TFS 53862
	idx : Integer;
	criteria: CM_YACriteria;	// 27 Jul 2022 navsj20 TFS 53862
begin
	self.emptiesExcluded := (not self.myTerminal.getConfig(CedoAppliesToEmpties).Boolean);
	self.allCargoTypesForCEDO.clear();
	create tmpStops transient;
	app.myRoot.getCustomExportStops(tmpStops, self.myTerminal);
	
	foreach idx in tmpStops do
		stopTbl := app.myRoot.getStopTableForId(idx);
		if stopTbl &lt;&gt; null then
			// START 27 Jul 2022 navsj20 TFS 53862
			/*foreach cargoType in stopTbl.allCargoTypesNew do
				if (not self.allCargoTypesForCEDO.includesKey(cargoType.id)) then
					self.allCargoTypesForCEDO.add(cargoType);
				endif;
			endforeach;*/

			if stopTbl.myStopCriteria &lt;&gt; null then 
				foreach criteria in stopTbl.myStopCriteria.allCriteria where criteria.myYACriteriaType.type = YACriteriaType_CargoType do
					foreach cargoType in criteria.myYAData.CM_YADataObjects.allObjects do
						if cargoType.isKindOf(CM_CargoBOLType) and (not self.allCargoTypesForCEDO.includesKey(cargoType.CM_CargoBOLType.id)) then
							self.allCargoTypesForCEDO.add(cargoType.CM_CargoBOLType);
						endif;
					endforeach;
				endforeach;
			endif;
			// END 27 Jul 2022 navsj20 TFS 53862
		endif;
	endforeach;

epilog
	delete tmpStops;
end;</source>
        <access>protected</access>
    </JadeMethod>
