    <JadeMethod name="getYes" id="f2b5863a-3bbe-40cb-81fa-507a89b75588">
        <source>getYes() : String;
/*

Purpose:			


Return Value:		if true returns yes else null;


Date		Who		Reason
03 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	if self then
		return app.getTranslatedStringYes;
	else
		return null;
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getYesNo" id="7585e392-43ed-4f8b-a0c2-a793ea67c0a5">
