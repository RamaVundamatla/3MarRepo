    <JadeMethod name="setupVoyageStatusProcess" id="db1ed183-a740-4777-9b98-010bca1eb556">
        <source>setupVoyageStatusProcess();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 07/03/2018	jlgdap1		Initial creation TFS 37427 PEL 1 Voyage Status Enhancements
// 16/03/2018	jlgdap1		TFS 37540 PEL1 Voyage Statuses Pelindo 1
// 22/03/2018	jlgdap1		TFS 37544 PEL1 Voyage Statuses InaPortNet
// 11/04/2018	jlgdap1		TFS 37966 PEL1 Archive Status
// 01/06/2018	jlgdap1		TFS 38851 PEL1 Voyage Statuses for INAPORTNET - rewritten to use trx
//
vars
	realStatus : CM_VoyageStatus;

begin
	app.writeLog(method.qualifiedName &amp; " Create Voyage Process and Voyage Status defaults", LogINFO);
	
	app.myTrxUA.trxUpdateVoyageProcStatusAll(app.myPassport);
	
	if app.myPassport.trxCompletedOK then
		app.writeLog(method.qualifiedName &amp; " Voyage Process and Voyage Status defaults Completed OK", LogINFO);
	else
		app.writeLog(method.qualifiedName &amp; " Voyage Process and Voyage Status defaults FAILED!!", LogINFO);
	endif;

epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="standardRelease" id="aac6d97e-b593-4842-8c46-92c4920983db">
        <updating/>
        <source>standardRelease(pController: CnEcReleaseController) updating;
// ---------------------------------------------------------------------------
// Created:     13 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 12 Apr 2010	cnwkpd1		PAR #23525 - System performance enhancements
// 26 Sep 2012	cnwpjs1		PAR #30391 - Voyage rationisation	
// 29 Nov 2012 	cnwpjs1		PAR #30387 - Handle renaming of menu items 
// 05 Jan 2017	cnwkpd1		Remove unnecessary Event Transaction integrity check
//							for deployment performance
// 21/03/2018	jlgdap1		TFS 37427 PEL1 Voyage Status Enhancements
//							TFS 37540 PEL1 Voyage Statuses Pelindo 1
// 19 Sep 2018	jlgrs1		TFS 40627 STWR Make EDI MultiThreaded Stage 3
// 22/07/2019	jlgka1 		TFS 45620	JMT - Refactor remove remaining  Voyage Commodity  Planning
// 01 Oct 2019	jlgdi1		45802 JMTSupport user
// 21 Sep 2020	cnwma1 		ChangeRequest 49758: MTN - Navis Smart Data API - Snapshot Data
// 02 Oct 2020	cnwma1 		ChangeRequest 50112: ASPA - GCI Stevedores
// 24 Sep 2021	navpw1		Bug 52047: MTN - Invoice Status not added to Terminal Security role for new Starter DBs
// 01 Dev 2021	navmd1		TFS 52490 Moved 'createAuditConfigs' to the bottom of the list so starterDBs don't break
// 10 Feb 2023	navpw1		TFS 53697 (55830): Added code to create VBS Processes on release if they do not already exist
// 04 Sep 2024	jlizm1		TFS 65951 NSW Dyanmic Integration - invoice process
// ---------------------------------------------------------------------------
vars
	str : String;
	message : String;
begin
	app.isConverting := true; //cnwrs1 May 2009 should be on for all major release runs

	pController.logEntry('***** Processing standard release for ' &amp; class.name &amp; '... *****');

	inheritMethod(pController);
	
//	pController.logEntry('&gt;&gt;&gt;&gt; Loading Error Messages');


	//CNWTH2 resetting terminology type objects must be done twice
	//first time to build any new ones, second time for after the entTableRows
	//are rebuilt
	message := 'Resetting terminology objects for create';
	pController.logEntry('&gt;&gt;&gt;&gt;&gt; '&amp;message);
	self.resetTerminologyTypes();
	if app.myPassport.hasErrors then
		app.raiseCMException1(PortSchemaReleaseError, 'Error '&amp;message, null, null);
	endif;
		
	message := 'Loading EntTable Details';
	pController.logEntry('&gt;&gt;&gt;&gt;&gt; '&amp;message);
	str := self.loadEntTableDetails();
	if str.length &gt; 0 then
		pController.logEntry('&gt;&gt;&gt;&gt;&gt; '&amp;message &amp; str);
		if str = 'Fatal Error' then
			app.raiseCMException1(PortSchemaReleaseError, 'Error '&amp;message, null, null);
		endif;
	endif;
	
	message := 'Resetting terminology objects for update';
	pController.logEntry('&gt;&gt;&gt;&gt;&gt; '&amp;message);
	self.resetTerminologyTypes();
	if app.myPassport.hasErrors then
		app.raiseCMException1(PortSchemaReleaseError, 'Error '&amp;message, null, null);
	endif;
	
	//load graphics and toolbar icons
	message := 'Loading Graphics and Icons';
	pController.logEntry('&gt;&gt;&gt;&gt;&gt; '&amp;message);
	app.loadIcons();
	if app.myPassport.hasErrors then
		app.raiseCMException1(PortSchemaReleaseError, 'Error '&amp;message, null, null);
	endif;

	//Should force a refresh for all users so the above icons are loaded in including CM_MenuToolBar objects.	
	message := 'Loading Menus';
	pController.logEntry('&gt;&gt;&gt;&gt;&gt; '&amp;message);
	self.resetAllJMTMenus();
	if app.myPassport.hasErrors then
		app.raiseCMException1(PortSchemaReleaseError, 'Error '&amp;message, null, null);
	endif;
	
	
	// PAR #30787 - reload the translatable text after the mensu have been relaoded.
	// this will allow existing menu items to be renamed
	//
	// RBarr - replaced default message (CM_Root.allErrorMessages) with messages on default locale
	// Reload translatable text from global constants (and delete any obsolete objects).
	// This must be done AFTER EntTableRows are loaded from global constants
	// app.myRoot.loadErrMsgsFromGlbConstants();
	message := 'Reload translatable text from global constants';
	pController.logEntry('&gt;&gt;&gt;&gt;&gt; '&amp;message);
	self.loadTranslatableText();
	if app.myPassport.hasErrors then
		app.raiseCMException1(PortSchemaReleaseError, 'Error '&amp;message, null, null);
	endif;
	
	
	
	message := 'Creating qryReport default filter objects';
	pController.logEntry('&gt;&gt;&gt;&gt;&gt; '&amp;message);	
	self.createQryReportFilterObjects(pController);
	if app.myPassport.hasErrors then
		app.raiseCMException1(PortSchemaReleaseError, 'Error '&amp;message, null, null);
	endif;
		
	// Uncomment so get created - PAR 18996
	message := 'Reset TI Behaviour Types';
	pController.logEntry('&gt;&gt;&gt;&gt;&gt; '&amp;message);
	self.resetTIBehaviourTypes();
	if app.myPassport.hasErrors then
		app.raiseCMException1(PortSchemaReleaseError, 'Error '&amp;message, null, null);
	endif;
	
	message := 'Reset Cargo Types';
	pController.logEntry('&gt;&gt;&gt;&gt;&gt; '&amp;message);
	self.resetCargoTypes();
	if app.myPassport.hasErrors then
		app.raiseCMException1(PortSchemaReleaseError, 'Error '&amp;message, null, null);
	endif;
	
	//th2 added 14/02/2007 - event types
	message := 'Reset Event Types';
	pController.logEntry('&gt;&gt;&gt;&gt;&gt; '&amp;message);
	self.resetEventTypes();
	if app.myPassport.hasErrors then
		app.raiseCMException1(PortSchemaReleaseError, 'Error '&amp;message, null, null);
	endif;
	
	message := 'Reset Terminal Area Types';
	pController.logEntry('&gt;&gt;&gt;&gt;&gt; '&amp;message);
	self.resetTerminalAreaTypes();
	if app.myPassport.hasErrors then
		app.raiseCMException1(PortSchemaReleaseError, 'Error '&amp;message, null, null);
	endif;
	
	message := 'Reset Handling Types';
	pController.logEntry('&gt;&gt;&gt;&gt;&gt; '&amp;message);
	self.resetHandlingTypes();
	if app.myPassport.hasErrors then
		app.raiseCMException1(PortSchemaReleaseError, 'Error '&amp;message, null, null);
	endif;

	message := 'Reset Trx Trans Types';
	pController.logEntry('&gt;&gt;&gt;&gt;&gt; '&amp;message);
	self.resetTrxTypes();
	if app.myPassport.hasErrors then
		app.raiseCMException1(PortSchemaReleaseError, 'Error '&amp;message, null, null);
	endif;

	message := 'Reset Root Security Roles';
	pController.logEntry('&gt;&gt;&gt;&gt;&gt; '&amp;message);
	self.resetRootSecurityRoles();
	if app.myPassport.hasErrors then
		app.raiseCMException1(PortSchemaReleaseError, 'Error '&amp;message, null, null);
	endif;
	
	message := 'Resetting Audit Class/Properties';
	pController.logEntry('&gt;&gt;&gt;&gt;&gt; '&amp;message);
	self.resetAuditedClassProperties();
	if app.myPassport.hasErrors then
		app.raiseCMException1(PortSchemaReleaseError, 'Error '&amp;message, null, null);
	endif;
	
	message := 'Creating query menu Root if null';
	pController.logEntry('&gt;&gt;&gt;&gt;&gt; '&amp;message);
	self.createQueryMenuRoot();
	if app.myPassport.hasErrors then
		app.raiseCMException1(PortSchemaReleaseError, 'Error '&amp;message, null, null);
	endif;

	message := 'Creating query definition objects for selector';
	pController.logEntry('&gt;&gt;&gt;&gt;&gt; '&amp;message);
	app.myRoot.createQueryDefinitionObjects();
	if app.myPassport.hasErrors then
		app.raiseCMException1(PortSchemaReleaseError, 'Error '&amp;message, null, null);
	endif;
	
	message := 'Loading side profile graphic';
	pController.logEntry('&gt;&gt;&gt;&gt;&gt; '&amp;message);
	self.loadSideProfileGraphic(); // AKB Added
	if app.myPassport.hasErrors then
		app.raiseCMException1(PortSchemaReleaseError, 'Error '&amp;message, null, null);
	endif;

	message := 'Rebuilding master data dump classes and features';
	pController.logEntry('&gt;&gt;&gt;&gt;&gt; '&amp;message);
	self.rebuildMasterDataDumpObjs(pController);
	if app.myPassport.hasErrors then
		app.raiseCMException1(PortSchemaReleaseError, 'Error '&amp;message, null, null);
	endif;
	
	message := 'Reset terminology types';
	pController.logEntry('&gt;&gt;&gt;&gt;&gt; '&amp;message);
	self.resetTerminologyTypes();
	if app.myPassport.hasErrors then
		app.raiseCMException1(PortSchemaReleaseError, 'Error '&amp;message, null, null);
	endif;

	message := 'Reset code group types';
	pController.logEntry('&gt;&gt;&gt;&gt;&gt; '&amp;message);
	self.resetCodeGroupTypes();
	if app.myPassport.hasErrors then
		app.raiseCMException1(PortSchemaReleaseError, 'Error '&amp;message, null, null);
	endif;
	
	message := 'Reset Hook types';
	pController.logEntry('&gt;&gt;&gt;&gt;&gt; '&amp;message);
	self.resetHookTypes();
	if app.myPassport.hasErrors then
		app.raiseCMException1(PortSchemaReleaseError, 'Error '&amp;message, null, null);
	endif;
	
	message := 'Reset YA Types';
	pController.logEntry('&gt;&gt;&gt;&gt;&gt; '&amp;message);
	self.createYATypesStandard();
	if app.myPassport.hasErrors then
		app.raiseCMException1(PortSchemaReleaseError, 'Error '&amp;message, null, null);
	endif;

	message := 'Checking EDI Config for all terminals';
	pController.logEntry('&gt;&gt;&gt;&gt;&gt; '&amp;message);
	self.createEDIConfigForTerminals();
	if app.myPassport.hasErrors then
