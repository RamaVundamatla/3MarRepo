    <JadeMethod name="create" id="81dcf8c4-a0b9-456c-9616-c2f82fdab47a">
        <updating/>
        <source>create() updating;
// --------------------------------------------------------------------------------
// Created:		14 January 2003 by cnwdad2
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	SCHEMA_NAME		: String = "JSSLicenseKeySchema";
	CLASS_NAME		: String = "JSSLicenseKeyService";
	
vars
	theRemoteSchema	: Schema;
	theRemoteClass	: Class;
	theRemoteObject	: Object;
	
begin
	theRemoteSchema	:=	rootSchema.getSchema(SCHEMA_NAME);
	
	if theRemoteSchema = null then
		Exception.raise_(99999, "Could not locate the remote schema (" &amp; SCHEMA_NAME &amp; ").");
	else
		theRemoteClass	:=	theRemoteSchema.getClass(CLASS_NAME);
		
		if theRemoteClass = null then
			Exception.raise_(99999, "Could not locate the service interface class (" &amp; CLASS_NAME &amp; ").");
		else
			create theRemoteObject as theRemoteClass transient;
			self.myServiceObject	:=	theRemoteObject;
			theRemoteObject.sendMsgWithParams("setExternalInterface", self);
		endif;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="d8a95353-ad6a-40bb-a4d5-12778ba2fa82">
        <updating/>
        <source>delete() updating;
// --------------------------------------------------------------------------------
// Created:		14 January 2003 by cnwdad2
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	delete self.myServiceObject;
end;</source>
    </JadeMethod>
    <JadeMethod name="deleteLicenseKey" id="f0635daf-174d-4620-8252-abca00d71dea">
        <source>deleteLicenseKey(pCustomerName:String; pProductCode:String; pLicenseKey:String):Boolean;
// --------------------------------------------------------------------------------
// Created:		14 January 2003 by cnwdad2
//
// Purpose:		Removes a previously registered license key
//
// Parameters:	pCustomerName - The name of the customer who's license to delete.
//				pProductCode - The unique code of the licensed product.
//				pLicenceKey - A string containing the customer's product key.
//
// Returns:		True if the license key was deleted, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.myServiceObject.sendMsgWithParams(method.name, pCustomerName, pProductCode, pLicenseKey).Boolean;
end;</source>
        <Parameter name="pCustomerName" type="String"/>
        <Parameter name="pProductCode" type="String"/>
        <Parameter name="pLicenseKey" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="editLicenseKey" id="18e39eb0-e33b-4f84-a79d-bb28a006b05a">
        <source>editLicenseKey(pCustomerName:String; pProductCode:String):String;
// --------------------------------------------------------------------------------
// Created:		17 January 2003 by cnwdad1
//
// Purpose:		Shows a form on which to enter a (new) license registration key.
//
// Parameters:	pCustomerName - The name of the customer.
//				pProductCode - The unique code of the licensed product.
//
// Returns:		The Product Code if the license key was accepted, otherwise null.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.myServiceObject.sendMsgWithParams(method.name, pCustomerName, pProductCode).String;
end;</source>
        <Parameter name="pCustomerName" type="String"/>
        <Parameter name="pProductCode" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="enterLicenseKey" id="359e7e30-6617-4570-a812-1cdd964f745e">
        <source>enterLicenseKey(pCompanyName:String; pLicenseKey:String):String;
// --------------------------------------------------------------------------------
// Created:		14 January 2003 by cnwdad2
//
// Purpose:		Accepts a (new) license key, causing the registration bit mask to
//				be rebuilt.  If the key is not valid (i.e. checksum fails) or if
//				any other errors are detected, an exception will be raised (of type
//				JSSException) - refer to the isJSSException method for determining
//				whether an exception was raised by a JSS peer schema.
//
// Parameters:	pCustomerName - The name of the customer to whom the product is
//					registered.
//				pLicenceKey - A string containing the customer's product key.
//
// Returns:		The Product Code if the license key was accepted, otherwise null.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.myServiceObject.sendMsgWithParams(method.name, pCompanyName, pLicenseKey).String;
end;</source>
        <Parameter name="pCompanyName" type="String"/>
        <Parameter name="pLicenseKey" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVersion" id="8bf8c642-f660-41ee-b782-49dd0bd991b5">
        <source>getVersion(): String;
// --------------------------------------------------------------------------------
// Created:		14 January 2003 by cnwdad2
//
// Purpose:		Returns the version number of the peer schema.
//
// Parameters:	None
//
// Returns:		The peer schema version number, i.e. "1.0", as a string.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.myServiceObject.sendMsg(method.name).String;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVersionFull" id="8a41839c-dd76-4b39-92e3-e376b46a3a14">
        <source>getVersionFull(): String;
// --------------------------------------------------------------------------------
// Created:		14 January 2003 by cnwdad2
//
// Purpose:		Returns the full version number of the peer schema.
//
// Parameters:	None
//
// Returns:		The peer schema's full version number, i.e. "1.0.000", as a string.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.myServiceObject.sendMsg(method.name).String;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isJSSException" id="5ebcd832-bc67-4c0b-a901-16d07fd80292">
        <source>isJSSException(pTheException: Exception): Boolean;
// --------------------------------------------------------------------------------
// Created:		14 January 2003 by cnwdad2
//
// Purpose:		This method is for application schemas exception handling.  In most
//				cases, peer schemas will raise exceptions of type JSSException to
//				report any detected errors.  For the application schema to easily
//				determine whether their exception is a peer schema one or not, they
//				can simply call this method, and then treat the error according to
//				the application's needs.
//
// Parameters:	pTheException - The exception object.
//
// Returns:		True if the exception is a JSS exception, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.myServiceObject.sendMsgWithParams(method.name, pTheException).Boolean;
end;</source>
        <Parameter name="pTheException" type="Exception"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isLicensed" id="4a2c5fff-b67b-4012-97b1-5c4266a3490c">
        <updating/>
        <source>isLicensed(pCustomerName:String; pProductCode:String; pComponentId:Integer):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		14 January 2003 by cnwdad2
//
// Purpose:		Returns a boolean flag to indicate whether the specified product
//				component is registered for use.
//
// Parameters:	pCustomerName - The name of the customer to whom the product component
//				pProductCode - The unique code of the licensed product.
//					is registered.
//				pComponentId - The identifer of the product component.
//
// Returns:		True if the component is registered, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.myServiceObject.sendMsgWithParams(method.name, pCustomerName, pProductCode, pComponentId).Boolean;
end;</source>
        <Parameter name="pCustomerName" type="String"/>
        <Parameter name="pProductCode" type="String"/>
        <Parameter name="pComponentId" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showLicenseMaintenance" id="26cb4d4c-96c4-435b-8b22-8010aa9187d1">
        <source>showLicenseMaintenance();
// --------------------------------------------------------------------------------
// Created:		26 March 2003 by cnwdad2
//
// Purpose:		Shows a form with which to maintain a list of license registration keys.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.myServiceObject.sendMsg(method.name);
end;</source>
    </JadeMethod>
