    <JadeMethod name="initShtMultiSelect" id="dc490a5f-2df2-45e6-b167-6171bdb399e4">
        <source>initShtMultiSelect();
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 January 2010	cnwdap1	Initial creation
*/
constants
	LeftMargin		: Integer = 10;
	TopMargin		: Integer = 10;
	VerticalSpacing	: Integer = 5;

vars
	theForm		: SOP_TableMaintForm;
	theTable	: CM_DataTable;
	entTableDef	: EntTableDef;

begin
	theForm 	:= self.myForm;
	theTable 	:= theForm.tblCheckItems;
	inheritMethod();

	theForm.shtSingleSelect1.visible 	:= true;
	theForm.shtSingleSelect1.caption 	:= app.getErrorString(Check_items);
	theForm.lstSingleSelect1.visible 	:= false;
	theForm.tblCheckItems.visible		:= true;
	
	theForm.btnSingle1Up.visible 		:= true;
	theForm.btnSingle1Down.visible 		:= true;
	theForm.frmTBSingle.setToolbarControlsEnabled(true);
	
	// reposition/resize the check table
	theTable.top 	:= theForm.frmTBSingle.top + theForm.frmTBSingle.height;
	theTable.left	:= LeftMargin;	
	theTable.width 	:= theTable.parent.width - (LeftMargin * 2);
	theTable.height := theTable.parent.height - theTable.top - TopMargin;
    theTable.cnEcResizeContents();	
	
	theTable.clear;
	theTable.rows			:= 0;
	theTable.columns		:= 4;
	theTable.fixedRows		:= 0;
	theTable.selectMode		:= theTable.SelectMode_CurrentRow;
	theTable.disallowColumnSorter := true;
	
	entTableDef := app.myController.getEntTableDef(ETDef_CargoCheckItemTblMaint);
	theTable.setMyDataClass(CM_CargoCheckItem);
	theTable.setMyEntTableDef(entTableDef);	
	theTable.setTblDataEntRowsFromDef(entTableDef);	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="a5dee677-a9e7-4224-8fbc-1cc61f2e4df7">
        <updating/>
        <source>setControlsForAddEdit() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 January 2010	cnwdap1	Initial creation
*/
vars
	theForm : SOP_TableMaintForm;

begin
    theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
	theForm.btnSetDefault1.enabled := false;
	theForm.btnSingle1Edit.enabled := true;
	theForm.btnSingle1Delete.enabled := true;
	theForm.btnSingle1New.enabled := true;
	theForm.btnSingle1Down.enabled := true;
	theForm.btnSingle1Up.enabled := true;
	if theForm.mode = theForm.Mode_Add then
		theForm.tblInput1.clearValues;
		theForm.tblInput1.enableRowByName(ETRow_Context);
		theForm.tblInput1.moveFirst();
		// call this last as sets cell input type (case etc)
		// if not called can get problems with case on entry. 
		theForm.tblInput1.gotFocus(theForm.tblInput1);		

	else
		// refresh the data from the newly created proxy
		self.showThumbnail(theForm.myProxyObject.CM_CargoCheck);
		// cannot update code		
		theForm.tblInput1.disableRowByName(ETRow_Context);
	endif;
epilog

end;</source>
    </JadeMethod>
