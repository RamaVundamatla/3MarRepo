    <JadeMethod name="removeTIs" id="fba34140-2d4a-42a9-b355-30de52c9c0cb">
        <source>removeTIs();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 April 2023  navmv20 TFS 55304 Task 55545: UI - Invoice Line List Changes

*/

vars
	allSelectedItems : CM_TIArray;
	ti : CM_TrackedItem;
	iter : Iterator;
	idx : Integer;
begin
	create allSelectedItems transient;
	
	self.tblResults.allSelectedObjects.copy(allSelectedItems);
	if allSelectedItems.size = 0  then
		app.msgBox(app.getErrorString2(CMUI_Please_Select, "cargo item(s)", "remove"),app.getErrorString(NOTHING_SELECTED), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	foreach ti in allSelectedItems do
		self.allTIs.remove(ti);
	endforeach;
	
	iter := self.allTIs.createIterator(); 
	self.tblResults.clearAllData();
		
	while iter.next(ti) do	
		idx := self.tblResults.updateItemObject(ti, self.colorRow1, self.colorRow2, app.myPassport);
		self.tblResults.accessRow(idx).itemObject := ti;
	endwhile;
	
epilog
	delete allSelectedItems;
	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="saveSelectedTrackedItems" id="6816c026-d62b-4211-824d-5ae44006e7f4">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_CMUI_TrackedItems::saveSelectedTrackedItems"/>
        </interfaceImplements>
        <updating/>
        <source>saveSelectedTrackedItems(_allTIs : CM_TIArray) : Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 April 2023  navmv20 TFS 55304 Task 55545: UI - Invoice Line List Changes

*/

vars
	ti 		  : CM_TrackedItem;
	currentTA : CM_TerminalArea;
	iter      : Iterator;
	count,
	idx       : Integer;
begin

	if _allTIs = null then
		return true;
	endif;
	
	self.allTIs.clear();
	_allTIs.copy(self.allTIs);
	
	iter := self.allTIs.createIterator();
	self.tblResults.setMyDataClass(CM_TrackedItem);

	if self.allTIs.size &gt; 0 then
	while iter.next(ti) do
		count := count + 1;
		idx := self.tblResults.updateItemObject(ti, self.colorRow1, self.colorRow2, app.myPassport);
		self.tblResults.accessRow(idx).itemObject := ti;
	endwhile;
		self.shtCargoItems.caption := "Items (" &amp; allTIs.size().String &amp; ")";
		return true;
	endif;
	self.shtCargoItems.caption := "Items (" &amp; allTIs.size().String &amp; ")";
	return false;

epilog

end;</source>
        <Parameter name="_allTIs" type="CM_TIArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
