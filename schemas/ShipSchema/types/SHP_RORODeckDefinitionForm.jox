    <JadeMethod name="doShowRemarks" id="481356a8-6953-414b-b70b-a5254cd6f2f4">
        <updating/>
        <source>doShowRemarks() updating;
/*
Purpose:			
Date		Who		Reason
20 May 2011	cnwab1	Initial creation
*/

vars
	theLayer : CM_DeckLayerLayout;
	obj : Object;
	layerFrame : CMUI_PointDrawingFrame;
	showText : Boolean;
	deckItemLayout : CM_DeckItemLayout;
begin
	showText := self.btnDrawRemarks.value;
	
	foreach obj in self.allBackgroundFrames reversed, discreteLock do
		layerFrame := obj.CMUI_PointDrawingFrame;
		theLayer := layerFrame.userObject.CM_DeckLayerLayout;
		
		foreach deckItemLayout in theLayer.allDeckItemLayouts do
			self.doDrawRemarks(layerFrame, deckItemLayout);
		endforeach;

	endforeach;


epilog

end;</source>
