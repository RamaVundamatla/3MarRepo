    </JadeMethod>
    <JadeMethod name="switchViewMode" id="6edf2bba-c9f8-4580-931b-1265e483019b">
        <updating/>
        <source>switchViewMode(_theIndex : Integer; _btn : Button input) updating;
// ---------------------------------------------------------------------------
// Created:     27 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theGridArea : CMUI_GridArea;
	theFrame 	: CMUI_GridAreaFrame;
	flipString 	: String;
	theSDF 		: CMUI_ScrollableDrawingFrame;
	theGridFrame : CMUI_GridAreaFrame;
	theSDFs : ObjectArray;
	anObject : Object;
	strTerminology :  String;
begin

//	theSDF := self.myCurrentSDF;
//	if theSDF = null then
//		theSDF := self.sdf01;
//	endif;

	if _btn &lt;&gt; null then
		_btn.value := true;
	endif;

	if _theIndex = VIEW_LOG_GRADE then
		self.frmColLegendLogs.doChangeViewMode(_theIndex);
		self.sdf01.viewMode := _theIndex;
		self.frmStatusLine.myFrameCaption.caption := self.sdf01.setViewMode(_theIndex);// 03/04/2009 cnwdz2 PAR 18231
		self.sdf01.drawSelf();

	else
		create theSDFs transient;
		theSDFs.add(self.sdf01);
		if self.allTerminalAreas.size &gt;= 2 then
			theSDFs.add(self.sdf02);
		endif;
		if self.allTerminalAreas.size = 3 then
			theSDFs.add(self.sdf03);
		endif;	
		foreach anObject in theSDFs do
			theSDF := anObject.CMUI_ScrollableDrawingFrame;
		
			self.frmStatusLine.myFrameCaption.caption := theSDF.setViewMode(_theIndex);
			theSDF.drawSelf();
			
			self.doNotesForLegend(false);
			
			if self.areaType = self.Area_Type_Log then
				self.frmColLegendLogs.doChangeViewMode(_theIndex);
				self.frmColLegendLogs.myLegendTable.removeItem(1);
				strTerminology := app.getTerminologyAlternate(app.myRoot.allCargoTypesById[TI_CargoType_Log], self.myTerminal, CM_TerminologyOperator, CM_TermExpressionSingular, 'Operator');
				self.frmColLegendLogs.addRowAt(strTerminology,Red,null,1);
			else
				if not self.frmColLegendTIs.displayViewModeCodes(theSDF.viewMode, theSDF.myDrawingAttrController) then
					self.frmColLegendTIs.doChangeViewMode(_theIndex);
				endif;
			endif;
			self.doNotesForLegend(true);
		endforeach;
	endif;
	theFrame := self.frmGridArea.getControl(1).CMUI_GridAreaFrame;
	if theFrame &lt;&gt; null then
		theGridArea := theFrame.myGridArea;
//		self.doSetCaption(theGridArea);
	endif;
epilog
	delete theSDFs;
end;</source>
        <Parameter name="_theIndex" type="Integer"/>
        <Parameter name="_btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="ab325c31-e0a8-4f0b-896e-0ac42bfa7d7d">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
//	self.translateCaption(Xlat_0017723, locale);
	btnAutoMask.translateCaption(Xlat_0004319, locale);
	btnFlipH.translateBubbleHelp(Xlat_0004311, locale);
	btnFlipH.translateCaption(Xlat_0004320, locale);
	btnFlipV.translateBubbleHelp(Xlat_0004312, locale);
	btnFlipV.translateCaption(Xlat_0004321, locale);
	btnMoveBotLeft.translateBubbleHelp(Xlat_0004313, locale);
	btnMoveBotLeft.translateCaption(Xlat_0004322, locale);
	btnMoveBotRight.translateBubbleHelp(Xlat_0004301, locale);
	btnMoveBotRight.translateCaption(Xlat_0004306, locale);
	btnMoveTopLeft.translateBubbleHelp(Xlat_0004314, locale);
	btnMoveTopLeft.translateCaption(Xlat_0004323, locale);
	btnMoveTopRight.translateBubbleHelp(Xlat_0004302, locale);
	btnMoveTopRight.translateCaption(Xlat_0004307, locale);
	btnRefresh.translateBubbleHelp(Xlat_0004315, locale);
	btnRefresh.translateCaption(Xlat_0004324, locale);
	btnSelectAreasCl.translateCaption(Xlat_0004295, locale);
	btnSelectAreasSh.translateCaption(Xlat_0004296, locale);
	btnSelectTAs.translateBubbleHelp(Xlat_0004316, locale);
	btnSelectTAs.translateCaption(Xlat_0004325, locale);
	btnViewCommodity.translateBubbleHelp(Xlat_0004291, locale);
