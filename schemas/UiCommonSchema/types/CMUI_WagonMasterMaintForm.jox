    <JadeMethod name="wagonClassDataDiffers" id="29246bf3-fa2a-401d-be03-a853393843a5">
        <source>wagonClassDataDiffers( _wagonClass : CM_WagonClass; _changes : String output ):Boolean protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 July 2009	cnwndl1	Initial creation
01 APR 2010	NDL	Par 23356

*/

vars
	
	attribName : String;
	current : String;
	new : String;
	
begin

	if _wagonClass = null then
	
		// resetting it to null, no updatuing to do.
		return false;
	
	else

		if _wagonClass.myCarrier &lt;&gt; null then
			if self.cmbCarrier.listObject &lt;&gt; _wagonClass.myCarrier then
				attribName := self.lblCarrier.caption;
				current := "'" &amp; self.cmbCarrier.text &amp; "'";
				new := "'" &amp; self.myAssistant.displayEntryCarrier(_wagonClass.myCarrier) &amp; "'";
				if _changes &lt;&gt; null then
					_changes := _changes &amp; CrLf;
				endif;
				_changes := _changes &amp; attribName &amp; " : " &amp; current &amp; " --&gt; " &amp; new;
			endif;
		endif;
		if _wagonClass.maxCargoHeight &gt; 0 then
		//	if self.txtMaxCHeight.text.Decimal &lt;&gt; _wagonClass.maxCargoHeight then
			if self.txtMaxCHeight.text.asDecimalJMT() &lt;&gt; _wagonClass.maxCargoHeight then	// 01 APR 2010	NDL	Par 23556
				attribName := self.lblMaxCHeight.caption;
				current := "'" &amp; self.txtMaxCHeight.text &amp; "'";
				new := "'" &amp; _wagonClass.maxCargoHeight.asStringMeasurementJMT() &amp; "'";
				if _changes &lt;&gt; null then
					_changes := _changes &amp; CrLf;
				endif;
				_changes := _changes &amp; attribName &amp; " : " &amp; current &amp; " --&gt; " &amp; new;
			endif;
		endif;
		if _wagonClass.maxLoadWeight &gt; 0 then
		//	if self.txtMaxCWeight.text.Decimal &lt;&gt; _wagonClass.maxLoadWeight then
			if self.txtMaxCWeight.text.asDecimalJMT() &lt;&gt; _wagonClass.maxLoadWeight then	// 01 APR 2010	NDL	Par 23556
				attribName := self.lblMaxCWeight.caption;
				current := "'" &amp; self.txtMaxCWeight.text &amp; "'";
				new := "'" &amp; _wagonClass.maxLoadWeight.asStringWeightJMT() &amp; "'";
				if _changes &lt;&gt; null then
					_changes := _changes &amp; CrLf;
				endif;
				_changes := _changes &amp; attribName &amp; " : " &amp; current &amp; " --&gt; " &amp; new;
			endif;
		endif;
		if _wagonClass.tareWeight &gt; 0 then
		//	if self.txtTareWeight.text.Decimal &lt;&gt; _wagonClass.tareWeight then
			if self.txtTareWeight.text.asDecimalJMT() &lt;&gt; _wagonClass.tareWeight then	// 01 APR 2010	NDL	Par 23556
				attribName := self.lblTareWeight.caption;
				current := "'" &amp; self.txtTareWeight.text &amp; "'";
				new := "'" &amp; _wagonClass.tareWeight.asStringWeightJMT() &amp; "'";
				if _changes &lt;&gt; null then
					_changes := _changes &amp; CrLf;
				endif;
				_changes := _changes &amp; attribName &amp; " : " &amp; current &amp; " --&gt; " &amp; new;
			endif;
		endif;
	
	endif;
	
	return _changes.trimBlanks &lt;&gt; null;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_wagonClass" type="CM_WagonClass"/>
        <Parameter name="_changes" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
