    <JadeMethod name="doLstDataDragDrop" id="0ad65113-ffb7-41a2-a14c-4c8a18547333">
        <updating/>
        <source>doLstDataDragDrop(listbox: ListBox input; win: Window input; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:     26 January 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	bottomObject,
	lObjectTarget : Object;
	dropIndex: Integer;
begin
	
	inheritMethod(listbox, win, x,y);

	if self.myCurrentCalendar = null then
		return;  // cant drag drop root. 
	endif;
	
	dropIndex := listbox.dragListIndex;
	
	if dropIndex &lt; 1 then
		lObjectTarget := null;  // if draging off the list set target to null so later on can check. 
	else
		lObjectTarget := listbox.itemObject[dropIndex];  // set target so know what action to take 
	endif;

	if lObjectTarget = null then  // if dragged off list
		if self.myCurrentDate = null and self.myCurrentYear = null then	// no date set so drag item must be a calendar. As item is calendar then give user option to create new copy
			if app.msgBox('Do you want to make a copy of Calendar ' &amp; self.myCurrentCalendar.code ,'Confirm Copy',
						MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
				return; 
			else
				self.doBtnCopyClick(); // will call display screen to enter new calendar details. 
				return;  
			endif;
		//as lObjectTarget is null item has been dragged to bottom of list so must be wanted to be added to last calendar
		elseif self.myCurrentDate = null then //must be a year that has been dragged 
			if app.msgBox('Do you want to make a copy of Year ' &amp; self.myCurrentYear.year.String ,'Confirm Copy',
						MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
				return; 
			else
				bottomObject := listbox.itemObject[listbox.listCount];
				if bottomObject.isKindOf(CM_CalendarDate) then 		// set calendar being copied to to be the calender at bottom of list
					self.myCurrentCalendar := bottomObject.CM_CalendarDate.myCalendar;
				elseif bottomObject.isKindOf(CM_CalendarYear) then 
					self.myCurrentCalendar := bottomObject.CM_CalendarYear.myCalendar;
				else  //must be a calendar
					self.myCurrentCalendar := bottomObject.CM_Calendar;
				endif;
					self.doBtnCopyClick(); // will call display screen to enter new calendar details. 
				return;  
			endif;
		else
		// since item has been dragged off botom of list need to know what last entry 
			if app.msgBox('Do you want to make a copy of Date ' &amp; self.myCurrentDate.date.String ,'Confirm Copy',
						MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
				return;
			else
				bottomObject := listbox.itemObject[listbox.listCount];
				if bottomObject.isKindOf(CM_CalendarDate) then 		// set calendar being copied to to be the calender at bottom of list
					self.myCurrentCalendar := bottomObject.CM_CalendarDate.myCalendar;
					self.myCurrentYear := bottomObject.CM_CalendarDate.myCalendarYear;
				elseif bottomObject.isKindOf(CM_CalendarYear) then 
					self.myCurrentYear := bottomObject.CM_CalendarYear;
					self.myCurrentCalendar := bottomObject.CM_CalendarYear.myCalendar;
				else  //bottom must be a calendar
					self.myCurrentCalendar := bottomObject.CM_Calendar;
				endif;
					self.doBtnCopyClick(); // will call display screen to enter new calendar details. 
				return;  	
			endif;
		endif;
		
	elseif lObjectTarget.isKindOf(CM_Calendar) then 
		if self.myCurrentDate = null and self.myCurrentYear = null then 
			return; // cant copy calendar onto another calendar
		endif;
		if self.myCurrentDate = null then //is a year being dragged so copy year to callendar
			if	app.msgBox('Do you want to make a copy of Year ' &amp; self.myCurrentYear.year.String ,'Confirm Copy',
						MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
			return;
			endif;
		else
			if app.msgBox('Do you want to make a copy of Date ' &amp; self.myCurrentDate.date.String ,'Confirm Copy',
						MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
			return;
			endif;
		endif;

		self.myCurrentCalendar := lObjectTarget.CM_Calendar; //set calendar to be copied to. 

	elseif lObjectTarget.isKindOf(CM_CalendarYear) then
		if self.myCurrentDate = null and self.myCurrentYear = null then 
			return; // cant copy calendar onto another calendar
		endif;
		if self.myCurrentDate = null then //is a year being dragged so copy year to callendar
			if	app.msgBox('Do you want to make a copy of Year ' &amp; self.myCurrentYear.year.String ,'Confirm Copy',
						MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
				return;
			endif;
		else
			if app.msgBox('Do you want to make a copy of Date ' &amp; self.myCurrentDate.date.String ,'Confirm Copy',
						MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
				return;
			endif;
			self.myCurrentYear := lObjectTarget.CM_CalendarYear; //set calendar to be copied to.
		endif;
		self.myCurrentCalendar := lObjectTarget.CM_CalendarYear.myCalendar; //set calendar to be copied to. 
	elseif lObjectTarget.isKindOf(CM_CalendarDate) then
		if self.myCurrentDate = null and self.myCurrentYear = null then 
			return; // cant copy calendar onto another calendar
		endif;
		if lObjectTarget.CM_CalendarDate.myCalendarYear = self.myCurrentYear then
			return; 
		endif;
		if self.myCurrentDate = null then //is a year being dragged so copy year to callendar
			if	app.msgBox('Do you want to make a copy of Year ' &amp; self.myCurrentYear.year.String ,'Confirm Copy',
						MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
				return;
			endif;
		else	
			if app.msgBox('Do you want to make a copy of Date ' &amp; self.myCurrentDate.date.String ,'Confirm Copy',
						MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
			return;
			endif;
			self.myCurrentYear := lObjectTarget.CM_CalendarDate.myCalendarYear; //set calendar to be copied to
		endif;
	 	self.myCurrentCalendar := lObjectTarget.CM_CalendarDate.myCalendar; //set calendar to be copied to.
	endif;
	
	self.cmbYear.myCalendar := self.myCurrentCalendar;
	self.cmbYear.initialise(false);
	self.cmbYear.setObject(self.myCurrentYear); // set vaule of calendar to be copied to.
	self.tblCalendar.setValueByName(ETRow_YearCombo, self.myCurrentYear.year); 

	self.cmbCalendarCode.setObject(self.myCurrentCalendar); // set vaule of calendar to be copied to.
	self.tblCalendar.setValueByName(ETRow_CalendarCode, self.myCurrentCalendar.code); 
	self.doBtnCopyClick();	
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
