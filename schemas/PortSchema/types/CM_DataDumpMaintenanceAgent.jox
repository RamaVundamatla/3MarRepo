	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_Train::sealCheckRelease.name, "CM_Train", "sealCheckRelease", "CM_Train", _features); 

	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_Train::shunterInDT.name, "CM_Train", "shunterInDT", "CM_Train", _features); 
	
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_Train::shunterOutDT.name, "CM_Train", "shunterOutDT", "CM_Train", _features); 
	
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_Train::getTrackClearanceCode.name, "CM_Train", "trackClearanceCode", "CM_Train", _features); 
	
