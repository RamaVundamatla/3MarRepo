    <JadeMethod name="accumColor" id="2c0b8568-ac3a-4f5f-be44-2645e92a56d7">
        <updating/>
        <source>accumColor(_theColour : Integer io;_theOffset : Integer ) updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
		_theColour := theColour + _theOffset;
		if _theColour &gt; 6 then
			_theColour := _theColour - 6;
		endif;


end;</source>
        <Parameter name="_theColour" type="Integer" usage="io"/>
        <Parameter name="_theOffset" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="button1_click" id="550f155c-919d-472e-906d-cc44e5111b03">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>button1_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:		06 August 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	ta : CM_TerminalArea;
	tas : CM_TerminalAreaArray;
	row, col, idx, left, widf: Integer;
	fr : Frame;
begin
	create tas transient;
	
	fr := self.frame1;
	fr.autoRedraw := true;
	fr.clearGraphics();
	
	ta := CM_Terminal.firstInstance.allTerminalAreas["A"];
	tas.add(ta);
	ta := CM_Terminal.firstInstance.allTerminalAreas["B"];
	tas.add(ta);
	ta := CM_Terminal.firstInstance.allTerminalAreas["C"];
	tas.add(ta);
	
	left := 10;
	foreach ta in tas do
		row := ta.CM_GridArea.allGridRows.size;
		col :=  ta.CM_GridArea.allGridColumns.size;
		widf := (col * 10);

		fr.drawRectangle(left,10, widf + left ,(row * 5), Black);
		
		left := left + widf + 3;
	endforeach;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doFormLoad" id="728b2b93-340e-4cb5-8b5f-eaf7b4eed61d">
        <updating/>
        <source>doFormLoad() updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
begin
	self.colours.add(self.label_1.backColor);
	self.colours.add(self.label_2.backColor);
	self.colours.add(self.label_3.backColor);
	self.colours.add(self.label_4.backColor);
	self.colours.add(self.label_5.backColor);
	self.colours.add(self.label_6.backColor);
	self.beginTimer(200, Timer_Continuous, 0);
	
end;</source>
    </JadeMethod>
