    <JadeMethod name="setDateTimeToNow" id="135f0414-1c65-4fb5-82d3-5ac1e1ecfa81">
        <source>setDateTimeToNow();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/11/2024	navkc1 JIRA Story MTN-19092: EUP | 54014 - Work Orders Enhancements - Improved Search and usability

*/

vars
	now : TimeStamp;
	
begin

	// Required Date From
	self.mskRequestlDT.setDate(now.date());
	self.mskRequestTM.setTime("00:00".asTimeJMT());
	// Required Date To
	self.mskRequestToDT.setDate(now.date());
	self.mskRequestToTM.setTime("23:59".asTimeJMT());
	// Creation Date From
	self.mskRequestedByFromDT.setDate(now.date());
	
	self.mskRequestedByFromTM.setTime("00:00".asTimeJMT());
	// Creation Date To
	self.mskRequestedByToDT.setDate(now.date());
	self.mskRequestedByToTM.setTime("23:59".asTimeJMT());
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setDefaults" id="49885da8-d0b7-49cf-9710-eec324bc211c">
        <updating/>
        <source>setDefaults()updating ,protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 August 2009	cnwmd1	Initial creation
05 Oct 2019	cnwma1	Bug 46906: PEL1 - Urgent Error Max Table Row Work Order
*/

vars

begin

	self.optEnqWorkOrder.value := true; //Default to work order view
	
	//05.10.2019 cnwma1 #46906 
	self.setEnquiryType();
	self.initTblData();	
	
	if self.isEnqType_WorkOrder() then
		self.setCaption( app.getErrorString(Work_order) &amp; " " &amp; app.getErrorString(Enquiry) );
	elseif self.isEnqType_Task() then
		self.setCaption(app.getErrorString(Task) &amp; " " &amp; app.getErrorString(Enquiry));
	endif;
	self.setNavigatorHeading(self.caption);
	
	self.setStatusCaption();
	//self.optEnqWorkOrder.click(self.optEnqWorkOrder); //show table columns for work order  //05.10.2019 cnwma1 #46906
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
