    <JadeMethod name="getDestination" id="c3d30a0c-5e05-43ed-8e18-9f0eaf9f33e3">
        <source>getDestination() : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 January 2010	cnwndl1	Initial creation	CCMS MES 1004

*/

vars

	destinationPortCode : String;
	destinationPort : CM_Port;
	
begin

	if self.myTrackedItem &lt;&gt; null then
		destinationPortCode := self.myTrackedItem.destinationPort;
	elseif self.myBookingRef &lt;&gt; null then
		destinationPortCode := self.myBookingRef.destinationPort;
	elseif self.myBOL &lt;&gt; null then
		destinationPortCode := self.myBOL.destinationPort;
	elseif self.myGateReceival &lt;&gt; null then
		destinationPortCode := self.myGateReceival.destinationPort;
	elseif self.myGateReceivalByType &lt;&gt; null then			// 10/12/2010 cnwmh5 #26556
		destinationPortCode := self.myGateReceivalByType.myReceivalInfo.myBooking.destinationPort;
	endif;
	
	if destinationPortCode &lt;&gt; null then
		destinationPort := app.myRoot.allPorts[destinationPortCode];
		if destinationPort &lt;&gt; null then
			return app.getErrorString(Destination_Port) &amp; "  =  " &amp;destinationPort.getDisplayDetails(false);
		endif;
	else
		destinationPortCode := " ";
	endif;
	
	return app.getErrorString(Destination_Port) &amp; "  =  " &amp;destinationPortCode;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDischarge" id="c655be95-e2e2-4eba-bed6-179f68b6ea2f">
