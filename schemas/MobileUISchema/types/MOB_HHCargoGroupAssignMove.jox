    <JadeMethod name="populateCmbNotifiedCargoGroups" id="94c78cc8-1a92-4e4b-bf26-e6f23498035c">
        <updating/>
        <source>populateCmbNotifiedCargoGroups( _cgAssign : CM_CargoGroupAssignment; _selectedCargoGroup : CM_CargoGroup ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 July 2015	cnwndl1	Initial creation	Par 36608

*/

vars

	index : Integer;
	startIndex : Integer;
	cargoGroup : CM_CargoGroup;
	firstEnabledIndex : Integer;
	
	allCargoGroupsByIdDict : CM_TIByIdCargoTypeDict;	//02 Oct 2018	NDL	TFS 39186
	ti : CM_TrackedItem;		//02 Oct 2018	NDL	TFS 39186

begin

	if _selectedCargoGroup = null then
		
		self.cmbNotifyCGroup.clear();
		self.cmbNotifyCGroup.enabled := false;
		self.cmbNotifyCGroup.sorted := false;
		
		if _cgAssign &lt;&gt; null then
			startIndex := -1;
			if _cgAssign.isPreAssigned then
				//ALL cargo is pre-assigned to the cargo groups
				//selecting the 'cargo item id', will select the 'cargo group id'
			elseif _cgAssign.isSelectable then
				//let the user select the 'cargo group id' to assign the cargo to,
				// but when selecting the cargo id, if it is associated with a cargo group id,
				//then override the user selection.
				self.cmbNotifyCGroup.enabled := true;
				self.cmbNotifyCGroup.addItem( "&lt;Please select a Cargo Group&gt;" );
				startIndex := 1;
				firstEnabledIndex := 1;
			endif;
		
			create allCargoGroupsByIdDict transient;
			_cgAssign.getAllCargoGroupsByIdDict( allCargoGroupsByIdDict );
			
			foreach ti in allCargoGroupsByIdDict do
				cargoGroup := ti.CM_CargoGroup;
				//cargoGroup := self.myTerminal.getCargoGroupItem( notifyGroup.id );	//21 Sep 2015	NDL	Par 36338
				if cargoGroup &lt;&gt; null and cargoGroup.isComplete then	//21 Sep 2015	NDL	Par 36338
					index := self.cmbNotifyCGroup.addItem( cargoGroup.id &amp; "- " &amp; app.getErrorString(Complete) );
					self.cmbNotifyCGroup.itemObject[ index ] := cargoGroup;
					self.cmbNotifyCGroup.itemEnabled[ index ] := false;
				elseif cargoGroup.allPreAssignedCargoIdsDict.isEmpty then
					index := self.cmbNotifyCGroup.addItem( cargoGroup.id );
					self.cmbNotifyCGroup.itemObject[ index ] := cargoGroup;
					self.cmbNotifyCGroup.itemEnabled[ index ] := true;
					if firstEnabledIndex = 1 then
						firstEnabledIndex := index;
					endif;
				else
					index := self.cmbNotifyCGroup.addItem( cargoGroup.id &amp; "- " &amp; app.getErrorString(Preassigned_cargo) );
					self.cmbNotifyCGroup.itemObject[ index ] := cargoGroup;
					self.cmbNotifyCGroup.itemEnabled[ index ] := false;
				endif;
			endforeach;
		
		else
			self.cmbNotifyCGroup.addItem( "&lt;No Cargo Groups Available&gt;" );
			startIndex := 1;
		
		endif;
		
		if firstEnabledIndex &gt; 1 then
			self.cmbNotifyCGroup.listIndex := firstEnabledIndex;
		else
			self.cmbNotifyCGroup.listIndex := startIndex;
		endif;
	
	elseif _selectedCargoGroup &lt;&gt; null then
		if _selectedCargoGroup.isComplete then	//21 Sep 2015	NDL	Par 36338
			self.populateCmbNotifiedCargoGroups( self.myCargoGroupAssignment, null );
		else
			self.cmbNotifyCGroup.listIndex := self.cmbNotifyCGroup.findObject( _selectedCargoGroup );
		endif;

	endif;
	
	cargoGroup := self.cmbNotifyCGroup.listObject.CM_CargoGroup;
	
	self.setMyCargoGroup( cargoGroup );
	
	self.txtLocation.text := null;
	
	if self.myCargoGroup &lt;&gt; null and self.myCargoGroup.getLastOnsiteLocation() &lt;&gt; null then
		//pre-populate with the last location actually used if possible
		self.txtLocation.text := self.myCargoGroup.getLastOnsiteLocation().getFullId;
	endif;
	
	self.txtLocation_lostFocus( self.txtLocation );
	
	
	
epilog

	delete allCargoGroupsByIdDict;

end;</source>
        <Parameter name="_cgAssign" type="CM_CargoGroupAssignment"/>
        <Parameter name="_selectedCargoGroup" type="CM_CargoGroup"/>
    </JadeMethod>
    <JadeMethod name="populateTrackedItem" id="ba14ebf9-b45c-45b4-a803-e93c3656a318">
        <updating/>
        <source>populateTrackedItem() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 June 2015	cnwndl1	Initial creation

*/

vars

	desc1 : String;
	desc2 : String;
	weightStr : String;

begin

	if self.myAssignCargoItem &lt;&gt; null then
		self.txtCargoId.text := self.myAssignCargoItem.id;
		self.convertedCargoId := self.myAssignCargoItem.id;	//08 Jul 2016	NDL	TFS 2275 / 2216
		self.convertedAltId := self.myAssignCargoItem.alternativeId;		//08 Jul 2016	NDL	TFS 2275 / 2216
		
		self.myAssignCargoItem.getShortDescriptions( desc1, desc2 );
		//27 Oct 2015	NDL	Par 36608 - Email from Shane 21/10/15
		weightStr := self.myAssignCargoItem.getDefaultTotalWeightDisplay;
		self.lblCargoType.caption := weightStr &amp; " " &amp; desc1;
	//	self.lblCargoType.caption := desc1;
		self.lblCargoDesc.caption := desc2;
		
	else
		self.txtCargoId.text := self.lblCargoId.caption.toUpper;
		self.convertedCargoId := null;	//08 Jul 2016	NDL	TFS 2275 / 2216
		self.convertedAltId := null;		//08 Jul 2016	NDL	TFS 2275 / 2216
		
		self.lblCargoType.caption := null;
		self.lblCargoDesc.caption := null;
		
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="selectAssignCargoItem" id="ebd7a5fa-46ea-4732-837c-57ee9e08c470">
        <updating/>
        <source>selectAssignCargoItem( _manual : Boolean ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 June 2015	cnwndl1	Initial creation	Par 36338

*/

vars

	altIdStr : String;	//08 Jul 2016	NDL	TFS 2275 / 2216
	altIdLength : Integer;
	cargoIdStr : String;	//08 Jul 2016	NDL	TFS 2275 / 2216
	firstTi : CM_TrackedItem;
	iter : Iterator;
	selectedTi : CM_TrackedItem;
	errMsg : String;
		
	cargoIdLength : Integer;	
	cargoIdReversed : String;
	obj : CM_Object;
	cargoGroup : CM_CargoGroup;
	msg : String;
	autoSelectedNext : Boolean;	//15 Aug 2018	NDL	TFS 40119
	
	nextAvailCargoGroup : CM_CargoGroup;
	allCargoGroupsByIdDict : CM_TIByIdCargoTypeDict;	//02 Oct 2018	NDL	TFS 39186
	
begin

	cargoGroup := self.cmbNotifyCGroup.listObject.CM_CargoGroup;

	self.setMyTrackedItem( null );
	
	cargoIdStr := self.convertedCargoId;	//08 Jul 2016	NDL	TFS 2275 / 2216
	altIdStr := self.convertedAltId;	//08 Jul 2016	NDL	TFS 2275 / 2216
	if cargoIdStr = lblCargoId.caption.toUpper then
		cargoIdStr := null;
	endif;
	
	if self.myCargoGroupAssignment &lt;&gt; null then
		obj := self.myCargoGroupAssignment.getAssignedObject( cargoIdStr );
		if obj = null then
			self.msgBox("Cargo '" &amp; cargoIdStr &amp; "' not part of Cargo Group Assignment",app.getErrorString(Warning), MsgBox_OK_Only, false);
			self.populateTrackedItem();
			return;
		elseif obj.isKindOf(CM_CargoGroupAssignment) then
		//	self.populateCmbNotifiedCargoGroups( obj.CM_CargoGroupAssignment, null );
			self.populateCmbNotifiedCargoGroups( obj.CM_CargoGroupAssignment, cargoGroup );	//18 Oct 2018	NDL	TFS 40119
		elseif obj.isKindOf(CM_CargoGroup) then
			self.populateCmbNotifiedCargoGroups( null, obj.CM_CargoGroup );
		endif;
	endif;
	
	if cargoIdStr &lt;&gt; null then
	
		altIdLength := altIdStr.length;
		cargoIdLength := cargoIdStr.length;
		
		firstTi := self.myTerminal.allOnsiteTIsByIdCargoType.getAtKeyGeq( cargoIdStr, null );
		if firstTi &lt;&gt; null and firstTi.id[1:cargoIdLength] = cargoIdStr then	
			selectedTi := firstTi;
		endif;
		
		if selectedTi = null and altIdLength &gt; 0 then
			firstTi := self.myTerminal.allOnsiteTIsByAlternativeId.getAtKeyGeq(altIdStr);
			if firstTi &lt;&gt; null and firstTi.alternativeId[1:altIdLength] = altIdStr then	
				selectedTi := firstTi;
			endif;
		endif;
		
		//06 Jul 2018	NDL	TFS 39186
		if selectedTi &lt;&gt; null
		and self.myCargoGroupAssignment &lt;&gt; null
		and self.myCargoGroupAssignment.allProcessedTis.includes( selectedTi )
		and selectedTi.myCargoGroup &lt;&gt; null
		then
			errMsg := app.getErrorString2( Cargo_item_already_assigne, selectedTi.id, selectedTi.myCargoGroup.id );
			self.msgBox(errMsg,app.getErrorString(Error), MsgBox_OK_Only, false);
			self.txtCargoId.text := self.lblCargoId.caption.toUpper;
			self.setMyTrackedItem( null );
			return;
		endif;
		
		//30 Jul 2018	NDL	TFS 39186
		if selectedTi &lt;&gt; null then
			if cargoGroup = null then
				//Can be if all cargo is pre-assigned
				obj  := self.myCargoGroupAssignment.getAssignedObject( selectedTi.id );
				if obj &lt;&gt; null and obj.isKindOf( CM_CargoGroup ) then
					cargoGroup := obj.CM_CargoGroup;
				endif;
			//	cargoGroup := self.myCargoGroupAssignment.getAssignedObject( selectedTi.id ).CM_CargoGroup;
				if cargoGroup &lt;&gt; null then
					self.cmbNotifyCGroup.listIndex := self.cmbNotifyCGroup.findObject( cargoGroup );
				else
					self.msgBox( app.getErrorString(Must_select_notifi_cargo_group), app.getErrorString(Warning), MsgBox_OK_Only, false );
					self.populateCmbNotifiedCargoGroups( self.myCargoGroupAssignment, null );
					return;
				endif;
			endif;
			
	/*		if cargoGroup &lt;&gt; null then
				if cargoGroup.totalWeight + selectedTi.totalWeight &gt; cargoGroup.maxWeight then
					nextAvailCargoGroup := self.myCargoGroupAssignment.getNextCargoGroup( cargoGroup, selectedTi );
				
					if nextAvailCargoGroup = null then
						//msg := "This would exceed the maximum weight of '" &amp; cg.id &amp; "'. Unable to find the next Cargo Group to use.";
						msg := app.getErrorString1( This_would_excee_maxim_weigh_u, cargoGroup.id );
						app.msgBox( msg, app.getErrorString( Warning ), MsgBox_OK_Only);
					elseif cargoGroup.totalWeight &lt; cargoGroup.minWeight then
						//msg := "This would exceed the maximum weight of '" &amp; cg.id &amp; "', but it can not be closed because it is currently below its minimum weight. '";
						msg := app.getErrorString1( This_would_excee_maxim_weigh_n, cargoGroup.id );
						app.msgBox( msg, app.getErrorString( Warning ), MsgBox_OK_Only);
					else
						//msg := "This would exceed the maximum weight of '" &amp; cg.id &amp; "' it will be completed. The next available Cargo Group in the assignment will be auto selected.";
						msg := app.getErrorString1( This_would_excee_maxim_weigh_w, cargoGroup.id );
						app.msgBox( msg, app.getErrorString( Warning ), MsgBox_OK_Only);
						
						app.myTrxUA.trxCargoGroupComplete( cargoGroup, app.myPassport );
		
						if app.myPassport.trxCompletedOK then
							app.myPassport.clearErrorsWarnings;
						endif;
						
						self.cmbNotifyCGroup.listIndex := self.cmbNotifyCGroup.findObject( nextAvailCargoGroup );
						self.cmbNotifyCGroup.click( self.cmbNotifyCGroup );
						autoSelectedNext := true;	//15 Aug 2018	NDL	TFS 40119
						
					endif;
					
				endif;
			endif; */
		endif;
				
	endif;	
	
	
	//30 Jul 2018	NDL	TFS 39186
	if selectedTi &lt;&gt; null then
	
		self.setMyTrackedItem( selectedTi );
		self.populateTrackedItem();
		
		if autoSelectedNext then	//15 Aug 2018	NDL	TFS 40119
			return;
		endif;
		
	endif;
	
	if selectedTi = null then
		errMsg := app.getErrorString1( Cargo_item_not_found_site, cargoIdStr );
		self.msgBox(errMsg,app.getErrorString(Warning), MsgBox_OK_Only, false);
		self.populateCmbNotifiedCargoGroups( self.myCargoGroupAssignment, null );
		self.txtCargoId.setFocus();
	else
		if selectedTi.myCargoGroup = null then
			create allCargoGroupsByIdDict transient;
			if cargoGroup &lt;&gt; null and self.myCargoGroupAssignment &lt;&gt; null then
				self.myCargoGroupAssignment.getAllCargoGroupsByIdDict( allCargoGroupsByIdDict );
		
				if allCargoGroupsByIdDict.includes( cargoGroup )
				and ( cargoGroup.preAssignedCargoIdsInclude( selectedTi.id ) or  ( cargoGroup.allPreAssignedCargoIdsDict.isEmpty and not self.myCargoGroupAssignment.cargoIdsInclude( selectedTi.id ) ) )
				then
					self.populateCmbNotifiedCargoGroups( null, cargoGroup );
				endif;
			
			endif;
		else
			self.populateCmbNotifiedCargoGroups( null, selectedTi.myCargoGroup );
			errMsg := app.getErrorString2( Cargo_item_already_assigne, selectedTi.id, selectedTi.myCargoGroup.id );
			self.msgBox(errMsg,app.getErrorString(Warning), MsgBox_OK_Only, false);
		endif;
	endif;

epilog

	delete iter;
	delete allCargoGroupsByIdDict;

end;</source>
        <Parameter name="_manual" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMyCargoGroup" id="e63dc014-7b6c-4d10-814c-687ac9520d25">
        <updating/>
        <source>setMyCargoGroup( _cargoGroup : CM_CargoGroup )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 June 2015	cnwndl1	Initial creation

*/

vars

begin

	if _cargoGroup &lt;&gt; null and ( not _cargoGroup.isComplete ) then	//21 Sep 2015	NDL	Par 36338
		self.myCargoGroup := _cargoGroup;
	else
		self.myCargoGroup := null;
	endif;

	if self.myCargoGroup &lt;&gt; null then
		self.cmbNotifyCGroup.listIndex := self.cmbNotifyCGroup.findObject( self.myCargoGroup );
		self.lblCGroupDesc.caption := self.myCargoGroup.remarks;
	else
		self.lblCGroupDesc.caption := null;
	endif;
	
	self.setWeightAndCount();

epilog

end;</source>
        <Parameter name="_cargoGroup" type="CM_CargoGroup"/>
    </JadeMethod>
    <JadeMethod name="setMyCargoGroupAssignmentObj" id="bb218dc8-9349-4b69-bd31-89460934c493">
        <updating/>
        <source>setMyCargoGroupAssignmentObj( cgAssign : CM_CargoGroupAssignment ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 July 2015	cnwndl1	Initial creation	Par 36608

*/

vars

	cargoGroup : CM_CargoGroup;

begin

	if self.myCargoGroupAssignment &lt;&gt; cgAssign or cgAssign = null then
		
		self.myCargoGroupAssignment := cgAssign;
		self.populateCmbNotifiedCargoGroups( cgAssign, null );
		
		self.myAssignCargoItem := null;
		self.populateTrackedItem();
	
	endif;
	
	if self.myCargoGroupAssignment &lt;&gt; null then
		self.lblProgress.caption := self.myCargoGroupAssignment.getProgressCount;
	else
		self.lblProgress.caption := null;
	endif;
	
	//06 Jul 2018	NDL	TFS 39186
	self.btnTwo.enabled := self.myCargoGroupAssignment &lt;&gt; null;

epilog

end;</source>
        <Parameter name="cgAssign" type="CM_CargoGroupAssignment"/>
    </JadeMethod>
    <JadeMethod name="setMyTrackedItem" id="3fae249f-a286-4189-9c91-835e188d10f7">
        <updating/>
        <source>setMyTrackedItem( _ti : CM_TrackedItem ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 June 2015	cnwndl1	Initial creation	Par 36338

*/

vars

begin

	self.getSessionAgent().setMySelectedTI( _ti );
	app.myMobileCargoFindAgent.setMyTrackedItemToProcess( null );
	self.myAssignCargoItem := _ti;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setWeightAndCount" id="23135399-6976-4a79-9f43-4429c510fa0d">
        <source>setWeightAndCount();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05/06/2015	cnwndl1	Initial creation	Par 36338
16/01/2018	jlgdap1	TFS 36658 STWR Cargo Scanning Enhancements
*/

vars

//	notifyGroup : CM_NotifiedCargoGroup;
	minWeight : Decimal [16,4];
	totalWeight : Decimal [16,4];
	maxWeight : Decimal [16,4];
	totalQuantity : Integer;
	weightUnitStr : String; 
	diff : Decimal [16,4];
	
	cargoGroup : CM_CargoGroup;

begin

	cargoGroup := self.cmbNotifyCGroup.listObject.CM_CargoGroup;

	if self.myCargoGroup &lt;&gt; null then	
		totalWeight := self.myCargoGroup.totalWeight;
		totalQuantity := self.myCargoGroup.totalQuantity;
		minWeight := self.myCargoGroup.minWeight;
		maxWeight := self.myCargoGroup.maxWeight;
	
//	elseif notifyGroup &lt;&gt; null then
//		totalWeight := 0;
//		totalQuantity := 0;
//		minWeight := notifyGroup.minWeight;
//		maxWeight := notifyGroup.maxWeight;
		
	elseif cargoGroup &lt;&gt; null then
		totalWeight := cargoGroup.totalWeight;
		totalQuantity := cargoGroup.totalQuantity;
		minWeight := cargoGroup.minWeight;
		maxWeight := cargoGroup.maxWeight;
		
	else
		totalWeight := 0;
		totalQuantity := 0;
		minWeight := 0;
		maxWeight := 0;
		
	endif;
	
	if maxWeight &gt; 0 then
		if maxWeight &gt; totalWeight then
			diff := maxWeight - totalWeight;
		endif;
	endif;
	
	weightUnitStr := self.myMobileDataAgent.getMeasureLabelUnit(null,Type_Weight);
	if totalWeight &gt; 0 then
		lblWeightValue.caption := app.getErrorString(Group_weight) &amp; " : " &amp; self.myMobileDataAgent.getMeasureConvertedForDisplay(null, Type_Weight, totalWeight) &amp; weightUnitStr;
	else
		lblWeightValue.caption := app.getErrorString(Group_weight) &amp; " : " &amp; weightUnitStr;
	endif;
	
	if totalQuantity &gt; 0 then
		lblCountValue.caption := app.getErrorString(Count) &amp; " : " &amp; totalQuantity.String;
	else
		lblCountValue.caption := app.getErrorString(Count) &amp; " : ";
	endif;
	if cargoGroup &lt;&gt; null and not cargoGroup.allPreAssignedCargoIdsDict.isEmpty then	//02 Oct 2018	NDL	TFS 39186										// TFS 36658
		if totalQuantity &lt;= 0 then																								// TFS 36658
			self.lblCountValue.caption := self.lblCountValue.caption &amp; "0";														// TFS 36658
		endif;																													// TFS 36658
		self.lblCountValue.caption := self.lblCountValue.caption &amp; " of " &amp; cargoGroup.allPreAssignedCargoIdsDict.size.String;	// TFS 36658
	endif;																														// TFS 36658
	
	if minWeight = 0 and maxWeight = 0 then
		lblWeightRange.caption := null;
	elseif minWeight &gt; 0 and maxWeight &gt; 0 then
		lblWeightRange.caption := self.myMobileDataAgent.getMeasureConvertedForDisplay(null, Type_Weight, minWeight) &amp; " - " &amp; self.myMobileDataAgent.getMeasureConvertedForDisplay(null, Type_Weight, maxWeight);
	elseif minWeight &gt; 0 then
		lblWeightRange.caption := self.myMobileDataAgent.getMeasureConvertedForDisplay(null, Type_Weight, minWeight) &amp; " - ???";
	elseif maxWeight &gt; 0 then
		lblWeightRange.caption := "0 - " &amp; self.myMobileDataAgent.getMeasureConvertedForDisplay(null, Type_Weight, maxWeight);
	endif;
	
	if diff &gt; 0 then
		lblWeightRange.caption := lblWeightRange.caption &amp; " [" &amp; self.myMobileDataAgent.getMeasureConvertedForDisplay(null, Type_Weight, diff) &amp; "]"; 
	endif;
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupControls" id="90c13fda-93f4-49b9-8341-c5973772d96a">
        <updating/>
        <source>setupControls() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 June 2015	cnwndl1	Initial creation	Par 36338
06 July 2018	NDL	TFS 39186

*/

vars

	cga : CM_CargoGroupAssignment;
//	cgn : CM_NotifiedCargoGroup;
	cg : CM_CargoGroup;

begin

	self.doResizeControls(true);
	
	cga := self.myMobileGenericAgent.myCargoGroupAssignment;
	cg := self.myMobileGenericAgent.myCargoGroup;	//02 Oct 2018	NDL	TFS 39186
//	cgn := self.myMobileGenericAgent.myNotifiedCargoGroup;
	
	self.myMobileGenericAgent.setMyCargoGroupAssignment( null );
	self.myMobileGenericAgent.setMyCargoGroup( null );	//02 Oct 2018	NDL	TFS 39186
//	self.myMobileGenericAgent.setMyNotifiedCargoGroup( null );
	
	if cga &lt;&gt; null then
		self.txtCGAssign.text := cga.id;
	endif;
	
	self.txtCGAssign_lostFocus( self.txtCGAssign );
	self.txtCargoId_lostFocus( self.txtCargoId );
	self.txtLocation_lostFocus( self.txtLocation );
	
	if cg &lt;&gt; null then
		self.cmbNotifyCGroup.listIndex := self.cmbNotifyCGroup.findObject( cg );
		self.cmbNotifyCGroup.click( self.cmbNotifyCGroup );
	endif;
	
	self.locnWarningIssued := false;
		
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="82bd9d07-e5f5-4290-bf50-c3ff2852262f">
        <updating/>
        <source>setupForm() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 June 2015	cnwndl1	Initial creation	Par 36338

*/

vars

	ti : CM_TrackedItem;

begin

	if app.myMobileCargoFindAgent = null then
		create app.myMobileCargoFindAgent transient;
	endif;

	inheritMethod();
	
	self.setupCmdButtons( 3, app.getErrorString(Move), app.getErrorString(Overview), app.getErrorString(Back), null, null );
	
	self.setupControls();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="d21a1b2b-e50a-4f96-8e62-8cf6c8af6991">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 15 August 2015.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0020772, locale);
	lblCGAssign.translateCaption(Xlat_0020773, locale);
	lblCargoId.translateCaption(Xlat_0020774, locale);
	lblCountValue.translateCaption(Xlat_0020775, locale);
	lblGroupId.translateCaption(Xlat_0020776, locale);
	lblLocation.translateCaption(Xlat_0020777, locale);
	lblWeightValue.translateCaption(Xlat_0020778, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="txtCGAssign_gotFocus" id="3f4f4138-1a1e-4d51-a7cf-46fbbb68027b">
        <controlMethod name="TextBox::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtCGAssign_gotFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 July 2015	cnwndl1	Initial creation

*/

vars

begin

	if self.txtCGAssign.text = self.lblCGAssign.caption.toUpper then
		self.txtCGAssign.selStart := 0;
		self.txtCGAssign.selLength := self.lblCGAssign.caption.length;
	endif;

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
