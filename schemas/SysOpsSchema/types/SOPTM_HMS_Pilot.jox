    <JadeMethod name="initShtDataTable1" id="f90643cf-e3a3-4732-8644-f348b49516b6">
        <updating/>
        <source>initShtDataTable1() updating;
// ---------------------------------------------------------------------------
// Created:     18 February 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	sht							: CMUI_Sheet;
	tbl							: CM_DataTable;
	form						: SOP_HMS_TableMaintForm;
begin
//	inheritMethod();\

	form := self.myForm.SOP_HMS_TableMaintForm;
	sht := form.shtDataTable1;
	tbl := form.tblData1;
	
	sht.caption := 'Pilot Resources';
	sht.visible := true;
	
	tbl.rows := 1;
	tbl.columns := 4;
//	tbl.accessColumn(1).inputType := Table.InputType_CheckBox;
	
	tbl.accessCell(1,1).text := 'Harbour' &amp; Tab &amp; 
								'Arrival Resource' &amp; Tab &amp; 
								'Departure Resource' &amp; Tab &amp; 
								'Shift Resource';
	
	form.cmbResourceArr.automaticCellControl := true;
	form.cmbResourceDep.automaticCellControl := true;
	form.cmbResourceShift.automaticCellControl := true;
	
	// this should really be done by calling the superclass method !!!
	self.myForm.frmTBDataTable1.visible	:= false;	// par 19830 concms1 june2009
	
end;</source>
    </JadeMethod>
