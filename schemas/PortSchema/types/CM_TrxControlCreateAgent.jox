    <JadeMethod name="trxCreateBulkBookingRef" id="f3e1470a-4d20-45fb-ba23-1226bdd676b5">
        <updating/>
        <source>trxCreateBulkBookingRef(_pxyBookingRefs		: CM_BookingRefSet input; 
						_realBookingRefs	: CM_BookingRefSet input;
						_passport			: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Mar 2023	navpw1	Initial creation TFS: 56850 (56871)
20 Jul 2023	navdap1	TFS 58923 EUP CallOff EDI Data Type / Data Load
28 May 2024	navdap1	TFS 64315 CUX - System Lock when creating bookings and prenotes via Booking and Cargo APIs
*/

vars
	pxyBookingRef,
	realBookingRef	: CM_BookingRef;
	proxyColl		: CM_ObjectArrayActual;
	proxy			: CM_Object;
	pxyBulkRelease,
	_newBulkRelease : CM_BulkRelease;
	
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);
	
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);
	
	create proxyColl transient;
	
	// Start the transaction
	beginTransaction;
	
	// TFS 64315 lock everything up front
	if app.myPassport.myTerminal &lt;&gt; null then
		self.exclusiveLock(app.myPassport.myTerminal.allBookingRefsByOperatorRef);
		self.exclusiveLock(app.myPassport.myTerminal.allBookingRefsByRef);
	endif;
	foreach pxyBookingRef in _pxyBookingRefs do
		if pxyBookingRef.myVoyage &lt;&gt; null then
			self.exclusiveLock(pxyBookingRef.myVoyage.allBookingRefs);
		endif;
	endforeach;
	// TFS 64315 end
	
	// Perform the operation
	if not _pxyBookingRefs.isEmpty then
		foreach pxyBookingRef in _pxyBookingRefs do
			app.myUtilityCA.utlCreateBookingRef(pxyBookingRef, _passport, null, realBookingRef, proxyColl);
			
			pxyBulkRelease := pxyBookingRef.allReleaseRequests.first.CM_BulkRelease;
			
			if _passport.noErrors() and pxyBulkRelease &lt;&gt; null  then
				app.myUtilityCA.utlCreateBulkRelease(pxyBulkRelease, _newBulkRelease,  realBookingRef, null, null, null, _passport);	// TFS 58923
			endif;
			
			if _passport.noErrors and realBookingRef &lt;&gt; null then	// par 22762 - could be null if there were warnings
				app.myUtilityCA.myCreateAuditAgent.audCreateGeneric(realBookingRef);
			endif;
			
			if proxyColl &lt;&gt; null then
				//these proxies have not been committed yet so if there was an exception then need to remove proxy link
				foreach proxy in proxyColl do
					app.myProxyManager.deleteProxyLink(proxy);
				endforeach;
				
				delete proxyColl;
			endif;
			
			if _passport.noErrors and _realBookingRefs &lt;&gt; null then
				_realBookingRefs.add(realBookingRef);
			endif;
			
		endforeach;
	endif;
	
epilog
	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_pxyBookingRefs" type="CM_BookingRefSet" usage="input"/>
        <Parameter name="_realBookingRefs" type="CM_BookingRefSet" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCreateBulkInvLineDescMap" id="98cd280b-79e7-4224-b6cf-018b060ce10a">
        <updating/>
        <source>trxCreateBulkInvLineDescMap(_pxyCreateInvLineDescMappings, 
								_pxyUpdateInvLineDescMappings	: CM_InvLineDescMapByDebtorLType input; 
								_pxyDeleteInvLineDescMappings	: CM_InvLineDescMapByDebtorLType io;
								_realCreateInvLineDescMappings	: CM_InvLineDescMapByDebtorLType output;
								_passport						: CM_Passport input
								) updating;
/*

Purpose:			Creates, Updates and Deletes invoice line mapping data for a bulk update. Depending on what is needed

Parameters:			_pxyCreateInvLineDescMappings	CM_InvLineDescMapByDebtorLType	The proxy invoice line mappings to create
					_pxyUpdateInvLineDescMappings	CM_InvLineDescMapByDebtorLType	The proxy invoice line mappings to update
					_pxyDeleteInvLineDescMappings	CM_InvLineDescMapByDebtorLType	The proxy invoice line mappings to delete (proxy/transient collection contains real objects)
					_realCreateInvLineDescMappings	CM_InvLineDescMapByDebtorLType	The real invoice line mappings that were created
					_passport						CM_Passport						The passport to use the transaction

Return Value:		NONE

Date		Who		Reason
10 October 2022	navpw1	Initial creation TFS: 54566

*/

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);
	
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;
	
	// Perform the operation
	if not _pxyCreateInvLineDescMappings.isEmpty then
		app.myUtilityCA.utlCreateBulkInvLineDescMap(_pxyCreateInvLineDescMappings, _realCreateInvLineDescMappings, _passport);
	endif;
	
	if not _pxyUpdateInvLineDescMappings.isEmpty then
		app.myUtilityUA.utlUpdateBulkInvLineDescMap(_pxyUpdateInvLineDescMappings, _passport);
	endif;
	
	if not _pxyDeleteInvLineDescMappings.isEmpty then
		app.myUtilityDA.utlDeleteBulkInvLineDescMap(_pxyDeleteInvLineDescMappings, _passport);
	endif;
	
epilog
	self.finaliseActivityWithPassport(_passport);
	
end;</source>
        <Parameter name="_pxyCreateInvLineDescMappings" type="CM_InvLineDescMapByDebtorLType" usage="input"/>
        <Parameter name="_pxyUpdateInvLineDescMappings" type="CM_InvLineDescMapByDebtorLType" usage="input"/>
        <Parameter name="_pxyDeleteInvLineDescMappings" type="CM_InvLineDescMapByDebtorLType" usage="io"/>
        <Parameter name="_realCreateInvLineDescMappings" type="CM_InvLineDescMapByDebtorLType" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCreateBulkRelease" id="5078631e-452f-4aaa-9b24-d88e1ec12f6f">
        <updating/>
        <source>trxCreateBulkRelease(_pxyReleaseRequest : CM_BulkRelease input; 
					_newReleaseRequest : CM_BulkRelease output;
					_allTIPins : CM_StringDict;  //cnwrd1 par 25594 10.12.2010
					_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     21 February 2001 by cnwrs2
//
// Parameters:  _pxyReleaseRequest	- the proxy
//				_newReleaseRequest	- the request that wil be created
//				_allTIPins			- ???
//				_passport			-
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 14/02/2012	cnwcs5		par 28756 - use utlCreateBulkRelease instead of utlCreateBulkRelease_CMIF
//										since we never pass anything in the _cmifBookingRefParameter anyway
// 20/07/2023	navdap1		TFS 58923 EUP CallOff EDI Data Type / Data Load
// 15/07/2025	navcs2	MTN-35210 Add Deferred Updates for WO Transaction During Transport Manifest and Call-Off Loading to Reduce Deadlocks 
// ---------------------------------------------------------------------------
vars

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Set to use deffered updates
	_passport.useWOTransactionDeferUpdate := true;							// 15/07/2025	navcs2	MTN-35210
	_passport.useTITransactionDeferUpdate := true;							// 15/07/2025	navcs2	MTN-35210
	
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	beginTransaction;
	
	app.myUtilityCA.utlCreateBulkRelease (_pxyReleaseRequest, _newReleaseRequest, null, null, _allTIPins, null, _passport);		// TFS 58923
epilog
	if _passport.noErrors() then				// 15/07/2025	navcs2	MTN-35210
		_passport.doDeferredUpdates();			// 15/07/2025	navcs2	MTN-35210	
	endif;										// 15/07/2025	navcs2	MTN-35210
	
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_pxyReleaseRequest" type="CM_BulkRelease" usage="input"/>
        <Parameter name="_newReleaseRequest" type="CM_BulkRelease" usage="output"/>
        <Parameter name="_allTIPins" type="CM_StringDict"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
