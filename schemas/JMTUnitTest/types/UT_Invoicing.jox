	fileContent := 'TranMap Type,TranMap Name,CargoType,Cargo Subtype Group,Cargo Subtype,IMEX,Contents Status,Commodity,Transaction,MoveType,Debtor,Quantity Type,Quantity Range,Invoice Line,Over Dimsn?,Trans Ship?,Is 40?,Is Reefer?,Req Temp?,RORO?,Is 45?,Is 30?,Is 53?,Is Child?' &amp; CrLf &amp;
						'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),Import,(Default),(Default),Storage,,(Default),CCT108 Days Since First Discharge »,00 to 5,UT_LineTypeStore1' &amp; CrLf &amp; 
						'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),Import,(Default),(Default),Storage,,(Default),CCT108 Days Since First Discharge »,06 to 9,UT_LineTypeStore2' &amp; CrLf &amp; 
						'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),Import,(Default),(Default),Storage,,(Default),CCT108 Days Since First Discharge »,10 to 15,UT_LineTypeStore3' &amp; CrLf &amp; 
						'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),Import,(Default),(Default),Storage,,(Default),CCT108 Days Since First Discharge »,16 to MAX,UT_LineTypeStore4' &amp; CrLf;

	
	self.transactionMapLoad(fileContent, fileName);
