    <JadeMethod name="setWeekStartsOn" id="bf68e908-7131-4125-8dd5-eada14e2239f">
        <updating/>
        <source>setWeekStartsOn(pValue: Integer) updating;
// --------------------------------------------------------------------------------
// Created:		04 February 2000 by cnwdad1
//
// Purpose:		Sets the day of the week that is the first day shown.
//
// Parameters:	pValue - The day number that starts the week.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.weekStartsOn &lt;&gt; pValue then 
		self.weekStartsOn	:= pValue;
		self.redrawSelf();
	endif;
end;</source>
        <Parameter name="pValue" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="68bd23b3-b4c4-408e-8546-4e42eba261f7">
        <updating/>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	dateToday	: Date;

begin
	inheritMethod(cntrl, persistCntrl);

	if self.isLockRight or self.isStretchWidth then
 		self.distanceFromRight	:=	persistCntrl.parent.width - persistCntrl.width - persistCntrl.left;
 	endif;

	if self.isLockBottom or self.isStretchHeight then
		self.distanceFromBottom	:=	persistCntrl.parent.height - persistCntrl.height - persistCntrl.top;
	endif;

	self.borderStyle := BorderStyle_Single;

	// Create all child conttrols (one-time only).
	
	self.buildSelf();

	// Draw with current month by default.
	
	self.currentMonth	:= dateToday.month;
	self.currentYear	:= dateToday.year;

	self.redrawSelf();
end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
    <DevControlTypes name="JSSCalendar">
        <windowClass>AlBaseControl</windowClass>
        <DevControlProperties name="availableColor">
            <cntrlType>color</cntrlType>
        </DevControlProperties>
        <DevControlProperties name="availableTextColor">
            <cntrlType>color</cntrlType>
        </DevControlProperties>
        <DevControlProperties name="backBrush">
            <cntrlType>picture</cntrlType>
        </DevControlProperties>
        <DevControlProperties name="backBrushStyle">
            <cntrlType>list</cntrlType>
            <optionsList>
                <value>0 - tile</value>
                <value>1 - stretch</value>
                <value>2 - center</value>
                <value>3 - stretch proportional</value>
            </optionsList>
        </DevControlProperties>
        <DevControlProperties name="backColor">
            <cntrlType>color</cntrlType>
        </DevControlProperties>
        <DevControlProperties name="borderColorSingle">
            <cntrlType>color</cntrlType>
        </DevControlProperties>
        <DevControlProperties name="borderStyle">
            <cntrlType>list</cntrlType>
            <optionsList>
                <value>0 - None</value>
                <value>1 - Fixed single</value>
            </optionsList>
        </DevControlProperties>
        <DevControlProperties name="bubbleHelp">
            <cntrlType>multilined-string</cntrlType>
        </DevControlProperties>
        <DevControlProperties name="clipControls">
            <cntrlType>boolean</cntrlType>
        </DevControlProperties>
        <DevControlProperties name="description">
            <cntrlType>multilined-string</cntrlType>
        </DevControlProperties>
        <DevControlProperties name="dragCursor">
            <cntrlType>picture</cntrlType>
        </DevControlProperties>
        <DevControlProperties name="enabled">
            <cntrlType>boolean</cntrlType>
        </DevControlProperties>
        <DevControlProperties name="focusBackColor">
            <cntrlType>color</cntrlType>
        </DevControlProperties>
        <DevControlProperties name="focusForeColor">
            <cntrlType>color</cntrlType>
        </DevControlProperties>
        <DevControlProperties name="fontBold">
