    <JadeMethod name="setupForm" id="e1735885-df6b-4b58-9a81-7c675b9330c5">
        <updating/>
        <source>setupForm() updating;
//--------------------------------------------------
// Created:	19 December 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod();

	self.tblExtraInfo.optimiseRowHeight := true;
	self.myDataContainer.headerColour := self.colorHeadingColumn;
	self.myDataContainer.valueColour := self.colorValueColumn;	

		
end;</source>
