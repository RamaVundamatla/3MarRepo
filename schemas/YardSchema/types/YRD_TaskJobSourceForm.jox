		self.tblThumb.hideRowFromHeading(self.tblMain.getHeadingByName(ETRow_MyOperatorGroup));
		self.tblThumb.hideRowFromHeading(self.tblMain.getHeadingByName(ETRow_CarrierCode));
		self.tblThumb.hideRowFromHeading(self.tblExtra.getHeadingByName(ETRow_PowerRequirements));
		self.tblThumb.hideRowFromHeading(self.tblExtra.getHeadingByName(ETRow_HeavyRated));
		self.tblThumb.hideRowFromHeading(self.tblExtra.getHeadingByName(ETRow_DoorsForward));
		self.tblThumb.hideRowFromHeading(self.tblExtra.getHeadingByName(ETRow_RemoveStops));
		self.tblThumb.hideRowFromHeading(self.tblExtra.getHeadingByName(ETRow_FreightPayerCode));
	// Par 17478  - AER 11/07/2008 taken out for consistency with the entire form.
	//	self.tblThumb.setHeadingByHeading(self.tblMain.getHeadingByName(ETRow_ReleaseNo), "Booking Reference"); 
		self.tblThumb.setHeadingByHeading(self.tblExtra.getHeadingByName(ETRow_DeliveryReleaseNumber), "Delivery number");
		self.tblThumb.setHeadingByHeading(self.tblExtra.getHeadingByName(ETRow_EstimatedRequiredDate), "Pack By Date");
		self.tblThumb.setHeadingByHeading(self.tblExtra.getHeadingByName(ETRow_EstimatedRequiredTime), "Pack By Time");
		*/
	//endif;
	
	if app.isSpecial() then
		tblThumb.addItem(br.String);
	endif;
	
	// CCMS 1412
	/*
	if (not self.permissionMaint = PmGteEmptyReleaseMaintAll) then
		tmpStr := self.tblExtra.getHeadingByName(ETRow_PinNo);
		tmpRow := self.tblThumb.getRowFromHeading(tmpStr);
		if tmpRow &gt; 0 and tmpRow &lt;= self.tblThumb.rows then
			self.tblThumb.accessCell(tmpRow, 1).text := tmpStr &amp; Tab &amp; '****';
		endif;
	endif;
	*/
	
	//16/04/2009 cnwdz2 ccms1735
	/*
	if app.isSubTerminalsOn(self.myTerminal) then
		//self.cmbSubTerminal.automaticCellControl	:=	true;
	else
		//self.tblData.hideColumnByColName(ETRow_MySubTerminal);
		heading := self.tblExtra.getHeadingByName(ETRow_MySubTerminal);
		self.tblThumb.hideRowFromHeading(heading);
	endif;
	*/

//	self.tblThumb.fitColumnWidths();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doShowWorkOrderThumb" id="c8deca2a-66cd-4aba-bfd3-041098f1d24d">
        <source>doShowWorkOrderThumb();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 December 2009	cnwrd1	Initial creation

*/

