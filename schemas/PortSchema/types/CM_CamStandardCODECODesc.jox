    <JadeMethod name="includeVoyage" id="f9ac2458-70e8-47b4-8f58-dd92f2cec72e">
        <source>includeVoyage(_camProtocol: CM_CamProtocol; _voyage: CM_Voyage; _trx: CM_Transaction; _camAgent: CM_CamControllerAgent; _logExcluded: Boolean): Boolean protected;

/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 04 March 2019
TFS#		: 41708
Function	: 

*** Changes ***
Date		Name	TFS#	Description
24/04/2019 	jlgka1	43785	STWR - CAMS STANDARD CODECO for Non-Structure Voyage.
****************************************************/
begin
	if _voyage.isBarge or _camProtocol.useCodecoForNonStrucVoyage then 
		return true;
	else
		return inheritMethod(_camProtocol, _voyage, _trx, _camAgent, _logExcluded);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_trx" type="CM_Transaction"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent"/>
        <Parameter name="_logExcluded" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
