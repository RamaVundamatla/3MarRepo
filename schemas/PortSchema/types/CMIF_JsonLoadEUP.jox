    </PrimAttribute>
    <JadeMethod name="setFromDeliveryParty" id="e34452e9-6b55-4fae-ba52-76dcf2062889">
        <updating/>
        <source>setFromDeliveryParty( deliveryParty : CM_DeliveryParty) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 June 2023	jlier1	Initial creation 58839

*/

vars
	deliveryAddress : CM_Address;
begin

	if deliveryParty = null then
		return;
	endif;
		
	if deliveryParty &lt;&gt; null then
		self.number:=deliveryParty.code;
		self.name:=deliveryParty.name;
	endif;
	
	deliveryAddress:=deliveryParty.getDefaultAddress;
	if deliveryAddress &lt;&gt; null then
		self.street:=deliveryAddress.addr1;
		self.street2:=deliveryAddress.addr2;
		self.country:=deliveryAddress.countryCode;
		self.zipcode:=deliveryAddress.postCode;
		self.city:=deliveryAddress.city;
	endif;

epilog

end;</source>
        <Parameter name="deliveryParty" type="CM_DeliveryParty"/>
    </JadeMethod>
</Class>
