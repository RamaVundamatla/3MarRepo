    <JadeMethod name="validateCargo" id="2ad60f9a-1b37-418d-aff1-b608f25c86da">
        <source>validateCargo(_tiSet : CM_TISet input) protected;
// Par 23598 stop drop of non-import cargo
// 19/07/2010	cnwdap1		PAR #25021 review use of isImport/isExport for tranships
vars
	ti		: CM_TrackedItem;
begin
	if _tiSet = null then
		return;
	endif;

	foreach ti in _tiSet do
		if ti.isExport or (ti.isTranshipItem and ti.myExportVoyage &lt;&gt; self.myCurrentVoyage) then		// PAR #25021
			app.raiseCMException2(Status_only_import_cargo, ti.id, ti.getImExStatusString, null, null);
		endif;
	endforeach;
end;
</source>
        <access>protected</access>
        <Parameter name="_tiSet" type="CM_TISet" usage="input"/>
    </JadeMethod>
</GUIClass>
