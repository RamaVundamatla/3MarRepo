    <JadeMethod name="displayLogGrade" id="b5d2be38-829d-4003-99a3-ead53d547560">
        <source>displayLogGrade() protected;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 01 Jun 2010	cnwkpd1		PAR #21914 - Improve legend load performance when loading entire table
vars
	lLogGrade	: CM_LogGrade;
	iter01		: Iterator;
	aDict		: CM_LogGrade;
	anObject	: Object;
	anArray		: ObjectArray;
	tmpCodeGrp	: CM_CodeGroup;
	codeGrps	: CM_CodeGroupSet;
	tmpOperator	: CM_Operator;
	dac 		: CM_DataAccessController;
	tmpObj		: Object;
	tmpCode		: CM_Code;
	tmpGrade	: CM_Code;

begin
	create codeGrps transient;
	self.myLegendTable.rows := 0;
	self.addRow("Log Grades",Red,null,true);
	self.myLegendTable.fixedRows := 1;
	/*
	dac := app.myPassport.allDataAccessControllers[CM_Operator.name];
	if dac &lt;&gt; null then
		// only load valid grades for the valid operators
		foreach tmpObj in dac.allObjects do
			tmpOperator := tmpObj.CM_Operator;
			tmpCodeGrp := tmpOperator.allCodeGroups[CodeGroup_LogSpecs];
			if tmpCodeGrp &lt;&gt; null then
				if (not codeGrps.includes(tmpCodeGrp)) then
					codeGrps.add(tmpCodeGrp);
				endif;
			endif;
		endforeach;
		
		foreach tmpCodeGrp in codeGrps do
			foreach tmpCode in tmpCodeGrp.allCodes do
				foreach tmpGrade in tmpCode.CM_LogSpecies.allLogGrades do
					self.addRow(tmpGrade.code.trimBlanks, tmpGrade.CM_LogGrade.colour, null);
				endforeach;
			endforeach;
		endforeach;

		return;

	endif;
	self.myLegendTable.rows := 0;
	*/
	create anArray transient;
	
	CM_LogGrade.allInstances(anArray, 1000, false);

	foreach anObject in anArray do
		self.addRow(anObject.CM_LogGrade.code.trimBlanks,anObject.CM_LogGrade.colour,null,false);
	endforeach;
epilog
	delete anArray;
	delete codeGrps;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="displayMTGrade" id="a06315bb-c275-41ed-bae2-c257dd38b206">
        <source>displayMTGrade() protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 12/05/2017	cnwdap1		Initial creation TFS 4416 SNO Dwell Day Legend
//
vars
	mtGrade : CM_MTGrade;
	iter : Iterator;
	
begin
	self.myLegendTable.rows := 0;
	self.addRow(app.getErrorString(AvailabilityGrade), Red, null, true);
	self.myLegendTable.fixedRows := 1;
	
	iter := app.myRoot.allAvailabilityGrades.createIterator;
	
	while iter.next(mtGrade) do
		if mtGrade.isNotAvailableForEntry then
			continue;
		endif;
		self.addRow(mtGrade.description, mtGrade.colour, mtGrade, false);
	endwhile;
	
epilog
	delete iter;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="displayOperator" id="b79fb480-3fea-4313-997b-2fd156ed2d40">
        <source>displayOperator() protected;
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	lOperator : CM_Operator;
	iter01 : Iterator;
	passport : CM_Passport;
	strTerminology : String;
	failedDAC  :CM_DataAccessController;
	
begin
	self.myLegendTable.rows := 0;
	
	strTerminology := app.getTerminologyAlternate(null, null, CM_TerminologyOperator, CM_TermExpressionSingular, 'Operator');
	self.addRow(strTerminology,Red,null,true);
	self.myLegendTable.fixedRows := 1;
	
	passport := app.myPassport;
	iter01 := app.myRoot.allOperators.createIterator;
	
	while iter01.next(lOperator) do
		// sgp 12 June 2003 : only show operator legend if have access to view operator
		if not lOperator.canUserAccessSelf(null, failedDAC, passport) then
			continue;
		endif;
	
		self.addRow(lOperator.code.trimBlanks,lOperator.colour,lOperator,false);
	endwhile;
epilog
	delete iter01;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="displayProduct" id="55c99f49-0ff2-49b0-90c6-09bd2c9c3853">
        <source>displayProduct() protected;
// --------------------------------------------------------------------------------
// Created:		02 December 2005 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	productObj		: CM_Product;
	iteratorObj		: Iterator;
	passportObj		: CM_Passport;
	failedDAC  :CM_DataAccessController;
	
begin
	self.myLegendTable.rows	:=	0;
	self.addRow(app.getErrorString(Product), Red, null,true);
	self.myLegendTable.fixedRows	:=	1;
	
	passportObj	:=	app.myPassport;
	iteratorObj	:=	self.allUsedProducts.createIterator();
	
	while iteratorObj.next(productObj) do
		// sgp 12 June 2003 : only show operator legend if have access to view operator
		if not productObj.canUserAccessSelf(null, failedDAC, passportObj) then
			continue;
		endif;
	
		self.addRow(productObj.code.trimBlanks, productObj.colour, productObj,false);
	endwhile;
epilog
	delete iteratorObj;
end;</source>
        <access>protected</access>
    </JadeMethod>
