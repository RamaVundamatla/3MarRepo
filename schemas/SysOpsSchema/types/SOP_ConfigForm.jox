/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 August 2021	navndl1	Initial creation	TFS 51632

*/

vars

begin

	self.doTableHandlePassword( table.CM_EntryTable, 0, 0 );
	self.currentSelectedRow := self.tblConfig.row; // TFS 52235 2NOV2021 NAVLW1
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblConfig_contextMenu" id="2c33ff07-8876-4ad5-a3f1-879a030eb550">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblConfig_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 March 2011	cnwndl1	Initial creation

*/

vars

begin

	if app.isSpecial then
		self.mnuFindConfig.enabled := true;
		self.mnuFindConfig.visible := true;
		self.popupMenu(mnuContext, x, y);
		return true;
	endif;
	
	return false;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
