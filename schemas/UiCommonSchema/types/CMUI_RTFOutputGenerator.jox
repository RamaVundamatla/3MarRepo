    <JadeMethod name="addHeader" id="ce12e639-f53a-4b5d-8408-52f0845fb894">
        <updating/>
        <source>addHeader(pFrame: Frame) updating;
/*
	Purpose   		to ...
	Parameters  	none
	Returns			nothing
	Preconditions	none
	Note			...
*/
vars

begin
	if pFrame &lt;&gt; null then
		self.allHeaderFrames[allHeaderFrames.size + 1] := pFrame;
	else
		self.allHeaderFrames.clear;
	endif;
end;</source>
        <Parameter name="pFrame" type="Frame"/>
    </JadeMethod>
    <JadeMethod name="close" id="ce960d14-0edf-4a68-a951-90282f2c2bcf">
        <updating/>
        <source>close() updating;

begin
	if self.myOutputFile &lt;&gt; null then
		if self.myOutputFile.isOpen then
			if self.discardOutput then
				self.myOutputFile.purge;
			else
				self.myOutputFile.writeBinary("}".Binary);
				self.myOutputFile.close;
			endif;
		endif;
		delete self.myOutputFile;
		self.myOutputFile := null;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="colourToRTF" id="18a4bd72-d798-4689-be7e-cfdb967e55d8">
        <source>colourToRTF(pColour : Integer) : String protected;
/* return a string with the RTF representation of the Windows colour integer value parameter */
vars
	red, green, blue, intColour : Integer;
begin
	intColour := pColour;
	
	if intColour &gt; 65535 then
		blue := intColour div 65536;
		intColour := intColour mod 65536;
	else
		blue := 0;
	endif;
	
	if intColour &gt; 255 then
		green := intColour div 256;
		intColour := intColour mod 256;
	else
		green := 0;
	endif;

	red := intColour mod 256;

	return "\red" &amp; red.String &amp; "\green"&amp;green.String &amp; "\blue"&amp; blue.String;
end;</source>
        <access>protected</access>
        <Parameter name="pColour" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="convertRTFString" id="95731bab-3fca-498b-a981-4301e2091313">
        <source>convertRTFString(pString : String) : String protected;
/* return a String of the input string with RTF control characters ('\', '{' and '}') preceded 
   by a '\' character, which acts as an escape, to retain their value and not be taken as a control. */
vars
	intPos,
	  intStart	: Integer;
	strOut,
	str,	
	  strTest	: String;
begin
	intPos := pString.pos("\",1);
	if intPos = 0 then
	   	return pString;
	else
		intStart := intPos;
	endif;
	intPos := pString.pos("{",1);
	if intPos = 0 then
		return pString;
	elseif intStart &lt; intPos then
		intStart := intPos;
	endif;
	intPos := pString.pos("}",1);
	if intPos = 0 then
	   	return pString;
	elseif intStart &lt; intPos then
		intStart := intPos;
	endif;

	intPos := intStart;
	if intStart &gt; 1 then
		strOut := pString[1:intStart-1];
	else
		strOut := "";
	endif;
	while intPos &lt;= pString.length do
		strTest := pString[intPos:1];
		if strTest = "\" then
			strOut := strOut &amp; "\\";
		elseif strTest = "{" then
			strOut := strOut &amp; "\{";
		elseif strTest = "}" then
			strOut := strOut &amp; "\}";
		else
			strOut := strOut &amp; strTest;
		endif;
		intPos := intPos + 1;
	endwhile;

	return strOut;
end;</source>
        <access>protected</access>
        <Parameter name="pString" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="create" id="42861748-90b2-4ccc-a09e-2b23ccd4501b">
        <updating/>
        <source>create() updating;
/*
	Purpose   		to ...
	Parameters  	none
	Returns			nothing
	Preconditions	none
	Note			...
*/
vars

begin
	self.firstPage	:= true;
	self.pageNumber	:= 1;
	
	create self.allControlsByFrame transient;
	self.allControlsByFrame.setMembership(DynaDictionary);
	self.allControlsByFrame.addExternalKey(String, 30, false, false);	// frame name
	self.allControlsByFrame.endKeys(false);

end;</source>
    </JadeMethod>
    <JadeMethod name="createControlCollForFrame" id="02231652-a6f4-4bd7-b975-27107ac80219">
        <source>createControlCollForFrame(pFrame :Frame):DynaDictionary protected;
/*
	Purpose   		To create a collection of controls for a frame.  The order
					is that in which the controls will be output
	Parameters  	pFrame	the frame to be printed
	Returns			nothing
	Preconditions	none
	Note			...
*/
vars
	dd			:DynaDictionary;
	intCount	:Integer;
	control		:Control;
begin
	create dd transient;
	dd.setMembership(Control);
	dd.addExternalKey(Integer, 0, false, false);
	dd.addExternalKey(Integer, 0, false, false);
	dd.addExternalKey(Integer, 0, false, false);	// force lines to be before other controls
	dd.endKeys(true);
	
	while intCount &lt; self.myReportForm.controlCount do
		intCount := intCount + 1;
		control := self.myReportForm.controls(intCount);
		if control.parent = pFrame then
			dd.putAtKey(control.top.Integer, control.left.Integer, 1, control);
		endif;
	endwhile;
	
	self.allControlsByFrame.putAtKey(pFrame.name, dd);
	
	return dd;
end;</source>
        <access>protected</access>
        <Parameter name="pFrame" type="Frame"/>
        <ReturnType type="DynaDictionary"/>
    </JadeMethod>
    <JadeMethod name="delete" id="8ad13f8e-17a3-49f7-9d97-c0d999a77caa">
        <updating/>
        <source>delete() updating, protected;
/*
	Purpose   		to ...
	Parameters  	none
	Returns			nothing
	Preconditions	none
	Note			...
*/
vars

begin
	if self.myOutputFile &lt;&gt; null then
		delete self.myOutputFile;
	endif;
	
	self.allControlsByFrame.purge;	// deletes memeber collections
	delete self.allControlsByFrame;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="endSection" id="62ac508f-158f-4291-8db0-81d00d1186c3">
        <updating/>
        <source>endSection() updating;

vars

begin
	myOutputFile.writeBinary(" }".Binary);
end;</source>
    </JadeMethod>
    <JadeMethod name="extractCrLf" id="bac070bb-dc59-4aeb-bea0-e3864d6d3f67">
        <source>extractCrLf(remarks: String) : String;

constants
	Spacer = '\par ';
vars
	pos,
	max:	Integer;
	str: 	String;
begin
	pos := 1;
	max := remarks.length;
	while pos &gt; 0 and pos &lt;= max do
		str := str &amp; remarks.scanUntil(CrLf, pos);
		if pos &lt;&gt; 0 then
			str := str &amp; Spacer;
			pos := pos + 2;
		endif;
	endwhile;	
	
	return 	str;
end;</source>
        <Parameter name="remarks" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="generateFooterRTF" id="bd73e2d8-9d58-429a-8ce6-1aa03ebc88c3">
        <updating/>
        <source>generateFooterRTF() updating, protected;

vars
	strLine		: String;
	obj			: Object;
	frame		: Frame;
begin
	prevFrame := null;
	strLine := strLine &amp; "{\footer \plain \s16 \widctlpar \adjustright ";
	myOutputFile.writeBinary(strLine.Binary);
	foreach obj in self.allFooterFrames do
		frame := obj.Frame;
		generateFrameRTF(frame);
	endforeach;
	myOutputFile.writeBinary(" }".Binary);
	prevFrame := null;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="generateFrameRTF" id="f087d3e9-df4f-478a-bf31-f67e80553c43">
        <updating/>
        <source>generateFrameRTF(pFrame: Frame input) updating, protected;

vars
	control, prevControl		:Control;
	obj							:Object;
	binPicture					:Binary;
	strTabs, strNewLine, fieldOut, strSpaceAfter :String;
	lineOut, fOut				:String;
	prevTop, prevBott			:Real;
	blnFirst, blnTab, blnLine,
	blnNewParagraph				:Boolean;
	dd							:DynaDictionary;
	relLeft, relTop				:Real;
	iter						:Iterator;
begin
	blnFirst := true;

	/*	get all the controls we need to output and order according to their top/left 
		properties so we get them in the order we want to output them */

	dd := self.allControlsByFrame[pFrame.name].DynaDictionary;
	
	if dd = null then
		dd := self.createControlCollForFrame(pFrame);
	endif;
			
	iter := dd.createIterator;
	
	while iter.next(obj) do	
		control 		:= obj.Control;
		relTop			:= control.top;
		relLeft			:= control.left;
		blnTab			:= false;
		blnNewParagraph	:= false;
		
		if relTop &gt;= pFrame.height then
			/*	control is not visible in the frame */
			break;
		endif;

		if not blnFirst then
			/*	first time through there is nothing to write out */
			if relTop &lt;&gt; prevTop then
				/*	this control is not on the same line as the last */
//				or prevControl.isKindOf(HorizontalLine) then	
				/*	lines are always a paragraph of their own */
				/*	write out previous line in this frame */
				if prevControl.isKindOf(Table) then
					myOutputFile.writeBinary((strNewLine &amp; strTabs &amp; lineOut &amp; CrLf).Binary);
				else
					myOutputFile.writeBinary((strNewLine &amp; strTabs &amp; lineOut &amp;  '\par' &amp; CrLf).Binary);
				endif;
				blnNewParagraph := true;
			endif;		
		else
			blnNewParagraph := true;
		endif;
		
		if blnNewParagraph then
			if control.isKindOf(Label) then
				/*	set paragraph height */
				strNewLine	:= "\pard \sl-" &amp; (self.pixelsToTwips(control.height)).Integer.String &amp; '\slmult0 ' ;
				
				/*	check paragraph indentation */
				if pFrame.left &lt;&gt; 0 then
					strNewLine := strNewLine &amp; '\li' &amp; self.pixelsToTwips(pFrame.left).Integer.String &amp; ' ';
				endif;
	
				/*	check for gap between last paragraph and this one */
				if prevBott &lt; relTop - 1 then
					strNewLine := strNewLine &amp; "\sb" &amp; (self.pixelsToTwips(relTop - prevBott)).String;
				endif;
			elseif control.isKindOf(Table) then
				strNewLine := null;
				/*	check for gap between last paragraph and this one */
				if prevBott &lt; relTop - 1 then
					/*	add a dummy paragraph for the spacing */
					myOutputFile.writeBinary(("\pard \sl-" &amp; (self.pixelsToTwips(relTop - prevBott)).Integer.String 
										&amp; '\slmult0\ {\tab}' &amp; CrLf &amp; '\par').Binary);
				endif;
			endif;
			
			blnFirst	:= false;
			prevTop 	:= relTop;
			prevBott	:= prevTop + control.height;
			lineOut 	:= null;
			strTabs 	:= null;
		endif;					
			
		if control.isKindOf(Label) then
			/* check for line */
			if (false /*(control.isKindOf(HorizontalLine)*/ or
				control.height &lt; 2) and
				control.left = 0 and
				control.width &gt;= pFrame.width then
				/*	only handle lines across whole frame */
				fieldOut := null;
				blnLine	:= true;
			else
				fieldOut := control.Label.caption;
				blnLine := false;
			endif;	

			if relLeft &gt; 0 or 
				control.Label.alignment &gt; Label.Alignment_Left_Bottom then
				blnTab := true;
				if control.Label.alignment = Label.Alignment_Left_Top or
					control.Label.alignment = Label.Alignment_Left_Middle or
					control.Label.alignment = Label.Alignment_Left_Bottom then
					strTabs := strTabs &amp; "\tx" &amp; (self.pixelsToTwips(pFrame.left + relLeft)).Integer.String &amp; " ";
				elseif control.Label.alignment = Label.Alignment_Center_Top or
					control.Label.alignment = Label.Alignment_Center_Middle or
					control.Label.alignment = Label.Alignment_Center_Bottom then
					strTabs := strTabs &amp; "\tqc\tx" &amp; (self.pixelsToTwips(pFrame.left + relLeft + (control.width/2))).Integer.String &amp; " ";
				elseif control.Label.alignment = Label.Alignment_Right_Top or
					control.Label.alignment = Label.Alignment_Right_Middle or
					control.Label.alignment = Label.Alignment_Right_Bottom then
					strTabs := strTabs &amp; "\tqr\tx" &amp; (self.pixelsToTwips(pFrame.left + relLeft + control.width)).Integer.String &amp; " ";
				endif;
			endif;
			
			if not blnLine then
				fieldOut := self.convertRTFString(fieldOut);
			endif;
			
			/* check for special fields such as page number */
			fOut := control.Label.formatOut;
			if fOut = '=page' or fOut = '=Page' or fOut = '=PAGE' then
				fieldOut := '\chpgn ';
			endif;
			
			if blnLine then
				/*	 create a very small pargraph with 100% shading */
				lineOut := '\shading10000 \cbpat' &amp; self.getColourIndex(control.backColor).String &amp; 
							'\cfpat' &amp; self.getColourIndex(control.backColor).String &amp; ' \tab ';
				strTabs := '\tx0 ';
			else
				lineOut := lineOut &amp; self.generateTextRTF(fieldOut, blnTab, control.fontName, control.fontSize,
									control.fontBold, control.fontItalic, control.fontUnderline, control.foreColor);
			endif;			
			
		elseif control.isKindOf(Picture) then
			binPicture := control.Picture.picture;
			if relLeft &gt; 0  then
				blnTab := true;
				strTabs := strTabs &amp; "\tx" &amp; (self.pixelsToTwips(pFrame.left + relLeft)).Integer.String &amp; " ";
			endif;
			if lineOut &lt;&gt; null then
				myOutputFile.writeBinary(lineOut.Binary);
				lineOut := null;
			endif;
			self.generatePictureRTF(control.Picture);
			
		elseif control.isKindOf(Table) then
			lineOut := self.generateTableRTF(control.Table);		
		endif;
		prevControl := control;
	endwhile;

	/* spacing for remainder of frame */
	if pFrame.height &gt; prevBott then
		if prevControl &lt;&gt; null and prevControl.isKindOf(Table) then
//		if prevControl.isKindOf(Table) then
			strSpaceAfter := null;	
		else
			strSpaceAfter := "\sa" &amp; (self.pixelsToTwips(pFrame.height - prevBott)).String;
		endif;
	endif;
	
	/*	write out the last paragraph to file */
	if lineOut &lt;&gt; null or
		strNewLine &lt;&gt; null or
		strSpaceAfter &lt;&gt; null then
		if prevControl &lt;&gt; null and prevControl.isKindOf(Table) then
			/*	 no new paragraph after table */
			myOutputFile.writeBinary((strNewLine &amp; strTabs &amp; lineOut &amp; strSpaceAfter &amp; CrLf).Binary);
		else
			myOutputFile.writeBinary((strNewLine &amp; strTabs &amp; lineOut &amp; strSpaceAfter &amp; CrLf &amp; '\par').Binary);
		endif;
		
		if prevControl &lt;&gt; null and prevControl.isKindOf(Table) then
			if pFrame.height &gt; prevBott then
				/*	add a dummy paragraph for the space after the table */
				myOutputFile.writeBinary(("\pard \sl-" &amp; (self.pixelsToTwips(pFrame.height - prevBott)).Integer.String 
										&amp; '\slmult0\ {\tab}' &amp; CrLf &amp; '\par').Binary);
			endif;
		endif;
	endif;
	self.prevFrame := pFrame;
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="pFrame" type="Frame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="generateHeaderRTF" id="0639e591-7d5c-4b0a-b7aa-9dde8893d4db">
        <updating/>
        <source>generateHeaderRTF() updating,protected;

vars
	strLine		: String;
	obj			: Object;
	frame		: Frame;
begin
	if self.allHeaderFrames.size = 0 then
		return;
	endif;
	
	self.prevFrame := null;
	strLine := "{\header \plain  ";
	myOutputFile.writeBinary(strLine.Binary);
	foreach obj in self.allHeaderFrames do
		generateFrameRTF(frame);
	endforeach;
	myOutputFile.writeBinary("}".Binary);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="generatePictureRTF" id="3cb2038c-418f-456b-abf7-5fe21316e100">
        <updating/>
        <source>generatePictureRTF(pPicture:Picture) updating, protected;
/* pictures are written as JPEG, so only picture types which are already or can be converted to JPEG are used. */
vars
	pic		: Binary;
	strOut	: String;
	scaleX,scaleY:	Integer;
begin
	pic := pPicture.picture;
	// djc, 1 Dec 2000: Don't do anything with null pictures
	if pic &lt;&gt; null then
		if pPicture.pictureType &lt;&gt; Window.PictureType_Jpeg then
			pic := pPicture.picture.convertPicture(Window.PictureType_Jpeg);
		endif;
	endif;

	if pic &lt;&gt; null and pic.pictureType = Window.PictureType_Jpeg then
		if pPicture.left &gt; 0 then
			strOut := "\tab ";
		endif;
/*  picture width and height are in pixels for RTF, not twips */
		scaleX := pPicture.width * 100 div pPicture.pictureWidth;
		scaleY := pPicture.height * 100 div pPicture.pictureHeight;
		strOut := strOut &amp; "{\pict \jpegblip\picscalex" &amp; scaleX.String &amp; "\picscaley" &amp; scaleY.String &amp; "\picw" &amp; pPicture.width.String &amp; "\pich" &amp; pPicture.height.String &amp; " \bin"
			&amp; pic.length.String;
		myOutputFile.writeBinary(strOut.Binary);
		myOutputFile.writeBinary(pic);
		myOutputFile.writeBinary("}".Binary);
	else // djc, 1 Dec 2000: Do the "else" for null pictures also (even if they're JPEGs)
/* for non-JPEG just write a tab, if needed, to keep any following items on the line in the correct position */	
		if pPicture.left &gt; 0 then
			myOutputFile.writeBinary("\tab ".Binary);
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pPicture" type="Picture"/>
    </JadeMethod>
    <JadeMethod name="generateTableRTF" id="e34ec74f-265d-4958-b3ee-3bed1b1a51ef">
        <source>generateTableRTF(pTable :Table input):String protected;

vars
	str,
	strOut, strCells,
	strReturn			:String;
	intCol, intRow,
	intCellRight		:Integer;
	cell				:JadeTableCell;
	column				:JadeTableColumn;
	rowHeight			: Integer;
begin
	while intRow &lt; pTable.rows do
		intRow 			:= intRow + 1;
		intCol 			:= 0;
		intCellRight	:= 0;
		strCells 		:= null;

		/*	row defaults */
		strOut	:= '\trowd ';
		/*	half space between table cells - hardcoded at 1 pixels */
		strOut	:= strOut &amp; '\trgaph' &amp; self.pixelsToTwips(1).String;
		/*	row height */
		if pTable.gridLines then
			rowHeight := pTable.rowHeight[intRow] - 1;
		else
			rowHeight := pTable.rowHeight[intRow];
		endif;
		strOut	:= strOut &amp; '\trrh-' &amp; self.pixelsToTwips(rowHeight).String;
		/*	position of leftmost edge of table */
		strOut	:= strOut &amp; '\trleft' &amp; self.pixelsToTwips(pTable.left + pTable.parent.left).String;
		/*	row borders */
		if pTable.borderStyle &lt;&gt; Window.BorderStyle_None then
			strOut := strOut &amp; '\trbrdrt\brdrs\brdrw' &amp; self.pixelsToTwips(1).Integer.String;	// top		
			strOut := strOut &amp; '\trbrdrl\brdrs\brdrw' &amp; self.pixelsToTwips(1).Integer.String;	// left		
			strOut := strOut &amp; '\trbrdrb\brdrs\brdrw' &amp; self.pixelsToTwips(1).Integer.String;	// bottom		
			strOut := strOut &amp; '\trbrdrr\brdrs\brdrw' &amp; self.pixelsToTwips(1).Integer.String;	// right		
			strOut := strOut &amp; '\trbrdrh\brdrs\brdrw' &amp; self.pixelsToTwips(1).Integer.String;	// inside horizontal		
			strOut := strOut &amp; '\trbrdrv\brdrs\brdrw' &amp; self.pixelsToTwips(1).Integer.String;	// inside vertical		
		endif;

		while intCol &lt; pTable.columns do
			intCol := intCol + 1;
			cell := pTable.accessCell(intRow, intCol);
			/*	cell borders */
			if pTable.gridLines then
				strOut := strOut &amp; '\clbrdrb\brdrs\brdrw' &amp; self.pixelsToTwips(1).Integer.String;	// bottom
				strOut := strOut &amp; '\clbrdrt\brdrs\brdrw' &amp; self.pixelsToTwips(1).Integer.String;	// top
				strOut := strOut &amp; '\clbrdrl\brdrs\brdrw' &amp; self.pixelsToTwips(1).Integer.String;	// left
				strOut := strOut &amp; '\clbrdrr\brdrs\brdrw' &amp; self.pixelsToTwips(1).Integer.String;	// right
			endif;
			/*	vertical text alignment */
			if cell.alignment = Table.Alignment_Default or
				cell.alignment = Table.Alignment_Left or
				cell.alignment = Table.Alignment_Left_Middle or
				cell.alignment = Table.Alignment_Right or
				cell.alignment = Table.Alignment_Right_Middle or
				cell.alignment = Table.Alignment_Center or
				cell.alignment = Table.Alignment_Center_Middle then
				strOut := strOut &amp; '\clvertalc';
			elseif cell.alignment = Table.Alignment_Left_Top or
				cell.alignment = Table.Alignment_Right_Top or
				cell.alignment = Table.Alignment_Center_Top then
				strOut := strOut &amp; '\clvertalt';
			elseif cell.alignment = Table.Alignment_Left_Bottom or
				cell.alignment = Table.Alignment_Right_Bottom or
				cell.alignment = Table.Alignment_Center_Bottom then
				strOut := strOut &amp; '\clvertalb';
			else
				strOut := strOut &amp; '\clvertalc';			
			endif;
			/*	cell position (width) */
			column := pTable.accessColumn(intCol);
			intCellRight := intCellRight + column.width;
			strOut := strOut &amp; '\cellx' &amp; self.pixelsToTwips(pTable.left + pTable.parent.left + intCellRight).Integer.String;
			/*	cell contents */
			strCells := strCells &amp; '\pard \plain \widctlpar \adjustright \intbl ';
			/*	alignment */
			if cell.alignment = Table.Alignment_Default or
				cell.alignment = Table.Alignment_Left or
				cell.alignment = Table.Alignment_Left_Middle or
				cell.alignment = Table.Alignment_Left_Top or 
				cell.alignment = Table.Alignment_Left_Bottom then
				strCells := strCells &amp; '\ql ';
			elseif cell.alignment = Table.Alignment_Right or
				cell.alignment = Table.Alignment_Right_Middle or
				cell.alignment = Table.Alignment_Right_Top or
				cell.alignment = Table.Alignment_Right_Bottom then
				strCells := strCells &amp; '\qr ';
			elseif 	
				cell.alignment = Table.Alignment_Center or
				cell.alignment = Table.Alignment_Center_Middle or
				cell.alignment = Table.Alignment_Center_Bottom or
				cell.alignment = Table.Alignment_Center_Top then
				strCells := strCells &amp; '\qc ';	
			endif;			
			// KMG the self.convertRTFString(cell.text) cannot be the first param
			// as it is IO and a method return cannot be IO
			str:=self.convertRTFString(cell.text);
			if str = null then
				str := ' ';
			endif;
			strCells := strCells &amp; '{' &amp; self.generateTextRTF(str , false, 
											cell.fontName, cell.fontSize, cell.fontBold, cell.fontItalic, 
											cell.fontUnderline, cell.foreColor) &amp; '}\cell ';
		endwhile;
		strReturn := strReturn &amp; strOut &amp; strCells &amp; '\row \pard ';
	endwhile;
	
	return strReturn;
end;</source>
        <access>protected</access>
        <Parameter name="pTable" type="Table" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="generateTextRTF" id="e0e93190-d38b-4abd-b361-d388a53f923f">
        <source>generateTextRTF(pString :String io; pTab :Boolean; pFontName :String;
				pFontSize :Real; pFontBold, pFontItalic, pFontUnderline :Boolean;
				pColour :Integer) : String protected;

vars
	out,
	fontFace				:String;
	intIndex, intColour	 	:Integer;
	relFontSize				:Real;
	blnBold, blnItalic, blnUnderline
							:Boolean;
begin
 	/*	set the correct font for the control */
 	if pFontName &lt;&gt; null then
 		fontFace 		:= pFontName;
 		relFontSize 	:= pFontSize;
		blnBold 		:= pFontBold;
		blnItalic		:= pFontItalic;
		blnUnderline	:= pFontUnderline;
 	else
 		fontFace 		:= app.fontName;
		relFontSize 	:= app.fontSize;
		blnBold 		:= app.fontBold;
		blnItalic		:= false;
		blnUnderline	:= false;
 	endif;
 	
 	/*	this is a bit of a kludge - word will not display spaces underlined if they are the last
 		thing on the line.  We don't know if our text is the last thing so we just add an invisible
 		'.' to every setof underlined spaces */
 	if pString.trimBlanks = null and
 		pFontUnderline then
 		pString := pString &amp; '.';
 		intColour := White;
 	else
 		intColour	:= pColour;
 	endif;
	
 	out := "{";
	intIndex := 1;
	while intIndex &lt;= self.fontFamilyList.size do
		if self.fontFamilyList[intIndex] = fontFace then
			break;
		endif;
		intIndex := intIndex + 1;
	endwhile;
	
	if intIndex &gt; self.fontFamilyList.size then
		out := out &amp; "\f0";
	else
		out := out &amp; "\f" &amp; intIndex.String;
	endif;
	
	/*	font size is in 1/2 points */
	out := out &amp; "\fs" &amp; (relFontSize * 2).Integer.String &amp; " ";
	
	if blnBold then
		out := out &amp; '\b ';
	endif;	
	if blnItalic then
		out := out &amp; '\i ';
	endif;	
	if blnUnderline then
		out := out &amp; '\ul ';
	endif;
		
	if intColour &lt;&gt; Black then
		intIndex := self.getColourIndex(intColour);
		out := out &amp; "\cf" &amp; (intIndex).String &amp; ' ';
	endif;

	
	if pTab then
		out := "\tab " &amp; out;
	endif;
	
	out := out &amp; pString;

	if blnBold then
		out := out &amp; '\b0 ';
	endif;	
	if blnItalic then
		out := out &amp; '\i0 ';
	endif;	
	if blnUnderline then
		out := out &amp; '\ul0 ';
	endif;	

	return extractCrLf(out) &amp; "}";
end;</source>
        <access>protected</access>
        <Parameter name="pString" type="String" usage="io"/>
        <Parameter name="pTab" type="Boolean"/>
        <Parameter name="pFontName" type="String"/>
        <Parameter name="pFontSize" type="Real"/>
        <Parameter name="pFontBold" type="Boolean"/>
        <Parameter name="pFontItalic" type="Boolean"/>
        <Parameter name="pFontUnderline" type="Boolean"/>
        <Parameter name="pColour" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getColourIndex" id="33395295-60ba-4e99-b267-7ea7ecb7c69f">
        <source>getColourIndex(pColour:Integer):Integer protected;
/*
	Purpose   		to ...
	Parameters  	pColour		the colour we are looking for
	Returns			the index corresponding to pColour (zero relative)
	Preconditions	none
	Note			...
*/
vars
	intIndex	:Integer;
begin
	intIndex := 1;
	while intIndex &lt;= self.colourList.size do
		if self.colourList[intIndex] = pColour then
			return intIndex - 1;
		endif;
		intIndex := intIndex + 1;
	endwhile;
	return null;
end;</source>
        <access>protected</access>
        <Parameter name="pColour" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getCurrentPosition" id="b97a99ea-9066-47e4-b831-915adada27cd">
        <source>getCurrentPosition():Real;

vars

begin
	return self.currentPosition;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getPageHeight" id="b6f9b53f-e78e-4fd7-86ce-3d20dd8131cc">
