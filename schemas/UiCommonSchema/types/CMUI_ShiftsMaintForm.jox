    <JadeMethod name="addDisplayRow" id="512e6998-eb51-4aa9-8709-7fe45a523b8c">
        <source>addDisplayRow(_shiftStd : CM_ShiftStd; _index : Integer io; _isFirst : Boolean) protected;
// ---------------------------------------------------------------------------
// Created:     01 May 2007 by cnwyl1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if _isFirst then
		self.tblShift.rows := self.tblShift.rows + 1;
		self.tblShift.accessCell(_index, COL_SHIFT_TYPE).text := _shiftStd.getShiftDay();
		self.tblShift.accessRow(_index).backColor := self.ColourYellowDark;
		_index := _index + 1;
	endif;
	self.tblShift.rows := self.tblShift.rows + 1;
	self.tblShift.accessCell(_index, COL_START_TIME).text := _shiftStd.getStartTime();
	self.tblShift.accessCell(_index, COL_END_TIME).text := _shiftStd.getEndTime();
	self.tblShift.accessCell(_index, COL_SHIFT_CODE).text := _shiftStd.getShiftCode();
	self.tblShift.accessCell(_index, COL_SHIFT_DESC).text := _shiftStd.getShiftDesc();
	self.tblShift.accessRow(_index).backColor := self.ColourYellowLight;
	self.tblShift.accessRow(_index).itemObject := _shiftStd;
end;
</source>
        <access>protected</access>
        <Parameter name="_shiftStd" type="CM_ShiftStd"/>
        <Parameter name="_index" type="Integer" usage="io"/>
        <Parameter name="_isFirst" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="addToTable" id="ad73165f-bcd4-4b88-ad0c-9357fd8fc931">
        <updating/>
        <source>addToTable(_row : Integer; _col : Integer; _value : String) updating;

vars
	cell		: JadeTableCell;
begin
	cell := self.tblShift.accessCell(_row, _col);
	cell.text := _value.String;
end;
</source>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_col" type="Integer"/>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="a20173ef-41fc-40d4-b07f-2a3f32be407d">
        <updating/>
        <source>addToolbarControls() updating, protected;
// ---------------------------------------------------------------------------
// Created:		April  2007 By Yi Liu (cnwyl1)
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	queryToolbar,
	toolbar	: CMUI_Toolbar;

begin
	toolbar := self.frmToolbar;
	inheritMethod();
	toolbar.addButton(self.btnAdd, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnEdit, CMUI_Toolbar.Control_Alignment_Left);
	//toolbar.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnDelete, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addFrame(self.frmOption, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnRefresh, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
end;</source>
        <access>protected</access>
    </JadeMethod>
