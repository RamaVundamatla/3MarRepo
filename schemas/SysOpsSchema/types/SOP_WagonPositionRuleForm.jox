    <JadeMethod name="unload" id="51f094bc-5844-4211-a4b0-2a1b97fbb281">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 July 2009	cnwndl1	Initial creation

*/

vars
	index : Integer;
	form : SOP_TableMaintForm;
	table : CM_DataTable;
begin
	
	delete myPxyWagonClass;
	if self.myParentForm &lt;&gt; null then
		if self.myParentForm.isKindOf(SOP_TableMaintForm) then
			form := self.myParentForm.SOP_TableMaintForm;
			table := form.tblData;
			if table.findObjectInRow(myRealWagonClass,index) then
				form.myCurrentObject := myRealWagonClass;
				table.row := index;
				table.clearAllSelected();
				table.selectRow(index,true);
				form.showThumbnailData(myRealWagonClass);
			endif;
		endif;
	endif;
		
epilog

end;</source>
    </JadeMethod>
</GUIClass>
