    <JadeMethod name="getFirstUnusedWLE" id="d92ae749-4841-4a20-b283-ecd46f9ee55b">
        <source>getFirstUnusedWLE() : CM_WorkListEntry;
/*
Purpose:			
Date				Who			Reason
AUGUST 2011		CNWAB1		Initial creation
*/


vars
	aWLE : CM_WorkListEntry;
begin

	foreach aWLE in self.allWorkListEntries do
		if aWLE.myTrackedItem = null then
			return aWLE;
		endif;
	endforeach;
	
	// we are full up so return a WLE to produce an error about the WLE already being planned
	 aWLE := self.allWorkListEntries.first;
	return aWLE;
end;</source>
        <ReturnType type="CM_WorkListEntry"/>
    </JadeMethod>
