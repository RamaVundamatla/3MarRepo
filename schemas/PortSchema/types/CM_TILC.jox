    <JadeMethod name="getOnboardHazDetails" id="a4f517a8-4d02-4bea-a45f-780cb386d27e">
        <source>getOnboardHazDetails(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
28 March 2023	navmk20	Task 57224: Jade - New MAFI Columns
14 Mar 2024	jlika1	TFS 62803 CUX | Onboard cargo - new get methods and additional locations
*/

vars
	lc : CM_LocationsController;
	ti : CM_TrackedItem;
	tmpStr, hazardDetails : String;
    failedDAC             : CM_DataAccessController;       //JIRA-34864 
begin
	foreach lc in self.allLCs do
		foreach ti in lc.allTrackedItems do
            if not ti.canUserAccessSelf(null, failedDAC, app.myPassport) then           //JIRA-34864 
                continue;                                                               //JIRA-34864
            endif;                                                                      //JIRA-34864
			hazardDetails := self.getAllTIHazards(ti);
			
			/*
			if hazardDetails &lt;&gt; null then
				if tmpStr = null then
					tmpStr := hazardDetails;
				elseif tmpStr.pos(hazardDetails, 1) = 0 then
					tmpStr := tmpStr &amp; ', ' &amp; hazardDetails;
				endif;
			endif;
			*/
			
			tmpStr.addStringToList(hazardDetails, ", "); //04/04/2025	navkc1 JIRA Story MTN-33940
			
			if ti.isKindOf( CM_TILC ) then // a stack of trailers
				hazardDetails := ti.getOnboardHazDetails();
				if hazardDetails &lt;&gt; null then
					tmpStr := tmpStr &amp; ', ' &amp; hazardDetails;
				endif;
			endif;
		endforeach;
	endforeach;
	return tmpStr;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
