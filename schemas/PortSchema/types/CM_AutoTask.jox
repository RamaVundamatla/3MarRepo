    <JadeMethod name="validate" id="340f5c60-08ff-43bd-a053-d22a8823be3a">
        <source>validate();

// cnwdvb1 17 January 2003 
// 12/12/2014  cnwdb2	PAR 35364

vars

begin

	if self.description = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Description', ETRow_BgpAutoDescription, null);
		app.raiseCMException(Input_required_field_Desc, ETRow_BgpAutoDescription, null);
	endif;
	
	if self.myUser = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'User', ETRow_BgpAutoUser, null);	
		app.raiseCMException(Input_required_field_Usr, ETRow_BgpAutoUser, null);	// cnwdb2	PAR 35364


	endif;
end;</source>
    </JadeMethod>
</Class>
