    <JadeMethod name="isSubTerminalsOn" id="c63f7afb-3bb3-453f-a56e-1acb25213870">
        <source>isSubTerminalsOn():Boolean;
// --------------------------------------------------------------------------------
// Created:		08 April 2009 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether Sub-Terminals is turned
//				on for the current Terminal.
//
// Parameters:	None
//
// Returns:		True if turned on, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.myTerminal = null then
		if self.myAssistant &lt;&gt; null then
			if self.myAssistant.myTerminal &lt;&gt; null then
				return self.myAssistant.myTerminal.getConfig(IsSubTerminalsOn).Boolean;
			endif;
		endif;
	else
		return self.myTerminal.getConfig(IsSubTerminalsOn).Boolean;
	endif;
	
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
