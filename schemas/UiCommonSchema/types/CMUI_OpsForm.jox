    <JadeMethod name="getXMLSettingsForSave" id="5b975ed1-7d1b-43ed-b793-54242e0d5baf">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
//--------------------------------------------------------------
//Created: 15 January 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	xmlStr	: String;
	entRow	: EntTableRow;	
	powerReqBold : Boolean;
begin
	xmlStr := inheritMethod();

	xmlStr := xmlStr &amp; self.tblWorkEntries.getXmlStrForColumns(true);
	
	// listbox splitter ratio
	xmlStr := xmlStr &amp; 
			global.formatAsXMLPrefix(XMLTag_Splitter &amp; ' ' &amp; self.name &amp; ' ' &amp; self.splOperations.name) &amp;
			global.formatAsXML(XMLTag_Ratio, splOperations.leftToRightRatio.String) &amp;
			global.formatAsXMLSuffix(XMLTag_Splitter &amp; ' ' &amp; self.name &amp; ' ' &amp; self.splOperations.name);

	// grid area splitter ratio
	xmlStr := xmlStr &amp; global.formatAsXMLPrefix(XMLTag_Splitter &amp; ' ' &amp; self.name &amp; ' ' &amp; self.splGridArea.name) &amp;
			global.formatAsXML(XMLTag_Ratio, splGridArea.leftToRightRatio.String) &amp;
			global.formatAsXMLSuffix(XMLTag_Splitter &amp; ' ' &amp; self.name &amp; ' ' &amp; self.splGridArea.name);	

	// grid area Extra info splitter ratio
	xmlStr := xmlStr &amp; 
			global.formatAsXMLPrefix(XMLTag_Splitter &amp; ' ' &amp; self.name &amp; ' ' &amp; self.splExtraInfo.name) &amp;
			global.formatAsXML(XMLTag_Ratio, splExtraInfo.leftToRightRatio.String) &amp;
			global.formatAsXMLSuffix(XMLTag_Splitter &amp; ' ' &amp; self.name &amp; ' ' &amp; self.splExtraInfo.name);	

	// main splitter ratio
	xmlStr := xmlStr &amp; 
			global.formatAsXMLPrefix(XMLTag_Splitter &amp; ' ' &amp; self.name &amp; ' ' &amp; self.splMain.name) &amp;
			global.formatAsXML(XMLTag_Ratio, splMain.leftToRightRatio.String) &amp;
			global.formatAsXMLSuffix(XMLTag_Splitter &amp; ' ' &amp; self.name &amp; ' ' &amp; self.splMain.name);				
				
	xmlStr := xmlStr &amp; global.formatAsXML(XML_BP,self.boldRequiresPower.Integer.String);	
			

	return xmlStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="gridAreaMouseDownEvent" id="79674be3-618d-4069-a40c-a69afd322ea7">
        <updating/>
        <source>gridAreaMouseDownEvent(_button : Integer; _x, _y : Real) updating, protected;
//--------------------------------------------------------------
//Created: 19 March 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	gridPoint	: CMUI_GridPoint; 
	lX, lY 		: Real;
	lFactor 	: Real;
	lTI 		: CM_TrackedItem;
	lc		 	: CM_LocationsController;
begin
	if self.frmGridArea = null or
			self.frmGridArea.myGridArea = null then
		return;
	endif;
	
	gridPoint := self.frmGridArea.myGridArea.convertPositionToGridPoint(_x, _y); 

	lX := _x;
	lY := _y;
	self.frmGridArea.windowToScreen(lX, lY);
	self.screenToWindow(lX, lY);

	if _button = Window.MouseButton_Left then
		self.myCurrentLocation := null;
		self.frmModeStatusBar.myFrameCaption.caption := null;
		self.gridPointChange(gridPoint, _x, _y);
		if gridPoint &lt;&gt; null then
			self.myCurrentLocation := gridPoint.myLocationsController;
		endif;
		
	elseif _button = Window.MouseButton_Right then
		if gridPoint &lt;&gt; null then
			self.myCurrentLocation := gridPoint.myLocationsController;
		endif;
	endif;

	if _button = 1 then
		self.origXPos := _x;
		self.origYPos := _y;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_button" type="Integer"/>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="gridAreaMouseMoveEvent" id="667a8f20-5dae-46e1-a41c-14fdb379af97">
        <updating/>
        <source>gridAreaMouseMoveEvent(_button : Integer; _x, _y : Real)updating;
//--------------------------------------------------------------
//Created: 19 March 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	gridPoint	: CMUI_GridPoint;
	theTI		: CM_TrackedItem;
	wle			: CM_WorkListEntry;
begin
	if self.frmGridArea = null or
			self.frmGridArea.myGridArea = null then
		return;
	endif;

	if _button &lt;&gt; 1 or (not app.dragDetected(_x, _y, self.origXPos, self.origYPos)) then
		return;
	endif;

	// initiate a drag/drop
	gridPoint := self.frmGridArea.myGridArea.convertPositionToGridPoint(self.origXPos, self.origYPos);
	if gridPoint = null then
		return;
	endif;
	
	theTI := gridPoint.getTI(self.origXPos, self.origYPos);
	if theTI = null then
		return;
	endif;

	app.myDraggedTrackedItem := theTI;
	if theTI.jobRailReceive &lt;&gt; null then
		wle := theTI.jobRailReceive.getWLEForTI(theTI);
	endif;
	if wle &lt;&gt; null then
		if wle.status = WLE_COMPLETED then
			app.raiseCMException2(VB_JOB_NOT_UNACTIONED, wle.job.jobId, wle.statusString, null, null);
			return;
		endif;
	endif;		
	self.dragTrackedItem(theTI, wle, self.frmGridArea);
	
end;</source>
        <Parameter name="_button" type="Integer"/>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="gridPointChange" id="16ade143-c7fd-4d9f-aa57-3e7076929a75">
        <updating/>
        <source>gridPointChange(_gridPoint : CMUI_GridPoint input; _x, _y : Real) updating;
//--------------------------------------------------------------
//Created: 19 March 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if _gridPoint = null then
		self.frmModeStatusBar.myFrameCaption.caption := null;
	else
		self.frmModeStatusBar.myFrameCaption.caption := _gridPoint.getTIDetails(_x, _y);
	endif;
end;</source>
        <Parameter name="_gridPoint" type="CMUI_GridPoint" usage="input"/>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="gridPointRecieveDrop" id="82a750b4-b12f-4bb0-8049-8cfa5f3df0db">
        <updating/>
        <source>gridPointRecieveDrop(_frame: Frame input; _win: Window input; _gridPoint : CMUI_GridPoint input;_x, _y : Real) updating;
//-----------------------------------------
//Created: April 2003 By: cnwgd1
//-----------------------------------------
vars

begin
	if _gridPoint = null then
		return;
	endif;
	
	app.mousePointer := MousePointer_HourGlass;

	self.gridPointChange(_gridPoint, _x, _y);
	self.assignTIToTransport(_gridPoint.myLocationsController);

epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="_frame" type="Frame" usage="input"/>
        <Parameter name="_win" type="Window" usage="input"/>
        <Parameter name="_gridPoint" type="CMUI_GridPoint" usage="input"/>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="handleExceptionJob" id="3ffce07c-b33b-4e71-854c-94655d37d2eb">
        <source>handleExceptionJob(exObj : Exception; _job : CM_Job io) : Integer protected;
//--------------------------------------------------
// Created:	05 February 2004 By: cnwgd1
//--------------------------------------------------
constants
	ObjectNotFound	: Integer = 4;
	ObjectDeleted	: Integer = 1072;
begin

	if exObj.errorCode = ObjectNotFound 
	or exObj.errorCode = ObjectDeleted then
		_job := null;
		return Ex_Resume_Next;
	endif;

	return Ex_Pass_Back;

end;</source>
        <access>protected</access>
        <Parameter name="exObj" type="Exception"/>
        <Parameter name="_job" type="CM_Job" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleExceptionWLE" id="9d09bcb3-c300-4086-ad3e-cdf4ecf2aa11">
        <source>handleExceptionWLE(exObj : Exception; _wle : CM_WorkListEntry io) : Integer protected;
//--------------------------------------------------
// Created:	04 February 2004 By: cnwgd1
//--------------------------------------------------
constants
	ObjectNotFound	: Integer = 4;
	ObjectDeleted	: Integer = 1072;
begin

	if exObj.errorCode = ObjectNotFound 
	or exObj.errorCode = ObjectDeleted then
		_wle := null;
		return Ex_Resume_Next;
	endif;

	return Ex_Pass_Back;

end;</source>
        <access>protected</access>
        <Parameter name="exObj" type="Exception"/>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
