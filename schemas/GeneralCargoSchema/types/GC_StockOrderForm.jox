    <JadeMethod name="doUserNotify" id="a989bb14-b1ad-4a5c-8070-3ad6af269635">
        <updating/>
        <source>doUserNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:     07 May 2004	cnwth2
// ----------   ----------  --------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	numRows,
	row				: Integer;
	tbl				: CM_DataTable;
	stkOrd			: CM_StockOrderHeaderGeneric;
	breakOut		: Boolean;
	orderNo			: String;
	entDef			: EntTableDef;
begin
	
	tbl := self.tblDataMaster;
	entDef := tbl.myEntTableDef;
	if eventType = Event_StockOrderHdr_Create then
		if self.mode &lt;&gt; self.Mode_View then
			return;
		endif;
		
		if (not CM_StockOrderHeaderGeneric.hasInstance(userInfo.Object)) then
			return;
		endif;
		
		stkOrd := userInfo.CM_StockOrderHeaderGeneric;
		if (not self.includesObject(stkOrd)) then
			return;
		endif;

		self.addObjectToMasterTable(tbl, stkOrd, null, null, breakOut);
		if stkOrd = self.myCurrentMasterObject then
			tbl.selectObject(stkOrd, true);
			self.zShowThumbnailData(stkOrd);
		endif;
		
	elseif eventType = Event_StockOrderHdr_Update then
		if (not CM_StockOrderHeaderGeneric.hasInstance(userInfo.Object)) then
			return;
		endif;
		
		stkOrd := userInfo.CM_StockOrderHeaderGeneric;
				
		if stkOrd = self.myCurrentMasterObject then
			if self.mode = self.Mode_Edit then
				if app.msgBox('Another user has updated the stock order (' &amp; stkOrd.orderNo &amp; ') that you are currently editing.' &amp; CrLf &amp;
			 			'Do you want to refresh the information displayed or cancel?','Stock Order updated by another user...', MsgBox_OK_Cancel) &lt;&gt; MB_OK then
					self.zDoCancel();
				endif;
			endif;
			
			self.zShowThumbnailData(stkOrd);	
		endif;
		
		numRows := tbl.rows;
		foreach row in tbl.fixedRows + 1 to numRows do
			if tbl.accessRow(row).itemObject = stkOrd then
				tbl.setCellText(row, 1, self.getDataRowForDef(stkOrd, entDef));
				break;
			endif;
		endforeach;
	
	elseif eventType = Event_StockOrderHdr_Delete then
		
		orderNo := userInfo.String;
		if orderNo = null then
			return;
		endif;
		
		if not global.isValidObject(self.myCurrentMasterObject) then
			if self.mode = self.Mode_Edit then
				app.msgBox('Another user has deleted the stock order (' &amp; orderNo &amp; ') that you are currently editing. This operation will be cancelled','Stock order deleted', MsgBox_Exclamation_Mark_Icon);
				self.myCurrentMasterObject := null;
				self.zDoCancel();
			else
				//app.msgBox('Another user has deleted the stock order (' &amp; orderNo &amp; ') that you are currently viewing.','Stock order deleted', MsgBox_Exclamation_Mark_Icon);
				self.myCurrentMasterObject := null;
				self.zClearThumbnailData();
			endif;
		endif;
					
		numRows := tbl.rows;
		foreach row in tbl.fixedRows + 1 to numRows do
			if tbl.getCellText(row, 1) = orderNo then
				tbl.removeItem(row);
				break;
			endif;			 
		endforeach;
		
	endif;

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="getDataEntityClass" id="925861dc-2f42-4cc1-a7cf-dc7deffb81c5">
