    <JadeMethod name="assignValueSpecial" id="a082d5fc-d749-4860-ad7b-58ebbe6a3ce8">
        <updating/>
        <source>assignValueSpecial(_propName: String; _processedValue: String; _xlationOperator: CM_Operator): Boolean updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 16/09/2014	cnwdap1		Initial creation PAR #34874 Correct Volume setting
/// 22 Feb 2016	cnwrs1	TFS 3401 fixup EDI Operations update of EDI TIs
//4 sept 2024 	navsaa30 Bug 63853: EUP | FR 53158 (CARGO ON SHIP) - Additional Fields - EDI loaded dimensions are not processed correctly (Precision issue)
//
vars
	value : String;
	contRange : CM_ContRange;
begin
	if _propName = ETRow_CoolingType then
		value := _processedValue.toUpper;
		if value = 'AIR' or value = 'AC' or value = 'A' or value = ContainerAirCooledStr.toUpper then
			self.coolingType := ContainerAirCooled;
		elseif value = 'WATER' or value = 'WC' or value = 'W' or value = ContainerWaterCooledStr.toUpper then
			self.coolingType := ContainerWaterCooled;
		else
			contRange := self.getContRange();
			if contRange &lt;&gt; null then
				self.coolingType := contRange.coolingType;
			else
				self.coolingType := ContainerCooledNull;
			endif;
		endif;
		return true;
	elseif _propName = ETRow_VoltageType then
		value := _processedValue.toUpper; 
		if value = 'DUAL' or value = 'DV' or value = 'D' or value = ContainerDualVoltStr.toUpper then 
			self.voltageType := ContainerDualVolt;
		elseif value = 'SINGLE' or value = 'SV' or value = 'S' or value = ContainerSingleVoltStr.toUpper then
			self.voltageType := ContainerSingleVolt;
		else
			self.voltageType := ContainerVoltNull;
		endif;
		return true;
	elseif _propName = ETRow_Volume then
		self.setPropertyValue(CM_EDIFleetTI::volume.name, _processedValue.Real);
		return true;
	elseif _propName = ETRow_TareWeight then	//27 Mar 2018	NDL	TFS 37596 
		self.tareWeight := _processedValue.asDecimalJMT;			//4/9/24  navsaa30  #63853
		return true;
	elseif _propName = ETRow_ExtHeight then	
		self.extHeight := _processedValue.asIntegerJMT;			//5/9/24  navsaa30  #63853
		return true;
	elseif _propName = ETRow_ExtWidth then	
		self.extWidth := _processedValue.asIntegerJMT;			//5/9/24  navsaa30  #63853
		return true;
	elseif _propName = ETRow_ExtLength then	
		self.extLength := _processedValue.asIntegerJMT;			//5/9/24  navsaa30  #63853
		return true;
	elseif _propName = ETRow_IntHeight then	
		self.intHeight := _processedValue.asIntegerJMT;			//5/9/24  navsaa30  #63853
		return true;
	elseif _propName = ETRow_IntWidth then	
		self.intWidth := _processedValue.asIntegerJMT;			//5/9/24  navsaa30  #63853
		return true;
	elseif _propName = ETRow_IntLength then	
		self.intLength := _processedValue.asIntegerJMT;			//5/9/24  navsaa30  #63853
		return true;
	endif;
	
	return inheritMethod(_propName, _processedValue, _xlationOperator);

epilog

end;</source>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_processedValue" type="String"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canUserSet" id="97d71140-ab88-4794-96c6-25bce19f45dd">
        <source>canUserSet(_propName: String): Boolean;
//
// 30 Jun 2014	cnwrs1	Par 34702 - Add support for JMT XML
//
vars

begin
	if _propName = CM_EDIFleetTI::myOwner.name then
		return false;
	else
		return inheritMethod(_propName);
	endif;
end;
</source>
        <Parameter name="_propName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="9e4f676e-46bd-4227-b06c-383f174f59c4">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 May 2009	cnwrd1	Initial creation
23 Apr 2014	cnwdap1	PAR #33005 CCMS SFW 1381 Imperial measurements for EDI user defined layouts
*/

vars
	rowName, type	: String;							// PAR #33005
begin

	if _attrName = ETRow_TareWeight then //cnwrd1 par  19701 18.5.09
		return self.tareWeight.asStringWeightJMT();
	//elseif _attrName = ETRow_Weight then //cnwrd1 par  19701 18.5.09					//-cnwml2 MSL CCMS 1017
	elseif _attrName = ETRow_TotalWeight then											//+cnwml2 MSL CCMS 1017
		return self.weight.asStringWeightJMT();		
	elseif _attrName = ETRow_IntHeight then
		return self.intHeight.asStringMeasurementJMT();		
	elseif _attrName = ETRow_IntWidth then
		return self.intWidth.asStringMeasurementJMT();		
	elseif _attrName = ETRow_IntLength then
		return self.intLength.asStringMeasurementJMT();				
		
	elseif _attrName.isMeasurementType then
		_attrName.getRowNameMeasureType(rowName, type);
		return self.getMeasurementStringForAttrib(rowName, type, _short);
		
	endif;
	

	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMeasurementStringForAttrib" id="8c9fd213-c6f6-4e23-b262-fe5ebf1f6e82">
        <source>getMeasurementStringForAttrib(_attrName: String; _measureType: String; _short: Boolean): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 23/04/2014	cnwdap1		Initial creation PAR #33005 CCMS SFW 1381 Imperial measurements for EDI user defined layouts
//
vars

begin
	if _attrName = ETRow_TotalWeight then
		return app.convertMeasurementForDisplay(_measureType, self.weight);
	endif;
	
	return inheritMethod(_attrName, _measureType, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_measureType" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
