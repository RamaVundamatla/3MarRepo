<Class name="CMIF_InaportnetWSRequest" id="18121bf7-7e9d-4415-a479-2bcfe4ac4e8a">
    <superclass name="CMIF_ExternalWSRequest"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <JadeMethod name="copyToRealWSObject" id="13819c78-bce5-46cb-b821-3ce1a17453ff">
        <source>copyToRealWSObject(_realRequest: ImportedWebServiceProxy input; _createdObjects: ObjectSet input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 June 2019	jlger1	Initial creation

*/

vars

	properties : PropertyNDict;
	prop : Property;
	value : Any;
begin
	
	
	foreach prop in self.class.allProperties do
		if _realRequest.class.getProperty(prop.name) &lt;&gt; null then
			value:=self.getPropertyValue(prop.name);		
			_realRequest.setPropertyValue(prop.name,value);
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="_realRequest" type="ImportedWebServiceProxy" usage="input"/>
        <Parameter name="_createdObjects" type="ObjectSet" usage="input"/>
    </JadeMethod>
</Class>
