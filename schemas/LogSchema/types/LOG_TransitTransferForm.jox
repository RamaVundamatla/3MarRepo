    <JadeMethod name="clear" id="b1707217-042c-4477-9e8a-ad57fb1c2156">
        <source>clear(_level : Integer) protected;

vars

begin

	if _level &gt;=CLEAR_SUPPLIER then
		self.tblSelection.setValueByName(ETRow_Supplier, null);
	endif;
	
	if _level &gt;=CLEAR_SPECIES then
		self.tblSelection.setValueByName(ETRow_Species, null);
		self.cmbSpecies.clear;
	endif;
	
	if _level &gt;=CLEAR_GRADE then
		self.tblSelection.setValueByName(ETRow_Grade, null);
		self.cmbGrade.clear;
	endif;
	
	if _level &gt;=CLEAR_TTL then
		self.tblSelection.setValueByName(ETRow_Type, null);
		self.cmbType.clear;
		self.tblSelection.setValueByName(ETRow_Treatment, null);
		self.cmbTreatment.clear;
		self.tblSelection.setValueByName(ETRow_Length, null);
		self.cmbLength.clear;
	endif;
		
	if _level &gt;= CLEAR_ALL then
		self.tblSelectData.rows := 1;
		self.tblSelection.setValueByName(ETRow_DocketNumber, null);
		self.cmbDocket.clear;
		self.tblSelection.setValueByName(ETRow_Lot, null);
		self.tblSelection.setValueByName(ETRow_Hatch, null);
		self.tblSelection.setValueByName(ETRow_Place, null);
		self.cmbHatch.clear;
		self.cmbPlace.listIndex := -1;
		self.cmbToPlace.listIndex := -1;		
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_level" type="Integer"/>
    </JadeMethod>
