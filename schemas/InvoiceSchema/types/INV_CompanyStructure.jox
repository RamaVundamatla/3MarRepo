    <JadeMethod name="doUserNote" id="36e300b9-014c-4c4b-937a-8db48ab0f55b">
        <updating/>
        <source>doUserNote(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theBank : CM_Bank;

begin
	if userInfo.isKindOf(CM_Bank) then
		theBank := userInfo.CM_Bank;
		self.doUserNoteCompany(eventType, theObject, eventTag, theBank);
	endif;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="doUserNoteCompany" id="6cb32a95-8ebd-4fd2-b1c4-0250ec17ab5f">
        <updating/>
        <source>doUserNoteCompany(eventType: Integer; theObject: Object; eventTag: Integer; theBank : CM_Bank) updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	event : Integer;
	theName : String;
	idx,idy,level, idxSt, idxEnd, newIdx,itemLevel : Integer;
	theListBox : ListBox;

begin
	theListBox := self.lstData;

	event := self.myTerminal.getEventFromTerminalEvent(eventType);
	if event = EVENT_COMPANY_DELETE then
		idx := self.lstData.findObject(theBank);
		if idx &gt; 0 then
			self.lstData.removeItem(idx);
		endif;
		if self.myCurrentBU = theBank then
			self.myCurrentBU := null;
		endif;
		return;
	endif;
	
	// from 35872 testing
	if theBank = null then
		return;
	endif;
	theName := theBank.mailingName;
	if theBank.isBusinessUnit then
		level := 2;
	else
		level := 1;
	endif;
	if event = EVENT_COMPANY_CREATE then


		// ## insert the new FinancialPeriodEnd by finding the group then insert under that.
		if theBank.parentCompany.isRootCompany then
			level :=  1;
			newIdx := 1;
		else
			idx := self.lstData.findObject(theBank.parentCompany);
			level := self.lstData.itemLevel[idx] + 1;
		endif;
		// ## insert alphabetically under parent.
		idxSt := idx + 1;
		idxEnd := self.lstData.listCount();
		foreach idy in idxSt to idxEnd do
			itemLevel := self.lstData.itemLevel[idy];
			if itemLevel = level then
				if self.lstData.itemText[idy] &gt; theBank.code &amp; " - " &amp; theBank.mailingName  then
					newIdx := idy;
					break;
				endif;
			elseif itemLevel &lt; level then
				newIdx := idy;
				break;
			endif;

		endforeach;
		if newIdx = 0 then
			newIdx := idxEnd + 1;
		endif;
		self.addCompanyAt(theBank, self.lstData, level, newIdx,false);
	elseif event = EVENT_COMPANY_UPDATE then
		
		idx := self.lstData.findObject(theBank);
		if idx &gt; 0 then
			self.addCompanyAt(theBank, self.lstData, level, idx,true);
		endif;
		self.doLstDataClick(self.lstData);
	endif;

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="theBank" type="CM_Bank"/>
    </JadeMethod>
