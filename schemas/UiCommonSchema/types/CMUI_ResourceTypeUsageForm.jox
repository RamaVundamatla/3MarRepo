        <updating/>
        <source>queryUnload(cancel: Integer io; reason: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 March 2010	cnwndl1	Initial creation	Par 22725

*/

vars

begin

	if reason = Form.QueryUnload_User then
	
		doBtnCancel();
		
		if self.modalResult = 1 then
			cancel := 1;
		endif;
	endif;
	
epilog

end;</source>
