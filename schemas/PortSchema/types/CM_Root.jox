    <JadeMethod name="createTranslationCategories" id="a0409c70-0e5e-4736-aa1c-3153787bda7d">
        <source>createTranslationCategories();

// one-off creation of reference instances for each category of XLAT_TranslatableText subclasses
// See Global constant category XLAT_GCCatetegories
// can be re-run, will only update changes
vars
	category : XLAT_Category;
begin
	self.zCreateTranslationCategory(XLAT_Exceptions, XLAT_TextMessage, "Text Messages", true);
	self.zCreateTranslationCategory(XLAT_FormCaptions, XLAT_FormCaption, "Form Captions", false);
	self.zCreateTranslationCategory(XLAT_Permissions, XLAT_Permission, "Permissions", false);
	self.zCreateTranslationCategory(XLAT_ReportNames, XLAT_ReportName, "Report Names", false);
	self.zCreateTranslationCategory(EntTableRows, XLAT_EntityTableText, "Table Entities", true);
	self.zCreateTranslationCategory(XLAT_Menus, XLAT_Menu, "Menu Entities", false);
end;</source>
