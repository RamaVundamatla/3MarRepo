    <JadeMethod name="getPictureForGateArea" id="6129f701-47e1-417b-8b20-9a4983629786">
        <source>getPictureForGateArea(_gateArea :CM_GateArea):Binary protected;
// ---------------------------------------------------------------------------
// Created:     25 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config Changes  
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if _gateArea.isAGate then
		return picAGate.picture;
	elseif _gateArea.isPGate then
		return picPGate.picture;
	elseif _gateArea.isTrouble then
		return picTrouble.picture;
	endif;
	
	return null;
