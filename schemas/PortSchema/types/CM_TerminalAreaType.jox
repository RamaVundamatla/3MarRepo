    <JadeMethod name="canAssociateInterchangeAreas" id="0d912648-c8be-4469-a768-53a2c336876e">
        <source>canAssociateInterchangeAreas() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
12 February 2010	cnwer1	Initial creation
26/05/2010			cnwcs5	par24292 - added types that cannot be maintained via terminal area form
							so we can use this method outside the terminal area definition form
*/

vars
	areaType	:Integer;		// par24292
	user		:CM_User;		// par24292
	terminal	:CM_Terminal;	// par 24292
begin
	if self.isGantryAreaType or
		self.isGantryInterchangeArea or
		self.isGantryLaneAreaType then	
		return false;
	endif;
// par24292 - start	
	areaType := self.type;						
	
	if areaType = TA_TYPE_YARD_INTERCHANGE or
		areaType = TA_TYPE_SWAP or 
		areaType = TA_TYPE_SUBBLOCK_STACK or
		areaType = TA_TYPE_GATE_ROAD or
		areaType = TA_TYPE_WORKPOINT_INTERCHANGE then
		return false;
	endif;
// par24292 - end

	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
