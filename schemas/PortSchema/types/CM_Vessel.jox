    <JadeMethod name="getLastVoyage" id="a8a292f9-6629-4788-ae6a-1b54ec43bfca">
        <source>getLastVoyage(_terminal : CM_Terminal) : CM_Voyage;
//--------------------------------------------------
// Created:	11 January 2006 By: cnwgd1
//--------------------------------------------------
vars
	lastVoyage,
	tmpVoyage : CM_Voyage;
	term : CM_Terminal;
	tmpDict : CM_TerminalByCodeDict;
	now : TimeStamp;
begin

	if _terminal &lt;&gt; null then
		return _terminal.getVesselsLastVoyage(self.code);
	else
		// Find vessels last visit to terminal
		now := app.actualTimeServer();
		tmpDict := self.myRootForVessel.allTerminals;
		foreach term in tmpDict do
			tmpVoyage := term.getVesselsLastVoyage(self.code);
			if tmpVoyage &lt;&gt; null then
				if lastVoyage = null then
					lastVoyage := tmpVoyage;
			elseif tmpVoyage.arrivedDT &gt; lastVoyage.arrivedDT
			and tmpVoyage.arrivedDT &lt;= now then
					lastVoyage := tmpVoyage;
				endif;
			endif;
		endforeach;
	endif;
	
	return lastVoyage;
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
