    <JadeMethod name="setConsignorVoyage" id="bfe8fa2e-a513-48f4-a51d-2531d4f0a808">
        <updating/>
        <source>setConsignorVoyage( _value : String ) updating;

/*
Date			Who		Reason
11 June 2010	cnwrl1	Initial creation as part of PAR 24299 - SFW 1118 EDI Form to allow searching of EDI file by Container / Voyage
// 20 Nov 2018	jlgrs1	TFS 41659 STWR Make EDI MultiThreaded Stage 6
*/
	
vars
	
begin
	// need to make sure the manual collection on CM_EDIConfig gets maintained correctly, this collection
	// keeps track of all EDITrackedITems that have some connection to a voyageCode of some kind.
	
	// remove the previous non-null value from this collection
	if self.consignorVoyage &lt;&gt; null and self.myEDIConfig &lt;&gt; null then
		if self.myEDIConfig.allEDITrackedItemsByVoyageCode.includesKey( self.consignorVoyage.toUpper, self ) then
			self.myEDIConfig.allEDITrackedItemsByVoyageCode.removeKeyEntry( self.consignorVoyage.toUpper, self, self );
		endif;
	endif;

	// now change it and add this new value to the manual collection (if not null).
	self.consignorVoyage	:= _value[ 1 : self.consignorVoyage.maxLength ];
	if not self.isTransient and
	   self.consignorVoyage &lt;&gt; null and self.myEDIConfig &lt;&gt; null then
		if not self.myEDIConfig.allEDITrackedItemsByVoyageCode.includesKey( self.consignorVoyage.toUpper, self ) then
			self.myEDIConfig.allEDITrackedItemsByVoyageCode.putAtKey( self.consignorVoyage.toUpper, self, self );
		endif;
	endif;
	
epilog
	
end;
</source>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="setContainerNumberText" id="7d3cca1f-7171-41f8-b360-c5c7376aab5b">
        <updating/>
        <source>setContainerNumberText(_value : String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Jul 2023	jlirs1	Initial creation TFS 59187 (59019) EUP - Manifest Processing - Container Reference Field

*/

vars

begin
	global.setExtraData(self.allExtraData, self, ContainerNumberText, _value);
epilog

end;</source>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="setDefaultsForFileFormat" id="757d2902-2581-458c-a943-341f1f84ad52">
        <updating/>
        <source>setDefaultsForFileFormat(_ediData: CM_EDIData) updating;
//----------------------------------------------------------------
//	Created:	17 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//25 Jun 2015	cnwrs1	Par 33901/36027 - Default booking commodity
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	terminal	: CM_Terminal;
	defISO		: CM_ISOType;
	defVoy		: CM_Voyage;
begin
	inheritMethod(_ediData);
	
	terminal := self.getMyTerminal();
	
	self.operatorCode := _ediData.operatorCode;
	
//	self.commodity := terminal.getConfig(DefCommodity).String;

	self.loadPort := terminal.getConfig(PortDestCode).String;
	
	defISO := terminal.getConfig(DefISOType).CM_ISOType;
	if defISO &lt;&gt; null then
		self.isoType := defISO.code;
	endif;

	self.transportMode := TI_TRANSMODE_ROAD_STR;
	
	defVoy := terminal.getConfig(DefVoyage).CM_Voyage;
	if defVoy &lt;&gt; null then
//		self.voyageCode := defVoy.code;	// cnwrl1 09/06/2010 PAR 24299 - what it was
		// make sure the manual collection on CM_EDIConfig gets maintained
		self.setVoyageCode( defVoy.code );
	endif;

	self.temperature := NULL_TEMPERATURE;

end;</source>
        <Parameter name="_ediData" type="CM_EDIData"/>
    </JadeMethod>
    <JadeMethod name="setDefaultsFromMaster" id="93cb83d5-250c-4de1-afd4-aa3df8a27b99">
        <updating/>
        <source>setDefaultsFromMaster(_masterEDITI: SelfType) updating;
//----------------------------------------------------------------
//	Created:	25 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 05 Jun 2018	jlgrs1	TFS 39018 SNO Cargo Operator in COPRAR
vars

begin

	inheritMethod(_masterEDITI);

	if _masterEDITI.operatorCode &lt;&gt; null then
		self.operatorCode := _masterEDITI.operatorCode;
	endif;
	
	if _masterEDITI.commodityDescription &lt;&gt; null then
		self.commodityDescription := _masterEDITI.commodityDescription;
	endif;
	
	if _masterEDITI.commodity &lt;&gt; null then
		self.commodity := _masterEDITI.commodity;
	endif;
	
//	if _masterEDITI.voyageCode &lt;&gt; null then			// cnwrl1 09/06/2010 PAR 24299 - what it was
	if _masterEDITI.getVoyageCode() &lt;&gt; null then
//		self.voyageCode := _masterEDITI.voyageCode;		// cnwrl1 09/06/2010 PAR 24299 - what it was
		// make sure the manual collection on CM_EDIConfig gets maintained
		self.setVoyageCode( _masterEDITI.getVoyageCode() );
	endif;
	
	if _masterEDITI.vesselName &lt;&gt; null then
		self.vesselName := _masterEDITI.vesselName;
	endif;
		
	if _masterEDITI.dischargePort &lt;&gt; null then
		self.dischargePort := _masterEDITI.dischargePort;
	endif;
	
	if _masterEDITI.loadPort &lt;&gt; null then
		self.loadPort := _masterEDITI.loadPort;
	endif;
	
	if _masterEDITI.destinationPort &lt;&gt; null then
		self.destinationPort := _masterEDITI.destinationPort;
	endif;
	
	if _masterEDITI.consignor &lt;&gt; null then
		self.consignor := _masterEDITI.consignor;
	endif;
	// cnwjre1 4/08/2016 TFS 2489 add customs agent to EDI prenote
	if _masterEDITI.customsAgent &lt;&gt; null then
		self.customsAgent := _masterEDITI.customsAgent;
	endif;
	if _masterEDITI.releaseCarrierCode &lt;&gt; null then
		self.releaseCarrierCode := _masterEDITI.releaseCarrierCode;
	endif;
	/* cnwrl1 11/06/2010 PAR 24299 - what it was
	//par17696 cnwrs1 Aug 2008
	if _masterEDITI.consignorVoyage &lt;&gt; null then
		self.consignorVoyage := _masterEDITI.consignorVoyage;
	endif;
	cnwrl1 11/06/2010 PAR 24299 - end of what it was */
	// cnwrl1 11/06/2010 PAR 24299 - start of coding
	// make sure the manual collection on CM_EDIConfig gets maintained
	if _masterEDITI.getConsignorVoyage &lt;&gt; null then
		self.setConsignorVoyage( _masterEDITI.getConsignorVoyage() );
	endif;
	// cnwrl1 11/06/2010 PAR 24299 - end of coding
	if _masterEDITI.customsSeal &lt;&gt; null then
		self.customsSeal := _masterEDITI.customsSeal;
	endif;
	if _masterEDITI.freightForwarder &lt;&gt; null then
		self.freightForwarder := _masterEDITI.freightForwarder;
	endif;
	if _masterEDITI.imexStatus &lt;&gt; null then
		self.imexStatus := _masterEDITI.imexStatus;
	endif;
end;</source>
        <Parameter name="_masterEDITI" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreateNew" id="170faef1-a06c-4288-b585-dfe8df3e6d5b">
        <updating/>
        <source>setForCreateNew(_ediData: CM_EDIData) updating;
//----------------------------------------------------------------
//	Created:	05 August 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	inheritMethod(_ediData);

	self.dischargePort := '****';
	self.temperature := NULL_TEMPERATURE; //par17696 cnwrs1 Aug 2008
end;</source>
        <Parameter name="_ediData" type="CM_EDIData"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="6f19154d-3ea7-41f6-8c58-18653d509337">
        <updating/>
        <source>setForUpdate(_proxyEDITI: SelfType) updating;
//----------------------------------------------------------------
//	Created:	08 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// Changed By	On			Reason
// ----------	--------	--------------------------------------
// 20/09/2013	cnwdap1		PAR #32215 CCMS DPH 2290 New Car Attributes
//11 Jul 2014	cnwrs1 	Par 34566 CCMS 2346 Suzano - Viagram Prenote file 
//16 Nov 2015	cnwrs1 	Par 36790 unable to update some fields
//22 Feb 2016	cnwrs1	Par 37568 TFS 1177 CCMS 2158 - EDI User defined  field expansion
// 03 May 2016	cnwdap1	TFS #1699 Verified Gross Mass changes
/// 22 Feb 2016	cnwrs1	TFS 3401 fixup EDI Operations update of EDI TIs
// 07 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
// 05 Jun 2018	jlgrs1	TFS 39018 SNO Cargo Operator in COPRAR
// 02 Oct 2020  cnwma1  ChangeRequest 50112: ASPA - GCI Stevedores
// 13 Jun 2022	jlika1	TFS 53316 - EUP - GEN - Additional Dimensions For Cargo - PortSchema
// 29 Nov 2022	jlika1	TFS 55586 HS Code User Defined EDI
// 19 Jun 2023	navdap1	TFS 57074 EUP manifest EDI Operations / Load Task 58604
// 19 Jul 2023	jlirs1	TFS 59187 (59019) EUP - Manifest Processing - Container Reference Field
// 20 Jul 2023	navdap1	TFS 58813 EUP Manifest Instructions and Work Orders
// 23 Apr 2024	jlirs1	TFS 63738 CUX - Enable trailers to be prenoted with User-Defined EDI
// 01 Oct 2025	navdap1	MTN-36141 AAT | RotaBox Creation (EDI/API/Manual)
vars
	objParentCargoType : CM_CargoType;
begin
	inheritMethod(_proxyEDITI);
	self.alternativeId := _proxyEDITI.alternativeId;
	self.bookingRef := _proxyEDITI.bookingRef;
	if app.isCargoGroupEnabled then	//17 Feb 2016	NDL	Par 37544
		self.cargoGroupId := _proxyEDITI.cargoGroupId;
	endif;
	self.commodity := _proxyEDITI.commodity;
	self.commodityDescription := _proxyEDITI.commodityDescription;
	self.consignee := _proxyEDITI.consignee;
	self.consignor := _proxyEDITI.consignor;
	self.customExportEntryNumber :=  _proxyEDITI.customExportEntryNumber;
	self.customsAgent := _proxyEDITI.customsAgent;		// cnwjre1 4/08/2016 TFS 2489 add customs agent to EDI prenote
	self.availabilityGrade := _proxyEDITI.availabilityGrade;
	self.destinationTerminal := _proxyEDITI.destinationTerminal;
	self.generatorType := _proxyEDITI.generatorType;
	self.expectedArrivalDate := _proxyEDITI.expectedArrivalDate;
	self.expectedArrivalTime := _proxyEDITI.expectedArrivalTime;
	self.onPowerDuringTransit := _proxyEDITI.onPowerDuringTransit;
	self.transitOnPowerDate := _proxyEDITI.transitOnPowerDate;
	self.transitOnPowerTime := _proxyEDITI.transitOnPowerTime;
	self.destinationPort := _proxyEDITI.destinationPort;
	self.dischargePort := _proxyEDITI.dischargePort;
	self.imCodes.clear;
	self.isoType := _proxyEDITI.isoType;
	_proxyEDITI.imCodes.copy(self.imCodes);
	self.height := _proxyEDITI.height;
	self.weight := _proxyEDITI.weight;
	self.width := _proxyEDITI.width;
	self.length := _proxyEDITI.length;
	self.loadPort := _proxyEDITI.loadPort;
	self.operatorCode := _proxyEDITI.operatorCode;
	self.remarks := _proxyEDITI.remarks;
	self.sealNum :=  _proxyEDITI.sealNum;				// this is the operator seal
	self.statusString :=  _proxyEDITI.statusString;
	self.transportMode :=  _proxyEDITI.transportMode;
	self.temperature := _proxyEDITI.temperature;
//	self.voyageCode := _proxyEDITI.voyageCode;	// cnwrl1 09/06/2010 PAR 24299 - what it was
	self.wagonNumber :=  _proxyEDITI.wagonNumber;
	self.wagonClass :=  _proxyEDITI.wagonClass;	//13 May 2014	NDL	Par 33615
	self.vent :=  _proxyEDITI.vent;
	self.setHumidity( _proxyEDITI.getHumidity );
	self.setOxygen(  _proxyEDITI.getOxygen );
	self.setCarbonDioxide(  _proxyEDITI.getCarbonDioxide );
	self.curtainsIn := _proxyEDITI.curtainsIn;
	 //par17696 cnwrs1 Aug 2008
//	self.consignorVoyage := _proxyEDITI.consignorVoyage;		// cnwrl1 11/06/2010 PAR 24299 - what it was
	// make sure the manual collection on CM_EDIConfig gets maintained
	self.setConsignorVoyage( _proxyEDITI.getConsignorVoyage() );
	self.customsSeal := _proxyEDITI.customsSeal;		// MAF/Customs Seal
	self.freightForwarder := _proxyEDITI.freightForwarder;
	self.imexStatus := _proxyEDITI.imexStatus;
	self.carrierCode := _proxyEDITI.carrierCode; //ccms1726 cnwrs1 sep 2008
	self.vehicle := _proxyEDITI.vehicle; //ccms1726

	// cnwjk3 CCMS 1758
	self.mark := _proxyEDITI.mark;
	self.markNumber := _proxyEDITI.markNumber;
	
	// cnwrl1 24/11/2009 PAR 21009 - start of coding
	// The following fields should also be allowed to be editable.
	self.bol				:= _proxyEDITI.bol;
	self.volume				:= _proxyEDITI.volume;
	self.receiveDate		:= _proxyEDITI.receiveDate;
	self.sealShipper		:= _proxyEDITI.sealShipper;
	self.product			:= _proxyEDITI.product.toUpper;		// Product is now Cargo Subtype
	self.productQuantity	:= _proxyEDITI.productQuantity;
	// cnwrl1 24/11/2009 PAR 21009 - end of coding
	
	self.sealNumberVent		:= _proxyEDITI.sealNumberVent; 		//CCMS1909 - PAR22160. cnwsh3	
	
	self.customsReference	:= _proxyEDITI.customsReference;	// cnwrl1 09/12/2009 PAR 21907
	
	//cnwgb1 par 21881 10.12.2009
	self.setOperatorImportReleasePIN( _proxyEDITI.getOperatorImportReleasePIN() );
	self.operatorImportReleasePIN := _proxyEDITI.operatorImportReleasePIN;// cnwgb1	PAR 23419 9.4.2010 
	
	self.parentCargoID := _proxyEDITI.parentCargoID;// cnwgb1	PAR 23419 9.4.2010 
	self.parentCargoType := _proxyEDITI.parentCargoType;// cnwgb1	PAR 23419 9.4.2010 
	if self.parentCargoType &lt;&gt; null then
		objParentCargoType	:= app.myRoot.getCargoTypeFromAbbrevOrDescr(self.parentCargoType);
		if objParentCargoType &lt;&gt; null then
			self.parentCargoTypeCode := objParentCargoType.id;
			self.parentCargoType := objParentCargoType.description;
		endif;
	else
		self.parentCargoTypeCode := 0;
	endif;

	self.make := _proxyEDITI.make;								// PAR #32215
	self.model := _proxyEDITI.model;							// PAR #32215
	self.carType := _proxyEDITI.carType;						// PAR #32215
	self.year := _proxyEDITI.year;								// PAR #32215
	self.colour := _proxyEDITI.colour;							// PAR #32215
	self.trackingNumber1 := _proxyEDITI.trackingNumber1;		// PAR #32215
	self.trackingNumber2 := _proxyEDITI.trackingNumber2;		// PAR #32215
	self.docsReceived := _proxyEDITI.docsReceived;				// PAR #32215
	self.docsSent := _proxyEDITI.docsSent;						// PAR #32215
	self.docsCleared := _proxyEDITI.docsCleared;				// PAR #32215
	self.docsReturned := _proxyEDITI.docsReturned;				// PAR #32215
	self.selfPropelled := _proxyEDITI.selfPropelled;			// PAR #32215
	self.doors := _proxyEDITI.doors;							// PAR #32215
	self.isNew := _proxyEDITI.isNew;							// PAR #32215
	self.hasRadio := _proxyEDITI.hasRadio;						// PAR #32215
	
	self.totalQuantity := _proxyEDITI.totalQuantity; 		//epr par  32950 14/11/13
	self.orderNumber := _proxyEDITI.orderNumber;
	self.invoiceNumber := _proxyEDITI.invoiceNumber;
	// par 36790 missing update fields
	self.timeAllowedOffPower := _proxyEDITI.timeAllowedOffPower;
	self.clientRef := _proxyEDITI.clientRef;
	self.coolingType := _proxyEDITI.coolingType;
	self.eirNumber := _proxyEDITI.eirNumber;
	self.offsiteCleaned := _proxyEDITI.offsiteCleaned;
	self.offsitePreTrip := _proxyEDITI.offsitePreTrip;
	self.overHeight := _proxyEDITI.overHeight;
	self.overLengthBack := _proxyEDITI.overLengthBack;
	self.overLengthFront := _proxyEDITI.overLengthFront;
	self.overWidthLeft := _proxyEDITI.overWidthLeft;
	self.overWidthRight := _proxyEDITI.overWidthRight;
	self.packDate := _proxyEDITI.packDate;
	self.packTempC := _proxyEDITI.packTempC;
	self.packTempF := _proxyEDITI.packTempF;
	self.packTime := _proxyEDITI.packTime;
	self.preTripped:= _proxyEDITI.preTripped;
	self.shippingLineCode := _proxyEDITI.shippingLineCode;
	self.vesselName := _proxyEDITI.vesselName;
	
	self.isWeightCertified := _proxyEDITI.isWeightCertified;					// TFS #1699
	self.weightCertifiedName := _proxyEDITI.weightCertifiedName;				// TFS #1699
	self.weightCertifiedReference := _proxyEDITI.weightCertifiedReference;		// TFS #1699
	
	self.serviceOrder := _proxyEDITI.serviceOrder;	//08 Nov 2016	NDL	TFS 2912 / 2419
	
	self.tareWeight := _proxyEDITI.tareWeight;	//15 Nov 2016	NDL	TFS 2959 / 2420
	self.cargoWeight := _proxyEDITI.cargoWeight;	//15 Nov 2016	NDL	TFS 2959 / 2420
	self.isControlledAtmosphere := _proxyEDITI.isControlledAtmosphere;
	self.expiryDate := _proxyEDITI.expiryDate;
	self.voltageType := _proxyEDITI.voltageType;
	self.isExternallyMonitored :=_proxyEDITI.isExternallyMonitored; //epr TFS 3581 6/3/17
	
	//24 Apr 2017	NDL	TFS 3414 
	self.heatTreated 		  := _proxyEDITI.heatTreated;
	self.storeOnPallet 		  := _proxyEDITI.storeOnPallet;
	self.palletType			  := _proxyEDITI.palletType;
	self.sealTerminalOperator := _proxyEDITI.sealTerminalOperator;
	self.sealUnknown 		  := _proxyEDITI.sealUnknown;
	self.releaseCarrierCode   := _proxyEDITI.releaseCarrierCode;
	self.stevedore            := _proxyEDITI.stevedore;               //02.10.2020 cnwma1 TFS #50112
	// jlika1 TFS 53316 --&gt;
	self.diameter 		:= _proxyEDITI.diameter;
	self.grade	  		:= _proxyEDITI.grade;
	self.grammage 		:= _proxyEDITI.grammage;
	self.rollingLength 	:= _proxyEDITI.rollingLength;
	// jlika1 TFS 53316 &lt;--
	self.operatorExportReleaseNumber:=_proxyEDITI.operatorExportReleaseNumber; //jlier1 TFS 53030 8/9/22
	self.hsCode	:= _proxyEDITI.hsCode;	//jlika1 TFS 55586
	
	self.itemised := _proxyEDITI.itemised;						// TFS 57074
	self.secondaryBarcodeId := _proxyEDITI.secondaryBarcodeId;	// TFS 57074
	self.sortingMethod := _proxyEDITI.sortingMethod;			// TFS 57074
	self.setContainerNumberText(_proxyEDITI.getContainerNumberText());	//19 Jul 2023	jlirs1	TFS 59187 (59019) EUP
	
	self.instructionType := _proxyEDITI.instructionType;			// TFS 58813
	self.instructionExternal := _proxyEDITI.instructionExternal;	// TFS 58813
	self.instructionInternal := _proxyEDITI.instructionInternal;	// TFS 58813
	self.condition := _proxyEDITI.condition; //16.Jun.2023 navsp1 TFS 57805
	self.trailerType := _proxyEDITI.trailerType;	// TFS 63738
	
	self.cargoTypeContents := _proxyEDITI.cargoTypeContents;			// MTN-36141
	self.cargoTypeDescContents := _proxyEDITI.cargoTypeDescContents;	// MTN-36141
epilog

end;</source>
        <Parameter name="_proxyEDITI" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setFromGoodAndItem" id="99df49c6-d76f-46dd-bb81-44c2152f5763">
        <updating/>
        <source>setFromGoodAndItem(	_transport : CMIF_JsonTransportFullEUP; 
					_good : CMIF_JsonGoodEUP; 
					_item : CMIF_JsonItemEUP; 
					_parent : CM_EDIPrenoteTI io; 
					_parentData : CM_EDIData; 
					_xlationOperator : CM_Operator;
					_manifest : CM_EDIDataTransManifest;
					_messageMode : String;
					_itemised : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Jun 2023	navsp1	Initial creation TFS ChangeRequest 57074: EUP - Manifest EDI Operations / Load (EDI Controller Agent) - Task 58269
23 Jun 2023	navdap1	TFS 58813 EUP - Manifest Instructions
18 Jul 2023	jlirs1	TFS 59004 Country of origin not being loaded
19 Jul 2023	jlirs1	TFS 59187 (59019) EUP - Manifest Processing - Container Reference Field
02 Aug 2023 navra1  TFS 59591 - EUP - Train Create
30 Aug 2023	navdap1	TFS 60150 EUP | FR 53824 - Road Manifest IMPORT cargo
07 Sep 2023	navdap1	TFS 60205 EUP | FR 53824 - Client Ref / Sales Order Number Validation
25 Sep 2023	navra1	TFS 60475 EUP | FR 53824 - Instructions are not imported from EDI file
13 Oct 2023	navdap1	TFS 60390 EUP | FR 53824 - Goods/Good/ID and Item grouping
19 Dec 2023	navcs2	Bug 61010: EUP | FR - 53824 Transport Manifest MilOrderNumber / MillOrderLineNumber Mapping Differences to Call Off
24 Jan 2024 navsp1  Bug 61660: EUP | FR 53824 Transport Manifest - Hazard Details From File Are Inaccurate
28 Feb 2024 navsp1  Bug 61725: MTN - Transport Manifest Date/Time Issue
16 May 2024 navsp1  TFS Bug 62254: EUP | FR - Transport Manifest - "Itemised" Field is not Working Correctly.
// 25 Nov 2024  navsaa30    MTN-33445 EUP - Hazardous Details in Transport Manifest are Only at the Good Level
// 09 May 2025	navpw1		JIRA: MTN-34625 - Added mapping of fields at item level if they are not null otherwise will use the value at good level
*/
vars
	cargoGroup		: Integer;
	cargoType 		: CM_CargoType;
	measureType 	: CM_MeasurementType;
	hazard 			: CM_EDIHazDetailsTI;
	foundMatch 		: Boolean;
	isoType			: CM_ISOType;
	cargoTypeStr,
	subCargoStr,
	isoTypeStr,
	xlatVoyageCode,
	xlatCommodity,
	xlatSorting,
	xlatConsignee,
	freightfwdrStr  : String;
	truckInfo		: CMIF_JsonTruckInfoEUP;
	dischargeStr, sortingStr, loadStr, destStr, carrierStr, location : String;
	commodity		: CM_Commodity;
	instrTypeStr	: String;
	uNcode,packingGrp,
	iMOclass			: String;
	flashpoint	: Real;
	limitedQuantity : Boolean;
begin
	truckInfo := _transport.truckInfo;
	
	if _transport.estimatedDateTimeOfArrival &lt;&gt; null then
		self.expectedArrivalDate	:= _transport.estimatedDateTimeOfArrival.asUTCTimeStamp.utcToLocalTime.Date;		//TFS 61725
		self.expectedArrivalTime 	:= _transport.estimatedDateTimeOfArrival.asUTCTimeStamp.utcToLocalTime.Time;		//TFS 61725
	endif;
	
	dischargeStr := _good.unloadingPort.toUpper();				//navra1 - TFS 59671 - 8th Aug 2023
	loadStr := _good.loadingPort.toUpper();						//navra1 - TFS 59671 - 8th Aug 2023
	destStr := _good.finalDestinationPort.toUpper();			//navra1 - TFS 59671 - 8th Aug 2023
	if _xlationOperator &lt;&gt; null then
		dischargeStr := _xlationOperator.getXlationSystemCode(dischargeStr, XLATION_TYPE_PORT_BYOP, foundMatch);
		loadStr :=  _xlationOperator.getXlationSystemCode(loadStr, XLATION_TYPE_PORT_BYOP, foundMatch);
		destStr :=  _xlationOperator.getXlationSystemCode(destStr, XLATION_TYPE_PORT_BYOP, foundMatch);//04.Aug.2023 navsp1 TFS 59656
	endif;
	self.dischargePort			:= dischargeStr;
	self.loadPort				:= loadStr;
	self.destinationPort		:= destStr;
	
	if _transport.trainInfo &lt;&gt; null then
		self.wagonClass := _transport.trainInfo.type;
		self.wagonNumber := _transport.trainInfo.wagonNumber;		
	endif;
	
	if _transport.containers.size &gt; 0 then			
		//ISO Type. Validate against ISO Types. Translatable by Sender Operator.
		isoTypeStr	:= _transport.containers.first.containerSizeType;
		if _xlationOperator &lt;&gt; null then
			isoTypeStr := _xlationOperator.getXlationSystemCode(isoTypeStr, XLATION_TYPE_ISOTYPE_BYOP, foundMatch);
		endif;
		isoType := app.myRoot.allISOTypes[isoTypeStr];
		if isoType &lt;&gt; null then
			self.isoType	:=	isoTypeStr;
		endif;		
	endif;
	
	if _transport.carrierParty &lt;&gt; null then
		carrierStr := _transport.carrierParty.code;
		if _xlationOperator &lt;&gt; null then
			carrierStr := _xlationOperator.getXlationSystemCode(carrierStr, XLATION_TYPE_CARRIER_BYOP, foundMatch);
		endif;
		self.carrierCode	:=  carrierStr;
	endif;
	
	self.messageMode := _messageMode;	//03.Jul.2023 navsp1 TFS 58055
	
	if _good &lt;&gt; null then
		if self.myEDIData = null then
			self.setMyEDIData(_parentData);
		endif;
		
		// create a cargo group - use the terminal default cargo group type
		cargoGroup := _parentData.getMyTerminal.defaultCargoGroupType;
		
		if cargoGroup &lt;&gt; null then
			//self.setCargoType(cargoGroup);	//navra1 - TFS 59591 - 2nd Aug 2023
		else
			app.writeLog(method.qualifiedName &amp; Tab &amp; "No configured Default Cargo Group Type for terminal", LogERROR);
		endif;
		
		if _item = null then			//TFS 62254
			self.id := _good.iD;		//TFS 62254
		else							//TFS 62254
			self.id := _good.keyMarks;
		endif;							//TFS 62254
		
		//Read and find the cargotype from good level																		//TFS 62254
		cargoTypeStr := _good.cargoType;																					//TFS 62254
		if _xlationOperator &lt;&gt; null then																					//TFS 62254
			cargoTypeStr := _xlationOperator.getXlationSystemCode(_good.cargoType, XLATION_TYPE_CARGOTYPE_BYOP, foundMatch);//TFS 62254
		endif;																												//TFS 62254
		//Translation return id for the cargo type object																	//TFS 62254
		if cargoTypeStr.isInteger then																						//TFS 62254
			cargoType := app.myRoot.allCargoTypesById[cargoTypeStr.Integer];												//TFS 62254
		else																												//TFS 62254
			cargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr( cargoTypeStr );											//TFS 62254
		endif;																												//TFS 62254
		
		// TFS 60150 don't convert Imex Status to Export, Euroports do send Import Road prenotes
		self.imexStatus := _good.movementType;
		
		if _good.goodsOwner &lt;&gt; null then	
			self.operatorCode := app.myRoot.getXlationSystemOperatorCode( _xlationOperator, _good.goodsOwner.code, foundMatch)[1:4];	// TFS 60150
		endif;
		
		//navra1 - TFS - 57808 - 16th June 2023 - start
		if self.operatorCode = null and _xlationOperator &lt;&gt; null then	//28.Jul.2023 navsp1 TFS 59265
			self.operatorCode := _xlationOperator.code;
		endif;	
		//navra1 - TFS - 57808 - 16th June 2023 - end	
		
		self.bol := _good.bOLNumber;
		if _good.bOLReference &lt;&gt; null then
			xlatVoyageCode := _good.bOLReference;
			if _xlationOperator &lt;&gt; null then
				xlatVoyageCode := _xlationOperator.getXlationSystemCode_Voyage(xlatVoyageCode, null, null, null, foundMatch);
			endif;
			self.setVoyageCode(xlatVoyageCode);		//Translated	
		endif;
		
		//InwardCode := VoyageNumber//Voyage Translation based on Sender Operator. Validate translated Code against Voyage Code, then Inward Code. 
		
		self.mark := _good.reference;
		
		if _good.millOrderNumber &lt;&gt; null and _good.millOrderLineNumber &lt;&gt; null then 		//19/12/2023 navcs2	Bug 61010
			self.orderNumber := _good.millOrderNumber &amp; '|' &amp; _good.millOrderLineNumber;	//19/12/2023 navcs2	Bug 61010
		endif;																				//19/12/2023 navcs2	Bug 61010
		
		self.setDescription(_good.description);
		self.grade := _good.grade;
		self.remarks := _good.remarks;
		self.colour := _good.colour;
		
		measureType := app.getMeasurementTypeByNameDesc(_good.lengthUOM);
		self.width := _good.width;
		self.length := _good.length;
		self.height := _good.thickness;
		self.diameter := _good.diameter;
		
		if measureType &lt;&gt; null then
			self.width := app.convertMeasurementForStorage(measureType.shortName, self.width);
			self.length := app.convertMeasurementForStorage(measureType.shortName, self.length);
			self.height := app.convertMeasurementForStorage(measureType.shortName, self.height);
			self.diameter := app.convertMeasurementForStorage(measureType.shortName, self.diameter);
		endif;
		
		self.grammage := _good.grammage;
		self.productQuantity := _good.piecesPerPack;//quantity

		self.condition 		:= _good.certificate;
		
		xlatCommodity := _good.quality;
		xlatSorting := _good.sortingMethod;
		if _xlationOperator &lt;&gt; null then
			xlatCommodity := _xlationOperator.getXlationSystemCode_Commodity(_good.quality, foundMatch, null);//Translate
			xlatSorting := _xlationOperator.getXlationSystemCode(xlatSorting, XLATION_TYPE_SORTINGMETHD_BYOP, foundMatch);//Translate
		endif;
		self.commodity := xlatCommodity;
		
		commodity := app.myRoot.allCommodities[xlatCommodity];		//07.Aug.2023 navsp1 TFS 59656
		if commodity &lt;&gt; null then
			self.commodityDescription := commodity.description;
		endif;
		
		self.sortingMethod := xlatSorting;
		
		//self.totalQuantity := _good.quantityExpected;
		self.totalQuantity := 1;			//navra1 - TFS 57808 - 23rd June 2023 - This is only one item, it should not be the total quantity exp
		
		measureType := app.getMeasurementTypeByNameDesc(_good.weightUOM);	//rs
		self.weight := _good.grossWeightExpected;		//rs
		self.tareWeight := _good.tareWeightExpected;
		self.cargoWeight := _good.nettWeightExpected;		//rs
		
		if measureType &lt;&gt; null then
			self.weight := app.convertMeasurementForStorage(measureType.shortName, self.weight);
			self.tareWeight := app.convertMeasurementForStorage(measureType.shortName, self.tareWeight);
			self.cargoWeight := app.convertMeasurementForStorage(measureType.shortName, self.cargoWeight);
		endif;
		
		measureType := app.getMeasurementTypeByNameDesc(_good.volumeUOM);
		self.volume := _good.volumeExpected;
		
		if measureType &lt;&gt; null then
			self.volume := app.convertMeasurementForStorage(measureType.shortName, self.volume);
		endif;
		
		if _good.mill &lt;&gt; null then
			xlatConsignee := _good.mill.code;
			if _xlationOperator &lt;&gt; null then
				xlatConsignee :=  _xlationOperator.getXlationSystemCode(xlatConsignee, XLATION_TYPE_CONSIGNEE_BYOP, foundMatch);//Translate;			
			endif;
		endif;
		self.consignor := xlatConsignee;
		
		xlatConsignee := null;
		if _good.buyer &lt;&gt; null then
			xlatConsignee := _good.buyer.code;
			if _xlationOperator &lt;&gt; null then
				xlatConsignee :=  _xlationOperator.getXlationSystemCode(xlatConsignee, XLATION_TYPE_CONSIGNEE_BYOP, foundMatch);//Translate;			
			endif;
		endif;
		self.consignee := xlatConsignee;
		
		if _good.forwardingAgent &lt;&gt; null then
             freightfwdrStr := _good.forwardingAgent.code;
            if _xlationOperator &lt;&gt; null then
				freightfwdrStr :=  _xlationOperator.getXlationSystemCode(freightfwdrStr, XLATION_TYPE_CONSIGNEE_BYOP, foundMatch);//09.Aug.2023 navsp1 TFS 59656	
			endif;
			self.freightForwarder:= freightfwdrStr;
		endif;
		
		self.directDelivery := _good.directOperation;
		self.alternativeId := _good.goodsBarcode;
		self.certificate1 := _good.certificate;
		self.parentCargoID := _good.containerNumber;
		self.countryOfOriginCode := _good.countryOfOrigin;	// 18 Jul 2023	jlirs1	TYFS 59004 Country of origin not being loaded
		if _manifest &lt;&gt; null then
			self.manifestNumber := _manifest.manifestNumber &amp; "|" &amp; _manifest.guid &amp; "|" &amp; _good.iD;		// TFS 60390
		endif;
		
		if _good.exportShippingLine &lt;&gt; null then
//rs			self.shippingLineCodeForTI := _good.exportShippingLine.code;
		endif;
		
		self.clientRef := _good.customerReference[1:30];		// TFS 60205
		self.specialStowage := _good.stowageMode;
		self.setLocationId(_good.vesselStorageLocation);
		self.setRemarksAdditional2(_good.operatorVoyageNumber);
		self.itemised := _itemised;								//TFS 62254
		
		// hazards?
		if  _itemised and (_good.iMOClass &lt;&gt; null or _good.uNCode &lt;&gt; null) then			//23.Jul.24 navsp1 TFS 61660 - _itemised condition restored, _item check removed
			iMOclass := _good.iMOClass;													//25/11/24  navsaa30 #33445
			uNcode := _good.uNCode;												
			flashpoint := _good.flashpoint;
			limitedQuantity := _good.limitedQuantity;
			packingGrp := _good.packingGroup;
		endif;
		
		// TFS 58813 instructions
		//if _good.instruction &lt;&gt; null and _item = null then																								//navra1 - TFS 60475 - 22nd Sep 2023
		if _good.instruction &lt;&gt; null and _item &lt;&gt; null then		//if you have instruction detail passed in and you are filling up the item of the good		//navra1 - TFS 60475 - 22nd Sep 2023
			instrTypeStr := _good.instruction.code;
			if _xlationOperator &lt;&gt; null then													//28.Aug.2023 navsp1 TFS 59656
				instrTypeStr := _xlationOperator.getXlationSystemCode_Instruct(instrTypeStr, foundMatch);
			endif;	
			self.instructionType := instrTypeStr;
			self.instructionExternal := _good.instruction.remark;
			self.instructionInternal := _good.instruction.internalRemark;
		endif;
		// TFS 58813
		
		if self.getContainerNumberText() = null and		// 19 Jul 2023	jlirs1	TFS 59187 (59019) EUP
		   _good.containerNumberText &lt;&gt; null then
			self.setContainerNumberText(_good.containerNumberText);
		endif;
		
		if _item = null then
			_parent := self;
			
			//set cargo type, cargo sub-type, cargo group-id for the non-itemised(zero items) cargo								//TFS 62254
			self.myParent := self;																								//TFS 62254
			if cargoType &lt;&gt; null then																							//TFS 62254
				self.setCargoType(cargoType.id);																				//TFS 62254
				if _good.packageType &lt;&gt; null then																				//TFS 62254
					subCargoStr := _good.packageType;																			//TFS 62254
					if _xlationOperator &lt;&gt; null then																			//TFS 62254
						subCargoStr := _xlationOperator.getXlationSystemCode_CargoSubT(subCargoStr, cargoType, foundMatch);		//TFS 62254
					endif;																										//TFS 62254					
					if foundMatch then																							//TFS 62254
						self.product := subCargoStr;																			//TFS 62254
					else																										//TFS 62254
						self.product := subCargoStr.toUpper();																	//TFS 62254
					endif;																										//TFS 62254
				endif;																											//TFS 62254
			else																												//TFS 62254
				app.writeLog(method.qualifiedName &amp; Tab &amp; "Cargo type could not be derived from " &amp; _good.cargoType, LogERROR);	//TFS 62254
				self.cargoTypeDescr := cargoTypeStr;																			//TFS 62254
			endif;																												//TFS 62254		
			// asociate this item with the cargo group created already															//TFS 62254
			self.cargoGroupId := _good.keyMarks;																				//TFS 62254
			
		endif;
		
	endif;
	
	if _item &lt;&gt; null then
		/**************Using the same value from _good level																	//TFS 62254
		// create cargo of the type specified in the good 
		cargoTypeStr := _good.cargoType;
		if _xlationOperator &lt;&gt; null then
			cargoTypeStr := _xlationOperator.getXlationSystemCode(_good.cargoType, XLATION_TYPE_CARGOTYPE_BYOP, foundMatch);
		endif;
		
		//Translation return id for the cargo type object
		if cargoTypeStr.isInteger then											//07.Aug.2023 navsp1 TFS 59656
			cargoType := app.myRoot.allCargoTypesById[cargoTypeStr.Integer];
		else
			cargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr( cargoTypeStr );
		endif;*/
		
		if cargoType &lt;&gt; null then
			self.setCargoType(cargoType.id);
		else
			app.writeLog(method.qualifiedName &amp; Tab &amp; "Cargo type could not be derived from " &amp; _good.cargoType, LogERROR);
			self.cargoTypeDescr := cargoTypeStr;		//navra1 - TFS 59591 - 2nd Aug 2023
		endif;
		
		// asociate this item with the cargo group created already
		self.cargoGroupId := _good.keyMarks;
		
		if _good.packageType &lt;&gt; null and cargoType &lt;&gt; null then																		//07.Aug.2023 navsp1 TFS 59656 - 
			subCargoStr := _good.packageType;
			if _xlationOperator &lt;&gt; null then
				subCargoStr := _xlationOperator.getXlationSystemCode_CargoSubT(subCargoStr, cargoType, foundMatch);//Translate     	//07.Aug.2023 navsp1 TFS 59656 - Translation require cargo type
			endif;
			
			if foundMatch then							//02.Oct.2023 navsp1 - fixes -
				self.product := subCargoStr;	//navra1 - TFS 59591 - 2nd Aug 2023
			else
				self.product := subCargoStr.toUpper();	//02.Oct.2023 navsp1 - Fixes - Since all the products are in uppercase format.
			endif;
		endif;
		
		if _parent &lt;&gt; null then
			self.myParent := _parent;
		endif;
		
		//self.itemised := _good = null or _good.items.size &gt; 1;	//TFS 62254
		self.itemised := _itemised;									//TFS 62254
		
		// overwrite selected fields with item values
		if _item.itemId &lt;&gt; null then
			self.id := _item.itemId;
		else
			self.id := _good.keyMarks;
		endif;
		
		if _item.itemBarcode1 &lt;&gt; null then
			self.alternativeId := _item.itemBarcode1;
		endif;
		if _item.itemBarcode2 &lt;&gt; null then
			self.secondaryBarcodeId := _item.itemBarcode2;
		endif;
		
		if _item.quantityExpected &lt;&gt; null then
			self.totalQuantity := _item.quantityExpected;
		endif;
		
		// weights
		if _item.weightUOM &lt;&gt; null then
			measureType := app.getMeasurementTypeByNameDesc(_item.weightUOM);
		elseif _good.weightUOM &lt;&gt; null then
			measureType := app.getMeasurementTypeByNameDesc(_good.weightUOM);
		endif;
		
		if _item.grossWeightExpected &lt;&gt; null then
			self.weight := _item.grossWeightExpected;
			if measureType &lt;&gt; null then
				self.weight := app.convertMeasurementForStorage(measureType.shortName, _item.grossWeightExpected);
			endif;
		endif;
		// ### JIRA: MTN-34625 12Jun2026 NAVPW1
		if _item.aDMTExpected &lt;&gt; null and
		   self.weight = null then
			self.weight := _item.aDMTExpected;
			if measureType &lt;&gt; null then
				self.weight := app.convertMeasurementForStorage(measureType.shortName, _item.aDMTExpected);
			endif;
		endif;
		// ### JIRA: MTN-34625 12Jun2026 NAVPW1
		if _item.nettWeightExpected &lt;&gt; null then					//rs
			self.cargoWeight := _item.nettWeightExpected;		//rs
			if measureType &lt;&gt; null then
				self.cargoWeight := app.convertMeasurementForStorage(measureType.shortName, _item.nettWeightExpected);	//rs
			endif;
		endif;
		
		if _item.tareWeightExpected &lt;&gt; null then
			self.tareWeight := _item.tareWeightExpected;
			if measureType &lt;&gt; null then
				self.tareWeight := app.convertMeasurementForStorage(measureType.shortName, _item.tareWeightExpected);
			endif;
		endif;
		
		// volume
		if _item.volumeExpected &lt;&gt; null then
			self.volume := _item.volumeExpected;
			if _item.volumeUOM &lt;&gt; null then
				measureType := app.getMeasurementTypeByNameDesc(_item.volumeUOM);
				if measureType &lt;&gt; null then
					self.volume := app.convertMeasurementForStorage(measureType.shortName, _item.volumeExpected);
				endif;
			endif;
		endif;
		
		// linear meaurements
		measureType := app.getMeasurementTypeByNameDesc(_item.lengthUOM);
		if _item.length &lt;&gt; null then
			self.length := _item.length;
			if measureType &lt;&gt; null then
				self.length := app.convertMeasurementForStorage(measureType.shortName, _item.length);
			endif;
		endif;
		
		if _item.width &lt;&gt; null then
			self.width := _item.length;
			if measureType &lt;&gt; null then
				self.width := app.convertMeasurementForStorage(measureType.shortName, _item.width);
			endif;
		endif;
		
		if _item.thickness &lt;&gt; null then
			self.height := _item.thickness;
			if measureType &lt;&gt; null then
				self.height := app.convertMeasurementForStorage(measureType.shortName, _item.thickness);
			endif;
		endif;
		
		if _item.diameter &lt;&gt; null then
			self.diameter := _item.thickness;
			if measureType &lt;&gt; null then
				self.diameter := app.convertMeasurementForStorage(measureType.shortName, _item.diameter);
			endif;
		endif;
		
		if _item.piecesPerPack &lt;&gt; null then
			self.productQuantity := _item.piecesPerPack;//quantity
		endif;
		
		if _item.containerNumber &lt;&gt; null then
			self.parentCargoID := _item.containerNumber;
		endif;
		
		measureType := app.getMeasurementTypeByNameDesc(_item.runningLengthUOM);
		if _item.runningLength &lt;&gt; null then
			self.rollingLength := _item.runningLength;
			if measureType &lt;&gt; null then
				self.rollingLength := app.convertMeasurementForStorage(measureType.shortName, _item.runningLength);
			endif;
		endif;	
		
		//Container operator 
		if _transport.containers.size &gt; 0 and _transport.containers.first.containerOperator &lt;&gt; null and _xlationOperator &lt;&gt; null then //28.Jul.2023 navsp1 TFS 59265
			self.operatorCode	:= _xlationOperator.getXlationSystemCode(_transport.containers.first.containerOperator.code, XLATION_TYPE_OPERATOR_BYOP, foundMatch)[1:4];//Translate
		endif;
		
		if self.operatorCode = null and _parent &lt;&gt; null then	//02.Nov.2023 navsp1 TFS 61067
			self.operatorCode := _parent.operatorCode;
		endif;
		
		// TFS 58813 instructions
		//we are definitely filling the item here, so fill the instruction if available //navra1 - TFS 60475 - 22nd Sep 2023
		if _item.instruction &lt;&gt; null then
			instrTypeStr := _item.instruction.code;
			if _xlationOperator &lt;&gt; null then								//28.Aug.2023 navsp1 TFS 59656
				instrTypeStr := _xlationOperator.getXlationSystemCode_Instruct(instrTypeStr, foundMatch);
			endif;	
			self.instructionType := instrTypeStr;
			self.instructionExternal := _item.instruction.remark;
			self.instructionInternal := _item.instruction.internalRemark;
		endif;
		// TFS 58813
		
		if self.getContainerNumberText() = null and		// 19 Jul 2023	jlirs1	TFS 59187 (59019) EUP
		   _item.containerNumberText &lt;&gt; null then
			self.setContainerNumberText(_item.containerNumberText);
		endif;
		
		// ### JIRA: MTN-34625 12Jun2026 NAVPW1
		if _itemised then
			if _item.iMOClass &lt;&gt; null then
			  iMOclass := _item.iMOClass;
			endif;
			
			if _item.uNCode &lt;&gt; null then
			  uNcode := _item.uNCode;
			endif;
			
			if _item.flashpoint &lt;&gt; null then
				flashpoint := _item.flashpoint;
			endif;
			
			if _item.limitedQuantity &lt;&gt; null then
				limitedQuantity := _item.limitedQuantity;
			endif;
			
			if _item.packingGroup &lt;&gt; null then
				packingGrp := _item.packingGroup;
			endif;
			
		endif;
		// ### JIRA: MTN-34625 12Jun2026 NAVPW1
		
		if _itemised and  (iMOclass &lt;&gt; null or uNcode &lt;&gt; null) then				//TFS 61660/64071		//25/11/24  navsaa30 #33445
			create hazard persistent;														//TFS 61660/64071
			hazard.messageMode := _messageMode;												//TFS 61660/64071
			hazard.code := iMOclass;													//TFS 61660/64071		//25/11/24  navsaa30 #33445
			hazard.id := _item.itemId;														//TFS 61660/64071
			hazard.myParent := self;														//TFS 61660/64071
			hazard.setMyEDIData(_parentData);												//TFS 61660/64071
			hazard.flashpointTemperature := flashpoint;								//TFS 61660/64071		//25/11/24  navsaa30 #33445
			hazard.limitedQuantity := limitedQuantity;								//TFS 61660/64071		//25/11/24  navsaa30 #33445
			hazard.packingGroup := packingGrp;										//TFS 61660/64071		//25/11/24  navsaa30 #33445
			hazard.undgCodes := uNcode;												//TFS 61660/64071		//25/11/24  navsaa30 #33445
			if cargoType &lt;&gt; null then														//TFS 61660/64071
				hazard.cargoTypeDescr := cargoType.description;								//TFS 61660/64071
				hazard.cargoSubType	:= self.product;	//_good.packageType.toUpper;							//TFS 61660/64071               //JIRA 33568 -  use the one set earlier
			endif;																			//TFS 61660/64071
			
		endif;																				//TFS 61660
		
		// ### JIRA: MTN-34625 12Jun2026 NAVPW1
		if _item.certificate &lt;&gt; null then
			self.condition := _item.certificate;
		endif;
		
		if _item.colour &lt;&gt; null then
			self.colour := _item.colour;
		endif;
		
		if _item.countryOfOrigin &lt;&gt; null then
			self.countryOfOriginCode := _item.countryOfOrigin;
		endif;
		
		if _item.description &lt;&gt; null then
			self.setDescription(_item.description);
		endif;
		
		if _item.grade &lt;&gt; null then
			self.grade := _item.grade;
		endif;
		
		if _item.grammage &lt;&gt; null then
			self.grammage := _item.grammage;
		endif;
		
		if _item.goodsBarCode &lt;&gt; self.id then
			self.alternativeId := _item.goodsBarCode;
		endif;
		
		if _item.loadPort &lt;&gt; null then
			loadStr := _item.loadPort.toUpper();
			if _xlationOperator &lt;&gt; null then
				loadStr :=  _xlationOperator.getXlationSystemCode(loadStr, XLATION_TYPE_PORT_BYOP, foundMatch);//Translate;
			endif;
			self.loadPort := loadStr;
		endif;
		
		if _item.stowMode &lt;&gt; null then
			self.specialStowage := _item.stowMode;
		endif;
		
		if _item.millOrderNumber &lt;&gt; null and _item.millOrderLineNumber &lt;&gt; null then
			self.orderNumber := _item.millOrderNumber &amp; '|' &amp; _item.millOrderLineNumber;
		endif;
		
		if _item.reference &lt;&gt; null then
			self.mark := _item.reference;
		endif;
		
		if _item.remarks &lt;&gt; null then
			self.remarks := _item.remarks;
		endif;
		
		if _item.sortingMethod &lt;&gt; null then
			sortingStr := _item.sortingMethod;
			if _xlationOperator &lt;&gt; null then
				sortingStr := _xlationOperator.getXlationSystemCode(sortingStr, XLATION_TYPE_SORTINGMETHD_BYOP, foundMatch);
			endif;
			self.sortingMethod := sortingStr;
		endif;
		
		if _item.warehouse &lt;&gt; null then
			location := _item.warehouse &amp; ' ' &amp; _item.storageLocation;
			if _item.storageLocation = null then
				location := _item.warehouse; 
			endif;
			self.setLocationId(location);
		endif;
		
		// ### JIRA: MTN-34625 12Jun2026 NAVPW1
		
	endif;
	

epilog

end;</source>
        <Parameter name="_transport" type="CMIF_JsonTransportFullEUP"/>
        <Parameter name="_good" type="CMIF_JsonGoodEUP"/>
        <Parameter name="_item" type="CMIF_JsonItemEUP"/>
        <Parameter name="_parent" type="CM_EDIPrenoteTI" usage="io"/>
        <Parameter name="_parentData" type="CM_EDIData"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
        <Parameter name="_manifest" type="CM_EDIDataTransManifest"/>
        <Parameter name="_messageMode" type="String"/>
        <Parameter name="_itemised" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setHumidity" id="e646ecd5-9540-4c9e-b4f4-addf13e7a0a8">
        <updating/>
        <source>setHumidity(_humidity : Decimal) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 April 2020	jlgndl1	Initial creation	TFS 47958
*/
vars

begin
	self.humidity	:= _humidity;
epilog

end;</source>
        <Parameter name="_humidity" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="setImCodes" id="c4d8d5a6-edd7-4954-aee3-9d3a4b664ec3">
        <updating/>
        <source>setImCodes(_codes: String) updating;
//
//02 Feb 2012	cnwrs1	Par 29076 Fix up Hazard Processing in EDI
//
vars
	tmpIMCodes : StringArray;
begin
	create tmpIMCodes transient;
	self.addImCodes(_codes, tmpIMCodes);			// MES1008 allow imCodes in toehr classes. Was typecasting to _ediTI.CM_EDIPrenoteTI.imCodes.add(_processedValue);
	self.imCodes.clear();							// 17/03/2014 cnwmh5 #33648
	tmpIMCodes.copy(self.imCodes);
epilog    
	delete tmpIMCodes;
end;
</source>
        <Parameter name="_codes" type="String"/>
    </JadeMethod>
    <JadeMethod name="setItemisedData" id="123d844e-473f-4c4e-b45c-932b90c06ecf">
        <updating/>
        <source>setItemisedData() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 February 2025	navsp1	Initial creation JIRA-27323

*/

vars
	ct 				: CM_CargoType;
begin
	if self.cargoType &lt;&gt; null then
		ct := app.myRoot.allCargoTypesById[self.cargoType];
		if ct &lt;&gt; null and not ct.allowDuplicates then
			self.itemised	:= true;
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setLocationId" id="dc61e153-44cd-4776-bd49-8004b49e3a5c">
        <updating/>
        <source>setLocationId(_value: String) updating;
//----------------------------------------------------------------
//	Created:	24 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	self.locationId := _value.padLeadingZeros(7);

epilog

end;</source>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="setMeasurementTypeValue" id="8e4194f3-5eb7-489a-8dce-4def2f92293c">
        <updating/>
        <source>setMeasurementTypeValue(_columnName: String; _value: String) : Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 September 2014	cnwmc5	Initial creation	PAR 34533

*/

vars
	rowName,
	measureType		: String;
	
begin

	if not inheritMethod(_columnName, _value) then
		return false;
	endif;
	
	_columnName.getRowNameMeasureType(rowName, measureType);
	
	if rowName = ETRow_TotalWeight then
		self.weight := app.convertMeasurementForStorage(measureType, _value.asDecimalJMT());
		return true;
	endif;
	
	if self.class.getPropertyInHTree(rowName) &lt;&gt; null then
		self.setPropertyValue(rowName, app.convertMeasurementForStorage(measureType, _value.asDecimalJMT()));
	endif;
	
	return true;
	
epilog

end;</source>
        <Parameter name="_columnName" type="String"/>
        <Parameter name="_value" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setOneStopAperakValues" id="ddc1aecb-8580-4946-a7d1-1df7800c5167">
        <updating/>
        <source>setOneStopAperakValues( _ediFile: CM_EDIFile; _docRef : String; _sentTs : TimeStamp ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 September 2016	cnwndl1	Initial creation	TFS 2276 / 2565

*/

vars

begin

	global.setExtraData(self.allExtraData, self, CM_EDIFileTypeXMLOneStopPre.EDIFileRef, _ediFile);
	global.setExtraData(self.allExtraData, self, CM_EDIFileTypeXMLOneStopPre.TagDocumentRefNum, _docRef);
	global.setExtraData(self.allExtraData, self, CM_EDIFileTypeXMLOneStopPre.TagLocalDateTimeSent, _sentTs);
	
epilog

end;</source>
        <Parameter name="_ediFile" type="CM_EDIFile"/>
        <Parameter name="_docRef" type="String"/>
        <Parameter name="_sentTs" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="setOperator" id="dafbe668-3080-4929-bba5-782c06700438">
        <updating/>
        <source>setOperator(_operator: CM_Operator) updating;
//----------------------------------------------------------------
//	Created:	24 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	if _operator = null then
		self.operatorCode := "";
		return;
	endif;
		
	self.operatorCode := _operator.code;
	
end;</source>
        <Parameter name="_operator" type="CM_Operator"/>
    </JadeMethod>
