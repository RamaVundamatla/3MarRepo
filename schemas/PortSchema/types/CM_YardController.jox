    <JadeMethod name="setupForDeckingInBlock" id="f8037407-2d7a-46ae-bca7-cb023fccb21d">
        <source>setupForDeckingInBlock(_fromHeight, _toHeight: Integer; _deckingOptions: CM_YADeckingOptionsBlock input);
//----------------------------------------------------------------
//	Created:	28 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	taIndex,
	rowIndex,
	blockIndex,
	intHeight		: Integer;
	yaLocnCell,
	prevYALocnCell	: CM_YALocationCell;
	terminalArea	: CM_TerminalArea;
	gridRow			: CM_GridObject;
	yaBlock			: CM_YABlock;
begin
	if _fromHeight &lt; 1 then
		//applies to nothing
		return;
	endif;

	yaBlock := _deckingOptions.myYABlock;
	gridRow := yaBlock.getGridObject();
	if gridRow = null then
		terminalArea := yaBlock.myTerminalArea;
	else
		terminalArea := gridRow.getGridArea();
	endif;
	
	//other rules may cover other heights
	foreach intHeight in _fromHeight to _toHeight do
		blockIndex			:= null;
		rowIndex			:= null;
		taIndex				:= null;
		prevYALocnCell		:= yaLocnCell;
		
		if intHeight &gt; self.allYAYardLocationCells.size then
			yaLocnCell := null;
		else
			yaLocnCell := self.allYAYardLocationCells[intHeight];		
		endif;

		if yaLocnCell = null then
			//missing a cell at this height
			create yaLocnCell persistent;
			self.allYAYardLocationCells.insert(intHeight, yaLocnCell);
			yaLocnCell.setForCreate(intHeight);
		else
			//find the index in the ta
			taIndex := terminalArea.myYADeckingOptions.allYALocationCellsIn.indexOf(yaLocnCell);
			if gridRow &lt;&gt; null then
				rowIndex := gridRow.myDeckingOptions.allYALocationCellsIn.indexOf(yaLocnCell);
			endif;
			blockIndex := _deckingOptions.allYALocationCellsIn.indexOf(yaLocnCell);
		endif;
		
		if taIndex = null then	//new and/or can't find it ta array
			//fixup ta
			if  prevYALocnCell = null then
				//a new pad position/cell - stick it in at the end
				
				terminalArea.myYADeckingOptions.allYALocationCellsIn.add(yaLocnCell);
				
			else
				//an old pad position but now higher - stick it in after previous
				//insert it after
				taIndex := terminalArea.myYADeckingOptions.allYALocationCellsIn.indexOf(prevYALocnCell);
				if taIndex &gt; 0 then
					terminalArea.myYADeckingOptions.allYALocationCellsIn.insert(taIndex+1, yaLocnCell);
				else
					terminalArea.myYADeckingOptions.allYALocationCellsIn.add(yaLocnCell);
				endif;
			endif;
		endif;
		
		if gridRow &lt;&gt; null
		and rowIndex = null then	//new and/or can't find it row array
			if  prevYALocnCell = null then
				//a new pad position/cell - stick it in at the end
				gridRow.myDeckingOptions.allYALocationCellsIn.add(yaLocnCell);
			else
				//an old pad position but now higher - stick it in after previous
				//insert it after
				rowIndex := gridRow.myDeckingOptions.allYALocationCellsIn.indexOf(prevYALocnCell);
				if rowIndex &gt; 0 then
					gridRow.myDeckingOptions.allYALocationCellsIn.insert(rowIndex+1, yaLocnCell);
				else
					gridRow.myDeckingOptions.allYALocationCellsIn.add(yaLocnCell);
				endif;
			endif;
		endif;
		
		if blockIndex = null then	//new and/or can't find it row array
			if  prevYALocnCell = null then
				//a new pad position/cell - stick it in at the end
				_deckingOptions.allYALocationCellsIn.add(yaLocnCell);
			else
				//an old pad position but now higher - stick it in after previous
				//insert it after
				blockIndex := _deckingOptions.allYALocationCellsIn.indexOf(prevYALocnCell);
				if blockIndex &gt; 0 then
					_deckingOptions.allYALocationCellsIn.insert(blockIndex+1, yaLocnCell);
				else
					_deckingOptions.allYALocationCellsIn.add(yaLocnCell);
				endif;
			endif;
		endif;		
	endforeach;
end;</source>
        <Parameter name="_fromHeight" type="Integer"/>
        <Parameter name="_toHeight" type="Integer"/>
        <Parameter name="_deckingOptions" type="CM_YADeckingOptionsBlock" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForDeckingInRow" id="90a84632-e737-4c7b-b857-968358c38557">
        <source>setupForDeckingInRow(_fromHeight, _toHeight: Integer; _deckingOptions: CM_YADeckingOptionsRow input; _yaIndex: Integer io);
//----------------------------------------------------------------
//	Created:	28 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	taIndex,
	rowIndex,
	intHeight		: Integer;
	yaLocnCell,
	prevYALocnCell	: CM_YALocationCell;
	terminalArea	: CM_GridArea;
	gridRow			: CM_GridObject;
begin
	if _fromHeight &lt; 1 then
		//applies to nothing
		return;
	endif;

//app.writeStatement('CNWJC2 ' &amp; class.name &amp; " " &amp; method.name &amp;  "              applying to " &amp; self.String );

	gridRow := _deckingOptions.myGridObject;
	terminalArea := gridRow.getGridArea;
	
	//other rules may cover other heights
	foreach intHeight in _fromHeight to _toHeight do
		//default index
		_yaIndex			:= _yaIndex + 1;	//decking index
		rowIndex			:= null;
		taIndex				:= null;
		prevYALocnCell		:= yaLocnCell;
		
		if intHeight &gt; self.allYAYardLocationCells.size then
			yaLocnCell := null;
		else
			yaLocnCell := self.allYAYardLocationCells[intHeight];		
		endif;

		if yaLocnCell = null then
			//missing a cell at this height
			create yaLocnCell persistent;
			self.allYAYardLocationCells.insert(intHeight, yaLocnCell);
			yaLocnCell.setForCreate(intHeight);
//app.writeStatement('CNWJC2 ' &amp; class.name &amp; " " &amp; method.name &amp;  " create " );
		else
			//find the index in the ta
			taIndex := terminalArea.myYADeckingOptions.allYALocationCellsIn.indexOf(yaLocnCell);
			rowIndex := _deckingOptions.allYALocationCellsIn.indexOf(yaLocnCell);
		endif;
		
//app.writeStatement('CNWJC2 ' &amp; class.name &amp; " " &amp; method.name &amp;  "                   height " &amp; intHeight.String &amp; "  idx " &amp; _yaIndex.String &amp; " taIndex=" &amp; taIndex.String);

		
		if taIndex = null then	//new and/or can't find it ta array
			//fixup ta
			if  prevYALocnCell = null then
//app.writeStatement('CNWJC2 ' &amp; class.name &amp; " " &amp; method.name &amp;  " adding to ta array " );
				//a new pad position/cell - stick it in at the end
				terminalArea.myYADeckingOptions.allYALocationCellsIn.add(yaLocnCell);
			else
				//an old pad position but now higher - stick it in after previous
				//insert it after
				taIndex := terminalArea.myYADeckingOptions.allYALocationCellsIn.indexOf(prevYALocnCell);
				if taIndex &gt; 0 then
//app.writeStatement('CNWJC2 ' &amp; class.name &amp; " " &amp; method.name &amp;  " inserting after previous " );
					terminalArea.myYADeckingOptions.allYALocationCellsIn.insert(taIndex+1, yaLocnCell);
				else
//app.writeStatement('CNWJC2 ' &amp; class.name &amp; " " &amp; method.name &amp;  " adding - no taIndex for previous " );
					terminalArea.myYADeckingOptions.allYALocationCellsIn.add(yaLocnCell);
				endif;
			endif;
		endif;
		
		if rowIndex = null then	//new and/or can't find it row array
			if  prevYALocnCell = null then
//app.writeStatement('CNWJC2 ' &amp; class.name &amp; " " &amp; method.name &amp;  " adding to ta array " );
				//a new pad position/cell - stick it in at the end
				_deckingOptions.allYALocationCellsIn.add(yaLocnCell);
			else
				//an old pad position but now higher - stick it in after previous
				//insert it after
				rowIndex := _deckingOptions.allYALocationCellsIn.indexOf(prevYALocnCell);
				if rowIndex &gt; 0 then
//app.writeStatement('CNWJC2 ' &amp; class.name &amp; " " &amp; method.name &amp;  " inserting after previous " );
					_deckingOptions.allYALocationCellsIn.insert(rowIndex+1, yaLocnCell);
				else
//app.writeStatement('CNWJC2 ' &amp; class.name &amp; " " &amp; method.name &amp;  " adding - no rowIndex for previous " );
					_deckingOptions.allYALocationCellsIn.add(yaLocnCell);
				endif;
			endif;
		endif;
		
		
	endforeach;

end;</source>
        <Parameter name="_fromHeight" type="Integer"/>
        <Parameter name="_toHeight" type="Integer"/>
        <Parameter name="_deckingOptions" type="CM_YADeckingOptionsRow" usage="input"/>
        <Parameter name="_yaIndex" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setupForDeckingInTA" id="cd2ce7e1-97e5-41ea-9070-a3c761ef9c54">
        <source>setupForDeckingInTA(_fromHeight, _toHeight: Integer; _deckingOptions: CM_YADeckingOptionsTA input; _yaIndex: Integer io);
//----------------------------------------------------------------
//	Created:	07 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	taIndex,
	intHeight		: Integer;
	yaLocnCell,
	prevYALocnCell	: CM_YALocationCell;
//	terminalArea	: CM_GridArea;
begin
	if _fromHeight &lt; 1 then
		//applies to nothing
		return;
	endif;

//app.writeStatement('CNWJC2 ' &amp; class.name &amp; " " &amp; method.name &amp;  "              applying to " &amp; self.String );
	
//	terminalArea := _deckingOptions.myTerminalGridArea;
	//other rules may cover other heights
	foreach intHeight in _fromHeight to _toHeight do
		//default index
		_yaIndex			:= _yaIndex + 1;	//decking index
		taIndex				:= null;
		prevYALocnCell		:= yaLocnCell;
		
		if intHeight &gt; self.allYAYardLocationCells.size then
			yaLocnCell := null;
		else
			yaLocnCell := self.allYAYardLocationCells[intHeight];		
		endif;

		if yaLocnCell = null then
			//missing a cell at this height
			create yaLocnCell persistent;
			self.allYAYardLocationCells.insert(intHeight, yaLocnCell);
			yaLocnCell.setForCreate(intHeight);
//app.writeStatement('CNWJC2 ' &amp; class.name &amp; " " &amp; method.name &amp;  " create " );
		else
			//find the index in the ta
			taIndex := _deckingOptions.allYALocationCellsIn.indexOf(yaLocnCell);
		endif;
		
//app.writeStatement('CNWJC2 ' &amp; class.name &amp; " " &amp; method.name &amp;  "                   height " &amp; intHeight.String &amp; "  idx " &amp; _yaIndex.String &amp; " taIndex=" &amp; taIndex.String);

		if taIndex = null then	//new and/or can't find it ta array
			if  prevYALocnCell = null then
//app.writeStatement('CNWJC2 ' &amp; class.name &amp; " " &amp; method.name &amp;  " adding to ta array " );
				//a new pad position/cell - stick it in at the end
				_deckingOptions.allYALocationCellsIn.add(yaLocnCell);
			else
				//an old pad position but now higher - stick it in after previous
				//insert it after
				taIndex := _deckingOptions.allYALocationCellsIn.indexOf(prevYALocnCell);
				if taIndex &gt; 0 then
//app.writeStatement('CNWJC2 ' &amp; class.name &amp; " " &amp; method.name &amp;  " inserting after previous " );
					_deckingOptions.allYALocationCellsIn.insert(taIndex+1, yaLocnCell);
				else
//app.writeStatement('CNWJC2 ' &amp; class.name &amp; " " &amp; method.name &amp;  " adding - no taIndex for previous " );
					_deckingOptions.allYALocationCellsIn.add(yaLocnCell);
				endif;
			endif;
		else
			_deckingOptions.allYALocationCellsIn.remove(yaLocnCell);
			_deckingOptions.allYALocationCellsIn.insert(_yaIndex, yaLocnCell);
		endif;
	endforeach;

end;</source>
        <Parameter name="_fromHeight" type="Integer"/>
        <Parameter name="_toHeight" type="Integer"/>
        <Parameter name="_deckingOptions" type="CM_YADeckingOptionsTA" usage="input"/>
        <Parameter name="_yaIndex" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="testAutoPlanRequest" id="ae19b2a3-a4a5-4320-b96a-b47624a1bd45">
        <source>testAutoPlanRequest(obj: CMIF_AutoMovePlan input);
//Request based testing only, looking for SOURCE of TI's

// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	ti : CM_TrackedItem;
	i : Integer;
	numToCheck : Integer;
	searchBothEnds : Boolean;
	msgStr : String;
	testAll	:	Boolean;
	numToTest	:	Integer;
	halfWayPoint		:	Integer;
	totalWeNeed	: Integer;			//AJA 3/9/99
	itemsFound : Integer;
begin

	//---------------
	//check the Restrictions on this area.
	//---------------
	//obj.addLogEntry("Testing location Restrictions", IsForLogging); //- cnwmd1, Par 20524
	obj.addLogEntry(app.getErrorString(Testing_location_restrictio), IsForLogging, Testing_location_restrictio);
	self.testIsControllerRestricted(obj);
	if obj.getController = null then
		return;
	endif;
	//We check for the number of TI's that exist here. No point sending a machine all over the place to satisfy requests.
	if obj.request.totalRequested = 0 then
		//Silly! Quit
		//obj.addVerboseLogEntry("No TI's in request", IsForLogging, 0); //- cnwmd1, Par 20524
		obj.addVerboseLogEntry(app.getErrorString(Request), IsForLogging, Request);
		obj.updateController(null);
		return;
	endif;
	/*
	This test has been removed, we want the system to check all boxes in a STRADDLE stack
	the blockController over-rides this method itself. DQ 23/04/1999

	if obj.request.totalRequested &gt; trackedItems.size then
		//Not enough here.. Quit
		obj.addVerboseLogEntry("Request wants " &amp; obj.request.totalRequested.String &amp; ", only " &amp; trackedItems.size.String &amp; " in area.");
		obj.updateController(null);
		return;
	endif; */
	//-------------
	//Damn, this has NOT given us enough goodies
	//Grab TI's, see if any are any good.
	//This will NOT be fun!
	//-------------
	
	numToTest := self.myTerminalArea.autoPlanTest.maxInBlockToTest;

	totalWeNeed := obj.request.totalRequested;

	testAll := ( numToTest = 0 );
 	//If stack is &gt; 6 (ie, 3 accessible from each end), then limit
	//search to either end, else do all
	numToCheck := numTIs;  //Check em all
  if numToCheck = 0 then
  	//aint nothing here!
		obj.updateController(null);
		return;
  endif;
	searchBothEnds := false;
	//msgStr := "Continuing to check all accessible Objects in this area. (" &amp; numTIs.String &amp; " in stack)"; //- cnwmd1, Par 20524
	if testAll = false then
		if numToCheck &gt; numToTest then
	 		searchBothEnds := true;
			numToCheck := numToTest;
	 		//msgStr := "Continuing to check maximum of " &amp; numToCheck.String &amp; " accessible Objects from each end of this area. (" &amp; numTIs.String &amp; " in stack)";
			msgStr := app.getErrorString2(Conti_check_maxim_acces_objec_, numToCheck.String, numTIs.String);
			obj.addLogEntry(msgStr, IsForLogging, Conti_check_maxim_acces_objec_);
	 		halfWayPoint := numTIs div 2;
	 	endif;
	endif;
	
	if msgStr = null then //+ cnwmd1, Par 20524
		//obj.addLogEntry(msgStr, IsForLogging);
		msgStr := app.getErrorString1(Conti_check_acces_objec_this_a, numTIs.String);
		obj.addLogEntry(msgStr, IsForLogging, Conti_check_acces_objec_this_a);
	endif;
	i := 1;
	itemsFound := 0;
	foreach ti in self.allTrackedItems do
		//-------------------
		//Default to the fact this is an OK area.
		//-------------------
		obj.updateController(self);
		
 		ti.testAutoPlanRequest(obj);	//This over-writes it if NOT
		if obj.getController &lt;&gt; null then
	 	 	//Located one!
	 	 	itemsFound := itemsFound + 1;
	 	 	if itemsFound &gt;= totalWeNeed then
	  		return;       //We have found enough in here to satisfy the request
	  	endif;
  	endif;
		if not testAll and ( i = numToCheck  or i = halfWayPoint) then
			break;
		endif;
		i := i +1;
 	endforeach;
 	msgStr := "";
 	if searchBothEnds then
		//obj.addVerboseLogEntry("Searching " &amp; numToCheck.String &amp; " from reverse end.", IsForLogging, 0); //- cnwmd1, Par 20524
		obj.addVerboseLogEntry(app.getErrorString1(Searching_from_reverse,numToCheck.String), IsForLogging, Searching_from_reverse);
		i := 1;
		itemsFound := 0 ;
		foreach ti in self.allTrackedItems reversed do
			obj.updateController(self);
	  		ti.testAutoPlanRequest(obj);
		  	if obj.getController &lt;&gt; null then
		  		//Located one!
	 	 			itemsFound := itemsFound + 1;
	 	 			if itemsFound &gt;= totalWeNeed then
	  				return;    //We have found enough in here to satisfy the request
	  			endif;
		  	endif;
		  	//-----------------
		  	//Only check as many as we need to, if they have specified a total that is &gt; 
		  	///1/2 tis in area, only check 1/2.
		  	//-----------------
			if i = numToCheck or i = halfWayPoint then
				break;
			endif;
		 	i := i +1;
		endforeach;
	endif;
end;</source>
        <Parameter name="obj" type="CMIF_AutoMovePlan" usage="input"/>
    </JadeMethod>
