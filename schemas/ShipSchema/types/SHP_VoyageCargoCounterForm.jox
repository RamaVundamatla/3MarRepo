    <JadeMethod name="displayCargoType" id="a3ed54b3-b0bb-447b-9d6b-82999a1a5495">
        <source>displayCargoType(_cargoType :CM_CargoType):String protected;
/*
Date		Who		Reason
18 August 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/
