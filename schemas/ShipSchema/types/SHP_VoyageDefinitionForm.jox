    <JadeMethod name="btnArchive_click" id="ef806a8b-81f4-49fd-bc52-b9b03a673f40">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnArchive_click(btn: Button input) updating;
//--------------------------------------------------
// Created:	02 August 2005 By: 
//--------------------------------------------------
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Aug 2005	cnwgd1	Initial creation
13 Mar 2020 cnwma1	Bug 48863: JMT - Voyage Archive, Non Worked Cargo Issue
*/

vars
	allVoyages	: CM_VoyageArray;
	errorMsg    : String;
begin

	if self.myCurrentVoyage = null then	
		app.msgBox('Please select a Voyage to archive.', 'Select Voyage', MsgBox_OK_Only+MsgBox_Information_Icon);
		return;
	endif;
	
	if not self.myCurrentVoyage.checkAllResourcesAreCharged() then
		errorMsg	:=	'Cannot Archive.' &amp; Cr &amp; 
						'Voyage ' 		  &amp; self.myCurrentVoyage.code &amp;
						' has outstanding Resources that have not been charged.';
		
		app.msgBox(errorMsg, 'Select Voyage', MsgBox_OK_Only+MsgBox_Information_Icon);
		return;	
	endif;
		
		
	create allVoyages transient;
	allVoyages.add(self.myCurrentVoyage);
	
	if self.myAssistant.showVoyageArchiveForm(allVoyages, self.myMasterMenuAction, false) then
		self.setMyCurrentVoyage(null);
	endif;
epilog
	delete allVoyages;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
