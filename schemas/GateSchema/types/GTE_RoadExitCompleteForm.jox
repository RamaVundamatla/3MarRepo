    <JadeMethod name="initDataTable" id="b50fec5f-9b36-45b3-9070-aaa1261862af">
        <updating/>
        <source>initDataTable(_table : CM_DataTable; _entdef : String) updating, protected;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 08 August 2007
//
//----------------------------------------------------------------------

vars
	numColumns,
	colWidth,
 	col			: Integer;
	entDef	:EntTableDef;
	tbl1	:CM_DataTable;
	
begin
	if _table = null or _entdef = null then
		return;
	endif;
	
	self.resize();
	entDef := app.myController.getEntTableDef(_entdef);
	tbl1 := _table;
	
	tbl1.rows := 1;
	tbl1.fixedRows 	:= 1;
	
	//if You change the entdef, make sure the etdef in self.addWorkEntry will correspond to correct column headings
	tbl1.setTblDataEntRowsFromDef(entDef);
		
	tbl1.multiSelect := CM_DataTable.MultiSelect_Simple;
	tbl1.selectionType := CM_DataTable.SelectionType_Row;
	tbl1.tabKey := J_key_Tab;

	numColumns := tbl1.columns;
	colWidth := (tbl1.width / numColumns).Integer;
	foreach col in 1 to numColumns do
		tbl1.accessColumn(col).width := (colWidth - 2);
	endforeach;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable"/>
        <Parameter name="_entdef" type="String"/>
    </JadeMethod>
