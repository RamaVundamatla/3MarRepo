    <JadeMethod name="isValidAreaForRTMoveMethod" id="7b6f37b1-55f1-4f99-a0f2-275b5d19ac8c">
        <source>isValidAreaForRTMoveMethod(_rtMoveMethod: CM_RTMoveMethod; _isSource: Boolean): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 March 2010	cnwer1	Initial creation

*/

vars

begin
	if _isSource then
		
		if _rtMoveMethod.allMachineTypeGroups.first.type = MACHINETYPEGRP_IMV then
			return false;
		endif;
	else
	
		if _rtMoveMethod.allMachineTypeGroups.last.type = MACHINETYPEGRP_IMV then
			return false;
		endif;
	endif;
	return true;

epilog

end;</source>
        <Parameter name="_rtMoveMethod" type="CM_RTMoveMethod"/>
        <Parameter name="_isSource" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
