    <JadeMethod name="convertBaseToTarget" id="afeeef07-29f7-4638-b47a-631673b5ccbd">
        <source>convertBaseToTarget(pMeasure: Real; pUnitTo: Integer): Real protected;
// --------------------------------------------------------------------------------
// Created:		02 June 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	convertedMeasure	: Real;
	
begin
	if pUnitTo = self.CENTIMETRES_PER_MINUTE then
		convertedMeasure	:=	pMeasure * 6000;

	elseif pUnitTo = self.CENTIMETRES_PER_SECOND then
		convertedMeasure	:=	pMeasure * 100;
		
	elseif pUnitTo = self.FEET_PER_HOUR then
		convertedMeasure	:=	pMeasure * 11811;
		
	elseif pUnitTo = self.FEET_PER_MINUTE then
		convertedMeasure	:=	pMeasure / 0.00508;
		
	elseif pUnitTo = self.FEET_PER_SECOND then
		convertedMeasure	:=	pMeasure / 0.3048;
		
	elseif pUnitTo = self.INCHES_PER_MINUTE then
		convertedMeasure	:=	pMeasure * 2362.2;
		
	elseif pUnitTo = self.INCHES_PER_SECOND then
		convertedMeasure	:=	pMeasure / 0.0254;
		
	elseif pUnitTo = self.KILOMETRES_PER_HOUR then
		convertedMeasure	:=	pMeasure * 3.6;
		
	elseif pUnitTo = self.KILOMETRES_PER_SECOND then
		convertedMeasure	:=	pMeasure / 1000;
		
	elseif pUnitTo = self.KNOTS then
		convertedMeasure	:=	pMeasure / 0.514444;
		
	elseif pUnitTo = self.MACH then
		convertedMeasure	:=	pMeasure / 331.5;
		
	elseif pUnitTo = self.METRES_PER_HOUR then
		convertedMeasure	:=	pMeasure * 3600;
		
	elseif pUnitTo = self.METRES_PER_MINUTE then
		convertedMeasure	:=	pMeasure * 60;
		
	elseif pUnitTo = self.METRES_PER_SECOND then
		convertedMeasure	:=	pMeasure;
		
	elseif pUnitTo = self.MILES_PER_HOUR then
		convertedMeasure	:=	pMeasure / 0.44704;
		
	elseif pUnitTo = self.MILES_PER_MINUTE then
		convertedMeasure	:=	pMeasure / 26.8224;
		
	elseif pUnitTo = self.MILES_PER_SECOND then
		convertedMeasure	:=	pMeasure / 1609.344;
		
	elseif pUnitTo = self.YARDS_PER_HOUR then
		convertedMeasure	:=	pMeasure * 3937;
		
	elseif pUnitTo = self.YARDS_PER_MINUTE then
		convertedMeasure	:=	pMeasure / 0.01524;
		
	elseif pUnitTo = self.YARDS_PER_SECOND then
		convertedMeasure	:=	pMeasure / 0.9144;
		
	else
		CnEcBaseSchemaException.raise_(CNEC_X_12004, "[" &amp; pUnitTo.String &amp; "] is an unknown unit of speed to convert to.");

	endif;
epilog
	return convertedMeasure;
end;</source>
        <access>protected</access>
        <Parameter name="pMeasure" type="Real"/>
        <Parameter name="pUnitTo" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="convertToBaseUnit" id="8a7da397-9a5f-4ec6-b087-3e77130c72fb">
        <source>convertToBaseUnit(pUnitFrom: Integer): Real protected;
// --------------------------------------------------------------------------------
// Created:		02 June 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	convertedMeasure	: Real;
	
begin
	if pUnitFrom = self.CENTIMETRES_PER_MINUTE then
		convertedMeasure	:=	self.measure / 6000;

	elseif pUnitFrom = self.CENTIMETRES_PER_SECOND then
		convertedMeasure	:=	self.measure / 100;
		
	elseif pUnitFrom = self.FEET_PER_HOUR then
		convertedMeasure	:=	self.measure / 11811;
		
	elseif pUnitFrom = self.FEET_PER_MINUTE then
		convertedMeasure	:=	self.measure * 0.00508;
		
	elseif pUnitFrom = self.FEET_PER_SECOND then
		convertedMeasure	:=	self.measure * 0.3048;
		
	elseif pUnitFrom = self.INCHES_PER_MINUTE then
		convertedMeasure	:=	self.measure / 2362.2;
		
	elseif pUnitFrom = self.INCHES_PER_SECOND then
		convertedMeasure	:=	self.measure * 0.0254;
		
	elseif pUnitFrom = self.KILOMETRES_PER_HOUR then
		convertedMeasure	:=	self.measure / 3.6;
		
	elseif pUnitFrom = self.KILOMETRES_PER_SECOND then
		convertedMeasure	:=	self.measure * 1000;
		
	elseif pUnitFrom = self.KNOTS then
		convertedMeasure	:=	self.measure * 0.514444;
		
	elseif pUnitFrom = self.MACH then
		convertedMeasure	:=	self.measure * 331.5;
		
	elseif pUnitFrom = self.METRES_PER_HOUR then
		convertedMeasure	:=	self.measure / 3600;
		
	elseif pUnitFrom = self.METRES_PER_MINUTE then
		convertedMeasure	:=	self.measure / 60;
		
	elseif pUnitFrom = self.METRES_PER_SECOND then
		convertedMeasure	:=	self.measure;
		
	elseif pUnitFrom = self.MILES_PER_HOUR then
		convertedMeasure	:=	self.measure * 0.44704;
		
	elseif pUnitFrom = self.MILES_PER_MINUTE then
		convertedMeasure	:=	self.measure * 26.8224;
		
	elseif pUnitFrom = self.MILES_PER_SECOND then
		convertedMeasure	:=	self.measure * 1609.344;
		
	elseif pUnitFrom = self.YARDS_PER_HOUR then
		convertedMeasure	:=	self.measure / 3937;
		
	elseif pUnitFrom = self.YARDS_PER_MINUTE then
		convertedMeasure	:=	self.measure * 0.01524;
		
	elseif pUnitFrom = self.YARDS_PER_SECOND then
		convertedMeasure	:=	self.measure * 0.9144;
		
	else
		CnEcBaseSchemaException.raise_(CNEC_X_12003, "[" &amp; pUnitFrom.String &amp; "] is an unknown unit of speed to convert from.");

	endif;
epilog
	return convertedMeasure;
end;</source>
        <access>protected</access>
        <Parameter name="pUnitFrom" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getAllUnits" id="6b06ceee-58d8-486c-9830-c3184c619916">
        <source>getAllUnits(pAllUnits: IntegerArray input);
// --------------------------------------------------------------------------------
// Created:		10 May 2008 by Darrell
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	pAllUnits.add(self.CENTIMETRES_PER_MINUTE);
	pAllUnits.add(self.CENTIMETRES_PER_SECOND);
	pAllUnits.add(self.FEET_PER_HOUR);
	pAllUnits.add(self.FEET_PER_MINUTE);
	pAllUnits.add(self.FEET_PER_SECOND);
	pAllUnits.add(self.INCHES_PER_MINUTE);
	pAllUnits.add(self.INCHES_PER_SECOND);
	pAllUnits.add(self.KILOMETRES_PER_HOUR);
	pAllUnits.add(self.KILOMETRES_PER_SECOND);
	pAllUnits.add(self.KNOTS);
	pAllUnits.add(self.MACH);
	pAllUnits.add(self.METRES_PER_HOUR);
	pAllUnits.add(self.METRES_PER_MINUTE);
	pAllUnits.add(self.METRES_PER_SECOND);
	pAllUnits.add(self.MILES_PER_HOUR);
	pAllUnits.add(self.MILES_PER_MINUTE);
	pAllUnits.add(self.MILES_PER_SECOND);
	pAllUnits.add(self.YARDS_PER_HOUR);
	pAllUnits.add(self.YARDS_PER_MINUTE);
	pAllUnits.add(self.YARDS_PER_SECOND);
end;</source>
        <Parameter name="pAllUnits" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getUnitName" id="435a7349-9357-4ec0-bfd6-7518832793b3">
        <source>getUnitName(pUnit: Integer): String;
// --------------------------------------------------------------------------------
// Created:		09 May 2008 by Darrell
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pUnit = self.CENTIMETRES_PER_MINUTE then
		return "Centimetres per Minute";
	elseif pUnit = self.CENTIMETRES_PER_SECOND then
		return "Centimetres per Second";
	elseif pUnit = self.FEET_PER_HOUR then
		return "Feet per Hour";
	elseif pUnit = self.FEET_PER_MINUTE then
		return "Feet per Minute";
	elseif pUnit = self.FEET_PER_SECOND then
		return "Feet per Second";
	elseif pUnit = self.INCHES_PER_MINUTE then
		return "Inches per Minute";
	elseif pUnit = self.INCHES_PER_SECOND then
		return "Inches per Second";
	elseif pUnit = self.KILOMETRES_PER_HOUR then
		return "Kilometres per Hour";
	elseif pUnit = self.KILOMETRES_PER_SECOND then
		return "Kilometres per Second";
	elseif pUnit = self.KNOTS then
		return "Knots";
	elseif pUnit = self.MACH then
		return "Mach";
	elseif pUnit = self.METRES_PER_HOUR then
		return "Metres per Hour";
	elseif pUnit = self.METRES_PER_MINUTE then
		return "Metres per Minute";
	elseif pUnit = self.METRES_PER_SECOND then
		return "Metres per Second";
	elseif pUnit = self.MILES_PER_HOUR then
		return "Miles per Hour";
	elseif pUnit = self.MILES_PER_MINUTE then
		return "Miles per Minute";
	elseif pUnit = self.MILES_PER_SECOND then
		return "Miles per Second";
	elseif pUnit = self.YARDS_PER_HOUR then
		return "yards per Hour";
	elseif pUnit = self.YARDS_PER_MINUTE then
		return "Yards per Minute";
	elseif pUnit = self.YARDS_PER_SECOND then
		return "Yards per Second";
	else
		CnEcBaseSchemaException.raise_(CNEC_X_12003, "[" &amp; pUnit.String &amp; "] is an unknown unit of Speed to convert from.");
		return null;
	endif;
end;</source>
        <Parameter name="pUnit" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
