		if pChangedTimeStamp &gt; pToTimeStamp then
			break;
		endif;
		if result = 0 then
			msg := msg&amp;objId.String&amp;' '&amp;ctInterface.mySelectionObject.changeTimestamp.String&amp;CrLf;
