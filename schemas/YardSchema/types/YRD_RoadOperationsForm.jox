    <JadeMethod name="doMenuGateLaneClick" id="b78ea5b9-d622-441b-9275-beea87e21912">
        <updating/>
        <source>doMenuGateLaneClick(_menu : MenuItem) updating, protected;
// ---------------------------------------------------------------------------
// Created:		20 May 2008 	By: Graeme Black cnwgb1
// ---------------------------------------------------------------------------
vars
	obj			: Object;
	area		: CM_GateArea;
	form	 	: YRD_GateLaneMaint;
begin
	obj := _menu.userObject;
	
	if obj = null then
		// nothing to do
	endif;
	
	if CM_GateArea.hasInstance (obj) then
		area := obj.CM_GateArea;
		
		if area.laneCount = 0 then
			// nothing to do
			return;
		endif;
	endif;
	
	create form transient;
	
	form.init(obj.CM_GateArea);
	form.showModal();
	
	delete form;
end;</source>
