    <JadeMethod name="getJobSheetStartTimeWithDelays" id="5d222eba-1a0d-4e7b-97fa-bff07e65f0ae">
        <source>getJobSheetStartTimeWithDelays(_craneId : String; _currentStartDT : TimeStamp input) :TimeStamp;
/*

Purpose:			


Return Value:		


Date		Who		Reason
14 May 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	voyageDelayIter : Iterator;
	delay  : CM_Delay;
	delayEndDT: TimeStamp;
	delayStartDT,
	newDelayStartDT: TimeStamp;
begin
	newDelayStartDT:=_currentStartDT;
	if self.myVoyage.allDelays.size &gt; 0 then
		voyageDelayIter:=self.myVoyage.allDelays.createIterator;
		while voyageDelayIter.next(delay) do
			delayEndDT:=delay.getEndDT;
			delayStartDT:=delay.startDT;
			if delayEndDT = null then
				continue;
			endif;
			if delay.myMachine = null or delay.myMachine.id &lt;&gt; _craneId then
				continue;
			endif;
			if delayEndDT &lt; _currentStartDT then
				continue;
			endif;
			if delayStartDT &gt;_currentStartDT then
				break;
			endif;
			if delayStartDT &lt; _currentStartDT and delayEndDT &gt; _currentStartDT then
				newDelayStartDT:=delayEndDT;
			endif;
		endwhile;
	endif;
	
	return newDelayStartDT;
epilog
	delete voyageDelayIter;

end;</source>
        <Parameter name="_craneId" type="String"/>
        <Parameter name="_currentStartDT" type="TimeStamp" usage="input"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getJobSheetStatsForJobSheet" id="a95f136b-a4a1-4de2-a0cc-84637dc607de">
        <updating/>
        <source>getJobSheetStatsForJobSheet(_jobSheet : CM_JobSheet) : CMIF_JobSheetStats updating;
// ---------------------------------------------------------------------------
// Created:     24 May 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpJobSheetStats	: CMIF_JobSheetStats;
begin
	if _jobSheet = null then
		return null;
	endif;
	if _jobSheet.CM_VoyageJobSheet.myVoyage &lt;&gt; self.myVoyage then
		app.raiseUnexpectedProgramError(class.name, method.name, 
				'Voyage for jobSheet passed in (' &amp; _jobSheet.CM_VoyageJobSheet.myVoyage.String &amp; 
				') does not match current voyage (' &amp; self.myVoyage.String &amp; ')');
		return null;
	endif;
	tmpJobSheetStats := self.allJobSheetStats[_jobSheet];
	if tmpJobSheetStats = null then
		tmpJobSheetStats := self.createStatsObjectForJobSheet(_jobSheet);
	endif;
	return tmpJobSheetStats;
end;</source>
        <Parameter name="_jobSheet" type="CM_JobSheet"/>
        <ReturnType type="CMIF_JobSheetStats"/>
    </JadeMethod>
