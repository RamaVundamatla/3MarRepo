    <JadeMethod name="importMyCollectionsXML" id="6927dbe1-c80f-4f8d-b79b-b10dfd66147b">
        <updating/>
        <source>importMyCollectionsXML(_collectionsBlock: String) updating;
// ---------------------------------------------------------------------------
// Created:     11 February 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	sohLoc				: CM_SOHLocation;
	sohBlock,
	sohLocBlock			: String;
	blockLength,
	pos					: Integer;

begin
	
	sohLocBlock := _collectionsBlock.cnEcGetTagValueOfName('allSOHLocations');
	if sohLocBlock = null then
		return;
	endif;
	
	pos := 1;
	blockLength := sohLocBlock.length;
	while pos &lt; blockLength do
		sohBlock := sohLocBlock.cnEcGetNextTagValueOfName('CM_SOHLocation', pos);
		if pos &lt; 1 then
			break;
		endif;
		
		if sohBlock = null then
			continue;
		endif;
		
		create sohLoc persistent;
		sohLoc.setPropertyValue('myLocationsController', self);
		sohLoc.importMeXML(sohBlock);
		sohLoc.setPropertyValue('currentQuantity', null);
		sohLoc.setPropertyValue('currentVolume', null);
		sohLoc.setPropertyValue('currentWeightKgs', null);
	endwhile;
end;</source>
        <Parameter name="_collectionsBlock" type="String"/>
    </JadeMethod>
    <JadeMethod name="includesTI" id="1eaa4d68-b86f-45a7-a4f4-ad08b5a67a1c">
        <source>includesTI(ti : CM_TrackedItem; mode : Integer)	: Boolean;
//Returns TRUE if the ti is in the controller
/*
AJA 13/1/00: Amended so does NOT return true if this YC only holds the
back end of a 40' box
DQ 15/2/01: Amended to take a mode.
DQ  12/09/01  Removed the bit where it checks back ends, should do so irrespective.
*/
vars
	array : CM_TIArray;
begin

	if ti = null then
		return false;
	endif;
	if mode = REAL_MODE then

		return self.allTrackedItems.includes(ti);
	endif;

	create array transient;
	if mode = PLANNING_MODE then
		self.getAllPlannedTrackedItems(array, true, false);
	elseif mode = QUEUE_MODE then
		self.getAllQueuedTrackedItems(array, true);
	endif;

	return array.includes(ti);

epilog
	delete array;
end;</source>
        <Parameter name="ti" type="CM_TrackedItem"/>
        <Parameter name="mode" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
