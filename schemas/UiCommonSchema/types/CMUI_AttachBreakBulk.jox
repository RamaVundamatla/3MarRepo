        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbDestPort_lostFocus(_combobox: CMUI_ComboPorts input) updating;
// ---------------------------------------------------------------------------
// Created:     31 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	voyageCombo : CMUI_ComboBox;
	operatorCombo : CMUI_ComboOperator;
	dischargeCombo : CMUI_ComboPorts;
	tmpOperator :CM_Operator;
	tmpVoyage : CM_Voyage;
	dischargePort : CM_Port;
	// cnwjk3 PAR 15627 25/11/08
	voyageCode : String;
	operatorCode : String;
	pos : Integer;
	destinationCode, dischargePortCode : String;
	tbl			: CM_EntryTable;
begin
	if not CM_EntryTable.hasInstance(_combobox.parent) then
		return;
	endif;

	tbl := _combobox.parent.CM_EntryTable;

/*	if combobox.listObject &lt;&gt; null then
		tbl.setValueByControlName(combobox.name, combobox.listObject.CM_Port.code);
	else
		tbl.setValueByControlName(combobox.name, null);
	endif;*/
	_combobox.doChangedCompareForEntryTable();

	// ccms1031 cnwrs1 Aug 2006
	//Check if we have something to lookup in the first place
	if _combobox.text = null then
		return;
	endif;
	
	dischargeCombo := self.cmbDisPort;
	if dischargeCombo.text &lt;&gt; null then
		return;
	endif;
	destinationCode := _combobox.getCode();
	
	voyageCombo := self.cmbVoyage;
	if voyageCombo = null then
		return;
	endif;
	
	// cnwjk3 PAR 15627 25/11/08
	tmpVoyage := voyageCombo.listObject.CM_Voyage;
	
	// cnwjk3 PAR 15627 25/11/08
	/*
	pos := 1;
	voyageCode := voyageCombo.text;
	if voyageCode &lt;&gt; null then
		// strip off the description
		voyageCode := voyageCode.scanUntil(Tab, pos).trimRight;
	endif;
	*/

	// need to reset list
//	tmpVoyage := self.myAssistant.getVoyageFromCombo(voyageCode);

	operatorCombo := self.cmbOperator;
	if operatorCombo = null then
		return;
	endif;
	pos := 1;
	operatorCode := operatorCombo.text;
	if operatorCode &lt;&gt; null then
		// strip off the description
		operatorCode := operatorCode.scanUntil(Tab, pos).trimRight;
	endif;
	tmpOperator := self.myAssistant.getOperatorFromCombo(operatorCode);
	// cnwjk3 PAR 15627 25/11/08
	//dischargePort := tmpOperator.getDischargePortFromDest(destinationCode, voyageCode, null);
	dischargePort := tmpOperator.getDischargePortFromDest(destinationCode, tmpVoyage, null);
	self.myAssistant.comboBoxPort(self.cmbDisPort, dischargePort, null);
	tbl := self.cmbDisPort.parent.CM_EntryTable;
	tbl.setValueByControlName(self.cmbDisPort.name, self.cmbDisPort.text);
end;</source>
        <Parameter name="_combobox" type="CMUI_ComboPorts" usage="input"/>
    </JadeMethod>
