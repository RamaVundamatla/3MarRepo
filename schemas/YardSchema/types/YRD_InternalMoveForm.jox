    <JadeMethod name="doSave" id="cc99eacd-5a9a-4680-85ea-fabb3c069a1d">
        <updating/>
        <source>doSave() : Boolean updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 August 2009	cnwrd1	Initial creation

*/

vars
	result : Boolean;
begin
	
	result := self.doSaveReal(); // cnwrd1 par 22987 8.3.2010
	
	if result then
		self.unloadForm();
	endif;
	
	return true;
	
	
epilog	
end;</source>
        <access>protected</access>
