    <JadeMethod name="cmbTermArea_lostFocus" id="1d0e7b02-9219-4794-a71a-0c90d38eda26">
        <controlMethod name="ComboBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbTermArea_lostFocus(combobox: ComboBox input) updating;
//--------------------------------------------------
// Created:	25 August 2003 By: cnwgd1
//--------------------------------------------------
vars
	tmpTA 	: CM_TerminalArea;
//	lcSet : CM_LCSet;
begin

	self.tblMove.setValueByControlName(combobox.name, combobox.text);
	if self.origValueStr &lt;&gt; combobox.text then	
		tmpTA := combobox.listObject.CM_TerminalArea;
		if tmpTA = null then
			self.cmbYardLocation.clear();		
		elseif (not tmpTA.isKindOf(CM_BlockStack)) then
		
			if tmpTA.isKindOf(CM_Rail) then	//21 mar 2013	NDl	Par 31278
				// PAR 32308 create lcSet transient;
				self.allLCsSet.clear();
				tmpTA.CM_Rail.getValidLCsCollectionForMove(self.allLCsSet);
				self.myAssistant.comboBoxLocationControllers(self.cmbYardLocation, self.allLCsSet, false);
				// PAR 32308 delete lcSet;
			elseif tmpTA.isKindOf(CM_IrregularBlockArea) then	//23 Aug 2013	NDL	Par 32308
				// PAR 32308 create lcSet transient;
				self.allLCsSet.clear(); // PAR 32308 getting a collection deleted error on combobox
				tmpTA.CM_IrregularBlockArea.getValidLCsCollectionForMove(self.allLCsSet);
				self.myAssistant.comboBoxLocationControllers(self.cmbYardLocation, self.allLCsSet, false);
				// PAR 32308 delete lcSet;
			else
				self.myAssistant.comboBoxLocationControllers(self.cmbYardLocation, tmpTA.getLCsCollectionForDisplay, false);
			endif;
		endif;
		self.cmbYardLocation.lostFocus(self.cmbYardLocation);	
	endif;

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
