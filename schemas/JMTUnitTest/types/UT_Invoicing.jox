    <JadeMethod name="createStorageTransactions6" id="2795d115-37ee-42f4-92ad-f483d905bc5c">
        <source>createStorageTransactions6(realTI : CM_TrackedItem input);
// ---------------------------------------------------------------------------
// Created:     20 July 2010 by NAVAB1
// FIRST day of each ILD quantity range plus several transactions for last ILD
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	transParams: CMIF_StorageTransController;
	tran : CM_TITransaction;
	tranTS : TimeStamp;
	tranDate : Date;
begin
		
	// ##################
	tranDate.setDate(1,5,2010);
	tranTS.setDate(tranDate);
	foreach tran in realTI.allTransactions do
		tranTS.setDate(tranDate);
		tranTS.setTime(tran.dateTime.time);
		
		beginTransaction;
		tran.setPropertyValue("dateTime", tranTS);
		commitTransaction;
	endforeach;
	

	create transParams transient;
	transParams.type := TRANS_TYPE_STORAGE;
	transParams.noCharge := false;
	transParams.userId := "NAVAB1";
	transParams.isManual := true; // NAVAB1 23APR2024 - FIXING UTs
	
	beginTransaction;
	tranDate.setDate(7,5,2010);
	tranTS.setDate(tranDate);
	transParams.dateTime := tranTS;
	realTI.createTransaction(transParams, app.myPassport);
	commitTransaction;
	beginTransaction;
	tranDate.setDate(11,5,2010);
	tranTS.setDate(tranDate);
	transParams.dateTime := tranTS;
	realTI.createTransaction(transParams, app.myPassport);
	commitTransaction;
	beginTransaction;
	tranDate.setDate(17,5,2010);
	tranTS.setDate(tranDate);
	transParams.dateTime := tranTS;
	realTI.createTransaction(transParams, app.myPassport);
	commitTransaction;
	beginTransaction;
	tranDate.setDate(20,5,2010);
	tranTS.setDate(tranDate);
	transParams.dateTime := tranTS;
	realTI.createTransaction(transParams, app.myPassport);
	commitTransaction;
	beginTransaction;
	tranDate.setDate(23,5,2010);
	tranTS.setDate(tranDate);
	transParams.dateTime := tranTS;
	realTI.createTransaction(transParams, app.myPassport);
	commitTransaction;
	beginTransaction;
	tranDate.setDate(24,5,2010);
	tranTS.setDate(tranDate);
	transParams.dateTime := tranTS;
	realTI.createTransaction(transParams, app.myPassport);
	commitTransaction;
epilog

	delete transParams;
end;</source>
        <Parameter name="realTI" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createStorageTransactions7" id="832f24a5-8963-405e-9e38-68aac69b6663">
        <source>createStorageTransactions7(realTI : CM_TrackedItem input);
// ---------------------------------------------------------------------------
// Created:     Oct 2010 by cnwjre1
//	Base test
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	transParams: CMIF_StorageTransController;
	tran : CM_TITransaction;
	tranTS : TimeStamp;
	tranDate : Date;
	now : Date;
begin
		
	// start with a date back 300 days
	now := app.actualTimeServer().date();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
	tranDate := now - 300;
	tranTS.setDate(tranDate);
	foreach tran in realTI.allTransactions do
		tranTS.setDate(tranDate);
		tranTS.setTime(tran.dateTime.time);
		
		beginTransaction;
		tran.setPropertyValue("dateTime", tranTS);
		commitTransaction;
	endforeach;
	

	create transParams transient;
	transParams.type := TRANS_TYPE_STORAGE;
	transParams.noCharge := false;
	transParams.userId := "NAVAB1";
	transParams.isManual := true; // NAVAB1 23APR2024 - FIXING UTs
	transParams.operatorCode := realTI.operatorCode; // ### TFS BUG 64177 21MAY2024 NAVAB1
	
	beginTransaction;
	tranDate := now - 1;
	tranTS.setDate(tranDate);
	transParams.dateTime := tranTS;
	realTI.createTransaction(transParams, app.myPassport);
	commitTransaction;
epilog

	delete transParams;
end;</source>
        <Parameter name="realTI" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
