    <JadeMethod name="getHasSeparations" id="89c7e535-e839-4b24-860d-6b586a40ecd6">
        <source>getHasSeparations() : Boolean;
/*

Purpose:			Gets whether the Invoice Type Debtor Separation has seprarations

Parameters:			NONE

Return Value:		Boolean	A boolean representing whether or not the Invoice Type Debtor Separation has seprarations

Date		Who		Reason
24 August 2022	navpw1	Initial creation TFS: 54565 (54384)

*/

begin
	return self.separatedByBillOfLading or self.separatedByBooking or self.separatedByCargoGroupId or self.separatedByCargoId or self.separatedByReleaseRequest or 
			self.separatedByVoyage or self.separatedByVoyageGroup
			or self.separatedByPONumber; // ### BUG 56925 07MAR2023 NAVAB1

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getSeparationDescriptions" id="933ce03f-2195-47af-b938-309a0321cce7">
        <source>getSeparationDescriptions() : String;
/*

Purpose:			Gets the separation descriptions for the debtor separation

Parameters:			NONE

Return Value:		String: Representing the invoice separations for the debtor

Date		Who		Reason
26 October 2022	navpw1	Initial creation TFS: 54565 (54384)

*/

vars
	returnStr : String;
	
begin
	if not self.getHasSeparations() then
		return null;
	endif;
	
	if self.separatedByVoyage then
		returnStr &amp;= app.getErrorString(Voyage) &amp; ", ";
	endif;
	
	if self.separatedByVoyageGroup then
		returnStr &amp;= app.getErrorString(Voyage_group) &amp; ", ";
	endif;
	
	if self.separatedByCargoId then
		returnStr &amp;= app.getErrorString(CargoItem_Name) &amp; ", ";
	endif;
	
	if self.separatedByBillOfLading then
		returnStr &amp;= app.getErrorString(BillOfLading) &amp; ", ";
	endif;
	
	if self.separatedByBooking then
		returnStr &amp;= app.getErrorString(Booking) &amp; ", ";
	endif;
	
	if self.separatedByCargoGroupId then
		returnStr &amp;= app.getErrorString(Cargo_group_id) &amp; ", ";
	endif;
	
	if self.separatedByReleaseRequest then
		returnStr &amp;= app.getErrorString(Release_request) &amp; ", ";
	endif;
	
	 // ### BUG 56925 07MAR2023 NAVAB1
	if self.separatedByPONumber then
		returnStr &amp;= app.getErrorString(Purchase_order_number) &amp; ", ";
	endif;
	
	return returnStr.stripTrailingChar(",");
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="721cd3b8-f401-401e-945b-b171d9eb25f7">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			Creates an Create/Update proxy for an Invoice Type Debtor Separation

Parameters:			NONE

Return Value:		SelfType	An object that is of this type with the properties populated

Date		Who		Reason
29 August 2022	navpw1	Initial creation TFS: 54565 (54384)

*/

vars
	pxy : SelfType;
	
begin
	pxy 							:= inheritMethod();
	pxy.myDebtor					:= self.myDebtor;
	pxy.myAccrualType 				:= self.myAccrualType;
	pxy.mySurchargesAndExemptions	:= self.mySurchargesAndExemptions;
	return pxy;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="90cab69d-067d-41dc-b88d-638c085fcd33">
        <updating/>
        <source>setForCreate(_pxyInvTypeDebtorSeparation : CM_InvTypeDebtorSeparation) updating;
/*

Purpose:			Sets the current object for creating a persistent object

Parameters:			_pxyInvTypeDebtorSeparation	CM_InvTypeDebtorSeparation	The proxy transient object to set our persistent object from

Return Value:		NONE

Date			Who		Reason
24 August 2022	navpw1	Initial creation TFS: 54565 (54384)
31 October 2022	navpw1	TFS: 55235 - Added setting of new field invoiceDescNumber to support a new dictionary added to CM_Debtor
*/

vars
	invoiceDesc : CM_InvoiceDesc;
	
begin
	// ### TFS 55235 31Oct2022 NAVPW1
	if _pxyInvTypeDebtorSeparation.mySurchargesAndExemptions &lt;&gt; null then
		invoiceDesc := _pxyInvTypeDebtorSeparation.mySurchargesAndExemptions.myInvoiceType;
	endif;
	
	if invoiceDesc &lt;&gt; null then
		self.invoiceDescNumber := invoiceDesc.number;
	endif;
	// ### TFS 55235 31Oct2022 NAVPW1
	
	self.myDebtor 					:= _pxyInvTypeDebtorSeparation.myDebtor;
	self.myAccrualType 				:= _pxyInvTypeDebtorSeparation.myAccrualType;
	self.separatedByVoyage 			:= _pxyInvTypeDebtorSeparation.separatedByVoyage;
	self.separatedByVoyageGroup 	:= _pxyInvTypeDebtorSeparation.separatedByVoyageGroup;
	self.separatedByCargoId 		:= _pxyInvTypeDebtorSeparation.separatedByCargoId;
	self.separatedByCargoGroupId 	:= _pxyInvTypeDebtorSeparation.separatedByCargoGroupId;
	self.separatedByBillOfLading 	:= _pxyInvTypeDebtorSeparation.separatedByBillOfLading;
	self.separatedByBooking 		:= _pxyInvTypeDebtorSeparation.separatedByBooking;
	self.separatedByReleaseRequest 	:= _pxyInvTypeDebtorSeparation.separatedByReleaseRequest;
	self.separatedByPONumber 	:= _pxyInvTypeDebtorSeparation.separatedByPONumber; // ### BUG 56925 07MAR2023 NAVAB1
	self.mySurchargesAndExemptions	:= _pxyInvTypeDebtorSeparation.mySurchargesAndExemptions;
	
end;</source>
        <Parameter name="_pxyInvTypeDebtorSeparation" type="CM_InvTypeDebtorSeparation"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="4cf06354-9fa9-4a90-80af-f114506bc8f8">
        <updating/>
        <source>setForUpdate(_pxyInvTypeDebtorSeparation : CM_InvTypeDebtorSeparation) updating;
/*

Purpose:			Sets the current object for updating a persistent object

Parameters:			_pxyInvTypeDebtorSeparation	CM_InvTypeDebtorSeparation	The proxy transient object to set our persistent object from

Return Value:		NONE

Date		Who		Reason
25 August 2022	navpw1	Initial creation TFS: 54565 (54384)

*/

begin
	self.setForCreate(_pxyInvTypeDebtorSeparation); //Sets the same fields
	
end;</source>
        <Parameter name="_pxyInvTypeDebtorSeparation" type="CM_InvTypeDebtorSeparation"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="1aaac338-d59f-4848-be5a-0860d8bfc4ae">
        <updating/>
        <source>setProxy(_debtor 					: CM_Debtor;
		_accrualType 				: CM_FinancialPeriodEnd;
		_separatedByVoyage,
		_separatedByVoyageGroup,
		_separatedByCargoId,
		_separatedByCargoGrpId,
		_separatedByBol,
		_separatedByBooking,
		_separatedByReleaseReq,
 		_separatedByPONumber : Boolean;
		_surchargesAndExemptions 	: CM_InvoiceTypeSurchargeExempt) updating;
/*

Purpose:			Sets our proxy transient object with the values passed in

Parameters:			_debtor						CM_Debtor						The debtor to use for the Invoice Type Debtor Separation
					_accrualType				CM_FinancialPeriodEnd			The financial period to use for the Invoice Type Debtor Separation
					_separatedByVoyage			Boolean							Whether the Invoice Type Debtor Separation is separated by voyage
					_separatedByVoyageGroup		Boolean							Whether the Invoice Type Debtor Separation is separated by voyage group
					_separatedByCargoId			Boolean							Whether the Invoice Type Debtor Separation is separated by cargo id
					_separatedByCargoGrpId		Boolean							Whether the Invoice Type Debtor Separation is separated by cargo group id
					_separatedByBol				Boolean							Whether the Invoice Type Debtor Separation is separated by bill of lading
					_separatedByBooking			Boolean							Whether the Invoice Type Debtor Separation is separated by booking
					_separatedByReleaseReq		Boolean							Whether the Invoice Type Debtor Separation is separated by release request
					_surchargesAndExemptions	CM_InvoiceTypeSurchargeExempt	The debtor to use for the Invoice Type Debtor Separation

Return Value:		NONE

Date			Who		Reason
24 August 2022	navpw1	Initial creation TFS: 54565 (54384)
31 October 2022	navpw1	TFS: 55235 - Added setting of new field invoiceDescNumber to support a new dictionary added to CM_Debtor
*/

vars
	invoiceDesc : CM_InvoiceDesc;	// ### TFS 55235 31Oct2022 NAVPW1
	
begin
	// ### TFS 55235 31Oct2022 NAVPW1
	if _surchargesAndExemptions &lt;&gt; null then
		invoiceDesc := _surchargesAndExemptions.myInvoiceType;
	endif;
	
	if invoiceDesc &lt;&gt; null then
		self.invoiceDescNumber := invoiceDesc.number;
	endif;
	// ### TFS 55235 31Oct2022 NAVPW1
	
	self.myDebtor 					:= _debtor;
	self.myAccrualType 				:= _accrualType;
	self.separatedByVoyage 			:= _separatedByVoyage;
	self.separatedByVoyageGroup	 	:= _separatedByVoyageGroup;
	self.separatedByCargoId 		:= _separatedByCargoId;
	self.separatedByCargoGroupId 	:= _separatedByCargoGrpId;
	self.separatedByBillOfLading 	:= _separatedByBol;
	self.separatedByBooking 		:= _separatedByBooking;
	self.separatedByReleaseRequest 	:= _separatedByReleaseReq;
	self.mySurchargesAndExemptions 	:= _surchargesAndExemptions;
	self.separatedByPONumber := _separatedByPONumber; // ### BUG 56925 07MAR2023 NAVAB1
	
end;</source>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <Parameter name="_accrualType" type="CM_FinancialPeriodEnd"/>
        <Parameter name="_separatedByVoyage" type="Boolean"/>
        <Parameter name="_separatedByVoyageGroup" type="Boolean"/>
        <Parameter name="_separatedByCargoId" type="Boolean"/>
        <Parameter name="_separatedByCargoGrpId" type="Boolean"/>
        <Parameter name="_separatedByBol" type="Boolean"/>
        <Parameter name="_separatedByBooking" type="Boolean"/>
        <Parameter name="_separatedByReleaseReq" type="Boolean"/>
        <Parameter name="_separatedByPONumber" type="Boolean"/>
        <Parameter name="_surchargesAndExemptions" type="CM_InvoiceTypeSurchargeExempt"/>
    </JadeMethod>
