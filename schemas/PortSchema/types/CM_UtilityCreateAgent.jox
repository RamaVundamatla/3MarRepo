    <JadeMethod name="utlCreateFiles" id="3024fca9-8af9-46b4-b84a-3bb4d9d068d5">
        <source>utlCreateFiles(_parent : CM_Object input; _allFiles : ObjectArray input; _passport : CM_Passport );
/*

Purpose:			Create file objects from the passed in collection, and attach to the given parent

Parameters:			_parent 	: Object to link files to
					_allFiles 	: Collection of files

Return Value:		

Date				Who		Reason
09 March 2022		jlizm1	Initial creation TFS 52834 SAL file attachments filter by work order

*/

vars

	obj 		: Object;
	fileData	: CM_FileData;

begin

	self.initialiseActivity();
	self.raiseExceptionIfNull(_parent, 'Parent');
	self.raiseExceptionIfNull(_allFiles, 'Files');
	
	if _parent.isKindOf(CM_Voyage) 
	or _parent.isKindOf(CM_VoyageGlobal) 
	or _parent.isKindOf(CM_CargoBOLType) 
	or _parent.isKindOf(CM_WorkOrder) then
	
		foreach obj in _allFiles discreteLock do
			create fileData persistent;
			fileData.setForCreateProxy(_parent,app.myPassport.userCode,obj.CM_FileData);	
		endforeach;
		
	else	
		app.raiseUnexpectedProgramError(class.name, method.name, "Parent is an invalid object type");
	endif;
	
epilog

end;</source>
        <Parameter name="_parent" type="CM_Object" usage="input"/>
        <Parameter name="_allFiles" type="ObjectArray" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
