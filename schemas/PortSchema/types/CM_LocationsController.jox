    <JadeMethod name="isOSBackendLC" id="51a3c08b-13b7-4f99-98db-7eab67c310e2">
        <source>isOSBackendLC() : Boolean;
// ---------------------------------------------------------------------------
// Created:		16 May 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	return (self.is30ft and self.offset30 &gt; 0) or (self.is53ft and self.offset53 &gt; 0) or (self.is45ft and self.offset45 &gt; 0);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isOffsetUnavailable" id="009a3c55-5eab-4287-93d2-82fe79dbb388">
        <source>isOffsetUnavailable() : Boolean;
// ---------------------------------------------------------------------------
// Created:		09 May 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	tmpTI : CM_TrackedItem;
begin
	tmpTI :=  self.allTrackedItems.first;
// PAR 18682	if tmpTI &lt;&gt; null and not tmpTI.isOverSizedContainer() then
	if tmpTI &lt;&gt; null and tmpTI.isTwenty() then
		return false;
	endif;

	
	if self.is30ft and self.offset30 = self.Offset30_Unavailable then
		return true;
	endif;
	
	// PAR 18682
	if self.is40ft and self.offset40 = self.Offset40_Unavailable then
		return true;
	endif;
	
	if self.is45ft and self.offset45 = self.Offset45_Unavailable then
		return true;
	endif;
	
	if self.is53ft and self.offset53 = self.Offset53_Unavailable then
		return true;
	endif;
	
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
