    <JadeMethod name="userNotify" id="febe83ac-abd3-4979-bfd5-d628fd049cef">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 March 2011	cnwer1	Initial creation

*/

vars

begin
//	app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' 1.eventType: ' &amp; eventType.String);
	if eventType = EVENT_VESSEL_DECK_CREATE or
		eventType = EVENT_VESSEL_DECK_UPDATE or
		eventType = EVENT_VESSEL_DECK_DELETE then
		self.doUserNotifyDecks(eventType,theObject,eventTag,userInfo);
	elseif  eventType = EVENT_SECTION_CREATE or
		eventType = EVENT_SECTION_UPDATE or
		eventType = EVENT_SECTION_DELETE then
			self.doDrawLabelH();
	elseif  eventType = EVENT_DECK_ITEM_CREATE or
		eventType = EVENT_DECK_ITEM_UPDATE or
		eventType = EVENT_DECK_ITEM_DELETE then
		self.doUserNotifyDeckItems(eventType,theObject,eventTag,userInfo);
	else
		self.doUserNotifyLayers(eventType,theObject,eventTag,userInfo);
	endif;
	
epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</GUIClass>
