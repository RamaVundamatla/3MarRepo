    <JadeMethod name="tblRequests_contextMenu" id="b669a887-6603-42cc-9276-fdc03af253c3">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblRequests_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 June 2024	navra1	Initial creation for //navra1 - TFS 60149/Task 64397 - 13th June 2024

*/
vars

begin
	
	if not app.myCurrentUserCan(self.myTerminal, PmAdmBGPFutActorMaint) then
		return false;
	endif;
	
	self.mnuProcessRequest.visible:=true;
	self.mnuClear.visible:=true;
	self.mnuClearSingleRequest.visible:=true;
	self.mnuClear.visible:=false;
	
	self.mnuInspect.visible := app.isSpecial(); // ### TFS BUG 64680 17JUNE024 NAVAB 
	
	return self.showContextMenu(mnuRequests, table, conwin, mouse, x, y);
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
