    <JadeMethod name="deleteContainer" id="88050d45-7c98-477e-8ebe-2ad08c3f201b">
        <source>deleteContainer(id: String);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 November 2009	cnwndl1	Initial creation	Par 21519

*/

vars
	ti		: CM_TrackedItem;	
	root	: CM_Root;
	job 	: CM_RailJob;
	
begin
	root := CM_Root.firstInstance;
	ti := self.getTerminal.lookupTrackedItem(id, TI_CargoType_Container, TI_STATE_UNDEFINED, null, false);
	if ti &lt;&gt; null then
		beginTransaction;
		if ti.jobRailReceive &lt;&gt; null then
			job := ti.jobRailReceive;
			delete job;
		endif;
		if ti.jobRailRelease &lt;&gt; null then
			job := ti.jobRailRelease;
			delete job;
		endif;
		commitTransaction;
	endif;


	inheritMethod(id);

epilog

end;</source>
        <Parameter name="id" type="String"/>
    </JadeMethod>
    <JadeMethod name="doOpsFormEquivalentMove" id="bdef6a35-b7ea-44ea-8f43-ec5acddd7dad">
        <source>doOpsFormEquivalentMove(_ti: CM_TrackedItem);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 October 2014	cnwndl1	Initial creation

*/

vars
	wle : CM_WorkListEntry;
	wleArray,
	wlesWithWarnings : CM_WLEArray;	
	result	: Integer;
begin

	wle := _ti.allWorklistEntries.first;
	create wleArray transient;
	wleArray.add(wle);

	create wlesWithWarnings transient;
	
	while true do
		app.myTrxUA.trxUpdateWLEsDoMove(wleArray, wlesWithWarnings, REAL_MODE, false,null, app.myPassport);
		if app.myPassport.trxCompletedOK then
			break;
		else
			if app.myPassport.allErrorWarnings.size = 1 
			and app.myPassport.returnCode = INFO_NO_AUTOPLAN then
				// don't show it here, ask Q below.
				result := 1;				
			endif;
			if app.myPassport.noErrors
			and result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				// only reprocess the wles that had warnings.
				wleArray.clear;
				wlesWithWarnings.copy(wleArray);
				wlesWithWarnings.clear;
				continue;
			endif;
		endif;
		break;
	endwhile;

epilog
	delete wlesWithWarnings;
	delete wleArray;
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="performSealChecks" id="e5b59b3d-1cf8-4b14-a896-d50bd78dfd66">
        <source>performSealChecks( _wagon : CM_Wagon; _context : Integer );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 July 2015	cnwndl1	Initial creation	Par 36658

*/

vars

	pxyWagonCheckDetailArray : ObjectArray;
	sealObj : CM_SealObject;
	pxySealCheckDetail : CM_WagonSealCheckDetail;
	wagonTrx : CMEVT_WagonTransaction;
	sealAfter : String;
	sealBefore : String;
	sealType : String;
	viewed : Integer;
	updateArray : CM_ObjectArray;
	pxyWagonSeal : CM_WagonSeal;

begin

	create pxyWagonCheckDetailArray transient;

	if _context = WAGON_CHECK_CONTEXT_PLACE_IN then
		self.assertTrueMsg( self.getTerminal.sealCheckWagonDischarge = SEAL_CHECK_VIEW, "Terminal config for rail seal check in NOT view mode" );
		
		foreach sealObj in _wagon.allWagonSeals do
			
			sealBefore := sealObj.getSealValueAsString;
			sealType := sealObj.sealType;
			sealAfter := sealBefore;
			viewed := CM_SealCheckDetail.Seal_Not_Viewed;
			
			create pxySealCheckDetail transient;
			pxySealCheckDetail.setProxy(	null,	//_sealCheck : CM_SealCheck;
											sealAfter,	//_sealAfter : String;
											sealBefore,	//_sealBefore : String;
											SEAL_CHECK_VIEW,	//_sealCheckType : Integer;
											sealType,	//_sealType : String;
											viewed	//_viewed : Integer;
											);
			
			pxyWagonCheckDetailArray.add( pxySealCheckDetail );
			
		endforeach;
		
		
	elseif _context = WAGON_CHECK_CONTEXT_PLACE_OUT then
		self.assertTrueMsg( self.getTerminal.sealCheckWagonLoad = SEAL_CHECK_FULL, "Terminal config for rail seal check out NOT full mode" );
	
		create updateArray transient;
		
		foreach sealObj in _wagon.allWagonSeals do
			
			sealBefore := sealObj.getSealValueAsString;
			sealType := sealObj.sealType;
			sealAfter := sealBefore &amp; "a";			
			
			create pxySealCheckDetail transient;
			pxySealCheckDetail.setProxy(	null,	//_sealCheck : CM_SealCheck;
											sealAfter,	//_sealAfter : String;
											sealBefore,	//_sealBefore : String;
											SEAL_CHECK_FULL,	//_sealCheckType : Integer;
											sealType,	//_sealType : String;
											viewed	//_viewed : Integer;
											);
			
			pxyWagonCheckDetailArray.add( pxySealCheckDetail );
			
			create pxyWagonSeal transient;
			pxyWagonSeal.setProxy(	sealAfter,	//_sealNum : String;
									sealBefore,	//_prevSeal : String;
									sealType,	//_sealType : String;
									sealObj.sealedDT,	//_sealedDT : TimeStamp;
									_wagon	//_myWagonVisit : CM_Wagon
									);
									
			updateArray.add(pxyWagonSeal);
			
		endforeach;
		
	endif;
	
	app.myTrxCA.trxCreateWagonSealsCheckTrans( null, _wagon, wagonTrx, pxyWagonCheckDetailArray, updateArray, _context, app.myPassport);
	

epilog

	if pxyWagonCheckDetailArray &lt;&gt; null and not pxyWagonCheckDetailArray.isEmpty then
		pxyWagonCheckDetailArray.purge();
	endif;
	delete pxyWagonCheckDetailArray;
	if updateArray &lt;&gt; null and not updateArray.isEmpty then
		updateArray.purge();
	endif;
	delete updateArray;

end;</source>
        <Parameter name="_wagon" type="CM_Wagon"/>
        <Parameter name="_context" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="planQueueTiToWagon" id="2805079a-addd-48de-9c76-e31d6c891f4d">
        <source>planQueueTiToWagon(_ti: CM_TrackedItem; _destination: Any; _moveMode : Integer);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 November 2009	cnwndl1	Initial creation	Par 21519

*/

vars
	moveController	: CMIF_MoveController;
	destination: CM_LocationsController;
	expectErrors : Boolean;
begin

	expectErrors := self.opts.bool("ExpectErrors");
	
	if _destination.isKindOf(CM_LocationsController) then
		destination := _destination.CM_LocationsController;
	elseif _destination.isKindOf(CM_TerminalArea) then
		destination := _destination.CM_TerminalArea.allLocationsControllers.first;
	endif;

	create moveController transient;
	moveController.setMyTrackedItem(_ti);
	moveController.setMyToPrimaryLocation(destination);
	moveController.setMoveMode(_moveMode);
	//moveController.isForcedMove := true;

	app.myTrxUA.trxMoveTrackedItemNewRailJob(moveController, app.myPassport);
	if not expectErrors then
		self.assertNoTrxErrorsOrWarnings();
	endif;

epilog
	delete moveController;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_destination" type="Any"/>
        <Parameter name="_moveMode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tAddSimpleTrainAndWagon" id="0ecf8e89-7f97-4377-86f9-ac94b70d2378">
        <source>tAddSimpleTrainAndWagon();
// CNWNDL1
//02 November 2009	cnwjo3	
//26/3/2014 cnwma1	 Delete Wagon Master after deleting wagon Class
//27/3/2014 cnwma1	  Update wagon details .

constants
	TrainCode : String = "UT-TRAINJ1";
	WagonCode1 : String = "JX_001";
	WagonClassCode : String = "JX";
	RailAreaId : String = "UT_JRA1";
vars
	train: CM_Train;
	railArea : CM_Rail;
	wagon : CM_Wagon;
	wagonClass : CM_WagonClass;
	operator : CM_Operator;
	wagonMaster : CM_WagonMaster;
	origRequiresImportOperatorPIN : Boolean;
begin

	//15 Aug 2011	NDL	reset value being dicked around with and left
	// set by other tests.
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);				
	origRequiresImportOperatorPIN := operator.getConfig(RequiresImportOperatorPIN).Boolean;							// 30/04/2014 cnwmh5
	beginTransaction;
	operator.setConfig (RequiresImportOperatorPIN, false);
	commitTransaction;
	
	// ****** DELETE EVERYTHING FROM LAST TEST
	self.deleteRailArea(RailAreaId);

	wagonClass := app.myRoot.allWagonClasses[WagonClassCode];
	if wagonClass &lt;&gt; null then
		self.deleteWagonClassAndWagons(wagonClass);
		wagonMaster	:=	self.getRoot.allWagonMasters[WagonCode1];
		if wagonMaster &lt;&gt; null then
			self.deleteWagonMasterAndWagons(wagonMaster);
		endif;
	endif;
	
	self.deleteTrain(TrainCode,null);


	// ****** ADD NEW TRAIN
	train := self.addTrain(TrainCode,null);
	self.assertNotNull(train);
	
	// ****** ADD NEW RAIL AREA
	railArea := self.addRailArea(RailAreaId, 4, 10);
	self.assertNotNull(railArea);
	
	
	// ****** ADD NEW WAGON CLASS AND WAGON, THEN ATTACH TO TRAIN
	wagonClass := self.addWagonClass(WagonClassCode);
	wagon := self.addWagonInRailArea(WagonCode1, WagonClassCode, railArea, train);
	self.assertNotNull(wagon);
	
	updateTrainWagon(wagon,train);
	
	//finished clean up
	self.deleteRailArea(RailAreaId);
	if wagon.myWagonMaster &lt;&gt; null then
		self.deleteWagonMasterAndWagons(wagon.myWagonMaster);
	endif;
	self.deleteTrain(TrainCode,null);
	
epilog

	// 30/04/2014 cnwmh5 - reset to original value
	beginTransaction;
	operator.setConfig (RequiresImportOperatorPIN, origRequiresImportOperatorPIN);
	commitTransaction;


//	if wagonClass &lt;&gt; null then
//		self.deleteWagonClassAndWagons(wagonClass);
//	endif;
	
//	self.writeTransientsNow( null );

end;</source>
    </JadeMethod>
    <JadeMethod name="tAddTrainAndWagonWithCargo" id="25c08e2f-c387-46d5-8bbd-41119e0df963">
        <source>tAddTrainAndWagonWithCargo();
// CNWNDL1
//02 November 2009	cnwjo3	
//

constants
	TrainCode : String = "UT-TRAINJ2";
	WagonCode1 : String = "JX_002";
	WagonClassCode : String = "JX";
	WagonMasterCode1 : String = "UT_WM_J1";
	RailAreaId : String = "UT_JRA2";
	TiCode : String = "UT_T_TI1";
	TiCode2 : String = "UT_T_TI2";
vars
	train: CM_Train;
	railArea : CM_Rail;
	wagon : CM_Wagon;
	wagonClass : CM_WagonClass;
	allTrackedItems : CM_TIByIdDups;
	ti : CM_TrackedItem;
	ti2 : CM_TrackedItem;
	ya : CM_YardAllocation;
	gbs : CM_ForkLiftStack;
	proxyLabourRestriction : CM_LabourRestriction;
	realLabourRestriction : CM_LabourRestriction;
	
	locations : CM_LCArray;
	tiArray  : CM_TIArray;
	
	pxyMaster : CM_WagonMaster;
	wagonMaster : CM_WagonMaster;
begin
	// ****** DELETE EVERYTHING FROM LAST TEST
	self.deleteRailArea(RailAreaId);
	
	wagonClass := app.myRoot.allWagonClasses[WagonClassCode];
	if wagonClass &lt;&gt; null then
		self.deleteWagonClassAndWagons(wagonClass);
	endif;
	
	self.deleteTrain(TrainCode,null);

	wagonMaster := self.getRoot.allWagonMasters[WagonMasterCode1];
	if wagonMaster &lt;&gt; null then
		self.deleteWagonMasterAndWagons( wagonMaster );
	endif;
	
	self.deleteContainer(TiCode);
	self.deleteContainer(TiCode2); //16 Feb 2017	NDL
	
	// ****** ADD NEW TRAIN
	train := self.addTrain(TrainCode,null);
	self.assertNotNull(train);
	
	// ****** ADD NEW RAIL AREA
	railArea := self.addRailArea(RailAreaId, 4, 5);
	self.assertNotNull(railArea);
	
	// ****** ADD NEW WAGON CLASS AND WAGON, THEN ATTACH TO TRAIN
	self.opts.purge();
	self.opts.addAssoc("MaxPosiWeight", "4500".Decimal);
	self.opts.addAssoc("MaxPosiHeight", "100".Decimal);
	wagonClass := self.addWagonClass(WagonClassCode);
	/*wagon := self.addWagonInRailArea(WagonCode1, WagonClassCode, railArea, train);
	self.assertNotNull(wagon);*/
	
	// ****** CREATE MASTER FOR SOME REASON
	create pxyMaster transient;
	pxyMaster.setProxy(	WagonMasterCode1,	//_id : String;
						wagonClass,	//_myWagonClass : CM_WagonClass;
						CM_Carrier.firstInstance,	//_myCarrier : CM_Carrier;
						450,	//_maxCargoHeight	: Decimal; 
						60000,	//_maxCargoWeight	: Decimal;
						15000	//_tareWeight	: Decimal
						);
	pxyMaster.setPropogateChanges(false);
	app.myTrxCA.trxCreateWagonMaster( pxyMaster, wagonMaster, app.myPassport );	
	
	
	// ****** ADD PLACE CONTAINERS ON WAGONS
	create allTrackedItems transient;
	ti := self.createContainer(	TiCode,
							"2200",	//_isoType: String;
							"GB1",	//_commodity: String;
							self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),	//_operator: CM_Operator
							false
							);
	allTrackedItems.add(ti);
	ti2 := self.createContainer(	TiCode2,
							"2200",	//_isoType: String;
							"GB1",	//_commodity: String;
							self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),	//_operator: CM_Operator
							false
							);
	self.assertNotNull(ti2);
	allTrackedItems.add(ti2);
	
	self.opts.purge();
	self.opts.addAssoc("RailLine", railArea.allRailLines.first);
	wagon := self.addWagonToTrainOption2(train, wagonMaster, allTrackedItems,false);
	
	// 21/07/2015 cnwmh5
	create tiArray transient;
	
	self.disableAllYA(true);
	
	gbs := self.addForkLiftStack("UTMHFC", 5, 5, 4);
	self.assertNotNull(gbs);
	
	create locations transient;
	locations.add(gbs.allGridControllersByRowColumn[1,4]);
	locations.add(gbs.allGridControllersByRowColumn[2,4]);
	
	self.deleteYA("MDHTRNLOB");
	ya := self.addYA("MDHTRNLOB", YACriteriaType_ISO, "2200", YACriteriaType_Commodity, "GB1", 
		YACriteriaType_OperatorItem, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), 
		locations, null);
		
	tiArray.clear();
	tiArray.add(allTrackedItems.first);
	
	beginTransaction;
	wagon.confirmWagonInwards(null,false, app.myPassport);
	commitTransaction;
	
	self.opts.purge();
	self.opts.addAssoc("MoveMode", QUEUE_MODE);
	self.moveQueued(ti, locations.first);
	self.assertNotEqual(ti.getQueueEntry().status, ENTRY_SYSTEM_HELD);
	
	locations.clear();
	locations.add(gbs.allGridControllersByRowColumn[1,4]);
	
	realLabourRestriction := self.addLabourRestriction("UTMHLR1", locations, true);
	self.assertNotNull(realLabourRestriction);
	self.assertEqual(ti.getQueueEntry().status, ENTRY_SYSTEM_HELD);
	
	self.opts.purge();
	self.opts.addAssoc("MoveMode", QUEUE_MODE);
	self.moveQueued(ti2, locations.first);
	self.assertEqual(ti2.isQueued(), true);
	self.assertEqual(ti.getQueueEntry().status, ENTRY_SYSTEM_HELD);
	
	foreach realLabourRestriction in gbs.allRestrictionsLabour discreteLock do
		if realLabourRestriction.id = "UTMHLR1" then
			self.deleteLabourRestriction(realLabourRestriction);
		endif;
	endforeach;
	self.assertNotEqual(ti.getQueueEntry().status, ENTRY_SYSTEM_HELD);
	self.assertNotEqual(ti2.getQueueEntry().status, ENTRY_SYSTEM_HELD);
	
	//finished clecn up 
	self.deleteRailArea(RailAreaId);
	wagonClass := app.myRoot.allWagonClasses[WagonClassCode];
	if wagonClass &lt;&gt; null then
		self.deleteWagonClassAndWagons(wagonClass);
	endif;
	self.deleteTrain(TrainCode,null);
	wagonMaster := self.getRoot.allWagonMasters[WagonMasterCode1];
	if wagonMaster &lt;&gt; null then
		self.deleteWagonMasterAndWagons( wagonMaster );
	endif;
	self.deleteContainer(TiCode);
	self.deleteContainer(TiCode2);
	self.deleteYA("MDHTRNLOB");
	
epilog
	self.disableAllYA(false);
	if allTrackedItems &lt;&gt; null then
		delete allTrackedItems;
	endif;
	delete pxyMaster;
	delete tiArray;
	delete locations;
	delete proxyLabourRestriction;
end;</source>
    </JadeMethod>
    <JadeMethod name="tBasicTrackClearance" id="68a9708d-e1bd-47c0-ac6c-4550e9dad474">
        <source>tBasicTrackClearance();
// cnwndl1
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 July 2009	cnwndl1	Initial creation

*/

vars

	trackClearanceZZ : CM_TrackClearance;
	gcId : String;
	existingTrackClearance : CM_TrackClearance;
	loadState : Boolean;
	trackClearanceZX : CM_TrackClearance;
	proxyTrackClearance : CM_TrackClearance;
	
begin

	// creates and deletes a basic CM_GaugeClearance object "ZZ".
	gcId := "ZZ";
	trackClearanceZZ := addTrackClearance(gcId);
	
	
	gcId := "ZX";
	existingTrackClearance := app.myRoot.allTrackClearances.getAtKey(gcId);
	self.assertTrueMsg(existingTrackClearance = null, "Track clearance '" &amp; gcId &amp; "' already exists !!");
	
	app.cmsBeginLoad(loadState);
	
	create proxyTrackClearance transient;
	proxyTrackClearance.setProxy(	true,	//_allowHiCube : Boolean;
									gcId,	//_code : String;
									gcId &amp; " Test track clearance",	//_description : String;
									300,	//_maxHeight : Decimal;
									15000,	//_maxWeightWagon : Decimal;
									260,	//_maxWidth : Decimal;
									true,	//_isNotAvailableForEntry : Boolean
									0, // max weight for train
									false // no empty wagons
									);
								
	app.myTrxCA.trxCreateTrackClearance(proxyTrackClearance, trackClearanceZX, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	self.assertTrueMsg(trackClearanceZX &lt;&gt; null, "Track Clearance '" &amp; gcId &amp; "' not created.");
	
	self.assertTrueMsg(trackClearanceZX.code = gcId, "Track Clearance 'code' not populated correctly.");
	self.assertTrueMsg(trackClearanceZX.allowHiCube, "Track Clearance 'allowHiCube' not populated correctly.");
	self.assertTrueMsg(trackClearanceZX.description = gcId &amp; " Test track clearance", "Track Clearance 'description' not populated correctly.");
	self.assertTrueMsg(trackClearanceZX.maxHeight = 300, "Track Clearance 'maxHeight' not populated correctly.");
	self.assertTrueMsg(trackClearanceZX.maxWeightWagon = 15000, "Track Clearance 'maxWeightWagon' not populated correctly.");
	self.assertTrueMsg(trackClearanceZX.maxWidth = 260, "Track Clearance 'maxWidth' not populated correctly.");
	self.assertTrueMsg(trackClearanceZX.isNotAvailableForEntry, "Track Clearance 'isNotAvailableForEntry' not populated correctly.");
	
epilog

	app.cmsEndLoad(loadState);
	delete proxyTrackClearance;

	self.deleteTrackClearance(trackClearanceZZ);
	self.deleteTrackClearance(trackClearanceZX);

end;</source>
    </JadeMethod>
    <JadeMethod name="tBasicWagonClass" id="0c1c78d3-c0aa-4a2f-b658-71db764c6fdc">
        <source>tBasicWagonClass();
// cnwndl1
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 July 2009	cnwndl1	Initial creation

*/

vars

	wagonClassId : String;
	wagonClassZZ : CM_WagonClass;
	rule : CM_WagonPositionalRule;
	posi : CM_WagonPosition;
	
	existingWagonClass : CM_WagonClass;
	wagonClassZX : CM_WagonClass;
	loadState : Boolean;
	proxyWagonClass : CM_WagonClass;
	pLocationIds : StringArray;
	pConsigneeRestrictions	: CM_ConsignCodeArray;
	pxyRule : CM_WagonPositionalRule;
	pxyPosi : CM_WagonPosition;
	
	wagonClassABCDEFG : CM_WagonClass;
	
begin

	// creates and deletes a basic CM_WagonClass object "ZZ" that includes simple Positional loading data
	wagonClassId := "ZZ";
	
	//Just in case some one has been testing during the day and not cleaned up again....
	existingWagonClass := app.myRoot.allWagonClasses.getAtKey(wagonClassId);
	if existingWagonClass &lt;&gt; null then
		self.deleteWagonClassAndWagons(existingWagonClass);
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("MaxPosiWeight", "4000".Decimal);
	wagonClassZZ := addWagonClass(wagonClassId);
	
	self.assertTrueMsg(wagonClassZZ &lt;&gt; null, "Wagon Class '" &amp; wagonClassId &amp; "' not created.");
	rule := wagonClassZZ.allWagonPositionalRules.first;
	self.assertTrueMsg(rule &lt;&gt; null, "Wagon Positional Rule not created!");
	self.assertTrueMsg(rule.allWagonPositions.getAtKey(1) &lt;&gt; null, "Wagon Position Rule 1. not created!");
	self.assertTrueMsg(rule.allWagonPositions.getAtKey(2) &lt;&gt; null, "Wagon Position Rule 2. not created!");
	self.assertTrueMsg(rule.allWagonPositions.getAtKey(3) &lt;&gt; null, "Wagon Position Rule 3. not created!");
	self.assertTrueMsg(rule.allWagonPositions.getAtKey(4) &lt;&gt; null, "Wagon Position Rule 4. not created!");
	
	// creates a basic CM_WagonClass objectZ "ZX" and checks the values
	wagonClassId := "ZX";
	existingWagonClass := app.myRoot.allWagonClasses.getAtKey(wagonClassId);
	self.assertTrueMsg(existingWagonClass = null, "Wagon class '" &amp; wagonClassId &amp; "' already exists !!");
	
	app.cmsBeginLoad(loadState);
	
	create proxyWagonClass transient;
	create pConsigneeRestrictions transient;
	create pLocationIds transient;
	pLocationIds.add("1");
	pLocationIds.add("2");
	pLocationIds.add("3");
	pLocationIds.add("4"); 
	proxyWagonClass.setProxy(	wagonClassId,	//pCode : String;
								true,	//pAcceptsGenerator : Boolean;
								true,	//pDoorsAccessible : Boolean;
								true,	//isNotAvailableForEntry : Boolean; 
								25000,	//pMaxLoadWeight : Integer;
								1,	//pMaxNumInStack : Integer;
								4,	//pLenInUnits : Integer;
								pLocationIds,	//pLocationIds : StringArray;
								pConsigneeRestrictions,	//pConsigneeRestrictions : CM_ConsignCodeArray;
								45,	//pDeckHeight : Decimal;
								300,	//pMaxCargoHeight : Decimal;
								5000,	//pTareWeight : Decimal;
								CM_Carrier.firstInstance,	//pMyCarrier : CM_Carrier
								0,	//pInternalHeight : Decimal;	//18 Mar 2013	NDL	Par 31278
								0,	//pInternalLength : Decimal;	//18 Mar 2013	NDL	Par 31278
								0,	//pInternalWidth : Decimal;	//18 Mar 2013	NDL	Par 31278
								0,	//pOverallHeight : Decimal;	//18 Mar 2013	NDL	Par 31278
								0,	//pOverallLength : Decimal;	//18 Mar 2013	NDL	Par 31278
								0,	//pOverallWidth : Decimal;	//18 Mar 2013	NDL	Par 31278
								1,	//pWagonType : Integer;
								null,		//pTierIds : StringArray
								null, //pSealTypes : CM_SealTypeDict	//10 Mar 2015	NDL	Par 35828
								CM_BoxcarVisit.BoxcarGraphicBreakBulk // TFS 49523
								);
								
	app.myTrxCA.trxCreateWagonClass(proxyWagonClass, wagonClassZX, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());

	create pxyRule transient;
	pxyRule.setProxy(	proxyWagonClass,	//_myWagonClass : CM_WagonClass;
						2,	//_numberOfPositions : Integer;
						null	//_allWagonPositions : CM_WagonPositionDict
						);
						
	foreach pxyPosi in pxyRule.allWagonPositions do
		pxyPosi.setProxy(	20,	//_cargoLength : Integer;
							45,	//_deckHeight : Decimal;
							4000,	//_maxWeight : Decimal;
							pxyPosi.position,	//_position : Integer;
							pxyRule	//_myWagonPositionalRule : CM_WagonPositionalRule
							);
	endforeach;

	app.myTrxCA.trxCreateWagonPositionalRule( pxyRule, rule, app.myPassport );
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	
	self.assertTrueMsg(wagonClassZX &lt;&gt; null, "Wagon Class '" &amp; wagonClassId &amp; "' not created!");
	self.assertTrueMsg(wagonClassZX.code = wagonClassId, "Wagon Class 'code' not populated correctly.");
	self.assertTrueMsg(wagonClassZX.acceptsGenerator, "Wagon Class 'acceptsGenerator' not populated correctly.");
	self.assertTrueMsg(wagonClassZX.doorsAccessible, "Wagon Class 'doorsAccessible' not populated correctly.");
	self.assertTrueMsg(wagonClassZX.isNotAvailableForEntry, "Wagon Class 'isNotAvailableForEntry' not populated correctly.");
	self.assertTrueMsg(wagonClassZX.maxLoadWeight = 25000, "Wagon Class 'maxLoadWeight' not populated correctly.");
	self.assertTrueMsg(wagonClassZX.maxNumInStack = 1, "Wagon Class 'maxNumInStack' not populated correctly.");
	self.assertTrueMsg(wagonClassZX.getLenInUnits = 4, "Wagon Class 'lenInUnits' not populated correctly.");
	self.assertTrueMsg(wagonClassZX.deckHeight = 45, "Wagon Class 'deckHeight' not populated correctly.");
	self.assertTrueMsg(wagonClassZX.maxCargoHeight = 300, "Wagon Class 'maxCargoHeight' not populated correctly.");
	self.assertTrueMsg(wagonClassZX.tareWeight = 5000, "Wagon Class 'tareWeight' not populated correctly.");
	self.assertTrueMsg(wagonClassZX.myCarrier = CM_Carrier.firstInstance, "Wagon Class 'myCarrier' not populated correctly.");
	
	rule := wagonClassZX.allWagonPositionalRules.first;
	self.assertTrueMsg(rule &lt;&gt; null, "Wagon Positional Rule not created!");
	self.assertTrueMsg(rule.numberOfPositions = 2, "Wagon Class Rule 'numberOfPositions' not populated correctly.");
	self.assertTrueMsg(rule.allWagonPositions.size = 2, "Wagon Class Rule 'allWagonPositions.size' incorrect.");
	self.assertTrueMsg(rule.allWagonPositions.getAtKey(1) &lt;&gt; null, "Wagon Position Rule 1. not created!");
	self.assertTrueMsg(rule.allWagonPositions.getAtKey(2) &lt;&gt; null, "Wagon Position Rule 2. not created!");
	
	posi := rule.allWagonPositions.getAtKey(1);
	self.assertTrueMsg(posi.cargoLength = 20, "Wagon Position Rule 1. 'cargoLength' not populated correctly.");
	self.assertTrueMsg(posi.deckHeight = 45, "Wagon Position Rule 1. 'deckHeight' not populated correctly.");
	self.assertTrueMsg(posi.maxWeight = 4000, "Wagon Position Rule 1. 'maxWeight' not populated correctly.");
	self.assertTrueMsg(posi.position = 1, "Wagon Position Rule 1. 'position' not populated correctly.");
	
	posi := rule.allWagonPositions.getAtKey(2);
	self.assertTrueMsg(posi.cargoLength = 20, "Wagon Position Rule 2. 'cargoLength' not populated correctly.");
	self.assertTrueMsg(posi.deckHeight = 45, "Wagon Position Rule 2. 'deckHeight' not populated correctly.");
	self.assertTrueMsg(posi.maxWeight = 4000, "Wagon Position Rule 2. 'maxWeight' not populated correctly.");
	self.assertTrueMsg(posi.position = 2, "Wagon Position Rule 2. 'position' not populated correctly.");
	
	// creates and deletes a basic CM_WagonClass object "ZZ", to ensure a wgon class can have 7 chars in its code.
	wagonClassId := "ABCDEFG";
	existingWagonClass := app.myRoot.allWagonClasses.getAtKey(wagonClassId);
	if existingWagonClass &lt;&gt; null then
		self.deleteWagonClassAndWagons(existingWagonClass);
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("MaxPosiWeight", "4000".Decimal);
	wagonClassABCDEFG := addWagonClass(wagonClassId);
	self.assertTrueMsg(wagonClassABCDEFG &lt;&gt; null, "Wagon Class '" &amp; wagonClassId &amp; "' not created.");
	self.assertTrueMsg(wagonClassABCDEFG.code = wagonClassId, "Wagon Class 'code' of 7 characters not populated correctly. Should be '" &amp; wagonClassId &amp; "', but is '" &amp; wagonClassABCDEFG.code &amp; "'");
	
	
epilog

	app.cmsEndLoad(loadState);
	delete proxyWagonClass;
	delete pConsigneeRestrictions;
	delete pLocationIds;
	
	self.deleteWagonClassAndWagons(wagonClassZZ);
	self.deleteWagonClassAndWagons(wagonClassZX);
	self.deleteWagonClassAndWagons(wagonClassABCDEFG);

end;</source>
    </JadeMethod>
    <JadeMethod name="tBreakBulkTrainInRoadOut" id="66404b9d-d287-4915-ba40-91ac626d75c4">
        <source>tBreakBulkTrainInRoadOut();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2020	jlgndl1	Initial creation	TFS 49202

*/

constants

	TrainInCode : String = "TR49202";
	WagonInCode : String = "W49202";
	WagonClassCode : String = "UTMH1";
	RailAreaId : String = "UT49202";
	CargoId1 : String = "BB49202";
	CargoType1 : String = "UTBYQ";
	TruckOut : String = 'TRK49202';
	DriverID1 : String = 'UTDRIVER1';
	BlockStack1 : String = "BSTR1";
	BlockStack2 : String = "BSTR2";
	TruckIn : String = 'TRK49202B';
	DriverID2 : String = 'UTDRIVER2';
	CargoId2 : String = "BB49202B";

vars

	term : CM_Terminal;
	cargoType : CM_CargoType;
	ti1In : CM_TrackedItem;
	job : CM_Job;
	wagonMaster : CM_WagonMaster;
	wagonClass : CM_WagonClass;
	operator : CM_Operator;
	train : CM_Train;
	railArea : CM_Rail;
	wagon : CM_Wagon;
	pxyTI : CM_TrackedItem;
	wagonCont : CM_WagonController;
	railLine : CM_RailLine;
	railReceive : CM_ReceiveRail;
	wle : CM_WorkListEntry;
	vvr : CM_VehicleVisitRecord;
	gate : CM_Gate;
	bs1 : CM_BlockStack;
	bs2 : CM_BlockStack;
	ti1Out : CM_TrackedItem;
	roadRelease : CM_ReleaseRoad;
	ifPreNote: CMIF_PreNote;
	ti2In : CM_TrackedItem;
	ifArray: CMIF_TIObjectArray;
	roadReceive : CM_ReceiveRoad;
	cmifToDepartTrain : CMIF_RakeRegion;
	railRelease : CM_ReleaseRail;
	finalRailLocation : String;
	
begin

	term := self.getTerminal;
	cargoType := term.getCargoTypeFromAbbrevOrDescr( CargoType1 );
	self.assertTrueMsg( cargoType &lt;&gt; null, CargoType1 &amp; " Cargo type not found during set up!");
	wagonClass := app.myRoot.allWagonClasses.getAtKey( WagonClassCode );
	self.assertTrueMsg( wagonClass &lt;&gt; null, WagonClassCode &amp; " Wagon Class not found during set up!");
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertTrueMsg( operator &lt;&gt; null, "Operator not found during set up!");
	gate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	self.assertTrueMsg( gate &lt;&gt; null, "Gate not found during set up!");
	
	//Clean up anything left behind from a previous fail.
	ti1In := term.lookupTrackedItem( CargoId1, cargoType.id, TI_STATE_UNDEFINED, null, false );
	if ti1In &lt;&gt; null and app.isValidObject( ti1In ) then
		beginTransaction;
		if ti1In.jobRailReceive &lt;&gt; null then
			job := ti1In.jobRailReceive;
			delete job;
		endif;
		commitTransaction;
		self.deleteTrackedItem( ti1In, false );
	endif;
	ti2In := term.lookupTrackedItem( CargoId2, cargoType.id, TI_STATE_UNDEFINED, null, false );
	if ti2In &lt;&gt; null and app.isValidObject( ti2In ) then
		beginTransaction;
		if ti2In.jobRailRelease &lt;&gt; null then
			job := ti2In.jobRailRelease;
			delete job;
		endif;
		commitTransaction;
		self.deleteTrackedItem( ti2In, false );
	endif;
	wagonMaster := self.getRoot.allWagonMasters[ WagonInCode ];
	if wagonMaster &lt;&gt; null then
		self.deleteWagonMasterAndWagons( wagonMaster );
	endif;
	self.deleteTrain( TrainInCode, null );
	self.deleteRailArea( RailAreaId );
	self.deleteVehicle( TruckOut );
	self.deleteVehicle( TruckIn );
	self.deleteTerminalArea( BlockStack1 );
	self.deleteTerminalArea( BlockStack2 );
	
	// Set up the data
	
	bs1 := self.addBlockStack( BlockStack1, 10, null );
	self.assertTrueMsg( bs1 &lt;&gt; null, "Block Stack1 not created during set up!");
	bs2 := self.addBlockStack( BlockStack2, 10, null );
	self.assertTrueMsg( bs2 &lt;&gt; null, "Block Stack2 not created during set up!");
	train := self.addTrain(TrainInCode,null);
	self.assertTrueMsg( train &lt;&gt; null, "Train not created during set up!");
	railArea := self.addRailArea(RailAreaId, 2, 5);
	self.assertTrueMsg( railArea &lt;&gt; null, "Rail Area not created during set up!");
	wagon := self.addWagonInRailArea(WagonInCode, WagonClassCode, railArea, train);
	
	//OK we now have a train offsite with an empty wagon on board.
	//Add a pre-noted cargo.
	
	pxyTI := app.myPassport.myTerminal.createTI(cargoType, true);
	pxyTI.setPxyFromDefaultTI( app.myPassport.myTerminal, cargoType.id, CargoId1, null, operator );
	pxyTI.zSetPxyImexStatus( TI_IMEX_STATUS_EXPORT );
	pxyTI.zSetPxyDestinationPort( "NZAKL" );
	pxyTI.zSetPxyDischargePort( "NZAKL" );
	pxyTI.zSetPxyVoyage( term.getNullVoyage, null );
	pxyTI.setReceiptTransportMode( TI_TRANSMODE_RAIL );
	pxyTI.setWagon( wagon.id, wagon, wagon.myWagonClass, false );
	pxyTI.setTotalQuantity( 50 );
	pxyTI.setTotalWeight( 5000, null, app.myPassport );
	
	app.myTrxCA.trxCreateTrackedItem( pxyTI, ti1In, app.myPassport );
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Errors creating pre-note&gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	
	wagonCont := wagon.allLocationsControllersArray[1];
	self.moveTiToWagon(ti1In, wagonCont);
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Errors in move Ti to Wagon&gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	// pre-note is now on wagon
	
	railLine := railArea.allRailLinesByIndex.first;
	railLine.switchPositions(wagon, 01);	
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Wagon set rail position Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	
	app.myTrxUA.trxUpdateWagonConfirmTrain(null, true, train, true, app.myPassport);  //in
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Confirm IN Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	//Its all arrived and confirmed in
	
	wle := ti1In.allWorklistEntries.first();
	self.opts.purge();
	self.opts.addAssoc( "SetWorkListEntry", wle );
	self.moveBreakBulk( ti1In, bs1.myLocationsController, 25 );
	
	ti2In := bs1.myLocationsController.allTrackedItems.first();
	
	//Check the Rail Received
	railReceive := ti2In.getTransReceive.CM_ReceiveRail;
	self.assertTrueMsg( railReceive.locationRail = wagonCont.getFullId, "Rail Receive locationRail s/be '" &amp; wagonCont.getFullId &amp; "' is '" &amp; railReceive.locationRail &amp; "'");
	self.assertTrueMsg( railReceive.locationYard = bs1.myLocationsController.getFullId, "Rail Receive locationYard s/be '" &amp; bs1.myLocationsController.getFullId &amp; "' is '" &amp; railReceive.locationYard &amp; "'");	
	self.assertTrueMsg( railReceive.trainCode = TrainInCode, "Rail Receive trainCode s/be '" &amp; TrainInCode &amp; "' is '" &amp; railReceive.trainCode &amp; "'");	
	self.assertTrueMsg( railReceive.wagonCode = WagonInCode, "Rail Receive wagonCode s/be '" &amp; WagonInCode &amp; "' is '" &amp; railReceive.wagonCode &amp; "'");
	
	wle := ti1In.allWorklistEntries.last();
	self.opts.purge();
	self.opts.addAssoc( "SetWorkListEntry", wle );
	self.moveBreakBulk( ti1In, bs2.myLocationsController, 25 );
	
	//Now gate a truck in to take some away
	self.opts.purge();
	self.opts.addAssoc("TotalRequested", 10);
	self.opts.addAssoc("MakeByType", true);
	vvr := gateOutGC( TruckOut, "", DriverID1, ti1In, gate, null);
	wle := vvr.myRoadJob.workListEntries.getFirstUnactionedWLE;
	self.assertTrueMsg(wle &lt;&gt; null, "No director task created to go out by truck in release part of test" );
	
	ti1Out := bs1.myLocationsController.allTrackedItems.first;
	self.opts.purge();
	self.opts.addAssoc( "SetWorkListEntry", wle );
	self.moveBreakBulk( ti1Out, vvr.vehicle.locationsController, 10 );

	ti1Out := vvr.vehicle.locationsController.allTrackedItems.first;
	
	self.roadExit(vvr);
	
	roadRelease := ti1Out.getTransRelease.CM_ReleaseRoad;
	self.assertTrueMsg( roadRelease.locationRoad = vvr.vehicle.locationsController.getFullId, "Road Release locationRoad s/be '" &amp; vvr.vehicle.locationsController.getFullId &amp; "' is '" &amp; roadRelease.locationRoad &amp; "'");
	self.assertTrueMsg( roadRelease.locationYard = bs1.myLocationsController.getFullId, "Road Release locationYard s/be '" &amp; bs1.myLocationsController.getFullId &amp; "' is '" &amp; roadRelease.locationYard &amp; "'");	
	self.assertTrueMsg( roadRelease.regNumber = vvr.vehicle.regNumber, "Road Release regNumber s/be '" &amp; vvr.vehicle.regNumber &amp; "' is '" &amp; roadRelease.regNumber &amp; "'");	
	

	//OK Now the reverse cargo comes in on Road goes out by Train.
	create ifArray transient;
	create ifPreNote transient;
	
	ifPreNote.id := CargoId2;
	ifPreNote.myTerminal := term;
	ifPreNote.cargoType := cargoType.id;
	ifPreNote.imExStatus := getRoot.allImexStatuses[TI_IMEX_STATUS_STORAGE];
	ifPreNote.operatorCode := operator.code;
	ifPreNote.transportMode := TI_TRANSMODE_ROAD_STR;
	ifPreNote.numberOfItems := 20;
	ifArray.add(ifPreNote);
	self.ignoreTrxWarnings(true);
	app.myTrxCA.trxCreatePreNotes(ifArray, false, app.myPassport);
	
	ti2In := self.getTerminal.lookupTrackedItem(ifPreNote.id, cargoType.id, TI_STATE_NOTIFIED, null, false);
	self.assertTrueMsg( ti2In &lt;&gt; null, CargoId2 &amp; " Pre-note for bringing in by truck not created during second scenario set up!");
	
	vvr := self.gateInGC( TruckIn, null, DriverID2, CargoId2, cargoType.description, operator.code, null, gate, ti2In.totalQuantity );
	
	//Move to the yard
	wle := ti2In.allWorklistEntries.first;
	self.opts.purge();
	self.opts.addAssoc( "SetWorkListEntry", wle );
	self.moveBreakBulk( ti2In, bs2.myLocationsController, 20 );
	
	roadReceive := ti2In.getTransReceive.CM_ReceiveRoad;
	self.assertTrueMsg( roadReceive.locationRoad = vvr.vehicle.locationsController.getFullId, "Road Receive locationRoad s/be '" &amp; vvr.vehicle.locationsController.getFullId &amp; "' is '" &amp; roadReceive.locationRoad &amp; "'");
	self.assertTrueMsg( roadReceive.locationYard = bs2.myLocationsController.getFullId, "Road Receive locationYard s/be '" &amp; bs2.myLocationsController.getFullId &amp; "' is '" &amp; roadReceive.locationYard &amp; "'");	
	self.assertTrueMsg( roadReceive.regNumber = vvr.vehicle.regNumber, "Road Receive regNumber s/be '" &amp; vvr.vehicle.regNumber &amp; "' is '" &amp; roadReceive.regNumber &amp; "'");
	
	//gate the truck out
	self.roadExit(vvr);
	
	//now move to the outbound wagon
	self.opts.purge();
	self.moveBreakBulk( ti2In, wagonCont, 20 );
	
	finalRailLocation := ti2In.myPrimaryActualLocation.getFullId();
	
	//30 Jun 2021	NDL	TFS 51421 - Now plan it back to the yard
	self.movePlanned( ti2In, bs2.myLocationsController );
	self.assertTrueMsg( ti2In.myPrimaryPlannedLocation = bs2.myLocationsController, "Cargo should be planned back to the yard" );
	
	//confirm train (wagons) out
	self.ignoreTrxWarnings(true);
	app.myTrxUA.trxUpdateWagonConfirmTrain(null, false, train, false, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());

	//make the train depart
	create cmifToDepartTrain transient;	
	cmifToDepartTrain.myTrain := train;
	self.ignoreTrxWarnings(true);
	app.myTrxUA.trxUpdateRailClearRake(cmifToDepartTrain, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	delete cmifToDepartTrain;
	
	//30 Jun 2021	NDL	TFS 51421 - Planned locations should be cleared on wagon depart.
	self.assertTrueMsg( ti2In.myPrimaryPlannedLocation = null, "Cargo should NO longer be planned back to the yard after departing wagon" );
	
	//Check the Rail Release
	railRelease := ti2In.getTransRelease.CM_ReleaseRail;	
	self.assertTrueMsg( railRelease.locationRail = finalRailLocation, "Rail Release locationRail s/be '" &amp; finalRailLocation &amp; "' is '" &amp; railRelease.locationRail &amp; "'");
	self.assertTrueMsg( railRelease.locationYard = bs2.myLocationsController.getFullId, "Rail Release locationYard s/be '" &amp; bs2.myLocationsController.getFullId &amp; "' is '" &amp; railRelease.locationYard &amp; "'");	
	self.assertTrueMsg( railRelease.trainCode = TrainInCode, "Rail Release trainCode s/be '" &amp; TrainInCode &amp; "' is '" &amp; railRelease.trainCode &amp; "'");	
	self.assertTrueMsg( railRelease.wagonCode = WagonInCode, "Rail Release wagonCode s/be '" &amp; WagonInCode &amp; "' is '" &amp; railRelease.wagonCode &amp; "'");

	//Be a tidy kiwi, get rid of teh data, cos its all passed.
	ti1In := term.lookupTrackedItem( CargoId1, cargoType.id, TI_STATE_UNDEFINED, null, false );
	if ti1In &lt;&gt; null and app.isValidObject( ti1In ) then
		beginTransaction;
		if ti1In.jobRailReceive &lt;&gt; null then
			job := ti1In.jobRailReceive;
			delete job;
		endif;
		commitTransaction;
		self.deleteTrackedItem( ti1In, false );
	endif;
	ti2In := term.lookupTrackedItem( CargoId1, cargoType.id, TI_STATE_UNDEFINED, null, false );
	if ti2In &lt;&gt; null and app.isValidObject( ti2In ) then
		beginTransaction;
		if ti2In.jobRailRelease &lt;&gt; null then
			job := ti2In.jobRailRelease;
			delete job;
		endif;
		commitTransaction;
		self.deleteTrackedItem( ti2In, false );
	endif;
	wagonMaster := self.getRoot.allWagonMasters[ WagonInCode ];
	if wagonMaster &lt;&gt; null then
		self.deleteWagonMasterAndWagons( wagonMaster );
	endif;
	self.deleteTrain( TrainInCode, null );
	self.deleteRailArea( RailAreaId );
	self.deleteVehicle( TruckOut );
	self.deleteVehicle( TruckIn );
	self.deleteTerminalArea( BlockStack1 );
	self.deleteTerminalArea( BlockStack2 );
	
epilog

	delete ifArray;
	delete ifPreNote;

end;</source>
    </JadeMethod>
    <JadeMethod name="tCargoForecastChkAudit" id="b26751f8-f1f8-45db-b712-155189b3271f">
        <source>tCargoForecastChkAudit();
/*

Purpose:			Tests the audits on an Cargo Forecast for creation, update and deletion

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
11 April 2022	navpw1	Initial creation TFS: 53132

*/

//Total of 3 Tests to run Audit Create, Audit Update. Each test has their own assert section

constants
	Ref						: String		= UT_DSL.TFS53132;
	TrainCode 				: String 		= "UT-T" &amp; Ref;
	WagonCode1 				: String 		= "JX" &amp; Ref;
	WagonClassCode 			: String 		= "JX";
	RailAreaId 				: String		= "UT" &amp; Ref;
	TOTALQUANTITY 			: Integer 		= 12;
	TOTALWEIGHT				: Decimal[23,6] = 23.345;
	TOTALVOLUME				: Decimal[23,6] = 24.345;
	
	UPDTOTALQUANTITY 		: Integer 		= 15;
	UPDTOTALWEIGHT			: Decimal[23,6] = 26.345;
	UPDTOTALVOLUME			: Decimal[23,6] = 27.345;
	
vars
	train					: CM_Train;
	railArea 				: CM_Rail;
	wagon 					: CM_Wagon;
	wagonClass 				: CM_WagonClass;
	errorMess 				: String;
	railLine 				: CM_RailLine;
	
	pxyCargoForecast,
	realCargoForecast		: CM_CargoForecast;
	cargoType				: CM_CargoType;
	commodity				: CM_Commodity;
	operator				: CM_Operator;
	
	auditObj 				: CM_AuditObject;
	createAuditExists,
	updateAuditExists		: Boolean;
	mode					: String;
	
begin
	// ****** DELETE EVERYTHING FROM LAST TEST
	self.deleteRailArea(RailAreaId);
	
	wagonClass := app.myRoot.allWagonClasses[WagonClassCode];
	if wagonClass &lt;&gt; null then
		self.deleteWagonClassAndWagons(wagonClass);
	endif;

	self.deleteTrain(TrainCode, null);
	
	// ****** ADD NEW TRAIN
	train := self.addTrain(TrainCode, null);
	self.assertNotNull(train);
	
	// ****** ADD NEW WAGON CLASS AND WAGON
	self.opts.purge();
	self.opts.addAssoc("MaxPosiWeight", "4500".Decimal);
	self.opts.addAssoc("MaxPosiHeight", "100".Decimal);
	wagonClass := self.addWagonClass(WagonClassCode);
	
	// ****** ADD NEW RAIL AREA
	railArea := self.addRailArea(RailAreaId, 4, 5);
	self.assertNotNull(railArea);
	railLine:=railArea.allRailLines.first;
	
	//ATTACH WAGON TO TRAIN
	wagon := train.createOrUpdateWagon(WagonCode1, 3, railLine, errorMess);
	self.assertNull(errorMess);
	self.assertNotNull(wagon);
	self.assertEqual(railLine.allWagons[3], wagon);

	/*
	**	Setup Test Create - Normal Happy Day Scenario
	*/
	operator 	:= app.myRoot.allOperators["****"];
	self.assertNotNullMsg(operator, "Operator is null");
	
	cargoType 	:= app.myRoot.allCargoTypesById.getCargoTypeByAbbreviation("CONT");
	self.assertNotNullMsg(cargoType, "Cargo type is null");
	
	commodity 	:= app.myRoot.allCommodities["GENL"];
	self.assertNotNullMsg(commodity, "Commodity is null");
	
	mode 		:= CM_CargoForecast.Mode_Discharge; 
	
	/*
	**	Run Test Create - Normal Happy Day Scenario
	*/
	create pxyCargoForecast transient;
	pxyCargoForecast.setProxyForCreate(cargoType, commodity, mode, operator, TOTALQUANTITY, TOTALWEIGHT, TOTALVOLUME, train);
	app.myTrxCA.trxCreateCargoForecast(pxyCargoForecast, realCargoForecast, app.myPassport);
	
	/*
	**	Assert Test Create - Normal Happy Day Scenario
	*/
	//Check Trx has no errors
	self.assertNoTrxErrorsOrWarnings();
	
	foreach auditObj in realCargoForecast.allAuditObjectsForClass do
		if auditObj.type = AuditCreated then
			createAuditExists := true;
			break;
		endif;
	endforeach;
	
	//Check the new reference are not null
	self.assertTrueMsg(createAuditExists, "Cargo Forecast: Could not find an audit of type Created");
	
	/*
	**	Setup Test Update - Normal Happy Day Scenario
	*/
	delete pxyCargoForecast;
	
	create pxyCargoForecast transient;
	pxyCargoForecast.setProxyForCreate(cargoType, commodity, mode, operator, TOTALQUANTITY, TOTALWEIGHT, TOTALVOLUME, train);
	app.myTrxCA.trxCreateCargoForecast(pxyCargoForecast, realCargoForecast, app.myPassport);
	
	/*
	**	Run Test Update - Normal Happy Day Scenario
	*/
	delete pxyCargoForecast;
	
	pxyCargoForecast := app.createUpdateProxy(realCargoForecast).CM_CargoForecast;
	
	pxyCargoForecast.setProxyForUpdate(cargoType, commodity, mode, operator, UPDTOTALQUANTITY, UPDTOTALWEIGHT, UPDTOTALVOLUME, train);
	
	app.myTrxUA.trxUpdateCargoForecast(pxyCargoForecast, app.myPassport);
	
	/*
	**	Assert Test Update - Normal Happy Day Scenario
	*/
	//Check Trx has no errors
	self.assertNoTrxErrorsOrWarnings();
	
	foreach auditObj in realCargoForecast.allAuditObjectsForClass do
		if auditObj.type = AuditUpdated then
			updateAuditExists := true;
			break;
		endif;
	endforeach;
	
	//Check the new reference are not null
	self.assertTrueMsg(updateAuditExists, "Cargo Forecast: Could not find an audit of type Updated");
	
epilog
	delete pxyCargoForecast;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tCargoForecastCreate" id="3c319c93-a085-4076-bd59-924898c11322">
        <source>tCargoForecastCreate();
/*

Purpose:			Tests that a Cargo Forecast can be created

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
08 April 2022	navpw1	Initial creation TFS: 53132

*/

constants
	Ref						: String		= UT_DSL.TFS53132;
	TrainCode 				: String 		= "UT-T" &amp; Ref;
	WagonCode1 				: String 		= "JX" &amp; Ref;
	WagonClassCode 			: String 		= "JX";
	RailAreaId 				: String		= "UT" &amp; Ref;
	TOTALQUANTITY 			: Integer 		= 12;
	TOTALWEIGHT				: Decimal[23,6] = 23.345;
	TOTALVOLUME				: Decimal[23,6] = 24.345;
	
vars
	train					: CM_Train;
	railArea 				: CM_Rail;
	wagon 					: CM_Wagon;
	wagonClass 				: CM_WagonClass;
	errorMess 				: String;
	railLine 				: CM_RailLine;
	
	pxyCargoForecast,
	realCargoForecast		: CM_CargoForecast;
	cargoType				: CM_CargoType;
	commodity				: CM_Commodity;
	operator				: CM_Operator;
	
	error					: CM_Error;
	cargoTypeCommodityError, 
	imexStatusError,
	totalWeightError		: Boolean;
	mode					: String;
	terminal				: CM_Terminal;
	requiredFields			: String;
	
begin
	terminal := self.getMyTerminal();
	requiredFields := self.setTerminalConfig(CargoForecastReqdFields, ETRow_Quantity &amp; "," &amp; ETRow_Volume &amp; "," &amp; ETRow_Weight).String;
	
	// ****** DELETE EVERYTHING FROM LAST TEST
	self.deleteRailArea(RailAreaId);
	
	wagonClass := app.myRoot.allWagonClasses[WagonClassCode];
	if wagonClass &lt;&gt; null then
		self.deleteWagonClassAndWagons(wagonClass);
	endif;

	self.deleteTrain(TrainCode, null);
	
	// ****** ADD NEW TRAIN
	train := self.addTrain(TrainCode, null);
	self.assertNotNull(train);
	
	// ****** ADD NEW WAGON CLASS AND WAGON
	self.opts.purge();
	self.opts.addAssoc("MaxPosiWeight", "4500".Decimal);
	self.opts.addAssoc("MaxPosiHeight", "100".Decimal);
	wagonClass := self.addWagonClass(WagonClassCode);
	
	// ****** ADD NEW RAIL AREA
	railArea := self.addRailArea(RailAreaId, 4, 5);
	self.assertNotNull(railArea);
	railLine:=railArea.allRailLines.first;
	
	//ATTACH WAGON TO TRAIN
	wagon := train.createOrUpdateWagon(WagonCode1, 3, railLine, errorMess);
	self.assertNull(errorMess);
	self.assertNotNull(wagon);
	self.assertEqual(railLine.allWagons[3], wagon);

	/*
	**	Setup Test Create - Normal Happy Day Scenario
	*/
	operator 	:= app.myRoot.allOperators["****"];
	self.assertNotNullMsg(operator, "Operator is null");
	
	cargoType 	:= app.myRoot.allCargoTypesById.getCargoTypeByAbbreviation("CONT");
	self.assertNotNullMsg(cargoType, "Cargo type is null");
	
	commodity 	:= app.myRoot.allCommodities["GENL"];
	self.assertNotNullMsg(commodity, "Commodity is null");
	
	mode 		:= CM_CargoForecast.Mode_Discharge;
	
	/*
	**	Run Test Create - Normal Happy Day Scenario
	*/
	create pxyCargoForecast transient;
	pxyCargoForecast.setProxyForCreate(cargoType, commodity, mode, operator, TOTALQUANTITY, TOTALWEIGHT, TOTALVOLUME, train);
	app.myTrxCA.trxCreateCargoForecast(pxyCargoForecast, realCargoForecast, app.myPassport);
	
	/*
	**	Assert Test Create - Normal Happy Day Scenario
	*/
	//Check Trx has no errors
	self.assertNoTrxErrorsOrWarnings();
	
	//Check that new fields match their expected value/are set
	self.assertTrueMsg(realCargoForecast.myParent &lt;&gt; null, "Cargo Forecast: Parent Object is null");
	self.assertTrueMsg(realCargoForecast.myCargoType &lt;&gt; null, "Cargo Forecast: Cargo Type Object is null");
	self.assertTrueMsg(realCargoForecast.myCommodity &lt;&gt; null, "Cargo Forecast: Commodity Object is null");
	self.assertTrueMsg(realCargoForecast.mode &lt;&gt; null, "Cargo Forecast: Mode is null");
	self.assertTrueMsg(realCargoForecast.myOperator &lt;&gt; null, "Cargo Forecast: Operator Object is null");
	
	self.assertTrueMsg(realCargoForecast.myParent = train, "Cargo Forecast: Parent Object does not match expected parent object");
	self.assertTrueMsg(realCargoForecast.myCargoType = cargoType, "Cargo Forecast: Cargo Type Object does not match expected cargo type");
	self.assertTrueMsg(realCargoForecast.myCommodity = commodity, "Cargo Forecast: Commodity Object does not match expected commodity");
	self.assertTrueMsg(realCargoForecast.mode = mode, "Cargo Forecast: Mode does not match expected mode");
	self.assertTrueMsg(realCargoForecast.myOperator = operator, "Cargo Forecast: Operator Object does not match expected operator");
	
	self.assertTrueMsg(realCargoForecast.totalQuantity = TOTALQUANTITY, "The total quantity on the Cargo Forecast does not match expected value: " &amp; TOTALQUANTITY.asStringJMT());
	self.assertTrueMsg(realCargoForecast.totalWeight = TOTALWEIGHT, "The total weight on the Cargo Forecast does not match expected value: " &amp; TOTALWEIGHT.asStringJMT());
	self.assertTrueMsg(realCargoForecast.totalVolume = TOTALVOLUME, "The total volume on the Cargo Forecast does not match expected value: " &amp; TOTALVOLUME.asStringJMT());
	
	/*
	**	Setup Test Create - Test Mandatory fields not specified gives errors
	*/
	delete pxyCargoForecast;
	
	/*
	**	Run Test Create - Test Mandatory fields not specified gives errors
	*/
	create pxyCargoForecast transient;
	pxyCargoForecast.setProxyForCreate(null, null, null, null, null, null, null, null);
	app.myTrxCA.trxCreateCargoForecast(pxyCargoForecast, realCargoForecast, app.myPassport);
	
	/*
	**	Assert Test Create - Test Mandatory fields not specified gives errors
	*/
	if app.myPassport.allErrors.size &lt; 1 then
		self.assertTrueMsg(false, "Expected: This trx should result in an error | Actual: No error exists");
	endif;
	
	foreach error in app.myPassport.allErrors do
		if error.text.cnContains("Cargo Type or Commodity") then
			self.assertTrueMsg(error.errorCode = Input_req_cargo_type_commodity, "Expected Error Code:" &amp; Input_req_cargo_type_commodity.String &amp; " | Actual: " &amp; error.errorCode.String); 					//Check Error Code Matches Expected
			self.assertTrueMsg(error.text.cnContains("Cargo Type or Commodity"), "Expected: error message to contain 'Cargo Type or Commodity' | Actual: " &amp; error.text);	//Check Error Message Contains cargo-type or commodity
			cargoTypeCommodityError := true;
			
		elseif error.text.cnContains("mode") then
			self.assertTrueMsg(error.errorCode = REQUIRED_FIELD, "Expected Error Code:" &amp; REQUIRED_FIELD.String &amp; " | Actual: " &amp; error.errorCode.String); 					//Check Error Code Matches Expected
			self.assertTrueMsg(error.text.cnContains("mode"), "Expected: error message to contain 'mode' | Actual: " &amp; error.text);											//Check Error Message Contains mode
			imexStatusError := true;
		endif;
	endforeach;
	
	if not cargoTypeCommodityError then
		self.assertTrueMsg(cargoTypeCommodityError, "Expected: error to be raised for required field (cargo-type or commodity) | Actual: No Error Raised"); 				//Check Error Code Matches Expected
		
	elseif not imexStatusError then
		self.assertTrueMsg(imexStatusError, "Expected: error to be raised for required field (imex-status) | Actual: No Error Raised"); 									//Check Error Code Matches Expected
		
	endif;
	
	//Check no new object has been set
	self.assertTrueMsg(realCargoForecast = null, "Cargo Forecast: Object should be null");
	
	/*
	**	Setup Test Create - Test Mandatory fields only specified
	*/
	delete pxyCargoForecast;
	
	/*
	**	Run Test Create - Test Mandatory fields only specified
	*/
	self.setTerminalConfig(CargoForecastReqdFields, ETRow_Volume &amp; "," &amp; ETRow_Weight);
	create pxyCargoForecast transient;
	pxyCargoForecast.setProxyForCreate(cargoType, null, mode, null, null, TOTALWEIGHT, TOTALVOLUME, train);
	app.myTrxCA.trxCreateCargoForecast(pxyCargoForecast, realCargoForecast, app.myPassport);
	
	/*
	**	Assert Test Create - Test Mandatory fields only specified
	*/
	//Check Trx has no errors
	self.assertNoTrxErrorsOrWarnings();
	
	//Check that new fields match their expected value/are set
	self.assertTrueMsg(realCargoForecast.myParent &lt;&gt; null, "Cargo Forecast: Parent Object is null");
	self.assertTrueMsg(realCargoForecast.myCargoType &lt;&gt; null, "Cargo Forecast: Cargo Type Object is null");
	self.assertTrueMsg(realCargoForecast.mode &lt;&gt; null, "Cargo Forecast: Mode is null");
	
	self.assertTrueMsg(realCargoForecast.myParent = train, "Cargo Forecast: Parent Object does not match expected parent object");
	self.assertTrueMsg(realCargoForecast.myCargoType = cargoType, "Cargo Forecast: Cargo Type Object does not match expected cargo type");
	self.assertTrueMsg(realCargoForecast.mode = mode, "Cargo Forecast: Mode does not match expected mode");
	
	self.assertTrueMsg(realCargoForecast.totalWeight = TOTALWEIGHT, "The total weight on the Cargo Forecast does not match expected value: " &amp; TOTALWEIGHT.asStringJMT());
	self.assertTrueMsg(realCargoForecast.totalVolume = TOTALVOLUME, "The total volume on the Cargo Forecast does not match expected value: " &amp; TOTALVOLUME.asStringJMT());
	
	/*
	**	Setup Test Create - Test Mandatory fields only specified 2
	*/
	delete pxyCargoForecast;
	
	/*
	**	Run Test Create - Test Mandatory fields only specified 2
	*/
	create pxyCargoForecast transient;
	pxyCargoForecast.setProxyForCreate(null, commodity, mode, null, null, TOTALWEIGHT, TOTALVOLUME, train);
	app.myTrxCA.trxCreateCargoForecast(pxyCargoForecast, realCargoForecast, app.myPassport);
	
	/*
	**	Assert Test Create - Test Mandatory fields only specified 2
	*/
	//Check Trx has no errors
	self.assertNoTrxErrorsOrWarnings();
	
	//Check that new fields match their expected value/are set
	self.assertTrueMsg(realCargoForecast.myParent &lt;&gt; null, "Cargo Forecast: Parent Object is null");
	self.assertTrueMsg(realCargoForecast.myCommodity &lt;&gt; null, "Cargo Forecast: Commodity Object is null");
	self.assertTrueMsg(realCargoForecast.mode &lt;&gt; null, "Cargo Forecast: Mode is null");
	
	self.assertTrueMsg(realCargoForecast.myParent = train, "Cargo Forecast: Parent Object does not match expected parent object");
	self.assertTrueMsg(realCargoForecast.myCommodity = commodity, "Cargo Forecast: Commodity Object does not match expected commodity");
	self.assertTrueMsg(realCargoForecast.mode = mode, "Cargo Forecast: Mode does not match expected mode");
	
	self.assertTrueMsg(realCargoForecast.totalWeight = TOTALWEIGHT, "The total weight on the Cargo Forecast does not match expected value: " &amp; TOTALWEIGHT.asStringJMT());
	self.assertTrueMsg(realCargoForecast.totalVolume = TOTALVOLUME, "The total volume on the Cargo Forecast does not match expected value: " &amp; TOTALVOLUME.asStringJMT());
	
	//finished clean up
	self.deleteRailArea(RailAreaId);	
	wagonClass := app.myRoot.allWagonClasses[WagonClassCode];
	if wagonClass &lt;&gt; null then
		self.deleteWagonClassAndWagons(wagonClass);
	endif;	
	self.deleteTrain(TrainCode,null);
	
epilog
	delete pxyCargoForecast;
	self.setTerminalConfig(CargoForecastReqdFields, requiredFields);
end;</source>
    </JadeMethod>
    <JadeMethod name="tCargoForecastDelete" id="8c2c695b-0e10-45ae-a7c7-0ab1fa0aab43">
        <source>tCargoForecastDelete();
/*

Purpose:			Tests that a Cargo Forecast can be deleted

