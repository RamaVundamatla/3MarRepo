    <JadeMethod name="setCargoTypeCommodityRequired" id="8d1868ad-69e7-4b42-a468-d4f8d0ba458c">
        <source>setCargoTypeCommodityRequired(_cargoType: CM_CargoType io; _isCommodityRequired: Boolean);
/*

Purpose:			Set Commodity required for cargo type

Date			Who		Reason
31 Jan 2025 	navec1	Unit test UT_WebMasterTerminalAPI::tPostSendEDIManifestRailCreat needs to be fixed - MTN-33864

*/

vars

begin
	if _cargoType &lt;&gt; null and _cargoType.isCommodityRequired &lt;&gt; _isCommodityRequired then
		if not process.isInTransactionState then
			beginTransaction;
		endif;
		_cargoType.setIsCommodityRequired(_isCommodityRequired);
		commitTransaction;
	endif;

epilog

end;</source>
