    <JadeMethod name="getFirstPickup" id="4a113e40-5d2c-42da-83ac-7f73d787d794">
        <updating/>
        <source>getFirstPickup() : CM_MachineMoveHistory updating;
/*
Purpose: Find and return the first Pickup

Parameters:			

Return Value:		

Date		Who		Reason
30 April 2012	cnwdw1	Initial creation
*/
vars
	first: CM_MachineMoveHistory;
begin
	first := self;
	while first &lt;&gt; null do
		if first.myPriorLiftHistory = null or first.myPriorLiftHistory.tiId &lt;&gt; self.tiId then
			break;
		endif;
		first := first.myPriorLiftHistory;
	endwhile;
	
	while first &lt;&gt; null and first.type &lt;&gt; Type_PickUp and 
		  (first.myNextLiftHistory &lt;&gt; null and first.myNextLiftHistory.tiId = self.tiId) do
		first := first.myNextLiftHistory;
	endwhile;
	
	return first;
epilog
end;</source>
        <ReturnType type="CM_MachineMoveHistory"/>
    </JadeMethod>
    <JadeMethod name="getGrossMoveDuration" id="0ac11349-4811-400b-8bfe-27dab3c63f4a">
        <source>getGrossMoveDuration():Integer;
// ---------------------------------------------------------------------------
// Created:     02 November 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     gross move duration in seconds
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	startTS, endTS	:TimeStamp;
	result			:Integer;
begin
	// gross move duration is time between accept and setdown
	startTS := self.getAcceptMoveTS;
	endTS	:= self.getEndOfMoveTS;
	
	if startTS &lt;&gt; null and endTS &lt;&gt; null then
		result := startTS.getDifferenceInSeconds (endTS).rounded;
	endif;
	
	return result;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getIMEXStatus" id="b256798e-b43e-47bc-8e7a-971eefa2cd14">
        <source>getIMEXStatus():Integer;
// ---------------------------------------------------------------------------
// Created:     08 November 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	trx	:CM_TITransaction;
begin
		trx 	:= self.myMoveTransaction;
	
	if trx = null then
		// machine must be a crane
		trx := self.myShipReceiveReleaseTrx;
	endif;
	
	if trx &lt;&gt; null then
		return trx.imExStatus;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
