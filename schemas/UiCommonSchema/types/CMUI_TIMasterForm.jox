    <JadeMethod name="tblDataSysNotifyCreate" id="ffbfb95d-a7f9-4367-8ea9-ab8e738039de">
        <updating/>
        <source>tblDataSysNotifyCreate(_eventType: Integer; _theObject: Object; _eventTag: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 December 2008	cnwrd1	Initial creation

*/

vars
	tiMaster : CM_TIMaster;
	wagonMaster : CM_WagonMaster;
begin

	if self.isWagonMaster then	// 03 Jul 2009	NDL	CCMS 1067
		wagonMaster := _theObject.CM_WagonMaster;
		self.tblDataDisplayRow(wagonMaster);
		self.myCurrentWagonMaster := wagonMaster;
		self.tblData.clearAllSelected();
		self.tblData.selectObject (  self.myCurrentWagonMaster , true) ;
	else
		tiMaster := _theObject.CM_TIMaster;
		self.tblDataDisplayRow(tiMaster);
		self.myCurrentTiMaster := tiMaster;
		self.tblData.clearAllSelected();
		self.tblData.selectObject (  self.myCurrentTiMaster , true) ;
	endif;
epilog

end;</source>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_theObject" type="Object"/>
        <Parameter name="_eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblDataSysNotifyDelete" id="ffd5c21c-9167-4bb7-85ef-c1edc70e7c33">
        <updating/>
        <source>tblDataSysNotifyDelete(_eventType: Integer; _theObject: Object; _eventTag: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 December 2008	cnwrd1	Initial creation

*/

// ---------------------------------------------------------------------------
vars
	
	theRow	: Integer;

begin

	self.tblData.findObjectInRow(_theObject, theRow);

	//theRow := self.zTblDataFindObject(theObject);

	if theRow &gt; 0 then

		self.tblData.removeDeletedObject(_theObject);

/*
		elseif self.mode = Mode_View then
			self.zTblDataRemoveItem(theRow);
		endif;
		*/
	endif;
	
end;</source>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_theObject" type="Object"/>
        <Parameter name="_eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblDataSysNotifyUpdate" id="66a8ca7a-256b-45f1-9676-6a469a8cf749">
        <updating/>
        <source>tblDataSysNotifyUpdate(_eventType: Integer; _theObject: Object; _eventTag: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 December 2008	cnwrd1	Initial creation

*/

vars
	theRow	: Integer;
begin
	self.tblData.findObjectInRow(_theObject, theRow);

	if theRow &gt; 0 then
		if self.isWagonMaster then	//06 Jul 2009	NDL	CCMS 1067
			self.tblData.accessCell(theRow, 1).text := _theObject.CM_WagonMaster.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
		else
			self.tblData.accessCell(theRow, 1).text := _theObject.CM_TIMaster.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_theObject" type="Object"/>
        <Parameter name="_eventTag" type="Integer"/>
    </JadeMethod>
