    <JadeMethod name="processEvent" id="e465c365-6eb7-46eb-ac74-17660110ce60">
        <updating/>
        <source>processEvent(_transaction: CM_EventTransaction; _camProtocol: CM_CamProtocol; _camAgent: CM_CamControllerAgent input; _camFile: CM_CamFile input) updating;
/*

Purpose:			Event Based Message (eg, Voyage Departed)
					Rule: (TFS 57902) Single Transaction per File is respected.
					If STPF is enabled, then we do the same as the processTransaction. That is, 1 message per transaction.
					If STPF is disabled, then we combine everything into one message per cargo operator.
	

	This method processes events for EUP Damage and Repair
	Accoring to TFS 54536 the format should end up looking like this:
		Multiple messages depending on how many cargo operators there were
		Header Operator CID1 (Cargo Operator)
		Good - CID1 - Operator COP1
		Good - CID2 - Operator COP1
		Header Operator CID2
		Good - CID3 - Operator COP2
		Good - CID4 - Operator COP2
		Header Operator VOP (Voyage Operator)
		Good - CID5 - Operator VOP
Parameters:			

Return Value:		

Date				Who		Reason
12 January 2023		navra1	Initial creation for TFS - 55859
17 March 2023		navmd1	TFS 57092 Refactor + Move allEventItemsProcessed to the transient CM_CamControllerAgent
11 May 2023			navmd1	TFS 57902 Change processEvent to respect Single File Per Transaction
19 May 2023			navra1	TFS 58118 EUP - FR 54536 | EDI for Damage and Repair
15 Sep 2023			navra1	TFS 60208 - EUP | FR 54536 - D&amp;R - File Generation.
*/

vars

	voyage 						: CM_Voyage;
	camMessage 					: CM_CamMessage;
	ti 							: CM_TrackedItem;
	damagedTrackedItem 			: CM_TrackedItem;
	iter						: Iterator;
	damageAndRepairObject 		: CMIF_JsonDamageRepairDescEUP;
	tiDict 						: CM_TIByCargoOperatorIdDict;	
	currentOperator				: CM_Operator;
	singleTransPerFile			: Boolean;
	seqNo,
	unhSeqNo					: Integer;
	damageInstance				: CM_DamageInstance;	//navra1 - TFS 57901 - 19th May 2023
	completedOpCodes			: StringArray;
	
begin	

	if not _transaction.isVoyageEvent() then
		if _camAgent.logExcludedTransactions then
			_camAgent.logReasonForExclusion(_transaction, 'Transaction not processed since its not a CMEVT_VoyageEvent');
		endif;
		
		return;
	endif;
	
	voyage := _transaction.CMEVT_VoyageEvent.getMyVoyage;
	camMessage := self.getCamMessage(_camFile, voyage.code, voyage.vesselName, self.DamageAndRepair, _camProtocol.singleContainerPerBGM);
	
	create tiDict transient;
	foreach ti in voyage.allOffsiteTIsByIdCargoType discreteLock do
		if ti.allDamageInstances.size &gt; 0 then			
			tiDict.add(ti);		
		endif;
	endforeach;
	
	foreach ti in voyage.allOnshipTIsByIdCargoType discreteLock do 
		if ti.allDamageInstances.size &gt; 0 then			
			tiDict.add(ti);		
		endif;
	endforeach;
	
	foreach ti in voyage.allOnsiteTIsByIdCargoType discreteLock do
		if ti.allDamageInstances.size &gt; 0 then			
			tiDict.add(ti);
		endif;
	endforeach;
	
	if tiDict.isEmpty then
		if _camAgent.logExcludedTransactions then
			_camAgent.logReasonForExclusion(_transaction, 'No cargo with damage instances found in transaction this one');
		endif;
		
		return;
	endif;
	
	singleTransPerFile := _camProtocol.isSingleTransPerFile;
	seqNo := _camAgent.processSeqNumber;
	unhSeqNo := _camAgent.unhSeqNumber;
	
	//navra1 - TFS 60208 - 15th Sep 2023 - start
	create completedOpCodes transient;
	if not singleTransPerFile then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "STPF not enabled" , LogDEBUG);
		iter := tiDict.createIterator;	
		while iter.next( damagedTrackedItem ) do
			if not completedOpCodes.includes(damagedTrackedItem.operatorCode) then				
				completedOpCodes.add(damagedTrackedItem.operatorCode);				
				
				create damageAndRepairObject transient;
				//new operator - new message - new header				
				damageAndRepairObject.buildHeader(damagedTrackedItem.allDamageInstances.first, _camProtocol);				
				
				//new operator - new message - new goods/items
				write ("working on operator : " &amp; damagedTrackedItem.operatorCode);
				damageAndRepairObject.addDamOfManyGoodManyItemOfOp(damagedTrackedItem.operatorCode, tiDict, true);		//this is always a damage, so the last params is true				
				
				foreach ti in tiDict where ti.operatorCode = damagedTrackedItem.operatorCode do
					foreach damageInstance in ti.allDamageInstances do
						if not _camAgent.allEventItemsProcessed.includes(damageInstance) then
							_camAgent.allEventItemsProcessed.add(damageInstance);
						endif;
					endforeach;	
				endforeach;			
				
				//add message for this operator
				self.addMessage(camMessage.group3, damageAndRepairObject.getJsonOfDamageAndRepairObj(), _camAgent);		
				
				delete damageAndRepairObject;
			endif;
		endwhile;
	else	//if it is single transaction per file
		foreach ti in tiDict do
			foreach damageInstance in ti.allDamageInstances do				
				create damageAndRepairObject transient;
				app.writeLog(method.qualifiedName &amp; Tab &amp; "MESSAGE BEING CREATED1: " &amp; damageAndRepairObject.getJsonOfDamageAndRepairObj()&amp; " with TIs "&amp; tiDict.size().String, LogDEBUG);
				
				damageAndRepairObject.buildHeader(damageInstance, _camProtocol);
				app.writeLog(method.qualifiedName &amp; Tab &amp; "MESSAGE BEING CREATED2: " &amp; damageAndRepairObject.getJsonOfDamageAndRepairObj()&amp; " with TIs "&amp; tiDict.size().String, LogDEBUG);
				
				damageAndRepairObject.addOneDamOfOneItem(ti, damageInstance, true);
				app.writeLog(method.qualifiedName &amp; Tab &amp; "MESSAGE BEING CREATED3: " &amp; damageAndRepairObject.getJsonOfDamageAndRepairObj()&amp; " with TIs "&amp; tiDict.size().String, LogDEBUG);
				
				_camAgent.allEventItemsProcessed.add(damageInstance);
				//add message for this damage transaction
				self.addMessage(camMessage.group3, damageAndRepairObject.getJsonOfDamageAndRepairObj(), _camAgent);
				delete damageAndRepairObject;
			endforeach;
		endforeach;
	endif;
	//navra1 - TFS 60208 - 15th Sep 2023 - end
	
epilog
	delete completedOpCodes;
	delete iter;
	delete tiDict;
	
	delete damageAndRepairObject;
end;</source>
        <Parameter name="_transaction" type="CM_EventTransaction"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent" usage="input"/>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
    </JadeMethod>
    <JadeMethod name="processTransaction" id="a27d4999-49f5-4574-8204-c8d70ac8381d">
        <updating/>
        <source>processTransaction(_transaction: CM_TITransaction; _camProtocol: CM_CamProtocol; _camAgent: CM_CamControllerAgent input; _camFile: CM_CamFile input) updating;
/*

Purpose:			Transaction Based Message (eg, Damage Transaction or Repair Transaction)
					Rule: (TFS 57902) Single Transaction per File is assumed to be always true.
					That is - we always sent one message per transaction.

Parameters:
	This method processes transactions for EUP Damage and Repair
Return Value:

Date				Who		Reason
12 January 2023		navra1	Initial creation for TFS - 55859
17 March 2023		navmd1	TFS 57092 Refactor + Move allEventItemsProcessed to the transient CM_CamControllerAgent
11 May 2023			navmd1	TFS 57902 Added additional comments and improved duplicate transaction check
29/09/2023			navcs2	ChangeRequest 60697: EUP | FR 54536 - Damage and Repair CAMS protocol transaction inclusion
*/

vars
	camMessage 					: CM_CamMessage;
	damageInstance 				: CM_DamageInstance;
	includedDamages				: CM_DamageInstanceSet;
	damageInstanceDict			: CM_DamageInstanceByLocDict;
	dI 							: CM_DamageInstance;
	damageAndRepairObject 		: CMIF_JsonDamageRepairDescEUP;
	theTI 						: CM_TrackedItem;
	code 						: String;
	vesselName 					: String;
	invalid						: Boolean;
	voyage						: CM_Voyage;
	isForRepair					: Boolean;
begin
	on Exception do app.handleDeletedObject(exception, theTI, invalid);	
	
	theTI := _transaction.myTrackedItem;
	
	theTI.edition;
	if invalid then				
		_camAgent.logReasonForExclusion(_transaction, 'TI no longer valid, skipping this transaction');
		return;
	endif;
	
	//get the voyage code
	voyage := theTI.myVoyage;
	if theTI.isExport or theTI.isTranshipOutbound then
		code := voyage.code;
	elseif theTI.isImport or theTI.isTranshipInbound then
		code := voyage.inwardCode;
	elseif theTI.isStorage then
		code := voyage.inwardCode;
	else
		code := voyage.code;
	endif;
	
	if code = null then	//inward may be blank - in which case...
		code := voyage.code;
	endif;
	
	vesselName := voyage.vesselName;
	camMessage := self.getCamMessage(_camFile, code, vesselName, self.DamageAndRepair, _camProtocol.singleContainerPerBGM);
		
	// If we are a Repair transaction, then get its associated Damage one
	if _transaction.isRepairDetail() then
		damageInstance := _transaction.CM_RepairDetail.myDamagesInstance;
		isForRepair := true;																						// 29/03/2023 navcs2 60697
	elseif _transaction.isDamageLocation() then
		foreach dI in theTI.allDamageInstances do
			if invalid then
				break;
			endif;
			
			if dI.myDamagePosition &lt;&gt; null and dI.myDamageDefinition &lt;&gt; null then 									//navra1 - 1st Mar 2023 - TFS56862	// 29/09/2023 navcs2 ChangeRequest 60697
				// Find the matching Damage Instance to this transaction
				// NB. Updates to the DI will mean this no longer matches, but a new transaction should be created which will match
				if _transaction.CM_DamageLocation = dI.myDamageLocationTrx then										// 29/03/2023 navcs2 60697
					damageInstance := dI;
				endif;
			endif;																									//navra1 - 1st Mar 2023 - TFS56862
		endforeach;
	endif;
	
	if damageInstance = null then		//should not happen, but being safe		
		_camAgent.logReasonForExclusion(_transaction, 'Advanced Damage / Damage Instance not found, skipping this transaction');
		return;
	endif;	
	
	// Skip this Transaction if we're doing both Events and Transactions and we've already processed this one in the Event run
	if _camAgent.allEventItemsProcessed.includes(damageInstance) then		
		_camAgent.logReasonForExclusion(_transaction, 'Transaction already processed, so ignoring repetition');
		return;
	endif;
	
	create damageAndRepairObject transient;
	damageAndRepairObject.buildHeader(damageInstance, _camProtocol);
	
	create damageInstanceDict transient;
	damageInstanceDict.add(damageInstance);
	
	//this could be a damage or repair transaction
	damageAndRepairObject.addDamagesOfOneGoodDetails(damageInstanceDict, _transaction.type = TRANS_TYPE_DAMAGED, isForRepair);		// 29/03/2023 navcs2 60697
	
	// Dont want to include the same damage instance twice if using damage location and repair details transactions
	_camAgent.allEventItemsProcessed.add(damageInstance);																			// 29/03/2023 navcs2 60697
	
	self.addMessage(camMessage.group3, damageAndRepairObject.getJsonOfDamageAndRepairObj(), _camAgent);
	
epilog
	delete damageAndRepairObject;
	delete damageInstanceDict;
end;</source>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent" usage="input"/>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
    </JadeMethod>
</Class>
