    <JadeMethod name="setProxyForToDoRequest" id="0eb34bcc-b49d-4f62-8482-b521e6ca91e7">
        <updating/>
        <source>setProxyForToDoRequest(_requestType : CM_ToDoRequestType; _userCode : String; _job : CM_Job) updating, protected;
// ---------------------------------------------------------------------------
// Created:     08 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin

	self.setProxyForRequest(null, null, _job, _userCode);
	self.myToDoRequestType	:= _requestType;

end;</source>
        <access>protected</access>
        <Parameter name="_requestType" type="CM_ToDoRequestType"/>
        <Parameter name="_userCode" type="String"/>
        <Parameter name="_job" type="CM_Job"/>
    </JadeMethod>
    <JadeMethod name="typeString" id="8af8ba10-007e-4ad1-945f-8c2f8a8afd71">
        <source>typeString(): String;
// ---------------------------------------------------------------------------
// Created:     08 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.myToDoRequestType &lt;&gt; null then
		return self.myToDoRequestType.description;
	endif;
	
	return inheritMethod();

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="validate" id="ef4f9066-e485-46ad-9566-f0320e0309fa">
        <source>validate(pUserObject: Object);
// ---------------------------------------------------------------------------
// Created:     08 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(pUserObject);

	if self.myToDoRequestType = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'ToDo Request Type', 'toDoRequestType', null);
		app.raiseCMException(Input_required_field_toDoReqst, 'toDoRequestType', null); // cnwdb2	PAR 35364
	endif;

end;</source>
        <Parameter name="pUserObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="validateToDoTaskStatus" id="8932a60c-c64c-4f25-985a-81423ffd3c01">
        <source>validateToDoTaskStatus(_newStatus : Integer);
//--------------------------------------------------------------
//Created: 10 April 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if self.isComplete and not _newStatus = STATUS_COMPLETE then
		app.raiseCMException1(Err_InvalidType, _newStatus.String, null, null);
	endif;
end;</source>
        <Parameter name="_newStatus" type="Integer"/>
    </JadeMethod>
