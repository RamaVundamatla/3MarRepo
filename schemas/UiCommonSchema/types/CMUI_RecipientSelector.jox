    <JadeMethod name="setupButtonAccess" id="f61f47c2-f5e0-4ad6-8c70-f7a7866029ec">
        <source>setupButtonAccess();
/*

Purpose:			


Return Value:		


Date		Who		Reason
06 March 2008	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	self.btnBcc.enabled			:= not self.canOnlyAccessMode or self.mode =CMUI_RecipientSelector.Mode_BCC;
	self.btnCc.enabled			:= not self.canOnlyAccessMode or self.mode =CMUI_RecipientSelector.Mode_CC;
	self.btnTo.enabled			:= not self.canOnlyAccessMode or self.mode =CMUI_RecipientSelector.Mode_To;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="be70c723-4fa8-4f63-8276-1b597861e267">
        <updating/>
        <source>setupForm() updating;
//--------------------------------------------------
// Created:	24 May 2005 By: cnwgd1
//19 May 2022 navmv20 ChangeRequest 53472: MTN - Add Filter to the select Recipients Emails
//--------------------------------------------------
vars

begin
	self.createMyAssistant(CMUI_Assistant);
	self.initTblAddAddress();
	inheritMethod();
	self.myAssistant.comboBoxAutoReply(self.cmbAutoReply);
	self.refreshToolbar();
	self.btnOk.default := false;
	self.initTblContacts();
	self.setupButtonAccess();
	//25/06/2024	navkc1 CR 64823 Task 64824
	//self.btnClearFilter.enabled:= false; //19 May 2022 navmv20 TFS 53472
	
	if self.disableBCC then
		self.lstBoxBcc.enabled := false;
		self.btnBcc.enabled := false;
	else
		self.lstBoxBcc.enabled := true;
	endif;
	if self.disableCC then
		self.btnCc.enabled := false;
		self.lstBoxCc.enabled := false;
	else
		self.lstBoxCc.enabled := true;
	endif;
	
	//22 May 2018	NDL	TFS 38767
	if self.disableTo then
		self.btnTo.enabled := false;
		self.lstBoxTo.enabled := false;
	else
		self.lstBoxTo.enabled := true;
	endif;
	
	self.frmTableFilter.setupControl(self.tblContacts, null); //05/06/2024	navkc1 CR 63736 Task 63770
end;</source>
    </JadeMethod>
    <JadeMethod name="showAddressesSelected" id="964053c8-9661-430e-aac5-a4ccdd61c23b">
        <updating/>
        <source>showAddressesSelected() updating;
//--------------------------------------------------
// Created:	24 May 2005 By: cnwgd1
//--------------------------------------------------
vars
	str : String;
	lstBox : CMUI_ListBox;
	emailEntity : CM_EmailEntity;
	tmpDict : CM_EmailEntityByTypeNameDict;
begin

	if self.myEmailController = null then
		return;		
	endif;
	
	//Show Bcc Addresses
	tmpDict := self.myEmailController.allBccAddresses;
	lstBox := self.lstBoxBcc;
	foreach emailEntity in tmpDict do
		str := emailEntity.getDisplayStringForAttribute(ETRow_Title, false);
		lstBox.addTreeObjectIfNotPresent(str, emailEntity, 1, false);
	endforeach;

	//Show Cc Addresses
	tmpDict := self.myEmailController.allCcAddresses;
	lstBox := self.lstBoxCc;
	foreach emailEntity in tmpDict do
		str := emailEntity.getDisplayStringForAttribute(ETRow_Title, false);
		lstBox.addTreeObjectIfNotPresent(str, emailEntity, 1, false);
	endforeach;

	//Show To Addresses
	tmpDict := self.myEmailController.allToAddresses;
	lstBox := self.lstBoxTo;
	foreach emailEntity in tmpDict do
		str := emailEntity.getDisplayStringForAttribute(ETRow_Title, false);
		lstBox.addTreeObjectIfNotPresent(str, emailEntity, 1, false);
	endforeach;		
		
end;</source>
    </JadeMethod>
    <JadeMethod name="tblContacts_contextMenu" id="96d8d094-bf89-4e93-86c3-be7d1b1720b7">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblContacts_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
//--------------------------------------------------
// Created:	23 November 2005 By: cnwgd1
//--------------------------------------------------
vars
	xLeft 	: Real;
	yTop	: Real;
begin

	xLeft := x;
	yTop := y;

	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);   // convert x, y relative to form

	self.popupMenu(self.mnuContext, xLeft.Integer, yTop.Integer);

	return false;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblContacts_dblClick" id="03291ce8-6a16-431f-b16b-03c6d099e2ca">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblContacts_dblClick(table: Table input) updating;
//--------------------------------------------------
// Created:	14 October 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	if table.row &gt; table.fixedRows and table.row &lt; table.rows then
		if self.mode = self.Mode_BCC then
			self.addAddressToList(self.lstBoxBcc);
		elseif self.mode = self.Mode_CC then
			self.addAddressToList(self.lstBoxCc);
		else
			self.addAddressToList(self.lstBoxTo);
		endif;
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
