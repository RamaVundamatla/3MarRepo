    <JadeMethod name="clearAll" id="d10c98fb-3457-40d4-8cd4-b3cbc8fd322c">
        <updating/>
        <source>clearAll() updating;
/*
Purpose:			Clear everything and setup defaults

Parameters:			

Return Value:		

Date				Who		Reason
02 February 2010	conkc1	Initial creation

*/
vars

begin
	self.allAvailableTerminalAreas.clear;
	self.allSelectedTerminalAreas.clear;
	self.allInterTermTargetTermInfo.clear;
	self.cmbDefaultGate.clear;
	self.cmbDefaultLane.clear;

	self.cmbConfigName.enabled       := true;
	
	self.lstDestination.clear;
	self.tbxRelNumber.readOnly       := true;
	self.tbxRelNumber.text           := '';
	self.vUpdated                    := false;
	//self.cmbConsignorVoy.listIndex   := -1;
	self.txtConsignorVoy.text			:= '';
	self.cmbConsignee.listIndex      := -1;
	self.cmbSubTerminal.listIndex    := -1;
	self.cmbDeliveryReasn.listIndex  := -1;
	self.chxAutoAssign.value         := false;
	self.chxAutoUnassign.value       := false;
	self.tbxConfigName.text          := '';

epilog

end;</source>
    </JadeMethod>
