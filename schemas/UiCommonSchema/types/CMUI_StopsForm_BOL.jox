    <JadeMethod name="getStopsString" id="c0363f9e-f007-4bdc-ada5-c3ee05879466">
        <source>getStopsString():String protected;
// ---------------------------------------------------------------------------
// Created:     01 July 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	stop 				:CM_Stops;
	strStop, strAll		:String;
begin
	foreach stop in self.myBOL.allStops do
		strStop := stop.id.String;
		strAll 	:= strAll &amp; strStop;
	endforeach;
	
	return strAll;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
