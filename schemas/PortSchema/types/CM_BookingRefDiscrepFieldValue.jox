    <JadeMethod name="isDiscrepancy" id="3903fc47-f2ee-4d86-bf1e-03d69b15b749">
        <source>isDiscrepancy():Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 September 2009	cnwndl1	Initial creation

*/

vars

begin

	return self.bookingRefFieldValue &lt;&gt; null and self.bookingRefFieldValue &lt;&gt; self.tiFieldValue;
	
epilog

end;</source>
