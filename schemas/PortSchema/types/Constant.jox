<Class name="Constant">
    <JadeMethod name="isUsed" id="11c5b786-3acf-43c8-b819-b6419188d9ed">
        <source>isUsed() : Boolean;
// ---------------------------------------------------------------------------
// Created:     17 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpMethsSet	: MethodSet;

begin

	if (not self.constantRefs.isEmpty) then
		return true;
	endif;
	if (not self.constantUsages.isEmpty) then
		return true;
	endif;
	
	create tmpMethsSet transient;
	self.getMethodRefs(tmpMethsSet);
	
	if (not tmpMethsSet.isEmpty) then
		return true;
	endif;
	
	return false;

epilog
	delete tmpMethsSet;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
