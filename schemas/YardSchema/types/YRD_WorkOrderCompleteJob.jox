    <JadeMethod name="translateForm" id="6eb8f69e-e1a0-4ec3-8a63-e7f71769db37">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 15 November 2024 19:34:48.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0026707, locale);
//	btnClear.translateCaption(Xlat_0026708, locale);
	btnCollapseAll.translateCaption(Xlat_0026945, locale);
	btnDoOperation.translateCaption(Xlat_0026709, locale);
	btnExpandAll.translateCaption(Xlat_0026946, locale);
	btnPack.translateCaption(Xlat_0026765, locale);
	btnResComplete.translateCaption(Xlat_0026766, locale);
	btnResDelete.translateCaption(Xlat_0026767, locale);
	btnResUpdate.translateCaption(Xlat_0026768, locale);
	btnStartStop.translateCaption(Xlat_0026797, locale);
	btnUnpack.translateCaption(Xlat_0026769, locale);
