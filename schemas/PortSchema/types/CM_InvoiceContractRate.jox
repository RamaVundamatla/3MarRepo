    <JadeMethod name="validateForUpdate" id="7918ba60-57dd-49ec-bd1d-067675e409a4">
        <source>validateForUpdate();
/*
Purpose:			

Date		Who		Reason
08 December 2022	navab1	TFS CR 55623 TASK 55675
*/

vars
	rate, realMe : CM_InvoiceContractRate;
	invLineType : CM_InvoiceLineDesc;
begin
	if self.myService = null then
		app.raiseCMException(Contra_rate_must_have_servic,null,null);
	endif;
	
	if self.myInvoiceContractDetail = null then
		app.raiseCMException(Contr_rate_must_have_contr_det,null,null);
	else
		realMe := self.pxyGetRealObject();
		
		invLineType := self.myInvoiceContractDetail.myInvoiceLineType;
		if invLineType &lt;&gt; null 
		and self.myService &lt;&gt; null then
			if not invLineType.services.includes(self.myService) then
				app.raiseCMException(Servi_not_confi_contr_detai_in,null,null);
			
			endif;
		
		endif;
		
		rate := self.myInvoiceContractDetail.allInvContractRatesByService[self.myService]; // ### TFS CR 55644 TASK 55684 16JAN2023 NAVAB1 - new collection for finding correct rate
		if rate &lt;&gt; null  
		and rate &lt;&gt; realMe then
			app.raiseCMException1(Rate_alrea_exist_with_servi_cu,self.myService.name,null,null);
			
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
</Class>
