    <JadeMethod name="deleteGate" id="e7737921-231a-45f4-a3a1-f7a11084d708">
        <source>deleteGate(_gate : Any);

/*

Purpose:		Delete a Commodity	

Date			Who		Reason
05/12/2011		cnwmh5	Initial creation

*/

vars

	gate			: CM_Gate;
	obj				: Object;
	obj2			: Object;
	ica				: CM_InterchangeArea;
	gau				: CM_GateAreaUsage;
	ga				: CM_GateArea;
	lc				: CM_LocationsController;
	
	gauArray		: ObjectArray;
	
begin

	if _gate.isKindOf(String) then
		gate := self.getTerminal.allGates[_gate.String];
	elseif _gate.isKindOf(CM_Gate) then
		gate := _gate.CM_Gate;
	endif;
	if gate &lt;&gt; null then
	
		create gauArray transient;
		gate.allGateAreas_IN.copy(gauArray);
		gate.allGateAreas_OUT.copy(gauArray);
		foreach obj in gauArray do
			gau := obj.CM_GateAreaUsage;
			ga := obj.CM_GateAreaUsage.myGateArea;
			
			if ga &lt;&gt; null then
				foreach lc in ga.allLocationsControllers where lc.isKindOf(CM_YardController) do
					foreach obj in lc.CM_YardController.allVehicleMachines do
						if obj.isKindOf(CM_Machine) then
							self.deleteMachine(obj.CM_Machine.id);
						elseif obj.isKindOf(CM_Vehicle) then
							self.deleteVehicle(obj.CM_Vehicle);
						endif;
					endforeach;			
				endforeach;
			endif;
			
			beginTransaction;
			delete ga;
			delete gau;
			commitTransaction;
		endforeach;
		
		beginTransaction;
		foreach obj in gate.allInterchangeAreasDefault do
			obj.CM_InterchangeArea.setPropertyValue("myDefaultOutGate", null);
		endforeach;
		
		foreach obj in gate.allVehicleVisits do
			delete obj;		
		endforeach;
		commitTransaction;
		
		app.myTrxDA.trxDeleteGate(gate, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;

	if app.myPassport.hasErrors then
		delete gate;
	endif;
	
epilog
	delete gauArray;
end;</source>
        <Parameter name="_gate" type="Any"/>
    </JadeMethod>
    <JadeMethod name="deleteGateScanRecord" id="1aba7863-d9fa-4af3-9813-3110b6e6da48">
        <source>deleteGateScanRecord(_deviceId : String; _timestamp : TimeStampOffset);
/*

Purpose:			Deletes our gate Scan Records used for testing

Parameters:			_deviceId	String			The device id the record was created for
					_timestamp	TimeStampOffset	The timestamp the record was created

Return Value:		NONE

Date		Who		Reason
16 February 2022	navpw1	Initial creation TFS: 52773

*/

vars
	gateScanRecord : CM_GenericGateScanRecord;
	
begin
	foreach gateScanRecord in CM_GenericGateScanRecord.instances do
		if gateScanRecord.deviceId = _deviceId and gateScanRecord.timestamp = _timestamp then
			beginTransaction;
				delete gateScanRecord;
			commitTransaction;
		endif;
	endforeach;
	
end;</source>
        <Parameter name="_deviceId" type="String"/>
        <Parameter name="_timestamp" type="TimeStampOffset"/>
    </JadeMethod>
