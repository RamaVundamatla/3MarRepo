    <JadeMethod name="getReferencedExportClass" id="75eb7914-0345-4071-a1ca-526103230783">
        <source>getReferencedExportClass(_exportProp: CM_ExportImportProperty): CM_ExportImportClass;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 January 2026	naviv1	Initial creation  MTN 36787 - JADE Core Framework - Export Import Class Registry Maintenance Engine

*/

vars
   
begin
	return app.myRoot.allExportImportClasses[_exportProp.referencedClassName];
end;</source>
        <Parameter name="_exportProp" type="CM_ExportImportProperty"/>
        <ReturnType type="CM_ExportImportClass"/>
    </JadeMethod>
    <JadeMethod name="maintainExportImportClasses" id="71e8572b-2be6-46f5-966a-9102306c0141">
        <updating/>
        <source>maintainExportImportClasses() updating;
/*

Purpose:			
	 * Main registry maintenance with two-phase configuration
	 * 
	 * Phase 1: Create all classes and properties
	 * Phase 2: Resolve reference key names
	 * 
	 * This solves circular dependency issue where referenced classes
	 * don't exist yet during initial configuration
Parameters:			

Return Value:		

Date		Who		Reason
06 January 2026	naviv1	Initial creation  MTN 36787 - JADE Core Framework - Export Import Class Registry Maintenance Engine

*/

 vars
    classes: ClassColl;
    cls: Class;
    exportClass: CM_ExportImportClass;
    toDeleteClasses: CM_ExportImportClassSet;
    realClass, proxyExportClass: CM_ExportImportClass;
    iter: Iterator;
    addedCount, updatedCount, deletedCount: Integer;
begin
    create classes transient;
    create toDeleteClasses transient;
    
    //self.lockMutex("Maintain export import classes");
    self.writeLog("=== Starting Export/Import Registry Maintenance ===");
    self.writeLog("System: " &amp; app.myRoot.client);
    self.writeLog("Timestamp: " &amp; app.actualTime.String);
    
    addedCount := 0;
    updatedCount := 0;
    deletedCount := 0;
    

    
    // Mark all existing classes for potential deletion
    app.myRoot.allExportImportClasses.copy(toDeleteClasses);
    
    // Get curated list from code
    self.getExportableClasses(classes);
    self.writeLog("Found " &amp; classes.size.String &amp; " exportable classes in code");
    self.writeLog("");
    
    // ========================================================================
    // PHASE 1: CREATE/UPDATE ALL CLASSES AND PROPERTIES
    // ========================================================================
    self.writeLog("=== Phase 1: Creating/Updating Classes ===");
    
    iter := classes.createIterator();
    while iter.next(cls) do
        exportClass := app.myRoot.allExportImportClasses[cls.name];
        
        if exportClass = null then
            // NEW class - create configuration
            self.writeLog("CREATING: " &amp; cls.name);
            self.createExportImportClass(cls);
            addedCount := addedCount + 1;
        else
            // EXISTING class - update configuration
            self.writeLog("UPDATING: " &amp; cls.name);
            toDeleteClasses.removeIfPresent(exportClass);
            self.syncExportImportClass(exportClass);
            updatedCount := updatedCount + 1;
        endif;
    endwhile;
    
    // ========================================================================
    // PHASE 2: RESOLVE REFERENCE KEY NAMES
    // ========================================================================
    self.writeLog("");
    self.writeLog("=== Phase 2: Resolving Reference Key Names ===");
    
    self.resolveReferenceKeyNames();
    
    // Remove obsolete classes
    foreach realClass in toDeleteClasses do
        self.writeLog("DELETING: " &amp; realClass.className &amp; " (no longer in curated list)");
        self.deleteExportImportClass(realClass);
        deletedCount := deletedCount + 1;
    endforeach;
    
    
    self.writeLog("");
    self.writeLog("=== Registry Maintenance Complete ===");
    self.writeLog("Added: " &amp; addedCount.String);
    self.writeLog("Updated: " &amp; updatedCount.String);
    self.writeLog("Deleted: " &amp; deletedCount.String);
    
epilog
   // self.unlockMutex();
    delete classes;
    delete toDeleteClasses;
	delete proxyExportClass;
end;</source>
    </JadeMethod>
    <JadeMethod name="registerClass" id="23ef45ff-884c-4e95-95fd-0bef30d079ea">
        <source>registerClass(
    _registry: CM_ExportImportClassDict io;
    _className: String;
    _category: String;
    _displayName: String;
    _keyPropertyName: String;
    _loadMethodName: String;
    _isExportable: Boolean);
/*

Purpose:			
	 * Helper method to register a single class in the metadata registry
	 * Reduces boilerplate in category methods
	 * 
	 * @param _registry Dictionary to add metadata to
	 * @param _className Full JADE class name (e.g., "CM_Commodity")
	 * @param _category Category code (e.g., "system-admin")
	 * @param _displayName User-friendly name (e.g., "Commodity")
	 * @param _keyPropertyName Business key property name (e.g., "code")
	 * @param _loadMethodName Load method on CM_DataLoadAgent (e.g., "loadCommodity")
	 * @param _isExportable True if directly exportable, false if internal
Parameters:			

Return Value:		

Date		Who		Reason
06 January 2026	naviv1	Initial creation  MTN 36787 - JADE Core Framework - Export Import Class Registry Maintenance Engine

*/

vars
    meta: CM_ExportImportClass;
begin
    create meta transient;
    meta.className := _className;
    meta.category := _category;
    meta.displayName := _displayName;
    meta.myKeyName := _keyPropertyName;
    meta.loadMethodName := _loadMethodName;
    meta.isExportable := _isExportable;
    
    _registry.add(meta);
end;</source>
        <Parameter name="_registry" type="CM_ExportImportClassDict" usage="io"/>
        <Parameter name="_className" type="String"/>
        <Parameter name="_category" type="String"/>
        <Parameter name="_displayName" type="String"/>
        <Parameter name="_keyPropertyName" type="String"/>
        <Parameter name="_loadMethodName" type="String"/>
        <Parameter name="_isExportable" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="resolveReferenceKeyNames" id="5babfbf8-51e1-405a-9ad7-09937d2942d7">
        <updating/>
        <source>resolveReferenceKeyNames() updating;
/*

Purpose:			

 * Phase 2: Resolves reference key names for all properties
 * 
 * Called after all classes are created/updated
 * Iterates through all properties and sets myKeyName based on referenced class
 * 
 * This solves circular dependency - all classes exist now, so we can
 * look up their key names
 
Parameters:			

Return Value:		

Date		Who		Reason
21 January 2026	naviv1	Initial creation MTN 36787 - JADE Core Framework - Export Import Class Registry Maintenance Engine

*/

vars
    exportClass, pxyExportClass: CM_ExportImportClass;
    exportProp: CM_ExportImportProperty;
    refExportClass: CM_ExportImportClass;
    resolvedCount: Integer;
    unresolvedCount: Integer;
begin
    resolvedCount := 0;
    unresolvedCount := 0;
    
    self.writeLog("Resolving reference key names for all properties...");
    
    foreach exportClass in app.myRoot.allExportImportClasses do
		pxyExportClass := exportClass.pxyGetProxyObject;
		if pxyExportClass = null then
			pxyExportClass := app.createUpdateProxy(exportClass).CM_ExportImportClass;
		endif;	
        foreach exportProp in pxyExportClass.allProperties do
            
            // Only process references and collections (not attributes)
            if exportProp.isReference or exportProp.isCollection then
                
                // Get the referenced class name from property
                refExportClass := self.getReferencedExportClass(exportProp);
                
                if refExportClass &lt;&gt; null then
					//pxyProperty := app.createUpdateProxy(exportProp).CM_ExportImportProperty;
                    // Set key name from referenced class
					if exportProp.myKeyName &lt;&gt; refExportClass.myKeyName then
						exportProp.myKeyName := refExportClass.myKeyName;
						resolvedCount := resolvedCount + 1;
                    
						self.writeLog("  ? " &amp; exportClass.className &amp; "." &amp; 
                        exportProp.propertyName &amp; " ? " &amp; 
                        refExportClass.className &amp; "." &amp; exportProp.myKeyName);
					endif;
                else
                    // Referenced class not found in registry
                    unresolvedCount := unresolvedCount + 1;
                    
                    self.writeLog("  ? " &amp; exportClass.className &amp; "." &amp; 
                        exportProp.propertyName &amp; " ? Referenced class not in registry");
                endif;
            endif;
        endforeach;
		if resolvedCount &gt; 0  then
			app.myTrxUA.trxUpdateExportImportClass(pxyExportClass,app.myPassport);
		endif;
    endforeach;
    
    self.writeLog("");
    self.writeLog("Resolved: " &amp; resolvedCount.String &amp; " references");
    
    if unresolvedCount &gt; 0 then
        self.writeLog("? Unresolved: " &amp; unresolvedCount.String &amp; " references");
        self.writeLog("  These properties reference classes not in export registry");
    endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="syncExportImportClass" id="f724e760-c12b-4d03-aa46-28499d0f0aa8">
        <updating/>
        <source>syncExportImportClass(_exportClass: CM_ExportImportClass io) updating;
/*

Purpose:			
* Syncs existing class configuration with latest definitions
 * Uses registry for metadata lookup - no if-elseif chains
Parameters:			

Return Value:		

Date		Who		Reason
21 January 2026	naviv1	Initial creation MTN 36787 - JADE Core Framework - Export Import Class Registry Maintenance Engine

*/

vars
    toDeleteProps: CM_ExportImportPropertySet;
    prop, pxyProp: CM_ExportImportProperty;
    beforeCount, afterCount: Integer;
    proxyClass, metaClass: CM_ExportImportClass;
    oldLoadMethod: String;
begin
    create toDeleteProps transient;
    
    beforeCount := _exportClass.allProperties.size;
    oldLoadMethod := _exportClass.loadMethodName;
    
    // Mark all current properties for potential deletion
  //  _exportClass.allProperties.copy(toDeleteProps);
	//_exportClass.allProperties.clear;
    
    
	
	create proxyClass transient;
	
	proxyClass := app.createUpdateProxy(_exportClass).CM_ExportImportClass;
	proxyClass.allProperties.copy(toDeleteProps);
	
	// Get updated metadata from registry
    metaClass := self.getClassMetadata(_exportClass.className);
    
	self.configureClassProperties(metaClass);


	proxyClass.setProxy(metaClass);
	
	foreach prop in metaClass.allProperties do
			pxyProp := proxyClass.allProperties[prop.propertyName];		
			if pxyProp = null then
				proxyClass.pxyCreateProprty(prop);
			else
				pxyProp.setForUpdate(pxyProp);
				toDeleteProps.removeIfPresent(pxyProp);
			endif;
	endforeach;
	
	 foreach prop in toDeleteProps do
		proxyClass.allProperties.removeIfPresent(prop);
        self.writeLog("  Removing obsolete property: " &amp; 
            proxyClass.className &amp; "." &amp; prop.propertyName);
        delete prop;
    endforeach;
	
	//_pxyExportClass.setForUpdate(proxyClass);
	app.myTrxUA.trxUpdateExportImportClass(proxyClass,app.myPassport);
	
    
    // Log if load method changed
    if oldLoadMethod &lt;&gt; proxyClass.loadMethodName then
        self.writeLog("  Load method changed: " &amp; oldLoadMethod &amp; 
            " ? " &amp; proxyClass.loadMethodName);
    endif;
    
    afterCount := proxyClass.allProperties.size;
    
    self.writeLog("  Updated: " &amp; proxyClass.displayName);
    self.writeLog("    Load Method: " &amp; proxyClass.loadMethodName);
    self.writeLog("    Before: " &amp; beforeCount.String &amp; " properties");
    self.writeLog("    After: " &amp; afterCount.String &amp; " properties");
    
epilog
    delete toDeleteProps;
    //delete proxyClass;
end;</source>
        <Parameter name="_exportClass" type="CM_ExportImportClass" usage="io"/>
    </JadeMethod>
    <JadeMethod name="writeLog" id="e2212fd0-283b-4a91-bc8e-f9f7f1bccaa2">
        <executionLocation>client</executionLocation>
        <source>writeLog(_msg : String) clientExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 January 2026	naviv1	Initial creation  MTN 36787 - JADE Core Framework - Export Import Class Registry Maintenance Engine

*/

vars

	
begin
	write _msg;

epilog

end;</source>
        <Parameter name="_msg" type="String"/>
    </JadeMethod>
</Class>
