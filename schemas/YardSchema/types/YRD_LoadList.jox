    <JadeMethod name="doMnuHideClick" id="c9d91d18-ca2e-4f0f-bd63-557d7b73292d">
        <updating/>
        <source>doMnuHideClick(_menuItem :MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:		22 August 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
//	08 Dec 2011	NDL	Par 28797
vars

begin
	if _menuItem.caption = self.MNU_MACRO_HIDE then
		_menuItem.caption := self.MNU_MACRO_SHOW;
		self.splMain.hideRightControl(true);
		//self.splTranShip.hideRightControl(true);
		self.splPlanned.hideRightControl(true);
		//self.splDLR.hideRightControl(true);
	else
		_menuItem.caption := self.MNU_MACRO_HIDE;
		self.splMain.showRightControl(30, true);
		//self.splTranShip.showRightControl(30, true);
		self.splPlanned.showRightControl(30, true);
		//self.splDLR.showRightControl(30, true);
		self.frmPopupInfo.visible := false;
	endif;
	xmlMacro := self.mnuContextHide.caption = self.MNU_MACRO_SHOW;
end;</source>
