<Class name="CM_QPlanningStateProperty" id="bfbe04ea-4f44-449b-8606-ab4521bc25b2">
    <superclass name="CM_QIntegerLookupProperty"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="create" id="6326f274-3206-438c-8228-4c91d81e083e">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     06 November 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	oper : CM_QueryOperator;

begin
	if self.isTransient then 
		return;
	endif;
		
	create oper as CM_QIntegerLookupEqual persistent;
	self.allAllowedOperators.add(oper);
	
	create oper as CM_QIntegerLookupNotEqual persistent;
	self.allAllowedOperators.add(oper);

	create oper as CM_QIntegerIsOneOf persistent;
	self.allAllowedOperators.add(oper);

end;</source>
    </JadeMethod>
    <JadeMethod name="doesIncludeState" id="b4850e71-b735-4d50-b485-4860883cc4a4">
        <source>doesIncludeState(_state : Integer; _operator : CM_QIntegerIsOneOf) : String protected;
// ---------------------------------------------------------------------------
// Created:     06 November 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if _operator &lt;&gt; null and _operator.allSelectionValues.includes(_state) then
		return '1';
	endif;
	
	return '0';

end;</source>
        <access>protected</access>
        <Parameter name="_state" type="Integer"/>
        <Parameter name="_operator" type="CM_QIntegerIsOneOf"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getKeyLengthForXTABDictionary" id="35e64066-dbd6-4430-96ff-d44731f3c19b">
        <source>getKeyLengthForXTABDictionary(): Integer;
// ---------------------------------------------------------------------------
// Created:     04 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	length	:Integer;
begin
	// just incase the global constant values change !!!
	length := app.getErrorString(Null).length;
	length := length.max (app.getErrorString(Notified).length);
	length := length.max (app.getErrorString(Received).length);
	length := length.max (app.getErrorString(Planned_To_Load).length);
	length := length.max (app.getErrorString(Loaded).length);
	length := length.max (app.getErrorString(Planned_To_Discharge).length);
	length := length.max (app.getErrorString(Discharged).length);
	length := length.max (app.getErrorString(Delivered).length);
	length := length.max (app.getErrorString(Planned_SOB).length);
	length := length.max (app.getErrorString(Shifted_On_Board).length);
	length := length.max (app.getErrorString(Unknown).length);
	
	return length;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
