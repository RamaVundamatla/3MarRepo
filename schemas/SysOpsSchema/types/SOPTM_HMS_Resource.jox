    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="sysops"/>
    <JadeMethod name="addCurrentCT2Combo" id="139321cf-ea50-483e-90f2-2d7960a14c31">
        <source>addCurrentCT2Combo(_obj : Object);
// ---------------------------------------------------------------------------
// Created:		12 September 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//06 Oct 2017	cnwma1  TFS #7257 JMT - Refactoring - Commodity Planning
// ---------------------------------------------------------------------------
vars
	aCT : CM_CalculationType;
	tot, idx : Integer;
	theLabel : String;
	haveVTMIS : Boolean;
	haveCARGO : Boolean;
	theForm : SOP_HMS_TableMaintForm;
	
begin
  	theForm := self.myForm.SOP_HMS_TableMaintForm;

	haveVTMIS := app.myRoot.canDo(Mod_Harbour);// VTMIS License //06.10.2017	cnwma1  TFS #7257
	haveCARGO := app.myRoot.canDo(Mod_CargoHandling); // CONTAINER LICENSE

	if _obj.isKindOf(HMS_Resource) then
		aCT := _obj.HMS_Resource.myCalculationTypeQuantity;
		// ### not in the combo, so add it in!!!
		if aCT &lt;&gt; null then
			if 	theForm.cmbCalcType.findObject(aCT) = -1 then
				if aCT.isCargoCalcType then
					if haveCARGO then
						theForm.cmbCalcType.addItemObject(aCT.description,aCT);
					endif;
				elseif aCT.isVoyageCalcType then
					if haveVTMIS then
						theForm.cmbCalcType.addItemObject(aCT.description,aCT);
					endif;
				else
					theForm.cmbCalcType.addItemObject(aCT.description,aCT);
				endif;
			endif;
		endif;
	endif;
end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="create" id="bff5d6e4-0e8f-4c16-8f30-d0ec0ef5ff8b">
        <updating/>
        <source>create() updating;
//--------------------------------------------------------------
//Created: 04 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	self.name := SOP_TableMaintForm.Table_Resource;
	self.permissionView	 := PmHMSResourceView;
	self.permissionMaint := PmHMSResourceMaint;
	self.myDataClass := HMS_Resource;
end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbCalcTypeBuild" id="9981ff97-097c-4cab-a049-f45bbc54be47">
        <source>doCmbCalcTypeBuild();
// ---------------------------------------------------------------------------
// Created:		07 July 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	aCT : CM_CalculationType;
	theForm : SOP_HMS_TableMaintForm;
begin
	theForm := self.myForm.SOP_HMS_TableMaintForm;

	theForm.cmbCalcType.clear;
	theForm.cmbCalcType.sorted := true;

	foreach aCT in app.myRoot.allCalculationTypesByCode discreteLock  where not aCT.isNotAvailableForEntry do
		if aCT.isVoyageCalcType then
			theForm.cmbCalcType.addItemObject(aCT.description,aCT);
		endif;
	endforeach;

	theForm.cmbCalcType.sorted := false;
	theForm.cmbCalcType.addItemAt("",1);
	self.addCurrentCT2Combo(theForm.myCurrentObject);
end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="2871cce4-0bd5-473a-a671-1c9c439f7fd6">
        <updating/>
        <source>doSave(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Jul 2003 cnwgd1  Initial Creation
22 Jan 2019 cnwma1	ChangeRequest 41980: PEL1 - SAP Equipment Details

*/

vars
	pxyResource	: HMS_Resource;
	theForm     : SOP_HMS_TableMaintForm;
	aCT         : CM_CalculationType;
begin

  	theForm := self.myForm.SOP_HMS_TableMaintForm; 
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as HMS_Resource transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	pxyResource := theForm.myProxyObject.HMS_Resource;
	theForm.tblInput1.setObjectFromTable(pxyResource, null, false);
	
	aCT := theForm.cmbCalcType.listObject.CM_CalculationType;
	
	pxyResource.setProxy(theForm.myHarbour, theForm.cmbWharf.listObject.HMS_Wharf,aCT);
	theForm.tblInput1.setObjectFromTable(pxyResource, "setObjectFromTableSpecial", false); //22/01/2019 cnwma1 TFS #41980
	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateHMSObject(pxyResource, theForm.myCurrentObject, app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateHMSObject(pxyResource, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	return app.myPassport.trxCompletedOK;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCollection" id="5d29e7ac-dcf5-41cc-afaf-b7b9572ece69">
        <source>getCollection(): Collection;
//--------------------------------------------------------------
//Created: 04 July 2003 By: cnwgd1
