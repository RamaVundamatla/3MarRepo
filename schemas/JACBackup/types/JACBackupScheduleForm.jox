        <updating/>
        <source>btnBackupAbort_click(_btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.myCurrentCntrl := _btn;
	self.doBackupOrAbort;
end;</source>
        <Parameter name="_btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnDel_click" id="69bb3cd0-9227-4b70-a951-f84bef17f8be">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnDel_click(_btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	sched: JACBackupSchedule;
begin
	self.myCurrentCntrl := _btn;
	if jdtCurrent.row &gt; 1 then
		jdtCurrent.column := 1;
		beginTransaction;
		delete jdtCurrent.itemObject.JACBackupSchedule;
		commitTransaction;
		self.resetTable;
		btnDel.enabled := false;
		btnEdit.enabled := false;
		btnReset.enabled := false;		
	else
		app.msgBox("You must select a row before trying to delete.","Error",MsgBox_OK_Only);
	endif;
end;</source>
        <Parameter name="_btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnEdit_click" id="ce0c2e45-9eaf-4fd5-bb1d-739ae641131a">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnEdit_click(_btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	sched: JACBackupSchedule;
	form: JACBackupScheduleEditForm;
begin
	self.myCurrentCntrl := _btn;
	jdtCurrent.column:=1;
	sched:=jdtCurrent.itemObject.JACBackupSchedule;
	if sched &lt;&gt; null and
	   sched.status = JACBackupComplete then
//		return;
	endif;
	create form;
	form.centreWindow;
	form.mySchedule:=sched;
	form.showModal;
	self.resetTable;
end;</source>
        <Parameter name="_btn" type="Button" usage="input"/>
    </JadeMethod>
