    <JadeMethod name="translateForm" id="2d098e52-a5c1-479e-8bdf-e23740b47cb0">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 27 February 2015.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0020232, locale);
	btnSave.translateCaption(Xlat_0020233, locale);
	lblHold.translateCaption(Xlat_0020234, locale);
	lblRTQueue.translateCaption(Xlat_0020235, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="updateAllocation" id="f0e1c3fc-4898-40c9-986c-512dd71fc906">
        <updating/>
        <source>updateAllocation() updating;
/*
Purpose:			
Date		Who		Reason
03 February 2015	cnwab1	Initial creation
*/

vars
	objHold : CM_LocationsController;
	objCraneWP, obj : CM_Object;
	selectedObj : Object;
begin
	objCraneWP := self.cmbRTQueues.listObject.CM_Object;
	
//	self.tblData.accessRow(self.tblData.row);
//	objHold := self.tblData.accessedRow.itemObject.CM_LocationsController;
	


	foreach selectedObj in self.tblData.allSelectedObjects discreteLock do
		objHold := selectedObj.CM_LocationsController;
		
		obj := self.allCranesWPsByHolds.getAtKey(objHold);
		
		if obj = null then // not found
			if objCraneWP &lt;&gt; null then
				self.allCranesWPsByHolds.putAtKey(objHold,objCraneWP);
			endif;
		else // already found
			self.allCranesWPsByHolds.removeKey(objHold);
			
			if objCraneWP &lt;&gt; null then
				self.allCranesWPsByHolds.putAtKey(objHold,objCraneWP);
			
			endif;
		endif;
	endforeach;

epilog

end;</source>
    </JadeMethod>
</GUIClass>
