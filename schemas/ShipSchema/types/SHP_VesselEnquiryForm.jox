    <JadeMethod name="tblData_contextMenu" id="00ac1ce7-fbbc-483e-8817-5ac30529e9f7">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
//--------------------------------------------------
// Created:	13 April 2005 By: cnwgd1
//--------------------------------------------------
vars
	xLeft 	: Real;
	yTop	: Real;
begin

	xLeft := x;
	yTop := y;

	self.mnuInspectObj.visible := app.isAllowedToInspect();
	
	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);   // convert x, y relative to form

	self.popupMenu(self.mnuContextTbl, xLeft.Integer, yTop.Integer);

	return false;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblData_dblClick" id="b93717fe-662c-4dbb-9c4f-89105b1ab020">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_dblClick(table: CM_DataTable input) updating;
//--------------------------------------------------
// Created:	18 May 2005 By: cnwgd1
//--------------------------------------------------
vars

	msg : String;

begin
	if table.row &lt;= table.fixedRows then
		table.resortTableByColumn(table.column);
		table.colourRows(self.colorRow1, self.colorRow2);		
	else
		//12 May 2017	NDL	TFS 4313
		if self.myCurrentVessel = null then
			self.setSelectedVessel(self.tblData.accessRow(self.tblData.row).itemObject.CM_Vessel);
			if self.myCurrentVessel = null then
				msg := app.getErrorString(PleaseSelectAVoyage);
				app.msgBox(msg,app.getErrorString(Warning),MsgBox_OK_Only);
				return;
			endif;
		endif;
		self.myAssistant.showVesselDefForm(self.myCurrentVessel, self.myMasterMenuAction, false);
	endif;
end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblData_keyDown" id="6f477708-a55e-4284-af66-3cdba240861c">
        <controlMethod name="CM_DataTable::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_keyDown(table: Table input; keyCode: Integer io; shift: Integer) updating;
//--------------------------------------------------
// Created:	08 June 2005 By: cnwgd1
//--------------------------------------------------
vars
	theObject : Object;
begin
	if keyCode = J_key_Delete 
	and (not self.frmSearch.visible) then
		self.doDelete();

	elseif shift = 0 then
		theObject := self.tblData.doSearch(keyCode.Character.String, 1);

		if CM_Vessel.hasInstance(theObject) then
			self.setSelectedVessel(theObject.CM_Vessel);
		endif;	

	endif;		
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblData_rowColumnChg" id="f28ab60a-39c0-4298-9661-4ebe9a6e2335">
        <controlMethod name="CM_DataTable::rowColumnChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_rowColumnChg(table: Table input) updating;
//--------------------------------------------------
// Created:	05 May 2005 By: cnwgd1
//--------------------------------------------------
vars

begin	
	if table.row &gt; table.fixedRows and table.rows &lt;= table.rows then
		self.setSelectedVessel(self.tblData.accessRow(self.tblData.row).itemObject.CM_Vessel);
	else
		self.setSelectedVessel(null);
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
