<Class name="CM_KPITruckVisitDtl" id="acab2044-30d0-4102-baef-c402b1bcc099">
    <superclass name="CM_KPIVisitDtl"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="kpiPeriod"/>
    <PrimAttribute name="finishGateInTime" id="c04eb5b5-9098-476d-9a82-f83656444164">
        <embedded/>
        <type name="TimeStamp"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="gate" id="8497598f-07bd-4d82-8bed-767e563e007f">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="startGateOutTime" id="009313c7-778b-4adb-ab9f-812d9247a593">
        <embedded/>
        <type name="TimeStamp"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="truck" id="7fb243a0-3c49-4ef9-b687-4b64b4d2dc9e">
        <length>31</length>
        <embedded/>
