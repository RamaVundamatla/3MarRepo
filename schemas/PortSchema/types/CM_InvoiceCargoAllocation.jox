    <JadeMethod name="getTransactionTypes" id="f8c1b35e-4a3b-448b-b411-ad8ff92ac8ca">
        <source>getTransactionTypes(_types : IntegerArray input);
/*

Purpose:			Populate the passed in IntegerArray with the numeric Transaction types that the 
					receiver Allocation has Criteria for

Parameters:			IntegerArray to be populated

Return Value:		None

Date		Who		Reason
31 May 2017	cnwkpd1	TFS #4542 - Invoicing performance changes

*/

vars
	criteria		: CM_YACriteria;
	yaObjects		: CM_YADataObjects;
	transactionType	: CM_TransactionType;
	iter			: Iterator;
	
begin
	criteria := self.getCriteriaOfTypeValue(YACriteriaType_TransactionType);
	if criteria = null then
		return;
	endif;
	
	if criteria.myYAData &lt;&gt; null and criteria.myYAData.isKindOf(CM_YADataObjects) then
		yaObjects := criteria.myYAData.CM_YADataObjects;
		iter := yaObjects.allObjects.createIterator();
		while iter.next(transactionType) do
			_types.add(transactionType.trxType);
		endwhile;
	endif;		
	
epilog
	delete iter;
	
end;</source>
        <Parameter name="_types" type="IntegerArray" usage="input"/>
    </JadeMethod>
