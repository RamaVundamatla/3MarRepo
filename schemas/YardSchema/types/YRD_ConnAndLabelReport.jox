vars

begin

	self.myTerminal := _terminal;

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setupControls" id="131945e6-1aa3-4f1d-a28d-0cdcd6689c95">
        <source>setupControls();
//----------------------------------------------------------------
//	Created:	18 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
/*
Date		Who		Reason
18 Mar 2010	consw1	PAR #22886 - Leaking report transients
*/
vars
	term			: CM_Terminal;
	voy				: CM_Voyage;
	cmb				: CMUI_ComboBox;
	defPrint		: String;
	jrwRpt			: JadeReportWriterReport;
	defProf			: String;
	profile			: String;
	profileNames	: StringArray;
	idx, defIdx		: Integer;

begin
	term := self.myTerminal;
	
	
	cmb := self.cmbVoyages;
	cmb.clear;
	cmb.addItem(Any_String);
	if term &lt;&gt; null then 
		foreach voy in term.allVoyagesByCode do
			cmb.addItemObject(voy.getDisplayDetails(false), voy);
		endforeach;
		
		defPrint := term.getConfig(ReeferLabelPrinter).String;
	endif;
	cmb.listIndex := 1;
	
	cmb := self.cmbPrinters;
	cmb.clear;
	self.myAssistant.comboBoxPrinterDefs(cmb, false, defPrint);
	
	cmb := self.cmbRptProfile; 
	cmb.clear;
	
	jrwRpt := self.myJadeReportWriterManager.getReport(self.myQryConnectionReport.jrwReportName.first);
	defProf := self.myQryConnectionReport.jrwReportProfileName.last;
	
	if jrwRpt &lt;&gt; null then
	
		if defProf = null then
			defProf := jrwRpt.getDefaultProfile();
		endif;
		
		profileNames := jrwRpt.getProfiles();
		foreach profile in profileNames do
			idx := cmb.addItem(profile);
			if profile = defProf then
				defIdx := idx;
			endif;
		endforeach;
		
		if defIdx &gt; 0 then
			cmb.listIndex := defIdx;
		endif;
		
	endif;
	
epilog
	delete jrwRpt;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="99bf109e-242a-4ff7-9630-df9187de26be">
        <updating/>
        <source>setupForm() updating;
//----------------------------------------------------------------
//	Created:	18 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	termDict 		: CM_TerminalByCodeDict;
	jadeReport		: JadeReport;
	jrwManager		: JadeReportWriterManager;
	jrwReport		: JadeReportWriterReport;
	ls, inTrans		: Boolean;
	reportString	: String;
//	qryReport		: CM_QryReport;
begin
	inheritMethod();
	
	if self.useSelected then
		self.caption := 'Print selected containers';
		self.cmbVoyages.enabled := false;
	else
		self.caption := 'Print all containers';
	endif;
		
	self.btnOk.caption := "&amp;Print";

	self.myQryConnectionReport := app.myRoot.getQryReport(app.getErrorString(Reefer_Connection_Report));

	self.myJadeReportWriterManager := app.createReportWriterManager();
	
	self.setupControls();

	if self.myQryConnectionReport = null then
		app.raiseUnexpectedProgramError(class.name, method.name, "cannot retrieve report " &amp; app.getErrorString(Reefer_Connection_Report));
		return;
	endif;

epilog
	app.mousePointer := MousePointer_Default;	
end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="9ef68aa1-f791-4a1b-8c07-588726fda0fc">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0008404, locale);
	chkConnReport.translateCaption(Xlat_0004220, locale);
	chkIgnoreTShip.translateCaption(Xlat_0004224, locale);
	chkPrintLabels.translateCaption(Xlat_0004225, locale);
	chkPrintPreview.translateCaption(Xlat_0004218, locale);
	chkSaveToWkList.translateCaption(Xlat_0004219, locale);
	lblMainCaption.translateCaption(Xlat_0004226, locale);
	lblPrinter.translateCaption(Xlat_0004222, locale);
	lblReportProf.translateCaption(Xlat_0004221, locale);
	lblVoyage.translateCaption(Xlat_0004223, locale);
end;</source>
    </JadeMethod>
