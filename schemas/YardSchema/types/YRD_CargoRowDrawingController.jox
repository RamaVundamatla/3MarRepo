    </JadeMethod>
    <JadeMethod name="drawLCEndOn" id="af689269-a2ab-4abc-a28d-c37c7d0b2e74">
        <updating/>
        <source>drawLCEndOn(_lc: CM_GridController) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 May 2010	cnwndl1	Initial creation	Par 24044

*/

vars

	colIdx : Integer;
	
begin

	colIdx := 0;
	self.drawSelfLCEndOn(_lc, self.x1,self.x2,colIdx,true);
	
epilog

