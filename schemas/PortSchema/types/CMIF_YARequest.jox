        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isConsignee_Match" id="7785325d-95fc-447b-96a8-56a2bddde5f1">
        <source>isConsignee_Match(_yaData: CM_YADataObjects): Boolean;
// -------------------------------------------
// Created 27 May 2005 by cnwdvb1
// -------------------------------------------
vars
	code	: String;
begin

	code := self.consigneeCode.trimBlanks();	
	
	// Take a look anyway.
	if code = null then
		return true;
	endif;
	
	// Only priorities will be empty.
	if _yaData.isEmpty() then
		return true;
	endif;
	
	return _yaData.visitObjectsUntilTrue(self, CMIF_YARequest::isConsignee_Compare, code);
end;</source>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
        <ReturnType type="Boolean"/>
