    <JadeMethod name="resizeControls" id="8e7a020f-5bff-422c-834d-26d64b901dab">
        <updating/>
        <source>resizeControls()  protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 May 2010	cnwer1	Initial creation
23/03/2011	cnwmh5	PAR #26931 - Change so that if theWidth &gt; lblConfirmPW.clientWidth does New before Confirm
06 Nov 2012 cnwer1	PAR 30678 CCMS HAT 2200 -changes to resizing
*/
constants 
	VMargin = 5;
	HMargin = 10;
vars
	theWidth,maxScroll : Integer;
	theHeight : Integer;
	btnTextMargin,
	left,
	top   		:Integer;
	bottomButton : Button;
begin
	isOnNarrowScreen := self.clientWidth &lt;= 320;
	theHeight:=self.txtConfirmPW.clientHeight;
	self.lblUser.height:=theHeight;

	theWidth:=self.lblConfirmPW.getTextExtent(self.lblConfirmPW.caption);
	
	if theWidth &lt;&gt; self.lblConfirmPW.clientWidth then
		self.lblCurrentPW.move(0,self.lblCurrentPW.top,theWidth,theHeight);
		self.txtOldPW.left:=self.lblCurrentPW.left + theWidth + VMargin;
		self.txtOldPW.width:=self.frmPW.clientWidth - self.lblCurrentPW.left - self.lblCurrentPW.clientWidth -  (HMargin*2);
		
		// 23/03/2011 cnwmh5 #26931 - Start
		top:=(self.txtOldPW.top + theHeight + VMargin).Integer;
		self.lblNewPW.move(0,top  ,theWidth,theHeight);
		self.txtNewPW.move(txtOldPW.left,top,txtOldPW.width, theHeight);
		
		top:=(self.txtNewPW.top + theHeight + VMargin).Integer;
		self.lblConfirmPW.move(0,top  ,theWidth,theHeight);
		self.txtConfirmPW.move(txtNewPW.left,top,txtNewPW.width, theHeight);
	endif;
	
	//epr 22/9/10 resize issues 
	self.tblChgQ.parentAspect:=Table.ParentAspect_StretchBoth;
	self.frmChgQ.height:=self.frmDetails.clientHeight;
	self.frmChgQ.width:=self.frmDetails.clientWidth;
	self.tblChgQ.left:=0;
	self.tblChgQ.top:=0;
	self.tblChgQ.height:=self.frmChgQ.clientHeight;
	self.tblChgQ.width:=self.frmChgQ.clientWidth;
	
	self.btnChgQ.visible:=app.myCurrentUserCan(app.myVMAgent.myTerminal, PmRTChangePrimQueue)
							and app.myVMAgent.getMyRTVehicleConfig.allowChangeQueue;
	if not self.btnChgQ.visible then
	
		self.btnChgLocale.top:=self.btnChgPW.top + self.btnChgPW.clientHeight + VMargin;
		if self.btnChgScreenSize.visible then
			self.btnChgScreenSize.top := self.btnChgLocale.top + self.btnChgLocale.clientHeight + VMargin;
		
			self.cmbScreenSize.move(HMargin, self.lblChgScreenSize.top + self.lblChgScreenSize.clientHeight + VMargin , self.cmbLocale.clientWidth, self.cmbLocale.clientHeight);
		endif;
	endif;
	
	
	theWidth:=0;
	theWidth:= self.btnMenu.getTextExtent(self.btnMenu.caption).max(theWidth);
	theWidth:= self.btnSave.getTextExtent(self.btnSave.caption).max(theWidth);
	theWidth:= self.btnCancel.getTextExtent(self.btnCancel.caption).max(theWidth);
	btnTextMargin:=(self.btnMenu.getTextExtent("W") *2);
	theWidth:=theWidth + btnTextMargin;
	theWidth:=theWidth.max(65);
	
	self.btnMenu.width:=theWidth;
	self.btnSave.left:=self.btnMenu.left + theWidth + VMargin;
	self.btnSave.width:=theWidth;
	self.btnCancel.left:=self.btnSave.left + theWidth + VMargin;
	self.btnCancel.width:=theWidth;
	
	
	
	theHeight:=0;
	theHeight:=self.btnMenu.getTextHeight(self.btnMenu.caption);
	theHeight:= theHeight + (VMargin *2);
	theHeight:=theHeight.max(35);
	
	self.btnMenu.height:=theHeight;
	self.btnSave.height:=theHeight;
	self.btnCancel.height:=theHeight;
	
	
	theWidth:=0;
	theWidth:= self.btnAbout.getTextExtent(self.btnAbout.caption).max(theWidth);
	theWidth:= self.btnChgPW.getTextExtent(self.btnChgPW.caption).max(theWidth);
	if self.btnChgQ.visible then
		theWidth:= self.btnChgQ.getTextExtent(self.btnChgQ.caption).max(theWidth);
	endif;
	theWidth:= self.btnChgLocale.getTextExtent(self.btnChgLocale.caption).max(theWidth);
	theWidth:=theWidth + btnTextMargin;
	theWidth:=theWidth.max(150);
	
	
	self.btnAbout.height:=theHeight;
	self.btnAbout.width:=theWidth;
	self.btnNight.height:=theHeight;
	self.btnDay.height:=theHeight;
	self.grpScreenMode.width:=theWidth;
	self.grpScreenMode.height:=theHeight;
	self.grpScreenMode.top:=self.btnAbout.top + theHeight + VMargin;
	self.btnChgPW.height:=theHeight;
	self.btnChgPW.width:=theWidth;
	self.btnChgPW.top:=grpScreenMode.top + theHeight + VMargin;
	self.btnChgQ.height:=theHeight;
	self.btnChgQ.width:=theWidth;
	self.btnChgQ.top:=btnChgPW.top + theHeight + VMargin;
	
	
	self.btnChgLocale.height:=theHeight;
	self.btnChgLocale.width:=theWidth;
	if btnChgQ.visible then
		self.btnChgLocale.top:=btnChgQ.top + theHeight + VMargin;
	else
		self.btnChgLocale.top:=btnChgPW.top + theHeight + VMargin;
	endif;
	self.btnChgScreenSize.height:=theHeight;
	self.btnChgScreenSize.width:=theWidth;
	self.btnChgScreenSize.top:=btnChgLocale.top + theHeight + VMargin;
		
	if self.btnChgScreenSize.visible then
		bottomButton:=self.btnChgScreenSize;
	endif;
	
	if bottomButton = null  then
		bottomButton:= self.btnChgLocale;
	endif;
	
	
	theWidth:=0;
	theWidth:= self.btnDay.getTextExtent(self.btnDay.caption).max(theWidth);
	theWidth:= self.btnNight.getTextExtent(self.btnNight.caption).max(theWidth);
	theWidth:=theWidth + btnTextMargin;
	theWidth:=theWidth.max(70);
	self.btnDay.width:=theWidth;
	self.btnNight.width:=theWidth;
	self.btnDay.left:=VMargin;
	self.btnNight.left:=self.btnDay.left + theWidth + VMargin;
	//epr par 25494 19/8/10
	if bottomButton &lt;&gt; null and ((bottomButton.top + bottomButton.clientHeight).Integer - self.frmMenu.clientHeight &gt; 0) then
		maxScroll:= (bottomButton.top + bottomButton.clientHeight).Integer -self.frmMenu.clientHeight;
		
	else
		maxScroll:=0;
	endif;
	
	self.picMenu.setScrollRange(ScrollBar_Vertical, 0,maxScroll, 20, 100);
	
	if self.isOnNarrowScreen then
		self.tblDetails.visible:=false;
		self.frmMenu.width:=self.clientWidth;
		self.tblDetails.width:=self.clientWidth;
		self.frmChgLoc.width:=self.clientWidth;
		self.frmChgQ.width:=self.clientWidth;
		self.frmPW.width:=self.clientWidth;
	else
		self.frmMenu.visible:=true;
		self.frmMenu.width:=self.btnAbout.clientWidth + 60;
		self.btnCancel.visible:=false;
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="a41d1d0e-045a-419d-ac54-876cecc49968">
        <updating/>
        <source>setupForm() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 May 2010	cnwer1	Initial creation

*/

vars

begin
	self.setupControlFromParent(self.frmPW,self.frmDetails,0,0);
	self.setupControlFromParent(self.tblDetails,self.frmDetails,0,0);
	self.setupControlFromParent(self.frmChgQ,self.frmDetails,0,0);
	self.setupControlFromParent(self.frmChgLoc,self.frmDetails,0,0);
	
	if app.isDevelopmentSystem and (not app.isOnDevice) then
		// if running on a PC allow user to change the screen size
		self.loadComboScreenSize();
		self.btnChgScreenSize.visible := true;
	endif;

	
	
	inheritMethod();

	self.frmChgQ.visible:=false;
	self.frmPW.visible:=false;
	self.frmChgLoc.visible:=false;

	
	self.loadInfoTable();
	self.loadComboLocale();
	
	self.lblUser.caption:=app.getMyUserCode;
	self.lblUser.fontBold:=true;
	if app.myVMAgent.getMyScreenMode.isDayMode then
		self.btnDay.value:=true;
	else
		self.btnNight.value:=true;
	endif;
	
	
	self.btnCancel.visible:=false;	
	if not self.isOnNarrowScreen then
		self.doChangeMode(UpdateMode_None);
	
	endif;
	
	if app.isOnDevice() then
		self.windowState := self.WindowState_Maximized;		
	endif;
	
	self.setVehicleMountedScreenSize();
	self.resizeControls();
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
