    <JadeMethod name="onTrailerTypeChanged" id="24175574-71fa-46e9-935f-0ebef7be3538">
        <updating/>
        <source>onTrailerTypeChanged(_trailerType : CM_TILCType) updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23/11/2009	cnwdap1	PAR #21658 Initial creation
12/08/2022	navkc1	ChangeRequest 54495: CUX - Default Tare Weight for Trailers
 10/03/2023	jlika1	TFS 56923 - Add width to Trailer
*/
vars
	
begin
	if _trailerType &lt;&gt; null then
		//epr 20/2/18 tfs 7756 removed redunant code
		self.tblLength.setValueDefault(_trailerType.length.String);	//01 Feb 2011	NDL	Par 26780				// PAR #31155
		self.tblHeight.setValueDefault(_trailerType.height.String); //20/9/22 TFS 54700 jlier1 
		self.tblWidth.setValueDefault(_trailerType.width.String); //jlika1 --&gt; 08/03/2023 TFS 56923
		
		// 12/08/2022	navkc1	#54495 --&gt;
		if not self.tblTareWeight.isHidden then // it's using tare weight if shown, process this
			
			if self.tblTareWeight.getConvertedValue = null then	// check is tare weight entered
				self.tblTareWeight.setValueDefault(_trailerType.tareWeight.String);	// populate tareweight if nothing is entered
			endif;
			
		endif;
		// 12/08/2022	navkc1	#54495 &lt;--
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_trailerType" type="CM_TILCType"/>
    </JadeMethod>
    <JadeMethod name="prefillFromLastVisit" id="85289840-bc49-42f4-98e7-b38bf6af5ac3">
        <updating/>
        <source>prefillFromLastVisit( _id : String ) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06/11/2012	cnwndl1	Initial creation	30691 - QNS CCMS 2234 
19/06/2019	jlgdap1	TFS 43765 SNO Booking Operator Code Road Gate Defaults
*/

vars

	existing : CM_TrackedItem;
	now : TimeStamp;
	lastVisit : CM_TrackedItem;
	
	isoType : CM_ISOType;
	tareWeight : Decimal [14,4];
	operator : CM_Operator;
	availGrade : CM_MTGrade;

begin

	//31 May 2013	NDL	Par 31518 - Interim fix until 8.2.2
//	if app.myRoot.isClientPortOtago then
//		return;
//	endif;
	if not self.myTerminal.getConfig(PrefillPreNoteRoadGate).Boolean then
		return;
	endif;

	if not self.isFlexiGateForm then
		// this behaviour is only valid in the road gate
		return;
	endif;
	
	if not self.flexiCargoType = CMUI_FlexiCargoForm.FLEXI_CARGO_FULL and not flexiCargoType = CMUI_FlexiCargoForm.FLEXI_CARGO_EMPTY then
		// If the user hasn't got here via pressing "Receive Empty" or "Receive Full" then don't do it.
		return;
	endif;

	if self.myPxyGTEEntity &lt;&gt; null then
		// The form has already been setup... bail.
		return;
	endif;
	
	// if the item is  already onsite, or an existing pre-note don't dick with the fields, just bail.
	existing := self.myTerminal.allOnsiteTIsByCargoTypeId.getAtKey( TI_CargoType_Container, _id );
	if existing &lt;&gt; null then
		return;
	endif;
	
	existing := self.myTerminal.allNotifiedTIsByCargoTypeId.getAtKey( TI_CargoType_Container, _id );
	if existing &lt;&gt; null then
		return;
	endif;
	
	//OK, so far good, so lets see if we can find a container that has visited here before with this id.
	now := app.actualTimeServer;
	lastVisit := self.myTerminal.allOffsiteTIsByCargoTypeId.getAtKeyLeq( TI_CargoType_Container, _id, now );
	
	if lastVisit = null then
		//nothing found
		return;
	elseif lastVisit.id &lt;&gt; _id then
		//not our cargo id
		return;
	elseif lastVisit.cargoType &lt;&gt; TI_CargoType_Container then
		//not a container
		return;
	endif;
	
	//Ok the container has been here before, and we have the details..
	isoType := lastVisit.getISOTypeObject;
	tareWeight := lastVisit.weightTare;
	operator := lastVisit.myOperator;
	availGrade := lastVisit.cargoIF_GetObjectForETRow(ETRow_AvailabilityGradeCode).CM_MTGrade;
	
	// TFS 43765 new rules if config option "Prefill Prenote Container from Booking" is ticked
	// If we have a booking, set operator to the booking operator
	// if we have a booking, and the booking item has an iso type, set iso type and tare weight from the booking item
	if self.myTerminal.getConfig(PrefillRecContBookGate).Boolean then
		if self.myBookingRefItem &lt;&gt; null then
			if self.myBookingRefItem.myBookingReference.myOperator &lt;&gt; null then
				operator := self.myBookingRefItem.myBookingReference.myOperator;
			endif;
			if self.myBookingRefItem.myISOType &lt;&gt; null then
				isoType := self.myBookingRefItem.myISOType;
				if self.myBookingRefItem.myISOType.tareKilos &lt;&gt; null then
					tareWeight := self.myBookingRefItem.myISOType.tareKilos;
				endif;
			endif;
		endif;
	endif;
	// TFS 43765 end
	
	if isoType &lt;&gt; null then
		self.cmbISOType.setForObject(isoType);
		self.doISOTypeChange();
	endif;
	
	if tareWeight &gt; 0 then
		//self.txtTareWeight.setValue( tareWeight.asStringWeightJMT() );		// PAR #31155
		self.tblTareWeight.setValueDefault(tareWeight.String);					// PAR #31155
	endif;
	
	if operator &lt;&gt; null then
		self.cmbOperatorCode.setObject( operator );
	endif;
	
	if availGrade &lt;&gt; null then
		self.cmbMTGrade.setForObject( availGrade );
	endif;
		
	

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_id" type="String"/>
    </JadeMethod>
    <JadeMethod name="purgeTransientAttachments" id="be7e99b5-3fd2-4c0f-bce5-7fe5c9d6fbea">
        <source>purgeTransientAttachments();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 October 2012	cnwndl1	Initial creation	Par 30503

*/

vars

begin

	inheritMethod();
	
	self.cmbAttachments.clear();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="recheckSubCargoTypeAttributes" id="f322445c-a0d1-4aeb-b9bb-8c2a8d1f3a4f">
        <updating/>
        <source>recheckSubCargoTypeAttributes() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28/01/2011	cnwdap1	Initial creation PAR #26785 redo product attribute specific caption changes
02/02/2011	cnwdap1	PAR #26862 allow for cargo types that don't have any cargo sub types
*/
vars
	cargoSubType	: CM_Product;
	cargoType		: CM_CargoType;		// PAR #26862

begin
	cargoSubType := self.cmbSubCargo.getObject.CM_Product;
	cargoType := self.cmbType.getObject.CM_CargoType;				// PAR #26862
	
	// if cargo sub type has been selected, or the cargo type has been and it doesn't have any cargo sub types,
	// rebuild the cargo subtype / system subtype attribute labels
	if cargoType &lt;&gt; null and cargoType.allProducts.isEmpty then		// PAR #26862
		cargoSubType := cargoType.mySystemProductType;				// PAR #26862
	endif;															// PAR #26862
	
	self.doFilterProductAttributes(cargoSubType);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="removeAttachment" id="9aef7ac9-68a5-4b3f-af8f-04fb47770fb1">
        <updating/>
        <source>removeAttachment(_attachment : Object) updating;
// -----------------------------------------------------------------------------
// Created:		03 September 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
// 12/08/2105	cnwdap1		PAR #36421 Hazardous Materials Handling
// -----------------------------------------------------------------------------

vars
	idx : Integer;
	id : String;							// PAR #36421
begin
	if _attachment &lt;&gt; null and self.allAttachments.includes(_attachment) then
		self.allAttachments.remove(_attachment);
		if _attachment.isKindOf(CMGTE_Entity) then								// PAR #36421
			id := _attachment.CMGTE_Entity.id;									// PAR #36421
		elseif _attachment.isKindOf(CMIF_Receival) then							// PAR #36421
			id := _attachment.CMIF_Receival.id;									// PAR #36421
		endif;																	// PAR #36421
		if id &lt;&gt; null then														// PAR #36421
			//idx := self.cmbAttachments.findStringExact(1, _attachment.id);	// PAR #36421
			idx := self.cmbAttachments.findStringExact(1, id);					// PAR #36421
			if idx &gt; 0 then
				self.cmbAttachments.removeItem(idx);
			endif;
		endif;																	// PAR #36421
	endif;

epilog

end;</source>
        <Parameter name="_attachment" type="Object"/>
    </JadeMethod>
    <JadeMethod name="resetForm" id="8f8d03be-645a-4cac-8b16-665474a980d1">
        <updating/>
        <source>resetForm() updating;
// -----------------------------------------------------------------------------
// Created:		04 September 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars

begin
	self.allDamageInstancesByPos.purge; //epr par 31845
	self.allPhotos.purge;
	
	inheritMethod();
	
	// Attachments - default to blank entry
	if self.isVVRUpdatable() then
		self.cmbAttachments.addItem("** New **");
		self.cmbAttachments.listIndex := 1;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="resetHazardTable" id="597c4ab9-d150-4e92-afca-7aa4510e4158">
        <source>resetHazardTable();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 Oct 2013	cnwmc5	Initial creation	PAR 32666
26 Feb 2024 naviv1	Bug 62381 - PNL - Prenotes - Save-Next button doesn't populate Hazard Details on subsequent prenotes
*/

vars

begin
	self.lstHazardList.loadHazardObjects();
	self.myAssistant.resetHazardListTable(self.lstHazardList);
