    <JadeMethod name="ccms1061_conversion" id="3dfd15f0-259b-4d7b-84f7-35f72bc6cd0f">
        <updating/>
        <source>ccms1061_conversion(_terminalArea :CM_VehicleTransferArea)updating;
// ---------------------------------------------------------------------------
// Created:     15 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	// this is a BIG kludge to remove CM_TILCRow instances from the
	// CM_TerminalArea::allLocationsControllers 
	self.myTerminalArea	:= _terminalArea;	// force inverse maintenance
	self.myTerminalArea := null;			// force inverse maintenance
epilog

end;</source>
        <Parameter name="_terminalArea" type="CM_VehicleTransferArea"/>
    </JadeMethod>
    <JadeMethod name="executeDisplayNotesForMove" id="da33e6a8-915f-4a1a-aa83-4deafcc72e34">
        <source>executeDisplayNotesForMove(_controller: CMIF_MoveController);
/*

Date		Who		Reason
23 August 2013	cnwer1	Initial creation PAR 32261

*/

vars

begin
	if self.myTILC &lt;&gt;  null then	
	inheritMethod(_controller);
	endif;

epilog

end;</source>
        <Parameter name="_controller" type="CMIF_MoveController"/>
    </JadeMethod>
    <JadeMethod name="getFullId" id="bd90c2b3-810a-4346-9cde-d09d2612a69b">
        <source>getFullId(): String;
/*

Date		Who		Reason
23 August 2013	cnwer1	Initial creation PAR 32261

*/

vars
	terminal : CM_Terminal;
begin
	if self.myVehicle = null then	
		//jlier1 TFS 54700 31/8/22
		terminal:=self.myTerminal;
		if terminal &lt;&gt; null then
			if terminal.getConfig(IgnoreTrailerTypeTEUCap).Boolean then
				return self.myTILC.id;
			endif;
		endif;
		return self.myTILC.id &amp; " "  &amp; self.myTILC.allLCs.indexOf(self).asStringJMT;
	else
		return self.myVehicle.regNumber &amp; " " &amp; self.UnknownTrailer; //unknown-trailer is now all one word because terminal findLocation can find it
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOverrideQueue" id="b1dd86fa-c618-4d71-bef9-4272d34e7500">
        <source>getOverrideQueue(): CM_SubQueue;
/*

Date		Who		Reason
14 January 2014	cnwer1	Initial creation PAR 33302

*/

vars
	parent : CM_LocationsController;
begin
	
	parent:=self.getParent().CM_LocationsController;
	
	if parent &lt;&gt;  null then
		return parent.getOverrideQueue();
	endif;
	
	if self.myVehicle &lt;&gt; null then
		return self.myVehicle.locationsController.getOverrideQueue;
	endif;
	
	return inheritMethod();

epilog

end;</source>
        <ReturnType type="CM_SubQueue"/>
    </JadeMethod>
    <JadeMethod name="getStateForTIHere" id="50d91276-1dec-495c-9498-c0641f188d5a">
        <source>getStateForTIHere(_ti: CM_TrackedItem): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 May 2024	navsp1	Initial creation TFS Bug 63940: CUX | FR 63476: - POST /CARGO Prenote shows Onboard Cargo as Onsite - GoLCrit 01

*/

vars

begin
	
	if self.myTILC  &lt;&gt; null then
		return self.myTILC.state;
	endif;
	
	return inheritMethod(_ti);

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="myTerminal" id="cbe9e5c0-8ffe-4e3d-933c-6625b896ea3d">
        <methodInvocation>mapping</methodInvocation>
        <source>myTerminal(set: Boolean; _value: CM_Terminal io) mapping;
/*

Date		Who		Reason
23 August 2013	cnwer1	Initial creation PAR 32261

*/

vars

begin
	if self.myVehicle = null then	
		inheritMethod(set, _value);
	else
		_value := self.myVehicle.myTerminal;
	endif;

epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_Terminal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setMyVehicle" id="a2ad3d38-780b-455e-85a4-b3e1c5b74cc8">
