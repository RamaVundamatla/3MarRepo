    <JadeMethod name="setProxyFromObject" id="762fadcd-3e9c-42fa-a714-1eaa3d4ad5aa">
        <updating/>
        <source>setProxyFromObject(_object: CM_WodTimeChange) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 June 2018	jlger1	Initial creation

*/

vars
	invalidResource : Boolean;
	invalidWO  : Boolean;
begin
	inheritMethod(_object);
	self.occursOnDT:= _object.occursOnDT.asStringForWebInterface;
	
	on Exception do app.handleDeletedObject(exception,_object.myHMSResourceUsedToUpdate,invalidResource);
	on Exception do app.handleDeletedObject(exception, _object.myWorkOrderToUpdate,invalidWO);
	
	if _object.myHMSResourceUsedToUpdate &lt;&gt; null then
		self.hmsResourceUsedOid:=_object.myHMSResourceUsedToUpdate.getOidAsString;
	endif;
	
	if _object.myWorkOrderToUpdate &lt;&gt; null then
		self.workOrderOid:=_object.myWorkOrderToUpdate.getOidAsString;
	endif;
	
epilog

end;</source>
        <Parameter name="_object" type="CM_WodTimeChange"/>
    </JadeMethod>
    <JadeMethod name="updateProxyWorkOrder" id="6f7912cb-73a5-4438-a443-81a5ab078745">
        <source>updateProxyWorkOrder(_pxyWorkOrder: CM_WodTimeChange input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 June 2018	jlger1	Initial creation

*/

vars
	hmsResourceUsed : HMS_ResourceUsed;
	workOrder : CM_WorkOrder;
	ts : TimeStamp;
begin
	inheritMethod(_pxyWorkOrder);
	
	//11 Oct 2018	NDL	TFS 41084
	ts := self.occursOnDT.asTimeStampFromWebInterface;
	if ts.date.isValid and ts &lt; app.actualTimeServer then
		app.raiseCMException1( Past, ts.asStringJMT, null, null );
		return;
	endif;
	
	self.validateDateIsDuringVoyage( self.voyage, self.occursOnDT.asTimeStampFromWebInterface );	//28 Sep 2018	NDL	TFS 41148
	self.validateDateIsDuringVoyage( self.voyage, self.requiredByDT.asTimeStampFromWebInterface );	//28 Sep 2018	NDL	TFS 41148
	
	if self.hmsResourceUsedOid &lt;&gt; null then
		hmsResourceUsed:=app.myPassport.getObjectOfTypeFromOid(self.hmsResourceUsedOid,HMS_ResourceUsed).HMS_ResourceUsed;
	endif;
	if self.workOrderOid &lt;&gt; null then
		workOrder:= app.myPassport.getObjectOfTypeFromOid(self.workOrderOid,CM_WorkOrder).CM_WorkOrder;
	endif;
	
	_pxyWorkOrder.setProxyWodTimeChange(self.occursOnDT.asTimeStampFromWebInterface,hmsResourceUsed,workOrder);

end;</source>
        <Parameter name="_pxyWorkOrder" type="CM_WodTimeChange" usage="input"/>
    </JadeMethod>
</Class>
