    <JadeMethod name="mapCargoChain" id="cd2b077d-fa80-411d-82b2-ab4ef114d4da">
        <source>
mapCargoChain();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 November 2018	jlgmp6	Initial creation

*/

vars
	req: CM_CargoChainWSAgent;
	xml				: JadeXMLDocument;
	xmlElement,
	xmlMessage		: JadeXMLElement;
	jsonPostData	: String;
	jsonHelper		: CMIF_JsonHelper;
	jsonResponse,
	cargoJSON		: String;
	xmlHelper		: CM_XmlHelperAgent;
	conn,
	conn2			: JadeHTTPConnection;
	sendSuccess		: Boolean;
	token			: String;

begin
	create req transient;
	
	
	create jsonHelper transient;
	create xml transient;
	create xmlHelper transient;
	xml.outputDeclaration := false;
	xml.addElement("root");
	xml.rootElement.addElement("client_id").setText("IIz8t7cP8YeUjFCJhRTB");
	xml.rootElement.addElement("client_secret").setText("7yWDJyZyB4CiVxWD10rqMbCbZKDGCPpd1uHUsbP2bNyY1H4+J1ByW0AtIKXWbwtGU0mwfYO7OcCA58fgcRIi8DYcc6Mg4PNKiUI4U6SV/Og=");
	xml.rootElement.addElement("grant_type").setText("client_credentials");
	jsonPostData := jsonHelper.convertXMLToJson(xml.writeToString());
	write jsonPostData;
	
	// Call authenticate
/*	jsonResponse := req.doSendHTTPRequest("https://tests-auth.cargochain.com/api/accesstoken/ask",
										   "POST",
										   "Content-Type: application/json",
										   jsonPostData);
*/
   	create conn transient;
	
	// Set timeouts of required
/*	if self.timeoutSeconds &lt;&gt; 0 then
		timeoutMS := self.timeoutSeconds * 1000;
		conn.sendTimeout := timeoutMS;
		conn.receiveTimeout := timeoutMS;
	endif;
	*/

	conn.url := "https://tests-auth.cargochain.com/api/accesstoken/ask";
	sendSuccess := conn.sendRequest("POST", "Content-Type: application/json", jsonPostData);
	write sendSuccess.asStringJMT();

	if sendSuccess then
		conn.readBody(0);
		jsonResponse := conn.responseBody.StringUtf8.String;
		xmlHelper.tryParseToXMLDocument(jsonHelper.convertJsonToXML(jsonResponse), xml);
	
		// Find token in response
		xmlElement := xml.findElementByTagName("access_token");
		if xmlElement &lt;&gt; null then
			token := xmlElement.text();
			write token;
		endif;
		
		delete xml;
		create xml transient;
		xml.outputDeclaration := false;
		xml.addElement("root");
		xmlMessage := xml.rootElement.addElement("message");
		xmlElement := xmlMessage.addElement("type");
		xmlElement.addElement("id").setText("type");
		xmlElement.addElement("dataType").setText("profileType");
		xmlElement.addElement("value").setText("Breakbulk");
		xmlElement := xmlMessage.addElement("aliasId");
		xmlElement.addElement("id").setText("AliasId");
		xmlElement.addElement("datatype").setText("AliasId");
		xmlElement.addElement("value").setText("JMTU1234567");
		xmlElement.addElement("initialization").setText("true");
		xmlElement.addElement("isRequired").setText("false");
		xmlElement := xmlMessage.addElement("aliasName");
		xmlElement.addElement("id").setText("aliasName");
		xmlElement.addElement("datatype").setText("AliasName");
		xmlElement.addElement("value").setText("");
		xmlElement.addElement("initialization").setText("true");
		xmlElement.addElement("isRequired").setText("false");
		xmlElement := xmlMessage.addElement("creationDate");
		cargoJSON := jsonHelper.convertXMLToJson(xml.writeToString());
		write cargoJSON;
		// Send the request
//		jsonResponse := self.doSendHTTPRequest('https://tests.cargochain.com/cargo/create',
//											   "POST",
//											   "Content-Type: application/json" &amp; CrLf &amp; "Authorization: Bearer " &amp; token,
//											   cargoJSON);
		create conn2 transient;
		conn2.url := "https://tests.cargochain.com/cargo/create?access_token=" &amp; token;
		sendSuccess := conn2.sendRequest("POST", "Content-Type: application/json", cargoJSON);
//		sendSuccess := conn2.sendRequest("POST", "Content-Type: application/json" &amp; CrLf &amp; "Authorization: Bearer " &amp; token, cargoJSON);
		write sendSuccess;
		conn2.readBody(0);
		conn2.inspectModal();
		jsonResponse := conn2.responseBody.StringUtf8.String;
		write jsonResponse;
	endif;

epilog
	delete req;
	delete conn;
	delete conn2;
	delete jsonHelper;
	delete xmlHelper;
	delete xml;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="mapCargoChainAddEvent" id="9fd3bc97-b54e-4e6b-be9f-cfb74e16044b">
        <source>mapCargoChainAddEvent();
/*

Purpose:			

