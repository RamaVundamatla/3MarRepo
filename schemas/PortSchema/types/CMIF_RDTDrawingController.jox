        <updating/>
        <source>setWagonWidthFt(_ft : Real) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 April 2010	cnwjk3	Initial creation

*/

vars

begin
	self.wagonWidthFt := _ft;
