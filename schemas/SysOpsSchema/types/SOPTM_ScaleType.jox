    <JadeMethod name="doSave" id="f5d0a2e5-9660-4eca-92f4-81ead743589c">
        <updating/>
        <source>doSave(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 March 2014	cnwndl1	Initial creation	Par 33268

*/

vars

	proxyScaleType : CM_WeighBridgeObjType;
	lCode : String;
	lDescription : String;
	theForm : SOP_TableMaintForm;
	grams : CM_MeasurementType;
	kilos : CM_MeasurementType;
	ounces : CM_MeasurementType;
	pounds : CM_MeasurementType;
	tons : CM_MeasurementType;
	
begin

	theForm := self.myForm; 
	lCode := theForm.tblInput1.getValueByName(ETRow_Code).String;
	lDescription := theForm.tblInput1.getValueByName(ETRow_Description).String;
	grams := theForm.cmbGrams.listObject.CM_MeasurementType;
	kilos := theForm.cmbKilos.listObject.CM_MeasurementType;
	ounces := theForm.cmbOunces.listObject.CM_MeasurementType;
	pounds := theForm.cmbPounds.listObject.CM_MeasurementType;
	tons := theForm.cmbTons.listObject.CM_MeasurementType; 

	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_WeighBridgeObjType transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	proxyScaleType := theForm.myProxyObject.CM_WeighBridgeObjType;
	proxyScaleType.setProxy(	lCode,	//_code : String;
								lDescription,	//_description : String;
								grams,	//_gramsMT : CM_MeasurementType;
								kilos,	//_kilosMT : CM_MeasurementType;
								ounces,	//_ouncesMT : CM_MeasurementType;
								pounds,	//_poundsMT : CM_MeasurementType;
								tons	//_tonsMT : CM_MeasurementType
								);

	if theForm.mode = theForm.Mode_Add then
		 app.myTrxCA.trxCreateScaleType(proxyScaleType, theForm.myCurrentObject,app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateScaleType(proxyScaleType, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	
	return app.myPassport.trxCompletedOK;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
