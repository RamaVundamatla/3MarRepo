    <JadeMethod name="isJobMatchingMode" id="ce7b6609-de92-4274-8a33-db58dfe83b64">
        <source>isJobMatchingMode(_mode: Integer): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Oct 2023 navhl20 ChangeRequest 60090: EUP | Ship Operations in DD - [54176.020] -[Receive] Allocate Jobs to Gangs and Gangs to Holds
29 Nov 2023 navhl20 ChangeRequest 61510: EUP | Ship Operations in DD - [54176.020] - [Release] Allocate Jobs to Gangs and Gangs to Holds
25 Feb 2025 navma1  MTN-34075 MTN | Dead Lock (1081) on CM_JobsByPriorityRequiredDT
*/

vars
	wod 		: CM_WorkOrderTIDtl;
	transport	: Integer;
begin
	wod := self.myWODtl;
	
	if wod &lt;&gt; null then
		if wod.isWodReceive then							//25.02.2025 navma1 #MTN-34075
			transport := wod.CM_WodReceive.transport;
		else
			transport := wod.CM_WodRelease.transport;
		endif;
		if transport = TI_TRANSMODE_SHIP then
			return _mode = 3;								//YRD_WorkOrderOperation.Mode_SHIP
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_mode" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
