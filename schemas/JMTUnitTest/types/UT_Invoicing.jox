    <JadeMethod name="verifyInvoiceLineCopyValues" id="f118be0a-f730-4dd0-80d4-6dc06acaa99f">
        <source>verifyInvoiceLineCopyValues(_cmifInvLineCopy : CMIF_InvoiceLineCopy);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 April 2023  navmv20 TFS 55304 Task 55543: Jade - Invoice Line Copy Unit Test

*/

vars
	noOfTrackedItems,
	startIdx1,
	startIdx2,
	endIdx1,
	endIdx2,
	row1,
	row2,
	tiIdx				: Integer;	
	selectedInvLine,
	realInvLine         : CM_InvoiceLine;
	ti                  : CM_TrackedItem;
	
begin
	if  _cmifInvLineCopy.differentCargos then
		noOfTrackedItems := _cmifInvLineCopy.allTrackedItems.size();
	else 
		noOfTrackedItems := 1;
	endif;
	startIdx1	:= 1;
	startIdx2	:= 1;
	tiIdx 		:= 1;
	
	endIdx1 := _cmifInvLineCopy.allSelectedInvoiceLines.size();
	endIdx2 := noOfTrackedItems;

	foreach  row1 in startIdx1 to endIdx1 do
		selectedInvLine := _cmifInvLineCopy.allSelectedInvoiceLines[row1].CM_InvoiceLine;
		
		foreach row2 in startIdx2 to endIdx2 do
			realInvLine := _cmifInvLineCopy.allRealInvLines[row2].CM_InvoiceLine;
			if _cmifInvLineCopy.differentCargos then
				ti := _cmifInvLineCopy.allTrackedItems[tiIdx];
			else
				ti := selectedInvLine.trackedItem;
			endif;
			checkInvLineCopyValues(ti,_cmifInvLineCopy,selectedInvLine, realInvLine);
			tiIdx := tiIdx + 1;
		endforeach;
		startIdx2 := endIdx2 + 1;
		endIdx2 := startIdx2 + noOfTrackedItems - 1;
		tiIdx := 1;
	endforeach;
epilog

end;</source>
        <Parameter name="_cmifInvLineCopy" type="CMIF_InvoiceLineCopy"/>
    </JadeMethod>
    <JadeMethod name="xCreateStorage" id="a1a7ab97-3831-4005-840c-34b44e536ee5">
        <source>xCreateStorage(_day : Integer; _useFirst : Boolean; _useLast : Boolean; _storageConfig : CM_StorageConfig input; _ti : CM_TrackedItem input);
// create a single CM_Storage for the given date with the storage config options as entered
vars
	tranTS		: TimeStamp;
	tranDate	: Date;
	tranTime	: Time;
	tran			: CM_TITransaction;
	storageConfig	: CM_StorageConfig;
	invLine		: CM_InvoiceLine;
	msg			: String;

begin
	// delete any existing CM_Storage then create a new one
	beginTransaction;
	foreach tran in _ti.allTransactions do
		if tran.class.name = CM_Storage.name then
			delete tran;
		endif;
	endforeach;
	_storageConfig.setPropertyValue("includeFirstDay", _useFirst);
	_storageConfig.setPropertyValue("includeLastDay", _useLast);
	commitTransaction;

	tranDate.setDate(_day,3,2016);
	tranTS.setDate(tranDate);
	tranTime.setTime(1, 1, 00, 00);
	tranTS.setTime(tranTime);
	tran := self.createDatedTransaction(_ti, tranTS, TRANS_TYPE_STORAGE);
	msg := "In 1 out " &amp; _day.String &amp; " Use First day=" &amp; _useFirst.String &amp; " Use Last Day=" &amp; _useLast.String;
	if tran = null then
		msg := msg &amp; " NO storage transaction";
	elseif tran.allInvoiceLines.isEmpty then
		msg := msg &amp; " NO invoice lines";
	else
		foreach invLine in tran.allInvoiceLines do
			msg := msg &amp; " Quantity=" &amp; invLine.quantity.String;
		endforeach;
	endif;
	write msg;

epilog

end;</source>
        <Parameter name="_day" type="Integer"/>
        <Parameter name="_useFirst" type="Boolean"/>
        <Parameter name="_useLast" type="Boolean"/>
        <Parameter name="_storageConfig" type="CM_StorageConfig" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="xCreateTwoStorages" id="fcd83ef3-0f7c-41ab-81ca-70ed94adea65">
        <source>xCreateTwoStorages(_day : Integer; _useFirst : Boolean; _useLast : Boolean; _storageConfig : CM_StorageConfig input; _ti : CM_TrackedItem input);
// create one CM_Storage for the given date with the storage config options as entered
//	and then another 2 days later
vars
	day			: Integer;
	tranTS		: TimeStamp;
	tranDate	: Date;
	tranTime	: Time;
	tran			: CM_TITransaction;
	storageConfig	: CM_StorageConfig;
	invLine		: CM_InvoiceLine;
	msg			: String;

begin
	day := _day;
	// delete any existing CM_Storage then create a new one
	beginTransaction;
	foreach tran in _ti.allTransactions do
		if tran.class.name = CM_Storage.name then
			delete tran;
		endif;
	endforeach;
	_storageConfig.setPropertyValue("includeFirstDay", _useFirst);
	_storageConfig.setPropertyValue("includeLastDay", _useLast);
	commitTransaction;

	tranDate.setDate(day,3,2016);
	tranTS.setDate(tranDate);
	tranTime.setTime(1, 1, 00, 00);
	tranTS.setTime(tranTime);
	tran := self.createDatedTransaction(_ti, tranTS, TRANS_TYPE_STORAGE);
	msg := "FIRST Storage: In 1 out " &amp; day.String &amp; " Use First day=" &amp; _useFirst.String &amp; " Use Last Day=" &amp; _useLast.String;
	if tran = null then
		msg := msg &amp; " NO storage transaction";
	else
		foreach invLine in tran.allInvoiceLines do
			msg := msg &amp; "Quantity=" &amp; invLine.quantity.String;
		endforeach;
	endif;
	write msg;

	day := day + 2;
	tranDate.setDate(day,3,2016);
	tranTS.setDate(tranDate);
	tranTime.setTime(1, 1, 00, 00);
	tranTS.setTime(tranTime);
	tran := self.createDatedTransaction(_ti, tranTS, TRANS_TYPE_STORAGE);
	msg := "SECOND Storage: In 1 out " &amp; day.String &amp; " Use First day=" &amp; _useFirst.String &amp; " Use Last Day=" &amp; _useLast.String;
	if tran = null then
		msg := msg &amp; " NO storage transaction";
	else
		foreach invLine in tran.allInvoiceLines do
			msg := msg &amp; "Quantity=" &amp; invLine.quantity.String;
		endforeach;
	endif;
	write msg;
epilog

end;</source>
        <Parameter name="_day" type="Integer"/>
        <Parameter name="_useFirst" type="Boolean"/>
        <Parameter name="_useLast" type="Boolean"/>
        <Parameter name="_storageConfig" type="CM_StorageConfig" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="xCreateTwoStorages2" id="856085a5-352b-4125-8d7f-dd1a993db365">
        <source>xCreateTwoStorages2(_day1 : Integer; _day2 : Integer; _useFirst : Boolean; _useLast : Boolean; _storageConfig : CM_StorageConfig input; _ti : CM_TrackedItem input);
