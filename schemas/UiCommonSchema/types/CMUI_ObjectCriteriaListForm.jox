    <JadeMethod name="doAdd" id="bbd07ca8-7c73-4fe6-ac3a-0d0031d19264">
        <source>doAdd();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 December 2013	cnwndl1	Initial creation	Par 33184

*/

vars
	theForm : CMUI_ObjectCriteriaLineForm;
	moreTerminals	: Boolean;
	userTerm : CM_UserTerminal;
	reeferForm : CMUI_ReeferAutoJobsForm;
begin

	if self.context = CM_ObjectMatchCriteria.ReeferJobCriteriaInt then	//03 Aug 2020	NDL	TFS 49581
		create reeferForm transient;
		reeferForm.setBaseData(	null, self );
		reeferForm.showModal();
		self.loadTable();
		return;
	endif;
	
	// 34300 check if there are more terminals to have restrictions - if not, the CMUI_ObjectCriteriaLineForm has a null myTerminal
	if self.context = CM_ObjectMatchCriteria.WagonRestrictionInt then
		foreach userTerm in app.getMyUser.allUserTerminals do
			if contextObject.CM_WagonMaster.getMyObjectMatchCriteriaFor( userTerm.myTerminal ) = null then
				moreTerminals := true;
				break;
			endif;
		endforeach;
		if not moreTerminals then
			return;
		endif;
	endif;

	create theForm transient;
	
	if self.context = CM_ObjectMatchCriteria.WagonRestrictionInt and self.myTerminal = null then
		foreach userTerm in app.getMyUser.allUserTerminals do
			if contextObject.CM_WagonMaster.getMyObjectMatchCriteriaFor( userTerm.myTerminal ) = null then
				theForm.setMyTerminal(userTerm.myTerminal);
				break;
			endif;
		endforeach;
	else
		theForm.setMyTerminal(self.myTerminal);
	endif;
	
	theForm.setBaseData(	context,	//_context : Integer;
							contextObject,	//_contextObj : CM_Object;
							null,	//_myObjectMatchCriteria : CM_ObjectMatchCriteria;
							self,	//_myListForm : CMUI_ObjectCriteriaListForm
							null	//_myParentForm: CM_BaseForm
							);
	
	theForm.showModal();
	
	return;
end;</source>
    </JadeMethod>
    <JadeMethod name="doDel" id="35f2434a-e699-431a-a029-8bade81aa6e8">
        <source>doDel();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 December 2013	cnwndl1	Initial creation

*/

vars
	obj : Object;
begin

	obj :=self.tblMain.accessRow( self.tblMain.row).itemObject;
	if obj = null or not obj.isKindOf(CM_ObjectMatchCriteria) then
		return;
	endif;
	
	app.myTrxDA.trxDeleteCMObject( obj.CM_Object, app.myPassport);
	
	self.loadTable();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doUpd" id="28e03ec4-1bfc-4468-9ab1-a438bd72adba">
        <source>doUpd();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 December 2013	cnwndl1	Initial creation	Par 33184

*/

vars
	obj : Object;
	theForm : CMUI_ObjectCriteriaLineForm;
	reeferForm : CMUI_ReeferAutoJobsForm;
begin

	obj :=self.tblMain.accessRow( self.tblMain.row).itemObject;
	if obj = null or not obj.isKindOf(CM_ObjectMatchCriteria) then
		return;
	endif;

	//03 Aug 2020	NDL	TFS 49581
	if self.context = CM_ObjectMatchCriteria.ReeferJobCriteriaInt then
		create reeferForm transient;
		reeferForm.setBaseData(	obj.CM_ReeferJobCriteria, self );
		reeferForm.showModal();
		self.loadTable();
		return;
	endif;
	
	create theForm transient;
	
	if self.context = CM_ObjectMatchCriteria.WagonRestrictionInt then
		theForm.setMyTerminal(obj.CM_CargoRestrictionCriteria.myTerminal);
	else
		theForm.setMyTerminal(self.myTerminal);
	endif;
	
	theForm.setBaseData(	context,	//_context : Integer;
							contextObject,	//_contextObj : CM_Object;
							obj.CM_ObjectMatchCriteria,	//_myObjectMatchCriteria : CM_ObjectMatchCriteria;
							self,	//_myListForm : CMUI_ObjectCriteriaListForm
							null	//_myParentForm: CM_BaseForm
							);
	theForm.show();
	
	return;
end;</source>
    </JadeMethod>
    <JadeMethod name="enableButtons" id="fd3d14a4-a1ef-48a4-96c1-87452e2e58b3">
        <source>enableButtons();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 December 2013	cnwndl1	Initial creation

*/

vars

	moreTerminals	: Boolean;
	obj : Object;
	term	: CM_Terminal;
	userTerm	: CM_UserTerminal;
	wagonMaster	: CM_WagonMaster;

begin
	obj :=self.tblMain.accessRow( self.tblMain.row).itemObject;

	
	self.btnAdd.enabled := true;
	if self.context = CM_ObjectMatchCriteria.WagonRestrictionInt then
		if not app.getMyUser.canDo( null, PmWagonCargoRestrict ) then
			self.btnAdd.enabled := false;
			self.btnUpd.enabled := false;
			self.btnDel.enabled := false;
			return;
		else
			// 34300 only enable add if there are more terminals to have restrictions
			if self.contextObject &lt;&gt; null then
				wagonMaster := self.contextObject.CM_WagonMaster;
				foreach userTerm in app.getMyUser.allUserTerminals do
					term := userTerm.myTerminal;
					if wagonMaster.getMyObjectMatchCriteriaFor( term ) = null then
						moreTerminals := true;
						break;
					endif;
				endforeach;
			endif;
			self.btnAdd.enabled := moreTerminals;
		endif;
		self.btnUpd.enabled := obj &lt;&gt; null;
		self.btnDel.enabled := obj &lt;&gt; null;
		
	elseif self.context = CM_ObjectMatchCriteria.VBSExclusionInt then	//15 May 2015	NDL	Par 36234
		self.btnUpd.enabled := obj &lt;&gt; null;
		self.btnDel.enabled := obj &lt;&gt; null;
		//Only allowed One set of Criteria
		self.btnAdd.enabled := self.tblMain.rows = self.tblMain.fixedRows;
		// TFS 2198 CNWAB1
		if not app.myCurrentUserCan(self.myTerminal, PmGteVehSchBgp) then
			self.btnAdd.enabled:= false;
			self.btnDel.enabled:= false;
			self.btnUpd.enabled:= false;
		endif;
		
	elseif self.context = CM_ObjectMatchCriteria.ReeferJobCriteriaInt then	//04 Aug 2020	NDL`	TFS 49581
		self.btnUpd.enabled := obj &lt;&gt; null;
		self.btnDel.enabled := obj &lt;&gt; null and app.myCurrentUserCan(self.myTerminal, PmAdmReeferAutoMaint);
		if not app.myCurrentUserCan(self.myTerminal, PmAdmReeferAutoView) then
			self.btnAdd.enabled:= false;
			self.btnUpd.enabled:= false;
		endif;
		
	endif;

	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initTable" id="25fa650a-418e-4caf-afd2-64019150d05b">
        <source>initTable();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 December 2013	cnwndl1	Initial creation	Par 33184

*/

vars

	heading : String;

begin

	self.tblMain.clear();
	self.tblMain.columns := 3;
	self.tblMain.rows := 1;
	
	if self.context = CM_ObjectMatchCriteria.VBSExclusionInt then //15 May 2015	NDL	Par 36234
		self.tblMain.columns := 1;
		self.tblMain.fixedColumns := 0;
		heading := app.getErrorString(Criteria_summary);
	elseif self.context = CM_ObjectMatchCriteria.WagonRestrictionInt then
		heading := app.getErrorString(Terminal) &amp; Tab &amp; app.getErrorString(Colour) &amp; Tab &amp; app.getErrorString(Criteria_summary);
	else
		heading := app.getErrorString(Seq) &amp; Tab &amp; app.getErrorString(Name) &amp; Tab &amp; app.getErrorString(Criteria_summary);
	endif;
	self.tblMain.setCellText(1,1,heading);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadTable" id="9cb8c1b6-e22e-4cdc-8c6b-afd18d5f5a21">
        <source>loadTable();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 December 2013	cnwndl1	Initial creation

*/

vars

	obj : Object;
	repFormatDict : CM_ReportFormatMatchCritDict;
	objMatchCriteria : CM_ObjectMatchCriteria;
	rowString : String;
	rowIndex : Integer;
	nextParent : CM_BaseForm;
	wagonMaster : CM_WagonMaster;
	vbst : CM_VehicleBookingTerminal;
	reeferCrit : CM_ReeferJobCriteria;
	iter : Iterator;

begin

	self.tblMain.rows := 1;
	
	if self.context &gt; 0 then
	
		if self.context = CM_ObjectMatchCriteria.ReeferJobCriteriaInt then
			iter := self.myTerminal.allReeferJobCriteria.createIterator;
			while iter.next( reeferCrit ) do	
				rowString := reeferCrit.getTableDisplayString;
				rowIndex := self.tblMain.addItem( rowString );
				self.tblMain.accessRow( rowIndex ).itemObject := reeferCrit;
			endwhile;
			self.enableButtons();
		
		elseif self.context = CM_ObjectMatchCriteria.VBSExclusionInt then	//15 May 2015	NDL	Par 36234
			vbst := self.contextObject.CM_VehicleBookingTerminal;
			obj := vbst.myExclusionCriteria;
			if obj &lt;&gt; null then
				rowString := obj.CM_ObjectMatchCriteria.getTableDisplayString;
				rowIndex := self.tblMain.addItem( rowString );
				self.tblMain.accessRow( rowIndex ).itemObject := obj;
			endif;
			self.enableButtons();
		
		elseif self.context = CM_ObjectMatchCriteria.WagonRestrictionInt then
		
			wagonMaster := self.contextObject.CM_WagonMaster;
			
			foreach obj in wagonMaster.allCargoRestrictionCriteria do
				if obj.isKindOf(CM_ObjectMatchCriteria) then
					rowString := obj.CM_ObjectMatchCriteria.getTableDisplayString;
					rowIndex := self.tblMain.addItem( rowString );
					self.tblMain.accessRow( rowIndex ).itemObject := obj;
					tblMain.accessCell( rowIndex, 2).backColor := obj.CM_CargoRestrictionCriteria.colour;
				endif;
			endforeach;
			self.enableButtons();		// 34300 enable/disable Add
			
		else
			create repFormatDict transient;
			self.myTerminal.getAlternateFormatsByContext( repFormatDict, self.context );
		
			foreach obj in repFormatDict do
				if obj.isKindOf(CM_ObjectMatchCriteria) then
					rowString := obj.CM_ObjectMatchCriteria.getTableDisplayString;
					rowIndex := self.tblMain.addItem( rowString );
					self.tblMain.accessRow( rowIndex ).itemObject := obj;
				endif;
			endforeach;
		
		endif;
		
	endif;
	
	if self.myParentForm &lt;&gt; null and self.myParentForm.class.name = "SOP_GateConfigForm" then
		if self.context = CM_ObjectMatchCriteria.VBSExclusionInt then	//15 May 2015	NDL	Par 36234
			self.myParentForm.sendMsg("rebuildVBSLblCaptions");
		else
			self.myParentForm.sendMsg("setAlternateBtnCaption");
		endif;
	endif;

epilog

	delete repFormatDict;
	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="setBaseData" id="537624ab-8fb4-4891-a891-fdcebcbc5d45">
        <updating/>
        <source>setBaseData( _parentForm : CM_BaseForm;
			_contextObject : CM_Object;
			_context : Integer
			) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 December 2013	cnwndl1	Initial creation	Par 33184

*/

vars

begin

	self.myParentForm := _parentForm;
	if _parentForm &lt;&gt; null then
		self.setMyTerminal( _parentForm.myTerminal );
	endif;
	
	self.context := _context;
	self.contextObject := _contextObject;

epilog

end;</source>
        <Parameter name="_parentForm" type="CM_BaseForm"/>
        <Parameter name="_contextObject" type="CM_Object"/>
        <Parameter name="_context" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="ee1c5c8d-4135-46e9-96f0-6efc8b6893d0">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 December 2013	cnwndl1	Initial creation	Par 33184
04/01/2017                    cnwrh7     TFS    2899 Cargo Attribute Filter for Driver Instructions

*/

vars

	capStr : String;

begin

	self.minimumHeight := 400;
	self.minimumWidth := 470;
	self.btnCancel.visible := false;
	self.btnOk.left := self.btnCancel.left;
	
	if self.context = CM_ObjectMatchCriteria.RoadReceiptReportInt then
		capStr := CM_ObjectMatchCriteria.RoadReceiptReportName;
	elseif self.context = CM_ObjectMatchCriteria.WagonRestrictionInt then
		capStr := CM_ObjectMatchCriteria.WagonRestrictionName;
		if self.contextObject &lt;&gt; null then
			capStr := self.contextObject.CM_WagonMaster.id &amp; "  " &amp; capStr;
		endif;
	elseif self.context = CM_ObjectMatchCriteria.VBSExclusionInt then	//15 May 2015	NDL	Par 36234
		capStr := CM_ObjectMatchCriteria.VBSExclusionName;
		if self.contextObject &lt;&gt; null then
			capStr := self.contextObject.CM_VehicleBookingTerminal.myTerminal.code &amp; "  " &amp; capStr;
		endif;
	elseif self.context =  CM_ObjectMatchCriteria.DriverCriteriaInt then	//TFS2899
		capStr := CM_ObjectMatchCriteria.DriverInstructionReportName;
	elseif self.context = CM_ObjectMatchCriteria.InterchangeCriteriaInt then	//11 Jan 2019	NDL	TFS 40479
		capStr := CM_ObjectMatchCriteria.InterchangeCriteriaName;
	elseif self.context = CM_ObjectMatchCriteria.RpDriverCriteriaInt then
		capStr := CM_ObjectMatchCriteria.RpDriverInstructionReportName;
	elseif self.context = CM_ObjectMatchCriteria.RoadGateCargoCheckInt then	//21 Oct 2019	NDL	TFS 46911
		capStr := CM_ObjectMatchCriteria.RoadGateCargoCheckName;
	elseif self.context = CM_ObjectMatchCriteria.ReeferJobCriteriaInt then	//30 Jul 2020	NDL	TFS 49581
		capStr := CM_ObjectMatchCriteria.ReeferJobCriteriaName;
	else
		capStr := "Unknown Object type!! " &amp; method.qualifiedName;
	endif;
	
	self.caption := capStr;


	inheritMethod();
	
	self.initTable();
	self.loadTable();
	
	self.enableButtons();

epilog

end;</source>
    </JadeMethod>
