    <JadeMethod name="vLabelsFrame_contextMenu" id="24b9aa66-788d-44e1-bce7-f1a9cd90a2a2">
        <updating/>
        <source>vLabelsFrame_contextMenu(frame: Frame input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
23 January 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	xLeft, 
	yTop : Real;
	bay :  CM_BayVoyage;
begin	
	xLeft := x;
	yTop := y;

	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);
	if conwin &lt;&gt; self.picSideBtm and conwin &lt;&gt; picSideTop then
		bay := null;
	else
		bay := self.myJobController.myVoyageDrawController.getBayFromX(y);
	endif;

	self.setupContextMenu(bay,null,null);
	self.popupMenu(mnuContextMenu, xLeft.Integer, yTop.Integer);
	return true;
epilog

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
