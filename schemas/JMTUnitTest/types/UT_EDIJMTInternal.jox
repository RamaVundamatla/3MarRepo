    <Constant name="UT_BESTPICK" id="87c9a268-5eb7-4faa-8c63-a8b0d418aeeb">
        <source>"RELEASEREQUEST
**IGNORE**,ACTION,REQUEST DATE,RELEASE REQUEST NUMBER,RELEASE TYPE (STRING),RELEASE BY TYPE,STATUS (BULK RELEASE),OPERATOR,CARRIER CODE,AVAILABILITY GRADES,CARGO TYPE DESCR,CLEAN,EMPTIES ONLY,ISO TYPE,ISO GROUP,QUANTITY,
,A,07/31/2018,UT_REL31012022,ROAD,YES,ACTIVE,MSL,,,CONT,,YES,45G0,,1,True
"</source>
        <type name="String"/>
    </Constant>
    <Constant name="WebMultiActionCount" id="698eccc7-a2d9-4b8d-9ffe-93e9d975eeee">
