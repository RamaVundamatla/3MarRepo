    <JadeMethod name="resetButtonState" id="6b200e68-661d-4a78-9508-ae6256b9047d">
        <updating/>
        <source>resetButtonState(_value: Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05/06/2024	navkc1 CR 63736 Task 63737: Jade - New Filter Control

*/
vars
	btn		: CMUI_ButtonForToolbarTblFilter;
	tmpStyle	: Integer;

begin

	tmpStyle := self.style;
	btn 	 := self.myBtnForToolbarTblFilter;

	if tmpStyle = Button.Style_Normal or
	   btn = null then
		return;
	endif;

	btn.value := _value;

	if tmpStyle = Button.Style_Auto2State then
		if _value then
			self.drawButtonDown();
			if self.myToolbar &lt;&gt; null then
				self.myToolbar.resetButtonStateForParent(self, btn.parent);
			endif;
		else
			self.drawButtonUp();
		endif;
	elseif self.style = Button.Style_2State then
		if _value then
			self.drawButtonDown();
		else
			self.drawButtonNormal();
		endif;
	endif;

	if btn.pictureDown &lt;&gt; null then
		if _value then 
			self.myToolbarPicture.picture := btn.pictureDown;
			self.myToolbarPictureCaption.picture := btn.pictureDown;
		else 
			self.myToolbarPicture.picture := btn.picture;
			self.myToolbarPictureCaption.picture := btn.picture;
		endif;
	endif;

end;</source>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="resetButtonsInGroup" id="2cbf1c0c-2b0f-45f8-b2ad-275b9fc045a0">
        <updating/>
        <source>resetButtonsInGroup(_value: Boolean; _parent: Window) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05/06/2024	navkc1 CR 63736 Task 63737: Jade - New Filter Control

*/
vars
	btn			: CMUI_ButtonForToolbarTblFilter;
	tmpStyle	: Integer;

begin

	btn := self.myBtnForToolbarTblFilter;
	tmpStyle := self.style;
	
	if btn.style &lt;&gt; Button.Style_Auto2State and
	   btn = null then
		return;
	endif;
	
	if btn.parent &lt;&gt; _parent then
		return;
	endif;
	
	self.resetButtonState(false);
	self.clearGraphics;

end;</source>
        <Parameter name="_value" type="Boolean"/>
        <Parameter name="_parent" type="Window"/>
    </JadeMethod>
    <JadeMethod name="setMyParent" id="7efa2644-4364-4218-8e14-febe416db065">
        <updating/>
        <source>setMyParent(_parent : CMUI_ToolbarFrameTableFilter) updating;
/*

Purpose:			

Parameters:			

