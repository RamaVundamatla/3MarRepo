    <JadeMethod name="showLocationEnquiryForm" id="18fe8257-2b03-4892-be2c-63c8a38b1c5b">
        <source>showLocationEnquiryForm();
// ---------------------------------------------------------------------------
// Created:     15 September 2003 by cnwrs2
// ---------------------------------------------------------------------------
vars
	table	: CM_DataTable;
	ta		: CM_TerminalArea;
	row		: Integer;
	
begin
	table	:= self.tblData;
	row 	:= table.row;
	
	if row &lt;= table.fixedRows then
		return;
	endif;

	ta := table.accessRow(row).itemObject.CM_TerminalArea;
	
	if ta = null then
		return;
	endif;
	
	// 10/05/2010 cnwmh5 #23880 - Start
	if ta.isKindOf(CM_IrregularBlockArea) then
		self.myAssistant.showGeneralCargoAreaForm(ta, self.myMasterMenuAction, false, false);
	else
		self.myAssistant.showLocationEnquiryForm(ta, self.myMasterMenuAction, false, false);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="showMonitorForSearch" id="c8cb6c6f-d898-4dd4-aff4-967367f87634">
        <updating/>
        <source>showMonitorForSearch() : CMIF_Monitor updating;
// ---------------------------------------------------------------------------
// Created:     15 March 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// 05/11/2012	cnwcs5	par 30475 - tidy up translations
vars
	cmifMonitor			: CMIF_Monitor;
begin
	cmifMonitor := app.myPassport.myCMIFMonitor;
	
	if cmifMonitor = null then
		create cmifMonitor transient;
		app.myPassport.setMyCMIFMonitor(cmifMonitor);
	endif;
	
	cmifMonitor.myParent := self;
	
	self.modalDialogShow(null, 
						app.getErrorString(Cancel), 
						app.getErrorString(Return), 
						null, 
						app.getErrorString1 (Terminal_areas_found, '0'),
						app.getErrorString1 (Containers_queried, '0'));
						
	self.frmModalDialog.zOrder(1);
	
	self.lblModalMessage.visible 	:= true;
	self.lblModalInfo.visible 		:= true;
	
	self.frmModalDialog.refreshNow;

	return cmifMonitor;
end;</source>
        <ReturnType type="CMIF_Monitor"/>
    </JadeMethod>
    <JadeMethod name="showSelector" id="42a3a142-a671-4d17-b08d-23257936095a">
        <updating/>
        <source>showSelector() protected, updating;
// ---------------------------------------------------------------------------
// Created:     17 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	selector			: CMUI_Selector;
	cargoBOLType		: CM_CargoBOLType;
	critLine			: CM_SelectorCriteriaLine;
	coll				: ObjectSet;
	queryType			: Integer;
begin
	
	selector := app.getSelectorForm(self, self.myMasterMenuAction);
	
	if selector = null then
		return;
	endif;
	
	selector.disableMnuEnquiry 			:= true;
	selector.myEnquiryCollectionClass 	:= CM_ObjectSet;
	selector.myTerminal 				:= self.myTerminal;	
	
	//set the mode of selector by the current filter cargo type
	cargoBOLType := app.myPassport.getDefaultCargoBOLType();
	
	if cargoBOLType &lt;&gt; null then //else it'll just open in tracked item mode
		//23 Nov 2009	NDL	CCMS 1028
		if cargoBOLType.id &gt;= BOLType_Min and cargoBOLType.id &lt;= BOLType_Max then
			queryType := CM_QueryDefinition.BOL_Query_Type;
		else
			queryType := CM_QueryDefinition.TrackedItem_Query_Type;
		endif;
		selector.myQDef := app.myRoot.allQueryDefinitionObjects[queryType, cargoBOLType.id];	
	endif;
	
	//check to see if a previous query in this session contained terminal areas criteria, and if so
	//populate that criteria line with the currently displayed areas, other wise set the
	//allDefaultTerminalAreas collection on the form and that will build a new criteria line for this property
	critLine := self.allSelectorCriteria['myTerminalArea', 'CM_Container'];

	if critLine &lt;&gt; null and CM_QReferenceIsOneOf.hasInstance(critLine.myQueryOperator) then
		coll := critLine.myQueryOperator.CM_QReferenceIsOneOf.allSelectionValues;
	else
		coll := selector.allDefaultTerminalAreas;
	endif;
	
	coll.clear;
	//th2  on 4/07/2007 for PAR14306 - just the selected TAs
	self.tblData.allSelectedObjects.copy(coll);
	
	selector.defaultSiteStr := TI_SITE_ONSITE_str;
	
	selector.show;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showYardAllocScreen" id="4df5eed1-7708-43d9-aca2-d66156187be0">
        <updating/>
        <source>showYardAllocScreen(_yalloc : CM_YardAllocation) updating;
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	yas: ObjectArray;
begin
	if _yalloc &lt;&gt; null then
		create yas transient;
		yas.add(_yalloc);
	endif;
	
	self.myAssistant.showYAMaintForm(yas, null,self, null, 0);
epilog
	delete yas;
end;</source>
        <Parameter name="_yalloc" type="CM_YardAllocation"/>
    </JadeMethod>
    <JadeMethod name="tblData_click" id="295770f0-248a-4c17-9c49-d44bebb470eb">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_click(table: Table input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	11 December 2006 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin

	//16 Jun 2010	NDL	Par 24369 - Should be able to edit Sub Block Stacks....
	if table.accessRow(table.row).itemObject.isKindOf(CM_SubBlockStack) then
		self.btnEdit.enabled := false;
		self.btnDelete.enabled := false;
	else
		self.btnEdit.enabled := true;
		self.btnDelete.enabled := true;
	endif;

	if table.accessRow(table.row).itemObject.isKindOf(CM_BulkArea) then
		self.btnAdjustStock.enabled := true;
	else
		self.btnAdjustStock.enabled := false;	
	endif;
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnEdit.enabled:= false;
		self.btnNew.enabled:= false;
		self.btnDelete.enabled:= false;
		self.tblData.userInputEnabled := false;
		
	endif;
end;
</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblData_contextMenu" id="7d0d0c69-f351-48c9-83f8-a7f8c1ec3329">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_contextMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
//-----------------------------------------------------------------------
//
//  Created by: cnwsh3
//
//	Date: 18 September 2003
//
//-----------------------------------------------------------------------
vars
	xLeft 	: Real;
	yTop	: Real;
	obj	 	: CM_Object;
begin


	xLeft := x;
	yTop := y;
	self.doShowContextMenu;
	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);   // convert x, y relative to form
	self.popupMenu(mnuTableContext, xLeft.Integer, yTop.Integer);

	return false;
end;</source>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblData_dblClick" id="49777ce7-748b-4b76-8951-e373b8160d48">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_dblClick(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:     15 September 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theRow	: Integer;
	
begin


	theRow := self.tblData.row;
	
	if theRow = 1 then
		self.resortTblData();
	elseif theRow &gt; 1 then
		self.showLocationEnquiryForm();
	endif;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblData_resizeColumn" id="e8509f8c-bb9b-491b-ac2d-68ca3c24478d">
        <controlMethod name="Table::resizeColumn"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_resizeColumn(_table: CM_DataTable input; _column: Integer input; _previousWidth: Integer input) updating;
//-----------------------------------------------------------------------
//  Created by: cnwsh3
//
//	Date: 11 September 2003
//-----------------------------------------------------------------------
// 01/11/2012	cnwcs5	par 30475 - using labout restrictions &amp; yard allocations instead of restrictions
vars
	numRows, tmpWidth, tmpHeight, idx	: Integer;
	colLR, colLRWidth, colYA, colYAWidth :Integer;
	tmpStr								: String;
begin
	// Labout Restrictions and Yard Alloctions bot use word wrap
	colLR := _table.getColumnByRowName(ETRow_LabourRestrictions);
	colYA := _table.getColumnByRowName(ETRow_YardAllocations);
	
	
	if _column = colLR or _column = colYA then
		if colLR &lt;&gt; 0 then
			colLRWidth := _table.accessColumn(colLR).width;
		endif;

		if colYA &lt;&gt; 0 then
			colYAWidth := _table.accessColumn(colYA).width;
		endif;

		numRows 	:= _table.rows;
		tmpWidth 	:= _table.accessColumn(_column).width;
	
		foreach idx in _table.fixedRows to numRows do
			if idx = 0 then
				continue;
			endif;
			
			self.setRowHeight (_table, idx, colLR, colLRWidth, colYA, colYAWidth);
		endforeach;
	endif;
end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_column" type="Integer" usage="input"/>
        <Parameter name="_previousWidth" type="Integer" usage="input"/>
    </JadeMethod>
