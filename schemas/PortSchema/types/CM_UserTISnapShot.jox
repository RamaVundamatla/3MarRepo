    <JadeMethod name="deleted" id="e1045227-4f66-43b2-a183-2edd1040d18e">
        <methodInvocation>mapping</methodInvocation>
        <source>deleted(set: Boolean; _value: Boolean io) mapping;
//----------------------------------------------------------------
//	Created:	10 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	if set then
		return;
	else
		if self.myTISnapShot &lt;&gt; null then
			_value := self.myTISnapShot.deleted;
		endif;
	endif;
	
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="cb2a7780-a4d9-45c9-b038-abdcc97933ff">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//----------------------------------------------------------------
//	Created:	09 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	changeNote	: CM_MessageUser;
begin
	if _attrName = ETRow_Ignore then
		return self.ignore.String;
	elseif _attrName = ETRow_LastChangedBy then
		if self.allChangeNotes.isNotEmpty then
			changeNote := self.allChangeNotes.last.CM_MessageUser;
			return changeNote.userCode;
		else
			return null;
		endif;
	elseif _attrName = ETRow_LastChangedDT then
		if self.allChangeNotes.isNotEmpty then
			changeNote := self.allChangeNotes.last.CM_MessageUser;
			return changeNote.createdDateTime.shortCurrentLocaleFormat;
		else
			return null;
		endif;
	elseif _attrName = ETRow_ChangeReason then
		if self.allChangeNotes.isNotEmpty then
			changeNote := self.allChangeNotes.last.CM_MessageUser;
			return changeNote.text;
		else
			return null;
		endif;
	else
		return inheritMethod(_attrName, _short);
	endif;
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyTransaction" id="b1b11571-14e6-47d3-9ffd-f7ba0e7346ee">
        <source>getMyTransaction(): CM_Transaction;
//
// cnwrs1 par 15848 (CCMS1468) feb 2008
//
vars

begin
	if self.myTransaction &lt;&gt; null then
		return self.myTransaction;
	else
		if self.myTISnapShot &lt;&gt; null then
			return self.myTISnapShot.myTransaction;
		else
			return null;
		endif;
	endif;
end;
</source>
        <ReturnType type="CM_Transaction"/>
    </JadeMethod>
