    <JadeMethod name="abort" id="f8cb9ef2-569c-4062-a603-81f68ea7bc48">
        <updating/>
        <source>abort() : Boolean updating;
// -------------------------------------------
// Created 23 August 2004 by cnwdvb1
// -------------------------------------------
/*

Date		Who		Reason
8/11/17 	jlgns1 	TFS 6960 QNS - Disk space issues and house keeping inside JMT
24 Nov 2017	jlgkpd1	TFS 6960 - change logging to highlight abort reason	

*/

vars
	now : TimeStamp;
begin

	now := app.actualTimeServer;	
	if self.myBGPRequest &lt;&gt; null and self.myBGPRequest.maxDurationMinutes &gt; 0 and now &gt;= self.finishTimeStamp then
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' maxDuration exceeded, aborting', LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		abortTransaction;
		return true;
	endif;
	
	self.isToAbort := false;
	if self.myBGPRequest &lt;&gt; null and self.myBGPRequest.doCallBackAbortCheck() then
		self.isToAbort := true;
		abortTransaction;
		return true;
	endif;
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="addNumCompleted" id="c35dc3f7-5624-4a3b-9568-15006a979b92">
        <updating/>
        <source>addNumCompleted(_numCompleted : Integer) updating;
// -------------------------------------------
// Created 25 August 2004 by cnwdvb1
// -------------------------------------------
vars

begin
	self.numCompleted := self.numCompleted + _numCompleted;
end;</source>
        <Parameter name="_numCompleted" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="createActivityHistory" id="1956e172-5bf0-496d-9006-96822db37ba8">
        <source>createActivityHistory(_msg : String; _isError : Boolean; _temp: Boolean);
// -------------------------------------------
// Created 25 August 2004 by cnwdvb1
// -------------------------------------------
//TFS 6960 jlgns1 8/11/17 QNS - Disk space issues and house keeping inside JMT
vars

	str : String;

begin

	// Want different timestamp for display.
	//process.sleep(1000);	// commented by  par 23656 12/04/2010
	if _msg = null and self.statsStr &lt;&gt; null then
		str := self.statsStr;
	elseif _msg &lt;&gt; null then
		str := _msg;
	else
		return;
	endif;
	process.sleep(0);//TFS 6960
	//process.sleep(1000);	// par 23656 12/04/2010  //TFS 6960
	
	if _isError then
		app.createActivityHistory(ActivityHistoryDBPurge, self.myTerminal, self, str, false, _temp);
	else
		app.createActivityHistory(ActivityHistoryDBPurge, self.myTerminal, self.myBGPRequest, str, false, _temp);
		app.writeLog(str, LogINFO);	//25 Nov 2019	NDL	TFS 47053
		
	endif;

end;</source>
        <Parameter name="_msg" type="String"/>
        <Parameter name="_isError" type="Boolean"/>
        <Parameter name="_temp" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doCheckForError" id="dd42d0ba-3e17-4d23-a53d-eda40219911d">
        <source>doCheckForError() protected;
// -------------------------------------------
// Created 26 August 2004 by cnwdvb1
// -------------------------------------------
vars

	str : String;

begin

	if not self.allErrors.isEmpty then
		str := self.currentArchiveType &amp; ' Errors (Dbl Click)';
		self.createActivityHistory(str, true, false);
	endif;


end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doErase" id="aeda6de1-706d-4ff6-8282-5603b5053a73">
        <source>doErase(_setAll : CM_ObjectSetActual input; _currentObject : CM_Object io) protected;
// -------------------------------------------
// Created 26 August 2004 by cnwdvb1
// -------------------------------------------
//TFS 6960 jlgns1 8/11/17 QNS - Disk space issues and house keeping inside JMT
constants
	MaxTransactionTime = 10000;		// 33002 Jan 2014 10 second max transaction time to limit lock duration, matching the default ini ServerTimeout setting

vars
	lastCommit,
	now			: Decimal[20];

begin

	lastCommit := app.relativeMachineTime();
	beginTransaction;

	foreach _currentObject in _setAll do
		// 33002 timed commits (within the blocked commits of the _setAll sizing), to minimise locking of the rest of the system
		now := app.relativeMachineTime();
		if now - lastCommit &gt; MaxTransactionTime then
			commitTransaction;
			lastCommit := app.relativeMachineTime();
			beginTransaction;
		endif;
		_currentObject.erase(NORMAL_ERASE);
	endforeach;
	
	commitTransaction;
	


end;</source>
        <access>protected</access>
        <Parameter name="_setAll" type="CM_ObjectSetActual" usage="input"/>
        <Parameter name="_currentObject" type="CM_Object" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doEraseBlockOfObjects" id="2382f98b-7767-4ce6-bdd2-2670ac0aa687">
        <updating/>
        <source>doEraseBlockOfObjects(_setAll, _setErrors : CM_ObjectSetActual input) : Boolean updating;
// -------------------------------------------
// Created 26 August 2004 by cnwdvb1
// -------------------------------------------
vars

	numOfLockExceptions,
	count,
	commitBlockSize 		: Integer;
	currentObj				: CM_Object;
	hadException,
	hadLockException		: Boolean;
	errTxt,
	msg						: String;
	str : String;
begin

	on Exception do self.xHandlerBlockCommit(exception, _setAll, _setErrors, currentObj, hadException);
	on LockException do self.xLockHandler(exception, hadLockException, numOfLockExceptions, errTxt, false);
	
	hadException := true;
	commitBlockSize := _setAll.size;
	while count &lt; commitBlockSize and (hadException or hadLockException) do
		if not hadLockException then
			count := count + 1;
		endif;
		hadException := false;
		hadLockException := false;
		self.doErase(_setAll, currentObj);
		if self.abort() then
			return false;
		endif;
		if numOfLockExceptions &gt;= self.Lock_Exception_Limit then
			msg := errTxt &amp; ' (' &amp; currentArchiveType &amp; ')';
			self.allErrors.add(msg);
			app.remoteErrorWarningToAlert(app.getErrorString(Garbage_Collection) &amp; ' ' &amp; msg, null, null, null, false, false);
			str := app.getErrorString(Garbage_Collection) &amp; ' ' &amp; msg;
			app.writeLog(str,LogINFO);	//25 Nov 2019	NDL	TFS 47053
			
			return false;
		endif;
	endwhile;
	return true;
end;</source>
        <Parameter name="_setAll" type="CM_ObjectSetActual" usage="input"/>
        <Parameter name="_setErrors" type="CM_ObjectSetActual" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doInitiateProcess" id="2e089d78-943e-40dd-a58c-d06cd1a595fa">
        <updating/>
        <source>doInitiateProcess() protected, updating;
// -------------------------------------------
// Created 26 August 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	self.allErrors.clear();
	self.statsStr := null;


end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doPurgeAgGatewayMessages" id="e905b16a-e1ae-48d0-ae1b-e55402996f14">
        <updating/>
        <source>doPurgeAgGatewayMessages() : Boolean protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
5th Sep 2025	navra1	Initial creation for //navra1 - MTN-35875- 5th Sep 2025-2
09 Sep 2025		navnk30	JIRA 35757: 7 - Use the "EWS History Retainment Period" in the AG Gateway ext web service create a service runs periodically and clears out EWS history older than the specified period
*/

vars
	errCode	: Integer;
	errTxt	: String;
	purgeBeforeDays : Integer;
	purgeBeforeDate : Date;
	aggatewayExtWebServ	:	CM_AgGatewayServiceDef;
	terminal : CM_Terminal;
	ewsAct : CM_EWSActivityAgGateway;
	errArr,
	ewsArr : CM_ObjectSetActual;
	sz : Integer;
	
	//	
	count, count2, completed, theSize   : Integer;
	iter,
	iter1   : Iterator;
	setAll,
    setErrors			: CM_ObjectSetActual;	
	ewsActivities : CM_EWSActivityByDateTime;
	//
begin

	on Exception do app.alertExceptionHandler(exception, null, app.getErrorString(Garbage_Collection), errCode, errTxt, true, false);
	
	self.doInitiateProcess;
	self.createActivityHistory('BEGIN ' &amp; app.getErrorString(Database_Purging) &amp; ' ' &amp; app.getErrorString(Aggateway_messages), false, false);
	
	create setAll transient;				//navra1 - MTN-36076 - 17th Sep 2025
	create ewsArr transient;				
	create errArr transient;
	create setErrors transient;				//navra1 - MTN-36076 - 17th Sep 2025
	
	foreach aggatewayExtWebServ in CM_AgGatewayServiceDef.instances do
		//purgeBeforeDays := aggatewayExtWebServ.retainmentPeriodDays;
		//purgeBeforeDays := 1;	//THIS NEEDS TO BE CHANGED TO THE CONFIGURED VALUE IN THE EXT WEB SERVICE(AS SHOWN ABOVE)
		purgeBeforeDays := aggatewayExtWebServ.msgRetentionPeriod;			//09-09-2025 navnk30 MTN-35757
		purgeBeforeDate := (app.actualTimeServer.Date - purgeBeforeDays);		
		terminal := aggatewayExtWebServ.myTerminal;
		
		//not good to loop inside a loop n2.. but..
		foreach ewsAct in CM_EWSActivityAgGateway.instances do
			if ewsAct.myTerminal &lt;&gt; terminal then
				continue;
			endif;
			
			if ewsAct.createdTime.date &lt; purgeBeforeDate then
				ewsArr.add(ewsAct);
			endif;
		endforeach;				
	endforeach;
	
	sz := ewsArr.size();	
	
	iter1 := ewsArr.createIterator();
	theSize:= ewsArr.size;
	
	while iter1.next(ewsAct) do
		count := count + 1; 
		
		setAll.add(ewsAct);
		
		if count = self.Commit_Block_Size_Medium then
			self.addNumCompleted(setAll.size);
			if not self.doEraseBlockOfObjects(setAll, setErrors) then
				return false;
			endif;
			setAll.clear();
			count := 0;
			if self.abort() then
				return false;
			endif;
			if self.numCompleted mod self.Activity_Progress_Count_Small = 0 then
				self.createActivityHistory(app.getErrorString2(Progress, app.getErrorString(Purged) &amp; ' ' &amp; self.numCompleted.String, theSize.String &amp; ' ' &amp; app.getErrorString(Aggateway_messages) &amp; ' ' &amp; app.getErrorString(Available)), false, false);
			endif;
		endif;
	endwhile;	
	
	if not setAll.isEmpty() then
		self.addNumCompleted(setAll.size);
		if not self.doEraseBlockOfObjects(setAll, setErrors) then
			return false;
		endif;
	endif;
	
	self.setStats("END " &amp; app.getErrorString(Purged) &amp; ' ' &amp; self.numCompleted.String &amp; ' ' &amp; app.getErrorString(Aggateway_messages) &amp; ' ' &amp; setErrors.size.String &amp; ' ' &amp; app.getErrorString(Errors));
	
	self.createActivityHistory("Purged "&amp; self.numCompleted.asStringJMT() &amp; ' ' &amp; app.getErrorString(Aggateway_messages), false, false);	
	
	return true;
	
epilog
	delete ewsArr;
	delete setAll;							//navra1 - MTN-36076 - 17th Sep 2025
	delete setErrors;						//navra1 - MTN-36076 - 17th Sep 2025
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPurgeArchivedLocations" id="11d46040-192a-4324-8831-081e36849404">
        <updating/>
        <source>doPurgeArchivedLocations() : Boolean protected, updating;
// -------------------------------------------
// Created 23 August 2004 by cnwdvb1
// -------------------------------------------
vars

begin
	self.doInitiateProcess();
	self.createActivityHistory(app.getErrorString(Database_Purging)&amp;' '&amp;app.getErrorString(Archived_Locations), false, false);
	app.myTrxDA.trxDeleteDBPurgeArchivedLns(self.myTerminal, self.date.TimeStamp.cnEcAddDays(1), self, app.myPassport);
	// Get stats if any.
	self.createActivityHistory(null, false, false);
	self.doCheckForError();
	return not self.isToAbort;	
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPurgeArchivedVoyages" id="c77a468b-3378-46a0-aa0c-885a137340b9">
        <updating/>
        <source>doPurgeArchivedVoyages() : Boolean protected, updating;
// -------------------------------------------
// Created 23 August 2004 by cnwdvb1
// -------------------------------------------
vars

	allVoyagesToPurge	: DynaDictionary;
	obj					: Object;
	voyage				: CM_Voyage;
	errCode				: Integer;
	errTxt				: String;
	rtnCode				: Boolean;

begin

	on Exception do app.alertExceptionHandler(exception, null, app.getErrorString(Garbage_Collection), errCode, errTxt, true, false);
	
	self.createActivityHistory(app.getErrorString(Database_Purging)&amp;' '&amp;app.getErrorString(Archived_Voyages), false, false);
	create allVoyagesToPurge transient;
	allVoyagesToPurge.setMembership(CM_Voyage);
	allVoyagesToPurge.addMemberKey("archivedDT", false, false);
	allVoyagesToPurge.endKeys(true);
	self.getArchivedVoyagesOldThanDate(allVoyagesToPurge);
	foreach obj in allVoyagesToPurge do
		errTxt := null;
		self.doInitiateProcess();
		voyage := obj.CM_Voyage;
//		voyage := '2416.1797'.asOid.CM_Voyage;
		self.createActivityHistory("Voyage "&amp;voyage.code &amp; ' archived ' &amp; voyage.archivedDT.date.shortFormatJMT(), false, false);
		app.myTrxDA.trxDeleteDBPurgeArchivedVoyage(voyage, self, app.myPassport);
		// Will get here if trx has been unsuccessful due to abort.
		rtnCode := self.isToAbort or self.abort();
		if rtnCode then
			return false;
		endif;
		if errTxt &lt;&gt; null then
			self.allErrors.add(errTxt);
		endif;
		self.createActivityHistory(null, false, false);
		self.doCheckForError();
	endforeach;
	return true;
epilog
	delete allVoyagesToPurge;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPurgeAttachFilesCargoTypes" id="94e1a04b-a196-4065-8e84-43b4c881bd0d">
        <updating/>
        <source>doPurgeAttachFilesCargoTypes(): Boolean protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 February 2023	navhl20	ChangeRequest 54900:[56518] EUP - Garbage Collection for Document Attachments

*/

vars
	date 		: TimeStamp;
	file 		: CM_FileData;
	iter		: Iterator;
	count, 
	theSize 	: Integer;
	deleted     : Integer; 
	term        : CM_Terminal;
begin
	self.doInitiateProcess();
	self.createActivityHistory(app.getErrorString(Database_Purging)&amp;' '&amp;app.getErrorString(Attachment_files_cargotypes), false, false);

	date 	:= self.date.TimeStamp;
	iter 	:= CM_FileData.instances.createIterator();
	theSize := CM_FileData.instances.size();
	term    := self.myTerminal;
	
	while iter.next(file) do
		if file.createdTime &lt; date then
			
			if file.myParent = null then
				continue;
			endif;
			
			if not file.myParent.isKindOf(CM_CargoBOLType) then
				continue;
			endif;
			
			if not file.myParent.CM_CargoBOLType.allTerminals.includes(term) then
				continue;
			endif;
			
			count := count + 1;
			if count mod self.Commit_Block_Size_Large = 0 then
				if self.abort() then
					return false;
				endif;
				if count mod self.Activity_Progress_Count_Large = 0 then
					self.createActivityHistory("Processed "&amp; count.String &amp; " of " &amp; theSize.String, false, true);
				endif;
			endif;
			app.myTrxDA.trxDeleteFile(file.myParent,file, app.myPassport);
			if app.myPassport.trxCompletedOK then
				deleted := deleted + 1;
			endif;
		endif;
	endwhile;
		
	self.createActivityHistory(null, false, false);
	self.doCheckForError();
	self.createActivityHistory("Purged " &amp; deleted.String &amp; " Attchment Files - Cargo Type records.", false, false);
	return not self.isToAbort;	
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPurgeAttachFilesContract" id="4e972170-ec2a-4dd4-8e69-eb1d64f12f8a">
        <updating/>
        <source>doPurgeAttachFilesContract(): Boolean protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 February 2023	navhl20	ChangeRequest 54900:[56518] EUP - Garbage Collection for Document Attachments

*/

vars
	date 		: TimeStamp;
	file 		: CM_FileData;
	iter		: Iterator;
	count, 
	theSize 	: Integer;
	deleted     : Integer; 
	term        : CM_Terminal;
begin
	self.doInitiateProcess();
	self.createActivityHistory(app.getErrorString(Database_Purging)&amp;' '&amp;app.getErrorString(Attachment_files_contracts), false, false);

	date 	:= self.date.TimeStamp;
	term 	:= self.myTerminal;
	iter 	:= CM_FileData.instances.createIterator();
	theSize := CM_FileData.instances.size();
	
	while iter.next(file) do
		if file.createdTime &lt; date then
			
			if file.myParent = null then
				continue;
			endif;
			
			if not file.myParent.isKindOf(CM_InvoiceContract) then
				continue;
			endif;
			
			if file.myParent.CM_InvoiceContract.myTerminal &lt;&gt; term then
				continue;
			endif;
			
			count := count + 1;
			if count mod self.Commit_Block_Size_Large = 0 then
				if self.abort() then
					return false;
				endif;
				if count mod self.Activity_Progress_Count_Large = 0 then
					self.createActivityHistory("Processed "&amp; count.String &amp; " of " &amp; theSize.String, false, true);
				endif;
			endif;
			app.myTrxDA.trxDeleteFile(file.myParent,file, app.myPassport);
			if app.myPassport.trxCompletedOK then
				deleted := deleted + 1;
			endif;
		endif;
	endwhile;
		
	self.createActivityHistory(null, false, false);
	self.doCheckForError();
	self.createActivityHistory("Purged " &amp; deleted.String &amp; " Attchment Files - Contract records.", false, false);
	return not self.isToAbort;	
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPurgeAttachFilesInvoices" id="f79cf246-6978-4b1a-aa2b-5754f6a786b5">
        <updating/>
        <source>doPurgeAttachFilesInvoices(): Boolean protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 February 2023	navhl20	ChangeRequest 54900:[56518] EUP - Garbage Collection for Document Attachments

*/

vars
	date 		: TimeStamp;
	file 		: CM_FileData;
	iter		: Iterator;
	count, 
	theSize		: Integer;
	deleted     : Integer;
	term        : CM_Terminal;
begin
	self.doInitiateProcess();
	self.createActivityHistory(app.getErrorString(Database_Purging)&amp;' '&amp;app.getErrorString(Attachment_files_invoices), false, false);

	date 	:= self.date.TimeStamp;
	term 	:= self.myTerminal;
	iter 	:= CM_FileData.instances.createIterator();
	theSize := CM_FileData.instances.size();
	
	while iter.next(file) do
		if file.createdTime &lt; date then
			if file.myParent = null then
				continue;
			endif;
			
			if not file.myParent.isKindOf(CM_Invoice) then
				continue;
			endif;
			
			if file.myParent.CM_Invoice.myTerminal &lt;&gt; term then
				continue;
			endif;
			
			count := count + 1;
			if count mod self.Commit_Block_Size_Large = 0 then
				if self.abort() then
					return false;
				endif;
				if count mod self.Activity_Progress_Count_Large = 0 then
					self.createActivityHistory("Processed "&amp; count.String &amp; " of " &amp; theSize.String, false, true);
				endif;
			endif;
			app.myTrxDA.trxDeleteFile(file.myParent,file, app.myPassport);
			if app.myPassport.trxCompletedOK then
				deleted := deleted + 1;
			endif;
		endif;
	endwhile;
		
	self.createActivityHistory(null, false, false);
	self.doCheckForError();
	self.createActivityHistory("Purged " &amp; deleted.String &amp; " Attchment Files - Invoice records.", false, false);
	return not self.isToAbort;	
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPurgeAttachFilesVoyages" id="a57d3700-cd11-488c-b279-e4dd13d206b0">
        <updating/>
        <source>doPurgeAttachFilesVoyages(): Boolean protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 February 2023	navhl20	ChangeRequest 54900:[56518] EUP - Garbage Collection for Document Attachments

*/

vars
	date 		: TimeStamp;
	file 		: CM_FileData;
	iter		: Iterator;
	count, 
	theSize 	: Integer;
	deleted     : Integer; 
	term		: CM_Terminal;
begin
	self.doInitiateProcess();
	self.createActivityHistory(app.getErrorString(Database_Purging)&amp;' '&amp;app.getErrorString(Attachment_files_voyages), false, false);

	date 	:= self.date.TimeStamp;
	term	:= self.myTerminal;
	iter 	:= CM_FileData.instances.createIterator();
	theSize := CM_FileData.instances.size();
	
	while iter.next(file) do
		if file.createdTime &lt; date then
			
			if file.myParent = null then
				continue;
			endif;
			
			if not file.myParent.isKindOf(CM_Voyage) then
				continue;
			endif;
			
			if file.myParent.CM_Voyage.myTerminal &lt;&gt; term then
				continue;
			endif;
			
			count := count + 1;
			if count mod self.Commit_Block_Size_Large = 0 then
				if self.abort() then
					return false;
				endif;
				if count mod self.Activity_Progress_Count_Large = 0 then
					self.createActivityHistory("Processed "&amp; count.String &amp; " of " &amp; theSize.String, false, true);
				endif;
			endif;
			
			app.myTrxDA.trxDeleteFile(file.myParent,file, app.myPassport);
			
			if app.myPassport.trxCompletedOK then
				deleted := deleted + 1;
			endif;
		endif;
	endwhile;
		
	self.createActivityHistory(null, false, false);
	self.doCheckForError();
	self.createActivityHistory("Purged " &amp; deleted.String &amp; " Attchment Files - Voyage records.", false, false);
	return not self.isToAbort;	
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPurgeAttachFilesWO" id="50051d30-d9ea-41a1-8067-96f114c27be9">
        <updating/>
        <source>doPurgeAttachFilesWO(): Boolean protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 February 2023	navhl20	ChangeRequest 54900:[56518] EUP - Garbage Collection for Document Attachments
10 Jul 2025 navah1	Task 35253: MTN - Fix tFileGarbageCollect Unit Test
*/

vars
	date 		: TimeStamp;
	file 		: CM_FileData;
	iter		: Iterator;
	count, 
	theSize 	: Integer;
	deleted     : Integer; 
	term        : CM_Terminal;
	workOrder	: CM_WorkOrder;
begin
	self.doInitiateProcess();
	self.createActivityHistory(app.getErrorString(Database_Purging)&amp;' '&amp;app.getErrorString(Attachment_files_workorders), false, false);

	date    := self.date.TimeStamp;
	term    := self.myTerminal;									
	iter    := CM_FileData.instances.createIterator();
	theSize := CM_FileData.instances.size();
	
	while iter.next(file) do 
		
		//if file.createdTime &lt; date then                                                 //10.07.2025 navah1 #35253
		if file.createdTime &lt; date or (app.isJMTUnitTest() and file.dateTime &lt; date) then //10.07.2025 navah1 #35253
			
			if file.myParent = null then
				continue;
			endif;
		
			if not file.myParent.isKindOf(CM_WorkOrder) then
				continue;
			endif;
			
			if file.myParent.CM_WorkOrder.myTerminal &lt;&gt; term then
				continue;
			endif;
			count := count + 1;
			
			if count mod self.Commit_Block_Size_Large = 0 then
				if self.abort() then
					return false;
				endif;
				if count mod self.Activity_Progress_Count_Large = 0 then
					self.createActivityHistory("Processed "&amp; count.String &amp; " of " &amp; theSize.String, false, true);
				endif;
			endif;
			
			app.myTrxDA.trxDeleteFile(file.myParent,file, app.myPassport);
			
			if app.myPassport.trxCompletedOK then
				deleted := deleted + 1;
			endif;
		endif;
	endwhile;
		
	self.createActivityHistory(null, false, false);
	self.doCheckForError();
	self.createActivityHistory("Purged " &amp; deleted.String &amp; " Attchment Files - Work Orders records.", false, false);
	
	return not self.isToAbort;	
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPurgeBookingRefTis" id="bcd39918-e463-4c78-afa5-cf64fcb518f7">
        <updating/>
        <source>doPurgeBookingRefTis() : Boolean protected, updating;
// -------------------------------------------
// Created 02 01 2007 by cnwyl1
// -------------------------------------------
//TFS 6960 jlgns1 8/11/17 QNS - Disk space issues and house keeping inside JMT
vars
	date 		: TimeStamp;
	terminal 	: CM_Terminal;
	bookingRef 	: CM_BookingRef;
	iter		: Iterator;
	count, theSize : Integer;
begin
	self.doInitiateProcess();
	self.createActivityHistory(app.getErrorString(Database_Purging)&amp;' '&amp;app.getErrorString(BookingRef), false, false);

	date := self.date.TimeStamp;
	terminal := self.myTerminal;
	
	iter := terminal.allBookingRefsByRef.createIterator();
	theSize := terminal.allBookingRefsByRef.size;
	while iter.next(bookingRef) do
		if bookingRef.createdTime &lt; date then
			count := count + 1;
			if count mod Commit_Block_Size_Large = 0 then
				if self.abort() then
					return false;
				endif;
				if count mod self.Activity_Progress_Count_Large = 0 then
					self.createActivityHistory("Processed "&amp; count.String &amp; " of " &amp; theSize.String, false, true);
				endif;
			endif;
			app.myTrxDA.trxDeleteBookingRef(bookingRef, null, app.myPassport);
		endif;
	endwhile;
		
	self.createActivityHistory(null, false, false);
	self.doCheckForError();
	self.createActivityHistory("Purged " &amp; count.String &amp; " Booking Reference records.", false, false);
	return not self.isToAbort;	
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPurgeCargoPhotos" id="dedbcd5d-f9cc-42bf-95f2-1b881e056f57">
        <updating/>
        <source>doPurgeCargoPhotos() : Boolean protected, updating;
// -------------------------------------------
// Created 01 Dec 2009 by cnwdz2
// -------------------------------------------
vars

	trackedItem	: CM_TrackedItem;
	errCode	: Integer;
	errTxt	: String;
	count   : Integer;
	iter,
	iter1   : Iterator;
	voyage  : CM_Voyage;
begin
	on Exception do app.alertExceptionHandler(exception, null, app.getErrorString(Garbage_Collection), errCode, errTxt, true, false);
	
	self.doInitiateProcess;
	self.createActivityHistory(app.getErrorString(Database_Purging)&amp;' '&amp;app.getErrorString(Cargo_Photos), false, false);
	
	self.doPurgeCargoPhotosForTIDict(self.myTerminal.allOnsiteTIsByIdCargoType);
	self.doPurgeCargoPhotosForTIDict(self.myTerminal.allOffsiteTIsByIdCargoType);
	self.doPurgeCargoPhotosForTIDict(self.myTerminal.allTbaTIsByIdCargoType);
	self.doPurgeCargoPhotosForTIDict(self.myTerminal.allRRPTIsByIdCargoType);	//16 Mar 2020	NDL	TFS 47004
	self.doPurgeCargoPhotosForTIDict(self.myTerminal.allNotifiedTIsByIdCargoType);
	self.doPurgeCargoPhotosForTIDict(self.myTerminal.allDeletedTIsByIdCargoType);
	
	//search unarchived voyages for on-ship tis 
	iter := self.myTerminal.allVoyagesByCode.createIterator();
	while iter.next(voyage) do
		self.doPurgeCargoPhotosForTIDict(voyage.allOnshipTIsByIdCargoType);
		self.doPurgeCargoPhotosForTIDict(voyage.allOffloadedTIsByIdCargoType);
	endwhile;
	
	iter1 := self.myTerminal.allVoyagesArchived.createIterator();
	while iter1.next(voyage) do
		self.doPurgeCargoPhotosForTIDict(voyage.allOnshipTIsByIdCargoType);
		self.doPurgeCargoPhotosForTIDict(voyage.allOffloadedTIsByIdCargoType);
	endwhile;
	
	self.createActivityHistory("Purged "&amp;self.numCompleted.asStringJMT()&amp;' '&amp;app.getErrorString(Cargo_Photos), false, false);
	return true;
epilog
	delete iter;
	delete iter1;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPurgeCargoPhotosForTIDict" id="f09bc88c-c2fc-47c1-bca8-e72eb59d14af">
        <updating/>
        <source>doPurgeCargoPhotosForTIDict(_dict:CM_TrackedItemDicts) : Boolean protected, updating;
// -------------------------------------------
// Created 23 August 2004 by cnwdvb1
// -------------------------------------------
//TFS 6960 jlgns1 8/11/17 QNS - Disk space issues and house keeping inside JMT
//08 Apr 2025	navhl20 Bug MTN-34530: MTN - Large Number of trxDeleteDBCargoPhotosForTI during garbage collection
vars
	trackedItem	: CM_TrackedItem;
	errCode	: Integer;
	errTxt	: String;
	count   : Integer;
	iter   : Iterator;
begin
	iter := _dict.createIterator();
	while iter.next(trackedItem) do
	
		if trackedItem.allAttachments.isEmpty then			//08.04.2025 navhl20 #34530
			continue;
		endif;
		
		count := count + 1;
		if count mod Commit_Block_Size_Large = 0 then
			if self.abort() then
				return false;
			endif;
			if count mod self.Activity_Progress_Count_Large = 0 then
				self.createActivityHistory("Processed "&amp;self.numCompleted.asStringJMT(), false, true);
			endif;
		endif;
		app.myTrxDA.trxDeleteDBCargoPhotosForTI(trackedItem, self.date.TimeStamp, self, app.myPassport);
		if self.abort() then
			return false;
		endif;
		self.createActivityHistory(null, false, false);
	endwhile;
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_dict" type="CM_TrackedItemDicts"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPurgeDDExtractHistory" id="2d0ea42b-088c-4e18-8b1b-7d88856aa155">
        <updating/>
        <source>doPurgeDDExtractHistory(): Boolean protected, updating;
// -------------------------------------------
// do purge data dump extract history
// Created Aug 2005 by cnwrs1
// -------------------------------------------
//TFS 6960 jlgns1 8/11/17 QNS - Disk space issues and house keeping inside JMT
vars

	allddExtHistoryToPurge: DynaDictionary;
	obj: Object;
	ddExtHistory: CM_DataDumpExtractHistory;
	errCode: Integer;
	errTxt: String;
	rtnCode: Boolean;
	theSize, count : Integer;
begin

	on Exception do app.alertExceptionHandler(exception, null, app.getErrorString(Garbage_Collection), errCode, errTxt, true, false);
	
	create allddExtHistoryToPurge transient;
	self.createActivityHistory(app.getErrorString(Database_Purging)&amp;' '&amp;"Data Dump Extract History", false, false);
	allddExtHistoryToPurge.setMembership(CM_DataDumpExtractHistory);
	allddExtHistoryToPurge.addMemberKey("createdTime", false, false);
	allddExtHistoryToPurge.endKeys(true);
	self.getddExtHistoryOldThanDate(allddExtHistoryToPurge);
	theSize := allddExtHistoryToPurge.size;
	foreach obj in allddExtHistoryToPurge do
		errTxt := null;
		self.doInitiateProcess();
		count := count + 1;
		if count mod Commit_Block_Size_Large = 0 then
			if self.abort() then
				return false;
			endif;
			if count mod self.Activity_Progress_Count_Large = 0 then
				self.createActivityHistory("Processed "&amp;count.String&amp;" of "&amp;theSize.String, false, true);
			endif;
		endif;
		ddExtHistory := obj.CM_DataDumpExtractHistory;
//		self.createActivityHistory(ddExtHistory.className.String &amp; ' - ' &amp; ddExtHistory.createdTime.date.shortFormatJMT(), false, false);
		app.myTrxDA.trxDeleteDDExtractHistory(ddExtHistory, app.myPassport);
		// Will get here if trx has been unsuccessful due to abort.
		rtnCode := self.isToAbort or self.abort();
		if rtnCode then
			return false;
		endif;
		if errTxt &lt;&gt; null then
			self.allErrors.add(errTxt);
		endif;
//		self.createActivityHistory(null, false, false);
		self.doCheckForError();
	endforeach;
	self.createActivityHistory("Purged "&amp;theSize.String&amp;" Data Dump Extract History records.", false, false);
	return true;

epilog
	delete allddExtHistoryToPurge;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPurgeDiscrepancies" id="42eda684-24ba-4125-85c5-e6a31ddc39d1">
        <updating/>
