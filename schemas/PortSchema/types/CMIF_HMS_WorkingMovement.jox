    </JadeMethod>
    <JadeMethod name="setResourcesUsed" id="a7708c7e-dd78-447c-b6aa-26c11b7c482f">
        <updating/>
        <source>setResourcesUsed(_fromMovement : HMS_VoyageMovement; _fromWorkingMovement : CMIF_HMS_WorkingMovement) updating;
//-----------------------------------------
// Created: February 2005 By: cnwgd1
//-----------------------------------------				 
vars
 	permResourceUsed : HMS_ResourceUsed;
 	newWorkResourceUsed,
 	tmpWorkResourceUsed : CMIF_HMS_ResourceUsed;
begin

	if _fromWorkingMovement &lt;&gt; null then
		// Create newWorkingResourceUsed objs for each workingResourceUsed object in _fromWorkingMovement.allWorkingResUsed
	 	foreach tmpWorkResourceUsed in _fromWorkingMovement.allWorkingResUsed do
	 		create newWorkResourceUsed transient;
	  		newWorkResourceUsed.myWorkingMovement := self;
	  		newWorkResourceUsed.myViewController := self.myViewController;
	 		newWorkResourceUsed.myPersistentResourceUsed := tmpWorkResourceUsed.myPersistentResourceUsed;
	 		newWorkResourceUsed.myResource := tmpWorkResourceUsed.myResource;
	 		newWorkResourceUsed.myResourceType := tmpWorkResourceUsed.myResourceType; 		 		
	  		newWorkResourceUsed.notYetSaved := tmpWorkResourceUsed.notYetSaved;
			newWorkResourceUsed.fromDateTime := tmpWorkResourceUsed.fromDateTime;
			newWorkResourceUsed.toDateTime := tmpWorkResourceUsed.toDateTime;
			newWorkResourceUsed.unitsUsed := tmpWorkResourceUsed.unitsUsed;  		
			newWorkResourceUsed.isCharged := tmpWorkResourceUsed.isCharged;  		
			newWorkResourceUsed.isPartOfContract := tmpWorkResourceUsed.isPartOfContract;  								
	  	endforeach;

 	elseif _fromMovement &lt;&gt; null then

 		// This copies permanent movement information to a working movement and 
 		// Create workingResourceUsed objs for each permanentResourceUsed object
	 	foreach permResourceUsed in _fromMovement.allResourceUsed do
	 		create newWorkResourceUsed transient;
			newWorkResourceUsed.myWorkingMovement := self;
			newWorkResourceUsed.myViewController := self.myViewController;
			newWorkResourceUsed.notYetSaved := false; 	 		
	 		newWorkResourceUsed.myPersistentResourceUsed := permResourceUsed;
	 		newWorkResourceUsed.myResource := permResourceUsed.myResource;
	 		newWorkResourceUsed.myResourceType := permResourceUsed.myResourceType;
			newWorkResourceUsed.fromDateTime := permResourceUsed.fromDateTime;
			newWorkResourceUsed.toDateTime := permResourceUsed.toDateTime;
			newWorkResourceUsed.unitsUsed := permResourceUsed.unitsUsed;
			newWorkResourceUsed.isCharged := permResourceUsed.myVTMISTransaction &lt;&gt; null;  		
			newWorkResourceUsed.isPartOfContract := permResourceUsed.partOfContract;  											
	  	endforeach;	
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'No Resources created');
	endif;	      
	
end;</source>
        <Parameter name="_fromMovement" type="HMS_VoyageMovement"/>
        <Parameter name="_fromWorkingMovement" type="CMIF_HMS_WorkingMovement"/>
    </JadeMethod>
    <JadeMethod name="setToPreferredBerthMarks" id="516842a5-37e7-4ece-ac3d-050f72ca4834">
        <updating/>
        <source>setToPreferredBerthMarks() : Boolean updating;

vars
	ship:			CM_Vessel;
	berthPref:		HMS_BerthPreference;
	targetBerth:	HMS_Berth;
	voyageData:		HMS_VoyageData;
	waterOnLeftOfWharf : Boolean;
	shipStart, shipEnd : Decimal[12,2];
	tmpSideTo : Integer;	
begin
   	// This method returns the preferred marks for the specified berth if
   	// the exist, else the ship is centred on the berth
	targetBerth := self.myBerth;
	if targetBerth = null then
		return false;
	endif;
		
	if self.myPersistentMovement &lt;&gt; null then
		voyageData := self.myPersistentMovement.myHMSVoyageData;
		// Check collection of preferred berths on ship for this berth
		if voyageData &lt;&gt; null then
			berthPref := voyageData.allBerthPreferencesByName.getAtKey(targetBerth.code);
		endif;
	endif;

	if berthPref &lt;&gt; null then 
		// Target berth is a preferred berth - set bow and stern marks
		/* WAS...
		self.bowMarkTo := berthPref.defaultBowMark;
		self.sternMarkTo := berthPref.defaultSternMark;
		self.sideTo := berthPref.orientation;		
		*/
		// This will set the marks for the orientation of the ship and water to wharf
		berthPref.getDefaultMarks(voyageData.dim_LengthOverall, self.sideTo, self.bowMarkTo, self.sternMarkTo);
	    return true;

	elseif voyageData &lt;&gt; null then
		// Target berth is not a preferred berth - centre ship on berth
        return self.clonedMove_CentreShip(voyageData.dim_LengthOverall);
	endif;
	
	return false;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="timesOverlap" id="5618af78-53dd-4b00-aa03-241c0caec611">
        <source>timesOverlap( otherArrivalMove : CMIF_HMS_WorkingMovement ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 May 2014	cnwndl1	Initial creation	Par 34175

*/

vars

	workMove : CMIF_HMS_WorkingMovement;

	myRangeStartDT : TimeStamp;
	myRangeEndDT : TimeStamp;
	hisRangeStartDT : TimeStamp;
	hisRangeEndDT : TimeStamp;

begin

	if otherArrivalMove = null then
		return false;
	endif;

	myRangeStartDT := self.occursOnDT;
	workMove := self.getMovementNext();	
	if workMove &lt;&gt; null then
		myRangeEndDT := workMove.occursOnDT;
		workMove := null;
	else	
		myRangeEndDT := null;
	endif;

	hisRangeStartDT := otherArrivalMove.occursOnDT;
	workMove := otherArrivalMove.getMovementNext();	
	if workMove &lt;&gt; null then
		hisRangeEndDT := workMove.occursOnDT;
	else
		hisRangeEndDT := null;
	endif;
	
	workMove := null;

	workMove := self.getMovementNext();	
	if workMove &lt;&gt; null then
		myRangeEndDT := workMove.occursOnDT;
		workMove := null;
	else
		myRangeEndDT := null;
	endif;
	
	if myRangeEndDT = null and hisRangeEndDT = null then
		//can't check with out at least one range
		return false;
	endif;
	
	if myRangeEndDT &lt;&gt; null and hisRangeEndDT &lt;&gt; null then
		//web have two complete ranges
		if ( myRangeStartDT &lt;= hisRangeStartDT ) and ( hisRangeStartDT &lt;= myRangeEndDT ) then
			return true;
		elseif ( myRangeStartDT &lt;= hisRangeEndDT ) and ( hisRangeEndDT &lt;= myRangeEndDT ) then
			return true;
		elseif ( hisRangeStartDT &lt;= myRangeStartDT ) and ( myRangeStartDT &lt;= hisRangeEndDT ) then
			return true;
		elseif ( hisRangeStartDT &lt;= myRangeEndDT ) and ( myRangeEndDT &lt;= hisRangeEndDT ) then
			return true;
		else	
			return false;
		endif;
	elseif myRangeEndDT &lt;&gt; null then
		//we have our range and his start only
		if ( myRangeStartDT &lt;= hisRangeStartDT ) and ( hisRangeStartDT &lt;= myRangeEndDT ) then
			return true;
		else	
			return false;
		endif;
	elseif hisRangeEndDT &lt;&gt; null then
		//web have his range and our start only
		if ( hisRangeStartDT &lt;= myRangeStartDT ) and ( myRangeStartDT &lt;= hisRangeEndDT ) then
			return true;
		else	
			return false;
		endif;
	endif;
	
	
	
	

epilog

end;</source>
        <Parameter name="otherArrivalMove" type="CMIF_HMS_WorkingMovement"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateController" id="548ee2d1-d485-4908-bbe6-eeadebcdd562">
        <updating/>
        <source>updateController() updating;

vars

begin

end;</source>
    </JadeMethod>
    <JadeMethod name="updateForMoveType" id="d16d10c9-7b79-4509-85cf-17a57ef7fc8a">
        <updating/>
        <source>updateForMoveType(moveType : String) updating;
/* 
Updates the movement to make it reflect the move type passed in. This happens
for example after we add a new movement in front of this one and have to adjust
timings etc
*/
vars

begin
	if moveType=HMSMovementTypeArrival then
		self.relativeOrderTimeLines:=myHarbour.defaultOrderTimesArrive[1];
		self.relativeOrderTimePlaunch:=myHarbour.defaultOrderTimesArrive[2];
		self.relativeOrderTimeTugs:=myHarbour.defaultOrderTimesArrive[3];
		self.locationPilotLaunch:=AlongSide;
		self.locationTug:=OnStation;
	elseif moveType=HMSMovementTypeShift then
		self.relativeOrderTimeLines:=myHarbour.defaultOrderTimesShift[1];
		self.relativeOrderTimeTugs:=myHarbour.defaultOrderTimesShift[2];
		self.locationPilotLaunch:=AlongSide;
		self.locationTug:=AlongSide;
	elseif moveType=HMSMovementTypeDeparture then
		self.relativeOrderTimeLines:=myHarbour.defaultOrderTimesDepart[1];
		self.relativeOrderTimePlaunch:=myHarbour.defaultOrderTimesDepart[2];
		self.relativeOrderTimeTugs:=myHarbour.defaultOrderTimesDepart[3];
		self.locationPilotLaunch:=OnStation;
		self.locationTug:=AlongSide;
	endif;

end;</source>
        <Parameter name="moveType" type="String"/>
    </JadeMethod>
    <JadeMethod name="updateMovementNext" id="86a88794-50f9-465f-9e5d-2b5b3d1b035d">
        <source>updateMovementNext();
//This adds marine services to a movement that previously did not require them. MS are now
//required because the preceeding movement has been added or changed.
vars
	nextMovement : CMIF_HMS_WorkingMovement;

begin
 	nextMovement := self.getMovementNext;

  	if nextMovement = null then
   		return;
   	endif;

    if nextMovement.requiresMarineServices = true then
	//if selectedMovement.myBerth.noMarineServices = false and didNotRequireMarineServices then
        nextMovement.checkAndSetInitialValues;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="validateBollardSelections" id="9e2b3661-3bfa-43de-afa2-1836436b8938">
        <source>validateBollardSelections(_waterOnLeft : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Oct 2022	navsj20	ChangeRequest 54739: EUP - PLAN - Berth planning by bollards
29 Nov 2022	navdap1	TFS 55614 MTN Issue with Movement Maintenance and Berthage
*/

vars
	bridgeMark	:	Decimal[9,2];
	bowMarkMax	: 	Boolean;
	sideToUse	:	Integer;	// TFS 55614
begin
	bridgeMark := self.getBridgeMarkTo.Decimal;
	// TFS 55614 start
	sideToUse := self.sideTo;
	if sideToUse = null then
		sideToUse := OrientPortSideTo;
	endif;
	// TFS 55614 end
	// water on left, ship is port side to - bow mark is min, stern mark is max
	// water on right, ship is starboard side to - bow mark is min, stern mark is max
	if (_waterOnLeft and sideToUse = OrientPortSideTo) or (not _waterOnLeft and sideToUse = OrientStarboardSideTo) then
		bowMarkMax := false;
	// water on left, ship is starboard side to - bow mark is max, stern mark is min
	// water on right, ship is port side to - bow mark is max, stern mark is min
	elseif (_waterOnLeft and sideToUse = OrientStarboardSideTo) or (not _waterOnLeft and sideToUse = OrientPortSideTo) then
		bowMarkMax := true;
	endif;
	if (self.bowMarkTo &lt; bridgeMark or bridgeMark &lt; self.sternMarkTo) and bowMarkMax then
		app.raiseCMException3(PortSideBollardPositionInvalid, self.bowMarkTo.String, bridgeMark.String, self.sternMarkTo.String, null, null);
	endif;
	if (self.bowMarkTo &gt; bridgeMark or bridgeMark &gt; self.sternMarkTo) and not bowMarkMax then
		app.raiseCMException3(StarBoardSideBollardPosInvalid, self.bowMarkTo.String, bridgeMark.String, self.sternMarkTo.String, null, null);
	endif;
epilog

end;</source>
        <Parameter name="_waterOnLeft" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateMovement" id="be42922a-afed-46a2-96a1-1b28f6ade038">
        <source>validateMovement();

vars

begin

	// This method runs all validation checks on this movement
	
	if (not self.isLogicalBerth())
	and self.moveType &lt;&gt; HMSMovementTypeDeparture then
		
		// Only check ship position for non-logical berths
		self.check_WharfLockouts();

		self.check_WharfOverHang();
		
		// This actually sets the aft and fore clearance.
		// Now done before the validation
		/*if (not self.check_Clearances(false)) then
			rtnValue := false;
		endif;*/

 	endif;
	
	self.check_TidalWindow();

end;</source>
    </JadeMethod>
    <JadeMethod name="validateMvmntPilotDetails" id="8b4093b1-746a-49ef-bc21-4acb7f038c68">
        <source>validateMvmntPilotDetails(_passport : CM_Passport input) : Boolean;
/*

Purpose:			If pilots have a launch, it has to be 'theirs' only.
					A pilot can only be on one launch per movement.
					Almost identical to HMS_VoyageMovement::validate_MvmntPilotDetails
Parameters:			

Return Value:		

Date		Who		Reason
17 May 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement

*/

vars
	pilotsUsed : HMS_PilotByCodeDict;
	pilotLaunchesUsed : HMS_PilotLaunchByCodeDict;
	mvmntPilotDetails : HMS_MovementPilotDetails;
	valid : Boolean;
	voyage : CM_Voyage;
	voyageGlobal : CM_VoyageGlobal;
	persVoyageMovement : HMS_VoyageMovement;
begin
	valid := true;
	create pilotsUsed transient;
	create pilotLaunchesUsed transient;
	foreach mvmntPilotDetails in self.allMovementPilotDetails do
		if mvmntPilotDetails.myPilot &lt;&gt; null then
			if not pilotsUsed.includes(mvmntPilotDetails.myPilot) then
				pilotsUsed.add(mvmntPilotDetails.myPilot);
			else // pilots can only be used once per movement
				valid := false;	// raise exception then fall through to pilot launch check		
				app.raiseCMException(Pilot_used_once_movemen, null, null);
			endif;
		else // tried to use a blank pilot
			valid := false;		
			app.raiseCMException(Input_require_pilot_field, null, null);
		endif;
		if mvmntPilotDetails.myPilotLaunch &lt;&gt; null then // if launch not used in this movement yet, add it to the 'used' list
			if not pilotLaunchesUsed.includes(mvmntPilotDetails.myPilotLaunch) then
				pilotLaunchesUsed.add(mvmntPilotDetails.myPilotLaunch);
			else
				if mvmntPilotDetails.myWorkingMovement &lt;&gt; null then // shouldn't be null, but...
					persVoyageMovement := mvmntPilotDetails.myWorkingMovement.myPersistentMovement;
					if persVoyageMovement &lt;&gt; null then
						voyageGlobal := persVoyageMovement.myVoyageGlobal;
						if voyageGlobal &lt;&gt; null then
							voyage := voyageGlobal.allVoyages.first;					
							if voyage &lt;&gt; null then // if trying to reuse launch and it's a Pelindo terminal, 'Can only have one pilot per pilot launch'
								if voyage.myVoyageProcess.isMTNWOProcess then //epr TFS 51963 11/10/21
									valid := false;
									app.raiseCMException(Only_have_pilot_pilot_launch, null, null);
									break;
								endif;
							endif;
						endif;
					endif;
				endif;
			endif;
		endif;
	endforeach;
	return valid;
epilog
	delete pilotsUsed;
	delete pilotLaunchesUsed;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateResourcesUsed" id="1a9188dc-61f9-4950-8c00-f0a0a1c5678a">
        <source>validateResourcesUsed(_passport : CM_Passport input) : Boolean;
//--------------------------------------------------
// Created:	28 February 2005 By: cnwgd1
//--------------------------------------------------
vars
	tmpWorkResUsed : CMIF_HMS_ResourceUsed;
begin
	//Check Resource used required data	is set if they are charging it
	foreach tmpWorkResUsed in self.allWorkingResUsed do
		if tmpWorkResUsed.isCharged then
			if (not tmpWorkResUsed.validateForCharging(_passport)) then
				return false;
			endif;
		elseif tmpWorkResUsed.myResourceType = null then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Resource Type', null, null);
			app.raiseCMException(Input_required_field_resorceTy, null, null); // cnwdb2	PAR 35364
			return false;		
		endif;
	endforeach;
	
	return true;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
