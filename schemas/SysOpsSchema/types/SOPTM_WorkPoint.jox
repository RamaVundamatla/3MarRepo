    <JadeMethod name="doExtractRates" id="badd53a5-784a-4008-97f2-74b2b5400d3d">
        <source>doExtractRates( _workPoint : CM_WorkPoint );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 November 2018	jlgndl1	Initial creation	TFS 41980

*/

vars

	msg : String;

	fileCMD: CMDFileSave;
	fileName : String;
	file : File;

	wpcr : CM_WorkPointCargoRates;
	
	hdr : String;

begin

	if _workPoint = null then
		msg := app.getErrorString(Work_point_selected);
		app.msgBox( msg, app.getErrorString(Warning), MsgBox_OK_Only );
		return;
	endif;

	create fileCMD transient;
	create file transient;
	
	fileCMD.cnEcSetFilters( CNEC_FILE_FILTER_XML, true, 1 );
	fileCMD.fileName := _workPoint.code &amp; XML_Filetype;
	
	if fileCMD.open = 0 then	
		file.mode := File.Mode_Output;
		file.fileName := fileCMD.fileName;
		file.allowReplace := true;
	else
		return;
	endif;
	
	file.writeLine('&lt;?xml version="1.0" encoding="UTF-8"?&gt;');
	file.writeLine(J_key_LessThan.Character &amp; _workPoint.allWorkPointRates.class.name &amp; " " &amp; 'document="' &amp;  _workPoint.code &amp; '"' &amp; J_key_GreaterThan.Character);
	foreach wpcr in _workPoint.allWorkPointRates do
		file.writeLine(J_key_LessThan.Character &amp; wpcr.class.name &amp; J_key_GreaterThan.Character);
		wpcr.exportAsXMLDoc(file);
		if wpcr.myCargoType &lt;&gt; null then
			file.writeLine(J_key_LessThan.Character &amp; CM_WorkPointCargoRates::myCargoType.name &amp; J_key_GreaterThan.Character &amp; wpcr.myCargoType.abbreviation &amp; self.formatAsXMLSuffix(CM_WorkPointCargoRates::myCargoType.name) );
		endif;
		if wpcr.myProduct &lt;&gt; null then
			file.writeLine(J_key_LessThan.Character &amp; CM_WorkPointCargoRates::myProduct.name &amp; J_key_GreaterThan.Character &amp; wpcr.myProduct.code &amp; self.formatAsXMLSuffix(CM_WorkPointCargoRates::myProduct.name) );
		endif;
		file.writeString(self.formatAsXMLSuffix(wpcr.class.name));
	endforeach;
	file.writeString(self.formatAsXMLSuffix(_workPoint.allWorkPointRates.class.name));
	
	hdr := app.getErrorString(Complete);
	msg := app.getErrorString2( Work_point_rates_extrac_comple, _workPoint.code, file.fileName );
	app.msgBox( msg, hdr, MsgBox_OK_Only );

epilog

	if file &lt;&gt; null then
		file.close;
	endif;
	delete file;
	delete fileCMD;

end;</source>
        <Parameter name="_workPoint" type="CM_WorkPoint"/>
    </JadeMethod>
    <JadeMethod name="doLoadRates" id="38a75a70-677e-4216-9ee4-fdd4d221404b">
        <source>doLoadRates( _workPoint : CM_WorkPoint input; _table : CM_DataTable input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 November 2018	jlgndl1	Initial creation	TFS 41980

*/

vars

	theForm : SOP_TableMaintForm;
	
	msg : String;

	fileCMD: CMDFileOpen;
	fileName : String;
	file : File;

	wpcr : CM_WorkPointCargoRates;
	wpcrXML : String;
	xmlDoc : JadeXMLDocument;
	xmlElement : JadeXMLElement;
	xmlElements : JadeXMLElementArray;
	subElement : JadeXMLElement;
	
	dailyHoursWorkable : Decimal[4,2];
	jobType : Integer;
	myCargoType : CM_CargoType;
	myProduct : CM_Product;
	targetRatePHQuantity : Integer;
	targetRatePHVolume : Decimal[16,4];
	targetRatePHWeight : Decimal[16,4];
	transferType : Integer;
	
	selectedDict : CM_WorkPointByCodeDict;
	templateWpcr : CM_WorkPointCargoRates;
	allTemplates : CM_WPRatesByCargoTypeProduct;
	
	rawTextData : String;
	hdr : String;
	row : Integer;
	wp : CM_WorkPoint;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815

begin

	theForm := self.myForm;

	if _workPoint = null then
		msg := app.getErrorString(Work_point_selected);
		app.msgBox( msg, app.getErrorString(Warning), MsgBox_OK_Only );
		return;
	endif;

	create fileCMD transient;
	create file transient;
	
	fileCMD.cnEcSetFilters( true, 1, CNEC_FILE_FILTER_XML );
	
	if fileCMD.open = 0 then	
		file.kind :=	File.Kind_Unknown_Text;
		file.mode := File.Mode_Input;
		file.shareMode := File.Share_Read;
		file.fileName := fileCMD.fileName;
	else
		return;
	endif;
	
	while not file.endOfFile() do
		wpcrXML := wpcrXML &amp; file.readLine.trimBlanks;
	endwhile;
	
	if wpcrXML.trimBlanks = null then
		msg := app.getErrorString(NO_Data);
		app.msgBox( msg, app.getErrorString(Warning), MsgBox_OK_Only );
		return;
	endif;
	
	create xmlDoc transient;
	xmlDoc.parseString(wpcrXML);
	
	xmlElement := xmlDoc.rootElement;
	if xmlElement = null then
		msg := "File formating error, no root element";
		app.msgBox( msg, app.getErrorString(Warning), MsgBox_OK_Only );
		return;
	endif;
	
	create xmlElements transient;
	xmlDoc.getElementsByTagName( CM_WorkPointCargoRates.name, xmlElements );

	if xmlElements.isEmpty then
		msg := "File formating error, no '" &amp; CM_WorkPointCargoRates.name &amp; "' elements found.";
		app.msgBox( msg, app.getErrorString(Warning), MsgBox_OK_Only );
		return;
	endif;
	
	create selectedDict transient;
	selectedDict.add( _workPoint );
	create allTemplates transient;
	foreach xmlElement in xmlElements do
	
		dailyHoursWorkable := null;
		jobType := null;
		myCargoType := null;
		myProduct := null;
		targetRatePHQuantity := null;
		targetRatePHVolume := null;
		targetRatePHWeight := null;
		transferType := null;
		
		subElement := xmlElement.getElementByTagName( CM_WorkPointCargoRates::dailyHoursWorkable.name );
		if subElement &lt;&gt; null then
			rawTextData := subElement.textData.trimBlanks;
			if rawTextData &lt;&gt; null then
				if not rawTextData.isDecimal then
					msg := "File formating error, dailyHoursWorkable [" &amp; rawTextData &amp; "] must be decimal";
				else
					dailyHoursWorkable := rawTextData.Decimal;
				endif;
			endif;
		endif;
	
		subElement := xmlElement.getElementByTagName( CM_WorkPointCargoRates::jobType.name );
		if subElement &lt;&gt; null then
			rawTextData := subElement.textData.trimBlanks;
			if rawTextData &lt;&gt; null then
				if not rawTextData.isInteger then
					msg := "File formating error, jobType [" &amp; rawTextData &amp; "] must be an integer";
				else
					jobType := rawTextData.Integer;
				endif;
			endif;
		endif;
		
		subElement := xmlElement.getElementByTagName( CM_WorkPointCargoRates::myCargoType.name );
		if subElement &lt;&gt; null then
			rawTextData := subElement.textData.trimBlanks;
			if rawTextData &lt;&gt; null then
				myCargoType := app.myRoot.getCargoTypeFromAbbrev( rawTextData );
				if myCargoType = null then
					msg := "File formating error, myCargoType [" &amp; rawTextData &amp; "] no matching Cargo Type with this abbreviation found";
				else
					subElement := xmlElement.getElementByTagName( CM_WorkPointCargoRates::myProduct.name );
					if subElement &lt;&gt; null then
						rawTextData := subElement.textData.trimBlanks;
						if rawTextData &lt;&gt; null then
							myProduct := myCargoType.getProductFromCode( rawTextData );
							if myProduct = null then
								msg := "File formating error, myProduct [" &amp; rawTextData &amp; "] no matching Sub Cargo Type with this code within Cargo Type [" &amp; myCargoType.abbreviation &amp; "] found";
							endif;
						endif;
					endif;
				endif;
			endif;
		endif;
		
		subElement := xmlElement.getElementByTagName( CM_WorkPointCargoRates::targetRatePHQuantity.name );
		if subElement &lt;&gt; null then
			rawTextData := subElement.textData.trimBlanks;
			if rawTextData &lt;&gt; null then
				if not rawTextData.isInteger then
					msg := "File formating error, targetRatePHQuantity [" &amp; rawTextData &amp; "] must be an integer";
				else
					targetRatePHQuantity := rawTextData.Integer;
				endif;
			endif;
		endif;
		
		subElement := xmlElement.getElementByTagName( CM_WorkPointCargoRates::targetRatePHVolume.name );
		if subElement &lt;&gt; null then
			rawTextData := subElement.textData.trimBlanks;
			if rawTextData &lt;&gt; null then
				if not rawTextData.isDecimal then
					msg := "File formating error, targetRatePHVolume [" &amp; rawTextData &amp; "] must be decimal";
				else
					targetRatePHVolume := rawTextData.Decimal;
				endif;
			endif;
		endif;
		
		subElement := xmlElement.getElementByTagName( CM_WorkPointCargoRates::targetRatePHWeight.name );
		if subElement &lt;&gt; null then
			rawTextData := subElement.textData.trimBlanks;
			if rawTextData &lt;&gt; null then
				if not rawTextData.isDecimal then
					msg := "File formating error, targetRatePHWeight [" &amp; rawTextData &amp; "] must be decimal";
				else
					targetRatePHWeight := rawTextData.Decimal;
				endif;
			endif;
		endif;
		
		subElement := xmlElement.getElementByTagName( CM_WorkPointCargoRates::transferType.name );
		if subElement &lt;&gt; null then
			rawTextData := subElement.textData.trimBlanks;
			if rawTextData &lt;&gt; null then
				if not rawTextData.isInteger then
					msg := "File formating error, transferType [" &amp; rawTextData &amp; "] must be an integer";
				else
					transferType := rawTextData.Integer;
				endif;
			endif;
		endif;
		
		if msg &lt;&gt; null then
			app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
			return;
		endif;
	
		create templateWpcr transient;
		templateWpcr.setProxy(	dailyHoursWorkable,	//_dailyHoursWorkable : Decimal;
								jobType,	//_jobType : Integer;
								myCargoType,	//_myCargoType : CM_CargoType;
								myProduct,	//_myProduct : CM_Product;
								null,	//_myWorkPoint : CM_WorkPoint;
								targetRatePHQuantity,	//_targetRatePHQuantity : Integer;
								targetRatePHVolume,	//_targetRatePHVolume : Decimal;
								targetRatePHWeight,	//_targetRatePHWeight : Decimal;
								transferType	//_transferType : Integer
								);
		allTemplates.add( templateWpcr );
		
	endforeach;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxPropagateWorkPointRates( selectedDict, allTemplates, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog( app.getErrorString(Load), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings );
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return;
		
	endwhile;
	
	if app.myPassport.trxCompletedOK() then
		hdr := app.getErrorString(Complete);
		msg := app.getErrorString1( Work_point_rates_load_comple, _workPoint.code );
		app.msgBox( msg, hdr, MsgBox_OK_Only );
		//refresh teh row.
		row := _table.row;
		if row &gt; _table.fixedRows and row &lt;= _table.rows then
			wp := _table.accessRow( row ).itemObject.CM_WorkPoint;
			if wp &lt;&gt; null then
				_table.setCellText( row, 1, wp.getAttributeStringForDefArray( _table.allTblDataEntRows ) );
				theForm.showThumbnailData(wp);
			endif;
		endif;
	endif;

epilog

	if file &lt;&gt; null then
		file.close;
	endif;
	delete file;
	delete fileCMD;
	delete xmlDoc;
	delete xmlElements;
	
	delete selectedDict;
	if allTemplates &lt;&gt; null and not allTemplates.isEmpty then
		allTemplates.purge();
	endif;
	delete allTemplates;

end;</source>
        <Parameter name="_workPoint" type="CM_WorkPoint" usage="input"/>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuContext1Click" id="16ba0f3b-61d5-477b-8d8b-e45610fc375e">
        <updating/>
        <source>doMnuContext1Click(theMenuItem: MenuItem) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 November 2018	jlgndl1	Initial creation	TFS 41980

*/

vars

	wpCopyForm : SOP_WPRatesCopyForm;
	theForm : SOP_TableMaintForm;
	workPoint : CM_WorkPoint;	

begin

	theForm := self.myForm;
	if theForm = null then
		return;
	endif;
	
	workPoint := theForm.myCurrentObject.CM_WorkPoint;
	if workPoint = null or workPoint.allWorkPointRates.isEmpty then
		return;
	endif;
	
	wpCopyForm := app.loadForm(SOP_WPRatesCopyForm, SOP_Assistant, false, false, false, theForm.myTerminal, null).SOP_WPRatesCopyForm;
	
	if wpCopyForm = null then
		return;
	endif;

	wpCopyForm.setMyWpToCopy( workPoint );
	wpCopyForm.showModal();
	
	
epilog

end;</source>
        <Parameter name="theMenuItem" type="MenuItem"/>
    </JadeMethod>
    <JadeMethod name="doMnuContext2Click" id="f9dff05b-834d-4efc-a301-203dd242761f">
        <updating/>
        <source>doMnuContext2Click(theMenuItem: MenuItem) updating;
/*

Purpose:			

Parameters:			

Return Value:		

