    <JadeMethod name="validationExceptionHandler" id="d43d8866-cddc-4b5a-b8ec-fac3972aa606">
        <source>validationExceptionHandler(_exObj: Exception; _passport: CM_Passport input): Integer protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 August 2008	cnwrd1	Initial creation
//ccms 1660 cnwrd1 

*/

vars

begin

	if _exObj.isKindOf(CM_Exception) and _exObj.CM_Exception.isWarning then
		// code for CCMS-1660
		if _passport.allWarningsToIgnore.includesKey(_exObj.errorCode) then  //includes(_exObj.errorCode) then
			return Ex_Continue;
		endif;
		app.addWarningFullPassport(_exObj.errorCode, _exObj.extendedErrorText, _exObj.CM_Exception.userString, _exObj.CM_Exception.myUserObject, _passport);
		return Ex_Continue;
	endif;
	if _exObj.isKindOf(CM_Exception) then
		app.addErrorFullPassport(_exObj.errorCode, _exObj.extendedErrorText, _exObj.CM_Exception.userString, _exObj.CM_Exception.myUserObject, _passport);
		if _exObj.continuable then
			return Ex_Continue;
		endif;
	endif;
	return Ex_Pass_Back;
end;</source>
        <access>protected</access>
        <Parameter name="_exObj" type="Exception"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="verifyEDIData" id="4fa739d5-10be-4a6f-9de7-9093f32b9ea3">
        <updating/>
        <source>verifyEDIData(): Integer updating;

vars
//	voyage :	CM_Voyage;
begin

	on Exception do validationExceptionHandler(exception, app.myPassport);
	app.setContinueCMExceptions(true);
//	voyage := self.getVoyage(self.importVoyageCode);
//	if voyage = null then
//		app.raiseCMException2(ERR_IMP_VOY_CODE,self.importVoyageCode, 'import voyage code', self.importVoyageCode, null);
//	endif;

// Par 21809 - PHB - Export Voyage is now obtained from the individual TrackedItem lines
/*	voyage := null;
	voyage := self.getVoyage(self.exportVoyageCode);
	if voyage = null then
		app.raiseCMException2(ERR_EXP_VOY_CODE,self.exportVoyageCode, 'export voyage code', self.exportVoyageCode, null);
	endif;
*/
epilog	
	return app.myPassport.allErrorWarnings.size;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="verifyEDIDataTIs" id="66f287ec-4b79-4b9f-b925-bc536a46629d">
        <updating/>
        <source>verifyEDIDataTIs( _passport : CM_Passport input ) : Integer updating;
/* Changes

Date		Name	TFS#		Description
============================================================================
30 Jun 2014	cnwrs1	Par 34702 	Add support for JMT XML
04 Aug 2014	cnwrs1	Par 34668	EDI Status can be wrong if doDeferredUpdate fails
13 May 2016	cnwns1	TFS 488 	Multi Timezone Support
03 Sep 2019 jlgka1 	TFS 45332 	STWR - Better Forms and Interfaces for EDI Module
20 Oct 2020	jlgmd1	TFS 50204	Refactor progress updates to superclass method
============================================================================*/

vars
	// cnwrl1 14/07/2010 PAR 23499 - start of coding
	partsDone			: Integer;
	partsInJob			: Integer;
	progressStr			: String;
	progressTS			: TimeStamp;
	// cnwrl1 14/07/2010 PAR 23499 - end of coding
	ediTI				: CM_EDITrackedItem;
	allRealTIs    		: CM_TISet;
	ediTranshipTI		: CM_EDITranshipTI;
	ediFile				: CM_EDIFile;
	realTI				: CM_TrackedItem;			// cnwrl1 07/07/2010 PAR 24592
	realBOL				: CM_BOL;					// cnwrl1 07/07/2010 PAR 24592
	terminal			: CM_Terminal;			// cnwrl1 03/08/2010 PAR 24991
	voyageCode 			: String;
	voyage 				: CM_Voyage;
begin
	// cnwrl1 14/07/2010 PAR 23499 - start of coding
	partsInJob	:= self.allEDITrackedItems.size();
	partsDone	:= null;
	progressStr	:= app.getString( Verifying_Loaded_Details, partsInJob.display );
	progressTS	:= app.actualTimeServer;// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.updateProgress(progressTS, progressStr, partsInJob, partsDone, true, _passport);
	// cnwrl1 14/07/2010 PAR 23499 - end of coding
	
	// cnwrl1 03/08/2010 PAR 24991
	// Improve the efficiency by passing in the terminal rather than getting it each time around the loops.
	terminal	:= self.getMyTerminal();
	
	//ccms 1660 cnwrd1 
	//populate _passport with errors to ignore.
	ediFile := self.myEDIFile;	 // ccms1117 cnwrs1 29 Apr 2010
	if ediFile &lt;&gt; null and ediFile.myEDIFileType &lt;&gt; null and ediFile.myEDIFileType.isKindOf(CM_EDIFileTypeUser) then
		ediFile.myEDIFileType.CM_EDIFileTypeUser.myEDIFileConfig.allWarningsToIgnore.copy(_passport.allWarningsToIgnore);
	endif;
	
	// Arm our base exception handlers
	on Exception do validationExceptionHandler(exception, _passport);
	app.setContinueCMExceptions(true);
	
	foreach ediTI in self.allEDITrackedItems discreteLock do
		// cnwrl1 14/07/2010 PAR 23499 - start of coding
		partsDone			:= partsDone + 1;
		self.updateProgress(progressTS, progressStr, partsInJob, partsDone, false, _passport);
		// cnwrl1 14/07/2010 PAR 23499 - end of coding
		
		ediTranshipTI	:=	ediTI.CM_EDITranshipTI;
		voyageCode := ediTranshipTI.getVoyageCode;
		voyage := self.getMyTerminal.lookupVoyage(voyageCode, null, false);
		if voyage = null then
			app.raiseCMException2(ERR_VOYAGE_CODE, ediTranshipTI.getVoyageCode, 'voyage code', null, self);
			return 1;
		endif;
		
		
		// cnwrl1 07/07/2010 PAR 24592 - start of coding
		// make sure there is at least 1 TrackedItems to be process for each EDITrackedItem
		realTI	:= ediTranshipTI.getRealTI( terminal );
		if realTI = null then
			realBOL	:= ediTranshipTI.getRealBOLIn( terminal );
			if realBOL = null then
				// could happen if entered say a none exsistent BOL or a BOL with no TrackedItems.
				// This stops a programmers error message in CM_UtilityCreateAgent::utlCreateTrackedItemsTranShip
				app.raiseCMException( EDI_Tranship_Has_No_Valid_TIs, ETRow_Id, ediTranshipTI );
				continue;
			endif;
		endif;

		ediTranshipTI.verifyIdAndIsoType( terminal );
		ediTranshipTI.verifyDischargePort(terminal);	// 27/6/19 MAP TFS45340
		ediTranshipTI.verifyDestinationPort();		// cnwrl1 13/08/2010 PAR 25355
		ediTranshipTI.verifyCommodity();
		ediTranshipTI.verifyExportVoyageCode();	// Par 21809 - PHB - Export Voyage is now obtained from the individual TrackedItem lines
	endforeach;
	
	// cnwrl1 14/07/2010 PAR 23499 - start of coding
	self.updateProgress(progressTS, progressStr, partsInJob, partsDone, true, _passport);
	// cnwrl1 14/07/2010 PAR 23499 - end of coding
	
	return app.myPassport.allErrorWarnings.size;
	
epilog
	_passport.allWarningsToIgnore.clear(); //ccms 1660 cnwrd1 
	delete allRealTIs;
	
end;
</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
