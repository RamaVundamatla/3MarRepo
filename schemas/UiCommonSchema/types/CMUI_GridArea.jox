        <Parameter name="_theTI" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="addTerminalLabel" id="84e6a102-d21f-4579-933d-aa7ab4ebe255">
        <source>addTerminalLabel(_theX, _theY : Integer;aTA : CM_TerminalArea);
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theTA : CM_TerminalArea;
	anObject : CM_Object;
	removeObj, idx : CM_Object;
	theX, theY : Integer;
	iter01 : Iterator;
begin

	iter01 := self.allPointLabels.createIterator;
	
	while iter01.next(anObject) do
		if global.isValidObject(anObject) then
			if CM_TerminalArea.hasInstance(anObject) then
				if anObject.CM_TerminalArea.id.trimBlanks = aTA.id then
					return;
				endif;
			else
				return;
			endif;
		else
			removeObj := anObject;
			theX := iter01.getCurrentKey(1).Integer;
			theY := iter01.getCurrentKey(2).Integer;
		endif;
	endwhile;

	if removeObj &lt;&gt; null then
		self.allPointLabels.removeKeyEntry(theX, theY, removeObj);
	endif;

	//epr par 37377 18/1/16
	self.allTerminalAreas.addNoDuplicates(aTA,false);
	// Here we are putting in any labels, plus X &amp; Y so that at the end of drawing we can put the sub block stack labels on the grid
	self.allPointLabels.putAtKey(_theX,_theY, aTA);
epilog
	delete iter01;
end;</source>
        <Parameter name="_theX" type="Integer"/>
        <Parameter name="_theY" type="Integer"/>
        <Parameter name="aTA" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="clearAllSelectedItems" id="4cd164ad-feb6-4e22-ae29-f8167478ad22">
        <source>clearAllSelectedItems();
// ---------------------------------------------------------------------------
// Created:     11 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpSet	: CMUI_GridPointSet;
	tmpPoint	: CMUI_GridPoint;
	invalidPoint	: Boolean;
begin

	self.allSelectedTrackedItems.clear;

	create tmpSet transient;
	self.allSelectedPoints.copy(tmpSet);
	self.allSelectedPoints.clear;

	on Exception do app.handleDeletedObject(exception, tmpPoint, invalidPoint);//4 Nov 2009	cnwdz2 21292	
	foreach tmpPoint in tmpSet do
		tmpPoint.drawSelf(self.myGridAreaFrame);
	endforeach;


epilog
	delete tmpSet;

end;</source>
    </JadeMethod>
    <JadeMethod name="clearAllSelectedItemsAlt" id="e7f9ac18-442d-46ef-9f47-1e05a4e1d51a">
        <source>clearAllSelectedItemsAlt();
// ---------------------------------------------------------------------------
// Created:     11 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpSet	: CMUI_GridPointSet;
	tmpPoint	: CMUI_GridPoint;
	
begin
	self.allSelectedTrackedItems.clear;

	// ALT key selected points
	create tmpSet transient;
	self.allSelectedPointsAlt.copy(tmpSet);
	self.allSelectedPointsAlt.clear;
	foreach tmpPoint in tmpSet do
		tmpPoint.drawSelf(self.myGridAreaFrame);
	endforeach;

epilog
	delete tmpSet;

end;</source>
    </JadeMethod>
    <JadeMethod name="convertPosToClosestGridColumn" id="f9b1354f-b6b0-458f-82d6-07d05498b6e7">
        <source>convertPosToClosestGridColumn(x: Real;_isOutsideEdge : Boolean io) : CMUI_GridColumn;// serverExecution;


vars
	foundCol,tmpCol		: CMUI_GridColumn;
	midRowX				: Real;
	iter 				: Iterator;
	rowSpacing			: Integer;
begin
	
	// Do the row first as it is "non-variable" length.  At some
	// point columns in each row may be variable length (RJS Dec/02)
	if x &lt; self.allGridColumns.first.x1 then
		return self.allGridColumns.first;
	elseif x &gt;= self.allGridColumns.last.x2 then
		_isOutsideEdge:=true;
		return self.allGridColumns.last;
	endif;
	
	
	iter:=self.allGridColumns.createIterator;
	while iter.next(tmpCol ) do
		if x &gt;= tmpCol.x1 and
		   x &lt; tmpCol.x2 then

		   foundCol := tmpCol;
		   midRowX:= tmpCol.x1 + ((tmpCol.x2- tmpCol.x1)/2);
		   
		
			if x &gt; midRowX then
				if iter.next(tmpCol) then
					foundCol:=tmpCol;
				else
					_isOutsideEdge:=true;
				endif;
			endif;
			break;
		endif;
	endwhile;
	
	return foundCol;
epilog
	delete iter;

end;</source>
        <Parameter name="x" type="Real"/>
        <Parameter name="_isOutsideEdge" type="Boolean" usage="io"/>
        <ReturnType type="CMUI_GridColumn"/>
    </JadeMethod>
    <JadeMethod name="convertPosToClosestGridRow" id="9e88c04b-8123-4a39-a058-7e538ae740fe">
        <source>convertPosToClosestGridRow(y : Real;_isOutsideEdge : Boolean io) : CMUI_GridRow;// serverExecution;


vars
	foundPoint,tmpPoint	: CMUI_GridPoint;
	foundRow,tmpRow		: CMUI_GridRow;
	
	midRowY				: Real;
	iter 				: Iterator;
begin

	_isOutsideEdge:=false;
	// Do the row first as it is "non-variable" length.  At some
	// point columns in each row may be variable length (RJS Dec/02)
	if y &lt; self.allGridRows.first.y1 then
		return self.allGridRows.first;
	elseif y &gt;= self.allGridRows.last.y2 then
		_isOutsideEdge:=true;
		return self.allGridRows.last;
	endif;
	

	iter:=self.allGridRows.createIterator;
	while iter.next(tmpRow ) do
		if y &gt;= tmpRow.y1 and
		   y &lt; (tmpRow.y2 + getRowSpacing)  then

		   foundRow := tmpRow;
		   midRowY:= tmpRow.y1 + ((tmpRow.y2- tmpRow.y1)/2);
		   
		
			if y &gt; midRowY then
				if iter.next(tmpRow) then
					foundRow:=tmpRow;
				else
					_isOutsideEdge:=true;
				endif;
			endif;
			break;
		endif;
	endwhile;
	
	return foundRow;
epilog
	delete iter;

end;</source>
        <Parameter name="y" type="Real"/>
        <Parameter name="_isOutsideEdge" type="Boolean" usage="io"/>
        <ReturnType type="CMUI_GridRow"/>
    </JadeMethod>
    <JadeMethod name="convertPositionToFirstColumn" id="8fd3829a-983b-4345-a7f8-f9f213b439a4">
        <source>convertPositionToFirstColumn(x, y : Real) : CMUI_GridPoint;// serverExecution;
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	foundPoint,
	tmpPoint	: CMUI_GridPoint;
	tmpRow		: CMUI_GridRow;
		
begin

	foreach tmpRow in self.allGridRows do : outerLoop
	   	foreach tmpPoint in tmpRow.allGridPointsByColumn do
			if x &lt; tmpPoint.x1 then
			   	foundPoint := tmpPoint;
			   	break;
			endif;
	   	endforeach;
	endforeach;
	return foundPoint;

end;</source>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <ReturnType type="CMUI_GridPoint"/>
    </JadeMethod>
    <JadeMethod name="convertPositionToGridPoint" id="1b863e2a-6155-40e4-8c09-b2758f0397b1">
        <source>convertPositionToGridPoint(x, y : Real) : CMUI_GridPoint; 

vars
	foundPoint,
	tmpPoint	: CMUI_GridPoint;
	tmpRow		: CMUI_GridRow;
	tmpX, tmpY : Real;
	pntX, pntY : Real;	
	rowX, rowY : Real;	
begin

	// Do the row first as it is "non-variable" length.  At some
	// point columns in each row may be variable length (RJS Dec/02)
	tmpX := x;
	tmpY := y;
	foreach tmpRow in self.allGridRows do : outerLoop
		if tmpY &gt;= tmpRow.y1 and
		   tmpY &lt; tmpRow.y2 then
		   	// Found the row now check the points in this row
		   	foreach tmpPoint in tmpRow.allGridPointsByColumn do
				if tmpX &gt;= tmpPoint.x1 and
				   tmpX &lt; tmpPoint.x2 then
					if tmpY &gt;= tmpPoint.y1 and
					   tmpY &lt; tmpPoint.y2 then

					   	foundPoint := tmpPoint;
					   	break outerLoop;
					endif;
				endif;
		   	endforeach;
		endif;
	endforeach;
	
	return foundPoint;

end;</source>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <ReturnType type="CMUI_GridPoint"/>
    </JadeMethod>
    <JadeMethod name="convertPositionToGridRow" id="cee7efc5-6e39-4ddc-a62a-2bf81c8388c4">
        <source>convertPositionToGridRow(x, y : Real) : CMUI_GridRow;// serverExecution;


vars
	foundPoint,tmpPoint	: CMUI_GridPoint;
	foundRow,tmpRow		: CMUI_GridRow;
		
begin

	// Do the row first as it is "non-variable" length.  At some
	// point columns in each row may be variable length (RJS Dec/02)

	foreach tmpRow in self.allGridRows do
		if y &gt;= tmpRow.y1 and
		   y &lt; tmpRow.y2 then
		   foundRow := tmpRow;
		   	// Found the row now check the points in this row
		   	foreach tmpPoint in tmpRow.allGridPointsByColumn do
				if x &gt;= tmpPoint.x1 and
				   x &lt; tmpPoint.x2 then
				   	foundPoint := tmpPoint;
				   	break;
				endif;
		   	endforeach;
		endif;
	endforeach;
	
	return foundRow;

end;</source>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <ReturnType type="CMUI_GridRow"/>
    </JadeMethod>
    <JadeMethod name="create" id="5e6e7a36-a584-4f0c-8e8d-3fbebb776f3c">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     31 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	// Default these to 1 so that when get added into the SDF
	// collection will work correctly without user having
	// to always override.  If more then 1 then user will need
	// to override
	self.row	:= 1;
	self.column	:= 1;
	create self.myDummyTI transient;
	self.myDummyTI.setPropertyValue("id", "DUMMY");

