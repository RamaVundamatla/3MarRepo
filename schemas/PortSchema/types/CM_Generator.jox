    <JadeMethod name="pxyCreateUpdateProxy" id="56fdfd2e-857b-48e1-b493-082f3088905a">
        <source>pxyCreateUpdateProxy(): SelfType;
/* ---------------------------------------------------------------------------
Created:	27 August 2008	by cnwvu1

Purpose:	Par17775. ccms1405. APM Yard Ops, new generator types
   
Change Date		Who		Reason
20/04/2011		cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
						trying to create the proxy
------------------------------------------------------------------------------*/
vars
	pxyTI : CM_Generator;
	completedOK		: Boolean;
begin

	pxyTI := inheritMethod();

	pxyTI.myGeneratorType := self.myGeneratorType;

	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyTI;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyTI;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
