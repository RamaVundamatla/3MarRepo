  COPYRIGHT © JADE SOFTWARE CORPORATION LIMITED 2002 - ALL RIGHTS RESERVED
____________________________________________________________________________</text>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jssGetWordForTens" id="3ca49d09-1f05-443a-aef1-75f0777a7191">
        <source>jssGetWordForTens(pTensDigit:Real; pUnitDigit:Real):String protected;
// --------------------------------------------------------------------------------
// Created:		21 August 2001 by cnwdad1
//
// Purpose:		Returns the worded amount for a two-digit amount.
//
// Parameters:	pTensDigit - The tens value of the amount.
//				pUnitDigit - The unit digit of the amount.
//
// Returns:		The worded amount.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	wordedAmount	: String;
	teenValue		: Real;
	
begin
	if pTensDigit = 1 then
		teenValue		:=	(pTensDigit * 10) + pUnitDigit;
		wordedAmount	:=	teenValue.jssGetWordForTeen();
	else
		if pTensDigit = 2 then
			wordedAmount	:=	$JSS_NUM_TWENTY;
		elseif pTensDigit = 3 then
			wordedAmount	:=	$JSS_NUM_THIRTY;
		elseif pTensDigit = 4 then
			wordedAmount	:=	$JSS_NUM_FORTY;
		elseif pTensDigit = 5 then
			wordedAmount	:=	$JSS_NUM_FIFTY;
		elseif pTensDigit = 6 then
			wordedAmount	:=	$JSS_NUM_SIXTY;
		elseif pTensDigit = 7 then
			wordedAmount	:=	$JSS_NUM_SEVENTY;
		elseif pTensDigit = 8 then
			wordedAmount	:=	$JSS_NUM_EIGHTY;
		elseif pTensDigit = 9 then
			wordedAmount	:=	$JSS_NUM_NINETY;
		endif;
		
		if pUnitDigit &gt; 0 then
			wordedAmount	:=	wordedAmount &amp; " " &amp; pUnitDigit.jssGetWordForUnit();
		endif;
	endif;
epilog
	return wordedAmount;
end;</source>
        <access>protected</access>
        <text>___________________________________________________________________________

              P R O P R I E T A R Y   N O T I C E

This software, in whole and in every part, is proprietary to Jade Software
Corporation Limited at Christchurch, New Zealand and is not to be
reproduced, used or disclosed except upon prior written permission of Jade
Software Corporation Limited.

  COPYRIGHT © JADE SOFTWARE CORPORATION LIMITED 2002 - ALL RIGHTS RESERVED
____________________________________________________________________________</text>
        <Parameter name="pTensDigit" type="Real"/>
        <Parameter name="pUnitDigit" type="Real"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jssGetWordForUnit" id="4d288704-e327-4f08-af3d-d85a46aed9bb">
        <source>jssGetWordForUnit():String protected;
// --------------------------------------------------------------------------------
// Created:		21 August 2001 by cnwdad1
//
// Purpose:		Converts the receiver into it's equivalent word.  This method only
//				handles values between 1 and 9.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	value	: Real;
	
begin
	value	:=	self;
	
	if value = 1 then
		return $JSS_NUM_ONE;
	elseif value = 2 then
		return $JSS_NUM_TWO;
	elseif value = 3 then
		return $JSS_NUM_THREE;
	elseif value = 4 then
		return $JSS_NUM_FOUR;
	elseif value = 5 then
		return $JSS_NUM_FIVE;
	elseif value = 6 then
		return $JSS_NUM_SIX;
	elseif value = 7 then
		return $JSS_NUM_SEVEN;
	elseif value = 8 then
		return $JSS_NUM_EIGHT;
	elseif value = 9 then
		return $JSS_NUM_NINE;
	endif;
end;</source>
        <access>protected</access>
        <text>___________________________________________________________________________

              P R O P R I E T A R Y   N O T I C E

This software, in whole and in every part, is proprietary to Jade Software
