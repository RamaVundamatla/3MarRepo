    <JadeMethod name="doBtnLocateClick" id="1f104389-f0e4-491f-bcbd-b8d9588e3d3b">
        <updating/>
        <source>doBtnLocateClick(_theTable : CM_DataTable input) updating;
// ---------------------------------------------------------------------------
// Created:		May 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theObject : Object;
	theTI : CM_TrackedItem;
	theLC : CM_LocationsController;
	theTA : CM_TerminalArea;
	aForm 	: Form;
	menuAction 		: CMUI_MenuAction;
	theTerminalArea : CM_GridArea;
	theArea : CM_TerminalArea;
begin
	self.mousePointer := Window.MousePointer_HourGlass;

	if _theTable.row &lt;= _theTable.fixedRows then
		return;
	endif;
	
	if (not _theTable.accessRow(_theTable.row).selected) then
		app.msgBox(app.getErrorString(S_Please_Select_A_Container_To),app.getErrorString(Nothing_Selected), MsgBox_Exclamation_Mark_Icon); 
		return;
	endif;
	theObject := _theTable.accessedRow.itemObject;
	
	//Par 18252 Mar 2009
	if theObject.isKindOf(CM_TrackedItem) then
		theTI := theObject.CM_TrackedItem;
	elseif theObject.isKindOf(CM_WorkListEntry) then	// from the Sequence sheet there is CM_VoyageWLE
		theTI := theObject.CM_WorkListEntry.myTrackedItem;
	else
		return;
	endif;
	if theTI = null then
		return;
	endif;
	//comented by 18252. Mar 2009

	// PAR 21532 CCMS SFW 1025 - method call below replaces commented code below it
	self.myAssistant.showYardLocationFromTI(theTI, self.myMasterMenuAction);
epilog
	self.mousePointer := Window.MousePointer_Default;
	
end;</source>
        <Parameter name="_theTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
