    <JadeMethod name="getName" id="213280fa-7219-489f-b9fe-e5653260d839">
        <source>getName(): String;
// ---------------------------------------------------------------------------
// Created:		26 June 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	return inheritMethod() &amp; ' row ' &amp; self.row.String &amp; ' height ' &amp; self.height.String &amp; ' column ' &amp;self.column.String;//self.myYardController.getName();

end;</source>
