    <JadeMethod name="tblConditions_rowColumnChg" id="0caddf66-85d6-47de-adf1-6b446819ed45">
        <controlMethod name="CM_DataTable::rowColumnChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblConditions_rowColumnChg(table: Table input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	24 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	self.mySelectedCondition := table.accessRow(table.row).itemObject.CM_SegregationCondition;
