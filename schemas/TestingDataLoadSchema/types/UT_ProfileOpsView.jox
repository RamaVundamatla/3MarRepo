<Class name="UT_ProfileOpsView" id="268668b6-4a03-4ec2-ad61-daad9fb23e3a">
    <superclass name="UT_Profile"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="userData"/>
    <JadeMethod name="initialize" id="1f093f47-cbbb-451d-b116-60f1e957b6a3">
        <source>initialize();

vars

begin
	inheritMethod();
	self.settings.addAssociation(UT_Profile.P_OPERATOR, "MSL");
	self.settings.addAssociation(UT_Profile.P_SHIPPING_LINE, "MSL");
	self.settings.addAssociation(UT_Profile.P_USER, "MTN-OPS");
	self.settings.addAssociation(UT_Profile.P_TERMINAL, "MTNQ");
	self.settings.addAssociation(UT_Profile.P_TRADE, "New Zealand East Coast");
end;
</source>
    </JadeMethod>
</Class>
