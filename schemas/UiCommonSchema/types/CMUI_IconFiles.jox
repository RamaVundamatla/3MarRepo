    <JadeMethod name="btnAddDisFromDisk_click" id="453621ae-5ea6-419c-8084-15ef56302267">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnAddDisFromDisk_click(btn: Button input) updating;
/*
Purpose:			

Date		Who		Reason
15 October 2021	navab1	TFS 51853
*/

vars
	icon : CMUI_IconFile;
	row : Integer;
	newIcon : Binary;
	newName : String;
	root : CMUI_Root;
	filename : String;
begin
	root := CMUI_Root.firstInstance;
	
	newIcon := self.picLoadMethod(filename);
	
	if newIcon &lt;&gt; null then
		newName := "ICON2021_" &amp; filename.removeInvalidChars() &amp; "_dis";
		
		if root.allIconFilesByName[newName] = null then
		
			
			beginTransaction;
			create icon;
			icon.setForCreate(root, filename, newName, newIcon, 2021, newName.Binary);
			commitTransaction;

			self.populateTable();
	
			self.tblData.findObjectInRow(icon, row);
			
			self.tblData.topRow := row;

		else
			app.msgBox("Icon with the name " &amp; newName &amp; " already exists." &amp; CrLf &amp; CrLf &amp; "Use the Update option or rename the file on the disk" , "Issue", MsgBox_OK_Only);
		endif;	
	endif;
	
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
