<Class name="CM_YATypeReceiveDateRange" id="b4890cee-e304-467a-86c1-e193441e1536">
    <superclass name="CM_YATypeDateRange"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="yardAllocations"/>
    <JadeMethod name="getCriteriaValueForTi" id="9aaf45b2-8e06-45f1-8e1d-857561c42115">
        <source>getCriteriaValueForTi(_ti: CM_TrackedItem; _criteriaValue: Any output);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 27/05/2025	navdap1		Initial creation MTN-34981 MTN -Yard Allocations - Storing Cargo Based on a Date Range 
//
vars

begin
	_criteriaValue := _ti.receivedDT.date;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_criteriaValue" type="Any" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getTypeName" id="46d722df-41a7-45c0-b1cf-cdeeee74e229">
