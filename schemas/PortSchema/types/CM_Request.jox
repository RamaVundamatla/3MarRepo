    <JadeMethod name="getCargoGroupId" id="ffef8efd-ebcc-4d70-b646-f7245f348f25">
        <source>getCargoGroupId():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 December 2016	cnwndl1	Initial creation	TFS 2995 / 2638

*/

vars

	crit : CM_ReleaseByTypeCriteria;
	yaCriteria : CM_YACriteria;
	retStr : String;

begin

	crit := self.getReserveSelectionCriteria();
	if crit &lt;&gt; null then
		yaCriteria := crit.getCriteriaFor( YACriteriaType_CargoGroup );
		if yaCriteria &lt;&gt; null then
			retStr := yaCriteria.getDisplayForYAMTableColumn;
		endif;
	endif;
	
	return retStr;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
