    <JadeMethod name="toolbarShowCaptions" id="45acd80c-089e-4320-8205-1b5c369f335f">
        <updating/>
        <source>toolbarShowCaptions(_showCaptions: Boolean) updating;
//
//19 Jan 2017	cnwrs1	TFS 3137 - resize the form when show captions is on
//
vars
	currentHeight : Real;
	newHeight : Real;
	heightDiff : Real;
begin
	currentHeight := self.frmToolbar.height;
	inheritMethod(_showCaptions);
	newHeight := self.frmToolbar.height;
	heightDiff := newHeight - currentHeight;
	self.frmSearch.top := self.frmSearch.top + heightDiff;
	self.fldSearch.top := self.fldSearch.top + heightDiff;
	self.fldSearch.height := self.fldSearch.height - heightDiff;
	self.lstEventTypes.height := self.lstEventTypes.height - heightDiff;
	self.lstEventGroups.height := self.lstEventGroups.height - heightDiff;
	self.lstUsers.height := self.lstUsers.height - heightDiff;
	self.lstTerminals.height := self.lstTerminals.height - heightDiff;
	self.doResize();
	self.doResize();	// ?? dont know whay I need to do this twice ??
end;</source>
        <Parameter name="_showCaptions" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="3b1303a1-3956-4e5a-8c2f-bd0f3e90d1be">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
//	self.translateCaption(Xlat_0017359, locale);
	btnSelAllSearch.translateBubbleHelp(Xlat_0005055, locale);
	btnSelAllSearch.translateCaption(Xlat_0005056, locale);
	chkIncludeNoTerm.translateCaption(Xlat_0005057, locale);
	chkIncludeNoUser.translateCaption(Xlat_0005058, locale);
	lblDateFrom.translateCaption(Xlat_0005059, locale);
	lblDateTo.translateCaption(Xlat_0005060, locale);
	lblFromTime.translateCaption(Xlat_0005061, locale);
	lblTimeTo.translateCaption(Xlat_0005062, locale);
	mnuContextExtras.translateCaption(Xlat_0009870, locale);
	mnuEditDiscrepancy.translateCaption(Xlat_0011971, locale);
	mnuPrintDetails.translateCaption(Xlat_0009871, locale);
	shtEventGroups.translateCaption(Xlat_0005063, locale);
	shtEventTypes.translateCaption(Xlat_0005064, locale);
	shtSearchDates.translateCaption(Xlat_0005065, locale);
	shtTerminals.translateCaption(Xlat_0005066, locale);
	shtUsers.translateCaption(Xlat_0005067, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="xmlGetListSelected" id="dc4ba752-10ec-46c0-b0cc-2f9bf6379868">
        <source>xmlGetListSelected(_tagName : String; _lstTable : CMUI_ListTable; _propertyName : String) : String protected;
/*
----------   ----------  --------------------------------------------------
Created:	11 July 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	str			: String;
	obj			: Object;
begin
	foreach obj in _lstTable.allSelectedObjects do
		str := str &amp; global.formatAsXML(_tagName, obj.getPropertyValue(_propertyName).String);
	endforeach;
	
	return str;
	
end;

</source>
        <access>protected</access>
        <Parameter name="_tagName" type="String"/>
        <Parameter name="_lstTable" type="CMUI_ListTable"/>
        <Parameter name="_propertyName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="xmlGetSearchCriteria" id="aada0e50-af04-4f9b-8b5d-f743d146b6ae">
        <updating/>
        <source>xmlGetSearchCriteria(): String protected, updating;
/*
----------   ----------  --------------------------------------------------
Created:	11 July 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support	
----------   ----------  --------------------------------------------------
*/
vars
	block			: String;
	userDate,
	today			: Date;
	toDays,
	fromDays		: Integer;
	fromTimeStr,
	toTimeStr		: String;
begin
	//set filter value incase has been opened via quick search
	self.setFilterValues();
	
	today := self.systemToLocalTime(app.actualTimeServer).date;// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// cnwdad1 17/06/2009 - PAR #19942.
//	userDate := self.txtDateFrom.text.Date;
	userDate := self.txtDateFrom.text.asDateJMT();
	
	if userDate.isValid() then
		fromDays := (userDate - today).Integer;
	endif;
	
// cnwdad1 17/06/2009 - PAR #19942.
//	userDate := self.txtDateTo.text.Date;
	userDate := self.txtDateTo.text.asDateJMT();

	if userDate.isValid then
		toDays := (userDate - today).Integer;
	endif;
	
// cnwdad1 17/06/2009 - PAR #19942.
//	if self.txtTimeFrom.text.trimBlanks.Time.isValid then
	if self.txtTimeFrom.text.trimBlanks().asTimeJMT().isValid() then
		fromTimeStr := self.txtTimeFrom.text.trimBlanks();
	endif;
	
// cnwdad1 17/06/2009 - PAR #19942.
//	if self.txtTimeTo.text.trimBlanks.Time.isValid then
	if self.txtTimeTo.text.trimBlanks().asTimeJMT().isValid() then
		toTimeStr := self.txtTimeTo.text.trimBlanks();
	endif;
	
	block := block &amp; global.formatAsXMLPrefix(CMUI_EventEnquiryForm.name) &amp;
			//dates and times
			global.formatAsXML(self.XML_SEARCHFROMDATE, fromDays.String) &amp;
			global.formatAsXML(self.XML_SEARCHFROMTIME, fromTimeStr) &amp;
			global.formatAsXML(self.XML_SEARCHTODATE, toDays.String) &amp;
			global.formatAsXML(self.XML_SEARCHTOTIME, toTimeStr) &amp;
			//event types
			global.formatAsXMLPrefix(self.XML_SEARCHEVENTTYPES) &amp;
				self.xmlGetListSelected(self.XML_SEARCHEVENTTYPE, self.lstEventTypes, CM_EventType::type.name) &amp;
			global.formatAsXMLSuffix(self.XML_SEARCHEVENTTYPES) &amp;
			
			//event type groups
			global.formatAsXMLPrefix(self.XML_SEARCHEVENTGROUPS) &amp;
				self.xmlGetListSelected(self.XML_SEARCHEVENTGROUP, self.lstEventGroups, CM_EventTypeGroup::name.name) &amp;
			global.formatAsXMLSuffix(self.XML_SEARCHEVENTGROUPS) &amp; 
			
			//users
			global.formatAsXMLPrefix(self.XML_SEARCHUSERS) &amp;
				self.xmlGetListSelected(self.XML_SEARCHUSER, self.lstUsers, CM_User::code.name) &amp;
			global.formatAsXMLSuffix(self.XML_SEARCHUSERS) &amp; 
			global.formatAsXML(self.XML_SEARCHINCLUDENOUSER, self.chkIncludeNoUser.value.String) &amp;
			
			//terminals
			global.formatAsXMLPrefix(self.XML_SEARCHTERMINALS) &amp;
				self.xmlGetListSelected(self.XML_SEARCHTERMINAL, self.lstTerminals, CM_Terminal::code.name) &amp;
			global.formatAsXMLSuffix(self.XML_SEARCHTERMINALS) &amp; 
			global.formatAsXML(self.XML_SEARCHINCLUDENOTERM, self.chkIncludeNoTerm.value.String);
	
	block := block &amp; global.formatAsXMLSuffix(CMUI_EventEnquiryForm.name);
	
	return block;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="xmlSetListSelected" id="0b7b427b-f0c1-43e0-a0fb-4b6fcd38c3c1">
        <source>xmlSetListSelected(_xmlBlock, 
					_tagName		: String;
					_keyType		: Type;
					_rootCollection : CM_MemberKeyDictionary; 
					_lstTable 		: CMUI_ListTable io) protected;
/*
----------   ----------  --------------------------------------------------
Created:	10 July 2007 By cnwth2

Purpose:	used for all multi-select tables in search frame to set from user's last selected items

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	len,
	pos					: Integer;
	objectSet			: ObjectSet;
	selectStr			: String;
	obj					: Object;
begin

	create objectSet transient;
	len := _xmlBlock.length;
	pos := 1;
	objectSet.clear();
	
	while pos &lt;= len do 
		selectStr := _xmlBlock.cnEcGetNextTagValueOfName(_tagName , pos);
		if selectStr = null then
			break;
		endif;
		if _keyType = Integer then
			obj := _rootCollection[selectStr.Integer];
		elseif _keyType = String then
			obj := _rootCollection[selectStr.String];
		endif;	
			
		if obj &lt;&gt; null then
			objectSet.add(obj);
		endif;		
	endwhile;
	
	_lstTable.setSelected(objectSet);
	
	
epilog
	delete objectSet;
end;

</source>
        <access>protected</access>
        <Parameter name="_xmlBlock" type="String"/>
        <Parameter name="_tagName" type="String"/>
        <Parameter name="_keyType" type="Type"/>
        <Parameter name="_rootCollection" type="CM_MemberKeyDictionary"/>
        <Parameter name="_lstTable" type="CMUI_ListTable" usage="io"/>
    </JadeMethod>
    <JadeMethod name="xmlSetSearchCriteria" id="a3dba8d2-6037-45aa-adf7-5d842ec78439">
        <updating/>
        <source>xmlSetSearchCriteria(_userWindow: CM_UserWindow) protected, updating;
/*
----------   ----------  --------------------------------------------------
Created:	10 July 2007 By cnwth2

Purpose:	N.B this is called from setupForm because for some reason the initFromUserWindow
			is called BEFORE the form has an opportunity to populate the list tables (!!??)

Changed On   Changed By  Reason
// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support	
----------   ----------  --------------------------------------------------
*/
vars
	allSelectedBlock,
	tmpStr,
	block			: String;
	tmpDate,
	today			: Date;
	
begin
	today := self.systemToLocalTime(app.actualTimeServer).date;// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	if _userWindow &lt;&gt; null then
		block := _userWindow.xmlInfo.cnEcGetTagValueOfName(CMUI_EventEnquiryForm.name);
	endif;
	
	
	if block = null then
// cnwdad1 17/06/2009 - PAR #19942.
//		self.txtDateFrom.text := (today - 1).Date.asStringJMT();
//		self.txtTimeFrom.text := '00:00';
		self.txtDateFrom.setDate(today - 1);
		self.txtTimeFrom.setTime('00:00'.asTimeJMT());
		self.lstEventTypes.setSelected(app.myRoot.allEventTypesByType);
		self.lstEventGroups.setSelected(app.myRoot.allEventTypeGroups);
		self.myAssistant.listTableTerminal(self.lstTerminals, false, true, app.myRoot.allTerminals, app.myRoot.allTerminals);
		self.lstUsers.setSelected(app.myRoot.allUsers);
		self.chkIncludeNoUser.value := true;
		return;
	endif;
	
	
	//user's preference for date from - should be integer set to the number of days before
	//the current date when form last closed.(N.B we'll likely be adding a negitave value for 
	//from date, and possibly null or negitive value for to date as a positive value for 
	//to date makes no sense)
	tmpStr := block.cnEcGetTagValueOfName(self.XML_SEARCHFROMDATE);
	tmpDate := today + tmpStr.Integer;
	self.txtDateFrom.text := tmpDate.asStringJMT();
	
	//from time
	tmpStr := block.cnEcGetTagValueOfName(self.XML_SEARCHFROMTIME);
// cnwdad1 17/06/2009 - PAR #19942.
//	self.txtTimeFrom.setTime(tmpStr.Time);
	self.txtTimeFrom.setTime(tmpStr.asTimeJMT());
	
	//to date
	tmpStr := block.cnEcGetTagValueOfName(self.XML_SEARCHTODATE);
	tmpDate := today + tmpStr.Integer;
	
	if tmpDate.isValid then
		if tmpDate = app.actualTimeServer.date then
			self.txtDateTo.text := null;
		else
			self.txtDateTo.text := tmpDate.asStringJMT();
		endif;
	endif;

	//to time
	tmpStr := block.cnEcGetTagValueOfName(self.XML_SEARCHTOTIME);
// cnwdad1 17/06/2009 - PAR #19942.
//	self.txtTimeTo.setTime(tmpStr.Time);
	self.txtTimeTo.setTime(tmpStr.asTimeJMT());
	
	//sest multi-select list tables
	allSelectedBlock := block.cnEcGetTagValueOfName(self.XML_SEARCHEVENTTYPES);
	xmlSetListSelected(allSelectedBlock, self.XML_SEARCHEVENTTYPE, Integer, app.myRoot.allEventTypesByType, self.lstEventTypes);

	allSelectedBlock := block.cnEcGetTagValueOfName(self.XML_SEARCHEVENTGROUPS);
	xmlSetListSelected(allSelectedBlock, self.XML_SEARCHEVENTGROUP, String, app.myRoot.allEventTypeGroups, self.lstEventGroups);

	allSelectedBlock := block.cnEcGetTagValueOfName(self.XML_SEARCHUSERS);
	xmlSetListSelected(allSelectedBlock, self.XML_SEARCHUSER, String, app.myRoot.allUsers, self.lstUsers);
	
	tmpStr := block.cnEcGetTagValueOfName(self.XML_SEARCHINCLUDENOUSER);
	self.chkIncludeNoUser.value := tmpStr.Boolean;
	
	allSelectedBlock := block.cnEcGetTagValueOfName(self.XML_SEARCHTERMINALS);
	xmlSetListSelected(allSelectedBlock, self.XML_SEARCHTERMINAL, String, app.myRoot.allTerminals, self.lstTerminals);
	
	tmpStr := block.cnEcGetTagValueOfName(self.XML_SEARCHINCLUDENOTERM);
	self.chkIncludeNoTerm.value := tmpStr.Boolean;
	
	
end;

</source>
        <access>protected</access>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="zDoSearch" id="0781dbc7-eb65-4729-9c16-f47f5c6544cd">
        <updating/>
        <source>zDoSearch() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	11 July 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if (not self.txtDateFrom.text.asDateJMT.isValid) then
		app.msgBox(app.getErrorString(ERR_Valid_From_DT), app.getErrorString(Error), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	inheritMethod();


end;

</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zShowSearcher" id="46013bff-d3d8-4023-9b78-b1bcd66de86b">
        <updating/>
        <source>zShowSearcher() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	12 July 2007 By cnwth2

Purpose:	re-implemented to bypass the crazy resizing and other strange things
			that rely on a the user a filter entry table (which this form does not use)

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	
	self.isSearcherVisible := true;
	self.btnShowSearchTV.caption := 'Hide Searcher';
	self.btnShowSearchTV.bubbleHelp := 'Hide Searcher';

	frmSearch.centreWindow();
	frmSearch.visible := true;
	frmSearch.zOrder(1);
	
end;

</source>
        <access>protected</access>
    </JadeMethod>
</GUIClass>
