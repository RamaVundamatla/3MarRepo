    <JadeMethod name="asStringJMT" id="2ff91fb6-fba1-4848-aceb-cf1ef9bbeba8">
        <source>asStringJMT() : String;
/*

Purpose:			

Return Value:		

Date		Who		Reason
31 May 2007	cnwer1	Initial creation - PAR#xxxx
31/08/2010	cnwdad1	PAR #20064.

*/
constants
	JMTdecimalSeparator = ".";
vars
	decimalSeparator,
	localeFormat		: String;
begin
	// cnwdad1 31/08/2010 - PAR #20064.
	decimalSeparator := app.getMyLocaleInfoJMT().numericInfo.decimalSeparator;
	
	if decimalSeparator = JMTdecimalSeparator then
		return self.display();
	endif;
	
	localeFormat := self.display();
	localeFormat.replaceChar(JMTdecimalSeparator,decimalSeparator.Character);
	
	return localeFormat;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="asStringJMTWithDecSeparator" id="7aceb852-8bba-4372-bc02-559eeb5de056">
        <source>asStringJMTWithDecSeparator(_decimalSeparator : String) : String;
/*

Purpose:			

Return Value:		

Date		Who		Reason
10/09/2012	cnwmh5	Initial creation - PAR30354

*/
constants
	JMTdecimalSeparator = ".";
vars
	decimalSeparator,
	localeFormat: String;
begin
	
	decimalSeparator := _decimalSeparator;
	if decimalSeparator = null then
		decimalSeparator := app.getMyLocaleInfoJMT().numericInfo.decimalSeparator;
	endif;
	
	if decimalSeparator = JMTdecimalSeparator then
		return self.display();
	endif;
	
	localeFormat := self.display();
	localeFormat.replaceChar(JMTdecimalSeparator, decimalSeparator.Character);
	
	return localeFormat;
end;</source>
        <Parameter name="_decimalSeparator" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="asStringJMTWithPrecision" id="d373ed02-307e-46d6-a78e-07fbb424b1be">
        <source>asStringJMTWithPrecision(_decimalPrecision : Integer; _useThousandSeparator : Boolean) :String;
/*

Purpose:			


Return Value:		


Date		Who		Reason
31 May 2007	cnwer1	Initial creation - PAR#xxxx
31/08/2010	cnwdad1	PAR #20064.
21 Nov 2022	navma1	ChangeRequest 55424: MTN - Improve the performance of Edi file loading
*/
constants
	JMTDecimalSeperator = ".";
vars
	decimalSeperator,
	thousandSeperator,
	localeFormat			: String;
	len, 
	pos, 
	sbe, 
	diff 					: Integer;
	isNeg 					: Boolean;
	locale					: LocaleFullInfo;
begin
	
	locale				:= app.getMyLocaleInfoJMT();									//21.11.2022 navma1 #55424
	decimalSeperator	:= locale.numericInfo.decimalSeparator;							//21.11.2022 navma1 #55424
	localeFormat 		:= self.roundedTo(_decimalPrecision).display;
	
	if JMTDecimalSeperator &lt;&gt; decimalSeperator.Character	then						//21.11.2022 navma1 #55424
		localeFormat.replaceChar(JMTDecimalSeperator, decimalSeperator.Character);
	endif;
	
	// PAR 14668 PAD with ZEROS
	pos := localeFormat.pos(decimalSeperator,1);
	if pos = 0 then
		if _decimalPrecision &gt; 0 then // PAR 15494
			len 		 := localeFormat.length;
			sbe 		 := len + 1  + _decimalPrecision;
			localeFormat := localeFormat &amp; decimalSeperator;
			foreach pos in 1 to _decimalPrecision do
				localeFormat := localeFormat &amp; "0";
			endforeach;
		endif;
	else
		len  := localeFormat.length;
		sbe  := pos + _decimalPrecision;
		diff := sbe - len;
		if diff &gt; 0 then
			foreach pos in 1 to diff do
				localeFormat := localeFormat &amp; "0";
			endforeach;
		
		endif;
	endif;
		
	// 09/01/2008 cnwar2 #14738
	if _useThousandSeparator then
		thousandSeperator	:= locale.numericInfo.thousandSeparator;		//21.11.2022 navma1 #55424
		isNeg :=  (self &lt; 0);					    // PAR 16890 and 17110
		if isNeg then 								// PAR 16890 and 17110
			localeFormat := localeFormat[2:end];    // PAR 16890 and 17110
		endif; 										// PAR 16890 and 17110
		if _decimalPrecision &gt; 0 then
			pos	:= localeFormat.pos(decimalSeperator,1) - 1;
		else
			pos	:= localeFormat.length;
		endif;
		pos := pos - 3;
		while pos &gt; 0 do
			localeFormat := localeFormat[1:pos] &amp; thousandSeperator &amp; localeFormat[pos+1:end];
			pos		     := pos - 3;
		endwhile;
		if isNeg then 							 // PAR 16890 and 17110
			localeFormat := "-" &amp; localeFormat;  // PAR 16890 and 17110
		endif; 									 // PAR 16890 and 17110
	endif;
		
	return localeFormat;
epilog

end;</source>
        <Parameter name="_decimalPrecision" type="Integer"/>
        <Parameter name="_useThousandSeparator" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="asStringJSON" id="fd90a036-5307-458d-9aa9-fe4a9f4855e4">
        <source>asStringJSON() : String;
/*

Purpose:			Return the receiver formatted for JSON

Parameters:			None

