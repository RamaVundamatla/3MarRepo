    <JadeMethod name="setMyTerminal" id="c79c8c2a-46d9-4090-86f0-734ee890a346">
        <updating/>
        <source>setMyTerminal(_value : CM_Terminal) updating;
// ---------------------------------------------------------------------------
// Created:     01 August 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.myTerminal := _value;
	
end;</source>
