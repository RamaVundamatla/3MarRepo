    <JadeMethod name="causeHMSEvent" id="79eda468-6619-4cc6-8349-74d0e2aaae55">
        <source>causeHMSEvent(_eventMode: Integer);
//--------------------------------------------------
// Created:	27 September 2005 By: cnwgd1
//--------------------------------------------------
/*

Date		Who		Reason
12 Oct 2016	cnwkpd1	TFS 2815 - JADE 7.1.08 causeEvent changes
	
*/

vars

begin
	if _eventMode = self.EventMode_Delete 
	or _eventMode = self.EventMode_Update 
	or _eventMode = self.EventMode_Create then		
//		self.myVoyageData.myVoyage.causeEvent(Object_Update_Event, false, self);
		self.updateObjectEdition(self.myVoyageData.myVoyage);
	else
		inheritMethod(_eventMode);
	endif;

end;</source>
        <Parameter name="_eventMode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cloneMySelf" id="fabd126e-1d31-41a3-a305-e5220f4802f9">
        <source>cloneMySelf(_transient : Boolean) : SelfType;
//--------------------------------------------------
// Created:	29 March 2004 By: cnwgd1
//--------------------------------------------------
vars
	newDelay : HMS_VoyageDelay;
begin
	
	newDelay := self.cloneSelf(_transient);
	newDelay.myDelay := self.myDelay;
	
	return newDelay;
end;</source>
        <Parameter name="_transient" type="Boolean"/>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="createPropertyChangeFromProxy" id="b00be931-009b-4c87-b1ef-40f8bc017a57">
        <source>createPropertyChangeFromProxy(_transaction : HMS_Transaction; _pxyDelay : HMS_VoyageDelay);
//--------------------------------------------------
// Created:	09 September 2004 By: cnwgd1
//--------------------------------------------------
vars
	oldStr,
	newStr:			String;
 	propertyChange:	HMS_PropertyChange;
begin

	if _pxyDelay = null then
		return;
	endif;
	// Check all properties for changes
    // ------------------------------------------------------------------------

	// Delay Reason
    // Property has changed
    if self.myDelay &lt;&gt; _pxyDelay.myDelay then
		create propertyChange;
   		propertyChange.set(_transaction, "Delay Reason", self.myDelay.description, _pxyDelay.myDelay.description);
	endif;

	// Start DT for delay
    // Property has changed
    if self.startTime &lt;&gt; _pxyDelay.startTime then
		create propertyChange;
   		//oldStr := self.startTime.date.format('dd/MM/yy') &amp; ", " &amp; self.startTime.Time.currentLocaleFormatJMT();
		oldStr := self.startTime.shortCurrentLocaleSystemUTC();				// 30/5/16 cnwmp6 TFS 488 - Multi timezone support
		//newStr := _pxyDelay.startTime.date.format('dd/MM/yy') &amp; ", " &amp; _pxyDelay.startTime.Time.currentLocaleFormatJMT();
		newStr := _pxyDelay.startTime.shortCurrentLocaleSystemUTC();		// 30/5/16 cnwmp6 TFS 488 - Multi timezone support
   		propertyChange.set(_transaction, "Start of delay", oldStr, newStr);
	endif;

	// End DT for delay
    // Property has changed
    if self.stopTime &lt;&gt; _pxyDelay.stopTime then
		create propertyChange;
   		//oldStr := self.stopTime.date.format('dd/MM/yy') &amp; ", " &amp; self.stopTime.Time.currentLocaleFormatJMT;
		oldStr := self.stopTime.shortCurrentLocaleSystemUTC();				// 30/5/16 cnwmp6 TFS 488 - Multi timezone support
		//newStr := _pxyDelay.stopTime.date.format('dd/MM/yy') &amp; ", " &amp; _pxyDelay.stopTime.Time.currentLocaleFormatJMT;
		newStr := _pxyDelay.stopTime.shortCurrentLocaleSystemUTC();			// 30/5/16 cnwmp6 TFS 488 - Multi timezone support
   		propertyChange.set(_transaction, "End of delay", oldStr, newStr);
	endif;

	// Delay isChargeable
    // Property has changed
    if self.isChargeable &lt;&gt; _pxyDelay.isChargeable then
		create propertyChange;
   		if self.isChargeable then
   			oldStr := "Chargeable";
		else
			oldStr := "NOT Chargeable";
		endif;
		if _pxyDelay.isChargeable then
   			newStr := "Chargeable";
		else
			newStr := "NOT Chargeable";
		endif;
   		propertyChange.set(_transaction, "Chargeable Status", oldStr, newStr);
	endif;
end;</source>
        <Parameter name="_transaction" type="HMS_Transaction"/>
        <Parameter name="_pxyDelay" type="HMS_VoyageDelay"/>
    </JadeMethod>
    <JadeMethod name="createPropertyChanges" id="8a675529-2146-4eac-b921-9ec186809c30">
        <source>createPropertyChanges(_transaction : HMS_Transaction; _workingDelay : CMIF_HMS_VoyageDelay);
//--------------------------------------------------
// Created:	09 September 2004 By: cnwgd1
//--------------------------------------------------
vars
	oldStr,
	newStr:			String;
 	propertyChange:	HMS_PropertyChange;
begin

	if _workingDelay = null then
		return;
	endif;
	// Check all properties for changes
    // ------------------------------------------------------------------------

	// Delay Reason
    // Property has changed
    if self.myDelay &lt;&gt; _workingDelay.myDelay then
		create propertyChange;
   		propertyChange.set(_transaction, "Delay Reason", self.myDelay.description, _workingDelay.myDelay.description);
	endif;

	// Start DT for delay
    // Property has changed
    if self.startTime &lt;&gt; _workingDelay.startTime then
		create propertyChange;
   		//oldStr := self.startTime.date.format('dd/MM/yy') &amp; ", " &amp; self.startTime.Time.currentLocaleFormatJMT();
		oldStr := self.startTime.shortCurrentLocaleSystemUTC();					// 30/5/16 cnwmp6 TFS 488 - Multi timezone support
		//newStr := _workingDelay.startTime.date.format('dd/MM/yy') &amp; ", " &amp; _workingDelay.startTime.Time.currentLocaleFormatJMT();
		newStr := _workingDelay.startTime.shortCurrentLocaleSystemUTC();		// 30/5/16 cnwmp6 TFS 488 - Multi timezone support
   		propertyChange.set(_transaction, "Start of delay", oldStr, newStr);
	endif;

	// End DT for delay
    // Property has changed
    if self.stopTime &lt;&gt; _workingDelay.stopTime then
		create propertyChange;
   		//oldStr := self.stopTime.date.format('dd/MM/yy') &amp; ", " &amp; self.stopTime.Time.currentLocaleFormatJMT();
		oldStr := self.stopTime.shortCurrentLocaleSystemUTC();					// 30/5/16 cnwmp6 TFS 488 - Multi timezone support
		//newStr := _workingDelay.stopTime.date.format('dd/MM/yy') &amp; ", " &amp; _workingDelay.stopTime.Time.currentLocaleFormatJMT();
		newStr := _workingDelay.stopTime.shortCurrentLocaleSystemUTC();			// 30/5/16 cnwmp6 TFS 488 - Multi timezone support
   		propertyChange.set(_transaction, "End of delay", oldStr, newStr);
	endif;

	// Delay isChargeable
    // Property has changed
    if self.isChargeable &lt;&gt; _workingDelay.isChargeable then
		create propertyChange;
   		if self.isChargeable then
   			oldStr := "Chargeable";
		else
			oldStr := "NOT Chargeable";
		endif;
		if _workingDelay.isChargeable then
   			newStr := "Chargeable";
		else
			newStr := "NOT Chargeable";
		endif;
   		propertyChange.set(_transaction, "Chargeable Status", oldStr, newStr);
	endif;
end;</source>
        <Parameter name="_transaction" type="HMS_Transaction"/>
        <Parameter name="_workingDelay" type="CMIF_HMS_VoyageDelay"/>
    </JadeMethod>
    <JadeMethod name="createTransaction" id="0bff3d88-b5e5-416a-a501-767d8549e9bf">
        <source>createTransaction(_type : Integer; _cmifVoyageDelayWorking : CMIF_HMS_VoyageDelay; _pxyVoyDelay : HMS_VoyageDelay; _passport : CM_Passport input) protected;
//-----------------------------------------
//Created: July 2003 By: cnwgd1
//-----------------------------------------
vars
 	cmifTrans : CMIF_HMS_TransactionController;
begin
	// This method creates a cmifTrans for all the changes that take place when the 
	// permanent voyage is added NOTE: A single cmifTrans may cover changes to one or more properties
	create cmifTrans transient;

	// Set general cmifTrans properties and references
	cmifTrans.myPersistentVoyageDelay := self;
	cmifTrans.myWorkingDelay := _cmifVoyageDelayWorking;
	cmifTrans.myHMSVoyageData := self.myVoyageData;
	cmifTrans.myProxyHMSObject := _pxyVoyDelay;
	
 	if cmifTrans.myHMSVoyageData = null then
 		cmifTrans.myHMSVoyageData := _cmifVoyageDelayWorking.myWorkingVoyage.myHMSVoyageData;
 	endif;
	if self.myVoyageData &lt;&gt; null then
		cmifTrans.myTerminal := self.myVoyageData.myVoyage.myTerminalActive;
	endif;
	
	if cmifTrans.myTerminal = null then
		cmifTrans.myTerminal := _passport.myTerminal;
	endif;
		
	cmifTrans.type := _type;
	
	cmifTrans.createTransaction(_passport);

epilog
	delete cmifTrans;
end;</source>
        <access>protected</access>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_cmifVoyageDelayWorking" type="CMIF_HMS_VoyageDelay"/>
        <Parameter name="_pxyVoyDelay" type="HMS_VoyageDelay"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
