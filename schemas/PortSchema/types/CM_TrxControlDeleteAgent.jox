    <JadeMethod name="trxDeleteYardActivity" id="53e0aab5-f386-471f-8d1f-20266846c284">
        <updating/>
        <source>trxDeleteYardActivity( pYardActivities : CM_YardActivityDict input; _passport : CM_Passport input ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 July 2020	jlgndl1	Initial creation	TFS 49581

*/

vars

	yardActivity : CM_YardActivity;

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	

	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;
	
	foreach yardActivity in pYardActivities do

		app.myUtilityDA.utlDeleteYardActivity( yardActivity, _passport );
		
		if _passport.hasErrors then
			break;
		endif;
	
	endforeach;
	
epilog		
	self.finaliseActivityWithPassport(_passport);
end;</source>
