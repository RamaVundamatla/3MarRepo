    <JadeMethod name="setToDoTaskComplete" id="87a455ec-09ec-4d0d-aaaf-9d7f0f7d9359">
        <updating/>
        <source>setToDoTaskComplete(_wle : CM_WorkListEntry input) updating;
/*
Purpose - 	
Who - NAVAB1
Date - 27SEP2023
ADO - CR 60699 TASK 60700 
05 Jul 2024 navbs1  CR 64901 Task 64903: UI - Show Cargo Ids in To Do Complete Thin Client
Functionality Moved From WO Opeartion to WO Enquiry
23 Aug 2024 navlc30 Bug 65665: EUP | Complete Job button should not be available on the Unallocated tab for the VAS work orders
06 Mar 2025 navma1 MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars

	wle : CM_WorkListEntry;
	wleArray : CM_WLEArray;
	tiTask : CM_ToDoTask;
	realTiSet : CM_TISet;
	pxyTiSet : CM_TISet;
	ti : CM_TrackedItem;
	taskDescCode : Integer;
	resourceUsageProxys : CM_ResourceTypeUsageSet;
	theResult : Integer;	
	resourceUsageResult : Boolean;
	selObj 				: Object;
 	workOrder			: CM_WorkOrder;	
	job					: CM_Job;
	woToDoTask			: CM_WodToDo;	
	
begin
	
	selObj := self.tblData.allSelectedObjects.first;
	
	workOrder := selObj.CM_WorkOrder;
	
	woToDoTask := workOrder.allWoDtls.first.CM_WodToDo;
	
	if woToDoTask = null then
		return;
	endif;
	
	job := woToDoTask.allJobs.first;	
	
	if job = null then
		return;
	endif;

	if _wle = null or not _wle.isKindOf(CM_WOToDoWLE) then
		app.msgBox(app.getErrorString(Select_work_entry_complete),app.getErrorString(Make_selection), MsgBox_Stop_Icon + MsgBox_OK_Only);
		return;	
	endif;
	
	tiTask := self.getToDoTask(_wle.CM_WOToDoWLE);
	taskDescCode := tiTask.toDoTaskDescCode;

	if _wle.isForToDoWOTransaction() then
		if not tiTask.toDoTaskDesc.allResourceTypes.isEmpty then
			create resourceUsageProxys transient;	// will be populated with template versions of the resources to apply..
			resourceUsageResult := self.myAssistant.showResourceTypeUsageForTxn(null, null, tiTask.toDoTaskDesc, null, resourceUsageProxys, true, _wle.job.CM_WorkOrderJob);	//05.07.2024  navbs1  CR 64901 Task 64903
			if resourceUsageResult = false then
				// failed to create the form or was cancelled.
				app.msgBox(app.getErrorString(Resource_Usage_Form_Not_shown),app.getErrorString(Error),MsgBox_OK_Only + MsgBox_Stop_Icon);
				return;
			endif;
		endif;
		
		while true do
			app.myTrxUA.trxUpdateWODTIToDoNoTIComplete(_wle.CM_WOToDoWLE,tiTask.CM_TiToDoTask,resourceUsageProxys,app.myPassport);
			if app.myPassport.trxCompletedOK then
				break;
			else
			theResult := app.showErrorWarningDialog("Complete", app.myPassport, ErrWarnMode_Update);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;

			break;
		endwhile;
		return;
	endif;
	
	ti := _wle.myTrackedItem;

	create wleArray transient;
	foreach wle in job.workListEntries  discreteLock do			//06.03.2025 navma1 #MTN-34179
		if wle = null or not wle.isKindOf(CM_WOToDoWLE) then
			continue;
		endif;		
		if wle = null then
			// wle is set to null by the ex handler if it is not found / deleted
			continue;
		endif;
		wleArray.add(wle);
	endforeach;
	
	create realTiSet transient;
	foreach wle in wleArray where self.canCompleteToDoWLE(wle.CM_WOToDoWLE) do
		if wle.myTrackedItem &lt;&gt; null then 
			if not realTiSet.includes(wle.myTrackedItem) then
				realTiSet.add(wle.myTrackedItem);
			endif;
		endif;	
		
	endforeach;

	create pxyTiSet transient;
	
	if not self.myAssistant.doTaskProxySetForComplete( taskDescCode, pxyTiSet, ti, realTiSet, resourceUsageProxys) = IDOK then
		return;
	endif;
	
	while true do
	
		app.myTrxUA.trxUpdateTIToDoTaskCmpltBulk(tiTask.toDoTaskDesc, pxyTiSet, resourceUsageProxys, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog("Complete", app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
epilog

	if pxyTiSet &lt;&gt; null and not pxyTiSet.isEmpty then
		pxyTiSet.purge;
	endif;
	delete pxyTiSet;
	delete realTiSet;
	delete wleArray;
	

end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="447437af-890c-495d-add0-da597c90a0b7">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23/07/2009	cnwmd1	Initial creation
25/05/2018	jlgdap1	TFS 38560 PEL1 Voyage Work Orders
24/09/2021	jlizm1	TFS 51963 SAL Voyage Request Changes
29/09/2021  navma1  ChangeRequest 51925: SAL - Web Portal Cargo Work Orders
25/04/2022  navma1  ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
14 Mar 2023 navhl20  ChangeRequest 56844:[56845] EUP - VAS Work Order Remarks
21/12/2022 	navcs2 	ChangeRequest 56006: EUP - New VAS Workorder Subscription 
10/03/2023	navcs2	ChangeRequest Task 57034:[57035]: EUP - Status bar to show work order count at Work order Enquiry Screen
16/05/2024	navdap1	TFS 64055 EUP - lock/1038 when loading an EDI file while Work Order Screen is open
28 May 2024 navhl20 Bug 64275: MTN - Work Order Enquiry Screen Freeze due to notifications - Phase 2 
26/11/2024	navkc1 JIRA Story MTN-19092: EUP | 54014 - Work Orders Enhancements - Improved Search and usability
*/

vars
	term : CM_Terminal;
begin
	term 				:= self.myTerminal;					//29.09.2021 navma1 #51925
	self.isUseYardJobs	:= term.isUseYardJobsForCargoWo;    //29.09.2021 navma1 #51925
	
	self.usesQueryFrame  := true;
	self.toolbarStyle	 := self.ToolbarStyle_ShowNoHide;
	self.showToolbar 	 := true;
	self.useTableSorting := true;
	self.useTableInfo 	 := true;
	
	inheritMethod();

	self.setCaption(app.getErrorString(Work_order) &amp; " " &amp; app.getErrorString(Enquiry));
	self.setNavigatorHeading(self.caption);
	
	self.setDefaults();
	self.setContextMenuItems();

	//jlier1 29/5/25 MTN-34591 
	//only need create system events - updates &amp; deletes are handled on object notes when the object is added to table in - doNotableAdd
	self.beginClassNotification(CM_WorkOrder,    false, self.myTerminal.getTerminalEvent(Event_WorkOrder_Create), Response_Continuous, null);		
	self.beginClassNotification(CM_WorkOrderDtl,    false, self.myTerminal.getTerminalEvent(Event_WODtl_Create), Response_Continuous, null);
	
	/*
		self.beginClassNotification(CM_WorkOrder,    false, Any_System_Event, Response_Continuous, null);			// TFS 38560
		self.beginClassNotification(CM_WorkOrderDtl, false, Any_System_Event, Response_Continuous, null);
		self.beginClassNotification(CM_WorkOrderTIDtl, false, self.myTerminal.getTerminalEvent(Event_WODtl_Update), Response_Continuous, null);			//28.05.2024 navhl20 #64275*/
	
	
	self.hasVasSubscription := app.myPassport.isVASEnabled(); 												// 21/12/2022 navcs2 ChangeRequest 56006
	self.initSearch();																						// 21/12/2022 navcs2 ChangeRequest 56006
	
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(term, self.permissionMaint) then
		self.btnDelete.enabled   	  := false;
		self.btnNewCargoWO.enabled    := false;
		self.btnEditItem.enabled	  := false;
		self.btnNewVoyWO.enabled 	  := false;																	// TFS 38560
	endif;
	
	//29.09.2021 navma1 #51925
	if not  self.isUseYardJobs then
		self.lblSchedule.visible        := false;
		self.lblScheduleTo.visible      := false;
		self.mskScheduleDT.visible 		:= false;
		self.mskScheduleTM.visible		:= false;
		self.mskScheduleToDT.visible    := false;
		self.mskScheduleToTM.visible    := false;
	endif;
	
	self.btnOOWConfirm.enabled  := false;
	self.btnAttachments.enabled := false;	// TFS 51963
	self.doBuildComboVoyage(); 				// TFS 41026	
	self.buildUsersCombo();					//29.09.2021 navma1 #51925
	self.staStatusBar.visible := true;		//10.03.2023	navcs2 #57034:[57035]
	self.doBuildComboToDoTaskDesc(); 		//26/11/2024	navkc1 JIRA Story MTN-19092
	self.setDateTimeToNow(); 				//26/11/2024	navkc1 JIRA Story MTN-19092
	self.doBuildComboTrain();				//26/11/2024	navkc1 JIRA Story MTN-19092
	self.doBuildComboVehicleVisit();		//26/11/2024	navkc1 JIRA Story MTN-19092
	
	//self.beginTimer(500, Timer_OneShot, self.Timer_Notification);	// TFS 64055 //07/05/2025	navkc1 JIRA MTN-34592 Using notification framework

epilog

end;</source>
    </JadeMethod>
