    <JadeMethod name="setPxyFromCMIF_TBAContainer" id="297916f2-dbc3-4fcc-9b19-867655f4e700">
        <updating/>
        <source>setPxyFromCMIF_TBAContainer(_theInterface: CMIF_TBAContainer) updating;
// ---------------------------------------------------------------------------
// Created:		July 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 11/09/2014	cnwdap1		PAR #33872 Add measurement types to TBAs
vars

begin
	inheritMethod(_theInterface);
	
	if _theInterface.myISOType &lt;&gt; null then
		self.zSetPxyISOType(_theInterface.myISOType.code);
	endif;
	
	self.overHeight 		:= _theInterface.height;		// PAR #33872
	self.overLengthFront 	:= _theInterface.length;		// PAR #33872
	self.overWidthLeft 		:= _theInterface.width;			// PAR #33872
end;</source>
        <Parameter name="_theInterface" type="CMIF_TBAContainer"/>
    </JadeMethod>
    <JadeMethod name="setPxyFromCMIF_VoyageCargo" id="8007226f-403e-4d25-8d22-acaba38c76b8">
        <updating/>
        <source>setPxyFromCMIF_VoyageCargo(_theInterface: CMIF_VoyageCargo) updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 01/12/2009	cnwdap1		CCMS MES 1007 Move reefer properties up to CM_TrackedItem level
// 07 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
// ---------------------------------------------------------------------------

vars

	now : TimeStamp;

begin
	inheritMethod(_theInterface);

	now := app.actualTimeServer();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
		
	self.isoType := _theInterface.isoType;
	
	self.offsiteCleaned := _theInterface.offsiteCleaned;
	self.offsitePreTrip := _theInterface.offsitePreTrip;
	
	
	//16 Sep 2010	NDL	Par 25608	- Use new CM_SealTI structure.
	if not _theInterface.allSeals.isEmpty then
		// if sealTIs has been populated, then use them, otherwise assume data is pre-conversion or from a source not
		// supporting teh new structure, i.e. EDI
		self.createProxySeals(_theInterface.allSeals);
	else
		self.createProxySealTIsFromRawData(	_theInterface.getSealNum,	//_sealNum : String;
											_theInterface.getPrevSealNum,	//_prevSealNum : String;
											_theInterface.getSealNumShippers,	//_sealNumShippers : String;
											_theInterface.getSealNumVent,	//_sealNumVent : String;
											_theInterface.getSealNumCustoms,	//_sealNumCustoms : String;
											_theInterface.getSealNumTerminalOperator(),
											_theInterface.getSealNumUnknown(),
											now	//_now : TimeStamp
											);
	endif;

end;</source>
        <Parameter name="_theInterface" type="CMIF_VoyageCargo"/>
    </JadeMethod>
    <JadeMethod name="setPxyFromDefaultTI" id="f9862a83-d2a1-4b6d-ab9e-e4a7350f4a19">
        <updating/>
        <source>setPxyFromDefaultTI(_terminal : CM_Terminal; _cargoType: Integer; _id, _commodity: String; _oper : CM_Operator) updating;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	isoType : CM_ISOType;
begin
	inheritMethod(_terminal, _cargoType, _id, _commodity, _oper);
	
	isoType := _terminal.getConfig(DefISOType).CM_ISOType;

	if isoType &lt;&gt; null then
		self.isoType := isoType.code;
	endif;

	self.updateContentsStatus();
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_id" type="String"/>
        <Parameter name="_commodity" type="String"/>
        <Parameter name="_oper" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="setPxyFromEDIBayPlanTI" id="4ef052d1-2577-4258-bc5a-dd7ace3e64ce">
        <updating/>
        <source>setPxyFromEDIBayPlanTI(pEdiTi: CM_EDIBayPlanTI; pVoyage: CM_Voyage; _updateController: CMIF_TIUpdateController input; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     28 September 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 01/12/2009	cnwdap1		CCMS MES 1007 Move reefer properties up to CM_TrackedItem level
// 07 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
// 127/06/2017	cnwdap1		TFS 4492 SNO VERMAS Changes
// ---------------------------------------------------------------------------
vars
	aCOU	: CM_ClipOnUnit;
	now : TimeStamp;
begin
	inheritMethod(pEdiTi, pVoyage, _updateController, _passport);
	
	now := app.actualTimeServer();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
		
	self.changeISOType(pEdiTi.isoType, _updateController, _passport);

	//16 Sep 2010	NDL	Par 25608	- Use new CM_SealTI structure.
	self.createProxySealTIsFromRawData(	pEdiTi.sealNum,	//_sealNum : String;
										null,	//_prevSealNum : String;
										null,	//_sealNumShippers : String;
										null,	//_sealNumVent : String;
										null,	//_sealNumCustoms : String;
										null,
										null,
										now	//_now : TimeStamp
										);
	
	//cnwmc5 - 23 Jan 2014 - PAR 33001
	if pEdiTi.overHeight &lt;&gt; NULL_INTEGER then
		self.overHeight			:=	pEdiTi.overHeight;
	endif;
	if pEdiTi.overLengthFront &lt;&gt; NULL_INTEGER then
		self.overLengthFront	:=	pEdiTi.overLengthFront;
	endif;
	if pEdiTi.overLengthBack &lt;&gt; NULL_INTEGER then
		self.overLengthRear		:=	pEdiTi.overLengthBack;
	endif;
	if pEdiTi.overWidthLeft &lt;&gt; NULL_INTEGER then
		self.overWidthLeft		:=	pEdiTi.overWidthLeft;
	endif;
	if pEdiTi.overWidthRight &lt;&gt; NULL_INTEGER then
		self.overWidthRight		:=	pEdiTi.overWidthRight;
	endif;
	
	self.setMyVGMDetails(	pEdiTi.weightCertifiedReference,	// TFS 4492
							pEdiTi.weightCertifiedName,			// TFS 4492
							pEdiTi.vgmAuthSignature,			// TFS 4492
							pEdiTi.vgmCommsType,				// TFS 4492
							pEdiTi.vgmDocumentDetails,			// TFS 4492
							pEdiTi.vgmEDITransmission,			// TFS 4492
							pEdiTi.vgmElectronicMail,			// TFS 4492
							pEdiTi.vgmMail,						// TFS 4492
							pEdiTi.vgmPhone,					// TFS 4492
							pEdiTi.vgmTelefax,					// TFS 4492
							pEdiTi.vgmTelephone,				// TFS 4492
							pEdiTi.vgmDocsIssuedDT,				// TFS 4492
							pEdiTi.vgmDeterminationDT,			// TFS 4492
							null 	);							// TFS 4492
end;</source>
        <Parameter name="pEdiTi" type="CM_EDIBayPlanTI"/>
        <Parameter name="pVoyage" type="CM_Voyage"/>
        <Parameter name="_updateController" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setPxyFromEDILoadListTI" id="66284540-6bfe-4512-b942-2af4fdbcd738">
        <updating/>
        <source>setPxyFromEDILoadListTI(_ediTi: CM_EDILoadListTI; _voyage: CM_Voyage; _passport: CM_Passport input) updating;
//----------------------------------------------------------------
//	Created:	22 October 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 01/12/2009	cnwdap1		CCMS MES 1007 Move reefer properties up to CM_TrackedItem level
// 28 May 2012	cnwrs1	Par 31625 DPH Load list changes
// 07 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
// 27 Jun 2017	cnwdap1	TFS 4492 SNO VERMAS Changes
// ---------------------------------------------------------------------------
vars
	now : TimeStamp;
begin
	inheritMethod(_ediTi, _voyage, _passport);

	now := app.actualTimeServer();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
		
	self.zSetPxyISOType(_ediTi.isoType);
	//self.setTemperature(_ediTi.temperature);				// CCMS 1007
	
	//self.sealNum := _ediTi.sealNum; //ccms1690 cnwrs1 mar 2008
	//16 Sep 2010	NDL	Par 25608	- Use new CM_SealTI structure.
	self.createProxySealTIsFromRawData(	_ediTi.sealNum,	//_sealNum : String;
										null,	//_prevSealNum : String;
										_ediTi.sealShipper,	//_sealNumShippers : String;
										_ediTi.sealNumberVent,	//_sealNumVent : String;
										_ediTi.sealCustoms,	//_sealNumCustoms : String;
										_ediTi.sealTerminalOperator,
										_ediTi.sealUnknown,
										now	//_now : TimeStamp
										);
	
	self.setMyVGMDetails(	_ediTi.weightCertifiedReference, 	// TFS 4492
							_ediTi.weightCertifiedName, 		// TFS 4492
							_ediTi.vgmAuthSignature,			// TFS 4492
							_ediTi.vgmCommsType,				// TFS 4492
							_ediTi.vgmDocumentDetails,			// TFS 4492
							_ediTi.vgmEDITransmission,			// TFS 4492
							_ediTi.vgmElectronicMail,			// TFS 4492
							_ediTi.vgmMail,						// TFS 4492
							_ediTi.vgmPhone,					// TFS 4492
							_ediTi.vgmTelefax,					// TFS 4492
							_ediTi.vgmTelephone,				// TFS 4492
							_ediTi.vgmDocsIssuedDT,				// TFS 4492
							_ediTi.vgmDeterminationDT,			// TFS 4492
							null	);							// TFS 4492
							
	
end;</source>
        <Parameter name="_ediTi" type="CM_EDILoadListTI"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setPxyFromFieldValue" id="ec22a182-40d0-4604-8b4f-cd9db7fc523a">
        <updating/>
        <source>setPxyFromFieldValue(_fieldName:String; _fieldValue:String; _errLinkObj : Object; _passportObj:CM_Passport input) updating;
// --------------------------------------------------------------------------------
// Created:		02 February 2010 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 02/02/2010	cnwdad1		PAR #21946 - Added this reimplemented method.
//01 Feb 2018   cnwma1      ChangeRequest 36751: POL - ‘is Externally Monitored’ for EDI User Defined File Types
// 03/02/2023	jlizm1		TFS 56416 PNL Update Reefer PTI from edi
// --------------------------------------------------------------------------------
vars
	upperFieldName	: String;
	
begin

	upperFieldName := _fieldName.toUpper;

	if upperFieldName = CM_EDICargoFieldUpdateTI.F_AvailabilityGrade.toUpper then
		//self.setAvailabilityGrade(_fieldValue.Integer, _updControllerObj, _passportObj);
		self.availabilityGrade 		:= _fieldValue.Integer;
		
	elseif upperFieldName = CM_EDICargoFieldUpdateTI.F_ShipperSeal.toUpper then
		self.setSealNumShippers(_fieldValue);
	
	elseif upperFieldName = CM_EDICargoFieldUpdateTI.F_IsExternallyMonitored.toUpper then  //01.02.2018 cnwma1 TF #36751
		self.setExternalMonitoring(_fieldValue.asBooleanJMT);
	
	elseif upperFieldName = CM_EDICargoFieldUpdateTI.F_PreTripDT.toUpper() then	// TFS 56416
		self.setPreTripDT(_fieldValue.asTimeStampJMT());
	else
		inheritMethod(_fieldName, _fieldValue, _errLinkObj, _passportObj);
	endif;
end;</source>
        <Parameter name="_fieldName" type="String"/>
        <Parameter name="_fieldValue" type="String"/>
        <Parameter name="_errLinkObj" type="Object"/>
        <Parameter name="_passportObj" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setPxyFromNamedFields" id="b50f08de-3f25-4488-a6ad-4dc91ef41c62">
        <updating/>
        <source>setPxyFromNamedFields(_value: Any; _field:String) updating;
// ---------------------------------------------------------------------------
// Created:     Jan 2006 cnwrs1
// update selected fields by name
// ---------------------------------------------------------------------------
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 01/12/2009	cnwdap1		CCMS MES 1007 Move reefer properties up to CM_TrackedItem level
// ---------------------------------------------------------------------------
vars
	//now : TimeStamp;
begin
	self.raiseExceptionIfNotTransient(method);

	if _field = CM_Container::isoType.name then
		self.changeISOType(_value.String, null, app.myPassport);
	else
		inheritMethod(_value, _field);
	endif;
end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_field" type="String"/>
    </JadeMethod>
    <JadeMethod name="setPxyGenerator" id="7eac53f3-d8f6-48dc-be17-8dc42dd437d4">
        <updating/>
        <source>setPxyGenerator(pProxyGenerator : CM_Generator) updating;
// ---------------------------------------------------------------------------
// Created:      18 July 2003 by cnwsgp1
// ---------------------------------------------------------------------------
begin
	if pProxyGenerator &lt;&gt; null then // removing a generator
		if not pProxyGenerator.isTransient then
			app.raiseCMException1(NotAProxyObject,"Generator " &amp; pProxyGenerator.id,"", null);
		endif;
	endif;
	if not self.isTransient then
		app.raiseCMException1(NotAProxyObject,"Container " &amp; self.id,"", null);
	endif;

	self.setGenerator(pProxyGenerator);
end;</source>
        <Parameter name="pProxyGenerator" type="CM_Generator"/>
    </JadeMethod>
