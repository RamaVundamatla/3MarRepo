    <JadeMethod name="validate" id="66ce0628-7b95-4708-b6bf-04ef6fd426d3">
        <updating/>
        <source>validate(_passport : CM_Passport input; pUserObject : Object) updating, protected;
/* ---------------------------------------------------------------------------
Created:     11 January 2010 by cnwrs2

Purpose:     
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars

begin
	if self.cargoType = null then
		app.raiseCMException1 (WARN_GENERIC, 'There is no value entered for Cargo Type', null, null);
	endif;
	
	if self.cargoType &lt;&gt; null then
		if self.myCargoType.isCommodityRequired then
			if self.commodity = null then
				app.raiseCMException1 (WARN_GENERIC, 'A commodity is required for this Cargo Type', null, null);
			endif;
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="pUserObject" type="Object"/>
    </JadeMethod>
