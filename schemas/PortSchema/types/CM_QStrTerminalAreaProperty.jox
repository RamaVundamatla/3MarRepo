    <JadeMethod name="create" id="28dcbf87-89a8-445e-83e1-3a81420dff1f">
        <updating/>
        <source>create() updating;

vars
	oper : CM_QueryOperator;
begin
	if self.isTransient then 
		return;
	endif;
	create oper as CM_QStringIsOneOf persistent;
	self.allAllowedOperators.add(oper);
end;
</source>
    </JadeMethod>
    <JadeMethod name="getControlNameForOperator" id="b55ee3f7-f8c2-4c9f-8a95-7da86d54b4ea">
        <source>getControlNameForOperator(_operator: CM_QueryOperator): String;

vars

begin
	if CM_QStringLookup.hasInstance(_operator) then
		return 'cmbTerminalArea';
	endif;
end;
</source>
