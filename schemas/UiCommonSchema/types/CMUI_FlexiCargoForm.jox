    <JadeMethod name="hasPreNote" id="b748861e-5460-44e0-ad40-2f23598d86b9">
        <source>hasPreNote() : Boolean protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 July 2009	cnwdap1	Initial creation

