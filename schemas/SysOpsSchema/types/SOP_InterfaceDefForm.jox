    <JadeMethod name="cmbTermArea_gotFocus" id="c68503bd-5ba2-4b2d-b0c8-291b82d7bc9f">
        <controlMethod name="ComboBox::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbTermArea_gotFocus(combobox: CMUI_ComboBox input) updating;
// --------------------------------------------------------------------------------
// Created:		05 September 2008 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if combobox.text &lt;&gt; null then
		combobox.selStart	:=	0;
		combobox.selLength	:=	combobox.text.length();
	endif;
	
	self.doEnableControls();
end;</source>
        <Parameter name="combobox" type="CMUI_ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbType_click" id="34815156-51f7-4570-9498-88316e7de409">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbType_click(combobox: ComboBox input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 December 2009	#cnwdz2	 par21593

*/

vars

begin
	if combobox.text = ITSRNSServer then
		self.lblMaxQEntries.visible := true;
		self.lblMessageACKTO.visible := true;
		self.txtMaxQEntries.visible := true;
		self.txtMessageACKTO.visible := true;
		self.btnResetInterfac.visible:= true;
		self.btnViewMessage.visible := true;
		self.shtTranslations.visible := false;
		return;
	endif;

	if combobox.text = TCPListener then
		self.lblMaxQEntries.visible := false;
		self.lblMessageACKTO.visible := false;
		self.txtMaxQEntries.visible := false;
		self.txtMessageACKTO.visible := false;
		self.btnResetInterfac.visible:= false;
		self.btnViewMessage.visible := false;
		self.shtTranslations.visible := true;
		return;
	endif;
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="comboboxPopulateDefinitions" id="096a5750-e9ed-4216-a8e8-a453107c9f0b">
