    <JadeMethod name="getKeyString" id="4c5860a5-ace2-47eb-8749-37ddf71312d2">
        <source>getKeyString(	_top : Integer; _left : Integer; _attrib : Integer ):String protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 July 2014	cnwndl1	Initial creation	Par 34611

*/

vars

begin

	// if you change this, you will need to change "printFields" as well
	return _top.padLeadingWith("0",4) &amp; _left.padLeadingWith("0",4) &amp; _attrib.padLeadingWith("0",3);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_top" type="Integer"/>
