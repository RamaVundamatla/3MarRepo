    <JadeMethod name="setupControls" id="fe3d16b2-9933-4758-aac8-6bab7466f728">
        <updating/>
        <source>setupControls() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 May 2013	cnwndl1	Initial creation	Par 31506

*/

vars

begin

	self.setCaption;
	
	self.doResizeControls(true);

	frmHelp.visible := false;
	self.isMenuBuilt := false;
	
	self.populateTrackedItem();	
	self.txtCargoId.setFocus;
	
epilog

end;</source>
