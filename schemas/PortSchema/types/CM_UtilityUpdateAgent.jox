    <JadeMethod name="utlUpdateDutyChargesManual" id="0d915e8f-ef12-498e-be21-1ae0b41c7f54">
        <source>utlUpdateDutyChargesManual(_dutyDoc: CM_DutyDoc; _pxyCharge : CM_Charge; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 July 2014	cnwma1	Initial creation
31 July 2014    cnwma1 PAR 34408 Credit Customer current charges
*/

vars
	cancelSave:Boolean;
	realCharge:CM_Charge;
	expectedEdition:Integer;
	theInvLine : CM_InvoiceLine;
begin

	self.initialiseActivity();

	_pxyCharge.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_pxyCharge.pxyGetRealObjectAndEdition(realCharge, expectedEdition);
	
	if realCharge = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_Charge.name, null, null);
		return;
	endif;

//	app.myValUA.valChargeQualify(realCharge, _pxyCharge);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;


	app.setContinueCMExceptions(false);

	exclusiveLock(realCharge);

	if _passport.noErrors and realCharge.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Charge', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realCharge, true);
	endif;
	
	if _passport.noErrors then
		realCharge.setForUpdate(_pxyCharge);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realCharge, false);
		theInvLine := realCharge.invoiceLine;
		
		if theInvLine.myTransactionTI.isKindOf(CM_DutyCharge) then         // +cnwma1 31/07/2014 PAR 34408
			theInvLine.myTransactionTI.CM_DutyCharge.setDutyDocId(_dutyDoc.id);
		endif;																//+ cnwma1 31/07/2014 PAR 34408
		theInvLine.causeEvent(_passport.myTerminal.getTerminalEvent(Event_InvoiceLineUpdate), false, theInvLine);
	endif;

epilog
	
	
end;</source>
        <Parameter name="_dutyDoc" type="CM_DutyDoc"/>
        <Parameter name="_pxyCharge" type="CM_Charge"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateDutyDoc" id="0e453e3d-475b-4e80-8247-2e5469437a17">
        <source>utlUpdateDutyDoc(_proxyDutyDoc : CM_DutyDoc input; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 December 2012	cnwer1	Initial creation HAT 2189

*/

vars
	realDutyDoc : CM_DutyDoc;
	expectedEdition : Integer;
	generateDocDeposit : Boolean;
	generateDutyDeposit : Boolean;
	dutyDeposit : Decimal [16,4];
	debtor : CM_Debtor;
begin
	self.initialiseActivity();

	_proxyDutyDoc.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_proxyDutyDoc.pxyGetRealObjectAndEdition(realDutyDoc, expectedEdition);
	
	if realDutyDoc = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_DutyDoc.name, null, null);
		return;
	endif;

	app.myValUA.valCM_Object( _proxyDutyDoc,_passport);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;

	app.setContinueCMExceptions(false);

	exclusiveLock(realDutyDoc);

	if _passport.noErrors and realDutyDoc.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Duty Doc', null, null);
		return;
	endif;
	
	generateDocDeposit := ( _proxyDutyDoc.docDeposit &lt;&gt; realDutyDoc.docDeposit ) and _proxyDutyDoc.docDeposit = true;
	generateDutyDeposit := ( _proxyDutyDoc.dutyDeposit &lt;&gt; realDutyDoc.dutyDeposit ) and ( _proxyDutyDoc.dutyDeposit &lt;&gt; 0 );
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realDutyDoc, true);
	endif;
	
	if _passport.noErrors then
		realDutyDoc.setForUpdate(_proxyDutyDoc);
	endif;
	
	debtor := realDutyDoc.getMyDebtor();
	if generateDocDeposit and debtor &lt;&gt; null then
		//generate new doc deposit inv line
		app.myUtilityCA.utlCreateDutyDocDocDepositChg(realDutyDoc, _passport);
	endif;
	
	if not _passport.noErrors then
		return;
	endif;
	
	if generateDutyDeposit and debtor &lt;&gt; null then
		//generate new duty deposit inv line
		dutyDeposit := realDutyDoc.dutyDeposit;
		app.myUtilityCA.utlCreateDutyDocDutyDepositChg(realDutyDoc, dutyDeposit, _passport);
	endif;


	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realDutyDoc, false);
	endif;	
epilog

end;</source>
        <Parameter name="_proxyDutyDoc" type="CM_DutyDoc" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
