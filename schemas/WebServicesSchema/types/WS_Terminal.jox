<Class name="WS_Terminal" id="4bd697ca-25e4-4eb3-bc3b-d77398e6b633">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Represents  all terminals in the system</text>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="code" id="b71b3925-4515-4062-bf8c-28716e4afc77">
        <length>5</length>
        <embedded/>
        <type name="String"/>
        <text>
The Terminal Code</text>
    </PrimAttribute>
    <PrimAttribute name="name" id="2a27c5ed-62dd-4bbd-9e49-60cb22f40b19">
        <length>81</length>
        <embedded/>
        <type name="String"/>
        <text>The Terminal Name.</text>
    </PrimAttribute>
    <PrimAttribute name="systemTimeZoneID" id="d52d5323-6a8c-4a98-92f8-57c679b6abd2">
        <length>33</length>
        <embedded/>
        <type name="String"/>
        <text>The Windows Id for the timezone the system server is running under.</text>
    </PrimAttribute>
    <PrimAttribute name="timeZoneID" id="4067367b-e406-4a41-af31-d718eb9316d9">
        <length>33</length>
        <embedded/>
        <type name="String"/>
        <text>The Windows Id for the timezone this Terminal is using.</text>
    </PrimAttribute>
    <PrimAttribute name="timeZoneShortID" id="aadfb2fd-6991-4590-bd34-2d56eaf28b92">
        <length>11</length>
        <embedded/>
        <type name="String"/>
        <text>Short code defined for the Terminal's timezone.</text>
    </PrimAttribute>
    <PrimAttribute name="voyageProcess" id="4f7b659a-90e2-4af2-8435-502847dae88e">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="setProxyFromObject" id="112f0da4-33c8-4d7f-8f4d-0271c5f978d8">
        <updating/>
        <source>setProxyFromObject(_object: CM_Terminal) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 Jan 2009	cnwkpd1	PAR #17554 - Development of new RIA Web Service application
05/09/2016  cnwrh7  TFS2437    Add VGM details to Weight data entry for Mobile Web apps
31/05/2021  navma1  ChangeRequest 51002: MTN - Web Portal Cargo Work Orders
*/

vars

begin
	inheritMethod(_object);
	
	self.code 			  := _object.code;
	self.name 			  := _object.name;
	self.timeZoneID 	  := _object.timeZoneID;
	self.timeZoneShortID  := _object.timeZoneShortID;
	self.systemTimeZoneID := app.systemTimeZoneID;
	
	if _object.getDefaultVoyageProcess &lt;&gt; null then                   //31.05.2021 navma1 #51002
		self.voyageProcess := _object.getDefaultVoyageProcess.code;
	endif;
epilog

end;</source>
        <Parameter name="_object" type="CM_Terminal"/>
    </JadeMethod>
</Class>
