    <JadeMethod name="pxyCreateUpdateProxy" id="4aaacf4a-f354-42b1-a9aa-23e1673ac5b1">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 July 2018	jlgndl1	Initial creation	TFS 39186

*/

vars

	pxy : CM_WorkTask;
	completedOK : Boolean;

begin

	pxy :=  inheritMethod();
	
	pxy.myTerminal := self.myTerminal;

	completedOK := true;
	return pxy;

epilog

	if not completedOK then
		delete pxy;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
