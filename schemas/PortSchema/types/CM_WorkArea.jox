    <JadeMethod name="areasDisplayString" id="cb8aa12e-2821-4d55-9423-768117a9bd24">
        <source>areasDisplayString( _short :Boolean ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 November 2014	cnwndl1	Initial creation	Par 35295

*/

vars

	str : String;
	workStr : String;

begin

	if _short then
		if not self.allTerminalAreas.isEmpty then
			str := self.allTerminalAreas.size.String &amp; "x Term Areas";
		endif;
		if not self.allGridObjects.isEmpty then
			workStr := self.allGridObjects.size.String &amp; "x Grid Areas";
		endif;
		
		if str.trimBlanks = null then
			str := workStr;
		elseif workStr.trimBlanks &lt;&gt; null then
			str := str &amp; ", " &amp; workStr;
		endif;
		
		workStr := null;
		if not self.allLocationsControllers.isEmpty then
			workStr := self.allLocationsControllers.size.String &amp; "x Locations";
		endif;
		
		if str.trimBlanks = null then
			str := workStr;
		elseif workStr.trimBlanks &lt;&gt; null then
			str := str &amp; ", " &amp; workStr;
		endif;
		
	else
		str := self.getTerminalAreasString();
		workStr := self.getSubAreasString();
		
		if str.trimBlanks = null then
			str := workStr;
		elseif workStr.trimBlanks &lt;&gt; null then
			str := str &amp; ", " &amp; workStr;
		endif;
		
		workStr := null;
		workStr := self.getSubSubAreasString();
		
		if str.trimBlanks = null then
			str := workStr;
		elseif workStr.trimBlanks &lt;&gt; null then
			str := str &amp; ", " &amp; workStr;
		endif;
		
	endif;
	
	if str = null then
		str := app.getErrorString(None);
	endif;
	
	return str;

epilog

end;</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAllTisInArea" id="8a678d90-05a3-40cd-b630-a421b05d0a63">
        <source>getAllTisInArea( _tiSet : CM_TISet input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 May 2015	cnwndl1	Initial creation	Par 36181

*/

vars

	localSet : ObjectSet;
	localArray : CM_TIArray;
	ta : CM_TerminalArea;
	obj : Object;
	invalidObj : Boolean;
	edition : Integer;
	iter : Iterator;
	ti : CM_TrackedItem;
	go : CM_GridObject;
	lc : CM_LocationsController;

begin

	create localSet transient;
	create localArray transient;
	
	on Exception do app.handleDeletedObject( exception, ti, invalidObj );

	foreach ta in self.allTerminalAreas do
		localSet.clear();
		ta.getAllLocationsTrackedItems( localSet );
		iter := localSet.createIterator;
		while iter.next( obj ) do
			invalidObj := false;
			ti := obj.CM_TrackedItem;
			edition := ti.edition;
			if not invalidObj then
				_tiSet.addNoDuplicates( ti, false );
			endif;
		endwhile;
		delete iter;
	endforeach;
	
	foreach go in self.allGridObjects do
		localArray.clear();
		go.getTIs(localArray, REAL_MODE);
		iter := localArray.createIterator;
		while iter.next( ti ) do
			invalidObj := false;
			edition := ti.edition;
			if not invalidObj then
				_tiSet.addNoDuplicates( ti, false );
			endif;
		endwhile;
		delete iter;
	endforeach;
	
	foreach lc in self.allLocationsControllers do
		iter := lc.allTrackedItems.createIterator;
		while iter.next( ti ) do
			invalidObj := false;
			edition := ti.edition;
			if not invalidObj then
				_tiSet.addNoDuplicates( ti, false );
			endif;
		endwhile;
		delete iter;
	endforeach;
	
epilog

	delete localSet;
	delete localArray;
	delete iter;

end;</source>
        <Parameter name="_tiSet" type="CM_TISet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="f6530fbd-4a15-4b09-89bf-ca00f5fba6db">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 April 2014	cnwndl1	Initial creation	Par 33995

*/

vars

	str : String;
	ta : CM_TerminalArea;
	go : CM_GridObject;
	lc : CM_LocationsController;

begin

	if  _attrName = ETRow_Code then
		return self.code;
	
	elseif  _attrName = ETRow_Description then
		return self.description;
	
	elseif  _attrName = ETRow_NotAvailable then
		return self.notAvailableForEntry.String;
	
	elseif  _attrName = ETRow_TermAreas then
		return self.getTerminalAreasString();
	
	elseif  _attrName = ETRow_SubAreas then
		return self.getSubAreasString();
	
	elseif  _attrName = ETRow_SubSubAreas then
		return self.getSubSubAreasString();
		
	elseif _attrName = ETRow_AreasDefined then	//26 Nov 2014	NDL	Par 35295
		return self.areasDisplayString(false);
	
	else
	
		return inheritMethod(_attrName, _short);
	
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSubAreasString" id="1dd84a34-02b5-4e4b-9dcf-c6e4679dbbe7">
        <source>getSubAreasString():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 April 2014	cnwndl1	Initial creation	Par 33995

*/

vars

	str : String;
	ta : CM_TerminalArea;
	go : CM_GridObject;

begin

	foreach go in self.allGridObjects do
		ta := go.getGridArea;
		if str &lt;&gt; null then
			str := str &amp; ", ";
		endif;
		str := str &amp; ta.id &amp; " " &amp; go.getNiceName;
	endforeach;
	
	return str;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSubSubAreasString" id="1d302907-68f0-44a7-905b-fbd1ac791d46">
        <source>getSubSubAreasString():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 April 2014	cnwndl1	Initial creation	Par 33995

*/

vars

	str : String;
	lc : CM_LocationsController;

begin

	foreach lc in self.allLocationsControllers do
		if str &lt;&gt; null then
			str := str &amp; ", ";
		endif;
		str := str &amp; lc.getFullId;
	endforeach;
	
	return str;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
