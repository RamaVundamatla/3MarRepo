    <JadeMethod name="showTableDisplayMode" id="9f60cb22-e68a-4c2f-b0ab-3310d252aa0c">
        <source>showTableDisplayMode( _dispFrame : CMUI_Frame io) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 November 2009	cnwndl1	Initial creation	CCMS 1031

*/

vars

	dispMode : Integer;
	aPicture : Binary;
	lCaption : String;
	
begin
	if _dispFrame = self.frmDispOffsite then
		dispMode := self.displayModeOffSite;
	elseif _dispFrame = frmDispOnship then
		dispMode := self.displayModeOnShip;
	elseif _dispFrame = frmDispOnsite then
		dispMode := self.displayModeOnSite;
	elseif _dispFrame = frmDispPreNote then
		dispMode := self.displayModePreNote;
	else
		return;
	endif;

	if dispMode = DISPLAY_MODE_PLAN then	//3
		aPicture := app.myRoot.getConfig(PicDisplayModeP).Binary;
		lCaption := DISPLAY_MODE_PLAN_CAPTION;
	elseif dispMode = DISPLAY_MODE_QUEUE then	//2
		aPicture := app.myRoot.getConfig(PicDisplayModeQ).Binary;
		lCaption := DISPLAY_MODE_QUEUE_CAPTION;
	else
		aPicture := app.myRoot.getConfig(PicDisplayModeI).Binary;
		lCaption := DISPLAY_MODE_ACTUAL_CAPTION;
	endif;

	_dispFrame.width := self.stbGeneral.myFrameDisplayMode.width;
	_dispFrame.caption := null;
	_dispFrame.autoRedraw := true;
	_dispFrame.clearGraphics;
	_dispFrame.drawTextAt(lCaption,19,4, Black);
	_dispFrame.drawPictureAt(aPicture,1,3);
	

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_dispFrame" type="CMUI_Frame" usage="io"/>
    </JadeMethod>
    <JadeMethod name="showTranshipForm" id="88d8b96d-59b0-4a6b-af8a-a5b929ecba4c">
        <source>showTranshipForm();
//
// cnwrs1 Mar 2007 Par 13560 add tranship option to nonplanned non worked
//
vars
	tiArray : CM_TIArray;
