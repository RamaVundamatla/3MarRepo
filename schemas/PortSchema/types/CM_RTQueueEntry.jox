    <JadeMethod name="getAmountLeftToMoveDisplay" id="2b4badc8-ac9a-4a1d-b7d1-cf379802b156">
        <source>getAmountLeftToMoveDisplay() : String;
/*

Date		Who		Reason
21 March 2014	cnwer1	Initial creation PAR

*/

vars
	weightLeft : Decimal[14,4];
	wle : CM_WorkListEntry;
begin
	
	if self.isBulkMove then
		if self.myBreakBulkMaster &lt;&gt; null then
			weightLeft:=self.myBreakBulkMaster.weight - self.myBreakBulkMaster.weightMoved;
			wle:=self.myBreakBulkMaster.myWorkListEntry;
			return wle.getMoveAmountForWeight(weightLeft,true);
		else
			return self.myWorkListEntry.getMoveAmountDisplay(true);
		endif;
		
	else
		if self.myBreakBulkMaster &lt;&gt; null then
			return (self.myBreakBulkMaster.quantity - self.myBreakBulkMaster.totalMoved).asStringJMT;		
		else
			if self.isBreakBulkGenericMaster then
				return (self.quantity - self.totalMoved).asStringJMT;
			else
				return self.myWorkListEntry.getQuantity.asStringJMT;
			endif;
		endif;
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAmountMovedDisplay" id="78c9190a-6a04-4d2d-b3f0-29a627a4df1d">
        <source>getAmountMovedDisplay(_showUnit : Boolean) : String;
/*

Date		Who		Reason
19 March 2014	cnwer1	Initial creation PAR

*/

vars
	wle : CM_WorkListEntry;
begin
	if self.isBulkMove then
		
		if self.myBreakBulkMaster &lt;&gt; null then
			wle:=self.myBreakBulkMaster.myWorkListEntry;		
		else
			wle:=self.myWorkListEntry;
		endif;
	
		return wle.getMoveAmountForWeight(self.weight,_showUnit);
	else
		return self.quantity.asStringJMT;
	endif;
epilog

end;</source>
        <Parameter name="_showUnit" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAmountToMoveDisplay" id="6ba1d2c7-9a6a-4d13-bee7-d98a7c0013e4">
        <source>getAmountToMoveDisplay(_fromWLE : Boolean; _showUnit : Boolean) : String;
/*

Date		Who		Reason
12 March 2014	cnwer1	Initial creation PAR

*/

vars

	wle 	: CM_WorkListEntry;
begin
	if self.myBreakBulkMaster &lt;&gt; null then
		wle:=self.myBreakBulkMaster.myWorkListEntry;		
	else
		wle:=self.myWorkListEntry;
	endif;
	
	if _fromWLE then	
		return wle.getMoveAmountDisplay(_showUnit);	
	else
		if self.isBulkMove then
			return wle.getMoveAmountForWeight(self.weight,_showUnit);
		else
			return self.quantity.asStringJMT;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_fromWLE" type="Boolean"/>
        <Parameter name="_showUnit" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCargoType" id="0f27183f-cdae-4f18-9d33-5368360c30d9">
        <source>getCargoType() : CM_CargoType;
/*

Date		Who		Reason
08 April 2014	cnwer1	Initial creation PAR

*/

vars
	ti : CM_TrackedItem;
begin
	ti:= self.getTrackedItem();
	
	if ti &lt;&gt; null then 
		return ti.myCargoType;
	endif;
	
