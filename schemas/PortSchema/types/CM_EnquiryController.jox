    <JadeMethod name="queryExHandler" id="d3743485-84bf-450b-a64f-35425f9c5c9f">
        <updating/>
        <source>queryExHandler(exObj: Exception): Integer updating, protected;
// ---------------------------------------------------------------------------
// Created:     13 February 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	//1309 is obj already added to set
	if exObj.errorCode = 1309 then
		self.numItemsFound := self.numItemsFound - 1;
		return Ex_Resume_Next;
	else
		return Ex_Pass_Back;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="exObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="removeCritLine" id="46e9101e-4868-49cd-b7de-387277c55d1f">
        <source>removeCritLine(_propName : String; _propClassName : String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10/04/2024	navkc1 CR63383 Task 63384: Jade - Improved invoice queries

*/

vars

begin
	if self.myCriteriaLineHolder = null then
		return;
	endif;
	
	self.myCriteriaLineHolder.removeCritLine(_propName, _propClassName);
	
epilog

end;</source>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_propClassName" type="String"/>
    </JadeMethod>
