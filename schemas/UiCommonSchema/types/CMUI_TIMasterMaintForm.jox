    <JadeMethod name="translateForm" id="eaabb039-a0e5-4b90-9d31-f45d767de1f5">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 04 June 2025 11:33:04.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0008201, locale);
	btnCancel.translateCaption(Xlat_0010059, locale);
	btnDamage.translateCaption(Xlat_0013527, locale);
	btnDelete.translateBubbleHelp(Xlat_0001050, locale);
	btnDelete.translateCaption(Xlat_0001051, locale);
	btnNext.translateBubbleHelp(Xlat_0001052, locale);
	btnNext.translateCaption(Xlat_0001053, locale);
	btnOk.translateCaption(Xlat_0010060, locale);
	lblDescription.translateCaption(Xlat_0010062, locale);
	lblGenerator.translateCaption(Xlat_0022223, locale);
	lblID.translateCaption(Xlat_0010063, locale);
	lblID_1_1.translateCaption(Xlat_0013528, locale);
	lblISOType.translateCaption(Xlat_0010064, locale);
	lblLicenceIss.translateCaption(Xlat_0010065, locale);
	lblLicenceNo.translateCaption(Xlat_0010066, locale);
	lblOffHireDate.translateCaption(Xlat_0013529, locale);
	lblOperator.translateCaption(Xlat_0010067, locale);
	lblOwner.translateCaption(Xlat_0010068, locale);
	lblRemarks.translateCaption(Xlat_0013530, locale);
	lblStops.translateCaption(Xlat_0010069, locale);
	lblToDoTasks.translateCaption(Xlat_0010070, locale);
	lblWeight.translateCaption(Xlat_0010071, locale);
	txtFloorType.translateCaption(Xlat_0027088, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="unloadForm" id="1656677b-4b84-4e4e-89db-6ed63512faf3">
