begin
	klass := CM_Commodity.class;
	klassName := klass.name;
	foreach mtd in klass.cnGetMethods() do
		write klassName &amp; Separator &amp; mtd.name;
	endforeach;
epilog
end;</source>
    </JadeMethod>
</Class>
