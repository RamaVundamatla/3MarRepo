    <JadeMethod name="trxCreateLRReasonCode" id="d2e75fe3-c3ee-4a4f-95d8-039dc9e072a4">
        <updating/>
        <source>trxCreateLRReasonCode(_proxyLabourRestrictReasonCode : CM_LabourRestrictionReasonCode input; 
				_newLabourRestrictReasonCode:CM_LabourRestrictionReasonCode output;
				_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     25 May 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;

	// Perform the operation
	self.raiseExceptionIfNull(_proxyLabourRestrictReasonCode, 'Labour Restriction Reason Code Proxy');
	_proxyLabourRestrictReasonCode.raiseExceptionIfNotTransient(method);

	_proxyLabourRestrictReasonCode.validateForCreate();

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	create _newLabourRestrictReasonCode persistent;
	_newLabourRestrictReasonCode.setForCreate(_proxyLabourRestrictReasonCode);
	
	if _passport.noErrors then
		app.myUtilityCA.myCreateAuditAgent.audCreateGeneric(_newLabourRestrictReasonCode);
	endif;
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_proxyLabourRestrictReasonCode" type="CM_LabourRestrictionReasonCode" usage="input"/>
        <Parameter name="_newLabourRestrictReasonCode" type="CM_LabourRestrictionReasonCode" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
