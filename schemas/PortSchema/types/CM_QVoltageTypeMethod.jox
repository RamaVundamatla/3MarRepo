    <JadeMethod name="setComboValues" id="8a4eaf7a-dbfc-445f-a32f-72b2ad0469e5">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 December 2009	cnwdap1	Initial creation
*/
vars

begin
	_combo.clear();

	_combo.addItem(app.voltageTypeENumToString(ContainerDualVolt, false));	
	_combo.addItem(app.voltageTypeENumToString(ContainerSingleVolt, false));	
	
	if CM_QIntegerLookupEqual.hasInstance(_queryOperator) then
		_combo.text := app.voltageTypeENumToString(_queryOperator.CM_QIntegerLookupEqual.searchValue, false);
	elseif CM_QIntegerLookupNotEqual.hasInstance(_queryOperator) then
		_combo.text := app.voltageTypeENumToString(_queryOperator.CM_QIntegerLookupNotEqual.searchValue, false);
	endif;
epilog

end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="e234309a-b6aa-4db8-ab7c-c1b48382a05b">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QueryOperator; _passport: CM_Passport);
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 December 2009	cnwdap1	Initial creation
*/
vars
	intArray	: IntegerArray;
	idx,intSite	: Integer;
	strObj		: CM_String;
begin

	_tbl.purgeTableObjects();
	_tbl.clear;
	_tbl.rows := _tbl.fixedRows;
	
	create intArray transient;
	
	intArray.add(ContainerDualVolt);
	intArray.add(ContainerSingleVolt);
	
	self.setListTableFromIntConstants(_tbl, _operator.CM_QIntegerIsOneOf, intArray, Container_VoltageType_Constant);	

epilog
	delete intArray;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="bd1f66b4-01a2-49ef-89f3-3f4025bf07c9">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 December 2009	cnwdap1	Initial creation
*/
vars
	str		: String;
	numRows,
	idx		: Integer;
	ia		: IntegerArray;

begin
	create ia transient;
	
	numRows := _tbl.rows;
	foreach idx in (_tbl.fixedRows + 1) to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			str := _tbl.accessCell(idx, 2).text;
			ia.add(self.translateToSearchValue(str).Integer);
		endif;
	endforeach;
	
	_op.setSearchValue(ia);
	
epilog
	delete ia;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateStringToSearchValue" id="b648fa8d-f3f0-4a7e-9f09-901a1704b273">
        <source>translateStringToSearchValue(_value: Any; _criteriaLine: CM_SelectorCriteriaLine): Any;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 December 2009	cnwdap1	Initial creation
*/
vars
	voltageType : Integer;
	
begin
	if _value.String.isInteger then
		return _value;
	endif;
	
	voltageType := app.voltageTypeStringToENum(_value.String);
	
	if voltageType = ContainerVoltNull and _value &lt;&gt; null then	 //Par 17092	cnwvu1, June 2008
		app.raiseCMException2( ERR_FIELD_VALUE, _value.String, _criteriaLine.myQueryProperty.niceName, null, self );
	endif;
	
	return voltageType;
epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_criteriaLine" type="CM_SelectorCriteriaLine"/>
        <ReturnType type="Any"/>
    </JadeMethod>
