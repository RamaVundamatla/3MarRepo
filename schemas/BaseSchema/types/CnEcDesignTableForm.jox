    <JadeMethod name="mFilterByCell_click" id="3cde0752-c50c-4eae-9e12-8649144d6287">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mFilterByCell_click(menuItem: MenuItem input) updating;

vars
	value				: String;
	loopIndex			: Integer;
	col					: Integer;
begin
	value := transientTable.text;

	loopIndex := transientTable.rows;
	col := transientTable.column;
	while loopIndex &gt; 1 do
		if transientTable.rowVisible[loopIndex] then
			if transientTable.getCellText(loopIndex, col) = value then
			else
				transientTable.rowVisible[loopIndex] := false;
			endif;
		endif;
		loopIndex := loopIndex - 1;
	endwhile;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
