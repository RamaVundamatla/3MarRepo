    <JadeMethod name="nextTablePosition" id="bebae11a-cb72-47d0-a1bb-2e02e2784138">
        <updating/>
        <source>nextTablePosition(_frmTable : Frame input;
				_table : Table input;
				nextTopRow : Integer io; 
				nextLeftColumn : Integer io) updating, protected;

constants
	Height_Correction = 0;  // epr was 8 changed to 6 because was getting 15007 print errors
					//was 6
	Width_Correction = 2;//was 8
vars
	row:             Integer;
	column:          Integer;
	theHeight:       Integer;
	theWidth:        Integer;
	advanceTopRow:   Boolean;

//these (below) are used for preventing widows and orphans - keeping groups together
//see text on CMIF_TableReportMarker for more info
	marker			: Object;
	inGrp,
	grpLargerThanPg	: Boolean;
	grpRowStart,
	grpRowEnd,
	pgRowEnd,
	breakPosHeight,
	numPrintedRows,
	intRow,
	oldTopRow		: Integer;		

begin

	oldTopRow := nextTopRow;

	if (nextTopRow = _table.fixedRows + 1)
	and (nextLeftColumn = _table.fixedColumns + 1)
	and nextTopRow &lt;= _table.rows then
		advanceTopRow := true;
	endif;

	theWidth := fixedColumnWidth;
	if _table.fixedColumns = _table.columns then	//14 Jul 2016	NDL TFS 2077
		column := _table.fixedColumns;
	elseif nextLeftColumn &gt; _table.columns then
		column := _table.fixedColumns + 1;
		advanceTopRow := true;
	else
		column := nextLeftColumn;
	endif;

	_table.leftColumn := column;

	if column &lt;= _table.columns and theWidth + _table.columnWidth[column] &gt; maxTableWidth  then 
		// the column is too large to fit in table. means will skip the while loop conditions below. 
		// was getting a problem that if column was to big would skip loop and not get incremented. 
		// would cause continuous loop and 1000s of blank pages sent to printer. 
		theWidth := maxTableWidth - Width_Correction; // set width to max for screen 
		column := column + 1; 						//increment
	else
		while column &lt;= _table.columns and theWidth + _table.columnWidth[column] &lt;= maxTableWidth do
			if _table.columnVisible[column] then
				theWidth := theWidth + _table.columnWidth[column];
			endif;
			column := column + 1;
		endwhile;
	endif;
	
	nextLeftColumn := column;	
	_frmTable.width := theWidth + Width_Correction;
	_table.width := _frmTable.width - 2;	//added by cnwyl1 10072006

	if advanceTopRow then
		theHeight := fixedRowHeight;
		row := nextTopRow;
		_table.topRow := nextTopRow;
		while pgRowEnd = null and row &lt;= _table.rows and theHeight + _table.rowHeight[row] &lt;= maxTableHeight do
			theHeight := theHeight + _table.rowHeight[row];
			marker := _table.accessRow(row).itemObject;
			if CMIF_ReportGroupBegin.hasInstance(marker) then
				inGrp := true;
				grpRowStart := row;
			elseif CMIF_ReportGroupEnd.hasInstance(marker) then
				inGrp := false;
				grpRowEnd := row;
				breakPosHeight := theHeight;
			elseif CMIF_ReportPageEnd.hasInstance(marker) then
				inGrp := false;
				pgRowEnd := row;
				breakPosHeight := theHeight;
			endif;

			row := row + 1;
		endwhile;
		
		numPrintedRows := (row - nextTopRow); //(newTopRow - lastTopRow)
		if inGrp then
			//count rows to GroupEnd
			foreach intRow in row to _table.rows do
				marker := _table.accessRow(intRow).itemObject;
				if CMIF_ReportGroupEnd.hasInstance(marker) then
					grpLargerThanPg := (intRow - grpRowStart)+1 &gt;= numPrintedRows;
					break;
				endif;
			endforeach;
		endif;

		if pgRowEnd &lt;&gt; null then					//found an end page row
			nextTopRow := pgRowEnd+1;
			_frmTable.height := breakPosHeight + Height_Correction;
			_table.height := _frmTable.height;	
		elseif inGrp								//page break is in the middle of a group			
//		and (grpRowStart &gt; (row+nextTopRow)/2) 		//the group start is not in the top half of a page //(ignoring this setting for now - cnwjc2)
		and not grpLargerThanPg then				//the group can fit on one page by itself (so shifting to the next page is not a waste of time)
			if grpRowEnd &lt;&gt; null then
				nextTopRow := grpRowEnd+1;
			else
				nextTopRow := grpRowStart;
			endif; 
			_frmTable.height := breakPosHeight + Height_Correction;
			_table.height := _frmTable.height;	
		else										//normal operation
			nextTopRow := row;
			_frmTable.height := theHeight + Height_Correction;
			_table.height := _frmTable.height;	
		endif;

		if oldTopRow = nextTopRow then
			//supposed to advance - why hasn't it?
			nextTopRow := row;
			_frmTable.height := theHeight + Height_Correction;
			_table.height := _frmTable.height;	
		endif;

	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_frmTable" type="Frame" usage="input"/>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="nextTopRow" type="Integer" usage="io"/>
        <Parameter name="nextLeftColumn" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="nextTablePositionOld" id="0f177105-684a-4bf0-a224-524e164cf6ed">
        <updating/>
        <source>nextTablePositionOld(_frmTable : Frame input;
				_table : Table input;
				nextTopRow : Integer io; 
				nextLeftColumn : Integer io) updating, protected;

constants
	Height_Correction = 2;
	Width_Correction = 2;
vars
	row:             Integer;
	column:          Integer;
	theHeight:       Integer;
	theWidth:        Integer;
	advanceTopRow:   Boolean;
			
begin

	if (nextTopRow = _table.fixedRows + 1) and 
	   (nextLeftColumn = _table.fixedColumns + 1) then
		advanceTopRow := true;
	endif;

	theWidth := fixedColumnWidth;
	if nextLeftColumn &gt; _table.columns then
		column := _table.fixedColumns + 1;
		advanceTopRow := true;
	else
		column := nextLeftColumn;
	endif;

	_table.leftColumn := column;
	while column &lt;= _table.columns and theWidth + _table.columnWidth[column] &lt;= maxTableWidth do
		if _table.columnVisible[column] then
			theWidth := theWidth + _table.columnWidth[column];
		endif;
		column := column + 1;
	endwhile;
	nextLeftColumn := column;	
	_frmTable.width := theWidth + Width_Correction;

	if advanceTopRow then
		theHeight := fixedRowHeight;
		row := nextTopRow;
		_table.topRow := nextTopRow;
		while row &lt;= _table.rows and theHeight + _table.rowHeight[row] &lt;= maxTableHeight do
			theHeight := theHeight + _table.rowHeight[row];
			row := row + 1;
		endwhile;
		nextTopRow := row;	
		_frmTable.height := theHeight + Height_Correction;
		_table.height := _frmTable.height;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_frmTable" type="Frame" usage="input"/>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="nextTopRow" type="Integer" usage="io"/>
        <Parameter name="nextLeftColumn" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="printTable" id="1f08de92-c348-40d4-b7ba-32de7ac2c48a">
        <updating/>
        <source>printTable(tblIn: Table input; 
			landscape: Boolean; 
			progress: CMS_Progress input) updating;

vars
	nextTopRow				: Integer;
	nextLeftColumn			: Integer;
	row						: Integer;
	column					: Integer;
	numRows					: Integer;
	numCols					: Integer;
	numInvisibleFixedRows	: Integer;
	numInvisibleFixedCols	: Integer;
	wrapCol					: Integer;
	
begin
	if self.table.rows &lt;= self.table.fixedRows then
		return;
	endif;
	
	if tblIn &lt;&gt; null then
		numRows := tblIn.rows;
		numCols := tblIn.columns;
		
		if progress &lt;&gt; null then
			progress.progress.partsInJob := 5;
		endif;
		
		foreach row in 1 to tblIn.fixedRows do
			if (not tblIn.accessRow(row).visible) then
				numInvisibleFixedRows := numInvisibleFixedRows + 1;
			endif;		
		endforeach;
		
		if progress &lt;&gt; null then
			progress.progress.partsDone := progress.progress.partsDone + 1;
		endif;
		
		foreach column in 1 to tblIn.fixedColumns do
			if (not tblIn.accessColumn(column).visible) then
				numInvisibleFixedCols := numInvisibleFixedCols + 1;
			endif;	
		endforeach;
		
		if progress &lt;&gt; null then
			progress.progress.partsDone := progress.progress.partsDone + 1;
		endif;
	
		// Copy the table
		self.copyTable(tblIn, numInvisibleFixedRows, numInvisibleFixedCols);
		
		if progress &lt;&gt; null then
			progress.progress.partsDone := progress.progress.partsDone + 1;
		endif;
	elseif progress &lt;&gt; null then
		progress.progress.partsInJob := 2;
	endif;

	// now set topRow/leftColumn and height/width
	self.setMaxTableHeight;
	self.setMaxTableWidth;
	self.setFixedRowHeight(self.table);
	self.setFixedColumnWidth(self.table);
	
	if progress &lt;&gt; null then
		progress.progress.partsDone := progress.progress.partsDone + 1;
	endif;

	nextTopRow := table.fixedRows + 1;
	nextLeftColumn := table.fixedColumns + 1;
	
	if progress &lt;&gt; null then
		progress.progress.partsInJob := table.columns;
	endif;
	
	//th2 added 5/10/06 - copy word wrap information
	if tblIn &lt;&gt; null then
		table.autoSize := tblIn.autoSize;
		foreach wrapCol in 1 to tblIn.columns do
			if tblIn.accessColumn(wrapCol).wordWrap then
				table.accessColumn(wrapCol).width := tblIn.accessedColumn.width;
				table.accessedColumn.wordWrap := true;
				table.accessedColumn.widthPercent := tblIn.accessedColumn.widthPercent;		
			endif;
		endforeach;
	endif;
	while nextTopRow &lt;= table.rows or nextLeftColumn &lt;= table.columns do
		self.nextTablePosition(self.frTable, self.table, nextTopRow, nextLeftColumn);
	//	self.nextTablePositionOld(self.frTable, self.table, nextTopRow, nextLeftColumn);
		if progress &lt;&gt; null then
			progress.progress.partsDone := progress.progress.partsDone + 1;
		endif;
		app.printer.print(frTable);
	endwhile;
end;</source>
        <Parameter name="tblIn" type="Table" usage="input"/>
        <Parameter name="landscape" type="Boolean"/>
        <Parameter name="progress" type="CMS_Progress" usage="input"/>
    </JadeMethod>
    <JadeMethod name="printTableGeneric" id="86626ce3-f392-40de-9a54-ab93873ef09d">
        <updating/>
        <source>printTableGeneric(_frmHeader, _frmTable, _frmFooter : Frame input;
				_tblIn: Table input; _landscape : Boolean) updating;

vars
	nextTopRow,
	nextLeftColumn,
	row,
	column,
	numRows,
	numCols,
	numFixedRows,
	numFixedColumns,
	numInvisibleFixedRows,
	numInvisibleFixedCols		: Integer;
begin
	if table.rows = table.fixedRows then
		return;
	endif;
	numRows := _tblIn.rows;
	numCols := _tblIn.columns;
	
	foreach row in 1 to _tblIn.fixedRows do
		if (not _tblIn.accessRow(row).visible) then
			numInvisibleFixedRows := numInvisibleFixedRows + 1;
		endif;		
	endforeach;
	
	foreach column in 1 to _tblIn.fixedColumns do
		if (not _tblIn.accessColumn(column).visible) then
			numInvisibleFixedCols := numInvisibleFixedCols + 1;
		endif;	
	endforeach;
	
	self.frHeader := _frmHeader;
	self.frTable := _frmTable;
	self.frFooter := _frmFooter;
	
	numRows := _tblIn.rows;
	numCols := _tblIn.columns;
	// now set topRow/leftColumn and height/width
	self.setMaxTableHeight;
	self.setMaxTableWidth;
	self.setFixedRowHeight(_tblIn);
	self.setFixedColumnWidth(_tblIn);
	
	nextTopRow := (_tblIn.fixedRows + 1);// - numInvisibleFixedRows;
	nextLeftColumn := (_tblIn.fixedColumns + 1);// - numInvisibleFixedCols;
	numFixedRows := _tblIn.fixedRows;// - numInvisibleFixedRows;
	numFixedColumns := _tblIn.fixedColumns;// - numInvisibleFixedCols;
	
	while nextTopRow &lt;= _tblIn.rows or nextLeftColumn &lt;= _tblIn.columns do
		self.getNextTablePos(_frmTable, _tblIn, nextTopRow, nextLeftColumn, numFixedRows, numFixedColumns);
		app.printer.print(_frmTable);
	endwhile;

end;</source>
        <Parameter name="_frmHeader" type="Frame" usage="input"/>
        <Parameter name="_frmTable" type="Frame" usage="input"/>
        <Parameter name="_frmFooter" type="Frame" usage="input"/>
        <Parameter name="_tblIn" type="Table" usage="input"/>
        <Parameter name="_landscape" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setFixedColumnWidth" id="9a1959fe-9f0b-4248-bb06-2f9fdfef4c32">
        <updating/>
        <source>setFixedColumnWidth(_table : Table input) updating, protected;

vars
	i:  Integer;
begin
	fixedColumnWidth := 0;

	i := 1;
	while i &lt;= _table.fixedColumns do
		if (not _table.accessColumn(i).visible) then
			i := i + 1;
			continue;
		endif;
		
		fixedColumnWidth := fixedColumnWidth + _table.columnWidth[i];
		i := i + 1;
	endwhile;

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setFixedRowHeight" id="7743542f-88ff-4fea-b898-3455d74486e0">
        <updating/>
        <source>setFixedRowHeight(_table : Table input) updating, protected;

vars
	i:  Integer;
begin
	fixedRowHeight := 0;

	i := 1;
	while i &lt;= _table.fixedRows do
		if (not _table.accessRow(i).visible) then
			i := i + 1;
			continue;
		endif;
		
		fixedRowHeight := fixedRowHeight + _table.rowHeight[i];
		i := i + 1;
	endwhile;

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setHeaders" id="ff2627ed-1b9a-4b40-b10c-825444609ebd">
        <source>setHeaders(_hdr1, _hdr2 : String);
// ---------------------------------------------------------------------------
// Created:     31 July 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
constants
	StdHeaderFrmHeight	= 70;
vars

begin

	lblHeader1.caption	:= _hdr1;
	if _hdr1 &lt;&gt; null then
		lblHeader1.autoSize := false;
		lblHeader1.visible := true;
		lblHeader1.width := self.picHeader.left - (self.picJMT.left + self.picJMT.width);
		lblHeader1.centreHorizontallyInParent;
		lblHeader1.wordWrap := true;
		lblHeader1.height := lblHeader1.getTextHeightForWidth(_hdr1, lblHeader1.width.Integer);

		//if lblHeader1.parent &lt;&gt; null then
		//	lblHeader1.left := (lblHeader1.parent.width - lblHeader1.width)/2;
		//endif;
	endif;

	lblHeader2.caption	:= _hdr2;
	if _hdr2 &lt;&gt; null then
		lblHeader2.visible := true;
		lblHeader2.centreHorizontallyInParent;
		
		frHeader.height := lblHeader1.height.max(StdHeaderFrmHeight) + lblHeader2.height;
	else
		frHeader.height	:= lblHeader1.height.max(StdHeaderFrmHeight);
	endif;


end;</source>
        <Parameter name="_hdr1" type="String"/>
        <Parameter name="_hdr2" type="String"/>
    </JadeMethod>
    <JadeMethod name="setMaxTableHeight" id="162d75f3-fb35-4960-8457-7ac766c523a5">
        <updating/>
        <source>setMaxTableHeight() updating, protected;

constants
	Height_Correction = 4;
vars
	headFrame:           Frame;
	footFrame:           Frame;
begin
	maxTableHeight := app.printer.pageHeight;
	// use "getPropertyValue" as this is a protected property in the printer class
	headFrame := app.printer.getPropertyValue(Printer::headerFrame.name).Frame;
	if headFrame &lt;&gt; null then
		maxTableHeight := maxTableHeight - headFrame.height.Integer;
	endif;

	footFrame := app.printer.getPropertyValue(Printer::footerFrame.name).Frame;
	if footFrame &lt;&gt; null then
		maxTableHeight := maxTableHeight - footFrame.height.Integer;
	endif;

	maxTableHeight := maxTableHeight - Height_Correction;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setMaxTableWidth" id="30209ba3-97ab-4da2-a1d5-75d27ac5c7af">
        <updating/>
        <source>setMaxTableWidth() updating, protected;

constants
	Width_Correction = 4;
vars

begin
	maxTableWidth := app.printer.pageWidth;

	maxTableWidth := maxTableWidth - Width_Correction;

end;</source>
        <access>protected</access>
    </JadeMethod>
</GUIClass>
