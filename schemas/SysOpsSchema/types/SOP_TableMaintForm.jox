    <JadeMethod name="lstSingleSelect1_displayEntry" id="4e49dd45-68ee-4b3a-a1a4-9e8e1ab569be">
        <controlMethod name="ListBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstSingleSelect1_displayEntry(listbox: ListBox input; obj: Any; lstIndex: Integer):String updating;

vars

begin
	if obj.isKindOf(CM_ShipPortGroup) then
		return obj.CM_ShipPortGroup.code &amp; Tab &amp; obj.CM_ShipPortGroup.description;
	endif;
	// TFS #43007 - Remove Teklogix	jlgmd1 22/01/2019
	/*if obj.isKindOf(CM_RadioTelemetrySession) then
		return obj.CM_RadioTelemetrySession.id;
	endif;*/
	if obj.isKindOf(CM_FaultQuestion) then
		return obj.CM_FaultQuestion.description.removeTabCrLfs;
	endif;
	if obj.isKindOf(CM_Terminal) then  //ccms1824 cnwrs1 may 2009
		return obj.CM_Terminal.code;
	endif;
	if obj.isKindOf(CM_CargoCheckItem) then	// CCMS 1071 cnwdap1 29/01/2010
		return obj.CM_CargoCheckItem.name;
	endif;
	if obj.isKindOf(CM_KioskObject) then	// TFS 59550 jlizm1 18/08/2023
		return obj.CM_KioskObject.code;
	endif;
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="obj" type="Any"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
