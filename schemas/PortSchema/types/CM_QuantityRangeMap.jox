    <JadeMethod name="clear" id="771fd3bc-a601-48df-a530-55d1c13df694">
        <source>clear();
// ---------------------------------------------------------------------------
// Created:		05 October 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
// TFS 40620	self.allInvoiceLineMaps.clear;
// TFS 40620	self.allInvoiceLinesUsed.clear;
	
	if self.allRegisteredMethods &lt;&gt; null then
		self.allRegisteredMethods.clear;	
	endif;
		
	// 30955 clear line maps as well
	self.allTMInvoiceLineMappings.purge();
end;</source>
    </JadeMethod>
    <JadeMethod name="clearAllTMInvoiceLineMaps" id="fb98cb72-437a-4b1b-9403-9c2c2d935a22">
        <updating/>
        <source>clearAllTMInvoiceLineMaps() updating;
/*
Purpose:	'allTMInvoiceLineMappings' object extension was used to mimic a collection property for 8.1.2 hotfix, now deleted and object extension instances removed.

Date		Who		Reason
15/11/2012	cnwjre1	Initial creation - CCMS QNS 2177
*/
vars
	any		: Any;
	dict	: CM_TMInvLineMapByCargoAttrDict;
begin
	any :=  self.getExtensionObjectValue ('allTMInvoiceLineMappings');
	
	if any &lt;&gt; null and any.isKindOf (CM_TMInvLineMapByCargoAttrDict) then
		dict := any.CM_TMInvLineMapByCargoAttrDict;
		dict.purge();
		delete dict;
	endif;
	
	self.setExtensionObjectValue('allTMInvoiceLineMappings', null);

end;</source>
    </JadeMethod>
    <JadeMethod name="copyFrom" id="4f17ec11-3723-4d56-a0fc-9d6680894bd4">
        <updating/>
        <source>copyFrom(_map : CM_QuantityRangeMap; _parent : CM_QuantityMap) updating;
// 32311 set up self from the parameter plus the new transaction type, copy all of the parameter map children under self.
vars
	lineMapDict	: CM_TMInvLineMapByCargoAttrDict;
	mapLineMapping,
	lineMapping		: CM_TranMapInvoiceLineMapping;

begin

	self.rangeStart := _map.rangeStart;
	self.rangeEnd := _map.rangeEnd;
	self.rangeType := _map.rangeType;

	if _parent &lt;&gt; null then
		self.myQuantityMap := _parent;
	else
		self.myQuantityMap := _map.myQuantityMap;
	endif;

	if self.allRegisteredMethods = null then
		create self.allRegisteredMethods;
	endif;
// TFS 40620	_map.allInvoiceLineMaps.copy(self.allInvoiceLineMaps);
// TFS 40620	_map.allInvoiceLinesUsed.copy(self.allInvoiceLinesUsed);
	_map.allRegisteredMethods.copy(self.allRegisteredMethods);

	lineMapDict := _map.allTMInvoiceLineMappings;
	if lineMapDict &lt;&gt; null then
		foreach mapLineMapping in lineMapDict do
			create lineMapping persistent;
			lineMapping.setFromProxy(mapLineMapping, self);
		endforeach;
	endif;
	
end;</source>
        <Parameter name="_map" type="CM_QuantityRangeMap"/>
        <Parameter name="_parent" type="CM_QuantityMap"/>
    </JadeMethod>
    <JadeMethod name="delete" id="d5c6af2d-0bbc-43ea-b857-704ae73b388c">
        <updating/>
        <source>delete() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 January 2011	cnwndl1	Initial creation

*/

vars
	
begin

	if self.allRegisteredMethods &lt;&gt; null then	//10 Jan 2010	- trans leak in unit tests.
		delete self.allRegisteredMethods;
	endif;
	
	self.resetAuditsDuringDelete();	//25 Jan 2021	NDL	TFS 50152 
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doIConflictWithRanges" id="ba143f0b-3153-4073-8ad3-3be80d005b65">
        <source>doIConflictWithRanges(_qm :CM_QuantityMap; _mess : String io) : Boolean;
// ---------------------------------------------------------------------------
// Created:		04 October 2007 By Andrew Bishop cnwab1
// CCMS 1043 Snapshot Summary Invoicing 	Oct 2010 	cnwjre1	parameter change
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	aQRM, realME: CM_QuantityRangeMap;
	myst, myen,st, en : Integer;
begin
	realME := self.pxyGetRealObject();
	
	myst := self.rangeStart.Integer;
	myen := self.rangeEnd.Integer;
	
	foreach aQRM in _qm.allQuantityRanges discreteLock do
		// ignore me, as I am about to be updated
		if realME = aQRM or
		   self = aQRM then			// 37434 if both are transient
			continue;
		endif;
		st := aQRM.rangeStart.Integer;
		en := aQRM.rangeEnd.Integer;
		
		if myst = st then
			_mess := _mess &amp; ", " &amp;  myst.String &amp; " is the same as " &amp; st.String &amp; " (" &amp; st.String &amp; " - " &amp; en.String &amp; ")";
		endif;
		if myst = en then
			_mess := _mess &amp; ", " &amp;  myst.String &amp; " is the same as " &amp; en.String &amp; " (" &amp; st.String &amp; " - " &amp; en.String &amp; ")";
		endif;
		if myen = st then
			_mess := _mess &amp; ", " &amp;  myen.String &amp; " is the same as " &amp; st.String &amp; " (" &amp; st.String &amp; " - " &amp; en.String &amp; ")";
		endif;
		if myen = en then
			_mess := _mess &amp; ", " &amp;  myen.String &amp; " is the same as " &amp; en.String &amp; " (" &amp; st.String &amp; " - " &amp; en.String &amp; ")";
		endif;

		if myst &gt; en then
			continue;
		endif;
		
		if myen &lt; st then
			continue;
		else
			if myst &gt; st then
				if myen &gt; en then
					_mess := _mess &amp; ", " &amp;  myen.String &amp; " is greater than " &amp; en.String &amp; " (" &amp; st.String &amp; " - " &amp; en.String &amp; ")";
				elseif myen &lt; en then
					_mess := _mess &amp; ", " &amp;  myen.String &amp; " is less than " &amp; en.String &amp; " (" &amp; st.String &amp; " - " &amp; en.String &amp; ")";
				endif;
			else
				_mess := _mess &amp; ", " &amp;  myen.String &amp; " is greater than " &amp; st.String &amp; " (" &amp; st.String &amp; " - " &amp; en.String &amp; ")";
			endif;
		endif;
		
	endforeach;
	
	return (_mess = null);
end;</source>
        <Parameter name="_qm" type="CM_QuantityMap"/>
        <Parameter name="_mess" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="erase" id="8ef584e0-72f2-4549-9eec-edb27276025c">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
// ---------------------------------------------------------------------------
// Created:		04 October 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin

	if self.myQuantityMap.myParentFinancialObject = null then // ### TFS CR 58022 TASK 58023 18MAY2023 NAVAB1
 		if self.myQuantityMap.allQuantityRanges.size = 1 
		and (self.myQuantityMap.myInvoiceAllocation = null and self.myQuantityMap.myFutureStorageMap = null) then // PAR 36275
	// TFS 40620		self.allInvoiceLineMaps.clear;
	// TFS 40620		self.allInvoiceLinesUsed.clear;
			self.allRegisteredMethods.clear;
			self.allTMInvoiceLineMappings.purge();

			self.initialise(self.myQuantityMap, self.myQuantityMap.getBank(), true);
			return;
		endif;
	else // ### TFS CR 58022 TASK 58023 18MAY2023 NAVAB1
 		if self.myQuantityMap.allQuantityRanges.size = 1 then
			self.myQuantityMap.erase(NORMAL_ERASE);
			return;
		endif;
	endif;
	
	inheritMethod(_eraseLevel);

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="findGroupedInvoiceLineDesc" id="b1514460-5f35-4694-96cc-20b1ae3cf327">
        <source>findGroupedInvoiceLineDesc(_aSBController : CMIF_ServiceBroker input; _invLineTypes	: ObjectArray input; _lineGroups : IntegerArray input) protected;
/* If there is more than one invoice line type and invoice type grouping of other than all,
	create transient invoice lines and charges with quantity and rates set, group by value and remove the unwanted invoice line types from 
	CMIF_ServiceBroker.allInvoiceLineTypes.  Clean up the transients.
	35365 copied from CM_Bank to handle this properly in escalating charges
Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
27 November 2012	cnwjre1	Initial creation
14/04/2016			cnwjre1	from Milaha cash contact checking, stop creating a persistent invoice from here in some cases
23 Oct 2024			navlw1	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025			navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/

vars
	bank	: CM_Bank;
	transaction: CM_TITransaction;
	invType		: CM_InvoiceDesc;
	transInvoice : CM_Invoice;
	debtor		: CM_Debtor;
	invLineDesc:  CM_InvoiceLineDesc;
	invLineTypes : CM_InvoiceLineDescArray;
	obj	: Object;
	lineGroup, defLineGroup	: Integer;
	idx : Integer;
	allGroupings : CMIF_InvoiceTMGroupingByType;
	invLineGrouping : CMIF_InvoiceTMGrouping;
	lineGroupName : String;
	canLogExtra	: Boolean;	//27.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//27.02.2025 navah1	#34141
	if _aSBController.invoiceLineMappingGroupType = TranMapInvLineGroupTypeAll 
	or _invLineTypes.size = 1 then
		return;
	endif;

	create allGroupings transient;
	
	transaction := _aSBController.myTransaction;
	// 36090 if called from CM_Bank::getStorageTimes transaction is null and the grouping processing here is not actually required so just exit
	if transaction = null then
		return;
	endif;
	bank := transaction.myTrackedItem.companyOid;
	// create a transient invoice first
	if not _invLineTypes.isEmpty then
		obj := _invLineTypes.first;
		invLineDesc := obj.CM_InvoiceLineDesc;
		debtor := transaction.getDebtorForInvoiceLine(invLineDesc); // TFS 42221
		if debtor &lt;&gt; null then
			invType := invLineDesc.getInvoiceType(debtor);
			transInvoice := bank.createTransientInvoice(invType, invLineDesc, debtor);
		endif;
	endif;
	foreach obj in _invLineTypes do
		invLineDesc := obj.CM_InvoiceLineDesc;
		idx := idx + 1;
		// exclude any 'All' grouping line types
		lineGroup := _lineGroups[idx];
		
		 // ### TFS CR 56446 TASK 56447 15FEB2023 NAVAB1
		if lineGroup = TranMapInvLineGroupTypeHighDef then
			lineGroup := TranMapInvLineGroupTypeHigh;
			defLineGroup := TranMapInvLineGroupTypeHighDef;
		endif;
		if lineGroup = TranMapInvLineGroupTypeHigh2Df then
			lineGroup := TranMapInvLineGroupTypeHigh2;
			defLineGroup := TranMapInvLineGroupTypeHigh2Df;
		endif;
		if lineGroup = TranMapInvLineGroupTypeHigh3Df then
			lineGroup := TranMapInvLineGroupTypeHigh3;
			defLineGroup := TranMapInvLineGroupTypeHigh3Df;
		endif;
		if lineGroup = TranMapInvLineGroupTypeHigh4Df then
			lineGroup := TranMapInvLineGroupTypeHigh4;
			defLineGroup := TranMapInvLineGroupTypeHigh4Df;
		endif;
		if lineGroup = TranMapInvLineGroupTypeHigh5Df then
			lineGroup := TranMapInvLineGroupTypeHigh5;
			defLineGroup := TranMapInvLineGroupTypeHigh5Df;
		endif;
		if lineGroup = TranMapInvLineGroupTypeLowDef then
			lineGroup := TranMapInvLineGroupTypeLow;
			defLineGroup := TranMapInvLineGroupTypeLowDef;
		endif;
		
		
		invLineGrouping := allGroupings[lineGroup];
		if invLineGrouping = null then
			create invLineGrouping transient;
			invLineGrouping.invoiceLineGroupType := lineGroup;
			invLineGrouping.myBusinessUnit := bank;
			invLineGrouping.myTransientInvoice := transInvoice;
			invLineGrouping.myTransaction := transaction;
			invLineGrouping.myQRM := self;
			
			
			allGroupings.add(invLineGrouping);
		endif;
		invLineGrouping.allInvoiceLineTypes.add(invLineDesc);
		lineGroup := _lineGroups[idx];
		if lineGroup = TranMapInvLineGroupTypeLowDef 
		or lineGroup = TranMapInvLineGroupTypeHighDef 
		or lineGroup = TranMapInvLineGroupTypeHigh2Df 
		or lineGroup = TranMapInvLineGroupTypeHigh3Df 
		or lineGroup = TranMapInvLineGroupTypeHigh4Df 
		or lineGroup = TranMapInvLineGroupTypeHigh5Df then
			invLineGrouping.defaultLineType := invLineDesc;
			invLineGrouping.defaultLineGroupType := defLineGroup;
		endif;
	endforeach;

	_invLineTypes.clear;
	
	// ### TFS BUG 64673 15JUNE024 NAVAB1
	if canLogExtra then	//27.02.2025 navah1	#34141
		app.invLog(CrLf &amp; method.qualifiedName &amp;  " - GROUPINGs Used :", LogINFO.String);
		foreach invLineGrouping in allGroupings discreteLock do
			lineGroup := invLineGrouping.invoiceLineGroupType;
			if lineGroup = TranMapInvLineGroupTypeAll then
				lineGroupName := "ALL";
			elseif lineGroup &gt;= TranMapInvLineGroupTypeHigh then
				lineGroupName := "HIGHEST";
			else
				lineGroupName := "LOWEST";
			endif;
			app.invLog(lineGroup.String &amp; " " &amp; lineGroupName, LogINFO.String);
			foreach invLineDesc in invLineGrouping.allInvoiceLineTypes do
				app.invLog(Tab &amp; invLineDesc.narration, LogINFO.String);
			endforeach;

		endforeach;
		app.invLog(CrLf, LogINFO.String);
	endif;
	
	foreach invLineGrouping in allGroupings discreteLock do
		// always include the 'ALL' lines
		if invLineGrouping.invoiceLineGroupType = TranMapInvLineGroupTypeAll then
			invLineGrouping.allInvoiceLineTypes.copy(_invLineTypes);
			continue;
		endif;

		// get the single highest or lowest
		invLineDesc := invLineGrouping.findGroupedInvoiceLineDesc();
	
		_invLineTypes.add(invLineDesc);
	
	endforeach;

epilog
	delete transInvoice;
	delete invLineTypes;
	if allGroupings &lt;&gt; null then
	allGroupings.purge;
	endif;
	delete allGroupings;
end;</source>
        <access>protected</access>
        <Parameter name="_aSBController" type="CMIF_ServiceBroker" usage="input"/>
        <Parameter name="_invLineTypes" type="ObjectArray" usage="input"/>
        <Parameter name="_lineGroups" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllTMInvoiceLineMaps" id="8904ab9b-aac0-4d39-b6c5-93e3464b45eb">
        <source>getAllTMInvoiceLineMaps() : CM_TMInvLineMapByCargoAttrDict;
/*
Purpose:	Mimic a collection property for 8.1.2 hotfix, only used here for conversion.
			The actual reference allTMInvoiceLineMappings is now used instead.

Date		Who		Reason
15/11/2012	cnwjre1	Initial creation - CCMS QNS 2177
*/
vars
	any	: Any;
begin
	any :=  self.getExtensionObjectValue ('allTMInvoiceLineMappings');
	
	if any &lt;&gt; null and any.isKindOf (CM_TMInvLineMapByCargoAttrDict) then
		return any.CM_TMInvLineMapByCargoAttrDict;
	endif;
	
	return null;

end;</source>
        <ReturnType type="CM_TMInvLineMapByCargoAttrDict"/>
    </JadeMethod>
    <JadeMethod name="getAnswerFromMethod" id="043054c6-82e1-4daa-acea-7a1b7b508899">
        <source>getAnswerFromMethod(_theMethod : String;_theTI : CM_TrackedItem) : Boolean;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	tmpMethod	: Method;

begin
	if _theTI = null then
		return false;
	endif;
	
	// check to see if the method exists on the class
	// we are looking at.  Need to look up everytime as
	// we need to get the correct method for this sub-class,
	// and not one for another sub-class
	tmpMethod := _theTI.class.getMethodInHTree(_theMethod);
	if (tmpMethod = null) then

		return false;
	endif;
	


	if tmpMethod.isMappingMethod() then
		return _theTI.getPropertyValue(_theMethod).Boolean;
	endif;
	
	return _theTI.sendMsg(_theMethod).Boolean;

end;</source>
        <Parameter name="_theMethod" type="String"/>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="6f6172fd-92d5-485a-b675-637aa8caec1c">
        <source>getAuditText(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 January 2017	cnwma1	Initial creation
09/02/2017 cnwma1  TFS #2901:ADP - Variable storage charges based on weight and time

*/

	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	txt,
	tmpStr	: String;
	lineMapDict		: CM_TMInvLineMapByCargoAttrDict;
		hasTranship,
	includesTranshipMethod : Boolean;
	currKey	: Integer;
	narration,
	voidString,
	inContract,
	groupString,
	mapString,
	wholeLine, tmpString : String;
	invLineDesc : CM_InvoiceLineDesc;
	lineMapping		: CM_TranMapInvoiceLineMapping;
	groupType		: CM_TranMapInvoiceLineGroupType;
	groupTypeName : String;
	range 	: String;
	sb : CM_ServiceBroker;
	finObj : CM_FinancialObject;
	contract,
	transTypeString,
	vesselCatString, cargoString: String;
begin
	txt[10000] 	:= '*';
	txt 		:= null;
	txt 		:= inheritMethod();
	tmpStr := self.getTranMapBreadCrumb;
	txt := txt &amp; 'Item Path' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	
	tmpStr := null;
	if self.myQuantityMap &lt;&gt; null then
		tmpStr := self.myQuantityMap.getName;
		txt := txt &amp;'Quantity By' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
		
		//21 Dec 2017	NDL	TFS 8095
		tmpStr := null;
		if self.myQuantityMap.mappingType = CM_QuantityMap.MapType_Single then
			tmpStr :=  "Single";
			txt := txt &amp; app.getFormCaptionsString(Xlat_0006251) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
		elseif self.myQuantityMap.mappingType = CM_QuantityMap.MapType_Escalate then
			tmpStr := "Escalating";
			txt := txt &amp;app.getFormCaptionsString(Xlat_0006251)&amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
		endif;
		
		tmpStr := null;
		tmpStr := self.myQuantityMap.chargeZero.String;
		txt := txt &amp; app.getErrorString(Charge_zero_quantity) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	
	endif;
	
	finObj := self.myQuantityMap.myParentFinancialObject;
	if finObj.isKindOf(CM_DebtorMap) then
		sb := finObj.CM_DebtorMap.myServiceBroker;
	elseif finObj.isKindOf(CM_QuantityRangeMap) then  //09/02/2017 cnwma1 TFS #2901
		if  finObj.CM_QuantityRangeMap.myQuantityMap.myParentFinancialObject.isKindOf(CM_ServiceBroker) then //17/02/2017 cnwma1 TFS #2901
			sb := finObj.CM_QuantityRangeMap.myQuantityMap.myParentFinancialObject.CM_ServiceBroker;
		elseif finObj.CM_QuantityRangeMap.myQuantityMap.myParentFinancialObject.isKindOf(CM_DebtorMap) then
			sb := finObj.CM_QuantityRangeMap.myQuantityMap.myParentFinancialObject.CM_DebtorMap.myServiceBroker;
		
		endif;
	else
		sb := finObj.CM_ServiceBroker;
	endif;
	
	tmpStr := null;
	// TFS 40620if self.allInvoiceLineMaps.size &gt; 0 then
	if self.allTMInvoiceLineMappings.size &gt; 0 then // TFS 40620
		lineMapDict := self.allTMInvoiceLineMappings;
		foreach lineMapping in lineMapDict do
			vesselCatString := "";
			transTypeString := "";
			invLineDesc := lineMapping.myTMInvoiceLineDesc;
			groupType := lineMapping.myTMInvoiceLineGroupType;
			currKey := lineMapping.mapValue;
			mapString := self.getMappingMethods(currKey);
			if mapString &lt;&gt; null then
				mapString :=" , Methods :"&amp; mapString; 
				mapString :=mapString.cnEcFindReplace("-","",true);
			endif;
			if groupType = null then 
				groupTypeName:= "All";
			else
				groupTypeName:= groupType.name; 
			endif;
			if sb.isKindOf(CM_ResourceServiceBroker) then
				if lineMapping.mapValue =(CM_ResourceServiceBroker.INVOICELINE_KEY_IN_CONTRACT) then
					contract :="Included In Contract     &gt;&gt; ";
				else
					contract :="Not Included In Contract &gt;&gt; ";
				endif;
				
				// ### TFS CR 65336 TASK 65338 06AUG2024 NAVAB1
				cargoString := "Cargo Type: ";
				if lineMapping.myCargoType = null then
					cargoString := cargoString &amp; app.getErrorString(AnyString);
				else
					cargoString := cargoString &amp; lineMapping.myCargoType.abbreviation;
				endif;
				cargoString := cargoString &amp; Comma &amp; Space;
				cargoString := cargoString &amp; "Cargo Sub Type: ";
				if lineMapping.myCargoSubtype = null then
					cargoString := cargoString &amp; app.getErrorString(AnyString);
				else
					cargoString := cargoString &amp; lineMapping.myCargoSubtype.code;
				endif;
				cargoString := cargoString &amp; Comma &amp; Space;
				cargoString := cargoString &amp; "Commodity: ";
				if lineMapping.myCommodity = null then
					cargoString := cargoString &amp; app.getErrorString(AnyString);
				else
					cargoString := cargoString &amp; lineMapping.myCommodity.code;
				endif;
				cargoString := cargoString &amp; Comma &amp; Space;
				
				
				
				vesselCatString := "Vessel Category: ";			// 20/6/18 MAP TFS38899
				if lineMapping.myVesselCategory = null then
					vesselCatString := vesselCatString &amp; app.getErrorString(AnyString);
				else
					vesselCatString := vesselCatString &amp; lineMapping.myVesselCategory.code;
				endif;
				vesselCatString := vesselCatString &amp; Comma &amp; Space;
				
				transTypeString := "Transfer Type: ";			// 20/6/18 MAP TFS38899
				if lineMapping.myTransferType = null then
					transTypeString := transTypeString &amp; app.getErrorString(AnyString);
				else
					transTypeString := transTypeString &amp; lineMapping.myTransferType.description;
				endif;
				transTypeString := transTypeString &amp; Comma &amp; Space;
				groupString := "Grouping: "&amp; groupTypeName &amp; ", "; 
				narration := " Invoice Line: "&amp;invLineDesc.narration.removeTabCrLfs();
			else
				if sb.isKindOf(CM_TransServiceBroker) 
				and (sb.CM_TransServiceBroker.className = CM_ReceiveShip.name 
					or sb.CM_TransServiceBroker.className = CM_ReleaseShip.name
					or sb.CM_TransServiceBroker.className = CM_WorkOrderExtraTI.name) then // TFS 42221
					transTypeString := "Transfer Type: ";			// 20/6/18 MAP TFS38899
					if lineMapping.myTransferType = null then
						transTypeString := transTypeString &amp; app.getErrorString(AnyString);
					else
						transTypeString := transTypeString &amp; lineMapping.myTransferType.description;
					endif;
					transTypeString := transTypeString &amp; Comma &amp; Space;
				endif;
				groupString := "Grouping: "&amp; groupTypeName &amp; ", "; 
				narration := " Invoice Line: "&amp;invLineDesc.narration.removeTabCrLfs();
			endif;
			
// ### TFS CR 65336 TASK 65338 07AUG2024 NAVAB1			if contract &lt;&gt; null then
				wholeLine := wholeLine &amp; contract &amp; cargoString &amp; vesselCatString &amp; transTypeString &amp; groupString &amp; narration &amp; mapString &amp; CrLf;
//			else
//				wholeLine := wholeLine &amp; transTypeString &amp; groupString &amp; narration &amp; mapString &amp; CrLf;
//			endif;
		endforeach;
	
		range := "Range Start: "&amp; self.rangeStart.String &amp; "  "&amp;"Range End: "&amp;self.rangeEnd.String;
		tmpStr := range &amp;CrLf &amp;wholeLine;
		txt := txt &amp;'Invoice Line Mapping' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;

	if self.getMyTerminal &lt;&gt; null then
		tmpStr := self.getMyTerminal.name;
		txt := txt &amp; app.getErrorString(Terminal) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	if self.myQuantityMap.getBank &lt;&gt; null then
		tmpStr := self.myQuantityMap.getBank.mailingName;
		txt := txt &amp; app.getErrorString(CM_Business_Unit) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	if self.myQuantityMap.myParentFinancialObject &lt;&gt; null then
		if self.myQuantityMap.myParentFinancialObject.isKindOf(CM_DebtorMap) then
			tmpStr := self.myQuantityMap.myParentFinancialObject.CM_DebtorMap.getDebtorDescription;
			txt := txt &amp; app.getErrorString(Debtor_GC) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
		endif;
	endif;
	return txt;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getBank" id="52dc6a19-3c36-49fa-9b3f-2aa011497448">
        <source>getBank(): CM_Bank;

vars
	bank	: CM_Bank;
begin
	if self.myQuantityMap &lt;&gt; null then
		bank := self.myQuantityMap.getBank();
	endif;

	return bank;
end;
</source>
        <ReturnType type="CM_Bank"/>
    </JadeMethod>
    <JadeMethod name="getCalcType" id="e12a0fa1-0c9a-4724-a9a6-dff013611f70">
        <source>getCalcType() : CM_CalculationType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 April 2018	jlgab1	Initial creation

*/

vars

begin
	if self.myQuantityMap = null then
		return null;
	endif;
	
	return self.myQuantityMap.myCalculationType;
epilog

end;</source>
        <ReturnType type="CM_CalculationType"/>
    </JadeMethod>
    <JadeMethod name="getDefaultInvoiceLine" id="ce2f0185-e00f-40d7-9a7b-5480d06e2f09">
        <source>getDefaultInvoiceLine() : CM_InvoiceLineDesc;
// ---------------------------------------------------------------------------
// Created:		05 October 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	lineDescription : CM_InvoiceLineDesc;
	mapping : CM_TranMapInvoiceLineMapping;
begin
	// TFS 40620 lineDescription := self.allInvoiceLineMaps[DEFAULT_INVOICELINE_KEY];
	mapping := self.allTMInvoiceLineMappings[DEFAULT_INVOICELINE_KEY]; // TFS 40620
	lineDescription := mapping.myTMInvoiceLineDesc; // TFS 40620
	return lineDescription;

end;</source>
        <ReturnType type="CM_InvoiceLineDesc"/>
    </JadeMethod>
    <JadeMethod name="getDefaultLineDescForKeyValue" id="5b7d6fa2-f635-4a86-be15-5a08a5d21130">
        <source>getDefaultLineDescForKeyValue(_key : Integer) : CM_InvoiceLineDesc;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 November 2012	cnwjre1	Initial creation

*/

vars
	currKey		: Integer;
	lineMapping	: CM_TranMapInvoiceLineMapping;
	lineDescription	: CM_InvoiceLineDesc;
	firstILD,
	matchILD	: CM_InvoiceLineDesc;
	groupType	: CM_TranMapInvoiceLineGroupType;
begin

	foreach lineMapping in self.allTMInvoiceLineMappings do
		lineDescription := lineMapping.myTMInvoiceLineDesc;
		currKey := lineMapping.mapValue;
		groupType := lineMapping.myTMInvoiceLineGroupType;
		if currKey = _key then
			firstILD := lineDescription;
			// this assumes that low and high default are not mixed in together
			if groupType.type = TranMapInvLineGroupTypeLowDef or
			   groupType.type = TranMapInvLineGroupTypeHighDef then
				matchILD := lineDescription;
				break;
			endif;
		endif;
	endforeach;
	
	if matchILD &lt;&gt; null then
		return matchILD;
	elseif firstILD &lt;&gt; null then
		return firstILD;
	else
		return null;
	endif;
epilog

end;</source>
        <Parameter name="_key" type="Integer"/>
        <ReturnType type="CM_InvoiceLineDesc"/>
    </JadeMethod>
    <JadeMethod name="getExtractDetails" id="c43cf75b-9df0-4432-9dea-3eb9f8a5618d">
        <source>getExtractDetails(): String;
// 23659 Apr 2010 invoice transaction map extract to use codes instead of descriptions
//  in this case, to extract properties.
vars
	padLen : Integer;
begin
	padLen := self.myQuantityMap.allQuantityRanges.last.rangeStart.String.length();
	if self.rangeEnd &gt;= self.MAX_RANGE and self.rangeStart = 0 then
		return CM_FinancialObject.Extract_Default;
	else
		if self.rangeEnd &gt;= self.MAX_RANGE then
			return self.rangeStart.Integer.padLeadingWith("0", padLen) &amp; " to MAX";
		else
			return self.rangeStart.Integer.padLeadingWith("0", padLen) &amp; " to " &amp; self.rangeEnd.Integer.String;
		endif;
	endif;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFullName" id="05f5a950-eeed-4413-b572-779a8aceaeb4">
        <source>getFullName() : String;
/*
Purpose:			
Date		Who		Reason
19 March 2015	cnwab1	Initial creation
*/

vars
	name, invLines : String;
	ild : CM_InvoiceLineDesc;
	mapping : CM_TranMapInvoiceLineMapping;
begin
	name := self.getName();
	
	 // TFS 40620foreach ild in self.allInvoiceLineMaps discreteLock do
	
	foreach mapping in self.allTMInvoiceLineMappings do // TFS 40620
		ild := mapping.myTMInvoiceLineDesc; // TFS 40620
	
		if invLines = "" then
			invLines := ild.narration;
		else
			invLines := invLines &amp; ", "  &amp; ild.narration;
		endif;
		
	endforeach;
	
	return name &amp; " - " &amp; invLines;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getInvoiceAllocation" id="0afb344e-c9f5-4d3e-8170-23935bc408a6">
        <source>getInvoiceAllocation() : CM_InvoiceAllocation;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//09/01/2025	navkc1 JIRA Sub-task MTN-19517: MTN | Jade Sub quantity Range Invoice Cargo Allocations

*/

vars
	parentObject: CM_FinancialObject;
	parentQrm	: CM_QuantityRangeMap;
	parentQm,
	qm	 		: CM_QuantityMap;
	invAlloc	: CM_InvoiceAllocation;
begin
	
	qm := self.myQuantityMap;
	
	if qm = null then
		return null;
	endif;
	
	if self.isSubRange() then
		parentObject := qm.myParentFinancialObject;
		if parentObject &lt;&gt; null and parentObject.isKindOf(CM_QuantityRangeMap) then
			parentQrm := parentObject.CM_QuantityRangeMap;
		endif;
		
		if parentQrm &lt;&gt; null then
			parentQm := parentQrm.myQuantityMap;
		endif;
		
		if parentQm &lt;&gt; null then
			invAlloc := parentQm.myInvoiceAllocation;
		endif;
	else
		invAlloc := qm.myInvoiceAllocation;
	endif;
	
	return invAlloc;
	
epilog

end;</source>
        <ReturnType type="CM_InvoiceAllocation"/>
    </JadeMethod>
    <JadeMethod name="getInvoiceLineDesc" id="e53ac813-ec82-49d1-b8e8-5b393ad94ecc">
        <source>getInvoiceLineDesc(_aSBController : CMIF_ServiceBroker input);
//09/02/2017  	cnwma1  	TFS #2901:ADP - Variable storage charges based on weight and time
//31 Oct 2023 	navma1  	ChangeRequest 60920: EUP | Cargo Enquiry Performance - Work Packet 1
//23 Oct 2024 	navlw1		JIRA-33107: Invoice Logging Use Levels
vars
	lineDescription	: CM_InvoiceLineDesc;
	intKey, 
	currKey,
	groupTypeType	: Integer;
	theMethod 		: String;
	found, 
	bMethResult		: Boolean;
	index			: Integer;
	obj				: Object;
	ti				: CM_TrackedItem;
	tiTrans 		: CM_TITransaction;
	lineMapDict		: CM_TMInvLineMapByCargoAttrDict;
	groupType		: CM_TranMapInvoiceLineGroupType;
	lineMapping		: CM_TranMapInvoiceLineMapping;
	invLineTypes	: ObjectArray;
	lineGroups		: IntegerArray;
	isSnapshot 		: Boolean;	//21 Feb 2019	NDL	TFS 43153
	voyage 			: CM_Voyage;
	vesselCat 		: HMS_VesselCategory;
	canlogExtra		: Boolean;
	cargoTypes : CM_CargoTypeSet; 
	subTypes : CM_ProductSet;
	commodities : CM_CommoditySet;
	matches, cargoTypeReqd : Boolean;
begin
	
	if _aSBController.myServiceBroker &lt;&gt; null 
	and _aSBController.myServiceBroker.isKindOf(CM_SnapShotServiceBroker) then //21 Feb 2019	NDL	TFS 43153
		isSnapshot := true;
	endif;

	if isSnapshot or //21 Feb 2019	NDL	TFS 43153
	_aSBController.isInvoiceCargoAllocation  // PAR 35833
	or _aSBController.myInventoryEvent &lt;&gt; null then // ### TFS 51219 01JUN2021 NAVAB1
		self.getInvoiceLineDescInvCargAlloc(_aSBController);
		return;
	endif;

	create invLineTypes transient;
	create lineGroups transient;

	// ### USE THE DEFAULT
	index   := 0;
	tiTrans := _aSBController.myTransaction;
	ti      := _aSBController.myTrackedItem;
	
	if ti = null and tiTrans &lt;&gt; null then
		ti := tiTrans.myTrackedItem;
	endif;
	
	canlogExtra := app.canLogExtraDetail;								//31.10.2023 navma1 #60920
	
	if _aSBController.myEventTransaction &lt;&gt; null then		 			// EVENT INVOICING
		intKey := CM_EventServiceBroker.DEFAULT_INVOICELINE_KEY;
	elseif _aSBController.myTransactionWO &lt;&gt; null then					// TFS 39236	 // WORK ORDER INVOICING
		intKey := CM_WorkOrderServiceBroker.DEFAULT_INVOICELINE_KEY;	// TFS 39236
	elseif _aSBController.myBOLTransaction &lt;&gt; null then					//01 Nov 2019	NDL	TFS 47100 BOL INVOICING
		intKey := CM_BOLServiceBroker.DEFAULT_INVOICELINE_KEY;			//01 Nov 2019	NDL	TFS 47100	
	elseif _aSBController.myVTMISTransaction &lt;&gt; null then 				// HMS INVOICING
		if _aSBController.myVTMISTransaction.partOfContract then
			intKey := CM_ResourceServiceBroker.INVOICELINE_KEY_IN_CONTRACT;
		else
			intKey := CM_ResourceServiceBroker.INVOICELINE_KEY_OUT_CONTRACT;
		endif;
		
		// ### TFS CR 65328 TASK 65329 07AUG2024 NAVAB1
		voyage := _aSBController.myVTMISTransaction. myVoyage;
		if voyage &lt;&gt; null then
			cargoTypeReqd := self.getInvoiceLineDescIsHMSCTReqd(_aSBController);
			if cargoTypeReqd then
				create cargoTypes transient;
				create subTypes transient;
				create commodities transient;
				voyage.getCargoTypes(cargoTypes, subTypes, commodities);	
			endif;
			vesselCat := voyage.getVesselCategory();
		endif;
	else
		foreach theMethod in self.allRegisteredMethods do

			bMethResult := self.getAnswerFromMethod(theMethod,ti);
			if bMethResult then
				intKey := intKey + (2^index);
			endif;
			index := index + 1;

		endforeach;
	endif;

	lineMapDict := self.allTMInvoiceLineMappings;
	foreach lineMapping in lineMapDict do

			if tiTrans.isKindOf(CM_ReleaseShip) and tiTrans.CM_ReleaseShip.transferType &gt; 0 
			or tiTrans.isKindOf(CM_ReceiveShip) and tiTrans.CM_ReceiveShip.transferType &gt; 0
			or tiTrans.isKindOf(CM_WorkOrderExtraTI) and tiTrans.CM_WorkOrderExtraTI.getTransferType() &gt; 0 then
				if lineMapping.myTransferType &lt;&gt; null then	
					if tiTrans.isKindOf(CM_ReleaseShip) and tiTrans.CM_ReleaseShip.transferType &lt;&gt; lineMapping.myTransferType.id then
						continue;
					elseif tiTrans.isKindOf(CM_ReceiveShip) and tiTrans.CM_ReceiveShip.transferType &lt;&gt; lineMapping.myTransferType.id then
						continue;
					elseif tiTrans.isKindOf(CM_WorkOrderExtraTI) and tiTrans.CM_WorkOrderExtraTI.getTransferType() &lt;&gt; lineMapping.myTransferType.id then // TFS 42221
						continue;
					endif;
 // ### TFS 56303 24JAN2023 NAVAB1 if no transfer type has been specified it means 'ALL transfer types' so do not ignore by continuing					
 // ### TFS 56303 24JAN2023 NAVAB1				else	
 // ### TFS 56303 24JAN2023 NAVAB1					continue;
				endif;
			elseif _aSBController.myVTMISTransaction &lt;&gt; null then 	// HMS INVOICING  // ### TFS 52132 12OCT2021 NAVAB1
				if lineMapping.myVesselCategory &lt;&gt; null then
// ### TFS CR 65328 TASK 65328 07AUG2024 NAVAB1					voyage := _aSBController.myVTMISTransaction.myVoyage;
					if voyage &lt;&gt; null then
// ### TFS CR 65328 TASK 65328 07AUG2024 NAVAB1						vesselCat := voyage.getVesselCategory();
						if vesselCat &lt;&gt; null then
							if vesselCat &lt;&gt; lineMapping.myVesselCategory then
								continue;
							endif;
						endif;
					endif;
				endif;
				
				
				// ### TFS CR 65328 TASK 65329 07AUG2024 NAVAB1
				if cargoTypeReqd then
					matches := false;
					if lineMapping.myCargoType &lt;&gt; null then
						matches := cargoTypes.includes(lineMapping.myCargoType);
						if matches and lineMapping.myCargoSubtype &lt;&gt; null then
							matches := subTypes.includes(lineMapping.myCargoSubtype);	
							if matches	and lineMapping.myCommodity &lt;&gt; null then
								matches := commodities.includes(lineMapping.myCommodity);	
							endif;
						endif;
					elseif lineMapping.myCargoSubtype &lt;&gt; null then
						matches := subTypes.includes(lineMapping.myCargoSubtype);	
						if matches and lineMapping.myCommodity &lt;&gt; null then
							matches := commodities.includes(lineMapping.myCommodity);	
						endif;
					// ### TFS DEFECT 65685 19AUG2024 NAVAB1 - if all the cargo attributes are null it is a match
					elseif lineMapping.myCommodity &lt;&gt; null then
						matches := commodities.includes(lineMapping.myCommodity);	
					else
						matches := true;
					endif;
				else
					matches := true;
				endif;	
				
				if not matches then
					continue;
				endif;
			
				
			else // transaction transfer type is zero, is there an actual LOLO transfer type mapping?
				if lineMapping.myTransferType &lt;&gt; null 
				and lineMapping.myTransferType.id &lt;&gt; 0 then
						continue;
				endif;
			endif;
	
	
		
		
		
		lineDescription := lineMapping.myTMInvoiceLineDesc;
		currKey := lineMapping.mapValue;
		groupType := lineMapping.myTMInvoiceLineGroupType;
		//epr par 32314 3/9/13 could not figure out how this is ever null setting to all if null
		if groupType &lt;&gt; null then
			groupTypeType:=groupType.type;
		else
			groupTypeType:=TranMapInvLineGroupTypeAll;
		endif;
		if currKey = intKey	then
			found := true;
			if canlogExtra then			//31.10.2023 navma1 #60920
				app.invLog("Invoice line map " &amp; lineDescription.narration &amp; " for quantity range " &amp; self.rangeStart.String &amp; " to " &amp; self.rangeEnd.String, LogTRACE.String);
			endif;
			// 35365 save these locally and consolidate below
			invLineTypes.add(lineDescription);
			lineGroups.add(groupTypeType);
			_aSBController.invoiceLineMappingKey := intKey;
//  PAR 33927			_aSBController.invoiceLineMappingGroupType := groupTypeType;
			// PAR 33927 could have a mix of ALL and HIGHEST, but it only worked if ALL was first in the mapping
			//					Now always override ALL
			if _aSBController.invoiceLineMappingGroupType  = TranMapInvLineGroupTypeAll then 
				_aSBController.invoiceLineMappingGroupType := groupTypeType;
			endif;

		endif;
	endforeach;
	
	// DEFAULT
	if not found then
		foreach lineMapping in lineMapDict do
			lineDescription := lineMapping.myTMInvoiceLineDesc;
			currKey := lineMapping.mapValue;
			
			if currKey = intKey then // TFS 43649
	// TFS 43649		if currKey = DEFAULT_INVOICELINE_KEY then
			
				if lineMapping.myTransferType &lt;&gt; null then // TFS 40620
					continue; // TFS 40620
				endif;
				
				if _aSBController.myVTMISTransaction &lt;&gt; null then 	// HMS INVOICING  // ### TFS 52132 12OCT2021 NAVAB1
					// The default one has no vessel category
					if lineMapping.myVesselCategory &lt;&gt; null 	// HMS INVOICING  // ### TFS 52132 12OCT2021 NAVAB1
					// ### TFS CR 65328 TASK 65329 13AUG2024 NAVAB1
					or lineMapping.myCargoType &lt;&gt; null 
					or lineMapping.myCargoSubtype &lt;&gt; null 
					or lineMapping.myCommodity &lt;&gt; null then
						continue;	// HMS INVOICING  // ### TFS 52132 12OCT2021 NAVAB1
					endif;
				endif;
				
				found := true;
				if canlogExtra then	//31.10.2023 navma1 #60920
					app.invLog("Invoice line map DEFAULT " &amp; lineDescription.narration &amp; " for quantity range " &amp; self.rangeStart.String &amp; " to " &amp; self.rangeEnd.String, LogTRACE.String);
				endif;
				// 35365 save these locally and consolidate below
				invLineTypes.add(lineDescription);
				lineGroups.add(TranMapInvLineGroupTypeAll);
				_aSBController.invoiceLineMappingKey := DEFAULT_INVOICELINE_KEY;
				_aSBController.invoiceLineMappingGroupType := TranMapInvLineGroupTypeAll;
			endif;
		endforeach;
	endif;

	if not found then
		if canlogExtra then
			app.invLog("NO Invoice line map found for quantity range " &amp; self.rangeStart.String &amp; " to " &amp; self.rangeEnd.String, LogTRACE.String);
		endif;
	endif;
	
	// 35365 do the grouping here, not at a higher level (was on CM_Bank) so that it does each level of an escalating charge
	self.findGroupedInvoiceLineDesc(_aSBController, invLineTypes, lineGroups);

	// 35365 now populate the controller
	index := 0;
	foreach obj in invLineTypes do
		index := index + 1;
		lineDescription := obj.CM_InvoiceLineDesc;

			
		intKey := lineGroups[index];
		_aSBController.allInvoiceLineTypes.add(lineDescription);
// -TFS 2901 AB 		if self.myQuantityMap.myParentFinancialObject.isKindOf(CM_QuantityRangeMap)  then 					//15/02/2017 cnwma1 TFS #2901
			// -TFS 2901 AB _aSBController.allQuantityRangeMaps.add(self.myQuantityMap.myParentFinancialObject.CM_QuantityRangeMap);
// -TFS 2901 AB 		else
			_aSBController.allQuantityRangeMaps.add(self);
// -TFS 2901 AB 		endif;
		_aSBController.allLineGroups.add(intKey);
	endforeach;
	
epilog
	delete invLineTypes;
	delete lineGroups;
	delete cargoTypes;
	delete subTypes;
	delete commodities;
end;</source>
        <Parameter name="_aSBController" type="CMIF_ServiceBroker" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getInvoiceLineDescInvCargAlloc" id="05d66112-61cf-4f59-a302-ee1d6284e1db">
        <source>getInvoiceLineDescInvCargAlloc(_aSBController : CMIF_ServiceBroker input);
 // ### TFS 51219 28MAY2021 NAVAB1 removed unused ti and tiTrans varibles and code
 // 23 Oct 2024 	navlw1		JIRA-33107: Invoice Logging Use Levels
 // 25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
vars
	lineDescription:   CM_InvoiceLineDesc;
	intKey, currKey,
	groupTypeType:            Integer;
	theMethod : String;
	found, bMethResult:       Boolean;
	index:             Integer;
	obj		: Object;

	lineMapDict		: CM_TMInvLineMapByCargoAttrDict;
	groupType		: CM_TranMapInvoiceLineGroupType;
	lineMapping		: CM_TranMapInvoiceLineMapping;
	
	invLineTypes	: ObjectArray;
	lineGroups		: IntegerArray;
	canLogExtra		: Boolean;	//27.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//27.02.2025 navah1	#34141 
	create invLineTypes transient;
	create lineGroups transient;

	// ### USE THE DEFAULT
	index := 0;

	lineMapDict := self.allTMInvoiceLineMappings;
	foreach lineMapping in lineMapDict do
		lineDescription := lineMapping.myTMInvoiceLineDesc;
		currKey := lineMapping.mapValue;
		groupType := lineMapping.myTMInvoiceLineGroupType;
		if groupType &lt;&gt; null then
			groupTypeType:=groupType.type;
		else
			groupTypeType:=TranMapInvLineGroupTypeAll;
		endif;

		found := true;
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog("Invoice line map " &amp; lineDescription.narration &amp; " for quantity range " &amp; self.rangeStart.String &amp; " to " &amp; self.rangeEnd.String, LogINFO.String);
		endif;
		invLineTypes.add(lineDescription);
		
		lineGroups.add(groupTypeType);
		
		_aSBController.invoiceLineMappingKey := currKey;
		
		if _aSBController.invoiceLineMappingGroupType  = TranMapInvLineGroupTypeAll then 
			_aSBController.invoiceLineMappingGroupType := groupTypeType;
		endif;

	endforeach;

	
	self.findGroupedInvoiceLineDesc(_aSBController, invLineTypes, lineGroups);

	index := 0;
	foreach obj in invLineTypes do
		index := index + 1;
		lineDescription := obj.CM_InvoiceLineDesc;
		intKey := lineGroups[index];
		_aSBController.allInvoiceLineTypes.add(lineDescription);
		_aSBController.allQuantityRangeMaps.add(self);
		_aSBController.allLineGroups.add(intKey);
	endforeach;
	
epilog
	delete invLineTypes;
	delete lineGroups;
end;</source>
        <Parameter name="_aSBController" type="CMIF_ServiceBroker" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getInvoiceLineDescIsHMSCTReqd" id="52ef9b39-38bd-46d1-9562-9cd720f6ae32">
        <source>getInvoiceLineDescIsHMSCTReqd(_aSBController : CMIF_ServiceBroker input) : Boolean;
// ### TFS CR 65328 TASK 65329 30AUG2024 NAVAB1
// Do we need to get all the cargo types, commodities and sub cargo types for mapping?
vars
	lineMapDict		: CM_TMInvLineMapByCargoAttrDict;
	lineMapping		: CM_TranMapInvoiceLineMapping;
begin
	if _aSBController.myVTMISTransaction = null then 				// HMS INVOICING
		return false;
	endif;


	lineMapDict := self.allTMInvoiceLineMappings;
	foreach lineMapping in lineMapDict do

		if lineMapping.myCargoType &lt;&gt; null 
		or lineMapping.myCargoSubtype &lt;&gt; null 
		or lineMapping.myCommodity &lt;&gt; null then
			return true;
		endif;

	endforeach;
	
	return false;
epilog
end;</source>
        <Parameter name="_aSBController" type="CMIF_ServiceBroker" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getMappingMethods" id="8da47cda-b9ae-4787-917d-eb41b5f5ff3d">
        <source>getMappingMethods(_curKey : Integer):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Jan 2017	cnwma1	TFS #2643 :JMT - Audit of Invoice Maintenance Set-up


*/

vars
	methodsArray : StringArray;
	tmpStr,str : String;
	idx : Integer;
begin
	if self.allRegisteredMethods.size &gt;0  then
		create methodsArray transient;
		self.allRegisteredMethods.copy(methodsArray);
		foreach idx in 1 to methodsArray.size do
			if _curKey.bitAnd(2^(idx-1)) &lt;&gt; 0 then
				tmpStr := tmpStr &amp;" - "  &amp;methodsArray[idx];
				
			endif;
		endforeach;
	endif;
	return tmpStr;
epilog
	delete methodsArray;
end;</source>
        <Parameter name="_curKey" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getName" id="a6d80156-bd0c-4253-a0e4-b1b77e910e36">
        <source>getName(): String;
// ---------------------------------------------------------------------------
// Created:		02 October 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	padLen : Integer;
begin
	padLen := self.myQuantityMap.allQuantityRanges.last.rangeStart.String.length();
	if self.rangeEnd &gt;= self.MAX_RANGE and self.rangeStart = 0 then
		return "Default (" &amp; self.rangeStart.Integer.String &amp; " to MAX)";
	else
		if self.rangeEnd &gt;= self.MAX_RANGE then
			return self.rangeStart.Integer.padLeadingWith("0", padLen) &amp; " to MAX";
			return self.rangeStart.Integer.String &amp; " to MAX";
		else
			return self.rangeStart.Integer.padLeadingWith("0", padLen) &amp; " to " &amp; self.rangeEnd.Integer.String;
			return self.rangeStart.Integer.String &amp; " to " &amp; self.rangeEnd.Integer.String;
		endif;
	endif;
	
	return inheritMethod();

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNumMappings" id="ee273eae-8ba1-4ba9-a40b-59a35da84cb3">
        <source>getNumMappings() : Integer;

vars

begin
	// TFS 40620 return self.allInvoiceLineMaps.size;
	return self.allTMInvoiceLineMappings.size;// TFS 40620 

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getNumberOfMappingsForLineType" id="284014dc-51ae-436e-a4b4-84125d54b0fd">
        <source>getNumberOfMappingsForLineType(_invLineType : CM_InvoiceLineDesc) : Integer;
/*
Purpose:			
Date		Who		Reason
08 October 2014	cnwab1	Initial creation
*/

vars
	invLine:CM_InvoiceLineDesc;
	idx : Integer;
	mapping : CM_TranMapInvoiceLineMapping;
begin
	// TFS 40620 foreach invLine in self.allInvoiceLineMaps discreteLock do
	foreach mapping in self.allTMInvoiceLineMappings do // TFS 40620
		invLine := mapping.myTMInvoiceLineDesc; // TFS 40620

		if invLine = _invLineType then
			return 1;
		endif;
 
	endforeach;
	
	return 0;
epilog

end;</source>
        <Parameter name="_invLineType" type="CM_InvoiceLineDesc"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTranMapBreadCrumb" id="708716a6-b2b2-48f1-9d88-e2e8906759d2">
        <source>getTranMapBreadCrumb() : String;
/*
Purpose:			
Date		Who		Reason
19 October 2016	cnwab1	Initial creation
*/

vars

begin

	if self.myQuantityMap = null then	//04 Feb 2019	NDL	TFS 43153
		return self.getOidString;
	endif;
	
	return self.myQuantityMap.getTranMapBreadCrumb() &amp; "/" &amp;  self.getName();
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initFromDebtorMap" id="00c77178-3d8e-421b-9f33-0137680934cb">
