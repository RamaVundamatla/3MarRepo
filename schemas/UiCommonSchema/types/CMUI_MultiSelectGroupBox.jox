    <JadeMethod name="displayEntry" id="98767f54-797b-49e9-9976-f78784a2748e">
        <updating/>
        <source>displayEntry(obj: Any): String updating;
// ---------------------------------------------------------------------------
// Created:     29 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 
// ---------------------------------------------------------------------------
vars
		
begin
	if self.formDisplayEntryMethodName &lt;&gt; null then
		return self.form.sendMsgWithParams(self.formDisplayEntryMethodName, obj).String;
	else
		return 'set &lt;formDisplayEntryMethodName&gt;';
	endif;
	
end;</source>
        <Parameter name="obj" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
