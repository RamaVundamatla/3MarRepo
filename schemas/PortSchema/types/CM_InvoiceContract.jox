    <JadeMethod name="setForUpdateEndDate" id="06c96732-fb92-4f43-af2c-1de487ecd47c">
        <updating/>
        <source>setForUpdateEndDate(_newEndDate : TimeStamp) updating;
/*
Purpose:			

Date		Who		Reason
20 February 2023	navab1	TFS CR 55646 TASK 56413
*/

vars
	detail : CM_InvoiceContractDetails;
	rate : CM_InvoiceContractRate;
	entry : CM_InvoiceContractRateEntry;
	audit : CM_UpdateTransactionAuditAgent;
begin
	if not _newEndDate.isValid() then
		return;
	endif;
	
	if _newEndDate = self.toTS then // nothing to change
		return;
	endif;
	
	foreach detail in self.allInvoiceContractDetails discreteLock do
		if detail.toTS.date = self.toTS.date then
			create audit transient;
			audit.audUpdateGeneric(detail, true);
			detail.setToTS(_newEndDate);
			audit.audUpdateGeneric(detail, false);
			delete audit;
			app.myEventManager.createSingleObjInfoNoteEvt(self,app.myPassport.myTerminal.getTerminalEvent(Event_InvContractDtlUpdate),detail);
		endif;
		
		foreach rate in detail.allInvoiceContractRates discreteLock do
		
			foreach entry in rate.allInvoiceContractRateEntries discreteLock do
				if entry.toTS.date = self.toTS.date then
					create audit transient;
					audit.audUpdateGeneric(entry, true);
					entry.setToTS(_newEndDate);
					audit.audUpdateGeneric(entry, false);
					delete audit;
				endif;
			
			endforeach;
			
		endforeach;
	
	endforeach;
	
	self.toTS := _newEndDate;
epilog
	delete audit;
end;</source>
        <Parameter name="_newEndDate" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="5a08137a-b020-4c71-bee3-555165012900">
        <updating/>
        <source>setProxy(_active : Boolean; _contractId : String; _fromTS : TimeStamp; _toTS : TimeStamp; _primary : Boolean; _bank : CM_Bank; _term : CM_Terminal; _debtor : CM_Debtor; _descr : String) updating;
/*
Purpose:			

Date		Who		Reason
01 December 2022	navab1	TFS CR 55623 TASK 55671
*/

vars

begin
	self.active := _active;
	self.contractId := _contractId;
	self.fromTS := _fromTS;
	self.toTS := _toTS;
	self.primary := _primary;
	
	self.myBusinessUnit := _bank;
	self.myTerminal := _term;
	self.myDebtor := _debtor;
	self.description := _descr;
epilog

end;</source>
        <Parameter name="_active" type="Boolean"/>
        <Parameter name="_contractId" type="String"/>
        <Parameter name="_fromTS" type="TimeStamp"/>
        <Parameter name="_toTS" type="TimeStamp"/>
        <Parameter name="_primary" type="Boolean"/>
        <Parameter name="_bank" type="CM_Bank"/>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <Parameter name="_descr" type="String"/>
    </JadeMethod>
    <JadeMethod name="validateDateRangeUnique" id="751968b6-5c65-47f1-93af-adee894e3878">
        <source>validateDateRangeUnique(_otherContract : CM_InvoiceContract) : Boolean;
/*
Purpose:			

Date		Who		Reason
15 November 2023	navab1	BUG 60627
*/

vars

begin
	if _otherContract = null then
		return true;
	endif;
	
	if _otherContract.fromTS &gt;= self.fromTS
	and _otherContract.fromTS &lt;= self.toTS then
		return false;
	endif;
	if _otherContract.toTS &gt;= self.fromTS
	and _otherContract.toTS &lt;= self.toTS then
		return false;
	endif;
	
	return true;
epilog

end;</source>
        <Parameter name="_otherContract" type="CM_InvoiceContract"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="1c29832c-c34e-4b5e-8174-cfb0fefc1fe3">
        <source>validateForCreate();
/*
Purpose:			

Date		Who		Reason
01 December 2022	navab1	TFS CR 55623 TASK 55671
*/

vars
	contract : SelfType;
	detail : CM_InvoiceContractDetails;
	iter : Iterator;
	myBU : CM_Bank;
begin
	myBU := self.myBusinessUnit;
	
	if myBU.allInvoiceContractsById[self.contractId,self.myDebtor] &lt;&gt; null then
		app.raiseCMException2(Invoic_contra_alread_exists_de,self.contractId, self.myDebtor.name,null,null);
	endif;

	if self.myTerminal.allInvoiceContractsById[self.contractId,self.myDebtor] &lt;&gt; null then
		app.raiseCMException3(Invoi_contr_alrea_exist_debto_,self.contractId, self.myDebtor.name, self.myTerminal.code, null,null);
	endif;
	
	if self.primary then
		iter := self.myDebtor.allInvoiceContracts.createIterator();

		contract := self.myDebtor.allInvoiceContracts.getAtKeyGeq(myBU,null);
		
		if contract &lt;&gt; null
		and contract.myBusinessUnit = myBU then
			iter.startAtObject(contract);
			while(iter.next(contract))  do
				if contract.myBusinessUnit &lt;&gt; myBU then
					break;
				endif;
				if contract.primary then
					if not self.validateDateRangeUnique(contract) then // ### TFS BUG 60627 15NOV2023 NAVAB1
						app.raiseCMException1(Debtor_already_primary_contrac,self.myDebtor.name,null,null);
						break;
					endif;
				endif;
				
			endwhile;
		endif;
	endif;

	self.validateMe();
	
epilog
	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="49f4d306-8307-4440-a1ff-aaaf03f267d0">
        <source>validateForDelete();
/*
Purpose:			

Date		Who		Reason
01 December 2022	navab1	TFS CR 55623 TASK 55671
25 July    2024 navrv30 Bug 65128: FR | 54089 - Invoice Contracts - Deletion of a Debtor with used rates
*/

vars
	contract : SelfType;
	otherActive : Boolean;
	iter : Iterator;
	myBU : CM_Bank;
	invContractDetail : CM_InvoiceContractDetails;
	invContractRate : CM_InvoiceContractRate;
begin
	myBU := self.myBusinessUnit;


	if self.primary then 
		app.raiseCMException2(Invoi_contr_debto_prima_canno_, self.contractId, self.myDebtor.name,null, null);
	endif;
	//25 July    2024 navrv30 Bug 65128
	foreach invContractDetail in self.allInvoiceContractDetails do
	/*
		foreach invContractRate in invContractDetail.allInvoiceContractRates do
			if invContractRate.myService &lt;&gt; null and invContractRate.myService.charges.isNotEmpty then
				app.raiseCMException1(Cannot_delete_been_used_invoic,invContractDetail.auditId(),null,null);
			endif;
		endforeach;
		*/
		// ### JIRA 33307 19NOV2024 NAVAB1
		if invContractDetail.allInvoiceLines.isNotEmpty then
			app.raiseCMException1(Cannot_delete_been_used_invoic,invContractDetail.auditId(),null,null);
		endif;

	endforeach;
	
	if self.active 
	and self.myDebtor &lt;&gt; null then
		iter := self.myDebtor.allInvoiceContracts.createIterator();

		contract := self.myDebtor.allInvoiceContracts.getAtKeyGeq(myBU,null);
		
		if contract &lt;&gt; null
		and contract.myBusinessUnit = myBU then
			iter.startAtObject(contract);
			while(iter.next(contract))  do
				if contract.myBusinessUnit &lt;&gt; myBU then
					break;
				endif;

				if contract = self then
					continue;
				endif;
				
				if contract.active then
					otherActive := true;
					break;
				endif;
			endwhile;
		endif;
		
		if not otherActive then
			app.raiseCMWarning1(This_contr_last_activ_contr_de, self.myDebtor.name,null, null, null);
		
		endif;
	endif;
epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForSwitchPrimary" id="b1c7cdd7-470b-49d5-aa11-36357f0f76bb">
        <source>validateForSwitchPrimary(_pxyOther : CM_InvoiceContract);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 March 2024 navrv30 Initial creation - Bug 62682: FR - 54089 - Primary status - Invoice contracts
*/

vars
	contract, realMe : SelfType;
	otherContract, realOther : CM_InvoiceContract;
	iter : Iterator;
	myBU : CM_Bank;
begin
	myBU := self.myBusinessUnit;
	
	realMe := self.pxyGetRealObject();		

	realOther := _pxyOther.pxyGetRealObject();
	
	
	if not realMe.myDebtor = realOther.myDebtor then
		app.raiseCMException2(Invoic_contra_debtor_mismatch, self.myDebtor.name, _pxyOther.myDebtor.name, null,null);
	endif;
	
	if realMe.primary = false and realOther.primary = false then
		app.raiseCMException1(Debto_must_have_least_prima_co, self.myDebtor.name, null,null);
	endif;
	
	if self.validateDateRangeUnique(_pxyOther) then
		app.raiseCMException1(Debtor_already_primary_contrac,self.myDebtor.name,null,null);
	endif;	
epilog
	delete iter;

end;</source>
        <Parameter name="_pxyOther" type="CM_InvoiceContract"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="c314de4a-9816-4704-bed0-d779a65f9654">
        <source>validateForUpdate();
/*
Purpose:			

Date		Who		Reason
01 December 2022	navab1	TFS CR 55623 TASK 55671
06 March 2023 		navtnr20 Bug 56908: EUP - Able to get inconsistent dates between contracts, rate criteria and rates.
*/

vars
	contract, realMe : SelfType;
	detail : CM_InvoiceContractDetails;
	iter : Iterator;
	myBU : CM_Bank;
	endDate,startDate : TimeStamp;
	hasPrimary : Boolean;
begin
	myBU := self.myBusinessUnit;
	
	realMe := self.pxyGetRealObject();
	
	contract :=  myBU.allInvoiceContractsById[self.contractId,self.myDebtor];
	if contract &lt;&gt; null // might be changing the contract id value
	and contract &lt;&gt; realMe then
		app.raiseCMException2(Invoic_contra_alread_exists_de,self.contractId, self.myDebtor.name,null,null);
	endif;

	contract :=  self.myTerminal.allInvoiceContractsById[self.contractId,self.myDebtor];
	if contract &lt;&gt; null // might be changing the contract id value
	and  contract &lt;&gt; realMe then
		app.raiseCMException3(Invoi_contr_alrea_exist_debto_,self.contractId, self.myDebtor.name, self.myTerminal.code, null,null);
	endif;
	
	// ### TFS BUG 60627 16NOV2023 NAVAB1
	if not self.primary and realMe.primary then
		foreach contract in self.myDebtor.allInvoiceContracts discreteLock do
			if contract.myBusinessUnit &lt;&gt; myBU then
				continue;
			endif;
			if contract = realMe then
				continue;
			endif;
			
			if contract.primary then
				hasPrimary := true;
				break;
			endif;
		
		endforeach;
		
		if not hasPrimary then
			app.raiseCMException1(Debto_must_have_least_prima_co, self.myDebtor.name, null,null);
		endif;
		
	endif;
	
	if self.primary then
		iter := self.myDebtor.allInvoiceContracts.createIterator();

		contract := self.myDebtor.allInvoiceContracts.getAtKeyGeq(myBU,null);
		
		if contract &lt;&gt; null
		and contract.myBusinessUnit = myBU then
			iter.startAtObject(contract);
			while(iter.next(contract))  do
				if contract.myBusinessUnit &lt;&gt; myBU then
					break;
				endif;
				if contract.primary 
				and contract &lt;&gt; realMe then
					if not self.validateDateRangeUnique(contract) then // ### TFS BUG 60627 15NOV2023 NAVAB1
						app.raiseCMException1(Debtor_already_primary_contrac,self.myDebtor.name,null,null);
						break;
					endif;
				endif;
				
			endwhile;
		endif;	
	endif;
	// Start navtnr20 06-03-2023 bug 56908 

	 // ### BUG 56908 21MAR2023 NAVAB1. During a normal update 'self' the proxy will not have any details in this collection, for bulk update of the toTS it will
	if not self.allInvoiceContractDetails.isEmpty() then
		foreach detail in self.allInvoiceContractDetails discreteLock do
			if self.toTS &lt; detail.toTS or self.fromTS &gt; detail.fromTS then 
				app.raiseCMException3(Contr_date_range_confl_with_da,self.fromTS.shortCurrentLocaleFormat,self.toTS.shortCurrentLocaleFormat,detail.auditId,null,null);
			endif;
		endforeach;
	
	else
		foreach detail in realMe.allInvoiceContractDetails discreteLock do
			if self.toTS &lt; detail.toTS or self.fromTS &gt; detail.fromTS then 
				app.raiseCMException3(Contr_date_range_confl_with_da,self.fromTS.shortCurrentLocaleFormat,self.toTS.shortCurrentLocaleFormat,detail.auditId,null,null);
			endif;
		endforeach;
	endif;
	// End navtnr20 06-03-2023 bug 56908 
	self.validateMe();
	
epilog
	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="validateMe" id="8ab54c77-04df-4a40-86c9-6fd99220e437">
        <source>validateMe();
/*
Purpose:			

Date		Who		Reason
12 December 2022	navab1	TFS CR 55623 TASK 55671
*/

vars
	contract : SelfType;
	detail : CM_InvoiceContractDetails;
begin
	if self.contractId = null then
		app.raiseCMException(Invoice_contrac_must_entered,null,null);
	endif;
	
	if self.myDebtor = null then
		app.raiseCMException(Invoic_contra_debtor_must_ente,null,null);
	endif;
	
	if self.myBusinessUnit = null then
		app.raiseCMException(Invoi_contr_busin_unit_must_en,null,null);
	endif;
	
	if self.myTerminal = null then
		app.raiseCMException(Must_select_valid_term,null,null);
	endif;
	
	if self.fromTS = null then
		app.raiseCMException(Invoi_contr_from_date_time_mus, null, null);
	elseif self.fromTS &gt; self.toTS then
		app.raiseCMException(Invoi_contr_from_date_time_can,null,null);
	elseif self.fromTS &lt; self.systemToLocalTime(app.actualTimeServer).subtractYears(100) then
		app.raiseCMWarning(Invoi_contr_from_date_time_100, 'damageDateTime', null, null);
	endif;
	
	if self.toTS = null then
		app.raiseCMException(Invoi_contr_date_time_must_ent, null, null);
	elseif self.toTS &lt; self.fromTS then
		app.raiseCMException(Invoi_contr_date_time_canno_be,null,null);
	elseif self.toTS &gt; self.systemToLocalTime(app.actualTimeServer).addYears(100) then
		app.raiseCMWarning(Invoi_contr_date_time_canno_gr, 'damageDateTime', null, null);
	endif;

	
epilog

end;</source>
    </JadeMethod>
</Class>
