    <JadeMethod name="setSelectedCP" id="8e049555-aedf-4394-9a33-a7c004905851">
        <updating/>
        <source>setSelectedCP(pCriteriaPriorityObj:CM_YACriteriaPriority) updating;
// --------------------------------------------------------------------------------
// Created:		04 April 2005 by cnwdad1
//
// Purpose:		sets a reference to the currently selected Criteria/Priority on the
//				Criteria tab.
//
// Parameters:	pCriteriaPriorityObj - A reference to the selected Criteria/Priority.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.mySelectedCP	:=	pCriteriaPriorityObj;
	
	if pCriteriaPriorityObj = null then
		self.myBtnDODefault.enabled	:=	false;
		self.myBtnDOSpecify.enabled	:=	false;
	else
		self.myBtnDODefault.enabled	:=	true;
		self.myBtnDOSpecify.enabled	:=	true;
	endif;
end;</source>
        <Parameter name="pCriteriaPriorityObj" type="CM_YACriteriaPriority"/>
    </JadeMethod>
    <JadeMethod name="setTabOrders" id="c54e846f-3d20-43c3-9983-29fe7222411c">
        <source>setTabOrders() protected;
// --------------------------------------------------------------------------------
// Created:		02 May 2005 by cnwdad1
//
// Purpose:		Sets the tab ordering of the receiver's child controls.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.myFolder.tabIndex					:=	self.tabIndex + 1;
	self.myShtLocations.tabIndex			:=	self.myFolder.tabIndex + 1;
	self.myLblLocation.tabIndex				:=	self.myShtLocations.tabIndex + 1;
	self.myTxtLocation.tabIndex				:=	self.myLblLocation.tabIndex + 1;
	self.myBtnLocAdd.tabIndex				:=	self.myTxtLocation.tabIndex + 1;
	self.myBtnLocDelete.tabIndex			:=	self.myBtnLocAdd.tabIndex + 1;
	self.myLblLocSelected.tabIndex			:=	self.myBtnLocDelete.tabIndex + 1;
	self.myBtnDODefault.tabIndex			:=	self.myLblLocSelected.tabIndex + 1;
	self.myBtnDOSpecify.tabIndex			:=	self.myBtnDODefault.tabIndex + 1;
	self.myLstLocations.tabIndex			:=	self.myBtnDOSpecify.tabIndex + 1;
	self.myBtnClearLocs.tabIndex			:=	self.myLstLocations.tabIndex + 1;
	self.myLblSortFor.tabIndex				:=	self.myBtnClearLocs.tabIndex + 1;
	self.myOptSortIn.tabIndex				:=	self.myLblSortFor.tabIndex + 1;
	self.myOptSortOut.tabIndex				:=	self.myOptSortIn.tabIndex + 1;
	self.myLblOptionIn.tabIndex				:=	self.myOptSortOut.tabIndex + 1;
	self.myCmbOptionIn.tabIndex				:=	self.myLblOptionIn.tabIndex + 1;
	self.myLblOptionOut.tabIndex			:=	self.myCmbOptionIn.tabIndex + 1;
	self.myCmbOptionOut.tabIndex			:=	self.myLblOptionOut.tabIndex + 1;
	self.myShtCriteria.tabIndex				:=	self.myCmbOptionOut.tabIndex + 1;
	self.myCtrlCriteria.tabIndex			:=	self.myShtCriteria.tabIndex + 1;
	self.myCtrlCriteria.setTabOrders();
	self.myLstCriteria.tabIndex				:=	self.myCtrlCriteria.myBtnDelete.tabIndex + 1;
	self.myLblCode.tabIndex					:=	self.myLstCriteria.tabIndex + 1;
	self.myTxtCode.tabIndex					:=	self.myLblCode.tabIndex + 1;
	self.myLblDescription.tabIndex			:=	self.myTxtCode.tabIndex + 1;
	self.myTxtDescription.tabIndex			:=	self.myLblDescription.tabIndex + 1;
	self.myLblRemarks.tabIndex				:=	self.myTxtDescription.tabIndex + 1;
	self.myTxtRemarks.tabIndex				:=	self.myLblRemarks.tabIndex + 1;
	self.myShtOptions.tabIndex				:=	self.myTxtRemarks.tabIndex + 1;
	self.myGrpOptions.tabIndex				:=	self.myShtOptions.tabIndex + 1;
	self.myOptNever.tabIndex				:=	self.myGrpOptions.tabIndex + 1;
	self.myOptVoyageDepart.tabIndex			:=	self.myOptNever.tabIndex + 1;
	self.myOptWhenEmpty.tabIndex			:=	self.myOptVoyageDepart.tabIndex + 1;
	self.myOptSpecifiedDate.tabIndex		:=	self.myOptWhenEmpty.tabIndex + 1;
	self.myTxtExpiryDate.tabIndex			:=	self.myOptSpecifiedDate.tabIndex + 1;
	self.myLblColor.tabIndex				:=	self.myTxtExpiryDate.tabIndex + 1;
	self.myLblColorPicker.tabIndex			:=	self.myLblColor.tabIndex + 1;
	self.myLblAllowOthers.tabIndex			:=	self.myLblColorPicker.tabIndex + 1;
	self.myCmbAllowOthers.tabIndex			:=	self.myLblAllowOthers.tabIndex + 1;
	self.myLblNoLocation.tabIndex			:=	self.myCmbAllowOthers.tabIndex + 1;
	self.myCmbNoLocation.tabIndex			:=	self.myLblNoLocation.tabIndex + 1;
	// CCMS 1357
	self.myLblOverstowRule.tabIndex			:=	self.myCmbNoLocation.tabIndex + 1;
	self.myCmbOverstowRule.tabIndex			:=	self.myLblOverstowRule.tabIndex + 1;
	self.myLblPriorityAdj.tabIndex			:=	self.myCmbOverstowRule.tabIndex + 1;
	self.myTxtPriorityAdj.tabIndex			:=	self.myLblPriorityAdj.tabIndex + 1;
	self.myChkTestOverstowWeight.tabIndex	:=	self.myTxtPriorityAdj.tabIndex + 1;
	self.myChkIsDisabled.tabIndex			:=	self.myChkTestOverstowWeight.tabIndex + 1;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setYardAllocation" id="813a53b0-ae48-4875-ae0e-c39085a3adf5">
        <updating/>
        <source>setYardAllocation(pYardAllocObj:CM_YardAllocation) updating;
// --------------------------------------------------------------------------------
// Created:		16 March 2005 by cnwdad1
//
// Purpose:		This method will make transient proxies of the whole Yard Allocation
//				structure (i.e. the Yard Allocation, the Location Blocks, and the
//				Criteria) and store them on this form.  When the "Save" button is
//				clicked, the original Yard Allocation object will be discarded, and
//				the modified Yard Allocation structure will be persisted anew.
//
// Parameters:	pYardAllocObj - A reference to the persistent Yard Allocation object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	proxyObj		: CM_YardAllocation;
	blockGroupObj	: CM_YABlockGroup;
	allCriteriaObj	: CM_YACriteriaPriorityArray;
	isLoadSet		: Boolean;
	
begin
	self.isFirstLocationLoad	:=	true;
	self.doClearCurrentYA();
	
	if pYardAllocObj = null then
		create proxyObj transient;
		create blockGroupObj transient;
		proxyObj.allYABlockGroupsIn.add(blockGroupObj);
		proxyObj.allYABlockGroupsOut.add(blockGroupObj);
		self.allBlockGroupsIn.purge();
		self.allBlockGroupsOut.purge();
	else
//		app.cmsBeginLoad(isLoadSet);
		proxyObj	:=	app.createUpdateProxy(pYardAllocObj).CM_YardAllocation;
//		app.cmsEndLoad(isLoadSet);
		
		create allCriteriaObj transient;
		pYardAllocObj.allCriteria.copy(allCriteriaObj);
		self.myCtrlCriteria.preloadCriteriaPriorities(allCriteriaObj);
	endif;
	
	self.myCtrlCriteria.setupControl(true, (pYardAllocObj = null));
	self.myProxyYA			:=	proxyObj;
	self.myYardAllocation	:=	pYardAllocObj;
	self.setupControl();
epilog
	self.isFirstLocationLoad	:=	false;
	delete allCriteriaObj;
end;</source>
        <Parameter name="pYardAllocObj" type="CM_YardAllocation"/>
    </JadeMethod>
    <JadeMethod name="setupChildControls" id="bfdb0852-3484-4d11-89b1-e7c9a92f6db3">
        <updating/>
        <source>setupChildControls() updating, protected;
// --------------------------------------------------------------------------------
// Created:		28 February 2005 by cnwdad1
//
// Purpose:		Sets up the receiver's child controls.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	create self.myFolder transient;
	self.myFolder.width					:=	self.width;
	self.myFolder.height				:=	self.height;
	self.myFolder.borderStyle			:=	self.BorderStyle_3DRaised;
	self.myFolder.parent				:=	self;
	self.myFolder.parentAspect			:=	Control.ParentAspect_StretchBoth;
	self.myFolder.useSheetBackColors	:= true;
	self.form.addControl(self.myFolder);
	
	self.setupControlsLocations();
	self.setupControlsCriteria();
	self.setupControlsOptions();

	// must do this after all other controls setup
	self.myFolder.setDefaultSheetBackColors();
	self.myFolder.initSheetBackColors();		//set selected/unselected folders colours
	
	self.setTabOrders();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupControl" id="225429aa-afe0-4e63-ae20-5d31093629f2">
        <updating/>
        <source>setupControl() updating, protected;
// --------------------------------------------------------------------------------
// Created:		16 March 2005 by cnwdad1
//
// Purpose:		Sets up the receiver.  This method is invoked when the method to
//				set the receiver's reference to its Yard Allocation object is
//				called.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	proxyObj			: CM_YardAllocation;
	listPointer			: Integer;
	expiryType			: Integer;
	fillOption			: Integer;
	allowOthersOption	: Integer;
	noLocation			: Integer;
	
begin
	proxyObj	:=	self.myProxyYA;
	
	proxyObj.allYABlockGroupsIn.copy(self.allBlockGroupsIn);
	proxyObj.allYABlockGroupsOut.copy(self.allBlockGroupsOut);
	
	self.myTxtLocation.cnEcSet(null);
	
	// Here it is MO
	fillOption := proxyObj.fillOptionIn;
	if fillOption = 0 then
		fillOption := app.getMyTerminalDO_NOT_USE().getFillOption();   //SFW1030 04/08/2008
	endif;
	
	listPointer	:=	self.myCmbOptionIn.findStringExact(1, app.yaFillOptionToString(fillOption));

	self.myCmbOptionIn.cnEcSet(listPointer);
	
	fillOption := proxyObj.fillOptionOut;
	
	if fillOption = 0 then
		fillOption := app.getMyTerminalDO_NOT_USE().getFillOption;   //SFW1030 04/08/2008
	endif;
	
	listPointer	:=	self.myCmbOptionOut.findStringExact(1, app.yaFillOptionToString(fillOption));
	self.myCmbOptionOut.cnEcSet(listPointer);
	
	self.myTxtCode.cnEcSet(proxyObj.code);
	self.myTxtDescription.cnEcSet(proxyObj.description);
	self.myTxtRemarks.cnEcSet(proxyObj.remarks);
	
	expiryType	:=	proxyObj.expiryType;
	self.myOptNever.cnEcSet(expiryType = YAExpiryType_Never);
	self.myOptVoyageDepart.cnEcSet(expiryType = YAExpiryType_VoyageDepart);
	self.myOptWhenEmpty.cnEcSet(expiryType = YAExpiryType_WhenEmpty);
	self.myOptSpecifiedDate.cnEcSet(expiryType = YAExpiryType_SpecifiedDate);
	self.doExpiryDateOptClick(self.myOptSpecifiedDate.value);
	
	if proxyObj.expiryDate.isValid then
		self.myTxtExpiryDate.setDate(proxyObj.expiryDate);
	endif;
	
	self.myLblColorPicker.setColor(proxyObj.color);
	allowOthersOption	:=	proxyObj.allowOthersOption;
	
	if allowOthersOption = 0 then
		allowOthersOption	:=	YAOverlap_Always;
	endif;
	
	listPointer	:=	self.myCmbAllowOthers.findStringExact(1, app.yaOverlapFlagToString(allowOthersOption));
	self.myCmbAllowOthers.cnEcSet(listPointer);
	noLocation := proxyObj.noLocationOption;
	
	if noLocation = 0 then
		noLocation	:=	YANoLocation_Continue;
	endif;
	
	listPointer	:=	self.myCmbNoLocation.findStringExact(1, app.yaNoLocationFlagToString(noLocation));
	self.myCmbNoLocation.cnEcSet(listPointer);
	// CMS 1357
	listPointer	:=	self.myCmbOverstowRule.findObject(proxyObj.myYAOverstowRule);
	self.myCmbOverstowRule.cnEcSet(listPointer);
	
	self.myTxtPriorityAdj.cnEcSet(proxyObj.priorityAdjustment.String);
	self.myChkTestOverstowWeight.cnEcSet(proxyObj.isTestOverstowWeight);
	self.myChkIsDisabled.cnEcSet(proxyObj.isDisabled);
	
	self.populateLocationsListbox(true);
	self.yaRefreshCriteriaPriority(null);
	// Resets and loses set up.
	//	self.myCtrlCriteria.loadDetails(null);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupControlsCriteria" id="0a8bbbd9-5715-4fbd-9dc0-223497a12d24">
        <updating/>
        <source>setupControlsCriteria() updating, protected;
// --------------------------------------------------------------------------------
// Created:		02 March 2005 by cnwdad1
//
// Purpose:		Sets up the receiver's child controls for the Criteria tab.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	create self.myShtCriteria transient;
	self.myShtCriteria.caption			:=	"Criteria";
	self.myShtCriteria.tabStop			:=	true;
	self.myShtCriteria.parent			:=	self.myFolder;
	self.myShtCriteria.parentAspect		:=	Control.ParentAspect_StretchBoth;
	self.form.addControl(self.myShtCriteria);
	
	create self.myCtrlCriteria transient;
	self.myCtrlCriteria.transparent		:=	true;
	self.myCtrlCriteria.parent			:=	self.myShtCriteria;
	self.myCtrlCriteria.parentAspect	:=	Control.ParentAspect_None;
	self.myCtrlCriteria.setDisplayWindow(self);
	self.form.addControl(self.myCtrlCriteria);
	self.myCtrlCriteria.move(0, 0, 388, 173);
	
	create self.myLstCriteria transient;
	self.myLstCriteria.scrollHorizontal	:=	Control.ScrollBars_Both;
	self.myLstCriteria.show3D			:=	Control.Show3D_Use3D;
	self.myLstCriteria.integralHeight	:=	false;
	self.myLstCriteria.parent			:=	self.myShtCriteria;
	self.myLstCriteria.parentAspect		:=	Control.ParentAspect_None;
	//self.myLstCriteria.listIndex := CNEC_NULL_INDEX;
	self.myLstCriteria.setYAControl(self, false, true); 
	self.myLstCriteria.setCriteriaControl(self.myCtrlCriteria, false, false);
	self.form.addControl(self.myLstCriteria);
	self.myLstCriteria.move(5, 180, 383, 107);
	
	create self.myLblCode transient;
	self.myLblCode.caption				:=	"Code";
	self.myLblCode.alignment			:=	Label.Alignment_Left_Middle;
	self.myLblCode.transparent			:=	true;
	self.myLblCode.parent				:=	self.myShtCriteria;
	self.myLblCode.parentAspect			:=	Control.ParentAspect_None;
	self.form.addControl(self.myLblCode);
	self.myLblCode.move(5, (self.myLstCriteria.top + self.myLstCriteria.height + 5), 80, 21);
	
	create self.myTxtCode transient;
	self.myTxtCode.scrollHorizontal		:=	true;
	self.myTxtCode.maxLength			:=	50; // Max length  of 50 not 10
	self.myTxtCode.parent				:=	self.myShtCriteria;
	self.myTxtCode.parentAspect			:=	Control.ParentAspect_None;
	self.form.addControl(self.myTxtCode);
	self.myTxtCode.move(90, self.myLblCode.top, 298, 21);
	
	create self.myLblDescription transient;
	self.myLblDescription.caption		:=	"Description";
	self.myLblDescription.transparent	:=	true;
	self.myLblDescription.alignment		:=	Label.Alignment_Left_Middle;
	self.myLblDescription.parent		:=	self.myShtCriteria;
	self.myLblDescription.parentAspect	:=	Control.ParentAspect_None;
	self.form.addControl(self.myLblDescription);
	self.myLblDescription.move(5, (self.myLblCode.top + 25), 80, 21);
	
	create self.myTxtDescription transient;
	self.myTxtDescription.scrollHorizontal	:=	true;
	self.myTxtDescription.maxLength		:=	null; // PAR 10442 AKB2005JULY spec says desription is unlimited
	self.myTxtDescription.parent		:=	self.myShtCriteria;
	self.myTxtDescription.parentAspect	:=	Control.ParentAspect_None;
	self.form.addControl(self.myTxtDescription);
	self.myTxtDescription.move(90, self.myLblDescription.top, 298, 21);
	
	create self.myLblRemarks transient;
	self.myLblRemarks.caption			:=	"Remarks";
	self.myLblRemarks.transparent		:=	true;
	self.myLblRemarks.alignment			:=	Label.Alignment_Left_Middle;
	self.myLblRemarks.parent			:=	self.myShtCriteria;
	self.myLblRemarks.parentAspect		:=	Control.ParentAspect_None;
	self.form.addControl(self.myLblRemarks);
	self.myLblRemarks.move(5, (self.myLblDescription.top + 25), 80, 21);
	
	create self.myTxtRemarks transient;
	self.myTxtRemarks.scrollVertical	:=	true;
	self.myTxtRemarks.scrollBars		:=	TextBox.ScrollBar_Vertical;
	self.myTxtRemarks.parent			:=	self.myShtCriteria;
	self.myTxtRemarks.parentAspect		:=	Control.ParentAspect_None;
	self.form.addControl(self.myTxtRemarks);
	self.myTxtRemarks.move(90, self.myLblRemarks.top, 298, 63);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupControlsLocations" id="b4048c8c-f55b-4615-8e3c-9538e31d2b04">
        <updating/>
        <source>setupControlsLocations() updating, protected;
// --------------------------------------------------------------------------------
// Created:		02 March 2005 by cnwdad1
//
// Purpose:		Sets up the receiver's child controls for the Locations tab.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 05/05/2006	cnwdad1		CCMS #1010 - Make Locations list hierarchical.
// --------------------------------------------------------------------------------
begin
	create self.myShtLocations transient;
	self.myShtLocations.caption			:=	"Locations";
	self.myShtLocations.parent			:=	self.myFolder;
	self.myShtLocations.parentAspect	:=	Control.ParentAspect_StretchBoth;
	self.form.addControl(self.myShtLocations);
	
	create self.myLblLocation transient;
	self.myLblLocation.caption			:=	"Enter a Location";
	self.myLblLocation.transparent		:=	true;
	self.myLblLocation.parent			:=	self.myShtLocations;
	self.myLblLocation.parentAspect		:=	Control.ParentAspect_None;
	self.form.addControl(self.myLblLocation);
	self.myLblLocation.move(5, 10, 95, 21);
	
	create self.myTxtLocation transient;
	self.myTxtLocation.scrollHorizontal	:=	true;
	self.myTxtLocation.bubbleHelp		:=	"Enter a location as &lt;area&gt; &lt;row&gt; &lt;column&gt;, e.g. 'A 0210', then click 'Add'.";
	self.myTxtLocation.case				:=	TextBox.Case_Upper;
	self.myTxtLocation.parent			:=	self.myShtLocations;
	self.myTxtLocation.parentAspect		:=	Control.ParentAspect_None;
	self.form.addControl(self.myTxtLocation);
	self.myTxtLocation.move(100, 7, 298, 21);
	
	create self.myBtnLocAdd transient;
	self.myBtnLocAdd.caption			:=	"Add";
	self.myBtnLocAdd.parent				:=	self.myShtLocations;
	self.myBtnLocAdd.parentAspect		:=	Control.ParentAspect_None;
	self.myBtnLocAdd.setYAControl(self, true, false, false, false, false, false, false);
	self.form.addControl(self.myBtnLocAdd);
	self.myBtnLocAdd.move(215, 34, 90, 25);
	
	create self.myBtnLocDelete transient;
	self.myBtnLocDelete.caption			:=	"Delete";
	self.myBtnLocDelete.parent			:=	self.myShtLocations;
	self.myBtnLocDelete.parentAspect	:=	Control.ParentAspect_None;
	self.myBtnLocDelete.setYAControl(self, false, true, false, false, false, false, false);
	self.form.addControl(self.myBtnLocDelete);
	self.myBtnLocDelete.move((self.myBtnLocAdd.left + self.myBtnLocAdd.width + 3), myBtnLocAdd.top, 90, 25);
	
	create self.myLblLocSelected transient;
	self.myLblLocSelected.caption		:=	"Locations Selected";
	self.myLblLocSelected.transparent	:=	true;
	self.myLblLocSelected.wordWrap		:=	true;
	self.myLblLocSelected.parent		:=	self.myShtLocations;
	self.myLblLocSelected.parentAspect	:=	Control.ParentAspect_None;
	self.form.addControl(self.myLblLocSelected);
	self.myLblLocSelected.move(5, 72, 60, 45);
	
	create self.myBtnDODefault transient;
	self.myBtnDODefault.caption			:=	"Default";
	self.myBtnDODefault.parent			:=	self.myShtLocations;
	self.myBtnDODefault.parentAspect	:=	Control.ParentAspect_None;
	self.myBtnDODefault.setYAControl(self, false, false, false, false, false, true, false);
	self.form.addControl(self.myBtnDODefault);
	self.myBtnDODefault.move(5, 145, 80, 25);
	
	create self.myBtnDOSpecify transient;
	self.myBtnDOSpecify.caption			:=	"Specify";
	self.myBtnDOSpecify.parent			:=	self.myShtLocations;
	self.myBtnDOSpecify.parentAspect	:=	Control.ParentAspect_None;
	self.myBtnDOSpecify.setYAControl(self, false, false, false, false, false, false, true);
	self.form.addControl(self.myBtnDOSpecify);
	self.myBtnDOSpecify.move(	myBtnDODefault.left,
								(myBtnDODefault.top + myBtnDODefault.height + 3),
								myBtnDODefault.width,
								myBtnDODefault.height);
	
	create self.myLstLocations transient;
	self.myLstLocations.parent			:=	self.myShtLocations;
	self.myLstLocations.hasPictures		:=	true;
	self.myLstLocations.hasPlusMinus	:=	true;
	self.myLstLocations.hasTreeLines	:=	true;
	self.myLstLocations.multiSelect		:=	ListBox.MultiSelect_Extended;
	self.myLstLocations.scrollHorizontal	:=	ListBox.ScrollBars_Both;
	self.myLstLocations.parentAspect	:=	Control.ParentAspect_None;
	if self.isBlockGroupsUsed then
		self.myLstLocations.bubbleHelp		:=	"Right-click for Group maintenance";
	endif;
	self.myLstLocations.setYAControl(self, true, false);
	self.form.addControl(self.myLstLocations);
	self.myLstLocations.move(100, 72, 298, 200);
	
	create self.myLblSortFor transient;
	self.myLblSortFor.caption			:=	"Sort for";
	self.myLblSortFor.transparent		:=	true;
	self.myLblSortFor.alignment			:=	Label.Alignment_Left_Middle;
	self.myLblSortFor.parent			:=	self.myShtLocations;
	self.myLblSortFor.parentAspect		:=	Control.ParentAspect_None;
	self.form.addControl(self.myLblSortFor);
	self.myLblSortFor.move(5, 265, 60, 21);
	
	create self.myOptSortIn transient;
	self.myOptSortIn.caption			:=	"In";
	self.myOptSortIn.value				:=	true;
	self.myOptSortIn.parent				:=	self.myShtLocations;
	self.myOptSortIn.parentAspect		:=	Control.ParentAspect_None;
	self.myOptSortIn.setYAControl(self, true, false, false, false);
	self.form.addControl(self.myOptSortIn);
	self.myOptSortIn.move(5, 284, 40, 21);
	
	create self.myOptSortOut transient;
