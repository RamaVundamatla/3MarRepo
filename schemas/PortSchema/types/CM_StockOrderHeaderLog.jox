        <source>isConsigneeFromLines(set: Boolean; _value: Boolean io) mapping;
// ---------------------------------------------------------------------------
// Created:     23 July 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	_value := true;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="70b2e6b9-a54a-42f0-8b96-546d4c181348">
        <updating/>
        <source>setForCreate(_pxyHdr: CM_StockOrderHeader) updating;
//--------------------------------------------------------------
