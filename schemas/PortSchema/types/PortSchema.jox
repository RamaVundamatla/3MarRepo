    <JadeMethod name="timerEvent" id="ef0e822d-0ed1-47d2-8292-22365f854286">
        <updating/>
        <source>timerEvent(eventTag : Integer) updating;
//Fired every 60000ms, cleans up the RT queue. Only ever one of these working.
//NOTE: This is a SERVER appliation, its started whenever the server starts up.
//It is therefore running on its own thread, chugging away at the database.
vars
	numCleaned	:	Integer;
	recurseLvl	:	Integer;
	rt	:	CM_RadioTelemetry;
	now :	TimeStamp;
begin

	return;
	if self.getMyTerminalDO_NOT_USE() = null then
		return;
	endif;
	rt := self.getMyTerminalDO_NOT_USE().radioTelemetry;
	if rt = null then
		return;
	endif;
	if rt.masterQueue = null then
		return;
	endif;
	//----------------
	//Arm an exception handler, in case of locks etc!
	//----------------
	on NormalException do cleanupException(exception);
	beginTransaction;
	rt.masterQueue.cleanup(numCleaned, recurseLvl, app.myPassport);
	//----------------
	//Set the process's userInfo to the last cleanup time!
	//----------------
	now := app.actualTimeServer();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
	process.userInfo := "Last Cleaned up " &amp; now.display;
	commitTransaction;
end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
