    <JadeMethod name="delete" id="ad6c4edd-05a6-49f9-b5fd-2014dc577094">
        <updating/>
        <source>delete() updating;
/*

Date				Who		Reason
11 December 2014	cnwer1	Initial creation PAR
06 April 2023		jlizm1	TFS 57098 EUP Seal numbers on trucks

*/

vars
	any	: Any;
	allSealCheckDetails : CM_SealCheckDetailSet;
	
begin

	self.resetAuditsDuringDelete();	//01 Jan 2021	NDL	TFS 50152
	
	if self.type = EVT_TruckSealCheck then
		any := self.getExtraData( self.AllSealCheckDetails );	
		if any &lt;&gt; null then
			if any.isKindOf( CM_SealCheckDetailSet ) then
				allSealCheckDetails := any.CM_SealCheckDetailSet;
				if not allSealCheckDetails.isEmpty then
					allSealCheckDetails.purge();
				endif;
				delete allSealCheckDetails;
			endif;	
		endif;
	endif;
	
	if not self.isTransient then
		if self.myVisit &lt;&gt; null then
			self.myVisit.causeEvent(EventTransaction_Delete_Event,false,self);	
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getDebtor" id="17ea3a35-c275-43e8-bd8e-55029a3c8d59">
        <source>getDebtor(): CM_Debtor;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/08/2017  jlgndl1	Initial creation	TFS 5646
08/06/2020 	cnwma1  ChangeRequest 49400: ASPA - Invoice Enhancements for Barges
*/

vars
	carrier : CM_Carrier;
	debtor  : CM_Debtor;
begin

	if self.myDebtor &lt;&gt; null then                     //03/06/2020 cnwma1 TFS #49400
		debtor := self.myDebtor;
	else
		if self.myVisit &lt;&gt; null then
			carrier := self.myVisit.getCarrier();
		endif;
		
		if carrier &lt;&gt; null then
			debtor := carrier.myDebtor;
		endif;
	endif;
	
	if debtor &lt;&gt; null then
		return debtor;
	endif;
	
	return inheritMethod();
epilog

end;</source>
        <ReturnType type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="getDescription" id="200df30c-6dd1-4f49-be16-fc5d9e859802">
        <source>getDescription(): String;
/*
Purpose: TFS 2699			
Date				Who		Reason
22 September 2016	cnwab1	Initial creation
06 April 2023		jlizm1	TFS 57098 EUP Seal numbers on trucks
*/

vars

begin
	if self.type = EVT_TruckSealCheck then
		return self.getTruckSealCheckDetailsString();
		
	elseif self.type = EVT_TruckSealAdd or
		self.type = EVT_TruckSealDelete then
		return self.getSealDetails();
	
	elseif self.myVisit &lt;&gt; null and
	   self.myVisit.vehicle &lt;&gt; null  and self.myEventType &lt;&gt; null then
		return self.myEventType.description &amp; " (" &amp; self.myVisit.vehicle.regNumber &amp; ")";
		
	else
		return inheritMethod();
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayID" id="c7b20cbc-a88a-408b-936f-c5ca0f48374c">
        <source>getDisplayID(): String;
//
//30 Apr 2015	cnwrs1	Par35784 - increased exclusion reason logging to include non excluded
//
vars

begin
	if self.myVisit &lt;&gt; null and
	   self.myVisit.vehicle &lt;&gt; null then
		return self.myEventType.name &amp; ' ' &amp; self.myVisit.vehicle.regNumber;
	else
		return inheritMethod();
	endif;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
