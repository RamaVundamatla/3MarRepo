    <JadeMethod name="translateForm" id="b2bf0e52-fdc7-44d1-9d6c-60cf56d82719">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 11 March 2019 19:52:37.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0023451, locale);
	chkPrintAllDecks.translateCaption(Xlat_0023453, locale);
	chkPrintColour.translateCaption(Xlat_0023455, locale);
	chkPrintLabels.translateCaption(Xlat_0023457, locale);
	chkPrintPreview.translateCaption(Xlat_0023456, locale);
	grpReport.translateCaption(Xlat_0023452, locale);
	lblPrintDeck.translateCaption(Xlat_0023454, locale);
end;</source>
    </JadeMethod>
</GUIClass>
