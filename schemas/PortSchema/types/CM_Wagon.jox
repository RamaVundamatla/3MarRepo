    <JadeMethod name="getTotalWeight" id="55afcfff-0133-47d7-a92a-7053db0d54cb">
        <source>getTotalWeight( _control : CMIF_MoveController ):Decimal;

/*

Purpose:			
	if controller is null, returns current weight, if controller is populated
	will return weight current weight plus that of the cargo being moved to it...
Parameters:			

Return Value:		


Date		Who		Reason
15 July 2009	cnwndl1	Initial creation

*/

vars
	returnWeight : Decimal [12,2];
	tiBeingMoved : CM_TrackedItem;
	tiWeight : Decimal [12,2];
begin

	returnWeight :=  self.getLoadWeight() + self.getWagonTareWeight();	//07 Oct 2009	NDL Par 20908
	
	if _control &lt;&gt; null then
		tiBeingMoved := _control.myTrackedItem;	// the cargo we are moving 
		if tiBeingMoved &lt;&gt; null then
			tiWeight := tiBeingMoved.totalWeight;
			returnWeight := returnWeight + tiWeight;
		endif;
	endif;
	
	return returnWeight;
	
epilog

end;</source>
        <Parameter name="_control" type="CMIF_MoveController"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getTotalWeightWidthHeight" id="4df69783-c7ec-4efb-a372-80f49e420453">
        <source>getTotalWeightWidthHeight(maxWeight : Decimal output; maxWidth : Decimal output; maxHeight : Decimal output) : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 March 2010	cnwas3	par 23112

*/

vars

	ti : CM_TrackedItem;
	tiArray : CM_TIArray;
	iterTi : Iterator;
	tempCont : CM_LocationsController;
	locCont : CM_WagonController;
	
	
	tiWidth : Decimal [12,2];	
	tiHeight : Decimal [12,2];
	tiWeight : Decimal [12,4];
	deckHeight : Decimal [12,2];	
	
begin

	create tiArray transient;
	
	self.getTIDataForClearanceCheck(tiArray);
	
	if myWagonClass &lt;&gt; null then
		deckHeight := myWagonClass.deckHeight;
	elseif myWagonMaster &lt;&gt; null then
		if myWagonMaster.myWagonClass &lt;&gt; null then
			deckHeight := myWagonMaster.myWagonClass.deckHeight;
		endif;
	endif;
	
	
	// check all the positions and get the widest and highest values
	iterTi := tiArray.createIterator;
	while iterTi.next( ti ) do

		
		tempCont := ti.getPrimaryLocation(REAL_MODE).CM_LocationsController;
		//if tempCont = null or not tempCont.isKindOf(CM_WagonController) then
		if tempCont = null or not tempCont.isWagon then//27 May 2013	NDL	Part of Boxcar conversion
			tempCont := ti.getPrimaryLocation(PLANNING_MODE).CM_LocationsController;
		//	if tempCont = null or not tempCont.isKindOf(CM_WagonController) then
			if tempCont = null or not tempCont.isWagon then//27 May 2013	NDL	Part of Boxcar conversion
				tempCont := ti.getPrimaryLocation(QUEUE_MODE).CM_LocationsController;
				//if tempCont = null or not tempCont.isKindOf(CM_WagonController) then
				if tempCont = null or not tempCont.isWagon then//27 May 2013	NDL	Part of Boxcar conversion
					continue;
				endif;
			endif;
		endif;
		locCont := tempCont.CM_WagonController;
		
	
		
		tiHeight := locCont.getTotalHeightRawForTIs(tiArray); 
		tiWidth := locCont.getTotalWidthRawForTIs(tiArray);	
		
		
		tiHeight := tiHeight + deckHeight;
		
		if maxHeight &lt; tiHeight then
			maxHeight := tiHeight;
		endif;
		
		if maxWidth &lt; tiWidth then
			maxWidth := tiWidth;
		endif;		

	endwhile;
	
	tiWeight := self.getTIsWeight(tiArray) + self.getWagonTareWeight();
	if maxWeight &lt; tiWeight then
		maxWeight := tiWeight;
	endif;
	return (not tiArray.isEmpty);
epilog

	delete iterTi;
	
end;</source>
        <Parameter name="maxWeight" type="Decimal" usage="output"/>
        <Parameter name="maxWidth" type="Decimal" usage="output"/>
