    <JadeMethod name="validateSplitMergeB" id="4127572a-3325-4eda-8c0d-56904aa8e063">
        <source>validateSplitMergeB(_cargo, _splitCargo : CM_TrackedItem);
// tPayBreakBulkSplitMerge validate lines and payments after the second split
vars
	count	: Integer;
	cargo,
	splitCargo	: CM_TrackedItem;
	payment		: CM_CashPayment;
	line		: CM_InvoiceLine;
begin
	cargo := _cargo;
	splitCargo := _splitCargo;

	// check the original and split invoice lines and payments
	count := 0;
	foreach payment in cargo.allCashPayments do
		if payment.myCashPaymentForInvoice &lt;&gt; null then // TFS 7357 tax payment ignore
			continue;
		endif;
		count := count + 1;
		if count = 1 then
			self.assertEqualMsg(payment.cashValue, 2000.Decimal, "First original cargo payment after second split");
		elseif count = 2 then
			self.assertEqualMsg(payment.cashValue, 5000.Decimal, "Second original cargo payment after second split");
		elseif count = 3 then
			self.assertEqualMsg(payment.cashValue, 2000.Decimal, "Third original cargo payment after second split");
			self.assertEqualMsg(payment.myProformaDetail.quantity, 20000.Real, "Third original cargo proforma quantity after second split");
			self.assertEqualMsg(payment.myProformaDetail.lineTotal, 2000.Decimal, "Third original cargo proforma value after second split");
		endif;
	endforeach;
	self.assertEqualMsg(count, 3, "Original cargo payments after second split");
	count := 0;
	foreach line in cargo.invoiceLines do
		count := count + 1;
		if count = 1 then
			self.assertEqualMsg(line.lineTotal, 2000.Decimal, "First original invoice line after second split");
		elseif count = 2 then
			self.assertEqualMsg(line.lineTotal, 5000.Decimal, "Second original invoice line after second split");
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, "Original invoice lines after second split");

	count := 0;
	foreach payment in splitCargo.allCashPayments  do
		if payment.myCashPaymentForInvoice &lt;&gt; null then // TFS 7357 tax payment ignore
			continue;
		endif;
		count := count + 1;
		if count = 1 then
			//self.assertEqualMsg(payment.cashValue, 2000.Decimal, "First split cargo payment after second split");
			self.assertEqualMsg(payment.cashValue, 3000.Decimal, "First split cargo payment after second split");
		elseif count = 2 then
			self.assertEqualMsg(payment.cashValue, 2000.Decimal, "Second split cargo payment after second split");
			self.assertEqualMsg(payment.myProformaDetail.quantity, 20000.Real, "Second split cargo proforma quantity after second split");
			self.assertEqualMsg(payment.myProformaDetail.lineTotal, 2000.Decimal, "Second split cargo proforma value after second split");
		elseif count = 3 then
			self.assertEqualMsg(payment.cashValue, 1000.Decimal, "Third split cargo payment after second split");
		elseif count = 4 then
			self.assertEqualMsg(payment.cashValue, 1000.Decimal, "Fourth split cargo payment after second split");
			self.assertEqualMsg(payment.myProformaDetail.quantity, 10000.Real, "Fourth split cargo proforma quantity after second split");
			self.assertEqualMsg(payment.myProformaDetail.lineTotal, 1000.Decimal, "Fourth split cargo proforma value after second split");
		endif;
	endforeach;
	//self.assertEqualMsg(count, 4, "Split cargo payments after second split");
		self.assertEqualMsg(count, 3, "Split cargo payments after second split");
	count := 0;
	foreach line in splitCargo.invoiceLines do
		count := count + 1;
		if count = 1 then
			//self.assertEqualMsg(line.lineTotal, 2000.Decimal, "First Split invoice line after second split");
				self.assertEqualMsg(line.lineTotal, 3000.Decimal, "First Split invoice line after second split");
		elseif count = 2 then
			self.assertEqualMsg(line.lineTotal, 1000.Decimal, "First Split invoice line after second split");
		endif;
	endforeach;
	//self.assertEqualMsg(count, 2, "Split invoice lines after second split");
	self.assertEqualMsg(count, 1, "Split invoice lines after second split");

end;
</source>
