    <JadeMethod name="doOK" id="4182a52d-16a7-45a6-bc08-e6c572a733e5">
        <updating/>
        <source>doOK() updating;
// ---------------------------------------------------------------------------
// Created:     25 May 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	vehicle	:CM_Vehicle;
	lc		:CM_YardController;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin
	vehicle		:= self.myVehicle;
	
	if vehicle = null then
		return;
	endif;

	lc := cmbNewLocation.listObject.CM_YardController;
	
	if lc = null then
		return;
	endif;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxMoveVehicle(vehicle, lc, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return;
		
	endwhile;
	
	inheritMethod();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getAllDirectDeliveryAreas" id="a15a2653-044d-4963-9b0e-67c3cedcbd09">
        <source>getAllDirectDeliveryAreas() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 April 2013	cnwndl1	Initial creation	Par 31102

*/

vars

	iter : Iterator;
	area : CM_TerminalArea;
	icArea : CM_InterchangeArea;
	set : CM_TerminalAreaSet;
	lc : Object;

begin

	if self.myVehicle = null then
		return;
	endif;
	
	if not self.myVehicle.hasDirectDeliveryTask then
		return;
	endif;
	
	create set transient;
	
	iter := self.myTerminal.allTerminalAreasByTypeId.createIterator;
	self.myTerminal.allTerminalAreasByTypeId.startKeyGeq (TA_TYPE_WORKPOINT_INTERCHANGE, null, iter);
	
	while iter.next (area) do
		if area.type &lt;&gt; TA_TYPE_WORKPOINT_INTERCHANGE then
			break;
		endif;
		set.add(area);
	endwhile;
	
	self.myTerminal.allTerminalAreasByTypeId.startKeyGeq (TA_TYPE_CRANE_TRANS, null, iter);
	
	while iter.next (area) do
		if area.type &lt;&gt; TA_TYPE_CRANE_TRANS then
			break;
		endif;
		set.add(area);
	endwhile;
	
	if set.isEmpty then
		return;
	endif;
	
	delete iter;
	iter := set.createIterator; 
	while iter.next (area) do
		lc := null;
		if area.isKindOf( CM_WorkPointInterchangeArea ) then
			lc := area.CM_WorkPointInterchangeArea.getLocationforVehicleMove;	
		elseif area.isKindOf( CM_CraneTransferArea ) then
			lc := area.CM_CraneTransferArea.getLocationforVehicleMove;
		endif;
		if lc &lt;&gt; null then
			self.cmbNewLocation.addItemObject(area.id, lc);
		endif;
	endwhile;
		
epilog

	delete iter;
	delete set;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getAllGateAreas" id="f9558e22-bae3-46a1-9f97-e6a1dbd8bf3a">
        <source>getAllGateAreas(_coll : CM_ObjectSet input) protected;
// actually input gates, for 29712
vars
	gate			:CM_Gate;
	area			:Object;
	coll			:CM_ObjectSet;
	invalidObject	:Boolean;
begin
	on Exception do app.handleDeletedObject (exception, gate, invalidObject);
	
	create coll transient;
	foreach gate in self.myTerminal.allGates do
		gate.CM_Gate.getPGateAreas_IN (coll); 
		
		if invalidObject then
			invalidObject := false;
			continue;
		endif;
		
		foreach area in coll do
			if area.CM_GateArea.laneCount = 0 then
				continue;
			endif;
			_coll.addNoDuplicates (area, false);
		endforeach;
		
		coll.clear;
	endforeach;
epilog
	delete coll;
end;</source>
        <access>protected</access>
        <Parameter name="_coll" type="CM_ObjectSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllGateLocations" id="8dac94f8-fd46-4b05-b85c-4364636c65c8">
        <source>getAllGateLocations( _includeOutLanes : Boolean ) protected;
// 29712
vars
	combo		:CMUI_ComboBox;
	coll		:CM_ObjectSet;
	obj			:Object;
	gateArea	:CM_GateArea;
	lc			:CM_LocationsController;
begin
	combo := self.cmbNewLocation;
	create coll transient;

	self.getAllGateAreas (coll);
	
	foreach obj in coll do
		gateArea := obj.CM_GateArea;
		
		if gateArea.laneCount = 0 then
			continue;
		endif;
		
		foreach lc in gateArea.allLocationsControllers do
			if lc.isKindOf(CM_BlockController) then
				combo.addItemObject(app.getErrorString(PRE_GATE) &amp; " " &amp; gateArea.id, lc);
				continue;
			endif;
			if not lc.isLaneController then
				continue;
			endif;
			// must be available, empty and input
			if lc.CM_LaneController.isUnavailable or
			   lc.CM_LaneController.hasVehicles() or
				//lc.CM_LaneController.vehicleDirection &lt;&gt; CM_LaneController.Is_In_Lane then
				( lc.CM_LaneController.vehicleDirection &lt;&gt; CM_LaneController.Is_In_Lane and not _includeOutLanes ) then	//06 Aug 2014	NDL	Par 34675
				continue;
			endif;
	
			combo.addItemObject(app.getErrorString(Gate) &amp; " " &amp; lc.CM_LocationsController.getFullId, lc);
		endforeach;
	endforeach;

epilog
	delete coll;
end;
</source>
        <access>protected</access>
        <Parameter name="_includeOutLanes" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadNewLocationCombo" id="b3ac6cf9-6140-49fc-92ed-efe9d9ba0e7d">
        <source>loadNewLocationCombo()protected;
// ---------------------------------------------------------------------------
// Created:     25 May 2010 by cnwcs5
// Purpose:     Load an entry for every interchange area/lane combination
//				for the terminal
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 24/06/2010	cnwcs5		par 24292 - don't include interchange areas that wont allow vehicles
// ---------------------------------------------------------------------------
vars
	coll		:MemberKeyDictionary;
	type		:CM_TerminalAreaType;
	iter		:Iterator;
	area		:CM_InterchangeArea;
	combo		:CMUI_ComboBox;
	terminal	:CM_Terminal;
	laneColl	:CM_ObjectArray;
	lc			:Object;
	includeOutwardLanes : Boolean;

begin
	// first the yard interchange areas
	combo		:= self.cmbNewLocation;
	terminal	:= self.myTerminal;
	type		:= app.myRoot.allTerminalAreaTypes[TA_TYPE_YARD_INTERCHANGE];
	coll		:= type.allTerminalAreasByTerminal;
	iter		:= coll.createIterator;
	
	create laneColl transient;
	
	coll.startKeyGeq (terminal, null, iter);
	
	while iter.next (area) do
		if area.myTerminal &lt;&gt; terminal then
			break;
		endif;
		
		if not area.isOKForVehicles then	// 24/06/2010 cnwcs5 
			continue;						// 24/06/2010 cnwcs5 
		endif;								// 24/06/2010 cnwcs5 
		
		if area.laneCount = 0 then
			combo.addItemObject(area.id, area.getDefaultLane);
		else
			laneColl.clear;
			
			area.getAllLaneControllers (laneColl);
			
			foreach lc in laneColl do
				combo.addItemObject(lc.CM_LocationsController.getFullId, lc);
			endforeach;
		endif;
	endwhile;
	
	//06 Aug 2014	NDL	Par 34675
	if self.myVehicle &lt;&gt; null then
		includeOutwardLanes := self.myVehicle.allRoadJobs.isEmpty or self.myVehicle.allRoadJobs.first.isCompleteForExit();
	endif;
	
	// 29712 add input gate lanes
	self.getAllGateLocations( includeOutwardLanes );
	
	//add direct delivery areas if appropriate
	self.getAllDirectDeliveryAreas();
	
epilog
	delete iter;
	delete laneColl;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="ed9ecf2c-19e8-47ea-b417-d307343c693c">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     25 May 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	vehicle	: CM_Vehicle;
	lc		: CM_LocationsController;
begin
	inheritMethod();
	
	vehicle					:= self.myVehicle;
	lc						:= vehicle.myPrimaryActualLocation;
	self.txtVehicle.text	:= vehicle.getDisplayDetails (true);
	
	if lc &lt;&gt; null then
		self.txtCurrentLocn.text	:= lc.getFullId;
	endif;
	
	self.loadNewLocationCombo;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="1dfdf225-d22f-424e-b150-7f3a64448d15">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0015096, locale);
	lblCurrentLocn.translateCaption(Xlat_0015097, locale);
	lblNewLocn.translateCaption(Xlat_0015098, locale);
	lblVehicle.translateCaption(Xlat_0015099, locale);
end;</source>
    </JadeMethod>
</GUIClass>
