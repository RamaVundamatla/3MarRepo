    <JadeMethod name="tblData_contextMenu" id="06fcad1e-a0ba-42fa-86b8-d3a1f55ce9d3">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2025	navlw1	JIRA-34824 MTN | Quick Cargo Review UI Refactor

*/

vars 
   actualXPos : Real; 
   actualYPos : Real; 

begin 

    actualXPos := x; 
    actualYPos := y;
	
    self.cnEcGetRelativePosition(table, actualXPos, actualYPos); 
    self.mnuColumnOrganiser.userObject := table; 
    self.popupMenu( self.mnuContext, 
                    actualXPos.Integer, 
                    actualYPos.Integer); 

    return true; 
end; </source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
