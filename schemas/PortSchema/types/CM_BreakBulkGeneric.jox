    <JadeMethod name="validateFieldValueLength" id="9e51377a-a910-4d0d-ad0c-23f8d5f9be60">
        <source>validateFieldValueLength(_fieldName: String; _fieldValue: String; _errLinkObj: Object): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 January 2020	jlgndl1	Initial creation	TFS 48250

*/

vars

	upperFieldName	: String;
	fieldLength		: Integer;

begin

	if _fieldValue.trimBlanks() = null then
		return true;
	endif;
	
	upperFieldName	:=	_fieldName.toUpper();

	if upperFieldName = CM_EDICargoFieldUpdateTI.F_HeatTreated then
		return true;	// This is a value which is converted to an boolean.
		
	elseif upperFieldName = CM_EDICargoFieldUpdateTI.F_PalletType then
		fieldLength	:=	CM_PalletType::code.getLengthForString();
		
	elseif upperFieldName = CM_EDICargoFieldUpdateTI.F_StoreOnPallet then
		return true;	// This is a value which is converted to an boolean.
		
	else
	
		return inheritMethod(_fieldName, _fieldValue, _errLinkObj);
	
	endif;
	
	if fieldLength &lt; _fieldValue.length() then
		app.raiseCMException2( Field_Value_Too_Long, _fieldName, fieldLength.asStringJMT(), _fieldName, _errLinkObj );
		return false;
	endif;
	
	return true;
	

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_fieldName" type="String"/>
        <Parameter name="_fieldValue" type="String"/>
        <Parameter name="_errLinkObj" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateReceiptRelease" id="02d25819-6723-454c-a61c-7ef9476517e4">
        <updating/>
        <source>validateReceiptRelease(pControl: CMIF_TIUpdateController; _passport: CM_Passport input) updating, protected;
//----------------------------------------------------------------
//	Created:	21 April 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	inheritMethod(pControl, _passport);
	if pControl.mode = TI_UPDMODE_RECEIPT
	or pControl.mode = TI_UPDMODE_BOOKINGREF then
		if self.requiresSubCargo and self.myProduct = null then
		//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Product), ETRow_MyProduct, pControl.myUserObject);
			app.raiseCMException1(Input_required_field_Required, app.getErrorString(Product), ETRow_MyProduct, pControl.myUserObject); // cnwdb2	PAR 35364
			return;
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pControl" type="CMIF_TIUpdateController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateWeight" id="6485ad06-5be5-4535-b3a9-c342b486ed00">
        <updating/>
        <source>validateWeight(pControl: CMIF_TIUpdateController; _passport: CM_Passport input) updating, protected;

// Created by cnwdvb1 on 30 May 2006
//12/04/2023	navkc1	CR 56431 Task 56438: UI - Cargo Enquiry
//29 Apr 2024   navma1	Bug 63868: MTN - 1081 from performance test QA-PerformanceTest-Dumps_20240424
vars
	product : CM_Product;
begin
	if pControl.mode = TI_UPDMODE_RECEIPT or
	   pControl.mode = TI_UPDMODE_BAYPLAN or
	   pControl.mode = TI_UPDMODE_BOOKINGREF then

		if self.totalWeight &lt;&gt; NULL_WEIGHT then					//+cnwml2 MSL CCMS 1017
			self.validateMaxWeight(pControl);					//#27158 11/03/2011. Extra method organized to have weight validation coded in one place.
			self.validateCombindTareCargoWeight();				// + 18/03/2010 cnwmh5 #22546
			
		else
			if self.totalWeight = NULL_WEIGHT and pControl.mode &lt;&gt; TI_UPDMODE_BOOKINGREF then
				// non-machinery items must have a weight
				product := self.myProduct;
				if product &lt;&gt; null and product.myCargoType.allAttributesOnProduct.includes(ETRow_MyWeight) then			//30.04.2024 navma1 #63868
					//12/04/2023	navkc1	CR 56431 Task 56438
					if self.isPersistentTiWeightZero() and self.isZeroedByDiscrTrans()  then
						// Good to proceed;
					else
						app.raiseCMException(Total_weight_should_not_zero, 'weight', pControl.myUserObject); 			// cnwdb2	PAR 35364
					endif;
				endif;
			endif;
		endif;
		
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pControl" type="CMIF_TIUpdateController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="zGetDisplayProductDetails" id="0426db43-9c8a-46fc-89ce-50c78503e780">
        <source>zGetDisplayProductDetails(_attrName : String):String protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 Oct 2023	navma1 ChangeRequest 60920: EUP | Cargo Enquiry Performance - Work Packet 1

*/

vars
	prod		: CM_Product;
	cargoType   : CM_CargoType;
	invalid		: Boolean;
	str			: String;
begin
	prod       := self.myProduct;
	cargoType  := self.myCargoType;
	
	if prod = null and cargoType &lt;&gt; null then
		prod := cargoType.mySystemProductType;
	endif;
	if prod &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, prod, invalid);
		invalid := false;
		str := prod.getTIDisplayValueForAttribute(self, _attrName);
	
		if not invalid then
			return str;
		endif;
	endif;
	
	//+cnwml2 PAR 23851
	if _attrName = ETRow_MyLength then
		return self.length.asStringMeasurementJMT();
	elseif _attrName = ETRow_MyWidth then
		return self.width.asStringMeasurementJMT();
	elseif _attrName = ETRow_MyHeight then
		return self.height.asStringMeasurementJMT();
	endif;
	return null;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_attrName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="zSetPxyPalletDetailsTI" id="c216838f-f14b-46db-bc39-cddfe01836a8">
        <updating/>
        <source>zSetPxyPalletDetailsTI(realTi: CM_BreakBulkGeneric) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 April 2017	cnwndl1	Initial creation	TFS 3424

*/

vars

	pxyPalletDetailsTI : CM_PalletDetailsTI;

begin

	inheritMethod(realTi);
	
	if realTi.myPalletDetailsTI &lt;&gt; null then
		pxyPalletDetailsTI := realTi.myPalletDetailsTI.pxyCreateUpdateProxy();
		self.myPalletDetailsTI := pxyPalletDetailsTI;
	endif;

epilog

end;</source>
        <Parameter name="realTi" type="CM_BreakBulkGeneric"/>
    </JadeMethod>
</Class>
