        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnDocActions_click" id="4cfa9504-6553-4f9f-a19c-db36e491d299">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnDocActions_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 September 2016	cnwndl1	Initial creation

*/

vars

	reserveDetail : CM_ReserveDetail;
	resDetailArray : CM_ReserveDetailArray;

begin

	if self.myBulkRelease.isRoadType and self.myBulkRelease.allReserveDetails.size = 1 then	
		reserveDetail := self.myBulkRelease.allReserveDetails.first;
	else
		reserveDetail := self.cmbRelItems.listObject.CM_ReserveDetail;
	endif;

	create resDetailArray transient;
	resDetailArray.add( reserveDetail ); // we will reset the form on return from this one
	
	//then add the rest
	foreach reserveDetail in self.myBulkRelease.allReserveDetails do
		resDetailArray.addExclusive( reserveDetail );
	endforeach;
	//27 Jan 2017	NDL	TFS 3157
	if not self.myBulkRelease.allReservePackingChildren.isEmpty then
		foreach reserveDetail in self.myBulkRelease.allReservePackingChildren do
			resDetailArray.addExclusive( reserveDetail );
		endforeach;
	endif;
	
	self.myMobileGenericAgent.setAllReserveDetails( resDetailArray );
	self.myMobileGenericAgent.setStringField1( self.fldCargo.topSheet.name );
	self.myMobileGenericAgent.setMyNextTiToAction( null );
	self.gotoForm( MOB_HHDocumentActions, false );

epilog

	delete resDetailArray;

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnSelectedTemp_click" id="4da09aaf-5a9f-4080-bd09-0f0f0c1bfdb7">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnSelectedTemp_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 April 2016	cnwndl1	Initial creation	TFS 1667

*/

vars

	unSelect : Boolean;
	opt1Str : String;
	opt2Str : String;
	opt3Str : String;
	returnValue : Integer;

begin

	if self.myTargetLocation = null then
		self.clickSelectedButton( btn.userObject, true, false );
	
	else
		opt1Str := app.getErrorString( Stage_this_one );
		opt2Str := app.getErrorString( Back_scanned_wrong );
		opt3Str := app.getErrorString( Neither_above_cancel );
		returnValue := self.optBox(opt1Str, opt2Str, opt3Str, null, 3, app.getErrorString(Select_option) );
		if returnValue = 1 then
			unSelect := false;
		elseif returnValue = 2 then
			unSelect := true;
		else
			return;
		endif;
	
		self.clickSelectedButton( btn.userObject, unSelect, false );
	
	endif;

epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
