<CollClass name="ObjectSet">
    <JadeMethod name="getMembersAsOidString" id="ce32885c-921a-482a-9d7d-ecce4298fa5c">
        <source>getMembersAsOidString() : String;
// ---------------------------------------------------------------------------
// Created:     07 April 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	obj	: Object;
	s	: String;
begin

	foreach obj in self do
		if s = null then
			s := obj.getOidString();
		else
			s := s &amp; ',' &amp; obj.getOidString();
		endif;
	endforeach;
	
	return s;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
