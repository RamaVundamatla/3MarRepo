    <JadeMethod name="qryVehicleVisit" id="52758a1f-d440-467a-81df-5e3179373af9">
        <updating/>
        <source>qryVehicleVisit(_filter : CMQF_FilterReports input; _passport : CM_Passport) : Integer updating;

vars
	numSelected 	: Integer;
	jrwTrans		: CM_JRWVehicleVisit;
	filter			: CMQF_VehicleReport;
	d : TimeStamp;
begin
	on CM_BreakOutException do self.xHandlerBreakOut(exception);
	
	filter := _filter.CMQF_VehicleReport;
	jrwTrans := self.createJRWTransient(CM_JRWVehicleVisit).CM_JRWVehicleVisit;
	
	if filter.dateFrom = null then
		jrwTrans.dateFrom := Any_String;
	else
		jrwTrans.dateFrom := filter.dateFrom.asStringJMT();
	endif;
	
	if filter.dateTo = null then
		jrwTrans.dateTo := Any_String;
	else
		jrwTrans.dateTo := filter.dateTo.asStringJMT();
	endif;
	
	jrwTrans.setAllTerminals(filter.allTerminals);
	
	filter.filterObjects(jrwTrans.allVehicleVisitRecords, _passport);
	
	numSelected := jrwTrans.allVehicleVisitRecords.size;
epilog
	return numSelected;
end;
</source>
        <Parameter name="_filter" type="CMQF_FilterReports" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="qryVesselOperationsReport" id="fe9f2eb4-a07a-4795-94c7-1687dd15f7df">
        <updating/>
        <source>qryVesselOperationsReport(_filter : CMQF_VesselOperationsReport input; _passport : CM_Passport) : Integer updating;
// ---------------------------------------------------------------------------
// Created:     06 August 2008 by concms1
//
// Purpose:     Query method for vessel operations reports		 
// ----------   ----------  --------------------------------------------------
vars
	numSelected	: Integer;
	jrwTrans	: CM_JRWVoyageSummary;
begin
	on CM_BreakOutException do self.xHandlerBreakOut(exception);
	
	jrwTrans := self.createJRWTransient(CM_JRWVoyageSummary).CM_JRWVoyageSummary;
	
	jrwTrans.allVoyageSummaryObjects.purge(); // PAR 25714
	
	_filter.filterObjects(jrwTrans.allVoyageSummaryObjects, _passport);
	
	jrwTrans.setAllTerminals(_filter.allTerminals);
	jrwTrans.myVoyage 			:= _filter.getMyVoyage;
	jrwTrans.myOperator 		:= _filter.myOperator;
	jrwTrans.orderedByHeading1 	:= _filter.orderKey1;
	jrwTrans.orderedByHeading2 	:= _filter.orderKey2;	
	jrwTrans.orderedByOption 	:= _filter.orderKey1;
	jrwTrans.modeDescription 	:= _filter.modeDescr;
	jrwTrans.planningStateDescr := _filter.planningStateDescr;
	
	numSelected := jrwTrans.allVoyageSummaryObjects.size; // PAR 25714
epilog
	return numSelected;
end;</source>
        <Parameter name="_filter" type="CMQF_VesselOperationsReport" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="qryVesselOperationsSummary" id="340c8fc4-2b0f-4de7-a84b-b06cc7eadd05">
        <updating/>
        <source>qryVesselOperationsSummary(_filter : CMQF_VesselOperationsSummary input; _passport : CM_Passport) : Integer updating;
// ---------------------------------------------------------------------------
// Created:     06 August 2008 by concms1
//
// Purpose:     Query method for vessel operations reports		 
// ----------   ----------  --------------------------------------------------

// 27/05/2009	concms1	Par 19768 - new parameters for Vessel Operations Summary
vars
	numSelected 	: Integer;
	jrwTrans		: CM_JRWVoyages;
	filter			: CMQF_VesselOperationsSummary;
begin

	on CM_BreakOutException do self.xHandlerBreakOut(exception);
	
	
	filter := _filter;
	
	jrwTrans := self.createJRWTransient(CM_JRWVoyages).CM_JRWVoyages;

	jrwTrans.setAllTerminals(filter.allTerminals);
	
	filter.filterObjects(jrwTrans.allVoyages, _passport);

	jrwTrans.arriveTsFrom.setDate(filter.arriveDateFrom);
	jrwTrans.arriveTsFrom.setTime(filter.arriveTimeFrom);
			
	jrwTrans.arriveTsTo.setDate(filter.arriveDateTo);
	jrwTrans.arriveTsTo.setTime(filter.arriveTimeTo);
	
	jrwTrans.myVessel 		:= filter.getMyVessel;
	jrwTrans.myShippingLine	:= filter.getMyShippingLine;	// par 19768
	jrwTrans.myVoyage		:= filter.getMyVoyage;			// par 19768

	numSelected := jrwTrans.allVoyages.size;

epilog
	return numSelected;
end;</source>
        <Parameter name="_filter" type="CMQF_VesselOperationsSummary" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
