<Class name="CMQF_BulkRelease">
    <JadeMethod name="setFromAgent" id="32a6f535-b444-46e8-9757-8d71eb6a6350">
        <updating/>
        <source>setFromAgent(_agent: CMUI_ReportAgent input) updating;
//----------------------------------------------------------------
//	Created:	30 May 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------
// 02/08/2017	jlgdap1		TFS 5558 SNO Empty Release Report
vars

begin
	inheritMethod(_agent);

	if _agent.isRowIncluded(ETRow_ReleaseType) then
		self.releaseType := _agent.getSelectedReleaseType();
	endif;

	if _agent.isRowIncluded(ETRow_OperatorGroup) then
		self.setMyOperatorGroup( _agent.getSelectedOperatorGroup() );
	endif;

	if _agent.isRowIncluded(ETRow_IsoTypeGroup) then
		self.setMyISOTypeGroup( _agent.getSelectedISOTypeGroup() );
	endif;
	
	if _agent.isRowIncluded(ETRow_AvaGrade) then
		self.allQryAvaGrades.clear;
		_agent.getSelectedAvaGrades(self.allQryAvaGrades);
	endif;
	
	if _agent.isRowIncluded(ETRow_PoolParty) then					// TFS 5558
		self.setMyMTPoolParty(_agent.getSelectedMTPoolParty);		// TFS 5558
	endif;															// TFS 5558
end;</source>
        <Parameter name="_agent" type="CMUI_ReportAgent" usage="input"/>
    </JadeMethod>
</Class>
