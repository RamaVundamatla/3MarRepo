/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Feb 2023 navtnr20	TFS CR 55646 Task 55665: UI - Contract Details

*/

vars

begin
	// ### TFS BUG 59222 20JUL2023 NAVAB1
	//self.updateMode := false; //31/01/2023	navkc1 Bug 61578
	self.mode := self.MODE_CREATE; //31/01/2023	navkc1 Bug 61578
	self.cmbInvoiceLine.enabled := true;
	self.chkVolume.enabled := true;
	
	
	self.clearFields();
epilog

end;</source>
