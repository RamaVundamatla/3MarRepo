    <JadeMethod name="setSelectedRowScalingDtl" id="b0f61e12-682d-4803-ba5c-fc30bb5b1f66">
        <updating/>
        <source>setSelectedRowScalingDtl(table: Table input) updating, protected;
//--------------------------------------------------------------
//Created: 12 April 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	theObject : Object;
begin
	if table.row &lt;= table.fixedRows then
		return;
	endif;
	table.accessRow(table.row).selected := true;
	self.selectedRow := table.row;
	self.setMySelectedScalingDtl(table.accessRow(table.row).itemObject.CM_LogScalingDtl);
	self.showSelectedScalingDtl();
	
end;</source>
