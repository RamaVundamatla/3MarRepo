    <JadeMethod name="createErrorsFromPassport" id="a55dd849-44e7-4047-ab28-6418eaca5296">
        <source>createErrorsFromPassport(_errorMsgs : DTO_HandHeldGateErrorDict input) : Boolean protected;
/*

Purpose:			


Return Value:		true if there are errors;


Date		Who		Reason
27 October 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	error : CM_Error;
	hasErrors : Boolean;
	
begin
	if not app.myPassport.trxCompletedOK then
		//create hand held errors
		hasErrors:=true;
		foreach error in app.myPassport.allErrors do
			self.addError(error.errorCode,error.text, _errorMsgs);
		endforeach;
	endif;
	
	return hasErrors;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
