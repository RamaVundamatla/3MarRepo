    <JadeMethod name="displayAttributeLegend" id="f11039a6-a4c7-4f2d-a3ca-c1196b95f68b">
        <updating/>
        <source>displayAttributeLegend(_theFrame : Frame input) updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	aDrawingAttribute :	CM_DrawingAttribute;
	theString : CM_String;
	idx,theX, theY : Integer;
	aControl : ComboBox; //Control;
begin
	_theFrame.clearGraphics();
	_theFrame.caption := null;
	_theFrame.drawFillStyle := Frame.DrawFillStyle_Transparent;
	_theFrame.autoRedraw := true;
//	_theFrame.drawTextAt
//	idx := _theFrame.addItem("Attribute" 	&amp; Tab &amp; "Image" );

	idx := 10;
	theX := 5;
	foreach theString in self.allAttributesUsed do
		aDrawingAttribute := app.myRoot.allDrawingAttributes[theString.string];
		if aDrawingAttribute = null then
				continue;
			endif;
		self.mySDF.displayAttribute(aDrawingAttribute,idx,_theFrame,false);
		self.mySDF.displayLabel(aDrawingAttribute,idx,_theFrame,false);

		theY := idx - 4;
//		_theFrame.drawFilledRectangle(1, theY,30,theY + 20,Black);
//		_theFrame.drawFilledRectangle(30, theY,150,theY + 20,Black);
		idx := idx + 20;
	endforeach;
	_theFrame.width := 200;
	_theFrame.height := idx;
	_theFrame.backColor := White;
end;</source>
        <Parameter name="_theFrame" type="Frame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doDrawJob" id="949d425d-ea4d-4325-b395-f43aefd5b849">
        <source>doDrawJob();
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theNeighborPoint,aPoint : CMUI_GridPoint;
	theFrame : CMUI_GridAreaFrame;
	offset : Integer;
begin
	theFrame := self.myGridAreaFrame;
	theFrame.drawWidth := 1;
	if self.allSelectedPoints.isEmpty then
		return;
	endif;
	
	theFrame.drawWidth := 3;
	offset := 1;
	foreach aPoint in self.allSelectedPoints do
		// ############
		// LEFT hand side
		theNeighborPoint := self.allGridPoints[aPoint.row, aPoint.column - 1];
		if not self.allSelectedPoints.includes(theNeighborPoint) then
			theFrame.drawLine(aPoint.x1 + offset,aPoint.y1,aPoint.x1 + offset,aPoint.y2,Black);
		endif;
		// ############
		// RIGHT hand side
		theNeighborPoint := self.allGridPoints[aPoint.row, aPoint.column + 1];
		if not self.allSelectedPoints.includes(theNeighborPoint) then
			theFrame.drawLine(aPoint.x2 - offset,aPoint.y1,aPoint.x2 - offset,aPoint.y2,Black);
		endif;
		// ############
		// TOP hand side
		theNeighborPoint := self.allGridPoints[aPoint.row - 1, aPoint.column];
		if not self.allSelectedPoints.includes(theNeighborPoint) then
			theFrame.drawLine(aPoint.x1,aPoint.y1 + offset,aPoint.x2,aPoint.y1 + offset,Black);
		endif;
		// ############
		// BOTTOM hand side
		theNeighborPoint := self.allGridPoints[aPoint.row + 1, aPoint.column];
		if not self.allSelectedPoints.includes(theNeighborPoint) then
			theFrame.drawLine(aPoint.x1,aPoint.y2 - offset,aPoint.x2,aPoint.y2 - offset,Black);
		endif;

	endforeach;
	theFrame.drawWidth := 1;
end;</source>
    </JadeMethod>
    <JadeMethod name="doDrawJobDischarge" id="04c32c36-73f5-458d-97ce-9da646d620be">
        <source>doDrawJobDischarge();
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	theNeighborPoint,aPoint : CMUI_GridPoint;
	theFrame : CMUI_GridAreaFrame;
	offset : Integer;
	aPort : CM_Port;
begin
	if self.allSelectedPoints.isEmpty then
		return;
	endif;

	//aPort := app.myRoot.allPorts[self.myGridAreaForm.myTerminal.getConfig(PortDestCode).String.trimBlanks];
	aPort := app.myRoot.allPorts[self.myGridAreaForm.myTerminal.getConfig(PortDestCode).String.trimBlanks];
	theFrame := self.myGridAreaFrame;
	
	foreach aPoint in self.allSelectedPoints do
		if aPoint.isKindOf(SHP_BayPoint) then
			aPoint.SHP_BayPoint.colDischMyDischPort := aPort;
			aPoint.SHP_BayPoint.colDischDischPortColour := aPort.colour;
			
		endif;
		aPoint.drawSelf(theFrame);
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="doNullColDischPoint" id="6b61652d-c6e7-493c-ad7c-f8e6b45cb7e3">
        <updating/>
        <source>doNullColDischPoint(_bayPoint : SHP_BayPoint input) updating;
// ---------------------------------------------------------------------------
// Created:		February 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	_bayPoint.colDischDLR := false;
	_bayPoint.colDischSOB := false;
	_bayPoint.colDischMyDischPort := null;
	_bayPoint.colDischDischPortColour := null;
	_bayPoint.colDischMyJob := null;
	_bayPoint.colDischMyJobIsComplete := false;
	_bayPoint.colDischReqLinked := false;
end;</source>
        <Parameter name="_bayPoint" type="SHP_BayPoint" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doNullColLoadPoint" id="5d8ce5ba-aee2-4b29-91db-6072bb59e7c1">
        <updating/>
        <source>doNullColLoadPoint(_bayPoint : SHP_BayPoint input) updating;
// ---------------------------------------------------------------------------
// Created:		February 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
