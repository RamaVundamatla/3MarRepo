    <JadeMethod name="moveControlsForSetup" id="b88132b1-0ee6-4e01-ac7b-d2b9bd05221e">
        <source>moveControlsForSetup();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 August 2020	jlgndl1	Initial creation	TFS 49581

*/

vars

begin

	//hide the crap we aren't using
	self.shtLocation.visible := false;
	self.shtOptions.visible := false;
	self.shtRemarks.visible := false;
	self.lblHeader.visible := false;
	self.cmbIMEX.visible := false;
	self.btnFindImex.visible := false;
	self.chkDisableYA.visible := false;
	self.lblGroupName.visible := false;
	self.txtGroupName.visible := false;
	self.lblYAColour.visible := false;
	self.clrYAColour.visible := false;
	self.grpTemplate.visible := false;
	self.btnNext.visible := false;
	self.txtImex.visible := false;
	
	// move the name field
	self.lblYACode.parent := self.frmHeader;		// Name: Label
	self.lblYACode.top := 1;
	self.lblYACode.transparent := true;
	
	self.txtYACode.parent := self.frmHeader;		// Name textbox
	self.txtYACode.top := 1;
	
	self.lblProjected20.parent := self.frmHeader;	// Priority Label
	self.lblProjected20.top := 35;
	self.lblProjected20.left := self.lblYACode.left;
	self.lblProjected20.width := self.lblYACode.width;
	self.lblProjected20.transparent := true;
	self.lblProjected20.alignment := Label.Alignment_Right_Middle;
	lblProjected20.caption := app.getErrorString(Priority) &amp; ":";
	
	self.txtProjected20.parent := self.frmHeader;	//Priority Textbox
	self.txtProjected20.left := self.txtYACode.left;
	self.txtProjected20.top := 35;
	self.txtProjected20.width := 70;
	self.txtProjected20.alignment := TextBox.Alignment_Right;
	
	//move criteria down
	self.frmHeader.height := 70;
	self.fldYardAlloc.height := 450;
	self.fldYardAlloc.top := 85;
	
	self.grpReeferJob.transparent := true;	
	
	self.btnSave.left := self.btnNext.left;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateCriteriaFrames" id="678bcc37-a042-48c5-bc44-c0caa88cfd51">
        <updating/>
        <source>populateCriteriaFrames(_autoSetFocus: Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 August 2020	jlgndl1	Initial creation

*/

vars
	i: Integer;
	criteria: CM_YACriteria;
	criteriaFrame: CMUI_YACriteriaCntl;
	saveChangeMethod: String;
	cmifObject: CMIF_Object;
	tabIndex: Integer;
	adjustment: Real;
	new: Boolean;
	defaultNumCriteria : Integer;
begin

	tabIndex := self.frmCriteria.tabIndex;					

	self.hideAllOpCriteriaFrames();
	
	defaultNumCriteria := 9;
	
	while i &lt; defaultNumCriteria do
		i := i + 1;
		criteria := null;
		if myObjectMatchCriteria &lt;&gt; null and not myObjectMatchCriteria.allCriteria.isEmpty and myObjectMatchCriteria.allCriteria.size &gt;= i then
			criteria := myObjectMatchCriteria.allCriteria[i];
		endif;
		if criteria = null then
			criteriaFrame := self.addCriteriaFrame(i, null, tabIndex);
		else
			criteriaFrame := self.addCriteriaFrame(i, criteria.myYACriteriaType, tabIndex);
		endif;
		saveChangeMethod := criteriaFrame.formCriteriaChangeMethodName;
		criteriaFrame.formCriteriaChangeMethodName := null;  // prevent invoke of criteria change method
		criteriaFrame.setCriteria( criteria );
		criteriaFrame.setMasterControl(self.frmCriteria);	
		criteriaFrame.formCriteriaChangeMethodName := saveChangeMethod;
		
	//	if criteria &lt;&gt; null and self.excludeCriteriaType(criteriaFrame, criteria.myYACriteriaType) then
	//		criteriaFrame.setCriteria( null );
	//	endif;
		
		if _autoSetFocus and i = 1 then
			criteriaFrame.CMUI_YACriteriaCntl.txtCriteriaValue.setFocus();
		endif;
	endwhile;
	
//	self.disableExcludedCriteria();	
	
epilog
end;</source>
        <Parameter name="_autoSetFocus" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="populateForm" id="bc6f48e5-38ab-4a7a-a441-8133c67806bb">
        <updating/>
        <source>populateForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 August 2020	jlgndl1	Initial creation	TFS 49581

*/

vars

	nullTimeStamp : TimeStamp;
	varTimeStamp : TimeStamp;
	selectedTimes : CM_StringDict;
	stringTime : CM_String;
	time : Time;
	
begin
	
	defaultYACodeChanged	:= false;
	create selectedTimes transient;
	
	if self.myObjectMatchCriteria &lt;&gt; null then
		self.txtYACode.text := self.myObjectMatchCriteria.name;
		self.txtProjected20.text := self.myObjectMatchCriteria.priority.String;
		self.chkAlarm.value := self.myObjectMatchCriteria.alarm;
		self.chkConnect.value := self.myObjectMatchCriteria.connect;
		self.txtConnMins.text := self.myObjectMatchCriteria.connectDelayMins.String;
		self.chkDisconnect.value := self.myObjectMatchCriteria.disconnect;
		self.txtDisconMins.text := self.myObjectMatchCriteria.disconnectDelayMins.String;
		self.chkMoitor.value := self.myObjectMatchCriteria.monitor;
		nullTimeStamp.setTime( "00:00:00".Time );
		varTimeStamp := nullTimeStamp + self.myObjectMatchCriteria.variance;
		self.txtMonVariance.setTime(varTimeStamp.Time);
		foreach stringTime in self.allTimes do
			time := stringTime.string.Time;
			if self.myObjectMatchCriteria.allTimes.includes( time ) then
				selectedTimes.add( stringTime );
			endif;
		endforeach;
		self.mulTimes.setSelected( selectedTimes ); 
		
	else
		self.txtYACode.text := null;
		self.txtProjected20.text := "0";
		self.chkAlarm.value := false;
		self.chkConnect.value := false;
		self.txtConnMins.text := "0";
		self.chkDisconnect.value := false;
		self.txtDisconMins.text := "0";
		self.chkMoitor.value := false;
		varTimeStamp.setTime( "00:00:00".Time );
		self.txtMonVariance.setTime(varTimeStamp.Time);
		self.mulTimes.setSelected( null ); 
		
	endif;

	self.doSetupCriteriaFrames();
	
epilog

	delete self.myAssistant;
	delete selectedTimes;

end;</source>
    </JadeMethod>
    <JadeMethod name="saveData" id="f5cdd3a1-8532-418b-a7c7-048a89da99fb">
        <updating/>
        <source>saveData(_saveAs: Boolean): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 August 2020	jlgndl1	Initial creation	TFS 49581

*/

vars

	seqNumber : Integer;
	allTransientCriteriaObj	: CMIF_Array;
	pxyObjMatch : CM_ObjectMatchCriteria;
	loadState : Boolean;
	result : Integer;
	deleteProxy: Boolean;
	selectedTimes : CM_StringDict;
	stringTime : CM_String;
	allTimes : TimeArray;
	time : Time;
	variance : TimeStampInterval;
	nullTimeStamp : TimeStamp;
	varTimeStamp : TimeStamp;
	real : CM_ObjectMatchCriteria;

begin

	nullTimeStamp.setTime( "00:00:00".Time );
	varTimeStamp.setTime( self.txtMonVariance.getTime );
	variance := varTimeStamp - nullTimeStamp;
	
	create allTransientCriteriaObj transient;
	self.getCriteriaAllCMIF( allTransientCriteriaObj );
	
	if self.myObjectMatchCriteria &lt;&gt; null and not self.myObjectMatchCriteria.isTransient then
		deleteProxy := true;
		app.cmsBeginLoad(loadState);
		pxyObjMatch := self.myObjectMatchCriteria.pxyCreateUpdateProxy();
		app.cmsEndLoad(loadState);
		
	elseif self.myObjectMatchCriteria &lt;&gt; null and self.myObjectMatchCriteria.isTransient then
		// let the real updating occur on the source from
		pxyObjMatch := self.myObjectMatchCriteria;
		
	else
		deleteProxy := true;	
		create pxyObjMatch as CM_ReeferJobCriteria transient;
		
	endif;
	
	seqNumber := self.txtProjected20.text.Integer;	
	pxyObjMatch.setProxy( 	allTransientCriteriaObj,	//_criterias: CMIF_Array;
							seqNumber	//_priority : Integer
							);
							
	create allTimes transient;
	create selectedTimes transient;
	self.mulTimes.getSelected( selectedTimes );
	foreach stringTime in selectedTimes do
		time := stringTime.string.Time;
		allTimes.add( time );
	endforeach;
							
	pxyObjMatch.CM_ReeferJobCriteria.setProxyBaseData(	self.chkAlarm.value,	//_alarm : Boolean;
														allTimes,	//_allTimes : TimeArray;
														self.chkConnect.value,	//_connect : Boolean;
														self.txtConnMins.text.Integer,	//_connectDelayMins : Integer;
														self.chkDisconnect.value,	//_disconnect : Boolean;
														self.chkDisconnect.value.Integer,	//_disconnectDelayMins : Integer;
														self.chkMoitor.value,	//_monitor : Boolean;
														self.txtYACode.text,	//_name : String;
														variance,	//_variance : TimeStampInterval;
														self.myTerminal	//_myTerminal : CM_Terminal
														);
	

	while true do
	
		if self.myObjectMatchCriteria = null then
			app.myTrxCA.trxCreateObjMatchCrit( pxyObjMatch, real, app.myPassport );
		else
			app.myTrxUA.trxUpdateObjMatchCrit(pxyObjMatch, app.myPassport);
		endif;
		
		if app.myPassport.trxCompletedOK then
			self.myObjectMatchCriteria := real.CM_ReeferJobCriteria;
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Reefer_criteria), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

		endif;
		
		return false;
		
	endwhile;
	
	self.unloadForm;
	
	return true;
	
epilog
	if deleteProxy then
		delete pxyObjMatch;
		if allTransientCriteriaObj &lt;&gt; null and not allTransientCriteriaObj.isEmpty then	//23 Jan 2018	NDL	TFS 43045
			allTransientCriteriaObj.purge();
		endif;
	endif;
	
	delete allTransientCriteriaObj;
	app.cmsEndLoad(loadState);
	delete allTimes;
	delete selectedTimes;
		
end;</source>
        <Parameter name="_saveAs" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setBaseData" id="0dfcce85-6fc5-43e0-9855-2ebe7ab742de">
        <updating/>
        <source>setBaseData(	_myObjectMatchCriteria : CM_ReeferJobCriteria;
				_myListForm : CMUI_ObjectCriteriaListForm
				) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 August 2020	jlgndl1	Initial creation	TFS 49581

*/

vars

begin

	self.myObjectMatchCriteria := _myObjectMatchCriteria;
