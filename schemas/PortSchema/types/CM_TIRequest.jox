    <JadeMethod name="pxyCreateUpdateProxy" id="79965fec-1826-4927-9a98-1847c5eef758">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     22 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// ---------------------------------------------------------------------------
vars
	proxyRequest	: CM_TIRequest;
	completedOK		: Boolean;
	
begin

	proxyRequest := inheritMethod();

	proxyRequest.setTrackedItem(self.trackedItem);

	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyRequest;
		
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyRequest;
	endif;		
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="returnJob" id="90e2106f-2593-4d8e-b2b8-48d59163dc4e">
        <updating/>
        <source>returnJob(_newJob : CM_Job)updating;
//--------------------------------------------------------------
//Created: 02 April 2003 By: cnwgd1
//--------------------------------------------------------------
// self.validateForReturnJob should have been done before we get here
// As WLE&lt;--&gt;myTrackedItem one to one we just unplan the ghost if there are any
vars

begin
	inheritMethod(_newJob);
	self.unplanWLEGhostTI();
	self.myJob := _newJob;
end;</source>
        <Parameter name="_newJob" type="CM_Job"/>
    </JadeMethod>
    <JadeMethod name="setBulkReleaseTI" id="9a1ef5c8-a0d9-42b6-8fd7-d58b9c869035">
        <updating/>
        <source>setBulkReleaseTI(_theTrackedItem: CM_TrackedItem input) updating;
/*

Purpose:			Adds the Ti to the bulk release as assigned

Parameters:			_theTrackedItem	CM_TrackedItem	The tracked item to assign to the bulk release

Return Value:		NONE

Date			Who		Reason
22 August 2024	navpw1	Initial creation TFS: 65623 (65624)

*/

vars
	reserveDetail	: CM_ReserveDetail;
	reserveHeader	: CM_BulkRelease;
	job				: CM_Job;
	request			: CM_Request;
	anyAmount,
	anyId			: Boolean;
	
begin
	inheritMethod(_theTrackedItem);
	
	reserveDetail := self.myReserveDetail;
	if reserveDetail &lt;&gt; null then
		reserveHeader := reserveDetail.myReserveHeader;
	endif;
	
	job := self.myJob;
	
	if job &lt;&gt; null then
		request := job.allRequests.first; //First request should be delivery request for any id amy amount.
	endif;
	
	if request &lt;&gt; null and request.isDeliveryRequest then
		anyAmount := request.isAnyAmount;
		anyId := request.isAnyId;
	endif;
	
	if reserveDetail &lt;&gt; null and 
		reserveHeader &lt;&gt; null and
		not reserveHeader.allTrackedItemsAssigned.includes(_theTrackedItem) and
		reserveHeader.releaseByType and 
		anyAmount and 
		anyId
	then // ### CCMS 1282 AKB2004NOV
		reserveDetail.addTI(_theTrackedItem);
		self.updateObjectEdition(reserveHeader);	// par 30292 //cause an update of the BR
		
	endif;
	
end;</source>
        <Parameter name="_theTrackedItem" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="70d70b45-bc2d-4089-933a-035c18a91817">
        <updating/>
        <source>setForCreate(pProxyRequest: CM_TIRequest) updating;
// ---------------------------------------------------------------------------
// Created:     26 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.raiseExceptionIfTransient(method);
	pProxyRequest.raiseExceptionIfNotTransient(method);

	// Have to set self.isReceipt before self.setTrackedItem();
	self.isReceipt := pProxyRequest.isReceipt;	
	self.setTrackedItem(pProxyRequest.trackedItem);
	self.quantity := pProxyRequest.quantity;	//16 Sep 2013	NDL	Par 32479
	inheritMethod(pProxyRequest);
	if self.myJob &lt;&gt; null then
	// Par 10712. This was causing the calling CM_YardInternalJob.updateTICollections twice.
	//	self.myJob.updateTICollections(self.trackedItem);
	endif;

end;</source>
        <Parameter name="pProxyRequest" type="CM_TIRequest"/>
    </JadeMethod>
    <JadeMethod name="setFromCMIF_Request" id="cf5c9ade-1129-4bcb-9358-7d9e7b6f1113">
        <updating/>
        <source>setFromCMIF_Request(_intFaceById	: CMIF_Request)updating;
//--------------------------------------------------------------
//Created: 28 March 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	inheritMethod(_intFaceById);
	
	self.setTrackedItem(_intFaceById.myTrackedItem);
	self.quantity := _intFaceById.quantityTxt;	//16 Sep 2013	NDL	Par 32479
	
end;</source>
        <Parameter name="_intFaceById" type="CMIF_Request"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="7d7869b2-2129-4eae-aaf8-d4c095b1dc0f">
        <updating/>
        <source>setProxy(lClean : Boolean; lconsignorVoyageCode : String; leirNumber : String; 
		lconsignee : String; ldoorsDirection : Integer; pDeliveryNumber : String;
		_freightForwarderCode, _freightPayeeCode : String; lisReceipt : Boolean; lISOType : String; 
		lOperator : String; lNumRequested : Integer; lreasonCode : Integer; 
		lHeavy : Boolean; lMask : String; lneedCOU : Boolean; 
		lneedGenerator : Boolean; lDate : Date; lvoyageCode : String; lCheckISO : Boolean; 
		pJob : CM_Job; pinNo : String; pAVG : Integer;  
		pRemoveStops : Boolean; pReasonCodeDescr,pRemarks : String;pTI : CM_TrackedItem;
		_userCode : String; _transToTerminal: CM_Terminal) updating;
/* This method exists to set up a proxy request.

*/
vars

begin

	if not self.isTransient then
		return;
	endif;

	self.setProxyForYardRequest(lconsignee, lconsignorVoyageCode, pDeliveryNumber,
						ldoorsDirection,
						leirNumber, _freightForwarderCode, _freightPayeeCode,
						lisReceipt, lneedCOU, lneedGenerator,
						lreasonCode, 
						pReasonCodeDescr, pRemarks,
						pRemoveStops,
						_userCode, lvoyageCode,
						pJob, pinNo, _transToTerminal);

	self.setTrackedItem(pTI);	

end;</source>
        <Parameter name="lClean" type="Boolean"/>
        <Parameter name="lconsignorVoyageCode" type="String"/>
        <Parameter name="leirNumber" type="String"/>
        <Parameter name="lconsignee" type="String"/>
        <Parameter name="ldoorsDirection" type="Integer"/>
        <Parameter name="pDeliveryNumber" type="String"/>
        <Parameter name="_freightForwarderCode" type="String"/>
        <Parameter name="_freightPayeeCode" type="String"/>
        <Parameter name="lisReceipt" type="Boolean"/>
        <Parameter name="lISOType" type="String"/>
        <Parameter name="lOperator" type="String"/>
        <Parameter name="lNumRequested" type="Integer"/>
