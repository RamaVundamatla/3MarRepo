<Class name="CM_QStrPortProperty" id="635e0508-1348-40eb-bed7-28b8bb5b1797">
    <superclass name="CM_QStringLookupProperty"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="create" id="175e2aeb-fbb3-4ada-b304-24ffb24aa56d">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:		10 March 2006  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	oper : CM_QueryOperator;
begin
	if self.isTransient then 
		return;
	endif;

	create oper as CM_QStringIsOneOf persistent;
	self.allAllowedOperators.add(oper);

end;</source>
    </JadeMethod>
    <JadeMethod name="getControlNameForOperator" id="800dfa64-5e6b-42e3-9889-270cf3099fec">
        <source>getControlNameForOperator(_operator: CM_QueryOperator): String;
// ---------------------------------------------------------------------------
// Created:     16 January 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if CM_QReferenceLookup.hasInstance(_operator) then
		return 'cmbPort';
	endif;


end;</source>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPortCodeFromDescription" id="21f20e5a-132d-4030-81fd-1ba1229b548d">
        <source>getPortCodeFromDescription(description : String; _portCmbOrderDescrFirst : Boolean) : String;
/****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 17 September 2018
TFS#		: 40200
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	port : CM_Port;
	countryCode	: String;
	code		: String;
begin
	if _portCmbOrderDescrFirst = true then
		return description[1:5];
	else
		return description[6:2] &amp; description[1:3];
	endif;		
	return null;
end;</source>
        <Parameter name="description" type="String"/>
        <Parameter name="_portCmbOrderDescrFirst" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getWebDataRowName" id="57328744-883c-44ac-bfb2-020af987be1c">
