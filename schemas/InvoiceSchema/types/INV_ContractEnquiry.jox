    <JadeMethod name="addRowToTblDetail" id="36dfd1e0-1a9e-4e60-af73-b960e86f8fe5">
        <source>addRowToTblDetail(_detail : CM_InvoiceContractDetails);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 October 2024	navlc30	Initial creation
10 Oct 2024 navlc30 JIRA 19508 UI - Contract Enquiry extra tables for results
*/

vars
	tbl			: CM_DataTable;
	idx			: Integer;
	str 		: String;
begin
	tbl := self.tblDetails;
	
	str := _detail.getAttributeStringForDefArray(tbl.allTblDataEntRows);
	idx := tbl.addItem(str);
	tbl.accessRow(idx).itemObject := _detail;	
epilog

end;</source>
