    <JadeMethod name="updateForCreate" id="4da23625-6d03-4bca-a25c-ce4607505933">
        <updating/>
        <source>updateForCreate(_name, _beforeValue, _afterValue : String;
	_objImage : CM_AuditObjectImage) updating;

// This should be called only when self is being created

begin
	if _name.length &gt; 60 then
		self.name := _name.truncatedAt(60);
	else	
		self.name := _name;
	endif;
	self.beforeValue := _beforeValue;
	self.afterValue := _afterValue;
	
	self.myObjectImage := _objImage;	

end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_beforeValue" type="String"/>
        <Parameter name="_afterValue" type="String"/>
        <Parameter name="_objImage" type="CM_AuditObjectImage"/>
    </JadeMethod>
</Class>
