    <JadeMethod name="createINCOMapping" id="fa25fc92-351c-48e6-97bd-5837b94ae375">
        <updating/>
        <source>createINCOMapping()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 MAY 2023 navtnr20	TFS CR 57991 Task 57992: EUP - INCO Terms Mapping

*/

vars
	charge,debtor : CM_DebtorType;
	pxyINCOMapping,
	realINCOMapping:CM_InvoiceINCOMapping;
	//myShippingTerm : CM_InvoiceContractShipTerm;
	bank : CM_Bank;
	allInvoice : CM_InvoiceLineDescSet;
	ild : CM_InvoiceLineDesc;
	theReturn : Integer;
begin
	if self.cmbCharge.listIndex &lt;&gt; -1 then
		charge := self.cmbCharge.itemObject[self.cmbCharge.listIndex].CM_DebtorType;
	endif;
	bank := self.myCurrentBank;
	debtor := app.myRoot.allDebtorTypes.first;
	create allInvoice transient;
	//ild := bank.invoiceLineDescriptors.first;
	self.msgInvlistTypes.getSelected(allInvoice);
	create pxyINCOMapping transient;
	pxyINCOMapping.setProxy(myIncoTerm,charge,allInvoice);

		while true do
		app.myTrxCA.trxCreateInvoiceINCOMapping(pxyINCOMapping, realINCOMapping, app.myPassport);
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			self.unloadForm();
			//self.myParentForm.INV_ShippingTermMaint.setProxyShippingItem(realShippingTermMapping);
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Invoice_inco_mapping_created), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);
		endif;
		break;
	endwhile;
	//self.setSelectedRow();
epilog
	delete	pxyINCOMapping;
	delete allInvoice;
end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbChargesBuild" id="5a3a9d66-a302-4c09-835c-159260022e9d">
        <source>doCmbChargesBuild(_combo : CMUI_ComboBox input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 MAY 2023 navtnr20	TFS CR 57991 Task 57992: EUP - INCO Terms Mapping

*/
vars
	aDebtorType : CM_DebtorType;
begin
	
	_combo.clear;
	_combo.sorted := true;
	
	
	foreach aDebtorType in app.myRoot.allDebtorTypes where not aDebtorType.isNotAvailableForEntry do
		if aDebtorType.code = CM_DebtorType.DT_EVENT_TYPE  then
			continue;
		endif;
		
		if aDebtorType.isSystemGenerated or aDebtorType.allDebtors.size &gt; 0 then
			_combo.addItem(aDebtorType.description);
			_combo.itemObject[_combo.newIndex] := aDebtorType;
		endif;
	endforeach;
end;</source>
        <Parameter name="_combo" type="CMUI_ComboBox" usage="input"/>
    </JadeMethod>
