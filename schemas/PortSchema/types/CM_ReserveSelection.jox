    <JadeMethod name="getHeight" id="a09cfe59-bf44-4039-b810-616b595e14a7">
        <source>getHeight(): Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Sep 2024	navnk30	Bug 66204: EUP | 53308 - 1011 error when using and dimensions field in the Grouping criteria URGENT

*/

vars
	relCriteria			: CM_ReleaseByTypeCriteria;
	heightCriteria		: CM_YACriteria;
begin
	relCriteria := self.myReleaseCriteria;
	if relCriteria = null then
		return self.heightSelection;
	endif;
	heightCriteria :=relCriteria.getCriteriaFor(YACriteriaType_CargoHeight);
	if heightCriteria = null then
		return self.heightSelection;
	endif;
	return heightCriteria.myYAData.CM_YADataString.value.Decimal;
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
