    <JadeMethod name="setVoyageCode" id="e794ea6b-6244-4fe4-8fa7-16e2854ccea8">
        <updating/>
        <source>setVoyageCode(_value: String) updating;
//
//18 August 2017	jlgrs1	TFS 5457 Make JMTInternal XML work
//27 Sep 2022 navtnr20 Bug 53101: MTN US Customs Message EDI not added to collection by Voyage Code
//
vars
	config			:CM_EDIConfig;
	coll			:CM_EDITIsByVoyageCodeDict;
	code, codeUpper	:String;
begin
	//self.voyageCode := _value;	//27.09.2022 navtnr20 53101
	
	// need to make sure the manual collection on CM_EDIConfig gets maintained correctly, this collection
	// keeps track of all EDITrackedITems that have some connection to a voyageCode of some kind.
	config := self.myEDIConfig;
	
	if config &lt;&gt; null then
		coll := config.allEDITrackedItemsByVoyageCode;
	endif;
	
	code := self.voyageCode;
	
	// remove the previous non-null value from this collection
	if code &lt;&gt; null and coll &lt;&gt; null then
		codeUpper := code.toUpper;
		
		if coll.includesKey( codeUpper, self ) then
			coll.removeKeyEntry( codeUpper, self, self );
		endif;
	endif;

	// now change it and add this new value to the manual collection (if not null).
	code			:= _value[ 1 : self.voyageCode.maxLength ];
	self.voyageCode	:= code;
	
	if not self.isTransient and
	   code &lt;&gt; null and coll &lt;&gt; null then
		codeUpper := code.toUpper;
		
		if not coll.includesKey( codeUpper, self ) then
			coll.putAtKey( codeUpper, self, self );
		endif;
	endif;
	
epilog
	
end;
</source>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="verifyBOL" id="0bd63150-c0e1-4101-8f0b-23bfc5aacb76">
        <source>verifyBOL(_terminal : CM_Terminal) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 July 2014	cnwmc5	Initial creation
//6/11/2019	JLGNS1	ChangeRequest 46721: PEN - CAMIR Message Processing
26 Mar 2024	jlirs1	TFS 63046 - Check the voyage Code and inwards code
*/

vars
	bol : CM_BOLIn;
	
begin
	if self.billOfLading = null and self.id &lt;&gt; null then
		return;
	endif;
	
	bol := _terminal.getBOLInByNumber(self.billOfLading, BOLType_GeneralBillOfLading);
	
	if bol = null then
		app.raiseCMException1(Err_BOLNotFound, self.billOfLading, null, self);
		return;
	endif;
	
	if not bol.myVoyage.isVoyageCodeValid(self.voyageCode) then			//26 Mar 2024	jlirs1	TFS 63046 - Check the voyage Code and inwards code

		app.raiseCMException2(NoBillOfLadingOnVoyage, self.billOfLading, self.voyageCode, null, self);
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="verifyDisposition" id="26339e43-8b31-497f-bbce-bbab589a3144">
        <source>verifyDisposition() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 July 2014	cnwmc5	Initial creation

*/

vars
	ediFileType			: CM_EDIFileType;
	ediFileTypeCAMIR	: CM_EDIFileTypeCAMIRStatusUpd;
	
begin
	
	ediFileType := app.myRoot.allEDIFileTypes.getAtKeyGeq(EDIFileTypeCAMIR_CustomsStatus, null);
	if ediFileType &lt;&gt; null and ediFileType.isKindOf(CM_EDIFileTypeCAMIRStatusUpd) then
		ediFileTypeCAMIR := ediFileType.CM_EDIFileTypeCAMIRStatusUpd;
	endif;
	
	if ediFileTypeCAMIR = null then
		return;
	endif;
	
	if not ediFileTypeCAMIR.hasEDIActionForCustomsMessage(self.dispositionCode) then
		app.raiseCMException1(CustomsActionTypeReq, self.dispositionCode, null, self);
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="verifyPorts" id="787c92fb-01b1-4c34-8040-59ab5fe8de2c">
        <source>verifyPorts() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 July 2014	cnwmc5	Initial creation

*/

vars
	portDestCode	: String;

	aPort 			: CM_Port;
	
begin

	//Verify Port
	portDestCode := app.myPassport.myTerminal.getConfig(PortDestCode).String.trimBlanks();
	aPort := app.myRoot.allPorts[self.portOfEntry];
	
	if aPort &lt;&gt; null then
		if aPort.code &lt;&gt; portDestCode then
			//DISCHARGE PORT IS NOT US
			//app.raiseCMException1(ERR_INVALID_DIS_PORT, self.dischargePort, null, null);
		endif;
	else
		app.raiseCMException1(ERR_INVALID_DIS_PORT, self.portOfEntry, null, self);
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="verifySelf" id="10bd9d80-05c3-4c28-9a0a-9e0a7a75abd7">
        <source>verifySelf();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 July 2014	cnwmc5	Initial creation
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
*/
vars
	terminal : CM_Terminal;
begin

	terminal := self.getMyTerminal();
	if terminal = null then
		app.raiseCMException1(Err_InvalidTerminal, 'null', null, null);
		return;
	endif;
	
	self.verifyPorts();
	
	self.verifyVoyage(terminal);
	
	self.verifyDisposition();
	
	self.verifyBOL(terminal);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="verifyVoyage" id="9c994586-37ab-48f1-ad73-eba95f768f37">
        <source>verifyVoyage(_terminal : CM_Terminal) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 July 2014	cnwmc5	Initial creation

*/

vars
	voyage : CM_Voyage;
	
begin
	
	voyage := _terminal.lookupVoyage(self.voyageCode, null, false);
	
	if voyage = null then
		app.raiseCMException1(ERR_INVALID_VOYAGE, self.voyageCode, null, self);
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
</Class>
