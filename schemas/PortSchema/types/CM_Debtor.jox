/*

Purpose:			Gets Debtor's Currency Type

Parameters:			NONE

Return Value:		CM_CurrencyType	Returns the debtors Currency Type

Date		Who		Reason
22 August 2022	navpw1	Initial creation TFS: 54564 (54382)

*/

vars
	debtorTerminal 	: CM_DebtorTerminal;
	currencyType 	: CM_CurrencyType;
	
begin
	debtorTerminal := self.allDebtorTerminals[app.myPassport.myTerminal];
	
