        <source>setFromTimeStampInterval(_interval :CM_TimeStampInterval)updating;
/*
Date		Who		Reason
20 September 2011	cnwcs5	Initial creation - CCMS RIO 2041 / par 28220 Start/Stop Times
*/
vars

begin
	self.startDT	:= _interval.startDT;
	self.endDT		:= _interval.endDT;
epilog

end;</source>
        <Parameter name="_interval" type="CM_TimeStampInterval"/>
    </JadeMethod>
