    <JadeMethod name="create" id="96caaa8e-df76-4b7a-a4ba-a603140c0db7">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27/09/2023	navkc1	CR 60428 Task 60702: UI - Cargo Review Option in Transport UI

*/

vars
	oper : CM_QueryOperator;
begin
	if self.isTransient then 
		return;
	endif;
	
	create oper as CM_QStringIsOneOf persistent;
	self.allAllowedOperators.add(oper);
epilog

end;</source>
