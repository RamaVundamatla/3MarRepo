    <JadeMethod name="xGCDCStatusBarStep7" id="68d21430-a074-4116-b677-f7475cf2850a">
        <updating/>
        <source>xGCDCStatusBarStep7() updating;

/*

Purpose:		Create the jobs for the load color coding and check that the status bar is correct	

Date			Who		Reason
15/05/2013		cnwmh5	Initial creation

*/
constants

	ContainerPartialId					: String = 'UTGCDC1';

vars

	voyageJob							: CM_VoyageJob;
	
begin

	app.writeLog("STEP 7", LogINFO);
	app.writeLog("Creating job(s) for load color coding.  Please wait...", LogINFO);
	
	voyageJob:=self.addVoyageROROJob(self.myVoyage, self.myDeck, "UT_MHQ", self.roroLCs, false);
	assertTrue(voyageJob &lt;&gt; null);
	
	app.writeLog("Checking Status Bar (ACTUAL) details are correct.  Please wait...", LogINFO);
	self.locationArray.clear();
	self.statusArray.clear();
	self.locationArray.add("D4339O");
	self.statusArray.add("D4339O D4339O | 2 x CONT NZLYT  U20G | UTGCDC10020, UTGCDC10021");
	self.locationArray.add("D4341O");
	self.statusArray.add("D4341O D4341O | Aft: D4340O | 1 x CONT NZLYT  U40G | UTGCDC10033");
	self.locationArray.add("D4270682");
	self.statusArray.add("D4270682 D4270682 |  Fwd: D4250682 | 4 x CONT NZLYT  U20G | UTGCDC10010, UTGCDC10011, UTGCDC10012, UTGCDC10013");
	self.locationArray.add("D4270282");
	self.statusArray.add("D4270282 D4270282 |  Fwd: D4250282 | 2 x CONT NZLYT  U20G | UTGCDC10002, UTGCDC10003");
	self.locationArray.add("D4250282");
	self.statusArray.add("D4250282 D4250282 | Aft: D4270282 | 1 x CONT NZLYT  U20G | UTGCDC10001");
	self.locationArray.add("D4250382");
