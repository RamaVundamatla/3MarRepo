    <JadeMethod name="setViewModeCode" id="7e3dee4b-a1ef-4725-8ef4-7123a4565229">
        <updating/>
        <source>setViewModeCode(value : String) updating;
//30 May 2008	cnwdw1	
// When the view mode code is set, then only display the colour for this code
begin
	if value &lt;&gt; self.viewModeCode then
		self.viewModeCode := value;
		self.refreshLocations();
	endif;
end;</source>
        <Parameter name="value" type="String"/>
    </JadeMethod>
    <JadeMethod name="setYardAllocation" id="ac7cc2cc-6b37-4a1f-9deb-fabddfccd0f8">
        <updating/>
        <source>setYardAllocation(_yardAllocation : CM_YardAllocation; _new : Boolean) updating;
//28 May 2008	cnwdw1	
// Set the selected yard allocation. Only this yard allocation will be displayed. 
// If the yardAllocation is null and it is not _new, then all allocations are displayed
vars
	location : CM_LocationsController;
begin
	self.deleteDummyYardAllocation();
	if _new then
		self.createDummyYardAllocation();
	else
		self.mySelectedYardAllocation := _yardAllocation;
	endif;
	self.isNewYardAllocation := _new;
	
	// Create a collection of locations that are in this yard allocation
	// so we can get track of changes during editing of yard allocations
	self.myYardAllocationLocations.clear();
	foreach location in myTerminalArea.allLocationsControllers do
		if location.CM_YardController.allYardAllocations.includes(self.mySelectedYardAllocation) then
			self.myYardAllocationLocations.add(location);
		endif;
	endforeach;
end;</source>
        <Parameter name="_yardAllocation" type="CM_YardAllocation"/>
        <Parameter name="_new" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="toggleCellSelection" id="3ed940fb-fe92-4c8d-9b8f-bfcac469eac2">
        <source>toggleCellSelection(cell: Point) protected;
// Select/Unselected the cell
vars

begin
	self.getCell(cell.x, cell.y).setIsSelected(not self.getCell(cell.x, cell.y).isSelected);
	self.drawCell(cell.x, cell.y);
end;
</source>
        <access>protected</access>
        <Parameter name="cell" type="Point"/>
    </JadeMethod>
</Class>
