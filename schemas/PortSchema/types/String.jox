    <JadeMethod name="isBookingRefMatch" id="c8438146-f5c0-4414-8640-7a312f408e38">
        <source>isBookingRefMatch(_bookingReference:String; _isPartial:Boolean):Boolean;
// --------------------------------------------------------------------------------
// Created:		10 June 2009 by cnwdad1
//
// Purpose:		Returns a boolean value to indicate whether the specified Booking
//				Reference code matches the receiver.
//
// Parameters:	_bookingReference - The Booking Reference code to match.
//				_isPartial - True if a partial match will be made.
//
// Returns:		True if the Booking Reference is a match, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if _isPartial then
		if self.length() &gt; _bookingReference.length() then
			return _bookingReference = self[1:_bookingReference.length()];
		else
			return (_bookingReference = self);
		endif;
	else
		return (_bookingReference = self);
	endif;
end;</source>
        <Parameter name="_bookingReference" type="String"/>
        <Parameter name="_isPartial" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isDecimalJMT" id="789ccdbe-5c88-44cd-89e8-6d360b54060a">
        <source>isDecimalJMT() : Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 03/10/2017	jlgdap1		Initial creation TFS 7204 STWR problems with decimals in non-standard locale
//
constants
	JMTDecimalSeparator = ".";
	JMTThousandSeparator = ",";
vars
	decimalSeparator,
	thousandSeparator,
	tmpStr	: String;
	
begin
	decimalSeparator := app.getMyLocaleInfoJMT().numericInfo.decimalSeparator;
	thousandSeparator := app.getMyLocaleInfoJMT().numericInfo.thousandSeparator;
	
	tmpStr := self;
	tmpStr.replaceChar(thousandSeparator.Character, " ");
	tmpStr := tmpStr.cnEcRemoveSubstring(" ");
	tmpStr.replaceChar(decimalSeparator.Character, JMTDecimalSeparator);
	
	return tmpStr.isDecimal;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isEqualIgnoreCase" id="15d95e3c-c775-45f6-9ec0-d01dba239e83">
        <source>isEqualIgnoreCase(_comparisonString: String): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 January 2026	navcs2	Initial creation

*/

vars
	c1, c2 		: 	Character;
	index		:	Integer;
	strLength	:	Integer;
begin
	strLength := self.length;
	
	if not strLength = _comparisonString.length then
		return false;
	endif;
	
	foreach index in 1 to strLength do
        c1 := self[index];
        c2 := _comparisonString[index];

        if 'A' &lt;= c1 and c1 &lt;= 'Z' then
            c1 := (c1.Integer + 32).Character;
		endif;
		
        if 'A' &lt;= c2 and c2 &lt;= 'Z' then
            c2 := (c2.Integer + 32).Character;
		endif;
		
        if not c1 = c2 then
            return false;
		endif;
	endforeach;
	
    return true;
epilog

end;</source>
        <Parameter name="_comparisonString" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isFilename" id="4a55c070-0004-43c0-ac0b-98573a19b4fb">
        <source>isFilename() : Boolean;
// ---------------------------------------------------------------------------
// Created:     04 June 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
	trimmedFilename : String;
	f : File;

begin
	trimmedFilename := self.trimBlanks;
	if trimmedFilename = null then
		return false;
	endif;
	
	create f transient;
	f.allowCreate := false;
	f.fileName := trimmedFilename;
	f.usePresentationFileSystem := true;
	f.allowReplace := false;
	f.kind := File.Kind_Binary;
	f.mode := File.Mode_Input;
	f.shareMode := File.Share_Read;
	
	return f.isAvailable;
	
epilog
	if f &lt;&gt; null then
		if f.isOpen then
			f.close;
		endif;
		delete f;
	endif;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isFoldername" id="9a8310be-cdef-4034-b259-d32d84a6b400">
