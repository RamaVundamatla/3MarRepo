    <JadeMethod name="tLogRowMaint" id="aff708da-30ce-42e1-95a6-1d4e7c0d1b83">
        <source>tLogRowMaint();
// cnwns1
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 January 2015	cnwmc5	Initial creation

*/
constants
	LOG_AREA		: String = "UTLOG";
	LOG_AREA_COMM	: String = "UT Log Area 1";

vars
	logArea			: CM_LogArea;
	realLocation	: CM_LogController;
	logModule		: UT_LogModule;
	cmif_LogRow		: CMIF_LogRowRestriction;
begin
	
	create logModule transient;
	logModule.setActiveProfileMDHONLY();
	
	logModule.deleteLogArea(LOG_AREA);
	logModule.addLogArea(LOG_AREA, LOG_AREA_COMM);
	
	create cmif_LogRow transient;
	self.xCreateProxyLogRow(cmif_LogRow, LOG_AREA);
	logModule.addLogRow(cmif_LogRow);
	
	self.webServiceCall( CM_UnitTestAgent::wsLogRowMaint.name );

epilog

	logArea := self.getTerminal().allTerminalAreas[LOG_AREA].CM_LogArea;
	if logArea &lt;&gt; null then
		realLocation := logArea.findLogRow('UT_WEB');
		if realLocation &lt;&gt; null then
			app.myTrxDA.trxDeleteRowController(realLocation, app.myPassport);
		endif;
	endif;
	
	delete logModule;
	delete cmif_LogRow;		
end;</source>
    </JadeMethod>
    <JadeMethod name="tMergeCargo" id="d0825c01-3459-4fae-8e63-f426476a4598">
        <source>tMergeCargo();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 July 2016	cnwns1	Initial creation

*/
constants
	BlockStackId1 : String = "UTWBS666";
	CargoTypeAbbrev : String = "UTBYQ";// "ALIG";
	ParentName : String = "UTCARGO666";
	ChildName : String = "UTCARGO667";
	
vars

	expectdIdArray : StringArray;
	expectdId : String;
	bs1 : CM_BlockStack;
//	ti : CM_TrackedItem;
	cargoType : CM_CargoType;
	operator : CM_Operator;
	commodity : CM_Commodity;


cargoParent : CM_TrackedItem;
cargoChild : CM_TrackedItem;
xtraTestString : String;


begin

	cargoType := self.getRoot().getCargoTypeFromAbbrevOrDescr( CargoTypeAbbrev );
	commodity := cargoType.allCommodities.first;
	operator := app.myRoot.allOperators[self.getProfileSetting(UT_Profile.P_OPERATOR).asString].CM_Operator;
		
	bs1 := self.addBlockStack(BlockStackId1, 99, null);
	self.opts.purge();
	self.opts.addAssoc("totalQuantity",50.Integer);
	cargoParent := self.addCargoOpts(ParentName,"", null, operator, cargoType.id);
	
	self.move( cargoParent, bs1 );
	cargoChild := self.addCargoOpts(ChildName, "", null, operator, cargoType.id);
	self.move( cargoChild, bs1 );

	self.webServiceCallWithParams( CM_UnitTestAgent::wsCargoMerge.name, cargoParent, cargoChild, xtraTestString);
	
	self.assertEqualMsg(cargoParent.totalQuantity,100,"Total Quantity is not 100");
	
	self.deleteTrackedItem(cargoChild, false);	
	
	self.deleteTrackedItem(cargoParent, false);


	deleteTerminalArea(BlockStackId1);

	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tPublicUserWhiteList" id="ca5b3e2f-3cde-49d6-b241-f63864c3e612">
