    <JadeMethod name="checkProse" id="214c9460-7833-434f-8671-2a3d00fc2009">
        <updating/>
        <source>checkProse(pProse:String):String updating;
// -----------------------------------------------------------------------------
// Created:		18 June 2003 by cnwdad1
//
// Purpose:		Checks the specified prose, and returns the updated string.
//
// Parameters:	pProse - The prose to be checked.
//
// Returns:		The updated prose.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
// 03/06/2003	cnwdad1		Changed the ignoreDict from a StringArray to type
//							CnEcArray to handle prose with words longer than 60
//							characters.
//
// 18/06/2003	cnwdad1		If the last word in the prose was being corrected,
//							then the last character in the word was always
//							appended to the end, and hence the original text was
//							ALWAYS updated even if the user cancelled the check.
//
// 07/06/2008	cnwdad1		Fixed a problem where the allSoundexWords and
//							allMetaphoneWords arrays were being leaked.
// -----------------------------------------------------------------------------
vars
	replacementWord		: String;
	wordToCheck			: String;
	wordToCheckLower	: String;
	spellRootObj		: CnEcSpellRoot;
	spellFormObj		: CnEcSpellCheckForm;
	ignoreDict			: CnEcArray;
	agentObj			: CnEcSpellAgent;
	charPos				: Integer;
	proseLength			: Integer;
	allSoundexWords		: StringArray;
	allMetaphoneWords	: StringArray;
	allReplacementWords	: CnEcDualStringArray;
	letter				: Character;
	remainingProse		: String;
	checkedProse		: String;
	  
begin
	spellRootObj	:=	app.myBaseRoot.getSpellRoot();

	create ignoreDict transient;
	create agentObj transient;
	create allReplacementWords transient;

	// search through each position in the prose
	proseLength	:=	pProse.length();
	
	foreach charPos in 1 to proseLength do
		letter	:=	pProse[charPos];
		
		if letter.isAlpha() then
			wordToCheck := wordToCheck &amp; letter;
			
			if charPos = proseLength then
				// to allow write of last word if necessary
			else
				//If the character is still alpha we are building a wordToCheck so skip the rest
				continue;
			endif;
		endif;
		
		if wordToCheck.length() &gt; 0 then
			// if we have a word convert it to lower case
			wordToCheckLower	:=	wordToCheck.toLower();
			
			// if its a known replacement word do the replacement
			if allReplacementWords.indexOf(wordToCheckLower) &gt; 0 then				
				allReplacementWords.cnEcGet(wordToCheckLower, replacementWord, allReplacementWords.indexOf(wordToCheckLower));
				wordToCheck	:=	replacementWord;
			
			// if we don't recognise the word let the user decide	 	 
			elseif spellRootObj.allSpellWords.getAtKey(wordToCheckLower) = null and not ignoreDict.includesString(wordToCheckLower) then				
				create allSoundexWords transient;
				create allMetaphoneWords transient;
				create spellFormObj;
				
				self.getAlternateWordsBySoundex(wordToCheckLower, allSoundexWords);
				self.getAlternateWordsByMetaphone(wordToCheckLower, allMetaphoneWords);
				
				if charPos &lt; proseLength then					// cnwdad1 18/06/2003.
					remainingProse	:=	pProse[charPos:end];	// cnwdad1 18/06/2003.
				else											// cnwdad1 18/06/2003.
					remainingProse	:=	null;					// cnwdad1 18/06/2003.
				endif;											// cnwdad1 18/06/2003.
				
				spellFormObj.setSpellFeatures(	self,
												self.isMetaphoneSearch,
												checkedProse,
												wordToCheck,
												remainingProse,		// cnwdad1 18/06/2003. pProse[charPos:end]
												allSoundexWords,
												allMetaphoneWords);
				
				spellFormObj.showModal();
				
				//process what has come back from the User
				if self.isCancelSpellCheck then
//					checkedProse	:=	checkedProse &amp; wordToCheck &amp; pProse[charPos:end];		// cnwdad1 18/06/2003.
					checkedProse	:=	checkedProse &amp; wordToCheck &amp; remainingProse;			// cnwdad1 18/06/2003.
					break;
				else
					self.doProcessUsersResponse(ignoreDict, agentObj, wordToCheckLower, spellRootObj, wordToCheck, allReplacementWords);
				endif;
				
		
				delete allSoundexWords;
				delete allMetaphoneWords;
			else
				//we have a word we recognise do nothing
			endif;
			
		endif;
		
		//write what we have to checkedProse
		
		if charPos = proseLength and letter.isAlpha() then
			//got to the last letter and it was an alpha, so it is already part of the word.
			checkedProse	:=	checkedProse &amp; wordToCheck;
		else
			checkedProse	:=	checkedProse &amp; wordToCheck &amp; letter;
		endif;
		
		//just in case we have just processed a word, clear it out and go around again
		wordToCheck	:=	"";
	endforeach;
epilog
	delete spellFormObj;
	delete ignoreDict;
	delete agentObj;
	delete allSoundexWords;
	delete allMetaphoneWords;
	delete allReplacementWords;
	
	return checkedProse;	
end;</source>
        <Parameter name="pProse" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doProcessUsersResponse" id="f78073f2-63fd-415a-9230-54571e980fc0">
        <updating/>
        <source>doProcessUsersResponse(	pAllIgnoredWords : CnEcArray io;
						pSpellAgentObj : CnEcSpellAgent io;
						pWordToCheckLower : String io;
						pSpellRootObj : CnEcSpellRoot io;
						pWordToCheck : String io;
						pAllReplacementWords : CnEcDualStringArray io) updating, protected;

vars
	newWordObj	: CnEcSpellWord;
	
begin			
	if self.isIgnoreWord then
		pAllIgnoredWords.addString(pWordToCheckLower);
		self.isIgnoreWord	:=	false;
		
	elseif self.isIgnoreOnce then
		self.isIgnoreOnce	:=	false;
						
	elseif self.isAddWord then
		pSpellAgentObj.trxSpellWordCreate(	pSpellRootObj,
											pSpellRootObj,
											pWordToCheckLower,
											newWordObj);
		self.isAddWord	:=	false;
		
	elseif self.replaceAll &lt;&gt; "" then
		pWordToCheck	:=	self.replaceAll;
		pAllReplacementWords.cnEcAdd(pWordToCheckLower, self.replaceAll);
		self.replaceAll	:=	"";
		
	elseif self.replaceOnce &lt;&gt; "" then
		pWordToCheck		:=	self.replaceOnce;
		self.replaceOnce	:=	"";
		
	endif;		
end;</source>
        <access>protected</access>
        <Parameter name="pAllIgnoredWords" type="CnEcArray" usage="io"/>
        <Parameter name="pSpellAgentObj" type="CnEcSpellAgent" usage="io"/>
        <Parameter name="pWordToCheckLower" type="String" usage="io"/>
        <Parameter name="pSpellRootObj" type="CnEcSpellRoot" usage="io"/>
        <Parameter name="pWordToCheck" type="String" usage="io"/>
        <Parameter name="pAllReplacementWords" type="CnEcDualStringArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getAlternateWordsByMetaphone" id="207aa4e0-c1b4-4d2b-ad91-3ee1d3e75681">
        <source>getAlternateWordsByMetaphone(pWord : String; pAllAlternatives : StringArray io) protected;

vars
	spellRootObj		: CnEcSpellRoot;
	iterObj				: Iterator;
	startChar			: String;
	alternateWordObj	: CnEcSpellWord;
	metaphoneValue		: String;
	metaphoneLength		: Integer;	
	
begin
	spellRootObj	:=	app.myBaseRoot.getSpellRoot();
	iterObj			:=	spellRootObj.allSpellWordsByMetaphone.createIterator();
	metaphoneValue	:=	self.getMetaphone(pWord);
	spellRootObj.allSpellWordsByMetaphone.startKeyGeq(metaphoneValue, iterObj);
	pAllAlternatives.clear();

	while (iterObj.next(alternateWordObj)) and alternateWordObj.metaPhoneName = metaphoneValue do
		pAllAlternatives.add(alternateWordObj.name);
	endwhile;
	
	// while we have no results widen the search
	startChar := metaphoneValue[1:1]; 
	
	while metaphoneValue.length &gt; 1 and pAllAlternatives.size() = 0 do
		metaphoneValue := metaphoneValue[1:metaphoneValue.length() - 1];
		metaphoneLength := metaphoneValue.length; 
		spellRootObj.allSpellWordsByMetaphone.startKeyGeq(metaphoneValue, iterObj);
		
		while (iterObj.next(alternateWordObj)) and alternateWordObj.metaPhoneName[1:1] = startChar do 
			if alternateWordObj.metaPhoneName = metaphoneValue then
				pAllAlternatives.add(alternateWordObj.name);
			else
				if alternateWordObj.soundexName.length &gt; metaphoneLength then
					if alternateWordObj.soundexName[1:metaphoneLength] = metaphoneValue then
						pAllAlternatives.add(alternateWordObj.name);
					endif;  
				endif;				
			endif;
		endwhile;
	endwhile;
epilog	
	delete iterObj;	
end;</source>
        <access>protected</access>
        <Parameter name="pWord" type="String"/>
        <Parameter name="pAllAlternatives" type="StringArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getAlternateWordsBySoundex" id="2a8f9085-3dbd-438b-9139-60504d4edebc">
        <source>getAlternateWordsBySoundex(pWord : String; pAllAlternatives : StringArray io) protected;

vars
	spellRootObj		: CnEcSpellRoot;
	iteratorObj			: Iterator;
	startChar			: String;
	alternateWordObj	: CnEcSpellWord;
	soundexValue		: String;
	soundexLength		: Integer;
	
begin
	spellRootObj	:=	app.myBaseRoot.getSpellRoot();
	iteratorObj		:=	spellRootObj.allSpellWordsBySoundex.createIterator();
	soundexValue	:=	self.getSoundex(pWord);
	spellRootObj.allSpellWordsBySoundex.startKeyGeq(soundexValue, iteratorObj);
	pAllAlternatives.clear();

	while (iteratorObj.next(alternateWordObj)) and alternateWordObj.soundexName = soundexValue do
		pAllAlternatives.add(alternateWordObj.name);
	endwhile;
	
	// while we have no results widen the search
	startChar := soundexValue[1:1]; 
	
	while soundexValue.length &gt; 1 and pAllAlternatives.size() = 0 do
		soundexValue := soundexValue[1:soundexValue.length() - 1];
		soundexLength := soundexValue.length; 
		spellRootObj.allSpellWordsBySoundex.startKeyGeq(soundexValue, iteratorObj);
		
		while (iteratorObj.next(alternateWordObj)) and alternateWordObj.soundexName[1:1] = startChar do 
			if alternateWordObj.soundexName = soundexValue then
				pAllAlternatives.add(alternateWordObj.name);
			else
				if alternateWordObj.soundexName.length &gt; soundexLength then
					if alternateWordObj.soundexName[1:soundexLength] = soundexValue then
						pAllAlternatives.add(alternateWordObj.name);
					endif;  
				endif;				
			endif;
		endwhile;
	endwhile;
epilog	
	delete iteratorObj;	
end;</source>
        <access>protected</access>
        <Parameter name="pWord" type="String"/>
        <Parameter name="pAllAlternatives" type="StringArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getMetaphone" id="cc99dd9f-d4c7-4c0d-b127-999ebab087eb">
        <source>getMetaphone(pWord:String):String protected;

vars
	metaphoneObj	: CnEcMetaphone;
	
begin
	create metaphoneObj transient;
	metaphoneObj.updateMe(pWord);
	return metaphoneObj.getTransform(5);
epilog
	delete metaphoneObj;	
end;</source>
        <access>protected</access>
        <Parameter name="pWord" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSoundex" id="e9c6e478-9080-4e5f-90df-849b314dcc40">
        <source>getSoundex(pWord:String):String protected;

vars
	soundexObj	: CnEcSoundex;
	
begin
	create soundexObj transient;
	soundexObj.updateMe(pWord);
	return soundexObj.getTransform(5);
epilog
	delete soundexObj;	
end;</source>
        <access>protected</access>
        <Parameter name="pWord" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isCheckProse" id="3d8c311e-659b-420c-8620-97ff0aff25a2">
        <updating/>
        <source>isCheckProse(pProse:String; pCheckedProse:String output):Boolean updating;
// -----------------------------------------------------------------------------
// Created:		09 December 2001 by cnwdad1
//
// Purpose:		Checks the specified prose, and returns the updated string.
//
// Parameters:	pProse - The prose to be checked.
//				pCheckedProse - The checke and updated prose.
//
// Returns:		True if the prose was updated, otherwise false.  The checked
//				prose is always return in the output pCheckedProse parameter,
//				regardless of whether it was updated or not.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	updatedProse	: String;
	
begin
	updatedProse	:=	self.checkProse(pProse);
	pCheckedProse	:=	updatedProse;
epilog
	return (updatedProse &lt;&gt; pProse);
end;</source>
        <Parameter name="pProse" type="String"/>
        <Parameter name="pCheckedProse" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
