    <JadeMethod name="cloneSelf" id="ab9593c0-7581-4d91-9d5a-8665a63b49f2">
        <source>cloneSelf(bTransient: Boolean): SelfType;
// ---------------------------------------------------------------------------
// Created:     20 January 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
//25 Nov 2019 jlger1	TFS 47132 - in testing was getting error4s if invalid operator or propetrty
vars
clonedCriteriaLine		: CM_SelectorCriteriaLine;
	clonedProp				: CM_QueryProperty;
	clonedOp				: CM_QueryOperator;
	invalidObj : Boolean;
begin
	clonedCriteriaLine := inheritMethod(bTransient);

	on Exception do app.handleDeletedObject(exception,self.myQueryProperty,invalidObj);
	on Exception do app.handleDeletedObject(exception,self.myQueryOperator,invalidObj);
	clonedProp := self.myQueryProperty.cloneSelf(bTransient);
	if invalidObj then
		delete clonedCriteriaLine;
		return null;
	endif;
	
	clonedCriteriaLine.myQueryProperty := clonedProp;
	
	clonedOp := self.myQueryOperator.cloneSelf(bTransient);
	if invalidObj then
		delete clonedCriteriaLine;
		return null;
	endif;
	
	self.myQueryOperator.cloneReferences(clonedOp);
	
	
	clonedCriteriaLine.myQueryOperator := clonedOp;
	
	return clonedCriteriaLine;
end;</source>
        <Parameter name="bTransient" type="Boolean"/>
        <ReturnType type="SelfType"/>
    </JadeMethod>
