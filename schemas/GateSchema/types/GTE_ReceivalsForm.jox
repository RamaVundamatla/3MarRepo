    <JadeMethod name="displayRowBookingRef" id="64733ff9-e4db-4cbd-808b-880d4137590d">
        <source>displayRowBookingRef(pBookingRef : CM_BookingRef) : String;
// ---------------------------------------------------------------------------
// Created:     14 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	opCode,
	voyCode,
	str			: String;

begin

	if self.isDataFiltered then
		// data is filtered
		if filterOperatorCode &lt;&gt; null and 
		   filterOperatorCode &lt;&gt; pBookingRef.operatorCode then 
		   	return null;
		endif;

		if filterBookingReference &lt;&gt; null and not pBookingRef.bookingReference.startsWith(filterBookingReference) then
		   //filterBookingReference &lt;&gt; pBookingRef.bookingReference then PAR4928
		   	return null;
		endif;
	endif;
	
	if pBookingRef.myOperator &lt;&gt; null then
		opCode := pBookingRef.operatorCode;
	endif;
	
	if pBookingRef.myVoyage &lt;&gt; null then
		voyCode := pBookingRef.myVoyage.code;
	endif;
	
	str := opCode &amp; Tab &amp;
		   pBookingRef.bookingReference &amp; Tab &amp;
		   pBookingRef.vesselCode &amp; Tab &amp;
		   voyCode &amp; Tab &amp;
//		   pBookingRef.quantity.String; // dh 29/2/2008 ccms 1618 for individual br items
		   pBookingRef.getTotalQuantity.String;
	
	return str;
	 
end;</source>
        <Parameter name="pBookingRef" type="CM_BookingRef"/>
        <ReturnType type="String"/>
    </JadeMethod>
