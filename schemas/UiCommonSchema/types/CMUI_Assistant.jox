    <JadeMethod name="comboBoxDataAccessController" id="ec4bda4b-528d-44b7-92e6-2d9eb7cec127">
        <source>comboBoxDataAccessController(pCmb : ComboBox input; pClass : Class; pDataAccess : CM_DataAccessController);
// ---------------------------------------------------------------------------
// Created:     05 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpCombo	: ComboBox;
begin

	tmpCombo := pCmb;
	
//	pCmb.sorted := false;
	tmpCombo.listCollection(app.myRoot.allDataAccessControllers, true, 0);
	
	if pDataAccess &lt;&gt; null then
		tmpCombo.text := self.displayEntryDataAccess(pDataAccess, pClass);
		tmpCombo.listObject := pDataAccess;
	endif;

end;</source>
        <Parameter name="pCmb" type="ComboBox" usage="input"/>
