epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbFileType_click" id="227757fa-be02-4039-a41f-607f9ecac8af">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbFileType_click(_combo: ComboBox input) updating;
/*
Date		Who		Reason
21/03/2012	cnwcs5	Initial creation - CCMS POL 2144 / Par 29312 - Extract Baplie by Operator
*/
vars

begin
	self.tblDetail.setValueByControlName(_combo.name, _combo.text);
	self.setTableForFileType(_combo.text);
epilog

end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbFormat_lostFocus" id="a5c3a1a8-2c87-4e03-bf4f-4046520af40e">
