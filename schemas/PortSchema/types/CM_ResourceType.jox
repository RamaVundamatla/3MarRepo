    <JadeMethod name="validateForCreate" id="effa2401-0041-43cf-aebb-8f8972de08f5">
        <source>validateForCreate();
/*
Date				Who		Reason
21 December 2009	conkc1	Initial creation
13 Jan 2023			navhl20	Defect 56121: MTN - Error 1310 When creating a To Do Task resource
*/

vars
	resourceType : CM_ResourceType;
begin
	/*resourceType := app.myRoot.allTaskResourceTypes[self.code];  //01/08/2016 cnwma1 TFS #2447
	if resourceType &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.code.String, null, null);
	endif;*/
	foreach resourceType in app.myRoot.allTaskResourceTypes do    //01/08/2016 cnwma1 TFS #2447
		//where resourceType.type = TODO_TYPE_GROUP_TI or resourceType.type = TODO_TYPE_GROUP_ALL do // ### TFS #56635[54261] 22NOV2022 NAVAB1  //13.01.2023 navhl20 TFS 56121

		if resourceType.code.toUpper = self.code.toUpper then
			app.raiseCMException1(VB_DUPLICATED_ITEM, self.code.String, null, null);
		endif;
	endforeach;

	self.validateMe;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="53eee6a0-58d1-4004-97ed-2403d188f9b2">
        <source>validateForDelete();
/*
Date		Who		Reason
21 December 2009	conkc1	Initial creation
*/
vars

begin
	if self.hasBeenUsed = true then
		app.raiseCMException1(ResourceCanNotDelete, '"' &amp; self.code &amp; '" - ', null, null);
	endif;
	
	if self.isMapped(null) = true then
		app.raiseCMException1(ResourceCanNotDelete, '"' &amp; self.code &amp; '" - ', null, null);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="9796a7a3-ea60-4cfb-b618-cf890bd0aad9">
        <source>validateForUpdate();
/*
Date				Who		Reason
21 December 2009	conkc1	Initial creation
*/
vars

begin
	self.validateMe;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateMe" id="66ec7cfd-9f89-417f-8386-4cbc66f3d7a7">
        <source>validateMe();
/*
Date		Who		Reason
21/12/2009	conkc1	Initial creation
01/08/2016	cnwma1 	TFS #2447:Adding duplicate gives error
06/04/2020	jlgdap1	TFS 48977 STWO Unable to add enough digits for to do task resource
*/
vars
	realMe : SelfType;
begin
	realMe := self.pxyGetRealObject();
	
	if realMe &lt;&gt; null then
		if realMe.type &lt;&gt; self.type then // ### TFS #56635[54261] 18NOV2022 NAVAB1
			//app.raiseCMException(Respour_type_cannot_changed, null, null);				//navra1 - 13th March 2024 - BUG 62783
			app.raiseCMWarning(Todo_type_changeT, null, null, null);						//navra1 - 13th March 2024 - BUG 62783
		endif;
	endif;
	
	if self.unitDescription = null then
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(ResourceUnitDescription), null, null); // cnwdb2	PAR 35364
	endif;
	
	if self.description = null then
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(ResourceDescription), null, null);
	endif;
	
	if self.decimalPlaces &gt; 4 then											// TFS 48977
		app.raiseCMException(Not_have_more_than_decim_place, null, null);	// TFS 48977
	endif;																	// TFS 48977
epilog

end;</source>
    </JadeMethod>
</Class>
