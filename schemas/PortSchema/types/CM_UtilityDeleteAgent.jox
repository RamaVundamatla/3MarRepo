    <JadeMethod name="utlDeleteTimeSlot" id="7e27e4f8-ed7e-4a24-96b6-c9935535ddcd">
        <source>utlDeleteTimeSlot(pTimeSlot : CM_TimeSlotEntity; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     08 May 2007 by cnwyl1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	toDelete : CM_TimeSlotEntity;
	tmpTerm : CM_Terminal;
begin

	self.initialiseActivity();

	if pTimeSlot = null then
		app.raiseCMException1(ERR_DEL_NULLOBJECT, 'Time Slot', null, null);
		return;
	endif;
	toDelete := pTimeSlot;
	tmpTerm := toDelete.getMyTerminal();
	
	if not self.exclusiveLockObjectToDelete(toDelete) then
	    // toDelete is null, invalid or has already been deleted
	    return;
	endif;

	if _passport.noErrors then
		self.myDeleteAuditAgent.audDeleteGeneric(toDelete);
		if tmpTerm &lt;&gt; null then
			toDelete.causeEvent(tmpTerm.getTerminalEvent(Event_TimeSlotStd_Delete), false, null);
		endif;
	endif;

	if _passport.noErrors then
		toDelete.erase(NORMAL_ERASE);
	endif;
	

end;
</source>
        <Parameter name="pTimeSlot" type="CM_TimeSlotEntity"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
