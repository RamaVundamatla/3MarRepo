    <JadeMethod name="doResizeControls" id="10e79463-977a-4351-ab80-eaa7a8dc61c5">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 February 2015	cnwndl1	Initial creation	Par 35604

*/

vars

	str : String;
	stdLeft : Real;
	top : Real;
	stdWidth : Real;
	stdHeight : Real;
	btnWidth : Real;
	btnLeft : Real;
	arrowLeft : Real;
	arrowWidth : Real;
	tabIndex : Integer;

begin

	self.setResizeableMarginAndFontSize();
	tabIndex := 4000;
	stdLeft :=  self.resizedMargin;
	top := self.resizedMargin;
	stdWidth := self.clientWidth - 2 - self.resizedMargin - self.resizedMargin;
	stdHeight := self.getStdControlHeight;
	btnWidth := stdWidth / 3;
	
	if _initialSetup then
		self.cmbRakePos.setAndIncrementTabIndex( tabIndex );
		self.cmbRakePos.visible := true;
	endif;
	self.cmbRakePos.move(	stdLeft,
							top,
							stdWidth,
							stdHeight );
	if _initialSetup then						
		self.populateCmbRakePos();
	endif;
	
	top := self.cmbRakePos.top + self.cmbRakePos.height + self.resizedMargin;
	if _initialSetup then
		self.cmbWagon.setAndIncrementTabIndex( tabIndex );
		self.cmbWagon.visible := true;
	endif;
	self.cmbWagon.move(	stdLeft,
						top,
						stdWidth,
						stdHeight );
	
	if _initialSetup then
		self.btnAddWagon.setAndIncrementTabIndex( tabIndex );
		self.btnAddWagon.pictureDisabled := self.btnAddWagon.picture;
		self.populateCmbWagon();
	endif;
							
	//top := self.cmbWagon.top + cmbWagon.height + ( stdHeight / 2 )  + margin;
	top := self.cmbWagon.top + cmbWagon.height + self.resizedMargin;
	btnLeft := btnWidth;
	if _initialSetup then
		self.lblMessage.setAndIncrementTabIndex( tabIndex );
		self.lblMessage.visible := true;
	endif;
	self.lblMessage.move(	stdLeft,
							top,
							stdWidth,
							stdHeight * 1.5 );
						
	top := self.lblMessage.top + self.lblMessage.height + self.resizedMargin;
	if _initialSetup then
		self.frmCargoBtns2.setAndIncrementTabIndex( tabIndex );
		self.frmCargoBtns2.visible := true;
	endif;
	self.frmCargoBtns2.move(	stdLeft,
								top,
								stdWidth,
								stdHeight + 12 );	//14 Nov 2011	NDL	Par 28674
							
	top := self.frmCargoBtns2.top + self.frmCargoBtns2.height;
	if _initialSetup then
		self.frmCargoBtns.setAndIncrementTabIndex( tabIndex );
		self.frmCargoBtns.visible := true;
	endif;
	self.frmCargoBtns.move(	stdLeft,
							top,
							stdWidth,
							stdHeight + 12 );
							
														
	top := self.frmCargoBtns.top + self.frmCargoBtns.height + self.resizedMargin;
	if _initialSetup then
		self.frmWagonGraphic.setAndIncrementTabIndex( tabIndex );
		self.frmWagonGraphic.visible := true;
	endif;
	self.frmWagonGraphic.move(	stdLeft,
								top,
								stdWidth,
								stdHeight  - 6 );
								
//	top := self.frmWagonGraphic.top + self.frmWagonGraphic.height + (stdHeight / 2);
	top := self.frmWagonGraphic.top + self.frmWagonGraphic.height + self.resizedMargin;
	btnWidth := ( stdWidth / 3 ) - self.resizedMargin; 
	arrowLeft := btnWidth / 4;
	arrowWidth := btnWidth / 2;
	if _initialSetup then
		self.btnRakeBack.setAndIncrementTabIndex( tabIndex );
		self.btnRakeBack.visible := true;
	endif;
	self.btnRakeBack.move(	arrowLeft,
							top,
							arrowWidth,
							stdHeight);
							
	btnLeft := stdLeft + btnWidth + self.resizedMargin;
	if _initialSetup then
		self.btnWagonChecks.setAndIncrementTabIndex( tabIndex );
		self.btnWagonChecks.visible := true;
	endif;
	self.btnWagonChecks.move(	btnLeft,
								top,
								btnWidth,
								stdHeight );
								
	btnLeft := btnLeft + btnWidth + self.resizedMargin + arrowLeft;
	if _initialSetup then
		self.btnRakeForward.setAndIncrementTabIndex( tabIndex );
		self.btnRakeForward.visible := true;
	endif;
	self.btnRakeForward.move(	btnLeft,
								top,
								arrowWidth,
								stdHeight );
								
	top := self.btnWagonChecks.top + self.btnWagonChecks.height + self.resizedMargin;
	btnLeft := btnWagonChecks.left;
	if _initialSetup then
		self.btnConfirmWagon.setAndIncrementTabIndex( tabIndex );
		self.btnConfirmWagon.visible := true;
	endif;
	self.btnConfirmWagon.move(	btnLeft,
								top,
								btnWidth,
								stdHeight );
	
	if _initialSetup then
		self.setReturningFromAnotherForm();	
	endif;
	
	self.shuffleControls();
	
	self.displayWagon();
								
								
	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="drawBoxcarBody" id="713dfbb6-b738-4a47-98e4-8d88367e30fd">
        <source>drawBoxcarBody(	btn : Button io;
				wagon : CM_Wagon;
				btnLeft : Real;
				btnTop : Real;
				btnWidth : Real;
				btnHeight : Real
				);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 March 2013	cnwndl1	Initial creation	Par 31278

*/

vars

	doorPosArray : IntegerArray;
	wagCont : CM_WagonController;
	numTis : Integer;
	sections : Integer;
	sectionWidth : Real;
	index : Integer;
	startX : Real;
	startY : Real;
	endX : Real;
	endY : Real;
	newX : Real;
	increment : Real;
	newY : Real;

begin

	btn.clearGraphics;

	create doorPosArray transient;
	wagon.getBoxcarLengthAndDoorPosition(sections,doorPosArray);
	if not wagon.allLocationsControllersArray.isEmpty then
	//	wagCont := wagon.allLocationsControllersArray[1];
	//	if wagCont &lt;&gt; null then
	//		numTis := wagCont.allTrackedItems.size;
	//	endif;
		//20 Aug 2013	NDL	Par 32174
		numTis := wagon.getCargoCountForBoxcarGraphic( DISPLAY_MODE_ACTUAL );
	endif;

	btn.caption := null;

	btn.autoRedraw := true;
	
	btn.drawWidth := 1;
	sectionWidth := btnWidth / sections;
	
	startX := btnLeft;
	startY := btnTop;
	endX := btnLeft + btnWidth;
	endY := btnTop + btnHeight;
	
	
	foreach index in 1 to sections do
		if index = sections then
			newX := endX;
		else
			//draw the section uprights
			newX := startX + sectionWidth;
			btn.drawLine( newX, startY, newX, endY, Gray );
		endif;
		//draw the section diagonals
		if doorPosArray.includes(index) then
			//draw door
			increment := ( endY - startY ) / 6; // gap between horizontal lines on door.
			newY := startY + increment;
			while newY &lt; endY do
				btn.drawLine(startX, newY, newX, newY, Gray);
				newY := newY + increment;
			endwhile;
		elseif index.isOdd then
			btn.drawLine( startX, startY, newX, endY, Gray );
		else
			btn.drawLine( startX, endY, newX, startY, Gray );
		endif;
		startX := newX;
	endforeach;
	
	btn.drawWidth := 2;
	startX := btnLeft;
	
	//draw the body surround
	btn.drawRectangle( startX, startY, endX, endY, Black);
	
	// write the number of items inside
	startX := startX + 2;
	btn.drawTextAlign := Window.DrawTextAlign_Left;
	btn.drawTextAt( numTis.String, startX, startY, Black );
	

epilog

	delete doorPosArray;

end;</source>
        <Parameter name="btn" type="Button" usage="io"/>
        <Parameter name="wagon" type="CM_Wagon"/>
        <Parameter name="btnLeft" type="Real"/>
        <Parameter name="btnTop" type="Real"/>
        <Parameter name="btnWidth" type="Real"/>
        <Parameter name="btnHeight" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawEmptyWagonChassis" id="3e8e94f5-fd51-4420-b707-47b3e2711c6d">
        <updating/>
        <source>drawEmptyWagonChassis( _y1 : Real output; _y2 : Real output) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 August 2010	cnwndl1	Initial creation	Par 25215
*/


vars

	deckBottom : Real;
	deckTop : Real;
	deckWidth : Real;

begin

	self.frmWagonGraphic.clearGraphics();
	self.frmWagonGraphic.autoRedraw := true;

	deckWidth := self.frmWagonGraphic.width - 1;
	deckBottom := self.frmWagonGraphic.height - 12;
	deckTop := self.frmWagonGraphic.height - 20;
	_y1 := deckBottom;
	_y2 := self.frmWagonGraphic.height - 15;
	
	self.frmWagonGraphic.drawRectangle(0, deckBottom, deckWidth, deckTop,Black);
	
epilog

end;</source>
        <Parameter name="_y1" type="Real" usage="output"/>
        <Parameter name="_y2" type="Real" usage="output"/>
    </JadeMethod>
    <JadeMethod name="drawSkeletonCarArms" id="1829c0d5-617c-4bda-b3cd-7f15d5e3531a">
        <source>drawSkeletonCarArms(btn : Button io;
				wagon : CM_Wagon;
				btnLeft : Real;
				btnTop : Real;
				btnWidth : Real;
				btnHeight : Real);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 September 2016	cnwmp6	Initial creation	TFS 2533

*/

vars
	interval: Real;
	index: Integer;
	x: Real;
	indent: Integer;
begin
	btn.clearGraphics;
	btn.caption := null;
	btn.autoRedraw := true;

	btn.drawFillColor := btn.backColor;
	btn.drawFilledRectangle(btnLeft, btnTop, btnWidth, btnHeight, btn.backColor);
	
	btn.drawFillColor := Brown;

//	if _numTIs &gt; 0 then
		indent := (btnWidth * 0.05).Integer;
		btn.drawFilledRectangle(btnLeft + indent, btnTop + 6, btnLeft + btnWidth - indent, btnTop + btnHeight, Brown);
		btn.drawLine(btnLeft + indent, btnTop + 15, btnLeft + btnWidth - indent, btnTop + 15, Black);
		btn.drawLine(btnLeft + indent, btnTop + 25, btnLeft + btnWidth - indent, btnTop + 25, Black);
//	endif;

	interval := btnWidth / 5;
	foreach index in 1 to 4 do
		x := (index * interval).Integer;
		btn.drawRectangle(x, btnTop, x + 1, btnTop + btnHeight, Black);
	endforeach;
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="io"/>
        <Parameter name="wagon" type="CM_Wagon"/>
        <Parameter name="btnLeft" type="Real"/>
        <Parameter name="btnTop" type="Real"/>
        <Parameter name="btnWidth" type="Real"/>
        <Parameter name="btnHeight" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawWagonWheels" id="439acc1a-8d55-46bc-aa68-dab10a1d6b93">
        <source>drawWagonWheels();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 August 2010	cnwndl1	Initial creation	Par 25215

*/

constants
	WheelDiameter  = 9;
vars

	leftHandSideOfWheel : Real;
	rightHandSideOfWheel : Real;
	wheelBottom : Real;
	wheelTop : Real;
	rightOfWheel2 : Real;
	leftOfWheel3 : Real;
	widthBetweenWheels : Real;
	text : String;
	textWidth : Real;
	offSet : Real;
	
begin

	wheelBottom := self.frmWagonGraphic.height;
	wheelTop := wheelBottom - WheelDiameter;
	
	//draw wheels
	self.frmWagonGraphic.drawFillStyle:=DrawFillStyle_Solid;
	self.frmWagonGraphic.drawFillColor := Yellow;
	//wheel 1
	leftHandSideOfWheel := 0;
	rightHandSideOfWheel := leftHandSideOfWheel + WheelDiameter;
	self.frmWagonGraphic.drawEllipse(leftHandSideOfWheel, wheelTop, rightHandSideOfWheel, wheelBottom, Black);
	
	self.frmWagonGraphic.drawFillStyle:=DrawFillStyle_Transparent;
	//wheel 2
	leftHandSideOfWheel := 10;
	rightHandSideOfWheel := leftHandSideOfWheel + WheelDiameter;
	rightOfWheel2 := rightHandSideOfWheel;
	self.frmWagonGraphic.drawEllipse(leftHandSideOfWheel, wheelTop, rightHandSideOfWheel, wheelBottom, Black);
	// wheel 4
	leftHandSideOfWheel := self.frmWagonGraphic.width - 10;
	rightHandSideOfWheel := leftHandSideOfWheel + WheelDiameter;
	self.frmWagonGraphic.drawEllipse(leftHandSideOfWheel, wheelTop, rightHandSideOfWheel, wheelBottom, Black);
	//wheel 3
	leftHandSideOfWheel := leftHandSideOfWheel - 10;
	leftOfWheel3 := leftHandSideOfWheel;
	rightHandSideOfWheel := leftHandSideOfWheel + WheelDiameter;
	self.frmWagonGraphic.drawEllipse(leftHandSideOfWheel, wheelTop, rightHandSideOfWheel, wheelBottom, Black); 
	
	widthBetweenWheels := leftOfWheel3 - rightOfWheel2;
	text := cmbWagon.text.trimBlanks;
	
	if text &lt;&gt; null then
		self.frmWagonGraphic.fontSize := 9;
		textWidth := self.frmWagonGraphic.getTextExtent(text);
		offSet := ( widthBetweenWheels - textWidth ) / 2;
		self.frmWagonGraphic.drawTextAt(text, rightOfWheel2 + offSet,  wheelTop - 4,  Black);
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getAllWagonsForPartial" id="066b5b2e-b062-411f-9bd5-7183fbb16f86">
        <updating/>
        <source>getAllWagonsForPartial(_text : String) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 August 2010	cnwndl1	Initial creation	Par 25215

*/

vars

	iter: Iterator;
	wagon : CM_Wagon;
	id ,startText: String;
	pos : Integer;
	allWagons : CM_WagonSet;
	index : Integer;
	
begin

	create allWagons transient;
	pos := self.cmbWagon.selStart;
	iter := self.allDynaWagons.createIterator;
	
	if self.isIdReversed then
		startText:=_text.reverse.toUpper;
	else
		startText:=_text.toUpper;
	endif;
	
	if startText = null then
		self.populateCmbWagon();
	else
		self.allDynaWagons.startKeyGeq(startText,iter);
		while iter.next(wagon) do
			self.allDynaWagons.getIteratorKeys(id,iter);
			if  id[1:startText.length] &lt;&gt; startText then
				break;
			endif;
			allWagons.add(wagon);
		endwhile;
	endif;
	
	if not allWagons.isEmpty then
		self.cmbWagon.clear();
		foreach wagon in allWagons do
			index := self.cmbWagon.addItem(wagon.id);
			self.cmbWagon.itemObject[index] := wagon;
		endforeach;
		self.cmbWagon.text:=_text;
		self.cmbWagon.selStart:=pos;
		self.cmbWagon.closeDropDown();
		self.cmbWagon.showDropDown();
	endif;
	
epilog

	delete iter;
	delete allWagons;		// fix transient leak
	
end;</source>
        <Parameter name="_text" type="String"/>
    </JadeMethod>
