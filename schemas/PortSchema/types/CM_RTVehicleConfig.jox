    <JadeMethod name="createDefaultConfig" id="0b66a0c4-184a-4613-9060-2a09a60a961e">
        <options>4</options>
        <source>createDefaultConfig() :CM_RTVehicleConfig typeMethod;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 March 2023	jlier1	Initial creation 57064

*/
constants	
	PrimaryTaskView = "primary tasks";
vars
	rtVehicleConfig : CM_RTVehicleConfig;
	theName : String;
	theEntDef  : EntTableDef;
begin
	create rtVehicleConfig transient;
	rtVehicleConfig.taskViewMode:= CM_RTVehicleConfig.TASKVIEW_LIST;
	create rtVehicleConfig.myPrimaryTaskFields transient;
	theName:=rtVehicleConfig.getUniqueViewName &amp; CM_RTVehicleConfig.ETVIEW_SEPARATOR &amp; PrimaryTaskView;
	theEntDef:=app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_VehicleAppFields];
	rtVehicleConfig.myPrimaryTaskFields.set(theName,theName,theEntDef);
	rtVehicleConfig.myPrimaryTaskFields.addRowByName(ETRow_Id);
	rtVehicleConfig.myPrimaryTaskFields.addRowByName(ETRow_Info);
	rtVehicleConfig.myPrimaryTaskFields.addRowByName(ETRow_SourceLocation);
	rtVehicleConfig.myPrimaryTaskFields.addRowByName(ETRow_TargetLocation);
	
	return rtVehicleConfig;
epilog

end;</source>
        <ReturnType type="CM_RTVehicleConfig"/>
    </JadeMethod>
    <JadeMethod name="delete" id="c82f6815-6d69-4ba3-b0f4-4a882436fee3">
        <updating/>
        <source>delete() updating;
/*
Date		Who		Reason
21 September 2010	cnwer1	Initial creation	Par 35816
// 11 May 2018	jlgrs1	make delete Terminal work
*/
vars

	changeString : String;
	changeName : String;

begin
	if not self.isTransient and
	   not app.isGarbageCollectionProcess then
		if self.myTerminal &lt;&gt; null then
			changeName := self.myTerminal.code;
		endif;
		if self.myMachine &lt;&gt; null then
			if changeName &lt;&gt; null then
				changeName:= changeName &amp; " / ";	
			endif;
			changeName:= changeName &amp; self.myMachine.id;
		endif;
	
		changeString := "Deleted RT Vehicle Config for " &amp; changeName;
		app.createActivityHistory(	ActivityHistoryGeneralSys,	//_type : Integer;
									self.myTerminal,	//_terminal : CM_Terminal;
									null,	//_objectForExtraDetail : Object;
									changeString,	//_description : String;
									true,	//_insideTransaction : Boolean;
									false	//_temp: Boolean
									);
	endif;
									
	self.allStateData.purge; //epr par 25206
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getCargoDoorDirHookString" id="69be07a7-f138-4fdb-a3fd-af24076433b8">
        <source>getCargoDoorDirHookString(_ti : CM_TrackedItem) : String;
/*

Date		Who		Reason
04 August 2014	cnwer1	Initial creation PAR 34682 CCMS 2404

*/

vars
	cmifParams		: CMIF_LocationTransParams;
begin

	
	if self.myDoorDirectionHookCode = null then
		return null;
	endif;
	
	create cmifParams transient;
	cmifParams.isSource := true;

	cmifParams.myQueueTask:=null;
	cmifParams.myTrackedItem := _ti;

	cmifParams.myLocation :=_ti.myPrimaryActualLocation;
	
	
	return app.myHookAgent.runHookLinkPublic( self.myDoorDirectionHookCode.myHookType.hookType,	// _hookType : Integer;
											   self.myTerminal,							// _hookObject : CM_Object;
											   self,							// _receiver : Object;
											   cmifParams).String;
	
epilog
	delete cmifParams;


end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCargoEntTableRows" id="43d7091c-5010-4b1f-9ce3-7db97a28820b">
        <source>getCargoEntTableRows() : EntTableRowArray;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 April 2022	jlier1	Initial creation

*/

vars
	allEntTableRows : EntTableRowArray;
	entTableGroup : EntTableGroup;
	entTableRow 	: EntTableRow;
begin
	if  self.myPrimaryCargoFields = null or self.myPrimaryCargoFields.allEntTableRows.first = null then
		create allEntTableRows transient;
		entTableGroup := app.myRoot.myEntTableDataRoot.allEntTableGroups[ETGrp_TrackedItemDetails];
		if entTableGroup &lt;&gt; null then
			entTableRow := entTableGroup.allEntTableRowsByName[ETRow_Id];
			if entTableRow &lt;&gt; null then
				allEntTableRows.add(entTableRow);
			endif;
			entTableRow := entTableGroup.allEntTableRowsByName[ETRow_Info];
			if entTableRow &lt;&gt; null then
				allEntTableRows.add(entTableRow);
			endif;
			entTableRow := entTableGroup.allEntTableRowsByName[ETRow_Location];
			if entTableRow &lt;&gt; null then
				allEntTableRows.add(entTableRow);
			endif;
		endif;
	else
		allEntTableRows:=self.myPrimaryCargoFields.allEntTableRows;
	endif;
	
	return allEntTableRows;
epilog

end;</source>
        <ReturnType type="EntTableRowArray"/>
    </JadeMethod>
    <JadeMethod name="getCargoLocationHookString" id="eb2f8e70-954e-4f0c-8bff-6a35cdb210b7">
        <source>getCargoLocationHookString(_ti : CM_TrackedItem) : String;
/*

Date		Who		Reason
04 August 2014	cnwer1	Initial creation PAR 34682 CCMS 2404

*/

vars
	cmifParams		: CMIF_LocationTransParams;
begin
	create cmifParams transient;
	cmifParams.isSource := true;

	cmifParams.myQueueTask:=null;
	cmifParams.myTrackedItem := _ti;
	cmifParams.myLocation :=_ti.myPrimaryActualLocation;

	if self.myLocationHookCode = null then
		if cmifParams.myLocation = null then
			return null;
		endif;
		return cmifParams.myLocation.getFullId();
	endif;
	
	return app.myHookAgent.runHookLinkPublic( self.myLocationHookCode.myHookType.hookType,	// _hookType : Integer;
											   self.myTerminal,							// _hookObject : CM_Object;
											   self,							// _receiver : Object;
											   cmifParams).String;
	
epilog
	delete cmifParams;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
