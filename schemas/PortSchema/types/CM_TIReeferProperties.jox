    <JadeMethod name="createPackTempReadingIfReqd" id="b2e212ac-db82-4296-9558-2d119cdf855e">
        <updating/>
        <source>createPackTempReadingIfReqd() updating;
/*
Date		Who		Reason
23 August 2010	cnwdap1	Initial creation
*/
vars

begin
	if self.packTempDetails = null then
		if self.isTransient then
			create self.packTempDetails transient;
		else
			create self.packTempDetails persistent;
		endif;
	endif;
			
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="94c4c648-84fe-441d-ac8b-ec13e665a2f6">
        <updating/>
        <source>delete() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 December 2009	cnwdap1	Initial creation
*/
// 19 May 2017	cnwrs1	TFS 4259 _ Penn Seaboard implimentation
vars
	 invalid : Boolean;
begin

	on Exception do app.handleDeletedObject(exception, self.packTempDetails, invalid);  // TFS 45590
	if self.packTempDetails &lt;&gt; null then
		delete self.packTempDetails;
	endif;
	if self.isTransient then
		if self.generator &lt;&gt; null then
			delete self.generator;
		endif;
		if self.cou &lt;&gt; null then
			delete self.cou;
		endif;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="deletePackTempDetails" id="41d60781-edc3-4408-8ea3-b57a1834a4f7">
        <updating/>
        <source>deletePackTempDetails() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 November 2009	cnwdap1	Initial creation
*/
vars

begin
	if self.isTransient and self.packTempDetails &lt;&gt; null and self.packTempDetails.isTransient then
		delete self.packTempDetails;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="displayTempFahrenheit" id="655cfd6d-f892-4668-9487-11a4ab0582e1">
        <methodInvocation>mapping</methodInvocation>
        <source>displayTempFahrenheit(set: Boolean; _value: Boolean io) mapping;
/*
Purpose:			CCMS 1007 Allow for reefer details on booking and CM_TrackedItem, not just CM_Container
					Returns TRUE if this operator requires a display in Fahrenheit
Parameters:			

Return Value:		

Date		Who		Reason
25/11/2009	cnwdap1	Initial creation
*/
vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	_value := null;
	//epr par 32291 9/1/14
	if self.myParent = null then
		return;
	endif;
	
	if self.myParent.CM_TrackedItem.myOperator = null then
		return;
	endif;
	
	_value := self.myParent.CM_TrackedItem.myOperator.displayTempFahrenheit;
epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="erase" id="51fe5eb2-baf9-4680-90be-6b492c500d84">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 November 2009	cnwdap1	Initial creation
*/
// 24 May 2017	cnwrs1	TFS 4259 _ Penn Seaboard implimentation 
vars
	child	: CM_TrackedItem;
	iter	: Iterator;
	log 	: CM_DailyReeferTemp;
	invalid : Boolean;
	
begin

	//------------------------------------------------------------------
	//             Remove any cou it has 
	//------------------------------------------------------------------
	if self.cou &lt;&gt; null then
		child := self.cou;
		on Exception do app.handleDeletedObject( exception, child, invalid );
		if child.site &lt;&gt; TI_SITE_ONSHIP and
		   self.myParent.CM_Container &lt;&gt; null then //rs oct 2004 stopping garbage collection
			self.myParent.CM_Container.detachCOU(app.myPassport);
		endif;
		if not invalid then
			child.erase(_eraseLevel);
		endif;
		on Exception do null;
	endif;
	
	//------------------------------------------------------------------
	//             Remove any generator it has 
	//------------------------------------------------------------------
	if self.generator &lt;&gt; null then
		child := self.generator;
		on Exception do app.handleDeletedObject( exception, child, invalid );
		if child.site &lt;&gt; TI_SITE_ONSHIP and
		   self.myParent.CM_Container &lt;&gt; null then //rs oct 2004 stopping garbage collection
			self.myParent.CM_Container.detachGenerator(app.myPassport);
		endif;
		if not invalid then
			child.erase(_eraseLevel);
		endif;
		on Exception do null;
	endif;
	
	//And remove the packed temp details
	if packTempDetails &lt;&gt; null then
		delete packTempDetails;
	endif;

	inheritMethod(_eraseLevel);

epilog
	if iter &lt;&gt; null then
		delete iter;
	endif;
end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="generatorId" id="3acb8418-1d9c-4669-ac56-89baf534cda3">
