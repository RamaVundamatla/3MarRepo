    <JadeMethod name="refreshTableEntry" id="fe8202fd-eb23-4273-a958-ddf792ca6421">
        <updating/>
        <source>refreshTableEntry(_entry: CM_RTQueueEntry) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
13 April 2010	cnwer1	Initial creation
12 July 2018	jlgmd1	TFS #39292 - POL - Discharge job leaving details on Screen

*/

vars
	selectedEntry: CM_RTQueueEntry;
	allSelectedEntries : CM_RTQueueEntrySet ;
	allRTQueueEntriesShown : CM_RTQueueEntryArray;
begin
	
	if app.myVMAgent.showingTaskList or self.frmTaskTable.visible  then
	
		//epr par 25518 20/8/10 only refresh if not in discharge mode
		// epr par 26844 28/2/2010 problem with amending target location in discharge mode
		// if accept mode just set the focus to search field otherwise update the working entry
		if  self.isInDischargeMode and self.myVMAgent.getNextMoveState = VehicleMountedGenericAgent.ACCEPT_TASK then
			if self.txtSearch.text = null or self.txtSearch.text = app.getErrorString(Search) then	// TFS 39292
				//epr par 35217 19/11/14
				//if self.txtSearch.text = null and	self.tblTasks.rows &gt; 1 then		
				if self.tblTasks.rows &gt; 1 then
					self.clearTableData(self.tblTasks); //epr par 34603
				endif;	
				//epr par 35468 23/1/14
				//if self.txtSearch.text = null then
				self.txtSearch.setFocus();
				//endif;
			endif;
		else
			create allSelectedEntries transient;
			if  self.frmTaskTable.visible then
				//get the current selected entry
				self.getSelectedRTQueueEntries(allSelectedEntries);
			endif;
			
			if app.myVMAgent.isShowingFilterResults then
				create allRTQueueEntriesShown transient;
				if app.myVMAgent.isShowingFilterResultsWithTask(_entry,allRTQueueEntriesShown) then
					self.clearTableData(self.tblTasks);
					app.myVMAgent.loadTableFromRTQueueEntries(self.tblTasks,allRTQueueEntriesShown);
				endif;
			else
				app.myVMAgent.refreshTableEntry(self.tblTasks,_entry);
			endif;
			//if control has allocated then automatically select the task
			if self.myMachine.hasAllocatedQueueTasks and
				self.myMachine.isQueueEntryAllocated( _entry) then
				selectedEntry:=_entry;
			endif;
				
			
			if  self.frmTaskTable.visible then
				self.reselectRTQueueEntries(allSelectedEntries);
			endif;
		endif;
	elseif not app.myVMAgent.showingTaskList or self.frmGetTask.visible then
		self.loadTable(self.tblGetNext);
	endif;
	
	//status changed to unactioned
	if self.myVMAgent.myMachine.allCurrentQueueTasks.size = 0 then
		self.goToTaskFrame;
	else
		self.setupFrmMove;
	endif;
	
epilog
	delete allSelectedEntries;
	delete allRTQueueEntriesShown;
	// par 33401 1/2/14
	self.hasControlChangedTarget:=false; 
	self.hasControlChangedTwinTarget:=false;
end;</source>
        <access>protected</access>
        <Parameter name="_entry" type="CM_RTQueueEntry"/>
    </JadeMethod>
    <JadeMethod name="registerKeyCodes" id="ab792f07-5d52-4ef1-bb5e-16bcc4025520">
        <source>registerKeyCodes();
