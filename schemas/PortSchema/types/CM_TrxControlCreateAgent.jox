    <JadeMethod name="trxCreateRORODischargeCC" id="434f6eb2-28ac-4437-a6c5-9fc57a2f2c3a">
        <updating/>
        <source>trxCreateRORODischargeCC(_realROROController : CM_VoyageROROController input; _passport : CM_Passport input) updating;
/*
Purpose:			
Date				Who			Reason
JUNE 2011		CNWAB1		Initial creation
*/

vars

begin

// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);

	beginTransaction;
	app.myUtilityCA.utlCreateROROSlotDischargeCC(_realROROController, _passport);
//			

epilog
	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_realROROController" type="CM_VoyageROROController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
