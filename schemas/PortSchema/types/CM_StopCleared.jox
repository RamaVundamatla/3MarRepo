    <JadeMethod name="setStop" id="92b16bd9-c150-43f3-be78-e1a3b8547444">
        <updating/>
        <source>setStop( _tiTransCntrl : CMIF_TITransactionController ) updating, protected;
//setStop(_stopTable : CM_StopsTable)updating, protected;		// cnwrl1 31/08/2010 PAR 23697 - what it was
//--------------------------------------------------
// Created:	12 April 2005 By: cnwgd1
//--------------------------------------------------
// Purpose:	Set the stop details on this TITransaction object.
	
vars
	caption		: String;
	currentInfo	: String;
	maxLength	: Integer;
	case		: Integer;
	proxyTI		: CM_TrackedItem;
	stop		: CM_Stops;
	realStop	: CM_Stops;
	stopsTable	: CM_StopsTable;
	
begin
	
	//epr 2/8/12 Cash pro forma mode won't have stop table info
	if app.isInProformaMode or self.isStopClearedDocAction then
		return;
	endif;
	/* cnwrl1 31/08/2010 PAR 23697 - what it was
	if _stopTable &lt;&gt; null then
		self.stopDescription := _stopTable.heading;
		self.stopID := _stopTable.id;
	else
		app.raiseCMException1(REQUIRED_FIELD, 'myStopTable', null, null);
	endif;
	cnwrl1 31/08/2010 PAR 23697 - end of what it was */
	
	// the stop and stopsTable have already been validated!
	stop		:= _tiTransCntrl.myStop;
	stopsTable	:= stop.myStopsTable;
	
	self.setStopDescription( stopsTable.heading );
	self.setStopID( stopsTable.id );
	self.setClearanceExpiryDate( stop.clearanceExpiryDate );
	
	if stopsTable.requiresInfoType &lt;&gt; null then
		self.setRequiresInfoType( stopsTable.requiresInfoType );
		// Get the entered requiredInfo via the proxy TrackedItem
		proxyTI	:= app.myProxyManager.getProxyObject( _tiTransCntrl.myTrackedItem ).CM_TrackedItem;
		stopsTable.getDetailsForRequiredInfo( caption, currentInfo, maxLength, case, proxyTI );
		self.setRequiredInfo( currentInfo );
	endif;
	
	// cnwrl1 23/09/2010 PAR 23697 - start of coding
	if stop.isTransient then
		// do not expect ever to have a proxy as createProxyStops just creates transients
		realStop		:= stop.pxyGetRealObject().CM_Stops;
		
		if realStop = null and _tiTransCntrl.myTrackedItem &lt;&gt; null then
			// need to go directly to the persistent stop
			realStop	:= _tiTransCntrl.myTrackedItem.getStop( self.stopID );
		endif;
	else
		// not sure if we will ever get here as we only ever
		// set the stop referenceon the trx to the proxy.
		realStop := stop;
	endif;
	
	// we only want to attach the stop to the latest stop cleared transaction
	if realStop &lt;&gt; null then
		realStop.setMyStopClearTxn( null );
	endif;
	
	self.setMyStop( realStop );
	// cnwrl1 23/09/2010 PAR 23697 - end of coding
	
epilog
	
end;
</source>
        <access>protected</access>
        <Parameter name="_tiTransCntrl" type="CMIF_TITransactionController"/>
    </JadeMethod>
