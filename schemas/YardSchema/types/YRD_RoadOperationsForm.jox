    <JadeMethod name="setMyCurrentAttributes" id="c866fd9b-e289-47b9-aa7d-38b6ed978f6c">
        <updating/>
        <source>setMyCurrentAttributes(_obj : CM_Object) : Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 May 2010	cnwmh5	Initial creation #23634

*/

vars
	roadJob 		: CM_RoadJob;
	itemIndex 		: Integer;
	oldArea			: CM_TerminalArea;
	invalidObject	: Boolean;
	roadOpObject	: CMIF_RoadOpObject;
	objectSet		: Boolean;
begin
	on Exception do app.handleDeletedObject (exception, _obj, invalidObject);
	
	objectSet := false;
	
	if _obj.isKindOf(CM_WorkListEntry) then
		self.myCurrentWLE := _obj.CM_WorkListEntry;
		if self.myCurrentWLE.CM_WorkListEntry.job &lt;&gt; null and  
			self.myCurrentWLE.CM_WorkListEntry.job.isKindOf(CM_RoadJob) then
			self.myCurrentRoadJob := self.myCurrentWLE.CM_WorkListEntry.job.CM_RoadJob;
		endif;
		if self.myCurrentWLE &lt;&gt; null then
			self.myCurrentTrackedItem 	:= self.myCurrentWLE.myTrackedItem;
			self.myCurrentVehicle 		:= self.myCurrentWLE.getJobVehicle;
		endif;
		objectSet := true;
	elseif _obj.isKindOf(CM_Vehicle) then
		self.myCurrentVehicle :=_obj.CM_Vehicle;	
		if self.myCurrentVehicle.allRoadJobs.size = 1 then
			self.myCurrentRoadJob := self.myCurrentVehicle.allRoadJobs.first.CM_RoadJob;
		endif;
		objectSet := true;
	elseif _obj.isKindOf(CM_TrackedItem) then
		self.myCurrentTrackedItem:=_obj.CM_TrackedItem;
		if self.myCurrentTrackedItem.jobRoadReceive &lt;&gt; null then
			roadJob := self.myCurrentTrackedItem.jobRoadReceive;
		elseif self.myCurrentTrackedItem.jobRoadRelease &lt;&gt; null then
			roadJob := self.myCurrentTrackedItem.jobRoadRelease;
		endif;
		if roadJob &lt;&gt; null then
			self.myCurrentRoadJob := roadJob;
			self.myCurrentVehicle := roadJob.myVehicle;
		endif;
		objectSet := true;
	endif;
	
	return objectSet;
epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setNavigator" id="2b85dc6a-ed2b-40ee-800b-7c38f9205812">
        <updating/>
        <source>setNavigator(pObject : Object) updating;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lNavString : String;
begin
	self.mousePointer := Window.MousePointer_HourGlass;
	if pObject = null then
		lNavString := self.caption;
	elseif pObject.isKindOf(CM_Job) then
		lNavString := pObject.CM_Job.jobId &amp; " - " &amp; app.getErrorString (Job); // 11/09/2009 - cnwcs5 xlated
	elseif pObject.isKindOf(CM_TrackedItem) then
		lNavString := pObject.CM_TrackedItem.id;
	elseif pObject.isKindOf(CM_WorkListEntry) then
		lNavString := pObject.CM_WorkListEntry.getTreeDescription();
	elseif pObject.isKindOf(CM_Vehicle) then
		lNavString := pObject.CM_Vehicle.regNumber &amp; " - " &amp; app.getErrorString (Vehicle);	// 11/09/2009 - cnwcs5 xlated
	elseif pObject.isKindOf(CM_TerminalArea) then
		lNavString := pObject.CM_TerminalArea.id;
	else
		lNavString := self.caption;
	endif;			

	// Update the navigator
	self.setNavigatorHeading(lNavString); 

epilog
	self.mousePointer := Window.MousePointer_Default;

end;</source>
        <Parameter name="pObject" type="Object"/>
    </JadeMethod>
