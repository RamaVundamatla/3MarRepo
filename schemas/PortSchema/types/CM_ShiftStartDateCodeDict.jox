    <JadeMethod name="deleteObjects" id="dd9b45fb-a2d9-4e3c-a499-cfb7ec3f7fbe">
        <lockReceiver/>
        <updating/>
        <source>deleteObjects(_includePersistent : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		22 May 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	shift : CM_Shift;
begin
	foreach shift in self discreteLock do
		if shift.isTransient() then
			self.remove(shift);
			delete shift;
		else
			if _includePersistent then
				delete shift;
			else
				self.remove(shift);
			endif;
		endif;
	endforeach;
end;</source>
        <Parameter name="_includePersistent" type="Boolean"/>
    </JadeMethod>
</CollClass>
