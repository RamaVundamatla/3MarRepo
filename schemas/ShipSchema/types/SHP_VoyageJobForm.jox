    <JadeMethod name="initFilterTable" id="09f45bd8-6c91-4d16-9dac-d6dc9cc94e13">
        <updating/>
        <source>initFilterTable() updating;
//-----------------------------------------
//Created: April 2003 By: cnwgd1
//-----------------------------------------
vars
	voy 			: CM_Voyage;
	theJob 			: CM_VoyageJob;
	entTableDef		: EntTableDef;
	theTable		: CM_EntryTable;
	idx : Integer;
begin

	theTable := self.tblSearch;
	
	entTableDef := app.myController.getEntTableDef(ETDef_JobFilter);
	
	if entTableDef &lt;&gt; null then
		theTable.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
		theTable.adjustHeight(200);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'EntTableDef FullReleaseFind not found');
	endif;

	if self.amInitialisingWithObject then
		if self.myCurrentObject.isKindOf(CM_VoyageJob) then
			theJob := self.myCurrentObject.CM_VoyageJob;
			self.caption := "Job " &amp; theJob.jobId;
			self.tblSearch.setValueByName(ETRow_JobID, theJob.jobId);
			voy := self.myCurrentObject.CM_VoyageJob.myVoyage;
		elseif self.myCurrentObject.isKindOf(CM_Voyage) then
			voy := self.myCurrentObject.CM_Voyage;
		endif;	
	endif;

	if voy = null then
		//cnwjo3 par 23105
		voy := app.getMyCurrentVoyage();
	endif;
	
	if voy &lt;&gt; null then
		if self.allCurrentVoyages.includes(voy) then
			self.cmbVoyageCode.text := self.myAssistant.displayEntryVoyageObject(voy);
			idx := self.cmbVoyageCode.findObject(voy);
			if idx &gt; 0 then
				self.cmbVoyageCode.listIndex := idx;
			endif;

	   		self.cmbVoyageCode.click(self.cmbVoyageCode);
	   		self.cmbJobId.lostFocus(self.cmbJobId);
		endif;	   	
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="initForm" id="d3bd80af-095e-4b73-aaf2-650bc0e65e4a">
        <updating/>
        <source>initForm() updating;
//--------------------------------------------------------------
//Created: 23 April 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	self.showFilterOnStartup := true; 	// Show the filter frame
	self.showDataOnStartup 	:= true; 	// Do not populate the data table with data
	self.allowPrint 	:= false;
//	self.allowExportCSV	:= false;
	self.allowExportCSV	:= true;	//27 Oct 2011	NDL	Par 28103

	self.allCurrentVoyages.clear();
	self.myTerminal.getAllCurrentCellularVoyages(self.allCurrentVoyages, false, false);
	self.cmbVoyageCode.listCollection(self.allCurrentVoyages, false, 0);
	
	self.doComboStatusBuild();
	self.myAssistant.comboBoxJobType(self.cmbJobType);
	
	self.tblJobEdit.optimiseRowHeight:=true;
	self.useTblThumb := false;
	self.tblJobEdit.move(0,0,self.frmDetailsTop.clientWidth,self.frmDetailsTop.clientHeight);
	self.tblJobEdit.parentAspect:=Frame.ParentAspect_StretchBoth;
	
	self.filterStatus := self.FILTER_STATUS_NULL;
	self.cmbSysRemarks.listCollection(app.myRoot.allPreDefinedRemarks, false, 0);	
	self.initJobEditTable();
										
end;</source>
    </JadeMethod>
