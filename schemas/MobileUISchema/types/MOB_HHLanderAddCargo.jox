    <JadeMethod name="setupForm" id="082f6b4c-d879-47c0-b67d-efc229e18770">
        <updating/>
        <source>setupForm() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 June 2011	cnwndl1	Initial creation	Par 27003

*/

vars
	
begin

	self.myHandHeldCheckerAgent := app.myHandHeldCheckerAgent;
	
	self.myVoyage := self.myMobileGenericAgent.myVoyage;
	self.caption := self.caption &amp; " : " &amp; self.myVoyage.code;

	self.setupCmdButtons( 2, app.getErrorString(Save), app.getErrorString(Back), null, null, null );
	
	self.myTrackedItem := null;
	self.myMobileGenericAgent.setMyNextTiToAction( null );

	inheritMethod();
	
	self.setupControls();
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="bdb23861-bfb6-41b3-8351-07de57aaaed1">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0016607, locale);
	lblId.translateCaption(Xlat_0016608, locale);
	lblIsoType.translateCaption(Xlat_0016609, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="txtId_lostFocus" id="e36d91f5-8105-4e72-94f0-094838e6c60d">
