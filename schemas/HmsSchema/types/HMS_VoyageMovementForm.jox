    <JadeMethod name="addMvmntPilotDetailsToTable" id="7da40dc4-1afc-4139-bcfd-4ad1791b2270">
        <updating/>
        <source>addMvmntPilotDetailsToTable(_movementPilotDetails : HMS_MovementPilotDetails) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 May 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement

*/

vars
	tmpTable : CM_DataTable;
	rowArray : EntTableRowArray;
	rowIndex,
	backColour : Integer;
	newCombo : CMUI_ComboBox;
begin
	tmpTable := self.tblPilotLaunch;
	if _movementPilotDetails = null then
		return;
	endif;
	rowArray := tmpTable.allTblDataEntRows;
	rowIndex := tmpTable.rows + 1;
	tmpTable.addItemAt(_movementPilotDetails.getAttributeStringForDefArray(rowArray), rowIndex);
	tmpTable.accessRow(rowIndex).itemObject := _movementPilotDetails;
	if rowIndex mod 2 = 0 then
		backColour := self.colorRow1;
	else
		backColour := self.colorRow2;
	endif;
	tmpTable.accessRow(rowIndex).backColor := backColour;

	if self.mode = self.Mode_Update	or self.mode = self.Mode_Add then
		self.newIndex := self.newIndex + 1;
		newCombo := self.cmbSetPilotLaunch.loadControl(newIndex).CMUI_ComboBox; // set up pilot launch combo
		self.allClonedControls.add(newCombo);
		tmpTable.accessCell(rowIndex, self.colPilotLaunch).cellControl := newCombo;
		newCombo.CMUI_ComboPilotLaunch.setObjectAndHarbour(_movementPilotDetails.myPilotLaunch, self.myTerminal.myHarbour);

		newCombo := self.cmbPilot.loadControl(newIndex).CMUI_ComboBox; // set up pilot combo
		self.allClonedControls.add(newCombo);
		tmpTable.accessCell(rowIndex, self.colPilot).cellControl := newCombo;
		newCombo.CMUI_ComboPilot.setObjectAndHarbour(_movementPilotDetails.myPilot, self.myTerminal.myHarbour);
	endif;
epilog

end;</source>
        <Parameter name="_movementPilotDetails" type="HMS_MovementPilotDetails"/>
    </JadeMethod>
    <JadeMethod name="addResourceUsedToTable" id="c9b10d8f-54fa-407c-8f15-ffb1616cac8f">
        <updating/>
        <source>addResourceUsedToTable(_resourceUsed : HMS_ResourceUsed)updating;
//--------------------------------------------------
// Created:	16 February 2005 By: cnwgd1
// 28 Nov 2024 navlc30 JIRA 33450 NSW | Movement Maintenance Screen - Invalid Day Error: 14190
// 05 Nov 2025 navhl20 Bug MTN-36437: SAL - Dropdown not working properly in Harbor Function &gt;&gt; Movement Maintenance &gt;&gt; Add Resource
//--------------------------------------------------
vars
	backColour,
	rowIdx 		: Integer;
	tmpTable 	: CM_DataTable;
	rowArray 	: EntTableRowArray;
	newTxtBox 	: CMUI_TextBox;
	newCombo 	: CMUI_ComboBox;
	assist 		: CMUI_Assistant;
	cell 		: JadeTableCell;
	voyage 		: CM_Voyage;
	isMarineMTN : Boolean;
begin

	tmpTable := self.tblResUsed;
		
	if _resourceUsed = null then
		return;
	endif;
	
	if _resourceUsed.myVTMISTransaction = null then // show charged marine resources
		if _resourceUsed.myResourceType &lt;&gt; null 
		and _resourceUsed.myResourceType.isMarineService then // CCMS 1350
		
			voyage :=  self.myCurrentMovement.getMyVoyage(); // TFS 41411
			if voyage &lt;&gt; null  // TFS 41411
			and not voyage.isNullVoyage	//18 Dec 2018	TFS 42546
			and not voyage.isUsingDefaultProcessJMT() then // TFS 41411
				isMarineMTN := true;
			else
				return;
			endif;
		endif;
	endif;	
	rowArray := tmpTable.allTblDataEntRows;
		
	assist := self.myAssistant;
	
	rowIdx := tmpTable.rows+1;
	tmpTable.addItemAt(_resourceUsed.getAttributeStringForDefArray(rowArray), rowIdx);
	tmpTable.accessRow(rowIdx).itemObject := _resourceUsed;
	
	
	if _resourceUsed.myVTMISTransaction &lt;&gt; null then
		//Already invoiced, disable row as cannot change once invoiced
		tmpTable.accessRow(rowIdx).enabled := false;
		tmpTable.accessRow(rowIdx).backColor := Gray;	
		return;
	endif;
	
	if rowIdx mod 2 = 0 then
		backColour := self.colorRow1;
	else
		backColour := self.colorRow2;
	endif;			
	tmpTable.accessRow(rowIdx).backColor := backColour;	

	if self.mode = self.Mode_Update
	or self.mode = self.Mode_Add then
	
		//Add controls for update mode
					
		self.newIndex := self.newIndex + 1;

		cell := self.tblResUsed.accessCell(rowIdx, self.colQtyUnits);
		//Load from date control
		cell := self.tblResUsed.accessCell(rowIdx, self.colDateFrom);
		cell.inputType := Table.InputType_EditMask;
		cell.editMask := app.getDateEditMaskForShortFormat();
		cell.text := self.systemToLocalTime(_resourceUsed.fromDateTime).date.shortFormatJMT();	// 26/5/16 cnwmp6 TFS 488 - Multi timezone changes
			
		//Load from time control
		cell := self.tblResUsed.accessCell(rowIdx, self.colTimeFrom);
		cell.inputType := Table.InputType_EditMask;
		cell.editMask := app.getTimeEditMaskShortFormat(false);		// cnwdad1 16/06/2009 - PAR #19942.
		cell.text := self.systemToLocalTime(_resourceUsed.fromDateTime).Time.shortFormatJMT();	// 26/5/16 cnwmp6 TFS 488 - Multi timezone changes
			
		//Load to date control
		cell := self.tblResUsed.accessCell(rowIdx, self.colDateTo);	// Mar 2013 was colDateFrom - wasn't setting up the 'to' date correctly
		cell.inputType := Table.InputType_EditMask;
		cell.editMask := app.getDateEditMaskForShortFormat();
		cell.text := self.systemToLocalTime(_resourceUsed.toDateTime).date.shortFormatJMT();	// was fromDateTime		// 26/5/16 cnwmp6 TFS 488 - Multi timezone changes
			
		//Load to time control
		cell := self.tblResUsed.accessCell(rowIdx, self.colTimeTo);
		cell.inputType := Table.InputType_EditMask;
		cell.editMask := app.getTimeEditMaskShortFormat(false);		// cnwdad1 16/06/2009 - PAR #19942.
		cell.text := self.systemToLocalTime(_resourceUsed.toDateTime).Time.shortFormatJMT();	// 26/5/16 cnwmp6 TFS 488 - Multi timezone changes
	
		//Load myResourceType control
		newCombo := self.cmbResourceType.loadControl(newIndex).CMUI_ComboBox;
		//newCombo.filterIgnore := true;								//28.11.2024 navlc30 #33450				//05.11.2025 navhl20 #36437
		self.allClonedControls.add(newCombo);
		tmpTable.accessCell(rowIdx, self.colResourceType).cellControl := newCombo;
		newCombo.CMUI_ComboResourceTypes.setObject(_resourceUsed.myResourceType);
		if isMarineMTN then // TFS 41411
			newCombo.enabled := false;
			tmpTable.accessedCell.enabled := false;
		endif;

		//Load myResource control
		newCombo := self.cmbResource.loadControl(newIndex).CMUI_ComboBox;
		//newCombo.filterIgnore := true;								//28.11.2024 navlc30 #33450				//05.11.2025 navhl20 #36437
		self.allClonedControls.add(newCombo);
		tmpTable.accessCell(rowIdx, self.colResource).cellControl := newCombo;
		newCombo.CMUI_ComboResources.setObjectAndResourceType(_resourceUsed.myResource,_resourceUsed.myResourceType,_resourceUsed.myHarbour);
		if isMarineMTN then // TFS 41411
			newCombo.enabled := false;
			tmpTable.accessedCell.enabled := false;
		endif;

		//Load units used control
		newTxtBox := self.txtUnitsUsed.loadControl(newIndex).CMUI_TextBox;
		self.allClonedControls.add(newTxtBox);
		tmpTable.accessCell(rowIdx, self.colUnitsUsed).cellControl := newTxtBox;
		if _resourceUsed.myResourceType &lt;&gt; null then
			newTxtBox.decimals := _resourceUsed.myResourceType.numDecimalPlaces;
		endif;
		newTxtBox.text := _resourceUsed.unitsUsed.String;
		newTxtBox.selectionStyle := TextBox.SelectionStyle_SelectAll;
						
		tmpTable.accessedRow.height := newTxtBox.height.Integer;

		self.setTblResourceCells(rowIdx, _resourceUsed, _resourceUsed.myResourceType);		
		
	endif;
	

end;</source>
        <Parameter name="_resourceUsed" type="HMS_ResourceUsed"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="38deed52-c410-48fb-9c0d-21af62403aad">
        <updating/>
        <source>addToolbarControls() updating, protected;
//--------------------------------------------------
// Created:	05 April 2005 By: cnwgd1
//--------------------------------------------------
vars
	toolbar		: CMUI_Toolbar;
begin
	inheritMethod();
	
	toolbar := self.frmToolbar;
	toolbar.addButton(self.btnNew, CMUI_Toolbar.Control_Alignment_Left);			
	toolbar.addButton(self.btnEdit, CMUI_Toolbar.Control_Alignment_Left);				
	toolbar.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addButton(self.btnDelete, CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addButton(self.btnCancelMove, CMUI_Toolbar.Control_Alignment_Left);	//19 Nov 2018	NDL	TFS 42043
	toolbar.addButton(self.btnShippingAgent, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnShippingLine, CMUI_Toolbar.Control_Alignment_Left);
	
	if app.myRoot.canDo(Mod_Invoicing) // Invoice License
	and self.myTerminal.getConfig(FinancialsEnabled).Boolean then // Invoicing Turned On
		toolbar.addButton(self.btnResourcesUsed, CMUI_Toolbar.Control_Alignment_Left);
	endif;
	
	toolbar.addButton(self.btnTimings, CMUI_Toolbar.Control_Alignment_Left);	//18 Jun 2018	NDL	TFS 39215

	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);				
	toolbar.addButton(self.btnVesselDef, CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="adjustMarksFromBollards" id="7c9ce9c1-647d-41c6-bfac-a866c0cd5a32">
        <updating/>
        <source>adjustMarksFromBollards(_cmbBollard : ComboBox; _textbox : TextBox) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 19/10/2022	navdap1		Initial creation TFS 54739 EUP - PLAN - Berth planning by bollards
// 22/03/2023	navdap1		TFS 56593 EUP - Show Bollard+Meters in all instances
// 05/09/2023	navdap1		TFS 59472 EUP | FR 56588 Berth planning by bollards Remedial
// 10/07/2024	navcs2		Bug 64769: MSL- IMT- Unable to manage the movements in Harbor management
//
vars
	oldBowMark, newBowMark, oldSternMark, newSternMark, oldBridgeMark, newBridgeMark : Decimal [12,2];
	oldBowMeters, newBowMeters, oldSternMeters, newSternMeters, oldBridgeMeters, newBridgeMeters : Decimal [12,2];
	loa, bowToBridge : Decimal [12,2];
	orientation : Integer;
	waterOnLeft, bowMarkHigh : Boolean;
	berth : HMS_Berth;											// TFS 56593
	sternBollard, bridgeBollard, bowBollard : HMS_Resource;		// TFS 56593
	wharf : HMS_Wharf;					// TFS 59472

begin
	// some basic stuff first - orientation and water side to
	orientation := self.cbxOrientTo.listIndex;
	berth := self.cmbToBerth.listObject.HMS_Berth;		// TFS 56593
	waterOnLeft := berth.myWharf.waterOnLeft;			// TFS 56593
	wharf := berth.myWharf;							// TFS 59472
	loa := self.cmbHMSVoyage.listObject.HMS_VoyageData.dim_LengthOverall;
	bowToBridge := self.cmbHMSVoyage.listObject.HMS_VoyageData.dist_BridgeToBow;
	// water on left, ship is port side to - bow mark is min, stern mark is max
	// water on right, ship is starboard side to - bow mark is min, stern mark is max
	if (waterOnLeft and orientation = OrientPortSideTo) or (not waterOnLeft and orientation = OrientStarboardSideTo) then
		bowMarkHigh := false;
	// water on left, ship is starboard side to - bow mark is max, stern mark is min
	// water on right, ship is port side to - bow mark is max, stern mark is min
	elseif (waterOnLeft and orientation = OrientStarboardSideTo) or (not waterOnLeft and orientation = OrientPortSideTo) then
		bowMarkHigh := true;
	endif;
	
	oldBowMark := self.txtBowMarkTo.text.Decimal;
	oldSternMark := self.txtSternMarkTo.text.Decimal;
	oldBridgeMark := self.txtBridgeMark.text.Decimal;
	oldBowMeters := self.txtBowMarkMeter.text.Decimal;
	oldSternMeters := self.txtSternMarkMeter.text.Decimal;
	oldBridgeMeters := self.txtBridgeMarkMeter.text.Decimal;
	
	// if bow bollard or bow meters change
	if _cmbBollard = self.cmbBowMarkBollard or _textbox = self.txtBowMarkMeter then
		if _cmbBollard.listObject = null then
			return;
		endif;
		// adjust the bow, stern and bridge marks to suit
		newBowMeters := _textbox.text.Decimal;
		newBowMark := _cmbBollard.listObject.HMS_Resource.startPosnAlongWharf + newBowMeters;
		
		if bowMarkHigh then
			newSternMark := newBowMark - loa;
			newBridgeMark := newBowMark - bowToBridge;
		else
			newSternMark := newBowMark + loa;
			newBridgeMark := newBowMark + bowToBridge;
		endif;
		
		// TFS 56593 bollard marks are always bollard + metres, never bollard - metres. So find the closest bollard
		// for the new stern and bridge positions, and the metres to those new bollard(s)
		wharf.getBollardForMark(newBowMark.Integer, newBowMeters, bowBollard);				// TFS 59472
		wharf.getBollardForMark(newSternMark.Integer, newSternMeters, sternBollard);		// TFS 59472
		wharf.getBollardForMark(newBridgeMark.Integer, newBridgeMeters, bridgeBollard);		// TFS 59472
	endif;
	
	// if stern bollard or stern meters change
	if _cmbBollard = self.cmbSternMarkBollard or _textbox = self.txtSternMarkMeter then
		if _cmbBollard.listObject = null then
			return;
		endif;
		// adjust the bow, stern and bridge mark text boxes to suit 
		newSternMeters := _textbox.text.Decimal;
		newSternMark := _cmbBollard.listObject.HMS_Resource.startPosnAlongWharf + newSternMeters;
		
		if bowMarkHigh then
			newBowMark := newSternMark + loa;
			newBridgeMark := newBowMark - bowToBridge;
		else
			newBowMark := newSternMark - loa;
			newBridgeMark := newBowMark + bowToBridge;
		endif;
		
		// TFS 56593 bollard marks are always bollard + metres, never bollard - metres. So find the closest bollard
		// for the new bow and bridge positions, and the metres to those new bollard(s)
		wharf.getBollardForMark(newBowMark.Integer, newBowMeters, bowBollard);				// TFS 59472
		wharf.getBollardForMark(newBridgeMark.Integer, newBridgeMeters, bridgeBollard);		// TFS 59472
		wharf.getBollardForMark(newSternMark.Integer, newSternMeters, sternBollard);		// TFS 59472
	endif;
	
	// If the bridge bollard / meters are changed, change the bridge mark text box, but leave the other mark, bollard and meter fields as they are
	if _cmbBollard = self.cmbBridgeMarkBollard or _textbox = self.txtBridgeMarkMeter then
		if self.cmbBridgeMarkBollard.listObject = null then
			return;
		endif;
		newBridgeMark := self.cmbBridgeMarkBollard.listObject.HMS_Resource.startPosnAlongWharf + self.txtBridgeMarkMeter.text.Decimal;
		newBridgeMeters := self.txtBridgeMarkMeter.text.Decimal;
		
		// TFS 56593 allow bridge changes to change bow and stern as well
		if bowMarkHigh then
			newBowMark := newBridgeMark + bowToBridge;
			newSternMark := newBowMark - loa;
		else
			newBowMark := newBridgeMark - bowToBridge;
			newSternMark := newBowMark + loa;
		endif;
		
		wharf.getBollardForMark(newBowMark.Integer, newBowMeters, bowBollard);				// TFS 59472
		wharf.getBollardForMark(newBridgeMark.Integer, newBridgeMeters, bridgeBollard);		// TFS 59472
		wharf.getBollardForMark(newSternMark.Integer, newSternMeters, sternBollard);		// TFS 59472
		// TFS 56593 end of this bit
	endif;
	
	self.txtBowMarkTo.text := newBowMark.asStringJMT;
	self.txtSternMarkTo.text := newSternMark.asStringJMT;
	self.txtBridgeMark.text := newBridgeMark.asStringJMT;
	self.txtBowMarkMeter.text := self.stringOrNull(newBowMeters.Integer);			// TFS 56593			// 10/07/2024	navcs2		Bug 64769
	self.txtSternMarkMeter.text := self.stringOrNull(newSternMeters.Integer);		// TFS 56593			// 10/07/2024	navcs2		Bug 64769
	self.txtBridgeMarkMeter.text := self.stringOrNull(newBridgeMeters.Integer);		// TFS 56593			// 10/07/2024	navcs2		Bug 64769
	
	// TFS 56593 also update the bollard combos if required
	if bowBollard &lt;&gt; self.cmbBowMarkBollard.listObject then
		self.cmbBowMarkBollard.listIndex := self.cmbBowMarkBollard.findObject(bowBollard);
	elseif bowBollard = null then												// TFS 59472
		self.cmbBowMarkBollard.listIndex := -1;									// TFS 59472
	endif;
	if sternBollard &lt;&gt; self.cmbSternMarkBollard.listObject then
		self.cmbSternMarkBollard.listIndex := self.cmbSternMarkBollard.findObject(sternBollard);
	elseif sternBollard = null then												// TFS 59472
		self.cmbSternMarkBollard.listIndex := -1;								// TFS 59472
	endif;
	if bridgeBollard &lt;&gt; self.cmbBridgeMarkBollard.listObject then
		self.cmbBridgeMarkBollard.listIndex := self.cmbBridgeMarkBollard.findObject(bridgeBollard);
	elseif bridgeBollard = null then											// TFS 59472
		self.cmbBridgeMarkBollard.listIndex := -1;								// TFS 59472
	endif;
	// TFS 56593 end of this bit
	
	// TFS 59472 Adjust To Berth combo if required
	if bowBollard &lt;&gt; null and bowBollard.myBerth &lt;&gt; self.cmbToBerth.listObject then
		self.cmbToBerth.listIndex := self.cmbToBerth.findObject(bowBollard.myBerth);
	endif;
	// TFS 59472 end of this bit
	
epilog

end;</source>
        <Parameter name="_cmbBollard" type="ComboBox"/>
        <Parameter name="_textbox" type="TextBox"/>
    </JadeMethod>
    <JadeMethod name="armNotesForObject" id="f094b866-a071-4276-97d2-027b3e5614bb">
        <source>armNotesForObject(_obj: Object);
//--------------------------------------------------
// Created:	05 April 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.beginNotification(_obj, Object_Delete_Event, Response_Continuous, 0);
	self.beginNotification(_obj, Object_Update_Event, Response_Continuous, 0);

