        <source>showSelectorDialogForm(_mode : Integer;
					   _parentForm : Form;
					   _terminal : CM_Terminal; //17/02/2023 navmv20 TFS 55649 Task 56228
					   _type : Integer; //12/09/2023	navkc1	CR 60429 Task 60445
					   _qdef : CM_QueryDefinition; //12/09/2023	navkc1	CR 60429 Task 60445
					   _critLineHolder : CM_QueryCriteriaLineHolder //12/09/2023	navkc1	CR 60429 Task 60445
					   );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Dec 2022 navtnr20  Task 55553: UI - New Selector Dialog
16 February 2023  navmv20	TFS 55649 Task 56228: UI - Selector Dialog for Contracts
12/09/2023	navkc1	CR 60429 Task 60445: UI - Cargo Review UI Changes - Queries
*/

vars
	form : CMUI_SelectorDialog;
begin
	if form = null then
		form := app.loadForm (CMUI_SelectorDialog, CMUI_Assistant, false, false, true , self.myTerminal, null).CMUI_SelectorDialog; 
	endif;
	form.queryMode	:= _mode;
	form.queryType := _type; //12/09/2023	navkc1	CR 60429 Task 60445
	
	//12/09/2023	navkc1	CR 60429 Task 60445
	if _qdef &lt;&gt; null then
		form.setMyQDef(_qdef);
	endif;
	
	//12/09/2023	navkc1	CR 60429 Task 60445
	if _critLineHolder &lt;&gt; null then
		form.setMyCriteriaLineHolder(_critLineHolder);
	endif;
	
	form.myParentFrm := _parentForm;
	form.CMUI_SelectorDialog.myParentTerminal := _terminal; //17/02/2023 navmv20 TFS 55649 Task 56228
	form.showModal();
epilog

end;</source>
