    <JadeMethod name="isSnapShotDataMatch" id="effbc0df-6cc0-436d-b9d9-eee0a0753ced">
        <source>isSnapShotDataMatch(_criteria: CM_YACriteria; _yaType: Integer; _propertyValue: String): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
01 June 2022	navgm20 ChangeRequest 53195: EUP - GEN/REP/INB - Additional Cargo Field ľ Shipping Line - Portschema

*/

vars
	obj		: Object;
begin
	if _yaType &lt;&gt; self.type then
		return false;
	endif;
	
	foreach obj in _criteria.myYAData.CM_YADataObjects.allObjects do
		if obj.CM_ShippingLine.code = _propertyValue then
			return true;
		endif;
	endforeach;
	
	if _criteria.myYAData.isKindOf(CM_YADataPattern) and
	   _criteria.myYAData.CM_YADataPattern.pattern = null then
		return true;
	endif;
	
	return false;
end;</source>
        <Parameter name="_criteria" type="CM_YACriteria"/>
        <Parameter name="_yaType" type="Integer"/>
        <Parameter name="_propertyValue" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isStorageDetailMatch" id="b3625c8e-7ee6-418f-b310-a962df02c35c">
        <source>isStorageDetailMatch(_criteria: CM_YACriteria; _ti: CM_TrackedItem; _tiTrx: CM_TITransaction): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
01 June 2022	navgm20	ChangeRequest 53195: EUP - GEN/REP/INB - Additional Cargo Field ľ Shipping Line - Portschema

*/

vars 
	shipLine : CM_ShippingLine;
begin
	
	
	if _tiTrx &lt;&gt; null then	
		if _tiTrx.shippingLineCode &lt;&gt; null then
			shipLine := app.myRoot.allShippingLines[ _tiTrx.shippingLineCode ];
		endif;
	else
		shipLine := app.myRoot.allShippingLines [_ti.getShippingLineCode()];		// 14.07.2022 navsrk20 53195
	endif;
	
	if _criteria.myYAData.CM_YADataObjects.matchesStorage(shipLine) then
		return true;
	endif;
	
	// default value
	if _criteria.myYAData.isKindOf(CM_YADataPattern) and
	   _criteria.myYAData.CM_YADataPattern.pattern = null then
		return true;
	endif;
	
	return false;
end;</source>
        <Parameter name="_criteria" type="CM_YACriteria"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_tiTrx" type="CM_TITransaction"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
