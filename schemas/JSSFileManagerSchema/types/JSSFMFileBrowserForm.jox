    <JadeMethod name="doFormInitialize" id="8436c61c-6576-4b69-95e1-9ccdeaf6a0d4">
        <updating/>
        <source>doFormInitialize() updating, protected;
// --------------------------------------------------------------------------------
// Created:		25 June 2002 by cnwdad1
//
// Purpose:		The standard JSS CoreSchema form initialization method.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	isDbServer	: Boolean;
	isAppServer	: Boolean;
	
begin
	inheritMethod();
	
	picState.picture			:=	picHolderIdle.picture;
	lstDirTop.pictureClosed		:=	picHolderClosed.picture;
	lstDirTop.pictureOpen		:=	picHolderOpen.picture;
	lstDirTop.pictureLeaf		:=	picHolderFile.picture;
	lstDirBottom.pictureClosed	:=	picHolderClosed.picture;
	lstDirBottom.pictureOpen	:=	picHolderOpen.picture;
	lstDirBottom.pictureLeaf	:=	picHolderFile.picture;
	
	self.initializeTable(tblFilesTop);
	self.initializeTable(tblFilesBottom);
	
	self.listLoadJadeNodeNames(lstDirTop);
	self.listLoadJadeNodeNames(lstDirBottom);
	
	self.doFormResize();
	
	if (not self.aAllPathNamesAppServer.isEmpty()) then
		isDbServer	:=	false;
		isAppServer	:=	true;
		self.listOpenBasePath(lstDirTop, isDbServer, isAppServer);
		self.listOpenBasePath(lstDirBottom, isDbServer, isAppServer);
	endif;
	
	if (not self.aAllPathNamesDbServer.isEmpty()) then
		isDbServer	:=	true;
		isAppServer	:=	false;
		self.listOpenBasePath(lstDirTop, isDbServer, isAppServer);
		self.listOpenBasePath(lstDirBottom, isDbServer, isAppServer);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormLoad" id="d67c04c1-9cf0-4fa2-9f10-2ae65780a62f">
        <updating/>
        <source>doFormLoad() updating, protected;
// --------------------------------------------------------------------------------
// Created:		22 June 2002 by cnwdad1
//
// Purpose:		The standard JSS CoreSchema form load event method.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 25 Oct 2013	cnwkpd1		Add app.dbPath to the caption for support user confirmation
//							that they are connected to the right environment
// --------------------------------------------------------------------------------
vars
	currentTimestamp	: TimeStamp;
	
begin
	inheritMethod();
	
	self.caption := self.caption &amp; " - " &amp; app.dbPath();
	
	if process.isUsingThinClient() then
		self.aIsUnixAppServer	:=	self.getUnixFlag();
	else
		self.aIsUnixAppServer	:=	false;
	endif;
	
	self.aIsUnixDbServer	:=	self.getUnixFlagServer();
	
	self.getServiceInterfaceSettings();
	self.doLoadUserProfileSetup();
	
	staStatus.height	:=	26;
	self.doRegisterFormKeys();
	
	mnuFile.visible					:=	true;
	mnuPrefs.visible				:=	true;
	mnuView.visible					:=	true;
	mnuFileChunkSeparator.visible	:=	false;
	mnuFileChunkSize.visible		:=	false;
	
	self.statusSetTimestampFormat();
	self.statusSetObjectCount(0, 0);
	self.statusSetSelectedCount(null);
	self.statusResizeTimestamp();
	self.statusResizeKeys();
	self.statusResizeObjectCounts();
	
	self.timerEvent(self.TIMER_STATUS_TIMESTAMP);
	beginTimer((1000 * 60), Timer_Continuous, self.TIMER_STATUS_TIMESTAMP);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormResize" id="43f6fd5f-09f9-4ec0-b2ab-3853b6bec04c">
        <source>doFormResize() protected;
// --------------------------------------------------------------------------------
// Created:		01 August 2002 by cnwdad1
//
// Purpose:		Resizes the form's contents to correctly fit its dimensions.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 11 May 2009	cnwkpd1		Change to use clientWidth and clientHeight to correct
//							resize behaviour under Vista
// --------------------------------------------------------------------------------
begin
//	basSplitMain.move(0, 0, (self.width - 8), (self.height - staStatus.height - 47));		// KPD 11/05/2009
	basSplitMain.move(0, 0, self.clientWidth, self.clientHeight - staStatus.height);
	basSplitMain.jssfmResizeContents();
	
	picState.move((staStatus.width - picState.width - 11), 1, picState.width, picState.height);
	
	self.statusResizeTimestamp();
	self.statusResizeKeys();
	self.statusResizeObjectCounts();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormUnload" id="ab64bedd-e25d-4fd7-8075-234d00f8ba6b">
        <updating/>
        <source>doFormUnload() updating, protected;
// --------------------------------------------------------------------------------
// Created:		05 July 2002 by cnwdad1
//
// Purpose:		The standard JSS CoreSchema form unload method.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.aAllCutAndPasteObjects.purge();
	
	if self.aMyMonitorForm &lt;&gt; null then
		self.aMyMonitorForm.unloadForm();
	endif;
	
	self.aMyServiceManager.setFileBrowserForm(null);
	
	inheritMethod();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doGetSelectedListFolder" id="18ad4816-c4e1-45aa-8ae3-2a2085d7f691">
        <source>doGetSelectedListFolder(pTheListbox:ListBox; pTheContainer:JSSFMFolder io) protected;
// --------------------------------------------------------------------------------
// Created:		05 July 2002 by cnwdad1
//
// Purpose:		Returns a container object with a folder details object of the currently
//				selected list folder on the specified listbox.
//
// Parameters:	pTheListbox - The listbox whose selected folder we want.
//				pTheContainer - The container object for the folder details object.
//
// Returns:		The pTheContainer containing the details object of the selected folder.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theListbox		: ListBox;
	listPointer		: Integer;
	fileName		: String;
	pathName		: String;
	nodeType		: Integer;
	isUnix			: Boolean;
	
begin
	theListbox	:=	pTheListbox;
	listPointer	:=	theListbox.listIndex;
	fileName	:=	theListbox.itemText[listPointer];
	pathName	:=	self.listGetQualifiedName(theListbox, listPointer);
	nodeType	:=	theListbox.itemData[listPointer];
	
	if nodeType = self.LISTBOX_NODE_LOCAL_FOLDER
	or nodeType = self.LISTBOX_NODE_APP_SERVER_FOLDER
	or nodeType = self.LISTBOX_NODE_DB_SERVER_FOLDER
	then
		isUnix	:=	false;
		
		if nodeType = self.LISTBOX_NODE_APP_SERVER_FOLDER then
			isUnix	:=	self.aIsUnixAppServer;
		elseif nodeType = self.LISTBOX_NODE_DB_SERVER_FOLDER then
			isUnix	:=	self.aIsUnixDbServer;
		endif;
		
		pTheContainer.addFolder(fileName, pathName, nodeType, isUnix);
	else
		self.aMyServiceManager.raiseJSSException1(JSS_EX_00009, nodeType.String);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pTheListbox" type="ListBox"/>
        <Parameter name="pTheContainer" type="JSSFMFolder" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doGetSelectedTableFiles" id="d31ef682-c8f9-4fdb-be2f-184ad3ca0566">
        <source>doGetSelectedTableFiles(pTheTable:Table; pTheContainer:JSSFMFolder io) protected;
// --------------------------------------------------------------------------------
// Created:		27 June 2002 by cnwdad1
//
// Purpose:		Returns a container object with a folder details object of the
//				currently selected directory contents in the specified table.
//
// Parameters:	pTheTable - The table whose selected directory contents we want.
//				pTheContainer - The container object for the selected contents
//					details objects.
//
// Returns:		The pTheContainer containing the details object of the selected
//				directory contents.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theTable		: Table;
	rowPointer		: Integer;
	startRow		: Integer;
	rowCount		: Integer;
	startColumn		: Integer;
	fileName		: String;
	pathName		: String;
	fileLength		: Integer;
	lastModified	: TimeStamp;
	fileAttributes	: String;
	isArchive		: Boolean;
	isHidden		: Boolean;
	isReadOnly		: Boolean;
	isSystemFile	: Boolean;
	nodeFlag		: Integer;		// Identifies whether node is a folder or a file.
	nodeType		: Integer;
	isUnix			: Boolean;
	
begin
	theTable	:=	pTheTable;
	startRow	:=	theTable.fixedRows + 1;
	rowCount	:=	theTable.rows;
	startColumn	:=	theTable.fixedColumns + 1;
	
	foreach rowPointer in startRow to rowCount do
		if theTable.getCellSelected(rowPointer, startColumn) then
			// Collect the file node information from the table control.
			// Note that columns 6 and thereafter are are hidden.
			fileName		:=	theTable.getCellText(rowPointer, 2);
			fileLength		:=	theTable.getCellText(rowPointer, 3).Integer;
			lastModified	:=	theTable.getCellText(rowPointer, 4).TimeStamp;
			fileAttributes	:=	theTable.getCellText(rowPointer, 5);
			self.doParseFileAttributes(fileAttributes, isArchive, isHidden, isReadOnly, isSystemFile);
			nodeFlag		:=	theTable.getCellText(rowPointer, 6).Integer;
			pathName		:=	theTable.getCellText(rowPointer, 7);
			nodeType		:=	theTable.getCellText(rowPointer, 8).Integer;
			isUnix			:=	theTable.getCellText(rowPointer, 9) = "true";
			
			if nodeFlag = JSSFMFileNode.NODE_FLAG_FOLDER then
				pTheContainer.addFolder(fileName, pathName, nodeType, isUnix);
				
			elseif nodeFlag = JSSFMFileNode.NODE_FLAG_FILE then
				pTheContainer.addFile(	fileName,
										pathName,
										nodeType,
										isUnix,
										fileLength,
										lastModified,
										isArchive,
										isHidden,
										isReadOnly,
										isSystemFile);
									
			else
				self.aMyServiceManager.raiseJSSException1(JSS_EX_00009, nodeFlag.String);
				
			endif;
		endif;
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="pTheTable" type="Table"/>
        <Parameter name="pTheContainer" type="JSSFMFolder" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doLoadUserProfileSetup" id="1a5f3fd3-a604-4c14-b017-f54a280d9482">
        <source>doLoadUserProfileSetup() protected;
// --------------------------------------------------------------------------------
// Created:		15 July 2002 by cnwdad1
//
// Purpose:		When the File Browser is run from within the peer schema, then a
//				user profile can be saved (keyed by the workstation name).  This
//				profile stores the window size, position and state.  If the File
//				Browser is run from a remote schema, the profile is not available.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theUserProfile	: JSSFMUserProfile;
	
begin
	if self.aMyServiceManager.isInLocalSchema then
		mnuPrefsSettingsSep.visible		:=	true;
		mnuPrefsSettingsClear.visible	:=	true;
		mnuPrefsSettingsSave.visible	:=	true;
		
		theUserProfile	:=	app.myRoot.allUserProfiles.getAtKey(app.computerName());
		
		if theUserProfile &lt;&gt; null then
			self.move(	theUserProfile.windowLeft,
						theUserProfile.windowTop,
						theUserProfile.windowWidth,
						theUserProfile.windowHeight);
		endif;
	else
		mnuPrefsSettingsSep.visible		:=	false;
		mnuPrefsSettingsClear.visible	:=	false;
		mnuPrefsSettingsSave.visible	:=	false;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doParseFileAttributes" id="93b6f16f-de83-4443-8484-c25b3944f638">
        <source>doParseFileAttributes(	pAttributes:String;
						pIsArchive:Boolean io;
						pIsHidden:Boolean io;
						pIsReadOnly:Boolean io;
						pIsSystemFile:Boolean io) protected;
// --------------------------------------------------------------------------------
// Created:		27 June 2002 by cnwdad1
//
// Purpose:		Pulls apart a string of disk file attributes, and returns them
//				individually via the IO parameters.
//
// Parameters:	pAttributes - The string of file attributes to separate out.
//				pIsArchive - Returns a boolean flag to indicate that the file's archive flag is set.
//				pIsHidden - Returns a boolean flag to indicate that the file's hidden flag is set.
//				pIsReadOnly - Returns a boolean flag to indicate that the file's read-only flag is set.
//				pIsSystemFile - Returns a boolean flag to indicate that the file's system file flag is set.
//
// Returns:		The four individual disk file attribute flags as IO parameters.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	characterPointer	: Integer;
	stringLength		: Integer;
	attribute			: Character;
	
begin
	pIsArchive		:=	false;
	pIsHidden		:=	false;
	pIsReadOnly		:=	false;
	pIsSystemFile	:=	false;
	stringLength	:=	pAttributes.trimBlanks().length();
	
	foreach characterPointer in 1 to stringLength do
		attribute	:=	pAttributes[characterPointer].toUpper();
		
		if attribute = "A" then
			pIsArchive		:=	true;
			
		elseif attribute = "H" then
			pIsHidden		:=	true;
			
		elseif attribute = "R" then
			pIsReadOnly		:=	true;
			
		elseif attribute = "S" then
			pIsSystemFile	:=	true;
			
		endif;
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="pAttributes" type="String"/>
        <Parameter name="pIsArchive" type="Boolean" usage="io"/>
        <Parameter name="pIsHidden" type="Boolean" usage="io"/>
        <Parameter name="pIsReadOnly" type="Boolean" usage="io"/>
        <Parameter name="pIsSystemFile" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doPasteSelectedNodes" id="1f61b26d-382d-4143-9c19-aa6888c278e8">
        <updating/>
        <source>doPasteSelectedNodes(pTargetPath:String; pTargetNodeOption:Integer; pIsTargetUnix:Boolean) updating, protected;
// --------------------------------------------------------------------------------
// Created:		05 July 2002 by cnwdad1
//
// Purpose:		Copies previously selected files and/or directories (using the Copy
//				and/or Cut menus) to the specified target destination.  If the files
//				and/or directories were Cut, then the original one will be deleted.
//
// Parameters:	pTargetPath - The destination directory to copy into.
//				pTargetNodeOptions - Specifies the target node options flag.
//				pIsTargetUnix - A flag to indicate whether the file/directory is
//					being copied to a Unix platform.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 19 Dec 2014	cnwkpd1		PAR #35448 - Speed up multiple file copy and enhance
//							cancellation functionality
// --------------------------------------------------------------------------------
vars
	theContainer	: JSSFMFileNode;
	theNode			: JSSFMFileNode;
	sourcePathName	: String;
	targetPathName	: String;
	nodeOptions		: Integer;
	isFolderNode	: Boolean;
	isCutAndPaste	: Boolean;
	isPurgeCache	: Boolean;
	theFileAgent	: JSSFMFileAgent;
	isSourceUnix	: Boolean;
	theIterator		: Iterator;
	
begin
	self.getServiceInterfaceSettings();
	theFileAgent	:=	self.getFileAgent();
	theFileAgent.progressStart(null, null, null, JSSFMFileAgent.COPY_CHUNK_SIZE);
	isCutAndPaste	:=	false;
	isPurgeCache	:=	false;
	
	foreach theContainer in self.aAllCutAndPasteObjects do
		isCutAndPaste	:=	theContainer.isCutAndPaste;
		
		foreach theNode in theContainer.JSSFMFolder.allFileNodes do

			// Set up the source and target path names.
			
			sourcePathName	:=	theNode.pathName;
			targetPathName	:=	pTargetPath &amp; JSS_SEPARATOR_WIN &amp; theNode.fileName;
			isSourceUnix	:=	theNode.isUnix;
			
			theFileAgent.setUnixFlags(isSourceUnix, pIsTargetUnix);
			
			// Work out the source and target nodes.
			
			if theNode.nodeType = self.LISTBOX_NODE_LOCAL_FOLDER then
				nodeOptions		:=	JSSFMFileManagerService.NODE_SOURCE_CLIENT + pTargetNodeOption;
				isFolderNode	:=	true;
				
			elseif theNode.nodeType = self.LISTBOX_NODE_LOCAL_FILE then
				nodeOptions		:=	JSSFMFileManagerService.NODE_SOURCE_CLIENT + pTargetNodeOption;
				isFolderNode	:=	false;
				
			elseif theNode.nodeType = self.LISTBOX_NODE_APP_SERVER_FOLDER then
				nodeOptions		:=	JSSFMFileManagerService.NODE_SOURCE_APPSERVER + pTargetNodeOption;
				isFolderNode	:=	true;
				
			elseif theNode.nodeType = self.LISTBOX_NODE_APP_SERVER_FILE then
				nodeOptions		:=	JSSFMFileManagerService.NODE_SOURCE_APPSERVER + pTargetNodeOption;
				isFolderNode	:=	false;
				
			elseif theNode.nodeType = self.LISTBOX_NODE_DB_SERVER_FOLDER then
				nodeOptions		:=	JSSFMFileManagerService.NODE_SOURCE_DBSERVER + pTargetNodeOption;
				isFolderNode	:=	true;
				
			elseif theNode.nodeType = self.LISTBOX_NODE_DB_SERVER_FILE then
				nodeOptions		:=	JSSFMFileManagerService.NODE_SOURCE_DBSERVER + pTargetNodeOption;
				isFolderNode	:=	false;
				
			endif;
			
			if isSourceUnix then
				sourcePathName.replaceChar(JSS_SEPARATOR_WIN.Character, JSS_SEPARATOR_UNIX.Character);
			else
				sourcePathName.replaceChar(JSS_SEPARATOR_UNIX.Character, JSS_SEPARATOR_WIN.Character);
			endif;
			
			if pIsTargetUnix then
				targetPathName.replaceChar(JSS_SEPARATOR_WIN.Character, JSS_SEPARATOR_UNIX.Character);
			else
				targetPathName.replaceChar(JSS_SEPARATOR_UNIX.Character, JSS_SEPARATOR_WIN.Character);
			endif;
			
			// Check that we're not trying to copy something to itself.
			
			if self.isSourceSameAsTarget(sourcePathName, pTargetPath, nodeOptions)
			or self.isSourceSameAsTarget(sourcePathName, targetPathName, nodeOptions)
			then
				isPurgeCache	:=	true;
				continue;
			endif;
			
			// OK, do the copy.
			
			if isFolderNode then
				theFileAgent.copyDirectory(sourcePathName, targetPathName, nodeOptions);
				self.listUpdateWithNewDirectory(lstDirTop, targetPathName);
				self.listUpdateWithNewDirectory(lstDirBottom, targetPathName);
			else
				theFileAgent.copyFile(sourcePathName, targetPathName, nodeOptions);
			endif;
			
			if theFileAgent.isCancelled then		// PAR #35448
				break;
			endif;
			
			// PAR #35448 - moved outside loops
//			lstDirTop.click(lstDirTop);
//			lstDirBottom.click(lstDirBottom);
		endforeach;
		
		if theFileAgent.isCancelled then			// PAR #35448
			break;
		endif;
	endforeach;

	// PAR #35448 - Only need to refresh the tables once
	lstDirTop.click(lstDirTop);
	lstDirBottom.click(lstDirBottom);

	if isPurgeCache then
		self.aAllCutAndPasteObjects.purge();
	endif;
	
	// PAR #35448 - Don't purge all the source items if cancelled
	if not theFileAgent.isCancelled and isCutAndPaste then
		self.doDeleteSelectedNodes();
	endif;

	if isCutAndPaste then
		self.aAllCutAndPasteObjects.purge();
	endif;

epilog
	delete theIterator;
	theFileAgent.progressEnd();
end;</source>
        <access>protected</access>
        <Parameter name="pTargetPath" type="String"/>
        <Parameter name="pTargetNodeOption" type="Integer"/>
        <Parameter name="pIsTargetUnix" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPasteSelectedNodesBackground" id="5c600c5c-b479-43c4-85f7-7361c96a55dd">
        <updating/>
        <source>doPasteSelectedNodesBackground(pTargetPath:String; pTargetNodeOption:Integer; pIsTargetUnix:Boolean) updating, protected;
// --------------------------------------------------------------------------------
// Created:		05 July 2002 by cnwdad1
//
// Purpose:		In the background (i.e. on a DB Server thread), copies previously
//				selected files and/or directories (using the Copy and/or Cut menus)
//				to the specified target destination.  If the files and/or directories
//				were Cut, then the original one will be deleted.
//
// Parameters:	pTargetPath - The destination directory to copy into.
//				pTargetNodeOptions - Specifies the target node options flag.
//				pIsTargetUnix - A flag to indicate whether the file/directory is
//					being copied to a Unix platform.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theRoot			: JSSFMRoot;
	theFileCopy		: JSSFMBackgroundCopy;
	thePasteFile	: JSSFMPasteFile;
	theContainer	: JSSFMFileNode;
	theNode			: JSSFMFileNode;
	sourcePathName	: String;
	targetPathName	: String;
	nodeOptions		: Integer;
	isFolderNode	: Boolean;
	isCutAndPaste	: Boolean;
	isPurgeCache	: Boolean;
	isSourceUnix	: Boolean;
	
begin
	self.getServiceInterfaceSettings();
//	theFileAgent	:=	self.getFileAgent();
	isCutAndPaste	:=	false;
	isPurgeCache	:=	false;
	theRoot			:=	JSSFMRoot.firstInstance();
	
	beginTransaction;
	
	if theRoot = null then
		create theRoot;
	endif;
	
	create theFileCopy;
	theFileCopy.updateMe(app.computerName, app.dbServerComputerName(), app.dbServerComputerName(), theRoot);
	
	foreach theContainer in self.aAllCutAndPasteObjects do
		isCutAndPaste	:=	theContainer.isCutAndPaste;
		
		foreach theNode in theContainer.JSSFMFolder.allFileNodes do
			// Set up the source and target path names.
			
			sourcePathName	:=	theNode.pathName;
			targetPathName	:=	pTargetPath &amp; JSS_SEPARATOR_WIN &amp; theNode.fileName;
			isSourceUnix	:=	theNode.isUnix;
			
			// Work out the source and target nodes.
			
			if theNode.nodeType = self.LISTBOX_NODE_LOCAL_FOLDER then
				nodeOptions		:=	JSSFMFileManagerService.NODE_SOURCE_CLIENT + pTargetNodeOption;
				isFolderNode	:=	true;
				
			elseif theNode.nodeType = self.LISTBOX_NODE_LOCAL_FILE then
				nodeOptions		:=	JSSFMFileManagerService.NODE_SOURCE_CLIENT + pTargetNodeOption;
				isFolderNode	:=	false;
				
			elseif theNode.nodeType = self.LISTBOX_NODE_APP_SERVER_FOLDER then
				nodeOptions		:=	JSSFMFileManagerService.NODE_SOURCE_APPSERVER + pTargetNodeOption;
				isFolderNode	:=	true;
				
			elseif theNode.nodeType = self.LISTBOX_NODE_APP_SERVER_FILE then
				nodeOptions		:=	JSSFMFileManagerService.NODE_SOURCE_APPSERVER + pTargetNodeOption;
				isFolderNode	:=	false;
				
			elseif theNode.nodeType = self.LISTBOX_NODE_DB_SERVER_FOLDER then
				nodeOptions		:=	JSSFMFileManagerService.NODE_SOURCE_DBSERVER + pTargetNodeOption;
				isFolderNode	:=	true;
				
			elseif theNode.nodeType = self.LISTBOX_NODE_DB_SERVER_FILE then
				nodeOptions		:=	JSSFMFileManagerService.NODE_SOURCE_DBSERVER + pTargetNodeOption;
				isFolderNode	:=	false;
				
			endif;
			
			if isSourceUnix then
				sourcePathName.replaceChar(JSS_SEPARATOR_WIN.Character, JSS_SEPARATOR_UNIX.Character);
			else
				sourcePathName.replaceChar(JSS_SEPARATOR_UNIX.Character, JSS_SEPARATOR_WIN.Character);
			endif;
			
			if pIsTargetUnix then
				targetPathName.replaceChar(JSS_SEPARATOR_WIN.Character, JSS_SEPARATOR_UNIX.Character);
			else
				targetPathName.replaceChar(JSS_SEPARATOR_UNIX.Character, JSS_SEPARATOR_WIN.Character);
			endif;
			
			// Check that we're not trying to copy something to itself.
			
			if self.isSourceSameAsTarget(sourcePathName, pTargetPath, nodeOptions)
			or self.isSourceSameAsTarget(sourcePathName, targetPathName, nodeOptions)
			then
				isPurgeCache	:=	true;
				continue;
			endif;
			
			// OK, start the backgrounf copy.
			
			create thePasteFile;
			thePasteFile.updateMe(	sourcePathName,
									targetPathName,
									nodeOptions,
									isFolderNode,
									isCutAndPaste,
									isSourceUnix,
									pIsTargetUnix,
									theFileCopy);
		endforeach;
	endforeach;
	
	commitTransaction;
	
	self.getFileAgent().startBackgroundCopy(theFileCopy);
	
	if isPurgeCache then
		self.aAllCutAndPasteObjects.purge();
	elseif isCutAndPaste then
		self.aAllCutAndPasteObjects.purge();
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pTargetPath" type="String"/>
        <Parameter name="pTargetNodeOption" type="Integer"/>
        <Parameter name="pIsTargetUnix" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doRegisterFormKeys" id="39d8ea06-1317-4f8e-93cc-13e17413f58c">
        <source>doRegisterFormKeys() protected;
// --------------------------------------------------------------------------------
// Created:		28 June 2002 by cnwdad1
//
// Purpose:		Registers a set of keycodes for keys required by this form.  No
//				other keys on the form will send key events back to the Application
//				Server node to save network traffic.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	allRegisteredKeys	: IntegerArray;
	
begin
	create allRegisteredKeys transient;
	
	allRegisteredKeys.add(JSS_KEY_F5);
	allRegisteredKeys.add(JSS_KEY_F11);
	
	self.registerFormKeys(allRegisteredKeys);
epilog
	delete allRegisteredKeys;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doRenameSelectedNodes" id="8ca4c6b4-9ca7-47d6-9a02-c73b5e7ba28c">
        <updating/>
        <source>doRenameSelectedNodes() updating, protected;
// --------------------------------------------------------------------------------
// Created:		09 July 2002 by cnwdad1
//
// Purpose:		Renames selected files and/or directories.  
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theContainer		: JSSFMFileNode;
	theNode				: JSSFMFileNode;
	theFileNameForm		: JSSFMFileNameForm;
	originalName		: String;
	newName				: String;
	nodeType			: Integer;
	nodeOptions			: Integer;
	theFileAgent		: JSSFMFileAgent;
	
begin
	self.getServiceInterfaceSettings();
	theFileAgent	:=	self.getFileAgent();
	theFileAgent.progressStart(null, null, null, JSSFMFileAgent.COPY_CHUNK_SIZE);
	
	foreach theContainer in self.aAllCutAndPasteObjects do : containerLoop
		foreach theNode in theContainer.JSSFMFolder.allFileNodes do
			create theFileNameForm;
			theFileNameForm.setFileNameInfo(theNode.fileName, theNode.pathName, theNode.isUnix, theNode.isFile, true);
			theFileNameForm.showModal();
			
			if theFileNameForm.modalResult = self.JSS_MODAL_CANCEL_ALL then
				break containerLoop;
				
			elseif theFileNameForm.modalResult = self.JSS_MODAL_UPDATE then
				newName			:=	theFileNameForm.aNewFileName;
				originalName	:=	theNode.pathName;
				nodeType		:=	theNode.nodeType;
				
				if nodeType = self.LISTBOX_NODE_LOCAL_FOLDER then
					nodeOptions	:=	JSSFMFileManagerService.NODE_SOURCE_CLIENT + JSSFMFileManagerService.NODE_TARGET_CLIENT;
				elseif nodeType = self.LISTBOX_NODE_LOCAL_FILE then
					nodeOptions	:=	JSSFMFileManagerService.NODE_SOURCE_CLIENT;
				elseif nodeType = self.LISTBOX_NODE_APP_SERVER_FOLDER then
					nodeOptions	:=	JSSFMFileManagerService.NODE_SOURCE_APPSERVER + JSSFMFileManagerService.NODE_TARGET_APPSERVER;
				elseif nodeType = self.LISTBOX_NODE_APP_SERVER_FILE then
					nodeOptions	:=	JSSFMFileManagerService.NODE_SOURCE_APPSERVER;
				elseif nodeType = self.LISTBOX_NODE_DB_SERVER_FOLDER then
					nodeOptions	:=	JSSFMFileManagerService.NODE_SOURCE_DBSERVER + JSSFMFileManagerService.NODE_TARGET_DBSERVER;
				elseif nodeType = self.LISTBOX_NODE_DB_SERVER_FILE then
					nodeOptions	:=	JSSFMFileManagerService.NODE_SOURCE_DBSERVER;
				endif;
				
				if theNode.isFolder then
					theFileAgent.renameDirectory(originalName, newName, nodeOptions);
					
					// Now refresh the lists and tables to reflect the new name.
					
					self.listRenameDirectory(lstDirTop, originalName, newName);
					self.listRenameDirectory(lstDirBottom, originalName, newName);
					self.tableRenameFileNode(tblFilesTop, originalName, newName);
					self.tableRenameFileNode(tblFilesBottom, originalName, newName);
				else
					// Now refresh the tables to reflect the new name.
					
					self.getFileAgent().renameFile(originalName, newName, nodeOptions);
					self.tableRenameFileNode(tblFilesTop, originalName, newName);
					self.tableRenameFileNode(tblFilesBottom, originalName, newName);
				endif;
			endif;
		endforeach;
	endforeach;
epilog
	theFileAgent.progressEnd();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doUpdateUserProfile" id="a1b14e43-faf2-4b6e-81ca-e92fa209a56f">
        <source>doUpdateUserProfile(pIsClearSettings:Boolean) protected;
// --------------------------------------------------------------------------------
// Created:		15 July 2002 by cnwdad1
//
// Purpose:		Updates the user profile details with the current File Browser
//				window dimensions and state etc.
//
// Parameters:	pIsClearSettings - If true, then the user profile for the workstation
//				is deleted, otherwise the current window settings will be updated.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theTransactionAgent	: JSSFMTransactionAgent;
	
begin
	if self.aMyServiceManager.isInLocalSchema then
		theTransactionAgent	:=	self.aMyServiceManager.getTA();
		
		if pIsClearSettings then
			theTransactionAgent.trxDeleteUserProfile(app.computerName(), app.myRoot);
		else
			theTransactionAgent.trxUpdateUserProfile(	app.computerName(),
														self.windowState,
														self.left,
														self.top,
														self.width,
														self.height,
														app.myRoot);
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pIsClearSettings" type="Boolean"/>
    </JadeMethod>
