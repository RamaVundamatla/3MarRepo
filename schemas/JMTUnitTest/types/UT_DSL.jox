    <JadeMethod name="processPrenoteContainer" id="6fc0ba45-e38e-402f-8b55-b5a80d62019c">
        <source>processPrenoteContainer(_id: String; _isoType: String; _commodity: String; _operator: CM_Operator; _weight : Decimal; _voyage : CM_Voyage; _dischargePort : String; _bookingRef : String; _action : String) : CM_TrackedItem;
//18 Jan 2010 cnwrs1 par21329	
// 08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
// 19/09/2012	cnwcs5		par 30316 - create edi data to pass to trx method so trx method does not need code just for a unit test
// 13 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
vars
	pxyPreNote 	: CM_TrackedItem;
	preNote 	: CM_TrackedItem;
	ifArray		: CMIF_PrenoteSet;
	ifPreNote	: CMIF_PreNote;
	ediData		: CM_EDIDataPrenote;
begin
	create ifArray transient;
	create ifPreNote transient;	
	create ediData transient;
	
	preNote := app.getMyTerminalDO_NOT_USE().allNotifiedTIsByCargoTypeId[TI_CargoType_Container, _id];
	
	if preNote &lt;&gt; null then 
		if _action &lt;&gt; "D" then
			ifPreNote.setFromTI(preNote, self.getTerminal);
			beginLoad;
			pxyPreNote := preNote.pxyCreateUpdateProxy().CM_TrackedItem;
			endLoad;
			ifPreNote.setMyOriginalProxyTI(pxyPreNote);
		else
			ifPreNote.setMyPersistentTrackedItem(preNote);
		endif;
	endif;
	
	ifPreNote.id := _id;
	ifPreNote.myTerminal := self.getTerminal;
	ifPreNote.cargoType := TI_CargoType_Container;
	ifPreNote.isoType := _isoType;
	ifPreNote.commodity := _commodity;
	ifPreNote.imExStatus := getRoot.allImexStatuses[TI_IMEX_STATUS_EXPORT];
	ifPreNote.operatorCode := _operator.code;
	ifPreNote.weightTotal := _weight;
	ifPreNote.voyageCode := _voyage.code;
	ifPreNote.dischargePort := _dischargePort;
	ifPreNote.transportMode := TI_TRANSMODE_ROAD_STR;
	ifPreNote.bookingReference := _bookingRef;
	ifPreNote.myBookingRefItem := null;
	ifPreNote.action := _action;
	ifArray.add(ifPreNote);
	
	self.ignoreTrxWarnings(true);
	//app.myPassport.setWarningsIgnored(true);
	app.myTrxUA.trxProcessEDIPreNotes(ifArray, false, ediData, app.myPassport);
	self.assertNoTrxErrorsOrWarnings;
	
	preNote := app.getMyTerminalDO_NOT_USE().allNotifiedTIsByCargoTypeId[TI_CargoType_Container, _id];
	return preNote;
epilog
	endLoad;				// 08/04/2011 cnwmh5 #27347
	delete pxyPreNote;
	delete ifArray;
	delete ifPreNote;
	delete ediData;
end;
</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_isoType" type="String"/>
        <Parameter name="_commodity" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_dischargePort" type="String"/>
        <Parameter name="_bookingRef" type="String"/>
        <Parameter name="_action" type="String"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="purgeStops" id="618a3c86-797c-4dc7-ad04-b1d8602eae6b">
        <source>purgeStops(_ti: CM_TrackedItem);
// ---------------------------------------------------------------------------
// Created:     JULY 2012 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin
	if _ti.getAllStops = null or _ti.getAllStops.isEmpty then
		return;
	endif;

	
	beginTransaction;
	_ti.getAllStops.purge();
	commitTransaction;
	
epilog
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="queueWLE" id="9b7bffa2-37af-4708-ac1d-578d652c5bfd">
        <source>queueWLE(_wle :CM_WorkListEntry);
/*
Date		Who		Reason
01 May 2012	cnwcs5	Initial creation - CCMS POL 2172 / par 29480 coparn release updates
*/
vars
	wleArray,
