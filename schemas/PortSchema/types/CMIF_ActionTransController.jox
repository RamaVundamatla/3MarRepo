<Class name="CMIF_ActionTransController" id="4e2bd844-4117-4e9a-b31f-3dcaa115fb7e">
    <superclass name="CMIF_TITransactionController"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="transact"/>
    <PrimAttribute name="action" id="f4cd8ed3-7952-4e6e-8837-3c5b233aebb6">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <JadeMethod name="setFromTransaction" id="f5a37f50-307d-4ec9-9eb8-cdb7708590c3">
        <updating/>
        <source>setFromTransaction(_txn: CM_TITransaction) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 October 2017	jlgndl1	Initial creation	TFS 5744

*/

vars

begin

	inheritMethod(_txn);
	
	if CM_Aggregated.hasInstance(_txn) then
		self.action := _txn.CM_Aggregated.action;
	elseif CM_Packaged.hasInstance(_txn) then
		self.action := _txn.CM_Packaged.action;
	elseif CM_Blend.hasInstance(_txn) then
		self.action := _txn.CM_Blend.action;
	else
		//no action
	endif;

epilog

end;</source>
        <Parameter name="_txn" type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="setTransactionDetails" id="e15c14a0-2781-4f72-a58c-9bb0b92fb1c4">
        <updating/>
        <source>setTransactionDetails(pTrx: CM_TITransaction input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 October 2017	jlgndl1	Initial creation

*/

vars

begin

	inheritMethod(pTrx);
	
	if CM_Aggregated.hasInstance(pTrx) then
		pTrx.CM_Aggregated.setAction(self.action);
	elseif CM_Packaged.hasInstance(pTrx) then
		pTrx.CM_Packaged.setAction(self.action);
	elseif CM_Blend.hasInstance(pTrx) then	//24 May 2021	NDL	TFS 51243
		pTrx.CM_Blend.setAction(self.action);
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="pTrx" type="CM_TITransaction" usage="input"/>
    </JadeMethod>
</Class>
