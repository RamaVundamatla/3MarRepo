    <JadeMethod name="updateHazardsFromDetailForm" id="827e7a77-a542-43c2-877c-919792f9cb19">
        <updating/>
        <source>updateHazardsFromDetailForm(_hazDict: CM_HazardByCodeDict): Boolean updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 16 November 2016	cnwdap1		Initial creation PAR #
//
vars
	str : String;

begin
	self.lstHazards.setSelected(_hazDict);
	str := self.lstHazards.getSelectedString();
	if str.length &gt; 37 then
		self.txtHazards.text := str[1:36] &amp; '...';
	else
		self.txtHazards.text := str;
	endif;
	
	return true;
epilog

end;</source>
        <Parameter name="_hazDict" type="CM_HazardByCodeDict"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
