    <JadeMethod name="doCheckPartyRules_AddRelease" id="57aa3211-4323-42ed-92d4-dca878b2e688">
        <source>doCheckPartyRules_AddRelease(_release :CM_BulkRelease; _rules :CM_EDIPartyCoparnRules; _checkVoyage, _checkGrade, _checkGenerator :Boolean) protected;
/*
Date		Who		Reason
01 December 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
*/
vars
	detail, genDetail	:CM_ReserveDetail;
	isoType				:CM_ISOType;
	genOK, foundGen		:Boolean;
begin
	// releases should always be created with a status of pending
	self.assertEqualMsg (_release.status, _rules.defaultReleaseStatus, 'Release should have a status of ' &amp; 
							app.releaseStatusEnumToString(_rules.defaultReleaseStatus));
	
	// send email for updates - no check heer as depends on file !!!
	
	// send email for deletes - no check heer as depends on file !!!
		
	// create RR for generator/generator ISO type - not check here as depends on file !!!
	
	// subterminal
	self.assertEqualMsg (_release.mySubTerminal, _rules.myDefaultSubTerminal, 'Sub terminal does not match default');
	// carrier
	self.assertEqualMsg (_release.getCarrier, _rules.myDefaultCarrier, 'Carrier does not match default');
	// release type
	self.assertEqualMsg (_release.type, _rules.defaultReleaseType, 'Release type does not match default');
	// voyage
	self.assertNotNullMsg (_release.myVoyage, 'Voyage not set');

	if _checkVoyage then
		self.assertEqualMsg (_release.myVoyage, _rules.myDefaultVoyage, 'Voyage does not match default');
	endif;
	// delivery reason
	self.assertEqualMsg (_release.deliveryReasonCode, _rules.defaultDeliveryReasonCode, 'DeliveryReason does not match default');
	// availability grades
	foreach detail in _release.allReserveDetails do
		if not detail.isKindOf (CM_ReserveSelection) then
			continue;
		endif;
		
		isoType := detail.getISOType;
		
		self.assertNotNullMsg (isoType, 'ISO type has not been set');
		
		if _checkGrade and not isoType.isGenerator then
			if not isoType.isReefer  then
				// grade (dry)
				if _rules.defaultAvailabilityGrade &lt;&gt; null then
					self.assertTrueMsg (detail.CM_ReserveSelection.allAvailabilityGrades.includes (_rules.defaultAvailabilityGrade), _release.code &amp; ' Grade (dry) does not match default');
				endif;
			else
				// grade (reefer)
				if _rules.defaultAvailabilityGradeReefer &lt;&gt; null then
					self.assertTrueMsg (detail.CM_ReserveSelection.allAvailabilityGrades.includes (_rules.defaultAvailabilityGradeReefer), _release.code &amp; ' Grade (reefer) does not match default');
				endif;
			endif;	
		endif;
		
		// use ISO group
		if _rules.useISOGroupForReleaseRequests then
			self.assertEqualMsg (detail.CM_ReserveSelection.myISOGroup, isoType.myISOTypeGroup, 'ISO group has not been set');
		else
			self.assertNullMsg (detail.CM_ReserveSelection.myISOGroup, 'ISO group should not be set');
		endif;

		//
		if _checkGenerator and _rules.createReleaseForEQA_plus_RD then
			// I need to find a generator release request
			if isoType.isGenerator then
				if isoType = _rules.myISOTypeForEQD_plus_RD then
					foundGen := true;
					self.assertEqualMsg (detail.CM_ReserveSelection.totalRequested, 1, 'GENERATOR QUANTITY SHOULD BE 1');
				endif;
			endif;
		endif;
	endforeach;

	if _checkGenerator and _rules.createReleaseForEQA_plus_RD then
		self.assertTrueMsg (foundGen, 'No generator release found');
	endif;
		
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_release" type="CM_BulkRelease"/>
        <Parameter name="_rules" type="CM_EDIPartyCoparnRules"/>
        <Parameter name="_checkVoyage" type="Boolean"/>
        <Parameter name="_checkGrade" type="Boolean"/>
        <Parameter name="_checkGenerator" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doCoparn_Multi_CCMS2221" id="8638747c-bae5-47c3-8003-4e7538483b30">
        <source>doCoparn_Multi_CCMS2221(_sender, _voyageCode, _vesselName, _consignorCode, _consigneeCode :String; 
							_operator :CM_Operator; _ta :CM_TerminalArea; _rules :CM_EDIPartyCoparnRules input) protected;
/*
Date		Who		Reason
19 August 2013	cnwcs5		CCMS POL 2221 / par 32094(2)
//23 Mar 2015	cnwrs1	Par 35827 - for error 88612 set the status to skip processing
// 31 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
// 16 Feb 2018	jlgrs1	TFS 36951 JMT Prenote Partial for GateDoc
*/
constants
	RELEASEID1	= 'UT_REL2221011';
	RELEASEID2 	= 'UT_REL2221012';
	RELEASEID3 	= 'UT_REL2221013';
	RELEASEID4 	= 'UT_REL2221014';
	RELEASEID5 	= 'UT_REL2221015';
	CONTAINER 	= 'UT_TI222101';
	CONTAINER2 	= 'UT_TI222102';
	ISOTYPE1 = '2200';
	ISOTYPE2 = '4010';
	ISOTYPE3 = '22G1';
	ISOTYPE4 = '42G1';
	MT = '4';
vars
	text	:String;
	ediFile	:CM_EDIFile;
	ediData	:CM_EDIData;
	ediTI	:CM_EDITrackedItem;
	release1, release2, release3, release4, release5	:CM_BulkRelease;
	detail	:CM_ReserveDetail;
	coll	:CM_BulkReleaseSet;
	ediColl	:CM_EDITISet;
	ti		:CM_TrackedItem;
	vvr		:CM_VehicleVisitRecord;
	gate	:CM_Gate;
	wle		:CM_WorkListEntry;
	error	:CM_EDIError;
	set	:CM_EDITISet;
	isPartial	:Boolean;
	ts1, ts2 :TimeStamp;
	ext		:String;
	ediItem : CM_EDITrackedItem;
begin
	isPartial := self.getTerminal().getConfig(EdiReleaseAllowPartial).Boolean;
	
	if isPartial then
		ext := '(partial)';
	endif;
//	-------------------------------------
//	get rid of left overs from last time
//	-------------------------------------
	self.deleteReleaseRequest(RELEASEID1);
	self.deleteReleaseRequest(RELEASEID2);
	self.deleteReleaseRequest(RELEASEID3);
	self.deleteReleaseRequest(RELEASEID4);
	self.deleteReleaseRequest(RELEASEID5);

	self.deleteContainer(CONTAINER);
	self.deleteContainer(CONTAINER2);
//	-----------------------------------------------------------------
//	add cargo, truck, terminal area so we can assign release to truck
//	------------------------------------------------------------------
	self.opts.purge;
	self.opts.addAssociation(UTTI_Consignee, _consigneeCode);
	self.opts.addAssociation(UTTI_Consignor, _consignorCode);
	self.opts.addAssociation(UTTI_DeliveryRelease, 'christina');
	self.opts.addAssociation('deliveryNumber', 'christina');
	self.opts.addAssociation(UTTI_IMEX, TI_IMEX_STATUS_STORAGE);
	
	ti := self.addContainerOpts(CONTAINER, ISOTYPE1, "MT", _operator);
	
	self.assertEqual(ti.consignee, _consigneeCode);
	self.assertEqual(ti.consignor, _consignorCode);
	self.assertEqual(ti.deliveryRelease, 'christina');
	
	self.move(ti, _ta);
	assertEqual(ti.myPrimaryActualLocation, _ta.allLocationsControllers.first);
	
	foreach gate in self.getTerminal.allGates do
		if not gate.hasPGateAreas then
			// single
			break;
		endif;
		gate := null;
	endforeach;
	
	self.assertNotNull(gate);

	create coll transient;
	create ediColl transient;
//	----------------------------------------------------
// 	create some  new releases which we will update later
//	----------------------------------------------------
	text 	:= self.zCoparn_mtrel_multi_CCMS2221(_sender, _voyageCode, _vesselName, 
													RELEASEID1, RELEASEID2, RELEASEID3, RELEASEID4, RELEASEID5, 
													ISOTYPE1, ISOTYPE2, ts1, ts2);
													
	ediFile := self.ediLoadFileName(text, EDIFileType_Coparn, "COPARN", "COPARN Add 5 releases" &amp; ext);			
	
	self.assertNotNull(ediFile);
	
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) then
		isPartial := true;
	endif;
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) or
	   ediFile.ediData.isKindOf(CM_EDIDataReleaseRequest) then
		ediData := ediFile.ediData;
	else
		ediData := ediFile.allEDIData.first;
	endif;
	
	self.assertNotNullMsg(ediData, 'No edi data for release requests' &amp; ext);
	if ediData.isKindOf(CM_EDIDataGateDoc) then
		self.assertEqualMsg(ediData.allEDITrackedItems.size, 15, 'Expecting 15 EDi TIs for add'&amp; ext);
	endif;
	if ediData.isKindOf(CM_EDIDataReleaseRequest) then
		self.assertEqualMsg(ediData.allEDITrackedItems.size, 10, 'Expecting 10 EDi TIs for add'&amp; ext);
	endif;
//	ediTI := ediData.allEDITrackedItems.first.CM_EDIRequestHeaderTI;
	foreach ediItem in ediData.allEDITrackedItems do
		if  ediItem.isKindOf(CM_EDIRequestHeaderTI) then
			ediTI := ediItem.CM_EDIRequestHeaderTI;
			break;
		endif;
		if  ediItem.isKindOf(CM_EDIReleaseRequestTI) then
			ediTI := ediItem.CM_EDIReleaseRequestTI;
			break;
		endif;
	endforeach;
	
	self.assertNotNullMsg(ediTI, 'EDI tracked items not created'&amp; ext);
	
	self.ediDBLoad(ediFile);

	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, 'DBLoad failed' &amp; ext &amp; CrLf &amp; app.myPassport.getErrorsAsString);

	release1 := self.getReleaseRequest(RELEASEID1);
	
	self.assertNotNull(release1);
	self.assertEqualMsg(release1.totalRequested, 1*2, RELEASEID1 &amp; ' Quantity is incorrect'&amp; ext); 
	coll.add(release1);
	beginTransaction;
	release1.setBlockEDIUpdates(true);
	commitTransaction;
	
	release2 := self.getReleaseRequest(RELEASEID2);
	
	self.assertNotNull(release2);
	self.assertEqualMsg(release2.totalRequested, 2*2, RELEASEID2 &amp; ' Quantity is incorrect'&amp; ext); 
	coll.add(release2);


	release3 := self.getReleaseRequest(RELEASEID3);
	
	self.assertNotNull(release3);
	self.assertEqualMsg(release3.totalRequested, 3*2, RELEASEID3 &amp; ' Quantity is incorrect'&amp; ext); 
	coll.add(release3);
	beginTransaction;
	release3.setBlockEDIUpdates(true);
	commitTransaction;
	
	release4 := self.getReleaseRequest(RELEASEID4);
	
	self.assertNotNull(release4);
	self.assertEqualMsg(release4.totalRequested, 4*2, RELEASEID4 &amp; ' Quantity is incorrect'&amp; ext); 
	coll.add(release4);
	
	release5 := self.getReleaseRequest(RELEASEID5);
	
	self.assertNotNull(release5);
	self.assertEqualMsg(release5.totalRequested, 5*2, RELEASEID5 &amp; ' Quantity is incorrect'&amp; ext); 
	coll.add(release5);
	beginTransaction;
	release5.setBlockEDIUpdates(true);
	commitTransaction;
//	----------------------------------------------------------------
// 	change to road releases - release 1, 3, &amp; 5 are blocked
//	----------------------------------------------------------------
	app.myTrxUA.trxSetReleaseRequestsType(BR_TYPE_ROAD, coll, app.myPassport);
	
	self.assertNoTrxErrors();
	
	self.assertEqual(release1.type, BR_TYPE_ROAD);	
	self.assertEqual(release2.type, BR_TYPE_ROAD);	
	self.assertEqual(release3.type, BR_TYPE_ROAD);	
	self.assertEqual(release4.type, BR_TYPE_ROAD);	
	self.assertEqual(release5.type, BR_TYPE_ROAD);	
	
	app.myTrxUA.trxSetReleaseRequestsStatus(BR_ACTIVE, coll, app.myPassport);
	
	self.assertNoTrxErrors();
	
	self.assertEqual(release1.status, BR_ACTIVE);
	self.assertEqual(release2.status, BR_ACTIVE);
	self.assertEqual(release3.status, BR_ACTIVE);
	self.assertEqual(release4.status, BR_ACTIVE);
	self.assertEqual(release5.status, BR_ACTIVE);
	
//	----------------------------------------------------------------
// 	load EDI update for the new releases
//	----------------------------------------------------------------
	text 	:= self.zCoparn_mtrel_multi_CCMS2221(_sender, _voyageCode, _vesselName, 
													RELEASEID1, RELEASEID2, RELEASEID3, RELEASEID4, RELEASEID5, 
													ISOTYPE3, ISOTYPE4, ts1, ts2);
													
	ediFile := self.ediLoadFileName(text, EDIFileType_Coparn, "COPARN", "COPARN - update 5 releases(1)"&amp; ext);			
	
	self.assertNotNull(ediFile);
	
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) or
	   ediFile.ediData.isKindOf(CM_EDIDataReleaseRequest) then
		ediData := ediFile.ediData;
	else
		ediData := ediFile.allEDIData.first;
	endif;
	
	self.assertNotNullMsg(ediData, 'No edi data for release requests');
	if ediData.isKindOf(CM_EDIDataGateDoc) then
		self.assertEqualMsg(ediData.allEDITrackedItems.size, 15, 'Expecting 15 EDi TIs for update'&amp; ext);
	endif;
	if ediData.isKindOf(CM_EDIDataReleaseRequest) then
		self.assertEqualMsg(ediData.allEDITrackedItems.size, 10, 'Expecting 10 EDi TIs for update'&amp; ext);
	endif;
	self.ediDBLoad(ediFile);
	if ediData.isKindOf(CM_EDIDataGateDoc) then
		self.assertEqualMsg(ediData.allErrorWarnings.size, 3, 'Expecting 3 errors' &amp; ext);
	endif;
	if ediData.isKindOf(CM_EDIDataReleaseRequest) then
		self.assertEqualMsg(ediData.allErrorWarnings.size, 6, 'Expecting 6 errors' &amp; ext);
	endif;
	foreach ediTI in ediData.allEDITrackedItems do
		if ediTI.isKindOf(CM_EDIRequestHeaderTI) then
			if ediTI.CM_EDIRequestHeaderTI.releaseRequestNumber = RELEASEID1 or
				ediTI.CM_EDIRequestHeaderTI.releaseRequestNumber = RELEASEID3 or
				ediTI.CM_EDIRequestHeaderTI.releaseRequestNumber = RELEASEID5 then
				self.assertEqualMsg(ediTI.status, CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING_X, ediTI.CM_EDIRequestHeaderTI.releaseRequestNumber &amp; ' should be skip processing(*)'&amp;ext);
			else
				if isPartial then
					self.assertEqualMsg(ediTI.status, CM_EDITrackedItem.EDI_STATUS_DBLOADED, ediTI.CM_EDIRequestHeaderTI.releaseRequestNumber &amp; ' should be DB Loaded'&amp;ext);
				else
					self.assertEqualMsg(ediTI.status, CM_EDITrackedItem.EDI_STATUS_DBLOADED, ediTI.CM_EDIRequestHeaderTI.releaseRequestNumber &amp; ' should be VERIFIED '&amp;ext);
				endif;
			endif;
		endif;
		if ediTI.isKindOf(CM_EDIReleaseRequestTI) then
			if ediTI.CM_EDIReleaseRequestTI.releaseRequestNumber = RELEASEID1 or
				ediTI.CM_EDIReleaseRequestTI.releaseRequestNumber = RELEASEID3 or
				ediTI.CM_EDIReleaseRequestTI.releaseRequestNumber = RELEASEID5 then
				self.assertEqualMsg (ediTI.status, CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING_X, ediTI.CM_EDIReleaseRequestTI.releaseRequestNumber &amp; ' should be skip processing (*)'&amp;ext);
			else
				if isPartial then
					self.assertEqualMsg (ediTI.status, CM_EDITrackedItem.EDI_STATUS_DBLOADED, ediTI.CM_EDIReleaseRequestTI.releaseRequestNumber &amp; ' should be DB Loaded'&amp;ext);
				else
					self.assertEqualMsg (ediTI.status, CM_EDITrackedItem.EDI_STATUS_DBLOADED, ediTI.CM_EDIReleaseRequestTI.releaseRequestNumber &amp; ' should be VERIFIED '&amp;ext);
				endif;
			endif;
		endif;
	endforeach;

	if isPartial then
//		if ediData.isKindOf(CM_EDIDataReleaseRequest) then
			self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL_X, 'Expecting DB Partially Loaded(*)' &amp; CrLf &amp; app.myPassport.getErrorsAsString);
//		else
//			self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, 'Expecting DB Partially Loaded(*)' &amp; CrLf &amp; app.myPassport.getErrorsAsString);
//		endif;
	else
		if ediData.isKindOf(CM_EDIDataReleaseRequest) then
			self.assertIsOneOf(ediData.status, 'Expecting Verify_Errors' &amp; CrLf &amp; app.myPassport.getErrorsAsString, CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL_X, CM_EDIFile.EDI_STATUS_VERIFY_ERRORS_X);
		else
			self.assertIsOneOf(ediData.status, 'Expecting Verify_Errors' &amp; CrLf &amp; app.myPassport.getErrorsAsString, CM_EDIFile.EDI_STATUS_DBLOADED, CM_EDIFile.EDI_STATUS_VERIFY_ERRORS_X);
		endif;
	endif; 
	
//	---------------------------------------------------------
// 	set RELEASEID1 to be ignored and RELEASE5 to be processed - also change RELEASE3 to have invalid iso type
//	---------------------------------------------------------
	ediColl.clear;
	
	foreach ediTI in ediData.allEDITrackedItems do
		if ediTI.isKindOf(CM_EDIRequestHeaderTI) then
			if ediTI.CM_EDIRequestHeaderTI.releaseRequestNumber = RELEASEID1 then
				ediColl.add(ediTI);
			endif;
		endif;
		if ediTI.isKindOf(CM_EDIReleaseRequestTI) then
			if ediTI.CM_EDIReleaseRequestTI.releaseRequestNumber = RELEASEID1  then
				ediColl.add (ediTI);
			endif;
		endif;
	endforeach;
	
	app.myTrxUA.trxEDIIgnoreEDITrackedItem(ediColl, app.myPassport);

	foreach ediTI in ediData.allEDITrackedItems do
		if ediTI.isKindOf(CM_EDIRequestHeaderTI) then
			if ediTI.CM_EDIRequestHeaderTI.releaseRequestNumber = RELEASEID1 then
				self.assertEqualMsg(ediTI.status, CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING, ediTI.CM_EDIRequestHeaderTI.releaseRequestNumber &amp; ' should be skip processing' &amp; ext);
	//			self.assertEqualMsg(ediTI.getKeepPersistentErrors, true, 'Expecting keep errors = true ' &amp; ext);
				self.assertEqualMsg(ediTI.getIsToBeProcessed, false, 'Expecting is to be processed = false' &amp; ext);
			endif;
		endif;
		if ediTI.isKindOf(CM_EDIReleaseRequestTI) then
			if ediTI.CM_EDIReleaseRequestTI.releaseRequestNumber = RELEASEID1  then
				self.assertEqualMsg (ediTI.status, CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING, ediTI.CM_EDIReleaseRequestTI.releaseRequestNumber &amp; ' should be skip processing' &amp; ext);
	//			self.assertEqualMsg (ediTI.getKeepPersistentErrors, true, 'Expecting keep errors = true ' &amp; ext);
				self.assertEqualMsg (ediTI.getIsToBeProcessed, false, 'Expecting is to be processed = false' &amp; ext);
			endif;
		endif;
	endforeach;

	if ediData.isKindOf(CM_EDIDataGateDoc) then
		self.assertEqualMsg(ediData.allErrorWarnings.size, 3, 'Expecting 3 errors' &amp; ext);
	endif;
	if ediData.isKindOf(CM_EDIDataReleaseRequest) then
		self.assertEqualMsg(ediData.allErrorWarnings.size, 6, 'Expecting 6 errors' &amp; ext);
	endif;

	if isPartial then
//		if ediData.isKindOf(CM_EDIDataReleaseRequest) then
			self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL_X, 'Expecting DB Partially Loaded(*)' &amp;ext&amp; CrLf &amp; app.myPassport.getErrorsAsString);
//		else
//			self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, 'Expecting DB Partially Loaded(*)' &amp;ext&amp; CrLf &amp; app.myPassport.getErrorsAsString);
//		endif;
	else
//		self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL_X, 'Expecting Verify_Errors' &amp;ext&amp; CrLf &amp; app.myPassport.getErrorsAsString);
		if ediData.isKindOf(CM_EDIDataReleaseRequest) then
			self.assertIsOneOf(ediData.status, 'Expecting Verify_Errors' &amp;ext&amp; CrLf &amp; app.myPassport.getErrorsAsString, CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL_X, CM_EDIFile.EDI_STATUS_VERIFY_ERRORS_X);
		else
			self.assertIsOneOf(ediData.status, 'Expecting Verify_Errors' &amp;ext&amp; CrLf &amp; app.myPassport.getErrorsAsString, CM_EDIFile.EDI_STATUS_DBLOADED, CM_EDIFile.EDI_STATUS_VERIFY_ERRORS_X);
		endif;
	endif; 
	
	ediColl.clear;
	
	foreach ediTI in ediData.allEDITrackedItems do
		if ediTI.isKindOf(CM_EDIRequestDetailTI) then
			if ediTI.CM_EDIRequestDetailTI.releaseRequestNumber = RELEASEID3  then
				beginTransaction;
				ediTI.setPropertyValue(CM_EDIRequestDetailTI::isoType.name, 'XXXX');
				commitTransaction;
			elseif ediTI.CM_EDIRequestDetailTI.releaseRequestNumber = RELEASEID5  then
				ediColl.add(ediTI);
			endif;
		endif;
		if ediTI.isKindOf(CM_EDIReleaseRequestTI) then
			if ediTI.CM_EDIReleaseRequestTI.releaseRequestNumber = RELEASEID3  then
				beginTransaction;
				ediTI.setPropertyValue (CM_EDIReleaseRequestTI::isoType.name, 'XXXX');
				commitTransaction;
			elseif ediTI.CM_EDIReleaseRequestTI.releaseRequestNumber = RELEASEID5  then
				ediColl.add (ediTI);
			endif;
		endif;
	endforeach;
	
	app.myTrxUA.trxEDIProcessEDITrackedItem(ediColl, app.myPassport);
	
	foreach ediTI in ediData.allEDITrackedItems do
		if ediTI.isKindOf(CM_EDIRequestHeaderTI) then
			if ediTI.CM_EDIRequestHeaderTI.releaseRequestNumber = RELEASEID5  then
				self.assertEqualMsg(ediTI.status, CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING_X, ediTI.CM_EDIRequestHeaderTI.releaseRequestNumber &amp; ' should be unprocessed' &amp; ext);
				self.assertEqualMsg(ediTI.getKeepPersistentErrors, true, 'Expecting keep errors = false ' &amp; ext);
				self.assertEqualMsg(ediTI.getIsToBeProcessed, false, 'Expecting is to be processed = true' &amp; ext);
			endif;
		endif;
		if ediTI.isKindOf(CM_EDIReleaseRequestTI) then
			if ediTI.CM_EDIReleaseRequestTI.releaseRequestNumber = RELEASEID5  then
				self.assertEqualMsg (ediTI.status, CM_EDITrackedItem.EDI_STATUS_UNPROCESSED, ediTI.CM_EDIReleaseRequestTI.releaseRequestNumber &amp; ' should be unprocessed' &amp; ext);
				self.assertEqualMsg (ediTI.getKeepPersistentErrors, false, 'Expecting keep errors = false ' &amp; ext);
				self.assertEqualMsg (ediTI.getIsToBeProcessed, true, 'Expecting is to be processed = true' &amp; ext);
			endif;
		endif;
	endforeach;
	
	if ediData.isKindOf(CM_EDIDataGateDoc) then
		self.assertEqualMsg(ediData.allErrorWarnings.size, 3, 'Expecting 3 errors' &amp; ext);
	endif;
	if ediData.isKindOf(CM_EDIDataReleaseRequest) then
		self.assertEqualMsg(ediData.allErrorWarnings.size, 6, 'Expecting 6 errors' &amp; ext);
	endif;

	if ediData.isKindOf(CM_EDIDataGateDoc) then
//		if isPartial then
			self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL_X, 'Expecting DB Partially Loaded' &amp; ext &amp; CrLf &amp; app.myPassport.getErrorsAsString);
//		else
//			self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL_X, 'Expecting Verify_Errors' &amp; ext &amp; CrLf &amp; app.myPassport.getErrorsAsString);
//			self.assertIsOneOf(ediData.status, 'Expecting Verify_Errors' &amp;ext&amp; CrLf &amp; app.myPassport.getErrorsAsString, CM_EDIFile.EDI_STATUS_DBLOADED, CM_EDIFile.EDI_STATUS_VERIFY_ERRORS_X);
//		endif; 
	elseif ediData.isKindOf(CM_EDIDataReleaseRequest) then
		if isPartial then
			self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL, 'Expecting DB Partially Loaded' &amp; ext &amp; CrLf &amp; app.myPassport.getErrorsAsString);
		else
			self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL, 'Expecting Verify_Errors' &amp; ext &amp; CrLf &amp; app.myPassport.getErrorsAsString);
		endif;
	endif;
//	---------------------------------------------------------
// 	reload the file - RELEASE5 should be updated(if partial)
//	---------------------------------------------------------
	self.ediDBLoad(ediFile);

	if ediData.isKindOf(CM_EDIDataGateDoc) then
		self.assertEqualMsg(ediData.allErrorWarnings.size, 3, 'Expecting 3 errors' &amp; ext);
	endif;
	if ediData.isKindOf(CM_EDIDataReleaseRequest) then
		self.assertEqualMsg(ediData.allErrorWarnings.size, 4, 'Expecting 4 errors' &amp; ext);
	endif;

	foreach ediTI in ediData.allEDITrackedItems do
		if ediTI.isKindOf(CM_EDIRequestHeaderTI) then
			if ediTI.CM_EDIRequestHeaderTI.releaseRequestNumber = RELEASEID1 then 
				self.assertEqualMsg(ediTI.status, CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING, ediTI.CM_EDIRequestHeaderTI.releaseRequestNumber &amp; ' should be skip processing'&amp;ext);
	
			elseif ediTI.CM_EDIRequestHeaderTI.releaseRequestNumber = RELEASEID3 or
				   ediTI.CM_EDIRequestHeaderTI.releaseRequestNumber = RELEASEID5 then
				self.assertEqualMsg(ediTI.status, CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING_X, ediTI.CM_EDIRequestHeaderTI.releaseRequestNumber &amp; ' should be skip processing(*)'&amp;ext);
			
			else
				if isPartial then
					self.assertEqualMsg(ediTI.status, CM_EDITrackedItem.EDI_STATUS_DBLOADED, ediTI.CM_EDIRequestHeaderTI.releaseRequestNumber &amp; ' should be DB Loaded'&amp;ext);
				else
//					self.assertEqualMsg(ediTI.status, CM_EDITrackedItem.EDI_STATUS_DBLOADED, ediTI.CM_EDIRequestHeaderTI.releaseRequestNumber &amp; ' should be VERIFIED '&amp;ext);
					self.assertIsOneOf(ediData.status, 'Expecting Verify_Errors' &amp;ext&amp; CrLf &amp; app.myPassport.getErrorsAsString, CM_EDIFile.EDI_STATUS_DBLOADED, CM_EDIFile.EDI_STATUS_VERIFY_ERRORS_X);
				endif;
			endif;
		endif;
		if ediTI.isKindOf(CM_EDIReleaseRequestTI) then
			if ediTI.CM_EDIReleaseRequestTI.releaseRequestNumber = RELEASEID1 then 
				self.assertEqualMsg (ediTI.status, CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING, ediTI.CM_EDIReleaseRequestTI.releaseRequestNumber &amp; ' should be skip processing'&amp;ext);
	
			elseif ediTI.CM_EDIReleaseRequestTI.releaseRequestNumber = RELEASEID3 then
				self.assertEqualMsg (ediTI.status, CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING_X, ediTI.CM_EDIReleaseRequestTI.releaseRequestNumber &amp; ' should be skip processing (*)'&amp;ext);
			
			else
				if isPartial then
					self.assertEqualMsg (ediTI.status, CM_EDITrackedItem.EDI_STATUS_DBLOADED, ediTI.CM_EDIReleaseRequestTI.releaseRequestNumber &amp; ' should be DB Loaded'&amp;ext);
				else
					self.assertEqualMsg (ediTI.status, CM_EDITrackedItem.EDI_STATUS_DBLOADED, ediTI.CM_EDIReleaseRequestTI.releaseRequestNumber &amp; ' should be VERIFIED '&amp;ext);
				endif;
			endif;
		endif;
	endforeach;

	if isPartial then
//		if ediData.isKindOf(CM_EDIDataReleaseRequest) then
			self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL_X, 'Expecting DB Partially Loaded(*)' &amp; CrLf &amp; app.myPassport.getErrorsAsString);
//		else
//			self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, 'Expecting DB Partially Loaded(*)' &amp; CrLf &amp; app.myPassport.getErrorsAsString);
//		endif;
	else
		self.assertIsOneOf(ediData.status, 'Expecting Verify_Errors' &amp;ext&amp; CrLf &amp; app.myPassport.getErrorsAsString, CM_EDIFile.EDI_STATUS_DBLOADED, CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL_X);
//		self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL_X, 'Expecting Verify_Errors' &amp; CrLf &amp; app.myPassport.getErrorsAsString);
	endif; 

	if ediData.isKindOf(CM_EDIDataGateDoc) then
		foreach detail in release5.allReserveDetails do
			if isPartial then
				self.assertIsOneOf(detail.CM_ReserveSelection.getISOCode, 'Expecting '&amp;ISOTYPE1&amp;' or '&amp;ISOTYPE2&amp;' '&amp;ext, ISOTYPE1, ISOTYPE2);
			else
	//			self.assertIsOneOf(detail.CM_ReserveSelection.getISOCode, 'Expecting ' &amp; ISOTYPE1 &amp; ' or ' &amp; ISOTYPE2 &amp; ext, ISOTYPE1, ISOTYPE2);
			endif;
		endforeach;
	elseif ediData.isKindOf(CM_EDIDataReleaseRequest) then
		foreach detail in release5.allReserveDetails do
			if isPartial then
			self.assertIsOneOf (detail.CM_ReserveSelection.getISOCode, 'Expecting ' &amp; ISOTYPE3 &amp; ' or ' &amp; ISOTYPE4 &amp; ext, ISOTYPE3, ISOTYPE4);
			else
	//			self.assertIsOneOf(detail.CM_ReserveSelection.getISOCode, 'Expecting ' &amp; ISOTYPE1 &amp; ' or ' &amp; ISOTYPE2 &amp; ext, ISOTYPE1, ISOTYPE2);
			endif;
		endforeach;
	endif;
//	---------------------------------------------------------
// 	set RELEASE3 to be processed - expect other errors when we load file
//	---------------------------------------------------------
	ediColl.clear;
	
	foreach ediTI in ediData.allEDITrackedItems do
		if ediTI.isKindOf(CM_EDIRequestHeaderTI) then
			if ediTI.CM_EDIRequestHeaderTI.releaseRequestNumber = RELEASEID3  then
				ediColl.add(ediTI);
			endif;
		endif;
		if ediTI.isKindOf(CM_EDIReleaseRequestTI) then
			if ediTI.CM_EDIReleaseRequestTI.releaseRequestNumber = RELEASEID3  then
				ediColl.add (ediTI);
			endif;
		endif;
	endforeach;
	
	app.myTrxUA.trxEDIProcessEDITrackedItem(ediColl, app.myPassport);	
	
	foreach ediTI in ediData.allEDITrackedItems do
		if ediTI.isKindOf(CM_EDIRequestHeaderTI) then
			if ediTI.CM_EDIRequestHeaderTI.releaseRequestNumber = RELEASEID3  then
				self.assertEqualMsg(ediTI.status, CM_EDITrackedItem.EDI_STATUS_UNPROCESSED, ediTI.CM_EDIRequestHeaderTI.releaseRequestNumber &amp; ' should be unprocessed' &amp; ext);
				self.assertEqualMsg(ediTI.getKeepPersistentErrors, false, 'Expecting keep errors = false ' &amp; ext);
				self.assertEqualMsg(ediTI.getIsToBeProcessed, true, 'Expecting is to be processed = true' &amp; ext);
			endif;
		endif;
		if ediTI.isKindOf(CM_EDIReleaseRequestTI) then
			if ediTI.CM_EDIReleaseRequestTI.releaseRequestNumber = RELEASEID3  then
				self.assertEqualMsg (ediTI.status, CM_EDITrackedItem.EDI_STATUS_UNPROCESSED, ediTI.CM_EDIReleaseRequestTI.releaseRequestNumber &amp; ' should be unprocessed' &amp; ext);
				self.assertEqualMsg (ediTI.getKeepPersistentErrors, false, 'Expecting keep errors = false ' &amp; ext);
				self.assertEqualMsg (ediTI.getIsToBeProcessed, true, 'Expecting is to be processed = true' &amp; ext);
			endif;
		endif;
	endforeach;	

	self.ediDBLoad(ediFile);

	if isPartial then
		if ediData.isKindOf(CM_EDIDataGateDoc) then
			self.assertEqualMsg(ediData.allErrorWarnings.size, 0, 'Expecting 4 errors' &amp; ext);	// 2 blocked, 2 iso type
		elseif ediData.isKindOf(CM_EDIDataReleaseRequest) then
			self.assertEqualMsg(ediData.allErrorWarnings.size, 2, 'Expecting 2 errors' &amp; ext);	// 2 blocked, 2 iso type
		endif;
	else	
		if ediData.isKindOf(CM_EDIDataGateDoc) then
			self.assertEqualMsg(ediData.allErrorWarnings.size, 2, 'Expecting 2 errors' &amp; ext);	// 2 blocked, 2 iso type
		elseif ediData.isKindOf(CM_EDIDataReleaseRequest) then
			self.assertEqualMsg(ediData.allErrorWarnings.size, 4, 'Expecting 4 errors' &amp; ext);	// 2 blocked, 2 iso type
		endif;
	endif;

	foreach ediTI in ediData.allEDITrackedItems do
		if ediTI.isKindOf(CM_EDIRequestHeaderTI) then
			if isPartial then
				if ediTI.CM_EDIRequestHeaderTI.releaseRequestNumber = RELEASEID1 then 
					self.assertEqualMsg(ediTI.status, CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING, ediTI.CM_EDIRequestHeaderTI.releaseRequestNumber &amp; ' should be skip processing'&amp;ext);
				elseif ediTI.CM_EDIRequestHeaderTI.releaseRequestNumber = RELEASEID2 then
					self.assertEqualMsg(ediTI.status, CM_EDITrackedItem.EDI_STATUS_DBLOADED, ediTI.CM_EDIRequestHeaderTI.releaseRequestNumber &amp; ' should be dbloaded errors'&amp;ext);
				elseif ediTI.CM_EDIRequestHeaderTI.releaseRequestNumber = RELEASEID3 then
					self.assertEqualMsg(ediTI.status, CM_EDITrackedItem.EDI_STATUS_VERIFIED_ERRORS, ediTI.CM_EDIRequestHeaderTI.releaseRequestNumber &amp; ' should be verify errors'&amp;ext);
				elseif ediTI.CM_EDIRequestHeaderTI.releaseRequestNumber = RELEASEID4 then
					self.assertEqualMsg(ediTI.status, CM_EDITrackedItem.EDI_STATUS_DBLOADED, ediTI.CM_EDIRequestHeaderTI.releaseRequestNumber &amp; ' should be dbloaded'&amp;ext);
				elseif ediTI.CM_EDIRequestHeaderTI.releaseRequestNumber = RELEASEID5 then
					self.assertEqualMsg(ediTI.status, CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING_X, ediTI.CM_EDIRequestHeaderTI.releaseRequestNumber &amp; ' should be skip x processing'&amp;ext);
				else
					if isPartial then
						self.assertEqualMsg(ediTI.status, CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING_X, ediTI.CM_EDIRequestHeaderTI.releaseRequestNumber &amp; ' should be DB Loaded'&amp;ext);
					else
		//				self.assertEqualMsg(ediTI.status, CM_EDITrackedItem.EDI_STATUS_VERIFIED, ediTI.CM_EDIRequestHeaderTI.releaseRequestNumber &amp; ' should be VERIFIED '&amp;ext);
					endif;
				endif;
			else
				if ediTI.CM_EDIRequestHeaderTI.releaseRequestNumber = RELEASEID1 then 
					self.assertEqualMsg(ediTI.status, CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING, ediTI.CM_EDIRequestHeaderTI.releaseRequestNumber &amp; ' should be skip processing'&amp;ext);
				elseif ediTI.CM_EDIRequestHeaderTI.releaseRequestNumber = RELEASEID2 then
					self.assertEqualMsg(ediTI.status, CM_EDITrackedItem.EDI_STATUS_DBLOADED, ediTI.CM_EDIRequestHeaderTI.releaseRequestNumber &amp; ' should be dbloaded errors'&amp;ext);
				elseif ediTI.CM_EDIRequestHeaderTI.releaseRequestNumber = RELEASEID3 then
					self.assertEqualMsg(ediTI.status, CM_EDITrackedItem.EDI_STATUS_VERIFIED_ERRORS, ediTI.CM_EDIRequestHeaderTI.releaseRequestNumber &amp; ' should be verify errors'&amp;ext);
				elseif ediTI.CM_EDIRequestHeaderTI.releaseRequestNumber = RELEASEID4 then
					self.assertEqualMsg(ediTI.status, CM_EDITrackedItem.EDI_STATUS_DBLOADED, ediTI.CM_EDIRequestHeaderTI.releaseRequestNumber &amp; ' should be dbloaded'&amp;ext);
				elseif ediTI.CM_EDIRequestHeaderTI.releaseRequestNumber = RELEASEID5 then
					self.assertEqualMsg(ediTI.status, CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING_X, ediTI.CM_EDIRequestHeaderTI.releaseRequestNumber &amp; ' should be skip x processing'&amp;ext);
				else
					if isPartial then
						self.assertEqualMsg(ediTI.status, CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING_X, ediTI.CM_EDIRequestHeaderTI.releaseRequestNumber &amp; ' should be DB Loaded'&amp;ext);
					else
		//				self.assertEqualMsg(ediTI.status, CM_EDITrackedItem.EDI_STATUS_VERIFIED, ediTI.CM_EDIRequestHeaderTI.releaseRequestNumber &amp; ' should be VERIFIED '&amp;ext);
					endif;
				endif;
			endif;
		endif;
		if ediTI.isKindOf(CM_EDIReleaseRequestTI) then
			if ediTI.CM_EDIReleaseRequestTI.releaseRequestNumber = RELEASEID1 then 
				self.assertEqualMsg (ediTI.status, CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING, ediTI.CM_EDIReleaseRequestTI.releaseRequestNumber &amp; ' should be skip processing'&amp;ext);
	
			elseif ediTI.CM_EDIReleaseRequestTI.releaseRequestNumber = RELEASEID3 then
				self.assertEqualMsg (ediTI.status, CM_EDITrackedItem.EDI_STATUS_VERIFIED_ERRORS, ediTI.CM_EDIReleaseRequestTI.releaseRequestNumber &amp; ' should be verify errors'&amp;ext);
			
			else
				if isPartial then
					self.assertEqualMsg (ediTI.status, CM_EDITrackedItem.EDI_STATUS_DBLOADED, ediTI.CM_EDIReleaseRequestTI.releaseRequestNumber &amp; ' should be DB Loaded'&amp;ext);
				else
					self.assertEqualMsg (ediTI.status, CM_EDITrackedItem.EDI_STATUS_DBLOADED, ediTI.CM_EDIReleaseRequestTI.releaseRequestNumber &amp; ' should be VERIFIED '&amp;ext);
				endif;
			endif;
		endif;
	endforeach;

epilog
	delete set;
	delete coll;
	delete ediColl;
end;</source>
