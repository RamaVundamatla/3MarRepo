    <JadeMethod name="createTransaction" id="809856d7-7562-4888-97d9-5a9eb01c6c90">
        <updating/>
        <source>createTransaction(_passport : CM_Passport input) : CM_Transaction updating;
/*
Purpose - 	
Who - NAVAB1
Date - 03OCT2024
ADO - JIRA 33015
*/

vars
	trans 			: CM_Transaction;
	theClass		: Class;
	containerId		: String;
	
begin
	
	if (not self.validate) then
		return null;
	endif;

	if app.myPassport.isInEdiVerifyMode then					//07.12.2022 navma1 #52499			
		return null;
	endif;
	
	theClass := global.getTiTxnClassForType(self.type, true);

	if theClass = null then
		return null;
	endif;
	
	create trans as theClass persistent;
	
	trans.CM_TITransaction.setFromCMIF_TITransactionCntrl(self, _passport);
		
	if _passport.hasErrors() then 
		delete trans;
		trans := null;
		return null;
	endif;
	
	//If we get to here then the transaction is OK
	_passport.addTITransactionForDeferUpd(trans.CM_TITransaction, self.myTerminal);
	
	return trans;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_Transaction"/>
    </JadeMethod>
    <JadeMethod name="originalCompanyCode" id="e783fddb-9478-4ff8-a5d0-22e3f6bd160a">
        <source>originalCompanyCode() :String;

vars

begin
	if originalCompanyOid &lt;&gt; null then
		return originalCompanyOid.code;
	endif;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
