    <JadeMethod name="displayEntry" id="e51d808b-6b97-4de2-9a69-6a63839299af">
        <controlMethod name="ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>displayEntry(combobox: ComboBox input; _carrier: CM_Carrier; lstIndex: Integer): String updating, clientExecution;
// -------------------------------------------
// Created 07 September 2004 by cnwdvb1
// -------------------------------------------
// Changed on	By			Reason
// ----------	----------	----------------------------------------------------
// 11/08/2011	cnwdap1		PAR #27972 Bulk release type no longer translated, replaced by string constants
// 15/01/2015   cnwma1      PAR #35462 Carrier Drop-down Fields
// 17/06/2022	navdap1		TFS 53362 EUP Master Data Interface Customers Between TOS and ERP
vars
	entTable : CM_EntryTable;
	failedDAC  :CM_DataAccessController;
begin
	if _carrier = null then
		return null;
	endif;
	
	if (not _carrier.canUserAccessSelf(null, failedDAC, app.myPassport)) then
		return null;
	endif;
	
	if _carrier.isNotAvailableForEntry then
		if self.myObject &lt;&gt; _carrier then
			return null;
		else
			self.hasDirtyObject := true;
		endif;
	endif;

	//cnwjo3, par 21883.  If Release Type is Rail then
	//we only want to display the Carriers that Are Rail, etc	
	if self.transportMode = BR_TYPE_RAIL then
		if not _carrier.isRail then
			return null;
		endif;
	elseif self.transportMode = BR_TYPE_ROAD then
		if not _carrier.isRoad then
			return null;
		endif;
	endif;
	
	//if app.myRoot.getConfig(CarrierCmbOrdDescr).Boolean then		// TFS 53362
	if self.isDisplayByName then  // 12/1/2015 cnwma1 PAR #35462	// TFS 53362
		return _carrier.getDescriptionTabCode;
	else
		return _carrier.code &amp; Tab &amp;  _carrier.description;
	endif;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="_carrier" type="CM_Carrier"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCollectionJMT" id="d574f1f7-4257-49f5-b1ae-b89b2e2a2273">
        <source>getCollectionJMT(): Collection protected;
// -------------------------------------------
// Created 07 September 2004 by cnwdvb1
// -------------------------------------------
vars


begin
	return app.myRoot.allCarriers;
end;</source>
        <access>protected</access>
        <ReturnType type="Collection"/>
    </JadeMethod>
    <JadeMethod name="init" id="5de13ab4-7e61-427f-a5a6-2fc5fc42520a">
        <updating/>
        <source>init() updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 09/06/2022	navdap1		Initial creation TFS 53362 EUP Master Data interface customers between TOS and ERP
//
vars

begin
	self.isDisplayByName := app.myRoot.getConfig(CarrierCmbOrdDescr).Boolean;	// TFS 53362
	inheritMethod();
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setTransportMode" id="6d98ea57-af09-4edc-8628-7d9af71e4552">
        <updating/>
        <source>setTransportMode(_trMode : Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 June 2010	cnwas3	par 24344

*/

vars

begin
	self.transportMode := _trMode;
epilog

end;</source>
        <Parameter name="_trMode" type="Integer"/>
    </JadeMethod>
