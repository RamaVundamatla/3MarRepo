    <JadeMethod name="cmbCargoSubType_click" id="cd2072e7-ebba-4551-ba6d-754589a0b28b">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbCargoSubType_click(combobox: ComboBox input) updating;
/*

Purpose:		TFS 40336	

Parameters:			

Return Value:		

Date		Who		Reason
12 September 2018	jlgab1	Initial creation

*/

vars
	cargosub : CM_Product;
begin
	if combobox.listObject.isKindOf(CM_Product) then
	cargosub := combobox.listObject.CM_Product;
	endif;
	
	if cargosub &lt;&gt; null then
		self.txtCargoSubDesc.text := cargosub.description;
	endif;
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbDestPort_click" id="38af7d51-26d9-4b75-ae7d-5a122495f9a3">
