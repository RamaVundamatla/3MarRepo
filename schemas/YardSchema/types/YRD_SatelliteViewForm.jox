    <JadeMethod name="setLocationControllerArray" id="5560c8d0-f55a-4eac-a097-40f5e66cc70c">
        <updating/>
        <source>setLocationControllerArray()updating;
//13 July 2010	cnwml2
//+cnwml2 PAR24701

vars
	theObj : Object;
	terminalArea : CM_TerminalArea;
begin
	theObj := self.myDrawingFrame.getObjectForPosition( self.origXPos.Integer, self.origYPos.Integer );
	if theObj = null then
		return;
	endif;
	
	create locationControllerArray transient;
	if theObj.isKindOf( CM_StackController ) or theObj.isKindOf( CM_RTGController ) then
		terminalArea := theObj.CM_LocationsController.myTerminalArea;
		if terminalArea &lt;&gt; null then
			terminalArea.getAllLCsWithCargo(locationControllerArray);
		endif;
	elseif theObj.isKindOf( CM_LocationsController ) then
		locationControllerArray.add(theObj.CM_LocationsController);
	elseif theObj.isKindOf( CM_TrackedItem ) then
		locationControllerArray.add(theObj.CM_TrackedItem.myPrimaryActualLocation.CM_LocationsController);
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setMyCurrentDrawingController" id="da4d4631-da5f-4857-9734-eac76dd5cda9">
        <updating/>
        <source>setMyCurrentDrawingController(_newController: CMUI_GridDrawingController input; _redraw: Boolean) updating;
//13 August 2008	cnwdw1	
//
vars

begin
	inheritMethod(_newController, _redraw);
	
	if myCurrentDrawingController &lt;&gt; null then
		self.frmStatusLine.myFrameMoveMode.visible  := true;//self.myCurrentDrawingController.isForEndView; process.isWei;
		self.frmStatusLine.myFrameDisplayMode.visible  := true;// self.myCurrentDrawingController.isForEndView; process.isWei;
		self.frmStatusLine.myFrameMoveMode.clearGraphics;
		self.frmStatusLine.myFrameDisplayMode.clearGraphics;
	endif;
	self.btnViewYardAlloc.enabled := true;
end;</source>
        <Parameter name="_newController" type="CMUI_GridDrawingController" usage="input"/>
        <Parameter name="_redraw" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMyTerminalAreaView" id="651343cb-2ff8-4311-a4cf-8dabb78680a0">
        <updating/>
        <source>setMyTerminalAreaView(_taView :CM_TerminalAreaView) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 December 2010	cnwer1	Initial creation

*/

vars

begin
	
	if self.myTerminalAreaView &lt;&gt; null then
		self.endNotification(self.myTerminalAreaView,self.myTerminal.getTerminalEvent(Event_TAView_Update));
		self.endNotification(self.myTerminalAreaView,self.myTerminal.getTerminalEvent(Event_TAView_Delete));
	endif;
	
	self.myTerminalAreaView:=_taView;
	self.doSetCaption();
	if self.myTerminalAreaView &lt;&gt; null then
		self.beginNotification(self.myTerminalAreaView,self.myTerminal.getTerminalEvent(Event_TAView_Update),Response_Continuous,null);
		self.beginNotification(self.myTerminalAreaView,self.myTerminal.getTerminalEvent(Event_TAView_Delete),Response_Continuous,null);
	endif;
epilog

end;</source>
        <access>protected</access>
