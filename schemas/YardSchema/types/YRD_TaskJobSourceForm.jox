    <JadeMethod name="updateRequestProxy" id="8c4809c2-55b8-4f13-80e3-afa1bdfb198f">
        <source>updateRequestProxy( _proxy : CM_WorkOrderRequestByType input );
// -----------------------------------------------------------------------------
// Created:		04 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	availGrades	: IntegerArray;
	isoType,
	isoGroup : String;
	termArea		: CM_TerminalArea;
	sourceLocation : CM_LocationsController;

begin
	if self.cmbReqISOType.listObject &lt;&gt; null then
		isoType := self.cmbReqISOType.listObject.CM_ISOType.code;
	endif;
	
	create availGrades transient;
	if self.cmbReqAvailGrade.listObject &lt;&gt; null then
		availGrades.add(self.cmbReqAvailGrade.listObject.CM_MTGrade.code);
	endif;
	
	if self.cmbSourceArea.listObject &lt;&gt; null then
		// 27911 cnwjre1 Nov 2011 extend source area to include gridded areas - use the first LC in this case
		//   and the code using the LC knows to use TA instead
		termArea := self.cmbSourceArea.listObject.CM_TerminalArea;
		if termArea.isKindOf(CM_GridArea) then
			sourceLocation := termArea.allLocationsControllers.first;
		else
			sourceLocation := termArea.getLocationsController();
		endif;
	endif;
	
	if  self.cmbISOGroup.listObject &lt;&gt; null then
		isoGroup := self.cmbISOGroup.listObject.CM_ISOTypeGroup.code;
	endif;

	_proxy.setProxy(	self.cmbReqCargoType.listObject.CM_CargoType,
						isoType,
						self.cmbReqOperator.listObject.CM_Operator,
						self.cmbReqOperatorGr.listObject.CM_OperatorGroup,
						self.txtReqRequested.getTextAsInteger,
						isoGroup,
						availGrades,
						self.chkReqClean.value,
						self.chkReqHeavyDuty.value,
						sourceLocation,
						self.cmbReqProduct.listObject.CM_Product );
	
epilog
	delete availGrades;
end;</source>
        <Parameter name="_proxy" type="CM_WorkOrderRequestByType" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateRequest" id="80d50f5c-d5e2-4b12-84b4-3c5076d303f8">
        <source>validateRequest() : Boolean;
// -----------------------------------------------------------------------------
// Created:		11 August 2009 by consw1
//
// Purpose:		Pre validate Request
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	proxy : CM_WorkOrderRequestByType;
	theResult : Integer;	//15 Jan 2020 NDL	TFS 46815
	
begin
	create proxy transient;
	self.updateRequestProxy(proxy);

	//  Note that this trx is only doing a validate
	//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxCA.trxCreateWorkOrderRequestByTyp(proxy, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return false;
		
	endwhile;
	
	return true;
	
epilog
	delete proxy;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
