end;
</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getMyEDIData" id="83d7bd50-9bcd-441c-b039-261bd733a2f5">
        <source>getMyEDIData(_deleted : Boolean output) : CM_EDIData;
//
// 04 Aug 2016	cnwrs1	Par 38117 make deleted EDI for finable
//
vars
	ediData : CM_EDIData;
	int : Integer;
	invalidObject : Boolean;
begin
	if self.myEDIData = null then
		_deleted := false;
		return null;
	endif;
	on Exception do app.handleDeletedObject(exception, self.myEDIData, invalidObject);
	int := self.myEDIData.edition;
	if not invalidObject then
		ediData := self.myEDIData;
	endif;
	_deleted := invalidObject;
	return ediData;
end;
</source>
        <Parameter name="_deleted" type="Boolean" usage="output"/>
        <ReturnType type="CM_EDIData"/>
    </JadeMethod>
    <JadeMethod name="setConfigNumber" id="747f2773-6b98-4d10-b3b2-7e2d225298f4">
        <updating/>
        <source>setConfigNumber(_number : Integer) updating;
//
// 09 Aug 2016	cnwrs1	Par 38117 make deleted EDI for finable
//
vars

begin
	self.number := _number;
end;
</source>
        <Parameter name="_number" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setFileDetails" id="f7020502-b3ad-4ca7-84d5-61d6642d0eee">
        <updating/>
        <source>setFileDetails(_fileDateTime : TimeStamp; _fileName : String; _seqNumber : String; _fileVersion : String; _ediData : CM_EDIData) updating;
//
//18 Sep 2015	cnwrs1	Par 32883 - EDI File Type sequence number
// 09 Aug 2016	cnwrs1	Par 38117 make deleted EDI for finable
//
vars

begin
	self.fileDateTime := _fileDateTime;
	self.fileName := _fileName;
	self.seqNumber := _seqNumber;
	self.fileVersion := _fileVersion;
	self.myEDIData := _ediData;
	if _ediData &lt;&gt; null then
		self.setConfigNumber(_ediData.number);
	endif;
end;
</source>
        <Parameter name="_fileDateTime" type="TimeStamp"/>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_seqNumber" type="String"/>
        <Parameter name="_fileVersion" type="String"/>
        <Parameter name="_ediData" type="CM_EDIData"/>
    </JadeMethod>
</Class>
