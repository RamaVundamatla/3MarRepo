    <JadeMethod name="getTimeRate" id="bec2e164-0a0f-4177-9c89-e9da89e2fe93">
        <source>getTimeRate(bank: CM_Bank; t: TimeStamp): CM_RateEntry;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Jun 2018 cnwma1	ChangeRequest 38953: PEL1 - Berth Rates, Vessel Type Rates, Visit Types

*/

vars
	iter : Iterator;
	found : Boolean;
	retVal : CM_RateEntry;

begin
	iter := self.rateEntries.createIterator;
	self.rateEntries.startKeyLeq(t, iter);
	found := false;
	while iter.back(retVal) do
		if retVal.ignoreThisEntry then
			continue;
		endif;
		if retVal.expiryTimestamp &lt;&gt; null and
		   retVal.expiryTimestamp &lt;= t then
			continue;
		endif;
		found := true;
		break;
	endwhile;
	if not found then
		retVal := null;
	endif;
	return retVal;
epilog
	delete iter;
end;</source>
        <Parameter name="bank" type="CM_Bank"/>
        <Parameter name="t" type="TimeStamp"/>
        <ReturnType type="CM_RateEntry"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="55c05aa9-a5d0-4959-84ab-dda27526426f">
        <updating/>
        <source>setForCreate(_pxyRate: CM_BerthRate) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Jun 2018 cnwma1	ChangeRequest 38953: PEL1 - Berth Rates, Vessel Type Rates, Visit Types

*/

vars

begin
	inheritMethod(_pxyRate);
	self.myBerth := _pxyRate.myBerth;
epilog

end;</source>
        <Parameter name="_pxyRate" type="CM_BerthRate"/>
    </JadeMethod>
