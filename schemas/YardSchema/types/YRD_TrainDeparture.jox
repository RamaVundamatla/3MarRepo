    <JadeMethod name="translateForm" id="40b897e6-5dfd-4481-9741-09eba55bb3aa">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0012569, locale);
	chkConfirmOut.translateCaption(Xlat_0012570, locale);
	chkPrintCargo.translateCaption(Xlat_0012571, locale);
	chkPrintCargoCON.translateCaption(Xlat_0012572, locale);
	chkPrintCargoOP.translateCaption(Xlat_0012573, locale);
	chkPrintCargoWAG.translateCaption(Xlat_0012574, locale);
	chkPrintManifest.translateCaption(Xlat_0014676, locale);
	chkPrintPreview.translateCaption(Xlat_0012576, locale);
	grpRail.translateCaption(Xlat_0012577, locale);
	grpReport.translateCaption(Xlat_0012578, locale);
	grpTrain.translateCaption(Xlat_0012579, locale);
	lblArea.translateCaption(Xlat_0012580, locale);
	lblEnd.translateCaption(Xlat_0012581, locale);
	lblRake.translateCaption(Xlat_0012582, locale);
	lblStart.translateCaption(Xlat_0012583, locale);
	lblTrains.translateCaption(Xlat_0012584, locale);
end;</source>
    </JadeMethod>
</GUIClass>
