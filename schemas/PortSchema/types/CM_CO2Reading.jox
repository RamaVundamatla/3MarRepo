<Class name="CM_CO2Reading" id="585e4c69-e474-41ec-bf33-8ebbdc68b67d">
    <superclass name="CM_Object"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="tempreading"/>
    <PrimAttribute name="co2" id="67b9ff6e-e664-415f-8518-563a1b4c8b99">
        <precision>12</precision>
        <scaleFactor>2</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="dateTime" id="28e8c4ec-d71f-4ed1-ab55-7c7d537e91b9">
        <embedded/>
        <type name="TimeStamp"/>
        <access>readonly</access>
    </PrimAttribute>
    <ImplicitInverseRef name="myCO2ReadingTransaction" id="15427793-5eb0-4919-9bd9-ba96048c26e6">
        <embedded/>
        <type name="CM_CO2ReadingTransaction"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ExplicitInverseRef name="myReeferProperties" id="0f402ce2-84e9-4d9f-9075-3683831ac5bf">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_TIReeferProperties"/>
        <access>readonly</access>
        <Inverse name="CM_TIReeferProperties::allCO2Readings"/>
    </ExplicitInverseRef>
    <PrimAttribute name="userId" id="008c81e8-3ec7-4c4f-86a0-3db58d483434">
        <length>11</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="cloneForTrackedItemRefs" id="3e115d5b-2ce7-4a5b-b763-69198701f236">
        <updating/>
        <source>cloneForTrackedItemRefs(_ti : CM_TrackedItem) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 16/12/2025	navdap1		Initial creation MTN-36569 CPL | Reefer Runner Integration
//
vars

begin
	self.myReeferProperties := _ti.myReeferProperties;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="0503a46d-8121-47ef-99cb-a2663cb1716b">
        <updating/>
        <source>setForCreate(_co2Params : CMIF_CO2Reading) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 16/12/2025	navdap1		Initial creation MTN-36569 CPL Reefer Runner Integration
//
vars
	ti : CM_TrackedItem;

begin
	self.dateTime := _co2Params.dateTime;
	self.co2 := _co2Params.co2;
	
	ti := _co2Params.myTrackedItem;
	ti.createReeferPropertiesIfReqd(self.dateTime);
	self.myReeferProperties := ti.myReeferProperties;
	
	self.userId := _co2Params.userId;
epilog

end;</source>
        <Parameter name="_co2Params" type="CMIF_CO2Reading"/>
    </JadeMethod>
</Class>
