        <Parameter name="pTI" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="addFromPinNo" id="725348e3-7163-41c6-82ef-82c3ac72cbc2">
        <updating/>
        <source>addFromPinNo(pPinNo : CM_PinNo) updating, protected;
// ---------------------------------------------------------------------------
// Created:     26 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	item,
	selectedObj			: Object;
	selected			: Boolean;
	ti					: CM_TrackedItem;
	carrier,regNumber 	: Any;
	
begin

	foreach item in pPinNo.allItems discreteLock do //+ cnwmd1 Par 25448 added dicreteLock
		if item.isKindOf(CM_TrackedItem) then
			ti := item.CM_TrackedItem;
			
			// ti is on site
			if ti.state = TI_STATE_NORMAL then 
				// 24/05/2010 cnwar2 #22015 - truck already in terminal for this item
				if ti.jobRoadRelease &lt;&gt; null then
					app.raiseCMException2(Cargo_item_being_released, ti.id, ti.jobRoadRelease.regNumber, null, null);
					txtNewItem.text := "";
					return;
				endif;
			
				self.setStatusLineCaption(app.getErrorString1(Default_from_cargo_item,app.getErrorString(Onsite)));
				self.addFromOnSiteTI(ti);
			// pre-noted ti
			elseif ti.state = TI_STATE_NOTIFIED then	
				//th2 added 27/06/2007 - inter-terminal transfers - we already know the truck and carrier
				regNumber := self.tblCommon.getValueByName(ETRow_RegNumber);										//cnwas3 par 26258 begin Added checks for pre-filled fields
				carrier := self.tblCommon.getValueByName(ETRow_CarrierCode);
				if ti.myMoveCloneFromTI &lt;&gt; null then
					if regNumber = null then
						self.tblCommon.setValueByName(ETRow_RegNumber, ti.myMoveCloneFromTI.releaseVehicle);
					endif;
					if carrier = null then
						self.cmbCarrier.setObject(app.myRoot.allCarriers[ti.myMoveCloneFromTI.releaseCarrier]);
						self.cmbCarrier.lostFocus(cmbCarrier);						
						self.tblCommon.setValueByName(ETRow_CarrierCode, ti.myMoveCloneFromTI.releaseCarrier);
					endif;
					if carrier = null or regNumber = null then 														//cnwas3 par 26258 end
						self.setStatusLineCaption(app.getErrorString1(Default_from_cargo_transf_term,app.getErrorString(Prenoted)) &amp; ti.myMoveCloneFromTI.myTerminal.code);					
					endif;
					//self.txtRegNumber.text := ti.myMoveCloneFromTI.releaseVehicle;
					//self.cmbCarrier.setObject(ti.myMoveCloneFromTI.getCarrierRelease());
				else
					self.setStatusLineCaption(app.getErrorString1(Def_from_prenoted_cargo_item,app.getErrorString(Prenoted)));
				endif;
				
				self.addFromPreNotifiedTI(ti);
			endif;
		elseif item.isKindOf(CM_BulkRelease) then
			// 13/08/2008 cnwar2 #16563 - allow selection of reserve lines
			selected	:= false;
			//selectedObj := self.getMatchingObjectToSelect(item.CM_BulkRelease.code, selected);
			selectedObj := self.getMatchingReserveToSelect(item.CM_BulkRelease, selected);	// 08/12/2008 cnwar2 #18620
			
			//PAR17915 - cnwsh3	16/9/2008
			//if selectedObj.isKindOf(CM_ReserveSelection) then
			if selectedObj.isKindOf(CM_ReserveDetail) then
				//self.addFromReserveDetail(selectedObj.CM_ReserveSelection);
				self.addFromReserveDetail(selectedObj.CM_ReserveDetail);
			else
				self.addFromBulkRelease(item.CM_BulkRelease);
			endif;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Unknown object in CM_PinNo.allItems (' &amp; item.String &amp; ')');
		endif;
	endforeach;

end;</source>
        <access>protected</access>
        <Parameter name="pPinNo" type="CM_PinNo"/>
    </JadeMethod>
    <JadeMethod name="addFromPreNotifiedTI" id="d86f72d0-8e8b-43e8-84d1-74830ccfdcc6">
        <updating/>
        <source>addFromPreNotifiedTI(pTI : CM_TrackedItem) updating, protected;
// ---------------------------------------------------------------------------
// Created:     27 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.fromPrenoteID := pTI.id;
	self.createMenuActionSheet(NavObj_GTE_In, pTI);
	
end;</source>
        <access>protected</access>
        <Parameter name="pTI" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="addFromReserveDetail" id="71f730db-a02a-4974-89df-cb2b71532adb">
        <source>addFromReserveDetail(res : CM_ReserveDetail) protected;
// ---------------------------------------------------------------------------
// Created:		March 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------	
// 22/02/2010	cnwas3 par 18106
// ---------------------------------------------------------------------------
vars
	br : CM_BulkRelease;
	invalidObject : Boolean;
	carrier : Any;//par 18106
begin
	on Exception do app.handleDeletedObject(exception, res, invalidObject); //Add 27/5/2008 cnwsh3 Added as part of getting rid of isValidObject method calls.
	
	self.createMenuActionSheet(NavObj_GTE_Out, res);

	br := res.myReserveHeader;
	
	if invalidObject then
		return;
	endif;
	
	carrier := self.tblCommon.getValueByName(ETRow_CarrierCode);	//par 18106
	
	if br.carrierId &lt;&gt; null and carrier = null then	//par 18106
		self.cmbCarrier.setObject(app.myRoot.allCarriers[br.carrierId]);
		self.cmbCarrier.lostFocus(cmbCarrier);
		self.tblCommon.setValueByName(ETRow_CarrierCode, self.cmbCarrier.text);
	endif;
	self.tblBulkRelease.selectObject(res, true);
	self.showBulkReleaseDtl();

end;</source>
        <access>protected</access>
        <Parameter name="res" type="CM_ReserveDetail"/>
    </JadeMethod>
    <JadeMethod name="addLogDocketDataRow" id="db0067b8-86d7-41d7-b506-6f656130e20b">
        <source>addLogDocketDataRow(_logDocketData : CM_LogDocketData) protected;
// ---------------------------------------------------------------------------
// Created:     14 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	idx					: Integer;
	str					: String;
	entRow				: EntTableRow;
begin
	if _logDocketData = null then
		return;
	endif;
	
	str := null;
	foreach entRow in self.tblLogDocketData.allTblDataEntRows do
		str := str &amp; _logDocketData.getDisplayStringForAttribute(entRow.name, false) &amp; Tab;
	endforeach;
	idx := self.tblLogDocketData.addItem(str);
	self.tblLogDocketData.accessRow(idx).itemObject := _logDocketData;

end;</source>
        <access>protected</access>
        <Parameter name="_logDocketData" type="CM_LogDocketData"/>
    </JadeMethod>
    <JadeMethod name="addNewItem" id="82d821d6-e6e5-4236-9bb9-075084d3fd53">
        <updating/>
        <source>addNewItem(pCode : String) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     20 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  CNWAER1 Reason : CCMS 1003 - Nelson Warehousing
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	bulkRelease		: CM_BulkRelease;
	bookingRef		: CM_BookingRef;
	bookingRefItem  : CM_BookingRefItem;
	tmpTI			: CM_TrackedItem;
	logDocketData		: CM_LogDocketData;
	//reserve			: CM_ReserveSelection;
	reserve			: CM_ReserveDetail;
	pinNo			: CM_PinNo;
	todaysDate		: Date;
	useTransferTI, 
	hasPickWin		: Boolean;
	str , tmpStr	: String;
	selectedObj		: CM_Object;
	
begin
	self.truckDriveOn();

	pinNo := self.myTerminal.allPinNos[pCode];
	if pinNo &lt;&gt; null then
		self.addFromPinNo(pinNo);
		txtNewItem.text := null;
		return true;
	endif;
	hasPickWin:= false;
	//AER 07/03/08 - CCMS 1003 - searching for a Booking Reference Item
	//Select an object to display
	selectedObj := self.getMatchingObjectToSelect(pCode, hasPickWin);

	// 	Defaulted from Booking Reference Item; // AER for Nelson 04/03/08
	if selectedObj &lt;&gt; null and selectedObj.isKindOf(CM_BookingRefItem) then
		bookingRefItem := selectedObj.CM_BookingRefItem;
		self.setStatusLineCaption('Defaulted from Booking Reference Item');
		self.addFromBookingRefItem(bookingRefItem); 
		//self.loadBookingRefItems(bookingRefItem.myBookingReference, bookingRefItem);
		txtNewItem.text := null;
		return true;
	endif;
	
	//	Defaulted from Bulk Release
	if selectedObj &lt;&gt; null and selectedObj.isKindOf(CM_BulkRelease) then
		bulkRelease := selectedObj.CM_BulkRelease;
		if bulkRelease.type = BR_TYPE_ROAD then 
			if bulkRelease.status = BR_ACTIVE then	
				self.setStatusLineCaption('Defaulted from Bulk Release');
				self.addFromBulkRelease(bulkRelease);
				txtNewItem.text := null;
				return true;
			elseif bulkRelease.status = BR_PENDING then
				str := app.getErrorString(Pending);
			elseif bulkRelease.status = BR_COMPLETE then
			 	str := app.getErrorString(Completed);
			endif;	
			app.msgBox('The status for Release Job ' &amp; pCode &amp; ' is ' &amp; str &amp; 
			'.'  &amp; CrLf &amp; CrLf &amp; 'To add a release the status of the Release Request needs to be Active', self.caption, MsgBox_OK_Only + MsgBox_Information_Icon);
			return false;
		endif;
	endif;
	//	Defaulted from reserve line of Bulk Release	- 13/08/2008 cnwar2 #16563
	//if selectedObj &lt;&gt; null and selectedObj.isKindOf(CM_ReserveSelection) then
	if selectedObj &lt;&gt; null and selectedObj.isKindOf(CM_ReserveDetail) then
		reserve 	:= selectedObj.CM_ReserveDetail;
		bulkRelease	:= reserve.myReserveHeader;
		if bulkRelease.type = BR_TYPE_ROAD then 
			if bulkRelease.status = BR_ACTIVE then	
				self.setStatusLineCaption('Defaulted from Bulk Release');
				self.addFromReserveDetail(reserve);
				txtNewItem.text := null;
				return true;
			elseif bulkRelease.status = BR_PENDING then
				str := app.getErrorString(Pending);
			elseif bulkRelease.status = BR_COMPLETE then
			 	str := app.getErrorString(Completed);
			endif;	
			app.msgBox('The status for Release Job ' &amp; pCode &amp; ' is ' &amp; str &amp; 
			'.'  &amp; CrLf &amp; CrLf &amp; 'To add a release the status of the Release Request needs to be Active', self.caption, MsgBox_OK_Only + MsgBox_Information_Icon);
			return false;
		endif;
	endif;

	//Pre notified container
	if selectedObj &lt;&gt; null and selectedObj.isKindOf(CM_TrackedItem) then 
		tmpTI  := selectedObj.CM_TrackedItem;
		self.setStatusLineCaption('Defaulted from Pre-Notification');
		self.addFromPreNotifiedTI(tmpTI);
		txtNewItem.text := null;
		return true;
	endif;

	//Inter-terminal transfers
	if selectedObj &lt;&gt; null and selectedObj.isKindOf(CM_TrackedItem) then 
		tmpTI  := selectedObj.CM_TrackedItem;
		self.setStatusLineCaption(app.getErrorString(DefaultedFromTransferTI));
		useTransferTI := true;
		
		/* not necessary anymore as the check up was transfer to the pick up window.    RS2 11/03/2008
		
		if (tmpTI.releasedDT.date + 8) &lt;= todaysDate then
			useTransferTI := false;
			if tmpTI.myInTransitTerminalFrom &lt;&gt; null then
				if app.msgBox(app.getErrorString(OldTransferTIFound) &amp; CrLf &amp; 
					app.getErrorString1(DoYouWantToProcess, tmpTI.id) &amp; " (released from " &amp; tmpTI.myInTransitTerminalFrom.code &amp; " on " &amp; tmpTI.releasedDT.date.String &amp;
					")?  " &amp; app.getErrorString(ToKeepSearchingPressNo), self.caption, MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_Yes then
					useTransferTI := true;
				endif;
			else
				if app.msgBox(app.getErrorString(OldTransferTIFound) &amp; CrLf &amp; 
					app.getErrorString1(DoYouWantToProcess, tmpTI.id) &amp; app.getErrorString(ToKeepSearchingPressNo), self.caption, MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_Yes then
					useTransferTI := true;
				endif;
			endif;
		endif;
		*/
		
		if useTransferTI then
			self.addFromInterTerminalTI(tmpTI);
			txtNewItem.text := null;
			return true;
		endif;
	endif;

	//Defaulted from Weighbridge Data
	if selectedObj &lt;&gt; null and selectedObj.isKindOf(CM_LogDocketData) then 
		logDocketData  := selectedObj.CM_LogDocketData;
		self.setStatusLineCaption('Defaulted from Log Docket Data');
		self.doLogDocketDataPrefill(pCode);
		txtNewItem.text := null;
		return true;
	endif;

	txtNewItem.text := null;
	if not hasPickWin then
		app.msgBox('No match found for ' &amp; pCode, self.caption, MsgBox_OK_Only + MsgBox_Information_Icon);
	endif;
	return false;
end;</source>
        <Parameter name="pCode" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="addSheetFromMenuAction" id="79c9ed82-0694-405a-b16f-359e031b8b19">
        <updating/>
        <source>addSheetFromMenuAction(_menuAction : GTE_InOutMenuAction input) updating;
// ---------------------------------------------------------------------------
// Created:     20 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 05/10/2009	cnwdad1		PAR #20969.
// 08/12/2009	cnwmh5		PAR 21565 - Make sure correct sheets sub terminal
//							details are getting updated
// ---------------------------------------------------------------------------
vars
	newSheet	: GTE_Sheet;
	tableObj	: CM_EntryTable;
	obj			: Object;
	brItem 		: CM_BookingRefItem;
	theTI		: CM_TrackedItem;
	subTerminalCmb	: CMUI_ComboBox;				// 08/12/2009 cnwmh5 #21565
begin
	app.mousePointer := MousePointer_HourGlass;
	
	beginLoad;
	
	newSheet := cloneSheet(self.shtInOut, _menuAction.mainTableDef, _menuAction.extraTableDef);

	tableObj	:=	newSheet.myTblExtra;	
	self.setColorsForEntryTable(tableObj);
	
	// get tblMain last as it is used further on
	tableObj	:=	newSheet.myTblMain;	
	self.setColorsForEntryTable(tableObj);		
					
	if _menuAction.code = NavObj_GTE_Out then

		self.setReleaseByType(tableObj, _menuAction.myObject);
	endif;
	
	self.setCargoTypeFields(newSheet);	

	// Setup the containers on the layout sheet
	if _menuAction.code = NavObj_GTE_In then
		trkLayoutIn.setContainer(0, _menuAction.headingPrefix, 0, true, newSheet);

	elseif _menuAction.code = NavObj_GTE_OutByType then
		trkLayoutOut.setContainer(0, _menuAction.headingPrefix, 0, true, newSheet);
		
	elseif _menuAction.code = NavObj_GTE_OutById then
		trkLayoutOut.setContainer(0, _menuAction.headingPrefix, 0, true, newSheet);

	elseif _menuAction.code = NavObj_GTE_Out then
		trkLayoutOut.setContainer(0, _menuAction.headingPrefix, 0, true, newSheet);
	endif;

	_menuAction.setMyWindowControl(newSheet, newSheet.index);

	newSheet.myMenuAction := _menuAction;
	newSheet.setCaption(_menuAction.headingPrefix);

	obj := _menuAction.myObject;

	if obj &lt;&gt; null then
		if obj.isKindOf(CM_BookingRef) then
			self.setDefaultsFromObject(newSheet, obj);			
		elseif obj.isKindOf(CM_BookingRefItem) then
			brItem := obj.CM_BookingRefItem;
			self.setDefaultsFromObject(newSheet, brItem);
			self.loadBookingRefItems(brItem.myBookingReference, brItem);	// AER for Nelson 04/03/08
			
		elseif obj.isKindOf(CM_ReserveDetail) then
			self.setValuesFromReserveDetail(obj.CM_ReserveDetail, newSheet);			
		elseif obj.isKindOf(CM_BulkRelease) then
			self.setValuesFromBulkRelease(obj.CM_BulkRelease, newSheet);
			// 28/10/2009 cnwar2 #21504
			if app.isSubTerminalsOn(self.myTerminal) 
			and obj.CM_BulkRelease.mySubTerminal &lt;&gt; null then
				cmbSubTerminal.cnEcSetObjectIndex(obj.CM_BulkRelease.mySubTerminal);
				newSheet.myTblExtra.setValueByName(ETRow_MySubTerminal, obj.CM_BulkRelease.mySubTerminal.code);
			endif;
			newSheet.myTblExtra.hideRowByName(ETRow_SubTerminalDesc, false);	// cnwdad1 05/10/2009 - PAR #20969.
			
		elseif obj.isKindOf(CM_TrackedItem) then
			theTI := obj.CM_TrackedItem;
			
			if theTI &lt;&gt; null then
				if app.isSubTerminalsOn(self.myTerminal) then		// cnwdad1 24/08/2009 - PAR #20505.
					cmbSubTerminal.cnEcSetObjectIndex(theTI.mySubTerminal);
// cnwdad1 30/07/2009 - PAR #20373.
					if theTI.mySubTerminal &lt;&gt; null then //20 Sep 2011	NDL	Found during implementation of 24455 / DMAST data issue.
						newSheet.myTblExtra.setValueByName(ETRow_MySubTerminal, theTI.mySubTerminal.code);	
					endif;
				endif;
			endif;
			
			if _menuAction.code = NavObj_GTE_In then
				self.setIsFromPrenote(theTI, newSheet);
				//self.setValuesFromReceivalTI(obj.CM_TrackedItem, newSheet);
				self.setDefaultsFromObject(newSheet, obj);
				self.loadBookingRefItems(theTI.myBookingRef, theTI.myBookingRefItem);
				
				// 05/07/2010 cnwar2 #24865 - moved to sheet.setIsFromPrenote so will happen if prenote id entered in txtTrackedItemID
				/*if newSheet.isPopulatedFromPrenote then
					newSheet.tiEdition := theTI.edition;
				endif;*/
			elseif _menuAction.code = NavObj_GTE_Out then //NavObj_GTE_OutById then
				self.setValuesFromReleaseTI(obj.CM_TrackedItem, newSheet);
			else
				app.raiseUnexpectedProgramError(class.name, method.name, 'Unhandled NavigationObject code (' &amp; _menuAction.code &amp; ') for TI object');
			endif;

		elseif obj.isKindOf(GTE_Sheet) then
			self.setValuesFromCopiedSheet(obj.GTE_Sheet, newSheet);
			
		elseif obj.isKindOf(CM_LogDocketData) then
			self.setValuesFromLogDocketData(obj.CM_LogDocketData, newSheet);
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Unknown CM_Object (' &amp; obj.String &amp; ')');
		endif;

		newSheet.setContainerSizeFromISOType();
	endif;
	self.resizeSheet(newSheet);

	btnDeleteCurrent.enabled := true;
	btnSaveBase.enabled := true;

	tblCommon.selected := false;
	
	if _menuAction.code = NavObj_GTE_In and
	   newSheet.getCargoBOLTypeId = BOLType_Log then
		tableObj.goToRowByName(ETRow_PercentScaled);
		tableObj.setFocus();		
	elseif tblCommon.getValueByName(ETRow_RegNumber) = null then
		tblCommon.goToRowByName(ETRow_RegNumber);
		tblCommon.setFocus();
	else
		tableObj.moveFirst();
		tableObj.setFocus();		
	endif;
	
	subTerminalCmb := newSheet.getControlByName(self.Cntrl_cmbSubTerminal).CMUI_ComboBox;	// 08/12/2009 cnwmh5 #21565
	
// cnwdad1 14/05/2009 - CCMS 1735.
	if not app.isSubTerminalsOn(self.myTerminal) then
		tableObj.hideRowByName(ETRow_MySubTerminal, false);
		newSheet.myTblExtra.hideRowByName(ETRow_MySubTerminal, false);
		
	////elseif cmbSubTerminal.listObject = null then			// 28/10/2009 cnwar2 #21504
	elseif subTerminalCmb &lt;&gt; null and subTerminalCmb.listObject = null then	// 08/12/2009 cnwmh5 #21565 
		self.setSubTerminalDefault(newSheet.isReceival, false, newSheet.myTblExtra);	// if subterminal not set off ti/release above, use default
	endif;
	if not app.myPassport.myTerminal.getConfig(ShowPortOfCallTranship).Boolean then		
			newSheet.myTblExtra.hideRowByName(ETRow_MyTranshipToPort, false);
		else
			newSheet.myTblExtra.showRowByName(ETRow_MyTranshipToPort, false);
	endif;
/*
	// ###  HIDE FROM GDANSK AND DUAL GATE
	if _menuAction.code = NavObj_GTE_Out then
		vta := self.myTerminal.allTerminalAreas[tblCommon.getRowByName(ETRow_RoadTransAreaId).String].CM_VehicleTransferArea;
		if vta = null then
			vta := self.myTerminal.allTerminalAreas[self.myTerminal.getConfig(DefRoadOpsArea).String.trimRight()].CM_VehicleTransferArea;
		endif;
	
		if vta &lt;&gt; null and vta.isDualGate then
			tbl.hideRowByName(ETRow_ReleaseByType,false);
		endif;
	endif;
	*/
	self.notifyGotFocus();
	
	self.shtInOut.myMenuAction := newSheet.myMenuAction;				//+cnwml2 PAR 24780
	
	// now done in setCargoTypeFields(..)
	//self.myAssistant.GTE_Assistant.showHideCEDOField(newSheet.myTblExtra, 1); // ### CCMS 1294 AKB2005JAN
epilog
	endLoad;
	app.mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="_menuAction" type="GTE_InOutMenuAction" usage="input"/>
    </JadeMethod>
    <JadeMethod name="addToTblBulkRelease" id="e807ba4f-1afa-4f7b-99a8-ce0550212093">
        <source>addToTblBulkRelease(_bulkRelease : CM_BulkRelease; _table : CM_DataTable io) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 February 2010	cnwmh5	Initial creation #22263
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
*/

vars
	
	rowIdx		: Integer;
	str			: String;
	reserve 	: CM_ReserveDetail;
	firstTi		: CM_TrackedItem;
begin

	foreach reserve in _bulkRelease.allReserveDetails discreteLock do
		//PAR18485
		firstTi := reserve.getFirstTI(false); 
		//if reserve.isKindOf(CM_ReserveTI) and reserve.allTrackedItems.isNotEmpty() then
		if reserve.isKindOf(CM_ReserveTI) and firstTi &lt;&gt; null then //23/06/2023	navkc1	CR 58406 Task 58408
			//if reserve.allTrackedItems.first().jobRoadRelease &lt;&gt; null then
			if firstTi.jobRoadRelease &lt;&gt; null then //23/06/2023	navkc1	CR 58406 Task 58408
				continue;
			endif;
		endif;
	
		if reserve.isKindOf(CM_ReserveTI) and reserve.allTrackedItemsReleased.isNotEmpty() then //cnwrd1 par 20833 09/10/09 if we are a reserve TI and already released we do not want to be put into this table
			continue;
		endif;
		
		str := reserve.getAttributeStringForDefArray(_table.allTblDataEntRows);
		if not _table.findObjectInRow(reserve, rowIdx) then
			//str := reserve.getAttributeStringForDefArray(_table.allTblDataEntRows);
			_table.addItemObject(reserve, str);
		else
			_table.setCellText(rowIdx, 1, str);
		endif;
		self.tblBulkRelease.beginNotification(reserve, Object_Delete_Event, Response_Cancel, 0);
		
	endforeach;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_bulkRelease" type="CM_BulkRelease"/>
        <Parameter name="_table" type="CM_DataTable" usage="io"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="70461813-22e0-49ac-86fb-bd199c38c4d1">
        <updating/>
        <source>addToolbarControls() updating, protected;
//--------------------------------------------------
// Created:	15 September 2003 By: cnwgd1
//--------------------------------------------------
vars
	toolbar	: CMUI_Toolbar;
begin
	inheritMethod();

	toolbar := self.frmToolbar;
	
	
	// TFS 2734 CNWAB1
	if app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		toolbar.addButton(self.btnReceive, CMUI_Toolbar.Control_Alignment_Left);
		toolbar.addButton(self.btnRelease, CMUI_Toolbar.Control_Alignment_Left);		
		toolbar.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);
		toolbar.addButton(self.btnCopyCurrent, CMUI_Toolbar.Control_Alignment_Left);	
		toolbar.addButton(self.btnDeleteCurrent, CMUI_Toolbar.Control_Alignment_Left);	
		
		toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);	//PAR 23408 22/04/2010
		toolbar.addButton(self.btnRefresh, CMUI_Toolbar.Control_Alignment_Left);	

	endif;

	

	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);	

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="addTransferRow" id="31a7f425-1dd9-4abb-a849-c239c59191c2">
        <source>addTransferRow(_ti: CM_TrackedItem) protected;
//----------------------------------------------------------------
//	Created:	29 July 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	idx					: Integer;
	str					: String;
	entRow				: EntTableRow;
begin
	if _ti = null then
		return;
	endif;
	
	if self.tblTransfers.findObjectInRow(_ti, idx) then
		//no need to add
		return;
	endif;
	
	str := null;
	foreach entRow in self.tblTransfers.allTblDataEntRows do
		str := str &amp; _ti.getDisplayStringForAttribute(entRow.name, false) &amp; Tab;
	endforeach;
	idx := self.tblTransfers.addItem(str);
	self.tblTransfers.accessRow(idx).itemObject := _ti;

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="armNotification" id="5097d138-998a-4a5b-9010-b81e76aaadb0">
        <source>armNotification() protected;
// ---------------------------------------------------------------------------
// Created:     14 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin

	self.endNotificationForSubscriber(self);
	
	self.beginNotification(global, self.myTerminal.getTerminalEvent(EVENT_ROWCONTROLLER_CREATE), Response_Continuous , null);
	self.beginNotification(global, self.myTerminal.getTerminalEvent(EVENT_ROWCONTROLLER_UPDATE), Response_Continuous , null);
	self.beginNotification(global, self.myTerminal.getTerminalEvent(EVENT_ROWCONTROLLER_DELETE), Response_Continuous , null);

	self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(EVENT_WEIGHBRIDGE_CREATE), Response_Continuous , null);		//cnwmc5 - 9 April 2014 - PAR 33937
	self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(EVENT_WEIGHBRIDGE_REMOVE), Response_Continuous , null);		//cnwmc5 - 9 April 2014 - PAR 33937
	
	self.beginNotification(self, GTE_InputObject_InOutAdd, Response_Continuous, 0);
	// DVB
//	self.beginNotification(app, CMUI_NavObject_Update, Response_Continuous, 0);

	self.beginClassNotification(CM_Voyage, false, self.myTerminal.getTerminalEvent(Voyage_Create_Event), Response_Continuous, 0);
	self.beginClassNotification(CM_Voyage, false, self.myTerminal.getTerminalEvent(Voyage_Update_Event), Response_Continuous, 0);
	self.beginClassNotification(CM_Voyage, false, self.myTerminal.getTerminalEvent(Voyage_Delete_Event), Response_Continuous, 0);

	self.beginNotification(global, self.myTerminal.getTerminalEvent(Event_BulkRelease_Update), Response_Continuous, 0);

	// DVB changed to use new flags 05/04/05
	if app.isInterTerminalTransferEnabled() then
		self.beginNotification(global, EVENT_Terminal_Transfer, Response_Continuous , null);
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
