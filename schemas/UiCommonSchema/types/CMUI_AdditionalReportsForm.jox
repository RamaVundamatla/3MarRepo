    <JadeMethod name="doAdd" id="1b254ad9-67e5-4a97-9245-a09521057b11">
        <source>doAdd();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 February 2019	jlgndl1	Initial creation

*/

vars

	pxyVoyProcRep : CM_VoyageProcessReport;

begin

	create pxyVoyProcRep transient;
	pxyVoyProcRep.setProxy(	self.txtDisplayName.text,	//_displayName : String;
							self.cmbReportName.text,	//_reportName : String;
							self.txtReportView.text,	//_reportView : String;
							null	//_myVoyageProcess : CM_VoyageProcess
							);
							
	self.allVoyProcReports.add( pxyVoyProcRep );
	self.populateTable();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doOK" id="d7994ebe-16b0-40df-82d1-a37b9b2d8ded">
        <updating/>
        <source>doOK() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 February 2019	jlgndl1	Initial creation	TFS 43240

*/

vars

begin
	if self.doSave then
		inheritMethod();	// closes the form
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doRemove" id="39d07606-c3f5-41f4-9faf-d92e735415ef">
        <source>doRemove();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 February 2019	jlgndl1	Initial creation

*/

vars

	rowIndex : Integer;
	pxyVoyProcRep : CM_VoyageProcessReport;
	arrayIndex : Integer;
	

begin

	rowIndex := self.tblReports.row;
	if rowIndex &lt;= self.tblReports.rows then
		pxyVoyProcRep := self.tblReports.accessRow( rowIndex ).itemObject.CM_VoyageProcessReport;
	endif;
	
	if pxyVoyProcRep &lt;&gt; null then
		arrayIndex := self.allVoyProcReports.indexOf( pxyVoyProcRep );
		if arrayIndex &gt; 0 then
			self.allVoyProcReports.removeAt( arrayIndex );
			populateTable();
		endif;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="18e648ed-276a-4598-aa3b-cf043fa72717">
        <source>doSave():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 February 2019	jlgndl1	Initial creation	TFS 43240

*/

vars

	success : Boolean;

begin

	app.myTrxUA.trxUpdateVoyageProcAddReps(self.myVoyageProcess, self.allVoyProcReports, app.myPassport);

	success := app.myPassport.trxCompletedOK;
	
	if not success then
		app.msgBox( app.myPassport.getErrorsAndWarningsAsString, app.getErrorString(Error), MsgBox_OK_Only );
	endif;
	
	return success;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="populateReports" id="8c894e2e-79cb-41c4-8404-ceccda98f37c">
        <source>populateReports();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 February 2019	jlgndl1	Initial creation	TFS 43240

*/

vars
reportName : String;
	viewName : String;
	str : CM_String;
	strStr : CM_StringWithString;
	jrw : JadeReportWriterReport;
	jrwManager : JadeReportWriterManager;
	path : String;
begin

	self.cmbReportName.clear();
	self.cmbReportName.addItem( null );
	self.clearFields();
	jrwManager := app.createReportWriterManager();
	foreach str in self.allReportNamesByView do
		
		viewName := str.string; 
		reportName := str.CM_StringWithString.strString;
		jrw:=jrwManager.getReport(reportName);
		if viewName = CM_InvoiceView or  viewName = CM_VoyageView then
				
			jrw := jrwManager.getReport(reportName);
			if jrw &lt;&gt; null then
				if viewName = CM_InvoiceView then
					path:=CM_JRWInvoice::allInvoices.name;
				elseif viewName = CM_VoyageView then
					path:= CM_JRWVoyages::allVoyages.name;						
				endif;
				if not jrw.reportsOn(path) then
					continue;
				endif;
			endif;
		
			self.cmbReportName.addItem( reportName );
		endif;
	endforeach;
	
epilog
	delete jrwManager;

end;</source>
    </JadeMethod>
    <JadeMethod name="populateTable" id="f241fa28-15b9-4e89-b22e-f34131d75d66">
        <source>populateTable();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 February 2019	jlgndl1	Initial creation	TFS 43240

*/

vars

	headingStr : String;
	bodyLine : String;
	voyProcRep : CM_VoyageProcessReport;
	rowIndex : Integer;

begin

	self.tblReports.clear();
	
	self.tblReports.rows := 1;
	self.tblReports.columns := 3;
	self.tblReports.fixedRows := 1;
	self.tblReports.fixedColumns := 0;
	self.tblReports.selectMode := Table.SelectMode_WholeRows;
	
	headingStr := "Report Name" &amp; Tab &amp; "Display Name" &amp; Tab &amp; "JRW View";
	self.tblReports.setCellText(1,1,headingStr);
	
	foreach voyProcRep in self.allVoyProcReports do
		bodyLine := voyProcRep.reportName &amp; Tab &amp; voyProcRep.displayName &amp; Tab &amp; voyProcRep.reportView;
		rowIndex := self.tblReports.addItemObject( voyProcRep, bodyLine );
	endforeach;
	
	self.clearFields();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="selectItem" id="9a7f6399-89c5-4d21-97fd-8e34896f3345">
        <source>selectItem();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 February 2019	jlgndl1	Initial creation	TFS 43240

*/

vars

	rowIndex : Integer;
	reportName : String;
	displayName : String;
	reportView : String;

begin

	rowIndex := self.tblReports.row;
	if rowIndex &gt; 1 and rowIndex &lt;= self.tblReports.rows then
		reportName := self.tblReports.getCellText( rowIndex, 1);
		displayName := self.tblReports.getCellText( rowIndex, 2);
		reportView := self.tblReports.getCellText( rowIndex, 3);
		
		self.cmbReportName.listIndex := self.cmbReportName.findStringExact( 1, reportName );
		self.txtDisplayName.text := displayName;
		self.setViewName();
		
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setMyVoyageProcess" id="31b054b1-a58c-49b2-a0ce-f3302a5e08b8">
        <updating/>
        <source>setMyVoyageProcess( _voyageProcess : CM_VoyageProcess; _allReportNamesByView : CM_StringDict ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 February 2019	jlgndl1	Initial creation	TFS 43240

*/

vars

	voyProcRep : CM_VoyageProcessReport;
	pxyVoyProcRep : CM_VoyageProcessReport;

begin

	self.myVoyageProcess := _voyageProcess;
	
	
	if not self.allVoyProcReports.isEmpty then
		self.allVoyProcReports.purge();
	endif;
	
	foreach voyProcRep in self.myVoyageProcess.allAdditionalReports do
		create pxyVoyProcRep transient;
		pxyVoyProcRep.setProxy(	voyProcRep.displayName,	//_displayName : String;
								voyProcRep.reportName,	//_reportName : String;
								voyProcRep.reportView,	//_reportView : String;
								null	//_myVoyageProcess : CM_VoyageProcess
								);
		self.allVoyProcReports.add( pxyVoyProcRep );
	endforeach;
	
	_allReportNamesByView.copy( self.allReportNamesByView );

epilog

end;</source>
        <Parameter name="_voyageProcess" type="CM_VoyageProcess"/>
        <Parameter name="_allReportNamesByView" type="CM_StringDict"/>
    </JadeMethod>
    <JadeMethod name="setViewName" id="8b9c6467-76d8-4726-8217-94b82bdfd32b">
        <source>setViewName();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 February 2019	jlgndl1	Initial creation

*/

vars

	repName : String;
	jrwReport : JadeReportWriterReport;
	repView : String;

begin

	self.txtReportView.text := null;
	
	repName := self.cmbReportName.text.trimBlanks;
	if repName &lt;&gt; null then
		jrwReport  := self.myJRWReportMgr.getReport(repName);
		if jrwReport &lt;&gt; null then
			repView := jrwReport.getReportingViewName;
			self.txtReportView.text := repView;
		endif;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="8704b906-db11-4d32-8d64-ddcf4d74686b">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 February 2019	jlgndl1	Initial creation	TFS 43240

*/

vars

	rm	: JadeReportWriterManager;

begin

	create rm transient;
	self.myJRWReportMgr := rm;

	self.populateReports();
	self.populateTable();
	
	inheritMethod();

epilog

end;</source>
    </JadeMethod>
