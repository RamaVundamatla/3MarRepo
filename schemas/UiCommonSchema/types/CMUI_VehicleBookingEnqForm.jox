    <JadeMethod name="setupForm" id="ff78cdd6-f674-401c-b64b-dc438a079442">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 Sep 2022 navma1	ChangeRequest 53900: EUP - VBS MTN - [4] - Search Screen
23 Sep 2022 navhl20 ChangeRequest 53900: EUP - VBS MTN - [4] - Search Screen
17 Oct 2022	navak20 ChangeRequest 54046: EUP - VBS MTN - [7] - Email configuration and notifications
24 Apr 2023 navhl20	ChangeRequest 57716:[57718] EUP - VBS changes MTN - Bulk Edit and Linking of slots [Refinement - 01]
19 May 2023 navlw1	ChangeRequest 53902: EUP - VBS MTN - [6] - Selector Query and JRW
06 Jul 2023	navma1	ChangeRequest 58753: EUP | Slot Creation - Date and Time defaults and updates
14 Jul 2023	navma1	ChangeRequest 59136: EUP | VBS Edi Enhancement [1]
19 Jul 2023 navhl20 Bug 59181: EUP | VBS changes MTN - VBS Enquiry refresh issue
06 Aug 2023	navlw1	Bug 60367: FR | 53429 - VBS MTN - Enquiry Screen issues
*/

vars
	vbTerminal			: CM_VehicleBookingTerminal;
	isFromSelector		: Boolean;
	creationMethod,
	slotType,
	status 				: String;
begin
	self.usesQueryFrame 	  	:= true;
	self.toolbarStyle	 	  	:= self.ToolbarStyle_ShowNoHide;
	self.showToolbar 	 	  	:= true;
	self.useTableSorting 	  	:= true;
	self.useTableInfo 		  	:= true;
	self.staStatusBar.visible 	:= true; 	//26.09.2022 navhl20 TFS 53900		//24.4.2023 navhl20 #57716[57718]
	self.mnuContextHide.visible := true;
	self.tblData.multiSelect    := CM_BaseTable.MultiSelect_Simple;
	
	inheritMethod();
	self.getXMLSettingsForSetup();
	
	self.setCaption("Vehicle Booking Enquiry");
	self.setNavigatorHeading(self.caption);
	self.initQueryFrame();
	self.initSearch();

	self.initTableData(ETDef_VBSEnquiryTbl);
	self.setContextMenuItems();
	self.setNavigatorHeading( self.caption );
	
	//Start 23.09.2022 navhl20 TFS 53900
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnDelete.enabled   := false;
		self.btnNew.enabled      := false;
		self.btnEditItem.enabled := false;															
	endif;
	
	self.beginClassNotification(CM_VehicleBookingTimeSlot, false, Object_Create_Event, Response_Continuous, null);
	self.beginClassNotification(CM_VehicleBookingTimeSlot, false, Object_Update_Event, Response_Continuous, null);
	self.beginClassNotification(CM_VehicleBookingTimeSlot, false, Object_Delete_Event, Response_Continuous, null);
	//End 23.09.2022 navhl20 TFS 53900
	
	vbTerminal := self.myTerminal.myVehicleBookingTerminal;
	
	// 19/05/2023 navlw1 tfs 53902
	if self.allVbsTimeslots.isEmpty then
		vbTerminal.allVBTimeslotsById.copy(self.allVbsTimeslots);
	else
		isFromSelector := true;
	endif;
	
	self.populateVbsSlots(self.allVbsTimeslots, isFromSelector);
	
	//Handles loading of saved settings
	
	// Start 05.08.2023 navlw1 tfs #60367
	slotType := self.xmlSettings.cnEcGetTagValueOfName(self.VbsSlotType_Setting.String);
	if slotType &lt;&gt; null then
		self.cmbSlotType.listIndex := self.cmbSlotType.findStringExact(1, self.xmlSettings.cnEcGetTagValueOfName(self.VbsSlotType_Setting.String));
	else
		self.cmbSlotType.setIndexForItemData(self.VbsSlotType_Setting);
	endif;
	
	self.cmbDirection.listIndex := self.cmbDirection.findStringExact(1, self.xmlSettings.cnEcGetTagValueOfName(self.Direction_Setting.String));
	if self.cmbDirection.text &lt;&gt; null then
		self.cmbDirection_change(self.cmbDirection);
	else
		self.cmbDirection.setIndexForItemData(self.DIRECTION_ANY);
	endif;
	
	status := self.xmlSettings.cnEcGetTagValueOfName(self.Status_Setting.String);
	if status &lt;&gt; null then
		self.cmbStatus.listIndex := self.cmbStatus.findStringExact(1, self.xmlSettings.cnEcGetTagValueOfName(self.Status_Setting.String));
	else
		self.cmbStatus.setIndexForItemData(self.Status_Setting);
	endif;
	
	// End 05.08.2023 navlw1 tfs #60367
	
	self.cmbSource.listIndex := self.cmbSource.findStringExact(1, self.xmlSettings.cnEcGetTagValueOfName(self.Source_Setting.String));
	if self.cmbSource.text &lt;&gt; null then
		self.cmbSource_change(self.cmbSource);
	endif;
	
	creationMethod := self.xmlSettings.cnEcGetTagValueOfName(self.CreationMethod_Setting.String);				//19.7.2023 navhl20 #59181
	if creationMethod &lt;&gt; null then																				//19.7.2023 navhl20 #59181
		self.cmbCreationMethod.listIndex := self.cmbCreationMethod.findStringExact(1, self.xmlSettings.cnEcGetTagValueOfName(self.CreationMethod_Setting.String));
	else
		self.cmbCreationMethod.setIndexForItemData(CreationMethod_Any_Item);
	endif;
	
	self.cmbRRID.listIndex := self.cmbRRID.findStringExact(1, self.xmlSettings.cnEcGetTagValueOfName(self.SourceId_Setting.String));
	
	self.emailLayoutPermissionCheck();	// 17.10.2022 navak20 TFS 54046
epilog

end;</source>
    </JadeMethod>
