    <JadeMethod name="create" id="c0c6d3ed-4cef-4a86-927e-4b501c981f62">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     02 June 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	create self.myAutoPlan transient;
end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="464aa6fc-5ab9-430d-aec2-0fbc74158f2a">
