    <JadeMethod name="doMouseDown" id="3735456c-6b08-4fd9-804d-95ea6601cefe">
        <updating/>
        <source>doMouseDown(_control: Control input; button: Integer; shift: Integer; x, y :Real)updating;
/*
	Purpose:			
	Parameters:			
	Return Value:		

Date		Who		Reason
30 July 2008	concms1	Initial creation
*/

vars
	left, top	: Real;
begin
	if button = 1 or button = 2 then
		// select the control
		self.selectControl (_control);
	endif;
	
	if button = 2 then
		left	:= _control.getFormLeft + x; 
		top 	:= _control.getFormTop + y; 
		
		self.popupMenu (self.mnuPopup, left.Integer, top.Integer); 
	endif;
epilog

end;</source>
