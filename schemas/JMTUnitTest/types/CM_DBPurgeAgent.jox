				&amp; ". tempReading to erase: " &amp; dict.size.userNumberFormat($CNEC_NO_DECIMALS));
			if self.abortStatus = true then
				return;							//Exits here can just go straight back
			endif;
		endif;

		if tempReading.myContainer = null then
			dict.add(tempReading);
