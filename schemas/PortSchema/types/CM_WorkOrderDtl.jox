    <JadeMethod name="getStatus" id="163ff3d8-4a8d-4c3c-bc8c-0f9b4d64d032">
        <source>getStatus() : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16/05/2018	jlger1	Initial creation 38520
19/09/2018	jlgdap1	TFS 40202 PEL1 Estimation SAP Integration
30/01/2019  cnwma1	ChangeRequest 42943: PEL1 - Recheck Finance for WSDL 1.4 on Web Portal
20/12/2022	navcs2	ChangeRequest 56840:[54265] EUP - [Framework] - VAS Work Order Maintenance Sceen
*/

vars

	workOrder : CM_WorkOrder;
begin
	workOrder := self.getMyParent;
	
	if workOrder.taskStatus = WO_STATUS_COMPLETE then
		return WO_STATUS_COMPLETE;
	endif;
	
	if workOrder.taskStatus = WO_STATUS_CANCELLED then
		return WO_STATUS_CANCELLED;
	endif;
	
	if workOrder.taskStatus = WO_STATUS_PENDING_CANCEL then
		return WO_STATUS_PENDING_CANCEL;
	endif;
	
	if workOrder.taskStatus = WO_STATUS_PENDING_HOLD then
		return WO_STATUS_PENDING_HOLD;
	endif;
	
	if workOrder.taskStatus = WO_STATUS_HELD then
		return WO_STATUS_HELD;
	endif;	
	
	if workOrder.taskStatus = WO_STATUS_USERENTRY then
		return WO_STATUS_USERENTRY;
	endif;
	
	if workOrder.taskStatus = WO_STATUS_PENDING then			// 20.12.2022 navcs2 #56840:[54265]
		return WO_STATUS_PENDING;								// 20.12.2022 navcs2 #56840:[54265]
	endif;														// 20.12.2022 navcs2 #56840:[54265]
	
	if workOrder.taskStatus = WO_STATUS_APPROVED then			// TFS 40202
		return WO_STATUS_APPROVED;								// TFS 40202
	endif;														// TFS 40202
	if workOrder.taskStatus = WO_STATUS_NOTAPPROVED then		// TFS 40202
		return WO_STATUS_NOTAPPROVED;							// TFS 40202
	endif;														// TFS 40202
	
	if workOrder.taskStatus = WO_STATUS_PENDING_FIN then       //30.01.2019 cnwma1 TFS #42943
		return WO_STATUS_PENDING_FIN;
	endif;
	
	if workOrder.taskStatus = WO_STATUS_REJECTED_FIN then       //30.01.2019 cnwma1 TFS #42943
		return WO_STATUS_REJECTED_FIN;
	endif;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getStatusString" id="fd7efd78-93d5-4600-8a4e-8046e894c531">
        <source>getStatusString() : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11/11/2009	cnwrd1	Initial creation
19/09/2018	jlgdap1	TFS 40202 PEL1 Estimation SAP Integration
