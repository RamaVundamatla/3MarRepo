    <JadeMethod name="setupTableMoveEntry" id="3057b72c-3f53-477c-8826-ea287867c870">
        <source>setupTableMoveEntry() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 April 2010	cnwer1	Initial creation

*/

vars
	extraDetailsRow : Integer;
	rtScreenMode	: CM_RTScreenConfig;
	extraDetailsCell : JadeTableCell;
	showIC : Boolean;
begin
	self.tblMoveEntry.parentAspect:=Table.ParentAspect_StretchRight;
	self.tblMoveEntry.left:=0;
	self.tblMoveEntry.top:=self.lblMode.top + self.lblMode.clientHeight;
	rtScreenMode:=app.myVMAgent.getMyScreenMode();
	self.tblMoveEntry.foreColor:=rtScreenMode.screenForeColour;
	self.tblMoveEntry.backColor:=rtScreenMode.screenBackColour;
	self.tblMoveEntry.visible:=true;

	
	self.txtMoveEntryExtr.visible:=false;
	self.btnRejectTask.parentAspect:=Table.ParentAspect_None;
	self.btnRejectTwin.parentAspect:=Table.ParentAspect_None;

	self.myMoveTableDetails.setTextInputBackColour(rtScreenMode.tableBackColour);
	self.myMoveTableDetails.initTable;
	
	if self.myVMAgent.getMyRTVehicleConfig.canRemoveTargetSource then
		self.setupTableMoveNoSplitTarget();
		return;
	endif;
	
	self.myMoveTableDetails.changeEntRowColInputType(ETRow_TargetID,DataColumn,Table.InputType_TextBox);
	self.myMoveTableDetails.changeEntRowColInputType(ETRow_TwinTargetID,DataColumn,Table.InputType_TextBox);
	self.myMoveTableDetails.changeEntRowColInputType(ETRow_TandemTargetID,DataColumn,Table.InputType_TextBox);
	self.myMoveTableDetails.changeEntRowColInputType(ETRow_TotalWeight,DataColumn,Table.InputType_TextBox);
	self.myMoveTableDetails.changeEntRowColInputType(ETRow_TotalQuantity,DataColumn,Table.InputType_TextBox);
	self.myMoveTableDetails.changeEntRowColInputType(ETRow_IsWeightCertified,DataColumn,Table.InputType_CheckBox);	// TFS 2357 add this option
	self.myMoveTableDetails.addDataForEntRowName(ETRow_IsWeightCertified,'1');										// TFS 2357 set the check box to selected
	self.myMoveTableDetails.insertRowAfterEntRow(ETRow_TargetID,null,self.btnRejectTask.clientHeight);
	self.myMoveTableDetails.insertRowAfterEntRow(ETRow_TwinTargetID,null,self.btnRejectTwin.clientHeight);
	
	showIC := self.myVMAgent.getMyRTVehicleConfig.allowChangeSetdown;
	if showIC then
		self.myMoveTableDetails.insertRowAfterEntRow(ETRow_IcArea,null,self.btnRejectTwin.clientHeight);
		self.myMoveTableDetails.changeEntRowColInputType(ETRow_IcArea,DataColumn,Table.InputType_ComboBox);
	endif;
	
	self.myMoveTableDetails.setRowVisibleAfterEntRow(ETRow_TwinTargetID, false);
	self.myMoveTableDetails.setRowVisibleAfterEntRow(ETRow_IcArea, false);

	if not self.myVMAgent.getMyRTVehicleConfig.canRemoveSplitScreen then
		self.myMoveTableDetails.mergeEntRowTableCells(ETRow_ExtraDetails,2,2,Table.InputType_None);
	endif;

	//epr par 25923
	self.myMoveTableDetails.setEntRowVisible(ETRow_ExtraDetails,false);
	extraDetailsRow:=self.myMoveTableDetails.findRowWithEntRowName(ETRow_ExtraDetails);
	extraDetailsCell:=self.tblMoveEntry.accessCell(extraDetailsRow,2);
	extraDetailsCell.fontBold:=true;
	extraDetailsCell.wordWrap:=true;
	extraDetailsCell.alignment:=Table.Alignment_Left_Middle;
	self.tblMoveEntry.fitColumnWidth(2,0);
	
	self.btnICSource.visible:=true;
	self.btnICTarget.visible:=true;
	self.btnRejectTask.zOrder(1);
	self.btnRejectTask.parent:=self.frmMoveEntry;
	self.btnRejectTwin.zOrder(1);
	self.btnRejectTwin.parent:=self.frmMoveEntry;
	self.btnSwap.zOrder(1);
	self.btnIC.zOrder(1);
	self.grpAccessDir.zOrder(1);
	self.grpICFrom.parent:=self.frmMoveEntry;
	self.grpICFrom.zOrder(1);
	self.btnTargetSearch.parentAspect:=Button.ParentAspect_AnchorRight;
	
	self.frmMoveEntry.height:=self.frmGraphic.clientHeight;
	self.tblMoveEntry.scrollBars:=Table.ScrollBars_None;
	self.frmMoveEntry.scrollBars:=Picture.ScrollBars_Vertical;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
