<Class name="CM_SingleObjectUserInfoNoteEvt" id="50ec31d8-0699-4db9-a2e0-3cf81e12ae7b">
    <superclass name="CM_NotificationEvent"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <ImplicitInverseRef name="myObjectUserInfo" id="f826b5cd-f93f-4721-ae4d-d07df03e5732">
        <embedded/>
        <type name="Object"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="doCauseEvent" id="e83f6aeb-4ff2-44f8-ab01-5b63ee5f7c9f">
        <source>doCauseEvent() protected;
// ---------------------------------------------------------------------------
// Created:     19 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
26 May 2008	cnwkpd1	PAR #16814 - Replace global.commonResumInvalidObjHandler

*/
vars
	selfSubject		: CM_Object;
	isImmediate,
	subjectInvalid	: Boolean;
	
begin
	selfSubject := self.mySubject;
	if selfSubject = null then
		return;
	endif;
	
	subjectInvalid := false;
	on Exception do app.handleDeletedObject(exception, selfSubject, subjectInvalid);		// PAR #16814
	
	// DVB changed 04/06/04 to immediately send notes if we are not in transaction.
	isImmediate := not process.isInTransactionState;
//	selfSubject.causeEvent(self.number, self.myModelEventManager.isMultiTransactionTrx, self.myObjectUserInfo);
	selfSubject.causeEvent(self.number, isImmediate, self.myObjectUserInfo);
	// If subject is invalid, causeEvent will not be done and our handler will resume to here
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="updateForCreate" id="d882c3b1-ba73-4d61-a8fc-3ad5c711f61e">
        <updating/>
        <source>updateForCreate(_target : CM_Object; _number : Integer; _userInfo : Object) updating;
// ---------------------------------------------------------------------------
// Created:     19 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin
	if _target = null then
		app.raiseUnexpectedProgramError(class.name, method.name, "null target");
		return;
	endif;

	if _number &lt; User_Base_Event then
		app.raiseUnexpectedProgramError(class.name, method.name, "invalid number: " &amp; _number.String);
		return;
	endif;
	
	self.mySubject := _target;
	self.number := _number;
	self.myObjectUserInfo := _userInfo;
end;</source>
        <Parameter name="_target" type="CM_Object"/>
        <Parameter name="_number" type="Integer"/>
        <Parameter name="_userInfo" type="Object"/>
    </JadeMethod>
</Class>
