    <JadeMethod name="removeRequestFromSortDict" id="29746ce9-6325-4d2f-914b-0abeeb4738f9">
        <source>removeRequestFromSortDict(_roroReq : CM_RORORequest);
/*
Purpose:			
Date		Who		Reason
08 August 2011	cnwab1	Initial creation
*/

vars
	deckOrd, x1,y1,z1, portIndex : Integer;
	iter : Iterator;
begin
	if _roroReq.isTransient then
		return;
	endif;
	
	if self.allLoadCCByPortRotationXYZ.includes(_roroReq) then
		iter := self.allLoadCCByPortRotationXYZ.createIterator();
		iter.startAtObject(_roroReq);
		self.allLoadCCByPortRotationXYZ.getIteratorKeys(portIndex, x1,y1,z1,deckOrd,iter);
		self.allLoadCCByPortRotationXYZ.removeKeyEntry(portIndex, x1,y1,z1,deckOrd, _roroReq);
	endif;

epilog
	delete iter;
end;</source>
        <Parameter name="_roroReq" type="CM_RORORequest"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="16793651-b166-446e-bc0c-10f99b6c288c">
        <updating/>
        <source>setForCreate(_proxyDeck: CM_DeckVoyage input; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	lastDeck : CM_Deck;
	newOrdinal : Integer;
begin
	self.myVoyageStructure:=_proxyDeck.myVoyageStructure;

	if self.myVoyageStructure  &lt;&gt; null then
		lastDeck:= self.myVoyageStructure.allDecks.last;
		if lastDeck = null then
			self.ordinal:=1;
		else
			self.ordinal:=lastDeck.ordinal+1;
		endif;
	
	endif;
	
	inheritMethod(_proxyDeck, _passport);

epilog
	
end;</source>
        <Parameter name="_proxyDeck" type="CM_DeckVoyage" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="1707fc2a-964c-456c-85e6-1a47067d4d20">
        <updating/>
        <source>setForUpdate(_proxyDeck: CM_Deck input; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin
	inheritMethod(_proxyDeck, _passport);
	
	if 	self.myVoyageStructure &lt;&gt; null then
		if _proxyDeck.pxyGetRealObject = null then
			app.myEventManager.createSingleObjInfoNoteEvt(self.myVoyageStructure, EVENT_VESSEL_DECK_CREATE, self);		
		else
			app.myEventManager.createSingleObjInfoNoteEvt(self.myVoyageStructure, EVENT_VESSEL_DECK_UPDATE, self);	
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_proxyDeck" type="CM_Deck" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setKPIVoyageDeckWorkPoint" id="05b926bc-0fcc-42da-87a3-cf8c4653188b">
        <source>setKPIVoyageDeckWorkPoint();
/*
Parameters:		_coll = collection of ship receive/release transactions	

Date		Who		Reason
10 August 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/



vars
	kpi : CM_KPI;
begin
	// receivals
	self.setKPIVoyageForColl (self.allShipReceivals);
	// releases
	self.setKPIVoyageForColl (self.allShipReleases);
	
	foreach kpi in self.allKPIVoyageDeckWorkPoints discreteLock do		
		kpi.CM_KPIVoyageDeckWorkPoint.setTotalTimeAndRate();
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="setKPIVoyageForColl" id="b4c59224-6b68-49e9-b038-9569cee4afec">
        <source>setKPIVoyageForColl(_coll :CM_TITransactionByDateDict) protected;
/*
Purpose:			
Parameters:		_coll - collection of ship receive/release transactions	
Return Value:		

Date		Who		Reason
10 August 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/
vars
	kpi 		: CM_KPIVoyageDeckWorkPoint;
	tran 		: CM_TITransaction;
	js	 		: CM_VoyageJobSheet;
	vessel		: CM_Vessel;
	voyage 		: CM_Voyage;
begin
	voyage		:= self.myVoyageStructure.myVoyage;
	vessel 		:= voyage.getMyVessel();
	
	foreach tran in _coll discreteLock do
		// KPIs are by Work Point and Deck, so must have a job sheet
		if tran.isKindOf (CM_ReceiveShip) then
			js := tran.CM_ReceiveShip.myJobSheet;
		elseif tran.isKindOf (CM_ReleaseShip) then
			js := tran.CM_ReleaseShip.myJobSheet;
		endif;
		
		kpi	 := null;
	
		if js &lt;&gt; null then
			// get KPI for Deck/WorkPoint
			kpi := self.getKPIVoyageDeckWorkPointForJS(js);
			
			if kpi = null then
				create kpi;

				kpi.setKPI(js.getMyWorkPoint, js, self);
			endif;
		endif;
		
		if kpi &lt;&gt; null then
			kpi.setFromTransaction(tran);
			
			if kpi.allTrackedItems.isEmpty then
				// should not happen :-)
				delete kpi;
			endif;
		endif;
	endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_coll" type="CM_TITransactionByDateDict"/>
    </JadeMethod>
    <JadeMethod name="setMyVoyageStructure" id="1ce49943-b4c1-481e-8256-2019817e7117">
        <updating/>
        <source>setMyVoyageStructure(_voyageStructure : CM_ROROVoyageStructure) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin
	self.myVoyageStructure:=_voyageStructure;
epilog

end;</source>
        <Parameter name="_voyageStructure" type="CM_ROROVoyageStructure"/>
    </JadeMethod>
    <JadeMethod name="setRemarks" id="1717b47c-e4f4-4020-9adf-5a8526f23ba8">
        <updating/>
        <source>setRemarks(_remarks: String;_additional: Boolean) updating;
/*
Date		    Who			Reason
28 September 2011	cnwas3	  
*/

vars

begin
	if _additional then
		self.remarks := _remarks &amp; ' ' &amp; self.remarks.trimBlanks;
	else
		self.remarks := _remarks.trimBlanks;
	endif;
epilog

end;</source>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_additional" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="sortLoadCCByPortRotation" id="7fcfd421-f340-4bf3-93b1-9855d4f279a9">
        <source>sortLoadCCByPortRotation();
/*
Purpose:			
Date		Who		Reason
04 August 2011	cnwab1	Initial creation
*/

vars
	alloc : CM_YardAllocation;
	voyAlloc : CM_VoyageAllocation;
	roroReq : CM_VoyageRequest;
	
//	deckOrd, x1,y1,z1, portIndex : Integer;
begin

	self.allLoadCCByPortRotationXYZ.clear();

	
	foreach alloc in self.myVoyageStructure.myVoyage.allVoyageAllocations discreteLock do
		voyAlloc := alloc.CM_VoyageAllocation;
		foreach roroReq in voyAlloc.allRequests discreteLock do
			if roroReq.isDischarge then
				continue;
			endif;
			self.addRequestToSortDict(roroReq.CM_RORORequest);
			
		endforeach;
	
	endforeach;
	
	
epilog


end;</source>
    </JadeMethod>
    <JadeMethod name="validateCreate" id="d37ad004-8e8e-4c64-bb1d-3a0acddf907f">
        <source>validateCreate(_passport: CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

	voyageStructure : CM_ROROVoyageStructure;
begin
	inheritMethod(_passport);

	voyageStructure:=self.getROROStructure;
	if voyageStructure = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Roro_vessel_structu_null),null,null );
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Roro_vessel_structu_null),null,null ); // cnwdb2	PAR 35364
		return;
	endif;
	if voyageStructure.allDecksByCode[self.code] &lt;&gt; null then
		app.raiseCMException1(Duplicate_code_must_unique,app.getErrorString(Voyage) &amp; " " &amp; app.getErrorString(Deck),null,null);
	endif;
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="894a055d-e9d9-47b9-abc7-2d67951d001d">
        <source>validateForDelete(_passport: CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2013	cnwmc5	Initial creation	PAR 32268

*/

vars
	deckItem : CM_DeckItem;
begin
	inheritMethod(_passport);
	
	foreach deckItem in self.allDeckItems do
		deckItem.validateDelete(_passport);
	endforeach;
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validatePortRotationForLoadCC" id="b97356f5-c08b-4c16-bc12-df8936f5d945">
        <source>validatePortRotationForLoadCC(tmpSlot : CM_VoyageROROController; _voyAlloc : CM_VoyageAllocation);
/*
Purpose:			
Date		Who		Reason
08 August 2011	cnwab1	Initial creation
*/

vars
	tmpPort, oDisPort : CM_Port;
	currentDischargePortIndex,
	currentX1, otherX1 : Integer;
	extremePoint : Point;
	otherReq	: CM_RORORequest;
	otherDisPort : String;

begin



	return; // we are not doing port rotation checks across a deck









	
	if tmpSlot.getDefn() = null then
		return;
	endif;

	//validate that any containers on this deck are for ports on correct port rotation
	// assumes that the ramp is the only access and that it is AFT
		tmpPort := _voyAlloc.getDischargePort();
		// Check XY of items for ports being discharged before me, am I more AFT than them?
		extremePoint := tmpSlot.getDefn().myLayout.getExtremePoint(CM_Graphic.Position_Top);
		currentX1 := extremePoint.x;
		currentDischargePortIndex := _voyAlloc.myVoyage.allPorts.indexOf(tmpPort);
		if currentDischargePortIndex &gt; 0 then
			otherReq := tmpSlot.myDeck.allLoadCCByPortRotationXYZ.getAtKeyLss(currentDischargePortIndex,0,0,0,0);
			if otherReq &lt;&gt; null then
				otherX1 := otherReq.getX1ForPortRotationSort();
				if otherX1 &gt; currentX1 then
					oDisPort := otherReq.getAttrDischargePort();
					otherDisPort := null;
					if oDisPort &lt;&gt; null then
						otherDisPort := oDisPort.code;
					endif;
					app.raiseCMWarning4(Port_rotat_over_stow_disch_por,tmpSlot.getFullId(),tmpPort.code,otherDisPort,tmpSlot.myDeck.code,null,null,null);
					return;
				endif;
			endif;
			
			// Check XY of items for ports being discharged before me, are they more AFT than me?
			otherReq := tmpSlot.myDeck.allLoadCCByPortRotationXYZ.getAtKeyGtr(currentDischargePortIndex,99999,99999,99999,99999);
			if otherReq &lt;&gt; null then
				otherX1 := otherReq.getX1ForPortRotationSort();
				if otherX1 &lt; currentX1 then
					oDisPort := otherReq.getAttrDischargePort();
					otherDisPort := null;
					if oDisPort &lt;&gt; null then
						otherDisPort := oDisPort.code;
					endif;
					app.raiseCMWarning4(Port_rotat_over_stow_dischPORT,tmpSlot.getFullId(),tmpPort.code,otherDisPort,tmpSlot.myDeck.code,null,null,null);
					return;
				endif;
			endif;
		endif;


epilog

end;</source>
        <Parameter name="tmpSlot" type="CM_VoyageROROController"/>
        <Parameter name="_voyAlloc" type="CM_VoyageAllocation"/>
    </JadeMethod>
    <JadeMethod name="validateUpdate" id="fcabddeb-b136-4bfa-b90e-41dac25d9dbb">
        <source>validateUpdate(_passport: CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars
	realLocnDefn, pxyLocnDefn : CM_ROROLocnDefn;
	realLaneDefn, pxyLaneDefn : CM_ROROLaneDefn;
	realSelf,dupDeck : CM_DeckVoyage;
	roroStructure : CM_ROROVoyageStructure;
begin
	inheritMethod(_passport);

	realSelf:=self.pxyGetRealObject;

	if realSelf &lt;&gt; null then
		roroStructure:=realSelf.getROROStructure();
		dupDeck:=roroStructure.allDecksByCode[self.code];
		if dupDeck &lt;&gt; null and dupDeck &lt;&gt; realSelf then
			app.raiseCMException1(Duplicate_code_must_unique,app.getErrorString(Voyage) &amp; " " &amp; app.getErrorString(Deck),null,null);
			return;
		endif;	
		
		
		// PAR 31671 validate any locations that are being deleted in the definition
		foreach realLocnDefn in realSelf.allROROLocnDefnByOrdinal discreteLock do
			pxyLocnDefn := realLocnDefn.pxyGetProxyObject();
			
			// no proxy means we are deleting the location
			if pxyLocnDefn = null then
				realLocnDefn.validateDelete(_passport);
			endif;
		endforeach;
		
		// PAR 31671 validate any locations that are being deleted in the definition
		foreach realLaneDefn in realSelf.allROROLaneDefnByOrdinal discreteLock do
			pxyLaneDefn := realLaneDefn.pxyGetProxyObject();
			
			// no proxy means we are deleting the lane
			if pxyLaneDefn = null then
				realLaneDefn.validateDelete(_passport);
			endif;
		endforeach;
 	endif;
	
	

	
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
