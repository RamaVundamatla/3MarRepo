    </JadeMethod>
    <JadeMethod name="findVBSlotType" id="963177b7-ee43-496f-979c-29c726403d51">
        <source>findVBSlotType(_slotType : String; _ediTI : CM_EDITrackedItem) : CM_VehicleBookingTimeSlotType;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 31/08/2023	navdap1		Initial creation TFS 60186 EUP | FR 53824 - Road Manifest VBS Booking
// 05/09/2023	navdap1		TFS 60362 EUP | 53824 Transport Manifest VBS check
// 15/06/2023	navdap1		TFS 60478 EUP | FR 53824 VBS Slot gets booked although the message contains different parameters
//
vars
	term : CM_Terminal;
	vbsType, matchingVbsType : CM_VehicleBookingTimeSlotType;
	typesByCriteria : DynaDictionary;
	ediPrenote : CM_EDIPrenoteTI;
	iter, dynaIter : Iterator;
	vbsSlotTypeCriteria : CM_VBSSlotTypeCriteria;
	criteria : CM_YACriteria;
	cargoType : CM_CargoType;
	cargoSubType : CM_Product;
	commodity : CM_Commodity;
	carrier : CM_Carrier;
	operator : CM_Operator;
	failedMatch : Boolean;
	
begin
	term := app.myPassport.myTerminal;
	
	// If we have a slot type, check if it's valid
	if _slotType &lt;&gt; null then
		vbsType := term.allTerminalVBSSlotTypes[_slotType];
		if vbsType &lt;&gt; null and not vbsType.notAvailableForEntry then
			// All good
			return vbsType;
		endif;
	endif;
	
	if _ediTI = null then
		return null;
	endif;
	
	// If we didn't find one from the code, we need to go by criteria
	// Look for slots with the most restrictive criteria first, working down to least restrictive
	create typesByCriteria;
	typesByCriteria.setMembership(CM_VehicleBookingTimeSlotType);
	typesByCriteria.addExternalKey(Integer, 4, true, true);			// TFS 60362
	typesByCriteria.addExternalKey(String, 10, false, true);
	typesByCriteria.endKeys(false);
	
	iter := term.allTerminalVBSSlotTypes.createIterator;
	while iter.next(vbsType) do
		vbsSlotTypeCriteria := vbsType.myVBSSlotTypeCriteria;
		if vbsSlotTypeCriteria &lt;&gt; null then
			typesByCriteria.putAtKey(vbsSlotTypeCriteria.allCriteria.size, vbsType.code, vbsType);
		else
			typesByCriteria.putAtKey(0, vbsType.code, vbsType);
		endif;
	endwhile;
	
	if _ediTI.isEDIPrenote then
		ediPrenote := _ediTI.CM_EDIPrenoteTI;
		operator := app.myRoot.allOperators[ediPrenote.operatorCode];
		cargoType := app.myRoot.allCargoTypesById[ediPrenote.cargoType];
		if cargoType &lt;&gt; null then
			cargoSubType := cargoType.allProducts[null, ediPrenote.product];
			if cargoSubType = null and operator &lt;&gt; null then
				cargoSubType := cargoType.allProducts[ediPrenote.operatorCode, ediPrenote.product];
			endif;
		endif;
		commodity := app.myRoot.allCommodities[ediPrenote.commodity];
		carrier := app.myRoot.allCarriers[ediPrenote.carrierCode];
	endif;
	
	// We have all slot types sorted by most restrictive to least restrictive
	// now look for matches on what's been passed from the message
	dynaIter := typesByCriteria.createIterator();
	while dynaIter.next(vbsType) do
		// TFS 60478 Ignore types that don't match the terminals' VBS process
		if vbsType.myVBSProcess &lt;&gt; term.myVBSProcess and term.myVBSProcess &lt;&gt; null then
			continue;
		endif;
		// TFS 60478 end of this bit
		
		// If there's no criteria, this one will do 
		// - we must either have no criteria on any slot type, or have failed to match any criteria so far
		if vbsType.myVBSSlotTypeCriteria = null then
			matchingVbsType := vbsType;
			break;
		endif;
		
		vbsSlotTypeCriteria := vbsType.myVBSSlotTypeCriteria;		// TFS 60362
		failedMatch := false;										// TFS 60478 moved outside foreach (otherwise we just find the first type to match *ANY* criteria
		foreach criteria in vbsSlotTypeCriteria.allCriteria discreteLock do
			
			// Do we have a carrier match
			if criteria.myYACriteriaType.isYATypeCarrier then
				if criteria.myYAData.isKindOf(CM_YADataObjects) and not criteria.myYAData.CM_YADataObjects.allObjects.includes(carrier) then		// TFS 60362
					failedMatch := true;
				elseif criteria.myYAData.isKindOf(CM_YADataString) and not criteria.myYAData.CM_YADataString.value = ediPrenote.carrierCode then
					failedMatch := true;
				endif;
			endif;
			
			// Do we have an operator match
			if criteria.myYACriteriaType.isYATypeOperatorItem then
				if criteria.myYAData.isKindOf(CM_YADataObjects) and not criteria.myYAData.CM_YADataObjects.allObjects.includes(operator) then		// TFS 60362
					failedMatch := true;
				elseif criteria.myYAData.isKindOf(CM_YADataString) and not criteria.myYAData.CM_YADataString.value = ediPrenote.operatorCode then
					failedMatch := true;
				endif;
			endif;
			
			// Do we have a cargo type match
			if criteria.myYACriteriaType.isYATypeCargoType then
				if criteria.myYAData.isKindOf(CM_YADataObjects) and not criteria.myYAData.CM_YADataObjects.allObjects.includes(cargoType) then		// TFS 60362
					failedMatch := true;
				elseif criteria.myYAData.isKindOf(CM_YADataInteger) and not criteria.myYAData.CM_YADataInteger.allValues.includes(ediPrenote.cargoType) then
					failedMatch := true;
				endif;
			endif;
			
			// Do we have a cargo subtype match
			if criteria.myYACriteriaType.isYATypeProduct then
				if criteria.myYAData.isKindOf(CM_YADataObjects) and not criteria.myYAData.CM_YADataObjects.allObjects.includes(cargoSubType) then	// TFS 60362
					failedMatch := true;
				elseif criteria.myYAData.isKindOf(CM_YADataString) and not criteria.myYAData.CM_YADataString.value = ediPrenote.product then
					failedMatch := true;
				endif;
			endif;
			
			// Do we have a commodity match
			if criteria.myYACriteriaType.isYATypeCommodity then
				if criteria.myYAData.isKindOf(CM_YADataObjects) and not criteria.myYAData.CM_YADataObjects.allObjects.includes(commodity) then		// TFS 60362
					failedMatch := true;
				elseif criteria.myYAData.isKindOf(CM_YADataString) and not criteria.myYAData.CM_YADataString.value = ediPrenote.commodity then
					failedMatch := true;
				endif;
			endif;
			
			// Everything must match
			if not failedMatch then
				matchingVbsType := vbsType;
			else
				matchingVbsType := null;
			endif;
			
		endforeach;
		
		if matchingVbsType &lt;&gt; null then		// TFS 60362
			break;							// TFS 60362
		endif;								// TFS 60362
		
	endwhile;
	
	return matchingVbsType;
	
epilog
	delete iter;
	delete dynaIter;
	delete typesByCriteria;
end;</source>
        <Parameter name="_slotType" type="String"/>
        <Parameter name="_ediTI" type="CM_EDITrackedItem"/>
        <ReturnType type="CM_VehicleBookingTimeSlotType"/>
    </JadeMethod>
    <JadeMethod name="findVBSlotTypeWithCriteria" id="0077eb48-1808-47a9-8beb-deba6394b9bd">
        <source>findVBSlotTypeWithCriteria(_cargoType : CM_CargoType; _cargoSubType : CM_Product; _commodity : CM_Commodity; _carrier : CM_Carrier; _operator : CM_Operator) : CM_VehicleBookingTimeSlotType;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 21/07/2023	navdap1		Initial creation TFS 58923 EUP CallOff EDI Data Type / Data Load
//
vars
	iter : Iterator;
	vbsType : CM_VehicleBookingTimeSlotType;
	vbsSlotTypeCriteria : CM_VBSSlotTypeCriteria;
	criteria : CM_YACriteria;
	term : CM_Terminal;
begin
	term := app.myPassport.myTerminal;
	iter := term.allTerminalVBSSlotTypes.createIterator; //app.myRoot.allVehicleBookingTSTypes.createIterator;  //26.Jul.2023 navsp1 TFS 59314
	while iter.next(vbsType) do
		vbsSlotTypeCriteria := vbsType.myVBSSlotTypeCriteria;
		if vbsSlotTypeCriteria &lt;&gt; null then																		//26.Jul.2023 navsp1 TFS 59314
			foreach criteria in vbsSlotTypeCriteria.allCriteria discreteLock do
				// do we have a carrier, and a carrier criteria - if they don't match, return null
				if criteria.myYACriteriaType.isYATypeCarrier and _carrier &lt;&gt; null then
					if criteria.myYAData.isKindOf(CM_YADataObjects) and not criteria.myYAData.CM_YADataObjects.includes(_carrier) then
						continue;
					elseif criteria.myYAData.isKindOf(CM_YADataString) and not criteria.myYAData.CM_YADataString.value = _carrier.code then
						continue;
					endif;
				endif;
				
				// do we have an operator, and an operator criteria, and do they match
				if criteria.myYACriteriaType.isYATypeOperatorItem and _operator &lt;&gt; null then
					if criteria.myYAData.isKindOf(CM_YADataObjects) and not criteria.myYAData.CM_YADataObjects.includes(_operator) then
						continue;
					elseif criteria.myYAData.isKindOf(CM_YADataString) and not criteria.myYAData.CM_YADataString.value = _operator.code then
						continue;
					endif;
				endif;
				
				// do we have a cargo type, and a carg type criteria, and do they match
				if criteria.myYACriteriaType.isYATypeCargoType and _cargoType &lt;&gt; null then
					if criteria.myYAData.isKindOf(CM_YADataObjects) and not criteria.myYAData.CM_YADataObjects.includes(_cargoType) then
						continue;
					elseif criteria.myYAData.isKindOf(CM_YADataInteger) and not criteria.myYAData.CM_YADataInteger.allValues.includes(_cargoType.id) then
						continue;
					endif;
				endif;
				
				// do we have a cargo subtype, and a cargo subtype criteria, and do they match
				if criteria.myYACriteriaType.isYATypeProduct and _cargoSubType &lt;&gt; null then
					if criteria.myYAData.isKindOf(CM_YADataObjects) and not criteria.myYAData.CM_YADataObjects.includes(_cargoSubType) then
						continue;
					elseif criteria.myYAData.isKindOf(CM_YADataString) and not criteria.myYAData.CM_YADataString.value = _cargoSubType.code then
						continue;
					endif;
				endif;
				
				// do we have a commodity, and a commodity criteria, and do they match
				if criteria.myYACriteriaType.isYATypeCommodity and _commodity &lt;&gt; null then
					if criteria.myYAData.isKindOf(CM_YADataObjects) and not criteria.myYAData.CM_YADataObjects.includes(_commodity) then
						continue;
					elseif criteria.myYAData.isKindOf(CM_YADataString) and not criteria.myYAData.CM_YADataString.value = _commodity.code then
						continue;
					endif;
				endif;
			endforeach;		
			// everything must match
			return vbsType;
		endif;
	endwhile;
	
	return null;
epilog

end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_cargoSubType" type="CM_Product"/>
        <Parameter name="_commodity" type="CM_Commodity"/>
        <Parameter name="_carrier" type="CM_Carrier"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <ReturnType type="CM_VehicleBookingTimeSlotType"/>
    </JadeMethod>
    <JadeMethod name="findYardAllocation" id="9639bf4f-f443-4971-b71c-cc733ee50540">
        <updating/>
        <source>findYardAllocation(_ti : CM_TrackedItem; _yardAllocations : CM_ObjectSet io; _tiCriteria : String output) updating;
// -------------------------------------------
// Created november 2007 by cnwrs1 CCMS 1547
// -------------------------------------------
// find all yard allocations that will match this container
vars
	agent : CM_YAAutoplanAgent;
begin
	if not self.checkYardAllocationLicensing(app.getMyTerminalDO_NOT_USE) then
	 	return;
	endif;

	agent := self.myYAAgent;
	agent.findYardAllocation(_ti, _yardAllocations, _tiCriteria);
end;
</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_yardAllocations" type="CM_ObjectSet" usage="io"/>
        <Parameter name="_tiCriteria" type="String" usage="output"/>
    </JadeMethod>
