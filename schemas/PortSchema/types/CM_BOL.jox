    <JadeMethod name="hasStopsForUser" id="d9132f8e-cc69-4191-827d-b2ffb6b031f7">
        <source>hasStopsForUser(_user : CM_User) : Boolean;
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 07 October 2008
//
// Implemented version:
// 
//----------------------------------------------------------------------
vars
	stop	:CM_Stops;
begin
	foreach stop in self.allStops do
		if _user.canViewStop (self.myTerminal, stop.myStopsTable ) then
			return true;
		endif;
	endforeach;
	
	return false;
epilog

end;</source>
        <Parameter name="_user" type="CM_User"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="importMyReferencesXML" id="d0d82416-7204-4051-94c7-3681c5da58e5">
        <updating/>
        <source>importMyReferencesXML(_referencesBlock : String) updating;
// ---------------------------------------------------------------------------
// Created:     10 February 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	extBlock			: String;
	newExtension		: CM_BOLExtWarehouse;
	opCode				: String;
	opTerminal			: CM_OperatorTerminal;
	op					: CM_Operator;
	terminal			: CM_Terminal;
begin
	
	opCode := _referencesBlock.cnEcGetTagValueOfName(self.class.name &amp; 'myOperator');
	op := app.myRoot.allOperators['BML'];
	
	self.myOperator := op;
	terminal := app.myRoot.allTerminals['POE'];
	self.myTerminal := terminal;
	opTerminal := op.allOperatorTerminals[terminal];
	if opTerminal = null then
		create opTerminal persistent;
		opTerminal.init(op, terminal);
	endif;
	self.myOperatorTerminal := opTerminal;

	extBlock := _referencesBlock.cnEcGetTagValueOfName(CM_BOLExtWarehouse.name);
	if extBlock &lt;&gt; null then
		create newExtension persistent;
		self.setPropertyValue('myExtension', newExtension);
		//newExtension.setPropertyValue('myBOL', self);
		newExtension.importMeXML(extBlock);
	endif;

end;</source>
        <Parameter name="_referencesBlock" type="String"/>
    </JadeMethod>
