    <JadeMethod name="valYardAllocation" id="25a5c0a0-9e7d-44d4-8271-d2982b0f7a8f">
        <source>valYardAllocation(pYardAllocationObj:CM_YardAllocation; pProxyObj:CM_YardAllocation);
// --------------------------------------------------------------------------------
// Created:		27 April 2005 by cnwdad1
//
// Purpose:		Validation for updating a Yard Allocation.
//
// Parameters:	pYardAllocationObj - A reference to the persistent Yard Allocation object.
//				pProxyObj - A reference to the proxy Yard Allocation object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.raiseExceptionIfNull(pProxyObj, "Yard Allocation Proxy");
	self.raiseExceptionIfNull(pYardAllocationObj, "Yard Allocation Existing");
	// CCMS 1043 Snapshot Summary Invoicing 	Oct 2010 	cnwjre1
	if not pProxyObj.isKindOf(CM_InvoiceAllocation) then
		pProxyObj.raiseExceptionIfNotProxy(method);
	endif;
	
	if ( pYardAllocationObj.code = pProxyObj.code )
	or ( pProxyObj.pxyGetRealObject = pYardAllocationObj )	//04 Feb 2019	NDL	TFS 43153
	then
		pProxyObj.validateForUpdate();
	else
		pProxyObj.validateForCreate();
	endif;
	
	pProxyObj.validate();
end;</source>
        <Parameter name="pYardAllocationObj" type="CM_YardAllocation"/>
        <Parameter name="pProxyObj" type="CM_YardAllocation"/>
    </JadeMethod>
