    <JadeMethod name="requiresOverHangingBackend" id="02c2ee2f-cbce-41dc-89cd-f697ce000f66">
        <source>requiresOverHangingBackend(_theTI : CM_TrackedItem) : Boolean;
// ---------------------------------------------------------------------------
// Created:     29 December 2008 by cnwab1
//
//					PAR 18682 CCMS SFW 1055
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
begin
	
	if _theTI.isAttributeTrue(TI_Attrib_IsThirty) then
		return true;
// 40s do not have an over hang on voyage - AKB
//	elseif _theTI.isAttributeTrue(TI_Attrib_IsFortyFive) then
//		return true;
	elseif _theTI.isAttributeTrue(TI_Attrib_IsFiftyThree) then
		return true;
	endif;
	
	return false;

epilog

end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setAltSlotDLRALT" id="51e0b13f-eae8-47e4-aead-8c37fcdf4606">
        <updating/>
        <source>setAltSlotDLRALT(_altDischSlot : CM_VoyageController; _moveType : Integer) updating;
/*
Purpose:		I am the ALT	LOAD
Date		Who		Reason
02 April 2012	cnwab1	Initial creation
*/

vars
	tmpSlotAlt, aftLC : CM_SlotController;
	aSlotReqLoad,pxySR, aftRequest : CM_SlotRequest;
	aSlotReqDisch : CM_Request;
	tmpTI : CM_TrackedItem;
	loadAlloc : CM_VoyageAllocation;
	needAftRequest : Boolean;
	qty, voyUpdEvent : Integer;
	voyAlloc : CM_VoyageAllocation;
	tmpVoyage : CM_Voyage;
	
	attrType	: String;		//cnwmc5 - 7 August 2014 - PAR 34361
	int : Integer;	//06 Nov 2015	NDL	Par 36772
	wle : CM_WorkListEntry;	//06 Nov 2015	NDL	Par 36772
	
begin
	tmpSlotAlt := self;
	tmpVoyage := self.myVoyage;
	voyUpdEvent := app.myPassport.myTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA);
	
	aSlotReqLoad := tmpSlotAlt.mySlotRequestLoad;
	
	aSlotReqDisch := _altDischSlot.getRequest(false);
	
	//05 Feb 2016	NDL	Par 37424
	if not _altDischSlot.allTrackedItems.isEmpty then
		tmpTI := _altDischSlot.allTrackedItems.first;
	endif;
	
	qty := _altDischSlot.allTrackedItems.size;
				
	if aSlotReqLoad = null then
		if _moveType = SOB_MOVETYPE then									//cnwmc5 - 7 August 2014 - PAR 34361
			attrType := CM_SlotRequest.Attribute_SOB;						//cnwmc5 - 7 August 2014 - PAR 34361
		else																//cnwmc5 - 7 August 2014 - PAR 34361
			attrType := CM_SlotRequest.Attribute_DLR;						//cnwmc5 - 7 August 2014 - PAR 34361
		endif;																//cnwmc5 - 7 August 2014 - PAR 34361
		//aSlotReqLoad := tmpSlotAlt.updateSlotRequestAttribute(true, CM_SlotRequest.Attribute_DLR, null, app.myPassport);		//cnwmc5 - 7 August 2014 - PAR 34361
		aSlotReqLoad := tmpSlotAlt.updateSlotRequestAttribute(true, attrType, null, app.myPassport);							//cnwmc5 - 7 August 2014 - PAR 34361
		
		if app.myPassport.hasErrorsOrNonIgnoredWarnings() then // PAR 35038
			return; // PAR 35038
		endif;
		
		aSlotReqLoad.setFromTI(_altDischSlot.allTrackedItems.first); // PAR 28968 , true);
		aSlotReqDisch.setLinkedRequest(aSlotReqLoad);
		
		//06 Nov 2015	NDL	Par 36772 - Missing WLEs from teh load side of teh DLR when multiple tis in one slot.
		if qty &gt; 1 then
			foreach int in 2 to qty do
				create wle as CM_VoyageWLE;
				wle.setForCreate(aSlotReqLoad.myJob, aSlotReqLoad);
				if aSlotReqLoad.isBulkRelease() then
					wle.setLocations(aSlotReqLoad.getBulkReleaseReserveDetail().getLocation(), aSlotReqLoad.stowageId);
				endif;
			endforeach;
		endif;
		
 	endif;
	
	voyAlloc := aSlotReqLoad.allAllocations.first.CM_VoyageAllocation;

	// 29734 may be no allocations
	if voyAlloc &lt;&gt; null then
		needAftRequest := voyAlloc.needsAftRequest();
		app.myEventManager.createSingleObjInfoNoteEvt(tmpVoyage,app.myPassport.myTerminal.getTerminalEvent(EVENT_VOY_ALLOC_UPDATE),voyAlloc);
	elseif tmpTI &lt;&gt; null then	//05 Feb 2016	NDL	Par 37424
		needAftRequest := not tmpTI.isTwenty();
	endif;
	
	if app.myPassport.noErrors 
	and needAftRequest 
	and aSlotReqLoad &lt;&gt; null 
	and aSlotReqLoad.mySlotRequestAft = null then	
	
		self.createAftSlotRequest(aSlotReqLoad, app.myPassport);
	//	tmpVoyage.causeEvent(voyUpdEvent, false, self.myAftSlot);	
		
		if aSlotReqLoad.getAttrIs53() then
			if aSlotReqLoad.mySlotController.myAftSlot &lt;&gt; null then // PAR 18823
			if aSlotReqLoad.mySlotController.myAftSlot.myAftSlot &lt;&gt; null then
				aSlotReqLoad.mySlotController.myAftSlot.createAftSlotRequest(aSlotReqLoad.mySlotRequestAft, app.myPassport);
				tmpVoyage.causeEvent(voyUpdEvent, false, self.myAftSlot.myAftSlot);
			endif;
			endif;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_altDischSlot" type="CM_VoyageController"/>
        <Parameter name="_moveType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateOrdinals" id="058808fa-1d45-4951-9830-fc887a305610">
        <updating/>
        <source>setForUpdateOrdinals(_deckOrd: Integer; _cellOrd: Integer; _tierOrd: Integer) updating;
// ---------------------------------------------------------------------------
// Created:		March 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.ordinalCell := _cellOrd;
	self.ordinalDeck := _deckOrd;
	self.ordinalTier := _tierOrd;

end;</source>
