        <source>setClassName(_className: String) updating;

begin
	self.className := _className;
end;</source>
        <Parameter name="_className" type="String"/>
    </JadeMethod>
    <JadeMethod name="setInitializing" id="86f9a282-bf52-4ffd-926b-6147fe74981d">
        <updating/>
        <source>setInitializing(_value: Boolean) updating;

vars

begin
	if self.initializing &lt;&gt; _value then 
		self.initializing := _value;
	endif;

end;</source>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setIsDelete" id="5ed1e3fd-86ff-41e7-9ce9-a8a315315ea6">
        <updating/>
        <source>setIsDelete(_value: Boolean) updating;

begin
	isDelete := _value;
end;</source>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
</Class>
