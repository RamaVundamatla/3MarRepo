    <JadeMethod name="setOtherTrackedItem" id="227ca532-3e19-43e5-9a96-76b9ed4865d0">
        <updating/>
        <source>setOtherTrackedItem(pTI: CM_TrackedItem) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 October 2017	jlgndl1	Initial creation	TFS 5744

*/

vars

begin

	if pTI = null then
		return;
	endif;
	
	self.otherTrackedItem := pTI;
	self.otherTrackedItemId := pTI.id;
	self.otherTrackedItemCargoType := pTI.cargoType;

