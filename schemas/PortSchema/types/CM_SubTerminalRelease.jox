    <JadeMethod name="pxyCreateUpdateProxy" id="006b6af9-c564-47a6-ae16-bef0951e2366">
        <source>pxyCreateUpdateProxy(): SelfType;
//
// par 27289 cnwrs1 30/3/2011
//
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	pxyObject : SelfType;
	completedOK		: Boolean;
begin
	pxyObject := inheritMethod();
	pxyObject.mySubTerminalTo := self.mySubTerminalTo;
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyObject;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyObject;
	endif;	
end;
</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setFromCMIF_TITransactionCntrl" id="f638788c-0e07-4b68-a39c-568c6138c822">
        <updating/>
        <source>setFromCMIF_TITransactionCntrl(_tiTransCntrl: CMIF_TITransactionController; _passport: CM_Passport input) updating;
/* ---------------------------------------------------------------------------
Created:     20 August 2009 by cnwrs2

Purpose:     CCM 1875
        
Change Date	Who		Reason
------------------------------------------------------------------------------*/
//18 Aug 2017		cnwma1	TFS #5027:POL - CAMS Transaction not being correctly processed
vars

begin
	inheritMethod(_tiTransCntrl, _passport);
	
	//self.mySubTerminal := _tiTransCntrl.mySubTerminalFrom;
	self.setExtraData(self.Temp_SubTerminal_From, _tiTransCntrl.mySubTerminalFrom);
	
	self.mySubTerminalTo := _tiTransCntrl.mySubTerminalTo;
	// 18.8.2017 cnwma1 TFS #5027
	if _tiTransCntrl.isManual then	
		self.mySubTerminal := _tiTransCntrl.mySubTerminalFrom;
	endif;
	
epilog

end;</source>
        <Parameter name="_tiTransCntrl" type="CMIF_TITransactionController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMySubTerminal" id="029ca6af-8983-4be9-94a7-047312495545">
        <updating/>
        <source>setMySubTerminal(_subTerminal: CM_SubTerminal) updating;
/* ---------------------------------------------------------------------------
Created:     20 August 2009 by cnwrs2

Purpose:     
        
Change Date	Who		Reason
------------------------------------------------------------------------------*/
vars
	stateData		: Any;
	tmpSubTerminal	: CM_SubTerminal;
	
begin
	

	stateData	:=	self.getExtraData(self.Temp_SubTerminal_From);
	
	if stateData &lt;&gt; null then
		tmpSubTerminal	:=	stateData.CM_SubTerminal;
	// cnwdad1 28/10/2009 - PAR #21309.
	else
		tmpSubTerminal	:=	_subTerminal;
	endif;
	inheritMethod(tmpSubTerminal);


end;</source>
        <Parameter name="_subTerminal" type="CM_SubTerminal"/>
    </JadeMethod>
</Class>
