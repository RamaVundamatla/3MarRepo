    <JadeMethod name="getRangesFromString" id="96a8cec3-b300-4c98-9f50-4287792c0b8b">
        <source>getRangesFromString(_textValue : String; _ranges : IntegerArray io);

// ---------------------------------------------------------------------------
// Created:     2 February 2009 cnwjo3
//
// Purpose:		The purpose of this method is to populate the ranges int array
//				with 2 different values found in the string _textValue.  For
//				example "10-30", "10 and 30", "10and300", etc should create two
//				integers 10 and 30
//			 
// ----------   ----------  --------------------------------------------------

vars
	fromDays,
	toDays					: String;
	pos,
	left,
	right					: Integer;
	foundNum				: Boolean;
begin
	foundNum := false;
	left := 0;
	right := 0;
	foreach pos in 1 to _textValue.length do
		if foundNum = false then
			if _textValue[pos:1].Character.Integer &gt;= '0'.Integer and _textValue[pos:1].Character.Integer &lt;= '9'.Integer then
				foundNum := true;
				left := pos;
			endif;
		else
			if _textValue[pos:1].Character.Integer &lt; '0'.Integer or _textValue[pos:1].Character.Integer &gt; '9'.Integer then
				foundNum := false;
				right := pos-left;
			endif;
		endif;
		if left &lt;&gt; 0 and right &lt;&gt; 0 then
			if fromDays = "" then
				fromDays := _textValue[left:right];
				left := 0;
				right := 0;
			else
				toDays := _textValue[left:right];
			endif;
		endif;
		if foundNum = true and pos = _textValue.length then
			if fromDays = "" then
				fromDays := _textValue[left:_textValue.length];
			else
				toDays := _textValue[left:_textValue.length];
			endif;
		endif;
	endforeach;
	_ranges.add(fromDays.Integer);
	_ranges.add(toDays.Integer);
end;
</source>
        <Parameter name="_textValue" type="String"/>
        <Parameter name="_ranges" type="IntegerArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getRowByControlName" id="bd9c83c1-68ed-4cdc-bced-e03b082cefb0">
        <source>getRowByControlName(_controlName : String) : Integer;
// ---------------------------------------------------------------------------
// Created:     08 January 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	numRows,
	row					: Integer;
	tbl					: CM_BaseTable;
	entTableRow			: EntTableRow;

begin
	if self.myEntryTable &lt;&gt; null then
		return self.myEntryTable.getRowByControlName(_controlName);
	endif;
	
	tbl := self.myBaseTable;
	if tbl = null then
		return null;
	endif;
	
	numRows := tbl.rows;
	foreach row in 1 to numRows do
		entTableRow := tbl.accessRow(row).itemObject.EntTableRow;
		if (entTableRow = null) or
		   (entTableRow.controlName &lt;&gt; _controlName) then
		   continue;
		endif;
		
		return row;
	endforeach;

	return null;
end;</source>
        <Parameter name="_controlName" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
