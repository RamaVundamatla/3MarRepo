    <JadeMethod name="setLOA" id="1dc477a9-0b91-4a35-be95-b3b26369b532">
        <updating/>
        <source>setLOA(_loa : Decimal)updating, protected;
//--------------------------------------------------
// Created:	29 March 2005 By: cnwgd1
//--------------------------------------------------
vars
	movement : HMS_VoyageMovement;
	origLOA : Decimal[6,2];
begin
	origLOA := self.dim_LengthOverall;
	
	self.dim_LengthOverall := _loa;
	
	if origLOA &lt;&gt; self.dim_LengthOverall then
	
		//need to update the movement marks to match the new lOA
		foreach movement in self.allVoyageMovements do
			movement.adjustSternMarkToLOA(self.dim_LengthOverall);
		endforeach;
		
		// this method updates the proxy movements as well
		// so must NOT call self.updateMovementClearances()
		// as it only updated real movements once this voyage is actually updated
		if (not self.isTransient())
		and process.isInTransactionState() then //Belts and braces check
			self.updateMovementClearances();								
		endif;
		
	endif;	
		
end;</source>
        <access>protected</access>
        <Parameter name="_loa" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="setMyBerth" id="63dce824-1222-4270-8ade-b75443d8f30f">
        <updating/>
        <source>setMyBerth(_berth : HMS_Berth)updating;
//--------------------------------------------------
// Created:	06 April 2004 By: cnwgd1
