    <JadeMethod name="setForUpdate" id="ca5dedbf-8fa1-491d-8fe4-33849a9ad5e0">
        <updating/>
        <source>setForUpdate(_pxyWorkPointType : CM_WorkPointType)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 April 2023	navhl20	ChangeRequest 57712:[54552] EUP - Delivery Dispatch – Adding Work Point Types

*/

vars
	workPoint : CM_WorkPoint;
begin
	self.description 			:= _pxyWorkPointType.description;
	self.code 					:= _pxyWorkPointType.code;
	self.notAvailableForEntry 	:= _pxyWorkPointType.notAvailableForEntry;
	self.type					:= _pxyWorkPointType.type;
	self.myTerminal				:= _pxyWorkPointType.myTerminal;
	self.isSystemType			:= _pxyWorkPointType.isSystemType;
	
	//detach
	foreach workPoint in self.allWorkPoints do
		workPoint.setMyWorkPointType(null);
	endforeach;
	// attach
	foreach workPoint in _pxyWorkPointType.allWorkPoints do
		workPoint.setMyWorkPointType(self);
	endforeach;
epilog

end;</source>
        <Parameter name="_pxyWorkPointType" type="CM_WorkPointType"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="66304510-8296-41b2-bc41-221363b7c6f7">
        <updating/>
        <source>setProxy( _code, 
		  _description 				: String;
		  _isNotAvailableForEntry 	: Boolean;
		  _type 					: Integer;
		  _isSystemType 			: Boolean;
		  _allWorkPoints 			: CM_WorkPointSet;
		  _terminal 				: CM_Terminal) updating;

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 Apr 2023 navhl20	ChangeRequest 57712:[54552] EUP - Delivery Dispatch – Adding Work Point Types

*/

vars

begin
	self.raiseExceptionIfNotTransient(method);
	self.code 					:= _code;
	self.description 			:= _description;
	self.type					:= _type;
	self.isSystemType 			:= _isSystemType;
	self.notAvailableForEntry 	:= _isNotAvailableForEntry;
	self.myTerminal				:= _terminal;
	
	if _allWorkPoints &lt;&gt; null then
		self.allWorkPoints.clear();
		_allWorkPoints.copy(self.allWorkPoints);
	endif;
epilog

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_isNotAvailableForEntry" type="Boolean"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_isSystemType" type="Boolean"/>
        <Parameter name="_allWorkPoints" type="CM_WorkPointSet"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="6a9058f7-c937-4cde-a3bb-28f2964727c0">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 Apr 2023 navhl20	ChangeRequest 57712:[54552] EUP - Delivery Dispatch – Adding Work Point Types

*/

vars
	propName	: String;
begin
	if _property = null then
		return false;
	endif;
	
	propName := _property.name;
	
	if propName  = CM_WorkPointType::type.name then
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
