	self.setupInvStatusEmailDefault(PINEmail_InvProcAPIOffset + CM_Invoice.INVOICE_POSTED_ERROR,
									app.invoiceStatusEnumToString(CM_InvoiceProcessInvoiceAPI.firstInstance, CM_Invoice.INVOICE_POSTED_ERROR),
