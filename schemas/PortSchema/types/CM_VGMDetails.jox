    <JadeMethod name="pxyCreateUpdateProxy" id="3cd23537-4547-4d82-a469-be96e1750627">
        <source>pxyCreateUpdateProxy(): SelfType;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 30/06/2017	cnwdap1		Initial creation TFS 4492 SNO VERMAS Changes
//
vars
	pxyVGMDetails : CM_VGMDetails;
	completedOK : Boolean;

begin
	pxyVGMDetails := inheritMethod();
	pxyVGMDetails.myWeighAuthTerminal := self.myWeighAuthTerminal;
	
	completedOK := true;
	return pxyVGMDetails;

epilog
	if not completedOK then
		delete pxyVGMDetails;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="8beadb27-08a5-4c9b-9ec4-fad886a27ebc">
        <updating/>
        <source>setForUpdate(	_certifiedName, _authorisedName : String;
				_authSig, _commsType, _docDetails, _ediTrans, _email, _mail, _phone, _fax, _telephone : String;
				_docDT, _deterDT : TimeStamp	) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/06/2017	cnwdap1		Initial creation TFS 4492 SNO VERMAS Changes
// 31/08/17		jlgns1		6735 POL - [Fwd: ##5431## : 8.5.1.090 Not saving VGM authorised details]
//	27 June 2018	jlgrh7 	TFS #39152 VERMAS Message Failures - String Too Long
// 28 Sep 2018 	jlgrh7 TFS #40610 SNO - Incoming VERMAS updates "Weigh Authority" table

//
constants
	RecEscapChc  = "?";
vars
	weighAuth, pxyWeighAuth : CM_WeighAuthority;
	authTerminal : CM_WeighAuthTerminal;
	authTerms : ObjectArray;
	mailAddWithSepChar : String;				//+TFS39152
begin
	self.weightCertifiedReference := _certifiedName;
	self.weightCertifiedName := _authorisedName;
	
	// if no certified name or authorised name provided, get the default terminal weighing authority
	if self.weightCertifiedReference = null or self.weightCertifiedName = null then
		authTerminal := self.myContainer.myTerminal.getDefaultWeighAuthority();
		if authTerminal &lt;&gt; null then
			weighAuth := authTerminal.myWeighAuthority;
		endif;
	endif;

	// if no default, and certified and authorised name both present, check if there is one
	if weighAuth = null and self.weightCertifiedReference &lt;&gt; null and self.weightCertifiedName &lt;&gt; null then
		weighAuth := app.myRoot.allWeighAuthorities[self.weightCertifiedReference, self.weightCertifiedName];
	endif;
	//	//TFS 6735
	//	// if still no weigh authority, create one if I'm persistent and I have a certified and authorised name
	//	if weighAuth = null and self.weightCertifiedReference &lt;&gt; null and self.weightCertifiedName &lt;&gt; null and not self.isTransient then
	//		create pxyWeighAuth transient;
	//		pxyWeighAuth.setProxy(self.weightCertifiedName, self.weightCertifiedReference, _mail, null, null, _email, null, _phone, _telephone, _commsType, false);
	//		create weighAuth persistent;
	//		create authTerms transient;
	//		weighAuth.setForCreate(pxyWeighAuth, authTerms);
	//	endif;
	if weighAuth &lt;&gt; null then
		authTerminal := weighAuth.allWeighAuthTerminals[self.myContainer.myTerminal];
		// create a weigh authority terminal if I'm a persistent object
		if authTerminal = null and not self.isTransient then
			create authTerminal;
			authTerminal.setForCreate(false, weighAuth, self.myContainer.myTerminal);
		endif;
	endif;
	self.myWeighAuthTerminal := authTerminal;
	// if we have a reference to a weigh authority, but we're missing a certified name 
	// or an authorised name, delete the link to the weigh authority
	if self.myWeighAuthTerminal &lt;&gt; null and (self.weightCertifiedName = null or self.weightCertifiedReference = null) then
		self.myWeighAuthTerminal := null;
	endif;
	
	if _authSig &lt;&gt; null then
		self.vgmAuthSignature := _authSig;
	endif;
	if _commsType &lt;&gt; null then
		self.vgmCommsType := _commsType;
	elseif weighAuth &lt;&gt; null and weighAuth.solasMethod &lt;&gt; null then
		self.vgmCommsType := weighAuth.solasMethod;
	endif;
	if _deterDT &lt;&gt; null then
		self.vgmDeterminationDT := _deterDT;
	endif;
	if _docDT &lt;&gt; null then
		self.vgmDocsIssuedDT := _docDT;
	endif;
	if _docDetails &lt;&gt; null then
		self.vgmDocumentDetails := _docDetails;
	endif;
	if _ediTrans &lt;&gt; null then
		self.vgmEDITransmission := _ediTrans;
	endif;
	if _email &lt;&gt; null then
		self.vgmElectronicMail := _email;
	endif;
	if _mail &lt;&gt; null then
		mailAddWithSepChar := _mail;																	//+TFS39152
		self.vgmMail := mailAddWithSepChar.handleEscapeChar(RecEscapChc, 1);
	endif;
	if _phone &lt;&gt; null then
		self.vgmPhone := _phone;
	endif;
	if _fax &lt;&gt; null then
		self.vgmTelefax := _fax;
	endif;
	if _telephone &lt;&gt; null then
		self.vgmTelephone := _telephone;
	endif;
	//if weighAuth &lt;&gt; null and not self.isTransient				//-TFS40610	
	if weighAuth &lt;&gt; null and not self.isTransient and
		(weighAuth.authorisedName = self.weightCertifiedName and weighAuth.certifiedName =  self.weightCertifiedReference) then	//+TFS40610 (Only Update the matching one)
		weighAuth.updateFromVGMDetails(self, mailAddWithSepChar);		//+TFS39152
	endif;
epilog
	delete pxyWeighAuth;
	delete authTerms;
end;</source>
        <Parameter name="_certifiedName" type="String"/>
        <Parameter name="_authorisedName" type="String"/>
        <Parameter name="_authSig" type="String"/>
        <Parameter name="_commsType" type="String"/>
        <Parameter name="_docDetails" type="String"/>
        <Parameter name="_ediTrans" type="String"/>
        <Parameter name="_email" type="String"/>
        <Parameter name="_mail" type="String"/>
        <Parameter name="_phone" type="String"/>
        <Parameter name="_fax" type="String"/>
        <Parameter name="_telephone" type="String"/>
        <Parameter name="_docDT" type="TimeStamp"/>
        <Parameter name="_deterDT" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="setMyContainer" id="c2a5bc0a-b558-46cb-a2cd-4d0034b20492">
