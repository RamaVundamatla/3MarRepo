    <JadeMethod name="myPxyRTGArea" id="76a00483-1dce-4b4f-988e-f11a695eaa2e">
        <methodInvocation>mapping</methodInvocation>
        <source>myPxyRTGArea(set: Boolean; _value: CM_RTGArea io) mapping;
/*
----------   ----------  --------------------------------------------------
Created:	28 July 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
	else
		_value := self.myPxyTerminalArea.CM_RTGArea;
	endif;


end;</source>
        <Parameter name="set" type="Boolean"/>
