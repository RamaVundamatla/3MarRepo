    <JadeMethod name="getMachine" id="513f3801-788f-4b6a-b6b1-964249a37580">
        <source>getMachine(_name: String) : SIM_Machine;

vars

begin
	return allMachines[_name].SIM_Machine;
epilog

end;</source>
        <Parameter name="_name" type="String"/>
