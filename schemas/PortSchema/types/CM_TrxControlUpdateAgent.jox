    <JadeMethod name="trxUpdateJobStatus" id="314d2488-f2fb-4a58-a94f-49f3ce2859bc">
        <updating/>
        <source>trxUpdateJobStatus(pJob : CM_Job input; _passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 28 February 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	oldStatus : Integer;
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	self.raiseExceptionIfNull(pJob, 'Job');
		
	beginTransaction;
	exclusiveLock(pJob);
	oldStatus := pJob.status;	
	app.myUtilityUA.utlUpdateJobStatus(pJob, _passport);
	
	//Only add alert here as we don't create alerts for non-GUI updates
	if oldStatus &lt;&gt; pJob.status then
		//The alertManager is TRANSIENT, and therefore unaffected by
		//begin/end transaction calls.
		pJob.createSystemAlert(oldStatus);
	endif;

epilog
	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="pJob" type="CM_Job" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
