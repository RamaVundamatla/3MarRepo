    <JadeMethod name="doRefresh" id="7311771a-a3a6-4446-a339-2b3faa7513d6">
        <updating/>
        <source>doRefresh() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 May 2010	cnwjk3	Initial creation

*/

vars
	dtoEntry,
	dtoTwinEntry: DTO_RTQueueEntry;
	dtoEntryArray 	: DTO_RTQueueEntryArray;
	startText	: Integer;
	tmpStr		: String;
	
begin

	//epr par 25214
	if (self.isEnquiryMode and canRejectNonRTCargo) or self.isInDischargeMode then
		self.clearTableData(self.tblTasks);
		return;
	endif;
	
	self.setAutoSearchDirector();	//13 Nov 2017	NDL	TFS 7427

	if self.frmTaskTable.visible then
		self.tblTasks.tag := null;		// 27090  Clear the selection
		self.loadTable(self.tblTasks);
	elseif self.frmGetTask.visible then
		self.loadTable(self.tblGetNext);
	elseif  self.frmMove.visible then
		if self.frmDirector.visible  then	
			create dtoEntryArray transient;
			app.myVMAgent.findWorkingDTORTEntries(dtoEntryArray,self.tblTasks);
			
			if dtoEntryArray.isEmpty then
				if self.myMachine.currentQueueTask &lt;&gt; null then
					dtoEntry:=app.myVMAgent.findDTOEntryByRTQueueEntry(app.myVMAgent.myMachine.currentQueueTask.myEntry);
				endif;
			else
				if dtoEntryArray.size &gt; 0 then
					dtoEntry:=dtoEntryArray[1];
				endif;
				if dtoEntryArray.size &gt; 1 then
					dtoTwinEntry:=dtoEntryArray[2];
				endif;
			endif;
			
			if dtoEntry &lt;&gt; null then
				self.setupFrmDirector(dtoEntry, dtoTwinEntry, false);
			endif;
		endif;
	//	if self.frmMoveEntry.visible then
			self.setupFrmMove();
	//	endif;
	endif;
	
	self.btnAccept.caption:=app.myVMAgent.getMoveTaskStr;
epilog
	delete dtoEntryArray;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doRejectNonRTCargo" id="52df8dd6-161e-4401-b1a7-dafa37fdfe85">
        <updating/>
        <source>doRejectNonRTCargo()  : Boolean updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 May 2010	cnwer1	Initial creation

*/

vars
	ti : CM_TrackedItem;
	result : Integer;
begin
	if self.canRejectNonRTCargo then
		result:=app.msgBox(app.getErrorString(Confirm_Reject_Task),app.getErrorString(Warning),MsgBox_Yes_No);
		if result = MsgBox_Return_No then
			return false;
		endif;
		self.goToTaskFrame();
		
		//epr par 34895 27/1/15
		if self.isShowOverstowCargo then
			self.isShowOverstowCargo:=false;		
		endif;
		//epr par 34740 22/8/14
		self.frmTaskTable.visible:=true; 
		self.frmMove.visible:=false;
		self.frmMoveEntry.visible:=false;
		self.doResetSearch();
		
	else
		
		self.addInfoDisplay(app.getErrorString(Reject_Task_On_Machine));
		return false;
	endif;
	
	return true;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doRejectSingleTask" id="ab681356-3d6e-4948-a467-8a652e620336">
        <source>doRejectSingleTask(_isTwin : Boolean) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 May 2010	cnwer1	Initial creation

*/

vars
	objSet 		: CM_RTQueueTaskArray;
	dtoEntry 	:	DTO_RTQueueEntry;
	addToRejectedList : Boolean;
	result		: Integer;
begin

	app.mousePointer	:=	Busy;
	addToRejectedList 	:= false;
	create objSet transient;
	
	
	if self.frmGetTask.visible then
		if _isTwin then
			objSet.add(	self.myMachine.allCurrentQueueTasks.last );
		else
			objSet.add(	self.myMachine.allCurrentQueueTasks.first);
		endif;
	else
		if _isTwin then
			dtoEntry:=self.getWorkingTwinDTOEntry;
		else
			dtoEntry:=self.getWorkingDTOEntry;
		endif;
		objSet.add(	dtoEntry.myRealQueueEntry.CM_RTQueueEntry.allTasks.first);
	endif;
	
	if objSet.isEmpty then
		return;
	endif;
	
	result:=app.msgBox(app.getErrorString(Confirm_Reject_Task),app.getErrorString(Warning),MsgBox_Yes_No);
	if result = MsgBox_Return_No then
		return;
	endif;

	app.myVMAgent.doCancelTasks(objSet,false,addToRejectedList,null);
	if not app.myPassport.trxCompletedOK then
		return;
	endif;

epilog
	app.mousePointer	:=	Idle;
	delete objSet;

end;</source>
        <access>protected</access>
        <Parameter name="_isTwin" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doRejectTasks" id="1d8b04e9-a5e5-441b-910b-7ca18b1bba81">
        <updating/>
        <source>doRejectTasks(_giveConfirmDialog : Boolean) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 April 2010	cnwer1	Initial creation

*/

vars
	objSet 		: CM_RTQueueTaskArray;
	addToRejectedList : Boolean;
	result			: Integer;
	row,col		: Integer;
begin
	app.mousePointer	:=	Busy;
	addToRejectedList 	:= false;
	create objSet transient;
	
	if not self.myVMAgent.showingTaskList then
		self.myMachine.allCurrentQueueTasks.copy(objSet);
	else
		self.myMachine.allCurrentWorkingQueueTasks.copy(objSet);
	endif;
	
	//tasks have not been accepted or offered yet but still want to reject
	if objSet.isEmpty and self.frmTaskTable.visible then
		addToRejectedList:=true;
		self.getSelectedTasks(objSet);
	endif;
	
	
	if objSet.isEmpty then
		return;
	endif;
	
	if _giveConfirmDialog then
		result:=app.msgBox(app.getErrorString(Confirm_Reject_Task),app.getErrorString(Warning),MsgBox_Yes_No);
		if result = MsgBox_Return_No then
			return;
		endif;
	else
		addToRejectedList:=false; //+ cnwmd1 &amp; cnwer1 Par 25664
	endif;
	
	app.myVMAgent.doCancelTasks(objSet,false,addToRejectedList,null);
	if not app.myPassport.trxCompletedOK then
	//if self.checkErrors() then
		return;
	endif;

	self.goToTaskFrame();
	if not app.myVMAgent.showingTaskList then
		self.clearTableData(self.tblGetNext);
	endif;
	self.clearTableData(tblMoveInfo);
	
	
epilog
	//epr par  28458 14/10/11
	if  app.myVMAgent.showingTaskList and self.tblTasks.rows &gt; 1 and (objSet.isEmpty or addToRejectedList)   then
		//14/01/2011 cnwdz2 26647
		self.tblTasks.tag:=null;
		self.tblTasks.row := 2;
		self.tblTasks.click(self.tblTasks);	
	
	endif;
	
	app.mousePointer	:=	Idle;
	delete objSet;

end;</source>
        <access>protected</access>
        <Parameter name="_giveConfirmDialog" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doResetSearch" id="725b58b0-a4f4-4782-8a8d-8255f0e17ad8">
        <updating/>
        <source>doResetSearch() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 April 2010	cnwer1	Initial creation
14 JUL   2014   cnwma1	PAR#33722 RT device  Ctnr Enquiry/ move window  curser not going back to search panel

*/

vars

begin
	self.doRefresh();
	self.txtSearch.text:=null;
	self.txtSearch.lostFocus(self.txtSearch);	
	self.txtSearch.setFocus;          //+cnwmwa1 PAR#33722
	self.btnSearchTwin.value:=false;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResize" id="933d54ef-d887-4232-a688-c5c00e420da4">
        <updating/>
        <source>doResize() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 May 2010	cnwjk3	Initial creation

*/

vars

begin
	self.isOnNarrowScreen:=self.clientWidth &lt;= 320;
	//self.isOnNarrowScreen:= global.cnwer1 and  app.myVMAgent.getMyRTVehicleConfig.allAvailableGraphicViews.isEmpty ;
	self.frmGraphic.height:=self.frmBody.clientHeight;
	self.frmGraphic.clearGraphics();
	self.frmGraphic.drawPictureIn(self.picGrayV.picture,0,0,self.frmGraphic.width,self.frmGraphic.height);

	if self.isGFXViewVisible then
		if self.myDrawingController.isLandscape or self.isForceLandscapeButtons() then
			self.resizeForGfxButtonsLandscape();
		else
			self.resizeForGfxButtonsPortrait();
		endif;
		self.myDrawingController.onResize();
	else
		self.resizeForNoGraphics();
	endif;
	
	self.frmGraphic.refreshNow();

	self.getSessionAgent().setLastScreenPosition(self.left.Integer, self.top.Integer, self.width.Integer, self.height.Integer );
	
	self.setFrmMoveEntryScollRange();
epilog

end;</source>
    </JadeMethod>
