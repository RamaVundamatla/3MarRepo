    <JadeMethod name="comboBoxState" id="45e09f7a-3da5-4212-80c8-3dee1368e1b3">
        <source>comboBoxState(_cmb : ComboBox input; _state : Integer);
// ---------------------------------------------------------------------------
// Created:     29 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	dict				: CM_MenuItemByTypeMenuIdDict;
	baseScm 			: Schema;
	category 			: ConstantCategory;
	constDict			: ConstantNDict;
	const 				: Constant;
	state,
	listIdx,
	cnt					: Integer;

begin
	baseScm := rootSchema.getSchema(PortSchemaName);
	category := baseScm.getCategory(TIStateConstant);
	constDict := category.getConstants();
	_cmb.clear();
	foreach const in constDict do
		cnt := cnt + 1;
		state := const.valueAsInteger;
		if state = _state then
			listIdx := cnt;
		endif;
		
		_cmb.addItem(app.stateEnumToString(state));
	endforeach;
	
	if listIdx &gt; 0 then
		_cmb.listIndex := listIdx;
	endif;
	
end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_state" type="Integer"/>
    </JadeMethod>
