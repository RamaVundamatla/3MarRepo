    <JadeMethod name="getAllAvailableTerminalRoles" id="61e1f577-b1ad-4f84-8a3f-f43cefbda0d0">
        <source>getAllAvailableTerminalRoles(_secRoles : CM_SecurityRoleDict input);
// ---------------------------------------------------------------------------
// Created:     25 February 2003 by cnwrs2
//
// Purpose:     returns the root terminal roles for the user
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	rootRoles	: CM_SecurityRoleDict;
	ut			: CM_UserTerminal;
	secRole		: CM_SecurityRole;
	
begin

	create rootRoles transient;
	self.getAllRootTerminalRoles(rootRoles);
	
	foreach secRole in rootRoles do
		secRole.addRoleAndChildrenToDict(_secRoles);
	endforeach;

epilog
	delete rootRoles;
end;</source>
        <Parameter name="_secRoles" type="CM_SecurityRoleDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllRootTerminalRoles" id="95c18e0e-0aba-4046-b69c-a9e3a55dc6b8">
        <source>getAllRootTerminalRoles(_secRoles : CM_SecurityRoleDict input);
// ---------------------------------------------------------------------------
// Created:     25 February 2003 by cnwrs2
//
// Purpose:     returns the root terminal roles for the user
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	ut		: CM_UserTerminal;
	newRole,
	chkRole	: CM_SecurityRole;
	addNew	: Boolean;
	
begin

	_secRoles.clear;
	
	foreach ut in self.allUserTerminals do
		newRole := ut.mySecurityRole;
		if newRole = null then
			continue;
		endif;
		
		if _secRoles.includes(newRole) then
			continue;
		endif;
		
		addNew := true;
		
		foreach chkRole in _secRoles do
			if newRole.isChildOf(chkRole) then
				addNew := false;
				break;
			endif;
			if newRole.isParentOf(chkRole) then
				_secRoles.remove(chkRole);
			endif;
		endforeach;
		
		if addNew then
			_secRoles.add(newRole);
		endif;
		
	endforeach;

end;</source>
        <Parameter name="_secRoles" type="CM_SecurityRoleDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="0928cad1-60f4-4abe-86f3-885e2a0d8b9a">
        <source>getAuditText(): String;
// ---------------------------------------------------------------------------
// Created:     07 February 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	txt,
	tmpStr, str	: String;
	alerts	: CM_SystemAlertType;
	tmpUT 	: CM_UserTerminal;
	eventType	: CM_EventType;
	email   : CM_EmailEntity;
	data    : CM_DataAccessController;

begin
	txt[10000] := '*';
	txt := null;
	txt := inheritMethod();
	//alert types subscribed
	foreach alerts in self.allSystemAlertTypes do
		if tmpStr = null then
			tmpStr := alerts.name;
		else
			tmpStr := tmpStr &amp; ', ' &amp; alerts.name;
		endif;
	endforeach;

	txt := txt &amp; "Alerts Type subscribed: " &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	
	//event types subscribed
	tmpStr := null;
	foreach eventType in self.allEventTypes do
		if tmpStr = null then
			tmpStr := eventType.name;
		else
			tmpStr := tmpStr &amp; ', ' &amp; eventType.name;
		endif;
	endforeach;

	txt := txt &amp; "Event types subscribed : " &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;

	//email adresses
	tmpStr := null;
	foreach email in self.allEmailsICanSee do
		if tmpStr = null then
			tmpStr := email.name;
		else
			tmpStr := tmpStr &amp; ', ' &amp; email.name;
		endif;
	endforeach;

	txt := txt &amp; "Emails Selected: " &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;

	foreach data in self.allDataAccessControllers do
		if data &lt;&gt; null then
		  if data.myClassContained &lt;&gt; null then
				if data.myClassContained = CM_Carrier then
					txt := txt &amp; "Carrier Data Access: " &amp; AuditStringSeparator &amp; data.name.length.String &amp; AuditStringSeparator &amp; data.name &amp; AuditStringSeparator;
				elseif data.myClassContained = CM_ConsigneeConsignor then
					txt := txt &amp; "Consignee Data Access: " &amp; AuditStringSeparator &amp; data.name.length.String &amp; AuditStringSeparator &amp; data.name &amp; AuditStringSeparator;
				elseif data.myClassContained = CM_Operator then
					txt := txt &amp; "Operator Data Access: " &amp; AuditStringSeparator &amp; data.name.length.String &amp; AuditStringSeparator &amp; data.name &amp; AuditStringSeparator;
				elseif data.myClassContained = CM_Organisation then
					txt := txt &amp; "Organisation Data Access: " &amp; AuditStringSeparator &amp; data.name.length.String &amp; AuditStringSeparator &amp; data.name &amp; AuditStringSeparator;
				endif;
		   endif;
		 endif;  
	endforeach;
	
	tmpStr := null;
	str	   := null;
	foreach tmpUT in self.allUserTerminals do
		tmpStr := tmpUT.getMyTerminal.code;
		if tmpUT.mySecurityRole = null then	//17 Oct 2012	NDL	Par 30566
			str:= 'Terminal Security Role: &lt;null&gt;';
		else
			str:= 'Terminal Security Role:' &amp; tmpUT.mySecurityRole.name.String;
		endif;
		if tmpUT.myDefaultCargoType &lt;&gt; null then 
			str := str &amp;', Default Cargo type:'&amp; tmpUT.myDefaultCargoType.description;
		endif;
		if tmpUT.myDefaultBOLType &lt;&gt; null then 
			str := str &amp;', Default BOL Type:'&amp; tmpUT.myDefaultBOLType.description;
		endif;
		if tmpUT.myDefaultCargoBOLType &lt;&gt; null then 
			str := str &amp;', Default cargo/BOL Type:'&amp; tmpUT.myDefaultCargoBOLType.description;
		endif;
		
		if tmpStr &lt;&gt; null then
			txt := txt &amp; 'Terminal ' &amp; tmpStr &amp; AuditStringSeparator &amp; str.length.String &amp; AuditStringSeparator &amp; str &amp; AuditStringSeparator;
		endif;
	endforeach;
	
	//12 Aug 2020	NDL	TFS 49857
	if self.mySystemSecurityRole = null then
		str:= '&lt;null&gt;';
	else
		str:= self.mySystemSecurityRole.name.String;
	endif;
	txt := txt &amp; 'System Security Role ' &amp; tmpStr &amp; AuditStringSeparator &amp; str.length.String &amp; AuditStringSeparator &amp; str &amp; AuditStringSeparator;
	
	//12 Aug 2020	NDL	TFS 49857
	if self.myOrganisation = null then
		str:= '&lt;null&gt;';
	else
		str:= self.myOrganisation.name.String;
	endif;
	txt := txt &amp; 'Organisation ' &amp; tmpStr &amp; AuditStringSeparator &amp; str.length.String &amp; AuditStringSeparator &amp; str &amp; AuditStringSeparator;

	return txt;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
