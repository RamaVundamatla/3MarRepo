    <JadeMethod name="createReportRequestNew" id="6dca722a-a4a0-44c7-ad9d-62f5a358a505">
        <updating/>
        <source>createReportRequestNew(_allEventData : CM_EventDataByTypeDict) updating;

// cnwdvb1 12 December 2002 
// 09 Jul 2019	jlgrs1	TFS45051 JMT terminate on a SDS secondary exception ie a takeover has happened.
//
vars
	
	reportTemplate		: CM_ReportTemplate;
//	profName			: String;
	pxyFilter			: CMQF_FilterReports;

begin
	
	reportTemplate := self.myReportTemplate;
	if self.myFilter = null then
		return;
	endif;
	// The reason we transiently clone the persistent filter on this template
	// is because the filter is altered in the setFromTemplate method.
	
	pxyFilter := self.myFilter.cloneSelf(true);
	pxyFilter.setFromTemplate(self.myFilter, app.actualTimeServer.date, _allEventData);
	
	app.myTrxCA.trxCreateAndRunBackgroundRpt(	false,
												reportTemplate.name,
												reportTemplate.description,
												pxyFilter.jrwProfileName,
												self.printerName,
												reportTemplate.networkFilepath,
												self.outputDestination,
												self.outputType,
												self.myReportTemplate.stopEmailWhenNoDataRpt,
												pxyFilter,
												reportTemplate.myQryReport,
												self.myExtraDetail,
												reportTemplate.myEmailTemplate,
												reportTemplate.myUserToRunAs.code,
												reportTemplate.allUsersToGetOutput,
                                                null, //MTN-36668
												app.myPassport);

				
	if app.myPassport.trxCompletedOK then
		return;
	else
		app.remoteErrorWarningToAlert('INFO &gt;&gt; Error processing Template report ' &amp; self.findName() &amp; ' for user ' &amp; reportTemplate.myUserToRunAs.code,
										null, app.myPassport.allErrors, null, true, true);
		return;
	endif;

end;</source>
        <Parameter name="_allEventData" type="CM_EventDataByTypeDict"/>
    </JadeMethod>
    <JadeMethod name="createReportRequestPackage" id="00dfb3b4-6a53-4127-b151-9c4817a0ed99">
        <updating/>
        <source>createReportRequestPackage(_allEventData : CM_EventDataByTypeDict) : CM_ReportTemplate updating;

// cnwdvb1 12 December 2002 
// 13 Jan 2026 	navah1	MTN-36669: PEN | Report Generation - SFTP Reports
vars
	
	packageTemplate,
	reportTemplate		: CM_ReportTemplate;
	
	pxyFilter			: CMQF_FilterReports;

begin
	
	reportTemplate := self.myReportTemplate;
	
	// The reason we transiently clone the persistent filter on this template
	// is because the filter is altered in the setFromTemplate method.
	
	pxyFilter := self.myFilter.cloneSelf(true);
	pxyFilter.setFromTemplate(self.myFilter, app.actualTimeServer.date, _allEventData);
	
	packageTemplate := app.myUtilityCA.utlCreateAndRunBackgroundRpt(	true,
																		reportTemplate.name,
																		reportTemplate.description,
																		pxyFilter.jrwProfileName,
																		self.printerName,
																		reportTemplate.networkFilepath,
																		self.outputDestination,
																		self.outputType,
																		self.myReportTemplate.stopEmailWhenNoDataRpt,
																		pxyFilter,
																		reportTemplate.myQryReport,
																		self.myExtraDetail,
																		reportTemplate.myEmailTemplate,
																		reportTemplate.myUserToRunAs.code,
																		reportTemplate.allUsersToGetOutput,
                                                                        reportTemplate.myFTPEntity, //MTN-36668 //MTN-36669
																		app.myPassport);

				
	if app.myPassport.noErrors() then
		return packageTemplate;
	else
		app.remoteErrorWarningToAlert('INFO &gt;&gt; Error processing Template report ' &amp; self.findName() &amp; ' for user ' &amp; reportTemplate.myUserToRunAs.code,
										null, app.myPassport.allErrors, null, true, true);
		return null;
	endif;
epilog
	delete pxyFilter;		// Nov 2011 from unit test leakage
end;</source>
        <Parameter name="_allEventData" type="CM_EventDataByTypeDict"/>
        <ReturnType type="CM_ReportTemplate"/>
    </JadeMethod>
    <JadeMethod name="findName" id="906dc564-da09-45fa-9e02-f1c2b4d41570">
        <source>findName(): String;

// cnwdvb1 05 May 2003 

vars

begin

	if self.myReportTemplate &lt;&gt; null then
		return self.myReportTemplate.name.trimBlanks();
	endif;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="init" id="68a17814-8509-457b-afbf-ebe457585bb2">
        <updating/>
        <source>init(_filter			: CMQF_FilterReports;
	 _reportDef			: CM_QryReport;
	 _profileName		: String; 
	 _destination		: Integer;
	 _extraDetail		: CM_ExtraDetail;
	 _printerName		: String;
	 _outputType		: Integer) updating;

// cnwdvb1 12 December 2002 

vars

begin

	// Delete existing extra detail if any.
	delete self.myExtraDetail;
	
	// Create new one.
	if _extraDetail &lt;&gt; null then
		self.myExtraDetail := _extraDetail.cloneSelf(false);
		self.myExtraDetail.cloneReferences(_extraDetail);
	endif;
	
	// Delete existing filter.
	delete self.myFilter;
	// Create new one.
	self.myFilter := _filter.cloneSelf(false);
	self.myFilter.cloneReferences(_filter, false);

	// Set other references.
	// Don't set reference as we have this info on the
	// report template.
//	self.myReportDef		:= _reportDef;
	// Output type. Where is this report going. Save, Print, Save and Print,
	self.outputType			:= _outputType;
	// Is it a csv, printer, html etc
	self.outputDestination	:= _destination;
	// Whats the printer called.
	self.printerName		:= _printerName;
	
	self.myReportTemplate.sendCreatedEvent(false);

end;</source>
        <Parameter name="_filter" type="CMQF_FilterReports"/>
        <Parameter name="_reportDef" type="CM_QryReport"/>
        <Parameter name="_profileName" type="String"/>
        <Parameter name="_destination" type="Integer"/>
        <Parameter name="_extraDetail" type="CM_ExtraDetail"/>
        <Parameter name="_printerName" type="String"/>
        <Parameter name="_outputType" type="Integer"/>
    </JadeMethod>
