    <JadeMethod name="copyToRealWSObject" id="4bb18d4b-e37c-4375-bcc7-fe0bbfd2c5a0">
        <source>copyToRealWSObject(_realRequest: SAP17_PostBilllnvoiceRequest_DT input;
				   _createdObjects : ObjectSet input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Jun 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars
	ar				: CMIF_SAPPostBillInvAR;
	copa			: CMIF_SAPPostBillInvCOPA;
	equipment		: CMIF_SAPPostBillInvEquipment;
	facility		: CMIF_SAPPostBillInvFacility;
	gl				: CMIF_SAPPostBillInvGL;
	services		: CMIF_SAPPostBillInvServices;
	ship			: CMIF_SAPPostBillInvShip;
	realAr			: SAP17_PostBilllnvoiceRequest_DT_T_AR_Item;
	realCopa		: SAP17_PostBilllnvoiceRequest_DT_T_COPA_Item;
	realEquipment	: SAP17_PostBilllnvoiceRequest_DT_T_Equipment_Item;
	realFacility	: SAP17_PostBilllnvoiceRequest_DT_T_Facility_Item;
	realGl			: SAP17_PostBilllnvoiceRequest_DT_T_GL_Item;
	realServices	: SAP17_PostBilllnvoiceRequest_DT_T_Services_Item;
	realShip		: SAP17_PostBilllnvoiceRequest_DT_T_Ship_Item;
	
begin
	inheritMethod(_realRequest, _createdObjects);
	
	_realRequest.amount := self.amount;

	// manual population of billInfo required
	create _realRequest.billInfo transient;
	_createdObjects.add(_realRequest.billInfo);
	if self.myBillInfo &lt;&gt; null then
		self.myBillInfo.copyToRealWSObject(_realRequest.billInfo, _createdObjects);
	endif;

	_realRequest.compCode := self.compCode;
	_realRequest.currency := self.currency;
	_realRequest.customerNo := self.customerNo;
	_realRequest.docDate := self.docDate;
	_realRequest.docType := self.docType;
	_realRequest.estimationID := self.estimationID;
	_realRequest.headerText := self.headerText;
	_realRequest.invoiceID := self.invoiceID;
	_realRequest.paymentCode := self.paymentCode;
	_realRequest.postingDate := self.postingDate;
	_realRequest.refDocNo := self.refDocNo;

	// manual population of t_AR required
	create _realRequest.t_AR transient;
	_createdObjects.add(_realRequest.t_AR);
	foreach ar in self.allAR do
		create realAr transient;
		_createdObjects.add(realAr);
		ar.copyToRealWSObject(realAr, _createdObjects);
		_realRequest.t_AR.item.add(realAr);
	endforeach;
	
	// manual population of t_COPA required
	create _realRequest.t_COPA transient;
	_createdObjects.add(_realRequest.t_COPA);
	foreach copa in self.allCOPA do
		create realCopa transient;
		_createdObjects.add(realCopa);
		copa.copyToRealWSObject(realCopa, _createdObjects);
		_realRequest.t_COPA.item.add(realCopa);
	endforeach;

	// manual population of t_Equipment required
	create _realRequest.t_Equipment transient;
	_createdObjects.add(_realRequest.t_Equipment);
	foreach equipment in self.allEquipment do
		create realEquipment transient;
		_createdObjects.add(realEquipment);
		equipment.copyToRealWSObject(realEquipment, _createdObjects);
		_realRequest.t_Equipment.item.add(realEquipment);
	endforeach;
	
	// manual population of t_Facility required
	create _realRequest.t_Facility transient;
	_createdObjects.add(_realRequest.t_Facility);
	foreach facility in self.allFacility do
		create realFacility transient;
		_createdObjects.add(realFacility);
		facility.copyToRealWSObject(realFacility, _createdObjects);
		_realRequest.t_Facility.item.add(realFacility);
	endforeach;	
		
	// manual population of t_GL required
	create _realRequest.t_GL transient;
	_createdObjects.add(_realRequest.t_GL);
	foreach gl in self.allGL do
		create realGl transient;
		_createdObjects.add(realGl);
		gl.copyToRealWSObject(realGl, _createdObjects);
		_realRequest.t_GL.item.add(realGl);
	endforeach;
	
	// manual population of t_Services required
	create _realRequest.t_Services transient;
	_createdObjects.add(_realRequest.t_Services);
	foreach services in self.allServices do
		create realServices transient;
		_createdObjects.add(realServices);
		services.copyToRealWSObject(realServices, _createdObjects);
		_realRequest.t_Services.item.add(realServices);
	endforeach;
	
	// manual population of t_Ship required
	create _realRequest.t_Ship transient;
	_createdObjects.add(_realRequest.t_Ship);
	foreach ship in self.allShip do
		create realShip transient;
		_createdObjects.add(realShip);
		ship.copyToRealWSObject(realShip, _createdObjects);
		_realRequest.t_Ship.item.add(realShip);
	endforeach;	
epilog

end;</source>
        <Parameter name="_realRequest" type="SAP17_PostBilllnvoiceRequest_DT" usage="input"/>
        <Parameter name="_createdObjects" type="ObjectSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="copyToSAPPostBillInvReq" id="4dd71d25-60ce-4338-a12f-1b1877b2661b">
        <updating/>
        <source>copyToSAPPostBillInvReq(_invoice : CM_Invoice)updating;
/*

Purpose:			
	37189.007 Send Invoice/Data for Post-Billing Customer
	WSDL 1.7: Post-Billing - Billing Payment Process
	PaymentType_PostPay 
Parameters:			

Return Value:		

Date		Who		Reason
02 Jul 2018 cnwma1	ChangeRequest 38633: PEL1 - SAP Send Invoice and Associated Data Interfaces
27 Sep 2018	cnwma1	ChangeRequest 41132: PEL1 - SAP Integration : Additional Changes
01 Oct 2018 cnwma1	Bug 41186: PEL1 - SAP Integration - Unit Test issues
06 Oct 2018 cmwma1  ChangeRequest 41132: PEL1 - SAP Integration : Additional Changes
22 Nov 2018	cnwma1	ChangeRequest 42118: PEL1 - Generate tax number and invoice date
21 Dec 2018 cnwma1	Bug 42690: PEL1 - Exchange Rate field in WSDLs for INT Invoices
*/

vars
	invLine 	  : CM_InvoiceLine;
	arItem  	  : CMIF_SAPPostBillInvAR;
	copaItem      : CMIF_SAPPostBillInvCOPA;
	shipItem      : CMIF_SAPPostBillInvShip;
	equipmentItem : CMIF_SAPPostBillInvEquipment;
	facilityItem  : CMIF_SAPPostBillInvFacility;
	serviceItem   : CMIF_SAPPostBillInvServices;
	glItem        : CMIF_SAPPostBillInvGL;
	billingInfo   : CMIF_SAPPostBillInvBillInfo;
	gLCode        : CM_GLCode;
	glExt,
	str, 
	tempCopy,
	copaFieldName : String;
	pos,
	fIndex,
	lineSeq,
	copaSeq		  : Integer;
begin
	// Start
	self.compCode 		:= self.sapHelper(_invoice,"compCode");
	self.docDate  		:= self.sapHelper(_invoice,"docDate");
	self.docType  		:= self.getDocType(_invoice,"S6") ;  					//27.09.2018 cnwma1 TFS #41132
	self.headerText 	:= self.sapHelper(_invoice,"headerText");
	self.invoiceID  	:= self.sapHelper(_invoice,"invoiceID");
	self.postingDate	:= self.sapHelper(_invoice,"postingDate");
	self.currency       := self.sapHelper(_invoice,"currency");
	self.paymentCode    := self.sapHelper(_invoice,"paymentCode");
	self.amount         := self.sapHelper(_invoice,"getTotalAmtDPP");           //23.01.2019 cnwma1 TFS #42942
	self.customerNo     := self.sapHelper(_invoice,"customerNo");
	self.estimationID   := "";     /*Pending*/
	self.refDocNo   	:= self.sapHelper(_invoice,"refDocNo");					//22.8.2018 cnwma1 TFS #39698
	
	//Start Billing Info
	create billingInfo transient ;
	billingInfo.bINFO1		:=  self.sapHelper(_invoice,"billingInfo.bINFO1");
	billingInfo.bINFO2		:=  self.sapHelper(_invoice,"billingInfo.bINFO2");
	billingInfo.bINFO3 		:=  self.sapHelper(_invoice,"getTotalAmtDPP");     //23.01.2019 cnwma1 TFS #42942
	billingInfo.bINFO4  	:=  self.sapHelper(_invoice,"billingInfo.bINFO4");
	billingInfo.bINFO5      :=  self.sapHelper(_invoice,"billingInfo.bINFO5");
	billingInfo.bINFO6  	:=  self.sapHelper(_invoice,"billingInfo.bINFO6");
	self.myBillInfo 		:=  billingInfo;
	//End Billing Info
	
	lineSeq   	 :=1;
	foreach invLine in _invoice.invoiceLines  discreteLock  where not invLine.voided do  // 01.10.2018 cnwma1 TFS #41186
		gLCode :=  invLine.getGLCode;
		
		create arItem transient;
		arItem.accItemNo  		:= lineSeq.String;		
		arItem.customerNo 		:= self.sapHelper(_invoice,"arItem.customerNo");		
		arItem.paymentTerms     := self.sapHelper(invLine,"arItem.paymentTerms");
        arItem.bLineDate        := self.sapHelper(invLine,"arItem.bLineDate");        					
		arItem.paymentRef   	:= self.sapHelper(invLine,"arItem.paymentRef"); 
		arItem.itemText 		:= self.sapHelper(invLine,"arItem.itemText");		
		arItem.currencyAR   	:= self.sapHelper(invLine,"currencyAR");
		arItem.paymentMethod    := "B";
		arItem.refKey1	  		:= Space;
		arItem.bank        		:= Space;	
		arItem.taxCode      	:= self.getTaxCode(_invoice);                  //22.11.2018 cnwma1 TFS #42118
		arItem.amtDocCurAR      := self.getAmtDocCurAR(invLine).String;
		arItem.amtDPP           := self.getAmtDPP(invLine).String;
		arItem.exRateAR         := self.sapHelper(_invoice,"arItem.exRateAR"); //21.12.2018 cnwma1 Bug #42690

		self.allAR.add(arItem);
		//AR End
		lineSeq := lineSeq+1;
	endforeach;
	
	copaSeq := lineSeq;
	foreach invLine in _invoice.invoiceLines discreteLock  where not invLine.voided do  // 01.10.2018 cnwma1 TFS #41186
		// T_COPA Start
		if invLine.getGLCode &lt;&gt; null then
			gLCode :=  invLine.getGLCode;
			if gLCode.externalRef &lt;&gt; null then
				glExt 		  := gLCode.externalRef;
				tempCopy 	  := glExt &amp;'.' &amp;"*";
				pos 		  := 1;
				fIndex 		  := 0;
				str			  := "";
				copaFieldName := "";
				while true do
					str := tempCopy.scanUntil('.', pos);
					str := str.trimLeft;		
					if pos = 0 then 
						break; 
					endif;
					pos  		  := pos + 1;
					fIndex		  := fIndex +1;
					copaFieldName := "00" &amp; fIndex.String;
					if copaFieldName.length &gt; 3 then
						copaFieldName := copaFieldName[2 : copaFieldName.length];
					endif;
					if str &lt;&gt; "*" then
						create copaItem transient;
						if copaFieldName = "009" then
							copaFieldName := "010";
						elseif copaFieldName = "010" then
							copaFieldName := "011";
						elseif copaFieldName = "011" then
							copaFieldName := "012";
						elseif copaFieldName = "012" then
							copaFieldName := "013";
						elseif copaFieldName = "013" then
							copaFieldName := "014";
						endif;
						
						if copaFieldName &lt;&gt; "014" then
							copaItem.accItemNo := copaSeq.String;
							copaItem.fieldName := "WW" &amp;copaFieldName;
							if  copaFieldName = "011" then
								copaItem.character := sapHelper(invLine,"copaItem.character"); //movementBerth.externalReference3
							else
								copaItem.character :=str;
							endif;
							self.allCOPA.add(copaItem);
						endif;
					else
						break;
					endif;
				endwhile;
			endif;
		endif;
		// T_COPA End
		
		// T_GL Start
		create glItem transient;
		glItem.accItemNo			:= copaSeq.String;
		glItem.gLAccount			:= self.sapHelper(invLine,"gLAccount");
		glItem.itemText  			:= self.sapHelper(invLine,"glItem.itemText");
		glItem.profitCtr 			:= self.sapHelper(invLine,"profitCtr");
		glItem.currencyGL           := self.sapHelper(invLine,"currencyGL");
		glItem.refKey1   			:= Space; 
		glItem.taxCode   			:= self.getTaxCode(_invoice);                  //22.11.2018 cnwma1 TFS #42118
		glItem.amtDocCurGL          := self.getAmtDocCurGL(invLine).String;
		glItem.exRateGL	  			:= self.sapHelper(_invoice,"glItem.exRateGL"); //21.12.2018 cnwma1 Bug #42690
		self.allGL.add(glItem);
		//T_GL End
		
		//T_Ship Start
		create shipItem transient;
		shipItem.itemNo     		:= copaSeq.String;
		shipItem.invoiceID			:= self.sapHelper(_invoice,"invoiceID");	
		shipItem.dataSource 		:= self.sapHelper(invLine,"shipItem.dataSource");
		shipItem.callSign			:= self.sapHelper(invLine,"callSign");
		shipItem.shipCode			:= self.sapHelper(invLine,"shipCode");			
		shipItem.lineType           := self.sapHelper(invLine,"shipItem.lineType");	
		shipItem.shipName         	:= self.sapHelper(invLine,"shipName");	
		shipItem.countryID	      	:= self.sapHelper(invLine,"countryID");
		shipItem.shipGT    			:= self.sapHelper(invLine,"shipGT");
		shipItem.shipLOA         	:= self.sapHelper(invLine,"shipLOA");	
		shipItem.basePort			:= self.sapHelper(invLine,"basePort");
		shipItem.destinationPort	:= self.sapHelper(invLine,"destinationPort");
		shipItem.shipType			:= self.sapHelper(invLine,"shipType");
		shipItem.flag1				:= Space;
		shipItem.prodCode		    := self.getProductCode(gLCode);
		
		self.allShip.add(shipItem);
		//T_Ship End		
	
		//T_Equipment Start
		create equipmentItem transient;
		equipmentItem.itemNo  		:=  copaSeq.String;
		equipmentItem.invoiceID		:=  self.sapHelper(_invoice,"invoiceID");
		equipmentItem.deviceID		:=  self.sapHelper(invLine,"equipmentItem.deviceID"); 		  //27.09.2018 cnwma1 TFS #41132              								
		equipmentItem.deviceName	:=  self.sapHelper(invLine,"equipmentItem.deviceName"); 	  //27.09.2018 cnwma1 TFS #41132     
		equipmentItem.employeeID	:=  self.sapHelper(invLine,"equipmentItem.employeeID");
		equipmentItem.name			:=  self.sapHelper(invLine,"equipmentItem.name");
		equipmentItem.startDate	 	:=  self.sapHelper(invLine,"equipmentItem.startDate");
		equipmentItem.startTime 	:=  self.sapHelper(invLine,"equipmentItem.startTime");
		equipmentItem.endDate		:=  self.sapHelper(invLine,"equipmentItem.endDate");
		equipmentItem.endTime   	:=  self.sapHelper(invLine,"equipmentItem.endTime");
		equipmentItem.uOM           :=  self.sapHelper(invLine,"equipmentItem.uOM");             //01.10.2018 cnwma1 BuG #41186
		equipmentItem.dataSource	:=  self.sapHelper(invLine,"equipmentItem.dataSource");   	 //01.10.2018 cnwma1 BuG #41186				
		equipmentItem.qTYRealization:=  self.sapHelper(invLine,"equipmentItem.qTYRealization");
		equipmentItem.qTYAchieved	:=  Space;
		equipmentItem.flag1			:=  Space;
		equipmentItem.prodCode  	:=  self.getProductCode(gLCode);
		self.allEquipment.add(equipmentItem);
		//T_Equipment End
		
		//T_Facility Start
		create facilityItem transient;
		facilityItem.itemNo	   		:= copaSeq.String;
		facilityItem.invoiceID 		:= self.sapHelper(_invoice,"invoiceID");
		facilityItem.facilityID     := self.sapHelper(invLine,"facilityItem.facilityID");
		facilityItem.facilityName   := self.sapHelper(invLine,"facilityItem.facilityName");
		facilityItem.dataSource   	:= self.sapHelper(invLine,"facilityItem.dataSource");
		facilityItem.qTYRealization := self.sapHelper(invLine,"facilityItem.qTYRealization");
		facilityItem.uOM			:= self.sapHelper(invLine,"facilityItem.uOM"); 
		facilityItem.flag1			:= Space;
		facilityItem.prodCode       := self.getProductCode(gLCode);
		self.allFacility.add(facilityItem);
		//T_Facility End
		
		//T_Service Start
		create serviceItem transient;
		serviceItem.itemNo	  		:= copaSeq.String;
		serviceItem.invoiceID 		:= self.sapHelper(_invoice,"invoiceID");
		serviceItem.itemCode  		:= self.sapHelper(invLine,"serviceItem.itemCode"); 
		serviceItem.comodityName 	:= self.sapHelper(invLine,"serviceItem.comodityName");
		serviceItem.qTYProduction 	:= self.sapHelper(invLine,"serviceItem.qTYProduction");
		serviceItem.uOM  			:= self.sapHelper(invLine,"serviceItem.uOM"); 
		serviceItem.dataSource 		:= self.sapHelper(invLine,"serviceItem.dataSource");
		serviceItem.flag1 			:= Space;
		serviceItem.prodCode		:= self.getProductCode(gLCode);
		self.allServices.add(serviceItem);
		//T_Service End	
		copaSeq := copaSeq+1;
	endforeach;
epilog

end;</source>
        <Parameter name="_invoice" type="CM_Invoice"/>
    </JadeMethod>
    <JadeMethod name="delete" id="d431e326-e317-4e0b-a27f-859781c9b1f3">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 June 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars

begin
	delete self.myBillInfo;
	
	self.allAR.purge();
	self.allCOPA.purge();
	self.allEquipment.purge();
	self.allFacility.purge();
	self.allGL.purge();
	self.allServices.purge();
	self.allShip.purge();
	
epilog

end;</source>
    </JadeMethod>
