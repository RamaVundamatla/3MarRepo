    <JadeMethod name="updateEditionForSelectedObjs" id="d71787f8-0e2e-4599-9c82-fa4f21a7894e">
        <source>updateEditionForSelectedObjs(_objs : Collection);
// ---------------------------------------------------------------------------
// Created:     09 February 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpAny	: Any;
	tmpObj	: Object;
	
begin

	foreach tmpAny in _objs do
		tmpObj := tmpAny.Object;
		if self.allObjectEditions.includes(tmpObj) then
			// this will update the edition in the dict
			self.allObjectEditions.add(tmpObj);
		endif;
	endforeach;

end;</source>
        <Parameter name="_objs" type="Collection"/>
    </JadeMethod>
    <JadeMethod name="userNotification" id="940a02db-8b90-4865-8150-8be9011516f6">
        <updating/>
        <source>userNotification(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:     05 February 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
26 May 2008	cnwkpd1	PAR #16814 - Replace global.commonResumInvalidObjHandler

*/

vars
	lController : CM_LocationsController;
	gotException : Boolean;
	voyJob : CM_VoyageJob;
begin

	// PAR 21817 event := self.myTerminal.getEventFromTerminalEvent(eventType);

//write class.name &amp; '::' &amp; method.name &amp; '  ' &amp; self.String &amp; '  eventType = ' &amp; eventType.String &amp; '  ' &amp; userInfo.String;

	if eventType = self.noteVoyageAreaUpdate and userInfo &lt;&gt; null then
	// PAR 21817 if event = EVENT_UPDATE_VOYAGE_AREA and userInfo &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, lController, gotException);		// PAR #16814
		if self.allNotableObjects.includes(theObject) then
			if not userInfo.isKindOf(CM_LocationsController) then // ### AKB2005JUNE. maybe a hatchlid in cust seq mode or a slotrequest for voyage allocations
				return;
			endif;
			
			lController := userInfo.CM_LocationsController;
		else
			return;
		endif;
		

		if lController &lt;&gt; null then
			if not lController.isKindOf(CM_SlotController) then
				return; // may be a ship block controller
			endif;
			
			// ###########################
			// Check to see if this location controller is on our form
			self.drawObject(null, lController);
			if gotException then
				// Exception handler resumes here if lController was invalid.
				return;
			endif;
			//epr par 28324 17/5/12 only draw weights on note not everytime we select a slot
			self.redrawWeightsForSlot(lController.CM_SlotController);
						
		endif;

	elseif eventType = self.noteVoyageAreaRefresh then
	// PAR 21817elseif event = EVENT_REFRESH_VOYAGE_AREA then
		self.handleEventVoyageRefresh();
		
		
	// PAR 21817
	elseif eventType = self.myTerminal.getTerminalEvent(VoyageJob_Create_Event) then // PAR 21817
		on Exception do app.handleDeletedObject(exception, voyJob, gotException);		// cnwmc5 - 11/01/2013 - PAR #30966
		
		if not userInfo.isKindOf(CM_VoyageJob) then
			return;
		endif;
		
		if userInfo.isKindOf(CM_VoyageDeckJob) then
			return;
		endif;
		
		if userInfo.isKindOf(CM_VoyageHoldJob) then // TFS 3631
			return;
		endif;
		
		voyJob := userInfo.CM_VoyageJob;
		if voyJob.isHatchLidJob then
			return;
		endif;
		self.userNotificationVoyJobCreate(voyJob);
	else
		inheritMethod(eventType, theObject, eventTag, userInfo);
	endif;

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="userNotificationVoyJobCreate" id="da0b33c2-5c57-4475-bc2a-f27dfe635c2c">
        <updating/>
        <source>userNotificationVoyJobCreate(_voyJob : CM_VoyageJob) updating;
// ---------------------------------------------------------------------------
// Created:     December 2009 ANDREW BISHOP
//
//	When a job is created is shoots off a note and this method redraws the slots involved.
// THE WEIGHTS. The drawing of teh weights for a job create  was a problem because teh job create was causing 
//	a note for each slot controller in teh job and when it arrived here for each one it re calced the cell and tier 
//	weights and that looks at all teh slots in the cell and tier, so a lot of work. We do not do teh weights tuiff at all 
//	now cos it is a waste of time since teh cargo has not chnaged so teh weights have not changed. However
//	

//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lController : CM_LocationsController;
	req : CM_Request;
	slotReq : CM_SlotRequest;
	slot : CM_SlotController;
begin
	
	foreach req in _voyJob.allRequests discreteLock do	
		slotReq := req.CM_SlotRequest;
		lController := slotReq.mySlotController;
		if lController &lt;&gt; null then
			if not lController.isKindOf(CM_SlotController) then
				continue; // may be a ship block controller
			endif;
			slot := lController.CM_SlotController;
			// ###########################
			// Check to see if this location controller is on our form
			self.drawObject(null, lController);
		endif;
	endforeach;
	
epilog
	
end;</source>
        <Parameter name="_voyJob" type="CM_VoyageJob"/>
    </JadeMethod>
    <JadeMethod name="validateObjectsSameType" id="9ec9f7b8-ada7-4809-9a93-42361aa352e9">
        <source>validateObjectsSameType(_set : ObjectSet) : Boolean;
// ---------------------------------------------------------------------------
// Created:     03 February 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpObj			: Object;
	hasSlots,
	hasHatchLids	: Boolean;
begin

	foreach tmpObj in _set do
		if (not hasSlots) and CM_SlotController.hasInstance(tmpObj) then
			hasSlots := true;
			if hasHatchLids then
				break;
			endif;
		elseif (not hasHatchLids) and CM_HatchLid.hasInstance(tmpObj) then
			hasHatchLids := true;
			if hasSlots then
				break;
			endif;
		endif;
	endforeach;
	
	if hasSlots and hasHatchLids then
		return false;
	endif;

	return true;

end;</source>
        <Parameter name="_set" type="ObjectSet"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
