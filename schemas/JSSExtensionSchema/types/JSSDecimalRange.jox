    <JadeMethod name="getValueFrom" id="f2746546-f552-4b96-a7b1-11ed4bea123b">
        <source>getValueFrom():Decimal;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return (self.integerFrom.String &amp; "." &amp; self.decimalFrom.String).Decimal;
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getValueTo" id="ad95a0b7-8cc2-4848-a43c-6e3aa2a51e3e">
        <source>getValueTo():Decimal;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return (self.integerTo.String &amp; "." &amp; self.decimalTo.String).Decimal;
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="setDecimalParts" id="ae6d6b8d-2bf0-4fa2-ad46-4a82b5caae2b">
        <source>setDecimalParts(pValue:Decimal;
				pInteger:Integer io;
				pDecimal:Integer io;
				pPlaces:Integer io) protected;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	integerPart		: Integer;
	decimalPart		: Integer;
	decimalPlaces	: Integer;
	
begin
	integerPart		:=	pValue.truncated();
	decimalPart		:=	(pValue - integerPart).String[3:end].Integer;
	decimalPlaces	:=	pValue.getDeclaredScaleFactor();
epilog
	pInteger	:=	integerPart;
	pDecimal	:=	decimalPart;
	pPlaces		:=	decimalPlaces;
end;</source>
        <access>protected</access>
        <Parameter name="pValue" type="Decimal"/>
        <Parameter name="pInteger" type="Integer" usage="io"/>
        <Parameter name="pDecimal" type="Integer" usage="io"/>
        <Parameter name="pPlaces" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setValueFrom" id="2afcd447-3322-43e9-bd68-92bea46d6267">
        <updating/>
        <source>setValueFrom(pValueFrom:Decimal) updating;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.validateRange(pValueFrom, self.getValueTo()) then
		self.setDecimalParts(pValueFrom, self.integerFrom, self.decimalFrom, self.placesFrom);
	endif;
end;</source>
        <Parameter name="pValueFrom" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="setValueTo" id="2419c3f5-8fed-42f7-ba13-7714f506cdb1">
        <updating/>
        <source>setValueTo(pValueTo:Decimal) updating;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.validateRange(self.getValueFrom(), pValueTo) then
		self.setDecimalParts(pValueTo, self.integerTo, self.decimalTo, self.placesTo);
	endif;
end;</source>
        <Parameter name="pValueTo" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="updateMe" id="b39f34df-cccc-4fff-bc3b-a5018618109a">
        <updating/>
        <source>updateMe(pValueFrom:Decimal; pValueTo:Decimal) updating;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.setValueTo(pValueTo);
	self.setValueFrom(pValueFrom);
end;</source>
        <Parameter name="pValueFrom" type="Decimal"/>
        <Parameter name="pValueTo" type="Decimal"/>
    </JadeMethod>
</Class>
