    <JadeMethod name="btnDelete_click" id="e409c8b9-46f4-4249-acf4-9e2f9ee407a6">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnDelete_click(btn: Button input) updating;

vars
	root			: CnEcLincDefRoot;		// Root object tree, contains Linc systems
	currSystem		: CnEcLincSystemDef;	// Linc system(s), 	 contains Ispecs
	currIspec		: CnEcLincIspecDef;		// Linc Ispec(s),	 contains Fields
	currField		: CnEcLincFieldDef;		// Ispec field(s),	 stores field attributes

	intReturn		: Integer;

begin
	// Handle database delete exceptions
	on SystemException do deleteExceptionHandler(exception);
	on LockException   do deleteExceptionHandler(exception);

	// Set the Linc system root and the FIRST Linc system
	root := CnEcLincDefRoot.firstInstance;

	if ( root = null ) then 
		// No root
	endif;

	if ( currentLincSystem = null) then
		// No active system
		return;
	endif;

	// check that the user really does want to delete the current system

	intReturn := app.msgBox ( ("Delete details for system " &amp; currentLincSystem.name.toUpper ), "Delete Confirmation" , 1 );

	if intReturn = 2 then 
		abortTransaction;
		return;
	endif;	

	// Delete the current Linc system and all Ispecs
	beginTransaction;

		currentLincSystem.deleteIspecs;
		delete currentLincSystem;

	commitTransaction;

	// Reset the current Linc system and Ispec to the first available
	setCurrentLincSystem ( null );
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
