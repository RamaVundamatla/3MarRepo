    <JadeMethod name="validateForDelete" id="e9c78ec4-bac4-4e64-be85-c84c3fdf6b01">
        <source>validateForDelete();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 10/06/2020	jlgdap1		Initial creation TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
//
vars
	lc, lcCol : CM_LocationsController;

begin
	foreach lc in self.allRowControllersById discreteLock do
		foreach lcCol in lc.CM_GeneralCargoAllocGroup.allLocations do
			lcCol.validateForDelete();
		endforeach;
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="fda748b3-3c9d-4977-ae74-506873ef9562">
        <source>validateForUpdate(pRealTerminalArea: CM_TerminalArea);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 05/06/2020	jlgdap1		Initial creation TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
// 16/07/2020	jlgdap1		TFS 49783 ASPA Graphical Display
//
vars
	realTA : CM_GeneralCargoAllocRowArea;
	idx : Integer;
	pxyRow, realRow : CM_RowAreaRow;
	hasCargo, columnsChanged : Boolean;
	hasYA, dividersChanged : Boolean;
	tiArray : CM_TIArray;
	plannedArray, queuedArray : CM_TIArray;

begin
	inheritMethod(pRealTerminalArea);
	
	// can't change column ids (or number of columns) if the area has cargo in it or planned/queued to it
	realTA := pRealTerminalArea.CM_GeneralCargoAllocRowArea;
	if self.allRows.size &lt;&gt; realTA.allRows.size then
		columnsChanged := true;
		dividersChanged := true;	//10 May 2021	NDL	TFS 51156
	endif;
	foreach idx in 1 to self.allRows.size do
		pxyRow := self.allRows[idx];
		if idx &lt;= realTA.allRows.size then			// TFS 49783
			realRow := realTA.allRows[idx];
			if pxyRow.myRowArea.id &lt;&gt; realRow.myRowArea.id then
				columnsChanged := true;
			endif;
			if pxyRow.allRowControllers.first.CM_GeneralCargoAllocController.myGroup.id &lt;&gt; realRow.allRowControllers.first.CM_GeneralCargoAllocController.myGroup.id then
				dividersChanged := true;
			endif;
		endif;										// TFS 49783
	endforeach;
	create tiArray transient;
	self.getAllTrackedItems(tiArray);
	self.getAllPlannedQueuedTIs(tiArray);
	hasCargo := tiArray.isNotEmpty;
	
	if hasCargo and columnsChanged then
		app.raiseCMException(Column_labels_cant_change, null, null);
	endif;
	
	// can't change dividers if we have any yard allocations
	if self.allRowControllersById.size &lt;&gt; realTA.allRowControllersById.size then
		dividersChanged := true;
	endif;
	
	if dividersChanged and ( realTA.allYardAllocations.isNotEmpty or realTA.allProductMinMax.isNotEmpty ) then
		app.raiseCMException(Dividers_cant_change, null, null);
	endif;
epilog
	delete tiArray;
end;</source>
        <Parameter name="pRealTerminalArea" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="yaBuildBlocks" id="e7c44fd0-0306-4fbb-bf17-2dd6ece3eac9">
        <source>yaBuildBlocks(pYardAllocationObj: CM_YardAllocation; pAllControllersObj: CM_LCArray input; pAllBlocksInObj: CM_YABlockArray input; pAllBlocksOutObj: CM_YABlockArray input): Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 07/07/2020	jlgdap1		Initial creation TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
//
vars
	yaAgent : CM_YAAgent;
	yaAlloc : CM_YardAllocation;
	lc : CM_LocationsController;
	startCol, endCol : CM_GeneralCargoAllocController;
	groups : StringArray;
	group, extra : String;

begin
	// don't inherit any behaviour
	//return inheritMethod(pYardAllocationObj, pAllControllersObj, pAllBlocksInObj, pAllBlocksOutObj);
	
	create yaAgent transient;
	create groups transient;
	startCol := pAllControllersObj.first.CM_GeneralCargoAllocController;
	endCol := pAllControllersObj.last.CM_GeneralCargoAllocController;
	if startCol &lt;&gt; null then
		group := startCol.myGroup.myTerminalArea.id &amp; Space &amp; startCol.id;
		if startCol &lt;&gt; endCol then
			group := group &amp; Hyphen &amp; endCol.id;
		endif;
	endif;
	
	yaAlloc := pYardAllocationObj;
	
	yaAgent.addRange(yaAlloc, group);
	
	yaAlloc.allYABlocksIn.copy(pAllBlocksInObj);
	yaAlloc.allYABlocksOut.copy(pAllBlocksOutObj);
	yaAlloc.allYABlocksIn.clear;
	yaAlloc.allYABlocksOut.clear;
	
	return true;
	
epilog
	delete yaAgent;
	delete groups;
end;</source>
        <Parameter name="pYardAllocationObj" type="CM_YardAllocation"/>
        <Parameter name="pAllControllersObj" type="CM_LCArray" usage="input"/>
        <Parameter name="pAllBlocksInObj" type="CM_YABlockArray" usage="input"/>
        <Parameter name="pAllBlocksOutObj" type="CM_YABlockArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
