    <JadeMethod name="hasCargoRestrictions" id="0e8ca60e-55a5-4711-a39b-a8300ca0c5d9">
        <source>hasCargoRestrictions():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 February 2014	cnwndl1	Initial creation	Par 22439

*/

vars

	wagController : CM_WagonController;

begin

	if self.myWagonMaster &lt;&gt; null and self.myTerminal &lt;&gt; null then
		if self.myWagonMaster.getMyObjectMatchCriteriaFor( self.myTerminal ) &lt;&gt; null then
			//wagController := self.allLocationsControllers.first.CM_WagonController;
			wagController := self.allLocationsControllersArray[1].CM_WagonController;	//04 Dec 2014	NDL	Par 35345
			if wagController &lt;&gt; null then
				return ( wagController.myRailAllocation &lt;&gt; null );
			endif;
		endif;
	endif;
	
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
