    <JadeMethod name="checkOpReportDataLine" id="3a86775d-472b-4bc4-b758-6507ef1a38dc">
        <source>checkOpReportDataLine( _dataLine : CM_MTPoolingEnquiryLine; _operator : CM_Operator; _iSOTypeGroup : CM_ISOTypeGroup  ) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 June 2011	cnwndl1	Initial creation	Par 27731

*/

vars

	thresh : CM_MTThreshold;
	lineStr : String;
	ti : CM_TrackedItem;
	relReq : CM_BulkRelease;
	isoType : CM_ISOType;
	iSOTypeGroupFor4200 : CM_ISOTypeGroup;

begin

	thresh := _dataLine.myMTThreshold;
	
	if thresh.processingPriority = 1 then
	
		lineStr := "OPS Line 1, ";
	
		self.assertTrueMsg( _dataLine.allOnsiteTis.size = 12, lineStr &amp; "allOnsiteTis expected 12, got " &amp; _dataLine.allOnsiteTis.size.String );
		self.assertTrueMsg( _dataLine.allPreTripTis.size = 2, lineStr &amp; "allPreTripTis expected 2, got " &amp; _dataLine.allPreTripTis.size.String );
		self.assertTrueMsg( _dataLine.allPreTripAreaTis.size = 1, lineStr &amp; "allPreTripAreaTis expected 1, got " &amp; _dataLine.allPreTripAreaTis.size.String );
		self.assertTrueMsg( _dataLine.allWashTis.size = 2, lineStr &amp; "allWashTis expected 2, got " &amp; _dataLine.allWashTis.size.String );
		self.assertTrueMsg( _dataLine.allWashAreaTis.size = 1, lineStr &amp; "allWashAreaTis expected 1, got " &amp; _dataLine.allWashAreaTis.size.String );
		self.assertTrueMsg( _dataLine.allRepairTis.size = 2, lineStr &amp; "allRepairTis expected 2, got " &amp; _dataLine.allRepairTis.size.String );
		self.assertTrueMsg( _dataLine.allRepairAreaTis.size = 1, lineStr &amp; "allRepairAreaTis expected 1, got " &amp; _dataLine.allRepairAreaTis.size.String );
		self.assertTrueMsg( _dataLine.allPtiRepairTis.size = 2, lineStr &amp; "allPtiRepairTis expected 2, got " &amp; _dataLine.allPtiRepairTis.size.String );
		self.assertTrueMsg( _dataLine.allSurveyTis.size = 2, lineStr &amp; "allSurveyTis expected 2, got " &amp; _dataLine.allSurveyTis.size.String );
		self.assertTrueMsg( _dataLine.allStopTis.size = 1, lineStr &amp; "allStopTis expected 1, got " &amp; _dataLine.allStopTis.size.String );
		self.assertTrueMsg( _dataLine.allAvailable.size = 1, lineStr &amp; "allAvailable expected 1, got " &amp; _dataLine.allAvailable.size.String );
		self.assertTrueMsg( _dataLine.allRoadReqs.size = 1, lineStr &amp; "allRoadReqs expected 1, got " &amp; _dataLine.allRoadReqs.size.String );
		self.assertTrueMsg( _dataLine.allRailReqs.size = 1, lineStr &amp; "allRailReqs expected 1, got " &amp; _dataLine.allRailReqs.size.String );
		self.assertTrueMsg( _dataLine.allShipReqs.size = 1, lineStr &amp; "allShipReqs expected 1, got " &amp; _dataLine.allShipReqs.size.String );
		self.assertTrueMsg( _dataLine.allPackReqs.size = 1, lineStr &amp; "allPackReqs expected 1, got " &amp; _dataLine.allPackReqs.size.String );
		self.assertTrueMsg( _dataLine.allPendReqs.size = 1, lineStr &amp; "allPendReqs expected 1, got " &amp; _dataLine.allPendReqs.size.String );
		self.assertTrueMsg( _dataLine.allRoadPreNotes.size = 2, lineStr &amp; "allRoadPreNotes expected 2, got " &amp; _dataLine.allRoadPreNotes.size.String );
		self.assertTrueMsg( _dataLine.allRailPreNotes.size = 2, lineStr &amp; "allRailPreNotes expected 2, got " &amp; _dataLine.allRailPreNotes.size.String );
		self.assertTrueMsg( _dataLine.allShipReceivals.size = 2, lineStr &amp; "allShipReceivals expected 2, got " &amp; _dataLine.allShipReceivals.size.String );
		
		self.assertTrueMsg( _dataLine.allPreTripAreaTis.first.id = "THRS1110101", lineStr &amp; "allPreTripAreaTis should contain 'THRS1110101'" );
		self.assertTrueMsg( _dataLine.allWashAreaTis.first.id = "THRS1110103", lineStr &amp; "allWashAreaTis should contain 'THRS1110103'" );
		self.assertTrueMsg( _dataLine.allRepairAreaTis.first.id = "THRS1110105", lineStr &amp; "allRepairAreaTis should contain 'THRS1110105'" );		
		
		foreach ti in _dataLine.allAvailable do
			self.assertTrueMsg( ti.myOperator = _operator, lineStr &amp; ti.id &amp; " operator NOT '" &amp; _operator.code &amp; "'[ allAvailable ]" );
			self.assertTrueMsg( ti.CM_Container.getISOTypeGroupObject = _iSOTypeGroup, lineStr &amp; ti.id &amp; " ISO group NOT '" &amp; _iSOTypeGroup.code &amp; "'[ allAvailable ]" );
		endforeach;
		foreach ti in _dataLine.allOnsiteTis do
			self.assertTrueMsg( ti.myOperator = _operator, lineStr &amp; ti.id &amp; " operator NOT '" &amp; _operator.code &amp; "'[ allOnsiteTis ]" );
			self.assertTrueMsg( ti.CM_Container.getISOTypeGroupObject = _iSOTypeGroup, lineStr &amp; ti.id &amp; " ISO group NOT '" &amp; _iSOTypeGroup.code &amp; "'[ allOnsiteTis ]" );
		endforeach;	
		foreach ti in _dataLine.allPreTripAreaTis do
			self.assertTrueMsg( ti.myOperator = _operator, lineStr &amp; ti.id &amp; " operator NOT '" &amp; _operator.code &amp; "'[ allPreTripAreaTis ]" );
			self.assertTrueMsg( ti.CM_Container.getISOTypeGroupObject = _iSOTypeGroup, lineStr &amp; ti.id &amp; " ISO group NOT '" &amp; _iSOTypeGroup.code &amp; "'[ allPreTripAreaTis ]" );
		endforeach;
		foreach ti in _dataLine.allPreTripTis do
			self.assertTrueMsg( ti.myOperator = _operator, lineStr &amp; ti.id &amp; " operator NOT '" &amp; _operator.code &amp; "'[ allPreTripTis ]" );
			self.assertTrueMsg( ti.CM_Container.getISOTypeGroupObject = _iSOTypeGroup, lineStr &amp; ti.id &amp; " ISO group NOT '" &amp; _iSOTypeGroup.code &amp; "'[ allPreTripTis ]" );
		endforeach;
		foreach ti in _dataLine.allPtiRepairTis do
			self.assertTrueMsg( ti.myOperator = _operator, lineStr &amp; ti.id &amp; " operator NOT '" &amp; _operator.code &amp; "'[ allPtiRepairTis ]" );
			self.assertTrueMsg( ti.CM_Container.getISOTypeGroupObject = _iSOTypeGroup, lineStr &amp; ti.id &amp; " ISO group NOT '" &amp; _iSOTypeGroup.code &amp; "'[ allPtiRepairTis ]" );
		endforeach;
		foreach ti in _dataLine.allRailPreNotes do
			self.assertTrueMsg( ti.myOperator = _operator, lineStr &amp; ti.id &amp; " operator NOT '" &amp; _operator.code &amp; "'[ allRailPreNotes ]" );
			self.assertTrueMsg( ti.CM_Container.getISOTypeGroupObject = _iSOTypeGroup, lineStr &amp; ti.id &amp; " ISO group NOT '" &amp; _iSOTypeGroup.code &amp; "'[ allRailPreNotes ]" );
		endforeach;		
		foreach ti in _dataLine.allRepairAreaTis do
			self.assertTrueMsg( ti.myOperator = _operator, lineStr &amp; ti.id &amp; " operator NOT '" &amp; _operator.code &amp; "'[ allRepairAreaTis ]" );
			self.assertTrueMsg( ti.CM_Container.getISOTypeGroupObject = _iSOTypeGroup, lineStr &amp; ti.id &amp; " ISO group NOT '" &amp; _iSOTypeGroup.code &amp; "'[ allRepairAreaTis ]" );
		endforeach;
		foreach ti in _dataLine.allRepairTis do
			self.assertTrueMsg( ti.myOperator = _operator, lineStr &amp; ti.id &amp; " operator NOT '" &amp; _operator.code &amp; "'[ allRepairTis ]" );
			self.assertTrueMsg( ti.CM_Container.getISOTypeGroupObject = _iSOTypeGroup, lineStr &amp; ti.id &amp; " ISO group NOT '" &amp; _iSOTypeGroup.code &amp; "'[ allRepairTis ]" );
		endforeach;
		foreach ti in _dataLine.allRoadPreNotes do
			self.assertTrueMsg( ti.myOperator = _operator, lineStr &amp; ti.id &amp; " operator NOT '" &amp; _operator.code &amp; "'[ allRoadPreNotes ]" );
			self.assertTrueMsg( ti.CM_Container.getISOTypeGroupObject = _iSOTypeGroup, lineStr &amp; ti.id &amp; " ISO group NOT '" &amp; _iSOTypeGroup.code &amp; "'[ allRoadPreNotes ]" );
		endforeach;		
		foreach ti in _dataLine.allShipReceivals do
			self.assertTrueMsg( ti.myOperator = _operator, lineStr &amp; ti.id &amp; " operator NOT '" &amp; _operator.code &amp; "'[ allShipReceivals ]" );
			self.assertTrueMsg( ti.CM_Container.getISOTypeGroupObject = _iSOTypeGroup, lineStr &amp; ti.id &amp; " ISO group NOT '" &amp; _iSOTypeGroup.code &amp; "'[ allShipReceivals ]" );
		endforeach;	
		foreach ti in _dataLine.allStopTis do
			self.assertTrueMsg( ti.myOperator = _operator, lineStr &amp; ti.id &amp; " operator NOT '" &amp; _operator.code &amp; "'[ allStopTis ]" );
			self.assertTrueMsg( ti.CM_Container.getISOTypeGroupObject = _iSOTypeGroup, lineStr &amp; ti.id &amp; " ISO group NOT '" &amp; _iSOTypeGroup.code &amp; "'[ allStopTis ]" );
		endforeach;
		foreach ti in _dataLine.allSurveyTis do
			self.assertTrueMsg( ti.myOperator = _operator, lineStr &amp; ti.id &amp; " operator NOT '" &amp; _operator.code &amp; "'[ allSurveyTis ]" );
			self.assertTrueMsg( ti.CM_Container.getISOTypeGroupObject = _iSOTypeGroup, lineStr &amp; ti.id &amp; " ISO group NOT '" &amp; _iSOTypeGroup.code &amp; "'[ allSurveyTis ]" );
		endforeach;
		foreach ti in _dataLine.allWashAreaTis do
			self.assertTrueMsg( ti.myOperator = _operator, lineStr &amp; ti.id &amp; " operator NOT '" &amp; _operator.code &amp; "'[ allWashAreaTis ]" );
			self.assertTrueMsg( ti.CM_Container.getISOTypeGroupObject = _iSOTypeGroup, lineStr &amp; ti.id &amp; " ISO group NOT '" &amp; _iSOTypeGroup.code &amp; "'[ allWashAreaTis ]" );
		endforeach;
		foreach ti in _dataLine.allWashTis do
			self.assertTrueMsg( ti.myOperator = _operator, lineStr &amp; ti.id &amp; " operator NOT '" &amp; _operator.code &amp; "'[ allWashTis ]" );
			self.assertTrueMsg( ti.CM_Container.getISOTypeGroupObject = _iSOTypeGroup, lineStr &amp; ti.id &amp; " ISO group NOT '" &amp; _iSOTypeGroup.code &amp; "'[ allWashTis ]" );
		endforeach;
		foreach relReq in _dataLine.allPackReqs do
			self.assertTrueMsg( relReq.myOperator = _operator, lineStr &amp; relReq.code &amp; " operator NOT '" &amp; _operator.code &amp; "'[ allPackReqs ]" );
			self.assertTrueMsg(relReq.getISOGroup = _iSOTypeGroup, lineStr &amp; relReq.code &amp; " ISO group NOT '" &amp; _iSOTypeGroup.code &amp; "'[ allPackReqs ]" );
		endforeach;
		foreach relReq in _dataLine.allPendReqs do
			self.assertTrueMsg( relReq.myOperator = _operator, lineStr &amp; relReq.code &amp; " operator NOT '" &amp; _operator.code &amp; "'[ allPendReqs ]" );
			self.assertTrueMsg(relReq.getISOGroup = _iSOTypeGroup, lineStr &amp; relReq.code &amp; " ISO group NOT '" &amp; _iSOTypeGroup.code &amp; "'[ allPendReqs ]" );
		endforeach;
		foreach relReq in _dataLine.allRailReqs do
			self.assertTrueMsg( relReq.myOperator = _operator, lineStr &amp; relReq.code &amp; " operator NOT '" &amp; _operator.code &amp; "'[ allRailReqs ]" );
			self.assertTrueMsg(relReq.getISOGroup = _iSOTypeGroup, lineStr &amp; relReq.code &amp; " ISO group NOT '" &amp; _iSOTypeGroup.code &amp; "'[ allRailReqs ]" );
		endforeach;
		foreach relReq in _dataLine.allRoadReqs do
			self.assertTrueMsg( relReq.myOperator = _operator, lineStr &amp; relReq.code &amp; " operator NOT '" &amp; _operator.code &amp; "'[ allRoadReqs ]" );
			self.assertTrueMsg(relReq.getISOGroup = _iSOTypeGroup, lineStr &amp; relReq.code &amp; " ISO group NOT '" &amp; _iSOTypeGroup.code &amp; "'[ allRoadReqs ]" );
		endforeach;
		foreach relReq in _dataLine.allShipReqs do
			self.assertTrueMsg( relReq.myOperator = _operator, lineStr &amp; relReq.code &amp; " operator NOT '" &amp; _operator.code &amp; "'[ allShipReqs ]" );
			self.assertTrueMsg(relReq.getISOGroup = _iSOTypeGroup, lineStr &amp; relReq.code &amp; " ISO group NOT '" &amp; _iSOTypeGroup.code &amp; "'[ allShipReqs ]" );
		endforeach;
		
		
	elseif thresh.processingPriority = 2 then
	
		lineStr := "OPS Line 2, ";
		
		self.assertTrueMsg( _dataLine.allAvailable.isEmpty, lineStr &amp; "allAvailable expected 0, got " &amp; _dataLine.allAvailable.size.String );	
		self.assertTrueMsg( _dataLine.allOnsiteTis.isEmpty, lineStr &amp; "allOnsiteTis expected 0, got " &amp; _dataLine.allOnsiteTis.size.String );
		self.assertTrueMsg( _dataLine.allPackReqs.isEmpty, lineStr &amp; "allPackReqs expected 0, got " &amp; _dataLine.allPackReqs.size.String );
		self.assertTrueMsg( _dataLine.allPendReqs.isEmpty, lineStr &amp; "allPendReqs expected 0, got " &amp; _dataLine.allPendReqs.size.String );
		self.assertTrueMsg( _dataLine.allPreTripAreaTis.isEmpty, lineStr &amp; "allPreTripAreaTis expected 0, got " &amp; _dataLine.allPreTripAreaTis.size.String );
		self.assertTrueMsg( _dataLine.allPreTripTis.isEmpty, lineStr &amp; "allPreTripTis expected 0, got " &amp; _dataLine.allPreTripTis.size.String );
		self.assertTrueMsg( _dataLine.allPtiRepairTis.isEmpty, lineStr &amp; "allPtiRepairTis expected 0, got " &amp; _dataLine.allPtiRepairTis.size.String );
		self.assertTrueMsg( _dataLine.allRailPreNotes.isEmpty, lineStr &amp; "allRailPreNotes expected 0, got " &amp; _dataLine.allRailPreNotes.size.String );
		self.assertTrueMsg( _dataLine.allRailReqs.isEmpty, lineStr &amp; "allRailReqs expected 0, got " &amp; _dataLine.allRailReqs.size.String );
		self.assertTrueMsg( _dataLine.allRepairAreaTis.isEmpty, lineStr &amp; "allRepairAreaTis expected 0, got " &amp; _dataLine.allRepairAreaTis.size.String );
		self.assertTrueMsg( _dataLine.allRepairTis.isEmpty, lineStr &amp; "allRepairTis expected 0, got " &amp; _dataLine.allRepairTis.size.String );
		self.assertTrueMsg( _dataLine.allRoadPreNotes.isEmpty, lineStr &amp; "allRoadPreNotes expected 0, got " &amp; _dataLine.allRoadPreNotes.size.String );
		self.assertTrueMsg( _dataLine.allRoadReqs.isEmpty, lineStr &amp; "allRoadReqs expected 0, got " &amp; _dataLine.allRoadReqs.size.String );
		self.assertTrueMsg( _dataLine.allShipReceivals.size = 3, lineStr &amp; "allShipReceivals expected 3, got " &amp; _dataLine.allShipReceivals.size.String );
		self.assertTrueMsg( _dataLine.allShipReqs.isEmpty, lineStr &amp; "allShipReqs expected 0, got " &amp; _dataLine.allShipReqs.size.String );
		self.assertTrueMsg( _dataLine.allStopTis.isEmpty, lineStr &amp; "allStopTis expected 0, got " &amp; _dataLine.allStopTis.size.String );
		self.assertTrueMsg( _dataLine.allSurveyTis.isEmpty, lineStr &amp; "allSurveyTis expected 0, got " &amp; _dataLine.allSurveyTis.size.String );
		self.assertTrueMsg( _dataLine.allWashAreaTis.isEmpty, lineStr &amp; "allWashAreaTis expected 0, got " &amp; _dataLine.allWashAreaTis.size.String );
		self.assertTrueMsg( _dataLine.allWashTis.isEmpty, lineStr &amp; "allWashTis expected 0, got " &amp; _dataLine.allWashTis.size.String );
		
	elseif thresh.processingPriority = 3 then	
		self.assertTrueMsg(false, "Threshold [3] produced a line in report agent for Operator = '" &amp; _operator.code &amp; "' and ISO Group = '" &amp; _iSOTypeGroup.code &amp; "', should not be included.");
	

	elseif thresh.processingPriority = 4 then
		self.assertTrueMsg(false, "'Inactive' threshold [4] produced a line in report agent!");
		
	elseif thresh.processingPriority = 5 then
		self.assertTrueMsg(false, "Threshold [5] produced a line in report agent for Operator = '" &amp; _operator.code &amp; "', should not be included.");
		
	endif;

	

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_dataLine" type="CM_MTPoolingEnquiryLine"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_iSOTypeGroup" type="CM_ISOTypeGroup"/>
    </JadeMethod>
    <JadeMethod name="checkReportDataLine" id="08c4682c-bd0a-473a-a77b-b90646551086">
        <source>checkReportDataLine( _dataLine : CM_MTPoolingEnquiryLine; _operator : CM_Operator ) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 June 2011	cnwndl1	Initial creation	Par 27731

*/

vars

	thresh : CM_MTThreshold;
	lineStr : String;
	ti : CM_TrackedItem;
	relReq : CM_BulkRelease;
	isoType : CM_ISOType;
	iSOTypeGroupFor4200 : CM_ISOTypeGroup;

begin

	thresh := _dataLine.myMTThreshold;
	
	if thresh.processingPriority = 1 then
	
		lineStr := "ALL Line 1, ";
	
		self.assertTrueMsg( _dataLine.allOnsiteTis.size = 12, lineStr &amp; "allOnsiteTis expected 12, got " &amp; _dataLine.allOnsiteTis.size.String );
		self.assertTrueMsg( _dataLine.allPreTripTis.size = 2, lineStr &amp; "allPreTripTis expected 2, got " &amp; _dataLine.allPreTripTis.size.String );
		self.assertTrueMsg( _dataLine.allPreTripAreaTis.size = 1, lineStr &amp; "allPreTripAreaTis expected 1, got " &amp; _dataLine.allPreTripAreaTis.size.String );
		self.assertTrueMsg( _dataLine.allWashTis.size = 2, lineStr &amp; "allWashTis expected 2, got " &amp; _dataLine.allWashTis.size.String );
		self.assertTrueMsg( _dataLine.allWashAreaTis.size = 1, lineStr &amp; "allWashAreaTis expected 1, got " &amp; _dataLine.allWashAreaTis.size.String );
		self.assertTrueMsg( _dataLine.allRepairTis.size = 2, lineStr &amp; "allRepairTis expected 2, got " &amp; _dataLine.allRepairTis.size.String );
		self.assertTrueMsg( _dataLine.allRepairAreaTis.size = 1, lineStr &amp; "allRepairAreaTis expected 1, got " &amp; _dataLine.allRepairAreaTis.size.String );
		self.assertTrueMsg( _dataLine.allPtiRepairTis.size = 2, lineStr &amp; "allPtiRepairTis expected 2, got " &amp; _dataLine.allPtiRepairTis.size.String );
		self.assertTrueMsg( _dataLine.allSurveyTis.size = 2, lineStr &amp; "allSurveyTis expected 2, got " &amp; _dataLine.allSurveyTis.size.String );
		self.assertTrueMsg( _dataLine.allStopTis.size = 1, lineStr &amp; "allStopTis expected 1, got " &amp; _dataLine.allStopTis.size.String );
		self.assertTrueMsg( _dataLine.allAvailable.size = 1, lineStr &amp; "allAvailable expected 1, got " &amp; _dataLine.allAvailable.size.String );
		self.assertTrueMsg( _dataLine.allRoadReqs.size = 1, lineStr &amp; "allRoadReqs expected 1, got " &amp; _dataLine.allRoadReqs.size.String );
		self.assertTrueMsg( _dataLine.allRailReqs.size = 1, lineStr &amp; "allRailReqs expected 1, got " &amp; _dataLine.allRailReqs.size.String );
		self.assertTrueMsg( _dataLine.allShipReqs.size = 1, lineStr &amp; "allShipReqs expected 1, got " &amp; _dataLine.allShipReqs.size.String );
		self.assertTrueMsg( _dataLine.allPackReqs.size = 1, lineStr &amp; "allPackReqs expected 1, got " &amp; _dataLine.allPackReqs.size.String );
		self.assertTrueMsg( _dataLine.allPendReqs.size = 1, lineStr &amp; "allPendReqs expected 1, got " &amp; _dataLine.allPendReqs.size.String );
		self.assertTrueMsg( _dataLine.allRoadPreNotes.size = 2, lineStr &amp; "allRoadPreNotes expected 2, got " &amp; _dataLine.allRoadPreNotes.size.String );
		self.assertTrueMsg( _dataLine.allRailPreNotes.size = 2, lineStr &amp; "allRailPreNotes expected 2, got " &amp; _dataLine.allRailPreNotes.size.String );
		self.assertTrueMsg( _dataLine.allShipReceivals.size = 2, lineStr &amp; "allShipReceivals expected 2, got " &amp; _dataLine.allShipReceivals.size.String );
		
	elseif thresh.processingPriority = 2 then
	
		lineStr := "ALL Line 2, ";
		
		self.assertTrueMsg( _dataLine.allAvailable.isEmpty, lineStr &amp; "allAvailable expected 0, got " &amp; _dataLine.allAvailable.size.String );	
		self.assertTrueMsg( _dataLine.allOnsiteTis.isEmpty, lineStr &amp; "allOnsiteTis expected 0, got " &amp; _dataLine.allOnsiteTis.size.String );
		self.assertTrueMsg( _dataLine.allPackReqs.isEmpty, lineStr &amp; "allPackReqs expected 0, got " &amp; _dataLine.allPackReqs.size.String );
		self.assertTrueMsg( _dataLine.allPendReqs.isEmpty, lineStr &amp; "allPendReqs expected 0, got " &amp; _dataLine.allPendReqs.size.String );
		self.assertTrueMsg( _dataLine.allPreTripAreaTis.isEmpty, lineStr &amp; "allPreTripAreaTis expected 0, got " &amp; _dataLine.allPreTripAreaTis.size.String );
		self.assertTrueMsg( _dataLine.allPreTripTis.isEmpty, lineStr &amp; "allPreTripTis expected 0, got " &amp; _dataLine.allPreTripTis.size.String );
		self.assertTrueMsg( _dataLine.allPtiRepairTis.isEmpty, lineStr &amp; "allPtiRepairTis expected 0, got " &amp; _dataLine.allPtiRepairTis.size.String );
		self.assertTrueMsg( _dataLine.allRailPreNotes.isEmpty, lineStr &amp; "allRailPreNotes expected 0, got " &amp; _dataLine.allRailPreNotes.size.String );
		self.assertTrueMsg( _dataLine.allRailReqs.isEmpty, lineStr &amp; "allRailReqs expected 0, got " &amp; _dataLine.allRailReqs.size.String );
		self.assertTrueMsg( _dataLine.allRepairAreaTis.isEmpty, lineStr &amp; "allRepairAreaTis expected 0, got " &amp; _dataLine.allRepairAreaTis.size.String );
		self.assertTrueMsg( _dataLine.allRepairTis.isEmpty, lineStr &amp; "allRepairTis expected 0, got " &amp; _dataLine.allRepairTis.size.String );
		self.assertTrueMsg( _dataLine.allRoadPreNotes.isEmpty, lineStr &amp; "allRoadPreNotes expected 0, got " &amp; _dataLine.allRoadPreNotes.size.String );
		self.assertTrueMsg( _dataLine.allRoadReqs.isEmpty, lineStr &amp; "allRoadReqs expected 0, got " &amp; _dataLine.allRoadReqs.size.String );
		self.assertTrueMsg( _dataLine.allShipReceivals.size = 3, lineStr &amp; "allShipReceivals expected 3, got " &amp; _dataLine.allShipReceivals.size.String );
		self.assertTrueMsg( _dataLine.allShipReqs.isEmpty, lineStr &amp; "allShipReqs expected 0, got " &amp; _dataLine.allShipReqs.size.String );
		self.assertTrueMsg( _dataLine.allStopTis.isEmpty, lineStr &amp; "allStopTis expected 0, got " &amp; _dataLine.allStopTis.size.String );
		self.assertTrueMsg( _dataLine.allSurveyTis.isEmpty, lineStr &amp; "allSurveyTis expected 0, got " &amp; _dataLine.allSurveyTis.size.String );
		self.assertTrueMsg( _dataLine.allWashAreaTis.isEmpty, lineStr &amp; "allWashAreaTis expected 0, got " &amp; _dataLine.allWashAreaTis.size.String );
		self.assertTrueMsg( _dataLine.allWashTis.isEmpty, lineStr &amp; "allWashTis expected 0, got " &amp; _dataLine.allWashTis.size.String );
		
	elseif thresh.processingPriority = 3 then
	
		lineStr := "ALL Line 3, ";
		isoType := app.myRoot.allISOTypes.getAtKey("4200");
		iSOTypeGroupFor4200 := isoType.myISOTypeGroup;
	
		self.assertTrueMsg( _dataLine.allOnsiteTis.size = 12, lineStr &amp; "allOnsiteTis expected 12, got " &amp; _dataLine.allOnsiteTis.size.String );
		self.assertTrueMsg( _dataLine.allPreTripTis.size = 2, lineStr &amp; "allPreTripTis expected 2, got " &amp; _dataLine.allPreTripTis.size.String );
		self.assertTrueMsg( _dataLine.allPreTripAreaTis.size = 1, lineStr &amp; "allPreTripAreaTis expected 1, got " &amp; _dataLine.allPreTripAreaTis.size.String );
		self.assertTrueMsg( _dataLine.allWashTis.size = 2, lineStr &amp; "allWashTis expected 2, got " &amp; _dataLine.allWashTis.size.String );
		self.assertTrueMsg( _dataLine.allWashAreaTis.size = 1, lineStr &amp; "allWashAreaTis expected 1, got " &amp; _dataLine.allWashAreaTis.size.String );
		self.assertTrueMsg( _dataLine.allRepairTis.size = 2, lineStr &amp; "allRepairTis expected 2, got " &amp; _dataLine.allRepairTis.size.String );
		self.assertTrueMsg( _dataLine.allRepairAreaTis.size = 1, lineStr &amp; "allRepairAreaTis expected 1, got " &amp; _dataLine.allRepairAreaTis.size.String );
		self.assertTrueMsg( _dataLine.allPtiRepairTis.size = 2, lineStr &amp; "allPtiRepairTis expected 2, got " &amp; _dataLine.allPtiRepairTis.size.String );
		self.assertTrueMsg( _dataLine.allSurveyTis.size = 2, lineStr &amp; "allSurveyTis expected 2, got " &amp; _dataLine.allSurveyTis.size.String );
		self.assertTrueMsg( _dataLine.allStopTis.size = 1, lineStr &amp; "allStopTis expected 1, got " &amp; _dataLine.allStopTis.size.String );
		self.assertTrueMsg( _dataLine.allAvailable.size = 1, lineStr &amp; "allAvailable expected 1, got " &amp; _dataLine.allAvailable.size.String );
		self.assertTrueMsg( _dataLine.allRoadReqs.size = 1, lineStr &amp; "allRoadReqs expected 1, got " &amp; _dataLine.allRoadReqs.size.String );
		self.assertTrueMsg( _dataLine.allRailReqs.size = 1, lineStr &amp; "allRailReqs expected 1, got " &amp; _dataLine.allRailReqs.size.String );
		self.assertTrueMsg( _dataLine.allShipReqs.size = 1, lineStr &amp; "allShipReqs expected 1, got " &amp; _dataLine.allShipReqs.size.String );
		self.assertTrueMsg( _dataLine.allPackReqs.size = 1, lineStr &amp; "allPackReqs expected 1, got " &amp; _dataLine.allPackReqs.size.String );
		self.assertTrueMsg( _dataLine.allPendReqs.size = 1, lineStr &amp; "allPendReqs expected 1, got " &amp; _dataLine.allPendReqs.size.String );
		self.assertTrueMsg( _dataLine.allRoadPreNotes.size = 2, lineStr &amp; "allRoadPreNotes expected 2, got " &amp; _dataLine.allRoadPreNotes.size.String );
		self.assertTrueMsg( _dataLine.allRailPreNotes.size = 2, lineStr &amp; "allRailPreNotes expected 2, got " &amp; _dataLine.allRailPreNotes.size.String );
		self.assertTrueMsg( _dataLine.allShipReceivals.isEmpty, lineStr &amp; "allShipReceivals expected 0, got " &amp; _dataLine.allShipReceivals.size.String );
		
		
		self.assertTrueMsg( _dataLine.allPreTripAreaTis.first.id = "THRS1110301", lineStr &amp; "allPreTripAreaTis should contain 'THRS1110301'" );
		self.assertTrueMsg( _dataLine.allWashAreaTis.first.id = "THRS1110303", lineStr &amp; "allWashAreaTis should contain 'THRS1110303'" );
		self.assertTrueMsg( _dataLine.allRepairAreaTis.first.id = "THRS1110305", lineStr &amp; "allRepairAreaTis should contain 'THRS1110305'" );
		
		
		foreach ti in _dataLine.allAvailable do
			self.assertTrueMsg( ti.myOperator = _operator, lineStr &amp; ti.id &amp; " operator NOT '" &amp; _operator.code &amp; "'[ allAvailable ]" );
			self.assertTrueMsg( ti.CM_Container.getISOTypeGroupObject = iSOTypeGroupFor4200, lineStr &amp; ti.id &amp; " ISO group NOT '" &amp; iSOTypeGroupFor4200.code &amp; "'[ allAvailable ]" );
		endforeach;
		foreach ti in _dataLine.allOnsiteTis do
			self.assertTrueMsg( ti.myOperator = _operator, lineStr &amp; ti.id &amp; " operator NOT '" &amp; _operator.code &amp; "'[ allOnsiteTis ]" );
			self.assertTrueMsg( ti.CM_Container.getISOTypeGroupObject = iSOTypeGroupFor4200, lineStr &amp; ti.id &amp; " ISO group NOT '" &amp; iSOTypeGroupFor4200.code &amp; "'[ allOnsiteTis ]" );
		endforeach;	
		foreach ti in _dataLine.allPreTripAreaTis do
			self.assertTrueMsg( ti.myOperator = _operator, lineStr &amp; ti.id &amp; " operator NOT '" &amp; _operator.code &amp; "'[ allPreTripAreaTis ]" );
			self.assertTrueMsg( ti.CM_Container.getISOTypeGroupObject = iSOTypeGroupFor4200, lineStr &amp; ti.id &amp; " ISO group NOT '" &amp; iSOTypeGroupFor4200.code &amp; "'[ allPreTripAreaTis ]" );
		endforeach;
		foreach ti in _dataLine.allPreTripTis do
			self.assertTrueMsg( ti.myOperator = _operator, lineStr &amp; ti.id &amp; " operator NOT '" &amp; _operator.code &amp; "'[ allPreTripTis ]" );
			self.assertTrueMsg( ti.CM_Container.getISOTypeGroupObject = iSOTypeGroupFor4200, lineStr &amp; ti.id &amp; " ISO group NOT '" &amp; iSOTypeGroupFor4200.code &amp; "'[ allPreTripTis ]" );
		endforeach;
		foreach ti in _dataLine.allPtiRepairTis do
			self.assertTrueMsg( ti.myOperator = _operator, lineStr &amp; ti.id &amp; " operator NOT '" &amp; _operator.code &amp; "'[ allPtiRepairTis ]" );
			self.assertTrueMsg( ti.CM_Container.getISOTypeGroupObject = iSOTypeGroupFor4200, lineStr &amp; ti.id &amp; " ISO group NOT '" &amp; iSOTypeGroupFor4200.code &amp; "'[ allPtiRepairTis ]" );
		endforeach;
		foreach ti in _dataLine.allRailPreNotes do
			self.assertTrueMsg( ti.myOperator = _operator, lineStr &amp; ti.id &amp; " operator NOT '" &amp; _operator.code &amp; "'[ allRailPreNotes ]" );
			self.assertTrueMsg( ti.CM_Container.getISOTypeGroupObject = iSOTypeGroupFor4200, lineStr &amp; ti.id &amp; " ISO group NOT '" &amp; iSOTypeGroupFor4200.code &amp; "'[ allRailPreNotes ]" );
		endforeach;		
		foreach ti in _dataLine.allRepairAreaTis do
			self.assertTrueMsg( ti.myOperator = _operator, lineStr &amp; ti.id &amp; " operator NOT '" &amp; _operator.code &amp; "'[ allRepairAreaTis ]" );
			self.assertTrueMsg( ti.CM_Container.getISOTypeGroupObject = iSOTypeGroupFor4200, lineStr &amp; ti.id &amp; " ISO group NOT '" &amp; iSOTypeGroupFor4200.code &amp; "'[ allRepairAreaTis ]" );
		endforeach;
		foreach ti in _dataLine.allRepairTis do
			self.assertTrueMsg( ti.myOperator = _operator, lineStr &amp; ti.id &amp; " operator NOT '" &amp; _operator.code &amp; "'[ allRepairTis ]" );
			self.assertTrueMsg( ti.CM_Container.getISOTypeGroupObject = iSOTypeGroupFor4200, lineStr &amp; ti.id &amp; " ISO group NOT '" &amp; iSOTypeGroupFor4200.code &amp; "'[ allRepairTis ]" );
		endforeach;
		foreach ti in _dataLine.allRoadPreNotes do
			self.assertTrueMsg( ti.myOperator = _operator, lineStr &amp; ti.id &amp; " operator NOT '" &amp; _operator.code &amp; "'[ allRoadPreNotes ]" );
			self.assertTrueMsg( ti.CM_Container.getISOTypeGroupObject = iSOTypeGroupFor4200, lineStr &amp; ti.id &amp; " ISO group NOT '" &amp; iSOTypeGroupFor4200.code &amp; "'[ allRoadPreNotes ]" );
		endforeach;		
		foreach ti in _dataLine.allShipReceivals do
			self.assertTrueMsg( ti.myOperator = _operator, lineStr &amp; ti.id &amp; " operator NOT '" &amp; _operator.code &amp; "'[ allShipReceivals ]" );
			self.assertTrueMsg( ti.CM_Container.getISOTypeGroupObject = iSOTypeGroupFor4200, lineStr &amp; ti.id &amp; " ISO group NOT '" &amp; iSOTypeGroupFor4200.code &amp; "'[ allShipReceivals ]" );
		endforeach;	
		foreach ti in _dataLine.allStopTis do
			self.assertTrueMsg( ti.myOperator = _operator, lineStr &amp; ti.id &amp; " operator NOT '" &amp; _operator.code &amp; "'[ allStopTis ]" );
			self.assertTrueMsg( ti.CM_Container.getISOTypeGroupObject = iSOTypeGroupFor4200, lineStr &amp; ti.id &amp; " ISO group NOT '" &amp; iSOTypeGroupFor4200.code &amp; "'[ allStopTis ]" );
		endforeach;
		foreach ti in _dataLine.allSurveyTis do
			self.assertTrueMsg( ti.myOperator = _operator, lineStr &amp; ti.id &amp; " operator NOT '" &amp; _operator.code &amp; "'[ allSurveyTis ]" );
			self.assertTrueMsg( ti.CM_Container.getISOTypeGroupObject = iSOTypeGroupFor4200, lineStr &amp; ti.id &amp; " ISO group NOT '" &amp; iSOTypeGroupFor4200.code &amp; "'[ allSurveyTis ]" );
		endforeach;
		foreach ti in _dataLine.allWashAreaTis do
			self.assertTrueMsg( ti.myOperator = _operator, lineStr &amp; ti.id &amp; " operator NOT '" &amp; _operator.code &amp; "'[ allWashAreaTis ]" );
			self.assertTrueMsg( ti.CM_Container.getISOTypeGroupObject = iSOTypeGroupFor4200, lineStr &amp; ti.id &amp; " ISO group NOT '" &amp; iSOTypeGroupFor4200.code &amp; "'[ allWashAreaTis ]" );
		endforeach;
		foreach ti in _dataLine.allWashTis do
			self.assertTrueMsg( ti.myOperator = _operator, lineStr &amp; ti.id &amp; " operator NOT '" &amp; _operator.code &amp; "'[ allWashTis ]" );
			self.assertTrueMsg( ti.CM_Container.getISOTypeGroupObject = iSOTypeGroupFor4200, lineStr &amp; ti.id &amp; " ISO group NOT '" &amp; iSOTypeGroupFor4200.code &amp; "'[ allWashTis ]" );
		endforeach;
		foreach relReq in _dataLine.allPackReqs do
			self.assertTrueMsg( relReq.myOperator = _operator, lineStr &amp; relReq.code &amp; " operator NOT '" &amp; _operator.code &amp; "'[ allPackReqs ]" );
			self.assertTrueMsg(relReq.getISOGroup = iSOTypeGroupFor4200, lineStr &amp; relReq.code &amp; " ISO group NOT '" &amp; iSOTypeGroupFor4200.code &amp; "'[ allPackReqs ]" );
		endforeach;
		foreach relReq in _dataLine.allPendReqs do
			self.assertTrueMsg( relReq.myOperator = _operator, lineStr &amp; relReq.code &amp; " operator NOT '" &amp; _operator.code &amp; "'[ allPendReqs ]" );
			self.assertTrueMsg(relReq.getISOGroup = iSOTypeGroupFor4200, lineStr &amp; relReq.code &amp; " ISO group NOT '" &amp; iSOTypeGroupFor4200.code &amp; "'[ allPendReqs ]" );
		endforeach;
		foreach relReq in _dataLine.allRailReqs do
			self.assertTrueMsg( relReq.myOperator = _operator, lineStr &amp; relReq.code &amp; " operator NOT '" &amp; _operator.code &amp; "'[ allRailReqs ]" );
			self.assertTrueMsg(relReq.getISOGroup = iSOTypeGroupFor4200, lineStr &amp; relReq.code &amp; " ISO group NOT '" &amp; iSOTypeGroupFor4200.code &amp; "'[ allRailReqs ]" );
		endforeach;
		foreach relReq in _dataLine.allRoadReqs do
			self.assertTrueMsg( relReq.myOperator = _operator, lineStr &amp; relReq.code &amp; " operator NOT '" &amp; _operator.code &amp; "'[ allRoadReqs ]" );
			self.assertTrueMsg(relReq.getISOGroup = iSOTypeGroupFor4200, lineStr &amp; relReq.code &amp; " ISO group NOT '" &amp; iSOTypeGroupFor4200.code &amp; "'[ allRoadReqs ]" );
		endforeach;
		foreach relReq in _dataLine.allShipReqs do
			self.assertTrueMsg( relReq.myOperator = _operator, lineStr &amp; relReq.code &amp; " operator NOT '" &amp; _operator.code &amp; "'[ allShipReqs ]" );
			self.assertTrueMsg(relReq.getISOGroup = iSOTypeGroupFor4200, lineStr &amp; relReq.code &amp; " ISO group NOT '" &amp; iSOTypeGroupFor4200.code &amp; "'[ allShipReqs ]" );
		endforeach;
		
	elseif thresh.processingPriority = 4 then
		self.assertTrueMsg(false, "'Inactive' threshold [4] produced a line in report agent!");
		
	elseif thresh.processingPriority = 5 then
		// do nothing, this is a line for what ever else happens to be in teh terminal
		
	endif;

	

epilog

end;</source>
