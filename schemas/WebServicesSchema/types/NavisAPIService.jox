    <JadeMethod name="validateFormUser" id="209f4e3e-ad6e-461b-ac22-75cf22aef064">
        <source>validateFormUser(_user : CM_User output) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Sep 2020	jlgrr1	Initial creation TFS 49227

*/

constants
	USERNAME = "username";
	PASSWORD = "password";
	
vars
	username, password : String;
	
begin
	username := self.formData.getValue(USERNAME);
	password := self.formData.getValue(PASSWORD);
	app.writeLog(method.qualifiedName &amp; Tab &amp; "validating user '" &amp; username &amp; "'", LogINFO);
	
	// First Validate the User
	if username = null then
		app.writeLog("username is null", LogERROR);		//navra1 - 24th Aug 2022 - TFS 50365
		return false;
	endif;

	_user := app.myRoot.allUsers[username.toUpper];
	if _user = null then
		app.writeLog("_user is null", LogERROR);	//navra1 - 24th Aug 2022 - TFS 50365
		return false;
	endif;
//	if _user.isSuspended then
	if _user.isSuspendedOrIsDisabled() then	 //23 Nov 2020	NDL TFS 50378
		app.writeLog("user is isSuspendedOrIsDisabled", LogERROR);		//navra1 - 24th Aug 2022 - TFS 50365
		return false;
	endif;
	
	// Then validate the password
	if not _user.isValidPassword(password) then
		app.writeLog("user password is invalid", LogERROR);		//navra1 - 24th Aug 2022 - TFS 50365
		return false;
	endif;
	
	return true;
end;</source>
        <Parameter name="_user" type="CM_User" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
