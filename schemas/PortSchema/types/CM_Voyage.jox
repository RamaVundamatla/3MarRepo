    <JadeMethod name="buildCMIFDeckItemsForActual" id="eedc04ea-69d4-4d29-bf6a-3edb4ec7b485">
        <source>buildCMIFDeckItemsForActual(_cmifDeckItemReportSet : CMIF_DeckItemPointReportSet input);
//----------------------------------------------------------------------
// Created by 	cnwsh3 - 19 October 2011
//
// Implemented version: JMT 7.9.2
// Date  		User  		Change
//----------------------------------------------------------------------
vars
	layout 		: CM_DeckItemLayout;
	ti 			: CM_TrackedItem;
	lc 			: CM_LocationsController;
	deckItem	: CM_DeckItem;
	cmifDeckItemReporter : CMIF_DeckItemPointReporter;

begin
	foreach ti in self.allOnshipTIsByCargoTypeId do 
		lc := ti.getPrimaryLocation(REAL_MODE);
		if lc &lt;&gt; null then
			deckItem := lc.getDefn();
			if deckItem &lt;&gt; null and 
			   deckItem.myLayout &lt;&gt; null then
			   //	_cmifDeckItemReportSet.add(deckItem.myLayout);
			endif;
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_cmifDeckItemReportSet" type="CMIF_DeckItemPointReportSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="buildSearcherDisplayString" id="46ce0aac-dd04-489d-8105-ded23e3cdd15">
        <source>buildSearcherDisplayString(_searcher : CMIF_HMSVoyageSearcher input; outputStr : String output) : Boolean;
// -------------------------------------------
// Created 12 May 2004 by cnwdvb1
// -------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// 23 Apr 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement

vars

	agentForMove		: CM_ShippingAgent;
	agentsUsed,
	pilotsUsed,
	drafts,
	tempStr1,
	theVesselType,
	theShippingLine			: String;
	movement			: HMS_VoyageMovement;
	voyageData			: HMS_VoyageData;
	pilot : HMS_Pilot;
	movementPilotDetails : HMS_MovementPilotDetails; // TFS 44438
begin

	// Check 'Agent' Criteria
	voyageData := self.myHMSVoyageData;
	
	foreach movement in voyageData.allVoyageMovements do
		_searcher.exportsArray.add(movement);
		if movement.isAgentDefault and movement.myShippingAgent &lt;&gt; null then
			agentsUsed	:= agentsUsed &amp; movement.myShippingAgent.description[1:20] &amp; "; ";
		else
			agentsUsed	:= agentsUsed &amp; "N/A; ";
		endif;
		drafts := drafts &amp; movement.draftMax.String &amp; "m; ";	//4.1.1 Draft enhancement
		
		// Check to see if selected pilot is used for any of the voyages movements
		if not movement.allMovementPilotDetails.isEmpty then //allPilots.isEmpty then	//31 Oct 2018	NDL	TFS 41662 // TFS 44438
			foreach movementPilotDetails in movement.allMovementPilotDetails do //pilot in movement.allPilots do // TFS 44438
				pilotsUsed	:= pilotsUsed &amp; movementPilotDetails.myPilot/*pilot*/.description[1:20] &amp; "; "; // TFS 44438
			endforeach;
		elseif movement.getUnConvertedMyPilotRef &lt;&gt; null then
			pilotsUsed	:= pilotsUsed &amp; movement.getUnConvertedMyPilotRef.description[1:20] &amp; "; ";
		else
			pilotsUsed:=pilotsUsed &amp; "N/A; ";
		endif;
	
	endforeach;
	
		
	if agentsUsed.length &gt;1 then
		// Trim last comma and space
	 	agentsUsed	:= agentsUsed[1:(agentsUsed.length - 2)];
	 endif;

	if drafts.length &gt; 1 then
		// Trim last comma and space
		drafts:=drafts[1:(drafts.length - 2)];
 	endif;					

	if pilotsUsed.length &gt; 1 then
		// Trim last comma and space
	 	pilotsUsed	:= pilotsUsed[1:(pilotsUsed.length - 2)];
	endif;
	

	// Add voyage details if list if criteria matched
	// Add Date
	if voyageData &lt;&gt; null
	and voyageData.myVesselType &lt;&gt; null then
		theVesselType := voyageData.myVesselType.description;
	endif;
	if self.myShippingLine = null then
		theShippingLine := "N/A";
	else
		theShippingLine := self.myShippingLine.description;
	endif;
	tempStr1 	:= self.arrivedDT.Date.format('dd MMM yy') &amp; Tab &amp;
	 			voyageData.vesselName &amp; Tab &amp;
	 			theVesselType &amp; Tab &amp; 
				theShippingLine &amp; Tab &amp;
	 			pilotsUsed &amp; Tab &amp;
	 			agentsUsed &amp; Tab &amp;
	 			drafts &amp; Tab;
	 			
	outputStr := tempStr1;
	return true;
end;</source>
        <Parameter name="_searcher" type="CMIF_HMSVoyageSearcher" usage="input"/>
        <Parameter name="outputStr" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canAccessConsigneeConsignor" id="6dbd6a34-5486-4253-adc2-d9f714dddc3c">
        <source>canAccessConsigneeConsignor(_user : CM_User) : Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 05/12/2018	jlgdap1		Initial creation TFS 42219 PEL1 Consignee Access Issues
// 18/02/2019	jlgmd1		Disabled logging to prevent cn_log spam. (if this is to be re-enabled, change to app.writeLog instead)
//
vars
	ti : CM_TrackedItem;
	tis : CM_TISet;
	wo : CM_WorkOrder;
	
begin
	create tis transient;
	self.getAllTrackedItems(tis);
	foreach ti in tis discreteLock do
		if ti.canAccessConsigneeConsignor(_user) then
			return true;
		else
		endif;
	endforeach;
	
	foreach wo in self.allWorkOrders discreteLock do
		if wo.canAccessConsigneeConsignor(_user) then
			return true;
		else
		endif;
	endforeach;
	
	return false;
	
epilog
	delete tis;
end;</source>
        <Parameter name="_user" type="CM_User"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canDataAccessGroupAccessSelf" id="155bbcda-9fa5-48c7-af5a-1aca0651cfb1">
        <source>canDataAccessGroupAccessSelf(dac : CM_DataAccessController; operatorSet : CM_OperatorSet input) : Boolean;
// ---------------------------------------------------------------------------
// Created:      26 May 2003 by cnwsgp1
//
// Parameters:	DataAccessController and OperatorSet are passed in for
//				performance reasons so that if this method is called
//				multiple times these objects don't have to be created
//				each time.
// ---------------------------------------------------------------------------
vars
	voyOp 		: CM_VoyageOperator;
	operator 	: CM_Operator;
begin
	if dac = null then
		// no Operator Data Access Group so view all
		return true;
	endif;
	
	if self.allVoyageIOperators.size &lt; 1 then
		return true;
	endif;
	
	operatorSet.clear;
	
	// does user have access to any of the operators
	foreach voyOp in self.allVoyageIOperators do
		operator := voyOp.myOperator;
		if operatorSet.includes(operator) then
			// already checked this operator
			continue;
		endif;
		operatorSet.add(operator);
	
		if dac.canAccess(operator) then
			return true;
		endif;
	endforeach;
	
	return false;
end;</source>
        <Parameter name="dac" type="CM_DataAccessController"/>
        <Parameter name="operatorSet" type="CM_OperatorSet" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canDoBulkCopyOrVoyChange" id="eb288be2-fd7d-4df9-be0a-c8e8bfb3f45e">
        <source>canDoBulkCopyOrVoyChange() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 July 2025	naviv1	Initial creation - MTN-35310 : CUX - Changing Vessel not possible

*/

vars
	transColl : CM_TITransactionByTypeDateDict;
	txn       : CM_TITransaction;
begin
	transColl := self.allTITransactionsByTypeDT;
	
	if not self.allOnshipTIsByIdCargoType.isEmpty or not self.allJobSheetsInOrder.isEmpty then  
		return false;
	endif;

	foreach txn in transColl do
		if not txn.type.isOneOf(TRANS_TYPE_LOADBOOKED,TRANS_TYPE_LOADCANCELLED) then
			return false;
		endif;
	endforeach;

	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
