    <JadeMethod name="getChildNiceName" id="684bfa73-67b8-4b1f-9129-b89f053d0a90">
        <source>getChildNiceName(_obj : CM_Object): String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin
	if _obj = null then
		return null ;
	endif;
	return _obj.CM_VesselTank.code;

epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
