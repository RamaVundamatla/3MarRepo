//
//----------------------------------------------------------------------

vars
	folder : FileFolder;
begin
	create folder transient;
	
	folder.fileName := _str;
	
	return folder;
epilog

end;</source>
        <Parameter name="_str" type="String"/>
        <ReturnType type="FileFolder"/>
    </JadeMethod>
    <JadeMethod name="isDumpFile" id="b93960c6-9730-4ebb-bfe5-9a70ca6c2454">
        <source>isDumpFile(_file : File): Boolean;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 18 January 2007
//
//----------------------------------------------------------------------

vars
	int : Integer;
begin
	if _file = null then
		app.writeStatement( self.class.name &amp; '&gt;&gt;' &amp; method.name &amp; ' No file passed to this method.');
	else
		int := 1;
		if _file.fileName.pos('_dump_20', int) &gt; 0 then
			return true;
		endif;
	endif;
	
	return false;
epilog

end;</source>
        <Parameter name="_file" type="File"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="moveFile" id="811e5062-6dab-4a90-8b6b-b097b27deba7">
        <source>moveFile(_sourceFile: File io; _dirName: String; _keepOriginal : Boolean): Boolean;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 22 January 2007
//
//----------------------------------------------------------------------

vars
	destFilePath : String;
	fileName	: String;
	fileLength	: Integer;
	str			: String;
	header 		: CM_FileDataStorageHeader;
begin
	
	create header transient;

	if not _sourceFile.tryOpen then
		return false;
	endif;

	destFilePath := self.myFileFolderDestination.fileName &amp; "\";

	header := app.writeFileToBinary(_sourceFile.fileName, false, true, null,true);

	fileLength := _sourceFile.fileLength();

	str := app.writeBinaryToFile(header, destFilePath);

	/*if not _keepOriginal then
		_sourceFile.close;
		_sourceFile.purge;
	endif;
	*/
	return true;
	_sourceFile.purge;
epilog
	if _sourceFile &lt;&gt; null then
		_sourceFile.close;
	endif;

	delete header;
end;</source>
        <Parameter name="_sourceFile" type="File" usage="io"/>
        <Parameter name="_dirName" type="String"/>
        <Parameter name="_keepOriginal" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="processFiles" id="b39e165c-2864-451e-b234-f681db039d85">
        <updating/>
        <source>processFiles(_fileArray : FileNodeArray io ; _keepOriginals : Boolean) updating;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 18 January 2007
//
//----------------------------------------------------------------------

vars
	fileNode : FileNode;
	fileArray : FileNodeArray;
	file : File;
	errorNumber,
	folderPath,
	fileFolder : String;
begin
	if _fileArray.isEmpty then
		return;
	endif;
	
	fileArray := _fileArray;
	
	foreach fileNode in fileArray where fileNode.isKindOf(File) do
		file := fileNode.File;
		//Are we a dump file
		if self.isDumpFile(file.File) then
			file.kind := File.Kind_Unknown_Text;	// 3/3/16 cnwmp6 PAR 36286 unicode version
			//if not self.isFileKeep then
			//	self.allFilesToDelete.add(file);
			//endif;
			errorNumber := self.getErrorNumberFromFile(file);
			
			folderPath := self.myParentFileFolder.fileName &amp; '\' &amp; errorNumber;
			//Now check if a folder of that error number exists
			if not self.checkFolderExists(folderPath) then
				self.createNewFolder(folderPath);
			endif;
			
			//Move File to folder path
			self.myFileFolderDestination := self.getFolderForFile(folderPath);

			self.moveFile(file, self.filePath, _keepOriginals);
					
		endif;
	endforeach;
		
epilog

end;</source>
        <Parameter name="_fileArray" type="FileNodeArray" usage="io"/>
        <Parameter name="_keepOriginals" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setFilePath" id="8b4173e8-464e-4080-aee8-756078531199">
