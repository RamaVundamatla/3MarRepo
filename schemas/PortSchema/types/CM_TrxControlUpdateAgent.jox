    <JadeMethod name="trxUpdateEventTransaction" id="850d1621-f68d-48b6-a7ea-74398c46f78d">
        <updating/>
        <source>trxUpdateEventTransaction(	_pxyEventTransaction : CM_EventTransaction;
							_passport 			 : CM_Passport input) updating;
/*

Date		Who		Reason
10 December 2014	cnwer1	Initial creation PAR
08/06/2020 			cnwma1  ChangeRequest 49400: ASPA - Invoice Enhancements for Barges
*/

vars
	controller 		: CMIF_InvoiceLineReeval;
	realEventTrans  : CM_EventTransaction;
	currentDebtor,
	oldDebtor       : CM_Debtor;
	debtorChanged   : Boolean;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	// Start the transaction
	
	//03/06/2020 cnwma1 TFS #49400
	realEventTrans := _pxyEventTransaction.pxyGetRealObject();
	if realEventTrans &lt;&gt; null then
		oldDebtor	  := realEventTrans.myDebtor;
		currentDebtor := _pxyEventTransaction.myDebtor;
		if oldDebtor &lt;&gt; currentDebtor then
			debtorChanged := true;
		endif;
	endif;
	
	beginTransaction;

	// Perform the operation
	app.myUtilityUA.utlUpdateEventTransaction(_pxyEventTransaction,  _passport);
	
	//03/06/2020 cnwma1 TFS #49400
	if app.myPassport.noErrors then
		if  debtorChanged then
			if realEventTrans.allInvoiceLines.isNotEmpty then
				create controller transient;
				realEventTrans.allInvoiceLines.copy(controller.allInvoiceLines);
				app.myUtilityUA.utlUpdateInvoiceLineReeval( controller, _passport);
			endif;
		endif;
	endif;
	
epilog
	delete controller;	 
	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_pxyEventTransaction" type="CM_EventTransaction"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
