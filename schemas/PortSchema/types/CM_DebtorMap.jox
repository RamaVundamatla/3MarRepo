    <JadeMethod name="copyFrom" id="ec3a29c9-5fa8-4132-9f2d-e2d9a08a4d44">
        <updating/>
        <source>copyFrom(_map : CM_DebtorMap; _debtor : CM_DebtorNode; _debtorType : CM_DebtorType; _parent : CM_ServiceBroker) updating;
// 32311 set up self from the parameter plus the new debtor, copy all of the parameter map children under self.
vars
	newQuantityMap	: CM_QuantityMap;
begin
	if _parent &lt;&gt; null then
		self.myServiceBroker := _parent;
	else
		self.myServiceBroker := _map.myServiceBroker;
	endif;

	self.myDebtorNode := _debtor;
	self.myDebtorType :=_debtorType;

	create newQuantityMap persistent;
	newQuantityMap.copyFrom(_map.myChildQuantityMap, self);

end;
</source>
        <Parameter name="_map" type="CM_DebtorMap"/>
        <Parameter name="_debtor" type="CM_DebtorNode"/>
        <Parameter name="_debtorType" type="CM_DebtorType"/>
        <Parameter name="_parent" type="CM_ServiceBroker"/>
    </JadeMethod>
