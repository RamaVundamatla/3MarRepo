    <JadeMethod name="doBtnPropSaveClick" id="4c454130-c22e-4044-a543-e9ed9602e4cb">
        <updating/>
        <source>doBtnPropSaveClick() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 March 2018	jlgndl1	Initial creation	TFS 37550

*/

vars

	roundingType : Integer;
	
	ls : Boolean;
	theReturn : Integer;
	realCurrencyRate : CM_CurrencyRate;
	pxyCurrencyRate : CM_CurrencyRate;	
	pxyCurrencyType : CM_CurrencyType;
	realCurrencyType : CM_CurrencyType;
	tmpEffectiveDT : TimeStamp;
	tmpEffectiveDTSystem : TimeStamp;
	
begin
	if self.updateMode = self.UpdateMode_New then
		if self.grpCurrType.visible then
			create pxyCurrencyType transient;
		elseif self.grpCurrRate.visible then
			create pxyCurrencyRate transient;
		endif;			
	else
		app.cmsBeginLoad(ls);
		if CM_CurrencyType.hasInstance(self.myCurrentListObject) then
			pxyCurrencyType := app.createUpdateProxy(self.myCurrentListObject).CM_CurrencyType;		
		elseif CM_CurrencyRate.hasInstance(self.myCurrentListObject) then
			pxyCurrencyRate := app.createUpdateProxy(self.myCurrentListObject).CM_CurrencyRate;
		endif;
		app.cmsEndLoad(ls);
	endif;
	
	if self.optUp.value then
		roundingType := RoundingType_Up;
	elseif self.optDown.value then
		roundingType := RoundingType_Down;
	endif;
	
	if pxyCurrencyType &lt;&gt; null then
		pxyCurrencyType.setProxy(	self.txtCurrTypeCode.text,	//_code : String;
									self.txtCurrSymbol.text,	//_currencySymbol : String;
									self.txtCurrTypeDescr.text,	//_description : String;
									self.txtRounding.text.asDecimalJMT,	//_roundingInterval : Decimal;
									roundingType.Integer	//_roundingType : Integer
									);
									
	elseif pxyCurrencyRate &lt;&gt; null then
		tmpEffectiveDT.setDate(self.effectiveDate.getDate());
		tmpEffectiveDT.setTime(self.effectiveTime.getTime());
	//	tmpEffectiveDTSystem := self.localToSystemTime(tmpEffectiveDT); 
		tmpEffectiveDTSystem := tmpEffectiveDT;
		pxyCurrencyRate.setProxy(tmpEffectiveDTSystem, self.myCurrentCurrencyType, self.txtTaxRate.text.asDecimalJMT());

	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'No proxy object found');
		return;
	endif;
	
	while true do
		if self.updateMode = self.UpdateMode_New then
			if pxyCurrencyType &lt;&gt; null then		
				app.myTrxCA.trxCreateCurrencyType(pxyCurrencyType, realCurrencyType, app.myPassport);
			elseif pxyCurrencyRate &lt;&gt; null then
				app.myTrxCA.trxCreateCurrencyRate(pxyCurrencyRate, realCurrencyRate, app.myPassport);			
			else
				app.raiseUnexpectedProgramError(class.name, method.name, 'No proxy object found');
				return;			
			endif;
		elseif self.updateMode = self.UpdateMode_Update then
			if pxyCurrencyType &lt;&gt; null then		
				app.myTrxUA.trxUpdateCurrencyType(pxyCurrencyType, app.myPassport);
			elseif pxyCurrencyRate &lt;&gt; null then
				app.myTrxUA.trxUpdateCurrencyRate(pxyCurrencyRate, app.myPassport);
			else
				app.raiseUnexpectedProgramError(class.name, method.name, 'No proxy object found');
				return;			
			endif;			
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid mode');		
			return;
		endif;
		
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			break;
		else
			theReturn := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	
			return;
		endif;
		
		break;
	endwhile;
	
	self.doRefresh();
	
	self.setEnableObjects(true);
	
epilog
	app.cmsEndLoad(ls);		
	delete pxyCurrencyType;
	delete pxyCurrencyRate;
end;</source>
    </JadeMethod>
    <JadeMethod name="doDelete" id="d850411b-9fd6-4527-980c-5667a7fe0bcf">
        <updating/>
        <source>doDelete() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 March 2018	jlgndl1	Initial creation	TFS 37550

*/

vars
	theReturn : Integer;
begin
	if self.myCurrentListObject = null or self.myCurrentListObject.isKindOf(CM_Bank) then
		app.msgBox('Please select and item from the list to delete.', app.getErrorString(SelectItem), MsgBox_OK_Only+MsgBox_Information_Icon);
		return;
	endif;
	
	while true do
	 	app.myTrxDA.trxDeleteCMObject(self.myCurrentListObject, app.myPassport);
		 
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(INV_Company_Delete), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;
	
	self.myCurrentListObject := null;
	
	self.doRefresh();
	
	self.setEnableObjects(true);

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doLstDataClick" id="e0c8c724-0102-45e1-b0e9-1790bcdb7b03">
        <updating/>
        <source>doLstDataClick(listbox: ListBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 March 2018	jlgndl1	Initial creation	TFS 37550

*/

vars

begin

	inheritMethod(listbox);
	
	self.myCurrentCurrencyType := null;
	self.myCurrentCurrencyRate := null;	
	
	if CM_CurrencyType.hasInstance(self.myCurrentListObject) then
		self.myCurrentCurrencyType := self.myCurrentListObject.CM_CurrencyType;
	elseif CM_CurrencyRate.hasInstance(self.myCurrentListObject) then
		self.myCurrentCurrencyRate := self.myCurrentListObject.CM_CurrencyRate;
		self.myCurrentCurrencyType := self.myCurrentCurrencyRate.myCurrencyType;		
	endif;

epilog

end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doLstDataContextMenu" id="fd566708-8f0c-4f03-85d5-22fcd605df80">
        <updating/>
        <source>doLstDataContextMenu(listbox: ListBox input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 March 2018	jlgndl1	Initial creation	TFS 37550

*/

vars

begin
	self.mnuAddCurrency.visible := true;
	if listbox.listIndex &lt; 1 then
		return true;
	elseif listbox.listIndex = 1 then
		self.mnuAddCurrRate.visible := false;
		self.mnuDelete.visible := false;
		self.mnuUpdate.visible := false;
		self.mnuAudits.visible := false;		
	elseif listbox.listIndex &gt; 1 then
		self.mnuAddCurrRate.visible := true;
		self.mnuDelete.visible := true;
		self.mnuUpdate.visible := true;	
		self.mnuAudits.visible := true;
	endif;
	
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnDelete.enabled:= false;
		self.btnNew.enabled:= false;
		self.btnEdit.enabled:= false;
		self.mnuAddCurrency.visible := false;
		self.mnuAddCurrRate.visible := false;
		self.mnuDelete.visible := false;
		self.mnuUpdate.visible := false;
	endif;
	
	return self.showContextMenu(self.mnuListContext, listbox, conwin, mouse, x, y);

epilog

end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
