*/

vars

begin

	if self.doSave = true then
		inheritMethod;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="3252356e-e8be-49cc-b9a4-5da6c62a21ba">
        <updating/>
        <source>doSave() : Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 February 2010	cnwrd1	Initial creation

*/


vars
	interTermVehicleJob : CM_InterTermVehicleJob;
	result              : Boolean;
begin
	result := self.doValidate;
	if result = false then
		return false;
	endif;
	
	interTermVehicleJob := self.myCurrentInterTerminalMove.myInterTermVehicleJob;
	
	if interTermVehicleJob = null then
		app.msgBox( 'Dev Error - no InterTermVehicleJob for ' &amp; self.myCurrentInterTerminalMove.String, app.getErrorString(Error), MsgBox_OK_Only);
		return false;
	endif;

	self.myInterTermVehicleJob := interTermVehicleJob;

	result := self.doCreateUnload();

	return result;
epilog

end;

</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doValidate" id="4c88bd93-f454-4717-9c38-5499ec841a4e">
        <updating/>
        <source>doValidate() : Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 February 2010	cnwrd1	Initial creation

*/

vars
	tmpLC : CM_LocationsController;
begin

	if not self.findLocationToMoveTo( tmpLC ) then
		return false;
	endif;
	
	self.setupMyTargetTerminal;
	if self.myTargetTerminal = null then
		app.msgBox( app.getErrorString(Select_Terminal), app.getErrorString(Error), MsgBox_OK_Only);
		self.cmbTargetTerm.setFocus();
		return false;
	endif;


	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findLocationToMoveTo" id="5584aa6a-77ca-422c-94f1-7f034a39528c">
        <source>findLocationToMoveTo(tmpFoundLC: CM_LocationsController output): Boolean protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 February 2010	cnwrd1	Initial creation

*/


vars
	dataString : String;
	term : CM_Terminal;
	tmpFoundHeight : Integer;
	errMess : String;
	
begin

	// Find the location we are moving to.
	dataString := self.txtLocation.text.toUpper;

	if dataString = null then
		errMess := app.getErrorString( No_Location_entered );
	else
		term := self.cmbTargetTerm.listObject.CM_Terminal;
		term.findLocationFromString(dataString, true, tmpFoundLC, tmpFoundHeight);
		
		if tmpFoundLC = null then
			errMess := app.getErrorString1(Location_NotFound, "'" &amp; dataString &amp; "'");
		else
			if not tmpFoundLC.isYardLocation then
				errMess := app.getErrorString(Location_must_yard);
			elseif tmpFoundLC.isVehicle then
				errMess := app.getErrorString(Location_Not_vehicle);
			endif;
		endif;
		
	endif;
	
	if errMess &lt;&gt; null then
		app.msgBox ( errMess, app.getErrorString(Error), MsgBox_OK_Only );
		self.txtLocation.setFocus();
		return false;
	endif; 
	
	return true;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="tmpFoundLC" type="CM_LocationsController" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="load" id="fe49b5be-b9e9-47a7-8da4-65304c88ce66">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 February 2010	cnwrd1	Initial creation

*/

constants
	ContainerTop  : Integer = 20;
	ContainerLeft : Integer = 2;
vars

begin
	inheritMethod;

	self.frmContainer.left    := ContainerLeft;
	self.frmContainer.top     := ContainerTop;
	self.clientWidth          := (self.frmContainer.width + (ContainerLeft * 2)).Integer;
	self.clientHeight         := (self.frmContainer.height + (ContainerTop * 2) + self.btnOk.height).Integer;
	self.centreWindow;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="302407ce-d2e2-4364-bad6-543d0cf8c052">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 February 2010	cnwrd1	Initial creation

*/

vars
	vvr : CM_VehicleVisitRecord;
begin
	inheritMethod();
	self.myTerminal := app.myPassport.myTerminal;
	self.doLoadTargetTerminal();
	
	if self.myCurrentInterTerminalMove &lt;&gt; null then // shouldnt be null
		if self.myCurrentInterTerminalMove.myTargetVehicleVisit &lt;&gt; null then
			txtDriver.text := self.myCurrentInterTerminalMove.myTargetVehicleVisit.driverCode;
		endif;

		txtVehicle.text := self.myCurrentInterTerminalMove.mySourceVehicle.regNumber;
		txtState.text   := self.myCurrentInterTerminalMove.mySourceVehicle.state;
		vvr := self.myCurrentInterTerminalMove.mySourceVehicleVisit;
		
		self.txtCargoID.text := self.myCurrentInterTerminalMove.mySourceTI.id;
		
		if vvr &lt;&gt; null then
		self.txtDriver.text := vvr.driversName; //drivercode?
		endif;
		
		if self.myUnloadTerminal &lt;&gt; null then
			self.cmbTargetTerm.listObject := self.myUnloadTerminal;
			if self.vAction_mode = Return_Mode then
				self.cmbTargetTerm.enabled := false;
			else
				self.cmbTargetTerm.enabled := true;
			endif;
		endif;
		
	endif;
	
	self.txtVehicle.readOnly := true;
	self.txtState.readOnly := true;
	self.txtDriver.readOnly := true;
	self.txtCargoID.readOnly := true;
	self.txtLocation.readOnly := false;

	if self.vAction_mode = Unload_Mode then
		self.caption := app.getErrorString(Unload_truck);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupMyTargetTerminal" id="3d4936c0-7502-456d-9a29-568fe058e90c">
        <updating/>
        <source>setupMyTargetTerminal()updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 February 2010	cnwrd1	Initial creation

*/

vars

begin
	if self.cmbTargetTerm.listIndex &gt; 0 then
		self.myTargetTerminal := self.cmbTargetTerm.listObject.CM_Terminal;
	else
		self.myTargetTerminal := null;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="3cb643b5-28e9-4066-acc1-0e2e1e73298d">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0014288, locale);
	lblCargoID.translateCaption(Xlat_0014289, locale);
	lblDriver.translateCaption(Xlat_0014290, locale);
	lblState.translateCaption(Xlat_0014291, locale);
	lblTargetLoc.translateCaption(Xlat_0014292, locale);
	lblTerm.translateCaption(Xlat_0014293, locale);
	lblVehicle.translateCaption(Xlat_0014294, locale);
end;</source>
    </JadeMethod>
</GUIClass>
