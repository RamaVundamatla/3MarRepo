    <JadeMethod name="translateForm" id="d181060f-f109-410f-ab87-f85a36a517fa">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 26 June 2024 17:20:00.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0013584, locale);
 //	btnClearFilter.translateBubbleHelp(Xlat_0024517, locale);
 //	btnClearFilter.translateCaption(Xlat_0024452, locale);
	btnCloseSearchTV.translateCaption(Xlat_0005404, locale);
	btnDeleteTV.translateCaption(Xlat_0005405, locale);
	btnEditTV.translateBubbleHelp(Xlat_0008367, locale);
	btnEditTV.translateCaption(Xlat_0005406, locale);
	btnEditWc.translateBubbleHelp(Xlat_0012248, locale);
	btnEditWc.translateCaption(Xlat_0012249, locale);
	btnExportCSVTV.translateCaption(Xlat_0005407, locale);
	btnNewTV.translateBubbleHelp(Xlat_0008368, locale);
	btnNewTV.translateCaption(Xlat_0008369, locale);
	btnNewWc.translateBubbleHelp(Xlat_0012250, locale);
	btnNewWc.translateCaption(Xlat_0012251, locale);
	btnNextTV.translateCaption(Xlat_0005409, locale);
	btnPrintTV.translateBubbleHelp(Xlat_0008370, locale);
	btnPrintTV.translateCaption(Xlat_0005410, locale);
	btnResetSearchTV.translateCaption(Xlat_0005411, locale);
	btnSearchTV.translateCaption(Xlat_0005412, locale);
	btnSelectAllTV.translateBubbleHelp(Xlat_0005413, locale);
	btnSelectAllTV.translateCaption(Xlat_0005414, locale);
	btnShowSearchTV.translateCaption(Xlat_0005415, locale);
	frmPrint.translateCaption(Xlat_0005416, locale);
 //	lblFilterBox.translateCaption(Xlat_0024445, locale);
	lblPrint.translateCaption(Xlat_0005417, locale);
	mnuColumnOrganiser.translateCaption(Xlat_0008371, locale);
	mnuConfig.translateCaption(Xlat_0017022, locale);
	mnuHideThumbnailEmtpy.translateCaption(Xlat_0019602, locale);
	mnuTblVCloneDataTbl.translateCaption(Xlat_0008372, locale);
	mnuTblVCloneTop.translateCaption(Xlat_0008373, locale);
