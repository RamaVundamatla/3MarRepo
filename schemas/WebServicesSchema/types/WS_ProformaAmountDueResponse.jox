    <JadeMethod name="setValuesFromController" id="2675ecd1-3188-40f2-a877-638fd0c5e8e4">
        <updating/>
        <source>setValuesFromController(_ctrl : CMIF_CashInvoiceProformaCtrl) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/05/2024	navkc1 CR63397  Task 63398: Jade - New REST API getProformaAmountForVoyage

*/

vars
	pxyCashReceipt 	: CM_CashReceipt;
	now				: TimeStamp;
	terminal		: CM_Terminal;
	
begin
	pxyCashReceipt := _ctrl.myPxyCashReceipt;
	if pxyCashReceipt = null then
		return;
	endif;
	
	self.cargoIdCSV := _ctrl.getAllTisID();
	self.taxValue := _ctrl.getTotalTaxValue();
	//self.amountValue := _ctrl.cargoTotalCharges;
	//self.amountValue := pxyCashReceipt.totalCargoCharges + pxyCashReceipt.taxValue1 + pxyCashReceipt.taxValue2 + pxyCashReceipt.taxValue3; //04/10/2024	navkc1	JIRA 33018
	self.amountValue := pxyCashReceipt.cashValue; // 25/07/2025	navkc1	JIRA MTN-35344
	self.totalValue := _ctrl.cashRequiredToClearCharges;
	self.debtorId := pxyCashReceipt.getDebtorAccountCode();
	self.agentId := _ctrl.myDebtorAgentId;
	self.businessUnitId := _ctrl.getBusinessUnitId();
	self.receiptNumber := pxyCashReceipt.sequenceNum;
	self.type := pxyCashReceipt.getTypeString(null);
	self.description := pxyCashReceipt.getDescription();
	self.invoiceType := pxyCashReceipt.getInvoiceTypeDesc();
	self.paymentType := app.paymentTypeEnumToString(pxyCashReceipt.getPaymentType());
	self.vesselName := pxyCashReceipt.getVesselName();
	self.voyageId := pxyCashReceipt.getVoyageCode();
	//self.voyageArrival := pxyCashReceipt.getVoyageArrivalDateLocalTZ().asStringJSON();
	self.voyageArrival := pxyCashReceipt.getVoyageArrivalDateLocalTZ().asStringForWebInterface(); //23/08/2024	navkc1 Bug 65781
	//self.voyageDeparture := pxyCashReceipt.getVoyageSailingDateLocalTZ().asStringJSON();
	self.voyageDeparture := pxyCashReceipt.getVoyageSailingDateLocalTZ().asStringForWebInterface(); //23/08/2024	navkc1 Bug 65781
	//self.dateTime := pxyCashReceipt.createdTime.asStringJSON();
	self.dateTime := pxyCashReceipt.createdTime.asStringForWebInterface(); //23/08/2024	navkc1 Bug 65781
	
	//8/07/2024	navkc1 CR 64835 Task 64850
	terminal := _ctrl.myTerminal;
	if terminal = null then
		terminal := pxyCashReceipt.myTerminal;
	endif;
	
	//8/07/2024	navkc1 CR 64835 Task 64850 - set currency code
	if terminal &lt;&gt; null then
		//self.currencyCode := terminal.getConfig(CurrencyCodeForAPI).asStringJSON();
		self.currencyCode := terminal.getConfig(CurrencyCodeForAPI).asString(); //23/08/2024	navkc1 Bug 65781
	endif;
epilog

end;</source>
        <Parameter name="_ctrl" type="CMIF_CashInvoiceProformaCtrl"/>
    </JadeMethod>
</Class>
