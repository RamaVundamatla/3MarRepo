    <JadeMethod name="setShipLineGroupDebtor" id="87d48791-a3c2-47d4-be49-4cc3627ea108">
        <source>setShipLineGroupDebtor();
// ---------------------------------------------------------------------------
// Created:		22 February 2006  By Andrew Bishop cnwab1
//
// Purpose:		 // 2006FEB AKB PASHA DEMO. Reset the operators on the voyages
//
// ---------------------------------------------------------------------------

vars
	aLGD : CM_LineGroupDebtor;
	aSPG : CM_ShipPortGroup;
	aSL : CM_ShippingLine;
begin
	
	foreach aLGD in self.lineGroups do
		aSPG := aLGD.shipPortGroup;
		
		aSL := aSPG.shippingLine;
		
		if aSL &lt;&gt; null then
			aSL.setForVoyageOperators();
		endif;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="suspend" id="c111ee45-d3f7-44aa-9632-f9177c7d45df">
        <updating/>
        <source>suspend() updating;

vars
	subDebtorNode:   CM_DebtorNode;
begin
	foreach subDebtorNode in self.allChildDebtorNodes do
		subDebtorNode.suspend;
	endforeach;

	self.isSuspended := true;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="af24145e-bc44-4c2c-b411-71acfba25e01">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 08/12/2014 cnwdb2	PAR 35364
// 08/08/2018  cnwma1	ChangeRequest 40092: PEL1 - Adding Changes to Debtors
vars

begin
	if self.name = null then
		app.raiseCMException2(ERR_INVALID_VALUE,"Debtor Name","Debtor name must be entered.",null,null);
	
	endif;
	if app.myRoot.myRootCompany.debtorNodes.includesKey(self.name) then
	//	app.raiseCMException3(ERR_DUPLICATE_KEY,"Debtor",self.name,null,null,null);
		app.raiseCMException1(Already_exists_debtor,self.name,null,null); //cnwdb2 PAR 35364
  
//		Full_Replacement_Message
	endif;
	if self.isKindOf(CM_Debtor) then
		if self.CM_Debtor.code &lt;&gt; null then
			if app.myRoot.myRootCompany.allDebtorsByCode[self.CM_Debtor.code] &lt;&gt; null then
				app.raiseCMException1(Already_exists_debtor,self.CM_Debtor.code,null,null);
			endif;
		endif;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="02946a5a-9f11-41df-b6f1-cb3fed78e39e">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aDM : CM_DebtorMap;
	str : String;
begin
	if self.lineGroups.size &gt; 0 then
		app.raiseCMException(ERR_LGDEBTORS_EXIST, null, null);
	endif;

	if self.allChildDebtorNodes.size &gt; 0 then
		app.raiseCMException(ERR_DEBTORGROUP_SUBITEMS, null, null);
	endif;

	// 781 testing - Invoice mapping left with null references
	if not self.allDebtorMaps.isEmpty then
	
		foreach aDM in self.allDebtorMaps do
			if str = null then
				str := aDM.getDescription(true);
			else
				str := str &amp; ", " &amp; aDM.getDescription(true);
			endif;
		endforeach;
		app.raiseCMException2(DEBTOR_NO_DELETE_HASMAPPINGS, self.name, str, null, null);
	
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="a77156de-1d7f-4c80-862d-fe5de94eb463">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 10/08/2018	jlgdap1		TFS 40092 PEL1 Adding Changes for Debtors
vars
	realMe : SelfType;
	aDM : CM_DebtorMap;
	str : String;
	existingName, newname : String;				// TFS 40092
	pos,crlfPos : Integer;						// TFS 40092
	found : Boolean;							// TFS 40092
	debtor : SelfType;							// TFS 40092
begin
	realMe := self.pxyGetRealObject();
	
	if realMe &lt;&gt; null then
		// trying to suspend the debtor, check its transmap mappings...
		if not realMe.isSuspended and self.isSuspended then
			if not realMe.allDebtorMaps.isEmpty then
			
				foreach aDM in realMe.allDebtorMaps do
					if str = null then
						str := aDM.getDescription(true);
					else
						str := str &amp; ", " &amp; aDM.getDescription(true);
					endif;
				endforeach;
				app.raiseCMException2(Canno_suspe_debto_debto_trans_, self.name, str, null, null);
			
			endif;
		endif;
		
		// TFS 40092 strip CrLfs from debtor name and check name is not a duplicate
		existingName := realMe.name;
		newname := self.name;
		if existingName[existingName.length-1:2] = CrLf then
			//new name is different (less characters)
			if existingName.length &gt; newname.length then
				//set existingName to existingName minus CrLf
				pos := existingName.length;
				crlfPos := pos;
				//remove multiple ending CrLfs.... yes, it could happen
				while crlfPos &lt;&gt; 0 do
					crlfPos := existingName.pos(CrLf,pos-2);
					if crlfPos &lt;&gt; pos then
						if crlfPos &lt;&gt; 0 then
							pos := crlfPos;
						endif;
					else
						crlfPos := 0;
					endif;
				endwhile;
				existingName := existingName[1:pos-1];
			endif;
		endif;
		debtor := app.myRoot.myRootCompany.debtorNodes[newname];
		if debtor &lt;&gt; null and debtor &lt;&gt; realMe then
			app.raiseCMException1(Already_exists_debtor,self.name,null,null);
		endif;
		// TFS 40092 end
	endif;
end;</source>
    </JadeMethod>
</Class>
