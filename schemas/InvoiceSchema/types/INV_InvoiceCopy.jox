    <JadeMethod name="addToolbarControls" id="27f6300b-1667-4c7a-b480-d1dc161304ba">
        <updating/>
        <source>addToolbarControls() updating, protected;
/*

Purpose:			Adds toolbar controls to the forms toolbar

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
30 September 2022	navpw1	Initial creation TFS: 54565 (54384)

*/

vars
	toolbar	: CMUI_Toolbar;
	
begin
	inheritMethod();
	
	toolbar := self.frmToolbar;
	
	//toolbar.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton(self.btnSearch, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.positionToolbarControls();
	toolbar.visible := true;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="btnSearch_click" id="25e8a9f6-cebf-49df-a0b1-5b1d4dba1751">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnSearch_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Apr 2023 navtnr20	TFS CR 55303	Task 55531: UI - Invoice NEW UI Changes Invoice Copy

*/

vars
	tiArray: CM_TIArray;
	form   : CMUI_CargoSearchFormModal;
begin
	form := app.loadForm(CMUI_CargoSearchFormModal, 
							CMUI_Assistant, 
							false, 
							false,
							true, 
							self.myTerminal,
							null).CMUI_CargoSearchFormModal;	

	if form = null then
		return;
	endif;
	
	form.setColumnsAndControlWidth(3, 175);
	form.setParentForm(self);
	form.centreWindow();
	form.show;
epilog
	delete tiArray;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
