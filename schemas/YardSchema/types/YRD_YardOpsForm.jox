    <JadeMethod name="updateAddJob" id="57393250-fe7e-404b-853d-0912e8f3cb08">
        <updating/>
        <source>updateAddJob(_wle : CM_WorkListEntry; _mode : Integer) updating;
// -----------------------------------------------------------------------------
// Created:		22 July 2009 by consw1
//
// Purpose:		Use WLE notifications to refresh jobs view also
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	job : CM_Job;
	rowIdx : Integer;

begin
	if _wle = null then
		return;
	endif;
	
	if _mode &lt; Mode_Add or _mode &gt; Mode_Update then
		return;
	endif;

	job := _wle.job;	

	if job = null then
		return;
	endif;
	
	if _mode = self.Mode_Update and self.tblJobs.findObjectInRow(job, rowIdx) then
		if self.filterJob(job) and self.includeJob(job) then
			self.tblJobs.accessCell(rowIdx, 1).text := self.displayRowForDataTable(job, self.tblJobs);
		else
			self.tblJobs.removeItemObject(job);
			if job.String = self.myCurrentJob.String then
				self.tblJobsChange(null);
			endif;		
		endif;
		return;
	endif;
	
	if self.filterJob(job) and self.includeJob(job) then
		self.tblJobs.addItemObject( job, self.displayRowForDataTable(job, self.tblJobs) );
	endif;
	
end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="userNotify" id="0b135604-0c42-4e8d-b7d9-d890a5e05e28">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 October 2010	cnwrd1	Initial creation

*/

vars
	anObject : Object;
	theJob : CM_Job;
	aRequest : CM_Request;
	invalidWLE : Boolean;
begin
	
	on Exception do app.handleDeletedObject(exception, anObject, invalidWLE); 

	
	anObject := theObject;

	inheritMethod(eventType, theObject, eventTag,userInfo );
	
	//cnwrd1 par 24971 5.10.2010 - need to refresht he job info if we get wle notes
	if ( self.optViewJob.value and anObject.isKindOf( CM_WorkListEntry) )	then
		//may have to update the job view if we have it.
		theJob := anObject.CM_WorkListEntry.job;	
				
		if invalidWLE then 
			return;
		endif;
		
		aRequest := anObject.CM_WorkListEntry.myRequest; //cnwrd1 22.11.2010
		
		theJob := aRequest.myJob;
		
		if theJob &lt;&gt; null and theJob.CM_Job.getMyTerminal() &lt;&gt; self.myTerminal then //cnwrd1 22.11.2010 - getting notes for other terminals WLE's and displaying them is bad.
			return;
		endif;
		
		if not invalidWLE then
			self.tblDataSysNotifyUpdate(eventType, theJob, eventTag);
		endif;
	endif;

	
epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</GUIClass>
