    <JadeMethod name="initFields" id="dc164ee3-9702-4951-a57b-a7f6930c1e3c">
        <updating/>
        <source>initFields(_id : Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 February 2018	jlghl1	Initial creation

*/

vars

begin
	self.id := _id;
	if _id = ContainerSingleVolt then
		self.description	:= ContainerSingleVoltStr;
	endif;
	
	if _id = ContainerDualVolt then
		self.description	:= ContainerDualVoltStr;
	endif;
	
	if _id = ContainerVoltNull then
		self.description	:= ContainerVoltNullStr;
	endif;
	
	
epilog

end;</source>
        <Parameter name="_id" type="Integer"/>
