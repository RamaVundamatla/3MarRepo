    <JadeMethod name="reloadFromSavedCriteria" id="7d1edf65-e5cf-4990-a564-858c928939ba">
        <updating/>
        <source>reloadFromSavedCriteria() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 June 2024	navra1	Initial creation for //navra1 - TFS 60149/Task 64397 - 10th June 2024

*/

vars
	idx : Integer;
begin	
	self.txtCargoId.text := self.searchCargoId;
	
	self.chkRegex.value := self.searchCargoIdRegex;						//navra1 - TFS 60149/Task 64397 - 1 - 13th June 2024
	
	self.chkPagination.value := self.paginationEnabled;						//navra1 - TFS 60149/Task 64732 - 25th June 2024
	
	if self.searchFromDT &lt;&gt; null then
		self.mskDateFrom.setDate(self.searchFromDT.dateTime.date());
		self.mskTimeFrom.setTime(self.searchFromDT.dateTime.time());
	endif;
	
	if self.searchToDT &lt;&gt; null then
		self.mskDateTo.setDate(self.searchToDT.dateTime.date());
		self.mskTimeTo.setTime(self.searchToDT.dateTime.time());
	endif;
	
	if self.savedCargoTypeIndex &gt; 0 and self.savedCargoTypeIndex &lt; self.cmbCargoType.listCount() then
		self.cmbCargoType.listIndex := self.savedCargoTypeIndex;
	else
		self.cmbCargoType.listIndex := 1;
	endif;
	
	if self.cmbCargoType.listObject &lt;&gt; null and self.cmbCargoType.listObject.isKindOf(CM_CargoType) then
		self.searchCargoTypeId := self.cmbCargoType.listObject.CM_CargoType.description;
	endif;
	
	if self.savedTerminalIndex &gt; 0 and self.savedTerminalIndex &lt; self.cmbTerminal.listCount() then
		self.cmbTerminal.listIndex := self.savedTerminalIndex;
	else
		self.cmbTerminal.listIndex := 1;
	endif;
	
	if self.cmbTerminal.listObject &lt;&gt; null and self.cmbTerminal.listObject.isKindOf(CM_Terminal) then
		self.searchTerminalCode := self.cmbTerminal.listObject.CM_Terminal.code;
	endif;
	
	if self.savedRequestTypeIndex &gt;0 and self.savedRequestTypeIndex &lt; self.cmbRequestType.listCount() then
		self.cmbRequestType.listIndex := self.savedRequestTypeIndex;
	else
		self.cmbRequestType.listIndex := 1;
	endif;
	
	self.searchRequestType := self.cmbRequestType.text;
	
	if self.searchRequestType = "&lt;&lt;ALL FUTURE ACTORS&gt;&gt;" then
		self.searchRequestType := "";
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="resize" id="37dd901e-138d-45d4-83f3-727eba201f54">
        <controlMethod name="Form::resize"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>resize() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 June 2024	navra1	Initial creation for //navra1 - TFS 60149/Task 64397 - 10th June 2024

*/

vars
	width  : Real;
	height : Real;
	startLabelLeft : Real;
	startLabelTop : Real;
	
begin
	width 	:= self.width;
	height	:= self.height;
	
	startLabelLeft := self.width/8+50-50;
	startLabelTop := 10;
	
	self.lblRequestType.left := startLabelLeft;
	self.lblRequestType.top :=  startLabelTop;
	self.cmbRequestType.left := startLabelLeft+100;
	self.cmbRequestType.top := startLabelTop;
	
	self.lblDateFrom.left := startLabelLeft-55;
	self.lblDateFrom.top := startLabelTop+30;	
	self.mskDateFrom.left := startLabelLeft-55+153;
	self.mskDateFrom.top := startLabelTop+30;	
	self.mskTimeFrom.left := startLabelLeft-55+233;
	self.mskTimeFrom.top := startLabelTop+30;
	
	self.lblDateTo.left := startLabelLeft-55;
	self.lblDateTo.top := startLabelTop+30+30;	
	self.mskDateTo.left := startLabelLeft-55+153;
	self.mskDateTo.top := startLabelTop+30+30;	
	self.mskTimeTo.left := startLabelLeft-55+233;
	self.mskTimeTo.top := startLabelTop+30+30;
	
	
	self.lblTerminal.left := startLabelLeft+300;
	self.lblTerminal.top :=  startLabelTop;
	self.cmbTerminal.left := startLabelLeft+380;
	self.cmbTerminal.top := startLabelTop;
	
	self.lblCargoType.left := startLabelLeft+300;
	self.lblCargoType.top :=  startLabelTop+30;
	self.cmbCargoType.left := startLabelLeft+380;
	self.cmbCargoType.top := startLabelTop+30;
	
	self.lblCargoId.left := startLabelLeft+300;
	self.lblCargoId.top :=  startLabelTop+30+30;
	self.txtCargoId.left := startLabelLeft+380;
	self.txtCargoId.top := startLabelTop+30+30;
	
	self.chkRegex.left := startLabelLeft+300+250;						//navra1 - TFS 60149/Task 64397 - 1 - 13th June 2024
	self.chkRegex.top := startLabelTop+30+30+2;							//navra1 - TFS 60149/Task 64397 - 1 - 13th June 2024
	
	if self.tableUsingDisplayCollection then
		self.filterTable.top := startLabelTop+30+30+30;	
		self.filterTable.left := 10;
	
		self.chkPagination.top := startLabelTop+30+30+30+13;					//navra1 - TFS 60149/Task 64732 - 25th June 2024
		self.chkPagination.left := 10;									//navra1 - TFS 60149/Task 64732 - 25th June 2024
	else
		self.filterTable.top := startLabelTop+30+30+30;	
		self.filterTable.left := 10;
	
		self.chkPagination.top := startLabelTop+30+30+30+13;					//navra1 - TFS 60149/Task 64732 - 25th June 2024
		self.chkPagination.left := 250;									//navra1 - TFS 60149/Task 64732 - 25th June 2024
	endif;
	
	self.btnRefresh.top := startLabelTop+10;
	self.btnRefresh.left := startLabelLeft+650;						//navra1 - TFS 60149/Task 64397 - 1 - 13th June 2024
	
	self.btnClearTable.top := startLabelTop+45;
	self.btnClearTable.left := startLabelLeft+650;					//navra1 - TFS 60149/Task 64397 - 1 - 13th June 2024
		
	self.tblRequests.left := 10;
	self.tblRequests.top := self.lblCargoId.top + 35+30 +10;
	self.tblRequests.height := self.txtCargoId.top +height -250-10;
	self.tblRequests.width := width - 40;
	
	self.lblCount.left := self.tblRequests.left;
	self.lblCount.top := self.tblRequests.top + self.tblRequests.height;	
	
	if self.offlineFutureActors = null then								//navra1 - TFS 60149/Task 64732 - 25th June 2024
		create self.offlineFutureActors transient;						//navra1 - TFS 60149/Task 64732 - 25th June 2024
	endif;																//navra1 - TFS 60149/Task 64732 - 25th June 2024
	
	if self.tableUsingDisplayCollection then
		self.lblCount.caption := (self.offlineFutureActors.size()).String  &amp; ' table entries(' &amp; (self.tblRequests.rows - 1).String  &amp; ' displayed)';	
	else
		self.lblCount.caption := (self.offlineFutureActors.size()).String  &amp; ' table entries';
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="rowPreprocess" id="9333f1d7-9bdd-4439-a63f-964b0a2a5713">
        <updating/>
        <source>rowPreprocess(_dataTable: CM_DataTable; _obj: Object) : Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 June 2024	navra1	Initial creation for //navra1 - TFS 60149/Task 64732 - 25th June 2024

*/

vars
	offlineActor : CM_OfflineFutureActor;
	displayStr: String;
	invalidActor : Boolean;
	localId : String;
begin

	if not _obj.isKindOf(CM_OfflineFutureActor) then
		return false;
	endif;
	
	offlineActor:=_obj.CM_OfflineFutureActor;
		
	//criteria filters
	if self.searchRequestType &lt;&gt; null then
		if offlineActor.getRequestType() &lt;&gt; self.searchRequestType then
			return false;
		endif;
	endif;
	
	if self.searchTerminalCode &lt;&gt; null then
		if offlineActor.getTerminalCode() &lt;&gt; self.searchTerminalCode then
			return false;
		endif;
	endif;
	
	if self.searchCargoId &lt;&gt; null then
		if self.searchCargoIdRegex = false then														//navra1 - TFS 60149/Task 64397 - 1 - 13th June 2024
			localId := offlineActor.getCargoId(); // ### JIRA 33015 04OCT2024 NAVAB1
			if offlineActor.getCargoId().pos(self.searchCargoId,1) &lt;= 0 then // ### JIRA 33015 04OCT2024 NAVAB1
				return false;
			endif;
		else																						//navra1 - TFS 60149/Task 64397 - 1 - 13th June 2024
			if not JadeRegex@isMatch(offlineActor.getCargoId(),  self.searchCargoId, true) then		//navra1 - TFS 60149/Task 64397 - 1 - 13th June 2024
				return false;																			//navra1 - TFS 60149/Task 64397 - 1 - 13th June 2024
			endif;																					//navra1 - TFS 60149/Task 64397 - 1 - 13th June 2024
		endif;																						//navra1 - TFS 60149/Task 64397 - 1 - 13th June 2024
	endif;
	
	if self.searchCargoTypeId &lt;&gt; null then
		if offlineActor.getCargoTypeId() &lt;&gt; self.searchCargoTypeId then
			return false;
		endif;
	endif;
	
	if self.searchCargoTypeId &lt;&gt; null then
		if offlineActor.getCargoTypeId() &lt;&gt; self.searchCargoTypeId then
			return false;
		endif;
	endif;
	
	if self.searchFromDT &lt;&gt; null and self.searchFromDT.dateTime.isValid() then
		if offlineActor.actionTimeStamp.cnEcIsLessThan(self.searchFromDT.dateTime) then
			return false;
		endif;
	endif;
	
	if self.searchToDT &lt;&gt; null and self.searchToDT.dateTime.isValid() then
		if offlineActor.actionTimeStamp.cnEcIsGreaterThan(self.searchToDT.dateTime) then
			return false;
		endif;
	endif;		
	//criteria filters	
	
	if invalidActor then
		invalidActor:=false;
		return false;			
	endif;	
	
	return true;

epilog

end;</source>
        <Parameter name="_dataTable" type="CM_DataTable"/>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="selectRequest" id="9fc4b18c-0183-4c9c-80ec-c2454b84cef3">
        <updating/>
        <source>selectRequest(_row : Integer; _isDoubleClick : Boolean) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 June 2024	navra1	Initial creation for //navra1 - TFS 60149/Task 64397 - 10th June 2024

*/
vars

	row 	: JadeTableRow;
	obj		: Object;
begin	
	if not app.myCurrentUserCan(self.myTerminal, PmAdmBGPFutActorMaint) then
		return;
	endif;

	row := self.tblRequests.accessRow(_row);
	if row = null then
		return;
	endif;
	
	obj := row.itemObject;
	
	if obj &lt;&gt; null then		 
		if obj.isKindOf(CM_OfflineFutureActor) then		
			if app.isAllowedToInspect() then
				if _isDoubleClick then
					obj.inspectModal();
				endif;
			endif;
			return;
		endif;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_isDoubleClick" type="Boolean"/>
    </JadeMethod>
