begin

	on SystemException do self.handleException(exception, canContinue);
	
	canContinue 	:= true;	
	batchrq 		:=	self.xmlStruct.findStructure(XML_BATCHRQ).CnEcXmlGroupInstance;
	foreach tibatch in batchrq.allFields do
		_rejectHdr.getAttributes(tibatch.tagAttribute, class, type);
		batchHdr		:= tibatch.findStructure(XML_BATCHHDR).tagData; 
		
		if type &lt;&gt; CM_RemoteDataObject.Type_Reject then
			canContinue := false;
			return canContinue;
		endif;
		
		remoteDetail	:= self.parseBatchHdr(batchHdr, _rejectHdr, class, type);
		tidtls		:= tibatch.findStructure(XML_TIDTLS).CnEcXmlGroupInstance;	
		_rejectHdr.getAttributes(tidtls.tagAttribute, class, type);
		
		if type &lt;&gt; CM_RemoteDataObject.Type_Reject then
			canContinue := false;
			return canContinue;
		endif;
				
		foreach ti in tidtls.allFields do
			tiString := ti.tagData;
			self.parseTiToExtraDetail(tiString, remoteDetail, class, type);
		endforeach;
	endforeach;
epilog

	return canContinue;
end;</source>
        <Parameter name="_rejectHdr" type="CM_RemoteRejectHdr"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createReticketDetail" id="55fe9bc8-ab5e-4f85-87a5-76a734269def">
        <updating/>
        <source>createReticketDetail(_reticketHdr: CM_RemoteReticketHdr input): Boolean updating;


vars

	tiDtls				,
	tibatch				: CnEcXmlGroupInstance;
	ti					,
	tiBatchHdr			: CnEcXmlStructureInstance;
	canContinue			: Boolean;
	class,
	type,
	batchHdr,
	tiString,
	original,
	new					: String;
	reticket			: CM_RemoteReticketDtl;
	array				: StringArray;
	areaLocation		: String;
	 

begin

	on SystemException do self.handleException(exception, canContinue);

	canContinue 	:= true;	
	tibatch 		:=	self.xmlStruct.findStructure(XML_TIBATCH).CnEcXmlGroupInstance;
	_reticketHdr.getAttributes(tibatch.tagAttribute, class, type);
	if type &lt;&gt; CM_RemoteDataObject.Type_Reticket then
		canContinue := false;
		return canContinue;
	endif;
	
	tiBatchHdr 		:= tibatch.findStructure(XML_BATCHHDR).CnEcXmlStructureInstance;
	areaLocation	:= tiBatchHdr.tagData;
	tiDtls			:= tibatch.findStructure(XML_TIDTLS).CnEcXmlGroupInstance;
	create array transient;
	foreach ti in tiDtls.allFields do
		array.add(ti.tagData);
	endforeach;
	_reticketHdr.setProxyForReticket(areaLocation);
	if array.size &gt; 0 then
		create reticket transient;
		reticket.setProxyForReticket(_reticketHdr, array, class);
	endif;
	
epilog

	delete array;
	return canContinue;
end;</source>
        <Parameter name="_reticketHdr" type="CM_RemoteReticketHdr" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createReticketDetailNew" id="fa239397-bc45-4943-9dad-55696944228f">
        <updating/>
        <source>createReticketDetailNew(_reticketHdr: CM_RemoteReticketHdrNew input): Boolean updating;

// cnwdvb1 12 June 2003 

vars
	tiDtls				: CnEcXmlStructureInstance;
	batchrq				: CnEcXmlGroupInstance;
	ti					: CnEcXmlStructureInstance;
	tiBatchHdr			: CnEcXmlStructureInstance;
	tibatch				: CnEcXmlStructureInstance;
	canContinue			: Boolean;
	className			: String;
	type				: String;
	reticketDtl			: CM_RemoteReticketDtlNew;
	array				: StringArray;
	areaLocation		: String;
	
begin
	on SystemException do self.handleException(exception, canContinue);

	canContinue 	:=	true;
//	batchrq 		:=	self.xmlStruct.findStructure(XML_BATCHRQ).CnEcXmlGroupInstance;
	batchrq 		:=	self.xmlStruct.findStructure(XML_TIBATCH).CnEcXmlGroupInstance;
	
	_reticketHdr.getAttributes(batchrq.tagAttribute, className, type);
	
	if type &lt;&gt; CM_RemoteDataObject.Type_Reticket then
		app.raiseUnexpectedProgramError(self.class.name, method.name, "The 'Type' for this Reticket message (" &amp; XML_TIBATCH &amp; " tag) is not valid.");
		return false;
	endif;
	
	tiBatchHdr 		:=	batchrq.findStructure(XML_BATCHHDR).CnEcXmlStructureInstance;
	areaLocation	:=	tiBatchHdr.tagData;
	
	if areaLocation &lt;&gt; null then
		_reticketHdr.getAttributes(tiBatchHdr.tagAttribute, className, type);
		
		if type &lt;&gt; CM_RemoteDataObject.Type_Reticket then
			app.raiseUnexpectedProgramError(self.class.name, method.name, "The 'Type' for this Reticket message (" &amp; XML_BATCHHDR &amp; " tag) is not valid.");
			return false;
		endif;
	endif;
	
	//tiDtls			:=	batchrq.findStructure(XML_TIDTLS).CnEcXmlGroupInstance;		// 10/08/2011 cnwar2 #27910
	tiDtls			:=	batchrq.findStructure(XML_TIDTLS).CnEcXmlStructureInstance;		// might be CnEcXmlFieldInstance
	if tiDtls.isKindOf(CnEcXmlGroupInstance) then										// if &lt;tidtls&gt; tag has no children
		_reticketHdr.getAttributes(tiDtls.tagAttribute, className, type);
		
		if type &lt;&gt; CM_RemoteDataObject.Type_Reticket then
			app.raiseUnexpectedProgramError(self.class.name, method.name, "The 'Type' for this Reticket message (" &amp; XML_TIDTLS &amp; " tag) is not valid.");
			return false;
		endif;
		
		create reticketDtl transient;
		create array transient;
		array.clear();
		
		foreach ti in tiDtls.CnEcXmlGroupInstance.allFields do
			array.add(ti.tagData);
		endforeach;
		
		if array.size() &gt; 0 then
			reticketDtl.setProxyForReticket(_reticketHdr, areaLocation, array);
		endif;
	endif;
	
/*
	foreach tibatch in batchrq.allFields do
		_reticketHdr.getAttributes(tibatch.tagAttribute, className, type);
		
		if type &lt;&gt; CM_RemoteDataObject.Type_Reticket then
			canContinue := false;
			return canContinue;
		endif;
		
		tiBatchHdr 		:= tibatch.findStructure(XML_BATCHHDR).CnEcXmlStructureInstance;
		areaLocation	:= tiBatchHdr.tagData;
		create reticketDtl transient;
		tiDtls			:= tibatch.findStructure(XML_TIDTLS).CnEcXmlGroupInstance;
		array.clear();
		
		foreach ti in tiDtls.allFields do
			array.add(ti.tagData);
		endforeach;

		if array.size &gt; 0 then
			reticketDtl.setProxyForReticket(_reticketHdr, areaLocation, array);
		endif;
	endforeach;
*/
epilog
	delete array;
	return canContinue;
end;</source>
        <Parameter name="_reticketHdr" type="CM_RemoteReticketHdrNew" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createScaleTruckDetail" id="48539cc5-6d70-43f9-9044-e62927c6fba1">
        <updating/>
        <source>createScaleTruckDetail(_scaleTruckHdr : CM_RemoteScaleTruckHdr): Boolean updating;

vars

	errString			: String;
	batchrq				: CnEcXmlGroupInstance;
	tibatch				: CnEcXmlStructureInstance;
	tidtls				: CnEcXmlGroupInstance;
	ti					: CnEcXmlStructureInstance;
	remoteDetail		: CM_RemoteDataDtl;
	headerDsc,
	detailDsc,
	tiString,
	batchHdr			: String;
	logDetailPxy, newDtl: CM_LogScalingDtl;
	class,
	type				: String;
	canContinue			: Boolean;

begin
	
	on SystemException do self.handleException(exception, canContinue);
	
	canContinue := true;
	batchrq :=	self.xmlStruct.findStructure(XML_BATCHRQ).CnEcXmlGroupInstance;
	foreach tibatch in batchrq.allFields do
		_scaleTruckHdr.getAttributes(tibatch.tagAttribute, class, type);
		batchHdr		:= tibatch.findStructure(XML_BATCHHDR).tagData; 
		
		if type &lt;&gt; CM_RemoteDataObject.Type_Scale or class &lt;&gt; CM_RemoteDataObject.Class_Log then
			canContinue := false;
			return canContinue;
		endif;
		remoteDetail	:= self.parseBatchHdr(batchHdr, _scaleTruckHdr, class, type);
		tidtls		:= tibatch.findStructure(XML_TIDTLS).CnEcXmlGroupInstance;	
		_scaleTruckHdr.getAttributes(tidtls.tagAttribute, class, type);
		
		if type &lt;&gt; CM_RemoteDataObject.Type_Scale or class &lt;&gt; CM_RemoteDataObject.Class_Log then
			canContinue := false;
			return canContinue;
		endif;
				
		foreach ti in tidtls.allFields do
			tiString := ti.tagData;
			self.parseTiToExtraDetail(tiString, remoteDetail, class, type);
		endforeach;
	endforeach;
	
epilog

	return canContinue;
end;</source>
        <Parameter name="_scaleTruckHdr" type="CM_RemoteScaleTruckHdr"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createTiQueryDetail" id="04b62a54-c7fd-4dea-924b-8d8a0d7167a0">
        <updating/>
        <source>createTiQueryDetail(_tiEnquiryHeader: CM_RemoteTiQueryHdr input) : Boolean updating;

vars


	 tiqryrq			: CnEcXmlGroupInstance;
	 ti					: CnEcXmlStructureInstance;
	 allTis				: StringArray;
	 tagAttribute		: String;
	 canContinue		: Boolean;

begin

	on SystemException do self.handleException(exception, canContinue);
	
	canContinue := true;	
	create allTis transient;
	tiqryrq :=	self.xmlStruct.findStructure(XML_TIQRYRQ).CnEcXmlGroupInstance;
	tagAttribute := tiqryrq.tagAttribute;
	foreach ti in tiqryrq.allFields do
		allTis.add(ti.tagData);
	endforeach;
	_tiEnquiryHeader.setProxyForTiQueryHdr(tagAttribute, allTis);

epilog

	delete allTis;
	return canContinue;
end;</source>
        <Parameter name="_tiEnquiryHeader" type="CM_RemoteTiQueryHdr" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createTransferDetail" id="8de80a49-0e39-452c-b03a-959970e8a4be">
        <updating/>
        <source>createTransferDetail(_transferHeader: CM_RemoteTransferHdr) : Boolean updating;

vars

	 trnsfrq,
	 noNumber,
	 tiDetail				: CnEcXmlGroupInstance;
	 trnsfr,
	 tiBatch,
	 ti						: CnEcXmlStructureInstance;
	 remoteTransfer			: CM_RemoteTransferDtl;
	 remoteTransferExtra	: CM_RemoteTransferExtra;
	 transferFrom,
	 transferTo,
	 areaTo,				
	 areaFrom,
	 tis,
	 batchHdr,
	 class,
	 type					: String;
	 tagAttribute			: String;
	 canContinue			: Boolean;
	 huge					: HugeStringArray;
	 allDetail				: StringArray;

begin

	on SystemException do self.handleException(exception, canContinue);
	
	canContinue := true;
	trnsfrq :=	self.xmlStruct.findStructure(XML_TRNSFRQ).CnEcXmlGroupInstance;
	foreach trnsfr in trnsfrq.allFields do
		create remoteTransfer transient;
		tagAttribute	:= trnsfr.tagAttribute;
		areaTo			:= trnsfr.findStructure(XML_AREATO).tagData;
		transferTo		:= trnsfr.findStructure(XML_LCTNTO).tagData;
		tis				:= trnsfr.findStructure(XML_ITEMLST).tagData;
		remoteTransfer.setProxyForTransfer(_transferHeader, areaTo, areaFrom, transferTo, transferFrom, tagAttribute, tis);
		noNumber := trnsfr.findStructure(XML_NN).CnEcXmlGroupInstance;
		if noNumber &lt;&gt; null then
			create huge transient;
			create allDetail transient;
			foreach tiBatch in noNumber.allFields do
				_transferHeader.getAttributes(tiBatch.tagAttribute, class, type);
				if type &lt;&gt; CM_RemoteDataObject.Type_NN or class &lt;&gt; CM_RemoteDataObject.Class_Log then
					canContinue := false;
					return canContinue;
				endif;
				batchHdr :=	tiBatch.findStructure(XML_BATCHHDR).tagData; 	
				batchHdr.parseCSV(huge);
				allDetail.clear();
				tiDetail := tiBatch.findStructure(XML_TIDTLS).CnEcXmlGroupInstance;
				_transferHeader.getAttributes(tiDetail.tagAttribute, class, type);
				if type &lt;&gt; CM_RemoteDataObject.Type_Scale or class &lt;&gt; CM_RemoteDataObject.Class_Log then
					canContinue := false;
					return canContinue;
				endif;
				foreach ti in tiDetail.allFields do
					allDetail.add(ti.tagData);
				endforeach;
				create remoteTransferExtra transient;
				remoteTransferExtra.setProxyForTransferExtra(remoteTransfer, huge[1], huge[2], huge[3], huge[4], huge[5], huge[6], allDetail);
			endforeach;	
			delete allDetail;
			delete huge;
		endif;
	endforeach;

epilog

	delete huge;
	delete allDetail;
	return canContinue;
end;</source>
        <Parameter name="_transferHeader" type="CM_RemoteTransferHdr"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getHeaderDetails" id="cafb96d1-a1a7-4144-907a-89227f192fba">
        <updating/>
        <source>getHeaderDetails(_messageId, _messageType, _time, _terminal : String output) : Boolean updating;

vars

	errString	: String;
