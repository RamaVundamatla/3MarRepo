    <JadeMethod name="dataDumpListExtractDefs" id="ad6baa76-467d-42e8-b73c-aa518cf0c78e">
        <source>dataDumpListExtractDefs();
// ---------------------------------------------------------------------------
// Created:     02 June 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
	def : CM_DataDumpExtractDef;
	class : CM_DataDumpExtractClass;
	root : CM_Root;
	feature : CM_DataDumpFeature;
	str : String;

begin
	root := CM_Root.firstInstance;
	
	foreach def in root.allDataDumpExtractDefs do
		str := str &amp; def.description &amp; CrLf;
		
		foreach class in def.allDataDumpExtractClasses do
			str := str &amp; Tab &amp; class.myDataDumpClass.className &amp; CrLf;
			
			foreach feature in class.allDataDumpFeatures do
				str := str &amp; Tab &amp; Tab &amp; feature.featureName &amp; CrLf;
			endforeach;
		endforeach;
	endforeach;
	
	app.writeStatement( str);
end;</source>
    </JadeMethod>
    <JadeMethod name="dataDumpListSQLRecs" id="f8c60f6c-0958-4b72-8914-4b88ccb6d219">
        <source>dataDumpListSQLRecs(_class : Class; _newObject : Boolean);
// ---------------------------------------------------------------------------
// Created:     cnwrs1 Feb 20006
// ---------------------------------------------------------------------------
constants
	DDxDefDescription = "Joe's Test SQL Native";
vars
	agent : CM_ExternalDatabaseAgent;
	objArray : ObjectArray;
	obj : Object;
	def : CM_DataDumpExtractDef;
	transExtractDef: CM_DataDumpTransExtractDef;
	created, updated : Boolean;
	sqlStatement: String;
	loadMode: Boolean;
	extObj : ExternalObject;
	file: File;
begin
	app.initialize;
	create objArray transient;
	_class.allInstances(objArray, 0, true);
	if objArray.size = 0 then
		return;
	endif;
	create file transient;
	file.fileName := 'c:\tmp\'&amp;objArray[1].class.name&amp;'.sql';
	
	if file.isAvailable then
		file.purge();
	endif;
		
	on Exception do self.dataDumpXDBExHandler(exception, agent);
	create agent transient;

	// Initialise the agent with the transExtractDef for this extractDef
	def := app.myRoot.allDataDumpExtractDefs[DDxDefDescription];
	if def = null then
		app.writeStatement( "Definition not found");
		return;
	endif;
	create transExtractDef transient;
	transExtractDef.setForCreate(def, false);

	agent.initialise(EDB_PortDss, transExtractDef, null, false);
	
	foreach obj in objArray do
		extObj := agent.getExternalObj(obj);
		if extObj &lt;&gt; null then
			file.writeLine(agent.createSQLStatement(extObj, _newObject));
		endif;
	endforeach;
	
epilog
	if agent &lt;&gt; null then
		agent.finalise;
	endif;
	delete agent;
	delete transExtractDef;
	if file &lt;&gt; null then
		file.close;
		delete file;
	endif;
end;</source>
        <Parameter name="_class" type="Class"/>
        <Parameter name="_newObject" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="dataDumpMaintainClasses" id="a0dd15ce-cf2d-4ebd-b40f-5ac40b099fd2">
        <source>dataDumpMaintainClasses();
// ---------------------------------------------------------------------------
// Created:     21 May 2003 by cnwsb1
//
// Purpose:		Maintains all Data Dump classes and their attributes.
//				Also updates server ini file with changes.
//				The data was obtained from the old SQLServerDb structures.
//
// Sequence:	Run this, then run dataDumpMaintainExtractDefs
// ---------------------------------------------------------------------------
vars
	agent : CM_DataDumpMaintenanceAgent;

begin
	app.initialize;
	
	create agent transient;
	agent.maintainDataDumpClasses();
	agent.maintainDataDumpFeatureUpdate();
	
	if app.myPassport.hasErrors then
		app.writeStatement(app.myPassport.getErrorsAsString);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="dataDumpMatchExtractClasses" id="b3340021-148c-4d4c-a777-88e12bd79914">
        <source>dataDumpMatchExtractClasses();
// ---------------------------------------------------------------------------
// Created:     12 March 2004 by cnwrs1
// ---------------------------------------------------------------------------
vars
	def : CM_DataDumpExtractDef;
	class : CM_DataDumpExtractClass;
	root : CM_Root;
	feature : CM_DataDumpFeature;
	str : String;

begin
	root := CM_Root.firstInstance;
	
	foreach def in root.allDataDumpExtractDefs do
		str := str&amp;def.description&amp;CrLf;
		
		foreach class in def.allDataDumpExtractClasses do
//			str := str&amp;Tab&amp;class.myDataDumpClass.className&amp;CrLf;
			
			foreach feature in class.myDataDumpClass.allDataDumpFeatures do
				if not class.allDataDumpFeatures.includes(feature) then 
					str := str&amp;Tab&amp;class.myDataDumpClass.className&amp;Tab&amp;feature.featureName&amp;CrLf;
					if feature.featureName &lt;&gt; "myTerminal" then
						app.writeStatement( "add "&amp;class.myDataDumpClass.className&amp;"::"&amp;feature.featureName);
//						beginTransaction;
//						class.allDataDumpFeatures.add(feature);
//						commitTransaction;
					endif;
				endif;
			endforeach;
		endforeach;
	endforeach;
	
	app.writeStatement( str);
end;</source>
    </JadeMethod>
