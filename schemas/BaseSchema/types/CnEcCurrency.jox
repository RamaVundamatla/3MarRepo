    <JadeMethod name="getWholeAndDecimalValues" id="04bdd913-77cf-43d3-ac73-2b60b8627944">
        <source>getWholeAndDecimalValues(pWholeValue:Integer output; pDecimalValue:Integer output) protected;
// --------------------------------------------------------------------------------
// Created:		28 August 2001 by cnwdad1
//
// Purpose:		Returns the whole part of the receiver's amount and the decimal
//				amount in IO parameters.
//
// Parameters:	pWholeValue - All digits before the decimal separator.
//				pDecimalValue - All digits after the decimal separator.
//
// Returns:		The whole and decimal values as IO parameters.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	stringValue	: String;
	
begin
	stringValue	:=	self.getDecimalCurrency().String;
end;</source>
        <access>protected</access>
        <Parameter name="pWholeValue" type="Integer" usage="output"/>
        <Parameter name="pDecimalValue" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="setAmount" id="ff9ca41f-618a-46e2-85aa-59824be91cc0">
        <updating/>
        <source>setAmount(pAmount:Real) updating;
// --------------------------------------------------------------------------------
// Created:		15 May 2001 by cnwdad1
//
// Purpose:		Sets the receiver's amount value.
//
// Parameters:	pAmount - The amount value.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.amount &lt;&gt; pAmount then
		self.amount	:=	pAmount;
	endif;
end;</source>
        <Parameter name="pAmount" type="Real"/>
    </JadeMethod>
    <JadeMethod name="setExchangeRate" id="5cddcd06-ecab-482b-8321-64e0ad162ce7">
        <updating/>
        <source>setExchangeRate(pExchangeRate:Real) updating;
// --------------------------------------------------------------------------------
// Created:		15 May 2001 by cnwdad1
//
// Purpose:		Sets the receiver's exchange rate.
//
// Parameters:	pExchangeRate - The rate of exchange between currencies.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.exchangeRate &lt;&gt; pExchangeRate then
		self.exchangeRate	:=	pExchangeRate;
	endif;
end;</source>
        <Parameter name="pExchangeRate" type="Real"/>
    </JadeMethod>
    <JadeMethod name="updateMe" id="135f2c5f-5f45-4c6c-b522-480424795664">
        <updating/>
        <source>updateMe(pAmount:Real; pExchangeRate:Real; pLocaleInfoObj:LocaleFullInfo; pRemoteLocaleInfoObj:LocaleFullInfo) updating;
// --------------------------------------------------------------------------------
// Created:		15 May 2001 by cnwdad1
//
// Purpose:		Updates the receiver's properties.
//
// Parameters:	pAmount - The receiver's amount value.
//				pExchangeRate - The rate of exchange between currencies.
//				pLocaleInfoObj - The default locale info object.
//				pRemoteLocaleInfoObj - The remote locale info object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.setAmount(pAmount);
	self.setLocaleInfo(pLocaleInfoObj);
	self.setExchangeRate(pExchangeRate);
	self.setRemoteLocaleInfo(pRemoteLocaleInfoObj);
end;</source>
        <Parameter name="pAmount" type="Real"/>
        <Parameter name="pExchangeRate" type="Real"/>
        <Parameter name="pLocaleInfoObj" type="LocaleFullInfo"/>
        <Parameter name="pRemoteLocaleInfoObj" type="LocaleFullInfo"/>
    </JadeMethod>
    <JadeMethod name="wholeAmountInWords" id="eefad608-352c-463d-b43f-f3a8fbff14e9">
        <source>wholeAmountInWords(pWholeUnits:String; pDecimalUnits:String):String;
// --------------------------------------------------------------------------------
// Created:		21 August 2001 by cnwdad1
//
// Purpose:		Returns the receiver's currency amount, with the whole amount
//				expressed in words, and the decimal portion as digits.
//
// Parameters:	pWholeUnits - The name of the whole currency units, e.g. "Dollars".
//				pDecimalUnits - The name of the decimal currency units, e.g. "Cents".
//
// Returns:		The currency amount expressed in words.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	localeInfoObj	: LocaleFullInfo;
	stringValue		: String;
	wholeValue		: Integer;
	wholeAmount		: String;
	decimalAmount	: String;
	wordedAmount	: String;
	
begin
	create localeInfoObj transient;
	self.getLocaleFullInfo(localeInfoObj, true);
	
	stringValue		:=	self.getDecimalCurrency().String;
	wholeValue		:=	stringValue.Decimal.truncated;
	wholeAmount		:=	wholeValue.cnEcAsWords(localeInfoObj);
	decimalAmount	:=	stringValue[(stringValue.pos(".", 1) + 1):end];

	if pWholeUnits = null then
		wordedAmount	:=	wholeAmount &amp; " " &amp; $CNEC_LIT_AND;
	else
		wordedAmount	:=	wholeAmount &amp; " " &amp; pWholeUnits &amp; " " &amp; $CNEC_LIT_AND;
	endif;
	
	if pDecimalUnits = null then
		wordedAmount	:=	wordedAmount &amp; " " &amp; decimalAmount;
	else
		wordedAmount	:=	wordedAmount &amp; " " &amp; decimalAmount &amp; " " &amp; pDecimalUnits;
	endif;
epilog
	delete localeInfoObj;
	
	return wordedAmount;
end;</source>
        <Parameter name="pWholeUnits" type="String"/>
        <Parameter name="pDecimalUnits" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
