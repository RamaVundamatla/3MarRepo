    <JadeMethod name="trxUpdateUserSettingsOnExit" id="eccb8580-66b7-49e6-8bac-2010c1780c36">
        <updating/>
        <source>trxUpdateUserSettingsOnExit(pUser : CM_User; 
							pUserWindows : CM_UserWindowsByClassNameDict;
							_userWinSet : CM_UserWindowForStartupSet;
							pSubSystem : Integer;
							pSaveSettings, pToolbarHidden, 
							pUseAnimation, pUseNavigator : Boolean;
							_showWelcomeScreen :Boolean;	// par 17903
							_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     07 March 2001 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 11/09/2008	concms1		par17903/ccms 1741 Welcome Form interim solution

// ***************************************************************************
// This is similar to method trxUpdateUserSettingsOnExitMOB.  
// Changes to this method may also need to be done in that method
// ***************************************************************************

vars
	userWindow : CM_UserWindow;
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
		
	beginTransaction;

	app.myUtilityUA.utlUpdateUserStateData(pUser, pSubSystem, UserToolbarHidden, pToolbarHidden);
	app.myUtilityUA.utlUpdateUserStateData(pUser, pSubSystem, UserSaveSettingsOnExit, pSaveSettings);
	app.myUtilityUA.utlUpdateUserStateData(pUser, pSubSystem, UserAnimation, pUseAnimation);
	app.myUtilityUA.utlUpdateUserStateData(pUser, pSubSystem, UserNavigatorWindow, pUseNavigator);
	app.myUtilityUA.utlUpdateUserStateData(pUser, ConfigGrp_System, UserShowWelcomeScreen, _showWelcomeScreen);	// par 17093
	
	foreach userWindow in pUserWindows do
		app.myUtilityUA.utlUpdateUserWindow(pUser, userWindow);
	endforeach;

	pUser.updateMenuUserDtlsOnExit(_userWinSet);

   	process.changeUserCode(app.computerName);
	process.causeEvent(Event_ProcessUserCodeUpdate, false, null);
	
epilog	
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="pUser" type="CM_User"/>
        <Parameter name="pUserWindows" type="CM_UserWindowsByClassNameDict"/>
        <Parameter name="_userWinSet" type="CM_UserWindowForStartupSet"/>
        <Parameter name="pSubSystem" type="Integer"/>
        <Parameter name="pSaveSettings" type="Boolean"/>
        <Parameter name="pToolbarHidden" type="Boolean"/>
        <Parameter name="pUseAnimation" type="Boolean"/>
        <Parameter name="pUseNavigator" type="Boolean"/>
        <Parameter name="_showWelcomeScreen" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
