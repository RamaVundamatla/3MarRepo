    <JadeMethod name="includeTrackedItem" id="eec709a5-ce9f-46b7-a1d1-65d758cffb3e">
        <source>includeTrackedItem(_ti : CM_TrackedItem; _checkCargoGroup : Boolean) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items

*/

vars
	includeTi : Boolean;
begin
	
	includeTi := self.allTrackedItems.includes(_ti);
	
	if self.isAllocationById() or includeTi or not _checkCargoGroup then
		return includeTi;
	endif;
	
	if self.myCargoGroup &lt;&gt; null then
		includeTi := self.myCargoGroup.allAssignedTrackedItems.includes(_ti);
	endif;
	
	return includeTi;
	
epilog
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_checkCargoGroup" type="Boolean"/>
        <ReturnType type="Boolean"/>
