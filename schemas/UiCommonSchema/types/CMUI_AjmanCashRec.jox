Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 November 2012	cnwndl1	Initial creation	Par 30689

*/

vars
	
	 topMMs : Real;
	 leftMMs : Real;
	 rightMMs : Real;
	 bottomMMs : Real;

begin

	topMMs := 50;
	bottomMMs := 55;
	leftMMs := 150;	rightMMs := 200;	self.moveLabel( self.lblA, topMMs, leftMMs, rightMMs, bottomMMs );
	
	topMMs := 59;
	bottomMMs := 64;
	leftMMs := 150;	rightMMs := 200;	self.moveLabel( self.lblB, topMMs, leftMMs, rightMMs, bottomMMs );
	
	topMMs := 71;
	bottomMMs := 95;
	leftMMs := 20;	rightMMs := 134;	self.moveLabel( self.lblC, topMMs, leftMMs, rightMMs, bottomMMs );
	
	topMMs := 71;
	bottomMMs := 89;
	leftMMs := 150;	rightMMs := 200;	self.moveLabel( self.lblD, topMMs, leftMMs, rightMMs, bottomMMs );
	
	topMMs := 90;
	bottomMMs := 95;
	leftMMs := 155;	rightMMs := 200;	self.moveLabel( self.lblE, topMMs, leftMMs, rightMMs, bottomMMs );
	
	topMMs := 108;
	bottomMMs := 190;
	leftMMs := 0;	rightMMs := 153;	self.moveLabel( self.lblF, topMMs, leftMMs, rightMMs, bottomMMs );
	leftMMs := 155;	rightMMs := 200;	self.moveLabel( self.lblG, topMMs, leftMMs, rightMMs, bottomMMs );
	
	topMMs := 191;
	bottomMMs := 202;
	leftMMs := 18;	rightMMs := 153;	self.moveLabel( self.lblH, topMMs, leftMMs, rightMMs, bottomMMs );
	leftMMs := 155;	rightMMs := 200;	self.moveLabel( self.lblI, topMMs, leftMMs, rightMMs, bottomMMs );
	
	topMMs := 211;
	bottomMMs := 240;
	leftMMs := 0;	rightMMs := 27;		self.moveLabel( self.lblJ, topMMs, leftMMs, rightMMs, bottomMMs );
	leftMMs := 28;	rightMMs := 67;		self.moveLabel( self.lblK, topMMs, leftMMs, rightMMs, bottomMMs );
	leftMMs := 68;	rightMMs := 94;		self.moveLabel( self.lblL, topMMs, leftMMs, rightMMs, bottomMMs );
	leftMMs := 96;	rightMMs := 153;	self.moveLabel( self.lblM, topMMs, leftMMs, rightMMs, bottomMMs );
	leftMMs := 155;	rightMMs := 200;	self.moveLabel( self.lblN, topMMs, leftMMs, rightMMs, bottomMMs );
	
	topMMs := 263;
	bottomMMs := 268;
	leftMMs := 25;	rightMMs := 200;		self.moveLabel( self.lblO, topMMs, leftMMs, rightMMs, bottomMMs );
	
