    <JadeMethod name="setProxyForHandHeld" id="8feb0280-f3bb-4871-a8da-fc4e025d083a">
        <updating/>
        <source>setProxyForHandHeld(_id : String; 
					_radioTelemetry 		: CM_RadioTelemetry;
					_model,
					_computerName 			: String;
					_isPasswordCompulsory,
					_useSerialConnection 	: Boolean;
					_useLocalTCPConnection : Boolean;		// +17/08/2016 cnwrh7	TFS	2501
					_cameraType : Integer;	//07 Dec 2010	NDL	Par 23831
					_labelPrinter : CM_PrinterDef	// Mar 2016 cnwjre1 TFS 978
					) updating;
// 17/08/2016 cnwrh7	TFS	2501
vars

begin
	
	// MAY NEED TO ADD STUFF IN THE FUTURE. SO THIS METHOD WILL HANDLE IT.
	self.isPasswordCompulsory := _isPasswordCompulsory;
	//self.setProxyRTDevice(_id, _radioTelemetry, _model, _computerName, _useSerialConnection);
	self.setProxyRTDevice(_id, _radioTelemetry, _model, _computerName, _useSerialConnection, _useLocalTCPConnection, _cameraType, _labelPrinter);	//07 Dec 2010	NDL	Par 23831	,  //+ 17/08/2016 cnwrh7	TFS	2501

end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_radioTelemetry" type="CM_RadioTelemetry"/>
        <Parameter name="_model" type="String"/>
        <Parameter name="_computerName" type="String"/>
        <Parameter name="_isPasswordCompulsory" type="Boolean"/>
        <Parameter name="_useSerialConnection" type="Boolean"/>
        <Parameter name="_useLocalTCPConnection" type="Boolean"/>
        <Parameter name="_cameraType" type="Integer"/>
        <Parameter name="_labelPrinter" type="CM_PrinterDef"/>
    </JadeMethod>
    <JadeMethod name="startAppFor" id="0b48a9c6-0d0d-4d72-9173-ae91fd3518f6">
