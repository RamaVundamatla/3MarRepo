<Class name="CM_BatNumber" id="7850efd6-8215-4ce5-931a-11e797ace144">
    <superclass name="CM_Object"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="terminal"/>
    <PrimAttribute name="code" id="051ae4ef-89f5-4071-b207-8bf5ea50dc94">
        <length>5</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <ExplicitInverseRef name="myRoadJob" id="bc997747-52fb-447a-8e5f-ccc650c8956f">
        <transientToPersistentAllowed/>
        <updateMode>automatic</updateMode>
        <embedded/>
        <type name="CM_RoadJob"/>
        <access>readonly</access>
        <Inverse name="CM_RoadJob::myBatNumber"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="myTerminal" id="2049d470-7d26-4bea-aa10-7a321518416f">
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_Terminal"/>
        <access>readonly</access>
        <Inverse name="CM_Terminal::allBatNumbersInUse"/>
    </ExplicitInverseRef>
    <JadeMethod name="auditId" id="b90c6ed5-ef7b-47f0-bf36-052edbf85a86">
        <source>auditId(): String;

vars

begin
	return self.code;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setMyTerminal" id="dabd571b-e2d2-4710-bdeb-f9dd9e42c603">
        <updating/>
        <source>setMyTerminal(_terminal : CM_Terminal)updating;
//--------------------------------------------------
// Created:	16 January 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.myTerminal := _terminal;
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="testInUse" id="d7becdd4-6fcb-48c4-bb06-fe6b0f6273d9">
        <source>testInUse(_theTerminal : CM_Terminal) : Boolean;
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

begin
	
	if self.myTerminal &lt;&gt; null then
		return true;
	endif;
	
	if self.myRoadJob &lt;&gt; null then
		return true;
	endif;
	
	return false;
	// Was doing a check in the jobSheet collection.  This has
	// been removed.  If this check is required then we should
	// add another dict of bats in use to terminal - rjs 5Jun03

end;</source>
        <Parameter name="_theTerminal" type="CM_Terminal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
