    <JadeMethod name="pictureStringButton" id="e16b332e-7afb-46c4-a165-bf0d58f2c73c">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>pictureStringButton(set: Boolean; _value: String io) mapping, updating;
// ---------------------------------------------------------------------------
// Created:     31 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if set then
		if _value &lt;&gt; null then
			self.pictureButton := app.myRoot.getConfig(_value).Binary;
		else
			self.pictureButton := null;
		endif;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
