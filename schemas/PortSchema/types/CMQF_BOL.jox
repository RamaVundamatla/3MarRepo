    <JadeMethod name="cloneReferences" id="2e687ec3-3d17-4552-adf2-ca8133ac722d">
        <updating/>
        <source>cloneReferences(_obj: CMQF_BOL; _transient: Boolean) updating;
/* ---------------------------------------------------------------------------
Created:	31 May 2010	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	inheritMethod(_obj, _transient);

	self.setMyDocketErrorType( _obj.getMyDocketErrorType );	//#24306	31/05/2010


end;</source>
        <Parameter name="_obj" type="CMQF_BOL"/>
        <Parameter name="_transient" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="filterObjects" id="98aa8583-37a4-4e6b-b957-6586fdfdbefd">
        <updating/>
        <source>filterObjects(_collection  : Collection input; _passport : CM_Passport) updating;
// ---------------------------------------------------------------------------
// Created:     06 September 2002 by cnwth2
//
// Purpose:     
// ----------   ----------  --------------------------------------------------

vars
	bolColl 		: CM_BOLByTypeNumberDTDict;	
	bol				: CM_BOL;
	iter			: Iterator;
	op				: CM_Operator;
	opTerm			: CM_OperatorTerminal;
	terminal		: CM_Terminal;
	breakOut		: Boolean;

begin
	op := self.myOperator;

	foreach terminal in self.allTerminals do : terminalLoop
		if op = null then
			bolColl := terminal.allBOLsReceivedByTypeNumberDT;
		else
			opTerm := op.getOperatorTerminal(terminal, false);
			if opTerm = null then
				continue terminalLoop;
			endif;
			
			bolColl := opTerm.allBOLByTypeNumber;
		endif;
		
		if self.docketNumber &lt;&gt; null and self.bolType &lt;&gt; null then
			bol := bolColl.getAtKeyGeq(self.bolType, self.docketNumber.toUpper, null);
			
			if bol &lt;&gt; null and 
			   bol.number = self.docketNumber.toUpper and 
			   (bol.bolType = self.bolType or self.bolType = null) then
				_collection.add(bol);
				break;
			endif;
		else
			
			delete iter;
			iter := bolColl.createIterator;
			bolColl.startKeyGeq(self.bolType, null, null, iter);
			
			
			while iter.next(bol) do	
				if bol.bolType &lt;&gt; self.bolType and self.bolType &lt;&gt; null then
					continue terminalLoop;
				endif;
				if self.checkStatusIncludesObject(bol, _passport, breakOut) then
//				if self.includesObject(bol, _passport, breakOut) then
					_collection.add(bol);
					if breakOut then
						break terminalLoop;
					endif;
				endif;
			endwhile;
		endif;
	endforeach;


epilog
	delete iter;
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="c930a4bb-ec82-417a-b6c4-a9255f43f220">
        <source>getDisplayStringForAttribute(_attrName : String; _getCalculatedRunDate : Boolean) : String;
// ---------------------------------------------------------------------------
// Created:     19/07/2010 cnwdz2	
//
// Purpose:     PAR24513 extend the current existing getDisplayStringForAttribute method to return an object's oid.		 
// ----------   ----------  --------------------------------------------------
vars
    oid : String;
begin
	return self.getOIDAndDescForAttribute(_attrName, _getCalculatedRunDate, oid);
	/*
	if _attrName = ETRow_DocketNumber or
		_attrName = ETRow_Number then
		return self.docketNumber;
	endif;
	
	return inheritMethod(_attrName, _getCalculatedRunDate);
*/

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_getCalculatedRunDate" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyDocketErrorType" id="69c69285-a42d-4eec-b1f6-03bf5d8e9b89">
        <source>getMyDocketErrorType():CM_DocketErrorType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 July 2016	cnwndl1	Initial creation	TFS 2329

*/

vars

	docketErrorType : CM_DocketErrorType;
	edition : Integer;
	invalidObj : Boolean;

begin

	docketErrorType := self.myDocketErrorType;

	if docketErrorType = null then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject( exception, docketErrorType, invalidObj );
	edition := docketErrorType.edition;
	
	if invalidObj then
		return null;
	endif;
	
	return docketErrorType;

epilog

end;</source>
        <ReturnType type="CM_DocketErrorType"/>
    </JadeMethod>
    <JadeMethod name="getOIDAndDescForAttribute" id="7da6caec-37b9-4286-9f74-e68a19738b57">
        <source>getOIDAndDescForAttribute(_attrName : String; _getCalculatedRunDate : Boolean; _oid:String output) : String;
// ---------------------------------------------------------------------------
// Created:     19/07/2010 cnwdz2	
//
// Purpose:     PAR24513 extend the current existing getDisplayStringForAttribute method to return an object's oid.		 
// ----------   ----------  --------------------------------------------------
vars

begin
	if _attrName = ETRow_DocketNumber or
		_attrName = ETRow_Number then
		return self.docketNumber;
	endif;
	
	return inheritMethod(_attrName, _getCalculatedRunDate, _oid);


end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_getCalculatedRunDate" type="Boolean"/>
        <Parameter name="_oid" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="ccbb85ec-77b9-4e9c-b40e-016715685373">
        <updating/>
        <source>includesObject(_bol: CM_BOL; _passport : CM_Passport; _breakOut : Boolean output): Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     09 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	queryBol			: CMQF_BOL;
	failedDAC  :CM_DataAccessController;
begin
	queryBol := self;
	queryBol.numSearched := queryBol.numSearched + 1;
	
	if (queryBol.docketNumber = _bol.number or queryBol.docketNumber = null)
	and (queryBol.bolType = null or queryBol.bolType = _bol.bolType)
	and (queryBol.startDate = null  or queryBol.startDate &lt;= _bol.dateTime.date)
	and (queryBol.endDate = null or queryBol.endDate &gt;= _bol.dateTime.date)
	and (queryBol.myOperator = null or queryBol.myOperator = _bol.myOperator)
	and (queryBol.consignor = null or queryBol.consignor = _bol.consignor)
	and (queryBol.getMySubTerminal = null or queryBol.getMySubTerminal = _bol.mySubTerminal) //29/04/2009 cnwdz2 ccms1735 
	and (_bol.canUserAccessSelf(null, failedDAC, _passport))
	then
		queryBol.numFound := queryBol.numFound + 1;
		return true;
	endif;
	
	return false;
end;</source>
        <access>protected</access>
        <Parameter name="_bol" type="CM_BOL"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setFromTemplate" id="4a94f6fc-0d12-434d-93ad-f1478d63b54e">
        <updating/>
        <source>setFromTemplate(_obj: CMQF_FilterReports; _runDate: Date; _allEventData: CM_EventDataByTypeDict) updating;
/*

Date		Who		Reason
10 September 2014	cnwer1	Initial creation PAR

*/

vars

eventData : CM_EventDataVoyage;

begin
	inheritMethod(_obj, _runDate, _allEventData);
	
	// This code sets the voyage for event driven schedules.
	// Have to do this for each appropriate class because they have different myVoyage references.
	eventData := _allEventData[EventDataVoyage].CM_EventDataVoyage;
	if eventData &lt;&gt; null and eventData.myVoyage &lt;&gt; null then
		self.voyageCode := eventData.myVoyage.code;
	endif;
epilog

end;</source>
        <Parameter name="_obj" type="CMQF_FilterReports"/>
        <Parameter name="_runDate" type="Date"/>
        <Parameter name="_allEventData" type="CM_EventDataByTypeDict"/>
    </JadeMethod>
    <JadeMethod name="setMyDocketErrorType" id="3f5bd349-9b38-40fd-88c6-13be0abf5d3b">
        <updating/>
        <source>setMyDocketErrorType( _docketErrorType : CM_DocketErrorType ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 July 2016	cnwndl1	Initial creation	TFS 2329

*/

vars

begin

	self.myDocketErrorType := _docketErrorType;

epilog

end;</source>
        <Parameter name="_docketErrorType" type="CM_DocketErrorType"/>
    </JadeMethod>
</Class>
