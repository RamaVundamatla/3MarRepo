    <JadeMethod name="deleteExtraDataSpecial" id="2f752c4c-579d-4ca5-a4c7-6ece1e9d514f">
        <source>deleteExtraDataSpecial();
/* ---------------------------------------------------------------------------
Created:	17 September 2009	by cnwvu1

Purpose:	CCMS1107 / PAR 20627 for Conversion script ccms1107_convertLogRowDetails().
			Used to go from JMT 772 to JMT 773 version.
			
			NEED to be DELETED when JMT is 774 or greater version/
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	self.myTerminal.deleteExtraData(LogRowExtraData_Inspected &amp; self.getOidString());
	self.myTerminal.deleteExtraData(LogRowExtraData_Fumigated &amp; self.getOidString());
	self.myTerminal.deleteExtraData(LogRowExtraData_AuditDict &amp; self.getOidString());


end;</source>
    </JadeMethod>
    <JadeMethod name="displayEntry" id="9b548f32-f8dd-40a4-9fef-d3c51d785e43">
        <source>displayEntry() : String;

vars
	restrict	: CM_LocationRestrictLog;
	tmpMixed	: String;
	
begin
	if self.myLocationRestriction &lt;&gt; null
	and self.myLocationRestriction.isKindOf(CM_LocationRestrictLog)
	then
		restrict := self.myLocationRestriction.CM_LocationRestrictLog;
		if restrict.mixedRow then
			tmpMixed := '*';
		endif;
	   
	endif;

	return self.id &amp; Tab &amp; tmpMixed &amp; Tab &amp; 
		   self.numTIs.String &amp; Tab &amp;
		   self.totalVolume.jasVolumeString.padLeftBlanks(8) &amp; Tab &amp;
		   self.averageSED.sedString.padLeftBlanks(8);

/*
	return self.id &amp; ' ' &amp; tmpMixed &amp; ' ' &amp; 
		   self.numTIs.String &amp; ' ' &amp;
		   self.currentStockOnHand.jasVolumeString.padLeftBlanks(8) &amp; ' ' &amp;
		   self.averageSED.sedString.padLeftBlanks(8);
*/
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="displayEntryWithSpaces" id="75bccdfa-38e0-418f-a9e2-f5315fe711a7">
        <source>displayEntryWithSpaces(_passport : CM_Passport) : String;

vars
	restrict	: CM_LocationRestrictLog;
	tmpMixed	: String;
	failedDAC  :CM_DataAccessController;
begin

	if (not self.canUserAccessSelf(null, failedDAC, _passport)) then
		return null;
	endif;

	if self.myLocationRestriction &lt;&gt; null and
	   self.myLocationRestriction.isKindOf(CM_LocationRestrictLog) then
		restrict := self.myLocationRestriction.CM_LocationRestrictLog;
		if restrict.mixedRow then
			tmpMixed := '*';
		endif;
	   
	endif;

	return self.id &amp; ' ' &amp; tmpMixed &amp; ' ' &amp; 
		   self.numTIs.String &amp; ' ' &amp;
		   self.totalVolume.jasVolumeString.padLeftBlanks(8) &amp; ' ' &amp;
		   self.averageSED.sedString.padLeftBlanks(8);

end;</source>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doesAllowType" id="57f35b3e-326f-4a65-83d3-b99e2c2dc2f9">
        <source>doesAllowType(_search : CMIF_SearchTypes; _giveError : Boolean) : Boolean;
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
begin

	if self.status &lt;&gt; LC_Status_Open then
		if _giveError then
			app.raiseCMException1(LocationIsClosed, self.getID, null, null);
		endif;
		return false;
	endif;

	if self.myLocationRestriction = null then
		return true;
	endif;
	
	if (not self.myLocationRestriction.isKindOf(CM_LocationRestrictLog)) then
		return true;
	endif;

	return self.myLocationRestriction.CM_LocationRestrictLog.doesAllowType(_search.myOperator, 
																			_search.allSpecies, 
																			_search.allGrades, 
																			_search.allTypes, 
																			_search.allTreatments, 
																			_search.allLengths);

end;</source>
        <Parameter name="_search" type="CMIF_SearchTypes"/>
        <Parameter name="_giveError" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="fixupStatusCollections" id="8087c200-09b6-4db2-b48f-f9813190c8a1">
        <updating/>
        <source>fixupStatusCollections() updating;
//-----------------------------------------------------------------------
//	Created:	25 July 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars
	theArea : CM_TerminalArea;
begin

	theArea := self.myTerminalArea;
	if theArea = null then
		app.writeStatement( " ERROR");
	endif;

	if status = LC_Status_Archived then
		self.myLogAreaWhenEmpty := null;
		self.myTerminalArea := null;
		self.myTerminalAreaWhenArchived := theArea;

	elseif status = LC_Status_PhysicallyEmpty then
		self.myLogAreaWhenEmpty := theArea.CM_LogArea;
	else // open/closed
		self.myLogAreaWhenEmpty := null;
		self.myTerminalAreaWhenArchived := null;
		self.myTerminalArea := theArea;

	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getAllStockOrderAllocations" id="5517e1c4-7494-4aee-b7f5-45400411811e">
        <source>getAllStockOrderAllocations() : String;
/*
Purpose:			
Date		Who		Reason
13 May 2014	cnwab1	Initial creation
*/

vars

	alloc : CM_StockOrderAllocation;
	allocStr : String;
begin
	foreach alloc in self.allStockOrderAllocations discreteLock do
		if allocStr = "" then
			allocStr := alloc.getOidString; //	.oidAsBin;
		else
			allocStr := allocStr &amp; "," &amp; alloc.getOidString; // oidAsBin;
		endif;
 
	endforeach;
	
	return allocStr;


epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAuditDictSpecial" id="8d1a7c21-7d0e-4d93-8783-0c3291c303e8">
        <source>getAuditDictSpecial(): CM_AuditObjectDictByTimestamp;
/* ---------------------------------------------------------------------------
Created:	17 September 2009	by cnwvu1

Purpose:	CCMS1107 / PAR 20627 for Conversion script ccms1107_convertLogRowDetails().
			Used to go from JMT 772 to JMT 773 version.
			
			NEED to be DELETED when JMT is 774 or greater version/
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	return self.myTerminal.getExtraData(LogRowExtraData_AuditDict &amp; self.getOidString()).String.asOid.CM_AuditObjectDictByTimestamp;

end;</source>
        <ReturnType type="CM_AuditObjectDictByTimestamp"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="cd1fbb5b-7fdc-41d2-8307-84669d82e63d">
        <source>getAuditText(): String;

/*
Date		Who		Reason
09 September 2009	cnwar2	Initial creation (CCMS-1107/#20627)

*/

vars
	logRestrict			: CM_LocationRestrictLog;		
	auditStr, tmpStr	: String;
	operator			: CM_Operator;
	code				: CM_Code;
	
begin
	auditStr := inheritMethod();
	
	if self.myLocationRestriction &lt;&gt; null then
		logRestrict := self.myLocationRestriction.CM_LocationRestrictLog;
		
		auditStr := auditStr &amp; self.formatAuditText(CM_LocationRestrictLog::mixedRow.name, logRestrict.mixedRow.getYesNo());
		
		foreach operator in logRestrict.allOperators discreteLock do
			tmpStr := tmpStr &amp; operator.code &amp; ',';
		endforeach;
		auditStr := auditStr &amp; self.formatAuditText(CM_LocationRestrictLog::allOperators.name, tmpStr);
		tmpStr := '';
		foreach code in logRestrict.allLogGrades do
			tmpStr := tmpStr &amp; code.code &amp; ',';
		endforeach;
		auditStr := auditStr &amp; self.formatAuditText(CM_LocationRestrictLog::allLogGrades.name, tmpStr);
		tmpStr := '';
		foreach code in logRestrict.allLogLengths do
			tmpStr := tmpStr &amp; code.code &amp; ',';
		endforeach;
		auditStr := auditStr &amp; self.formatAuditText(CM_LocationRestrictLog::allLogLengths.name, tmpStr);
		tmpStr := '';
		foreach code in logRestrict.allLogSpecies do
			tmpStr := tmpStr &amp; code.code &amp; ',';
		endforeach;
		auditStr := auditStr &amp; self.formatAuditText(CM_LocationRestrictLog::allLogSpecies.name, tmpStr);
		tmpStr := '';
		foreach code in logRestrict.allLogTreatments do
			tmpStr := tmpStr &amp; code.code &amp; ',';
		endforeach;
		auditStr := auditStr &amp; self.formatAuditText(CM_LocationRestrictLog::allLogTreatments.name, tmpStr);
		tmpStr := '';
		foreach code in logRestrict.allLogTypes do
			tmpStr := tmpStr &amp; code.code &amp; ',';
		endforeach;
		auditStr := auditStr &amp; self.formatAuditText(CM_LocationRestrictLog::allLogTypes.name, tmpStr);
		
		auditStr := auditStr &amp; self.formatAuditText(CM_LocationRestrictLog::transportMode.name, logRestrict.displayStringForTransportMode());
		auditStr := auditStr &amp; self.formatAuditText(CM_LocationRestrictLog::estimatedMaxVolume.name, logRestrict.estimatedMaxVolume.asStringJMT());
		auditStr := auditStr &amp; self.formatAuditText(CM_LocationRestrictLog::comment.name, logRestrict.comment);
	endif;
	
	return auditStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAuditTextForProperty" id="cc62ab21-8105-4891-abcf-bf2bb04bf499">
        <source>getAuditTextForProperty(_property: Property): String;

/*
Date		Who		Reason
09 September 2009	cnwar2	Initial creation (CCMS-1107/#20627)

*/

vars
	auditStr, tmpStr : String;
	
begin
	if _property.name = CM_LogController::status.name then
		return self.formatAuditText(CM_LogController::status.name, global.lcStatusEnumToString(self.status));
	endif;

	return inheritMethod(_property);
end;</source>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDataForDef" id="ae44a77b-137b-48a2-b533-72bf19fc9753">
        <source>getDataForDef(_entTableDef: EntTableDef; _headings: StringArray input; _data: HugeStringArray input; _terminal: CM_Terminal);
// ---------------------------------------------------------------------------
// Created:     20 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	entTableRow	: EntTableRow;
	terminologyCargoBOLType	: CM_CargoBOLType;
begin
	terminologyCargoBOLType := app.myRoot.allCargoTypesById[TI_CargoType_Log];

	foreach entTableRow in _entTableDef.allEntTableRows do
		self.getDataForAttribute(entTableRow.name, entTableRow.getHeading(terminologyCargoBOLType, self.myTerminal, app.myCurrentLocale), _headings, _data);
	endforeach;

end;</source>
        <Parameter name="_entTableDef" type="EntTableDef"/>
        <Parameter name="_headings" type="StringArray" usage="input"/>
        <Parameter name="_data" type="HugeStringArray" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="10855293-5017-4531-a3d9-c77d43dd142f">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     17 May 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	restriction : CM_LocationRestrictLog;
	operator	: CM_Operator;
	species		: CM_LogSpecies;
	code		: CM_Code;
	tmpStr		: String;
begin

	if self.myTerminalArea = null then
		return null;
	endif;
	if _attrName = ETRow_TerminalAreaId then
		return self.myTerminalArea.id;
	
	elseif _attrName = ETRow_RowId then
		tmpStr := self.getID;
		if self.rowIsMixed then
			tmpStr := tmpStr &amp; ' ' &amp; '*';
		endif;
		return tmpStr;
	elseif _attrName = ETRow_NumItems then 
		return self.numTIs.String;
	elseif _attrName = ETRow_Comment or
		   _attrName = ETRow_LogGrade or
		   _attrName = ETRow_LogLength or
		   _attrName = ETRow_LogTreatment or	
		   _attrName = ETRow_LogType or
		   _attrName = ETRow_LogSpecies or
		   _attrName = ETRow_MixedRow or
		   _attrName = ETRow_Operator or
		   _attrName = ETRow_LogTreatment or		// 27957
		   _attrName = ETRow_TransportMode then
		restriction := self.myLocationRestriction.CM_LocationRestrictLog;
		if restriction &lt;&gt; null then
			return restriction.getDisplayStringForAttribute(_attrName, _short);
		endif;
		return null;
		
	elseif _attrName = ETRow_TotalVolume then 
		return self.totalVolume.jasVolumeString;
	elseif _attrName = ETRow_PercentageFull then 
		return self.getPercentageFull().String;
	elseif _attrName = ETRow_IsInspected then 	// 10/09/2009 cnwar2 CCMS-1107/#20627
		return self.isInspected.getYesNo();
	elseif _attrName = ETRow_IsFumigated then 	// 10/09/2009 cnwar2 CCMS-1107/#20627
		return self.isFumigated.getYesNo();
	elseif _attrName = ETRow_IsExternallyVisible then //cnwrd1 ccms 1134 par 35101
		return self.isExternallyVisible.getYesNo();
	endif;
	
	return inheritMethod(_attrName, _short);

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDistanceFromPrevious" id="244b4334-0d67-482a-b89c-5471c62c613b">
        <source>getDistanceFromPrevious():Real;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 January 2014	cnwndl1	Initial creation	Par 33264

*/

vars

begin

	if self.myRowArea &lt;&gt; null and self.myRow &lt;&gt; null then
		return self.myRowArea.getPrevGap(self.myRow);
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getDrawingAttributes" id="6a5ffc5a-59b5-49cd-bed8-37229f6ba2a9">
        <source>getDrawingAttributes(pDisplay: Integer; pView: Integer; pHeight: Integer; 
			pColour: Integer output; pLetter: String output);
// ---------------------------------------------------------------------------
// Created:		April  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

begin
	pColour := White;

	// sgp 10 June 2003 : get colours from actual items at location before
	// looking at restrictions for the colours
	if pView = VIEW_OPERATOR then
		if self.getOperatorColour(pColour) then
			return;
		endif;

	elseif pView = VIEW_LOG_GRADE then
		if self.getLogGradeColour(pColour) then
			return;
		endif;
			
	elseif pView = VIEW_VOYAGE then
		if self.getVoyageColour(pColour) then
			return;
		endif;
	endif;		
	
	if self.myLocationRestriction &lt;&gt; null then
		pColour := self.myLocationRestriction.getDrawingViewColour(pView);
	endif;
	
/*	if pColour = White then
		if self.numTIs &gt; 0 then
			tmpTI := self.allTrackedItems.first;
			if pView = VIEW_OPERATOR then
				pColour := tmpTI.myOperator.colour;
			elseif pView = VIEW_LOG_GRADE then
				if tmpTI.isKindOf(CM_Log) then
					pColour := tmpTI.CM_Log.myLogGrade.colour;
				endif;
			endif;
		endif;
	endif;
*/	
end;</source>
        <Parameter name="pDisplay" type="Integer"/>
        <Parameter name="pView" type="Integer"/>
        <Parameter name="pHeight" type="Integer"/>
        <Parameter name="pColour" type="Integer" usage="output"/>
        <Parameter name="pLetter" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="5e4156f9-5f02-43e8-a7e4-ba727e4bf197">
        <source>getExtraInfo(dataContainer : CM_DataContainer);
// ---------------------------------------------------------------------------
// Created:		April  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 25 June 2003 sgp			Use CM_DataContainer to hold data
// ---------------------------------------------------------------------------
vars
	_displayMode : Integer;
	block : CM_DataContainerBlock;
	blockArray : CM_DataContainerBlockArray;

	lPercentFull : Decimal[12,2];
	theLogLocRestriction : CM_LocationRestrictLog;
	passport : CM_Passport;
	soh : CM_SOHLocation;
	sohLogs : Integer;
	totLogs : Integer;
	operatorTerminology,
	logsStr : String;
	sohUnscaledLogs : Integer;
	totUnscaledLogs : Integer;
	sohExt : CM_SOHLocationExtLog;
	sohVolume : Decimal[16,4];
	totVolume : Decimal[16,4];
	sohWeight : Decimal[14,4];
	totWeight : Decimal[14,4];
	seds : DecimalArray;
	lens : DecimalArray;
	items : IntegerArray;
	totAverageSED : Decimal[6,2];
	hasAccessRestrictions : Boolean;
	estMaxVolume : Decimal[12,3];
	operCode : String;
	failedDAC  :CM_DataAccessController;
begin
	passport := app.myPassport;
	_displayMode := dataContainer.displayMode;
	
	if (not self.canUserAccessSelf(null, failedDAC, passport)) then
		block := dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(CM_You_Do_Not_Have_Access),DC_Header, 1, null);
		return;
	endif;

	hasAccessRestrictions := (passport.allDataAccessControllers[CM_Operator.name] &lt;&gt; null);

	create blockArray transient;
	create lens transient;
	create seds transient;
	create items transient;

	// sgp 11 June 2003 : Get spec details.  Must be retrieved before the summary to calculate the
	// summary totals as only shows totals for those specs the user has access to see.
	foreach soh in self.allProductLocations do
		if soh.allTrackedItems.isEmpty and
		   soh.allStockOrderAllocations.isEmpty then
			continue;
		endif;
		if not soh.canUserAccessSelf(null, failedDAC, app.myPassport) then
			continue;
		endif;
		
		if soh.myOperator &lt;&gt; null then
			operCode := soh.myOperator.code;
		endif;
		sohLogs := soh.numTIs;
		totLogs := totLogs + sohLogs;
		sohVolume := soh.currentVolume;
		totVolume := totVolume + sohVolume;
		sohWeight := soh.currentWeightKgs;
		totWeight := totWeight + sohWeight;
		if CM_SOHLocationExtLog.hasInstance(soh.myExtension) then
			sohExt := soh.myExtension.CM_SOHLocationExtLog;
			if sohExt &lt;&gt; null then
				sohUnscaledLogs := sohExt.CM_SOHLocationExtLog.numUnscaledLogs;
				totUnscaledLogs := totUnscaledLogs + sohUnscaledLogs;

				lens.add(sohExt.myProductLog.logLength);
				seds.add(sohExt.averageSED);
				items.add(sohExt.countForSEDMean);
			endif;
		endif;
		
		// add the spec details to a local block array so they can be added
		// to the CM_DataContainer after the summary details
		create block transient;
		blockArray.add(block);
		block.addNewItem(operCode &amp; ':' &amp; soh.myProduct.code, DC_Data, 1, null);
		block.addNewItem(sohLogs.String, DC_Data, 1, null);
		block.addNewItem(sohVolume.jasVolumeString, DC_Data, 1, null);
		block.addNewItem(sohWeight.asStringWeightJMT(), DC_Data, 1, null);		
	endforeach;

	totAverageSED := global.calcAverageSEDMeanMixed(lens, seds, items);

	// summary
	theLogLocRestriction := self.myLocationRestriction.CM_LocationRestrictLog;

	block := dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Row_ID), DC_Label, 1, null);
	block.addNewItem(self.id.String, DC_Data, 1, null);

	block := dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Average_SED), DC_Label, 1, null);
	block.addNewItem(totAverageSED.sedString, DC_Data, 1, null);
	
	block := dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_No_Of_Unscaled_Logs), DC_Label, 1, null);
	block.addNewItem(totUnscaledLogs.String, DC_Data, 1, null);
	
	if theLogLocRestriction &lt;&gt; null then
		estMaxVolume := theLogLocRestriction.estimatedMaxVolume;
		block := dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(CM_Est_Max_Volume), DC_Label, 1, null);
		block.addNewItem(estMaxVolume.String, DC_Data, 1, null);
	endif;
	
	if estMaxVolume &lt;&gt; 0 then
		lPercentFull := self.totalVolume / estMaxVolume;
		if lPercentFull &lt; 0 then
			lPercentFull := 0;
		elseif lPercentFull &gt; 100 then
			lPercentFull := 100;
		endif;
	endif;
	block := dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Volume), DC_Label, 1, null);
	block.addNewItem((lPercentFull * 100).String &amp; "%", DC_Data, 1, null);

	block := dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Width), DC_Label, 1, null);
	block.addNewItem(self.myRow.width.String, DC_Data, 1, null);
	
	if theLogLocRestriction &lt;&gt; null then
		block := dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(CM_Comment), DC_Label, 1, null);
		block.addNewItem(theLogLocRestriction.comment, DC_Data, 3, null);
	endif;
	
	// pieces / volume / weight
	block := dataContainer.addNewBlock;
	block.addNewItem("", DC_LabelHeader, 1, null);
	block.addNewItem(app.getErrorString(CM_Pieces), DC_LabelHeader, 1, null);
	block.addNewItem(app.getErrorString(CM_Volume), DC_LabelHeader, 1, null);
	block.addNewItem(app.getErrorString(CM_Weight_Kgs), DC_LabelHeader, 1, null);
	block.addNewItem("", DC_LabelHeader, 1, null);
	block.addNewItem("", DC_LabelHeader, 1, null);
	
	if _displayMode = DISPLAY_MODE_PLAN then
		if hasAccessRestrictions then
			logsStr := "0";
		else
			logsStr := self.numPlannedTIs.String;
		endif;
		logsStr := logsStr &amp; " (Planned View)";
	elseif _displayMode = DISPLAY_MODE_QUEUE then
		if hasAccessRestrictions then
			logsStr := "0";
		else
			logsStr := self.numQueuedTIs.String;
		endif;
		logsStr := logsStr &amp; " (Queued View)";
	else
		logsStr := totLogs.String;
	endif;
	
	block := dataContainer.addNewBlock;
	block.addNewItem("TOTAL  ", DC_Data, 1, null);
	block.addNewItem(logsStr, DC_Data, 1, null);
	block.addNewItem(totVolume.jasVolumeString, DC_Data, 1, null);
	block.addNewItem(totWeight.asStringWeightJMT(), DC_Data, 1, null);
	
	// add the spec details after the summary details
	dataContainer.addMultipleBlocks(blockArray);
	
	// restrictions	
	if theLogLocRestriction &lt;&gt; null and not hasAccessRestrictions then
	
		// sgp 11 June 2003 : display a Restrictions heading
		block := dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(CM_Restrictions), DC_Header, 1, null);

		if theLogLocRestriction.allOperators.size &gt; 0 then
			block := dataContainer.addNewBlock;
			operatorTerminology := app.getTerminologyAlternate(app.myRoot.allCargoTypesById[TI_CargoType_Log], self.myTerminal, CM_TerminologyOperator, CM_TermExpressionSingular, 'Supplier');			
			block.addNewItem(operatorTerminology, DC_Label, 1, null);
			block.addNewItem(theLogLocRestriction.allOperators.first.code.toUpper,
					DC_Data, 1, theLogLocRestriction.allOperators.first);
		endif;

		block := dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(CM_Species), DC_Label, 1, null);
		block.addNewItem(theLogLocRestriction.allLogSpecies.getEntriesAsString, DC_Data, 1, null);

		block := dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(CM_Grades), DC_Label, 1, null);
		block.addNewItem(theLogLocRestriction.allLogGrades.getEntriesAsString, DC_Data, 1, null);

		block := dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(CM_Types), DC_Label, 1, null);
		block.addNewItem(theLogLocRestriction.allLogTypes.getEntriesAsString, DC_Data, 1, null);

		block := dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(CM_Treatments), DC_Label, 1, null);
		block.addNewItem(theLogLocRestriction.allLogTreatments.getEntriesAsString, DC_Data, 1, null);

		block := dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(CM_Lengths), DC_Label, 1, null);
		block.addNewItem(theLogLocRestriction.allLogLengths.getEntriesAsString, DC_Data, 1, null);
	endif;

epilog
	delete blockArray;
	delete lens;
	delete seds;
	delete items;
end;</source>
        <Parameter name="dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
