    <JadeMethod name="setDetails" id="5d87b2cb-203e-443a-be60-97f76284a2ba">
        <source>setDetails();
//14 December 2009	cnwml2
//16 Oct 2023 		navlc30 ChangeRequest 58996: EUP | VBS changes MTN - Adding multiple items at once (From Ticket FR 53429)

vars
	ti: CM_TrackedItem;
	reserveSelection : CM_ReserveSelection;
	release			 : CM_BulkRelease;
begin
	if self.myBookingItem &lt;&gt; null then
		if self.myBookingItem.isKindOf(CM_BRefItemContainer) then
			if self.myBookingItem.isoTypeGroup &lt;&gt; null then
				self.cmbIsoTypeGroup.setObject(self.myBookingItem.CM_BRefItemContainer.getISOTypeGroupObject);
			endif;
			
			if self.myBookingItem.myISOType &lt;&gt; null then
				self.cmbIsoTypes.setObject(self.myBookingItem.myISOType);
			endif;
		endif;
		
		if self.myBookingItem.myBookingReference.myOperator &lt;&gt; null then
			self.cmbOperatorCode.setObject(self.myBookingItem.myBookingReference.myOperator);
		endif;
		
		if self.myBookingItem.myBookingReference.myVoyage &lt;&gt; null then
			self.cmbVoyages.setObject(self.myBookingItem.myBookingReference.myVoyage);
		endif;
		
		if self.myBookingItem.myBookingReference.myConsignee &lt;&gt; null then
			self.cmbConsignees.setObject(self.myBookingItem.myBookingReference.myConsignee);
		endif;
	
	//cnwrd1 18.3.2010 par 21162
	elseif self.myReserveDetail &lt;&gt; null and self.myReserveDetail.isKindOf( CM_ReserveSelection)  then //set details from reserve 
		reserveSelection := self.myReserveDetail.CM_ReserveSelection;

		if reserveSelection.myISOGroup &lt;&gt; null then
			self.cmbIsoTypeGroup.setObject( reserveSelection.myISOGroup  );
		endif;
		
		if reserveSelection.myISOType &lt;&gt; null then
			self.cmbIsoTypes.setObject(reserveSelection.myISOType);
		endif;

		if reserveSelection.myReserveHeader.myOperator &lt;&gt; null then
			self.cmbOperatorCode.setObject(reserveSelection.myReserveHeader.myOperator );
		endif;		
	
		if reserveSelection.myReserveHeader.myVoyage &lt;&gt; null then
			self.cmbVoyages.setObject(reserveSelection.myReserveHeader.myVoyage );
		endif;
		
	elseif self.myContextSearchObject &lt;&gt; null and self.myContextSearchObject.isKindOf(CM_BulkRelease) then			//16.10.2023 navlc30 #58996
		release := self.myContextSearchObject.CM_BulkRelease;

		if release.myISOGroup &lt;&gt; null then
			self.cmbIsoTypeGroup.setObject( release.myISOGroup  );
		endif;
		
		if release.myOperator &lt;&gt; null then
			self.cmbOperatorCode.setObject( release.myOperator );
		endif;		
	
		if release.myVoyage &lt;&gt; null then
			self.cmbVoyages.setObject(release.myVoyage );
		endif;
	else
		//jlier1 JIRA- 36572 23/1/26
		if self.myOperator &lt;&gt; null then
			self.cmbOperatorCode.setObject(self.myOperator);
		endif;
		if self.myTerminalArea &lt;&gt; null then
			self.txtLocation.setValue(self.myTerminalArea.id);
		endif;
	endif;
	
epilog

end;</source>
    </JadeMethod>
