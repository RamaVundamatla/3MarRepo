    <JadeMethod name="getSelectorQueryByName" id="e302eff3-4528-41cb-ae67-44ea75247cc8">
        <source>getSelectorQueryByName(_queryname : String) : CM_MenuUserQuery;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 04/10/2019	jlgdap1		Initial creation TFS 46315 JMT Proforma Report Issue
//
vars
	menuEntity : CM_MenuEntity;

begin
	foreach menuEntity in app.myRoot.myQueryMenuRoot.allChildren do
		if menuEntity.getHeading = _queryname then
			return menuEntity.CM_MenuUserQuery;
		endif;
		
		return self.doGetUserQueryFromName(menuEntity, _queryname);
	endforeach;
epilog

end;</source>
