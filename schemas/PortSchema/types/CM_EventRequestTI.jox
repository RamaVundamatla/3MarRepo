    <JadeMethod name="validateMe" id="e3cb9135-2802-473e-9019-28cef8e8023a">
        <source>validateMe(_passport: CM_Passport input);
//--------------------------------------------------
// Created:	19 April 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod(_passport);
	if self.myCargoType = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'Cargo Type', ETRow_MyCargoType, null);
		app.raiseCMException(Input_required_field_cargoType, ETRow_MyCargoType, null); // cnwdb2	PAR 35364
	endif;
	if self.cargoId = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Cargo Id', ETRow_CargoId, null);
		app.raiseCMException(Input_required_field_cargoId, ETRow_CargoId, null); // cnwdb2	PAR 35364
	endif;
	
	if self.cargoId.length &gt; TrackedItemID_Length then
		app.raiseCMException2(ContainerIdToLong,  self.cargoId, TrackedItemID_Length.String, ETRow_CargoId, null);	
	endif;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
