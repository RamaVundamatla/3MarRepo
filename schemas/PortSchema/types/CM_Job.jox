			app.myEventManager.createSingleObjInfoNoteEvt(self, self.myJobSheetForWorkOrder.myTerminal.getTerminalEvent(WorkOrderJob_Update_Event),  self);
		elseif oldWorkPointJobSheet &lt;&gt; null then
			app.myEventManager.createSingleObjInfoNoteEvt(self, oldWorkPointJobSheet.myTerminal.getTerminalEvent(WorkOrderJob_Update_Event),  self);
		endif;
