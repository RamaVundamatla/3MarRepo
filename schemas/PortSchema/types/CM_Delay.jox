        <source>startDT(set : Boolean; _value : TimeStamp io) mapping;
// ---------------------------------------------------------------------------
// Created:     04 December 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if set and self.myEventStart &lt;&gt; null then
		self.myEventStart.setDateTime(_value);
	endif;
end;</source>
