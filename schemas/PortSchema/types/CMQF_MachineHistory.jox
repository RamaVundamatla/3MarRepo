        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyMachine" id="03607108-45c7-470d-ad98-f7a6fb767198">
        <source>getMyMachine():CM_Machine;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 July 2016	cnwndl1	Initial creation	TFS 2329

*/

vars

	object : CM_Machine;
	edition : Integer;
	invalidObj : Boolean;

begin

	object := self.myMachine;

	if object = null then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject( exception, object, invalidObj );
	edition := object.edition;
	
	if invalidObj then
		return null;
	endif;
	
	return object;

epilog

end;</source>
        <ReturnType type="CM_Machine"/>
    </JadeMethod>
    <JadeMethod name="getMyMachineType" id="216e17f1-a0f5-4873-a4a0-96133eff82fd">
        <source>getMyMachineType():CM_MachineType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 July 2016	cnwndl1	Initial creation	TFS 2329

*/

vars

	object : CM_MachineType;
	edition : Integer;
	invalidObj : Boolean;

begin

	object := self.myMachineType;

	if object = null then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject( exception, object, invalidObj );
	edition := object.edition;
	
	if invalidObj then
		return null;
	endif;
	
	return object;

epilog

end;</source>
        <ReturnType type="CM_MachineType"/>
    </JadeMethod>
    <JadeMethod name="getOIDAndDescForAttribute" id="fb26a209-4826-40cc-aa57-f7f89a288387">
        <source>getOIDAndDescForAttribute(_attrName: String; _getCalculatedDate: Boolean; _oid: String output): String;
// ---------------------------------------------------------------------------
// Created:     01 November 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	delay 			: CM_DelayType;
	delayTypeGroup 	: CM_DelayTypeGroup;
	machine 		: CM_Machine;
	machineType 	: CM_MachineType;
	machineOperator : CM_User;
	
begin
	if _attrName = ETRow_DelayType then
		return self.getDelayTypeCriteria();
	elseif _attrName = ETRow_DelayTypeGroup then
		return self.getDelayTypeGroupCriteria();
	elseif _attrName = ETRow_Machine then
		machine := self.getMyMachine;
		if machine &lt;&gt; null then
			_oid := machine.getOidAsString();
			return machine.description;
		endif;
	elseif _attrName = ETRow_MachineType then
		machineType := self.getMyMachineType;
		if machineType &lt;&gt; null then
			_oid := machineType.getOidAsString();
			return machineType.description;
		endif;
	elseif _attrName = ETRow_MachineOperator then
		machineOperator := self.myUser;
		if machineOperator &lt;&gt; null then
			_oid := machineOperator.getOidAsString();
			return machineOperator.code;
		endif;
	elseif _attrName = ETRow_StartTime then
		if self.startTime.isValid() then
			return self.startTime.asStringJMT();
		else
			return null.Time.asStringJMT;
		endif;
	elseif _attrName = ETRow_EndTime then
		if self.endTime.isValid() then
			return self.endTime.asStringJMT();
		else
			return null.Time.asStringJMT;
		endif;
	else
		return inheritMethod(_attrName, _getCalculatedDate, _oid);
	endif;
	
	

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_getCalculatedDate" type="Boolean"/>
        <Parameter name="_oid" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="kpiGenerate" id="27ba7a60-c22b-4424-b058-addcc50ca0a3">
        <updating/>
        <source>kpiGenerate(_tsFrom, _tsTo, _tsShiftsFrom, _tsShiftsTo:TimeStamp; _shifts :CM_ShiftStartDateCodeDict; _terminal :CM_Terminal; _machine :CM_Machine; 
			_historyColl :Collection input; _dateColl :CM_KPIMachineByDateUserDict input; _shiftColl :CM_KPIMachineByShiftUserDict input;
			_garbage :ObjectSet input)updating, protected;
// ---------------------------------------------------------------------------
// Created:     04 November 2010 by cnwcs5
// Purpose:     
// Parameters:  _tsFrom, _tsTo				- date/time range parameter
//				_tsShiftsFrom, _tsShiftsTo	- period covered by shifts that started within above date/time range
//				_shifts						- shifts that started within above date/time range
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	firstTS, lastTS	:TimeStamp;
	iter			:Iterator;
	history			:CM_MachineHistory;
	moveHistory		:CM_MachineMoveHistory;
	userID			:String;
	type			:Integer;
	kpiDate			:CM_KPIMachineDateUser;
	kpiShift		:CM_KPIMachineShiftUser;
	shift			:CM_Shift;
	delays			:CM_DelayByStartDTDict;
	delay			:CM_Delay;
	date			:Date;
begin
	// the range for date kpi may be different to the range for shift Kpi
	if _tsShiftsFrom &lt; _tsFrom then
		firstTS := _tsShiftsFrom;
	else
		firstTS	:= _tsFrom;
	endif;
	if _tsShiftsTo &gt; _tsTo then
		lastTS := _tsShiftsTo;
	else
		lastTS	:= _tsTo;
	endif;
	
	if self.myUser &lt;&gt; null then
		userID := self.myUser.code;
	endif;
	
	iter 	:= _machine.history.createIterator;
	_machine.history.startKeyGeq (firstTS, iter);
	
	while iter.next (history) do 
		if history.dateTime &gt; lastTS then
			// past our range
			break;
		endif;

		if userID &lt;&gt; null and history.userId &lt;&gt; userID then
			// not for the right user
			continue;
		endif;
		
		// history collection contains everything within time period
		if history.dateTime &gt;= firstTS and
			history.dateTime &lt;= lastTS then
			_historyColl.add (history);
		endif;
		
		type := history.type;
		
		if type = CM_MachineHistory.Type_RejectMove  or 
			type = CM_MachineHistory.Type_Move or
			type = CM_MachineHistory.Type_PickUp or
			type = CM_MachineHistory.Type_SetDown then
			
			moveHistory := history.CM_MachineMoveHistory;

			if history.dateTime &gt;= _tsFrom and history.dateTime &lt;= _tsTo then
				// update KPI daily figures 
				kpiDate := self.kpiGetDateUserKPI (_terminal, _machine, history.dateTime.date, history.userId, _dateColl, _garbage);
		
				kpiDate.updateForMoveHistory (moveHistory);
			endif;
			
			if not _shifts.isEmpty and history.dateTime &gt;= _tsShiftsFrom and history.dateTime &lt;= _tsShiftsTo then
				// update KPI figures for shift
				shift := _shifts.getAtKeyLeq (history.dateTime, null);
				
				kpiShift := self.kpiGetShiftUserKPI (_terminal, _machine, history.userId, shift,_shiftColl, _garbage);
				
				kpiShift.updateForMoveHistory (moveHistory);
			endif;
		elseif type = CM_MachineHistory.Type_LogOn or type = CM_MachineHistory.Type_LogOff then
			if history.dateTime &gt;= _tsFrom and history.dateTime &lt;= _tsTo then
				// update KPI daily figures 
				kpiDate := self.kpiGetDateUserKPI (_terminal, _machine, history.dateTime.date, history.userId, _dateColl, _garbage);
		
				kpiDate.updateForLogonLogoff (history.CM_MachineLogOnOffHistory);
			endif;
			
			if not _shifts.isEmpty and history.dateTime &gt;= _tsShiftsFrom and history.dateTime &lt;= _tsShiftsTo then
				// update KPI figures for shift
				shift := _shifts.getAtKeyLeq (history.dateTime, null);
				
				kpiShift := self.kpiGetShiftUserKPI (_terminal, _machine, history.userId, shift,_shiftColl, _garbage);
				
				kpiShift.updateForLogonLogoff (history.CM_MachineLogOnOffHistory);
			endif;
		endif;
			
	endwhile; 
	
	delete iter;
	
	// now do the delays - note re-using the userID local variable
	create delays transient;
	self.kpiGetDelays (firstTS, lastTS, _machine, delays);

	foreach delay in delays do
		if delay.myDriver &lt;&gt; null then
			userID := delay.myDriver.code;
		else
			userID := CM_MachineHistory.Unknown_Value;
		endif;
		
		// update kpis for dates that delay spans first
		foreach date in _tsFrom.date to _tsTo.date step 1 do
			if delay.endDT &lt;&gt; null and delay.endDT.date &lt; date then
				// no need to look at any other future dates
				break;
			endif;
			
			if delay.startDT &gt;= _tsTo or
				(delay.endDT &lt;&gt; null and delay.endDT &lt;= _tsFrom) then
				// delay did not span the date time range - maybe it was for a shift that started on this day
				continue;
			endif;
			if delay.startDT.date &gt; date then
				// not for this day
				continue;
			endif;
			
			if delay.myDriver &lt;&gt; null then
				kpiDate := self.kpiGetDateUserKPI (_terminal, _machine, date, userID, _dateColl, _garbage);
							
				kpiDate.updateForDelay (delay);
			else
				// delay affects all drivers for machine
				iter := _dateColl.createIterator;
				
				_dateColl.startKeyGeq (_terminal, _machine, date, null, iter);
				
				while iter.next (kpiDate) do
					if kpiDate.myTerminal &lt;&gt; _terminal or
						kpiDate.myMachine &lt;&gt; _machine or
						kpiDate.date &lt;&gt; date then
						break;
					endif;
					kpiDate.updateForDelay (delay);
				endwhile;
				delete iter;
			endif;
			
		endforeach;
		// update shift kpis
		foreach shift in _shifts do
			if delay.startDT &gt;= shift.endDateTime or
				(delay.endDT &lt;&gt; null and delay.endDT &lt;= shift.startDateTime) then
				// delay did not span shift
				continue;
			endif;
			
			if delay.myDriver &lt;&gt; null then
				kpiShift := self.kpiGetShiftUserKPI (_terminal, _machine, userID, shift,_shiftColl, _garbage);
				
				kpiShift.updateForDelay (delay);
			else
				// delay affects all drivers for machine
				iter := _shiftColl.createIterator;
				
				_shiftColl.startKeyGeq (_terminal, _machine, shift, null, iter);
				
				while iter.next (kpiShift) do
					if kpiShift.myTerminal &lt;&gt; _terminal or
						kpiShift.myMachine &lt;&gt; _machine or
						kpiShift.myShift &lt;&gt; shift then
						break;
					endif;
					kpiShift.updateForDelay (delay);
				endwhile;
				delete iter;
			endif;
		endforeach;
	endforeach;

	// now we have all the delays we need to update the net working/running times
	foreach kpiDate in _dateColl do
		kpiDate.calculateNetRunningTime;
		kpiDate.calculateNetWorkingTime;
	endforeach;
	
	foreach kpiShift in _shiftColl do
		kpiShift.calculateNetRunningTime;
		kpiShift.calculateNetWorkingTime;
	endforeach;
epilog
	delete delays;
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_tsFrom" type="TimeStamp"/>
        <Parameter name="_tsTo" type="TimeStamp"/>
        <Parameter name="_tsShiftsFrom" type="TimeStamp"/>
        <Parameter name="_tsShiftsTo" type="TimeStamp"/>
        <Parameter name="_shifts" type="CM_ShiftStartDateCodeDict"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_machine" type="CM_Machine"/>
        <Parameter name="_historyColl" type="Collection" usage="input"/>
        <Parameter name="_dateColl" type="CM_KPIMachineByDateUserDict" usage="input"/>
        <Parameter name="_shiftColl" type="CM_KPIMachineByShiftUserDict" usage="input"/>
        <Parameter name="_garbage" type="ObjectSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="kpiGetDateUserKPI" id="ffda78b6-55d6-46b5-ab17-ea0b25ed0c9b">
        <source>kpiGetDateUserKPI(_terminal :CM_Terminal; _machine :CM_Machine; _date :Date; _user :String; 
				_dateColl :CM_KPIMachineByDateUserDict input;_garbage :ObjectSet input):CM_KPIMachineDateUser protected;
// ---------------------------------------------------------------------------
// Created:     08 November 2010 by cnwcs5 par 23714/ccms 1132
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	kpiDate :CM_KPIMachineDateUser;
	
begin
	if _user = null then	// 22/09/2014 cnwar2 #34931
		kpiDate := _dateColl[_terminal, _machine, _date, CM_MachineHistory.Unknown_Value];
	else
		kpiDate := _dateColl[_terminal, _machine, _date, _user];
	endif;
	
	if kpiDate = null then
		if _dateColl.isTransient then
			create kpiDate as CM_KPIMachineDateUser transient;
			
			_garbage.add (kpiDate);
		else
			create kpiDate as CM_KPIMachineDateUser;
		endif;
		kpiDate.setDate (_date);
		kpiDate.setUserId (_user);
		kpiDate.setMachine (_machine);
		kpiDate.setTerminal (_terminal);
		
		_dateColl.add (kpiDate);
	endif;
	
	return kpiDate;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_machine" type="CM_Machine"/>
        <Parameter name="_date" type="Date"/>
        <Parameter name="_user" type="String"/>
        <Parameter name="_dateColl" type="CM_KPIMachineByDateUserDict" usage="input"/>
        <Parameter name="_garbage" type="ObjectSet" usage="input"/>
        <ReturnType type="CM_KPIMachineDateUser"/>
    </JadeMethod>
    <JadeMethod name="kpiGetDelays" id="4cc8a16c-ffca-41bb-a468-b5efda3773ff">
        <source>kpiGetDelays(_startTS, _endTS :TimeStamp; _machine :CM_Machine; _coll :CM_DelayByStartDTDict input) protected;
// ---------------------------------------------------------------------------
// Created:     16 November 2010 by cnwcs5
// Purpose:     Get all the delays that were active during a time period.
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	delay			:CM_Delay;
	thisType		:CM_DelayType;
	userID			:String;
	delayTypeGroup	:CM_DelayTypeGroup;
	match			:Boolean;
	delayTypeColl	:CM_DelayTypeSet;
	delayTypeGroupColl	:CM_DelayTypeGroupSet;
	checkTypes,
	checkGroups		:Boolean;
begin
	if self.myUser &lt;&gt; null then
		userID		:= self.myUser.code;
	endif;
	
//	delayTypeColl		:= self.allDelayTypes;
//	delayTypeGroupColl	:= self.allDelayTypeGroups;

	//18 July 2016	NDL	TFS 2329
	create delayTypeColl transient;
	create delayTypeGroupColl transient;	
	if not self.allDelayTypes.isEmpty then
		self.allDelayTypes.copy( delayTypeColl );
		delayTypeColl.removeInvalidObjects();
	endif;
	if not self.allDelayTypeGroups.isEmpty then
		self.allDelayTypeGroups.copy( delayTypeGroupColl );
		delayTypeGroupColl.removeInvalidObjects();
	endif;
	
	checkTypes			:= not delayTypeColl.isEmpty;
	checkGroups			:= not delayTypeGroupColl.isEmpty;

	foreach delay in _machine.allDelays  discreteLock do 
		if delay.startDT &gt;= _endTS or
			(delay.endDT &lt;&gt; null and delay.endDT.isValid and delay.endDT &lt;= _startTS) then 
			// outside the range we are interested in 
			continue;
		endif;
		
		thisType := delay.myDelayType;
		
		if checkTypes and not delayTypeColl.includes (thisType) then 
			continue;
		endif;
		
		if checkGroups then
			match := false;
			
			foreach delayTypeGroup in thisType.allDelayTypeGroups do
				if delayTypeGroupColl.includes (delayTypeGroup) then
					// there is a match
					match := true;
					break;
				endif;
			endforeach;
			
			if not match then 
				continue;
			endif;
		endif;
		
		if userID &lt;&gt; null and delay.myDriver &lt;&gt; null and delay.myDriver.code &lt;&gt; userID then 
			continue;
		endif;
		
		_coll.add (delay);	
	endforeach; 
	
epilog

	//18 July 2016	NDL	TFS 2329
	delete delayTypeColl;
	delete delayTypeGroupColl;

end;</source>
        <access>protected</access>
        <Parameter name="_startTS" type="TimeStamp"/>
        <Parameter name="_endTS" type="TimeStamp"/>
        <Parameter name="_machine" type="CM_Machine"/>
        <Parameter name="_coll" type="CM_DelayByStartDTDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="kpiGetShiftUserKPI" id="42c06549-60f7-4f62-8f12-1f0999e70ddd">
        <source>kpiGetShiftUserKPI(_terminal :CM_Terminal; _machine :CM_Machine; _user :String; 
				_shift :CM_Shift; _shiftColl :CM_KPIMachineByShiftUserDict input;
				_garbage :ObjectSet input):CM_KPIMachineShiftUser protected;
// ---------------------------------------------------------------------------
// Created:     10 November 2010 by cnwcs5 par 23714/ccms 1132
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	kpiShift :CM_KPIMachineShiftUser;
	
begin
	if _user = null then	// 22/09/2014 cnwar2 #34931
		kpiShift := _shiftColl[_terminal, _machine, _shift, CM_MachineHistory.Unknown_Value];
	else
		kpiShift := _shiftColl[_terminal, _machine, _shift, _user];
	endif;
	
	if kpiShift = null then
		if _shiftColl.isTransient then
			create kpiShift as CM_KPIMachineShiftUser transient;
			
			_garbage.add (kpiShift);
		else
			create kpiShift as CM_KPIMachineShiftUser;
		endif;
		kpiShift.setShift (_shift);
		kpiShift.setUserId (_user);
		kpiShift.setMachine (_machine);
		kpiShift.setTerminal (_terminal);
		
		_shiftColl.add (kpiShift);
	endif;
	
	return kpiShift;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_machine" type="CM_Machine"/>
        <Parameter name="_user" type="String"/>
        <Parameter name="_shift" type="CM_Shift"/>
        <Parameter name="_shiftColl" type="CM_KPIMachineByShiftUserDict" usage="input"/>
        <Parameter name="_garbage" type="ObjectSet" usage="input"/>
        <ReturnType type="CM_KPIMachineShiftUser"/>
    </JadeMethod>
    <JadeMethod name="kpiGetShiftsForDateRange" id="737eadb4-0671-473a-8bde-f6e6fd5c9520">
        <source>kpiGetShiftsForDateRange(_terminal :CM_Terminal; _tsFrom, _tsTo :TimeStamp; 
						_shifts :CM_ShiftStartDateCodeDict input; _garbage :ObjectSet input;
						_shiftsStartTS, _shiftsEndTS :TimeStamp output) protected;
// ---------------------------------------------------------------------------
// Created:     11 November 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     _shiftsStartTS, _shiftsEndTS - timeperiod covered by shifts
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	shift	:CM_Shift;
begin
	_shiftsStartTS	:= _tsFrom;
	_shiftsEndTS	:= _tsTo;
	
	// Get all the transient shifts for the date range
	_terminal.getShiftsFromRange(_shifts, _tsFrom, _tsTo);
	
	// we are only interested in the shifts that start within our date range
	// it's possible the collection contains shifts that overlap the start date/time
	foreach shift in _shifts do
		if shift.startDateTime &lt; _tsFrom then
			_shifts.remove (shift);
			
			delete shift;
			continue;
		endif;
	endforeach;
	
	shift := _shifts.first;
	
	if shift &lt;&gt; null then
		_shiftsStartTS := shift.startDateTime;
	endif;
	
	shift := _shifts.last;
	
	if shift &lt;&gt; null then
		_shiftsEndTS := shift.endDateTime;
	endif;
	
	
	_shifts.copy (_garbage);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_tsFrom" type="TimeStamp"/>
        <Parameter name="_tsTo" type="TimeStamp"/>
        <Parameter name="_shifts" type="CM_ShiftStartDateCodeDict" usage="input"/>
        <Parameter name="_garbage" type="ObjectSet" usage="input"/>
        <Parameter name="_shiftsStartTS" type="TimeStamp" usage="output"/>
        <Parameter name="_shiftsEndTS" type="TimeStamp" usage="output"/>
    </JadeMethod>
    <JadeMethod name="setDefaultStartEndDates" id="1fabc501-95aa-4851-8a1c-70ee2a39c5f5">
        <updating/>
        <source>setDefaultStartEndDates(_startTS: TimeStamp output; _endTS: TimeStamp output) updating;
// ---------------------------------------------------------------------------
// Created:     08 November 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(_startTS, _endTS);
	
	if self.startTime &lt;&gt; null then
		_startTS.setTime (self.startTime);
	else
		_startTS.setTime (null);
	endif;
	
	if self.endTime &lt;&gt; null then
		_endTS.setTime (self.endTime);
	else
		_endTS.setTime ('23:59:99.999'.Time);
	endif;
epilog

end;</source>
        <Parameter name="_startTS" type="TimeStamp" usage="output"/>
        <Parameter name="_endTS" type="TimeStamp" usage="output"/>
    </JadeMethod>
