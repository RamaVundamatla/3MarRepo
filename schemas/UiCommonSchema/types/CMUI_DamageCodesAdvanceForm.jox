    <JadeMethod name="setupForm" id="76911ddd-1b7c-4e6c-9e8d-8f3c78201fa7">
        <updating/>
        <source>setupForm() updating;
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 28 April 2009
//
// Implemented version:
// 
/* Changes

Date		Name	TFS#	Description
============================================================================
09/05/2019	jlgka1	44287	Set the minimumHeight and minimumWidth for resizing.
06 July 2022	navak20	TFS 53862 EUP - WMS - Damage Recording Extra Details
07 Nov 2022	navak20 Bug 55274: MTN - Damage Date/Time not showing current date/time as defaultr
27 September 2023	navcs2	ChangeRequest 60694: EUP | FR 54536 - Damage and Repair Thin Client UI changes
11 Feb 2025	navnk30	JIRA 34025: CUX | Add Damage - Add Photo Button Issue on Cargo Receival forms
============================================================================*/
vars
	tbl : CM_Table;
	notReadOnly : Boolean;
	dateTime : TimeStamp;	// 07.11.2022 navak20 TFS 55274
begin
	notReadOnly := (self.mode = Mode_Add) or (self.mode = Mode_Update);
	
	inheritMethod();
	
	//epr par 31845 24/10/13	
	if self.myParentForm.class.implementsInterface(IF_DamageDetails) then
		self.myDamageInterface:=self.myParentForm.IF_DamageDetails;
	endif;
	
	/* Start 02.08.2022 navak20 TFS 53862
	// jlgka1 TFS 44287 --&gt;
	self.minimumHeight := 470;
	self.minimumWidth := 460;
	// jlgka1 TFS 44287 &lt;--
	*/
	
	self.enableDisableRepairField(false);		// 06.07.2022 navak20 TFS 53862
	self.handleMenusForModalDisplay();	
	self.initCombos();
	self.initDamageTable();
	self.btnUpdate.enabled := false;
	self.btnRemove.enabled := false;
	
	self.btnAddImage.visible := (self.myProxyMasterItem &lt;&gt; null and self.myProxyMasterItem.isKindOf(CM_TrackedItem)) or	//11.02.2025 navnk30 JIRA 34025
								(self.myRealMasterItem &lt;&gt; null and self.myRealMasterItem.isKindOf(CM_TrackedItem));
	
	//Start 07.11.2022 navak20 TFS 55274
	dateTime := self.systemToLocalTime(app.actualTimeServer);
	self.damageDate.setDate(dateTime.date());
	self.damageTime.setTime(dateTime.time());
	//End 07.11.2022 navak20 TFS 55274
	
	self.loadDamageItems();
	
	self.btnNew.enabled := notReadOnly;			// 02.08.2022 navak20 TFS 53862
	self.btnAdd.enabled := notReadOnly;
	
	self.cmbDamage.enabled := notReadOnly;
	self.cmbPosition.enabled := notReadOnly;
	self.cmbSeverity.enabled := notReadOnly;
	self.txtQuantity.enabled := notReadOnly;
	self.optNo.enabled := notReadOnly;
	self.optYes.enabled := notReadOnly;
	self.optYes.value := true;
	self.txtDamageRemarks.enabled := notReadOnly;
	
	self.cmbStatus.enabled := notReadOnly;			// July 6, 2022 navak20 TFS 53862
	self.cmbResponsible.enabled := notReadOnly;		// July 6, 2022 navak20 TFS 53862
	self.cmbLocation.enabled := notReadOnly;		// July 6, 2022 navak20 TFS 53862
	self.txtSize.enabled := notReadOnly;			// July 6, 2022 navak20 TFS 53862
	self.cmbDamageReason.enabled := notReadOnly;	// July 6, 2022 navak20 TFS 53862	
	self.txtDamageRemarks.enabled := notReadOnly;	// July 6, 2022 navak20 TFS 53862
	self.damageDate.enabled := notReadOnly;			// July 6, 2022 navak20 TFS 53862
	self.damageTime.enabled := notReadOnly;			// July 6, 2022 navak20 TFS 53862
	if self.txtQuantity.text = null then
		self.txtQuantity.text := 1.String;			// 02.08.2022 navak20 TFS 53862
	endif;
	//+ cnwmd1 Par 23522 - Allow for view only
	if self.mode = Mode_View then
		self.btnOk.visible := false;
		self.btnCancel.caption := app.getErrorString(Close);
	else
		self.btnOk.visible := true;
		self.btnCancel.caption := app.getErrorString(Cancel);
		if self.mode = Mode_Update then
			self.btnOk.caption := app.getErrorString(CM_OK);
		else
			self.btnOk.caption := app.getErrorString(SAVE_THAT_LADY_YO);
		endif;
	endif;
	
	/* Start 02.08.2002 navak20 TFS 53862
	if self.myProxyMasterItem.isKindOf(CM_Bulk) then
		self.lblQuantity.visible:=false;
		self.txtQuantity.visible:=false;
	endif;
	End 02.08.2002 navak20 TFS 53862 */
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.frmControls.enabled:= false;
	endif;
	
	if self.myProxyMasterItem = null or self.tblDamage.rows = 1 then	// 27/09/2023 navcs2 ChangeRequest 60694
		self.btnAdd.enabled := true;									// 27/09/2023 navcs2 ChangeRequest 60694
	else																// 27/09/2023 navcs2 ChangeRequest 60694
		self.btnAdd.enabled := false;									// 27/09/2023 navcs2 ChangeRequest 60694
	endif;																// 27/09/2023 navcs2 ChangeRequest 60694
	
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="tblDamage_click" id="a4d9fba1-b24d-451a-9ad2-b703c12b9e82">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblDamage_click(table: Table input) updating;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		31 July 2009
//
// Implemented version: JMT 7.7.3
// Date  		User  		Change
// 31/07/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
// 27 September 2023	navcs2	ChangeRequest 60694: EUP | FR 54536 - Damage and Repair Thin Client UI changes
//----------------------------------------------------------------------
vars

begin
	self.displaySelectedItem();
	
	if self.myProxyMasterItem = null or self.tblDamage.rows = 1 then	// 27/09/2023 navcs2 ChangeRequest 60694
		self.btnAdd.enabled := true;									// 27/09/2023 navcs2 ChangeRequest 60694
	else																// 27/09/2023 navcs2 ChangeRequest 60694
		self.btnAdd.enabled := false;									// 27/09/2023 navcs2 ChangeRequest 60694
	endif;																// 27/09/2023 navcs2 ChangeRequest 60694
epilog
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
