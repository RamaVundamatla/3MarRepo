    <JadeMethod name="getTypeDescr" id="f3ce5709-2421-4d98-bf08-ef8bfc5eac2c">
        <source>getTypeDescr() : String;
/*
----------   ----------  --------------------------------------------------
Created:	30 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if self.tagType = self.TagType_ICODE then
		return self.TagType_IOCDE_Str;
	elseif self.tagType = self.TagType_ISO15693 then
		return self.TagType_ISO15693_Str;
	elseif self.tagType = self.TagType_Mifare then
		return self.TagType_Mifare_Str;
	elseif self.tagType = self.TagType_PICO then
		return self.TagType_PICO_Str;
	endif;

end;








</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="populateSelfFromStr" id="7d5af29c-74ba-48a6-8949-1f5de022c09c">
        <updating/>
        <source>populateSelfFromStr() : Boolean updating;
/*
----------   ----------  --------------------------------------------------
Created:	29 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	startPos,
	endMsg,
	startMsg			: Integer;
begin
	startPos := 1;
	startMsg := self.outputString.pos(self.Msg_Begin_Delimiter, startPos);
	if startMsg &lt; 1 then
		app.writeLog('Error: Begin delimiter not found in message (' &amp; self.outputString &amp; ')', LogINFO);
		return false;
	endif;

	
	if self.outputString.length &lt; startMsg + 16 then
		app.writeLog('Error: Unexpected message length (' &amp; self.outputString &amp; ') begin char found at position ' &amp; startMsg.String &amp; 
					' but message length needs to be at least ' &amp; (startMsg + 16).String, LogINFO);
		return false;
	endif;
	
	self.serialNumber 	:= self.outputString[startMsg + 1:16];
	//self.separationChar := self.outputString[startPos + 16:1].Character;
	//self.constant0000h 	:= self.outputString[startPos + 17:4];
	//self.tagType 		:= self.outputString[startPos + 22:1].Integer;
	//self.startChar 	:= self.outputString[startPos:1].Character;
	//self.endChar		:= self.outputString[startPos + 23:1].Character;
	//self.checksumChar	:= self.outputString[25:1].Character;
	
	return true;
	
	
end;





</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
