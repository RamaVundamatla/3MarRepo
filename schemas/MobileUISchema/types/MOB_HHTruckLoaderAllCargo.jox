    <JadeMethod name="processCargoFromScan" id="26d849fe-6e57-4d4f-876f-b88c81596294">
        <updating/>
        <source>processCargoFromScan() protected, updating;
/*

Purpose:			

Parameters:			Do everything all in one shot if we can.

Return Value:		

Date		Who		Reason
26 May 2016	cnwndl1	Initial creation	TFS 1593
10 Aug 2016	NDL		Allow for partial searches TFS 2511

*/

vars

	cargoId : String;
	ti : CM_TrackedItem;
	iter : Iterator;
	msg : String;
	//tiSet : CM_TISet;
	wleArray : CM_WLEArray;
	wle : CM_WorkListEntry;
	wleToUse : CM_WorkListEntry;
	delReq : CM_DeliveryRequest;
	reserveDetail : CM_ReserveDetail;
	reason : String;
	lc : CM_LocationsController;
	moveController : CMIF_MoveController;
	result : Integer;
	truck : CM_Vehicle;
	checksSubCargo : CM_TrackedItem;
	
	tiArray : CM_TIArray;	//10 Aug 2016	NDL Allow for partial searches TFS 2511
	cargoIdLength : Integer;	//10 Aug 2016	NDL Allow for partial searches TFS 2511
	cargoIdReversed : String;	//10 Aug 2016	NDL Allow for partial searches TFS 2511
	firstTi : CM_TrackedItem;	//10 Aug 2016	NDL Allow for partial searches TFS 2511
	term : CM_Terminal;	//10 Aug 2016	NDL Allow for partial searches TFS 2511

begin

//	if not self.allowDirectScan then
	if self.allowDirectScan = 0 then	//16 Dec 2016	NDL	TFS 3129
		return;
	endif;
	
	truck := self.myMobileGenericAgent.myTruck;
	
	cargoId := self.txtScanTxt.text.trimBlanks;
	if cargoId = null or cargoId = self.lblScanTxt.caption.toUpper then
		return;
	endif;

	//10 Aug 2016	NDL Allow for partial searches TFS 2511 - complete new block of code
	create tiArray transient;
	
	cargoIdLength := cargoId.length;
	cargoIdReversed := cargoId.reverse;
	term := self.myMobileDataAgent.myTerminal;
	
	//Exact match only for whole id
	firstTi := term.allOnsiteTIsByIdCargoType.getAtKey(cargoId,null);
	if firstTi &lt;&gt; null and firstTi.id[1:cargoIdLength] = cargoId then
		iter := term.allOnsiteTIsByIdCargoType.createIterator;
		iter.startAtObject(firstTi);
		while iter.next( ti ) do
			if ti.id[1:cargoIdLength] &lt;&gt; cargoId then
				break;
			endif;
			if ti.id &lt;&gt; cargoId then
				//to select, must be an exact match
				continue;
			endif;
			//01 May 2018 NDL TFS 38417 - Apparently we should ignore any cargo already on a truck
			if ti.myPrimaryActualLocation.isVehicle
			or ti.myPrimaryActualLocation.isTILCController
			then
				continue;
			endif;
			
			tiArray.addExclusive(ti);
		endwhile;
		delete iter;
	endif;
	
	//Allow for partial searches matching on the last 'n' chars
	//Try reverse 'cargoId' as any piece of the id
	if tiArray.isEmpty then
		firstTi := term.allOnsiteTIsByIdCargoTypeRev.getAtKeyGeq(cargoIdReversed,null);
		if firstTi &lt;&gt; null and firstTi.idReversed[1:cargoIdLength] = cargoIdReversed then
			iter := term.allOnsiteTIsByIdCargoTypeRev.createIterator;
			iter.startAtObject(firstTi);
			while iter.next( ti ) do
				if ti.idReversed[1:cargoIdLength] &lt;&gt; cargoIdReversed then
					break;
				endif;
				//01 May 2018 NDL TFS 38417 - Apparently we should ignore any cargo already on a truck
				if ti.myPrimaryActualLocation.isVehicle
				or ti.myPrimaryActualLocation.isTILCController
				then
					continue;
				endif;
				tiArray.addExclusive(ti);
			endwhile;
			delete iter;
		endif;
	endif;
	
	//Still nothing try an exact match on the alternate id
	if tiArray.isEmpty then
		firstTi := term.allOnsiteTIsByAlternativeId.getAtKey(cargoId);
		if firstTi &lt;&gt; null and firstTi.alternativeId = cargoId then	
			iter := term.allOnsiteTIsByAlternativeId.createIterator;
			iter.startAtObject(firstTi);
			while iter.next( ti ) do
				if ti.alternativeId &lt;&gt; cargoId then
					break;
				endif;
				//01 May 2018 NDL TFS 38417 - Apparently we should ignore any cargo already on a truck
				if ti.myPrimaryActualLocation.isVehicle
				or ti.myPrimaryActualLocation.isTILCController
				then
					continue;
				endif;
				tiArray.addExclusive(ti);
			endwhile;
			delete iter;
		endif;
	endif;
		
	if tiArray.size = 1 then
		// found just one, all good...
		ti := tiArray.first;
	elseif tiArray.size &gt; 1 then
		msg := app.getErrorString1( UniqueIdRequired, cargoId.trimBlanks);
		return;
	else
		msg := app.getErrorString1(Cargo_item_not_found_site, cargoId.trimBlanks);
		return;
	endif;

	
	//OK we have a unique piece of cargo, now find the first existing Road Wle for the truck that we match.
	wleArray := self.myMobileGenericAgent.allWlesToLoad;
	if wleArray = null or wleArray.isEmpty then
		msg := app.getErrorString1(Incomp_load_tasks_found_this, truck.regNumber );
		return;
	endif;
	
	iter := wleArray.createIterator;
	while iter.next( wle ) do
		if wle.status &lt;&gt; WLE_UNACTIONED then
			continue;
		endif;
		if wle.myTrackedItem = ti then
			wleToUse := wle;
			break;
		endif;
	endwhile;
	delete iter;
	
	on CM_Exception do app.validationExHandler(exception, app.myPassport);
	app.setContinueCMExceptions(true);
	
	if wleToUse = null then
		iter := wleArray.createIterator;
		while iter.next( wle ) do
			if wle.status &lt;&gt; WLE_UNACTIONED then
				continue;
			endif;
			if wle.myRequest = null or not wle.myRequest.isKindOf(CM_DeliveryRequest) then
				continue;
			endif;
			
			
			delReq := wle.myRequest.CM_DeliveryRequest;
			reserveDetail := delReq.myReserveDetail;
			if reserveDetail = null then
				app.myPassport.clearErrorsWarnings();
				ti.testAgainstRequest(delReq);
				if app.myPassport.hasErrorsOrNonIgnoredWarnings then
					app.myPassport.clearErrorsWarnings();
					continue;
				endif;
			else
				if not reserveDetail.isKindOf(CM_ReserveSelection) then
					continue;
				endif;
				if not ti.testAgainstReserveSelection( reserveDetail.CM_ReserveSelection, reason, true, null ) then	
					continue;
				endif;
			endif;
			
			wleToUse := wle;
			break;
		endwhile;
		delete iter;
	endif;
	
	on CM_Exception do null;
	
	if wleToUse = null then
		msg := app.getErrorString1(Incomp_load_task_found_matchi, ti.id );
		//10 Aug 2016	NDL TFS 2511 - show extra reason/logging if its available
		if reason &lt;&gt; null then
			msg := msg &amp; CrLf &amp; reason;
		elseif reserveDetail = null and app.myPassport.hasErrorsOrNonIgnoredWarnings then 
			msg := msg &amp; CrLf &amp; app.myPassport.getErrorsAndWarningsAsString;
		endif;
		return;
	endif;
	
	//OK now we have a valid 'ti' and a 'wleToUse'	
	
	//If the Truck loader / Cargo type combination is configured for mandatory cargo checks,
	//then they need to follow the normal process thru the std forms.
	if self.myMobileGenericAgent.isWaitingOnRequiredChecks(CARGO_CHECK_CONTEXT_TRUKLOAD, ti, checksSubCargo) &lt;&gt; null
	or ti.canSplitTotalQuantity	//05 Sep 2018	NDL	TFS 39950
	then
		
		self.myMobileGenericAgent.setMyNextTiToAction(ti);
		self.myMobileGenericAgent.setMyDeliveryRequest(null);
		self.myMobileGenericAgent.setChecksState(self.myMobileGenericAgent.TruckLoad);//28 May 2010	NDL	Par 23698
		self.myMobileGenericAgent.setMyWle( wleToUse );
		self.gotoForm( MOB_HHTruckLoaderCargo, false );
		return;
	endif;
	
	
	//OK its just 'Wham Bam, thank you Mam'.
	//Assign the ti to the wle and move the sucker to the truck
	
	lc := wleToUse.getRoadReleaseLC();
	
	create moveController transient;
	moveController.setMyWorkListEntry(wleToUse);
	moveController.setMyToPrimaryLocation(lc);
	moveController.setMyTrackedItem(ti);
	moveController.setQuantity(ti.totalQuantity);
	moveController.setWeight(ti.totalWeight);
	
	while true do
		app.myTrxUA.trxUpdateWLEAssignTI(moveController, app.myPassport);	
		if not app.myPassport.trxCompletedOK then
			result := app.showErrorWarningDialog(app.getErrorString( Assign_release ), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;
	
	self.setupCargo();
	self.doResizeControls(false);	//08 Jul 2016	NDL	TFS 2275 / 2216
	self.showWeights( truck );
	self.txtScanTxt.text := null;
	self.txtScanTxt.setFocus();

epilog

	if msg &lt;&gt; null then
		self.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only, true);
	endif;
	delete iter;
//	delete tiSet;
	delete moveController;
	delete tiArray;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="processCargoFromScanByLocn" id="598fbde4-3dfc-4f2b-ac3b-9cafab0a5a30">
        <updating/>
        <source>processCargoFromScanByLocn() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 September 2018	jlgndl1	Initial creation	TFS 39950

*/

vars

	cargoId : String;
	ti : CM_TrackedItem;
	iter : Iterator;
	msg : String;

	wleToUse : CM_WorkListEntry;
	delReq : CM_DeliveryRequest;
	reserveDetail : CM_ReserveDetail;
	reason : String;
	lc : CM_LocationsController;
	moveController : CMIF_MoveController;
	result : Integer;
	truck : CM_Vehicle;
	checksSubCargo : CM_TrackedItem;
	
	tiArray : CM_TIArray;	
	cargoIdLength : Integer;	
	cargoIdReversed : String;	
	
	term : CM_Terminal;	
	buttonNumber : Integer;	
	menuButton : MOB_Button;	
	obj : Object;	
	
	locationSet : CM_TISet;

begin

//	if not self.allowDirectScan then
	if self.allowDirectScan = 0 then	//16 Dec 2016	NDL	TFS 3129
		return;
	endif;
	
	truck := self.myMobileGenericAgent.myTruck;
	
	cargoId := self.txtScanTxt.text.trimBlanks;
	if cargoId = null or cargoId = self.lblScanTxt.caption.toUpper then
		return;
	endif;

	create tiArray transient;
	create locationSet transient;
	
	cargoIdLength := cargoId.length;
	cargoIdReversed := cargoId.reverse;
	term := self.myMobileDataAgent.myTerminal;
	
	//We are already showing the subset of available cargo, it has to be one of these.
	if self.inYardButtonCount &gt; 0 then
		foreach buttonNumber in 1 to self.inYardButtonCount do
			menuButton := self.btnInYardTemp.getControl( buttonNumber ).MOB_Button;
			if menuButton &lt;&gt; null then
				obj := menuButton.userObject;
				if obj &lt;&gt; null and obj.isKindOf( CM_TrackedItem ) then
					ti := obj.CM_TrackedItem;
				else
					continue;
				endif;
				locationSet.addNoDuplicates( ti, false );
			endif;
		endforeach;
		
	endif;
				
	//try exact match for the whole id first
	iter := locationSet.createIterator;
	while iter.next( ti ) do
		if ti.id &lt;&gt; cargoId then
			//to select, must be an exact match
			continue;
		endif;
		tiArray.addExclusive(ti);
	endwhile;
	delete iter;
			
	//Allow for partial searches matching on the last 'n' chars
	if tiArray.isEmpty then
		iter := locationSet.createIterator;
		while iter.next( ti ) do
			if ti.idReversed[1:cargoIdLength] &lt;&gt; cargoIdReversed then
				continue;
			endif;
			tiArray.addExclusive(ti);
		endwhile;
		delete iter;	
	endif;
		
	//Still nothing try an exact match on the alternate id
	if tiArray.isEmpty then
		iter := locationSet.createIterator;
		while iter.next( ti ) do
			if ti.alternativeId &lt;&gt; cargoId then
				continue;
			endif;
			tiArray.addExclusive(ti);
		endwhile;
		delete iter;
	endif;
		
	if tiArray.size = 1 then
		// found just one, all good...
		ti := tiArray.first;
	elseif tiArray.size &gt; 1 then
		msg := app.getErrorString2( Not_unique_within, cargoId.trimBlanks, self.myYardLocation.getFullId );
		return;
	else
		msg := app.getErrorString1(Cargo_item_not_found, cargoId.trimBlanks);
		return;
	endif;

	//OK we have a unique piece of cargo, now get the wle
	wleToUse := self.myMobileGenericAgent.getUnActionedIsAnyIdAnyAmount();
	if wleToUse = null then
		msg := app.getErrorString1(Incomp_load_tasks_found_this, truck.regNumber );
		return;
	endif;
	
	on CM_Exception do app.validationExHandler(exception, app.myPassport);
	app.setContinueCMExceptions(true);
	
			
	delReq := wleToUse.myRequest.CM_DeliveryRequest;
	reserveDetail := delReq.myReserveDetail;
	if reserveDetail = null then
		app.myPassport.clearErrorsWarnings();
		ti.testAgainstRequest(delReq);
		if app.myPassport.hasErrorsOrNonIgnoredWarnings then
			reason := app.myPassport.getAllErrorsWarningsAsString();
			app.myPassport.clearErrorsWarnings();
			msg := app.getErrorString1(Incomp_load_task_found_matchi, ti.id );
			if reason &lt;&gt; null then
				msg := msg &amp; CrLf &amp; reason;
			elseif reserveDetail = null and app.myPassport.hasErrorsOrNonIgnoredWarnings then 
				msg := msg &amp; CrLf &amp; app.myPassport.getErrorsAndWarningsAsString;
			endif;
			return;
		endif;
	endif;
			
	on CM_Exception do null;
	
	//OK now we have a valid 'ti' and a 'wleToUse'	
	
	//If the Truck loader / Cargo type combination is configured for mandatory cargo checks,
	//then they need to follow the normal process thru the std forms.
	if self.myMobileGenericAgent.isWaitingOnRequiredChecks(CARGO_CHECK_CONTEXT_TRUKLOAD, ti, checksSubCargo) &lt;&gt; null
	or ti.canSplitTotalQuantity	//05 Sep 2018	NDL	TFS 39950
	then
		
		self.myMobileGenericAgent.setMyNextTiToAction(ti);
		self.myMobileGenericAgent.setMyDeliveryRequest(null);
		self.myMobileGenericAgent.setChecksState(self.myMobileGenericAgent.TruckLoad);//28 May 2010	NDL	Par 23698
		self.myMobileGenericAgent.setMyWle( wleToUse );
		self.gotoForm( MOB_HHTruckLoaderCargo, false );
		return;
	endif;
	
	
	//OK its just 'Wham Bam, thank you Mam'.
	//Assign the ti to the wle and move the sucker to the truck
	
	lc := wleToUse.getRoadReleaseLC();
	
	create moveController transient;
	moveController.setMyWorkListEntry(wleToUse);
	moveController.setMyToPrimaryLocation(lc);
	moveController.setMyTrackedItem(ti);
	moveController.setQuantity(ti.totalQuantity);
	moveController.setWeight(ti.totalWeight);
	
	while true do
		app.myTrxUA.trxUpdateWLEAssignTI(moveController, app.myPassport);	
		if not app.myPassport.trxCompletedOK then
			result := app.showErrorWarningDialog(app.getErrorString( Assign_release ), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;
	
	self.setupCargo();
	self.doResizeControls(false);	//08 Jul 2016	NDL	TFS 2275 / 2216
	self.showWeights( truck );
	self.txtScanTxt.text := null;
	self.txtScanTxt.setFocus();

epilog

	if msg &lt;&gt; null then
		self.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only, true);
	endif;
	delete iter;
//	delete tiSet;
	delete moveController;
	delete tiArray;
	delete locationSet;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupControls" id="6868bd28-4bac-4053-8852-896162f1b18a">
        <updating/>
        <source>setupControls()updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 February 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

	truck : CM_Vehicle;
	
begin
							
	self.doResizeControls(true);

	truck := self.myMobileGenericAgent.myTruck;
	self.showWeights(truck);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="c602954f-51a2-4c9c-8514-73dda4f0eb26">
        <updating/>
        <source>setupForm() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 February 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

begin
	
	if app.myMobileCargoFindAgent = null then
		create app.myMobileCargoFindAgent transient;
	endif;
	
	self.includeBolNumber := self.myTerminal.getConfig( HhTruckLoadBolId ).Boolean;	//17 Jul 2017	NDl	TFS 5408
	
	//04 Sep 2018	NDL	TFS 39950 - STWO any amount Any ID for bulk and Break Bulk	
	if self.myMobileGenericAgent.myTerminal.getConfig( HhTruckLoadByLocn ).Boolean then
		self.myYardLocation := self.myMobileGenericAgent.myYardLocation;
		if self.myYardLocation &lt;&gt; null then	//12 Sep 2018	NDL	TFS 40776
			self.caption := self.caption &amp; " - " &amp; self.myMobileGenericAgent.myYardLocation.getFullId();
		endif;
	endif;
	
	inheritMethod();
	
	self.allowDirectScan := self.myTerminal.getConfig( HhTruckLoadScan ).Integer;	//16 Dec 2016	NDL	TFS 3129
	
	
	setupControls();
	
	self.shtOnTruck.caption := app.getErrorString(Loaded);
	self.shtInYard.caption := app.getErrorString(CargoToLoad);
	self.shtInYard.setFocus;
	if self.allowDirectScan &gt; 0  then	//26 May 2016	NDL	TS 1593
		self.txtScanTxt.lostFocus( self.txtScanTxt );
		self.txtScanTxt.setFocus();
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupInYard" id="cdd183e0-5eda-4b2e-9546-669c0cfb0889">
        <updating/>
        <source>setupInYard() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 January 2010	cnwndl1	Initial creation	CCMS MES 1005
22 May 2013	NDL	- CCMS 2274 Break Bulk
28 Aug 2013	NDL	Par 32337 - Make up the frigging rules after it goes to the client again... 
04 Nov 2013	- GTL CCMS 2257 / Par 30819
06 Jan 2017	NDL	TFS 3167 Allow for multiple Any Id releases and std releases in parallel i.e Oman do this on a single truck
*/

constants

	TAB_INDEX_START = 1000;
	
vars

	menuButton : MOB_Button;
	buttonOffset : Integer;
	buttonNumber : Integer;
	buttonWidth : Real;
	ti : CM_TrackedItem;
	delReq : CM_DeliveryRequest;
	wle : CM_WorkListEntry;
	size : Integer;
	buttonCaption : String;
	checksSubCargo : CM_TrackedItem;
	allowMoreCargoButton : Boolean;
	buttonHeight : Integer;
	filterText : String;
	
	normalWleArray : CM_WLEArray;	//06 Jan 2017	NDL	TFS 3167
	isAnyWleArray : CM_WLEArray;	//06 Jan 2017	NDL	TFS 3167
	tiAnyIdArray : CM_TIArray;	//09 Jan 2017	NDL	TFS 3167
	unloadedTiArray : CM_TIArray;	//09 Jan 2017	NDL	TFS 3167
	
	btnStrTemp : String;	//01 Aug 2017	NDL	TFS 5655
	
	panderingToOman : Boolean;	//25 Oct 2018	NDL	TFS 41240
	
begin
	panderingToOman := self.myTerminal.getConfig( HhAllowLoadUnloaded ).Boolean; //25 Oct 2018	NDL	TFS 41240

	if self.allowDirectScan &gt; 1 then	//21 Dec 2016	NDL	TFS 3129
		filterText := self.txtScanTxt.text.toUpper.trimBlanks;
		if filterText &lt;&gt; null and filterText = self.lblScanTxt.caption.toUpper then
			filterText := null;
		endif;
	endif;

	//27 May 2016	NDL	TFS 1593
	if self.inYardButtonCount &gt; 0 then
		foreach buttonNumber in 1 to self.inYardButtonCount do
			menuButton := self.btnInYardTemp.getControl( buttonNumber ).MOB_Button;
			if menuButton &lt;&gt; null then
				menuButton.visible := false;
				delete menuButton;
			endif;
		endforeach;
		self.inYardButtonCount := 0;
		buttonNumber := 0;
	endif;
	
	//05 Sep 2018	NDL	TFS 39950
	if self.isLoadingByLocation then
		//don't allow "Find More Cargo"
		allowMoreCargoButton := false;
	else
		allowMoreCargoButton := self.myTerminal.getConfig(AllowLoadMoreCargo).Boolean;	//04 Dec 2015	NDL	Par 36866
	endif;
	
	//06 Jan 2017	NDL	TFS 3167
	create normalWleArray transient;
	create isAnyWleArray transient;
	create tiAnyIdArray transient;
	create unloadedTiArray transient;
	
	foreach ti in self.myMobileGenericAgent.allUnloadedTis do
		if ti.myPrimaryActualLocation = null then
			continue;
		endif;
		if self.isLoadingByLocation then	//25 Oct 2018	NDL	TFS 41240
			if ti.myPrimaryActualLocation &lt;&gt; self.myYardLocation then
				continue;
			endif;
		endif;
		//25 Oct 2018	NDL	TFS 41240
		if panderingToOman and self.myMobileGenericAgent.allWlesToLoad.includesWLEfor( ti ) then	
			continue;
		endif;
		if filterText &lt;&gt; null then
			if self.includeBolNumber then	//17 Jul 2017	NDL	TFS 5408
				btnStrTemp := self.getButtonStrForTi( ti, null, null );
				if btnStrTemp.toUpper.pos(filterText,1) &lt; 1 then
					// filtered out.
					continue;
				endif;
			else
				if ti.id.pos(filterText,1) &lt; 1 then
					// filtered out.
					continue;
				endif;
			endif;
		endif;
		unloadedTiArray.add(ti);
	endforeach;
	
	foreach wle in self.myMobileGenericAgent.allWlesToLoad do
		if wle.myRequest = null or not wle.myRequest.isAnyId() then
			normalWleArray.add(wle);
		else
			isAnyWleArray.add(wle);
		endif;
	endforeach;
	
	if not isAnyWleArray.isEmpty then	//06 Jan 2017	NDL	TFS 3167
		self.setupInYardForAnyIdRelease( isAnyWleArray, filterText, unloadedTiArray, tiAnyIdArray );
	endif;
	
	size := unloadedTiArray.size + normalWleArray.size + tiAnyIdArray.size + 1;	// to allow for the extra buttons below.
	if allowMoreCargoButton then	//06 Mar 2014	NDL	Par 33554
		size := size + 1;
	endif;
	

	buttonHeight := self.getScrollingButtonHeight();
	self.btnInYardTemp.height := buttonHeight;
	buttonWidth := getButtonWidthSetScrollBar( size, self.frmCargoInYard, self.btnInYardTemp.height, self.scrCargoInYard );

	foreach wle in normalWleArray do
	
		ti := wle.myTrackedItem;
		if wle.myRequest &lt;&gt; null and wle.myRequest.isKindOf(CM_DeliveryRequest) then
			delReq := wle.myRequest.CM_DeliveryRequest;
		else
			delReq := null;
		endif;
		if ti = null and delReq = null then
			continue;
		endif;
		
		if ti &lt;&gt; null and ti.myPrimaryActualLocation = null then	//13 May 2015	NDL	Par 36189 / 19 May 2015	NDL 36250
			continue;
		endif;
		
		buttonCaption := self.getButtonStrForTi( ti, wle, delReq );	//17 Jul 2017	NDL	TFS 5408
		
		//19 Dec 2016	NDL	TFS 3129
		if filterText &lt;&gt; null then
			if self.includeBolNumber then	//17 Jul 2017	NDL	TFS 5408
				if buttonCaption.toUpper.pos(filterText,1) &lt; 1 then
					// filtered out.
					continue;
				endif;
			else
				if ti = null then	//29 Aug 2018	NDL	TFS 38431
					continue;
				elseif ti.id.pos(filterText,1) &lt; 1 then
					// filtered out.
					continue;
				endif;
			endif;
		endif;
		
		buttonNumber := buttonNumber + 1;
		menuButton := self.btnInYardTemp.loadControl( buttonNumber ).MOB_Button;
		menuButton.move(0, buttonOffset, buttonWidth, buttonHeight-4 );
		
		if ti &lt;&gt; null then
			menuButton.userObject := ti;
	//		buttonCaption := btnStr; //17 Jul 2017	NDL	TFS 5408
			
			//26 Sep 2013	NDL	Par 32557
			if not self.myMobileGenericAgent.isWaitingOnRequiredChecks( CARGO_CHECK_CONTEXT_TRUKLOAD, ti, checksSubCargo ) = null and not ti.isChild then
				menuButton.foreColor := Green;
			elseif checksSubCargo &lt;&gt; null or ti.isChild then
				menuButton.foreColor := Red;
			else
				menuButton.foreColor := Black;
			endif;
			self.allNotableObjects.add(ti);
		elseif delReq &lt;&gt; null then	//01 Jun 2010	NDL	Par 23903
			menuButton.userObject := delReq;
	//		buttonCaption := btnStr; //17 Jul 2017	NDL	TFS 5408
			
			self.allNotableObjects.add(delReq);
		endif;
		
		menuButton.caption := buttonCaption;
	
		buttonOffset := buttonOffset + buttonHeight-2;
		menuButton.tabIndex := TAB_INDEX_START + buttonNumber;
		
	endforeach;
	
	
	foreach ti in unloadedTiArray do
		
		buttonNumber := buttonNumber + 1;
		menuButton := self.btnInYardTemp.loadControl( buttonNumber ).MOB_Button;
		menuButton.move(0, buttonOffset, buttonWidth, buttonHeight-4 );
		
		menuButton.userObject := ti;
		if ti.canSplitTotalQuantity and ti.isBulkByQuantity then
			menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id &amp; "(" &amp; ti.totalQuantity.String &amp; ")" 
										&amp; CrLf &amp; ti.myPrimaryActualLocation.getFullId &amp; " (unloaded)";
		elseif ti.isBulkByWeight and ti.isBulkByVolume then
			menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id &amp; "(" &amp; ti.CM_Bulk.getBulkTrackByDisplayForWeight(true) &amp; ")" 
										&amp; CrLf &amp; ti.myPrimaryActualLocation.getFullId &amp; " (unloaded)";
		else
			menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id &amp; CrLf &amp; ti.myPrimaryActualLocation.getFullId &amp; " (unloaded)";
		endif;
		
		if panderingToOman and not ti.myCargoType.allowDuplicates then	//25 Oct 2018	NDL	TFS 41240
			menuButton.enabled := true;
		else
			menuButton.enabled := false;
		endif;
		
		buttonOffset := buttonOffset + buttonHeight-2;
		menuButton.tabIndex := TAB_INDEX_START + buttonNumber;
		
	endforeach;
	
	//09 Jan 2017	NDL	TFS 3167
	foreach ti in tiAnyIdArray do
		buttonNumber := buttonNumber + 1;
		menuButton := self.btnInYardTemp.loadControl( buttonNumber ).MOB_Button;
		menuButton.move(0, buttonOffset, buttonWidth, buttonHeight-4 );
		
		menuButton.userObject := ti;
		
		buttonCaption := self.getButtonStrForTi( ti, null, null );	//17 Jul 2017	NDL	TFS 5408
		
		if not self.myMobileGenericAgent.isWaitingOnRequiredChecks( CARGO_CHECK_CONTEXT_TRUKLOAD, ti, checksSubCargo ) = null then
			menuButton.foreColor := Green;
		elseif checksSubCargo &lt;&gt; null then
			menuButton.foreColor := Red;
		else
			menuButton.foreColor := Black;
		endif;
		self.allNotableObjects.add(ti);
		
		menuButton.caption := buttonCaption;
	
		buttonOffset := buttonOffset + buttonHeight-2;
		menuButton.tabIndex := TAB_INDEX_START + buttonNumber;
	endforeach;
	
	// add an extra button for finding unknown items....
	if allowMoreCargoButton then	//06 Mar 2014	NDL	Par 33554
		buttonNumber := buttonNumber + 1;
		menuButton := self.btnInYardTemp.loadControl( buttonNumber ).MOB_Button;
		menuButton.move(0, buttonOffset, buttonWidth, buttonHeight-4 );
		menuButton.userObject := null;
		menuButton.caption := app.getErrorString( Find_more_cargo );
		buttonOffset := buttonOffset + buttonHeight-2;
		menuButton.tabIndex := TAB_INDEX_START + buttonNumber;
	endif;
	
	//05 Sep 2018	NDL	TFS 39950
	if self.isLoadingByLocation then
		// Don't allow "Swap Cargo"
	else
		// add an extra button for swaping wles to load cargo between trucks....
		// 04 Nov 2013	- GTL CCMS 2257 / Par 30819
		buttonNumber := buttonNumber + 1;
		menuButton := self.btnInYardTemp.loadControl( buttonNumber ).MOB_Button;
		menuButton.move(0, buttonOffset, buttonWidth, buttonHeight-4 );
		menuButton.userObject := self.myMobileGenericAgent.myTruck;
		menuButton.caption := app.getErrorString( Swap_cargo );
		buttonOffset := buttonOffset + buttonHeight-2;
		menuButton.tabIndex := TAB_INDEX_START + buttonNumber;
	endif;
	
	self.inYardButtonCount := buttonNumber;	//05 Aug 2014	NDL	Par 34675
	
	self.btnInYardTemp.visible := false;
	self.frmCargoInYard.caption := null;
	
	lblNoCargoYard.visible := false;	// because we have the 'find more cargo' button.
	
	
epilog

	delete normalWleArray;
	delete unloadedTiArray;
	delete isAnyWleArray;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupInYardForAnyIdRelease" id="24d179ba-6d74-4498-ad83-1b8882917bdf">
        <updating/>
        <source>setupInYardForAnyIdRelease( _isAnyWleArray : CM_WLEArray input; _filterText : String; _unloadedTiArray : CM_TIArray input; _tiAnyIdArray : CM_TIArray input ) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 August 2014	cnwndl1	Initial creation	Par 34675
06 Jan 2017	NDL	TFS 3167 Allow for multiple Any Id releases and std releases in parallel i.e Oman do this on a single truck

	Specific variant of the 'setupInYard' for Multi ID releases where no IDs have been chosen.

*/

constants

	TAB_INDEX_START = 1000;
	
vars

	ti : CM_TrackedItem;
	delReq : CM_DeliveryRequest;
	wleArray : CM_WLEArray;
	wle : CM_WorkListEntry;
	bulkRelease : CM_BulkRelease;
	iter : Iterator;
	btnStr : String;
	resDet : CM_ReserveDetail;
	
begin

	if _isAnyWleArray = null then
		//no any id requests.
		return;
	endif;
	
	foreach wle in _isAnyWleArray do
	
		delReq := wle.myRequest.CM_DeliveryRequest; // its always a delivery request if its an Any Id
		bulkRelease := delReq.myOriginatingBulkRelease;
		
		if bulkRelease = null then
			continue;
		endif;
		//Ok we are dealing with a release by id but with no ids selected at the gate, (an 'Any Id' Release)
		//we must present the  whole list of available cargo
		
	//	iter := bulkRelease.allTrackedItemsAssigned.createIterator;
		iter := bulkRelease.allReserveDetails.createIterator;
		while iter.next( resDet ) do
			if not resDet.isKindOf( CM_ReserveTI ) then
				continue;
			endif;
			ti := resDet.CM_ReserveTI.getTI();
			if ti = null then
				continue;
	//		elseif ti.myPrimaryActualLocation &lt;&gt; null and ti.myPrimaryActualLocation.isVehicle then
	//			if ti.myCargoType.allowDuplicates and ti.myMasterTi &lt;&gt; null then
	//				ti := ti.myMasterTi;
	//			endif;
			endif;
			
			//05 Sep 2018	NDL	TFS 39950
			if self.isLoadingByLocation then
				if ti.myPrimaryActualLocation &lt;&gt; self.myYardLocation then
					continue;
				endif;
			endif;
			
			if not ti.isTiAvailableForAnyIdSelection() then
				continue;
			endif;
			
			//17 Jul 2017	NDL	TFS 5408 - self.includeBolNumber implies filetring is done on the whole button string
			if self.includeBolNumber then
				if _filterText &lt;&gt; null then
					btnStr := self.getButtonStrForTi( ti, wle, delReq );
					if btnStr.toUpper.pos(_filterText,1) &lt; 1 then
						// filetered out.
						continue;
					endif;
				endif;
			else
				//19 Dec 2016	NDL	TFS 3129
				if _filterText &lt;&gt; null then
					if ti.id.pos(_filterText,1) &lt; 1 then
						// filetered out.
						continue;
					endif;
				endif;
			endif;
			if _unloadedTiArray.includes(ti) then
				_unloadedTiArray.remove( ti );	 //25 Oct 2018	NDL	TFS 41240
				//continue;
			endif;
			_tiAnyIdArray.addExclusive( ti );
		endwhile;
		delete iter;
	
	endforeach;
	
epilog

	delete iter;
	
end;</source>
        <access>protected</access>
        <Parameter name="_isAnyWleArray" type="CM_WLEArray" usage="input"/>
        <Parameter name="_filterText" type="String"/>
        <Parameter name="_unloadedTiArray" type="CM_TIArray" usage="input"/>
        <Parameter name="_tiAnyIdArray" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupOnTruck" id="a09b87ef-eec3-4488-ad1b-fbd65cab6d85">
        <updating/>
        <source>setupOnTruck() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 January 2010	cnwndl1	Initial creation	CCMS MES 1005
22 May 2013	NDL	- CCMS 2274 Break Bulk
*/

constants

	TAB_INDEX_START = 1000;
	
vars

	menuButton : MOB_Button;
	buttonOffset : Integer;
	buttonNumber : Integer;
	buttonWidth : Real;
	tiArray: CM_TIArray;
	ti : CM_TrackedItem;
	size : Integer;
//	allowAddOfExtraCargo : Boolean;
	recReqInfo : CM_ReceivalRequestInfo;
	infoSet : CM_ReceivalRequestInfoSet;
	cargoTypeString : String;
	quantityString : String;
	buttonHeight : Integer;	
	
begin

	//27 May 2016	NDL	TFS 1593
	if self.onTruckButtonCount &gt; 0 then
		foreach buttonNumber in 1 to self.onTruckButtonCount do
			menuButton := self.btnOnTruckTemp.getControl( buttonNumber ).MOB_Button;
			if menuButton &lt;&gt; null then
				menuButton.visible := false;
				delete menuButton;
			endif;
		endforeach;
		self.onTruckButtonCount := 0;
		buttonNumber := 0;
	endif;

	tiArray := self.myMobileGenericAgent.allLoadedTis;
	size := tiArray.size;
	
	create infoSet transient;	
	self.myMobileGenericAgent.getAllReceivalRequestInfos( infoSet );
	size := size + infoSet.size;
	
	buttonHeight := self.getScrollingButtonHeight();
	self.btnOnTruckTemp.height := buttonHeight;
	buttonWidth := getButtonWidthSetScrollBar( size, self.frmCargoOnTruck, self.btnOnTruckTemp.height, self.scrCargoOnTruck );

	foreach ti in tiArray do
		
		buttonNumber := buttonNumber + 1;
		menuButton := self.btnOnTruckTemp.loadControl( buttonNumber ).MOB_Button;
		menuButton.move(0, buttonOffset, buttonWidth, buttonHeight-4 );
		
		menuButton.userObject := ti;
		if ti.canSplitTotalQuantity and ti.isBulkByQuantity then
			menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id &amp; "(" &amp; ti.totalQuantity.String &amp; ")" ;
		elseif ti.isBulkByWeight and ti.isBulkByVolume then
			menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id &amp; "(" &amp; ti.CM_Bulk.getBulkTrackByDisplayForWeight(true) &amp; ")"; 
		else
			menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id ;
		endif;
		
		self.addHazDetailsToButton( menuButton, ti, CrLf ); //30 May 2017	NDL	TFS 4587
		
		self.allNotableObjects.add(ti);

		buttonOffset := buttonOffset + buttonHeight-2;
		menuButton.tabIndex := TAB_INDEX_START + buttonNumber;
		
	endforeach;
	
	foreach recReqInfo in infoSet do
		buttonNumber := buttonNumber + 1;
		menuButton := self.btnOnTruckTemp.loadControl( buttonNumber ).MOB_Button;
		menuButton.move(0, buttonOffset, buttonWidth, buttonHeight-4 );
		menuButton.userObject := recReqInfo;
		self.allNotableObjects.add(recReqInfo);
		if recReqInfo.myCargoType = null then
			cargoTypeString := app.getErrorString(Undeclared_cargo_type);
		else
			cargoTypeString := recReqInfo.myCargoType.description;
		endif;
		//16 Nov 2010	NDL	Par 26055
		if recReqInfo.quantity = 0 then
			quantityString := "?? x ";
		else
			quantityString := recReqInfo.quantity.String &amp; " x ";
		endif;
		if recReqInfo.allTrackedItems.isEmpty then
			menuButton.caption := quantityString &amp; cargoTypeString;
		else
			menuButton.caption := quantityString &amp; cargoTypeString  &amp; " (x" &amp; recReqInfo.allTrackedItems.size.String &amp; " " &amp; app.getErrorString(Unloaded) &amp; ")";
		endif;

		buttonOffset := buttonOffset + buttonHeight-2;
		menuButton.tabIndex := TAB_INDEX_START + buttonNumber;
		menuButton.enabled := false;
	endforeach;
	
	self.onTruckButtonCount := buttonNumber;
	
	self.btnOnTruckTemp.visible := false;
	self.frmCargoOnTruck.caption := null;
	
	if size = 0 then
		lblNoCargoTruck.visible := true;
	else
		lblNoCargoTruck.visible := false;
	endif;
	
epilog

	delete infoSet;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showWeights" id="31f60b32-5db7-491f-8f70-f5a1c5d230a8">
        <source>showWeights( _truck : CM_Vehicle ) protected;


/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 February 2010	cnwndl1	Initial creation	CCMS MES 1005
22 May 2013	NDL	- CCMS 2274 Break Bulk
*/

vars
	ti : CM_TrackedItem;
	weight : Decimal[14,4];
	totWeight : Decimal[18,4];
	hideCount : Boolean;	//29 Nov 2018	NDL	TFS 42244
begin

	hideCount := false;

	if _truck = null then
		lblWeightValue.caption := app.getErrorString(CM_Load_Weight) &amp; " : ";
		lblCountValue.caption := app.getErrorString(Count) &amp; " : ";
	else
		foreach ti in self.myMobileGenericAgent.allLoadedTis do
			weight := ti.totalWeight;
			totWeight := totWeight + weight;
			//29 Nov 2018	NDL	TFS 42244
			if ti.isBulkByVolume or ti.isBulkByWeight then
				hideCount := true;
			endif;
		endforeach;
		//lblWeightValue.caption := app.getErrorString(CM_Load_Weight) &amp; " : " &amp; totWeight.asStringJMT;
		// cnwrd1 ccms 1321 imperial measurements
		lblWeightValue.caption := app.getErrorString(CM_Load_Weight) &amp; " : " &amp; self.myMobileDataAgent.getMeasureConvertedForDisplay(null,Type_Weight,totWeight) &amp; self.myMobileDataAgent.getMeasureLabelUnit(null,Type_Weight);
		//lblCountValue.caption := app.getErrorString(Count) &amp; " : " &amp; self.myHandHeldCheckerAgent.allLoadedTis.size.String;
		lblCountValue.caption := app.getErrorString(Count) &amp; " : " &amp; self.myMobileGenericAgent.getOnTruckCargoCount().String;
	endif;
	
	lblCountValue.visible := not hideCount;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_truck" type="CM_Vehicle"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="f1c957db-aeba-4e86-b18c-0437b1f3a5d5">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 18 January 2017 09:56:20.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0014430, locale);
	btnFiltClear.translateCaption(Xlat_0021741, locale);
	btnFilter.translateCaption(Xlat_0021742, locale);
	lblCountValue.translateCaption(Xlat_0014431, locale);
	lblScanTxt.translateCaption(Xlat_0021263, locale);
	lblWeightValue.translateCaption(Xlat_0014432, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="txtScanTxt_gotFocus" id="62d93aee-f2bf-4dd1-9c85-8aa988822d80">
        <controlMethod name="TextBox::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtScanTxt_gotFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 May 2016	cnwndl1	Initial creation	TFS 1593

*/

vars

begin

	if self.txtScanTxt.text = self.lblScanTxt.caption.toUpper then
		self.txtScanTxt.text := null;
	endif;

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtScanTxt_lostFocus" id="39b50e59-4cbd-4c2a-b9a8-7485d8a6ea26">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtScanTxt_lostFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 May 2016	cnwndl1	Initial creation	TFS 1593

*/

vars

begin

	//app.convertScannedCargoId( self.myTerminal, textbox, false, null );	//06 Jul 2016	NDL	TFS 2275
	app.convertScannedCargoId( self.myTerminal, textbox, true, null );	//08 Aug 2016	NDL	TFS 2567 - Is used for both cargo id and alternate id, don't truncate to 20
	
	if self.txtScanTxt.text.trimBlanks = null then
		self.txtScanTxt.text := self.lblScanTxt.caption.toUpper;
	elseif self.allowDirectScan = 1 then	//19 Dec 2016	NDL	TFS 3129
		if self.isLoadingByLocation then
			self.processCargoFromScanByLocn();	//06 Sep 2018	NDL	TFS 39950
		else
			self.processCargoFromScan();
		endif;
	endif;

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
</GUIClass>
