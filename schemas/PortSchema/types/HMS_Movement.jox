    <JadeMethod name="erase" id="bc4331a6-02b5-48f1-a9a0-1245e022eeea">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
//---------------------------------------------------------------------------------------------------------------
// Created:	20 Dec 2007 By cnwvu1. 
// Purpose: 
//		when erasing a movement, we should rebuild relationship: myNextMovement and myPreviousMovement. Par 15582
// CANNOT call these methods to rebuild here as if updating times on other movements the calls to rebuild are
//		based on the dicts being in the correct order which they may nor be.
// Once all updates/deletes/adds are complete the calling method should call either:
//    CM_Voyage::maintainMovementLinkedList or
//    CM_VoyageGlobal::maintainMovementLinkedList
// 21 Sep 2020 cnwma1 ChangeRequest 49906: MTN - Ops View External Webservice
//---------------------------------------------------------------------------------------------------------------
vars
	
begin
	
	//21/09/2020 cnwma1 TFS #49906
	if app.myPassport.isOpsViewEnabled(self.getMyTerminal()) then
		self.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_DELETE,
									 BGP_OpsViewWSRequest.OPS_TYPE_HMSMOVE,
									 self);
	endif;
	//21/09/2020 cnwma1 TFS #49906
		
	inheritMethod(_eraseLevel);
	
	//if prevMov &lt;&gt; null then
	//	prevMov.maintainLinkedList();
	//endif;
	//if nextMov &lt;&gt; null then
	//	nextMov.maintainLinkedList();
	//endif;
	
end;
</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
