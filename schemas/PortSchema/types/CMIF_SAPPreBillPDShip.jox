    <JadeMethod name="copyToRealWSObject" id="deedddff-4fa8-4bd0-ad86-d183fe6dd223">
        <source>copyToRealWSObject(_realRequest: SAP112_PreBillProdDataRequest_DT_T_Ship_item input;
