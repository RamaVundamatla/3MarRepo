*/

vars

begin
	return self.getPropertyValue("_methodName").String;
	
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleCMException" id="d8eb574b-d802-4519-b334-2ff03671d2cc">
        <source>handleCMException(_exc : CM_Exception) : Integer protected;

/*

Purpose:			Handle CM_Exceptions during a web service method execution

Parameters:			CM_Exception object

Return Value:		Exception return code


Date		Who		Reason
16 Jul 2008	cnwkpd1	PAR #17554 - Development of new RIA Web Service application

*/

vars

begin
	if _exc.isWarning then
		app.myPassport.addWarningFull(_exc.errorCode, _exc.extendedErrorText, _exc.userString, _exc.myUserObject, _exc.mySubject);
		return Ex_Continue;
	else
		abortTransaction;
		abortTransientTransaction;
		app.myPassport.addErrorFull(_exc.errorCode, _exc.extendedErrorText, _exc.userString, _exc.myUserObject, _exc);
		return Ex_Resume_Next;
	endif;
	
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_exc" type="CM_Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleInterruptExceptions" id="c619a42f-0a37-4be8-b7bf-4e671d2ea545">
        <source>handleInterruptExceptions(_exc : Exception;
					  _excOccurred : Boolean io) : Integer protected;

/*

Purpose:			Local exception handler to be armed in the reply method to automatic interrupts
					

Parameters:			Exception object

Return Value:		Standard JADE exception return code


Date			Who		Reason
07 Apr 2021		navmd1	Initial Creation TFS 42010 MTN - Early Termination of web services

*/

constants
	InterruptEx	= 4035;
	
vars
	
begin	
	// Not an Interrupt request ? Then not for us
	if not _exc.errorCode = InterruptEx then
		return Ex_Pass_Back;
	endif;
	
	_excOccurred := true;
	
	// Just log the fact that this happened for now... although we'll probably want to through an CM_ERROR of some description at some point
	app.writeLog("Webservice call Interrupted for " &amp; process.userInfo, LogWARN);
	
	return Ex_Resume_Next;
	
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_exc" type="Exception"/>
        <Parameter name="_excOccurred" type="Boolean" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleJADEExceptions" id="fd50f613-b662-4220-9593-a0b84e3a1bf7">
        <source>handleJADEExceptions(_exc : Exception) : Integer protected;

/*

Purpose:			Local exception handler to be armed in each Web Service method, to
					catch any unexpected exceptions

Parameters:			Exception object

Return Value:		Standard JADE exception return code


Date		Who		Reason
18 Feb 2009	cnwkpd1	PAR #17554 - Development of new RIA Web Service application
07 Apr 2021 navmd1	TFS 42010 Pass back 4035 (User Interrupted) UEs so we can handle them ourselves

*/

constants
	Interrupted = 4035;
vars
	
begin
	// If we've just been interrupted, then let someone else deal with it
	if _exc.errorCode = Interrupted then
		return Ex_Pass_Back;
	endif;

	// Just allow CardSchema generic exception handler to do its thing
	return app.cnGlobalExceptionHandler(_exc);

	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_exc" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleLockExceptions" id="33b0d23a-da42-4dd5-9ccf-b09bec77a111">
        <source>handleLockExceptions(_exc : LockException io) : Integer protected;

/*

Purpose:			Generic local lock exception handler for Web Service methods 

Parameters:			Lock Exception

Return Value:		Exception handler return code


Date		Who		Reason
18 Feb 2009	cnwkpd1	PAR #17554 - Development of new RIA Web Service application

*/

vars

begin
	// Just allow standard CardSchema lock retry mechanism
	return app.cnGlobalLockExceptionHandler(_exc);
	
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_exc" type="LockException" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleReplyExceptions" id="183a3a87-cc20-44ea-a443-baf3de462d36">
        <source>handleReplyExceptions(_exc : Exception;
					  _excOccurred : Boolean io) : Integer protected;

/*

Purpose:			Local exception handler to be armed in the reply method to handlle issues during the JADE
					framework reply

Parameters:			Exception object

Return Value:		Standard JADE exception return code


Date		Who		Reason
19 Dec 2013	cnwkpd1	PAR #33225 - Invalid Web Session objects causing "hanging" client

*/

constants
	ObjectNotFound	= 4;
	
vars
	stackDump		: CnStackDump;
	ignoreDump		: Boolean;
	
begin
	// Do not handle Lock Exceptions here
	if _exc.isKindOf(LockException) then
		return Ex_Pass_Back;
	endif;
	
	_excOccurred := true;

	// For resumable exceptions, resume so that a reply is sent
	if _exc.resumable then

		// If the exception is the known one with a deleted Web Session object, then do not dump
		if _exc.errorCode = ObjectNotFound and _exc.errorObject.isKindOf(SWebServiceSchema) then
			app.writeLog(method.qualifiedName &amp; " Error 4 for a Web Session, ignoring dump", LogERROR);	//26 Nov 2019	NDL	TFS 47053
			ignoreDump := true;
		endif;
		
		// Create a dump if required
		if not ignoreDump then
			create stackDump transient;
			stackDump.dumpStack(_exc);
		endif;
		
		app.writeLog(method.qualifiedName &amp; " returning Ex_Resume_Next", LogERROR);	//26 Nov 2019	NDL	TFS 47053
		
		return Ex_Resume_Next;
		
	endif;
	
	return Ex_Pass_Back;

	
epilog
	delete stackDump;
	
end;</source>
        <access>protected</access>
        <Parameter name="_exc" type="Exception"/>
        <Parameter name="_excOccurred" type="Boolean" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleXMLException" id="8fa15f0c-90c3-48a1-b68e-549107a5b786">
        <source>handleXMLException(_exc : JadeXMLException; _parsingError : Boolean io) : Integer protected;

/*

Purpose:			Handle any error during parsing of the incomingMessage

Parameters:			Exception object

Return Value:		_parsingError set to true when an exception occurs


Date		Who		Reason
31 Aug 2009	cnwkpd1	PAR #20537 - Stop exception when parsing non-XML (HTML Test Harness) input

*/

vars

begin
	app.writeLog(method.qualifiedName &amp; 
							 " " &amp; _exc.class.name &amp; 
							 " " &amp; _exc.errorCode.String &amp; 
							 " " &amp; _exc.text &amp; 
							 " " &amp; _exc.extendedErrorText, LogDEBUG);	//26 Nov 2019	NDL	TFS 47053
	
	_parsingError := true;
	
	return Ex_Resume_Next;
	
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_exc" type="JadeXMLException"/>
        <Parameter name="_parsingError" type="Boolean" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initialisePassport" id="98b7415a-65ba-4379-adda-efd722fef0bc">
        <source>initialisePassport() protected;

/*

Purpose:			Initialise passport to clean state, and set user and terminal from
					currentSession, ready for a web service transaction

Parameters:			None

Return Value:		None


Date		Who		Reason
16 Jul 2008	cnwkpd1	PAR #17554 - Development of new RIA Web Service application
// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	passport		: CM_Passport;
	locale			: CM_Locale;
	user			: CM_User;
	isJMTUnitTest	: Boolean;
	
begin
	passport := app.myPassport;
	passport.initialiseTransaction();
	
	if currentSession &lt;&gt; null then
		// Set details from session
		passport.setMyUser(currentSession.myUser);
		passport.setMyTerminal(currentSession.myCurrentTerminal);
	else
	/*	isJMTUnitTest := false;
		executeWhen JMTDevelopmentEnvironment;
		if app.name = "JMTUnitTest" or app.name = "JMTUnitTestRunner" then
			isJMTUnitTest := true;
		endif;
		endExecuteWhen; */
		isJMTUnitTest := app.isJMTUnitTest;
		if not isJMTUnitTest then
			// Set defaults for anonymous
			passport.setMyUserFromCode("SUPERUSER");
			passport.setMyTerminal(CM_Terminal.firstInstance);
		else
			// in test mode
			passport.setMyUserFromCode("SUPERUSER");
			passport.setMyTerminal(CM_Root.firstInstance.allTerminals.getAtKey("UT"));
		endif;
	endif;
	
	self.setIgnoreWarnings(false); //data integrity
	
	// Set up application locale from current User for each transaction
	user := app.getMyUser();
	if user &lt;&gt; null then
		locale := user.getLocale();
	endif;
	app.setLocale(locale);
	
	// Ensure "special" is set correctly
	if user &lt;&gt; null and user.code = "SUPERUSER" then
		app.setSpecial('31/12/3000'.TimeStamp);
	else
		app.setSpecial(app.actualTimeServer);// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	endif;
	
	app.isRTApp:=false;
	
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initialisePassportExternal" id="510715f2-0e11-4283-a2c1-b750165674ee">
        <source>initialisePassportExternal() protected;
/*

Purpose:			Initialise passport to clean state, ready for a web service transaction

Parameters:			None

Return Value:		None

Date		Who		Reason
04 Apr 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars
	passport		: CM_Passport;
	locale			: CM_Locale;
	user			: CM_User;
	isJMTUnitTest	: Boolean;
	
begin
	passport := app.myPassport;
	passport.setForLogon(null);
	passport.initialiseTransaction();
	
	self.setIgnoreWarnings(false); //data integrity
	
	app.isRTApp := false;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="isWhiteListedMethod" id="ed52a192-694d-4441-a685-2ee759c95cb6">
        <source>isWhiteListedMethod(methodName : String) : Boolean protected;
/*

Purpose:	

Returns true if method can be accessed by public user in web portal		

Parameters:			

Return Value:		

Date		Who		Reason
04 Jul 2024	NAVBK1	Initial creation Bug 62228
15 Aug 2024 NAVSCK1	Defect 65557: MTN -  Web Portal weight measurement is empty in bookings
30 Oct 2024	jlier1 	MTN-33249
*/
vars
	session : String;
begin
	if app.logLevel = LogDEBUG then
		session := currentSession.getPropertyValue('_encryptedSessionId').String;
		app.writeLog(method.qualifiedName &amp; " [" &amp; session &amp; "] Validating call to &lt;" &amp; methodName &amp; "&gt;", LogDEBUG);
	endif;
	
	if methodName = JMTSecureService::logonAsAnonymousUser.name then
		return true;
	endif;
	if methodName = JMTSecureService::logonWithRequest.name then
		return true;
	endif;
	if methodName = JMTSecureService::logonChangePasswordRequest.name then
		return true;
	endif;
	if methodName = JMTSecureService::resetPassword.name then
		return true;
	endif;
	if methodName = JMTSecureService::forceOffOldSessions.name then
		return true;
	endif;
	if methodName = JMTSecureService::logon.name then
		return true;
	endif;
	if methodName = JMTSecureService::logonAndChangePassword.name then
		return true;
	endif;
	if methodName = JMTSecureService::logout.name then
		return true;
	endif;
	if methodName = JMTUserInterfaceService::getAllLocales.name then
		return true;
	endif;
	if methodName = JMTUserInterfaceService::getUserLocale.name then
		return true;
	endif;
	if methodName = JMTUserInterfaceService::getTerminals.name then
		return true;
	endif;
	if methodName = JMTUserInterfaceService::getCurrentTerminal.name then
		return true;
	endif;
	if methodName = JMTUserInterfaceService::setCurrentTerminal.name then
		return true;
	endif;
	if methodName = JMTUserInterfaceService::getVesselSchedule.name then
		return true;
	endif;
	if methodName = JMTUserInterfaceService::checkPermissions.name then
		return true;
	endif;
	if methodName = JMTUserInterfaceService::getTerminalConfig.name then
		return true;
	endif;
	if methodName = JMTUserInterfaceService::getVoyageProcessDepot.name then
		return true;
	endif;
	if methodName = JMTUserInterfaceService::getUserStateData.name then
		return true;
	endif;
	if methodName = JMTUserInterfaceService::findCargoQuickView.name then
		return true;
	endif;
	if methodName = JMTUserInterfaceService::findCargoByUID.name then
		return true;
	endif;	
	if methodName = JMTUserInterfaceService::getMeasurementTypes.name then
		return true;
	endif;	
	if methodName = JMTUserInterfaceService::getIMEXStatuses.name then
		return true;
	endif;	
	if methodName = JMTUserInterfaceService::getSiteSate.name then
		return true;
	endif;	
	if methodName = JMTUserInterfaceService::getTransportModes.name then
		return true;
	endif;
	if methodName = JMTUserInterfaceService::getVehicleType.name then
		return true;
	endif;
	if methodName = JMTUserInterfaceService::getVehicleMake.name then
		return true;
	endif;
	if methodName = JMTUserInterfaceService::getVehicleModel.name then
		return true;
	endif;
	if methodName = JMTUserInterfaceService::getSystemSpecialLifts.name then
		return true;
	endif;
	if methodName = JMTUserInterfaceService::getCoolingTypes.name then
		return true;
	endif;
		
	return false;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="methodName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="logIncomingMessage" id="6c2b34e1-0631-4b15-b2a3-ddf2b034757b">
        <source>logIncomingMessage() protected;

/*

Purpose:			Log the incoming raw SOAP message if required

Parameters:			None

Return Value:		None


Date		Who		Reason
04 Feb 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift
01 Apr 2021 navmd1	TFS 51047 - Always log the input/start time of a SOAP web request - otherwise we don't have enough logging on the default log level

*/

vars

begin
	
	app.writeLog("input=" &amp; self.incomingMessage, LogINFO);	//26 Nov 2019	NDL	TFS 47053
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="logIncomingMessageSecure" id="dd66da37-1a84-4515-a88d-5382636d3096">
        <source>logIncomingMessageSecure() protected;

/*

Purpose:			Log the incoming raw SOAP message if required
					Reimplementation for secure services, which will strip out password information

Parameters:			None

Return Value:		None

Date		Who		Reason
05 Apr 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration
					Promoted from JMTSecureService
					Refactored out to CM_XmlHelperAgent
01 Apr 2021 navmd1	TFS 51047 - Always log the input/start time of a SOAP web request - otherwise we don't have enough logging on the default log level
*/

vars
	xmlHelper 		: CM_XmlHelperAgent;
	revisedXml		: String;
	
begin
	
	create xmlHelper transient;
	revisedXml := xmlHelper.hidePasswordFieldsForLogging(self.incomingMessage);

	app.writeLog("input=" &amp; revisedXml, LogINFO);	//26 Nov 2019	NDL	TFS 47053
		

epilog
	delete xmlHelper;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="postProcessResponse" id="295ad240-302a-452b-beab-4cc57bbe4616">
        <source>postProcessResponse(_reply : String) : String protected;
/*

Purpose:			Hook method to enable modification of the reply string before it is returned by
					JADE to the caller

Parameters:			Original reply message

Return Value:		Modified reply to send to caller

Date		Who		Reason
05 Apr 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration
12 Jul 2019 jlgmd1	TFS 45661 - Add some useful debug info to be able to tell what a web services is doing from monitor
07 Apr 2021 navmd1	TFS 42010 MTN - Early Termination of web services

*/

vars
	wsSupport : WS_WebServiceSupportAgent;
begin
	// Register the end of the message ASAP, so we don't interrupt our reply! (must be before setUserInfo)
	self.myWebServiceAgent.cancelInterruptRequest();

	process.setUserInfo(app.name);

	// Default is to make no changes
	return _reply;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_reply" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="preProcessRequest" id="4c5389dc-cc03-449e-bbbd-b378439cbe9d">
        <updating/>
        <source>preProcessRequest() updating, protected;
/*

Purpose:			Hook method to allow pre processing of the incomingMessage before JADE 
					tries to parse it

Parameters:			

Return Value:		

Date		Who		Reason
05 Apr 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration
12 Jul 2019 jlgmd1	TFS 45661 - Add some useful debug info to be able to tell what a web services is doing from monitor
07 Apr 2021	navmd1	TFS 42010 MTN - Early Termination of web services

*/

vars
	wsSupport	: WS_WebServiceSupportAgent;
begin
	self.logIncomingMessage();

	// Default is to do nothing to the incomingMessage
	
	process.setUserInfo(self.getMethodName &amp; "@" &amp; app.actualTimeServer.time.shortFormatJMTSecs());
	
	// Register the start of the message (must be after setUserInfo)
	self.myWebServiceAgent.startInterruptRequest(false);
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="processRequest" id="061b8e44-4eae-40c9-bd55-4ffe9b7486b1">
        <updating/>
        <source>processRequest() updating, protected;
/*

Purpose:			Process the request from the consumer

Parameters:			

Return Value:		

Date		Who		Reason
05 Apr 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration
					Created to allow for preProcessing hook call
*/

vars

begin
	// Add in hook to pre process the request if required
	self.preProcessRequest();
	
	inheritMethod();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="removeUnsuccessfullSession" id="d626bedd-3bc3-4077-b289-01915e5e9dc9">
        <source>removeUnsuccessfullSession() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Feb 2021 cnwma1  Bug 50631: AAT - MobileApps Issue - Invalid Web Session Messages

*/

vars
	option,
	timeRemaining	: Integer;
	active			: Boolean;
begin

	active := app.getTimerStatus(app.Remove_Session_After_Reply, option, timeRemaining);
	
	app.temporaryWebSessions.add(currentSession);
	
	if not active then
		app.beginTimer(0, Timer_OneShot, app.Remove_Session_After_Reply);
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="reply" id="33ae9a01-d4f9-4830-b0af-87aaaabca564">
        <updating/>
        <source>reply(): String updating, protected;

/*

Purpose:			Re-implementation of standard reply message.  
					Used to provide diagnostic logging of full output message content.
					Input message detail can be obtained by using JADE web service logging 
					if required.


Return Value:		Inherited reply String


Date		Who		Reason
16 Jul 2008	cnwkpd1	PAR #17554 - Development of new RIA Web Service application
19 Dec 2013	cnwkpd1	PAR #33225 - Invalid Web Session objects causing "hanging" client.  Ensure there is 
					a reply sent in all scenarios
05 Apr 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration
					Add preProcessing and postProcessing hook calls
18 Apr 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration
					Add createActivityHistory hook call
01 Apr 2021 navmd1	TFS 51047 - Always log the end time of a SOAP web request - otherwise we don't have enough logging on the default log level
08 Apr 2021 navmd1	TFS 42010 - Handle early terminaltion of Web Services
					
*/

vars
	returnVal		: String;
	pos				: Integer;
	excOccurred,
	interrupted		: Boolean;

begin
	on Exception do self.handleReplyExceptions(exception, excOccurred);
	on Exception do self.handleInterruptExceptions(exception, interrupted);
	
	returnVal := inheritMethod();
	
	if excOccurred or interrupted then
		returnVal := self.generateSOAPFault(interrupted);
	endif;
	
	// Add in hook to modify response if required
	returnVal := self.postProcessResponse(returnVal);
	
	// Add in hook to create Activity History if required
	self.createActivityHistory(returnVal);
	
	// Always write the reply time to the log, so we can match it to the start time
	app.writeLog("Sending Reply", LogINFO);
	
	app.writeLog("reply=" &amp; returnVal, LogDEBUG);	//26 Nov 2019	NDL	TFS 47053
	executeWhen JMTDevelopmentEnvironment;
	if returnVal.length &gt; 9000 then
		foreach pos in 1 to returnVal.length step 9000 do
			if pos + 9000 &gt; returnVal.length then
				app.writeLog(returnVal[pos:end], LogDEBUG);	//26 Nov 2019	NDL	TFS 47053
			else
				app.writeLog(returnVal[pos:9000], LogDEBUG);	//26 Nov 2019	NDL	TFS 47053
			endif;
		endforeach;
	endif;
	endExecuteWhen;
	
	// No point in doing this now we're not logging to the CN log
	//app.myCnLog.commitLog();
		
	return returnVal;

epilog

end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setIgnoreWarnings" id="dc6f1184-ccd9-4b6a-8c04-95acf97a07a6">
        <source>setIgnoreWarnings(ignore : Boolean) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 September 2008	cnwkao1	Initial creation

*/

vars

begin
	app.myPassport.setWarningsIgnored(ignore); 
	app.myPassport.warningsAcknowledged := ignore; 
epilog

end;</source>
        <access>protected</access>
