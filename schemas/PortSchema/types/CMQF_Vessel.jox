<Class name="CMQF_Vessel" id="cd04ce3b-d143-4311-8d75-a3f924c950b4">
    <superclass name="CMQF_FilterReports"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <ImplicitInverseRef name="myVessel" id="feec5c04-b9a8-4e77-befb-73aa627d3659">
        <embedded/>
        <type name="CM_Vessel"/>
        <access>protected</access>
    </ImplicitInverseRef>
    <JadeMethod name="cloneReferences" id="e470869e-2cd3-4077-9b3c-10d9d5b55362">
        <updating/>
        <source>cloneReferences(_obj: CMQF_Vessel; _transient: Boolean) updating;
/*

Date		Who		Reason
17 June 2015	cnwer1	Initial creation PAR 36434

*/

vars

begin
	inheritMethod(_obj, _transient);
	self.setMyVessel( _obj.getMyVessel );
epilog

end;</source>
        <Parameter name="_obj" type="CMQF_Vessel"/>
        <Parameter name="_transient" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="filterObjects" id="943452d0-2142-4a48-b744-50a9a99ba98f">
        <updating/>
        <source>filterObjects(_collection: Collection input; _passport: CM_Passport) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 May 2012	cnwndl1	Initial creation	Par 29496
17 Feb 2015	cnwkpd1	PAR #35704 - Changes to prevent extended locking

*/

vars

	vessel : CM_Vessel;
	breakOut : Boolean;

begin
	inheritMethod(_collection, _passport);
	
	if self.getMyVessel &lt;&gt; null then
		_collection.add(self.getMyVessel);
		return;
		
	else
		foreach vessel in app.myRoot.allVessels discreteLock do
					
			if self.includesObject(vessel, _passport, breakOut) then
				_collection.add(vessel);
			endif;
			
			if breakOut then
				break;
			endif;
				
		endforeach;
		
	endif;

epilog

end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="fc936e67-b4ed-4e07-902a-253bafe083a1">
        <source>getDisplayStringForAttribute(_attrName: String; _getCalculatedDate: Boolean): String;
/*

Date		Who		Reason
17 June 2015	cnwer1	Initial creation PAR 36434

*/

vars

begin
	if _attrName = ETRow_Vessel then
		if self.getMyVessel &lt;&gt; null then
			return self.getMyVessel.code;
		endif;
		return null;
	endif;
	
	return inheritMethod(_attrName, _getCalculatedDate);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_getCalculatedDate" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyVessel" id="dc9d05ba-a514-4e87-ae0c-07c0f151da85">
        <source>getMyVessel():CM_Vessel;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 July 2016	cnwndl1	Initial creation	TFS 2329

*/

vars

	vessel : CM_Vessel;
	edition : Integer;
	invalidObj : Boolean;

begin

	vessel := self.myVessel;

	if vessel = null then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject( exception, vessel, invalidObj );
	edition := vessel.edition;
	
	if invalidObj then
		return null;
	endif;
	
	return vessel;

epilog

end;</source>
        <ReturnType type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="db745bed-e2eb-48cf-9a6c-b6d963bb0a10">
        <updating/>
        <source>includesObject(_vessel: CM_Vessel; _passport: CM_Passport; _breakOut: Boolean output): Boolean updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 May 2012	cnwndl1	Initial creation

*/

vars
	querySelf 	: CMQF_Vessel;
	
begin
	querySelf := self;
	querySelf.numSearched := querySelf.numSearched + 1;
	
	if _vessel &lt;&gt; null  then
		querySelf.numFound := querySelf.numFound + 1;
		return true;
	endif;
	
	return false;

end;</source>
        <access>protected</access>
        <Parameter name="_vessel" type="CM_Vessel"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMyVessel" id="197352d7-d484-4df6-95e6-67b290ad13f1">
        <updating/>
        <source>setMyVessel( _vessel : CM_Vessel ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 July 2016	cnwndl1	Initial creation	TFS 2329

*/

vars

begin

	self.myVessel := _vessel;

epilog

end;</source>
        <Parameter name="_vessel" type="CM_Vessel"/>
    </JadeMethod>
</Class>
