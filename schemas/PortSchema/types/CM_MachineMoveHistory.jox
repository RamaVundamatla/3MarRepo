    <JadeMethod name="isRejectedMoveHistory" id="568c2ef9-2e4e-4276-a535-6b0ba1ce2e04">
        <source>isRejectedMoveHistory():Boolean;
// ---------------------------------------------------------------------------
// Created:     06 December 2010 by cnwcs5 par 23714/ccms 1132
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	result		:Boolean;
	nextHistory	:CM_MachineHistory;
begin
	if self.type = self.Type_RejectMove then
		result := true;
		
	elseif self.type = self.Type_AcceptMove then
		nextHistory := self.myNextHistory;
		
		if nextHistory &lt;&gt; null and nextHistory.type = self.Type_RejectMove then
			result := true;
		endif;
	endif;
	
	return result;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isStartOfMove" id="81014726-a531-4293-ad18-4cedd54dd8ac">
        <source>isStartOfMove():Boolean;
// ---------------------------------------------------------------------------
// Created:     04 November 2010 by cnwcs5 par 23714/ccms 1132
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	return self.myPriorHistory = null;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isTaskEndOfLift" id="66c21e1a-33e6-4132-9b3d-bfb4e4e9c4ee">
        <source>isTaskEndOfLift(_task :CM_RTQueueTask; _machine :CM_Machine):Boolean protected;
// ---------------------------------------------------------------------------
// Created:     02 November 2010 by cnwcs5 par 23714/ccms 1132
// Purpose:     
// Parameters:  _task 		- task related to the receiver
//				_machine	- machine history is being created for
// Returns:     true if there are not tasks other than _task assigned to the machine
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 13/11/2012	cnwcs5		par 30730 - diver initiated moves
// ---------------------------------------------------------------------------
vars
	type,
	size			:Integer;
	task, pickup,
 	imvTask			:CM_RTQueueTask;
	coll			:CM_RTQueueTaskByStatusDict;
begin
	type := self.type;
	coll := _machine.allCurrentWorkingQueueTasks;
	size := coll.size;
	
	if size = 0 then
		// machine has no working tasks right now - unlikely to happen since machine is set B4 history created
		return true;
	else
		// we have one or more tasks assigned to the machine
		if _task = null then
			// we are probably a driver initiated move 
			// still some other stuff to do.
			return false;
		endif;
	endif;

	// maybe it is the only task for this machine
	if size = 1 then
		task := coll.first;
		
		if task = _task then
			// I am the only task assigned to this machine
			return true;
		endif;
		
		// if _task is a setdown ignore corresponding pickup
		// we need to do this if recording history for completed Move
		// before pickup/setdown tasks have been completed
		if _task.isSetDown and _task.myMachine = null then
			// setdown task not assigned to machine 
			pickup := _task.myEntry.findTaskOfType (TASK_PICKUP, NULL_INTEGER);
			
			if task = pickup then
				return true;
			endif;
		elseif _task.taskType = TASK_PICKUP and _task.myMachine &lt;&gt; _machine and _machine.isIMV then
			// pickup from IMV by another machine - so setdown by IMV may be last task
			if task.taskType = TASK_MOVE and task.ti = _task.ti then
				// move for same ti - 
				return true;
			endif;
		endif;
	endif;
	return false;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_task" type="CM_RTQueueTask"/>
        <Parameter name="_machine" type="CM_Machine"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isTaskStartOfLift" id="fc630c82-74c4-47ed-8d4d-41a496cdab26">
        <source>isTaskStartOfLift(_task :CM_RTQueueTask; _machine :CM_Machine):Boolean protected;
// ---------------------------------------------------------------------------
// Created:     24 November 2010 by cnwcs5 par 23714/ccms 1132
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	type,
	size			:Integer;
	task, pickup,
 	imvTask			:CM_RTQueueTask;
	coll			:CM_RTQueueTaskByStatusDict;
begin
	type := self.type;
	
	if type &lt;&gt; self.Type_AcceptMove and type &lt;&gt; self.Type_Move then
		return false;
	endif;
	
	coll := _machine.allCurrentWorkingQueueTasks;
	size := coll.size;
	
	if size = 0 then
		// machine has no working tasks right now - must be first task for machine
		return true;
	endif;
		
	// maybe it is the only task for this machine
	if size = 1 then
		task := coll.first;
		
		if task = _task then
			return true;
		endif;
	endif;

	return false;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_task" type="CM_RTQueueTask"/>
        <Parameter name="_machine" type="CM_Machine"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jrwGetGrossMoveDuration" id="5c4d7af8-5837-4786-bc9e-1bec1f1a2f6e">
