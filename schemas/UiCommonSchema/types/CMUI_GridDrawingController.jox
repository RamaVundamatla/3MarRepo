    <JadeMethod name="getLegendDetailsForObject" id="f4703111-f8eb-4b5d-a066-3e017a09009a">
        <source>getLegendDetailsForObject(_obj : Object; _colour : Integer output) : String;
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	theViewMode : Integer;
	theString : String;
	anOp : CM_Operator;
	aVoy : CM_Voyage;
	aTemp : CM_TempRange;
	aCom : CM_CommodityGroup;
	aCon : CM_ConsigneeConsignor;
	aPort : CM_Port;
	anISO : CM_ISOTypeGroup;
	aWeight	: CM_WeightRange;
	tmpVoyYA : CM_VoyageAllocation;
	carrier: CM_Carrier;
	isoType : CM_ISOType;
begin

	_colour := White;

	theViewMode := self.viewMode;
	
	if theViewMode = VIEW_OPERATOR and CM_Operator.hasInstance(_obj) then
		anOp := _obj.CM_Operator;
		theString := anOp.description.trimBlanks;
		_colour	:= anOp.colour;
		
	elseif theViewMode = VIEW_VOYAGE and CM_Voyage.hasInstance(_obj) then
		aVoy := _obj.CM_Voyage;
		theString := aVoy.description.trimBlanks;
		_colour := aVoy.colour;
				
	elseif theViewMode = VIEW_TEMPERATURE and CM_TempRange.hasInstance(_obj) then
		aTemp := _obj.CM_TempRange;
		theString := aTemp.value.String;
		_colour := aTemp.colour;

	elseif theViewMode = VIEW_COMMODITY and CM_CommodityGroup.hasInstance(_obj) then
		aCom := _obj.CM_CommodityGroup;
		theString := aCom.description.trimBlanks;
		_colour := aCom.colour;
		
	elseif theViewMode = VIEW_WEIGHT and CM_WeightRange.hasInstance(_obj) then
		aWeight := _obj.CM_WeightRange;
		theString := aWeight.value.String;
		_colour := aWeight.colour;
		
	elseif theViewMode = VIEW_CONSIGNEE and CM_ConsigneeConsignor.hasInstance(_obj) then
		aCon := _obj.CM_ConsigneeConsignor;
		theString := aCon.description.trimBlanks;
		_colour := aCon.colour;

	elseif (theViewMode = VIEW_DISPORT or theViewMode = VIEW_LOADPORT) and
			CM_Port.hasInstance(_obj) then
		aPort := _obj.CM_Port;
		theString := aPort.description.trimBlanks;
		_colour := aPort.colour;

//	elseif theViewMode = VIEW_STATUS then
//		theString := theCode;
	elseif theViewMode = VIEW_ISOGROUP and self.getShipShowISOType()  and CM_ISOType.hasInstance(_obj) then // TFS 37556
		isoType := _obj.CM_ISOType;
		theString := isoType.description.trimBlanks;
		_colour := isoType.colour;

	elseif theViewMode = VIEW_ISOGROUP and CM_ISOTypeGroup.hasInstance(_obj) then
		anISO := _obj.CM_ISOTypeGroup;
		theString := anISO.description.trimBlanks;
		_colour := anISO.colour;
		
	elseif theViewMode = VIEW_YARD_ALLOC and CM_VoyageAllocation.hasInstance(_obj) then	// #25222 29/07/2010
		tmpVoyYA := _obj.CM_VoyageAllocation;
		theString := tmpVoyYA.description.trimBlanks;
		_colour := tmpVoyYA.color;
		
	elseif (theViewMode = VIEW_CARRIERIN or theViewMode = VIEW_CARRIEROUT) and CM_Carrier.hasInstance(_obj) then	// 9/6/17 MAP TFS4209
		carrier := _obj.CM_Carrier;
		theString := carrier.description.trimBlanks;
		_colour := carrier.colour;

	endif;
	
	return theString;

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_colour" type="Integer" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMoveModeFromDisplayMode" id="c5337e12-ad7d-44b9-92e9-e15b8e40f9d0">
        <source>getMoveModeFromDisplayMode() : Integer;
/*
Purpose:			
Date		Who		Reason
05 September 2013	cnwab1	Initial creation
*/

vars

begin
	if self.displayMode = DISPLAY_MODE_ACTUAL then
		return REAL_MODE;
	elseif self.displayMode = DISPLAY_MODE_PLAN then
		return PLANNING_MODE;
	elseif self.displayMode = DISPLAY_MODE_QUEUE then
		return QUEUE_MODE;
	endif;
	
	return REAL_MODE;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
