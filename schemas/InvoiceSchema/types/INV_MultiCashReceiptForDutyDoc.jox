    <JadeMethod name="loadFromInitDutyDoc" id="07c4b10a-c0c1-4b54-8768-5f2f89481d41">
        <updating/>
        <source>loadFromInitDutyDoc() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 March 2013	cnwer1	Initial creation HAT 2189

*/

vars

	consignee : CM_ConsigneeConsignor;

begin
	if self.myInitDutyDoc = null then
		return;
	endif;
	
	if self.txtItemId.text.trimBlanks = null then
		if self.myTerminal.getConfig(ProFormaInclDDTicket).Boolean and self.myInitDutyDoc.ticket.trimBlanks &lt;&gt; null then
			self.txtItemId.text := self.myInitDutyDoc.ticket.toUpper;
		elseif self.myTerminal.getConfig(ProFormaInclDDBill).Boolean then
			self.txtItemId.text := self.myInitDutyDoc.id.toUpper;
		endif;
	endif;
	
	self.doPerformSearch();
	
	//06 Nov 2013	NDL	Par 
	consignee := self.myInitDutyDoc.getMyConsignee;
	if consignee &lt;&gt; null then
		self.cmbConsignee.listIndex := self.cmbConsignee.findObject(consignee);
	endif;
	
	self.btnFind.visible:=false;
	self.btnAddPay.enabled:=false;
	self.btnDelPay.enabled:=false;
	self.btnPayCancel.enabled:=false;
	self.btnSave.enabled:=false;
	self.btnUpdPay.enabled:=false;
	
	self.optConsignee.visible := false;
	self.lblConsignee.visible := false;
	self.optConsignee.enabled := false;
	self.optConsignee.value := false;
	self.optItem.value := true;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
