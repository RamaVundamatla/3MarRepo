    <JadeMethod name="lookupAllOffSiteTrackedItems" id="ec1b1ef8-fe4e-4594-b1b1-a8f086be23d5">
        <source>lookupAllOffSiteTrackedItems(pCargoType : Integer; pId : String; _tis : CM_TISet input; _cmifMonitor : CMIF_Monitor input) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 May 2010	cnwrd1	Initial creation

*/

vars
	set		: CM_TISet;
	ls : Boolean;
	terminal : CM_Terminal;
begin

	terminal := self.myTerminal;
	
	create set transient;
	ls := process.isInLoadState;
	endLoad;
	beginLoad;
	if pCargoType = null then
		self.allOffsiteTIsByIdCargoType.lookupAllTIsUsingIdCargoType(pId, pCargoType, set, _cmifMonitor);
	else
		self.allOffsiteTIsByCargoTypeId.lookupAllTIsUsingIdCargoType(pId, pCargoType, set, _cmifMonitor);
	endif;
	endLoad;
	
	// no offsite tis by cargo type id rev
	
	if set.isEmpty then
		//cnwjo3 par 24661
		if pId.length &gt; 0 then
			// Check for reversed
			beginLoad;
			terminal.allOffsiteTIsByCargoTypeIdRev.lookupAllTIsUsingIdCargoType(pId.reverse, pCargoType, set, _cmifMonitor);
			endLoad;
			if set.isEmpty then
				// TI not found
				return;
			endif;
		endif;
	endif;
	
	set.copyNoDuplicates(_tis, false);
epilog
	delete set;
	if ls and not 	process.isInLoadState then
		beginLoad;
	else
		endLoad;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pCargoType" type="Integer"/>
        <Parameter name="pId" type="String"/>
        <Parameter name="_tis" type="CM_TISet" usage="input"/>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lookupAllTIsOfIdCargoType" id="072a0c9b-ea1e-418a-8417-b3200106cd5b">
        <source>lookupAllTIsOfIdCargoType(_id : String; _cargoType : Integer; _tis : Btree input; _cmifMonitor : CMIF_Monitor input);
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04/05/2010	cnwrd1	Initial creation
27/05/2010	cnwdap1	CCMS 1116 Tranship changes
// 06 Sep 2016	cnwrs1	TFS 2586 dont always include archived voyages and lookup reveresed even if we found data in non reverese lookup
*/
vars
	upperId, 
	reverseId	: String;
	voy 	: CM_Voyage;
	ls : Boolean;
	tSet : CM_TISet;
	terminal : CM_Terminal;
begin

	terminal := self.myTerminal;
	
	if terminal = null then
		app.raiseCMException1(ERR_TerminalNotSet, self.code, null, null);
		return;
	endif;		
	
//	app.cmsBeginLoad(ls);	//Removed because of duration of load state in this situation DQ 31/05/2004
	ls := process.isInLoadState;
	endLoad;
	if _tis = null then
		app.raiseCMException2(MethodWithNullParam, method.name, 'tiSet', null, null);
		return;
	endif;
	//--------------------
	//Clear the set
	//--------------------
	_tis.clear; 
	
	create tSet transient;	
	upperId := _id.toUpper.trimBlanks;
	reverseId := upperId.reverse;
	//-----------
	//Grab all offsite 1st
	//-----------
	if _cmifMonitor &lt;&gt; null then
		if (not _cmifMonitor.updateProgress(app.getErrorString(Searching_Offsite), 7, 1)) then
			return;
		endif;
	endif;
		
		
	beginLoad;
		self.lookupAllOffSiteTrackedItems(_cargoType, upperId, tSet, _cmifMonitor);
	endLoad;


	if (not tSet.isEmpty) then
		tSet.copyNoDuplicates(_tis, false);
	endif;
	tSet.clear;
	//-----------
	//Search on site
	//-----------
	if _cmifMonitor &lt;&gt; null then
		if (not _cmifMonitor.updateProgress(app.getErrorString(Searching_Onsite), 7, 2)) then
			return;
		endif;
	endif;
	beginLoad;
	if _cargoType = null then
		self.allOnsiteTIsByIdCargoType.lookupAllTIsUsingIdCargoType(upperId, _cargoType, tSet, _cmifMonitor);
	else
		self.allOnsiteTIsByCargoTypeId.lookupAllTIsUsingIdCargoType(upperId, _cargoType, tSet, _cmifMonitor);
	endif;
	endLoad;

	

	// ****
	// no onsite ti by ID cargotype rev dict use terminal one
	// ****

	if tSet.isEmpty = false then
		tSet.copyNoDuplicates(_tis, false);
	else
		//cnwjo3 par 24661
		if reverseId.length &gt; 0 then
			beginLoad;
			//Reversed Dictionary
			terminal.allOnsiteTIsByCargoTypeIdRev.lookupAllTIsUsingIdCargoType(reverseId, _cargoType, tSet, _cmifMonitor);
			endLoad;
			if tSet.isEmpty = false then
				tSet.copyNoDuplicates(_tis, false);
			endif;
		endif;
	endif;
	tSet.clear;
	
	//----------------------
	// TBA Dictionary
	//----------------------
	if _cmifMonitor &lt;&gt; null then
		if (not _cmifMonitor.updateProgress(app.getErrorString(Searching_TBA), 7, 3)) then
			return;
		endif;
	endif;
	beginLoad;	
	self.allTbaTIsByIdCargoType.lookupAllTIsUsingIdCargoType(upperId, _cargoType, tSet, _cmifMonitor);
	endLoad;


		
	// ****
	// no allTbaTIsByCargoTypeIdRev user terminal one
	// ****

	if tSet.isEmpty = false then
		tSet.copyNoDuplicates(_tis, false);
	else
		//cnwjo3 par 24661
		if reverseId.length &gt; 0 then
			//Reversed Dictionary
			beginLoad;
			terminal.allTbaTIsByCargoTypeIdRev.lookupAllTIsUsingIdCargoType(reverseId, _cargoType, tSet, _cmifMonitor);
			endLoad;
			if tSet.isEmpty = false then
				tSet.copyNoDuplicates(_tis, false);
			endif;
		endif;
	endif;
	tSet.clear;
	
	//----------------------
	//Pre-Notified Dictionary
	//----------------------
	if _cmifMonitor &lt;&gt; null then
		if (not _cmifMonitor.updateProgress(app.getErrorString(Searching_Pre_Notified), 7, 4)) then
			return;
		endif;
	endif;
	beginLoad;
	self.allNotifiedTIsByIdCargoType.lookupAllTIsUsingIdCargoType(upperId, _cargoType, tSet, _cmifMonitor);
	endLoad;
	

	// ****
	// no allNotifiedTIsByCargoTypeIdRev use terminal
	// ****
		
	if tSet.isEmpty = false then
		tSet.copyNoDuplicates(_tis, false);
	else
		//cnwjo3 par 24661
		if reverseId.length &gt; 0 then
			//Reversed Dictionary
			beginLoad;
			terminal.allNotifiedTIsByCargoTypeIdRev.lookupAllTIsUsingIdCargoType(reverseId, _cargoType, tSet, _cmifMonitor);
			endLoad;
			if tSet.isEmpty = false then
				tSet.copyNoDuplicates(_tis, false);
			endif;
		endif;
	endif;
	tSet.clear;
	
	//----------------------
	// Deleted Dictionary
	//----------------------
	if _cmifMonitor &lt;&gt; null then
		if (not _cmifMonitor.updateProgress(app.getErrorString(Searching_Deleted), 7, 5)) then
			return;
		endif;
	endif;

	beginLoad;
	self.allDeletedTIsByIdCargoType.lookupAllTIsUsingIdCargoType(upperId, _cargoType, tSet, _cmifMonitor);
	endLoad;

	// ****
	// no allDeletedTIsByIdCargoTypeRev  use terminal
	// ****
			

	if tSet.isEmpty = false then
		tSet.copyNoDuplicates(_tis, false);
	else
		//cnwjo3 par 24661
		if reverseId.length &gt; 0 then
			//Reversed Dictionary
			beginLoad;
			terminal.allDeletedTIsByIdCargoTypeRev.lookupAllTIsUsingIdCargoType(reverseId, _cargoType, tSet, _cmifMonitor);
			endLoad;
			if tSet.isEmpty = false then
				tSet.copyNoDuplicates(_tis, false);
			endif;
		endif;
	endif;
	tSet.clear;
	
	//----------------------
	//onship
	//----------------------
	if _cmifMonitor &lt;&gt; null then
		if (not _cmifMonitor.updateProgress(app.getErrorString(Searching_Current_Voyages), 7, 6)) then
			return;
		endif;
	endif;
	beginLoad;
	self.lookupAllTrackedItems(upperId , _cargoType, true, false, tSet, _cmifMonitor );
	endLoad;
		
	if tSet.isEmpty = false then
		tSet.copyNoDuplicates(_tis, false);
	endif;
	
	//-----------------------
	// Tranships PAR #23645 CCMS 1116 start
	//-----------------------
	if _cmifMonitor &lt;&gt; null then
		if (not _cmifMonitor.updateProgress(app.getErrorString(Searching_Current_Voyages), 7, 6)) then
			return;
		endif;
	endif;
	beginLoad;
	self.allImportTIs.lookupAllTIsUsingIdCargoType(upperId, _cargoType, tSet, _cmifMonitor);
	self.allExportTIs.lookupAllTIsUsingIdCargoType(upperId, _cargoType, tSet, _cmifMonitor);
	endLoad;
	if tSet.isEmpty = false then
		tSet.copyNoDuplicates(_tis, false);
	endif;
	// PAR #23645 CCMS 1116 end

epilog
	delete tSet;
	//app.cmsEndLoad(ls);	//Removed because of duration of load state in this situation DQ 31/05/2004
	if ls and not process.isInLoadState then
		beginLoad;
	else
		endLoad;
	endif;
end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_tis" type="Btree" usage="input"/>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lookupAllTrackedItems" id="0823922f-7448-44e1-919c-97893c87c18f">
        <source>lookupAllTrackedItems(_id : String; _cargoType : Integer; _includeOffLoaded, _searchReversed : Boolean; _tis : CM_TISet input; _cmifMonitor : CMIF_Monitor input) : Boolean;
// ---------------------------------------------------------------------------
// Created:     17 October 2002 by cnwdwq1
//
// Purpose: 	Gets all TI's with id LIKE == passed in. We DONT look at EDI TI's
//						ONLY ACTUALs!
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 06 Sep 2016	cnwrs1	TFS 2586 dont always include archived voyages and lookup reveresed even if we found data in non reverese lookup
// ---------------------------------------------------------------------------

vars
	tmpSet 		: CM_TISet;
begin

	//if self.code = NULL_VOYAGE_CODE then
	if self.isNullVoyage then
		return true;
	endif;
	
	create tmpSet transient;

	self.allOnshipTIsByIdCargoType.lookupAllTIsUsingIdCargoType(_id, _cargoType, tmpSet, null);
	
	if (not tmpSet.isEmpty) then
		tmpSet.copyNoDuplicates(_tis, false);
	endif;
	if tmpSet.isEmpty or
	   _searchReversed then
		tmpSet.clear;
		//cnwjo3 par 24661
		if _id.length &gt; 0 then
			//----------
			//Also do the reversed keys
			//----------
			if (not self.allOnshipTIsByIdCargoTypeRev.lookupAllTIsUsingIdCargoType(_id.reverse, _cargoType, tmpSet, _cmifMonitor)) then
				return false;
			endif;
		endif;
		
		if (not tmpSet.isEmpty) then
			tmpSet.copyNoDuplicates(_tis, false);
			tmpSet.clear;
		endif;
	endif;
	
	if _includeOffLoaded then
		// now do offloaded
		self.allOffloadedTIsByIdCargoType.lookupAllTIsUsingIdCargoType(_id, _cargoType, tmpSet, null);
		
		if (not tmpSet.isEmpty) then
			tmpSet.copyNoDuplicates(_tis, false);
			tmpSet.clear;
		endif;
	endif;
	
	return true;

epilog
	delete tmpSet;
end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_includeOffLoaded" type="Boolean"/>
        <Parameter name="_searchReversed" type="Boolean"/>
        <Parameter name="_tis" type="CM_TISet" usage="input"/>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="lookupBayVoyage" id="7cf0b4dc-8c21-47b0-84de-96a7e7d10c93">
        <source>lookupBayVoyage(_bayId : String) : CM_BayVoyage;
/*
 ------------------------------------------------------------------------
Created:			27 September 2002 by cnwdwq1
Purpose:			Re-implemented on CM_CellularVoyage
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
begin
	if self.myCellularVoyageStructure &lt;&gt; null then
		return self.myCellularVoyageStructure.lookupBayVoyage(_bayId);
	else
		return null;
	endif;
end;</source>
        <Parameter name="_bayId" type="String"/>
        <ReturnType type="CM_BayVoyage"/>
    </JadeMethod>
    <JadeMethod name="lookupJob" id="8bd0d7f5-5e0d-4e4b-863a-31979c97b97a">
        <source>lookupJob(_jobNum: String): CM_VoyageJob;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     Searches all the orders of work of this voyage for the given job
//              Returns the first job found with this id or null ref
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	jobSheet :	CM_VoyageJobSheet;
	job : CM_VoyageJob;
begin

	foreach jobSheet in self.allJobSheets discreteLock do
	  // Lookup this job number to see if it already exists
		job := jobSheet.allJobsByJobNum[_jobNum];
		if job &lt;&gt; null then
			return job;
		endif;
			
	endforeach;
	return null;
epilog
	
end;</source>
        <Parameter name="_jobNum" type="String"/>
        <ReturnType type="CM_VoyageJob"/>
    </JadeMethod>
    <JadeMethod name="lookupTrackedItem" id="6ce1ac7c-af4f-43c7-a3cb-c093100cbe67">
        <source>lookupTrackedItem(_id : String; _cargoType : Integer; _tryReversed : Boolean) : CM_TrackedItem;
// ---------------------------------------------------------------------------
// Created:     14 February 2001 by cnwdwq1
//
// Purpose: 
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// Removed Site/state/index crap. We ONLY lookup TI's ON THE SHIP. NOT planned/queued/whatever, there are
//	no dictionaries for them, and they have NEVER been needed.
// ---------------------------------------------------------------------------

vars
	theTI: CM_TrackedItem;
begin

	//if self.code = NULL_VOYAGE_CODE then
	if self.isNullVoyage then
		return null;
	endif;
	
	theTI := self.allOnshipTIsByIdCargoType.lookupTIUsingIdCargoType(_id, _cargoType);

	if theTI &lt;&gt; null then
		return theTI;
	endif;
	
	//----------
	//Not found, try reverse
	//----------
	if _tryReversed then
		return self.allOnshipTIsByIdCargoTypeRev.lookupTIUsingIdCargoType(_id.reverse, _cargoType);
	endif;
	
	return null;

end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_tryReversed" type="Boolean"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="lookupTrackedItemAnyWhere" id="050cf2ae-ffe4-4112-b5cc-41c3296b3cb9">
        <source>lookupTrackedItemAnyWhere(_id : String; _objArray : ObjectArray input) : CM_TrackedItem;
/*
Purpose:		PAR 36176	
Date				Who			Reason
MAY 2015		CNWAB1		Initial creation
*/

vars
	theTI: CM_TrackedItem;
begin

	if self.isNullVoyage then
		return null;
	endif;
	
	if _objArray = null then
		
		theTI := self.allOnshipTIsByIdCargoType.getAtKeyGeq(_id,null); // ONSHIP
		if theTI &lt;&gt; null and theTI.id = _id then
			return theTI;
		endif;
		
		theTI := self.allOnsiteTIsByIdCargoType.getAtKeyGeq(_id,null); // ONSITE
		if theTI &lt;&gt; null and theTI.id = _id then
			return theTI;
		endif;
		
		theTI := self.allOffsiteTIsByIdCargoType.getAtKeyGeq(_id,null,null); // OFFSITE
		if theTI &lt;&gt; null and theTI.id = _id then
			return theTI;
		endif;
		
		theTI := self.allNotifiedTIsByIdCargoType.getAtKeyGeq(_id,null); // PRENOTE
		if theTI &lt;&gt; null and theTI.id = _id then
			return theTI;
		endif;
	else
	
		theTI := self.allOnshipTIsByIdCargoType.getAtKeyGeq(_id,null); // ONSHIP
		if theTI &lt;&gt; null and theTI.id = _id then
			foreach theTI in self.allOnshipTIsByIdCargoType discreteLock where theTI.id = _id do
				_objArray.add(theTI);
			endforeach;
		endif;
		
		theTI := self.allOnsiteTIsByIdCargoType.getAtKeyGeq(_id,null); // ONSITE
		if theTI &lt;&gt; null and theTI.id = _id then
			foreach theTI in self.allOnsiteTIsByIdCargoType discreteLock where theTI.id = _id do
				_objArray.add(theTI);
			endforeach;
		endif;
		
		theTI := self.allOffsiteTIsByIdCargoType.getAtKeyGeq(_id,null,null); // OFFSITE
		if theTI &lt;&gt; null and theTI.id = _id then
			foreach theTI in self.allOffsiteTIsByIdCargoType discreteLock where theTI.id = _id do
				_objArray.add(theTI);
			endforeach;
		endif;
		
		theTI := self.allNotifiedTIsByIdCargoType.getAtKeyGeq(_id,null); // PRENOTE
		if theTI &lt;&gt; null and theTI.id = _id then
			foreach theTI in self.allNotifiedTIsByIdCargoType discreteLock where theTI.id = _id do
				_objArray.add(theTI);
			endforeach;
		endif;
	
	
	endif;
	
	return null;

end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_objArray" type="ObjectArray" usage="input"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="lookupTrackedItemAnyWhereBOL" id="359ae46f-7ee4-4f5f-a155-99a412ccea6c">
        <source>lookupTrackedItemAnyWhereBOL(_id : String; _searchOffsite : Boolean; _objArray : ObjectArray input);
/*
Purpose:		PAR 36176	
Date				Who			Reason
MAY 2015		CNWAB1		Initial creation
July 2015		cnwjre1			Par 36613 return all cargo if no id
July 2015		cnwjre1			Par 36102 add option for invocie pro forma to search offsite
21/04/2016 		cnwma1 			PAR #37681  QNS - locking issue
19APR18 JLGAB1 TFS 37839 IF NO BOL ID then include Prenotes.
*/

vars
	ti, parent: CM_TrackedItem;
begin

	if self.isNullVoyage then
		return;
	endif;
	
	// ### ON SHIP
	//foreach ti in self.allOnshipTIsByIdCargoType do
	foreach ti in self.allOnshipTIsByIdCargoType discreteLock do  //21/04/2016 cnwma1 PAR #37681 
		if ti.myTerminal &lt;&gt; self.myTerminal then
			continue;
		endif;
		if _id = null or
		   ti.billOfLading  = _id then
			if ti.isChild then
				parent := ti.myParent;
				if parent &lt;&gt; null and
				   not _objArray.includes(parent) then
					_objArray.add(parent);
				endif;
			else
				if not _objArray.includes(ti) then
					_objArray.add(ti);
				endif;
			endif;
		endif;
	endforeach;

	
	// ### ON SITE
	//foreach ti in self.allOnsiteTIsByIdCargoType do
	foreach ti in self.allOnsiteTIsByIdCargoType discreteLock do  //21/04/2016 cnwma1 PAR #37681 
		if ti.myTerminal &lt;&gt; self.myTerminal then
			continue;
		endif;
		if _id = null or
		   ti.billOfLading  = _id then
			if ti.isChild then
				parent := ti.myParent;
				if parent &lt;&gt; null and
				   not _objArray.includes(parent) then
					_objArray.add(parent);
				endif;
			else
				if not _objArray.includes(ti) then
					_objArray.add(ti);
				endif;
			endif;
		endif;
	endforeach;

	
	// ### OFF LOADED
	//foreach ti in self.allOffloadedTIsByCargoTypeId do
	foreach ti in self.allOffloadedTIsByCargoTypeId discreteLock do  //21/04/2016 cnwma1 PAR #37681 
		if ti.myTerminal &lt;&gt; self.myTerminal then
			continue;
		endif;
		if _id = null or
		   ti.billOfLading  = _id then
			if ti.isChild then
				parent := ti.myParent;
				if parent &lt;&gt; null and
				   not _objArray.includes(parent) then
					_objArray.add(parent);
				endif;
			else
				if not _objArray.includes(ti) then
					_objArray.add(ti);
				endif;
			endif;
		endif;
	endforeach;

	// ### OFF SITE
	if _searchOffsite then
		//foreach ti in self.allOffsiteTIsByCargoTypeId do
		foreach ti in self.allOffsiteTIsByCargoTypeId  discreteLock do  //21/04/2016 cnwma1 PAR #37681 
			if ti.myTerminal &lt;&gt; self.myTerminal then
				continue;
			endif;
			if _id = null or
			   ti.billOfLading  = _id then
				if ti.isChild then
					parent := ti.myParent;
					if parent &lt;&gt; null and
					   not _objArray.includes(parent) then
						_objArray.add(parent);
					endif;
				else
					if not _objArray.includes(ti) then
						_objArray.add(ti);
					endif;
				endif;
			endif;
		endforeach;
	endif;

	// ### PRENOTE TFS 37839 IF NO BOL ID then include Prenotes.
	// ### We need this for PELINDO1 where cash receipts are generated for estimating charges.cm_voya
	if _id = null then
		foreach ti in self.allNotifiedTIsByCargoTypeId  discreteLock do  
			if ti.myTerminal &lt;&gt; self.myTerminal then
				continue;
			endif;
			if ti.isChild then
				parent := ti.myParent;
				if parent &lt;&gt; null and
				   not _objArray.includes(parent) then
					_objArray.add(parent);
				endif;
			else
				if not _objArray.includes(ti) then
					_objArray.add(ti);
				endif;
			endif;
		endforeach;
	endif;end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_searchOffsite" type="Boolean"/>
        <Parameter name="_objArray" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="maintainMovementLinkedList" id="cf68c408-fe7d-4f77-be15-d03b34fde459">
        <source>maintainMovementLinkedList();
// ---------------------------------------------------------------------------
// Created:     19 February 2008 by cnwrs2
//
// Purpose:     The HMS_Movement object have a linked list of myPrevMovement,
//				myNextMovement.  These are currently set by looking at next/prev
//				movement on HMS_VoyageData.allVoyageMovements dict.  This does
//				not work as movements are updated and the date is changed which
//				affects the order in the dict, so the next/prev references get
//				set incorrectly.
//
//				At some stage this should be reviewed further to store movements
//				as an array.	
// ---------------------------------------------------------------------------
vars
	tmpHMS_Data	: HMS_VoyageData;
	tmpMovement	: HMS_Movement;
	
begin
	app.writeLog( method.qualifiedName &amp; " start", LogDEBUG);

	// IMPORTANT: Any changes here may also need to be made on 
	// method CM_VoyageGlobal::maintainMovementLinkedList

	// This method should be called whenever a movement dates are updated BUT
	// only ONCE all the movement updates have been completed
	
	tmpHMS_Data := self.myHMSVoyageData;
	if tmpHMS_Data = null then
		return;
	endif;
	
	foreach tmpMovement in tmpHMS_Data.allVoyageMovements do
		tmpMovement.maintainLinkedList();
	endforeach;
epilog
	app.writeLog( method.qualifiedName &amp; " end", LogDEBUG);
end;</source>
    </JadeMethod>
    <JadeMethod name="myDebtor" id="3508e5e8-a01a-4c23-af11-6e46c28d70e0">
        <methodInvocation>mapping</methodInvocation>
        <source>myDebtor(set: Boolean; _value: CM_DebtorNode io) mapping;
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	tmpDebtor : CM_DebtorNode;
begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	_value := null;
	
	if self.myOperator &lt;&gt; null then
		tmpDebtor := self.myOperator.debtor;
	endif;
	
	if tmpDebtor = null then
		if self.myDefaultLineGroupDebtor &lt;&gt; null then
			tmpDebtor := self.myDefaultLineGroupDebtor.debtor.CM_Debtor;
		endif;
	endif;
	
	_value := tmpDebtor;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_DebtorNode" usage="io"/>
    </JadeMethod>
    <JadeMethod name="onSiteAt" id="0fe97341-be03-40d9-b574-c7db3a423efd">
        <source>onSiteAt( _ts : TimeStamp ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 May 2021	navndl1	Initial creation	TFS 50906

*/

vars

begin

	if not _ts.isValid then
		return false;
	endif;

	if self.arrivedDT.isValid then
		if _ts &lt; self.arrivedDT then
			return false;
		endif;
	elseif self.estimatedArrivalDT.isValid then
		if _ts &lt; self.estimatedArrivalDT then
			return false;
		endif;
	endif;
	
	if self.departedDT.isValid then
		if _ts &gt; self.departedDT then
			return false;
		endif;
	elseif self.estimatedDepartureDT.isValid then
		if _ts &gt; self.estimatedDepartureDT then
			return false;
		endif;
	endif;
	
	return true;

epilog

end;</source>
        <Parameter name="_ts" type="TimeStamp"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="operatorCode" id="f7f3d106-7cbe-4fde-8543-8326d36fdf7d">
        <source>operatorCode():String;

// may 2005 PAR 10128 this has been added back to enable the SQLServer database to be 
//          populated with the old vessel oid. 

