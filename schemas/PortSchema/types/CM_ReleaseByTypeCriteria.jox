    <JadeMethod name="addPxyCriteriaFromEDI" id="e3c4a00d-32c7-4607-b4da-c7e0e68784b6">
        <updating/>
        <source>addPxyCriteriaFromEDI( _myReserveSelection : CM_ReserveSelection; _ediReqCrit : CM_EDIRequestCriteriaTI ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 December 2015	cnwndl1	Initial creation	STW Par 37402 TFS 1192  EDI Multi line Release

*/

vars

	critName : String;
	rawCriteriaValue : String;
	ct : CM_YACriteriaType;
	criteriaType : CM_YACriteriaType;
	errorItemId : String;
	
	proxyCriteria: CM_YACriteria;
	itemCode : String;
	value : Any;

begin

	self.raiseExceptionIfNotTransient(method);

	critName := _ediReqCrit.criteriaName.toUpper;
	rawCriteriaValue := _ediReqCrit.criteriaValue;
	errorItemId := _ediReqCrit.releaseRequestNumber &amp; "/" &amp; _ediReqCrit.requestDetailID.String;
	
	if _myReserveSelection = null then
		app.raiseCMException( Reserve_selecti_referen_not, errorItemId, null );
		return;
	elseif self.myReserveSelection &lt;&gt; null and self.myReserveSelection &lt;&gt; _myReserveSelection then
		app.raiseCMException( Incorrr_reserve_selecti_found, errorItemId, null );
		return;
	endif;
	
	if critName.trimBlanks = null then
		app.raiseCMException( Extra_criter_type_not_empty, errorItemId, null );
		return;
	endif;
	if rawCriteriaValue.trimBlanks = null then
		app.raiseCMException( Extra_crite_value_match_empty, errorItemId, null );
		return;
	endif;
	
	foreach ct in app.myRoot.allYACriteriaTypes do
		if ct.description.toUpper = critName then
			criteriaType := ct;
			break;
		endif;
	endforeach;
	
	if criteriaType = null then
		app.raiseCMException1( Extra_criter_type_not_known, _ediReqCrit.criteriaName, errorItemId, null );
		return;
	elseif self.isAnExcludedTypeForMatching(criteriaType.type) then
		app.raiseCMException1( Crite_type_not_valid_type_extr, _ediReqCrit.criteriaName, errorItemId, null );
		return;
	endif;
	
	// TFS 58923 Sorting Method validation
	if criteriaType.isKindOf(CM_YATypeSortingMethod) then
		if app.myRoot.allSortingMethods[rawCriteriaValue] = null then
			app.raiseCMException1(Sorting_method_invalid, rawCriteriaValue, null, null);
			return;
		endif;
	endif;
	// TFS 58923 end
	
	if criteriaType.isBooleanType then
		if rawCriteriaValue.toUpper.trimBlanks = "TRUE" then
			value := CM_YADataBoolean.VALUE_TRUE;
		elseif rawCriteriaValue.toUpper.trimBlanks = "FALSE" then
			value := CM_YADataBoolean.VALUE_FALSE;
		else
			app.raiseCMException2( Extra_crite_value_not_valid, rawCriteriaValue, critName , errorItemId, null );
		endif;
	else
		value := rawCriteriaValue;
	endif;
	
	itemCode := criteriaType.description.cnEcUpto(CM_YACriteriaPriority::code.length -1);
	
	if self.myReserveSelection = null then
		self.setProxyBaseData( _myReserveSelection );
	endif;
	
	create proxyCriteria transient;
	proxyCriteria.setProxy(criteriaType, value, itemCode);
	
	self.allCriteria.add(proxyCriteria);

epilog

end;</source>
        <Parameter name="_myReserveSelection" type="CM_ReserveSelection"/>
        <Parameter name="_ediReqCrit" type="CM_EDIRequestCriteriaTI"/>
    </JadeMethod>
    <JadeMethod name="getTableDisplayString" id="e61e9a1b-85db-4376-8be0-930b52058c87">
