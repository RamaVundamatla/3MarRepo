    <JadeMethod name="getValueSpecial" id="d91f82ef-1649-4978-9456-d5f8babb7b6a">
        <source>getValueSpecial(_propName: String; _xlationOperator: CM_Operator): String;
//
// 16 Jan 2012	MSL CCMS 1009 PAR 29024
//
// 05 Apr 2012	cnwrs1		Par 29391 - EDI RORO Stowage Advice hazard codes
// 07 Mar 2013	cnwcs5	CCMS POL 2097 / par 31259 - include foundMatch in method signatures
// 30 Jun 2014	cnwrs1	Par 34702 - Add support for JMT XML


vars
	returnValue : String;
	str 		: String;
	foundMatch	: Boolean;
begin
	if _propName =  ETRow_Commodity then //Par 13379 cnwrs1 feb 2007
		if _xlationOperator &lt;&gt; null then
			return _xlationOperator.getXlationForeignCode(self.commodity[1:30], XLATION_TYPE_COMMODITY_BYOP, foundMatch);
		else
			return self.commodity;
		endif;

	elseif _propName = ETRow_Humidity then//non-multiplied
		if self.getHumidity = NULL_HUMIDITY then//i.e. null STRING - NULL_Humidity - other wise '0' is a valid humidity
			return null;
		else
			return self.getHumidity.asStringJMT;
		endif;
	
	elseif _propName = ETRow_Ventilation or _propName = ETRow_Vent then//non-multiplied
		if self.vent = NULL_VENTILATION then//i.e. null STRING - NULL_VENTILATION - other wise '0' is a valid vent
			return null;
		else
			return vent.String;
		endif;
	
	elseif _propName = ETRow_CarbonDioxide then
		if self.getCarbonDioxide = NULL_CARBON_DIOXIDE then
			return null;
		else
			return self.getCarbonDioxide.asStringJMT;
		endif;
	
	elseif _propName = ETRow_Oxygen then
		if self.getOxygen = NULL_OXYGEN then
			return null;
		else
			return self.getOxygen.asStringJMT;
		endif;
	elseif _propName = ETRow_Temperature then
		if self.temperature = NULL_TEMPERATURE then
			return null;
		else
			return self.temperature.asStringJMT();
		endif;
	elseif _propName = ETRow_TotalWeight then
		return weight.String;
	else
		return inheritMethod(_propName, _xlationOperator);
	endif;
end;
</source>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
        <ReturnType type="String"/>
    </JadeMethod>
