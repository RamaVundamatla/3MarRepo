    <JadeMethod name="getHSDescription" id="d582b04d-0627-456d-9212-49858db40d50">
        <source>getHSDescription() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
25 November 2022		jlizm1	Initial creation TFS 55280 Harmonized System Codes

*/

vars

	code 		: CM_HarmonizedSystem;
	returnVal 	: String;
	
begin
	returnVal := app.getErrorString(HS_Unknown);
	
	code := self.myHSCode;
	if code &lt;&gt; null then
		returnVal := code.description;
	endif;
	
	return returnVal;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getHazardsAsString" id="eb7093de-881f-4fe2-86e6-5cf9a8b23336">
        <source>getHazardsAsString() : String;
/*
	Created on 17 January 2008
	
	by Debby Hutchison
	
	Purpose:
	
Changed On	By			Reason
----------	--------	-----------------------------------------------------
31/10/2011	cnwdap1		PAR #28524 CCMS POL 2096 Change hazardlist delimiter to ',' so it matches TI hazard list format
*/

vars
	haz 	: CM_Hazard;
	tmpStr 	: String;
begin
	foreach haz in self.allTIHazards do
		if tmpStr &lt;&gt; null then
			//tmpStr := tmpStr &amp; '; ';			// PAR #28524
			tmpStr := tmpStr &amp; ', ';			// PAR #28524
		endif;
		tmpStr := tmpStr &amp; haz.getTableDisplay(false, true);
	endforeach;
	return tmpStr;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getHumidity" id="1da5447a-b416-46ad-94fd-dd786feb9ccd">
        <source>getHumidity(): Decimal;
/*
	Created on 18 January 2008
	
	by Debby Hutchison
	
	Purpose:
	
Changed		By		Why
27/11/209	cnwdap1	CCMS 1007 - move reefer properties to their own class
02 Apr 2020	NDL	TFS 47958
*/
vars

begin
	if self.myReeferProperties &lt;&gt; null then
		return self.myReeferProperties.getHumidity;
	else
		return NULL_HUMIDITY;
	endif;
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
