    <JadeMethod name="setTicketSequences" id="76cfafef-92cf-4d68-b3fe-aff4455fc4c0">
        <updating/>
        <source>setTicketSequences(_proxy : CM_BOLExtLogIn) updating, protected;
// -----------------------------------------------------------------------------
// Created:		03 April 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	ticketSeq, proxySeq : CM_TicketSequence;
begin

	// Always delete the existing
	if (not self.allTicketSequences.isEmpty) then
		foreach ticketSeq in self.allTicketSequences do
			ticketSeq.erase(NORMAL_ERASE);
		endforeach;
	endif;

	if (not _proxy.allTicketSequences.isEmpty) then
		foreach proxySeq in _proxy.allTicketSequences do
			create ticketSeq persistent;
			ticketSeq.setForCreate(proxySeq);
			self.allTicketSequences.add(ticketSeq);
		endforeach;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_proxy" type="CM_BOLExtLogIn"/>
    </JadeMethod>
    <JadeMethod name="setWeightForLogs" id="7467e667-0e77-40f7-975e-fe5dcaba9874">
        <updating/>
        <source>setWeightForLogs(_tiUpdateCntrlr : CMIF_TIUpdateController; _passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 18 September 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	logSet 				: CM_TISet;
	log,
	largestLog			: CM_TrackedItem;
	logWeight,
	totWeight,
	bolWeightNet		: Decimal[14,4];
	totalVol,
	weightPortionPerJas : Decimal[12,3];
	tiAuditCntrl		: CM_TIAuditController;
	sa					: StringArray;
	forCreate,
	deleteCntrl			: Boolean;
	tiUpdateCntrl		: CMIF_TIUpdateController;
	needUpdate			: Boolean;
	txnSet				: CM_TITransactionSet;
	tmpTran				: CM_TITransaction;
	tmpDisassembly		: CM_Disassembly;
	
begin

	bolWeightNet := self.myBOL.weightNet;
//	if bolWeightNet &lt;= 0 or self.myBOL.allTrackedItems.isEmpty then //#24885 23/07/2010
	if self.myBOL.allTrackedItems.isEmpty then
		return;
	endif;
	
	if _tiUpdateCntrlr = null then
		tiUpdateCntrl := app.createTIUpdateControl(TI_UPDMODE_NORMAL, _passport.userCode, null);
		deleteCntrl := true;
	else
		tiUpdateCntrl := _tiUpdateCntrlr;
	endif;
	
	forCreate := tiUpdateCntrl.transactionType = TRANS_TYPE_CREATED;
	tiAuditCntrl := _passport.getTIAuditController();
	
	create sa transient;
	create txnSet transient;

	//sa.add(CM_TrackedItem::weight.name);								//-cnwml2 MSL CCMS 1017
	sa.add(CM_TrackedItem::totalWeight.name);							//+cnwml2 MSL CCMS 1017
	tiAuditCntrl.setAuditSpecific(CM_TrackedItem, sa);

	create logSet transient;
	self.myBOL.allTrackedItems.copy(logSet);

	foreach log in logSet do
		exclusiveLock(log);
		if log.state = TI_STATE_OFFLOADED then
			// in this case the cloned log will be counted
			continue;
		endif;
		
		//PAR 25560 01/09/2010
		tmpDisassembly := log.getDisassembledTransaction();
		if tmpDisassembly &lt;&gt; null then
			txnSet.add(tmpDisassembly);
			totalVol := totalVol + tmpDisassembly.residualVolume;
			continue;	// new logs will be counted, just need to add residual volume from CM_Disassembly
		endif;
		// Now update weight on ALL logs, so does not matter if largest log is not on-site. PAR 25560 31/08/2010
		//if (log.site = TI_SITE_ONSITE) then
			if largestLog = null then
				largestLog := log;
			elseif log.getMyTotalVolume &gt; largestLog.getMyTotalVolume then
				largestLog := log;	
			endif;
		//endif;
		
		// add volumne for all logs
		totalVol := totalVol + log.getMyTotalVolume;
	endforeach;
	 
	if totalVol &gt; 0 then
		weightPortionPerJas := (bolWeightNet/totalVol);
		/*if weightPortionPerJas &lt;= 0 then	//#24885 23/07/2010
			return;
		endif;*/

		//foreach log in logSet where log.site = TI_SITE_ONSITE do //Commented by PAR 25560 31/08/2010
		foreach log in logSet where log.state &lt;&gt; TI_STATE_OFFLOADED do 	//From now, weitgh for logs is updated regardless log site. PAR 25560 31/08/2010

			//par25560 01/09/2010
			tmpDisassembly := log.getDisassembledTransaction();
			if tmpDisassembly &lt;&gt; null then
				// We need to update residual weight on the 
				continue;	//we have to change residualWeight on CM_Disassembly
			endif;
		
			logWeight := (log.getMyTotalVolume * weightPortionPerJas).rounded;
			if forCreate then
				log.setTotalWeightWithoutTrans(logWeight);
			else
				//log.setWeight(logWeight, tiUpdateCntrl, _passport);					//-cnwml2 MSL CCMS 1017
				log.setTotalWeight(logWeight, tiUpdateCntrl, _passport);				//+cnwml2 MSL CCMS 1017
			endif;
			totWeight := totWeight + logWeight;

		endforeach;	
		
		// PAR 25560 01/09/2010. when all weights are counted, we still need to count residualWeight for disassembled logs.
		foreach tmpTran in txnSet do
			tmpDisassembly := tmpTran.CM_Disassembly;
			tmpDisassembly.setNewResidualWeight(weightPortionPerJas);
			totWeight := totWeight + tmpDisassembly.residualWeight;
		endforeach;
		
		if largestLog &lt;&gt; null then //Could be null if no logs are on site anymore
		
			if totWeight &lt; bolWeightNet then
				//logWeight := ((bolWeightNet - totWeight) + largestLog.weight);				//-cnwml2 MSL CCMS 1017
				logWeight := ((bolWeightNet - totWeight) + largestLog.totalWeight);				//+cnwml2 MSL CCMS 1017
				needUpdate := true;
			elseif totWeight &gt; bolWeightNet then
				//logWeight := (largestLog.weight - (totWeight - bolWeightNet));				//-cnwml2 MSL CCMS 1017
				logWeight := (largestLog.totalWeight - (totWeight - bolWeightNet));				//+cnwml2 MSL CCMS 1017
				needUpdate := true;
			else
				needUpdate := false;
			endif;
			
			// PAR 25560 - add needUpdate flag as was updating when (totWeight &gt; bolWeightNet) - CNWRS2 26 Aug 2010
			if needUpdate then
				if forCreate then	//PAR20040 - don't create CM_Create duplicate for largest log. August 2009
					largestLog.setTotalWeightWithoutTrans(logWeight);				//+cnwml2 PAR24683
				else
					//largestLog.setWeight(logWeight, tiUpdateCntrl, _passport);
					//cnwjo3 par 25248
					largestLog.setTotalWeight(logWeight, tiUpdateCntrl, _passport);
				endif;
			endif;
		endif;			
	endif;
	
epilog

	if tiAuditCntrl &lt;&gt; null then
		tiAuditCntrl.resetIsAudited(true);
	endif;
	delete logSet;
	if deleteCntrl then
		delete tiUpdateCntrl;
	endif;
	delete sa;
	delete txnSet;
	
end;</source>
        <Parameter name="_tiUpdateCntrlr" type="CMIF_TIUpdateController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="showThumbnailData" id="e32a494f-ea68-4a60-a2ed-c78429b39fe4">
        <source>showThumbnailData(pHeadings: HugeStringArray input; pData: HugeStringArray input; _terminal : CM_Terminal);
//--------------------------------------------------------------
//Created: 01 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	ticketSeq : CM_TicketSequence;
begin
	inheritMethod(pHeadings, pData, _terminal);
	if self.myBOL.matchTime.isValid and self.myTerminalIfUnmatched &lt;&gt; null then
		// a match was found but the logs could not be moved into the yard
		pHeadings.insert(1, 'Match Found');	
		pData.insert(1, 'A match was found but items could not be moved into the yard. Edit yard location to move items into new location.');
		pHeadings.insert(2, null);	
		pData.insert(2, null);
	endif;
	if self.allTicketSequences &lt;&gt; null then
		foreach ticketSeq in self.allTicketSequences do									
			pHeadings.add('Ticket Sequence');		pData.add(ticketSeq.fromId.String &amp; ' to ' &amp; ticketSeq.toId.String);
		endforeach;
	endif;		
end;</source>
        <Parameter name="pHeadings" type="HugeStringArray" usage="input"/>
        <Parameter name="pData" type="HugeStringArray" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="updateSEDAverages" id="dd740165-5d37-483c-9e4d-7fc72c0a6590">
        <updating/>
        <source>updateSEDAverages(_passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 12 November 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	//totVol		: Decimal[12,3];
	totVol		: Decimal[12,4];//par 13537 par 13657
	log			: CM_Log;
	
	numScaled	: Integer;
	aveMax,
	aveMin,		
	aveMean		: Decimal[6,2];
	totMin,
	totMax		: Decimal[10,2]; // Lorcan Change scale from 6 to 10 to prevent decimal precision on large dockets (PAR 12091)
	aveVolume,
	totVolume	: Decimal[16,4];			
	tiUpdCntrl	: CMIF_TIUpdateController;
	tmpBOL		: CM_BOL;
	coll		: Collection;
	obj			: Any;
	tiAudit,
	saveAuditCopy : CM_TIAuditController;
		
begin

	// PAR 19996 - do not update volume for 100% scaled logs
	if self.percentScaled = 100 then
		// this is NOT a percentage scaled log, so no need to update SED averages on other logs.
		// or to update total volumne on BOL
		return;
	endif;

	tmpBOL := self.myBOL;

	if _passport.myTerminal &lt;&gt; tmpBOL.myTerminal then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Attempt to update SED averages when not in original terminal for BOL');
		return;
	endif;

	if tmpBOL.myOrigBOLTerminal &lt;&gt; null then
		coll := tmpBOL.myOrigBOLTerminal.allTrackedItems;
	else
		coll := tmpBOL.allTrackedItems;
	endif;
	
	foreach obj in coll where (not obj.CM_Log.isAverageScaled) do
		log 		:= obj.CM_Log;
		totVol 		:= totVol + log.getMyTotalVolume;
		totMin 		:= totMin + log.sedMin;
		totMax 		:= totMax + log.sedMax;
		numScaled 	:= numScaled + 1;
	endforeach;
	
	aveMin 	:= (totMin / numScaled);	
	aveMax 	:= (totMax / numScaled);
	//aveVolume := (totVol/numScaled).roundedTo(4);		//commened by #24214	25/05/2010
	aveVolume := getVolumeForAveragedLogs(totVol, numScaled);	// #24214	25/05/2010
	aveMean	:= global.calcSEDMeanFromVolume(aveVolume, log.logLength);		
	
	tiUpdCntrl := app.createTIUpdateControl(TI_UPDMODE_NORMAL, null, null);
	
	foreach obj in coll where obj.CM_Log.isAverageScaled and obj.CM_TrackedItem.site = TI_SITE_ONSITE do
		
		// PAR 20048 Nov 2009. We will loose audit Before values for the "master" (not average scaled) log,
		//which has caused changes for all average scaled logs in the log docket. 
		//We need to save audit Before values for a "master" log, that has been setup in the method CM_TrackedItem:setForUpdate().
		if saveAuditCopy = null then	// When changing all averaged logs, the audit controller Before and After values are changed for each log.
			tiAudit := _passport.getTIAuditController();	
			create saveAuditCopy transient;
			saveAuditCopy.init();
			saveAuditCopy.copyBeforeAfterValues(tiAudit);	// this method updates Before and After audit values for each averaged log.
		endif;
		
		log := obj.CM_Log;
		log.setSEDsFromAverages(aveMax, aveMin, aveMean, aveVolume, tiUpdCntrl, _passport);
		totVol := totVol + log.getMyTotalVolume;
	endforeach;	
	
	if saveAuditCopy &lt;&gt; null then	//PAR 20048 Nov 2009.  Audit Before and After values in CM_AuditController on CM_Passport have been changed for average scaled logs
		tiAudit.copyBeforeAfterValues(saveAuditCopy);	// Restoring audit Before values for a "master" log
	endif;
	
	// PAR 19996 - do NOT update BOL volume ever based on logs changes
	//This is wrong as some logs have been excluded above (if offsite)
	//self.jasVolume := totVol;
	
epilog
	delete tiUpdCntrl;
	if saveAuditCopy &lt;&gt; null then
		delete saveAuditCopy;
	endif;
	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateTIsFromBOL" id="5391651b-fbe6-4aa9-a9ea-5ed72c47e061">
        <updating/>
        <source>updateTIsFromBOL(_passport : CM_Passport input)updating;
//--------------------------------------------------------------
//Created: 23 May 2002 By: cnwgd1
//--------------------------------------------------------------

vars
	newLocn		: CM_LocationsController;
	iter 		: Iterator;
	useSystemId : Boolean;
	str 		: String;
	ticketSeq 	: CM_TicketSequence;
	clonedLog 	: CM_Log;
	theDate		: Date;
	theBOLIn	: CM_BOLIn;
	terminal	: CM_Terminal;
	log, 
	firstLog  	: CM_TrackedItem;
	pieceCount, 
	adjustAmount, 
	numLogs 		: Integer;	
	tiUpdateCntrl	: CMIF_TIUpdateController;
	coll			: Collection;
	obj				: Any;
	moveController	: CMIF_MoveController;
begin

	theBOLIn := self.myBOL.CM_BOLIn;
	terminal := theBOLIn.myTerminal;	

	if _passport.myTerminal &lt;&gt; terminal then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Attempt to update unscaled logs when not in original terminal for BOL');
		return;
	endif;
	
	coll := theBOLIn.getTICollectionForTerminal(terminal);

	numLogs	 := theBOLIn.numTIs;	

	if numLogs = 0 then 
		return; //nothing to do here
	endif;

	tiUpdateCntrl 	:= app.createTIUpdateControl(TI_UPDMODE_NORMAL, _passport.userCode, null);
	
	if theBOLIn.isMatched then
		// only a subset of items on the TI get updated (eg fellDate)
		tiUpdateCntrl.transactionType := TRANS_TYPE_NULL;
		tiUpdateCntrl.stockMovementType := StkMove_Null;	
		foreach obj in coll do
			log := obj.CM_Log;
			exclusiveLock(log);
			//update the logs with any new details (but NOT specs)		
			//the update transaction is handled in here as well.
			log.setFromBOLIn(theBOLIn, false, tiUpdateCntrl, _passport);		//PAR20040 - added new parameter
		endforeach;

		if theBOLIn.isMatchedTodayForDocketCorrect() then	//PAR 19823. ccms1089. Docket Correction. When isMatchedTodayForDocketCorrect(), the product (Length) can be changed for logs. cnwvu1, 4 June 2009
			//self.setJasVolume(_passport.myTerminal);
			self.setJasVolume(theBOLIn.myTerminal);			// #25482 20/10/2010
		endif;
		
		// RETURN here if MATCHED
		return;	
	endif;
	
// ===========================================================
// Updates from here on down are only done for UN-MATCHED BOLs
// ===========================================================

	theDate 		:= app.actualTimeServer.date;
	pieceCount 		:= theBOLIn.numItems;	
	
	//Check to see if we need to add or delete any logs
	if pieceCount &lt;&gt; numLogs then
		if pieceCount &gt; numLogs then
			//Add extra required
			adjustAmount := (pieceCount - numLogs);
			tiUpdateCntrl.transactionType := TRANS_TYPE_CREATED;
			log := coll.first.CM_Log;

			create moveController transient;
			moveController.setMoveMode(REAL_MODE);

			while adjustAmount &gt; 0 do
				clonedLog := log.cloneSelf(false).CM_Log;
				clonedLog.setCloneIdReferences(terminal.logNextSeqNumber, log, false, tiUpdateCntrl, moveController, _passport);
				adjustAmount := adjustAmount - 1;
			endwhile;
		else
			//delete whats not required
			adjustAmount := (numLogs - pieceCount);
			while adjustAmount &gt; 0 do
				log := coll.last.CM_Log;
				log.erase(NORMAL_ERASE);
				adjustAmount := adjustAmount - 1;
			endwhile;
		endif;
	endif;
	
	/* No need to do this any more as we use the bol.myPlannedLocation to move TIs
	//first log will be used as the master log on the work list entry
	firstLog := coll.first.CM_Log;
	//firstLog shouldn't be null by time you get to here but we'll make sure anyway
	if firstLog &lt;&gt; null and theBOLIn.myPlannedLocation &lt;&gt; null then
		if theBOLIn.myPlannedLocation &lt;&gt; firstLog.getPrimaryLocation(PLANNING_MODE) then
			theBOLIn.doUpdateLocation(PLANNING_MODE, theBOLIn.myPlannedLocation, _passport);
		endif;
	endif;*/
	
	if _passport.hasErrors then
		return;
	endif;

	// Do not have to update the log.id as id is immaterial if unscaled.
	// Id will be updated when matching done later.
	
	tiUpdateCntrl.transactionType := TRANS_TYPE_NULL;
	tiUpdateCntrl.stockMovementType := StkMove_Null;	
	foreach obj in coll do
		log := obj.CM_Log;
		exclusiveLock(log);
		//update the logs with any new specs etc....		
		//the update transaction is handled in here as well.
		log.setFromBOLIn(theBOLIn, true, tiUpdateCntrl, _passport);		//PAR20040 - added new parameter
	endforeach;

epilog
	delete iter;
	delete tiUpdateCntrl;			
	delete moveController;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateUnscaledLogsFromScaleHdr" id="a4f655fd-4d4e-4bcc-b602-da1432f854b1">
        <updating/>
        <source>updateUnscaledLogsFromScaleHdr(_logScalingHdr : CM_LogScalingHdr; _passport : CM_Passport input) : Boolean updating;
//--------------------------------------------------------------
//Created: 20 May 2002 By: cnwgd1
//
// IMPORTANT	This should ONLY be called from CM_LogScalingHdr.attemptMatch
//--------------------------------------------------------------
//Update unscaled logs with scaling data.
//If not all ticketed then work out the average SED to apply to the system id logs
vars
	log 				: CM_Log;
	ti					: CM_TrackedItem;
	theBOLIn			: CM_BOLIn;
	numItems,
	numScaled			: Integer;
	logScalingDetail 	: CM_LogScalingDtl;
	thisTerminal		: CM_Terminal;
	applyAverages		: Boolean;
	tiByIdDict			: CM_TIByIdDict;
	tiUpdateCntrl 		: CMIF_TIUpdateController;
	aveMeanSed			: Decimal[6,2];
	aveVolume,
	totVolume			: Decimal[16,4];
	coll				: Collection;
	obj					: Any;		
	tiAuditCntrl	: CM_TIAuditController;
	sa				: StringArray;

begin
	
	theBOLIn 		:= self.myBOL.CM_BOLIn;
	thisTerminal 	:= theBOLIn.myTerminal;

	if _passport.myTerminal &lt;&gt; thisTerminal then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Attempt to update unscaled logs when not in original terminal for BOL');
		return false;
	endif;

	coll := theBOLIn.getTICollectionForTerminal(thisTerminal);

	numItems := theBOLIn.numTIs;
	
	if self.ticketedAll and self.percentScaled = 100 then 
		if _logScalingHdr.allLogScalingDtls.size &lt;&gt; numItems then
			app.raiseCMWarning3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, 
							  'Number of Scaling Details do not match number of Logs requiring update.', null, null, self);
			return false;
		endif;
	elseif _logScalingHdr.allLogScalingDtls.size &gt; numItems then
		app.raiseCMWarning3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, 
							  'Number of Scaling Details is more than number of Logs on Docket.', null, null, self);
		return false;		
	endif;
	
	//need dict in Id order to match order of allLogScalingDtls.
	create tiByIdDict transient;
	coll.copy(tiByIdDict);

	tiAuditCntrl := _passport.getTIAuditController();
	
	create sa transient;
	sa.add(CM_TrackedItem::id.name);	
	sa.add(CM_Log::sedMin.name);	
	sa.add(CM_Log::sedMax.name);
	sa.add(CM_Log::conditionCode.name);
	sa.add(CM_Log::scalerCode.name);
	sa.add(CM_Log::volume.name);
	tiAuditCntrl.setAuditSpecific(CM_TrackedItem, sa);

	tiUpdateCntrl := app.createTIUpdateControl(TI_UPDMODE_NORMAL, _passport.userCode, null);

	foreach logScalingDetail in _logScalingHdr.allLogScalingDtls do
		log := tiByIdDict.getAtKey(logScalingDetail.logID).CM_Log;
		if log = null then
			//log := tiByIdDict.first.CM_Log; //PAR8406 was replacing the last
			continue;
		endif;
		tiByIdDict.remove(log);
		log.setFromBOLInLogScaleDtl(null, logScalingDetail, null, tiUpdateCntrl, null, _passport);
		// Do not pass the bol through as this causes some attributes (eg product) on
		// the log to get updated back to that of the original bol.  These attributes 
		// should be already set correctly (rjs jun03)
		//log.setFromBOLInLogScaleDtl(theBOLIn, logScalingDetail, null, tiUpdateCntrl, _passport);
		totVolume := totVolume + log.getMyTotalVolume;
		numScaled := numScaled + 1;	
	endforeach;	
	
	//PAR8406 - Have to go through it again to set the ones not found
	foreach logScalingDetail in _logScalingHdr.allLogScalingDtls do
		log := tiByIdDict.getAtKey(logScalingDetail.logID).CM_Log;
		if log = null then
			if tiByIdDict.isEmpty then
				break;	// PAR 15198
			endif;
			log := tiByIdDict.first.CM_Log; //PAR8406 was replacing the last
		endif;
		tiByIdDict.remove(log);
		log.setFromBOLInLogScaleDtl(null, logScalingDetail, null, tiUpdateCntrl, null, _passport);
		// Do not pass the bol through as this causes some attributes (eg product) on
		// the log to get updated back to that of the original bol.  These attributes 
		// should be already set correctly (rjs jun03)
		//log.setFromBOLInLogScaleDtl(theBOLIn, logScalingDetail, null, tiUpdateCntrl, _passport);
		totVolume := totVolume + log.getMyTotalVolume;
		numScaled := numScaled + 1;	
	endforeach;		

	if (not _passport.noErrors) then
		return false;
	endif;
	
	if (not tiByIdDict.isEmpty) then 
		// This is a % scaled load so need to apply averages to other logs
		if self.jasScaled then
			applyAverages 	:= true;
			aveVolume	  	:= (totVolume/numScaled).roundedTo(4);
			aveMeanSed 		:= global.calcSEDMeanFromVolume(aveVolume, log.logLength);		
		endif;

		//change remaining log ids to ticketId or systemId
		foreach ti in tiByIdDict do
			log := ti.CM_Log;
			
			if applyAverages then
				log.setFromBOLInWithSEDAvg(theBOLIn, _logScalingHdr.averageMaxSed,
										_logScalingHdr.averageMinSed,
										aveMeanSed,	aveVolume, tiUpdateCntrl,
										_passport);		
			else
				log.setFromBOLInWithSEDAvg(theBOLIn, NULL_NEVERSCALED_LOG_SED,
									    NULL_NEVERSCALED_LOG_SED,
									    aveMeanSed, aveVolume, tiUpdateCntrl,
									    _passport);
			endif;
			
			/* PAR 20040 - refactor to above method to avoid repeated begin/endUpdate calls
			log.setFromBOLInInternal(theBOLIn, tiUpdateCntrl, (not theBOLIn.isMatched), _passport);	 	
			//set log from averages - condition remains the system default 
			if applyAverages then
				log.setSEDsFromAveragesInternal(_logScalingHdr.averageMaxSed,
										_logScalingHdr.averageMinSed,
										aveMeanSed,	aveVolume, tiUpdateCntrl,
										_passport);		
			else
				log.setSEDsFromAveragesInternal(NULL_NEVERSCALED_LOG_SED,
									    NULL_NEVERSCALED_LOG_SED,
									    aveMeanSed, aveVolume, tiUpdateCntrl,
									    _passport);
			endif;
			*/
		endforeach;
	endif;

	if (not _passport.noErrors) then
		return false;
	endif;

	// now we set the match time only
	// will be removed from the unmatched dict by the complete road in process if moved successfully
	// DVB Added 02/02/04 To fix deadlock situation.
	// Successful match so create scaler transactions.
	theBOLIn.createScalerTransactions(_logScalingHdr);
	//self.setJasVolume(_passport.myTerminal);
	self.setJasVolume(theBOLIn.myTerminal);			// #25482 20/10/2010
	self.setWeightForLogs(tiUpdateCntrl, _passport);	
	// Moved passport no errors check out of epilog so warnings with a return value
	// of false will cause match to create headers through BGP.	
	return _passport.noErrors();

epilog
	delete tiByIdDict;
	delete tiUpdateCntrl;	
	delete sa;
	if tiAuditCntrl &lt;&gt; null then
		tiAuditCntrl.resetIsAudited(true);
	endif;
	
end;</source>
        <Parameter name="_logScalingHdr" type="CM_LogScalingHdr"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="870b981e-0783-42c9-9b39-a82d3d5521f8">
        <source>validateForDelete();
//--------------------------------------------------------------
//Created: 22 January 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	ti : CM_TrackedItem;
begin

	if self.myBOL.allTrackedItems.size &gt; 0 then
		ti := self.myBOL.allTrackedItems.first;
		if not ti.CM_Log.isUnscaled then
			app.raiseCMException2(ObjectStillHasEntries, 'Log Docket ' &amp; self.myBOL.number.String, 'Log item', null, null);
		endif;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForIsMatchedToday" id="808d7d62-2e83-4a19-9481-4d2c92b80ea2">
        <source>validateForIsMatchedToday( _cmifSearchTypes: CMIF_SearchTypes; _control: CMIF_TIUpdateController; _passport : CM_Passport input ) protected;
// ---------------------------------------------------------------------------
// Created:     30 November 2007 by cnwvu1
// ---------------------------------------------------------------------------

vars
	locationId		: String;
	location		: CM_LogController;
	locationRow		: CM_RowController;
	trmArea			: CM_TerminalArea;
begin
	
	if not self.myBOL.isKindOf( CM_BOLIn ) then
		return;	// matchedToday is actual only  for CM_BOLIn
	else
		if not self.myBOL.CM_BOLIn.isMatchedTodayForDocketCorrect() then
			return;	// this method should validate in case, when a log docket is editted the same day as matching day
		endif;
	endif;

	//--------------------------------------- location validation ----------------------------------------------
	location := self.myBOL.myPlannedLocation.CM_LogController;
	
	if location = null then	// myPlannedLocation is null after log docket matching
		
		trmArea :=	self.myBOL.CM_BOLIn.myTerminal.allTerminalAreas[self.myBOL.CM_BOLIn.origTerminalAreaId];
		if trmArea = null then
			app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, 'Terminal area is null', null, _control.myUserObject );
			return;
		endif;
		if not trmArea.isKindOf( CM_LogArea ) then
			app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, 'Terminal area is not kind of CM_LogArea', null, _control.myUserObject );
			return;
		endif;
		
		locationId := self.myBOL.CM_BOLIn.origLocationControllerId;
		if locationId = null then
			app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, 'Original location Id is null', null, _control.myUserObject );
			return;
		endif;
	
		locationRow := trmArea.CM_LogArea.allRowControllersById[ locationId ];
		if locationRow = null then
			app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, 'Row Location is null', null, _control.myUserObject );
			return;
		endif;
		if not locationRow.isKindOf( CM_LogController ) then
			app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, 'Row Location is not kind of CM_LogController', null, _control.myUserObject );
			return;
		endif;
		
		location := locationRow.CM_LogController;
		
	endif;	
		
	if (not location.doesAllowType( _cmifSearchTypes, true )) then
		app.raiseCMException2( ERR_FIELD_LOCATION, location.id, 'Yard Location', null, _control.myUserObject );
	endif;

end;
</source>
        <access>protected</access>
        <Parameter name="_cmifSearchTypes" type="CMIF_SearchTypes"/>
        <Parameter name="_control" type="CMIF_TIUpdateController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateForUnscaledLogs" id="ef94f242-5fe0-4cb1-9fd4-32d88ef296a8">
        <source>validateForUnscaledLogs();
// ---------------------------------------------------------------------------
// Created:     24 June 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
//was checking for ticket sequences but not required now
end;</source>
    </JadeMethod>
    <JadeMethod name="validateMe" id="be771284-850f-407a-ab04-69a7db61bc94">
        <source>validateMe(pControl: CMIF_TIUpdateController; _passport : CM_Passport input) protected;
// ---------------------------------------------------------------------------
// Created:     24 June 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
// ---------------------------------------------------------------------------
vars
	now,
	sixMthsAgo 		: Date;
	cmifSearchTypes	: CMIF_SearchTypes;
	tempDate		: Date;
	fellDays		: Integer;
	realBOL			: CM_BOLExtLogIn;
	strWeightMin,
	strWeightMax,
	strWeightMsg	: String;
	minWeight,
	maxWeight		: Real;
	locationId		: String;
	location		: CM_LogController;
	
begin

	inheritMethod(pControl, _passport);

	realBOL := self.pxyGetRealObject().CM_BOLExtLogIn;

	if (not _passport.hasErrors) then
		// if we have had errors previously then don't check
		// locations at this point
		create cmifSearchTypes transient;	
		cmifSearchTypes.myOperator	:= self.myBOL.myOperator;
		cmifSearchTypes.mySpecies	:= self.myLogSpecies;
		cmifSearchTypes.myGrade		:= self.myLogGrade;
		cmifSearchTypes.myType		:= self.myLogType;
		cmifSearchTypes.myTreatment	:= self.myLogTreatment;
		cmifSearchTypes.myLength	:= self.myLogLength;
		
		if self.myBOL.myPlannedLocation &lt;&gt; null then	//before matching
			if (not self.myBOL.myPlannedLocation.doesAllowType(cmifSearchTypes, true)) then
				app.raiseCMException2( ERR_FIELD_LOCATION, self.myBOL.myPlannedLocation.ident, 'Yard Location', "AAA", pControl.myUserObject );
			endif;
		endif;
		self.validateForIsMatchedToday( cmifSearchTypes, pControl,_passport );//after matching, log docket's grade and location can be still editted the same day
		
	endif;

	if self.jasScaled then	//These field will be hidden on the entry screen if NOT jasScaled
		if self.percentScaled = null or self.percentScaled &gt; 100 or self.percentScaled &lt; 0 then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Percentage Scaled', ETRow_PercentScaled, pControl.myUserObject);
			app.raiseCMException(Input_required_field_PercntSca, ETRow_PercentScaled, pControl.myUserObject); // cnwdb2	PAR 35364
		endif;
	else
		app.raiseCMException1(NotYetImplemented, 'Non JAS-Scaled Logs', ETRow_JasScaled, pControl.myUserObject);
	endif;
				
	if realBOL = null or realBOL.fellDate &lt;&gt; self.fellDate then																			
		if (not self.fellDate.isValid) then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Fell Date. It is an empty or invalid', ETRow_FellDate, pControl.myUserObject);
			app.raiseCMException(Input_required_field_fellDate, ETRow_FellDate, pControl.myUserObject); // cnwdb2	PAR 35364

		else
			sixMthsAgo :=  now.cnEcAddMonths(-6);
			if self.fellDate &lt; sixMthsAgo then
				app.raiseCMException1(DATE_INVALID, 'Fell', ETRow_FellDate, pControl.myUserObject);
			endif;
			fellDays := app.getMyTerminalDO_NOT_USE.getConfig(LogMaxFellDateDays).Integer;
			if fellDays &lt;&gt; 0 then
				tempDate := self.fellDate.cnEcAddDays(fellDays);
				if tempDate &lt; app.actualTimeServer.date then// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
					app.raiseCMWarning1(AutoScheduleDateError, 'The Fell Date ' &amp; self.fellDate.shortFormatJMT() &amp; ' appears to be be older than ' &amp;
										fellDays.String &amp; ' day(s). Are you sure that it is correct?', ETRow_FellDate, pControl.myUserObject, self);
				endif;
			endif;
			if realBOL = null then 
				// is new one so check against proxy as no real one. 
				if self.fellDate &gt; self.myBOL.dateTime.date then
					app.raiseCMException1(AutoScheduleDateError, 'Fell Date must be before Receival Date.', ETRow_FellDate, pControl.myUserObject);	
				endif;
			else 
				// check against real BOL PAR11574 - when editing docket could change up till todays date (need to check against original BOL)
				if self.fellDate &gt; realBOL.myBOL.dateTime.date then
					app.raiseCMException1(AutoScheduleDateError, 'Fell Date must be before Receival Date.', ETRow_FellDate, pControl.myUserObject);
				endif;		
			endif;	
		endif;
	endif;

	if (not self.allTicketSequences.isEmpty) then
		if (not self.myBOL.matchTime.isValid)//&lt;--Added - Was not been validated when docket created at Gate In
		or self.myBOL.matchTime.isValid and self.myTerminalIfUnmatched = null then
			self.validateTicketSequences();
		else
			// there was a match but it could not be moved into the yard
			//therefore TI's would have been created with the ticketSequence id's
		endif;
	endif;
	
	maxWeight := app.getMyTerminalDO_NOT_USE.getConfig(MaxLogWeight).Real;
	minWeight := app.getMyTerminalDO_NOT_USE.getConfig(MinLogWeight).Real;

	if maxWeight &lt;&gt; 0 or minWeight &lt;&gt; 0 then 
	// if either max or min have a value then check weight 
		strWeightMin := '(' &amp; minWeight.String &amp; ')';
		strWeightMax := '(' &amp; maxWeight.String &amp; ')';
		strWeightMsg := '(max = ' &amp; maxWeight.String &amp; ', min = ' &amp; minWeight.String &amp; ')';
	
		if self.myBOL.weightNetTonnes = 0 and minWeight &lt;&gt; 0 then 
	// if no weight set then reguire one 
			app.raiseCMException2(ERR_REQUIRED_WEIGHT_LOG, strWeightMsg, 'Net Weight (Tonnes)',ETRow_WeightNetTonnes, pControl.myUserObject);		
		else 
	// check the weight		
			if maxWeight &lt;&gt; 0 then // if config at zero ignore re specs in CCMS 1071
				if self.myBOL.weightNetTonnes &gt; maxWeight then 	
				// too heavey
					app.raiseCMException1(ERR_MAX_WEIGHT_LOG, strWeightMax, ETRow_WeightNetTonnes, pControl.myUserObject);	
				endif;
			endif;
		
			if minWeight &lt;&gt; 0 then // if config at zero ignore re specs in CCMS 1071
				if self.myBOL.weightNetTonnes &lt; minWeight then 
				// too light. 
					app.raiseCMException1(ERR_MIN_WEIGHT_LOG, strWeightMin, ETRow_WeightNetTonnes, pControl.myUserObject);	
				endif;
			endif;			
		endif;
	endif;
	
	//cnwmc5 - 8 Dec 2014 - CCMS 1133 - validate for web matched (handled by GUI in JMT)
	if self.isMatched() and realBOL &lt;&gt; null then
		if self.jasScaled &lt;&gt; realBOL.jasScaled then
			app.raiseCMException2(LogDocketMatched, ETRow_JasScaled, realBOL.myBOL.number, ETRow_JasScaled, null);
		endif;
		
		if self.percentScaled &lt;&gt; realBOL.percentScaled then
			app.raiseCMException2(LogDocketMatched, ETRow_PercentScaled, realBOL.myBOL.number, ETRow_PercentScaled, null);
		endif;
		
		if self.ticketedAll &lt;&gt; realBOL.ticketedAll then
			app.raiseCMException2(LogDocketMatched, ETRow_TicketedAll, realBOL.myBOL.number, ETRow_TicketedAll, null);
		endif;
		
		if self.myBOL.getOperatorCode &lt;&gt; realBOL.myBOL.getOperatorCode then
			app.raiseCMException2(LogDocketMatched, ETRow_Operator, realBOL.myBOL.number, ETRow_Operator, null);
		endif;
		
		if self.myLogSpecies &lt;&gt; realBOL.myLogSpecies then
			app.raiseCMException2(LogDocketMatched, ETRow_LogSpecies, realBOL.myBOL.number, ETRow_LogSpecies, null);
		endif;
		
		if self.myLogGrade &lt;&gt; realBOL.myLogGrade then
			app.raiseCMException2(LogDocketMatched, ETRow_LogGrade, realBOL.myBOL.number, ETRow_LogGrade, null);
		endif;
		
		if self.myLogType &lt;&gt; realBOL.myLogType then
			app.raiseCMException2(LogDocketMatched, ETRow_LogType, realBOL.myBOL.number, ETRow_LogType, null);
		endif;
		
		if self.myLogTreatment &lt;&gt; realBOL.myLogTreatment then
			app.raiseCMException2(LogDocketMatched, ETRow_LogTreatment, realBOL.myBOL.number, ETRow_LogTreatment, null);
		endif;
		
		if self.myLogTreatment &lt;&gt; realBOL.myLogTreatment then
			app.raiseCMException2(LogDocketMatched, ETRow_LogTreatment, realBOL.myBOL.number, ETRow_LogTreatment, null);
		endif;
		
		if self.myLogLength &lt;&gt; realBOL.myLogLength then
			app.raiseCMException2(LogDocketMatched, ETRow_LogLength, realBOL.myBOL.number, ETRow_LogLength, null);
		endif;
	endif;
	
	// Par 9810
	self.validateTypeTreatment(pControl);

epilog
	delete cmifSearchTypes;
end;</source>
        <access>protected</access>
        <Parameter name="pControl" type="CMIF_TIUpdateController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateTicketSequenceId" id="6e7b4778-3206-4241-a979-8d56f7a5f64c">
        <source>validateTicketSequenceId(_pseudoIdArray : StringArray) : Boolean protected;
//--------------------------------------------------------------
//Created: 30 April 2002 By: cnwgd1
//--------------------------------------------------------------
constants 
	MsgStr = "in the Database. These entries must be unique.";
vars
	id	: String;
	count	: Integer;
	rtValue : Boolean;
	ticketSeq : CM_TicketSequence;
begin

	foreach id in _pseudoIdArray do
		foreach ticketSeq in self.allTicketSequences do
			rtValue := ticketSeq.isTicketIdNotInSequence(id);
			if not rtValue then
				app.raiseCMException3(ERR_DUPLICATED_LABEL, 'Log ID', id, MsgStr, ETRow_FromId, self);
				return false;	//One duplicate is all we need to quit
			endif;
		endforeach;
	endforeach;

	if self.percentScaled &lt; 100 and self.ticketedAll then
		foreach ticketSeq in self.allTicketSequences do
			count := (count + ticketSeq.allTicketIds.size);
		endforeach;
		if count &lt;&gt; self.myBOL.numItems then
			app.raiseCMException1(TicketSequenceImbalance, self.myBOL.numItems.String, ETRow_TicketSequence, self);		
		endif;
	endif;

	return true;
end;</source>
        <access>protected</access>
        <Parameter name="_pseudoIdArray" type="StringArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateTicketSequences" id="0fa3bb48-d2a4-46a6-a590-f430a3461ed9">
        <source>validateTicketSequences() protected;
// ---------------------------------------------------------------------------
// Created:     25 June 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	idArray		: StringArray;
	seq			: CM_TicketSequence;
	tmpTerminal	: CM_Terminal;
	tmpBOL		: CM_BOL;
begin

	tmpBOL := self.myBOL;

	//THIS WILL NEED TO BE CHANGED IF ALLOWING EDITS TO UNMATCHED BOLS 
	//THAT HAVE BEEN MOVED TO THE YARD (AUTO COMPLETE) IS IMPLEMENTED
	//-----------------------------------------------------------------------------
	if tmpBOL.myPlannedLocation = null then
		//already in location, must be editing a docket
		//therefore TI's would have been created with the ticketSequence id's
		return;
	endif;
	//------------------------------------------------------------------------------

	if (not tmpBOL.matchTime.isValid) //&lt;--Added - Was not been validated when docket created at Gate In
	or tmpBOL.matchTime.isValid and self.myTerminalIfUnmatched &lt;&gt; null then
		// check them
	else
		return;
		// there was a match but it could not be moved into the yard
		//therefore TI's would have been created with the ticketSequence id's
	endif;
	
	tmpTerminal := tmpBOL.myTerminal;
	
	create idArray transient;

	tmpTerminal.getIdsOfUnmatchedTickets(idArray, tmpBOL);

	if (not self.validateTicketSequenceId(idArray)) then
		return;
	endif;
	
	idArray.clear;
	
	foreach seq in self.allTicketSequences do
		seq.allTicketIds.copy(idArray);
	endforeach;
	
	tmpTerminal.validateOnsiteTrackedItemIDs(TI_CargoType_Log, idArray, null, true, false);

epilog
	delete idArray;
end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
