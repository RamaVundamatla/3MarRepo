    </JadeMethod>
    <JadeMethod name="isSnapShotDataMatch" id="8edcf5ba-f2da-44a8-a0d5-9818b257e949">
        <source>isSnapShotDataMatch(_criteria: CM_YACriteria; _yaType: Integer; _propertyValue: String): Boolean;

vars
	match	: Boolean;
	obj		: Object;
begin
	if _yaType &lt;&gt; self.type then
		return false;
	endif;
	
	foreach obj in _criteria.myYAData.CM_YADataObjects.allObjects do
		if obj.CM_CommodityGroup.code = _propertyValue then
			return true;
		endif;
	endforeach;
	
	if _criteria.myYAData.isKindOf(CM_YADataPattern) and
	   _criteria.myYAData.CM_YADataPattern.pattern = null then
		return true;
	endif;
	
	return false;
end;
</source>
        <Parameter name="_criteria" type="CM_YACriteria"/>
        <Parameter name="_yaType" type="Integer"/>
        <Parameter name="_propertyValue" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isStorageDetailMatch" id="6fd9c7ab-11ed-4fad-8780-1d088957852d">
        <source>isStorageDetailMatch(_criteria : CM_YACriteria; _ti: CM_TrackedItem; _tiTrx : CM_TITransaction): Boolean;
// CCMS 1295 free storage days
vars
	commodGroup		: CM_CommodityGroup;
	commod		: CM_Commodity;
begin
//	commodGroup := _ti.myCommodityGroup;
	
	if _tiTrx &lt;&gt; null then	//13 Nov 2019	NDL	TFS 47344
		if _tiTrx.commodity &lt;&gt; null then
			commod := app.myRoot.allCommodities[ _tiTrx.commodity ];
			if commod &lt;&gt; null then
				commodGroup := commod.myCommodityGroup;
			endif;
		endif;
	else
		commodGroup := _ti.myCommodityGroup;
	endif;
	
	// specific value - 31221 handle wild cards as well
	if _criteria.myYAData.CM_YADataObjects.matchesStorage(commodGroup) then
		return true;
	endif;
	
	// default value
	if _criteria.myYAData.isKindOf(CM_YADataPattern) and
	   _criteria.myYAData.CM_YADataPattern.pattern = null then
		return true;
	endif;
	
	return false;
end;
</source>
        <Parameter name="_criteria" type="CM_YACriteria"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_tiTrx" type="CM_TITransaction"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isVoyageAllocationCT" id="4ff7f16f-7a88-4378-b7b7-d551753ea697">
