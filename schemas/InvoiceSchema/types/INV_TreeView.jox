        <source>doBaseFormCancel() updating, protected;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if self.frmProperties.visible = false then
	//and self.frmSearch.visible = false then //navtnr20 25-07-2023 Bug-59312
		inheritMethod();
		self.unloadForm();
	endif;
end;</source>
