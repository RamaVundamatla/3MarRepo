    <JadeMethod name="translateForm" id="351e1719-2024-4d93-91a1-1792ce3ab8e7">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0008210, locale);
	btnAdd.translateBubbleHelp(Xlat_0005363, locale);
	btnAdd.translateCaption(Xlat_0005364, locale);
	btnDelete.translateBubbleHelp(Xlat_0005365, locale);
	btnDelete.translateCaption(Xlat_0005366, locale);
	btnEdit.translateBubbleHelp(Xlat_0005367, locale);
	btnEdit.translateCaption(Xlat_0005368, locale);
	btnNext.translateCaption(Xlat_0005369, locale);
	btnPrev.translateCaption(Xlat_0005370, locale);
	btnRefresh.translateBubbleHelp(Xlat_0005371, locale);
	btnRefresh.translateCaption(Xlat_0005372, locale);
	btnStdTimes.translateBubbleHelp(Xlat_0005373, locale);
	btnStdTimes.translateCaption(Xlat_0005374, locale);
	lblInstruction.translateCaption(Xlat_0005375, locale);
	mnuDelTimeSlot.translateCaption(Xlat_0008211, locale);
	mnuInsertTimeSlot.translateCaption(Xlat_0008212, locale);
	mnuInspect.translateCaption(Xlat_0008213, locale);
	mnuTS.translateCaption(Xlat_0008214, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="txtYear_lostFocus" id="161dda88-abe3-43f5-bcab-0f78e4eb2f6a">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtYear_lostFocus(textbox: TextBox input) updating;
// ---------------------------------------------------------------------------
// Created:     cnwyl1  Yi Liu
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
