    <JadeMethod name="btnAssignApply_click" id="1bba93c1-8236-4e4f-b4e1-8de6c9e5dc30">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnAssignApply_click(btn: Button input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 August 2009	cnwndl1	Initial creation

*/

vars

	theReturn : Integer;
	tis, tisWarn : CM_TIArray;
	theTrain : CM_Train;
	
begin

	create tis transient;
	create tisWarn transient;
	self.tblData.allSelectedObjects.copy(tis);
	
	if tis.isEmpty() then
		app.msgBox(app.getErrorString(Please_select_some_cargo_assig), app.getErrorString(Train_assign), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	theTrain := cmbAssignTrain.listObject.CM_Train;
	
	while true do
		app.myTrxUA.trxUpdateTIsAssignToTrain(tis, theTrain, tisWarn, app.myPassport);
		
		if tisWarn.isEmpty() then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Train_assign), app.myPassport, ErrWarnMode_AddUpdate ); //+ ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				
				tis.clear;
				tisWarn.copy(tis);
				tisWarn.clear;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			
			return;
		endif;
		break;
	endwhile;

epilog
	frmAssignTrain.visible := false;
	delete tis;
	delete tisWarn;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
