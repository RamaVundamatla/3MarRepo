    <JadeMethod name="assignValueSpecial" id="ce85fd2c-1924-42eb-b87e-1696af4f43ff">
        <updating/>
        <source>assignValueSpecial(_propName: String; _processedValue: String; _xlationOperator: CM_Operator): Boolean updating;
//
// 06 Jul 2017	jlgrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
//
vars
	
begin
//write class.name&amp;'::'&amp;method.name&amp;' '&amp;_propName&amp;' '&amp;_processedValue;
	if _propName = CM_EDISealTI::sealEDIType.name then
		self.sealEDIType := self.sealTypeTranslate(_processedValue);
		return true;
	else
		return inheritMethod(_propName, _processedValue, _xlationOperator);
	endif;
epilog

end;</source>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_processedValue" type="String"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canUserSet" id="aaf76e9c-9454-417a-9a05-ba383bf5f371">
        <source>canUserSet(_propName: String): Boolean;
//
// 15 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
//
vars

begin
	if _propName = CM_EDITrackedItem::cargoTypeDescr.name or
	   _propName = CM_EDITrackedItem::description.name or
	   _propName = CM_EDITrackedItem::fullOrMT.name then
//	   _propName = CM_EDITrackedItem::specialStowage.name then
		return false;
	else
		return inheritMethod(_propName);
	endif;
end;
</source>
        <Parameter name="_propName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
