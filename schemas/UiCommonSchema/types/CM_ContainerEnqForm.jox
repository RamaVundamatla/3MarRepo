begin
	if self.myProxyObject &lt;&gt; null then
		self.myProxyObject.CM_TrackedItem.setMySortingMethod(combobox.listObject.CM_SortingMethod);
	endif;
	
	tbl := combobox.parent.CM_EntryTable;
	if combobox.listObject &lt;&gt; null then
		tbl.setValueByControlName(combobox.name, combobox.listObject.CM_SortingMethod.code);
	else
		tbl.setValueByControlName(combobox.name, null);
	endif;
	
	combobox.doChangedCompareForEntryTable();
	
