<CollClass name="HMS_ResourceByTypeDict" id="07898482-cee3-4a09-a898-9efe9cedabfd">
    <duplicatesAllowed/>
    <loadFactor>66</loadFactor>
    <memberType name="HMS_Resource"/>
    <superclass name="CM_MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="harbour"/>
    <MemberKey>
        <keyPath>
            <ExplicitInverseRef name="HMS_Resource::myResourceType"/>
        </keyPath>
        <property name="HMS_ResourceType::code"/>
    </MemberKey>
    <JadeMethod name="getHMSResourceForClass" id="a6fd49b7-0872-46ab-a880-781c6ce51a13">
        <source>getHMSResourceForClass(_harbour : HMS_Harbour;_class : Class) : HMS_Resource;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 December 2018	jlger1	Initial creation 42253

*/

vars
		hmsResource : HMS_Resource;
	hmsResourceType : HMS_ResourceType;
begin	
	foreach hmsResource in self discreteLock do
		if hmsResource.myHarbour &lt;&gt; _harbour then
			continue;
		endif;
		
		hmsResourceType:=hmsResource.myResourceType;
		if hmsResourceType = null or hmsResourceType.isNotAvailableForEntry or
			hmsResourceType.isMarineService then
			continue;
		endif;	
	
		if hmsResource.isResourceForClass(_class) then
			return hmsResource;
		endif;
	
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_harbour" type="HMS_Harbour"/>
        <Parameter name="_class" type="Class"/>
        <ReturnType type="HMS_Resource"/>
    </JadeMethod>
</CollClass>
