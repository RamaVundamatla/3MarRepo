    <JadeMethod name="mnuUnassignDR_click" id="aac3f731-b3c8-417e-9790-56ab074db23d">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuUnassignDR_click(menuItem: MenuItem input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
06 September 2019		jlgzm1	Initial creation TFS 42872 Direct Release Between HOLD Voyages and Rail

*/

vars

begin
	self.doUnassignDirectRelease();
epilog

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="populateJobDetails" id="ff1ee357-4f90-41fb-a399-6841d2cb897a">
        <updating/>
        <source>populateJobDetails(_job : CM_VoyageHoldJob) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 19/01/2017	cnwdap1		Initial creation TFS 3219 LNX Voyage Operations Enhancwements
//13 Feb 2017	NDL				TFS 3425 - Remove timne conversion
// 21/02/2017	cnwdap1		TFS 3489 LNX DLR/SOB
// 14/03/2017	cnwdap1		TFS 3516 LNX Hold Planning Quantity
// 25/05/2018	jlgdap1		TFS 38534 Transfer Type not displaying correctly
// 28/09/2018 	JLGNS1		Bug 40500: STWO - Hold Planning(STWUJMT2)
// 28/10/2021	navdap1		TFS 52293 SAL Direct Loading Partial Prenoted Cargo from Truck to Vessel
// 10/12/2021   navma1		Bug 52539: SAL - Hold Planning Split Work - Delete Job
// 22/10/2024	navcs2		MTN-28961 EUP | Transaction Instrumentation - Voyage Planning
// 14 Jan 2026 	navhl20 	Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
vars
	shiftString : String;
	ti 			: CM_TrackedItem;
	invalid	    : Boolean;
	shift       : CM_Shift;
begin
	on Exception do app.handleDeletedObject(exception, _job, invalid); 	//10.12.21 navma1 #52539
	
	self.btnTranship.enabled := false; 				// TFS 3561

	if _job = null then
		self.clearDetails();
		self.handleLoadDischarge();
		self.showDLRDischargeFields(null, null);	// TFS 3516
		return;
	endif;
	
	_job.fetchLatest();							   	//10.12.21 navma1 #52539
	if invalid then
		self.clearDetails();
		self.handleLoadDischarge();
		self.showDLRDischargeFields(null, null);	
		return;
	endif;
		
	if _job.isDischarge then
		self.lblDischLoad.caption := app.getErrorString(Plan_discharge);

		self.cmbDischLoad.visible := true;
		self.cmbSubArea.visible   := true;
		self.lblSubArea.visible   := true;
		self.cmbDLRDisch.visible  := false;			  				//Bug 40500
		self.lblDLRDisch .visible := false;							//Bug 40500
		self.loadLocationsCombo(true);
		self.cmbDischLoad.width   := 150;							//Bug 40500
		self.chkDLR.visible 	  := true;							// TFS 3489
		self.chkSOB.visible 	  := true;							// TFS 3489
		self.btnTranship.enabled  := true; 							// TFS 3561
	else
		self.lblDischLoad.caption := app.getErrorString(Plan_load);
		self.cmbDischLoad.visible := true;
		self.cmbSubArea.visible   := false;
		self.lblSubArea.visible   := false;
		self.loadLocationsCombo(false);
		self.cmbDischLoad.width := 200;								//Bug 40500
		self.chkDLR.visible     := true;							// TFS 3489
		self.chkSOB.visible     := true;							// TFS 3489
	endif;
	
	self.chkDLR.value := false;										// TFS 3489
	self.chkSOB.value := false;										// TFS 3489
	if _job.isDischarge then										// TFS 3489
		ti := _job.allReceiveTrackedItems.first;					// TFS 3489
	else															// TFS 3489
		ti := _job.allReleaseTrackeditems.first;					// TFS 3489
	endif;															// TFS 3489
	if ti &lt;&gt; null then												// TFS 3489
		if ti.getTransitStatus = TI_TransitStatusDLR then			// TFS 3489
			self.chkDLR.value := true;								// TFS 3489
			self.chkSOB.value := false;								// TFS 3489
			if not _job.isDischarge then 																														//Bug 40500
				self.lblDLRDisch.visible   := true;																												//Bug 40500
				self.lblDLRDisch.move(self.lblSubArea.left+ 55 , self.lblSubArea.top , self.lblDLRDisch.width, self.lblDLRDisch.height);						//Bug 40500
				self.cmbDLRDisch.visible   := true;																												//Bug 40500
				self.cmbDLRDisch.move(self.lblDLRDisch.left+self.lblDLRDisch.width + 10, self.lblDLRDisch.top, self.cmbDLRDisch.width, self.cmbDLRDisch.height);//Bug 40500
				self.cmbDLRDisch.enabled   := false;																											//Bug 40500
				self.chkDLR.visible        := false;																											//Bug 40500
				self.chkSOB.visible        := false;																											//Bug 40500
				self.cmbDLRDisch.listIndex := self.cmbDLRDisch.findObject(_job.myDLRDischargeJob);																//Bug 40500
			endif;																																				//Bug 40500
		elseif ti.getTransitStatus = TI_TransitStatusSOB then		// TFS 3489
			self.chkSOB.value := true;								// TFS 3489
			self.chkDLR.value := false;								// TFS 3489
			self.doSOBSwitchDischargeLoad(true);					// TFS 3489
		endif;														// TFS 3489
	endif;															// TFS 3489
	self.populateJobDetailsLocation(_job);

	self.txtJobId.text             := _job.id;
	self.txtJobRemarks.text        := _job.remarks;
	self.cmbWorkPoint.listIndex    := self.cmbWorkPoint.findObject(_job.getMyWorkPointObject);
	self.cmbTransferType.listIndex := self.cmbTransferType.findObject(app.myRoot.allVoyageJobTransferTypes[_job.transferType]);	// TFS 38534
	
	shift := _job.myShift;
	
	if shift &lt;&gt; null then // TFS 3558
		shiftString 			 := shift.getShiftDay &amp; Space &amp; shift.code &amp; Space &amp; shift.startDateTime.date.asStringJMT();
		self.cmbShifts.listIndex := self.cmbShifts.findStringExact(1, shiftString);
		self.txtShiftStartDate.setDate(shift.startDateTime.date);
		self.txtShiftStartTime.setTime(shift.startDateTime.time);
		self.txtShiftEndDate.setDate(shift.endDateTime.date);
		self.txtShiftEndTime.setTime(shift.endDateTime.time);
		self.txtShiftRemarks.text := shift.remarks;
	else
		self.cmbShifts.listIndex := -1; 		// TFS 3558
		self.txtShiftStartDate.setDate(null); 	// TFS 3558
		self.txtShiftStartTime.setTime(null); 	// TFS 3558
		self.txtShiftEndDate.setDate(null); 	// TFS 3558
		self.txtShiftEndTime.setTime(null); 	// TFS 3558
		self.txtShiftRemarks.text := ""; 		// TFS 3558

	endif;
	self.chkDirectDelivery.value := _job.isDirectDelivery;		// TFS 52293
	
epilog
	
end;</source>
        <Parameter name="_job" type="CM_VoyageHoldJob"/>
    </JadeMethod>
    <JadeMethod name="populateJobDetailsLocation" id="444f9f99-aeda-4013-8f82-482e9f2a78ce">
        <updating/>
        <source>populateJobDetailsLocation(_job : CM_VoyageHoldJob) updating;
/*
Purpose:			
Date		Who		Reason
14/02/2017	cnwab1	Initial creation
22/02/2017	cnwdap1	TFS 3489 LNX DLR/SOB
06/03/2017	cnwdap1	TFS 3516 LNX Hold Planning Quantity
28/09/2018 	JLGNS1	Bug 40500: STWO - Hold Planning(STWUJMT2)
25/06/2020	jlgdap1	TFS 49453 ASPA Satellite View Screen for Felxible Terminal Areas
*/

vars
	wle 			: CM_WorkListEntry;
	trackedItem 	: CM_TrackedItem;
	locController 	: CM_LocationsController;
	termArea 		: CM_TerminalArea;
	showShipAreas 	: Boolean;							// TFS 3489
	hght 			: Integer;							// TFS 3516

begin
	foreach wle in _job.workListEntries discreteLock do
		trackedItem := wle.myTrackedItem;
		if trackedItem &lt;&gt; null then
			//if ti.isSOB then												// TFS 3489			// TFS 3516
			if trackedItem.isSOB or (trackedItem.isRehandle and not wle.isReceipt) then		// TFS 3489			// TFS 3516
				showShipAreas := true;										// TFS 3489
			endif;															// TFS 3489
			//Bug 40500
			self.myTerminal.findLocationFromString(wle.locationTarget, true, locController, hght);		// TFS 3516
			//Bug 40500
			if locController &lt;&gt; null then
				break;
			endif;
		endif;
	endforeach;
	
	//if _job.isDischarge then												// TFS 3489
	if _job.isDischarge and not showShipAreas then							// TFS 3489
		if locController &lt;&gt; null then																					//Bug 40500
			termArea := locController.getMyTerminalArea();																//Bug 40500
			if termArea &lt;&gt; null then																					//Bug 40500
				self.cmbDischLoad.listIndex := self.cmbDischLoad.findObject(termArea);									//Bug 40500
				self.doBuildSubAreaCombo();																				//Bug 40500
																													//Bug 40500
				if termArea.isIrregularBlockArea then																		//Bug 40500
					self.cmbSubArea.setIndex( self.cmbSubArea.findObject(locController));									//Bug 40500
				elseif termArea.type = TA_TYPE_FORK_LIFT_STACK then															//Bug 40500
					if self.cmbSubArea.listCount &gt; 0 then																	//Bug 40500
						self.cmbSubArea.setIndex(self.cmbSubArea.findObject(locController.CM_GridController.myGridColumn));	//Bug 40500
					endif;																									//Bug 40500
				elseif termArea.type = TA_TYPE_RORO_LANE_AREA then															//Bug 40500
					if self.cmbSubArea.listCount &gt; 0 then																	//Bug 40500
						self.cmbSubArea.setIndex(self.cmbSubArea.findObject(locController));								//Bug 40500
					endif;																									//Bug 40500
				elseif termArea.isGeneralCargoAllocArea then									// TFS 49453
					if self.cmbSubArea.listCount &gt; 0 then										// TFS 49453
						self.cmbSubArea.setIndex(self.cmbSubArea.findObject(locController));	// TFS 49453
					endif;																		// TFS 49453
				else																										//Bug 40500
					if self.cmbSubArea.listCount &gt; 0 then																	//Bug 40500
						self.cmbSubArea.setIndex(self.cmbSubArea.findObject(locController.CM_GridController.myGridRow));	//Bug 40500
					endif;																									//Bug 40500
				endif;																										//Bug 40500
			endif;
		endif;
	else
		if locController &lt;&gt; null then
			self.loadLocationsCombo(false);
			self.cmbDischLoad.listIndex := self.cmbDischLoad.findObject(locController);
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_job" type="CM_VoyageHoldJob"/>
    </JadeMethod>
    <JadeMethod name="removeTI" id="c2362b75-acb7-4df8-80ed-cb950168c0b8">
        <source>removeTI(_ti : CM_TrackedItem);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 18/01/2017	cnwdap1		Initial creation TFS 3219 LNX Voyage Operations Enhancements
// 20/08/2018	jlgdap1		TFS 39964 PEL1 Hold Job Ops Loading Changes
// 23/10/2019	jlgzm1		TFS 47085 Direct Release Ship to Ship
//
vars
	idx, cloneIdx : Integer;
	table : CM_DataTable;

begin
	if (not self.allDisplayedTIs.includes(_ti)) then
		return;
	endif;
	
	if self.tblOnShip.findObjectInRow(_ti, idx) then
		self.tblOnShip.removeItem(idx);
	endif;
	
	if self.tblOnSite.findObjectInRow(_ti, idx) then
		self.tblOnSite.removeItem(idx);
	endif;
	
	if self.tblPreNote.findObjectInRow(_ti, idx) then		// TFS 39964
		self.tblPreNote.removeItem(idx);					// TFS 39964
	endif;													// TFS 39964
	
	if self.tblTranship.findObjectInRow(_ti, idx) then		// TFS 47085
		self.tblTranship.removeItem(idx);					// TFS 47085
		self.setTranshipVisibility();						// TFS 47085
	endif;
	
	foreach cloneIdx in 1 to self.allocatedTableCount do
		table := self.tblAllocatedGang.getControl(cloneIdx);
		if table &lt;&gt; null and table.findObjectInRow(_ti, idx) then
			table.removeItem(idx);
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="removeWLE" id="061e6f36-72cc-440c-8767-c590eb66afc5">
        <source>removeWLE(_wle : CM_WorkListEntry);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
18 July 2019		jlgzm1	Initial creation Initial creation TFS 42872 Direct Release Between HOLD Voyages and Rail - All Cargo Types

*/

vars
	idx, cloneIdx : Integer;
	table : CM_DataTable;
begin
	if (not self.allDisplayedWLEs.includes(_wle)) then
		return;
	endif;
	
	foreach cloneIdx in 1 to self.allocatedTableCount do
		table := self.tblAllocatedGang.getControl(cloneIdx);
		if table &lt;&gt; null and table.findObjectInRow(_wle, idx) then
			table.removeItem(idx);
		endif;
	endforeach;
	
epilog

end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="setButtonStates" id="3e60ec39-e09b-4d81-8b1a-39db19d6ed62">
        <updating/>
        <source>setButtonStates(_job : CM_VoyageHoldJob) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 20/01/2017	cnwdap1		Initial creation TFS 3219 LNX Voyage Operations Enhancements
// 11/07/2017   cnwma1      TFS #4641:1215 error on Hold Planning form
vars

begin
	if _job = null or self.mode.isOneOf(self.Mode_Update, self.Mode_Add) then
		self.btnDeleteTV.enabled := false;
		self.btnEditTV.enabled := false;
		self.btnRefresh.enabled := false; 
		
		if self.mode.isOneOf(self.Mode_Update, self.Mode_Add) then
			self.btnSaveBase.enabled := true;
			self.btnNewTV.enabled := false;
			self.btnEventTrans.enabled := false; //11.7.2017 cnwma1 TFS #4641
		else
			self.btnSaveBase.enabled := false;
			if app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
				self.btnNewTV.enabled := true;
			endif;
			self.btnRefresh.enabled := true;
			self.btnEventTrans.enabled := true;  //11.7.2017 cnwma1 TFS #4641
		endif;
	else
		if app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
			self.btnDeleteTV.enabled := true;
			self.btnEditTV.enabled := true;
		endif;
		self.btnNewTV.enabled := false;
		if self.mode = self.Mode_View then
			self.btnSaveBase.enabled := false;
			self.btnRefresh.enabled := true;
			self.btnEventTrans.enabled := true;  //11.7.2017 cnwma1 TFS #4641
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_job" type="CM_VoyageHoldJob"/>
    </JadeMethod>
    <JadeMethod name="setClonedSheetAndTable" id="af04d246-d86f-42a4-bb10-4b42a83a70c2">
        <updating/>
        <source>setClonedSheetAndTable(	_job : CM_VoyageHoldJob; 
						_sheet : CMUI_Sheet output; 
						_table : CM_DataTable output;
						_allocatedWLEs : CM_WLEArray	) updating;		// TFS 3516
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 24/01/2017	cnwdap1		Initial creation TFS 3219 LNX Voyage Operations Enhancements
// 01/03/2017	cnwdap1		TFS 3516 LNX hold Planning Quantity
//
vars
	sheet : CMUI_Sheet;
	table, existingTable : CM_DataTable;
	tmpTblXML : String;
	userWindow : CM_UserWindow;
	startPos : Integer;

begin
	self.allocatedTableCount := self.allocatedTableCount + 1;
	sheet := self.shtAllocatedGang.loadControl(self.allocatedTableCount).CMUI_Sheet;
	if _job &lt;&gt; null then
		sheet.caption := _job.id &amp; Space &amp; _job.getJobTypeDescription;
	endif;
	sheet.tag := self.allocatedTableCount.String;
	sheet.userObject := _job;
	
	self.allocatedTableCount := self.allocatedTableCount + 1;
	table := self.tblAllocatedGang.loadControl(self.allocatedTableCount).CM_DataTable;
	table.selectMode := table.SelectMode_Row;
	table.multiSelect := table.MultiSelect_Simple;
	table.selectionType := table.SelectionType_Row;
	table.parent := sheet;
	self.setTableHeadings(table);
	// see if we have column / sort details for this table
	//09 May 2018	NDL	TFS 38460
	if _job.jobType = JOB_TYPE_DISCHARGE then
		table.setColumnsFromXMLStr(xmlDischargeTableStr);
	else 
		table.setColumnsFromXMLStr(xmlLoadTableStr);
	endif;
	/*
	userWindow := table.sendMsg(CM_DataTable::getMyUserWindow.name).CM_UserWindow;
	if userWindow &lt;&gt; null then
		startPos := 1;
		tmpTblXML := userWindow.xmlInfo.cnEcGetNextTagValueOfName(XMLTag_Job_Table &amp; table.parent.CMUI_Sheet.caption, startPos);
	endif;
	if tmpTblXML = null then
		// default column headings to existing table
		if _job.jobType = JOB_TYPE_DISCHARGE then
			existingTable := self.tblOnShip;
		else 
			existingTable := self.tblOnSite;
		endif;
		tmpTblXML := existingTable.getXmlStrForColumns(true);
	endif;
	if tmpTblXML &lt;&gt; null then
		table.setColumnsFromXMLStr(tmpTblXML);
	endif;
	*/
	//self.loadVoyageJobTable(_job, table);								// TFS 3516
	self.loadVoyageJobTable(_job, table, _allocatedWLEs);				// TFS 3516
	
	_sheet := sheet;
	_table := table;
	self.fldData.initSheetBackColors(); 
	
epilog

end;</source>
        <Parameter name="_job" type="CM_VoyageHoldJob"/>
        <Parameter name="_sheet" type="CMUI_Sheet" usage="output"/>
        <Parameter name="_table" type="CM_DataTable" usage="output"/>
        <Parameter name="_allocatedWLEs" type="CM_WLEArray"/>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="caba01ef-b5eb-46d6-9951-cc901506b2bc">
        <updating/>
        <source>setControlsForAddEdit(_job : CM_VoyageHoldJob) updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 20/01/2017	cnwdap1		Initial creation TFS 3219 LNX Voyage Operations Enhancements
// 17/02/2017	cnwdap1		TFS 3489 DLR / SOB
// 14/03/2017	cnwdap1		TFS 3516 LNX Hold Planning Quantity
// 25/05/2018	jlgdap1		TFS 38534 Transfer Type not displaying correctly
// 01/08/2018	jlgdap1		TFS 39964 PEL1 Hold Job Ops Loading Changes
// 28/09/2018 	JLGNS1		Bug 40500: STWO - Hold Planning(STWUJMT2)
// 23/10/219	jlgzm1		TFS 47085 Direct Release Ship to Ship
// 28/10/2021	navdap1		TFS 52293 SAL Direct Loading Partial Prenoted Cargo from Truck to Vessel

vars
	idx : Integer;
	ctrl : Control;
	dlr, unselDLR : Boolean;				// TFS 3516
	table : CM_DataTable;					// TFS 3516
	ti : CM_TrackedItem;					// TFS 3516
	
begin

	self.cmbWorkPoint.enabled :=  self.mode = self.Mode_Add;				//Bug 40500
	self.cmbVoyage.enabled := self.mode = self.Mode_Add;					//Bug 40500
	self.cmbShifts.enabled := _job &lt;&gt; null or self.mode = self.Mode_Add;
	self.txtJobId.enabled := _job &lt;&gt; null or self.mode = self.Mode_Add;
	self.txtShiftStartDate.enabled := _job &lt;&gt; null or self.mode = self.Mode_Add;
	self.txtShiftStartTime.enabled := _job &lt;&gt; null or self.mode = self.Mode_Add;
	self.txtShiftEndDate.enabled := _job &lt;&gt; null or self.mode = self.Mode_Add;
	self.txtShiftEndTime.enabled := _job &lt;&gt; null or self.mode = self.Mode_Add;
	self.txtJobRemarks.enabled := _job &lt;&gt; null or self.mode = self.Mode_Add;
	self.txtShiftRemarks.enabled := _job &lt;&gt; null or self.mode = self.Mode_Add;
	self.cmbDischLoad.enabled := _job &lt;&gt; null or self.mode = self.Mode_Add;
	self.cmbSubArea.enabled := _job &lt;&gt; null or self.mode = self.Mode_Add;
	self.chkDLR.enabled := _job &lt;&gt; null or self.mode = self.Mode_Add;					// TFS 3489
	self.chkSOB.enabled := _job &lt;&gt; null or self.mode = self.Mode_Add;					// TFS 3489
	self.shtOnSite.enabled := true;	//21 Jun 2017	NDL	TFS 4948
	self.shtOnShip.enabled := true;	//21 Jun 2017	NDL	TFS 4948
	self.shtPreNote.enabled := true;								// TFS 39964
	self.cmbTransferType.enabled := _job &lt;&gt; null or self.mode = self.Mode_Add;		// TFS 38534
	// TFS 52293 start
	self.chkDirectDelivery.enabled := _job &lt;&gt; null or self.mode = self.Mode_Add;
	if self.mode = self.Mode_Add then
		// default Direct Delivery to ticked if config set
		self.chkDirectDelivery.value := false;  // ### TFS 52619 20DEC2021 NAVAB1 default to false, was self.myTerminal.getConfig(DirectTruck2VesselMult).Boolean;
	endif;
	// TFS 52293 end
	
	// disable any job-related sheets
	foreach idx in 1 to self.allocatedTableCount do
		ctrl := self.shtAllocatedGang.getControl(idx);
		if ctrl &lt;&gt; null and ctrl.isKindOf(CMUI_Sheet) then
			// in Edit mode, we have to leave the top sheet enabled, because that's the job we're editing
			if ctrl.CMUI_Sheet &lt;&gt; self.fldData.topSheet or self.mode = self.Mode_Add then
				ctrl.enabled := false;
			endif;
		endif;
	endforeach;
	
	//21 Jun 2017	NDL	TFS 4948
	if  _job &lt;&gt; null and self.mode = self.Mode_Update then
		self.setMyPxyJobForEdit(_job,true);
		if _job.isDischarge then
			self.shtOnSite.enabled := false;
			self.shtPreNote.enabled := false;						// TFS 39964
		else
			self.shtOnShip.enabled := false;
		endif;
	endif;
	
	// see if we have a DLR job																			// TFS 3516
	if _job &lt;&gt; null and _job.isRehandle then															// TFS 3516
		dlr := true;																					// TFS 3516
	else																								// TFS 3516
		if self.fldData.topSheet = self.shtOnShip then													// TFS 3516
			table := self.tblOnShip;																	// TFS 3516
		elseif self.fldData.topSheet = self.shtOnSite then												// TFS 3516
			table := self.tblOnSite;																	// TFS 3516
		elseif self.fldData.topSheet = self.shtPreNote then			// TFS 39964
			table := self.tblPreNote;								// TFS 39964
		elseif self.fldData.topSheet = self.shtTranship then											// TFS 47085
			table := self.tblTranship;																	// TFS 47085
			self.chkDirectRelease.visible := true;														// TFS 47085
		else																							// TFS 3516
			table := self.tblAllocatedGang.getControl(self.fldData.topSheet.index+1).CM_DataTable;		// TFS 3516
		endif;																							// TFS 3516
		foreach idx in table.fixedRows + 1 to table.rows do												// TFS 3516
			if table.accessRow(idx).itemObject.isKindOf(CM_WorkListEntry) then							// TFS 42872 jlgzm1 12/07/2019
				ti :=  table.accessRow(idx).itemObject.CM_WorkListEntry.myTrackedItem;					// TFS 42872 
			else
				ti := table.accessRow(idx).itemObject.CM_TrackedItem;									// TFS 3516
			endif;
			if ti &lt;&gt; null and ti.isRehandle then 														// TFS 3516
				if table.accessedRow.selected then														// TFS 3516
					dlr := true;																		// TFS 3516
				else																					// TFS 3516
					unselDLR := true;																	// TFS 3516
				endif;																					// TFS 3516
			endif;																						// TFS 3516
		endforeach;																						// TFS 3516
		if dlr or (not dlr and unselDLR) then															// TFS 3516
			self.showDLRDischargeFields(table, null);													// TFS 3516
		endif;																							// TFS 3516
	endif;																								// TFS 3516
	
	self.setButtonStates(_job);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_job" type="CM_VoyageHoldJob"/>
    </JadeMethod>
    <JadeMethod name="setControlsForView" id="e7e49a96-f4e7-42dc-b9d4-94dbfbf22cae">
        <updating/>
        <source>setControlsForView() updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 23/01/2017	cnwdap1		Initial creation TFS 3219 LNX Voyge Operations Enhancements
// 17/02/2017	cnwdap1		TFS 3489 DLR / SOB
// 25/05/2018	jlgdap1		TFS 38534 Transfer Type not displaying correctly
// 20/08/2018	jlgdap1		TFS 39964 PEL1 Hold JOb Ops Loading Changes
// 28/09/2018 	JLGNS1	Bug 40500: STWO - Hold Planning(STWUJMT2)
// 23/10/219	jlgzm1		TFS 47085 Direct Release Ship to Ship
// 28/10/2021	navdap1		TFS 52293 SAL Direct Loading Partial Prenoted Cargo from Truck to Vessel
vars
	idx : Integer;
	ctrl : Control;
	table : CM_DataTable;

begin

	//22 Jun 2017	NDL	TFS 4948
	self.setMyPxyJobForEdit(null,true);
	self.cmbVoyage.enabled := true;				// Bug 40500
	self.btnRefresh.enabled := true;
	self.cmbWorkPoint.enabled := false;
	self.cmbTransferType.enabled := false;			// TFS 38534
	self.cmbShifts.enabled := false;
	self.txtJobId.enabled := false;
	self.txtShiftStartDate.enabled := false;
	self.txtShiftStartTime.enabled := false;
	self.txtShiftEndDate.enabled := false;
	self.txtShiftEndTime.enabled := false;
	self.txtJobRemarks.enabled := false;
	self.txtShiftRemarks.enabled := false;
	
	self.cmbDischLoad.enabled := false;
	self.cmbSubArea.enabled := false;
	
	self.chkDLR.enabled := false;				// TFS 3489
	self.chkSOB.enabled := false;				// TFS 3489
	self.chkDirectRelease.visible := false;		// TFS 47085
	self.chkDirectDelivery.enabled := false;	// TFS 52293
	
	self.tblOnShip.selectMode := CM_DataTable.SelectMode_None;
	self.tblOnSite.selectMode := CM_DataTable.SelectMode_None;
	self.shtOnSite.enabled := true;	//21 Jun 2017	NDL	TFS 4948
	self.shtOnShip.enabled := true;	//21 Jun 2017	NDL	TFS 4948
	self.tblPreNote.selectMode := CM_DataTable.SelectMode_None;			// TFS 39964
	self.shtPreNote.enabled := true;									// TFS 39964
	self.tblTranship.selectMode := CM_DataTable.SelectMode_None;		// TFS 47085
	self.shtTranship.enabled := true;									// TFS 47085
	
	foreach idx in 1 to self.allocatedTableCount do
		ctrl := self.tblAllocatedGang.getControl(idx);
		if ctrl &lt;&gt; null and ctrl.isKindOf(CM_DataTable) then
			table := ctrl.CM_DataTable;
			table.selectMode := CM_DataTable.SelectMode_None;
		endif;
	endforeach;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setMyCurrentVoyage" id="c0d116b4-0666-4e04-b9cf-34e48e7f4790">
        <updating/>
        <source>setMyCurrentVoyage(_voyage : CM_Voyage) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 09/01/2017	cnwdap1		Initial creation TFS 3219 LNX Voyage Operations Enhancements
// 20/08/2018	jlgdap1		TFS 39964 PEL1 Hold JOb Ops Loading Changes
// 3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
// 23/10/2019	jlgzm1		TFS 47085 Direct Release Ship to Ship
//
vars
	str : String;
	vessel : CM_Vessel;
	edLocal: TimeStamp;

begin
	self.myCurrentVoyage := _voyage;
			   
	str := self.baseCaption;	
	if self.myCurrentVoyage = null then
		self.tblOnShip.rows := self.tblOnShip.fixedRows;
		self.tblOnSite.rows := self.tblOnSite.fixedRows;
		self.tblPreNote.rows := self.tblPreNote.fixedRows;				// TFS 39964
		self.tblTranship.rows := self.tblTranship.fixedRows;			// TFS 47085
		self.tblAllocatedGang.rows := self.tblAllocatedGang.fixedRows;
	else
		str := str &amp; app.getFormCaptionsString(Xlat_0000046);

		
		
		str := str &amp; " " &amp; self.myCurrentVoyage.getId.trimBlanks;
	endif;

	

	self.setCaption(str);
	self.setNavigatorHeading(str);
	
	if self.myCurrentVoyage &lt;&gt; null then
		app.setMyCurrentVoyage(self.myCurrentVoyage);
	endif;
	


epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="setMyPxyJobForEdit" id="9f4469a0-6948-4437-8709-83eb6550f035">
        <updating/>
        <source>setMyPxyJobForEdit( _job : CM_VoyageHoldJob; _purgeWles : Boolean ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 June 2017	cnwndl1	Initial creation	TFS 4948

*/

vars

	invalid : Boolean;
	edition : Integer;

begin

	if self.myPxyJobForEdit &lt;&gt; null then
		on Exception do app.handleDeletedObject( exception, self.myPxyJobForEdit, invalid );
		edition := self.myPxyJobForEdit.edition;
		if not invalid then
			if self.myPxyJobForEdit.myShift &lt;&gt; null and self.myPxyJobForEdit.myShift.isTransient then
				delete self.myPxyJobForEdit.myShift;
			endif;
			delete self.myPxyJobForEdit;
		endif;
		self.myPxyJobForEdit := null;
	endif;

	if _job &lt;&gt; null then
		self.myPxyJobForEdit := app.createUpdateProxy(_job).CM_VoyageHoldJob;
	endif;
	
	if _purgeWles then
		if not allPxyWles.isEmpty then
			allPxyWles.purge();
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="_job" type="CM_VoyageHoldJob"/>
        <Parameter name="_purgeWles" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setProxyAndParams" id="6441d761-b227-40c4-9201-33bbad48611b">
        <source>setProxyAndParams(	_pxyJob : CM_VoyageHoldJob input; 
					_jobParams : CMIF_VoyageJobParams input; 
					_allocatedTIs : CM_TISet io;
					_allocatedWLEs : CM_WLEArray io;					// TFS 3516
					_askForAmounts : Boolean	) : Boolean;			// TFS 3516
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 24/01/2017	cnwdap1		Initial creation TFS 3219 LNX Voyage Operation Enhancements
// 20/02/2017	cnwdap1		TFS 3489 LNX DLR/SOB
// 01/03/2017	cnwdap1		TFS 3516 LNX Hold Planning Quantity
// 19/10/2017	jlgdap1		TFS 7492 LNX Voyage Hold Jobs - need to keep track of weight as well as quantity for LNX
// 15/06/2018	jlger1		tfs 39166  pxy errors on shifts
// 01/08/2018	jlgdap1		TFS 39964 PEL1 Hold Job Ops Loading Changes
// 22/07/2019	jlgzm1		TFS 42872 Direct Release Between HOLD Voyages and Rail - All Cargo Types
// 23/10/2019	jlgzm1		TFS 47085 Direct Release Ship to Ship
// 24/11/2021	navdap1		TFS 52360 SAL Direct Prenote to Voyage Incorrect Job Values
// 08/12/2021	navdap1		TFS 52293 SAL Direct Loading - Marking Job as Direct Delivery
//
vars
	jobId, workPointId, remarks : String;
	jobType, idx, row : Integer;
	ctrl : Control;
	topSheet : CMUI_Sheet;
	table : CM_DataTable;
	startTS, endTS : TimeStamp;
	startTSSystem, endTSSystem : TimeStamp;
	workPoint : CM_WorkPoint;
	shift, realShift : CM_Shift;
	shiftCode, shiftDesc : String;
	ti : CM_TrackedItem;									// TFS 3489
	wle : CM_VoyageWLE;										// TFS 3516
	moveAmount : String;									// TFS 3516
	moveType, pos : Integer;								// TFS 3516
	dlrJob : CM_VoyageHoldJob;								// TFS 3516
	currentJob : CM_VoyageHoldJob;							// TFS 42872
	directLoad : Boolean;							// TFS 52360
	jobTotal : Integer;								// TFS 52360

begin
	directLoad := self.myTerminal.getConfig(DirectTruck2VesselMult).Boolean;		// TFS 52360
	jobId := self.txtJobId.text.trimBlanks;
	
	_jobParams.myLocation := self.getLocationForJob();
	
	if self.mode = self.Mode_Add then
		if _jobParams.myLocation= null then
			return false;
		endif;
	endif;
	
	if self.fldData.topSheet = self.shtOnShip then
		jobType := JOB_TYPE_DISCHARGE;
		self.tblOnShip.allSelectedObjects.copy(_allocatedTIs);
	elseif self.fldData.topSheet = self.shtOnSite then
		jobType := JOB_TYPE_LOAD;
		self.tblOnSite.allSelectedObjects.copy(_allocatedTIs);
	elseif self.fldData.topSheet = self.shtPreNote then						// TFS 39964
		jobType := JOB_TYPE_LOAD;											// TFS 39964
		self.tblPreNote.allSelectedObjects.copy(_allocatedTIs);				// TFS 39964
	elseif self.fldData.topSheet = self.shtTranship then					// TFS 47085
		jobType := JOB_TYPE_LOAD;											// TFS 47085
		self.tblTranship.allSelectedObjects.copy(_allocatedTIs);			// TFS 47085
	else
		// we're creating or updating a job - the allocated TIs will be every row in the table
		// get the right table - it'll be the only one whose parent sheet is enabled
		foreach idx in 1 to self.allocatedTableCount do
			ctrl := self.tblAllocatedGang.getControl(idx);
			if ctrl &lt;&gt; null and ctrl.parent.enabled then
				table := ctrl.CM_DataTable;
				break;
			endif;
		endforeach;
		topSheet := table.parent.CMUI_Sheet;
		//jobType := topSheet.userObject.CM_VoyageHoldJob.jobType;
		currentJob := topSheet.userObject.CM_VoyageHoldJob;			// TFS 42872
		jobType := currentJob.jobType;								// TFS 42872
		
		foreach row in table.fixedRows + 1 to table.rows do
			wle := table.accessRow(row).itemObject.CM_VoyageWLE;					// TFS 42872
			if not _askForAmounts then												// TFS 42872
				if not currentJob.workListEntries.includes(wle) then				// TFS 42872
					// any wles added to _allocatedWLEs will be added to the job	// TFS 42872
					_allocatedWLEs.add(wle);										// TFS 42872		
				endif;																// TFS 42872
			endif;																	// TFS 42872
			_allocatedTIs.addNoDuplicates(wle.myTrackedItem, false);				// TFS 42872
		/*
			_allocatedTIs.add(table.accessRow(row).itemObject.CM_TrackedItem);
			if not _askForAmounts then													// TFS 3516
				if table.accessCell(row, 1).itemObject &lt;&gt; null then						// TFS 3516
					_allocatedWLEs.add(table.accessCell(row, 1).itemObject.CM_WorkListEntry);	// TFS 3516
				endif;																	// TFS 3516
			endif;																		// TFS 3516
		*/
		endforeach;
	endif;

	// TFS 3489 cargo mst be Remain on Board to be assigned to DLR or SOB job
	foreach ti in _allocatedTIs do
		if (self.chkDLR.value or self.chkSOB.value) and ti.getImExStatus &lt;&gt; TI_IMEX_STATUS_REMAINONBOARD then
			app.raiseCMException4(Cargo_must_be_ROB_for_DLRSOB, ti.id, app.getErrorString(In_Transit), app.getErrorString(CM_DLR), app.getErrorString(CM_SOB), null, null);
			return false;
		endif;
	endforeach;
	// TFS 3489 end
	
	// TFS 3516 get amounts for this job												// TFS 3516
	if _askForAmounts then																// TFS 3516
		foreach ti in _allocatedTIs do													// TFS 3516
			if ti.canMergeBreakBulk() then												// TFS 3516
				moveAmount := null;														// TFS 3516
				if self.getQuantityForMove(ti, moveAmount, moveType) then				// TFS 3516
					create wle transient;												// TFS 3516
					wle.setMyTrackedItem(ti);											// TFS 3516
					if moveType = self.ByQuantity then									// TFS 3516
						pos := moveAmount.pos(Tab, 1);									// TFS 3516
						wle.setQuantity(moveAmount[pos+1:end].Integer);					// TFS 3516
						wle.setWeight(ti.totalWeight / ti.totalQuantity * wle.quantity);			// TFS 7492
						jobTotal := jobTotal + wle.quantity;						// TFS 52360
					elseif moveType = self.ByVolume or moveType = self.ByWeight then	// TFS 3516
						pos := moveAmount.pos(Tab, 1);									// TFS 3516
						wle.setWeight(moveAmount[pos+1:end].Decimal);					// TFS 3516
						jobTotal := jobTotal + wle.weight.Integer;					// TFS 52360
					endif;																// TFS 3516
					_allocatedWLEs.add(wle);											// TFS 3516
				else																	// TFS 3516
					return false;														// TFS 3516
				endif;																	// TFS 3516
			endif;																		// TFS 3516
		endforeach;																		// TFS 3516
	else											// TFS 52293
		jobTotal := _pxyJob.originalJobAmount;		// TFS 52293
	endif;																				// TFS 3516
	if self.cmbDLRDisch.visible then													// TFS 3516
		dlrJob := self.cmbDLRDisch.listObject.CM_VoyageHoldJob;							// TFS 3516
	endif;																				// TFS 3516
	
	// sort out shift start and end times
	startTS := null;
	endTS := null;
	startTSSystem := null;
	endTSSystem := null;
	if self.txtShiftStartDate.getDate &lt;&gt; null then
		startTS.setDate(self.txtShiftStartDate.getDate);
		startTS.setTime(self.txtShiftStartTime.getTime);
	//	startTSSystem := startTS.localToSystemTimeUsingObject(self.myTerminal);
		startTSSystem := startTS;	//13 Feb 2017	NDL	TFS 3425
	endif;
	if self.txtShiftEndDate.getDate &lt;&gt; null then
		endTS.setDate(self.txtShiftEndDate.getDate);
		endTS.setTime(self.txtShiftEndTime.getTime);
	//	endTSSystem := endTS.localToSystemTimeUsingObject(self.myTerminal);
		endTSSystem := endTS;	//13 Feb 2017	NDL	TFS 3425
	endif;
	workPoint := self.cmbWorkPoint.listObject.CM_WorkPoint;
	if workPoint &lt;&gt; null then
		workPointId := workPoint.code;
	endif;
	
	// do we have a shift from the combo? Or are we creating one from scratch?
	shiftCode := jobId;
	shiftDesc := self.myCurrentVoyage.code &amp; Space &amp; jobId;
	shift := self.cmbShifts.listObject.CM_Shift;
	if shift &lt;&gt; null then
		realShift := self.myTerminal.allShiftsDay[shift.startDateTime, shift.code];
		if realShift &lt;&gt; null then
			shift := realShift;
		else
			shiftCode := shift.code;
			shiftDesc := shift.description;
		endif;
	else
		shift := _pxyJob.myShift;
		if shift = null then
		
			realShift := self.myTerminal.allShiftsDay[startTSSystem,shiftCode];
			if realShift  &lt;&gt; null then
				shift := realShift;
			else
				create shift transient;
			endif;
		endif;
	endif;
	
	// TFS 3561
	if not shift.isTransient then
		realShift := shift;
		if realShift &lt;&gt; null then
			shift := app.myProxyManager.getProxyObject(realShift).CM_Shift;
			if shift = null then
				shift := app.createUpdateProxy(realShift).CM_Shift;
			endif;
			shiftCode := realShift.code;
			shiftDesc := realShift.description;
		else
			shiftCode := shift.code;
			shiftDesc := shift.description;
		endif;
	endif;
	
	if shift &lt;&gt; _pxyJob.myShift then
		_pxyJob.setMyShift(shift);
	endif;
	
	
	shift.setProxy(null, startTSSystem.time, endTSSystem.time, shiftCode, shiftDesc, self.myTerminal, false);
	shift.startDateTime := startTSSystem;
	shift.endDateTime := endTSSystem;
	shift.setRemarks(self.txtShiftRemarks.text);
	
	remarks := self.txtJobRemarks.text.trimBlanks;
	_pxyJob.setProxy(jobId, jobType);
	_pxyJob.setProxyVoyage(self.myCurrentVoyage);
	//_pxyJob.setProxyVoyageHoldJob(null, jobId, remarks, null, false, jobType, null, null, startTSSystem, endTSSystem, false, shift, _allocatedTIs);			// TFS 3516
	_pxyJob.setProxyVoyageHoldJob(null, jobId, remarks, null, false, jobType, null, null, startTSSystem, endTSSystem, false, shift, dlrJob, _allocatedTIs,null,null);		// TFS 3516
	_pxyJob.setTransferType( self.getVoyJobTransferType() );
	_pxyJob.setIsDirectDelivery(self.chkDirectDelivery.value);		// TFS 52293
	_pxyJob.setOriginalJobAmount(jobTotal);											// TFS 52360
	
	if _jobParams &lt;&gt; null then
		_jobParams.myVoyage := _pxyJob.myVoyage;
		_jobParams.myProxyJob := _pxyJob;
		_jobParams.autoSortIntoOOW := false;
		_jobParams.craneID := null;
		_jobParams.myJobType := null;
		_jobParams.remarks := remarks;
		_jobParams.myWorkPoint := workPoint;
		_jobParams.craneID := workPointId;
		_jobParams.allowOutOfOrderLoading := false;
		if self.chkDLR.value then									// TFS 3489
			_jobParams.transitStatus := TI_TransitStatusDLR;		// TFS 3489
		elseif self.chkSOB.value then								// TFS 3489
			_jobParams.transitStatus := TI_TransitStatusSOB;		// TFS 3489
		else														// TFS 3489
			_jobParams.transitStatus := TI_TransitStatusNull;		// TFS 3489
		endif;														// TFS 3489
		_jobParams.isDischarge := jobType = JOB_TYPE_DISCHARGE;		// TFS 3489
		_jobParams.isDirectDelivery := self.chkDirectDelivery.value;	// TFS 52293
		_jobParams.originalJobAmount := jobTotal;									// TFS 52360
	endif;

	return true;
epilog
	
end;</source>
        <Parameter name="_pxyJob" type="CM_VoyageHoldJob" usage="input"/>
        <Parameter name="_jobParams" type="CMIF_VoyageJobParams" usage="input"/>
        <Parameter name="_allocatedTIs" type="CM_TISet" usage="io"/>
        <Parameter name="_allocatedWLEs" type="CM_WLEArray" usage="io"/>
        <Parameter name="_askForAmounts" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setTableDataFromOrganiser" id="ad60f612-fb20-438a-9f5b-25ddb6a500cd">
        <updating/>
        <source>setTableDataFromOrganiser(_theTable: CM_DataTable input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 17/01/2017	cnwdap1		Initial creation TFS 3127 LNX Voyage Operations Enhancements
// 02/03/2017	cnwdap1		TFS 3516 LNX Hold Planning Quantity
// 01/08/25018	jlgdap1		TFS 39964 PEL1 Hold Job Ops Loading Changes
// 23/10/2109	jlgzm1		TFS 47085 Direct Release Ship to Ship
//
vars
	sheet : CMUI_Sheet;
	job : CM_VoyageHoldJob;

begin
	if _theTable = self.tblAllocatedGang then
		sheet := self.fldData.topSheet.CMUI_Sheet;
		job := sheet.userObject.CM_VoyageHoldJob;
		//self.loadVoyageJobTable(job, _theTable);			// TFS 3516
		self.loadVoyageJobTable(job, _theTable, null);		// TFS 3516
		
	elseif _theTable = self.tblOnShip then
		self.loadOnShipTable();
	elseif _theTable = self.tblOnSite then
		self.loadOnSiteTable();
	elseif _theTable = self.tblPreNote then			// TFS 39964
		self.loadPreNoteTable();					// TFS 39964
	elseif _theTable = self.tblTranship then		// TFS 47085
		self.loadTranshipTable();					// TFS 47085
	else
		sheet := self.fldData.topSheet.CMUI_Sheet;
		job := sheet.userObject.CM_VoyageHoldJob;
		//self.loadVoyageJobTable(job, _theTable);			// TFS 3516
		self.loadVoyageJobTable(job, _theTable, null);		// TFS 3516
		
		//09 May 2018	NDL	TFS 38460
		if job &lt;&gt; null then
			if job.isDischarge then
				self.xmlDischargeTableStr := _theTable.getXmlStrForColumns(true);
				self.xmlDischargeTableStr.cnReplaceString( _theTable.name, self.tblAllocatedGang.name &amp; "DISCHARGE");
			else
				self.xmlLoadTableStr := _theTable.getXmlStrForColumns(true);
				self.xmlLoadTableStr.cnReplaceString( _theTable.name, self.tblAllocatedGang.name &amp; "LOAD");
			endif;
		endif;
		
	endif;

epilog

end;</source>
        <Parameter name="_theTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setTableHeadings" id="16975480-ef22-46a8-bf8c-61edbfee5820">
        <updating/>
        <source>setTableHeadings(_table : CM_DataTable input)updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/01/2017	cnwdap1		Initial creation TFS 3219 LNX Voyage Operations Enhancements
//
vars
	def : EntTableDef;
	tmpTblXML : String;	
	userWindow : CM_UserWindow;
	startPos : Integer;
	user : CM_User;
	
begin
	if _table = null then
		return;
	endif;
	
	def := app.myController.getEntTableDef(ETDef_LlHeadings);
	_table.setTblDataEntRowsFromDef(def);
	if _table.index &lt;&gt; null then
		// this is a cloned table - get the cloned table settings from the user window XML
		user := app.getMyUser();
		userWindow := app.getUserWindow(self.name, false);
		if userWindow = null then
			return;
		endif;
		
		startPos := 1;
		tmpTblXML := userWindow.xmlInfo.cnEcGetNextTagValueOfName(self.XMLTag_Job_Table &amp; _table.parent.CMUI_Sheet.caption, startPos);
		
		if tmpTblXML &lt;&gt; null then
			_table.setColumnsFromXMLStr(tmpTblXML);
		endif;	
	endif;
		
epilog

end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setTranshipVisibility" id="abd8cf38-f397-455a-89eb-c78bb53cd363">
        <source>setTranshipVisibility();
/*

Purpose:			Determines if the tranship table/sheet should be visible, and then
					sets its visibility accordingly

Parameters:			

Return Value:		

Date				Who		Reason
18 October 2019		jlgzm1	Initial creation TFS 47085 Direct Release Ship to Ship

*/

vars

begin
	if self.tblTranship.hasNoData then
		self.tblTranship.visible := false;
		self.shtTranship.visible := false;
	else
		self.tblTranship.visible := true;
		self.shtTranship.visible := true;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="33a2ab3e-c1ad-4557-bc5a-6787b59e55f2">
        <updating/>
        <source>setupForm() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 09/01/2017	cnwdap1		Initial creation LNX 3219 Voyage Operations Enhancements
// 14/03/2017	cnwdap1		TFS 3516 LNX Hold Planning Quantity
// 01/08/2018	jlgdap1		TFS 39964 PEl1 Hold Job Ops Loading Changes
// 23/10/2019	jlgzm1		TFS 47085 Direct Release Ship to Ship
// 15/10/2021	navdap1		TFS 52293 SAL Direct Loading Partial Prenoted Cargo from Truck to Vessel
//
vars

begin
	// The user can access the summarise functionality only if they have at least view security role.
	self.allowSummaryDefn := app.myCurrentUserCan( self.myTerminal, PmSummaryDefView );
	
	self.baseCaption := self.caption;
	inheritMethod();
	
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;	
	self.showToolbar := true;
	
	self.initTable(self.tblOnShip);
	self.initTable(self.tblOnSite);
	self.initTable(self.tblPreNote);					// TFS 39964
	self.initTable(self.tblTranship);					// TFS 47085
	self.initTable(self.tblAllocatedGang);
	self.initailiseXMLstrs(); //09 May 2018	NDL	TFS 38460
	
	self.shtAllocatedGang.visible := false;
	
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnNewTV.enabled := false;
		self.btnEditTV.enabled := false;
		self.btnDeleteTV.enabled := false;
	endif;
	self.btnSaveBase.enabled := false;
	self.btnTranship.enabled := false;	//14 Mar 201	NDL	TFS 3727
	self.mode := self.Mode_View;
	self.setControlsForView;
	self.setButtonStates(null);
	
	self.minimumWidth := 935;
	self.minimumHeight := 510;
	self.resize;
	self.cmbVoyage.setFocus;
	
	self.fldData.useSheetBackColors := true;
	self.fldData.setDefaultSheetBackColors();
	self.fldData.initSheetBackColors(); 
	
	self.lblDLRDisch.visible := false;					// TFS 3516
	self.cmbDLRDisch.visible := false;					// TFS 3516
	
	self.btnCreateJob.visible := false;	//12 Mar 2018	NLD	TFS 37444
	self.btnRemoveJob.visible := false;	//12 Mar 2018	NLD	TFS 37444
	self.buildTransferTypeCombo();		//12 Mar 2018	NLD	TFS 37444
	
	if not self.myTerminal.getConfig(DirectTruck2VesselMult).Boolean then	// TFS 52293
		self.chkDirectDelivery.visible := false;							// TFS 52293
	endif;																	// TFS 52293
	if self.fldData.topSheet &lt;&gt; self.shtAllocatedGang then					// TFS 52293
		self.chkDirectDelivery.visible := false;							// TFS 52293
	endif;																	// TFS 52293
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showColumnOrganiser" id="fda62d6d-bbb8-47af-81f3-322216a3c2e0">
        <updating/>
        <source>showColumnOrganiser(_dataTable : CM_DataTable input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 17/01/2017	cnwdap1		Initial creation TFS 3127 LNX Voyage Operations Enhancements
//
vars

begin
