    <JadeMethod name="getLinkedJob" id="83ec5f65-3df8-4dc1-bcc9-11d185522ed9">
        <source>getLinkedJob():CM_Job;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 Jun 2024 ChangeRequest 64770: EUP | 54014 - Cargo Work Orders Enhancements - Remedial - 1

*/

vars
	wod		: CM_WorkOrderDtl;
	job		: CM_Job;
	wle		: CM_WorkListEntry;
	jobSet	: CM_JobSet;
begin
	if not app.myPassport.isVASEnabled then
		return null;
	endif;
	
	foreach wod in self.allWoDtls discreteLock do
		if not wod.isKindOf(CM_WorkOrderTIDtl) then 
			continue;
		endif;
		
		if wod.CM_WorkOrderTIDtl.getTransport() = TI_TRANSMODE_SHIP then
			continue;
		endif;
		
		jobSet := wod.CM_WorkOrderTIDtl.allJobs;
		
		if jobSet &lt;&gt; null and jobSet.isNotEmpty then
			foreach job in jobSet do
				wle := job.workListEntries.first;
				if wle &lt;&gt; null then
					return wle.getLinkedJob();
				endif;
			endforeach;
		else
			return null;
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_Job"/>
    </JadeMethod>
