    <JadeMethod name="getTAClassToCreate" id="e745238f-454a-4ade-85e7-4fbe3d19bb8f">
        <source>getTAClassToCreate() : Class;
/*
----------   ----------  --------------------------------------------------
Created:	27 July 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
24/06/2009	concms1		ccms 1061 - added road inetrchange area
26/06/2009	concms1		ccms 1061 - added gate area1
17/08/2009	cnwer1		ccms 1076 - added RMG, RTG interchange, RMG Interchange,RTG lanes, RMG lanes
25/02/2010 	cnwcs5 		remove VTA references
15 Jul 2013  cnwer1		removed trailer area references - while here removed old general cargo area references
03/06/2020	jlgdap1		TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
08/09/2022	jlika1		TFS 54699 - CUX - MAFI Handling Enhancements - MAFI Heap Terminal Area
*/
vars
	terminalAreaType		: Integer;
begin
	terminalAreaType := self.type;
	
	if terminalAreaType = TA_TYPE_STRADDLE_STACK then
		return CM_StraddleStack;
	elseif self.isGantryAreaType then
		return CM_RTGArea;
	elseif self.isGantryLaneAreaType then
		return CM_RTGLane;
	elseif self.isGantryInterchangeArea then
		return CM_GantryInterchangeArea;
	elseif terminalAreaType = TA_TYPE_LOGAREA then
		return CM_LogArea;
	elseif terminalAreaType = TA_TYPE_FORK_LIFT_STACK then
		return CM_ForkLiftStack;
	elseif terminalAreaType = TA_TYPE_RTG then
		return CM_RTGArea;
	elseif terminalAreaType = TA_TYPE_RAILWAY_TRACK then
		return CM_Rail;
	elseif terminalAreaType = TA_TYPE_SUBBLOCK_STACK then
		return CM_SubBlockStack;
	elseif terminalAreaType = TA_TYPE_SWAP then
		return CM_SwapStack;
	elseif terminalAreaType = TA_TYPE_DEPOT_LCL then
		return CM_Depot;
	elseif terminalAreaType = TA_TYPE_BUILDING then
		return CM_Building;
	elseif terminalAreaType = TA_TYPE_CRANE_TRANS then
		return CM_CraneTransferArea;
	elseif terminalAreaType = TA_TYPE_INTERTERM_TRANS_AREA then
		return CM_InterTerminalTransferArea;
	elseif terminalAreaType = TA_TYPE_RAIL_TRANS then
		return CM_YardTransferArea;
//	elseif terminalAreaType = TA_TYPE_ROAD_TRANS then	25/02/2010 cnwcs5 remove VTA references
//		return CM_VehicleTransferArea;					25/02/2010 cnwcs5 remove VTA references
	elseif terminalAreaType = TA_TYPE_BULK then	// R Barr 2/11/2006 Comalco
		return CM_BulkArea;
	elseif terminalAreaType = TA_TYPE_IRREGULAR_BLOCK_AREA then
		return CM_IrregularBlockArea;
	elseif terminalAreaType = TA_TYPE_YARD_INTERCHANGE then	// ccms 1061 - concms1 24/06/2009
		return CM_YardInterchangeArea;							// ccms 1061 - concms1 24/06/2009
	elseif terminalAreaType = TA_TYPE_GATE_ROAD then		// ccms 1061 - concms1 26/06/2009
		return CM_GateArea;									// ccms 1061 - concms1 26/06/2009
	elseif terminalAreaType = TA_TYPE_RORO_LANE_AREA then	// ccms 1018 - cnwjk3 17/11/2009
		return CM_RoRoLaneArea;									// ccms 1018 - cnwjk3 17/11/2009	
	elseif terminalAreaType = TA_TYPE_WORKPOINT_INTERCHANGE then //ccms 1033 epr 9/8/11
		return CM_WorkPointInterchangeArea;
	elseif  terminalAreaType = TA_TYPE_BLOCK_STACK
		or terminalAreaType = TA_TYPE_REPAIR
		or terminalAreaType = TA_TYPE_PTI
		or terminalAreaType = TA_TYPE_COU_STORE_AREA
		or terminalAreaType = TA_TYPE_GENERATOR_STORE_AREA
		or terminalAreaType = TA_TYPE_WASH_AREA
		or terminalAreaType = TA_TYPE_FUMIGATION_AREA
		or terminalAreaType = TA_TYPE_CONT_PACK_REPACK
		or terminalAreaType = TA_TYPE_COU_CRIB_PACK_UNPACK
		or terminalAreaType = TA_TYPE_DELETE
		or terminalAreaType = TA_TYPE_HIDE
		or terminalAreaType = TA_TYPE_GATE_ROAD
		or terminalAreaType = TA_TYPE_RELTRANS		//NFS 3833 AA 5/0/01
		or terminalAreaType = TA_TYPE_RECTRANS
		or terminalAreaType = TA_TYPE_DAIRY	
		or terminalAreaType = TA_TYPE_MAFI	
		then
		return CM_BlockStack;
		
	elseif terminalAreaType = TA_TYPE_GEN_CARGO_ALLOC_ROW then		// TFS 49453
		return CM_GeneralCargoAllocRowArea;							// TFS 49453

	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Unhandled type (' &amp; self.type.String &amp; '"');
	endif;
		
	
	

end;</source>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="getTADefaultsForAttribute" id="fa281a84-5e7c-43dd-824e-562e48e7bff9">
        <source>getTADefaultsForAttribute(_attrName : String ) : Any;
/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
04 August 2009	cnwer1	Initial creation
25/02/2010 		cnwcs5 	remove VTA references
15/07/2013  	cnwer1	removed trailer area references 
08/09/2022		jlika1	TFS 54699 - CUX - MAFI Handling Enhancements - MAFI Heap Terminal Area
*/

vars

begin

	if _attrName = ETRow_Type then
		return self.description;
	endif;
	if self.type = TA_TYPE_STRADDLE_STACK then
		if _attrName = ETRow_Rows then
			return 5;
		elseif _attrName = ETRow_Cols then
			return 5;
		elseif _attrName = ETRow_Height then
			return 2;
		endif;
	elseif self.isGantryAreaType  then
		if _attrName = ETRow_Height then
			return 4;
		elseif _attrName = ETRow_Use40ftIds then
			return true;
		elseif _attrName = ETRow_DecColNums then
			return false;
		elseif _attrName = ETRow_DecRowNums then	
			return false;
		elseif _attrName = ETRow_ColStartNum then
			return 1;
		elseif _attrName = ETRow_RowStartNum then
			return 1;
		elseif _attrName =	ETRow_AutoRestrictionsEnabled then
			return false;
		elseif _attrName = ETRow_SideInterchangePos then
			return CM_RTGArea.ICPosition_BeforeRow1.toGantryInterchangePosString;
		endif;
	elseif self.type = TA_TYPE_LOGAREA then
		if _attrName = ETRow_Width then
			return 2;
		elseif _attrName = ETRow_Width then
			return  false;
		endif;
	elseif self.type = TA_TYPE_FORK_LIFT_STACK then
		if _attrName = ETRow_Rows then
			return 10;
		elseif _attrName = ETRow_Cols then
			return 10;
		elseif _attrName = ETRow_Height then
			return 6;
		elseif _attrName = ETRow_UseSideAccessRules then	// PAR 21532 CCMS SFW 1025
			return true;
		endif;
	elseif self.type = TA_TYPE_RAILWAY_TRACK then
		if _attrName = ETRow_NumberOfRailLines then
			return 4;
		elseif _attrName = ETRow_NumberOfWagonPositions then
			return 10;
		endif;
	elseif self.type = TA_TYPE_BUILDING then
		if _attrName = ETRow_Rows then
			return 5;
		elseif _attrName = ETRow_Cols then
			return 5;
		endif;
	elseif self.type = TA_TYPE_CRANE_TRANS then
		if _attrName = ETRow_NumLanes then
			return 4;
		endif;
	elseif self.type = TA_TYPE_RAIL_TRANS then
		if _attrName = ETRow_ActAsReleasePoint then
			return true;
		endif;
//	elseif self.type = TA_TYPE_ROAD_TRANS then			25/02/2010 cnwcs5 remove VTA references
//		if _attrName = ETRow_ActAsReleasePoint then		25/02/2010 cnwcs5 remove VTA references
//			return true;								25/02/2010 cnwcs5 remove VTA references
//		endif;											25/02/2010 cnwcs5 remove VTA references
	elseif self.type = TA_TYPE_IRREGULAR_BLOCK_AREA then
		if _attrName = ETRow_StockControlled then
			return true;
		elseif _attrName = ETRow_AutoRestrictionsEnabled then
			return true;
		endif;
	elseif self.type = TA_TYPE_YARD_INTERCHANGE then
		if _attrName = ETRow_IsBufferZone then
			return false;
		endif;
	elseif self.type = TA_TYPE_WORKPOINT_INTERCHANGE then
		if _attrName =  ETRow_IsBufferZone then
			return false;
		endif;
	elseif  self.type = TA_TYPE_BLOCK_STACK
		or self.type = TA_TYPE_REPAIR
		or self.type = TA_TYPE_PTI
		or self.type = TA_TYPE_COU_STORE_AREA
		or self.type = TA_TYPE_GENERATOR_STORE_AREA
		or self.type = TA_TYPE_WASH_AREA
		or self.type = TA_TYPE_FUMIGATION_AREA
		or self.type = TA_TYPE_CONT_PACK_REPACK
		or self.type = TA_TYPE_COU_CRIB_PACK_UNPACK
		or self.type = TA_TYPE_DELETE
		or self.type = TA_TYPE_HIDE
		or self.type = TA_TYPE_GATE_ROAD
		or self.type = TA_TYPE_RELTRANS		//NFS 3833 AA 5/0/01
		or self.type = TA_TYPE_RECTRANS
		or self.type = TA_TYPE_DAIRY	
		or self.type = TA_TYPE_MAFI
		then

		if _attrName = ETRow_MaxCapacity then
			return 999;
		
		//elseif _attrName = ETRow_TestAllInBlockStack then adm 170909 Par 20303
		//	return true;
		endif;
	else
		return null;
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="getTADefintionViewName" id="3021d36d-63be-40bf-b8a4-48de229103b5">
        <source>getTADefintionViewName(): String;
/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
04 August 2009	cnwer1	Initial creation
25/02/2010      cnwcs5  remove VTA references
15 Jul 2013  	cnwer1	removed trailer area references 
03/06/2020		jlgdap1	TFS 49453 ASPA Satellite View Screen For Flexible Terminal Areas
08/09/2022		jlika1	TFS 54699 - CUX - MAFI Handling Enhancements - MAFI Heap Terminal Area
*/

vars

begin

//	if self.type = TA_TYPE_ROAD_TRANS then	25/02/2010 cnwcs5 remove VTA references
//		return "ViewVTA";					25/02/2010 cnwcs5 remove VTA references
	if self.type = TA_TYPE_RAIL_TRANS then
		return  "ViewRoadRailTrans"; 
	elseif self.type = TA_TYPE_BUILDING then
		return "ViewBuilding";
	elseif self.type = TA_TYPE_BULK then
		return "ViewBulk";
	elseif  self.type = TA_TYPE_CRANE_TRANS then
		return "ViewCrane";
	elseif self.type = TA_TYPE_DEPOT_LCL then
		return "ViewDepot";
	elseif  self.type = TA_TYPE_BLOCK_STACK
        or self.type = TA_TYPE_REPAIR
        or self.type = TA_TYPE_PTI
        or self.type = TA_TYPE_COU_STORE_AREA
        or self.type = TA_TYPE_GENERATOR_STORE_AREA
        or self.type = TA_TYPE_WASH_AREA
        or self.type = TA_TYPE_FUMIGATION_AREA
        or self.type = TA_TYPE_CONT_PACK_REPACK
        or self.type = TA_TYPE_COU_CRIB_PACK_UNPACK
        or self.type = TA_TYPE_DELETE
        or self.type = TA_TYPE_HIDE
        or self.type = TA_TYPE_RELTRANS         //NFS 3833 AA 5/0/01
        or self.type = TA_TYPE_RECTRANS
        or self.type = TA_TYPE_DAIRY    
		or self.type = TA_TYPE_MAFI
		then
		return "ViewBlock";
	elseif self.type = TA_TYPE_FORK_LIFT_STACK then
        return 'ViewFork';
	 elseif self.type = TA_TYPE_STRADDLE_STACK then
        return 'ViewStraddle';
	elseif self.type = TA_TYPE_LOGAREA then
        return 'ViewLog';
    elseif self.type = TA_TYPE_IRREGULAR_BLOCK_AREA then
        return 'ViewIrregularBlockArea';
    elseif self.type = TA_TYPE_RAILWAY_TRACK then
        return 'ViewRail';	
	elseif self.type = TA_TYPE_INTERTERM_TRANS_AREA then
        return "ViewTermTransfer";
	elseif self.isGantryAreaType then                           
        return "ViewRTG";
	elseif self.isGantryLaneAreaType then
		return "ViewRTGLane";
	elseif self.isGantryInterchangeArea then
		return "ViewGantryIC";
	elseif self.type = TA_TYPE_YARD_INTERCHANGE then
		return "ViewYardInterchange";
	elseif self.type = TA_TYPE_RORO_LANE_AREA then	// ccms 1018 cnwjk3 17/11/09 
		return "ViewRoRoLaneArea";					// ccms 1018 cnwjk3 17/11/09
	elseif self.type = TA_TYPE_WORKPOINT_INTERCHANGE then
		return "ViewWorkPointInterchange";
	elseif self.type = TA_TYPE_GEN_CARGO_ALLOC_ROW then		// TFS 49453
		return "ViewGeneralCargoAllocRow";					// TFS 49453
	else
		return "ViewMain";
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
