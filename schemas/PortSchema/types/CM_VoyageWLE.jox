    <JadeMethod name="isOverstowedForEntry" id="a440d98a-ad9e-4973-8450-1566de40b3d7">
        <source>isOverstowedForEntry(): Boolean protected;
//--------------------------------------------------
// Created:	15 April 2004 By: cnwgd1
//--------------------------------------------------
vars

	tiArray				: CM_TIArray;
	sideAccessDirection : Integer;

begin
	if self.isReceipt then
		return false;
	endif;
	
	if self.status = WLE_COMPLETED then
		return false;
	endif;
	
	if self.job &lt;&gt; null then
		if self.job.status = JOB_COMPLETE then
			return false;
		endif;
	endif;
	
	if self.myTrackedItem &lt;&gt; null then
		return self.myTrackedItem.isOverStowedVoyageJob();
	endif;

	return false;
	
epilog
		delete tiArray;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
