    <JadeMethod name="doQueryStevedore" id="66abdd05-61a6-43b8-aa1c-692d09cff64a">
        <source>doQueryStevedore();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 31/05/2019	jlgdap1		Initial creation TFS 44554 AAT Stevedore Data Access
//
vars
	steve : CM_Stevedore;
	invoiceLineDesc : CM_InvoiceLineDesc;
	aMap : CM_InvoiceLineChargeMapping;
	row :Integer;
	column :Integer;
	count :Integer;
	pd :CMS_Progress;
	ls : Boolean;
	mapTable : Table;
	bank : CM_Bank;
	dict : CM_StevedoreByCodeDict;
	
begin
	bank := self.myCurrentBank;
	mapTable := self.tblData;

	self.setNavigatorHeading(self.caption);
	
	on CM_ProgressException do haltProgress(exception, ls);

	mapTable.accessCell(1,1).text := "Invoice Line Types/ Stevedores";

	create pd;
