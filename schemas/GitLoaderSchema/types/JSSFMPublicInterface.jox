// --------------------------------------------------------------------------------
// Created:		10 July 2002 by cnwdad1
//
// Purpose:		Copies the requested directory into the specified path.  Note that
//				all of the directory's child nodes will also be copied.
//
//				*********************************************************************
//				* You must call the setUnixFlags method before calling this method. *
//				*********************************************************************
//
// Parameters:	pSourcePath - The pathname of the source directory to be copied.
//				pTargetPath - The pathname of the directory's destination.
//				pNodeOptions - This parameter is not used, but is reserved for
//					future use.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.myServiceObject.sendMsgWithParams(method.name, pSourcePath, pTargetPath, pNodeOptions);
end;</source>
        <Parameter name="pSourcePath" type="String"/>
        <Parameter name="pTargetPath" type="String"/>
        <Parameter name="pNodeOptions" type="Integer"/>
    </JadeMethod>
