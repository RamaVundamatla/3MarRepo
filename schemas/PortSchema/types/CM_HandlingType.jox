    <JadeMethod name="getDefaultSubHandlingType" id="afb7ef23-3022-4ec6-9c65-c9b10a86085e">
        <source>getDefaultSubHandlingType():CM_HandlingSubType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 April 2017	cnwndl1	Initial creation	TFS 3424

*/

vars

begin

	return app.myRoot.getDefaultHandlingSubType( self );

epilog

end;</source>
        <ReturnType type="CM_HandlingSubType"/>
    </JadeMethod>
    <JadeMethod name="getHandlingSubType" id="9acbaac2-e73e-4157-9b1d-0409aa1f0369">
        <source>getHandlingSubType( _str : String ):CM_HandlingSubType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 April 2017	cnwndl1	Initial creation

*/

vars

	iter : Iterator;
	subType : CM_HandlingSubType;

begin

	iter := self.allHandlingSubTypes.createIterator;
	while iter.next( subType ) do
		if subType.code = _str.toUpper then
			return subType;
		endif;
	endwhile;
	delete iter;
	
	iter := self.allHandlingSubTypes.createIterator;
	while iter.next( subType ) do
		if subType.description = _str then
			return subType;
		endif;
	endwhile;
	delete iter;
	
	return null;

epilog

	delete iter;

end;</source>
        <Parameter name="_str" type="String"/>
        <ReturnType type="CM_HandlingSubType"/>
    </JadeMethod>
    <JadeMethod name="getHandlingTypeDisplay" id="eab59bb7-6559-4d9d-9f24-e5f909cf0c0d">
        <source>getHandlingTypeDisplay():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 April 2017	cnwndl1	Initial creation	TFS 3414

*/

vars

	str : String;

begin

	if self.description.trimBlanks &lt;&gt; null then
		str := self.description;
	else
		str := self.id.String;
	endif;
	
	return str;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getValidSubTypes" id="b0a27fb0-a3a3-474a-aebc-74a6e406d461">
        <source>getValidSubTypes( _allSubTypes : CM_HandlingSubByTypeCode input; _includeNotAvail : Boolean );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 March 2017	cnwndl1	Initial creation	TFS 3414

*/

vars

	iter :Iterator;
	startObject : CM_HandlingSubType;
	handlingSubType : CM_HandlingSubType;

begin

	_allSubTypes.clear();

	startObject := app.myRoot.allHandlingSubTypes.getAtKeyGeq( self, null ).CM_HandlingSubType; 
	if startObject &lt;&gt; null then
		iter := app.myRoot.allHandlingSubTypes.createIterator;
		iter.startAtObject( startObject );
		while iter.next( handlingSubType ) do
			if handlingSubType.getMyHandlingType &lt;&gt; self then
				break;
			endif;
			if not _includeNotAvail then
				if handlingSubType.isNotAvailableForEntry then
					continue;
				endif;
			endif;
			_allSubTypes.add( handlingSubType );
		endwhile;
	endif;

epilog

	delete iter;

end;</source>
        <Parameter name="_allSubTypes" type="CM_HandlingSubByTypeCode" usage="input"/>
        <Parameter name="_includeNotAvail" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasSubTypes" id="1b5ecf93-569d-4c56-8038-48eacbc6363b">
        <source>hasSubTypes():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 March 2017	cnwndl1	Initial creation	TFS 3414

*/

vars
	
	allSubTypes : CM_HandlingSubByTypeCode;

begin

	create allSubTypes transient;
	self.getValidSubTypes( allSubTypes, false );
	
	return not allSubTypes.isEmpty;

epilog

	delete allSubTypes;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initializeForActivity" id="739199f4-0947-4d65-b8a6-59b6e9ddc342">
        <updating/>
        <source>initializeForActivity(_ewsOpsView: CM_EWSActivityOpsview; _opsViewTable : CMIF_OpsViewTables) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 Jun 2022	navsp1	Initial creation TFS#53104

*/

vars
	opsviewtable : CMIF_AuxCrgPackageType;
begin
	if _opsViewTable.isKindOf(CMIF_AuxCrgPackageType) then
		opsviewtable				:= _opsViewTable.CMIF_AuxCrgPackageType;
		opsviewtable.tableName		:= opsviewtable.Aux_crg_package_type;
		opsviewtable.gkey       	:= opsviewtable.generateFullGKey(self,"");
		opsviewtable.client_id 		:= opsviewtable.generateCpxGKey().String;
		opsviewtable.id 			:= self.id.String;
		opsviewtable.ucc_code		:= null;
		opsviewtable.description 	:= self.description;
	endif;
epilog

end;</source>
        <Parameter name="_ewsOpsView" type="CM_EWSActivityOpsview"/>
        <Parameter name="_opsViewTable" type="CMIF_OpsViewTables"/>
    </JadeMethod>
