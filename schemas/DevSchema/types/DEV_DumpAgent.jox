    <JadeMethod name="checkFolderExists" id="3d9201b2-ab68-429f-8c20-a96b8293a370">
        <updating/>
        <source>checkFolderExists(_path : String) : Boolean updating;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 18 January 2007
//
// Check to see if a fileFolder exists before creating one. 
// This can be used to see if we need to create a new folder or not. 
//  
// _path : The file name of folder (eg C:\JMTerminal\DumpFiles)
//----------------------------------------------------------------------

vars
	fileFolder : FileFolder;
begin
	if _path = null then
		return false;
	endif;
	
	create fileFolder transient;
	fileFolder.fileName := _path;
	
	if not fileFolder.isAvailable() then
		return false;
	endif;
	
	return true;
	
epilog
	delete fileFolder;
end;</source>
        <Parameter name="_path" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cleanupFiles" id="bb683ade-f130-4292-9fa5-cf260195aa9d">
        <updating/>
        <source>cleanupFiles() updating;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 04 April 2007
//
//----------------------------------------------------------------------

vars
	file : FileNode;
	fileArray : FileNodeArray;
begin
	//No Longer need this so release the files 
	delete self.allFilesToProcess;
	
	foreach file in self.allFilesToDelete do
		fileArray.add(file);
	endforeach;
	
	delete self.allFilesToDelete;
	
	foreach file in fileArray do
		file.purge;
	endforeach;
	
	
epilog

end;</source>
    </JadeMethod>
