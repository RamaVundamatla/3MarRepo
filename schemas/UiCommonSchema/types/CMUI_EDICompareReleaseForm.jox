    <JadeMethod name="showChanges" id="feb69204-b563-4f13-a5ca-30e7e9afb4a6">
        <source>showChanges(_table :CM_DataTable input; _ediTI :CM_EDIReleaseRequestTI; _detail	:CM_ReserveDetail) protected;
/*
Date		Who		Reason
02 August 2013	cnwcs5	CCMS POL 2221 / par 32094
// 05 Dec 2017	jlgrs1	TFS 8195 - SNO - EDI Release Comparison add support for ReleaseRequestMulti
*/

vars
	ediRow, dbRow, col	:Integer;
	etRow				:EntTableRow;
	release				:CM_BulkRelease;
	doHighlight			:Boolean;
begin
		
	// find out where in the table our edi and db data is displayed
	if _ediTI &lt;&gt; null then
		_table.findObjectInRow (_ediTI, ediRow);
	endif;
	
	if _detail &lt;&gt; null then
		_table.findObjectInRow (_detail, dbRow);
	endif;
	
	if ediRow = null and dbRow = null then
		return;
	endif;
	
	if dbRow = null then
		// new EDI reserve -  put a "A" in the "*" column
		_table.accessCell (ediRow, 1).text 		:= CM_EDITrackedItem.EDI_ACTION_ADD;
		
		self.highlightJadeTableElement (_table.accessedCell);
		self.highlightJadeTableElement (_table.accessCell (ediRow, 2));
		
		// it could be we are changing to/from release by type 
		release := self.myTerminal.getBulkReleaseFromCode(_ediTI.releaseRequestNumber);
		
		if release &lt;&gt; null and release.releaseByType &lt;&gt; _ediTI.releaseByType then
			// find release by type column and highlight it
			etRow := _table.getEntRowColumnByRowName (ETRow_ReleaseByType, col);
			
			if etRow &lt;&gt; null then
				self.highlightJadeTableElement (_table.accessCell (ediRow, col));
			endif;
		endif;

	elseif ediRow = null then
		// going to delete this reserve - put a "D" in the "*" column
		_table.accessCell (dbRow, 1).text 		:= CM_EDITrackedItem.EDI_ACTION_DELETE;
		
		self.highlightJadeTableElement (_table.accessedCell);
		self.highlightJadeTableElement (_table.accessCell (dbRow, 2));
	else
		release := _detail.myReserveHeader;
		//epr TFS 2606 refactored into method 
		doHighlight:=self.showChangesEDITrackedItem(_table,_ediTI,_detail);
		
		if doHighlight then
			// *
			self.highlightJadeTableElement (_table.accessCell (ediRow, 1));
			// EDI
			self.highlightJadeTableElement (_table.accessCell (ediRow, 2));
			// *
			self.highlightJadeTableElement (_table.accessCell (dbRow, 1));
			// Db
			self.highlightJadeTableElement (_table.accessCell (dbRow, 2));
		endif;
	endif;
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_ediTI" type="CM_EDIReleaseRequestTI"/>
        <Parameter name="_detail" type="CM_ReserveDetail"/>
    </JadeMethod>
    <JadeMethod name="tblData_rowColumnChg" id="71934680-5d28-4c07-82b9-6d7fd0307b6e">
        <controlMethod name="CM_DataTable::rowColumnChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_rowColumnChg(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Aug 2017 cnwma1	TFs #4596 POL - Cannot ignore fields during EDI Release Request Update

*/

vars
	theRow, theCol : Integer;
	reserveSelection : CM_ReserveSelection;
	dBcell,ediCell : JadeTableCell;
	row : JadeTableRow;
	attr : String;
	
begin
	theRow := table.row;
	theCol := table.column;
	if theRow &gt; table.fixedRows then	
		if table.accessRow (theRow).itemObject.isKindOf(CM_ReserveSelection) then
			
			reserveSelection :=table.accessRow (theRow).itemObject.CM_ReserveSelection;
			table.accessCell(theRow,theCol).selected := true;
			
			dBcell := table.accessCell(theRow,theCol);
			ediCell := table.accessCell(theRow-1,theCol);

			self.mnuUpdateAttribute.visible := false;
			if theCol &gt; 2 and theRow &gt;1  then
				attr := table.CM_DataTable.allTblDataColHeadings[theCol-2];
				if reserveSelection &lt;&gt; null    then
					self.mnuUpdateAttribute.visible := true;
					self.mnuUpdateAttribute.caption := null;
					self.mnuUpdateAttribute.caption := "Update : " &amp; attr &amp; " " &amp;  ediCell.text;
					self.myReserveSelection := reserveSelection;
					self.attributeName := attr;
					self.updateValue :=ediCell.text;
				endif;
			endif;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="d3db6667-024e-4763-9d48-514acda9b82b">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 24 August 2017 09:59:44.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0019189, locale);
	mnuColumnOrganisor.translateCaption(Xlat_0019190, locale);
	mnuIgnoreEDI.translateCaption(Xlat_0019191, locale);
	mnuLoadToDB.translateCaption(Xlat_0021347, locale);
	mnuPopup.translateCaption(Xlat_0019192, locale);
	mnuProcessEDI.translateCaption(Xlat_0019193, locale);
	mnuUpdateAttribute.translateCaption(Xlat_0022059, locale);
	mnuVerify.translateCaption(Xlat_0021348, locale);
	mnuViewRelease.translateCaption(Xlat_0019194, locale);
end;</source>
    </JadeMethod>
</GUIClass>
