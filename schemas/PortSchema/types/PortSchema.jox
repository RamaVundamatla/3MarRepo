    <JadeMethod name="isSubTerminalsOn" id="25a519d1-7d70-4830-808a-54bd84b08124">
        <source>isSubTerminalsOn(_terminalObj:CM_Terminal):Boolean;
// --------------------------------------------------------------------------------
// Created:		14 April 2009 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether Sub-Terminals is on.
//
// Parameters:	_terminalObj - A reference to the Terminal in question.
//
// Returns:		True if Sub-Terminals is on, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.isSubTerminalsLicensed then
		if _terminalObj &lt;&gt; null then
			return _terminalObj.isSubTerminalsOn();
		endif;
	endif;

	return false;
end;</source>
