    <JadeMethod name="findAndProcessCargo" id="04a9b949-a510-45aa-adbf-576f5dd82e05">
        <source>findAndProcessCargo(_ediFile		: CM_EDIFile;
					_cargoId 		: String;
					_cargoTypeId 	: Integer;
					_responseStatus : String;
					_voyageNo		: String;
					_voyage 		: CM_Voyage;
					_stopAction		: String;
					_stopCode		: String;
					_refValueToPassToStop : String;
					_customsAgent 	: CM_CustomsAgent;
					_bolId ,
					_cargoDesc,_sealNumOperator 		: String ;              // 16/01/2017 cnwma1 TFS #2885
					_ediNofificationType :Integer) : CM_TrackedItem protected;   // 16/01/2017 cnwma1 TFS #2885
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 December 2015	cnwmc5	Initial creation 	 PAR 37275
16 Jan 2017			cnwma1	TFS #2885:QNS - Additional Data Mapping in Customs Message
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
// 08 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
*/

vars
	ti 			: CM_TrackedItem;
	terminal	: CM_Terminal;
	
	ediDataCargoStopTi : CM_EDIStopTI;
begin
	terminal := app.myPassport.myTerminal;
	
	//find on site
	ti := terminal.allOnsiteTIsByIdCargoType[_cargoId, _cargoTypeId];
	
	if ti = null then
		if _responseStatus = Customs_Import_Cleared then
			if _voyage &lt;&gt; null and not _voyage.hasDeparted then
				//find on voyage
				ti := _voyage.allOnshipTIsByIdCargoType[_cargoId, _cargoTypeId];
			endif;
		elseif _responseStatus = Customs_Export_Cleared then
			//find pre notified
			ti := terminal.allNotifiedTIsByIdCargoType[_cargoId, _cargoTypeId];
		endif;
	endif;
	
	create ediDataCargoStopTi;
	ediDataCargoStopTi.setMyEDIData( _ediFile.ediData );
	ediDataCargoStopTi.setId(_cargoId);
	ediDataCargoStopTi.setVoyageCode( _voyageNo );
	ediDataCargoStopTi.setStopAction( _stopAction );
	ediDataCargoStopTi.setStopCode( _stopCode );
	ediDataCargoStopTi.setCargoType( _cargoTypeId );
	ediDataCargoStopTi.setDeliveryReleaseNumber( _refValueToPassToStop );
	ediDataCargoStopTi.setCustomsAgent( _customsAgent );
	ediDataCargoStopTi.setDescription( _cargoDesc );				// 16/01/2017 cnwma1 TFS #2885
	ediDataCargoStopTi.setTISealNumOperator( _sealNumOperator );      // 16/01/2017 cnwma1 TFS #2885
	ediDataCargoStopTi.setTINotificationType(_ediNofificationType); // 16/01/2017 cnwma1 TFS #2885
	
	if ti &lt;&gt; null then
		ediDataCargoStopTi.setTrackedItem( ti );
	endif;
	
	//cnwmc5 - 21 Dec 2015 - PAR 37275
	if _bolId &lt;&gt; null then
		ediDataCargoStopTi.setTIBillOfLading(_bolId);
	endif;
	
	//cnwmc5 - 11 Jan 2016 - PAR 37275
	if _customsAgent = null then
		ediDataCargoStopTi.setClearCustomsAgent(true);
	endif;
	
	if _cargoDesc &lt;&gt; null then
	
		ediDataCargoStopTi.setDescription(_cargoDesc);		//cnwma1 TFS #2885
	endif;
	return ti;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ediFile" type="CM_EDIFile"/>
        <Parameter name="_cargoId" type="String"/>
        <Parameter name="_cargoTypeId" type="Integer"/>
        <Parameter name="_responseStatus" type="String"/>
        <Parameter name="_voyageNo" type="String"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_stopAction" type="String"/>
        <Parameter name="_stopCode" type="String"/>
        <Parameter name="_refValueToPassToStop" type="String"/>
        <Parameter name="_customsAgent" type="CM_CustomsAgent"/>
        <Parameter name="_bolId" type="String"/>
        <Parameter name="_cargoDesc" type="String"/>
        <Parameter name="_sealNumOperator" type="String"/>
        <Parameter name="_ediNofificationType" type="Integer"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="findCustomsAgent" id="ac802f65-592b-437f-8fbf-83f05150031e">
        <source>findCustomsAgent( _str : String ):CM_CustomsAgent protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 June 2015	cnwndl1	Initial creation

*/

vars

	cusAgent : CM_CustomsAgent;
	pos : Integer;
	firstSubString : String;
	cusAgentCode : String;
	foundMatch : Boolean;

begin

	cusAgent := app.myRoot.allCustomsAgents.getAtKey( _str );
	
	if cusAgent = null then
		pos := _str.pos(" ",1);
		if pos &gt; 1 then
			firstSubString := _str[1:pos-1];
			cusAgent := app.myRoot.allCustomsAgents.getAtKey( firstSubString );
		endif;
	
		if cusAgent = null then
			cusAgentCode := app.myRoot.getXlationSystemCode(_str, XLATION_TYPE_CUSTOMSAGENT, foundMatch);
			if cusAgentCode &lt;&gt; null then
				cusAgent := app.myRoot.allCustomsAgents[cusAgentCode];
			endif;
			
			if cusAgent = null and firstSubString &lt;&gt; null then
				cusAgentCode := app.myRoot.getXlationSystemCode(_str, XLATION_TYPE_CUSTOMSAGENT, foundMatch);
				if cusAgentCode &lt;&gt; null then
					cusAgent := app.myRoot.allCustomsAgents[cusAgentCode];
				endif;
			endif;
		endif;
		
	endif;
	
	return cusAgent;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_str" type="String"/>
        <ReturnType type="CM_CustomsAgent"/>
    </JadeMethod>
    <JadeMethod name="findEDIDataType" id="a6c05e48-bf89-4504-b55d-ff32851253a9">
