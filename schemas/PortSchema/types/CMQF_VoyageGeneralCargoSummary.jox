        <type name="Boolean"/>
    </PrimAttribute>
    <JadeMethod name="filterObjects" id="82d77ae0-8603-4112-9031-acfa67c126fd">
        <updating/>
        <source>filterObjects(_collection: Collection input; _passport: CM_Passport) updating;
//--------------------------------------------------
// Created:	02 February 2006 By: cnwgd1
//--------------------------------------------------
/*

Date		Who		Reason
17 Feb 2015	cnwkpd1	PAR #35704 - Changes to prevent extended locking

*/

vars
	tmpBol				: CM_BOL;
	voy					: CM_Voyage;
	querySelf			: CMQF_VoyageGeneralCargoSummary;
	breakOut			: Boolean;
	tmpManifest			: CM_Manifest;
	tmpDict				: CM_ManifestByIdDict;
	ti					: CM_TrackedItem;	
begin

	querySelf := self;
	
	voy := querySelf.getMyVoyage;
	
	if voy = null then
		return;
	endif;
	
	if self.queryCargo then
		// They want the matching cargo
		foreach ti in voy.allOnshipTIsByIdCargoType discreteLock do
			if querySelf.checkStatusIncludesObject(ti, _passport, breakOut) then
				querySelf.allTrackedItems.add(ti);
			endif;
		endforeach;
		
		foreach ti in voy.allOnsiteTIsByIdCargoType discreteLock do
			if querySelf.checkStatusIncludesObject(ti, _passport, breakOut) then
				querySelf.allTrackedItems.add(ti);
			endif;
		endforeach;	
	endif;
	
	if self.queryBOLs then
		// They want the matching BOLs
				
		if voy.myGeneralCargoVoyage &lt;&gt; null then
			tmpDict := voy.myGeneralCargoVoyage.allManifestsById;
		endif;
		
		
		if tmpDict &lt;&gt; null and tmpDict.isNotEmpty() then
			foreach tmpManifest in tmpDict discreteLock do
				//check if filtering is required
				if self.allBOLTypes.isEmpty
				and self.allOperators.isEmpty
				and self.allPortsLoad.isEmpty			
				and self.allPortsDischarge.isEmpty then
					tmpManifest.allBOLsByTypeNumDT.copy(querySelf.allBOLs);
					continue;			
				endif;
				
				// filtering is required
				foreach tmpBol in tmpManifest.allBOLsByTypeNumDT discreteLock do	
					if querySelf.checkStatusIncludesObject(tmpBol, _passport, breakOut) then
						querySelf.allBOLs.add(tmpBol);
					endif;	
				endforeach;
			endforeach;

		else
			
			//check if filtering is required
			if self.allBOLTypes.isEmpty
			and self.allOperators.isEmpty
			and self.allPortsLoad.isEmpty			
			and self.allPortsDischarge.isEmpty then
				voy.allBOLInByTypeStatusNumDT.copy(querySelf.allBOLs);
				return;			
			endif;
	
			// filtering is required						
			foreach tmpBol in voy.allBOLInByTypeStatusNumDT discreteLock do
				if querySelf.checkStatusIncludesObject(tmpBol, _passport, breakOut) then
					querySelf.allBOLs.add(tmpBol);
				endif;	
			endforeach;
				
		endif;
	endif;
	
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="5a6c65ee-0a9b-4809-93f0-85638e912bfe">
        <updating/>
        <source>includesObject(_obj: CM_Object; _passport: CM_Passport; _breakOut: Boolean output): Boolean updating, protected;
//--------------------------------------------------
// Created:	02 February 2006 By: cnwgd1
//--------------------------------------------------
vars
	tmpBOL : CM_BOL;
	loadPort,
	disPort : CM_Port;
	failedDAC  :CM_DataAccessController;
begin
	
	if CM_TrackedItem.hasInstance(_obj) then
		return inheritMethod(_obj, _passport, _breakOut);
	
	elseif CM_BOL.hasInstance(_obj) then
	
		tmpBOL := _obj.CM_BOL;
		if (not tmpBOL.canUserAccessSelf(null, failedDAC, _passport)) then
			return false;
		endif;
		
		//disPort := app.myRoot.allPorts[tmpBOL.dischargePort];
		//loadPort := app.myRoot.allPorts[tmpBOL.loadPortCode]; 
		
		disPort := app.myRoot.allPorts[tmpBOL.dischargePort];
		loadPort := app.myRoot.allPorts[tmpBOL.loadPortCode]; 

		if (self.allBOLTypes.isEmpty or self.allBOLTypes.includesKey(tmpBOL.bolType)) 
		and	(self.allPortsDischarge.isEmpty or (disPort &lt;&gt; null and self.allPortsDischarge.includes(disPort))) 
		and	(self.allPortsLoad.isEmpty or (loadPort &lt;&gt; null and self.allPortsLoad.includes(loadPort))) 		
		and (self.allOperators.isEmpty or self.allOperators.includes(tmpBOL.myOperator)) then
			return true;
		endif;
	
	endif;
	
	return false;
	
end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
