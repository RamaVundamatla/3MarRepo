    <JadeMethod name="xStorageCheck" id="b40c4d59-9406-4c70-af53-deea142d8882">
        <source>xStorageCheck(_crane : CM_Machine io; _tas : StringArray; _bs : CM_BlockStack; _freeDays : Integer; _releaseDays : Integer) protected;
// cnwjre1
/*	No storage config, check the pre-config code with both no free storage days and some free storage days, release both before, on and after the free storage expiry.
	Method uStorageCheck drives this.  Parameter _freeDays is the number of free storage days for the cargo.  Parameter _releaseDays is the number of days after receipt to do the release.
*/
constants
	VoyageName = 'UTVOYROR2';
	ShipName = 'UTROR2';
	TestOperator = 'UTOP';
	CraneTransferAreaId	= "UTC1T2";
	IMV1 = "UTI2";
vars
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	queue: CM_VoyageQueue;
	rampQueue: CM_VoyageCraneQueue;
	cargo1,
	cargo2	: CM_TrackedItem;
	tas: StringArray;
	imv: CM_Machine;
	wle : CM_WorkListEntry;
	job : CM_VoyageJob;
	forkLift: CM_Machine;
	task: CM_RTQueueTask;
	tran			: CM_TITransaction;
	invLine			: CM_InvoiceLine;
	tranDate		: Date;
	tranTime		: Time;
	tranTS			: TimeStamp;
	vvr 			: CM_VehicleVisitRecord;
	singleGate		: CM_Gate;
	msg				: String;

begin

	tas := _tas;
	self.deleteVoyage(VoyageName);
	self.deleteVessel(ShipName);
	vessel := self.addVesselLOLOholdsRORO(ShipName, self.getOperator(TestOperator));
	voyage	:= self.addVoyageWithConRORO(VoyageName,
													ShipName,
													TestOperator, 
													self.getProfileSetting( UT_Profile.P_SHIPPING_LINE ).asString,
													null, 10, false, true);
	// these methods both delete first
	queue := self.addVoyageQueue(voyage);
	rampQueue := self.addVoyageCraneQueue(voyage, queue, _crane);
	
	// add one import general container on-ship
	cargo1 := self.addContainerAtLocnDisch("MRKU0910410", "2200", "GENL", TI_IMEX_STATUS_IMPORT, voyage.myShipBlockStack, app.myRoot.allPorts["NZPOE"], voyage);
	
	imv := self.addIMV(IMV1, 93, tas, rampQueue.id);
	forkLift := self.addForkLift("UTFL", 94, tas, rampQueue.id);
	
	// move box
	self.doQueueUnplannedUnworkedCargo(cargo1, job, wle );
	self.assertNotNullMsg(wle, "Failed to queue cargo 1");
	
	// Lander puts cargo on IMV
	app.myTrxUA.trxUpdateShipMoveImport(imv, cargo1, wle, job,null,null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.checkTIForTxnOfType(cargo1, TRANS_TYPE_REC_SHIP);
	self.checkTIForTxnOfType(cargo1, TRANS_TYPE_WHARFAGE);
	
	beginTransaction;
	cargo1.setPropertyValue("freeStorageDays", _freeDays);
	commitTransaction;
	
	// Forklift sets down into yard
	self.machineLogon(forkLift);
	task := self.machineTaskRequest(forkLift);
	self.machineAcceptTask(forkLift, wle.allRTQueueEntries.last.allTasks.first);
	self.machinePickup(forkLift);
	self.machineSetdown(forkLift, cargo1, _bs.id);
	self.machineLogOff(forkLift);
	
	// Make sure temp voyage job is deleted
	self.assertEqual(voyage.allVoyageJobs.size, 0);
	

	// back-date cargo1 transactions to &lt;n&gt; days ago
	if _releaseDays &gt; 0 then
		tranDate := tranDate - _releaseDays;
		tranTS.setDate(tranDate);
		foreach tran in cargo1.allTransactions do
			tranTime := tran.dateTime.time;
			tranTS.setDate(tranDate);
			tranTS.setTime(tranTime);
			
			beginTransaction;
			tran.setPropertyValue("dateTime", tranTS);
			commitTransaction;
		endforeach;
	endif;
	
	process.sleep(2000);		// make sure the release is a few seconds after the receive
	// do a road release
	// Remove all automatic stops
	self.deleteStops(cargo1);

	singleGate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	
	self.deleteVehicle("UTMAT");
	self.opts.addAssoc("deliveryNumber", "999");
	vvr := self.gateOutContainer("UTMAT", "", "UTMATDRIVER", cargo1.CM_Container, true, singleGate , null); 
	
	self.workVehicle(vvr);
	self.roadExit(vvr);
	
	// check the storage transaction and invoicing
	write "";
	//write "Days onsite at 00:00, " &amp; _freeDays.String &amp; " free days, released " &amp; _releaseDays.String &amp; " days after receive.";
	write "Days since receival, " &amp; _freeDays.String &amp; " free days, released " &amp; _releaseDays.String &amp; " days after receive.";
	//write cargo1.id;
	foreach tran in cargo1.allTransactions do
		if tran.isKindOf(CM_Receive) or tran.isKindOf(CM_Release) then
			msg := msg &amp; " " &amp; tran.class.name &amp; " " &amp; tran.dateTime.String;
		endif;
		if tran.isKindOf(CM_Storage) then
			write "Storage " &amp; tran.dateTime.String &amp; " noCharge=" &amp; tran.noCharge.String &amp; " " &amp; tran.getDisplayStringForAttribute(ETRow_Storage, false);
			foreach invLine in tran.allInvoiceLines do
				write "Invoice line quantity " &amp; invLine.quantity.String &amp; " ild=" &amp; invLine.invoiceLineDesc.narration ;
			endforeach;
		endif;
	endforeach;
	write msg;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_crane" type="CM_Machine" usage="io"/>
        <Parameter name="_tas" type="StringArray"/>
        <Parameter name="_bs" type="CM_BlockStack"/>
        <Parameter name="_freeDays" type="Integer"/>
        <Parameter name="_releaseDays" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="xStorageCheckWithConfig" id="78af8cd6-ea93-411f-b13a-129cf5a3671f">
        <source>xStorageCheckWithConfig(_crane : CM_Machine io; _tas : StringArray; _bs : CM_BlockStack; _freeDays : Integer; _releaseDays : Integer) protected;
// cnwjre1
/*	NEW storage config, check the  revised config code with both no free storage days and some free storage days, release both before, on and after the free storage expiry.
	Method uStorageCheckWithConfig drives this.  Parameter _freeDays is the number of free storage days for the cargo.  Parameter _releaseDays is the number of days after receipt to do the release.
*/
constants
	VoyageName = 'UTVOYROR2';
	ShipName = 'UTROR2';
	TestOperator = 'UTOP';
	CraneTransferAreaId	= "UTC1T2";
	IMV1 = "UTI2";
vars
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	queue: CM_VoyageQueue;
	rampQueue: CM_VoyageCraneQueue;
	cargo1,
	cargo2	: CM_TrackedItem;
	tas: StringArray;
	imv: CM_Machine;
	wle : CM_WorkListEntry;
	job : CM_VoyageJob;
	forkLift: CM_Machine;
	task: CM_RTQueueTask;
	tran			: CM_TITransaction;
	invLine			: CM_InvoiceLine;
	tranDate		: Date;
	tranTime		: Time;
	tranTS			: TimeStamp;
	vvr 			: CM_VehicleVisitRecord;
	singleGate		: CM_Gate;
	msg				: String;

begin

	tas := _tas;
	self.deleteVoyage(VoyageName);
	self.deleteVessel(ShipName);
	vessel := self.addVesselLOLOholdsRORO(ShipName, self.getOperator(TestOperator));
	voyage	:= self.addVoyageWithConRORO(VoyageName,
													ShipName,
													TestOperator, 
													self.getProfileSetting( UT_Profile.P_SHIPPING_LINE ).asString,
													null, 10, false, true);
	// these methods both delete first
	queue := self.addVoyageQueue(voyage);
	rampQueue := self.addVoyageCraneQueue(voyage, queue, _crane);
	
	// add one import general container on-ship
	cargo1 := self.addContainerAtLocnDisch("MRKU0910410", "2200", "GENL", TI_IMEX_STATUS_IMPORT, voyage.myShipBlockStack, app.myRoot.allPorts["NZPOE"], voyage);
	
	imv := self.addIMV(IMV1, 93, tas, rampQueue.id);
	forkLift := self.addForkLift("UTFL", 94, tas, rampQueue.id);
	
	// move box
	self.doQueueUnplannedUnworkedCargo(cargo1, job, wle );
	self.assertNotNullMsg(wle, "Failed to queue cargo 1");
	
	// Lander puts cargo on IMV
	app.myTrxUA.trxUpdateShipMoveImport(imv, cargo1, wle, job,null,null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.checkTIForTxnOfType(cargo1, TRANS_TYPE_REC_SHIP);
	self.checkTIForTxnOfType(cargo1, TRANS_TYPE_WHARFAGE);
	
	beginTransaction;
	cargo1.setPropertyValue("freeStorageDays", _freeDays);
	commitTransaction;
	
	// Forklift sets down into yard
	self.machineLogon(forkLift);
	task := self.machineTaskRequest(forkLift);
	self.machineAcceptTask(forkLift, wle.allRTQueueEntries.last.allTasks.first);
	self.machinePickup(forkLift);
	self.machineSetdown(forkLift, cargo1, _bs.id);
	self.machineLogOff(forkLift);
	
	// Make sure temp voyage job is deleted
	self.assertEqual(voyage.allVoyageJobs.size, 0);
	

	// back-date cargo1 transactions to &lt;n&gt; days ago
	if _releaseDays &gt; 0 then
		tranDate := tranDate - _releaseDays;
		tranTS.setDate(tranDate);
		foreach tran in cargo1.allTransactions do
			tranTime := tran.dateTime.time;
			tranTS.setDate(tranDate);
			tranTS.setTime(tranTime);
			
			beginTransaction;
			tran.setPropertyValue("dateTime", tranTS);
			commitTransaction;
		endforeach;
	endif;
	
	process.sleep(2000);		// make sure the release is a few seconds after the receive
	// do a road release
	// Remove all automatic stops
	self.deleteStops(cargo1);

	singleGate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	
	self.deleteVehicle("UTMAT");
	self.opts.addAssoc("deliveryNumber", "999");
	vvr := self.gateOutContainer("UTMAT", "", "UTMATDRIVER", cargo1.CM_Container, true, singleGate , null); 
	
	self.workVehicle(vvr);
	self.roadExit(vvr);
	
	// check the storage transaction and invoicing
	write "";
	write "Days onsite at 00:00, " &amp; _freeDays.String &amp; " free days, released " &amp; _releaseDays.String &amp; " days after receive.";
	//write "Days since receival, " &amp; _freeDays.String &amp; " free days, released " &amp; _releaseDays.String &amp; " days after receive.";
	//write cargo1.id;
	foreach tran in cargo1.allTransactions do
		if tran.isKindOf(CM_Receive) or tran.isKindOf(CM_Release) then
			msg := msg &amp; " " &amp; tran.class.name &amp; " " &amp; tran.dateTime.String;
		endif;
		if tran.isKindOf(CM_Storage) then
			write "Storage " &amp; tran.dateTime.String &amp; " noCharge=" &amp; tran.noCharge.String &amp; " " &amp; tran.getDisplayStringForAttribute(ETRow_Storage, false);
			foreach invLine in tran.allInvoiceLines do
				write "Invoice line quantity " &amp; invLine.quantity.String &amp; " ild=" &amp; invLine.invoiceLineDesc.narration ;
			endforeach;
		endif;
	endforeach;
	write msg;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_crane" type="CM_Machine" usage="io"/>
        <Parameter name="_tas" type="StringArray"/>
        <Parameter name="_bs" type="CM_BlockStack"/>
        <Parameter name="_freeDays" type="Integer"/>
        <Parameter name="_releaseDays" type="Integer"/>
    </JadeMethod>
</Class>
