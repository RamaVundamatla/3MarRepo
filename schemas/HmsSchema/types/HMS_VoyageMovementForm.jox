    <JadeMethod name="setColumnIndex" id="6cf52a6e-79b1-49fc-ace5-4568fa3cec65">
        <updating/>
        <source>setColumnIndex() updating;
//--------------------------------------------------
// Created:	17 February 2005 By: cnwgd1
//--------------------------------------------------
// 02 May 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement

vars
	tmpTable : CM_DataTable;
begin
	tmpTable := self.tblResUsed;
	
	self.colResourceType := tmpTable.getColumnByRowName(ETRow_MyResourceType);
	self.colResource := tmpTable.getColumnByRowName(ETRow_MyResource);
//	self.colUnitsUsed := tmpTable.getColumnByRowName(ETRow_UnitsUsed);//added by cnwyl1 15062006 for Par 11921
	self.colDateFrom := tmpTable.getColumnByRowName(ETRow_FromDate);
	self.colDateTo := tmpTable.getColumnByRowName(ETRow_ToDate);
	self.colTimeFrom := tmpTable.getColumnByRowName(ETRow_FromTime);
	self.colTimeTo := tmpTable.getColumnByRowName(ETRow_ToTime);
	self.colUnitsUsed := tmpTable.getColumnByRowName(ETRow_UnitsUsed);
	self.colQtyUnits := tmpTable.getColumnByRowName(ETRow_QuantityUnits);	
	self.colInvNo := tmpTable.getColumnByRowName(ETRow_MyVTMISTransaction);	
	self.colCreateCharge := tmpTable.getColumnByRowName(ETRow_CreateCharge);	
	self.colPartOfContract := tmpTable.getColumnByRowName(ETRow_PartOfContract);
	
	tmpTable := self.tblPilotLaunch; // TFS 44438
	self.colPilotLaunch := tmpTable.getColumnByRowName(ETRow_MyPilotLaunch); // TFS 44438
	self.colPilot := tmpTable.getColumnByRowName(ETRow_MyPilot); // TFS 44438			
end;</source>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="1b60c453-0f24-41ce-9c56-ed066e8aac6e">
        <updating/>
        <source>setControlsForAddEdit() updating;
//--------------------------------------------------
// Created:	05 April 2004 By: cnwgd1
//--------------------------------------------------
vars

begin

	self.setEnableObjects(true);
		
	if self.mode = self.Mode_Update then
		
		self.setTblResourceForEdit();
		
		if self.fldMain.topSheet = self.shtResources then
			self.tblResUsed.setFocus();
			if self.tblResUsed.rows &gt; self.tblResUsed.fixedRows then
				self.tblResUsed.row := self.tblResUsed.fixedRows+1;
				self.tblResUsed.column := 1;
			endif;
		endif;
	
	else
		// can only add shift moves which only allow berths in current harbour
		self.myAssistant.comboBoxHMSBerth(self.cmbToBerth, self.myTerminal.myHarbour, null, true);
	endif;

	self.cmbMovements.enabled := false;
	self.cmbHMSVoyage.enabled := false;

	self.btnEdit.enabled := false;
	self.btnNew.enabled := false;	
	self.btnDelete.enabled := false;
	self.btnSaveBase.enabled := true;
	self.btnCancelBase.enabled := true;		
	self.btnResourcesUsed.enabled := false;	
	
	self.btnTimings.enabled :=  false;	//20 Jun 2018	NDL	TFS 39215
	self.btnCancelMove.enabled := false;	//19 Nov 2018	NDL	TFS 42043
		
end;</source>
    </JadeMethod>
    <JadeMethod name="setDefaultActOrderTimes" id="1e626568-10ea-48a4-8e7a-4c6c62dc174d">
        <source>setDefaultActOrderTimes() protected;

vars
 	baseTime:		TimeStamp;
 	launchOffset:	Time;
 	launchActual:	TimeStamp;
 	linesOffset:	Time;
 	linesActual:	TimeStamp;
 	tugsOffset:		Time;
 	tugsActual:		TimeStamp;
	harbour:		HMS_Harbour;	
begin
 	// Set harbour and terminal references
	if self.myCurrentMovement = null then
		return;
	endif;

 	harbour := self.myCurrentMovement.myHarbour;

	baseTime:=self.myCurrentMovement.occursOnDTNEW;

    // Set actual times
    // Lines actual

    if tbxLineRelative.text.Integer&lt;0 then
    	linesOffset.setTime(0,((tbxLineRelative.text.Integer)*-1),0,0);
    	linesActual:=baseTime-linesOffset;
    else
    	linesOffset.setTime(0,tbxLineRelative.text.Integer,0,0);
    	linesActual:=baseTime+linesOffset;
    endif;
    tbxLineOrderAct.text := self.systemToLocalTime(linesActual).Time.userFormat($CM_HMS_Time24Hour);	// 25/5/16 cnwmp6 TFS 488 - Multi timezone support

       // Launch actual
	if tbxLaunchRelative.text.Integer&lt;0 then
    	launchOffset.setTime(0,((tbxLaunchRelative.text.Integer)*-1),0,0);
    	launchActual:=baseTime-launchOffset;
    else
    	launchOffset.setTime(0,tbxLaunchRelative.text.Integer,0,0);
    	launchActual:=baseTime+launchOffset;
    endif;
    tbxLaunchOrderAct.text := self.systemToLocalTime(launchActual).Time.userFormat($CM_HMS_Time24Hour);	// 25/5/16 cnwmp6 TFS 488 - Multi timezone support

    // Tugs actual

    if tbxTugRelative.text.Integer&lt;0 then
    	tugsOffset.setTime(0,((tbxTugRelative.text.Integer)*-1),0,0);
    	tugsActual:=baseTime-tugsOffset;
    else
    	tugsOffset.setTime(0,tbxTugRelative.text.Integer,0,0);
    	tugsActual:=baseTime+tugsOffset;
    endif;
    tbxTugOrderAct.text := self.systemToLocalTime(tugsActual).Time.userFormat($CM_HMS_Time24Hour);	// 25/5/16 cnwmp6 TFS 488 - Multi timezone support


end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setDefaultRelOrderTimes" id="71c203be-14d3-4d1f-921d-465cde5dccb3">
        <source>setDefaultRelOrderTimes() protected;

vars
 	baseTime:		TimeStamp;
	movePrevious:	HMS_VoyageMovement;
	berthTo, berthFrom : HMS_Berth;
	harbour:		HMS_Harbour;	
begin
 	// Set harbour and terminal references
	if self.myCurrentMovement = null then
		return;
	endif;

 	harbour := self.myCurrentMovement.myHarbour;

	baseTime:=self.myCurrentMovement.occursOnDTNEW;


	// Set basetime offsets

//	if self.myCurrentMovement.requiresMarineServices = false then
		//This movement does not need pilot or tugs (e.g. Sea to Roadstead) adm 100310 Par 22794 move to setPLaunchReqdStatus
//		self.shtMarineService.enabled:= false;
//	endif;

 	// Set references
 	movePrevious:=self.myCurrentMovement.getVoyageMovementPrevious;
 	berthTo:=self.myCurrentMovement.getMyBerth;
 	if movePrevious&lt;&gt;null then
 		berthFrom:=movePrevious.getMyBerth;
 	endif;

	// [ARRIVAL]
	if self.myCurrentMovement.moveType=HMSMovementTypeArrival or 
		//We are 'shifting' into the harbour from anchorage etc.)
		(self.myCurrentMovement.moveType=HMSMovementTypeShift and berthFrom.noMarineServices = true) then
		// Default lines order time [ARRIVAL]
		if harbour.defaultOrderTimesArrive[1]&gt;-1 then
    		tbxLineRelative.text:="+" &amp; harbour.defaultOrderTimesArrive[1].String;
   		else
    		tbxLineRelative.text:=harbour.defaultOrderTimesArrive[1].String;
		endif;
		// Default pilot launch order time [ARRIVAL]
		if harbour.defaultOrderTimesArrive[2]&gt;-1 then
    		tbxLaunchRelative.text:="+" &amp; harbour.defaultOrderTimesArrive[2].String;
   		else
    		tbxLaunchRelative.text:=harbour.defaultOrderTimesArrive[2].String;
		endif;
		cbxLaunchPosn.listIndex:=AlongSide;
		cbxLaunchPosn.text:=cbxLaunchPosn.itemText[cbxLaunchPosn.listIndex];

		// Default tugs order time [ARRIVAL]
		if harbour.defaultOrderTimesArrive[3]&gt;-1 then
    		tbxTugRelative.text:="+" &amp; harbour.defaultOrderTimesArrive[3].String;
   		else
    		tbxTugRelative.text:=harbour.defaultOrderTimesArrive[3].String;
		endif;
		cbxTugPosn.listIndex:=OnStation;
		cbxTugPosn.text:=cbxTugPosn.itemText[cbxTugPosn.listIndex];

	//[DEPARTURE]
	elseif self.myCurrentMovement.moveType=HMSMovementTypeDeparture  or
		//We are departing to an anchorage etc
		(self.myCurrentMovement.moveType=HMSMovementTypeShift and berthTo.noMarineServices = true) then

		// Default lines order time [DEPARTURE]
		if harbour.defaultOrderTimesDepart[1]&gt;-1 then
    		tbxLineRelative.text:="+" &amp; harbour.defaultOrderTimesDepart[1].String;
   		else
    		tbxLineRelative.text:=harbour.defaultOrderTimesDepart[1].String;
		endif;
		// Default pilot launch order time [DEPARTURE]
		if harbour.defaultOrderTimesDepart[2]&gt;-1 then
    		tbxLaunchRelative.text:="+" &amp; harbour.defaultOrderTimesDepart[2].String;
   		else
    		tbxLaunchRelative.text:=harbour.defaultOrderTimesDepart[2].String;
		endif;
		cbxLaunchPosn.listIndex:=OnStation;
		cbxLaunchPosn.text:=cbxLaunchPosn.itemText[cbxLaunchPosn.listIndex];
		// Default tugs order time [DEPARTURE]
		if harbour.defaultOrderTimesDepart[3]&gt;-1 then
    		tbxTugRelative.text:="+" &amp; harbour.defaultOrderTimesDepart[3].String;
   		else
    		tbxTugRelative.text:=harbour.defaultOrderTimesDepart[3].String;
		endif;
		cbxTugPosn.listIndex:=AlongSide;
		cbxTugPosn.text:=cbxTugPosn.itemText[cbxTugPosn.listIndex];
	//[SHIFT: Except those to and from anchorages etc]
	elseif self.myCurrentMovement.moveType=HMSMovementTypeShift then
		// Default lines order time [SHIFT]
		if harbour.defaultOrderTimesShift[1]&gt;-1 then
    		tbxLineRelative.text:="+" &amp; harbour.defaultOrderTimesShift[1].String;
   		else
    		tbxLineRelative.text:=harbour.defaultOrderTimesShift[1].String;
		endif;
		// Default pilot launch order time [SHIFT]
			// Not required

			cbxLaunchPosn.enabled:=false;
			cmbPilotLaunch.enabled:=false;
			tbxLaunchRelative.enabled:=false;
			tbxLaunchOrderAct.enabled:=false;

		// Default tugs order time [SHIFT]
		if harbour.defaultOrderTimesShift[2]&gt;-1 then
    		tbxTugRelative.text:="+" &amp; harbour.defaultOrderTimesShift[2].String;
   		else
    		tbxTugRelative.text:=harbour.defaultOrderTimesShift[2].String;
		endif;
		cbxTugPosn.listIndex:=AlongSide;
		cbxTugPosn.text:=cbxTugPosn.itemText[cbxTugPosn.listIndex];
	endif;


end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setEnableObjects" id="4de5c4a1-66ef-40f9-b8f7-8593ae922484">
        <updating/>
        <source>setEnableObjects(_enable : Boolean)updating, protected;
//-----------------------------------------
// Created: July 2005 By: cnwgd1
//-----------------------------------------
// Changed On 	By			Reason
// ==========	========	=====================================================
// 17/08/2012	cnwdap1		PAR #30145 Enable/disable Pilot Launch relative time textbox along with all other pilot realated fields
// 02 May 2019	jlgsl4		TFS 44438 - PEL1 - Multiple Pilot Launches for one movement
//16/09/2022	 navgm20	ChangeRequest 54739: EUP - PLAN - Berth planning by bollards

vars
begin

	self.btnViewContact.enabled := _enable;

	self.cmbContact.enabled := _enable;
	self.cmbShippingLine.enabled := _enable;
	self.cmbTidalClass.enabled := _enable;
	self.cmbResourceType.enabled := _enable;
	self.cmbResource.enabled := _enable;
	self.cmbToBerth.enabled := _enable;
	//16/09/2022 navgm20 TFS 54739- Start
	self.cmbBowMarkBollard.enabled := _enable;
	self.cmbSternMarkBollard.enabled := _enable;
	self.cmbBridgeMarkBollard.enabled := _enable;
	self.txtBowMarkMeter.enabled := _enable;
	self.txtSternMarkMeter.enabled := _enable;
	self.txtBridgeMarkMeter.enabled := _enable;
	//16/09/2022 navgm20 TFS 54739- End
//	self.cmbPilot.enabled := _enable;
	self.lstPilots.readOnly := not _enable;	//30 Oct 2018	NDL	TFS 41662
	self.cmbLineCompany.enabled := _enable;
	self.cmbPilotLaunch.enabled := _enable;
	self.cmbShippingAgent.enabled := _enable;			
	self.cbxOrientTo.enabled := _enable;
	self.cbxTugPosn.enabled := _enable;	
	self.cbxLaunchPosn.enabled := _enable;
	self.tbxLaunchRelative.enabled := _enable;		// PAR #30145

	self.ckbxChargeMove.readOnly := (not _enable);
	self.ckbxPilotExempt.readOnly := (not _enable);	
	
	self.cmbMaster.enabled := _enable;
	self.cmbMaster.click(cmbMaster);

	self.optAgent.enabled := _enable;
	self.optShippingLine.enabled := _enable;
		
	self.tblResUsed.readOnly := (not _enable);
	self.tblResUsed.userInputEnabled := _enable;

	self.tblPilotLaunch.readOnly := (not _enable); // TFS 44438
	self.tblPilotLaunch.userInputEnabled := _enable; // TFS 44438	

	self.tbxShipsMaster.readOnly := (not _enable);	
	self.tbxLineCrewReqd.readOnly := (not _enable);
	self.tbxLineRelative.readOnly := (not _enable);
	self.tbxTugRelative.readOnly := (not _enable);
	self.tbxLaunchRelative.readOnly := (not _enable);
	
	self.txtBowMarkTo.readOnly := (not _enable);
	self.txtBridgeMark.readOnly := (not _enable);

	self.txtMoveOnTime.readOnly := (not _enable);
	self.txtMoveOnDate.readOnly := (not _enable);
	self.tbxDraftFwd.readOnly := (not _enable);
	self.tbxDraftAft.readOnly := (not _enable);
	self.tbxRemarks.readOnly := (not _enable);	
	
	self.lstTugs.readOnly := not _enable;

	if self.ckbxPilotExempt.value then	//Par15027 organize enabling according to Pilot Exempt status
		self.pilotExemptEnable();
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_enable" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMeterMarks" id="a497fe92-982e-4dd9-9305-422423bedb7a">
        <updating/>
        <source>setMeterMarks(_textBox : TextBox)updating;
//-----------------------------------------
// Created: December 2004 By: cnwgd1
// 26 Jul 2018	jlgrh7	TFS 39468  STWO - Issue with moving vessels to berth ANCHOR
// 22 Mar 2023	navdap1	TFS 56593 EUP - Show Bollards+Meters in all instances
// 10/07/2024	navcs2		Bug 64769: MSL- IMT- Unable to manage the movements in Harbor management
//-----------------------------------------
vars
	loa			: Decimal[6,2];
	sideTo		: Integer;
	bridgeToBow,
	bowMark,
	sternMark,
	bridgeMark	: Decimal[12,2];
	tmpStr		: String;
	berthForMarks,
	tmpBerth	: HMS_Berth;
	bowBMark, bridgeBMark, sternBMark : Integer;				// TFS 56593
	bowBollard, bridgeBollard, sternBollard : HMS_Resource;		// TFS 56593
begin

	tmpBerth := self.cmbToBerth.listObject.HMS_Berth;
	if tmpBerth = null then
		return;
	endif;

	loa := self.myCurrentMovement.myHMSVoyageData.dim_LengthOverall;
	bridgeToBow := self.myCurrentMovement.myHMSVoyageData.dist_BridgeToBow;
	
	tmpStr := self.cbxOrientTo.text;
	if tmpStr = app.getErrorString(StarboardSideToBerth) then
		sideTo := OrientStarboardSideTo;
	else
		sideTo := OrientPortSideTo;		
	endif;
		
	if _textBox = null then
		tmpBerth.getBowSternBridgeMarksFromLOA(loa, bridgeToBow, sideTo, bowMark, sternMark, bridgeMark, null, berthForMarks,true);
	elseif _textBox = self.txtBowMarkTo then
		//bowMark := _textBox.text.Decimal;
		bowMark := _textBox.text.asDecimalJMT();// 01 APR 2010	NDL	Par 23556
		tmpBerth.getBowSternBridgeMarksFromLOA(loa, bridgeToBow, sideTo, bowMark, sternMark, bridgeMark, app.getErrorString(HMS_BowMark), berthForMarks,true);
	elseif _textBox = self.txtSternMarkTo then
		//sternMark := _textBox.text.Decimal;
		sternMark := _textBox.text.asDecimalJMT();// 01 APR 2010	NDL	Par 23556
		tmpBerth.getBowSternBridgeMarksFromLOA(loa, bridgeToBow, sideTo, bowMark, sternMark, bridgeMark, app.getErrorString(HMS_SternMark), berthForMarks,true);	
	elseif _textBox = self.txtBridgeMark then
		//bridgeMark := _textBox.text.Decimal;
		bridgeMark := _textBox.text.asDecimalJMT();// 01 APR 2010	NDL	Par 23556
		tmpBerth.getBowSternBridgeMarksFromLOA(loa, bridgeToBow, sideTo, bowMark, sternMark, bridgeMark, app.getErrorString(HMS_BridgeMark), berthForMarks,true);			
	else
		return;
	endif;

	self.txtBowMarkTo.text	:= bowMark.asStringJMT();		//24363 17/06/2010
	self.txtSternMarkTo.text:= sternMark.asStringJMT();		//24363 17/06/2010
	self.txtBridgeMark.text := bridgeMark.asStringJMT();	//24363 17/06/2010
	
	// TFS 56593 start
	berthForMarks.getBollardForMark(bowMark.Integer, bowBMark, bowBollard);
	berthForMarks.getBollardForMark(sternMark.Integer, sternBMark, sternBollard);
	berthForMarks.getBollardForMark(bridgeMark.Integer, bridgeBMark, bridgeBollard);
	self.txtBowMarkMeter.text := self.stringOrNull(bowBMark);								// 10/07/2024	navcs2		Bug 64769
	if bowBollard &lt;&gt; self.cmbBowMarkBollard.listObject then
		self.cmbBowMarkBollard.listIndex := self.cmbBowMarkBollard.findObject(bowBollard);
	endif;
	self.txtBridgeMarkMeter.text := bridgeBMark.asStringOrBlank;
	if bridgeBollard &lt;&gt; self.cmbBridgeMarkBollard.listObject then
		self.cmbBridgeMarkBollard.listIndex := self.cmbBridgeMarkBollard.findObject(bridgeBollard);
	endif;
	self.txtSternMarkMeter.text := sternBMark.asStringOrBlank;
	if sternBollard &lt;&gt; self.cmbSternMarkBollard.listObject then
		self.cmbSternMarkBollard.listIndex := self.cmbSternMarkBollard.findObject(sternBollard);
	endif;
	if self.myProxyMovement &lt;&gt; null then
		self.myProxyMovement.setBollardDetails(bowBMark, bridgeBMark, sternBMark, bowBollard, sternBollard, bridgeBollard);
	endif;
	// TFS 56593 end
	
	if self.myProxyMovement &lt;&gt; null then							//+TFS39468
		self.myProxyMovement.setBowMarkValue(bowMark);
		self.myProxyMovement.setSternMarkToValue(sternMark);
	endif;
	
	if berthForMarks &lt;&gt; null and berthForMarks &lt;&gt; tmpBerth then
		self.cmbToBerth.listIndex := self.cmbToBerth.findObject(berthForMarks);
	endif;

end;</source>
        <Parameter name="_textBox" type="TextBox"/>
    </JadeMethod>
    <JadeMethod name="setMyCurrentMovement" id="98e84be2-c2a5-4fbb-9307-115d7f086737">
        <updating/>
        <source>setMyCurrentMovement(_movement : HMS_VoyageMovement)updating;
//--------------------------------------------------
// Created:	06 April 2004 By: cnwgd1
//--------------------------------------------------
vars

	voyage : CM_Voyage;
	repMove : HMS_VoyageMovement;
	gracePeriod : Integer;
	checkDT	: TimeStamp;

begin
	
	self.myCurrentMovement := _movement;

	self.setToViewMode(); 

	self.displayMovementDetails(); //&lt;-- data cleared here if the current voyage is null

	self.btnShippingAgent.enabled := self.cmbShippingAgent.listObject &lt;&gt; null;		
	self.btnShippingLine.enabled := self.cmbShippingLine.listObject &lt;&gt; null;
	self.btnCancelMove.enabled := false;	//19 Nov 2018	NDL	TFS 42043
	self.lblReplaced.caption := null;	//19 Nov 2018	NDL	TFS 42043
	
	if _movement &lt;&gt; null then
//		30/7/19 MAP TFS45879	Never show berths from other harbours
//		if _movement.moveType = HMSMovementTypeDeparture then
//			self.myAssistant.comboBoxHMSBerth(self.cmbToBerth, self.myTerminal.myHarbour, _movement.getMyBerth, false);
//		else
			self.myAssistant.comboBoxHMSBerth(self.cmbToBerth, self.myTerminal.myHarbour, _movement.getMyBerth, true);
//		endif;
		//19 Nov 2018	NDL	TFS 42043
		if app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
			if _movement.moveType.isOneOf( HMSMovementTypeArrival, HMSMovementTypeShift, HMSMovementTypeDeparture )then
				voyage := _movement.getMyVoyage;
				if voyage &lt;&gt; null
				and not voyage.isNullVoyage	//18 Dec 2018	TFS 42546
				and not voyage.isUsingDefaultProcessJMT then
					if not voyage.hasDeparted then
						self.btnCancelMove.enabled := true;
					//04 Dec 2018	NDL	TFS 42043 - give a grace period
					else
						gracePeriod := self.myTerminal.getConfig(VoyDepartedGracePeriod).Integer;
						if gracePeriod = null then
							gracePeriod := 24;
						endif;
						checkDT := app.actualTimeServer().changeByXXHours(gracePeriod);
						if voyage.departedDT.cnEcIsLessThanOrEqual( checkDT) then
							self.btnCancelMove.enabled := true;
						endif;
					endif;
					
				endif;
			endif;
		endif;
		//19 Nov 2018	NDL	TFS 42043
		if _movement.myReplacementMovement &lt;&gt; null and _movement.myReplacementMovement.isKindOf(HMS_VoyageMovement) then
			repMove := _movement.myReplacementMovement.HMS_VoyageMovement;
			self.lblReplaced.caption := repMove.moveType &amp; '   ' &amp; self.systemToLocalTime(repMove.occursOnDTNEW).shortCurrentLocaleFormat();
		endif;
		
	endif;

	self.doResizeTopSheet();
end;</source>
        <Parameter name="_movement" type="HMS_VoyageMovement"/>
    </JadeMethod>
    <JadeMethod name="setObjectFromTableSpecial" id="00eb0646-b1cb-4d1d-80f2-1c35fa280782">
        <source>setObjectFromTableSpecial(_attrName: String; _strValue: String; _obj: CM_Object input; _entryTable: CM_EntryTable input): Boolean;
//--------------------------------------------------
// Created:	08 April 2004 By: cnwgd1
//--------------------------------------------------
/* Changes

Date		Name	TFS#	Description
============================================================================
08/02/2022	jlika1	52659	SAL - HMS Movement Current Berth  
============================================================================*/
vars
	occursLocal: TimeStamp;
begin

	if _attrName = ETRow_OccursOnDate then
		if HMS_VoyageMovement.hasInstance(_obj) then
			occursLocal.setDate(_entryTable.getValueByName(ETRow_OccursOnDate).Date);
			occursLocal.setTime(_entryTable.getValueByName(ETRow_OccursOnTime).Time);
			_obj.setPropertyValue('occursOnDTNEW', self.localToSystemTime(occursLocal));	// 26/5/16 cnwmp6 TFS 488 - Multi timezone support
/*			_obj.setPropertyValue('occursOnDT', (_entryTable.getValueByName(ETRow_OccursOnDate).Date.shortFormatJMT() 
										&amp; ' ' &amp; _entryTable.getValueByName(ETRow_OccursOnTime).Time.String).TimeStamp);									
*/		endif;
		return true;
	elseif _attrName = ETRow_CustomerForMovement then		
		if HMS_VoyageMovement.hasInstance(_obj) then
			_obj.setPropertyValue('isAgentDefault', _strValue = app.getErrorString(Agent));									
		endif;
		return true;		
	elseif _attrName = ETRow_SideTo then		
		if HMS_VoyageMovement.hasInstance(_obj) then
			_obj.setPropertyValue('sideTo', app.sideToStringToNum(_strValue));									
		endif;
		return true;
	elseif _attrName = ETRow_LocationTug then		
		if HMS_VoyageMovement.hasInstance(_obj) then
			_obj.setPropertyValue('locationTug', app.locationPilotTugStringToNum(_strValue));									
		endif;
		return true;
	elseif _attrName = ETRow_LocationPilotLaunch then		
		if HMS_VoyageMovement.hasInstance(_obj) then
			_obj.setPropertyValue('locationPilotLaunch', app.locationPilotTugStringToNum(_strValue));									
		endif;
		return true;
	elseif _attrName = ETRow_MoveStatusNEW then		
		if HMS_VoyageMovement.hasInstance(_obj) then
			if _entryTable.getValueByName(ETRow_MoveStatusNEW).Boolean then
				_obj.setPropertyValue('moveStatus', MovementStatus_Planned);
			else
				_obj.setPropertyValue('moveStatus', MovementStatus_Actual);												
			endif;
		endif;
		return true;				
	endif;
	
	return false;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_strValue" type="String"/>
        <Parameter name="_obj" type="CM_Object" usage="input"/>
        <Parameter name="_entryTable" type="CM_EntryTable" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setPLaunchReqdStatus" id="e7fb0633-8b7c-411e-bc35-59de44d911cf">
        <source>setPLaunchReqdStatus() protected;

vars
	moveCurrent,
	movePrevious:	HMS_VoyageMovement;
	berthTo,
	berthFrom:		HMS_Berth;
	launchRequired:	Boolean;
begin
 	// This method sets the required status for the pilot launch for a movement
 	// LAUNCH REQUIRED	
 	// Arrival:		(except when Pilot Exempt = true // or // when 'to' berth is logical)
 	// Departure:	(except when Pilot Exempt = true // or // when 'from' berth is logical)
 	// Shift:		(except when Pilot Exempt = true // or // 'to' or 'from' berth
 	//               is a logical berth)
	if self.myCurrentMovement = null then
		return;
	endif;

 	// Set references
 	moveCurrent:=self.myCurrentMovement;
 	movePrevious:=self.myCurrentMovement.getVoyageMovementPrevious;
 	berthTo:=moveCurrent.getMyBerth;

 	if movePrevious&lt;&gt;null then
 		berthFrom:=movePrevious.getMyBerth;
 	endif;

 	launchRequired:=false;
 	if moveCurrent.pilotExempt=false or moveCurrent.myHMSVoyageData.isPilotExempt = false then
 		
 		if moveCurrent.moveType=HMSMovementTypeArrival then
 			if berthTo&lt;&gt;null then
 				if berthTo.noMarineServices=false then
 					// Arrival is to a physical berth					
 					launchRequired:=true; // Pilot is required.
 				endif;
 			endif;
 		// DEPARTURE
 		elseif moveCurrent.moveType=HMSMovementTypeDeparture then
 			if berthFrom&lt;&gt;null then
 				if berthFrom.noMarineServices=false then
 					// Departure is from a physical berth					
 					launchRequired:=true; // Pilot is required.
 				endif;
 			endif;
 		// SHIFT
 		elseif moveCurrent.moveType=HMSMovementTypeShift then
 			if berthFrom&lt;&gt;null and berthTo&lt;&gt;null then
 //				if berthFrom.ofWharf.isLogicalWharf=false or berthTo.ofWharf.isLogicalWharf=false then
 				

 				if berthFrom.noMarineServices=true or berthTo.noMarineServices=true then
 					// Shift is either to or from the berth					
 					launchRequired:=true; // Pilot is required.
 				endif;
 			endif;
 		endif;
 	endif;

	// adm 100310 Par 22794
	if moveCurrent.requiresMarineServices
	or launchRequired then
		self.shtMarineService.enabled	:= true;
	else
		self.shtMarineService.enabled	:= false;
	endif;

	if launchRequired=true then		
		if (self.mode = self.Mode_Add) or (self.mode = self.Mode_Update) then
		
//			self.shtMarineService.enabled:=true;
			cbxLaunchPosn.enabled:=true;
			cmbPilotLaunch.enabled:=true;
			tbxLaunchRelative.enabled:=true;
			tbxLaunchOrderAct.enabled:=true;
		endif;
	else
		// Pilot launch is NOT required - set order time and position cbx's to disabled 
		
		cbxLaunchPosn.enabled:=false;
		cmbPilotLaunch.enabled:=false;
		tbxLaunchRelative.enabled:=false;
		tbxLaunchOrderAct.enabled:=false;
	endif;					

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setPilotLaunchCellText" id="e7718c5e-3d11-44fb-ae46-4d83453621b1">
        <updating/>
        <source>setPilotLaunchCellText(table : Table input; _newRow : Integer; _newCol : Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 May 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement

*/

vars
	cntrl : Control;
	temp : Integer;
begin	
	if (not table.userInputEnabled)	or table.row &lt;= table.fixedRows then
		return;
	endif;
		
	if table.accessCell(table.row, table.column).enabled then
		cntrl := table.accessedCell.cellControl;
		if TextBox.hasInstance(cntrl) then
			temp := 1;
		elseif ComboBox.hasInstance(cntrl) then
			table.accessedCell.text := cntrl.ComboBox.text;
		endif;
	endif;
	
	if table.accessCell(_newRow, _newCol).enabled then
		cntrl := table.accessedCell.cellControl;
		if TextBox.hasInstance(cntrl) then
			table.gotFocus(table);
		endif;		
	endif;
		
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="_newRow" type="Integer"/>
        <Parameter name="_newCol" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setPxyMovement" id="8e297b23-8f3e-4986-b41b-5bac28fbb8e4">
        <updating/>
        <source>setPxyMovement(_pxyMovement : HMS_VoyageMovement input):Boolean updating;
// 26 Jul 2018	jlgrh7	TFS 39468  STWO - Issue with moving vessels to berth ANCHOR
// 30 Apr 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement
// 19 Sep 2022 	navsj20	ChangeRequest 54739: EUP - PLAN - Berth planning by bollards
// 29 Nov 2022	navdap1	TFS 55614 MTN Issue with Movement Maintenance and Berthage
vars
	aftClearanceFrom			: Decimal[9,2];
	aftClearanceTo				: Decimal[9,2];
	bowMarkTo					: Decimal[9,2];
	sternMarkTo					: Decimal[9,2];
	foreClearanceFrom			: Decimal[9,2];
	foreClearanceTo				: Decimal[9,2];
	locationPilotLaunch			: Integer;
	locationTug					: Integer;
	numContractTugs				: Integer;
	moveStatus					: Integer;
	numLineCrewRequired			: Integer;
	relativeOrderTimeLines		: Integer;
	relativeOrderTimePlaunch	: Integer;
	relativeOrderTimeTugs		: Integer;
	sideTo						: Integer;
	draftFwd					: Real;
	draftAft					: Real;	
	moveType					: String; 
	remarks						: String; 
	shipsMaster					: String; 
	occursOnDT					: TimeStamp;
	chargeForMove				: Boolean; 
	isAgentDefault				: Boolean; 
	overlapsWharfSection		: Boolean; 
	pilotExempt					: Boolean; 
	myPilot						: HMS_Pilot;
	myPilotLaunch				: HMS_PilotLaunch; 
	myLineCompany				: HMS_LineCompany; 
	myShippingAgent				: CM_ShippingAgent;
	myShippingLine				: CM_ShippingLine; 
	myContact					: CM_EmailAddress2; 
	myBerth						: HMS_Berth; 
	myTidalClass				: HMS_TidalClass;
	myMaster					: HMS_Master;
	prevMoveObj					: HMS_Movement;
	occursLocal					: TimeStamp;
	//allPilots 					: HMS_PilotByCodeDict;	//30 Oct 2018	NDL	TFS 41662 // TFS 44438 after 040 cut/release
	allMovementPilotDetails		: HMS_MovementPilotDetailsSet; // TFS 44438	
	bowToBollard				: Decimal[9,2];
	bridgeToBollard				: Decimal[9,2];
	sternToBollard				: Decimal[9,2];
	myBowBollard				: HMS_Resource;	
	myBridgeBollard				: HMS_Resource;	
	mySternBollard				: HMS_Resource;	


begin
	if _pxyMovement = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null _proxy movement for update');
		return false;
	endif;

	myBerth			:=	self.cmbToBerth.listObject.HMS_Berth;
	moveType		:=	self.tbxMoveType.text;
	occursLocal.setDate(self.txtMoveOnDate.getDate());
	occursLocal.setTime(self.txtMoveOnTime.getTime());
	occursOnDT		:=	self.localToSystemTime(occursLocal);	// 25/5/16 cnwmp6 TFS 488 - Multi timezone support
	numContractTugs	:=	_pxyMovement.numContractTugs;
	prevMoveObj		:=	_pxyMovement.getMovementPrevious;
	
	if (_pxyMovement.moveType = HMSMovementTypeShift
	or _pxyMovement.moveType = HMSMovementTypeDeparture)
	and prevMoveObj &lt;&gt; null
	and prevMoveObj.getMyBerth() &lt;&gt; null
	and myBerth &lt;&gt; null
	and prevMoveObj.getMyBerth() = myBerth
	then
// cnwdad1 02/10/2008 - PAR #18075.
		if prevMoveObj.isVoyageMovement() then
			if _pxyMovement.bowMarkTo = prevMoveObj.HMS_VoyageMovement.bowMarkTo
			and _pxyMovement.sternMarkTo = prevMoveObj.HMS_VoyageMovement.sternMarkTo
			then
				app.raiseCMException(Movement_Is_To_Same_Berth, null, null);
			endif;
		endif;
	endif;
	
	remarks := self.tbxRemarks.text;

	numLineCrewRequired := self.tbxLineCrewReqd.text.Integer;
	pilotExempt := self.ckbxPilotExempt.value;
	chargeForMove := (not self.ckbxChargeMove.value);
	shipsMaster := self.tbxShipsMaster.text;

    //draftAft := self.tbxDraftAft.text.Decimal;
	draftAft := self.tbxDraftAft.text.asDecimalJMT();// 01 APR 2010	NDL	Par 23556
    //draftFwd := self.tbxDraftFwd.text.Decimal;
	draftFwd := self.tbxDraftFwd.text.asDecimalJMT();// 01 APR 2010	NDL	Par 23556

	if tbxAftClearFrom.text = app.getErrorString(Unlimited) then
		aftClearanceFrom := ClearanceUnbounded;
	else
		aftClearanceFrom := self.tbxAftClearFrom.text.Integer;
	endif;
	
	if self.tbxForeClearFrom.text = app.getErrorString(Unlimited) then
		foreClearanceFrom := ClearanceUnbounded;
	else
		foreClearanceFrom := self.tbxForeClearFrom.text.Integer;
	endif;
	
	bowMarkTo := _pxyMovement.bowMarkTo;							//+TFS39468
	sternMarkTo := _pxyMovement.sternMarkTo;	
	
//	if (not _pxyMovement.isLogicalBerth()) then
	if myBerth &lt;&gt; null and ( not myBerth.isLogicalBerth() ) then	//11 Apr 2018	NDL	TFS 37888
		aftClearanceTo := self.lastValidAftClearance;
		foreClearanceTo := self.lastValidForeClearance;
		//bowMarkTo := self.txtBowMarkTo.text.Decimal;
		bowMarkTo := self.txtBowMarkTo.text.asDecimalJMT();// 01 APR 2010	NDL	Par 23556
		//sternMarkTo := self.txtSternMarkTo.text.Decimal;
		sternMarkTo := self.txtSternMarkTo.text.asDecimalJMT();// 01 APR 2010	NDL	Par 23556
	endif;

	relativeOrderTimeLines := self.tbxLineRelative.text.Integer;
	relativeOrderTimePlaunch := self.tbxLaunchRelative.text.Integer;
	relativeOrderTimeTugs := self.tbxTugRelative.text.Integer;	

	if self.cbxOrientTo.listIndex &gt; 0 then
		// fix for par 20526 --- ? cnwrd1 27.8.09
		if  _pxyMovement.moveType = HMSMovementTypeDeparture and self.cbxOrientTo.text = app.getErrorString(NotApplicable) and prevMoveObj &lt;&gt; null then 
			sideTo := prevMoveObj.HMS_VoyageMovement.sideTo;
		//elseif self.cbxOrientTo.text = app.getErrorString(PortSideToBerth) then																// TFS 55614
		elseif self.cbxOrientTo.text = app.getErrorString(PortSideToBerth) or self.cbxOrientTo.text = app.getErrorString(NotApplicable) then	// TFS 55614
			sideTo := OrientPortSideTo;
		else
	 		sideTo := OrientStarboardSideTo;
 		endif;
 	endif;

	//myPilot := self.cmbPilot.listObject.HMS_Pilot; // TFS 44438 after 040 cut/release
	
	//30 Oct 2018	NDL	TFS 41662
	/*create allPilots transient; // --&gt; TFS 44438 after 040 cut/release
	self.lstPilots.allSelectedObjects.copy(allPilots);
	myPilot := null;*/ // &lt;-- TFS 44438 after 040 cut/release

	create allMovementPilotDetails transient;// TFS 44438
	
	myMaster := self.cmbMaster.listObject.HMS_Master;
	//myPilotLaunch := self.cmbPilotLaunch.listObject.HMS_PilotLaunch; // TFS 44438 after 040 cut/release
	myLineCompany := self.cmbLineCompany.listObject.HMS_LineCompany;

	if self.cbxLaunchPosn.listIndex &gt; 0 then
		locationPilotLaunch := self.cbxLaunchPosn.listIndex;
 	endif;

	if self.cbxTugPosn.listIndex &gt; 0 then
		locationTug := self.cbxTugPosn.listIndex;
 	endif;

	myShippingAgent := self.cmbShippingAgent.listObject.CM_ShippingAgent;
 	isAgentDefault := (self.optAgent.value and (myShippingAgent &lt;&gt; null));

 	myShippingLine := self.cmbShippingLine.listObject.CM_ShippingLine;
	myContact := self.cmbContact.listObject.CM_EmailAddress2;
	myTidalClass := self.cmbTidalClass.listObject.HMS_TidalClass;
	
	moveStatus := self.setActOrPlanAsReqd(occursOnDT);
	
	// START 19 Sep 2022	navsj20	TFS 54739
	bowToBollard	:= self.txtBowMarkMeter.text.asDecimalJMT();
	bridgeToBollard	:= self.txtBridgeMarkMeter.text.asDecimalJMT();
	sternToBollard	:= self.txtSternMarkMeter.text.asDecimalJMT();
	myBowBollard	:= self.cmbBowMarkBollard.listObject.HMS_Resource;
	myBridgeBollard	:= self.cmbBridgeMarkBollard.listObject.HMS_Resource;
	mySternBollard	:= self.cmbSternMarkBollard.listObject.HMS_Resource;
	bowMarkTo 		:= self.txtBowMarkTo.text.asDecimalJMT();
	sternMarkTo 	:= self.txtSternMarkTo.text.asDecimalJMT();
	// END 19 Sep 2022	navsj20	TFS 54739

	_pxyMovement.setProxy(aftClearanceFrom,
						aftClearanceTo,
						bowMarkTo,
						sternMarkTo,
						foreClearanceFrom,
						foreClearanceTo,
						locationPilotLaunch,
						locationTug, 
						numContractTugs, 
						moveStatus, 
						numLineCrewRequired, 
						relativeOrderTimeLines, 
						relativeOrderTimePlaunch,
						relativeOrderTimeTugs, 
						sideTo, 
						draftFwd, 
						draftAft,
						moveType, 
						remarks, 
						shipsMaster,
						occursOnDT,
						chargeForMove, 
						isAgentDefault, 
						overlapsWharfSection, 
						pilotExempt,
						myPilot,
						myMaster,
						myPilotLaunch,
						myLineCompany,
						myShippingAgent,
						myShippingLine,
						myContact,
						myBerth,
						myTidalClass,
						null,
						//allPilots,	//_allPilots : HMS_PilotByCodeDict // TFS 44438 after 040 cut/release
						allMovementPilotDetails // TFS 44438,
						);
		
	_pxyMovement.setBollardDetails(bowToBollard,bridgeToBollard,sternToBollard,myBowBollard,myBridgeBollard,mySternBollard);	//19 Sep 2022	navsj20	TFS 54739
	_pxyMovement.allTugsUsed.clear();
	self.lstTugs.allSelectedObjects.copy(_pxyMovement.allTugsUsed);
	
	//Set and save the resources
	if app.myRoot.canDo(Mod_Invoicing) then// Invoice License
		self.doSaveProxyResourceUsedInvoice(_pxyMovement);
	else
		self.doSaveProxyResourcesUsed(_pxyMovement);
	endif;

	self.doSavePxyMvmntPilotDetails(_pxyMovement); // TFS 44438	
epilog
	//delete allPilots; // TFS 44438 after 040 cut/release
	delete allMovementPilotDetails; // TFS 44438
end;</source>
        <Parameter name="_pxyMovement" type="HMS_VoyageMovement" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setResourceCellText" id="566346e0-0b07-472a-95a0-5fc31cebfd83">
        <updating/>
        <source>setResourceCellText(table : Table input; _newRow : Integer; _newCol : Integer) updating;
//--------------------------------------------------
// Created:	24 February 2005 By: cnwgd1
//--------------------------------------------------
vars
	cntrl : Control;	
begin
	
	if (not table.userInputEnabled)
	or table.row &lt;= table.fixedRows then
		return;
	endif;
		
	if table.accessCell(table.row, table.column).enabled then
		cntrl := table.accessedCell.cellControl;
		if TextBox.hasInstance(cntrl) then
			if CMUI_DateMask.hasInstance(cntrl) then
				table.accessedCell.text := cntrl.CMUI_DateMask.getDate().shortFormatJMT();
			elseif CMUI_TimeMask.hasInstance(cntrl) then
				table.accessedCell.text := cntrl.CMUI_TimeMask.getTime().shortFormatJMT();
			else
				table.accessedCell.text := cntrl.TextBox.text;
			endif;
		elseif ComboBox.hasInstance(cntrl) then
			table.accessedCell.text := cntrl.ComboBox.text;
		endif;
	endif;
	
	if table.accessCell(_newRow, _newCol).enabled then
		cntrl := table.accessedCell.cellControl;
		if TextBox.hasInstance(cntrl) then
		//	table.accessedCell.selected := true;
		//	cntrl.TextBox.selStart := 0;
		//	cntrl.TextBox.selLength := -1;
		//	cntrl.TextBox.selectionStyle := TextBox.SelectionStyle_SelectAll;
		//	cntrl.TextBox.selText := cntrl.TextBox.text;
			table.gotFocus (table);
			//table.setCellSelected(_newRow, _newCol, true);
		endif;		
	endif;	
	
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="_newRow" type="Integer"/>
        <Parameter name="_newCol" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setSelectedResources" id="cfac54a5-fcb9-49c5-8414-6dfd633b6769">
        <source>setSelectedResources();
//--------------------------------------------------
// Created:	06 April 2004 By: cnwgd1
//--------------------------------------------------
vars
	idx : Integer;
	resource : HMS_Resource;
	resourceUsed : HMS_ResourceUsed;
begin
	
	if (not self.shtWharfServices.visible) then
		return;
	endif;
	
	if self.myCurrentMovement = null then
		return;
	endif;
	
	foreach resourceUsed in self.myCurrentMovement.allResourceUsed do
		idx := self.lstWharfServices.findObject(resourceUsed);
		if idx &gt; 0 then
			lstWharfServices.itemSelected[idx] := true;		
			lstWharfServices.itemObject[idx] := resourceUsed;
			continue;
		endif;
		resource := resourceUsed.myResource;
		idx := self.lstWharfServices.findObject(resource);
		if idx &gt; 0 then
			lstWharfServices.itemSelected[idx] := true;		
			lstWharfServices.itemObject[idx] := resourceUsed;
		endif;
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="setTblPilotLaunchForEdit" id="ff446044-8889-41ec-8f7b-2fee8a9254e6">
        <updating/>
        <source>setTblPilotLaunchForEdit() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 May 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement

*/

vars
	numRows,
	fixedRows,
	rowIndex : Integer;
	tmpMovementPilotDetails : HMS_MovementPilotDetails;
	tmpTable : CM_DataTable;
begin
	tmpTable := self.tblResUsed;
	fixedRows := tmpTable.fixedRows+1;
	numRows := tmpTable.rows;
	foreach rowIndex in fixedRows to numRows do
		tmpMovementPilotDetails := tmpTable.accessRow(rowIndex).itemObject.HMS_MovementPilotDetails;
		//disable cells that do not need input
		//self.setTblResourceCells(rowIdx, tmpResourceUsed, tmpResourceUsed.myResourceType);
	endforeach;	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setTblResourceCells" id="0b1697e5-3356-4d6f-9220-264d28e37c7d">
        <updating/>
        <source>setTblResourceCells(_theRow : Integer; _resourceUsed : HMS_ResourceUsed; _resourceType : HMS_ResourceType) updating;
//--------------------------------------------------
// Created:	February 2005 By: cnwgd1
//--------------------------------------------------
vars
	backColour : Integer;
	tmpTable : CM_DataTable;
begin

	tmpTable := self.tblResUsed;
	if _resourceUsed.myVTMISTransaction &lt;&gt; null then
		//Already invoiced, disable row as cannot change once invoiced
		tmpTable.accessRow(_theRow).enabled := false;
		tmpTable.accessRow(_theRow).backColor := Gray;	
		return;
	endif;	
	
	backColour := tmpTable.accessedRow.backColor;
	tmpTable.accessCell(_theRow, self.colResourceType).backColor := White;
	tmpTable.accessCell(_theRow, self.colResource).backColor := White;
	tmpTable.accessCell(_theRow, self.colCreateCharge).backColor := White;	
	tmpTable.accessCell(_theRow, self.colPartOfContract).backColor := White;	
									
	//disable cells that do not need input
	if _resourceType &lt;&gt; null and (not _resourceType.isQuantityRequired) then
		tmpTable.accessCell(_theRow, self.colUnitsUsed).enabled := false;
		tmpTable.accessCell(_theRow, self.colUnitsUsed).backColor := backColour;				
	else
		tmpTable.accessCell(_theRow, self.colUnitsUsed).enabled := true;
		tmpTable.accessCell(_theRow, self.colUnitsUsed).backColor := White;		
	endif;
	
	if _resourceType &lt;&gt; null and (not _resourceType.isActionDateTimeRequired)
	and (not _resourceType.isFromToDateTimeRequired) then
		tmpTable.accessCell(_theRow, self.colDateFrom).enabled := false;
		tmpTable.accessCell(_theRow, self.colTimeFrom).enabled := false;
		tmpTable.accessCell(_theRow, self.colDateTo).enabled := false;
		tmpTable.accessCell(_theRow, self.colTimeTo).enabled := false;
		tmpTable.accessCell(_theRow, self.colDateFrom).backColor := backColour;		
		tmpTable.accessCell(_theRow, self.colTimeFrom).backColor := backColour;		
		tmpTable.accessCell(_theRow, self.colDateTo).backColor := backColour;		
		tmpTable.accessCell(_theRow, self.colTimeTo).backColor := backColour;		
	
	elseif _resourceType &lt;&gt; null and _resourceType.isActionDateTimeRequired
	and (not _resourceType.isFromToDateTimeRequired) then
		tmpTable.accessCell(_theRow, self.colDateTo).enabled := false;
		tmpTable.accessCell(_theRow, self.colTimeTo).enabled := false;
		tmpTable.accessCell(_theRow, self.colDateFrom).enabled := true;
		tmpTable.accessCell(_theRow, self.colTimeFrom).enabled := true;		
		tmpTable.accessCell(_theRow, self.colDateFrom).backColor := White;		
		tmpTable.accessCell(_theRow, self.colTimeFrom).backColor := White;	
		tmpTable.accessCell(_theRow, self.colDateTo).backColor := backColour;		
		tmpTable.accessCell(_theRow, self.colTimeTo).backColor := backColour;		
	else
		//isActionDateTimeRequired not required and isFromToDateTimeRequired is required don't disable any DT columns
		tmpTable.accessCell(_theRow, self.colDateFrom).enabled := true;
		tmpTable.accessCell(_theRow, self.colTimeFrom).enabled := true;
		tmpTable.accessCell(_theRow, self.colDateTo).enabled := true;
		tmpTable.accessCell(_theRow, self.colTimeTo).enabled := true;		
		tmpTable.accessCell(_theRow, self.colDateFrom).backColor := White;		
		tmpTable.accessCell(_theRow, self.colTimeFrom).backColor := White;		
		tmpTable.accessCell(_theRow, self.colDateTo).backColor := White;		
		tmpTable.accessCell(_theRow, self.colTimeTo).backColor := White;		
	endif;			


	// ### PAR 10579 CCMS 1350
	if not self.canUpdateFull then
		if not self.canUpdatePartial then
			// View Only
			tmpTable.accessRow(_theRow).enabled := false;
		else
			// Partial Only - no generate invoiceline now or in/out contract
			tmpTable.accessCell(_theRow, self.colPartOfContract).enabled := false;
			tmpTable.accessCell(_theRow, self.colCreateCharge).enabled := false;
		endif;
	endif;

end;</source>
        <Parameter name="_theRow" type="Integer"/>
        <Parameter name="_resourceUsed" type="HMS_ResourceUsed"/>
        <Parameter name="_resourceType" type="HMS_ResourceType"/>
    </JadeMethod>
    <JadeMethod name="setTblResourceForEdit" id="99261565-fd00-4d25-b9e9-8c82c6d88ba6">
        <updating/>
        <source>setTblResourceForEdit() updating;
//--------------------------------------------------
// Created:	February 2005 By: cnwgd1
//--------------------------------------------------
vars
	numRows,
	fixedRows,
	rowIdx : Integer;
	tmpResourceUsed : HMS_ResourceUsed;
	tmpTable : CM_DataTable;
begin

	tmpTable := self.tblResUsed;
	fixedRows := tmpTable.fixedRows+1;
	numRows := tmpTable.rows;


	foreach rowIdx in fixedRows to numRows do
		tmpResourceUsed := tmpTable.accessRow(rowIdx).itemObject.HMS_ResourceUsed;
		//disable cells that do not need input
		self.setTblResourceCells(rowIdx, tmpResourceUsed, tmpResourceUsed.myResourceType);
	endforeach;	

end;</source>
    </JadeMethod>
    <JadeMethod name="setToViewMode" id="ecda3b25-d450-40f1-b79f-b969938973b1">
        <updating/>
        <source>setToViewMode() updating, protected;
//--------------------------------------------------
// Created:	05 April 2005 By: cnwgd1
//--------------------------------------------------
vars

begin

	if self.isFirstActivateComplete
	and self.mode = self.Mode_View then
		return;
	endif;

	self.mode := self.Mode_View;
	
	self.setEnableObjects(false);

	if (not self.viewOnly) then
		self.btnDelete.enabled := true;		
		self.btnEdit.enabled := true;
		self.btnNew.enabled := true;
	else
		self.btnDelete.enabled := false;		
		self.btnEdit.enabled := false;
		self.btnNew.enabled := false;
	endif;

	self.cmbHMSVoyage.enabled := true;
	self.cmbMovements.enabled := true;	
	self.btnSaveBase.enabled := false;
	self.btnCancelBase.enabled := false;	
	
	self.btnTimings.enabled :=  true;	//20 Jun 2018	NDL	TFS 39215
		
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupContextMenuItems" id="a56e5841-3863-4a4d-ad32-b35cdefbf730">
        <updating/>
        <source>setupContextMenuItems(conwin: Window input) updating;
//--------------------------------------------------
// Created:	15 February 2005 By: cnwgd1
//--------------------------------------------------
// 07 May 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement

vars
	obj : Object;
begin
	
	self.mnuResourceContext.visible := false;
	self.mnuResourceAdd.visible := false;
	self.mnuResourceDelete.visible := false;
	self.mnuResourceDelete.userObject := null;

	self.mnuPilotLaunchContext.visible := false; // --&gt; TFS 44438
	self.mnuPilotLaunchAdd.visible := false;
	self.mnuPilotLaunchDelete.visible := false;
	self.mnuPilotLaunchDelete.userObject := null; // &lt;-- TFS 44438

	if self.mode = self.Mode_Update then // TFS 44438
		if /*and*/ self.fldMain.topSheet = self.shtResources then // TFS 44438
			self.mnuResourceAdd.visible := true;
			if self.tblResUsed.row &gt; self.tblResUsed.fixedRows then					
				self.mnuResourceDelete.visible := true;	
				self.mnuResourceDelete.userObject := self.tblResUsed.accessRow(self.tblResUsed.row).itemObject;	
			endif;
		elseif self.fldMain.topSheet = self.shtMarineService then // --&gt; TFS 44438
			self.mnuPilotLaunchAdd.visible := true;
			if self.tblPilotLaunch.row &gt; self.tblPilotLaunch.fixedRows then					
				self.mnuPilotLaunchDelete.visible := true;	
				self.mnuPilotLaunchDelete.userObject := self.tblPilotLaunch.accessRow(self.tblPilotLaunch.row).itemObject;	
			endif;			
		endif; // &lt;-- TFS 44438
	endif;

	// ### PAR 10579 CCMS 1350
	if not self.canUpdateFull then
		if not self.canUpdatePartial then
			// View Only
			self.mnuResourceAdd.visible := false;
			self.mnuResourceDelete.visible := false;
			self.mnuResourceDelete.userObject := null;
			self.mnuPilotLaunchAdd.visible := false; // --&gt; TFS 44438
			self.mnuPilotLaunchDelete.visible := false;
			self.mnuPilotLaunchDelete.userObject := null; // &lt;-- TFS 44438			
		else
			// Partial Only - no deleting contract lines
			obj := self.tblResUsed.accessRow(self.tblResUsed.row).itemObject;
			if obj.isKindOf(HMS_ResourceUsed) then
				if obj.HMS_ResourceUsed.partOfContract then
					self.mnuResourceDelete.visible := false;
					self.mnuResourceDelete.userObject := null;				
				endif;
			endif;
		endif;
	endif;
end;</source>
        <Parameter name="conwin" type="Window" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="a619290f-3eed-41ab-a9e2-2914d7f5b90c">
        <updating/>
        <source>setupForm() updating;
//--------------------------------------------------
// Created:	27 October 2005 By: cnwgd1
//--------------------------------------------------
begin
	inheritMethod();
	
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;	
	self.showToolbar := true;	
	self.viewOnly := (not app.myCurrentUserCan(self.myTerminal, PmHMSMovementsMaint));	
	self.initForm();
	
// cnwdad1 11/07/2008 - PAR #17493.
	if self.myTerminal.myHarbour = null then
		app.raiseCMException1(HMSNoHarbourForTerminal, self.myTerminal.name, null, null);
		self.unloadForm();
		return;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="showWithObjectMode" id="75c7c9f7-d5a6-401e-bdb2-d732ce13045e">
        <updating/>
        <source>showWithObjectMode(_object: HMS_VoyageMovement; _doMode: Boolean) updating;
//--------------------------------------------------
// Created:	27 October 2005 By: cnwgd1
//--------------------------------------------------
vars

 failedDAC  :CM_DataAccessController;

begin
	inheritMethod(_object, _doMode);
	
	if _object &lt;&gt; null then
		if _object.canUserAccessSelf(null, failedDAC,  app.myPassport) then
			self.myCurrentMovement := _object;		

			if _doMode 
			and (not self.myCurrentMovement.archived) then
				// set to update mode. self.loadDataForFirstTime() will init form in update mode for the selected movement
				self.mode := self.Mode_Update;
		
			elseif _doMode then
				// set to add mode. self.loadDataForFirstTime() will init form in add mode
				self.mode := self.Mode_Add;	
			endif;
		endif;		
	endif;
	
	self.show();

end;</source>
        <Parameter name="_object" type="HMS_VoyageMovement"/>
        <Parameter name="_doMode" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showWithObjectResourceUsed" id="df27e42e-3490-458e-bdfd-af5060cadf2a">
        <source>showWithObjectResourceUsed(_resUsed : HMS_ResourceUsed);
// ---------------------------------------------------------------------------
// Created:		12 August 2005  By Andrew Bishop cnwab1
//
// Purpose:		Flips to the correct TAB and hightlights the field where necessary
//
// ---------------------------------------------------------------------------
// 30 Apr 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement
// 24 May 2019	jlgsl4	TFS 44932 - PEL1 - null myPilotLaunch causes 1090 

vars
	resource, mResource : HMS_Resource;
	resourceType : HMS_ResourceType;
	move : HMS_VoyageMovement;
	idx : Integer;
	aTug : HMS_Tug;
	pilot : HMS_Pilot;
	movementPilotDetails : HMS_MovementPilotDetails; // TFS 44438	
begin
	if _resUsed = null then
		self.fldMain.topSheet := self.shtGeneral;
		return;
	endif;
	
	resource := _resUsed.myResource;
	resourceType := _resUsed.myResourceType;
	move := _resUsed.myVoyageMovement;
	
	if resourceType &lt;&gt; null then
		if resourceType.isMarineService then
			//### TUGS
			aTug := move.allTugsUsed.first;
			if aTug &lt;&gt; null then
				mResource := aTug.getResourceForHarbourMovement(move.myHarbour,move.moveType);
				if mResource &lt;&gt; null then
					if mResource = resource then
						self.fldMain.topSheet := self.shtMarineService;
						return;
					endif;
				endif;
			endif;	

			//### BERTH
			if move.getMyBerth &lt;&gt; null then
				mResource := move.getMyBerth.myWharf.getResourceForHarbourMovement(move.moveType,HMS_Wharf.First_Resource);
				if mResource &lt;&gt; null then
					if mResource = resource then
						self.fldMain.topSheet := self.shtGeneral;
						self.cmbToBerth.setFocus();
						return;
					endif;
				endif;
				mResource := move.getMyBerth.myWharf.getResourceForHarbourMovement(move.moveType,HMS_Wharf.Second_Resource);
				if mResource &lt;&gt; null then
					if mResource = resource then
						self.fldMain.topSheet := self.shtGeneral;
						return;
					endif;
				endif;
			endif;


			self.fldMain.topSheet := self.shtMarineService;
			//### PILOT
			/*if move.getUnConvertedMyPilotRef &lt;&gt; null then // --&gt; TFS 44438
				mResource := move.getUnConvertedMyPilotRef.getResourceForHarbourMovement(move.myHarbour,move.moveType);
				if mResource &lt;&gt; null then
					if mResource = resource then
						self.fldMain.topSheet := self.shtMarineService;					
						//self.cmbPilot.setFocus();
						self.lstPilots.setFocus();	//30 Oct 2018	NDL	TFS 41662
						return;
					endif;
				endif;
	  else*/if not move.allMovementPilotDetails.isEmpty then // &lt;-- TFS 44438
				foreach movementPilotDetails in move.allMovementPilotDetails do
					mResource := movementPilotDetails.myPilot.getResourceForHarbourMovement(move.myHarbour,move.moveType);
					if mResource &lt;&gt; null then
						if mResource = resource then
							self.fldMain.topSheet := self.shtMarineService;					
							self.lstPilots.setFocus();	
							return;
						endif;
					endif;
				endforeach; // &lt;-- TFS 44438
			/*elseif not move.allPilots.isEmpty then	//31 Oct 2018	NDL	TFS 41662 // --&gt; TFS 44438
				foreach pilot in move.allPilots do
					mResource := pilot.getResourceForHarbourMovement(move.myHarbour,move.moveType);
					if mResource &lt;&gt; null then
						if mResource = resource then
							self.fldMain.topSheet := self.shtMarineService;					
							self.lstPilots.setFocus();	
							return;
						endif;
					endif;
				endforeach;*/ // &lt;-- TFS 44438
			endif;
			//### LINE COMPANY
			if move.myLineCompany &lt;&gt; null then
				mResource := move.myLineCompany.getResourceForHarbourMovement(move.myHarbour,move.moveType);
				if mResource &lt;&gt; null then
					if mResource = resource then
						self.fldMain.topSheet := self.shtMarineService;
						self.cmbLineCompany.setFocus();
						return;
					endif;
				endif;
			endif;
			//### PILOT LAUNCH
			if not move.allMovementPilotDetails.isEmpty then // --&gt; TFS 44438
				foreach movementPilotDetails in move.allMovementPilotDetails do
					if movementPilotDetails.myPilotLaunch &lt;&gt; null then // TFS 44932
						mResource := movementPilotDetails.myPilotLaunch.getResourceForHarbourMovement(move.myHarbour,move.moveType);
						if mResource &lt;&gt; null then
							if mResource = resource then
								self.fldMain.topSheet := self.shtMarineService;					
								self.cmbPilotLaunch.setFocus();	
								return;
							endif;
						endif;
					endif; // TFS 44932
				endforeach;
			endif; // &lt;-- TFS 44438
			/*if move.myPilotLaunch &lt;&gt; null then // --&gt; TFS 44438
				mResource := move.myPilotLaunch.getResourceForHarbourMovement(move.myHarbour,move.moveType);
				if mResource &lt;&gt; null then
					if mResource = resource then
						self.fldMain.topSheet := self.shtMarineService;
						self.cmbPilotLaunch.setFocus();
						return;
					endif;
				endif;
			endif;*/
		else
			self.fldMain.topSheet := self.shtResources;
			if self.tblResUsed.findObjectInRow(_resUsed, idx) then
				self.tblResUsed.row := idx;
			endif;
		endif;
	endif;
	
end;</source>
        <Parameter name="_resUsed" type="HMS_ResourceUsed"/>
    </JadeMethod>
    <JadeMethod name="stringOrNull" id="0f3ec281-1949-434c-8f04-46ef92f79541">
        <source>stringOrNull(_value : Integer): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
10 July 2024	navcs2	Bug 64769: MSL- IMT- Unable to manage the movements in Harbor management

*/

vars

begin
	if _value = null then
		return null;
	else
		return _value.asStringJMT;
	endif;
epilog

end;</source>
        <Parameter name="_value" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="tblPilotLaunch_contextMenu" id="bb5ea118-6509-4afa-949d-ac1272708661">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblPilotLaunch_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; _x: Integer; _y: Integer):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 May 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement

*/

vars
	xLeft 	: Real;
	yTop	: Real;
	obj : Object;
begin
	if self.mode = self.Mode_View then
		return false;
	endif;
	xLeft := _x;
	yTop := _y;

	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);   // convert x, y relative to form
	self.mnuPilotLaunchDelete.userObject := table.accessRow(table.row).itemObject;	
	self.mnuPilotLaunchDelete.visible := true;
	self.popupMenu(self.mnuPilotLaunchContext, xLeft.Integer, yTop.Integer);
	return true;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="_x" type="Integer"/>
        <Parameter name="_y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblPilotLaunch_keyDown" id="b6c8c70b-0882-4899-8719-6adfd39873cb">
        <controlMethod name="CM_DataTable::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblPilotLaunch_keyDown(table: Table input; keyCode: Integer io; shift: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 May 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement

*/

vars
begin
	if table.userInputEnabled and table.row &gt; table.fixedRows and shift = 0
		and keyCode = J_key_Tab then
		self.origValueInteger := table.rows;
		//if at the end of the last row then a new row will be added
		self.doQueryRowColumnChange(table, table.row+1);
		if table.rows &gt; self.origValueInteger then
			//A new row has been added, reset key code
			//To prevent jade from re-setting the column
			keyCode := 0;
		endif;
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblPilotLaunch_queryRowColChg" id="ed3ac8d0-e77d-43c5-be46-acd29285bb35">
        <controlMethod name="CM_DataTable::queryRowColChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblPilotLaunch_queryRowColChg(table: Table input; newSheet: Integer; newRow: Integer; newCol: Integer):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 May 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement

*/

vars

begin
	self.setPilotLaunchCellText(table, newRow, newCol);
	return true;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="newSheet" type="Integer"/>
        <Parameter name="newRow" type="Integer"/>
        <Parameter name="newCol" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblResUsed_contextMenu" id="fbc78a6c-263a-4325-bd4b-965d39393fec">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblResUsed_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
//--------------------------------------------------
// Created:	24 February 2005 By: cnwgd1
//--------------------------------------------------
vars
	xLeft 	: Real;
	yTop	: Real;
	obj : Object;
begin
	if self.mode = self.Mode_View then
		return false;
	endif;
	xLeft := x;
	yTop := y;

	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);   // convert x, y relative to form
	self.mnuResourceDelete.userObject := table.accessRow(table.row).itemObject;	

	// ### PAR 10579 CCMS 1350
	self.mnuResourceDelete.visible := true;
	if not self.canUpdateFull then
		if not self.canUpdatePartial then
			// View Only
			self.mnuResourceAdd.visible := false;
			self.mnuResourceDelete.visible := false;
			self.mnuResourceDelete.userObject := null;				
		else
			// Partial Only - no deleting contract lines
			obj := table.accessRow(table.row).itemObject;
			if obj.isKindOf(HMS_ResourceUsed) then
				if obj.HMS_ResourceUsed.partOfContract then
					self.mnuResourceDelete.visible := false;
					self.mnuResourceDelete.userObject := null;				
				endif;
			endif;
		endif;
	endif;



	self.popupMenu(self.mnuResourceContext, xLeft.Integer, yTop.Integer);
	
	return true;	
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblResUsed_dblClick" id="99e2d468-9637-4d7e-8afb-52ee7646ff47">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblResUsed_dblClick(table: CM_DataTable input) updating;
//--------------------------------------------------
// Created:	16 February 2005 By: cnwgd1
//--------------------------------------------------
vars
	inv : CM_Invoice;
	invLine : CM_InvoiceLine;
	anObject : Object;
	tmpRow,
	tmpCol	: Integer;
begin
//	tmpRow := table.row;
	
	tmpRow := table.getRowFromY(table.origYPos);
	
	//Par12072 Resolves the UHE for invalid table rows.  Leave if we don't have a valid row.
	if tmpRow = 0 then
		return;
	endif;
	tmpCol := table.column;
	if tmpRow = table.fixedRows then
		self.tblResUsed.resortTableByColumn(tmpCol);
		self.tblResUsed.colourRows(self.colorRow1, self.colorRow2);		
	elseif app.getMyUser.canDo(self.myTerminal,PmAdmInvoicelistView) then
		anObject := table.accessRow(tmpRow).itemObject;
		if anObject.isKindOf(HMS_ResourceUsed) then
			if anObject.HMS_ResourceUsed.myVTMISTransaction &lt;&gt; null then
				invLine := anObject.HMS_ResourceUsed.myVTMISTransaction.allInvoiceLines.first;
				if invLine &lt;&gt; null then
			
					inv := invLine.invoice;
					self.myAssistant.showInvoiceForm(inv, self.myMasterMenuAction);
				endif;
			endif;
		endif;
	endif;
	// need to validate that this is date column
	if tmpRow &gt; table.fixedRows 
	and table.accessRow(tmpRow).enabled
	and  (tmpCol = self.colDateFrom or tmpCol = self.colDateTo) then
		table.showCalenderForm(tmpRow, tmpCol);
	endif;
end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblResUsed_keyDown" id="c98a863d-b892-4e66-b2d7-e05a8e0877e3">
        <controlMethod name="CM_DataTable::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblResUsed_keyDown(table: Table input; keyCode: Integer io; shift: Integer) updating;
//--------------------------------------------------
// Created:	16 February 2005 By: cnwgd1
//--------------------------------------------------
vars
begin
	if table.userInputEnabled
	and table.row &gt; table.fixedRows
	and shift = 0
	and keyCode = J_key_Tab then
		self.origValueInteger := table.rows;
		//if at the end of the last row then a new row will be added
		self.doQueryRowColumnChange(table, table.row+1);
		if table.rows &gt; self.origValueInteger then
			//A new row has been added, reset key code
			//To prevent jade from re-setting the column
			keyCode := 0;
		endif;
	endif;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblResUsed_queryRowColChg" id="3cc7c623-b4f7-453e-bcea-ace0e183a925">
        <controlMethod name="CM_DataTable::queryRowColChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblResUsed_queryRowColChg(table: Table input; newSheet: Integer; newRow: Integer; newCol: Integer):Boolean updating;
//--------------------------------------------------
// Created:	25 February 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.setResourceCellText(table, newRow, newCol);
	return true;					
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="newSheet" type="Integer"/>
        <Parameter name="newRow" type="Integer"/>
        <Parameter name="newCol" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="f69386e3-5943-4cfc-baf3-dbb532d040ab">
