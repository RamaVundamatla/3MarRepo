<CollClass name="WS_ErrorMessageArray" id="34178fcb-c237-4b10-bba6-e42e5b06e1ef">
    <loadFactor>66</loadFactor>
    <memberType name="WS_ErrorMessage"/>
    <superclass name="ObjectArray"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <JadeMethod name="includesError" id="33ab0ef3-864a-4147-a7f5-860a8ee0dd19">
        <source>includesError( _error : Integer ): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 October 2015	cnwndl1	Initial creation	Par 36946

*/

vars

	iter : Iterator;
	wsError : WS_ErrorMessage;
begin

	iter := self.createIterator;
	while iter.next( wsError ) do
		if wsError.errorCode = _error then
			return true;
		endif;
	endwhile;
	
	return false;

epilog

	delete iter;

end;</source>
        <Parameter name="_error" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</CollClass>
