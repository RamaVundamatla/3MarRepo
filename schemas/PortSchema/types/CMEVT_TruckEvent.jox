    <JadeMethod name="getSealDetails" id="d8f82e5b-8966-42b2-a881-f6fb5dfc904a">
        <source>getSealDetails() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
06 April 2023		jlizm1	Initial creation TFS 57098 EUP Seal numbers on trucks

*/

vars
	any : Any;
	
begin
	any := self.getExtraData(self.SealDetails);
	
	if any = null or not any.isKindOf(String) then
		return null;
	endif;
	
	return any.String;	
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTruckSealCheckDetailsString" id="f9920ce8-1bb4-4c1f-990b-cd20bb289679">
        <source>getTruckSealCheckDetailsString() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
06 April 2023		jlizm1	Initial creation TFS 57098 EUP Seal numbers on trucks

*/

vars
	
	any 				: Any;
	str 				: String;
	allSealCheckDetails : CM_SealCheckDetailSet;
	sealCheckDetail 	: CM_SealCheckDetail;
	
begin

	any := self.getExtraData( self.AllSealCheckDetails );
	
	if any = null then
		return null;
	else
		if any.isKindOf( CM_SealCheckDetailSet ) then
		
			allSealCheckDetails := any.CM_SealCheckDetailSet;
			
			if not allSealCheckDetails.isEmpty then
				sealCheckDetail := allSealCheckDetails.first();
				str := sealCheckDetail.getSealCheckTypeString;
			endif;
			
			// now get the specific detail for each one.
			foreach sealCheckDetail in allSealCheckDetails do
				if str = null then
					str := sealCheckDetail.displayDetails;
				else
					str := str &amp; ", " &amp; sealCheckDetail.displayDetails;
				endif;
			endforeach;
			
			return str;
	
		endif;
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
