    <JadeMethod name="setProxyForCreate" id="ae609170-d8c1-4b77-a924-b9a409f8e984">
        <updating/>
        <source>setProxyForCreate(_tempCarr: Real; _humidity: Decimal; _ventilation: Decimal; _expiryDate: Date; _remarks: String; 
								_coolingType, _voltageType :Integer; _oxygen, _carbonDioxide: Decimal;
								_curtainsIn: Boolean; _packDate: Date; _packTime: Time; _remaining: Decimal; _packTemp: Real; _extMonitor: Boolean) updating;
/*

Purpose:			 // TFS 45590

Parameters:			

Return Value:		

Date		Who		Reason
01 November 2019	jlgab1	Initial creation

*/

vars

begin
	self.setCarbonDioxide( _carbonDioxide );
	self.curtainsIn := _curtainsIn;
	self.expiryDate := _expiryDate;
	self.setHumidity( _humidity );
	self.setOxygen( _oxygen );
	self.temperature := _tempCarr;
	self.ventilation := _ventilation;
epilog

end;</source>
        <Parameter name="_tempCarr" type="Real"/>
        <Parameter name="_humidity" type="Decimal"/>
        <Parameter name="_ventilation" type="Decimal"/>
        <Parameter name="_expiryDate" type="Date"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_coolingType" type="Integer"/>
        <Parameter name="_voltageType" type="Integer"/>
        <Parameter name="_oxygen" type="Decimal"/>
        <Parameter name="_carbonDioxide" type="Decimal"/>
        <Parameter name="_curtainsIn" type="Boolean"/>
        <Parameter name="_packDate" type="Date"/>
        <Parameter name="_packTime" type="Time"/>
        <Parameter name="_remaining" type="Decimal"/>
        <Parameter name="_packTemp" type="Real"/>
        <Parameter name="_extMonitor" type="Boolean"/>
    </JadeMethod>
