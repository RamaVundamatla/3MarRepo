	inheritMethod();
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResetColours" id="ad901845-dc5a-4e08-b5c5-00ef37cc01a4">
        <source>doResetColours( _parent : Control );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 October 2016	cnwndl1	Initial creation

*/

vars

begin

	if _parent = self.mulResultsCol then
		self.addCompulsoryResultCols( true );
		
	elseif _parent = self.mulSearchCrit then
		self.addCompulsorySearchCriteria( true, null );
		
	elseif _parent = self.mulViewTable then
		self.addCompulsoryViewRows( true );
		
	endif;

epilog

end;</source>
        <Parameter name="_parent" type="Control"/>
    </JadeMethod>
    <JadeMethod name="doResize" id="8626d9b7-020e-4ea0-aef0-08e25e81b4a2">
        <updating/>
        <source>doResize() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 October 2016	cnwndl1	Initial creation	TFS 2850 / 2370

*/

vars

begin

	self.dbcMain.width := self.clientWidth;
	self.dbcMain.height := self.clientHeight;
	
	inheritMethod();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="3ed97bf2-4d68-4dba-af1a-511e5331c947">
        <updating/>
        <source>doSave() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 October 2016	cnwndl1	Initial creation	TFS 2850 / 2370

*/

vars

	proxy : CM_HandHeldConfig;
	real : CM_HandHeldConfig;
	
	searchRows : EntTableRowArray;
	displayCols : EntTableRowArray;
	viewRows : EntTableRowArray;

	ret : Integer;
	load : Boolean;
	tmpConfig : CMIF_ConfigTerminal;

begin

	self.addCompulsorySearchCriteria( true, null );
	self.addCompulsoryResultCols( true );
	self.addCompulsoryViewRows( true );	//07 Dec 2016	NDL	TFS 3008 / 2370

	real := self.myTerminal.getHandHeldConfig( null );
	if real = null then
		create proxy transient;
	else
		app.cmsBeginLoad(load);
		proxy := real.pxyCreateUpdateProxy();
		app.cmsEndLoad(load);
	endif;
	
	proxy.setMyTerminal(self.myTerminal);
	
	create searchRows transient;
	self.mulSearchCrit.getSelected( searchRows );
	proxy.setVisibleSearchRows( searchRows );
	
	create displayCols transient;
	self.mulResultsCol.getSelected( displayCols );
	proxy.setVisibleResultsCols( displayCols );
	
	//07 Dec 2016	NDL	TFS 3008 / 2370
	create viewRows transient;
	self.mulViewTable.getSelected( viewRows );
	proxy.setVisibleViewRows( viewRows );
	
	create tmpConfig transient;
	tmpConfig.setFromPersistentData(self.myTerminal);
	self.updateCMIFConfigFromForm( tmpConfig );
		
	while true do
	
		if real = null then
			app.myTrxCA.trxCreateHHConfig( proxy, real, tmpConfig, app.myPassport );
		else
			app.myTrxUA.trxUpdateHHConfig( proxy, tmpConfig, app.myPassport );
		endif;
		
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			self.loadDataFromObject(self.myTerminal);
			break;
			
		else
			ret := app.showErrorWarningDialog("Hand Held Config", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   ret = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		
		break;
	
	endwhile;
	
epilog

	delete displayCols;
	delete searchRows;
	delete proxy;
	delete tmpConfig;
	app.cmsEndLoad(load);

end;</source>
    </JadeMethod>
