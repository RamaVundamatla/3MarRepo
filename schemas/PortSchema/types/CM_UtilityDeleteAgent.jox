    <JadeMethod name="utlDeleteFPDateTime" id="905cb130-8e9f-4f99-bb16-01fb625c444d">
        <source>utlDeleteFPDateTime(_financialPeriodDateTime:CM_FinancialPeriodDateTime io; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	app.myValDA.valFPDateTime(_financialPeriodDateTime);
	
	if (not self.checkValidationWithPassport(_passport)) then // Show any Errors and Warnings in a list
		return;
	endif;


	app.setContinueCMExceptions(false);

	if _passport.noErrors then
		self.myDeleteAuditAgent.audDeleteGeneric(_financialPeriodDateTime);
	endif;

	if _passport.noErrors then
		if _passport.noErrors then
//			_passport.myTerminal.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_FINPERIOD_DELETE),false,_financialPeriodDateTime);
			app.myRoot.causeEvent(EVENT_FINPERIOD_DELETE,false,_financialPeriodDateTime);
			_financialPeriodDateTime.erase(NORMAL_ERASE);
		endif;
	endif;

epilog
	return;

end;</source>
