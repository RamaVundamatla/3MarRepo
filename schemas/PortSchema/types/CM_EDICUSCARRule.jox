    <JadeMethod name="validate" id="6d697405-9b7d-45c7-a020-1b03dac9f211">
        <source>validate(_passport :CM_Passport input);

/*

Purpose:			

Parameters:			

Return Value:		
/* Changes

Date		Name	TFS#		Description
============================================================================
21 May 2014	cnwrd1				Initial creation
20 May 2019	jlgka1	42732		PNL - CUSCAR (Bayplan-Style)
============================================================================*/

vars
	ruleItem		:String;
	ruleFunction, 
	type			:Integer;
begin
	self.raiseExceptionIfNotTransient (method);
	
	ruleItem 	:= self.item;
	type 		:= self.myEDIPartyRules.getType;
	
	if ruleItem = null then
		app.raiseCMException (EDI_Party_Error6, null, null);
	elseif type = EDIFileType_CusCar 
		   and (ruleItem = self.Item_LOC_1_1 
		   or   ruleItem = self.Item_FTX_1_1
		   or 	ruleItem = self.Item_NAD_1_1) then
			//ok
	else
		// we expect GUI to take care of this (including not passing in null values)
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Item is not supported');
	endif;
	
	ruleFunction := self.function;
	
	if ruleFunction = null then
		app.raiseCMException (EDI_Party_Error8, null, null);
	endif;
	
	if ruleItem = self.Item_LOC_1_1 then
		if ruleFunction &lt;&gt; null then
			if ruleFunction &lt;&gt; self.Function_LOC_1_1_TODO then
				app.raiseUnexpectedProgramError (self.class.name, method.name, 'Function is not supported');
			endif;
		endif;
	elseif ruleItem = self.Item_FTX_1_1 then
		if ruleFunction &lt;&gt; null then
			if ruleFunction &lt;&gt; self.Function_FTX_1_1_Remarks
			and ruleFunction &lt;&gt; self.Function_FTX_1_1_Description	//29 Jan 2020	NDL	TFS 48360
			then
				app.raiseUnexpectedProgramError (self.class.name, method.name, 'Function is not supported');
			endif;
		endif;
	elseif ruleItem = self.Item_NAD_1_1 then
		if ruleFunction &lt;&gt; null then
			if ruleFunction &lt;&gt; self.Function_NAD_1_1_Consignee then
				app.raiseUnexpectedProgramError (self.class.name, method.name, 'Function is not supported');
			endif;
		endif;
	endif;
	
	if self.value = null then
		if ruleFunction = self.Function_FTX_1_1_Description then
			//no value required.
		else
			app.raiseCMException (EDI_Party_Error7, null, null);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
