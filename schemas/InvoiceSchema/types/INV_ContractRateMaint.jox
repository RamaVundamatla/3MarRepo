    <JadeMethod name="clearFields" id="e71ebcaf-7ef6-4a8b-a855-632526844b0e">
        <updating/>
        <source>clearFields()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Feb 2023 navtnr20	TFS CR 55646 Task 55665: UI - Contract Details

*/

vars
	localTS : TimeStamp;
begin
	self.cmbInvoiceLine.text := null;
	self.cmbUnitOfMeasure.text := null;
	self.cmbShippingTerm.text:= null;
	self.cmbCalculationTypes.text := null;
	
	// ### TFS BUG 58796 26JUN2023 NAVAB1 start
	localTS := self.systemToLocalTime(self.myInvoiceContract.fromTS);
	self.mskContractFromStart.setDate(localTS.date);
	self.mskContractFromStartTime.setTime(localTS.time);
	localTS := self.systemToLocalTime(self.myInvoiceContract.toTS);
	self.mskContractFromEnd.setDate(localTS.date);
	self.mskContractFromEndTime.setTime(localTS.time);
	// ### TFS BUG 58796 26JUN2023 NAVAB1 end
	self.chkVolume.value := false;
	
	//if not self.updateMode then //31/01/2023	navkc1 Bug 61578
	if self.mode = self.MODE_CREATE then
		delete self.myPxyContractDetails;
		create self.myPxyContractDetails transient;
	endif;
	self.setCriteriaLabel(self.myPxyContractDetails);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="cmbInvoiceLine_change" id="4b552fa7-b2d9-452f-9ee0-1198e022bfe5">
        <controlMethod name="ComboBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbInvoiceLine_change(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Feb 2023 navtnr20	TFS CR 55646 Task 55665: UI - Contract Details

*/

vars

begin
	self.myInvLineDescription := combobox.listObject.CM_InvoiceLineDesc;
	if self.myInvLineDescription &lt;&gt; null then
		self.doCmbUOMBuild();
		self.doCmbServicesBuild();
		self.doCmbCalculationTypes(self.myInvLineDescription);// ### TFS BUG 59913 31AUG2023 NAVAB1
	endif;
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbInvoiceLine_click" id="8f3303b0-5210-4404-818b-8953b4e8c867">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbInvoiceLine_click(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Feb 2023 navtnr20	TFS CR 55646 Task 55665: UI - Contract Details
28 Aug 2023 navhl20 	Bug 59914: FR | EUP 54089 - Inv Contract - Default UOM and Calc Type
*/

vars

begin
	self.myInvLineDescription := combobox.listObject.CM_InvoiceLineDesc;
	if self.myInvLineDescription &lt;&gt; null then
		self.doCmbUOMBuild();
		self.doCmbServicesBuild();
		self.doCmbCalculationTypes(self.myInvLineDescription);								//28.8.2023 navhl20 #59914// ### TFS BUG 59913 31AUG2023 NAVAB1
	endif;
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
