    <JadeMethod name="translateForm" id="2225782f-f0d7-4ef4-a580-d63c4a5887c8">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0006998, locale);
	btnAbort.translateBubbleHelp(Xlat_0003827, locale);
	btnAbort.translateCaption(Xlat_0003831, locale);
	btnAlerts.translateBubbleHelp(Xlat_0003828, locale);
	btnAlerts.translateCaption(Xlat_0003832, locale);
	btnDelete.translateBubbleHelp(Xlat_0003829, locale);
	btnDelete.translateCaption(Xlat_0003833, locale);
	btnRun.translateBubbleHelp(Xlat_0003830, locale);
	btnRun.translateCaption(Xlat_0003834, locale);
	fldPurgeSheet1.translateCaption(Xlat_0003825, locale);
	fldPurgeSheet2.translateCaption(Xlat_0003826, locale);
	mnuColumnOrganiser.translateCaption(Xlat_0006999, locale);
	mnuContext.translateCaption(Xlat_0007000, locale);
	mnuExtra.translateCaption(Xlat_0007001, locale);
	mnuHistoryAll.translateCaption(Xlat_0015835, locale);
	mnuHistoryMonth1.translateCaption(Xlat_0015836, locale);
	mnuHistoryMonth3.translateCaption(Xlat_0015837, locale);
	mnuHistoryWeek1.translateCaption(Xlat_0015838, locale);
end;</source>
    </JadeMethod>
