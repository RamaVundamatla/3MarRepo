    <JadeMethod name="getLocationForMode" id="9018f52a-d204-4eb9-b7fe-49d9824d396a">
        <source>getLocationForMode(_mode : Integer) : CM_LocationsController;
// Use the Bulk Release load controller if we have failed to find a location
vars
	location	: CM_LocationsController;
begin
	location := inheritMethod(_mode);
	if location = null and self.isBulkRelease() and _mode = PLANNING_MODE then
		location := self.myRequest.getVoyageLoadController();
	endif;
	return location;
end;</source>
        <Parameter name="_mode" type="Integer"/>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="getLocationIdActual" id="dce75cc0-0c41-47ec-aa62-4e6d8f7dd2b0">
        <source>getLocationIdActual() : String;
// ---------------------------------------------------------------------------
// Created:     29 October 2003	cnwth2
//
// Purpose:     USED IN LOAD SEQUENCE REPORTS - DO NOT DELETE
//			 
// ----------   ----------  --------------------------------------------------
vars
	ti			: CM_TrackedItem;
	lc			: CM_LocationsController;
	locId		: String;
begin
	ti := self.myTrackedItem;
	if ti = null then
		return null;
	endif;
	
	lc := ti.getPrimaryLocation(REAL_MODE);
	//if onship need the slot id without the voyage code
	if CM_SlotController.hasInstance(lc) then
		locId := lc.CM_SlotController.myBayVoyage.id &amp; ' ' &amp; lc.CM_SlotController.ident;
	else
		locId := lc.getFullId();
	endif;
	
	return locId;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLocationIdActualSeqSheet" id="195ca67e-78d1-45ac-b1bb-91dbdc576972">
        <source>getLocationIdActualSeqSheet() : String;
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	return self.getLocationIdSeqSheetSub(true,true);
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLocationIdPlanned" id="eef86dee-0ed0-4082-835e-8ae75b5c4117">
        <source>getLocationIdPlanned() : String;
// ---------------------------------------------------------------------------
// Created:     29 October 2003	cnwth2
//
// Purpose:     USED IN LOAD SEQUENCES REPORT - DO NOT DELETE
//			 	
// ----------   ----------  --------------------------------------------------
vars
	ti			: CM_TrackedItem;
	lc			: CM_LocationsController;
	locId		: String;
begin
	ti := self.myTrackedItem;
	if ti = null then
		return null;
	endif;
	lc := ti.getRehandleDischPrimaryLocn();
	if lc = null then
		lc := ti.getPrimaryLocation(PLANNING_MODE);
	endif;
	
	if lc = null then
		return null;
	endif;
	
	//if onship need the slot id without the voyage code
	if CM_SlotController.hasInstance(lc) then
		locId := lc.CM_SlotController.myBayVoyage.id &amp; ' ' &amp; lc.CM_SlotController.ident;
	else
		locId := lc.getFullId();
	endif;
	
	return locId;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLocationIdPlannedSeqSheet" id="3fe1006f-3416-41bc-adfa-21219523e6ec">
        <source>getLocationIdPlannedSeqSheet() : String;
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	lc			: CM_LocationsController;
	theString : String;
begin
	if self.myFutureMove = null then // PAR 8204
		return self.getLocationIdSeqSheetSub(false,true);
	endif;
	
	if CM_FutureMovePlanned.hasInstance(self.myFutureMove) then
		lc := self.myFutureMove.CM_FutureMovePlanned.allLocationsControllers.first;
	elseif CM_FutureMoveQueued.hasInstance(self.myFutureMove) then
		if self.myFutureMove.CM_FutureMoveQueued.allLocationsControllers.isEmpty then
			return self.getLocationIdSeqSheetSub(false,true);
		else
			lc := self.myFutureMove.CM_FutureMoveQueued.allLocationsControllers.first;
		endif;
	endif;
	
	if lc &lt;&gt; null and (CM_SlotController.hasInstance(lc)) then
		return lc.CM_SlotController.getStowageId(self.myTrackedItem);
	else
		return self.getLocationIdSeqSheetSub(false,true);
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLocationIdSeqSheetSub" id="89b93d1e-8650-44c9-8a32-454c4f5bf915">
        <source>getLocationIdSeqSheetSub(_actualLocation, _wantSeqSheetInfo : Boolean) : String;
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		On the sequence sheet, and elsewhere they want to see where the TI was and where it was planned to at any stage of the event.
//				This means that when a discharge to planned up, even after that move is complete and the TI is in the yard, they want to see where it
//				was, and where it was planned to.
//
// ---------------------------------------------------------------------------
vars
	wantSeqSheetInfo, 
	showYardPos,
	isCont 				: Boolean;
	ti 					: CM_TrackedItem;
	theLocationID,
	thePLocationID 		: String;
	realLoc,
	plannedLoc			: CM_LocationsController;
	spacePos,
	startPos			: Integer;
	theIndex			: String;
	aFM : CM_FutureMove;
begin

	// in VB this was always set to true;
	wantSeqSheetInfo := _wantSeqSheetInfo;
	ti := self.myTrackedItem;
	if ti = null then
		return null;
	endif;

	realLoc := ti.getPrimaryLocation(REAL_MODE);
	
	// PAR 8214. Cannot just get the first planned location, need to be more precise
	if self.job.jobType = JOB_TYPE_DISCHARGE then
		if self.myRequest.getIsRehandle() then
			aFM := ti.getFutureMoveOfType(PLANNING_MODE,TI_FutureMoveDLRDischarge);
		endif;
	elseif self.job.jobType = JOB_TYPE_LOAD then
		if self.myRequest.getIsRehandle() then
			aFM := ti.getFutureMoveOfType(PLANNING_MODE,TI_FutureMoveDLRLoad);
		endif;
	elseif self.job.jobType = JOB_TYPE_SOB then
		if self.myRequest.isSOB() then
			aFM := ti.getFutureMoveOfType(PLANNING_MODE,TI_FutureMoveSOB);
		endif;
	endif;
	if aFM = null then
		aFM := ti.getFutureMoveOfType(PLANNING_MODE,TI_FutureMovePlanned);
	endif;

	if aFM &lt;&gt; null then
		plannedLoc := aFM.CM_FutureMovePlanned.allLocationsControllers.first;
	else
		plannedLoc := ti.getPrimaryLocation(PLANNING_MODE);
	endif;
	if CM_SlotController.hasInstance(realLoc) then
		theLocationID := realLoc.CM_SlotController.getStowageId(ti);
	elseif realLoc &lt;&gt; null then
		if realLoc.myTerminalArea &lt;&gt; null 
		and not realLoc.myTerminalArea.isTransferArea 
		and not realLoc.myTerminalArea.isA(CM_BlockStack) then
			theIndex := realLoc.getIndexOfTiDisplay(REAL_MODE, ti).String;
		endif;
		theLocationID := realLoc.getFullId() &amp; " " &amp; theIndex;
	else
		theLocationID := ti.locationId;
	endif;
	
	if CM_SlotController.hasInstance(plannedLoc) then
		thePLocationID := plannedLoc.CM_SlotController.getStowageId(ti);
	elseif plannedLoc &lt;&gt; null then
		thePLocationID := plannedLoc.getFullId;
	else
		thePLocationID := ti.plannedLocnId;
	endif;
	
	isCont := ti.isKindOf(CM_Container);
	//--------------------
	//The showing of the OLD yard positions etc are now switchable, we use the config flag to determine
	//what they wish to see globally.
	//--------------------
	showYardPos := ti.myTerminal.getConfig(ShipShowYardPosition).Boolean;

	if self.job.jobType = JOB_TYPE_DISCHARGE then
		if ti.isRehandle then
			if (ti.site = TI_SITE_ONSITE) 
			and (ti.releasedDT.isValid = false 
						or  ti.isARework() ) then		 // PAR 8204
		   		// discharged but not loaded yet
				if (not showYardPos) then
					theLocationID := ti.priorStowageCellID;
				endif;
				if self.status = WLE_COMPLETED then // PAR 8204
					thePLocationID := ti.rehandleLocnId; // PAR 8204;
				endif;
			elseif (ti.site = TI_SITE_ONSHIP) 
			and (ti.releasedDT.isValid) 
			and not ti.isARework() then  // PAR 8204 - will already have a release date if a rework
				// discharged and loaded
				if (not showYardPos) then
					theLocationID := ti.priorStowageCellID;
				endif;
				thePLocationID := ti.priorLocation;
			endif;
			
		//normal import
		elseif ti.site = TI_SITE_ONSITE then		//if discharged
			if self.status = WLE_COMPLETED then // PAR 8204
				if (not showYardPos) then // PAR 8204
					theLocationID := ti.priorStowageCellID; // PAR 8204
				endif; // PAR 8204
				thePLocationID := ti.locationId; // PAR 8204
			else // PAR 8204
				if (not showYardPos) then
					theLocationID := ti.priorStowageCellID;
				endif;
			endif;
		endif;

	elseif self.job.jobType = JOB_TYPE_LOAD then
		if ti.isRehandle then
			if (ti.site = TI_SITE_ONSHIP) then
				if (ti.releasedDT.isValid = false) then	// This is not complete
					//must be still on the ship unworked
					if (not showYardPos) then
						theLocationID := thePLocationID;
					endif;
					thePLocationID := ti.rehandleLocnId;
				else  // PAR 8204 - now complete					
					if (not showYardPos) then // PAR 8204
						theLocationID := ti.priorLocation; // PAR 8204
					endif;
					thePLocationID := ti.locationId; // PAR 8204
				
				endif;
			endif;
		else 
			//normal export load
			if ti.state = TI_STATE_ONSHIP then  // PAR 8204
				//if loaded
				if wantSeqSheetInfo then		
					if self.status = WLE_COMPLETED then // PAR 8204
						if (not showYardPos) then // PAR 8204;
							theLocationID := ti.priorLocation; // PAR 8204;
						endif;
						thePLocationID := ti.locationId; // PAR 8204;
					else // PAR 8204;
							//if on a sequence sheet
						if (not showYardPos) then
							theLocationID := ti.priorLocation;
						endif;
					endif;
				else
					thePLocationID := null;
				endif;
			endif;
		endif;	
	elseif self.job.jobType = JOB_TYPE_SOB then 

		if self.status = WLE_COMPLETED then // PAR 8204
			thePLocationID := ti.locationId; // PAR 8204;
			if (not showYardPos) then // PAR 8204
				theLocationID := ti.priorStowageCellID; // PAR 8204
			endif; // PAR 8204
		elseif ti.receivedDT.isValid then	
			//Shifted
			if (not showYardPos) then
				theLocationID := ti.priorStowage;
			endif;
		else
			theLocationID := ti.locationId;
			thePLocationID := ti.plannedLocnId;
		endif;
	endif;
	
	
	if _actualLocation then
		return theLocationID;
	else
		return thePLocationID;	
	endif;

end;</source>
        <Parameter name="_actualLocation" type="Boolean"/>
        <Parameter name="_wantSeqSheetInfo" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMeasurementStringForAttrib" id="b87faa54-8ec2-4bff-9e9c-643fbf28f84f">
        <source>getMeasurementStringForAttrib(_attrName: String; _measureType: String; _short: Boolean): String;
/*
Purpose:			

Parameters:			

Return Value:		

Changed On	By			Reason
----------	--------	-----------------------------------------------------
29/04/2013	cnwdap1		Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
15/10/2021	navdap1		TFS 51935 SAL Direct Loading Partial Prenoted Cargo from Truck to Vessel
10/11/2021	navdap1		TFS 52360 SAL Direct Prenote to Voyage Incorrect Job Values
*/
vars
	value : Decimal [16,4];
	density : Decimal [16,4];

begin
	if self.myTrackedItem = null and (_attrName = ETRow_WeightTotal or _attrName = ETRow_MyOperator) and self.myRequest.isBulkRelease then
		// This is a bulk release that has not yet been actioned	
		return app.convertMeasurementForDisplay(_measureType, self.myRequest.getBulkRelease.getAverageWeight);
	// TFS 52360 start
	elseif self.job &lt;&gt; null and self.job.isKindOf(CM_VoyageHoldJob) then
		if _attrName = ETRow_TotalVolume then
			density := self.getDensity;
		endif;			
		if self.subSeqNum &lt;&gt; null and self.subSeqNum &lt; self.weight then
			if _attrName = ETRow_TotalVolume and density &lt;&gt; null then
				value := self.subSeqNum / density;
			elseif _attrName = ETRow_TotalVolume and density = null then
				value := null;
			else
				value := self.subSeqNum;
			endif;
		else
			if _attrName = ETRow_TotalVolume and density &lt;&gt; null then
				value := self.weight / density;
			elseif _attrName = ETRow_TotalVolume and density = null then
				value := null;
			else
				value := self.weight;
			endif;
		endif;
		return app.convertMeasurementForDisplay(_measureType, value);
	// TFS 52360 end
	endif;
	
	return inheritMethod(_attrName, _measureType, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_measureType" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyTrackedITem" id="46359b6a-685b-4ebc-acf5-8a2dba8fd2a9">
