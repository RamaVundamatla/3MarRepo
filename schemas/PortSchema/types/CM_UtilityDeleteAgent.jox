    <JadeMethod name="utlDeleteStockOrderAllocation" id="80e64257-3459-49c7-9e52-cea78694f472">
        <source>utlDeleteStockOrderAllocation(_allocation: CM_StockOrderAllocation io; _passport : CM_Passport input);
//--------------------------------------------------------------
//Created: July 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	cancelSave : Boolean;
begin
	self.initialiseActivity();

	app.setContinueCMExceptions(true);
	
	app.myValDA.valStockOrderAllocation(_allocation);
	
	if (not self.checkValidationWithPassport(_passport)) then // Show any Errors and Warnings in a list
		return;
	endif;


	app.setContinueCMExceptions(false);

	if _passport.noErrors then
		self.myDeleteAuditAgent.audDeleteGeneric(_allocation);
	endif;
	
	if _passport.noErrors then
		global.causeEvent(_allocation.myStockOrderHeader.myTerminal.getTerminalEvent(StockOrderAlloc_Delete_Event), false, _allocation);									
		if CM_StockOrderLineAlloc.hasInstance(_allocation) then
			if _allocation.CM_StockOrderLineAlloc.myStockOrderSummaryAlloc &lt;&gt; null then
				//Send not for the summary line
				global.causeEvent(LogVoyageOps_Update_Event, false, _allocation.CM_StockOrderLineAlloc.myStockOrderSummaryAlloc.myStockOrderSummary);		
			endif;
		endif;
		//Send not for the order line
		global.causeEvent(LogVoyageOps_Update_Event, false, _allocation.myParent);
		_allocation.erase(NORMAL_ERASE);
	endif;

epilog
	return;
end;</source>
        <Parameter name="_allocation" type="CM_StockOrderAllocation" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteStockOrderLine" id="13481f44-805c-41d5-915b-2a81b6a93066">
