    <JadeMethod name="disableMulSelect1Contents" id="b0eec5e8-a34c-4ac3-ba17-6a594fa1909f">
        <source>disableMulSelect1Contents();
// ---------------------------------------------------------------------------
// Created:     14 July 2005	cnwhjg1
//
// Purpose:     par 10158 - users having problem accidentally deleting table item 
//				when meaning to remove item from one listbox. By disabling contents
//				user will be force to use enter into edit mode before they can 
//				select items in listboxes
// ----------   ----------  --------------------------------------------------
vars
	theForm	:	SOP_TableMaintForm;
	
begin

  	theForm := self.myForm;
	
	theForm.mulSelect1.userInputEnabled := false;	//PAR 12727
	
end;</source>
