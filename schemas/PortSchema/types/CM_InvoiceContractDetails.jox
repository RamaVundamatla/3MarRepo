    <JadeMethod name="auditId" id="62e7f5d1-4201-4c4f-aa42-95eef6d915c2">
        <source>auditId(): String;
/*
Purpose:			

Date		Who		Reason
09 December 2022	navab1	TFS CR 55623 TASK 55785
*/

vars
	auditIdStr : String;
begin

	auditIdStr := self.myInvoiceContract.auditId();

	if self.myInvoiceLineType &lt;&gt; null then
		auditIdStr := auditIdStr &amp; "/" &amp; self.myInvoiceLineType.narration;
	endif;

	auditIdStr := auditIdStr &amp; "/" &amp; self.fromTS.asStringJMT() &amp; "-" &amp; self.toTS.asStringJMT();

	return auditIdStr;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
