    <JadeMethod name="loadCriteriaLines" id="a5096eaf-10d0-488e-8b8d-327d686c917b">
        <source>loadCriteriaLines(_query	:  CM_MenuUserQuery) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2010	cnwer1	Initial creation

*/

vars
	criteriaLineHolder : CM_QueryCriteriaLineHolder;
	criteriaLine 		:  CM_SelectorCriteriaLine;
	dynamicCriteriaLine	: JadeDynamicObject;
	newFrame			: Frame;
	newSheet			: Sheet;
	newFolder			: Folder;
	sheetHeight,
	visibleCriteria 	: Integer;
	rtScreenMode : CM_RTScreenConfig;
begin
	rtScreenMode:=app.myVMAgent.getMyScreenMode();
	self.deleteAllCriteriaLines();
	self.tblQueryResults.rows:=0;

	newFolder:=self.fldCriteria.loadControl(self.controlCount + 1).Folder;
	newFolder.fontSize:=app.myVMAgent.getMyRTVehicleConfig.tableFontSize;
	newFolder.fontName:="Tahoma";
	newFolder.foreColor:=rtScreenMode.screenForeColour;
	newFolder.backColor:=rtScreenMode.screenBackColour;
	
	// to create all QueryCriteriaLineHoldersRT
	foreach criteriaLineHolder in _query.allCriteriaLineHolders do
		visibleCriteria:=0;

		//create new Sheet
		newSheet:=self.shtCriteria.loadControl(self.controlCount + 1).Sheet;
		newSheet.fontSize:=app.myVMAgent.getMyRTVehicleConfig.tableSelectedFontSize;
		newSheet.fontName:="Tahoma";
		newSheet.fontBold:=true;
		newSheet.foreColor:=rtScreenMode.tableSelectColour;
		newSheet.backColor:=rtScreenMode.screenBackColour;
		newSheet.parent:=newFolder;
		newSheet.visible:=true;
		if newFolder.sheets &gt; 1 then
			newSheet.caption:=" -- OR --";
		endif;
		
		foreach criteriaLine in criteriaLineHolder.allCriteriaLines do
			if  criteriaLine.isUnavailableAtRunTime then
				continue;
			endif;
			if not criteriaLine.myQueryProperty.validateCriteriaLineVisibleRT() then
				continue;
			endif;
			
			create dynamicCriteriaLine transient;
			dynamicCriteriaLine.addProperty(self.CriteriaLineProp,CM_SelectorCriteriaLine);
			dynamicCriteriaLine.setPropertyValue(self.CriteriaLineProp,criteriaLine);
			dynamicCriteriaLine.addProperty(self.CriteriaFolder,Folder);
			dynamicCriteriaLine.setPropertyValue(self.CriteriaFolder,newFolder);
			dynamicCriteriaLine.addProperty(self.CriteriaSheet,Sheet);
			dynamicCriteriaLine.setPropertyValue(self.CriteriaSheet,newSheet);
			
			dynamicCriteriaLine.addProperty(self.CriteriaFrame,Frame);
			newFrame:=self.frmCriteria.loadControl(self.controlCount + 1).Frame;
			newFrame.visible:=true;
			newFrame.parent:=newSheet;
			dynamicCriteriaLine.setPropertyValue(self.CriteriaFrame,newFrame);
		
			self.addCriteriaLine(criteriaLine,dynamicCriteriaLine,newFrame);
			self.allCriteriaLines.add(dynamicCriteriaLine);
			visibleCriteria:=visibleCriteria+1;
		endforeach;
		

		sheetHeight:=(newFrame.clientHeight * visibleCriteria).max(sheetHeight);
		
		
	endforeach;
	
	self.fldCriteria.visible:=false;
	self.loadQueryResultsHeading(_query);
	
	dynamicCriteriaLine:=self.allCriteriaLines.first;
	newFrame:=dynamicCriteriaLine.getPropertyValue(self.CriteriaFrame).Frame;
	newFrame.showMySheet();
	
	newSheet:=dynamicCriteriaLine.getPropertyValue(self.CriteriaSheet).Sheet;
	newSheet.top:=0;
	newSheet.height:=sheetHeight;
	

	newFolder.height:=self.clientHeight - self.frmBottom.clientHeight;//newSheet.fontSize + 50 + newSheet.clientHeight ;
	self.frmTop.height:=newFolder.clientHeight;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_query" type="CM_MenuUserQuery"/>
    </JadeMethod>
    <JadeMethod name="loadQueries" id="d601c747-4802-42d5-a66f-5b538aa9da57">
        <updating/>
        <source>loadQueries() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2010	cnwer1	Initial creation

*/

vars

	selectorQueryAccess	: CM_SelectorQueryAccess;
	query				:  CM_MenuUserQuery;
	idx 				: Integer;
	theWidth			: Integer;
	row					: JadeTableRow;
begin

	self.setupControlFromParent(self.tblQueries,self.frmQueries,0,0);
	self.tblQueries.rows:=0;
	self.tblQueries.accessSheet(1).marginTop:=5;
	self.tblQueries.accessSheet(1).marginBottom:=5;
	self.tblQueries.borderStyle:=Table.BorderStyle_None;
	self.tblQueries.selectMode := Table.SelectMode_None;
	self.tblQueries.alignment := Table.Alignment_Center_Top;

	selectorQueryAccess:=app.myVMAgent.getMyRTVehicleConfig.myQueriesForDrivers;
	self.caption:=self.caption &amp; " - " &amp; selectorQueryAccess.description;
	
	foreach query in selectorQueryAccess.allSelectedQueries do
		idx:=self.tblQueries.addItem(query.heading);
		row:=self.tblQueries.accessRow(idx);
		row.itemObject := query;
		
		self.tblQueries.fontSize  :=  app.myVMAgent.getMyRTVehicleConfig.tableSelectedFontSize;
		self.tblQueries.fontBold:=true;
		theWidth:=theWidth.max(self.tblQueries.getTextExtent(query.heading));
		self.tblQueries.fontSize :=  app.myVMAgent.getMyRTVehicleConfig.tableFontSize;
		self.tblQueries.fontBold:=false;
	endforeach;
	
	//self.tblQueries.fitColumnWidths;
	self.tblQueries.accessRow(1);
	self.tblQueries.click(self.tblQueries);
	self.tblQueries.fitTableHeight;
	self.frmQueries.width:=theWidth;//self.tblQueries.clientWidth; //theWidth + 60;
	self.tblQueries.parentAspect:=Control.ParentAspect_None;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadQueryResults" id="072b72d8-a790-4dc8-9c40-2b37ea78f2bc">
        <source>loadQueryResults(	_selectorQuery : CM_MenuUserQuery;
					_enqController	 : CM_EnquiryController) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 June 2010	cnwer1	Initial creation

*/

vars
	any				: Any;
begin
	// allData
	if _enqController.allObjects.size &gt; 0 then
		self.tblQueryResults.visible:=true;
		self.btnRun.caption:=app.getErrorString(Back);
	endif;
	foreach any in _enqController.allObjects do
		self.tblQueryResults.addItem(_selectorQuery.getResultStringForObject(any.Object));
	endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_selectorQuery" type="CM_MenuUserQuery"/>
        <Parameter name="_enqController" type="CM_EnquiryController"/>
    </JadeMethod>
    <JadeMethod name="loadQueryResultsHeading" id="ab6b49dc-b80e-4b26-955c-40b930de1364">
        <source>loadQueryResultsHeading(_selectorQuery : CM_MenuUserQuery) protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01/06/2010	cnwer1	Initial creation
14/10/2013	cnwdap1	PAR #32731 Measurements not showing correctly in queries run in the vehicle apps
*/
vars
	queryProp		: CM_QueryProperty;
	propDict		: CM_QueryPropertyDict;
	theCargoBOLType	: CM_CargoBOLType;
	headingStr 		: String;
	attrName,
	termStr			: String;
	any				: Any;
	queryDef		: CM_QueryDefinition;
	pos, revPos		: Integer;									// PAR #32731
	niceName		: String;									// PAR #32731
	measure			: String;									// PAR #32731
begin

	self.tblQueryResults.rows:=0;
	theCargoBOLType := app.myRoot.allCargoTypesById[_selectorQuery.queryMode];
	queryDef	:= _selectorQuery.getQueryDefinition;
	propDict	:= queryDef.allQueryProperties;
	
	if _selectorQuery.allVisibleColumns.size = 0 then
		return;
	endif;
	self.tblQueryResults.columns := _selectorQuery.allVisibleColumns.size();
	
	headingStr	:= null;
	foreach attrName in _selectorQuery.allVisibleColumns do
		measure := null;										// PAR #32731
		if attrName.isMeasurementType then						// PAR #32731
			pos := attrName.pos("_", 1);						// PAR #32731
			revPos := attrName.reversePos("_");					// PAR #32731
			measure := attrName[revPos+1:end];					// PAR #32731
			attrName := attrName[pos+1:revPos-pos-1];			// PAR #32731
		endif;													// PAR #32731
		queryProp := propDict[attrName];
		if queryProp = null then
			continue;
		endif;	
		termStr := app.getTerminologyAlternate(theCargoBOLType, app.myVMAgent.myTerminal, queryProp.niceName, CM_TermExpressionSingular, queryProp.niceName);
		if measure &lt;&gt; null then									// PAR #32731
			termStr := termStr &amp; Space &amp; measure;				// PAR #32731
		endif;													// PAR #32731
		headingStr := headingStr &amp; termStr &amp; Tab;
	endforeach;
	
	self.tblQueryResults.addItem(headingStr);
	self.tblQueryResults.fixedRows:=1;
	self.tblQueryResults.accessRow(1).backColor:=app.myVMAgent.getMyScreenMode().screenBackColour;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_selectorQuery" type="CM_MenuUserQuery"/>
    </JadeMethod>
    <JadeMethod name="resizeControls" id="66ffd044-3f54-4d43-9d70-a6c8be2b4473">
        <source>resizeControls();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2010	cnwer1	Initial creation

*/
constants
	Margin = 5;
vars
	theWidth,
	theHeight : Integer;
begin
	self.txtSearchValueA.top:=Margin;
	self.txtSearchValueB.top:=Margin;
	self.lblCriteria.top:=Margin;
	self.optFalse.top:=Margin;
	self.optTrue.top:=Margin;
	
	self.frmCriteria.height:=self.txtSearchValueA.clientHeight + (Margin*2);
	
	
	theWidth:=self.btnRun.getTextExtent(app.getErrorString(Run_Query)).max(theWidth);
	theWidth:=self.btnRun.getTextExtent(app.getErrorString(Menu)).max(theWidth);
	
	theWidth:=theWidth + (Margin *2);
	
	if theWidth &gt; self.btnRun.clientWidth then
		self.btnMenu.width:=theWidth;
		self.btnMenu.left:=self.clientWidth - theWidth - Margin;
		self.btnRun.width:=theWidth;
		self.btnRun.left := self.btnMenu.left - theWidth - Margin;
	endif;
	
	//epr par 33025 
	theHeight:=self.btnRun.getTextHeight(app.getErrorString(Run_Query));
	theHeight:= theHeight + (Margin *2);
	self.btnRun.height:=theHeight;
	self.btnMenu.height:=theHeight;
	self.frmBottom.height:=theHeight + (Margin *2);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="runQuery" id="91acd890-82fc-4b7c-bc43-bc8dc39d6e3a">
        <source>runQuery() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 June 2010	cnwer1	Initial creation
// 08 June 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	selectorQuery : CM_MenuUserQuery;
	enqController : CM_EnquiryController;
	jdo				: JadeDynamicObject;
	realCriteriaLineHolder,
	criteriaLineHolder		: CM_QueryCriteriaLineHolder;
	runTimeCriteriaLine,
	realCriteriaLine,
	criteriaLine			: CM_SelectorCriteriaLine;
	searchTxtBoxA,
	searchTxtBoxB			: TextBox;
	optBtnTrue,
	optBtnFalse				: OptionButton;
	searchValueA,
	searchValueB			: String;
	boolValue				: Boolean;
	valueTranslated,
	valueTranslatedTo		: Any;
	dateArray				: DateArray;
	allCriteriaHolders		: ObjectArray;
	obj						: Object;
	queryType				: Integer;
	fromTS 					: TimeStamp;
	toTS 					: TimeStamp;
begin

	self.tblQueryResults.rows:=1;
	on CM_Exception do app.validationExHandler(exception, app.myPassport);
	app.setContinueCMExceptions(true);
	app.myPassport.clearErrorsWarnings();
	
	selectorQuery:=self.tblQueries.accessedRow.itemObject.CM_MenuUserQuery;
	app.myQAFilter.createEnqControllerForMode(selectorQuery.queryMode, selectorQuery.getType, enqController);
	
	enqController.numItemsFoundLimit	:= app.myVMAgent.getMyRTVehicleConfig.maxNumberQueryResults; //epr CCMS 1099 25/5/10 getConfig( MaxRowsForRTQueries ).Integer;
	if enqController.numItemsFoundLimit = null then
		app.msgBox(app.getErrorString( ERR_SetupMaxRowsForRTQueries ),app.getErrorString(Error),MsgBox_OK_Only); // need to setup Max Number of Rows for Queries in the Terminal Configuration
		return;
	endif;
	
	
	create enqController.allObjects as CM_ObjectSet transient;
	create allCriteriaHolders transient;
	
	foreach jdo in self.allCriteriaLines do
		realCriteriaLine:=jdo.getPropertyValue(self.CriteriaLineProp).CM_SelectorCriteriaLine;
		if criteriaLineHolder = null or
			realCriteriaLine.myCriteriaLineHolder &lt;&gt; realCriteriaLineHolder then
			
			realCriteriaLineHolder:=realCriteriaLine.myCriteriaLineHolder;
			criteriaLineHolder := realCriteriaLineHolder.cloneSelf(true);
			criteriaLineHolder.setForUpdate( realCriteriaLineHolder );	
			allCriteriaHolders.add(criteriaLineHolder);
			
			foreach runTimeCriteriaLine in realCriteriaLineHolder.allCriteriaLines where runTimeCriteriaLine.isUnavailableAtRunTime do
				create criteriaLine transient; 
				criteriaLine.setMyCriteriaLineHolder( criteriaLineHolder );
				criteriaLine.setForUpdateForRT( runTimeCriteriaLine );	
			endforeach;
		endif;
		
		searchTxtBoxA:=jdo.getPropertyValue(self.CriteriaSearchA).TextBox;
		if searchTxtBoxA &lt;&gt; null then
			searchValueA:=searchTxtBoxA.text;
			searchTxtBoxB:=jdo.getPropertyValue(self.CriteriaSearchB).TextBox;
			if searchTxtBoxB &lt;&gt; null then
				searchValueB:=searchTxtBoxB.text;
			endif;
		else
			optBtnTrue:=jdo.getPropertyValue(self.CriteriaBoolTrue).OptionButton;
			if optBtnTrue &lt;&gt; null then
				boolValue:=optBtnTrue.value; 
			endif;
			
		endif;
		
		create criteriaLine transient; 
		criteriaLine.setMyCriteriaLineHolder( criteriaLineHolder );
		criteriaLine.setForUpdateForRT( realCriteriaLine );	
		
		if searchValueA &lt;&gt; null then
		
			valueTranslated := criteriaLine.myQueryProperty.translateStringToSearchValue( searchValueA, criteriaLine );
			
			if searchValueB &lt;&gt; null then
				valueTranslatedTo	:= criteriaLine.myQueryProperty.translateStringToSearchValue( searchValueB, criteriaLine );
				
				create dateArray transient;
				fromTS.cnEcSetDateAndTime(valueTranslated.Date,TimeStartOfDay);
				toTS.cnEcSetDateAndTime(valueTranslatedTo.Date,TimeEndOfDay);
				//dateArray.add( valueTranslated.Date );
				//dateArray.add( valueTranslatedTo.Date );
				
				dateArray.add(self.localToSystemTime(fromTS).date() );	// 08 June 2016	cnwns1	TFS 488 - Multi Timezone Support
				dateArray.add(self.localToSystemTime(toTS).date() );	// 08 June 2016	cnwns1	TFS 488 - Multi Timezone Support
				criteriaLine.myQueryOperator.setSearchValue( dateArray );
				delete dateArray;
			else
				criteriaLine.myQueryOperator.setSearchValue( valueTranslated );
			endif;
		else
			valueTranslated := criteriaLine.myQueryProperty.translateStringToSearchValue( boolValue, criteriaLine );
			criteriaLine.myQueryOperator.setSearchValue( valueTranslated );
		endif;	
		
		if app.myPassport.hasErrors then
			app.msgBox(app.myPassport.allErrors.first.text,app.myPassport.allErrors.first.errorCode.asStringJMT,MsgBox_OK_Only);
			return;
		endif;
	endforeach;
	
	
	queryType := selectorQuery.getType;
	foreach obj in allCriteriaHolders do
		criteriaLineHolder:=obj.CM_QueryCriteriaLineHolder;
		enqController.myCriteriaLineHolder := criteriaLineHolder;
		enqController.doQuery( app.myRoot.allQueryDefinitionObjects[queryType, selectorQuery.queryMode] );
		
		if app.myPassport.hasErrors then
			app.msgBox(app.myPassport.allErrors.first.text,app.myPassport.allErrors.first.errorCode.asStringJMT,MsgBox_OK_Only);
			return;
		endif;
	endforeach;
	
	
	if app.myPassport.hasErrors then
		app.msgBox(app.myPassport.allErrors.first.text,app.myPassport.allErrors.first.errorCode.asStringJMT,MsgBox_OK_Only);
		return;
	endif;
	
	self.loadQueryResults(selectorQuery,enqController);
epilog
	delete enqController;
	if allCriteriaHolders &lt;&gt; null then
		allCriteriaHolders.purge;
	endif;
	
	delete allCriteriaHolders;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="af4db1da-f2da-48dd-b54b-bc3dccb32ef5">
        <updating/>
        <source>setupForm() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2010	cnwer1	Initial creation

*/

vars


	
	
begin
	inheritMethod();
	self.tblQueryResults.visible:=false;
	self.tblQueryResults.parent:=self.frmMain;
	self.tblQueryResults.left:=0;
	self.tblQueryResults.top:=0;
	self.tblQueryResults.width:=self.frmMain.clientWidth;
	self.tblQueryResults.height:=self.frmMain.clientHeight -self.frmBottom.clientHeight;
	self.tblQueryResults.selectMode:=Table.SelectMode_None;
	self.tblQueryResults.readOnly:=true;
	self.tblQueryResults.parentAspect:=Control.ParentAspect_StretchBoth;
	self.tblQueryResults.borderStyle:=Control.BorderStyle_None;
	self.tblQueryResults.accessSheet(1).marginBottom:=3;
	self.tblQueryResults.accessSheet(1).marginTop:=3;
	self.tblQueryResults.accessSheet(1).marginLeft:=3;
	self.tblQueryResults.accessSheet(1).marginRight:=3;
	
	self.frmTable.visible:=false;
	self.setupControlFromParent(self.fldCriteria,self.frmTop,0,0);
	if app.isOnDevice() then
		self.windowState := self.WindowState_Maximized;		
	endif;	
	self.setVehicleMountedScreenSize();
	self.updateCaption();
	self.loadQueries();
	self.frmCriteria.visible:=false;
	
	self.btnRun.caption:=app.getErrorString(Run_Query);
	self.btnMenu.caption:=app.getErrorString(Menu);
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="tblQueries_click" id="9abf2e8b-d13c-4904-8cf4-478e6390d612">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblQueries_click(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2010	cnwer1	Initial creation

*/

vars

begin
	self.displayVMTableRow(table,table.row,false);
	self.loadCriteriaLines(table.accessedRow.itemObject.CM_MenuUserQuery);
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblQueries_keyUp" id="1b86405d-4566-4617-9b38-486e409a3674">
        <controlMethod name="Table::keyUp"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblQueries_keyUp(table: Table input; keyCode: Integer io; shift: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 June 2010	cnwer1	Initial creation

*/

vars

begin
	if keyCode = J_key_UpArrow or
		keyCode = J_key_DownArrow then
		table.click(table);
	endif;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="935b8b01-086b-46ce-87f8-725698b8bbff">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0017623, locale);
	btnMenu.translateCaption(Xlat_0014892, locale);
	btnRun.translateCaption(Xlat_0014893, locale);
	lblCriteria.translateCaption(Xlat_0014894, locale);
	optFalse.translateCaption(Xlat_0014895, locale);
	optTrue.translateCaption(Xlat_0014896, locale);
	shtCriteria.translateCaption(Xlat_0014897, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="updateCaption" id="7fb2885b-c452-49c1-857b-21359172264f">
        <updating/>
        <source>updateCaption() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 June 2010	cnwer1	Initial creation

*/

vars
	caption : String;
begin
	caption	:= app.myVMAgent.myMachine.machineTypeString &amp; " " &amp; app.myVMAgent.myMachine.id.asStringJMT;
	self.caption:=caption;

epilog

end;</source>
    </JadeMethod>
</GUIClass>
