    <JadeMethod name="getTranslations" id="7d621a97-986f-4881-9fe3-9552bdee1ce0">
        <source>getTranslations(searchWords : StringArray; translations : XLAT_TranslationByCatAndNumber io);

vars
	word : String;
	keyword : XLAT_Keyword;
	translation : XLAT_Translation;

begin
	foreach word in searchWords do
		keyword := allTranslationKeywords[word];
		if keyword &lt;&gt; null then
			foreach translation in keyword.allTranslations do
				if not translations.includes(translation) then
					translations.add(translation);
				endif;
			endforeach;
		endif;
	endforeach;
end;
</source>
        <Parameter name="searchWords" type="StringArray"/>
        <Parameter name="translations" type="XLAT_TranslationByCatAndNumber" usage="io"/>
    </JadeMethod>
    <JadeMethod name="isUserDefined" id="79f05ecd-d983-4e02-af4e-779a0b9f6641">
        <source>isUserDefined() : Boolean;
/* ---------------------------------------------------------------------------
Created:	04 September 2008	by cnwvu1

Purpose:	Fosr system locales the code should be numeric, 
			for user defined the first cahracter in the code should be letter.
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	i	:Integer;
	
begin

	i := self.localeId[1].String.Integer;
	
	if i = 0 and self.localeId[1].String &lt;&gt; "0" then	//the first character is not number
		return true;
	endif;
	
	if i &gt;= 0 and i &lt;= 9 then
		return false;
	else
		return true;
	endif;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="0ad8da7d-516a-465c-9dee-6ac543710e45">
        <updating/>
        <source>setForCreate(_id : String; _desc : String; _isUserDefined : Boolean; _root : CM_Root) updating;
// ---------------------------------------------------------------------------
// Created:     01 April 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	self.localeId := _id;
	self.localeDescription := _desc;
	self.myRoot := _root;
	
	self.validateForCreate( _isUserDefined );

end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_desc" type="String"/>
        <Parameter name="_isUserDefined" type="Boolean"/>
        <Parameter name="_root" type="CM_Root"/>
    </JadeMethod>
