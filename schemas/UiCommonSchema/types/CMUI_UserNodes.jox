    <JadeMethod name="createTestLockTransactions" id="0723e2a2-a585-48de-838b-62be0f1da505">
        <source>createTestLockTransactions();
// ---------------------------------------------------------------------------
// Created:     13 October 2003 by cnwrs2
//
// Purpose:     Method to create test lock transaction data
//				copy and put into a workspace
// ---------------------------------------------------------------------------
vars
	lockTrans,
	masterTrans	: CM_LockTransaction;
	numToCreate,
	idx,
	offset		: Integer;
	nextTs		: TimeStamp;

begin

	numToCreate	:= 100;
	
	masterTrans := CM_LockTransaction.firstInstance;
	if masterTrans = null then
		app.writeStatement( 'need a master transaction to create from');
		return;
	endif;
	
	nextTs := app.actualTimeServer;
	
	foreach idx in 1 to numToCreate do
	
		offset := app.random(200);
		nextTs := nextTs.changeByXXMinutes(-offset);

		beginTransaction;
		create lockTrans persistent;
		lockTrans.setForCreate(nextTs, 'Lock',
						masterTrans.lockedUser, masterTrans.lockedTerminalCode,
						masterTrans.lockedByUser, masterTrans.lockedByTerminalCode, 
						masterTrans.lockTargetOid, masterTrans.lockTargetClass, 
						masterTrans.lockedByNodeName, masterTrans.lockedByAppName,
						masterTrans.lockedByDetails, 
						null,
						masterTrans.obtainedLockOid, masterTrans.obtainedLockClass,
						masterTrans.lockedByTrxStartTime, 
						masterTrans.lockedByTrxEndTime, 
						masterTrans.stackDump, 
						masterTrans.myGlobalProcessRoot);
		commitTransaction;
	endforeach;

end;</source>
    </JadeMethod>
