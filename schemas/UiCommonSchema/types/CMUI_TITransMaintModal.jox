<GUIClass name="CMUI_TITransMaintModal" id="7cdf1155-fcb5-493d-9f49-dcb8ef819ad5">
    <superclass name="CMUI_TITransMaint"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>The only reason for this subclass is so the MDIChild setting (not able to be set at run time)
can be set for the modal display neccessary from the container edit screen</text>
    <JadeMethod name="cmbUser_lostFocus" id="a39c60d4-7280-4a82-8743-a5dbf57f302d">
        <controlMethod name="CMUI_ComboBoxObject::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbUser_lostFocus(combobox: ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:     30 September 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	user  : CM_User;
begin
	user  := self.cmbUser.myObject.CM_User;
	
	if user &lt;&gt; null then 
		self.tblEntry.setValueByControlName(combobox.name, user.code);
	else
		self.tblEntry.setValueByControlName(combobox.name, null);
	endif;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="d2f69982-29ed-4c32-a312-dd51685d2009">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
//	self.translateCaption(Xlat_0017486, locale);
end;</source>
    </JadeMethod>
</GUIClass>
