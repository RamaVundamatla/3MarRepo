    <JadeMethod name="canBeDeletedByGC" id="888d4259-4419-497f-870b-ffb76116740c">
        <source>canBeDeletedByGC():Boolean;
/*

Purpose:	This method used to check the validations to delete the job through Garbage collection.			

Parameters:			

Return Value:		

Date		Who		Reason
24 July 2023		navma1	ChangeRequest 58158: EUP | [Framework] - Delivery Dispatch Garbage Collection

*/

vars
	wdtl	: CM_WorkOrderDtl;
	wod		: CM_WorkOrder;
begin
	wdtl := self.getMyWorkOrderDtl();
	wod  := self.getWorkOrder();
	if self.status = JOB_COMPLETE and
		wdtl &lt;&gt; null and wdtl.status = WO_STATUS_COMPLETE and 
		wod &lt;&gt; null and wod.taskStatus = WO_STATUS_COMPLETE then
			return true;
	endif;
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
