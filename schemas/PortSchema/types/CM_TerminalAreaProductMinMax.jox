    <JadeMethod name="getAuditTextDescription" id="dd7be1e2-b7a1-4d40-8e9b-6178bf06c58a">
        <source>getAuditTextDescription() : String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 26/06/2020	jlgdap1		Initial creation TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
//
vars
	result : String;

begin
	if self.myCargoType &lt;&gt; null then
		result := ETRow_CargoType &amp; Space &amp; self.myCargoType.description;
	endif;
	if self.myProduct &lt;&gt; null then
		result := result &amp; Space &amp; self.getProductDescription;
	endif;
	result := result &amp; Space &amp; self.minWeight.asStringJMT &amp;
					Space &amp; self.minVolume.asStringJMT;
	
	result := result &amp; Space &amp; self.maxWeight.asStringJMT &amp;
						Space &amp; self.maxVolume.asStringJMT &amp;
						Space &amp; self.maxQuantity.asStringJMT;
						
	//29 Mar 2021	NDL	TFS 49912
	if self.myLocationsController &lt;&gt; null then
		result := result &amp; Space &amp; self.myLocationsController.getFullId();
	endif;
						
	

	return result;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDetailedDescription" id="a185da42-b32b-4b68-a9c5-bee93e5ed159">
        <source>getDetailedDescription() : String;
// ---------------------------------------------------------------------------
// Created:		03 March 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	return self.myProduct.description &amp; Tab &amp; self.minVolume.asStringJMT() &amp; Tab &amp; self.maxVolume.asStringJMT() &amp; Tab &amp; self.minWeight.asStringJMT() &amp; Tab &amp; self.maxWeight.asStringJMT() &amp; CrLf;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="429f916b-3df1-4b58-bab1-cdc68bafc30d">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     15 September 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// Chnaged On	By			Reason
// ----------	--------	--------------------------------------------------
// 23/06/2020	jlgdap1		TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
vars
type : String;					
	str	: String;	
begin
	if _attrName = ETRow_Product then
		return self.getProductDescription();
	elseif _attrName = ETRow_CargoType then
		if self.myCargoType &lt;&gt; null then
			return self.myCargoType.description;
		endif;
		
		return null;
	elseif _attrName = ETRow_MinVolume then
		return self.minVolume.asStringJMT;
	elseif _attrName = ETRow_TaMaxVolume or _attrName = ETRow_TaMaxVolPerCol then		// TFS 49453
		return self.maxVolume.asStringJMT;
	elseif _attrName = ETRow_MinWeight then
		return self.minWeight.asStringJMT();
	elseif _attrName = ETRow_MaxWeight or _attrName = ETRow_MaxWeightPerCol then		// TFS 49453
		return self.maxWeight.asStringJMT();
	elseif _attrName = ETRow_MaxQuantity or _attrName = ETRow_MaxQtyPerCol then			// TFS 49453
		return self.maxQuantity.asStringJMT;
	elseif _attrName = ETRow_ColumnGroup then	//29 Mar 2021	NDL	TFS 49912
		//29 Mar 2021	NDL	TFS 49912
		if self.myLocationsController &lt;&gt; null then
			return self.myLocationsController.getFullId();
		else
			return app.getErrorString(NotApplicable);
		endif;
	elseif  _attrName.isMeasurementType then											
		// _attrName will be formatted as WTRow_&lt;real ent row name&gt;_&lt;weight unit&gt;	
		_attrName.getRowNameMeasureType(str, type);									
		return self.getMeasurementStringForAttrib(str, type, _short);
	endif;
	
	return inheritMethod(_attrName, _short);
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMeasurementStringForAttrib" id="f4d3f452-4e8c-4141-bf35-47d6fa93f53e">
        <source>getMeasurementStringForAttrib(_attrName: String; _measureType: String; _short: Boolean): String;
/*

Date		Who		Reason
27 Mar 2014	cnwer1	Initial creation PAR
23 Jun 2020	jlgdap1	TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
*/

vars

begin
	if _attrName = ETRow_MinVolume then
		return app.convertMeasurementForDisplay(_measureType, self.minVolume);
	elseif _attrName = ETRow_TaMaxVolume or _attrName = ETRow_TaMaxVolPerCol then			// TFS 49453 
		return  app.convertMeasurementForDisplay(_measureType, self.maxVolume);
	elseif _attrName = ETRow_MinWeight then
		return app.convertMeasurementForDisplay(_measureType, self.minWeight);
	elseif _attrName = ETRow_MaxWeight or _attrName = ETRow_MaxWeightPerCol then			// TFS 49453 
		return app.convertMeasurementForDisplay(_measureType, self.maxWeight);
	endif;
	
	return inheritMethod(_attrName, _measureType, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_measureType" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getProductDescription" id="c9d11356-aa05-48f3-b2b7-348d2cb90f3c">
        <source>getProductDescription() : String;
// ---------------------------------------------------------------------------
// Created:		03 March 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	code : String;
begin
	if self.myProduct = null then
		return null;
	endif;
	
	if self.myProduct.description = null then
		code := self.myProduct.code;
	else
		code := self.myProduct.description;
	endif;
	
	return code;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRawMeasurementValue" id="74471223-b85a-4e9d-b6bd-3ca0ce8ccab5">
        <source>getRawMeasurementValue(_rowName: String): Decimal;
/*

Date		Who		Reason
27 Mar 2014	cnwer1	Initial creation PAR
23 Jun 2020	jlgdap1	TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
*/

vars

begin
	if _rowName = ETRow_MinVolume then
		return self.minVolume;
	elseif _rowName = ETRow_TaMaxVolume or _rowName = ETRow_TaMaxVolPerCol then		// TFS 49453
		return self.maxVolume;
	elseif _rowName = ETRow_MinWeight then
		return self.minWeight;
	elseif _rowName = ETRow_MaxWeight or _rowName = ETRow_MaxWeightPerCol then		// TFS 49453
		return self.maxWeight;
	else
		
		return inheritMethod(_rowName);
	endif;
	

epilog

end;</source>
        <Parameter name="_rowName" type="String"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="isCheckMaxQuantity" id="cc31dcbe-95d1-4a01-a531-5d43e320248f">
        <source>isCheckMaxQuantity() : Boolean;
/*

Date		Who		Reason
01 April 2014	cnwer1	Initial creation PAR

*/

vars

begin
	if self.isCheckMaxVolume then
		return false;
	endif;
	
	if self.isCheckMaxWeight then
		return false;
	endif;
	
	return self.maxQuantity &gt; 0;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isCheckMaxVolume" id="195a9dcc-df0e-4a79-adef-f5c1b4038ea6">
        <source>isCheckMaxVolume() : Boolean;
/*

Date		Who		Reason
01 April 2014	cnwer1	Initial creation PAR

*/

vars

begin
	if self.myCargoType = null then
		return false;
	endif;
	
	
	if not self.myCargoType.isTrackByVolume then
		return false;
	endif;
	
	return self.maxVolume &gt; 0 ;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isCheckMaxWeight" id="843a48ed-5de1-4850-8ecb-f835a4d2a9b2">
        <source>isCheckMaxWeight() : Boolean;
/*

Date		Who		Reason
01 April 2014	cnwer1	Initial creation PAR

*/

vars

begin
	if self.myCargoType = null then
		return false;
	endif;
	
	
	if not self.myCargoType.isTrackByWeight then
		return false;
	endif;
	
	return self.maxWeight &gt; 0;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="3ba3a16b-659f-485b-9a9d-c0ca30cc8c4f">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:		03 March 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	prodMinMax : SelfType;
	completedOK		: Boolean;
begin
	prodMinMax :=  inheritMethod();
	
	prodMinMax.myProduct := self.myProduct;
	prodMinMax.myCargoType := self.myCargoType;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return prodMinMax;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete prodMinMax;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="e84997e0-a8db-4475-8104-f40da0d8bb95">
        <updating/>
        <source>setForCreate(_pxyMinMax: SelfType; _passport: CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		03 March 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

begin
	
	self.setForUpdate(_pxyMinMax,_passport);
	
end;</source>
        <Parameter name="_pxyMinMax" type="SelfType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="08876829-8889-4cc3-b966-7b246d0e0fa2">
        <updating/>
        <source>setForUpdate(_pxyMinMax: SelfType; _passport: CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		03 March 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	realTAM : CM_TerminalAreaMaster;
begin	
	if self.myProduct &lt;&gt; _pxyMinMax.myProduct then
		self.myProduct :=_pxyMinMax.myProduct;
	endif;
	
	if self.myProduct &lt;&gt; null then
		self.myCargoType:=self.myProduct.myCargoType;
	else
		self.myCargoType:=_pxyMinMax.myCargoType;
	endif;
	
	self.myLocationsController := _pxyMinMax.myLocationsController; //29 Mar 2021	NDL	TFS 49912
	
	if self.myCargoType.isBulkMulti then
		if self.myCargoType.isTrackByWeight then
			self.maxWeight := _pxyMinMax.maxWeight;
			self.maxVolume :=0;
			self.maxQuantity:=0;
		elseif  self.myCargoType.isTrackByVolume then
			self.maxVolume := _pxyMinMax.maxVolume;
			self.maxWeight :=0;
			self.maxQuantity:=0;
		endif;
	else
		self.maxQuantity:=_pxyMinMax.maxQuantity;
		self.maxWeight:=0;
		self.maxVolume:=0;
	endif;

	
	realTAM := _pxyMinMax.myTerminalAreaMaster.pxyGetRealObject().CM_TerminalAreaMaster;
	if realTAM = null then
		realTAM := _pxyMinMax.myTerminalAreaMaster;
	endif;
	
	self.myTerminalAreaMaster := realTAM;
	
end;</source>
        <Parameter name="_pxyMinMax" type="SelfType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setFromPxyLocationMinMax" id="6fd08fb6-c1a9-4ab1-8822-163b3d4e72c9">
        <updating/>
        <source>setFromPxyLocationMinMax( _realLc : CM_LocationsController; _pxyMinMax : CM_TerminalAreaProductMinMax ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 March 2021	navndl1	Initial creation	TFS 49912

*/

vars

begin

	if self.myProduct &lt;&gt; _pxyMinMax.myProduct then
		self.myProduct :=_pxyMinMax.myProduct;
	endif;
	
	if self.myProduct &lt;&gt; null then
		self.myCargoType:=self.myProduct.myCargoType;
	else
		self.myCargoType:=_pxyMinMax.myCargoType;
	endif;
	
	if self.myCargoType.isBulkMulti then
		if self.myCargoType.isTrackByWeight then
			self.maxWeight := _pxyMinMax.maxWeight;
			self.maxVolume :=0;
			self.maxQuantity:=0;
		elseif  self.myCargoType.isTrackByVolume then
			self.maxVolume := _pxyMinMax.maxVolume;
			self.maxWeight :=0;
			self.maxQuantity:=0;
		endif;
	else
		self.maxQuantity:=_pxyMinMax.maxQuantity;
		self.maxWeight:=0;
		self.maxVolume:=0;
	endif;

	self.myLocationsController := _realLc;
	
	if _realLc &lt;&gt; null then
		self.myTerminalAreaMaster := _realLc.getMyTerminalArea;
	endif;
	
epilog

end;</source>
        <Parameter name="_realLc" type="CM_LocationsController"/>
        <Parameter name="_pxyMinMax" type="CM_TerminalAreaProductMinMax"/>
    </JadeMethod>
    <JadeMethod name="setMyLocationsController" id="a29d916d-7826-4473-8b5f-2d3ab79837fe">
        <updating/>
        <source>setMyLocationsController( _locationsController : CM_LocationsController )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 March 2021	navndl1	Initial creation	TFS	49912 

*/

vars

begin

	self.myLocationsController := _locationsController;

epilog

end;</source>
        <Parameter name="_locationsController" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="setMyParents" id="b033925c-63d1-4074-93cd-88c1b71a983f">
        <updating/>
        <source>setMyParents(	_ta : CM_TerminalAreaMaster;
				_lc : CM_LocationsController )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 March 2021	navndl1	Initial creation	TFS 49912

*/

vars

begin

	if _ta = null and _lc = null then
		//when clearing always clear ta first
		self.myTerminalAreaMaster := _ta;
		self.myLocationsController := _lc;
	else
		//when setting, always set lc first
		self.myLocationsController := _lc;
		self.myTerminalAreaMaster := _ta;
	endif;

epilog

end;</source>
        <Parameter name="_ta" type="CM_TerminalAreaMaster"/>
        <Parameter name="_lc" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="setMyTerminalAreaMaster" id="b0115173-55c9-4a5a-a6c1-5c9100fc699c">
        <updating/>
        <source>setMyTerminalAreaMaster(_tam : CM_TerminalAreaMaster) updating;
// ---------------------------------------------------------------------------
// Created:		03 March 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	self.myTerminalAreaMaster := _tam;
end;</source>
        <Parameter name="_tam" type="CM_TerminalAreaMaster"/>
    </JadeMethod>
    <JadeMethod name="setupProxy" id="36e2128e-e67c-40da-baca-f7e0c183c82c">
        <updating/>
        <source>setupProxy(	_locationsController : CM_LocationsController; 
			_cargoType : CM_CargoType;
			_cargoSubType : CM_Product;
			_tam : CM_TerminalAreaMaster;
			_minVol	: Decimal;
			_minWeight : Integer; 
			_maxVol		: Decimal;
			_maxWeight : Integer;
			_maxQuantity : Integer ) updating;
// ---------------------------------------------------------------------------
// Created:		03 March 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	self.maxVolume := _maxVol;
	self.minVolume := _minVol;
	self.minWeight := _minWeight.Integer;
	self.maxWeight := _maxWeight;
	self.maxQuantity:= _maxQuantity;
	
	self.myProduct := _cargoSubType;
	self.myCargoType :=_cargoType;
	
	self.myLocationsController := _locationsController;	//29 Mar 2021	NDL	TFS 49912
	
	self.myTerminalAreaMaster := _tam;

end;</source>
        <Parameter name="_locationsController" type="CM_LocationsController"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_cargoSubType" type="CM_Product"/>
        <Parameter name="_tam" type="CM_TerminalAreaMaster"/>
        <Parameter name="_minVol" type="Decimal"/>
        <Parameter name="_minWeight" type="Integer"/>
        <Parameter name="_maxVol" type="Decimal"/>
        <Parameter name="_maxWeight" type="Integer"/>
        <Parameter name="_maxQuantity" type="Integer"/>
    </JadeMethod>
</Class>
