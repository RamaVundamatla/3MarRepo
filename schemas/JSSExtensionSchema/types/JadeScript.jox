<Class name="JadeScript">
    <JadeMethod name="cnwdad1_DoBackup" id="5d4d874f-cfb0-439e-8f5a-561f9c2e96d9">
        <source>cnwdad1_DoBackup();
// --------------------------------------------------------------------------------
// Created:		06 February 2001 by cnwdad1
//
// Purpose:		Used as the initialize method for a backup application which backs
//				up the development environment system directory to a directory
//				specified in the ADE initialization file.
//
//				It backs up the specific d:\jade51\system directory
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theDBAdmin			: JadeDatabaseAdmin;
	allDroppedFiles		: DbFileArray;
	theDBFile			: DbFile;
	isIncludeSysFiles	: Boolean;
	isVerifyFiles		: Boolean;
	isCompressFiles		: Boolean;
	isAllowOverwrite	: Boolean;
	isQuiesce			: Boolean;
	backupDirectory		: String;
	messageTitle		: String;
	taskMessage			: String;
	startTime			: Integer;

begin
	startTime	:=	app.clock();
	
	create theDBAdmin transient;
	create allDroppedFiles transient;
	
	backupDirectory		:=	app.getProfileString(app.getIniFileName(), "JEDI", "JadeSystemBackupDirectory", "c:\temp\jade");

	isIncludeSysFiles	:=	true;		// Exclude system files from backup.
	isVerifyFiles		:=	false;		// Verify data during backup.
	isCompressFiles		:=	true;		// Don’t perform on-the-fly data compression.
	isAllowOverwrite	:=	true;		// Overwrite existing files in backup directory.
	isQuiesce			:=	false;		// Don't quiesce =&gt; full online backup.

	theDBAdmin.backupAllDbFiles(backupDirectory, isIncludeSysFiles, isVerifyFiles,	isCompressFiles, isAllowOverwrite, isQuiesce, allDroppedFiles);
	
	// The database backup completed without exceptions.
	messageTitle	:=	"Database Backup Complete";
epilog
	if process.isInExceptionState() then
		// A fatal exception has occurred during the backup, the activated
		// exception handler aborted the current action - report the failure.
		messageTitle	:=	"Database Backup Failed";
	endif;

	// Report missing files (a missing file is only valid if it has never been created).

	if allDroppedFiles.jssIsNotEmpty() then
		taskMessage	:=	"The following files were not backed up :" &amp; CrLf;
		
		foreach theDBFile in allDroppedFiles do
			taskMessage	:=	taskMessage &amp; theDBFile.name &amp; ".dat" &amp; CrLf;
		endforeach;
	endif;

	if messageTitle = "Database Backup Failed" then
		app.msgBox(taskMessage &amp; Cr, messageTitle, MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
	endif;

	delete theDBAdmin;
	delete allDroppedFiles;
	
	write "Database Backup completed in " &amp; startTime.jssClockDifference().String &amp; " seconds.";
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_GetFile" id="917094a4-895c-4b4a-883e-5b22b1d494b7">
        <source>cnwdad1_GetFile(pFileName:String output; pMustExist:Boolean):Boolean;
// --------------------------------------------------------------------------------
// Created:		12 May 1999 - getFile
// By:			cnwdad1
//
// Purpose:		
//
// Parameters:	None
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	cmdFile		: CMDFileOpen;

begin
	create cmdFile;

	cmdFile.allowMultiSelect	:=	false;
	cmdFile.createPrompt		:=	false;
	cmdFile.defaultExt			:=	".*";
	cmdFile.fileMustExist		:=	pMustExist;
	cmdFile.filter				:=	'All Files|*.*';
	cmdFile.filterIndex			:=	1;
	cmdFile.hideReadOnly		:=	false;
//	cmdFile.initDir				:=
	cmdFile.noReadOnlyReturn	:=	true;
	cmdFile.pathMustExist		:=	true;
	cmdFile.readOnly			:=	false;
	cmdFile.resetCurrentPath	:=	true;
	cmdFile.shareAware			:=	true;
	cmdFile.validate			:=	true;

	if cmdFile.open() = 0 then
		pFileName	:=	cmdFile.fileName;
		return true;
	else
		return false;
	endif;
epilog
	delete cmdFile;
end;</source>
        <Parameter name="pFileName" type="String" usage="output"/>
        <Parameter name="pMustExist" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnwdad1_JadeSkins_Initialize" id="05b82f49-7616-4369-9142-13b4f0673b89">
        <source>cnwdad1_JadeSkins_Initialize();
// --------------------------------------------------------------------------------
// Created:		03 March 2001 by cnwdad1
//
// Purpose:		Add this code to your application's initialization method.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theSkinsColl	: JadeSkinsColl;
	skinSetNumber	: Integer;
	startTime		: Integer;
	
begin
	startTime		:=	app.clock();
	skinSetNumber	:=	1;		// Get the first set of skins.
	theSkinsColl	:=	app.getSkinCollection();
	
	if theSkinsColl &lt;&gt; null and (not theSkinsColl.isEmpty()) then
		app.setSkin(theSkinsColl[skinSetNumber]);
	endif;
epilog
	write "Skins initialization completed in " &amp; startTime.jssClockDifference().String &amp; " seconds.";
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_JadeSkins_Load" id="0db57c28-7bc3-4766-bd84-cf85e5932639">
        <source>cnwdad1_JadeSkins_Load();
// ---------------------------------------------------------------------------
// Created:     08 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theJadeSkin		: JadeSkin;
	theFile			: File;
	propertyFile	: File;
	fileDirectory	: String;
	thePropertyColl	: PropertyColl;
	theProperty		: Property;
	fileRecord		: String;
	tabPosition		: Integer;
	propertyName	: String;
	propertyValue	: String;
	startTime		: Integer;

begin
	startTime		:=	app.clock();
	fileDirectory	:=	"c:\Temp\TpSkins";
	theJadeSkin		:=	JadeSkin.lastInstance();
	
	if theJadeSkin = null then
		write "JadeSkin is null.";
		return;
	endif;
	
	create theFile transient;
	create propertyFile transient;
	
	theFile.mode			:=	File.Mode_Input;
	theFile.kind			:=	File.Kind_Binary;
	thePropertyColl			:=	JadeSkin.allProperties();
	
	propertyFile.mode		:=	File.Mode_Input;
	propertyFile.kind 		:=	File.Kind_Unknown_Text;	// 3/3/16 cnwmp6 PAR 36286 unicode version
	propertyFile.fileName	:=	fileDirectory &amp; "\JadeSkin.dat";
	propertyFile.open();
	
	beginTransaction;
	
	foreach theProperty in thePropertyColl do
		if theProperty.name[1:3] = "img" then
			theFile.fileName	:=	fileDirectory &amp; "\" &amp; theProperty.name &amp; ".png";
		
			if theFile.isAvailable() then
				theFile.open();
				theJadeSkin.setPropertyValue(theProperty.name,
				theFile.readBinary(theFile.fileLength() ));
				theFile.close();
			else
				write "No file for: " &amp; theProperty.name;
			endif;
		endif;
	endforeach;
	
	// Now set the properties.
	
	while propertyFile.jssIsNotEndOfFile() do
		fileRecord		:=	propertyFile.readLine();
		tabPosition		:=	fileRecord.pos(Tab, 1);
		propertyName	:=	fileRecord[1:(tabPosition - 1)];
		propertyValue	:=	fileRecord[(tabPosition + 1):end];
		theProperty		:=	theJadeSkin.class().getProperty(propertyName);

		if theProperty.type = String then
			theJadeSkin.setPropertyValue(propertyName, propertyValue);
		elseif theProperty.type = Real then
			theJadeSkin.setPropertyValue(propertyName, propertyValue.Real);
		elseif theProperty.type = Integer then
			theJadeSkin.setPropertyValue(propertyName, propertyValue.Integer);
		elseif theProperty.type = Boolean then
			theJadeSkin.setPropertyValue(propertyName, propertyValue.Boolean);
		else
			write theProperty.type.name;
		endif;
	endwhile;
	
	commitTransaction;
	
	propertyFile.close();
epilog
	delete theFile;
	delete propertyFile;
	
	write "Skins Load completed in " &amp; startTime.jssClockDifference().String &amp; " seconds.";
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_JadeSkins_Maint" id="2f8112df-499f-4776-a59e-ab5046fc13dc">
        <source>cnwdad1_JadeSkins_Maint();
// ---------------------------------------------------------------------------
// Created:     08 December 2000 by cnwrs2
//
