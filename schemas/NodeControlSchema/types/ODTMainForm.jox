    <JadeMethod name="fileSelect" id="1cfc04e7-d7e1-4674-84fe-ccc0db723d6c">
        <updating/>
        <source>fileSelect() updating;

vars
	cfo:CMDFileOpen;
begin
	create cfo;
	cfo.fileMustExist:=true;
	cfo.defaultExt:=".log";
	//cfo.initDir:=folder.fileName;
	//cfo.fileName:="*.log";
	cfo.initDir:=currentForm.file.fileName;
	cfo.fileName:=currentForm.file.fileName;
	if cfo.open=0 then
		folder.fileName:=cfo.fileName;
		currentForm.addFile(cfo.fileName, true);
	endif;
epilog
	delete cfo;
end;</source>
    </JadeMethod>
    <JadeMethod name="fileSelectServer" id="2e1ddb4b-9013-4b00-bc24-83c068bed570">
        <updating/>
        <source>fileSelectServer() updating;

vars
	sfb:FrmServerFileBrowser;
begin
	create sfb;
	sfb.myParentForm:=currentForm;
	sfb.selectedItem:=currentForm.monitorFileName;
	sfb.init("Browse for File on " &amp; app.dbServerComputerName, "Select Data  File", null);
	sfb.showModal;
	currentForm.addFile(sfb.selectedItem, true);
epilog
	delete sfb;
end;</source>
    </JadeMethod>
    <JadeMethod name="findMappedDrive" id="a02f0c99-e566-4a38-bedc-f697733b8783">
        <updating/>
        <source>findMappedDrive() updating;

vars
	i:Integer;
begin
	if app.computerName.toLower="cnwjhp1a" then
		folder.fileName:="s"&amp;folder.fileName[2:end];
	elseif app.computerName.toLower="cnwzll1a" or app.computerName.toLower="cnwmjn1c" then
		folder.fileName:="x"&amp;folder.fileName[2:end];
	else
		foreach i in 4 to 26 do
			folder.fileName:=(i+96).Character&amp;folder.fileName[2:end];
			if folder.isAvailable then
				break;
			endif;
		endforeach;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="load" id="9cb7ceb0-f49a-48ea-bc93-1a0ace1aa5db">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

begin
	app.mousePointer:=MousePointer_HourGlass;
	inheritMethod;
	doLoad;
	app.mousePointer:=MousePointer_Default;
end;</source>
    </JadeMethod>
