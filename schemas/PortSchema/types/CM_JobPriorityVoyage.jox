<Class name="CM_JobPriorityVoyage" id="de335b00-2bc9-45d2-96a9-de8164b9486a">
    <superclass name="CM_JobPriority"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="voyages"/>
    <ExplicitInverseRef name="myVoyage" id="ea2c9ddc-693c-4ecc-b791-10f502897072">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_Voyage"/>
        <access>readonly</access>
        <Inverse name="CM_Voyage::allJobPriorities"/>
    </ExplicitInverseRef>
    <JadeMethod name="pxyCreateUpdateProxy" id="189c2524-5465-4b97-9273-e03f61553d43">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:		07 April 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	jp : CM_JobPriorityVoyage;
	completedOK		: Boolean;
begin
	jp :=  inheritMethod();
	
	jp.myVoyage := self.myVoyage;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return jp;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete jp;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="dddf2e24-454f-4beb-90fc-62f5f9cd7c61">
        <updating/>
        <source>setForCreate(_pxyPriority: CM_JobPriorityVoyage) updating;
// ---------------------------------------------------------------------------
// Created:		07 April 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	inheritMethod(_pxyPriority);
	self.myVoyage := _pxyPriority.myVoyage;

end;</source>
        <Parameter name="_pxyPriority" type="CM_JobPriorityVoyage"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="d53d0c3b-8ffc-481e-983c-bbe4092dcdf5">
        <updating/>
        <source>setProxy(_ct: Integer; _jt: Integer; _p: Integer; _object: CM_Object) updating;
// ---------------------------------------------------------------------------
// Created:		07 April 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	inheritMethod(_ct, _jt, _p, _object);

	self.myVoyage := _object.CM_Voyage;

end;</source>
        <Parameter name="_ct" type="Integer"/>
        <Parameter name="_jt" type="Integer"/>
        <Parameter name="_p" type="Integer"/>
        <Parameter name="_object" type="CM_Object"/>
    </JadeMethod>
</Class>
