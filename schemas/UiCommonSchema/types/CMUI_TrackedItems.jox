    <JadeMethod name="tblListAll_mouseMove" id="f1276e6b-e446-40e4-8fc5-6d6ee0e79889">
        <controlMethod name="Table::mouseMove"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblListAll_mouseMove(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
/*
----------   ----------  --------------------------------------------------
Created:	06 June 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	tmpHeight : Real;	
begin
	if table.fixedRows &gt; 0 then
		tmpHeight := table.accessRow(table.fixedRows).height;
		if self.origYPos &lt;= tmpHeight then
			return;
		endif;
	endif;
	if button = 1 then
		if app.dragDetected(x, y, self.origXPos, self.origYPos) then
			self.doTblDataDragTrackedItem();
			self.origXPos := 0;
			self.origYPos := 0;
		endif;
	endif;
end;


</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="tblList_ShowTI" id="21025d96-4c33-4450-a562-c07855234c59">
        <updating/>
        <source>tblList_ShowTI(pTI : CM_TrackedItem; pRow : Integer; _table : CM_BaseTable input) : Integer updating, protected;
// ---------------------------------------------------------------------------
// Created:     08 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	str		: String;
	theRow	: Integer;
	
begin

	str := pTI.id &amp; Tab &amp;
		   pTI.cargoTypeDescr &amp; Tab &amp;
		   pTI.isoTypeGroup &amp; Tab &amp; 
		   pTI.getISOType &amp; Tab &amp;
		   pTI.voyageCode &amp; Tab &amp;
		   pTI.operatorCode;
	
	if pRow = 0 then
		theRow := _table.addItem(str);
	else
		theRow := pRow;
		_table.accessCell(theRow, 1).text := str;
	endif;
	
	_table.accessRow(theRow).itemObject := pTI;
	
	return theRow;

end;</source>
        <access>protected</access>
        <Parameter name="pTI" type="CM_TrackedItem"/>
        <Parameter name="pRow" type="Integer"/>
        <Parameter name="_table" type="CM_BaseTable" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
