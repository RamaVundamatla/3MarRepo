  COPYRIGHT © JADE SOFTWARE CORPORATION LIMITED 2002 - ALL RIGHTS RESERVED
____________________________________________________________________________</text>
        <Parameter name="pTimeStamp" type="TimeStamp"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jssSetDateAndTime" id="b91bde6a-badd-47f4-8cd8-71f8cb3712ab">
        <updating/>
        <source>jssSetDateAndTime(pDate:Date; pTime:Time) updating;
// --------------------------------------------------------------------------------
// Created:		08 November 2000 by cnwdad1
//
// Purpose:		Updates the Date and Time properties of the TimeStamp.
//
// Parameters:	pDate (Date) - The new date value.
//				pTime (Time) - The new time value.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.date &lt;&gt; pDate then
		self.setDate(pDate);
	endif;
	
	if self.time &lt;&gt; pTime then
		self.setTime(pTime);
	endif;
end;</source>
        <text>___________________________________________________________________________

              P R O P R I E T A R Y   N O T I C E

This software, in whole and in every part, is proprietary to Jade Software
Corporation Limited at Christchurch, New Zealand and is not to be
reproduced, used or disclosed except upon prior written permission of Jade
Software Corporation Limited.

  COPYRIGHT © JADE SOFTWARE CORPORATION LIMITED 2002 - ALL RIGHTS RESERVED
____________________________________________________________________________</text>
        <Parameter name="pDate" type="Date"/>
        <Parameter name="pTime" type="Time"/>
    </JadeMethod>
    <JadeMethod name="jssShortFullFormat" id="34ffb8f8-54f8-4fb2-aaf1-4ccbc05ccbed">
        <source>jssShortFullFormat():String;
// -----------------------------------------------------------------------------
// Created:		07 January 2002 by cnwdad1
//
// Purpose:		Returns the receiver in a short and full format, i.e. dd/MM/yyyy, hh:mm.
//
// Parameters:	None
//
// Returns:		The short-formated timestamp.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	return	self.date.userFormat($CNEC_DATE_SHORT_FULL) &amp; ", " &amp; self.time.userFormat($CNEC_TIME_HHMM_24);
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jssShortPartFormat" id="b551f9e9-18a0-4f4b-97cb-0205f5a937a8">
        <source>jssShortPartFormat():String;
// -----------------------------------------------------------------------------
// Created:		07 January 2002 by cnwdad1
//
// Purpose:		Returns the receiver in a short and full format, i.e. d/M/yy, hh:mm.
//
// Parameters:	None
//
// Returns:		The short-formated timestamp.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	return	self.date.userFormat($CNEC_DATE_SHORT_PART) &amp; ", " &amp; self.time.userFormat($CNEC_TIME_HHMM_24);
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
