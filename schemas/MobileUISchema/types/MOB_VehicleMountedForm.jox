    <JadeMethod name="goToTaskFrame" id="cd0315c5-fd7e-4b46-a4fc-9165602c56b6">
        <updating/>
        <source>goToTaskFrame() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 April 2010	cnwer1	Initial creation

*/

vars

begin
	if frmMove.visible then
		self.btnReject.enabled:=true;
		self.btnGraphic.caption:=app.getErrorString(Graphic);
		self.btnTaskMode.enabled:=true;
		self.btnTandem.visible:=false;
		//epr par 25047 19/7/10
		if app.myVMAgent.showingTaskList or self.isEnquiryMode then
			if self.myMachine.isTandemLift then
				self.btnTandem.visible := true;
				self.btnTandem.caption := app.getErrorString(Tandem);
			endif;
			// CCMS SFW 1210
			if self.myMachine.isTwinLift then
				self.btnTandem.visible := true;
				self.btnTandem.caption := app.getErrorString(CM_Twin);
			endif;
		endif;
		
		if self.btnVoyDischarge.visible then //cnwrd1 par 27559 5.8.2011
			self.btnVoyDischarge.enabled := true;
		endif;		
		
		if self.isInDischargeMode then
			self.doResetSearch();
			self.btnAccept.caption:=app.getErrorString(Pickup);
		else
		//	self.tblTasks.tag := null; // 27090 epr don't just clear the tag will leave the row display indicating it is selected but its accessed row state will not be 
			if self.tblTasks.accessedRow = null then
				if self.tblTasks.rows &gt; 1 then
					self.tblTasks.accessRow(1);
					self.tblTasks.click(self.tblTasks);
				endif;
			endif;
		endif;
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="handleWeightICException" id="cf0ab894-2286-408f-8fa4-e5d1f353896d">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_WeightCallerInterface::handleWeightICException"/>
            <JadeInterfaceMethod name="IF_TCPWeightCallerInterface::handleWeightICException"/>
        </interfaceImplements>
        <updating/>
        <source>handleWeightICException(_exceptionCode : Integer; _exceptionData : String) updating;

	/*
		this method stub has been automatically generated by Jade to satisfy interface implementation requirements
	*/
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 June 2010	cnwer1	Initial creation
19 Oct	2016	cnwrh7	TFS	2501
*/

vars
	alertText : String;
	device		: CM_RadioTelemetryDevice;										//+TFS2501
begin
	device := app.myVMAgent.myRTDevice;									//+TFS2501
	//if we already know there is a connection problem then return
	
	if device.canDoIScaleWeighting then
		self.addInfoDisplay(app.getErrorString(Iscale_interface_failed));		//+TFS2501 for Iscale Device
	endif;
	
	if  self.hasWeightInterfaceError then
		return;
	endif;
	
	//create alert for control with more of the exception details 
	alertText := app.getErrorString2(Loadrite_failed_machine,self.myMachine.id,_exceptionData);
	
	app.myPassport.createAlert(	SEVERE_ERROR, 
								alertText,
								null,
								null);
								
	beginTransaction;
	app.commitAlert();
	commitTransaction;
	
	//just give the user a generic message loadrite connection failed
	if device.canDoLoadriteWeighing then															//+TFS 2207 add canDoLoadriteWeighing condition here as device can weighting in 2 ways (Loadrite/Iscale)
		self.addInfoDisplay(app.getErrorString(Loadrite_interface_failed));
	endif;
	
	 self.hasWeightInterfaceError:=true;
epilog

end;</source>
        <Parameter name="_exceptionCode" type="Integer"/>
        <Parameter name="_exceptionData" type="String"/>
    </JadeMethod>
    <JadeMethod name="hasWorkingTask" id="015f25b1-7828-4da0-893e-4a4a12b2dfe2">
        <source>hasWorkingTask() : Boolean protected;
/*

Date		Who		Reason
12 February 2014	cnwer1	Initial creation PAR

*/

vars
	moveState	: Integer;
	hasWorkingTask : Boolean;
begin
	hasWorkingTask:=false;
	if self.isEnquiryMode then
		hasWorkingTask:=self.btnAccept.caption &lt;&gt; app.getErrorString(Accept);
	elseif self.isShowOverstowCargo then
		hasWorkingTask:=true;
	else
		moveState:=self.myVMAgent.getNextMoveState;		
		if self.myVMAgent.showingTaskList then
			hasWorkingTask:=moveState &lt;&gt; VehicleMountedGenericAgent.ACCEPT_TASK;
		else
			hasWorkingTask:=moveState &lt;&gt; VehicleMountedGenericAgent.ACCEPT_TASK and 
							moveState &lt;&gt; VehicleMountedGenericAgent.GETNEXT_TASK;
		endif;
	endif;
	
	return hasWorkingTask;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
