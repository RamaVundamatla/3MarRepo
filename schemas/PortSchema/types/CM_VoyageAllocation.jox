    <JadeMethod name="getDisplayForInUseValidation" id="f21467fd-4215-40fa-96dd-2562f344e211">
        <source>getDisplayForInUseValidation(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 November 2012	cnwndl1	Initial creation	NDL	Par 30767

*/

vars

	tempStr : String;
	term : CM_Terminal;
begin
	term := self.getTerminal();
	
	if term &lt;&gt; null then
		tempStr :=	app.getString( Terminal ) &amp; Space &amp; term.code &amp; ' / ';
	endif;
	
	if self.myVoyage &lt;&gt; null then
		tempStr := tempStr &amp; app.getString( Voyage ) &amp; Space &amp; self.myVoyage.code &amp; ' / ';
	endif;

	tempStr := tempStr &amp;  self.code &amp; " [" &amp; app.getErrorString(Voyage_allocation) &amp; "]";

epilog

	return tempStr;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="f53eb256-d31d-4868-8d94-5011b284a8ee">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 December 2009	cnwas3	Initial creation

*/

vars
	ccDLR,ccSOB,ccTotal : Integer;
begin
	if _attrName = ETRow_AllocName then 		
			return self.description;	
	elseif _attrName = ETRow_TotalActual then 		
			return "";	
	elseif _attrName = ETRow_ColourCodedSobs then 		
			return self.getNumSOB().zeroNotAllowed();
	elseif _attrName = ETRow_ColourCodedRehandles then					//cnwas3 par 26773
			return self.getNumColourCodedRehandles().zeroNotAllowed();
	elseif _attrName = ETRow_SlotRequests then 		
			return self.getNumSlotReqs().zeroNotAllowed();
	elseif _attrName = ETRow_ColourCodedExports then 		
			return (self.getNumSlotReqs()-(self.getNumSOB()+self.getNumColourCodedRehandles())).zeroNotAllowed();
	elseif _attrName = ETRow_MatchingTIsCollection then 		
			return "";
	elseif _attrName = ETRow_Projected then 		
			return self.projected20.zeroNotAllowed();
	elseif _attrName = ETRow_Variance then 		
			return "0";
	elseif _attrName = ETRow_NumSoB then 		
			return "";	
	elseif _attrName = ETRow_NumRehandles then 							//cnwas3 par 26773
			return "";
	elseif _attrName = ETRow_SlotReqWithPlannedTIs then 		
			return self.getLoadCCNumPlanned().zeroNotAllowed();
	
	elseif _attrName = ETRow_Selected then 		
			return "";
	endif;
	
	return inheritMethod(_attrName, _short);
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
