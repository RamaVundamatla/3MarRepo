	elseif _ediBundle = CM_EDIFileType.EDI_Bundle_SUZANO then
		return CM_EDIFileType.EDI_Bundle_SUZANO_Str;
	elseif _ediBundle = CM_EDIFileType.EDI_Bundle_X12 then
