    <JadeMethod name="verifyHSCode" id="3ecbbed4-eeb9-41ea-b2bd-97c99c44143b">
        <source>verifyHSCode();
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 29 November 2022
TFS#		: 55586
Function	:

*** Changes ***
Date			Name		TFS#		Description
03/07/2024		jlizm11		64736 		HS Code edi allow invalid codes
****************************************************/

vars
	hsCode		: CM_HarmonizedSystem;
	terminal 	: CM_Terminal;
	
begin

	terminal:=self.getMyTerminal;
	if terminal = null then	
		return;
	endif;
	
	if self.hsCode = null then
		if terminal.getConfig(EdiHSCodeMandatory).Boolean then
			app.raiseCMException1(EDI_HSCode_Mandatory,self.id, ETRow_HsCode, self);	
		endif;
		return;
	endif;
	
	if terminal.getConfig(EdiHSCodeMustBeValid).Boolean then
		hsCode := app.myRoot.getHarmonizedSystem(self.hsCode);
		if hsCode = null then
			app.raiseCMException1(Invalid_hsCode_specified, self.hsCode, ETRow_HsCode, self);	
		endif;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="verifyObjectAvailableForEntry" id="96df1058-08a9-4112-9583-f2c360d30071">
        <source>verifyObjectAvailableForEntry( _obj : CM_Object );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 September 2021	navndl1	Initial creation	TFS 51928

*/

vars

	consignee : CM_ConsigneeConsignor;
	term : CM_Terminal;
	subMsg : String;

begin

	if _obj = null then
		return;
	endif;
	
	if _obj.isKindOf( CM_ConsigneeConsignor ) then
		term := self.getMyTerminal; 
		if term = null then
			return;
		endif;
		if term.getConfig( EdiValConAvailEntry ).Boolean then
			consignee := _obj.CM_ConsigneeConsignor;
			if consignee.isNotAvailableForEntry then
				subMsg := app.getErrorString(Consignee_Consignor) &amp; " '" &amp; consignee.code &amp; "'";
				app.raiseCMException1( NotAvailableForEntry,  subMsg, null, self );
			endif;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
