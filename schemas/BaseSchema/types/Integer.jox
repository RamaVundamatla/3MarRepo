<PrimType name="Integer">
    <JadeMethod name="cnEcAdd" id="3e25784b-9c32-4002-b4ef-c814e25f878a">
        <updating/>
        <source>cnEcAdd(pIncrement:Integer):Integer updating;
// --------------------------------------------------------------------------------
// Created:		05 February 2001 by cnwdad1
//
// Purpose:		Increments the receiver by the value specified by the parameter,
//				and returns the result.
//
//				*************************************************************
//				* NOTE: Do not use this method to increment a loop counter. *
//				*************************************************************
//
// Parameters:	pIncrement (Integer) - The amount by which to increment the receiver.
//
// Returns:		The result of the increment.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self &lt;= (Max_Integer - pIncrement) then
		self := self + pIncrement;
	endif;
epilog
	return self;
end;</source>
        <Parameter name="pIncrement" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcAsKilobytes" id="55ec5353-df5a-45fe-9ba1-f1662cd45d46">
        <source>cnEcAsKilobytes():Real;
// -----------------------------------------------------------------------------
// Created:		21 January 2002 by cnwdad1
//
// Purpose:		Converts the receiver's value into its equivalent kilobytes.
//
// Parameters:	None
//
// Returns:		The receiver converted into kilobytes.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
constants
	BYTES_PER_KILOBYTE	: Integer = 1024;
	
begin
	return self / BYTES_PER_KILOBYTE;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="cnEcAsMegabytes" id="bee2908c-a5a3-4265-af83-707e0867623f">
        <source>cnEcAsMegabytes():Real;
// -----------------------------------------------------------------------------
// Created:		21 January 2002 by cnwdad1
//
// Purpose:		Converts the receiver's value into its equivalent megabytes.
//
// Parameters:	None
//
// Returns:		The receiver converted into megabytes.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
constants
	BYTES_PER_MEGABYTE	: Integer = 1048576;
	
begin
	return self / BYTES_PER_MEGABYTE;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="cnEcAsWords" id="c4b8dd64-c10e-4b95-9011-f5a3f13e44ee">
        <source>cnEcAsWords(pFullLocaleObj:LocaleFullInfo):String;
// --------------------------------------------------------------------------------
// Created:		21 August 2001 by cnwdad1
//
// Purpose:		Returns the receiver expressed in words.
//
// Parameters:	pFullLocaleObj - The locale of the number format information to
//				apply to the receiver, for example, the US "Billion" versus the UK
//				"Thousand Million".
//
//				If the locale is null, the default will be used.
//
// Returns:		The receiver expressed in words.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.Real.cnEcAsWordsWhole(pFullLocaleObj);
end;</source>
        <Parameter name="pFullLocaleObj" type="LocaleFullInfo"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcBinaryMatch" id="3900b2d1-2147-49df-9c4d-702b6b07d651">
        <source>cnEcBinaryMatch(pMask:Integer) : Boolean;
// Does the integer contain (match with) the binary pMask, e.g. pMask may be 1, 2, 4, 8, 16, ...
vars
    dividend	: Integer;

begin
	dividend := self div pMask;

	if dividend = 0 then
		return false;
	endif;

	if dividend mod 2 = 0 then
		return false;
	endif;

	return true;
end;</source>
        <Parameter name="pMask" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcClockDifference" id="f55257aa-f67b-459d-a318-ccf9a03ad6db">
        <source>cnEcClockDifference():Real;
// --------------------------------------------------------------------------------
// Created:		22 January 2002 by cnwdad1
//
// Purpose:		Returns the difference between the receiver and the current app.clock()
//				value, in seconds.
//
// Parameters:	None
//
// Returns:		The number of seconds difference between the receiver and app.clock.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return ((app.clock() - self) / 1000);
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="cnEcDaysInMonth" id="bfdcf7a5-e475-4e99-8e33-820225e83f41">
        <source>cnEcDaysInMonth(pIsLeapYear:Boolean):Integer;
// --------------------------------------------------------------------------------
// Created:		02 November 2000 by cnwdad1
//
// Purpose:		Returns the number of days of the month number.
//
// Parameters:	pIsLeapYear (Boolean) - Flag to indicate whether the month number
//					is within a leap year.
//
// Returns:		Integer - The number of days, or zero if the month number is invalid.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	IS_UNICODE_SYS	: Boolean = (-1).Character.Integer = 65535;
	DAYS_IN_MONTH	: Binary = #"1F 1C 1F 1E 1F 1E 1F 1F 1E 1F 1E 1F".Binary;	// Construct a compile-time value array.

begin
	if self &lt; 1 or self &gt; 12 then
		return null;
	endif;
	
    if self = 2 and pIsLeapYear then
        return 29;
    endif;

	if IS_UNICODE_SYS then
		return DAYS_IN_MONTH[(self*2-1):2].Integer;
	endif;

	return DAYS_IN_MONTH[self];
end;</source>
        <Parameter name="pIsLeapYear" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetColorRatios" id="c805570d-7f10-42a6-b926-dde0be402d70">
        <source>cnEcGetColorRatios():String;
// --------------------------------------------------------------------------------
// Created:		31 March 2004 by cnwdad1
//
// Purpose:		Returns a string with details of the percent of Red/Blue/Green for
//				the receiver.
//
// Parameters:	None
//
// Returns:		A string of RGB ratios.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	colorRed	: Integer;
	colorGreen	: Integer;
	colorBlue	: Integer;
	colorValue	: Integer;

begin
	// RGB values given by lower 3 bytes of integer Convert to percentage.
	colorValue	:=	self.abs;
	
	colorRed	:=	((colorValue mod 256) * 100 / 255).Integer;
	colorValue	:=	colorValue div 256;
	colorGreen	:=	((colorValue mod 256) * 100 / 255).Integer;
	colorValue	:=	colorValue div 256;
	colorBlue	:=	((colorValue mod 256) * 100 / 255).Integer;

	if colorRed = 0 and colorGreen = 0 and colorBlue = 0 then
		return "Black";
	elseif colorRed = 100 and colorGreen = 100 and colorBlue = 100 then
		return "White";
	else
		return "Red:" &amp; colorRed.String &amp; "% Green:" &amp; colorGreen.String &amp; "% Blue:" &amp; colorBlue.String &amp; "%";
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetDayName" id="cfe98e41-f61f-4e75-aa9b-7743ef62ced6">
        <source>cnEcGetDayName():String;
// --------------------------------------------------------------------------------
// Created:		13 January 2001 by cnwdad1
//
// Purpose:		Returns the name of the week day base upon the receiver day
//				number. If the receiver is &lt; 1 or &gt; 7 then a null value is returned.
//
// Parameters:	None
//
// Returns:		String - The name of the week day.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	weekDayNumber	: Integer;
	
begin
	weekDayNumber	:=	self;
	
	if weekDayNumber = 1 then
		return $CNEC_DAY_MONDAY;
	elseif weekDayNumber = 2 then
		return $CNEC_DAY_TUESDAY;
	elseif weekDayNumber = 3 then
		return $CNEC_DAY_WEDNESDAY;
	elseif weekDayNumber = 4 then
		return $CNEC_DAY_THURSDAY;
	elseif weekDayNumber = 5 then
		return $CNEC_DAY_FRIDAY;
	elseif weekDayNumber = 6 then
		return $CNEC_DAY_SATURDAY;
	elseif weekDayNumber = 7 then
		return $CNEC_DAY_SUNDAY;
	else
		return null;
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetEasterSundayForYear" id="a8a9148c-4ebe-426a-bbef-605f4d7f93e4">
        <source>cnEcGetEasterSundayForYear():Date;
// --------------------------------------------------------------------------------
// Created:		07 November 2000 by cnwdad1
//
// Purpose:		Returns the date of Easter Sunday for a (receiver) year.
//
// Parameters:	None
//
// Returns:		Date - The date Easter Sunday for the (receiver) year.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
/*

This method computes the date on which Easter Sunday occurs for the year passed as
a parameter.

The Gregorian calendar officially started in September 1752, so the formula shouldn't
be applied to 1752 and has been coded to return a null date for years prior to 1753.

The formula implemented by this method was devised by Christophorus Clavius under 
commission from Pope Gregory XIII. Basically it works out the date of the Paschal
Full moon, which is supposed to be the first full moon following the Vernal Equinox.
The formula here was worked out so that the new moon calculated always falls on, or
one, or two days after the true mean astronomical new moon. The full moon is then
considered to occur on the fourteenth day of the lunar month and Easter Sunday is
the first Sunday following that. In fact the formula is quite rough and ready as is
the Gregorian Calendar.

*/
constants	
	MARCH_21		: Integer = 31 + 28 + 21;
	GREGORY_START	: Integer = 1753;

vars
	yearNum			: Integer;
	century			: Integer;
	clavius			: Integer;
	dominical		: Integer;
	easter			: Integer;
	epact			: Integer;
	golden			: Integer;
	leap			: Integer;
	metonic_error	: Integer;
	moon			: Integer;
	paschal			: Integer;
	easter_sunday	: Date;

begin
	yearNum	:=	self;
	
	if (yearNum &lt; GREGORY_START) then
		easter_sunday.setDate(0, 0, 0);
		return easter_sunday;
	endif;

	century	:=	yearNum div 100;

	if (yearNum mod 4 = 0) and (yearNum mod 100 &lt;&gt; 0) or (yearNum mod 400 = 0) then
		leap	:=	1;
	else
		leap	:=	0;
	endif;				

	dominical		:=	7 - (yearNum + yearNum div 4 - century + century div 4 - 1 - leap) mod 7;
	golden			:=	yearNum mod 19 + 1;
	metonic_error	:=	(century - century div 4 - (century - (century - 17) div 25) div 3 - 8) mod 30;
	epact			:=	(11 * (golden - 1) - metonic_error) mod 30;
	moon			:=	31 - epact + 59 + leap;
	paschal			:=	moon + 13;	           // We got it - unless . .. .

	if (paschal &lt; (MARCH_21 + leap)) then	// It was before the Equinox.
		if (golden &gt; 11) then
			clavius	:=	26;
		else
			clavius	:=	25;
		endif;

		if (epact &lt; clavius) then
			moon	:=	moon + 29;
		else
			moon	:=	moon + 30;
		endif;

		paschal	:=	moon + 13;
	endif;	 				 			

	easter			:=	paschal + 7 - (paschal - dominical) mod 7;	// Sunday after Paschal full moon.
	easter_sunday.setDate(1, 1, yearNum);
	easter_sunday	:=	easter_sunday + easter - 1;

	return easter_sunday;
end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetHexColor" id="08c0527a-9811-4714-be49-58f9dcca6de8">
        <source>cnEcGetHexColor():String;
// --------------------------------------------------------------------------------
// Created:		06 June 2001 by cnwdad1
//
// Purpose:		Converts the receiver into an hexadecimal color, such as for HTML.
//				For example: FF0000
//
// Parameters:	None
//
// Returns:		The hexadecimal color value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	colorRed	: Integer;
	colorGreen	: Integer;
	colorBlue	: Integer;
	hexValue	: String;
	
begin
	self.cnEcGetRGBValues(colorRed, colorGreen, colorBlue);
	
	hexValue	:=	colorRed.Character.toHex &amp;
					colorGreen.Character.toHex &amp;
					colorBlue.Character.toHex;
epilog
	return hexValue;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetOrdinalWord" id="bf57dd2d-72b1-4320-bbb5-7f75d75f00a8">
        <source>cnEcGetOrdinalWord(pValue:String; pIsTeen:Boolean):String protected;
// --------------------------------------------------------------------------------
// Created:		06 May 2006 by cnwdad1
//
// Purpose:		Returns the ordinal
//
// Parameters:	pValue - The last value of the number who's ordinal to get.
//
// Returns:		The ordinal word.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pIsTeen then
		return "th";
	else
		if pValue = "0" then
			return "th";
		elseif pValue = "1" then
			return "st";
		elseif pValue = "2" then
			return "nd";
		elseif pValue = "3" then
			return "rd";
		else
			return "th";
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pValue" type="String"/>
        <Parameter name="pIsTeen" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetRGBValues" id="e0b5ca49-e7c9-423b-885e-0308cae1c0ee">
        <source>cnEcGetRGBValues(pColorRed:Integer output; pColorGreen:Integer output; pColorBlue:Integer output);
// --------------------------------------------------------------------------------
// Created:		06 June 2001 by cnwdad1
//
// Purpose:		Get the RGB values which make up the receiver's colour value.
//
// Parameters:	pColorRed (Integer) - The red part of the color.
//				pColorGreen (Integer) - The green part of the color.
//				pColorBlue (Integer) - The blue part of the color.
//
// Returns:		The red, green and blue values as output parameters.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	workValue	: Integer;
	
begin
	workValue	:=	self;	
	pColorRed	:=	workValue mod 256;
	workValue	:=	workValue div 256;
	pColorGreen	:=	workValue mod 256;
	workValue	:=	workValue div 256;
	pColorBlue	:=	workValue mod 256;
end;</source>
        <Parameter name="pColorRed" type="Integer" usage="output"/>
        <Parameter name="pColorGreen" type="Integer" usage="output"/>
        <Parameter name="pColorBlue" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetReverseColor" id="64ea7940-7814-4f1a-9ec7-bc98af273468">
        <source>cnEcGetReverseColor():Integer;
// --------------------------------------------------------------------------------
// Created:		30 March 2005 by cnwdad1
//
// Purpose:		Returns opposite of the color to the receiver's current color.
//
// Parameters:	None
//
// Returns:		The reverse color.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	colorRed	: Integer;
	colorGreen	: Integer;
	colorBlue	: Integer;
	revColor	: Integer;
	
begin
	revColor	:=	self.bitAnd(#FFFFFF);		// Remove sign bit if any.
	revColor.cnEcGetRGBValues(colorRed, colorGreen, colorBlue);
	
	// Get the opposite colors.
	colorRed	:=	(255 - colorRed).abs;
	colorBlue	:=	(255 - colorBlue).abs;
	colorGreen	:=	(255 - colorGreen).abs;
	revColor.cnEcSetColorFromRGB(colorRed, colorGreen, colorBlue);
	
	return revColor;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcIsAltKey" id="f0bc1311-0ea5-422d-ac51-ebfbb7c4ad7f">
        <source>cnEcIsAltKey():Boolean;
// --------------------------------------------------------------------------------
// Created:		24 January 2003 by cnwdad2
//
// Purpose:		Returns a boolean flag to indicate whether the ALT key is pressed.
//				This method assumes that the receiver is the value of the "shift"
//				parameter of various GUI object event methods, such as the keyDown,
//				keyUp, mouseDown, mouseMove and mouseUp events.
//
// Parameters:	None
//
// Returns:		True if the ALT key is pressed, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return (self.bitAnd(4) &lt;&gt; 0);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcIsBetween" id="2cfc8f0e-29bd-4369-8507-73a7cf231680">
        <source>cnEcIsBetween(pLowerValue:Integer; pUpperValue:Integer):Boolean;
// --------------------------------------------------------------------------------
// Created:		09 April 2002 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the receiver is within
//				(or equal to) to supplied range of values.
//
// Parameters:	pLowerValue - The lower limit of the range.
//				pUpperValue - The upper limit of the range.
//
// Returns:		True if the receiver is within the range, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return (self &gt;= pLowerValue and self &lt;= pUpperValue);
end;</source>
        <Parameter name="pLowerValue" type="Integer"/>
        <Parameter name="pUpperValue" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcIsCtrlKey" id="f2f1109f-9bb5-40e8-b030-e125ed445d9e">
        <source>cnEcIsCtrlKey():Boolean;
// --------------------------------------------------------------------------------
// Created:		24 January 2003 by cnwdad2
//
// Purpose:		Returns a boolean flag to indicate whether the CTRL key is pressed.
//				This method assumes that the receiver is the value of the "shift"
//				parameter of various GUI object event methods, such as the keyDown,
//				keyUp, mouseDown, mouseMove and mouseUp events.
//
// Parameters:	None
//
// Returns:		True if the CTRL key is pressed, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return (self.bitAnd(2) &lt;&gt; 0);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcIsLeapYear" id="8189b38d-9155-401c-ad2f-a3dd9fd66c63">
        <source>cnEcIsLeapYear():Boolean;
// --------------------------------------------------------------------------------
// Created:		02 November 2000 by cnwdad1
//
// Purpose:		Determines if the receiver year is a leap year.
//
// Parameters:	None
//
// Returns:		True if the receiver is a leap year, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
    return (self mod 4 = 0 and self mod 100 &lt;&gt; 0) or self mod 400 = 0;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcIsShiftKey" id="d8574344-6dd8-4289-b4ec-65548af78a49">
        <source>cnEcIsShiftKey():Boolean;
// --------------------------------------------------------------------------------
// Created:		24 January 2003 by cnwdad2
//
// Purpose:		Returns a boolean flag to indicate whether the Shift key is pressed.
//				This method assumes that the receiver is the value of the "shift"
//				parameter of various GUI object event methods, such as the keyDown,
//				keyUp, mouseDown, mouseMove and mouseUp events.
//
// Parameters:	None
//
// Returns:		True if the Shift key is pressed, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return (self.bitAnd(1) &lt;&gt; 0);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcNumberFormat" id="ed8d5951-e3ea-41ad-a2ad-7ad62eede96d">
        <source>cnEcNumberFormat():String;
// -----------------------------------------------------------------------------
// Created:		20 January 2002 by cnwdad1
//
// Purpose:		Formats the receiver as a string value, i.e. 1234 will be
//				returned as "1,234".
//
// Parameters:	None
//
// Returns:		The receiver formatted as a string.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	return self.userNumberFormat($CNEC_NO_DECIMALS);
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcOrdinalWord" id="6531b274-2bf0-4322-8632-f133b9238ab6">
        <source>cnEcOrdinalWord():String;
// --------------------------------------------------------------------------------
// Created:		06 May 2006 by cnwdad1
//
// Purpose:		Returns the receiver as an ordinal word, e.g. "26" would be returned
//				as "26th".
//
// Parameters:	None
//
// Returns:		The receiver with its ordinal word.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self = 0 then
		return "0";
	endif;
	
	if self.String.length() = 1 then
		return self.String &amp; self.cnEcGetOrdinalWord(self.String, false);
	endif;
	
	if self &gt;= 11 and self &lt;= 19 then
		return self.String &amp; self.cnEcGetOrdinalWord(self.String, true);
	else
		return self.String &amp; self.cnEcGetOrdinalWord(self.String[self.String.length():1], false);
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcPad" id="9e112817-bfb8-4bc1-a484-f718151ce71d">
        <source>cnEcPad(pLength:Integer):String;
// Turns an integer into a string with as many leading zeros as required.
vars
	paddedValue	: String;

begin
	paddedValue	:=	self.String;

	while paddedValue.length &lt; pLength do
		paddedValue	:=	"0" &amp; paddedValue;
	endwhile;

	return paddedValue; 
end;</source>
        <Parameter name="pLength" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcPadTrailingZeros" id="e03e5fd3-4674-445f-bea4-173491ee3aa3">
        <source>cnEcPadTrailingZeros(pLength:Integer):String;
// --------------------------------------------------------------------------------
// Created:		10 August 2001 by cnwdad1
//
// Purpose:		Pads the receiver with trailing zeros to the requested length, and
//				returns the result as a string.
//
//				If the receiver is already longer than the requested length, then
//				the receiver will be truncated and the result will be returned.
//
// Parameters:	pLength - The desired length of the result.
//
// Returns:		The padded (or truncated) receiver.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	returnString	: String;
	receiverLength	: Integer;
	
begin
	returnString	:=	self.String;
	receiverLength	:=	returnString.length;
	
	// If the receiver is the same length as the requested length, then no action
	// will be required.  If the receiver is longer than the requested length,
	// then truncate the receiver, otherwise pad the receiver to the requested
	// length.
	
	if receiverLength &gt; pLength then
		returnString	:=	returnString[1:pLength];
		
	elseif receiverLength &lt; pLength then
		returnString	:=	returnString &amp; "".padLeadingZeros(pLength - receiverLength);
		
	endif;
epilog
	return returnString;
end;</source>
        <Parameter name="pLength" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcSetColorFromRGB" id="75c177e9-ce94-4c87-a79b-dd3751c8050f">
        <updating/>
        <source>cnEcSetColorFromRGB(pColorRed:Integer; pColorGreen:Integer; pColorBlue:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		06 June 2001 by cnwdad1
//
// Purpose:		Sets the receiver to the JADE (Windows) color number corresponding
//				to the passed RGB values.
//
// Parameters:	pColorRed (Integer) - The red part of the color.
//				pColorGreen (Integer) - The green part of the color.
//				pColorBlue (Integer) - The blue part of the color.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self	:=	((pColorBlue * 256) + pColorGreen) * 256 + pColorRed;
end;</source>
        <Parameter name="pColorRed" type="Integer"/>
        <Parameter name="pColorGreen" type="Integer"/>
        <Parameter name="pColorBlue" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcSqrt" id="637eb247-85ee-4a85-83b9-2a69eeeaadb1">
        <source>cnEcSqrt():Decimal;
// --------------------------------------------------------------------------------
// Created:		06 May 2006 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	SqrtOf10 = 3.162277;
vars
	firstDigit			: Integer;
	intStr				: String;
	decAdjustment		: Real;
	result				: Decimal[23,1];//rough result
begin
	intStr := self.String;
	firstDigit := intStr[1:1].Integer;
	decAdjustment := SqrtOf10 ^ intStr.length;

	if firstDigit = 1 then
		result := 0.376 * decAdjustment;	        
	elseif firstDigit = 2 then
		result := 0.495 * decAdjustment;
	elseif firstDigit = 3 then
		result := 0.589 * decAdjustment;
	elseif firstDigit = 4 then
		result := 0.669 * decAdjustment;
	elseif firstDigit = 5 then
		result := 0.740 * decAdjustment;
	elseif firstDigit = 6 then
		result := 0.805 * decAdjustment;
	elseif firstDigit = 7 then
		result := 0.866 * decAdjustment;
	elseif firstDigit = 8 then
		result := 0.922 * decAdjustment;
	elseif firstDigit = 9 then
		result := 0.975 * decAdjustment;
	endif;
	
	return result;
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="cnEcTableCheckBoxValue" id="2290447c-a5ad-42ce-9256-a345153c7c77">
        <source>cnEcTableCheckBoxValue():Boolean;
// --------------------------------------------------------------------------------
// Created:		26 February 2007 by cnwdad1
//
// Purpose:		Returns a boolean value, assuming that the receiver is the value of
//				a checkbox in a table cell (which will be "1" or "0").
//
// Parameters:	None
//
// Returns:		True if the value is 1, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return (self = 1);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcTake" id="e2833ed8-6cff-4227-97e2-464b1beb8a29">
        <updating/>
        <source>cnEcTake(pDecrement:Integer):Integer updating;
// --------------------------------------------------------------------------------
// Created:		05 February 2001 by cnwdad1
//
// Purpose:		Decrements the receiver by the value specified by the parameter,
//				and returns the result.
//
//				*************************************************************
//				* NOTE: Do not use this method to decrement a loop counter. *
//				*************************************************************
//
// Parameters:	pDecrement (Integer) - The amount by which to decrement the receiver.
//
// Returns:		The result of the decrement.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self &gt;= (Min_Integer + pDecrement) then
		self := self - pDecrement;
	endif;
epilog
	return self;
end;</source>
        <Parameter name="pDecrement" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</PrimType>
