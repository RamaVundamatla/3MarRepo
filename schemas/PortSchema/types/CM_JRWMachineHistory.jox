    <JadeMethod name="getIdleCount" id="da490a7d-a6b9-417f-98a4-0953f9ee1b1e">
        <source>getIdleCount() : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 Apr 2025	navnk30	JIRA 34453: MSL | Report for Machine Idle Time

*/

vars
	hist		: CM_MachineHistory;
	idleCount	: Integer;
	startTS,
	endTS		: TimeStamp;
	histDict	: CM_MachineHistoryByDateTime;
begin
	startTS.cnEcSetDateAndTime(self.dateFrom, self.timeFrom);
	endTS.cnEcSetDateAndTime(self.dateTo, self.timeTo);
	
	histDict := self.myMachine.history;
	
	foreach hist in histDict do
		if hist.type &lt;&gt; CM_MachineHistory.Type_Idle or
				hist.dateTime &lt; startTS or 
				hist.dateTime &gt; endTS then
			continue;
		endif;
		idleCount += 1;
	endforeach;
	return idleCount;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getIdleTimeInMins" id="aa9b0282-d251-44cf-82fb-54e92e284e5c">
        <source>getIdleTimeInMins() : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 Apr 2025	navnk30	JIRA 34453: MSL | Report for Machine Idle Time

*/

vars
	iter			: Iterator;
	hist			: CM_MachineHistory;
	nextTrxTS		: TimeStamp;
	interval		: TimeStampInterval;
	idleTimeMins	: Integer;
	config			: CM_RTVehicleConfig;
	configIdleMins	: Integer;
	machineTerminal	: CM_Terminal;
	startTS,
	endTS		: TimeStamp;
begin
	if self.myMachine = null or self.myMachine.history.isEmpty() then
		return 0;
	endif;
	
	machineTerminal := self.myMachine.myTerminal;
	startTS.cnEcSetDateAndTime(self.dateFrom, self.timeFrom);
	endTS.cnEcSetDateAndTime(self.dateTo, self.timeTo);
	nextTrxTS := app.actualTimeServer();
	if nextTrxTS &gt; endTS then
		nextTrxTS := endTS;
	endif;
	
	if machineTerminal.getConfig(IdleTimeEnabled).Boolean then
		config := machineTerminal.getRTVehicleConfigForObject(self.myMachine);
		if config &lt;&gt; null then
			configIdleMins := config.idleTimeAllowable;
		endif;
	endif;
	
	/**
	 * Calculates the idle time by traversing the machine history in reverse order.
	 * Whenever an 'Idle History' is found, the duration between its DateTime
	 * and the DateTime of the next history is added.
	 */
	iter := self.myMachine.history.createIterator();
	while iter.back(hist) do
		if hist.dateTime &lt; startTS then 
			break; 
		elseif hist.dateTime &lt;= endTS then
			if hist.type = CM_MachineHistory.Type_Idle then
				interval := nextTrxTS - hist.dateTime;
				idleTimeMins := idleTimeMins + interval.asMinutes.Integer;
			endif;
			nextTrxTS := hist.dateTime;
		endif;
	endwhile;
	return idleTimeMins;
epilog
	delete iter;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
