    <JadeMethod name="translateForm" id="6a0dce0a-d422-4b97-a418-dc1157a09f37">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 16 June 2022 09:07:08.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0005844, locale);
	btnBerthUsage.translateBubbleHelp(Xlat_0001522, locale);
	btnBerthUsage.translateCaption(Xlat_0001525, locale);
	btnCancel.translateBubbleHelp(Xlat_0001501, locale);
	btnCancel.translateCaption(Xlat_0001511, locale);
	btnCancelToolTip.translateCaption(Xlat_0001479, locale);
	btnConflicts.translateBubbleHelp(Xlat_0014384, locale);
	btnConflicts.translateCaption(Xlat_0001512, locale);
	btnLock.translateBubbleHelp(Xlat_0001503, locale);
	btnLock.translateCaption(Xlat_0001513, locale);
	btnNSEWChanges.translateBubbleHelp(Xlat_0001494, locale);
	btnNSEWChanges.translateCaption(Xlat_0001497, locale);
	btnNewVoyage.translateBubbleHelp(Xlat_0001504, locale);
	btnNewVoyage.translateCaption(Xlat_0001514, locale);
	btnPosDetail.translateBubbleHelp(Xlat_0001505, locale);
	btnPosDetail.translateCaption(Xlat_0001515, locale);
	btnPrint.translateBubbleHelp(Xlat_0016574, locale);
	btnPrint.translateCaption(Xlat_0016575, locale);
	btnRedo.translateBubbleHelp(Xlat_0001506, locale);
	btnRedo.translateCaption(Xlat_0001516, locale);
	btnRefreshScales.translateBubbleHelp(Xlat_0001473, locale);
	btnRefreshScales.translateCaption(Xlat_0001480, locale);
	btnResourcesUsed.translateBubbleHelp(Xlat_0014385, locale);
	btnResourcesUsed.translateCaption(Xlat_0001481, locale);
	btnRoadStead.translateBubbleHelp(Xlat_0001507, locale);
