    <JadeMethod name="createEntry" id="14e05039-e967-453e-a125-18a83ec2612c">
        <lockReceiver/>
        <updating/>
        <source>createEntry():JSSElement updating, protected;
// --------------------------------------------------------------------------------
// Created:		29 August 1999 -  createEntry
// By:			cnwdad1
//
// Purpose:		Private method to create a new CnEcArrayObject instance for a new
//				element in the array.
//
// Parameters:	None
// Returns:		CnEcArrayObject - The newly created instance of CnEcArrayObject.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theElement	: JSSElement;

begin
	if self.isTransient() then
		create theElement transient;
	else
		create theElement;
	endif;
epilog
	return theElement;
end;</source>
        <access>protected</access>
        <ReturnType type="JSSElement"/>
    </JadeMethod>
    <JadeMethod name="delete" id="a71f1ff9-e3b0-4247-b5de-330ab1f2db0e">
        <lockReceiver/>
        <updating/>
        <source>delete() updating, protected, lockReceiver;
// --------------------------------------------------------------------------------
// Created:		16 April 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.purge();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getBinaryAt" id="1b2a4b6e-0b58-409c-8d52-8e354eb702a3">
        <source>getBinaryAt(pIndex:Integer):Binary;
// --------------------------------------------------------------------------------
// Created:		29 August 1999 -  getBinary
// By:			cnwdad1
//
// Purpose:		Returns the binary value of a specified array element.
//
// Parameters:	pIndex (Integer) - The index of the array element whose value to return.
// Returns:		Binary - The binary value of the specified array element.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars

begin
	if pIndex &gt; self.size() then
		return null;
	else
		return self[pIndex].getBinaryValue();
	endif;
end;</source>
        <Parameter name="pIndex" type="Integer"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="getStringAt" id="35a5c414-5786-4df0-b913-2f92a16bb5aa">
        <source>getStringAt(pIndex:Integer):String;
// --------------------------------------------------------------------------------
// Created:		29 August 1999 -  getString
// By:			cnwdad1
//
// Purpose:		Returns the string value of a specified array element.
//
// Parameters:	pIndex (Integer) - The index of the array element whose value to return.
// Returns:		String - The string value of the specified array element.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars

begin
	if pIndex &gt; self.size() then
		return null;
	else
		return self[pIndex].getStringValue();
	endif;
end;</source>
        <Parameter name="pIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="removeBinary" id="57db76b4-e302-41cf-a836-c83f38094a5e">
        <lockReceiver/>
        <updating/>
        <source>removeBinary(pBinaryValue:Binary):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		29 August 1999 -  removeBinary
// By:			cnwdad1
//
// Purpose:		Removes an array element which has a specified binary value.
//
// Parameters:	pBinaryValue (Binary) - The value to scan for in the array.
// Returns:		Boolean - True is an element was removed, false if not.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	elementsToDelete	: ObjectArray;
	object				: Object;
	theElement			: JSSElement;
	isRemoved			: Boolean;

begin
	create elementsToDelete transient;

	// Find the array elements to be removed.

	foreach theElement in self do
		if (theElement.getBinaryValue() = pBinaryValue) then
			elementsToDelete.add(theElement);
		endif;
	endforeach;

	// Now removed the matching array elements.

	foreach object in elementsToDelete do
		self.remove(object.JSSElement);

		if (not isRemoved) then
			isRemoved	:=	true;
		endif;
	endforeach;
epilog
	delete elementsToDelete;

	return isRemoved;
end;</source>
        <Parameter name="pBinaryValue" type="Binary"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="removeString" id="d52fdefe-eab2-4de3-8459-52ac375e903d">
        <lockReceiver/>
        <updating/>
        <source>removeString(pStringValue:String):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		29 August 1999 -  removeString
// By:			cnwdad1
//
// Purpose:		Removes an array element which has a specified string value.
//
// Parameters:	pStringValue (String) - The value to scan for in the array.
// Returns:		Boolean - True is an element was removed, false if not.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	elementsToDelete	: ObjectArray;
	object				: Object;
	theElement			: JSSElement;
	isRemoved			: Boolean;

begin
	create elementsToDelete transient;

	// Find the array elements to be removed.

	foreach theElement in self do
		if theElement.getStringValue() = pStringValue then
			elementsToDelete.add(theElement);
		endif;
	endforeach;

	// Now removed the matching array elements.

	foreach object in elementsToDelete do
		self.remove(object.JSSElement);

		if (not isRemoved) then
			isRemoved	:=	true;
		endif;
	endforeach;
epilog
	delete elementsToDelete;

	return isRemoved;
end;</source>
        <Parameter name="pStringValue" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</CollClass>
