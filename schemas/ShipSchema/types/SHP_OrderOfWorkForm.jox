    <JadeMethod name="getJobType" id="d2e25bec-d888-4bb4-92e5-f4cb0060b792">
        <source>getJobType(): Integer;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 July 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars

begin

	if self.filterWorkPoint &lt;&gt; null then
		return CMQF_VoyageOrderOfWork.JobType_Crane;
	elseif self.filterUnallocatedJobs then
		return self.JobType_UnallocatedSC;
	elseif self.filterJobState = JOB_COMPLETE then
		return self.JobType_CompleteSC;
	elseif self.filterJobState = JOB_PART_COMPLETE then
		return self.JobType_PartCompleteSC;
	endif;
	
	return self.JobType_AllSC;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getNumberOfTotalRows" id="72915872-f76d-4fef-902d-a0bb3313b383">
        <source>getNumberOfTotalRows() :Integer;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 October 2008	cnwer1	Initial creation

*/
constants
	BaseTotalRows = 6;
	
vars
	totalRows : Integer;
begin
	if self.showLengthOther then
		return BaseTotalRows + 1;
	endif;
	totalRows:=BaseTotalRows;
	if self.showLength30 then
		totalRows:= totalRows + 1;
	endif;
	if self.showLength45 then
		totalRows:= totalRows + 1;
	endif;
	if self.showLength53 then
		totalRows:= totalRows + 1;
	endif;
	
	return totalRows;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
