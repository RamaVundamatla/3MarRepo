    <JadeMethod name="clear" id="8db8093f-cb10-4763-92e8-b26e2bc779b2">
        <source>clear();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 May 2010	cnwjk3	Initial creation

*/

vars

begin
	self.allLCsByGridPos.purge();
	self.allTIsByGridPos.purge();
	self.allGridLocationsByLCoid.purge();
epilog

end;</source>
