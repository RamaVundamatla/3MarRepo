    <JadeMethod name="doCopyDeck" id="faed0ef4-d75c-453c-9211-6d2111cca5c9">
        <source>doCopyDeck() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

	deck, copyDeck : CM_DeckVoyage;
	
begin

	deck:=self.getSelectedDeck.CM_DeckVoyage;
	
	if deck = null then
		return;
	endif;
	
	//epr par 27486 16/5/11
	if deck.isKindOf(CM_DeckVoyageSub) then
		copyDeck:=deck.CM_DeckVoyageSub.cloneMySelfSub(deck.CM_DeckVoyageSub.myParentDeck, true, true);
	else
		copyDeck:=deck.cloneMySelf(deck.myVoyageStructure, true, true);
	endif;

	self.myAssistant.SHP_Assistant.showROROVoyageDeckDefn(self.myROROVoyageStructure,copyDeck,SHP_RORODeckDefinitionForm.Mode_Copy);


epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doEditDeck" id="03067c33-377b-41f4-88d3-cb06afc6d814">
        <source>doEditDeck() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

	deck : CM_DeckVoyage;
begin

	if self.tbRoRolDecks.accessRow(self.tbRoRolDecks.row) = null then
		return;
	endif;
	deck:=self.tbRoRolDecks.accessRow(self.tbRoRolDecks.row).itemObject.CM_DeckVoyage;

	if deck &lt;&gt; null then
		self.myAssistant.SHP_Assistant.showROROVoyageDeckDefn(self.myROROVoyageStructure,deck,SHP_RORODeckDefinitionForm.Mode_Edit);
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doNewDeck" id="f66a6b94-2611-4aeb-8126-fc266acd99a6">
        <source>doNewDeck() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

begin
	self.myAssistant.SHP_Assistant.showROROVoyageDeckDefn(self.myROROVoyageStructure,null,SHP_RORODeckDefinitionForm.Mode_New);

epilog

