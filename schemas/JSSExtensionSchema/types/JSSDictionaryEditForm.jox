    <JadeMethod name="doFormLoad" id="7a97398d-04c3-4f73-b6f5-4e48cfa5ed38">
        <updating/>
        <source>doFormLoad() updating, protected;
// --------------------------------------------------------------------------------
// Created:		09 September 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod();
	
	create self.aMyTA transient;
	
	lstDictionaries.listCollection(app.jssMyRoot.allDictionaries, true, Collection.JSS_ORDER_COLLECTION);
	self.enableButtons();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormUnload" id="215d991d-cc82-485e-a74a-e6092d5b7aba">
        <updating/>
        <source>doFormUnload() updating, protected;
// --------------------------------------------------------------------------------
// Created:		09 September 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	delete self.aMyTA;
	
	inheritMethod();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormUpdate" id="50f85ed8-7183-4ae0-91c0-dd7f2f371103">
        <updating/>
        <source>doFormUpdate(pIsDelete: Boolean): Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		09 September 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	dictionaryName	: String;
	theDictionary	: JSSWordDictionary;
	
begin
	dictionaryName	:=	txtName.jssString();
	theDictionary	:=	lstDictionaries.listObject.JSSWordDictionary;
	
	if self.aIsNew then
		self.aMyTA.trxCreateDictionary(app.jssMyRoot, dictionaryName, theDictionary);
	elseif pIsDelete then
		self.aMyTA.trxDeleteDictionary(theDictionary);
	else
		self.aMyTA.trxUpdateDictionary(theDictionary, self.aObjectEdition, app.jssMyRoot, dictionaryName);
	endif;
	
	return inheritMethod(pIsDelete);
end;</source>
        <access>protected</access>
        <Parameter name="pIsDelete" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="enableButtons" id="ae08a20c-35b9-40a9-97a5-25b423c84dac">
        <source>enableButtons() protected;
// --------------------------------------------------------------------------------
// Created:		09 September 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if lstDictionaries.listIndex = JSS_NULL_INDEX then
		if txtName.text = null then
			btnAdd.enabled		:=	false;
		else
			btnAdd.enabled		:=	true;
		endif;
		
		btnDelete.enabled	:=	false;
		btnUpdate.enabled	:=	false;
	else
		if txtName.text = null then
			btnAdd.enabled		:=	false;
			btnUpdate.enabled	:=	false;
		else
			btnAdd.enabled		:=	true;
			btnUpdate.enabled	:=	true;
		endif;
		
		btnDelete.enabled	:=	true;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="lstDictionaries_click" id="b694349a-cc00-4279-9ad7-e22ab7c3c894">
        <controlMethod name="ListBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstDictionaries_click(listbox: ListBox input) updating;
// --------------------------------------------------------------------------------
// Created:		09 September 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if listbox.listIndex = JSS_NULL_INDEX then
		txtName.text	:=	null;
	else
		txtName.text	:=	listbox.text;
		self.resynchObjectAndSetEdition(listbox.listObject);
	endif;
	
	self.enableButtons();
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lstDictionaries_displayEntry" id="172845a6-837f-47c1-9f37-d29a7186601c">
        <controlMethod name="ListBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstDictionaries_displayEntry(listbox: ListBox input; obj: Any; lstIndex: Integer):String updating;
// --------------------------------------------------------------------------------
// Created:		09 September 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return obj.JSSWordDictionary.dictionaryName;
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="obj" type="Any"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
