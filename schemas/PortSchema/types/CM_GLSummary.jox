    <JadeMethod name="getCargoIds" id="bd9f305e-395f-44c6-9cc9-28b1986972fc">
        <source>getCargoIds():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Mar 2020 cnwma1 Requirement 45899: CPL - Credit Invoice Details for Print

*/
constants
	 NoPerLine  = 10;
vars
	invLine 	: CM_InvoiceLine;
	cargoIds   	: String;
	cargoIdsArr : CM_TIArray;
	ti          : CM_TrackedItem;
	count       : Integer;
begin
	create cargoIdsArr  transient;
	foreach invLine in self.allInvoiceLines do
	
		if invLine.trackedItem &lt;&gt; null then
			cargoIdsArr.addExclusive(invLine.trackedItem);
		endif;
	endforeach;
	
	foreach  ti in cargoIdsArr do
		
		if cargoIds = null then
			cargoIds := ti.id;
		else
			cargoIds :=  cargoIds &amp; Comma &amp; ti.id ;
		endif;
		count := count + 1;
		
		if count mod NoPerLine = 0 then
			cargoIds :=  cargoIds &amp; CrLf  ;
		endif;
	endforeach;
	
	return cargoIds;
epilog
	delete cargoIdsArr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getServiceObject" id="27745ea3-6189-48be-a37c-ba268fac6e22">
        <source>getServiceObject() : CM_Service;
/*
Purpose:			
Date		Who		Reason
11 June 2013	cnwab1	Initial creation
*/

vars
	bu : CM_Bank;
begin
	
	if self.myInvoiceLine = null then
		return null;
	endif;
	
	bu := self.myInvoiceLine.bank;
	
	if bu = null then
		return null;
	endif;
	
	return bu.services[self.serviceName];
	
epilog

end;</source>
        <ReturnType type="CM_Service"/>
    </JadeMethod>
    <JadeMethod name="getTaxForInvoice" id="07ad9851-0a56-4035-a11b-36060849396c">
        <source>getTaxForInvoice(_useSplitTax : Boolean; _codes : StringArray input; _rates  : RealArray input; _amounts : RealArray input);
// ---------------------------------------------------------------------------
// Created:		18 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	effectiveDate	: TimeStamp;
	aService : CM_Service;
	charge: CM_Charge;
	glSumm : CM_GLSummaryByGLCodeRateDict;
	glStat : CM_GLSummary;
	aLineDesc : CM_InvoiceLineDesc;
	theInvoiceLine : CM_InvoiceLine;
	taxCode : CM_TaxCode;
	pTaxCode : String;
	pTaxRate : Real;
	taxRate : CM_TaxRate;
	idx : Integer;
	theInvoice : CM_Invoice;
	theBank : CM_Bank;
	debtor: CM_Debtor;
	voyage :  CM_Voyage;
	hookExempt : Boolean;
begin
	theInvoice := self.myInvoiceLine.invoice;
	debtor := theInvoice.debtor;
	if debtor &lt;&gt; null and debtor.isZeroRatedTax then		// 19/10/17 MAP TFS7357
		return;
	endif;
	theBank := theInvoice.bank;
	aService := theBank.services[self.serviceName];
	if aService = null then
		return;
	endif;
	
	
	// TFS 37562 exempt by voyage
	if theInvoice &lt;&gt; null then
		voyage := theInvoice.myVoyage;
		if voyage &lt;&gt; null then
			hookExempt := app.myRoot.getVoyageTaxExempt( voyage.myTerminal, voyage ).Boolean;
			if hookExempt then
				return;
			endif;
		endif;
	endif;
	
	
	effectiveDate := theInvoice.toDT;
	if not effectiveDate.isValid() then
		effectiveDate := theInvoice.postedDT;
	endif;
	if not effectiveDate.isValid() then
		effectiveDate := theInvoice.createdTime;
	endif;
	pTaxCode := theBank.parentCompany.taxNumber;
	pTaxRate := theBank.parentCompany.taxPercentageRate;
	
	taxCode := aService.myTaxCode;
	if taxCode &lt;&gt; null then
		idx := _codes.indexOf(taxCode.code);
		if idx = 0  then
			_codes.add(taxCode.code);
			idx := _codes.size;
			_amounts.add(0);
			
			taxRate := taxCode.getTimeRate(effectiveDate);
			if taxRate = null then
				_rates.add(0);
			else
				_rates.add(taxRate.rate);
			endif;
		endif;
		_amounts[idx] := _amounts[idx] + self.amount;
	else
		idx := _codes.indexOf(pTaxCode);
		if idx = 0  then
			_codes.add(pTaxCode);
			idx := _codes.size;
			_rates.add(pTaxRate);
			_amounts.add(0);
		endif;

		_amounts[idx] := _amounts[idx] + self.amount;

	endif;
end;</source>
        <Parameter name="_useSplitTax" type="Boolean"/>
        <Parameter name="_codes" type="StringArray" usage="input"/>
        <Parameter name="_rates" type="RealArray" usage="input"/>
        <Parameter name="_amounts" type="RealArray" usage="input"/>
    </JadeMethod>
</Class>
