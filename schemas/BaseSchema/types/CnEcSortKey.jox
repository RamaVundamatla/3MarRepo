    <JadeMethod name="getKey" id="9692fc5d-3c03-4072-ad48-062a2602d5d2">
        <source>getKey():Any;
// --------------------------------------------------------------------------------
// Created:		08 February 2001 by cnwdad1
//
// Purpose:		Returns the value of this member of the CnEcSorter's dynamic dictionary.
//
// Parameters:	pObject - A reference to the object associated with the key.
//
// Returns:		The value of the property corresponding to the type of sort.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.typeOfSort = CnEcSorter.AS_BOOLEAN then
		return self.booleanValue;
		
	elseif self.typeOfSort = CnEcSorter.AS_CHARACTER then
		return self.charValue;
		
	elseif self.typeOfSort = CnEcSorter.AS_DATE then
		return self.dateValue;
		
	elseif self.typeOfSort = CnEcSorter.AS_DECIMAL then
		return self.decimalValue;
		
	elseif self.typeOfSort = CnEcSorter.AS_INTEGER then
		return self.integerValue;
		
	elseif self.typeOfSort = CnEcSorter.AS_REAL then
		return self.realValue;
		
	elseif self.typeOfSort = CnEcSorter.AS_STRING then
		return self.stringValue;
		
	elseif self.typeOfSort = CnEcSorter.AS_TIME then
		return self.timeValue;
		
	elseif self.typeOfSort = CnEcSorter.AS_TIMESTAMP then
		return self.timestampValue;
		
	endif;
end;</source>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="getKeyWithObject" id="6027935a-ff77-48eb-9ce5-2881d3ecc30b">
        <source>getKeyWithObject(pObject:Object output):Any;
// --------------------------------------------------------------------------------
// Created:		26 October 2005 by cnwdad1
//
// Purpose:		Returns the value of this member of the CnEcSorter's dynamic dictionary.
//
// Parameters:	pObject - A reference to the object associated with the key.
//
// Returns:		The value of the property corresponding to the type of sort, and
//				any associated object via the output parameters.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	pObject	:=	self.myObject;
	
	return self.getKey();
end;</source>
        <Parameter name="pObject" type="Object" usage="output"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="setKey" id="58282a54-ec39-4dbe-9d48-9aedc3fbf139">
        <updating/>
        <source>setKey(pValue:Any; pSortType:String) updating;
// --------------------------------------------------------------------------------
// Created:		08 February 2001 by cnwdad1
//
// Purpose:		Set the key sort value for the receiver.
//
// Parameters:	pValue - The key sort value.
//				pSortType - The primtive type of the key.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.typeOfSort	:=	pSortType;
	
	if pSortType = CnEcSorter.AS_BOOLEAN then
		self.booleanValue	:=	pValue.Boolean;
		
	elseif pSortType = CnEcSorter.AS_CHARACTER then
		self.charValue		:=	pValue.Character;
		
	elseif pSortType = CnEcSorter.AS_DATE then
		self.dateValue		:=	pValue.Date;
		
	elseif pSortType = CnEcSorter.AS_DECIMAL then
		self.decimalValue	:=	pValue.Decimal;
		
	elseif pSortType = CnEcSorter.AS_INTEGER then
		self.integerValue	:=	pValue.Integer;
		
	elseif pSortType = CnEcSorter.AS_REAL then
		self.realValue		:=	pValue.Real;
		
	elseif pSortType = CnEcSorter.AS_STRING then
		self.stringValue	:=	pValue.String;
		
	elseif pSortType = CnEcSorter.AS_TIME then
		self.timeValue		:=	pValue.Time;
		
	elseif pSortType = CnEcSorter.AS_TIMESTAMP then
		self.timestampValue	:=	pValue.TimeStamp;
		
	endif;
end;</source>
        <Parameter name="pValue" type="Any"/>
        <Parameter name="pSortType" type="String"/>
    </JadeMethod>
    <JadeMethod name="setKeyWithObject" id="c60a9b89-ce9b-4005-bef0-8a9a36106424">
        <updating/>
        <source>setKeyWithObject(pValue:Any; pObject:Object; pSortType:String) updating;
// --------------------------------------------------------------------------------
// Created:		26 October 2005 by cnwdad1
//
// Purpose:		Set the key sort value for the receiver.
//
// Parameters:	pValue - The key sort value.
//				pObject - A reference to the object associated with the key.
//				pSortType - The primtive type of the key.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.myObject	:=	pObject;
	self.setKey(pValue, pSortType);
end;</source>
        <Parameter name="pValue" type="Any"/>
        <Parameter name="pObject" type="Object"/>
        <Parameter name="pSortType" type="String"/>
    </JadeMethod>
</Class>
