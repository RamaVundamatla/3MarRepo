    <JadeMethod name="getBulkDescForRailAssign" id="0a977732-d9cf-49d0-8025-f5cf35dac2c3">
        <source>getBulkDescForRailAssign():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 February 2017	cnwndl1	Initial creation	TFS 3514

*/

vars

	isByWeightOrVolume : Boolean;
	cargoType : CM_CargoType;
	density : Decimal [16,4];
	
	totReq : Integer;
	totAct : Integer;
	totDel : Integer;
	osValue : Integer;
	wtReq : Decimal [16,4];
	wtAct : Decimal [16,4];	
	wtDel : Decimal [16,4];
	osWeight : Decimal [16,4];
	
	measurementType : CM_MeasurementType;
	remainingStr : String;

begin

	cargoType := self.getCargoType();
	
	if cargoType &lt;&gt; null then
		if cargoType.isBulkByVolume or cargoType.isBulkByWeight then
			isByWeightOrVolume := true;	
		endif;
	
		// get the remaining amount for display
		if isByWeightOrVolume then	
			wtReq := self.weightRequested;
			self.quantityOnSiteWithJobRail( wtAct );	
			wtDel := self.getWeightReleased();
			osWeight := wtReq - wtAct - wtDel;
			
			if cargoType.isBulkByVolume then
				density := self.getDensity();
				if density &lt;= 0 then
					return self.getDescription;
				endif;
				measurementType := cargoType.getDefaultMeasurementForType(Type_Volume);
				remainingStr := app.getErrorString1( AmountToAssign, app.convertMeasurementForDisplay(measurementType.shortName, osWeight / density) &amp; " " &amp; measurementType.shortName );
			else
				measurementType := cargoType.getDefaultMeasurementForType(Type_Weight);
				remainingStr := app.getErrorString1( AmountToAssign, app.convertMeasurementForDisplay(measurementType.shortName, osWeight) &amp; " " &amp; measurementType.shortName );
			endif;
		
		else	
			totReq := self.totalRequested;
			totAct := self.quantityOnSiteWithJobRail( wtAct );
			totDel := self.allTrackedItemsReleased.size;
			osValue := totReq - totAct - totDel;
			
			remainingStr := app.getErrorString1( AmountToAssign, osValue.String );
			
		endif;
		
	//	return remainingStr &amp; self.getDescription;
		return remainingStr &amp; " " &amp; self.myReserveHeader.code &amp; " - " &amp; self.getDescription;

	else
	
		return self.getDescription;
	
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
