		table.hideRowByName(ETRow_Expiry, false);
		//table.showRowByName(ETRow_Description, false);
		table.showRowByName(ETRow_Id, false);
		table.showRowByName(ETRow_DoorDirectionRuleWording, false);
		table.showRowByName(ETRow_IsoTypeGroup, false);
		table.hideRowByName(ETRow_MaxCapacity, false); //par18840 cnwjo3
		table.hideRowByName(ETRow_HazardClass, false);								// TFS 2844
		table.hideRowByName(ETRow_Flashpoint, false);								// TFS 2844
		table.hideRowByName(ETRow_PackingGroup, false);								// TFS 2844
		table.hideRowByName(ETRow_AcidsBases, false);								// TFS 2844
		table.hideRowByName(ETRow_AllowNonHazardous, false);						// TFS 2844
		table.hideRowByName(ETRow_ShowError, false);								// TFS 2844
		sheet.cnEcResizeContents();
		
		if not ta.isRestrictionBlockStack()	then 
			if gridArea &lt;&gt; null then
				gridArea.YRD_PadArea.areaMode := YRD_PadArea.AreaMode_DoorDirection;
			endif;
		endif;
		
		self.setNavigatorHeading(ta.id &amp; " "  &amp; xlation);

		if not app.myCurrentUserCan(self.myTerminal,PmAdmDoorDirectionsUpdate) then
			self.shtRestrictData.disableAllChildren();
			self.btnEditTV.enabled:= false;
		endif;
		
	// ### HAZARDS TFS 2844 STWR Hazardous Detaisl Enhancements						// TFS 2844
		elseif _areaMode = YRD_PadArea.AreaMode_Hazardous then							// TFS 2844
		self.sptThumbEdit.showLeftControl(35, true);								// TFS 2844
																						// TFS 2844
		xlation			:= app.getErrorString (Hazards);							// TFS 2844
		sheet.caption 	:= xlation;													// TFS 2844
		sheet.visible 	:= true;													// TFS 2844
		sheet.enabled 	:= true;													// TFS 2844
																						// TFS 2844
		sheet.setFocus();															// TFS 2844
																						// TFS 2844
		
		table.showRowByName(ETRow_Id, false);										// TFS 2844
		table.showRowByName(ETRow_Colour, false);									// TFS 2844
		table.showRowByName(ETRow_HazardClass, false);								// TFS 2844
		table.showRowByName(ETRow_Flashpoint, false);								// TFS 2844
		table.showRowByName(ETRow_PackingGroup, false);								// TFS 2844
		table.showRowByName(ETRow_AcidsBases, false);								// TFS 2844
		table.showRowByName(ETRow_AllowNonHazardous, false);						// TFS 2844
		table.showRowByName(ETRow_ShowError, false);								// TFS 2844
																					// TFS 2844
		table.hideRowByName(ETRow_HideFromOverView, false);							// TFS 2844
		table.hideRowByName(ETRow_Washed, false);									// TFS 2844
		table.hideRowByName(ETRow_TestISOTypeGroup, false);							// TFS 2844
		table.hideRowByName(ETRow_HeavyLift, false);								// TFS 2844
		table.hideRowByName(ETRow_WaterCooled, false);								// TFS 2844
		table.hideRowByName(ETRow_ImportsOnly, false);								// TFS 2844
		table.hideRowByName(ETRow_ExportsOnly, false);								// TFS 2844
		table.hideRowByName(ETRow_StockControlled, false);							// TFS 2844
		table.hideRowByName(ETRow_RehandlesOnly, false);							// TFS 2844
		table.hideRowByName(ETRow_AllStops, false);									// TFS 2844
		table.hideRowByName(ETRow_Comment, false);									// TFS 2844
		table.hideRowByName(ETRow_Organisation, false);								// TFS 2844
		table.hideRowByName(ETRow_DurationHours, false);							// TFS 2844
		table.hideRowByName(ETRow_DurationDays, false);								// TFS 2844
		table.hideRowByName(ETRow_Reason, false);									// TFS 2844
		table.hideRowByName(ETRow_NotifyOnExpiry, false);							// TFS 2844
		table.hideRowByName(ETRow_Expiry, false);									// TFS 2844
		table.hideRowByName(ETRow_DoorDirectionRuleWording, false);					// TFS 2844
		table.hideRowByName(ETRow_IsoTypeGroup, false);								// TFS 2844
		table.hideRowByName(ETRow_MaxCapacity, false);								// TFS 2844
		table.hideRowByName(ETRow_Description, false);								// TFS 2844
		sheet.cnEcResizeContents();													// TFS 2844
																					// TFS 2844
																					
		if not ta.isRestrictionBlockStack()	then 									// TFS 2844
			if gridArea &lt;&gt; null then												// TFS 2844
				gridArea.YRD_PadArea.areaMode := YRD_PadArea.AreaMode_Hazardous;	// TFS 2844
			endif;																	// TFS 2844	
		endif;																		// TFS 2844
																					// TFS 2844
		self.setNavigatorHeading(ta.id &amp; " "  &amp; xlation);							// TFS 2844
																					// TFS 2844
		if not app.myCurrentUserCan(self.myTerminal, PmAdmHazardAreaMaint) then		// TFS 2844
			self.btnEditTV.enabled := false;										// TFS 2844
			self.btnNewTV.enabled := false;											// TFS 2844
			self.btnDeleteTV.enabled := false;										// TFS 2844
		endif;																		// TFS 2844
		
		
	else
		if gridArea &lt;&gt; null then
			gridArea.YRD_PadArea.areaMode := 0;
		endif;
		
		self.myMasterMenuAction.setHeading(ta.id &amp; " Unknown"); 
	endif;

	if not ta.isRestrictionBlockStack() then
		if gridArea &lt;&gt; null then
			self.mySDF.drawSelf();
		endif;
	endif;

	self.fldTop.initSheetBackColors();
epilog
	if self.topSheet.visible then
		self.fldTop.topSheet := self.topSheet;
	endif;
end;</source>
