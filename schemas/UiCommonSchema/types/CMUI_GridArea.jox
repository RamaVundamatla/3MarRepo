    <JadeMethod name="redrawGridArea" id="1b111657-a552-4eca-bf53-d4a501991586">
        <updating/>
        <source>redrawGridArea() updating;
// ---------------------------------------------------------------------------
// Created:		12 August 2003 by cnwsgp1
// ---------------------------------------------------------------------------
vars
	gridPoint	: CMUI_GridPoint;
	gridFrame	: CMUI_GridAreaFrame;
	lNow 		: TimeStamp;
	attrController : CMIF_DrawingAttrController;
	
begin
	gridFrame := self.myGridAreaFrame;
	if gridFrame &lt;&gt; null then
		attrController := self.mySDF.myDrawingAttrController;
		gridFrame.clearGraphics;
		foreach gridPoint in self.allGridPoints do
			gridPoint.setForUpdate(attrController); // update all the attributes for this point - mainly TI properties
			gridPoint.drawSelf(gridFrame);
			gridPoint.setForUpdateAssociatedPoint(attrController);
		endforeach;
		
		self.drawSelf;
	endif;
	
	self.mySDF.drawRowAndColumnLabels;
end;</source>
    </JadeMethod>
    <JadeMethod name="removeInvalidObjectLabel" id="c4d4a7b3-ece9-4a7c-ab35-63ea9f86101c">
        <source>removeInvalidObjectLabel();
// ---------------------------------------------------------------------------
// Created:		February 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theTA : CM_TerminalArea;
	anObject : CM_Object;
	removeObj, idx : CM_Object;
	theX, theY : Integer;
	iter01 : Iterator;
begin
	iter01 := self.allPointLabels.createIterator;
	
	while iter01.next(anObject) do
		if not global.isValidObject(anObject) then
			removeObj := anObject;
			theX := iter01.getCurrentKey(1).Integer;
			theY := iter01.getCurrentKey(2).Integer;
		endif;
	endwhile;

	if removeObj &lt;&gt; null then
		self.allPointLabels.removeKeyEntry(theX, theY, removeObj);
	endif;

epilog
	delete iter01;
end;</source>
    </JadeMethod>
    <JadeMethod name="selectBlock" id="6157a14b-0e5d-4c1a-837c-b0dd1acdccf5">
        <updating/>
        <source>selectBlock(_first, _second : CMUI_GridPoint) updating;

vars

	x1, x2, y1, y2	: Real;
	temp			: CMUI_GridPoint;

begin

	x1 := _first.x1;
	x2 := _first.x2;
	y1 := _first.y1;
	y2 := _first.y2;
	
	x1 := x1.min(_second.x1);
	x2 := x2.max(_second.x2);
	y1 := y1.min(_second.y1);
	y2 := y2.max(_second.y2);
	
	foreach temp in self.allGridPoints do
		if temp.locked then // AKB2002AUG
			continue;
		endif;
		if temp.x1 &gt;= x1 and temp.y1 &gt;= y1 and temp.x2 &lt;= x2 and temp.y2 &lt;= y2 then
			
			if not self.allSelectedPoints.includes(temp) then
				self.allSelectedPoints.add(temp);
			endif;
			temp.drawSelf(self.myGridAreaFrame);
		endif;
	endforeach;

end;</source>
        <Parameter name="_first" type="CMUI_GridPoint"/>
        <Parameter name="_second" type="CMUI_GridPoint"/>
    </JadeMethod>
