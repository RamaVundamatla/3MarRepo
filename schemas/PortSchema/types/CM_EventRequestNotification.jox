    <JadeMethod name="actionEventRequestNotification" id="f9a625d7-589b-4994-b5a8-eb79444d60cf">
        <updating/>
        <source>actionEventRequestNotification(_trackedItem: CM_TrackedItem input; _transaction : CM_TITransaction; _passport: CM_Passport input) updating;
//--------------------------------------------------
// Created:	17 May 2005 By: cnwgd1
//--------------------------------------------------
vars
	actionAndNotify : Boolean;
begin
	
	if (not self.setMyTrackedItem(_trackedItem, _passport)) then
		// either not set or user does not have access
		return;
	endif;

	if self.eventTypeNew = self.Event_Type_Transaction then
		actionAndNotify := global.isTiTxnOfType(_transaction.type, self.eventKey);
	elseif self.eventTypeNew = self.Event_Type_Stop then
		if CM_StopAdd.hasInstance(_transaction) then
			// Does stop match this request
			actionAndNotify := ((not self.isClear) and self.eventKey = _transaction.CM_StopAdd.stopID);
		elseif CM_StopCleared.hasInstance(_transaction) then
			// Does stop match this request
			actionAndNotify := (self.isClear and self.eventKey = _transaction.CM_StopCleared.stopID);
		endif;
	elseif self.eventTypeNew = self.Event_Type_TodoTask then
		if CM_TaskAdd.hasInstance(_transaction) then
			// Does task match this request	
			actionAndNotify := ((not self.isClear) and self.eventKey = _transaction.CM_TaskAdd.todoTaskCode);
									
		elseif CM_TaskComplete.hasInstance(_transaction) then
			// Does Task match this request
			actionAndNotify := (self.isClear and self.eventKey = _transaction.CM_TaskComplete.todoTaskCode);	
		endif;
	elseif self.eventTypeNew = self.Event_Type_IsAvailable then
		return;
	endif;

	if actionAndNotify then
		// We have a match
		// Set status to actioned and send email
		// if transaction occurs more than once then another email will be sent	

		self.updateStatusAndStatusInfo(EventRequestActioned, null);				
		self.sendEmail(_passport);

	endif;
				
end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="actionStopTaskEvent" id="ae2e08d3-b5b3-44e2-9636-bb65698a8f70">
        <updating/>
        <source>actionStopTaskEvent(_eventKey, _eventType : Integer; _isClear : Boolean; _passport : CM_Passport input)updating;
//--------------------------------------------------
// Created:	30 May 2005 By: cnwgd1
//--------------------------------------------------
vars

	failedDAC  :CM_DataAccessController;

begin

	if (self.eventKey &lt;&gt; _eventKey and self.eventTypeNew &lt;&gt; _eventType) then
		// no match
		return;
	elseif _isClear &lt;&gt; self.isClear then
		// no match
		return;
	elseif (not self.canUserAccessSelf(self.myUser, failedDAC, _passport)) then
		// user does not have access permission
		return;
	elseif _eventType = self.Event_Type_IsAvailable then
		if (not self.myTrackedItem.isAvailable) then
			// tracked item is not available for release
			return;
		endif;
	endif;

	// If we get to here the we have a match
	// Set status to actioned and send email
	// if transaction occurs more than once then another email will be sent	
	self.updateStatusAndStatusInfo(EventRequestActioned, null);				
	//self.sendEmail(self.myUser.allEventRequestEmail[self.type], _passport);
	self.sendEmail(_passport);
			
end;</source>
        <Parameter name="_eventKey" type="Integer"/>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_isClear" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
