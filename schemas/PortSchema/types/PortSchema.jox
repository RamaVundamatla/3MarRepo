    <JadeMethod name="getCallingMethod" id="3fe46a44-f031-4069-80d4-496c92b77fa6">
        <source>getCallingMethod( _numberOfMethodsToExclude : Integer ) : String;
//09 February 2009	cnwdw1	
//
vars
	stack: HugeStringArray;
	tmpStr,	stackStr : String;

begin
	create stack transient;
	app.getStackDisplayStringArray(stack, _numberOfMethodsToExclude);
	foreach tmpStr in stack do
		return tmpStr;
	endforeach;

	return stackStr;
epilog
	stack.purge;
	delete stack;
end;</source>
        <Parameter name="_numberOfMethodsToExclude" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCamsTypeForClass" id="064b0735-1c99-4bf0-9fe9-0310dc6f1288">
        <source>getCamsTypeForClass(_class: Class): Integer;
//----------------------------------------------------------------
//	Created:	03 March 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//18 Jul 2014 cnwgb1	PAR 34561 CCMS 2346
vars
	tmpClass	: Class;
	tmpType		: Integer;
begin
	tmpClass := _class;
		
	if tmpClass = CM_CamACOSDesc then
		tmpType := EDIFileTypeCams_MaerskACOS;
	elseif tmpClass = CM_CamCOARRIDesc then
		tmpType := EDIFileTypeCams_Coarri;
	elseif tmpClass = CM_CamCODECODesc then
		tmpType := EDIFileTypeCams_Codeco;
	elseif tmpClass = CM_CamINTRACDesc then
		tmpType := EDIFileTypeCams_NZEDIIntracon;
	elseif tmpClass = CM_CamAnlCOARRIDesc then
		tmpType := EDIFileTypeCams_ANLCoarri;
	elseif tmpClass = CM_CamCmaCOARRIDesc then
		tmpType := EDIFileTypeCams_CMACoarri;
	elseif tmpClass = CM_CamConCOARRIDesc then
		tmpType := EDIFileTypeCams_ContShipCoarri;
	elseif tmpClass = CM_CamCoscoCOARRIDesc then
		tmpType := EDIFileTypeCams_CoscoCoarri;
	elseif tmpClass = CM_CamHlcCOARRIDesc then
		tmpType := EDIFileTypeCams_HapagCoarri;
	elseif tmpClass = CM_CamMscCOARRIDesc then
		tmpType := EDIFileTypeCams_MSCCoarri;
	elseif tmpClass = CM_CamMskCOARRIDesc then
		tmpType := EDIFileTypeCams_MaerskCoarri;
	elseif tmpClass = CM_CamNykCOARRIDesc then
		tmpType := EDIFileTypeCams_NYKCoarri;
	elseif tmpClass = CM_CamOoclCOARRIDesc then
		tmpType := EDIFileTypeCams_OOCLCoarri;
	elseif tmpClass = CM_CamPandoCOARRIDesc then
		tmpType := EDIFileTypeCams_PONCoarri;
	elseif tmpClass = CM_CamConCOARRICEDODesc then
		tmpType := EDIFileTypeCams_ContCoarriCEDO;
	elseif tmpClass = CM_CamAnlCODECODesc then
		tmpType := EDIFileTypeCams_ANLCodeco;
	elseif tmpClass = CM_CamCmaCODECODesc then
		tmpType := EDIFileTypeCams_CMACodeco;
	elseif tmpClass = CM_CamColCODECODesc then
		tmpType := EDIFileTypeCams_COLCodeco;
	elseif tmpClass = CM_CamConCODECODesc then
		tmpType := EDIFileTypeCams_ContShipCodeco;
	elseif tmpClass = CM_CamCoscoCODECODesc then
		tmpType := EDIFileTypeCams_CoscoCodeco;
	elseif tmpClass = CM_CamHlcCODECODesc then
		tmpType := EDIFileTypeCams_HapagCodeco;
	elseif tmpClass = CM_CamMscCODECODesc then
		tmpType := EDIFileTypeCams_MSCCodeco;
	elseif tmpClass = CM_CamMskCODECODesc then
		tmpType := EDIFileTypeCams_MaerskCodeco;
	elseif tmpClass = CM_CamNykCODECODesc then
		tmpType := EDIFileTypeCams_NYKCodeco;
	elseif tmpClass = CM_CamOoclCODECODesc then
		tmpType := EDIFileTypeCams_OOCLCodeco;
	elseif tmpClass = CM_CamPandoCODECODesc then
		tmpType := EDIFileTypeCams_PONCodeco;
	elseif tmpClass = CM_CamANZDLINTRAC then
		tmpType := EDIFileTypeCams_ANZDLIntracon;
	elseif tmpClass = CM_CamPANDOINTRAC then
		tmpType := EDIFileTypeCams_POIntracon;
	elseif tmpClass = CM_CamSEATRANSINTRAC then
		tmpType := EDIFileTypeCams_SeatransIntrac;
	elseif tmpClass = CM_CamMaerskStockReport then
		tmpType := EDIFileTypeCams_MSKStockReport;
	elseif tmpClass = CM_CamTOLMove then
		tmpType := EDIFileTypeCams_TOLDepotMove;
	elseif tmpClass = CM_CamTOLWharfNotification then
		tmpType := EDIFileTypeCams_TOLWharfMove;
	elseif tmpClass = CM_CAMX12322Desc then
		tmpType := EDIFileTypeCams_X12322;
	elseif tmpClass = CM_CamSuzanoRelease then
		tmpType := EDIFileTypeCams_SuzanoRelease;
	elseif tmpClass = CM_CamSuzanoReceive then
		tmpType := EDIFileTypeCams_SuzanoReceive;
	elseif tmpClass = CM_CamSuzanoConfirm then
		tmpType := EDIFileTypeCams_SuzanoConfirm;
	elseif tmpClass = CM_CamPilCODECODesc then		//cnwmc5 - 15 Oct 2014 - CCMS 2380
		tmpType := EDIFileTypeCams_PILCodeco;		//cnwmc5 - 15 Oct 2014 - CCMS 2380
	elseif tmpClass = CM_CamPilCOARRIDesc then		//cnwmc5 - 15 Oct 2014 - CCMS 2380
		tmpType := EDIFileTypeCams_PILCoarri;		//cnwmc5 - 15 Oct 2014 - CCMS 2380
	else
		tmpType := EDIFileType_Unknown;
	endif;

	return tmpType;

end;</source>
        <Parameter name="_class" type="Class"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getCandHSummaryCategory" id="c6c9dda3-6377-4341-8913-5a4faf77b6ac">
        <source>getCandHSummaryCategory(_transitStatus : Integer; _is40Foot : Boolean;
	_isImport, _isEmpty, _isTShip, _isReeferCargo, _isLCL : Boolean) : Integer;
// ---------------------------------------------------------------------------
// Created:     11 October 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if _transitStatus = TI_TransitStatusDLR then
		if (_is40Foot) then
			return CMIF_CandHRpt.CategoryRehandle40;
		else
			return CMIF_CandHRpt.CategoryRehandle20;
		endif;
	elseif _transitStatus = TI_TransitStatusSOB then
		if (_is40Foot) then
			return CMIF_CandHRpt.CategorySOB40;
		else
			return CMIF_CandHRpt.CategorySOB20;
		endif;
	elseif _isImport then
		if (_is40Foot) then
			if (_isEmpty) then
				if (_isTShip) then
					return CMIF_CandHRpt.CategoryImportMTTShip40;
				else
					return CMIF_CandHRpt.CategoryImportMT40;
				endif;
			elseif (_isReeferCargo) then
				if (_isTShip) then
					return CMIF_CandHRpt.CategoryImportReeferTShip40;
				else
					return CMIF_CandHRpt.CategoryImportReefer40;
				endif;
			else
				if (_isTShip) then
					return CMIF_CandHRpt.CategoryImportDryTShip40;
				else
					return CMIF_CandHRpt.CategoryImportDry40;
				endif;
			endif;
		else
			if (_isEmpty) then
				if (_isTShip) then
					return CMIF_CandHRpt.CategoryImportMTTShip20;
				else
					return CMIF_CandHRpt.CategoryImportMT20;
				endif;
			elseif (_isReeferCargo) then
				if (_isTShip) then
					return CMIF_CandHRpt.CategoryImportReeferTShip20;
				else
					return CMIF_CandHRpt.CategoryImportReefer20;
				endif;
			else
				if (_isTShip) then
					return CMIF_CandHRpt.CategoryImportDryTShip20;
				else
					return CMIF_CandHRpt.CategoryImportDry20;
				endif;
			endif;
		endif;
	else	//export
		if (_is40Foot) then
			if (_isEmpty) then
				if (_isTShip) then
					return CMIF_CandHRpt.CategoryExportMTTShip40;
				else
					return CMIF_CandHRpt.CategoryExportMT40;
				endif;
			elseif (_isReeferCargo) then
				if (_isTShip) then
					return CMIF_CandHRpt.CategoryExportReeferTShip40;
				else
					return CMIF_CandHRpt.CategoryExportReefer40;
				endif;
			else
				if (_isLCL) then
					return CMIF_CandHRpt.CategoryExportDryLCL40;
				elseif (_isTShip) then
					return CMIF_CandHRpt.CategoryExportDryTShip40;
				else
					return CMIF_CandHRpt.CategoryExportDry40;
				endif;
			endif;
		else
			if (_isEmpty) then
				if (_isTShip) then
					return CMIF_CandHRpt.CategoryExportMTTShip20;
				else
					return CMIF_CandHRpt.CategoryExportMT20;
				endif;
			elseif (_isReeferCargo) then
				if (_isTShip) then
					return CMIF_CandHRpt.CategoryExportReeferTShip20;
				else
					return CMIF_CandHRpt.CategoryExportReefer20;
				endif;
			else
				if (_isLCL) then
					return CMIF_CandHRpt.CategoryExportDryLCL20;
				elseif (_isTShip) then
					return CMIF_CandHRpt.CategoryExportDryTShip20;
				else
					return CMIF_CandHRpt.CategoryExportDry20;
				endif;
			endif;
		endif;
	endif;
	
	return 0;

end;</source>
        <Parameter name="_transitStatus" type="Integer"/>
        <Parameter name="_is40Foot" type="Boolean"/>
        <Parameter name="_isImport" type="Boolean"/>
        <Parameter name="_isEmpty" type="Boolean"/>
        <Parameter name="_isTShip" type="Boolean"/>
        <Parameter name="_isReeferCargo" type="Boolean"/>
        <Parameter name="_isLCL" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
