    <JadeMethod name="clearAllProxies" id="45a8eaa5-e14c-4e68-9634-8964338a1e7b">
        <source>clearAllProxies();
// ---------------------------------------------------------------------------
// Created:     04 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.allProxies.purge;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="createProxyLink" id="6d92c61d-ee53-4974-8236-f59752c45625">
        <updating/>
        <source>createProxyLink(pReal, pProxy: CM_Object) updating;
// ---------------------------------------------------------------------------
// Created:     18 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	aProxyLink	: CM_ProxyLink;
	
begin


	if pProxy = null or pReal = null then
		return;
	endif;

	create aProxyLink transient;
	aProxyLink.originalRealEdition := pReal.edition;
	aProxyLink.myRealObject		:= pReal;
	aProxyLink.myProxyObject	:= pProxy;
	
	aProxyLink.myProxyManager:= self;

end;</source>
        <Parameter name="pReal" type="CM_Object"/>
        <Parameter name="pProxy" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="deleteProxyLink" id="9df1fe4a-efe0-4ec5-a551-b53494c0c741">
        <updating/>
        <source>deleteProxyLink(_proxy: CM_Object) updating;
// ---------------------------------------------------------------------------
// Created:     18 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// ---------------------------------------------------------------------------
vars
	proxyLink	: CM_ProxyLink;
	
begin
	if _proxy &lt;&gt; null then
		proxyLink := self.allProxies[_proxy];
		
		if proxyLink &lt;&gt; null then
			delete proxyLink;
		endif;
	endif;
end;</source>
        <Parameter name="_proxy" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="getAllProxies" id="1357f3fa-a35f-47bd-a1b8-4bb776bb21e5">
        <updating/>
        <source>getAllProxies(realObject: CM_Object; arr: CM_ObjectArray input) updating;
// ---------------------------------------------------------------------------
// Created:     18 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	aProxyLink	: CM_ProxyLink;
	iter		: Iterator;
	
begin

	if realObject = null then
		return;
	endif;
	
	iter:= allProxies.createIterator;
	allProxies.startKeyGeq(realObject, iter);
	
	while iter.next(aProxyLink) do
		if aProxyLink.myRealObject &lt;&gt; realObject then
			return;
		endif;
		arr.add(aProxyLink.myProxyObject);
	endwhile;
	
epilog
	delete iter;
	
end;</source>
        <Parameter name="realObject" type="CM_Object"/>
        <Parameter name="arr" type="CM_ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getProxyLinkEdition" id="1d5a571b-582d-4e35-b26a-dda148e0cada">
        <source>getProxyLinkEdition(pProxy: CM_Object) : Integer;
// ---------------------------------------------------------------------------
// Created:     18 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	aProxyLink	: CM_ProxyLink;

begin

	if pProxy = null then
		return 0;
	endif;
	
	aProxyLink:= self.allProxies[pProxy];
	
	if aProxyLink = null then
		return 0;
	endif;
	
	return aProxyLink.originalRealEdition;
	
end;</source>
        <Parameter name="pProxy" type="CM_Object"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getProxyObject" id="bb249b4a-fefd-4157-b2bd-5e3f6cf71313">
        <source>getProxyObject(pReal: CM_Object) : CM_Object;
// ---------------------------------------------------------------------------
// Created:     18 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	aProxyLink	: CM_ProxyLink;

begin

	if pReal = null then
		return null;
	endif;
	
	aProxyLink:= self.allReals[pReal];
	
	if aProxyLink = null then
		return null;
	endif;
	
	return aProxyLink.myProxyObject;
	
end;</source>
        <Parameter name="pReal" type="CM_Object"/>
        <ReturnType type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="getRealObject" id="e7189920-610c-40cb-9af8-2d774a0de367">
        <source>getRealObject(pProxy: CM_Object) : CM_Object;
// ---------------------------------------------------------------------------
// Created:     18 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	aProxyLink	: CM_ProxyLink;

begin

	if pProxy = null then
		return null;
	endif;
	
	aProxyLink:= self.allProxies[pProxy];
	
	if aProxyLink = null then
		return null;
	endif;
	
	return aProxyLink.myRealObject;
	
end;</source>
        <Parameter name="pProxy" type="CM_Object"/>
        <ReturnType type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="getRealObjectAndEdition" id="83a7f501-60e2-41f5-b774-4d1e81270865">
        <source>getRealObjectAndEdition(pProxy : CM_Object; pReal : CM_Object output; pEdition : Integer output);
// ---------------------------------------------------------------------------
// Created:     18 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	aProxyLink	: CM_ProxyLink;

begin
	
	if pProxy = null then
		return;
	endif;
	
	aProxyLink:= self.allProxies[pProxy];

	if aProxyLink = null then
		return;
	endif;
	
	pReal := aProxyLink.myRealObject;
	pEdition := aProxyLink.originalRealEdition;
end;</source>
        <Parameter name="pProxy" type="CM_Object"/>
        <Parameter name="pReal" type="CM_Object" usage="output"/>
        <Parameter name="pEdition" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="showAllProxies" id="17733e9d-3e2a-4f53-84b9-ef45e56e0541">
        <source>showAllProxies();
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	aLink : CM_ProxyLink;
begin

	if self.allProxies.size = 0 then
		app.writeStatement( app.actualTimeServer.String &amp; " NO PROXIES");// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	else
		app.writeStatement( app.actualTimeServer.String);// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		foreach aLink in self.allProxies do
			app.writeStatement( "myProxyObject : " &amp; aLink.myProxyObject.String &amp; 
				" myRealObject : " &amp; aLink.myRealObject.String &amp; 
				" originalRealEdition : " &amp; aLink.originalRealEdition.String &amp;
				" proxy created : " &amp; aLink.myProxyObject.createdTime.String);
		endforeach;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="updateProxyEditions" id="26b4184a-ff93-4136-bc0e-2b9cc3484c75">
        <source>updateProxyEditions(_allReals : ObjectSet input);
/*

Date		Who		Reason
16 March 2016	cnwer1	Initial creation TFS  1644 PAR 37649

*/

vars
	real: Object;
	pxyLink : CM_ProxyLink;
begin
	
	foreach real in _allReals  discreteLock do
		pxyLink:= self.allReals[real.CM_Object];
		if pxyLink &lt;&gt; null then
			pxyLink.originalRealEdition :=real.edition;
		endif;
			
	endforeach;
epilog

end;</source>
        <Parameter name="_allReals" type="ObjectSet" usage="input"/>
    </JadeMethod>
</Class>
