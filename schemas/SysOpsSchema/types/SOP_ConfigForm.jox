    <JadeMethod name="loadCombosEmail" id="8f4bce42-e559-4d9c-9d05-341660937a7c">
        <source>loadCombosEmail() protected;
// Created by cnwdvb1 on 14 August 2007
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------
// 21/07/2020	jlgdap1	TSF 49764MTN Retire Basic Authentication to Exchange Online
constants

/*	Automatically = -1;
	AUTH_LOGIN = 0; //(Default) 
	AUTH_NTLM = 1; //(Secure Password Authentication) 
	AUTH_CRAM_MD5 = 2;
	AUTH_PLAIN =3;
	AUTH_MSN = 4;
	NONE	= 5;*/
vars

	idx : Integer;

begin

	idx := self.cmbAuthType.addItem("NONE");
	self.cmbAuthType.itemData[idx] := BGP_EmailSendRequest.AUTH_NONE;
	idx := self.cmbAuthType.addItem("AUTH LOGIN");
	self.cmbAuthType.itemData[idx] := BGP_EmailSendRequest.AUTH_LOGIN;
	idx := self.cmbAuthType.addItem("AUTH NTLM");
	self.cmbAuthType.itemData[idx] := BGP_EmailSendRequest.AUTH_NTLM;
	idx := self.cmbAuthType.addItem("AUTH CRAM MD5");
	self.cmbAuthType.itemData[idx] := BGP_EmailSendRequest.AUTH_CRAM_MD5;
	idx := self.cmbAuthType.addItem("AUTH PLAIN");
	self.cmbAuthType.itemData[idx] := BGP_EmailSendRequest.AUTH_PLAIN;
	idx :=self.cmbAuthType.addItem("AUTH_MSN");
	self.cmbAuthType.itemData[idx] := BGP_EmailSendRequest.AUTH_MSN;
	
	self.cmbAuthType.listIndex := 1;
	
	idx := self.cmbSSL.addItem("NONE");
	self.cmbSSL.itemData[idx] := BGP_EmailSendRequest.SSL_NONE;
	idx := self.cmbSSL.addItem("SSL STARTTLS");
	self.cmbSSL.itemData[idx] := BGP_EmailSendRequest.SSL_STARTTLS;
	idx := self.cmbSSL.addItem("SSL DIRECT");
	self.cmbSSL.itemData[idx] := BGP_EmailSendRequest.SSL_DIRECT;
	
	self.cmbSSL.listIndex := 1;
	
	idx := self.cmbInwardSSL.addItem("NONE");
	self.cmbInwardSSL.itemData[idx] := BGP_EmailSendRequest.SSL_NONE;
	idx := self.cmbInwardSSL.addItem("SSL STARTTLS");
	self.cmbInwardSSL.itemData[idx] := BGP_EmailSendRequest.SSL_STARTTLS;
	idx := self.cmbInwardSSL.addItem("SSL DIRECT");
	self.cmbInwardSSL.itemData[idx] := BGP_EmailSendRequest.SSL_DIRECT;
	
	self.cmbInwardSSL.listIndex := 1;
	
	
	idx := self.cmbSoftware.addItem("CARDSCHEMA");
	self.cmbSoftware.itemData[idx] := BGP_EmailSendRequest.EMAIL_CARDSCHEMA;
	idx := self.cmbSoftware.addItem("IDSMAIL");
	self.cmbSoftware.itemData[idx] := BGP_EmailSendRequest.EMAIL_IDSMAIL;
	idx := self.cmbSoftware.addItem("EMAILARCHITECT");
	self.cmbSoftware.itemData[idx] := BGP_EmailSendRequest.EMAIL_EMAILARCHITECT;
	idx := self.cmbSoftware.addItem("EMAILARCHITECT OAUTH");							// TFS 49764
	self.cmbSoftware.itemData[idx] := BGP_EmailSendRequest.EMAIL_EMAILARCHITECTOAUTH;	// TFS 49764
	
	self.cmbSoftware.listIndex := 1;
		

end;</source>
        <access>protected</access>
    </JadeMethod>
