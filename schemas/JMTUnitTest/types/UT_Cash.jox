			self.assertTrueMsg(cashPay.myProformaDetail &lt;&gt; null, idx.String &amp; " Cash Pay has no proforma detail");
			self.assertTrueMsg(cashPay.myProformaDetail.myInvoiceLineType = invLineType2 ,  idx.String &amp; " line type sbe invLineType2");
			self.assertTrueMsg(cashPay.cashValue = 230.4,  idx.String &amp; " cash payment value &lt;&gt; 460.8 CCCCW");
		endif;
	
	idx += 1;
	endforeach;
	


	
	// ### SPLIT AGAIN
	app.myTrxUA.trxSplitBreakBulkToNewID(	origTI.CM_Cargo,	//_sourceTi : CM_Cargo;
											newTiIds,	//_newTiIds : StringArray;
											1,	//_quantity : Integer;
											4,	// _weightOrVolume : Decimal;
											origTI.myOperator,	//_operator : CM_Operator;
											true,
											true,
											true,
											true,
											app.myPassport	//_passport : CM_Passport input
											);
	
	self.assertNoTrxErrorsPassport("TRX ISSUE ON SPLIT 2 ");	
		
	// in this scenario the issue was at this point. having cancelled the first CR then created a new CR then split, this issue was that the payments for the split off TI was on the original cash receipt, where as they should  be on this new 1.
	// New Cash Receipt
	self.assertTrueMsg(cashReceipt2 &lt;&gt; null, "3.1 Cash receipt should not be null");
	self.assertTrueMsg(isPaymentAllowed, "3.1 Is Payment Allowed should be true");
	self.assertTrueMsg(cashReceipt2.allCashPayments.size = 30, "3.1 Cash receipt should have 24 payments");
	self.assertTrueMsg(cashReceipt2.cashValue = 660.800000, "3.1. cash value is not correct is " &amp; cashReceipt2.cashValue.String);
	self.assertTrueMsg(cashReceipt2.allTrackedItems.size = 7, "3.1. Cash Receipt should have 7 TIs, has " &amp; cashReceipt2.allTrackedItems.size.String); // (THREE ZOMBIES)
	
	// FIRST CASH RECEIPT
	self.assertTrueMsg(cashReceipt1.allCashPayments.size = 12, "2.5 Cash receipt should have 12 payments is " &amp; cashReceipt1.allCashPayments.size.String);
	self.assertTrueMsg(cashReceipt1.cashValue = 660.80, "2.5 Total amount is not correct is " &amp; cashReceipt1.cashValue.String);
	self.assertTrueMsg(cashReceipt1.allTrackedItems.size = 4, "2.5 Cash Receipt should have 1 TIs, has " &amp; cashReceipt1.allTrackedItems.size.String);
	
		
	// SET TO HOLD (22)
	request := '{
					"customsAgentCode" : "'&amp;agentId&amp;'",
					"customsEntryNumber" : "'&amp;CEN&amp;'",
					"draftReceiptNumber" : "'&amp;cashReceipt2.sequenceNum.asStringJMT()&amp;'",
					"finalReceiptNumber" : "'&amp;cashReceipt2.sequenceNum.asStringJMT()&amp;'",
					"externalFinancialId" : "'&amp;EXTFINANCIALID&amp;'",
					"externalReceiptNumber" : "'&amp;EXTRECEIPTNUMBER&amp;'",
					"externalRef1" : "'&amp;EXTREF1&amp;'",
					"externalTransaction" : "'&amp;EXTTRANSACTION&amp;'",
					"externalUserCode" : "'&amp;EXTUSER1&amp;'",
					"remarks" : "",
					"statusValue" : 22
				}
					';
	// call API for scenario 6
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutProformaStatus.name, request, responseInString, draftReceiptNumber, finalReceiptNumber);
	// Verify response Scenario 6 - Good scenario, update status to FINAL 25
	// YES, QT want to accept paymentStatus Paid 24, then set the paymentStatus to Final 25
	self.assertTrueMsg(cashReceipt2.paymentStatus = CM_CashReceipt.API_RECEIPT_HOLD, "Payment status should gets updated to be HOLD");
	self.assertTrueMsg(cashReceipt2.externalFinancialId = EXTFINANCIALID, "2 externalFinancialId should be " &amp; EXTFINANCIALID &amp; ", not " &amp; cashReceipt2.externalFinancialId);
	self.assertTrueMsg(cashReceipt2.externalReceiptNumber= EXTRECEIPTNUMBER,  "externalReceiptNumber should be " &amp; EXTRECEIPTNUMBER &amp; ", not " &amp; cashReceipt2.externalReceiptNumber);
	self.assertTrueMsg(cashReceipt2.externalRef1 = EXTREF1,  "externalRef1 should be " &amp; EXTREF1 &amp; ", not " &amp; cashReceipt2.externalRef1);
	self.assertTrueMsg(cashReceipt2.externalTransaction = EXTTRANSACTION,  "externalTransaction should be " &amp; EXTTRANSACTION &amp; ", not " &amp; cashReceipt2.externalTransaction);
	
	/*
	set to PAID (24)
	*/
	request := '{
					"customsAgentCode" : "'&amp;agentId&amp;'",
					"customsEntryNumber" : "'&amp;CEN&amp;'",
					"draftReceiptNumber" : "'&amp;cashReceipt2.sequenceNum.asStringJMT()&amp;'",
					"finalReceiptNumber" : "'&amp;cashReceipt2.sequenceNum.asStringJMT()&amp;'",
					"externalFinancialId" : "'&amp;EXTFINANCIALID&amp;'",
					"externalReceiptNumber" : "'&amp;EXTRECEIPTNUMBER&amp;'",
					"externalRef1" : "'&amp;EXTREF1&amp;'",
					"externalTransaction" : "'&amp;EXTTRANSACTION&amp;'",
					"externalUserCode" : "'&amp;EXTUSER1&amp;'",
					"remarks" : "",
					"statusValue" : 24
				}
					';
	// call API for scenario 6
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutProformaStatus.name, request, responseInString, draftReceiptNumber, finalReceiptNumber);
	// Verify response Scenario 6 - Good scenario, update status to FINAL 25
	// YES, QT want to accept paymentStatus Paid 24, then set the paymentStatus to Final 25
	self.assertTrueMsg(cashReceipt2.paymentStatus = CM_CashReceipt.API_RECEIPT_FINAL, "Payment status should gets updated to be FINAL");
	
epilog
	if toDoTaskDesc &lt;&gt; null then
		self.deleteToDoTaskDescription(toDoTaskDesc);
	endif;
	delete pxyTransService;
	delete proxyCriteria;
	delete proxyResourceTypeUsage;
	delete resourceUsageProxys;
	delete toDoTaskList;
	delete newTiIds;
	self.resetDefaultTranMap();
	app.myTrxDA.trxDeleteInvoiceTranMap(tm, app.myPassport); 
	self.deleteVoyage(VOYCODE);
	self.deleteTrackedItem(ti, true);
	self.deleteVessel(VESSCODE);
	if criterias &lt;&gt; null then
		criterias.purge();
	endif;
	delete allTisToMerge;
	delete allTIsForTODO;
	delete criterias;
	delete selectedTrxTypes;
	delete proxyProCrit;
	if realProCrit &lt;&gt; null then
		app.myTrxDA.trxDeleteProformaCriteria(realProCrit, app.myPassport);
	endif;
	if cashReceipt1 &lt;&gt; null then
		app.myTrxDA.trxDeleteCashReceipt(cashReceipt1);
	endif;
	if cashReceipt2 &lt;&gt; null then
		app.myTrxDA.trxDeleteCashReceipt(cashReceipt2);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCashReleaseValidation" id="914eaf66-90b9-4136-a28f-c5181f0661f0">
        <updating/>
        <source>tCashReleaseValidation() updating;
// cnwma1

/*

Purpose:
Parameters:			

Return Value:		


Date		Who		Reason
22 Sep 2020 cnwma1  Bug 49799: AAT - Invoice 4009927 - Error when booking out of terminal
*/

constants

vars
	isDutyDoc	: Boolean;
	multiTax	: Boolean;
	noImportStops	: Boolean;
	cargoId1,
	cargoId2	: String;
	debtorName	: String;
	cargoIds	: StringArray;
	
	drTerm1 : CM_DebtorTerminal;

	currentFinClass	: CM_ExtFinanceIO;
	
	costs : DecimalArray;
	service : CM_Service;
	debtorRate : CM_DebtorRate;

	endDate : Date;
	
	debtor		: CM_Debtor;
	proxyDebtor		: CM_Debtor;
	debtorNode	: CM_DebtorNode;
	debtorNodeController	: CMIF_DebtorNode;
	debtorType	: CM_DebtorType;
	cashInvType,
	invType			: CM_InvoiceDesc;
	invLineType1,
	invLineType2  	: CM_InvoiceLineDesc;
	customsAgent	: CM_CustomsAgent;
	operator		: CM_Operator;
begin

	cashInvType := self.getInvoiceType("UT_InvType");		// cash receipt invoice type

	// turn off duty docs to get all the latest code; turn off terminal multi tax to avoid tax
	isDutyDoc := self.myTerminal.getConfig(DutyDocumentationEnabled).Boolean;
	multiTax := self.myTerminal.getConfig(InvoiceMultiTaxRates).Boolean;
	noImportStops := self.myTerminal.getConfig(NoImportStops).Boolean;
	// set default financial to get their external cash receipt number
	currentFinClass := getInvoiceFinancialClass();
	self.setInvoiceFinancialClass(CM_ADPInterface, null);
	self.setTerminalConfig(DutyDocumentationEnabled, false);
	self.setDefaultBankCashInvoiceType(cashInvType);
	self.setTerminalConfig(InvoiceMultiTaxRates, false);
	self.setTerminalConfig(NoImportStops, true);
	self.setTerminalConfig(CashInvoiceEveryReceipt, true);
	
	create cargoIds transient;
	// ids with valid check digits
	self.getCargoIds(cargoIds);
	foreach cargoId1 in cargoIds do
		self.deleteContainer(cargoId1);
	endforeach;
	
	self.setTaxOnBank( false );
	
	// use an operator with a known non-cash debtor
	operator := self.getOperator("UTC1");
	if operator = null then
		operator := self.addOperatorSimple("UTC1", "Cash Test Operator");
	endif;
	debtorName := "UT_Debtor1";
	debtor := app.myRoot.myRootCompany.debtorNodes[debtorName].CM_Debtor;
	if debtor = null then
		create debtorNodeController transient;
		create proxyDebtor transient;
		self.setDebtorNodeController1(debtorName, debtorNodeController, proxyDebtor);
		app.myTrxCA.trxCreateDebtorNode(debtorNodeController, debtorNode, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
		debtor := debtorNode.CM_Debtor;
	endif;

	beginTransaction;
		operator.setPropertyValue(CM_Operator::debtor.name, debtor);
	commitTransaction;
	self.myOperator := operator;
	
	endDate := app.actualTimeServer.Date + 10;	// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support

	//set terminal to be cash enabled.
	self.enableCashOnlyTerminal( self.myTerminal, true );
	
	//set up criteria permitted for this Bank in this terminal on pro forma allocation
	self.setBankAvailAllocCriteria();
	
	//set up Bank pro forma allocation
	self.setBankProFormaAllocations();
	
	//create Method of payment if needed
	self.myPaymentMethod :=  app.myRoot.allPaymentMethods.getAtKey(PayMethName);
	if self.myPaymentMethod = null then
		self.myPaymentMethod := self.createPaymentMethod(PayMethName);
	endif;
	self.assertTrueMsg(self.myPaymentMethod &lt;&gt; null, "Payment Method not created...");
	
	//create cash only debtors.
	self.myDebtor1 := app.myRoot.myRootCompany.debtors[DrNameOne];
	if self.myDebtor1 = null then
		self.myDebtor1 := self.addCashOnlyDebtor( DrNameOne );
	endif;
	self.assertTrueMsg(self.myDebtor1 &lt;&gt; null, "Cash only Debtor not created...");
	drTerm1 := self.myDebtor1.allDebtorTerminals.getAtKey( self.myTerminal );
	self.assertTrueMsg(drTerm1 &lt;&gt; null, "Debtor/Terminal not created...");
	self.assertTrueMsg(drTerm1.isCashOnly, "Debtor/Terminal is not cash only...");
	// clear any credits etc from prior tests such as tCashCredit
	self.zPurgeCashDebtor(drTerm1);
	
	customsAgent := app.myRoot.allCustomsAgents['UTCA1'];
	debtor := customsAgent.myDebtor;
	drTerm1 := debtor.allDebtorTerminals.getAtKey( self.myTerminal );
	self.assertTrueMsg(drTerm1 &lt;&gt; null, "Debtor/Terminal not created...");
	self.assertTrueMsg(drTerm1.isCashOnly, "Debtor/Terminal is not cash only...");
	// clear any credits etc from prior tests such as tCashCredit
	self.zPurgeCashDebtor(drTerm1);

	// Voyage invoice type, ILT8 invoice line type, used in ship receive, charged to shipping operator, calc type Cargo Quantity
	invType := self.addIfNewInvoiceType("UT_Voyage");
	self.addIfNewServiceILD("UT_ServiceX8", "CCT01", "UT_ILT8", null, invType);
	// set service rate
	service := self.myBank.services["UT_ServiceX8"];		// for receive ship
	self.setServiceRate(service, debtor, "01/01/2013".Date, 100.4546);

	invLineType1 := self.myBank.invoiceLineDescriptors["UT_ILT8"];
	debtorType := app.myRoot.allDebtorTypes["SDT4"];	// cargo operator
	beginTransaction;
	invLineType1.setPropertyValue("myDebtorType", debtorType);
	commitTransaction;

	// Yard invoice type, ILT9 invoice line type, used in yard and road release, charged to customs agent, calc type Cargo Quantity
	invType := self.addIfNewInvoiceType("UT_Yard");
	self.addIfNewServiceILD("UT_ServiceX9", "CCT01", "UT_ILT9", null, invType);

	invLineType1 := self.myBank.invoiceLineDescriptors["UT_ILT9"];
	debtorType := app.myRoot.allDebtorTypes["SDT6"];	// customs agent
	beginTransaction;
	invLineType1.setPropertyValue("myDebtorType", debtorType);
	commitTransaction;
	service := self.myBank.services["UT_ServiceX9"];		// for move and road release
	self.setServiceRate(service, debtor, "01/01/2013".Date, 20.666);
	
	// Yard invoice type, ILT10 and ILT11 invoice line type, used in storage, charged to customs agent, calc type Days Since Receival
	invType := self.addIfNewInvoiceType("UT_Yard");
	self.addIfNewServiceILD("UT_ServiceX10", "CCT06", "UT_ILT10", null, invType);
	self.addIfNewServiceILD("UT_ServiceX11", "CCT06", "UT_ILT11", null, invType);

	invLineType1 := self.myBank.invoiceLineDescriptors["UT_ILT10"];
	invLineType2 := self.myBank.invoiceLineDescriptors["UT_ILT11"];
	debtorType := app.myRoot.allDebtorTypes["SDT6"];	// customs agent
	beginTransaction;
	invLineType1.setPropertyValue("myDebtorType", debtorType);
	invLineType2.setPropertyValue("myDebtorType", debtorType);
	commitTransaction;
	service := self.myBank.services["UT_ServiceX10"];		// for storage, rate per day
	self.setServiceRate(service, debtor, "01/01/2013".Date, 20.226);
	service := self.myBank.services["UT_ServiceX11"];		// for double storage, rate per day
	self.setServiceRate(service, debtor, "01/01/2013".Date, 40.556);
	service := self.myBank.services["UT_ServiceX8"];			// receive ship, to get a value on the invoice lines
	self.setServiceRate(service, debtor, "01/01/2013".Date, 100.886);
	
	debtor := operator.debtor;
	service := self.myBank.services["UT_ServiceX8"];			// receive ship, to get a value on the invoice lines
	self.setServiceRate(service, debtor, "01/01/2013".Date, 5.326);
	
	self.myVoyage := self.createVesselVoyageCash("JMT STAR", "JSTAR001", operator.code);
	self.assertTrueMsg(self.myVoyage &lt;&gt; null, "Voyage '" &amp; CashVoyageCode &amp; "' not created...");

	self.tranMapLoadMultipleReceipts();
	
	// two receipts, each should have its own cash invoice, post the first one before releasing the cargo
	cargoId1 := cargoIds[1];
	cargoId2 := cargoIds[2];
	self.cashTestMultipleReceipts2(cargoId1, cargoId2, drTerm1, 1);
	
epilog
	if currentFinClass &lt;&gt; null then
		self.setInvoiceFinancialClass(currentFinClass.class, null);
	endif;

	delete costs;
	delete debtorRate;
	delete cargoIds;
	self.resetDefaultTranMap();
end;</source>
    </JadeMethod>
    <JadeMethod name="tCashSplitReceipts" id="3730e9e5-3750-489a-9cac-34bfc20231eb">
        <updating/>
        <source>tCashSplitReceipts() updating;
// cnwma1

/*

Purpose:		Cash module testing of partial payments, splitting over invoice lines.

Parameters:			

Return Value:		


Date		Who		Reason
29/04/2014	cnwjre1	After par 33885
// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
*/

constants

vars
	isDutyDoc	: Boolean;
	multiTax	: Boolean;
	noImportStops	: Boolean;
	allowUnderpay	: Boolean;
	cargoId		: String;
	debtorName	: String;
	cargoIds	: StringArray;
	
	drTerm1 : CM_DebtorTerminal;
	drTerm2 : CM_DebtorTerminal;
	currentFinClass	: CM_ExtFinanceIO;
	
	costs : DecimalArray;
	service : CM_Service;
	debtorRate : CM_DebtorRate;

	endDate : Date;
	
	carrier : CM_Carrier;
	
	truckOut : CM_Vehicle;
	
	debtor		: CM_Debtor;
	proxyDebtor		: CM_Debtor;
	debtorNode	: CM_DebtorNode;
	debtorNodeController	: CMIF_DebtorNode;
	debtorType	: CM_DebtorType;
	cashInvType,
	invType			: CM_InvoiceDesc;
	invLineType1,
	invLineType2  	: CM_InvoiceLineDesc;
	customsAgent	: CM_CustomsAgent;
	operator		: CM_Operator;
begin


	cashInvType := self.getInvoiceType("UT_InvType");		// cash receipt invoice type

	// turn off duty docs to get all the latest code; turn off terminal multi tax to avoid tax
	isDutyDoc := self.myTerminal.getConfig(DutyDocumentationEnabled).Boolean;
	multiTax := self.myTerminal.getConfig(InvoiceMultiTaxRates).Boolean;
	noImportStops := self.myTerminal.getConfig(NoImportStops).Boolean;
	allowUnderpay := self.myTerminal.getConfig(CashCollectAllowUnderpay).Boolean;
	// set Oracle financials to get their external cash receipt number
	currentFinClass := getInvoiceFinancialClass();
	self.setInvoiceFinancialClass(CM_OracleFinancials, null);
	self.setTerminalConfig(DutyDocumentationEnabled, false);
	self.setDefaultBankCashInvoiceType(cashInvType);
	self.setTerminalConfig(InvoiceMultiTaxRates, false);
	self.setTerminalConfig(NoImportStops, true);
	self.setTerminalConfig(CashCollectAllowUnderpay, true);
	// TFS 45953  self.setTerminalConfig(CashShowParentAndChildItems, true);

	create cargoIds transient;
	// ids with valid check digits
	self.getCargoIds(cargoIds);
	foreach cargoId in cargoIds do
		self.deleteContainer(cargoId);
	endforeach;
	
	self.setTaxOnBank( false );
	
	// use an operator with a known non-cash debtor
	operator := self.getOperator("UTC1");
	if operator = null then
		operator := self.addOperatorSimple("UTC1", "Cash Test Operator");
	endif;
	debtorName := "UT_Debtor1";
	debtor := app.myRoot.myRootCompany.debtorNodes[debtorName].CM_Debtor;
	if debtor = null then
		create debtorNodeController transient;
		create proxyDebtor transient;
		self.setDebtorNodeController1(debtorName, debtorNodeController, proxyDebtor);
		app.myTrxCA.trxCreateDebtorNode(debtorNodeController, debtorNode, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
		debtor := debtorNode.CM_Debtor;
	endif;

	beginTransaction;
		operator.setPropertyValue(CM_Operator::debtor.name, debtor);
	commitTransaction;
	self.myOperator := operator;
	
	endDate := app.actualTimeServer.Date + 10;	// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support

	//set terminal to be cash enabled.
	self.enableCashOnlyTerminal( self.myTerminal, true );
	
	//set up criteria permitted for this Bank in this terminal on pro forma allocation
	self.setBankAvailAllocCriteria();
	
	//set up Bank pro forma allocation
	self.setBankProFormaAllocations();
	
	//create Method of payment if needed
	self.myPaymentMethod :=  app.myRoot.allPaymentMethods.getAtKey(PayMethName);
	if self.myPaymentMethod = null then
		self.myPaymentMethod := self.createPaymentMethod(PayMethName);
	endif;
	self.assertTrueMsg(self.myPaymentMethod &lt;&gt; null, "Payment Method not created...");
	
	//create cash only debtors.
	self.myDebtor1 := app.myRoot.myRootCompany.debtors[DrNameOne];
	if self.myDebtor1 = null then
		self.myDebtor1 := self.addCashOnlyDebtor( DrNameOne );
	endif;
	self.assertTrueMsg(self.myDebtor1 &lt;&gt; null, "Cash only Debtor not created...");
	drTerm1 := self.myDebtor1.allDebtorTerminals.getAtKey( self.myTerminal );
	self.assertTrueMsg(drTerm1 &lt;&gt; null, "Debtor/Terminal not created...");
	self.assertTrueMsg(drTerm1.isCashOnly, "Debtor/Terminal is not cash only...");
	
	self.myDebtor2 := app.myRoot.myRootCompany.debtors[DrNameTwo];
	if self.myDebtor2 = null then
		self.myDebtor2 := self.addCashOnlyDebtor( DrNameTwo );
	endif;
	drTerm2 := self.myDebtor2.allDebtorTerminals.getAtKey( self.myTerminal );

	customsAgent := app.myRoot.allCustomsAgents['UTCA1'];
	debtor := customsAgent.myDebtor;

	// Voyage invoice type, ILT8 invoice line type, used in ship receive, charged to shipping operator, calc type Cargo Quantity
	invType := self.addIfNewInvoiceType("UT_Voyage");
	self.addIfNewServiceILD("UT_ServiceX8", "CCT01", "UT_ILT8", null, invType);
	// set service rate
	service := self.myBank.services["UT_ServiceX8"];		// for receive ship
	self.setServiceRate(service, debtor, "01/01/2013".Date, 100.00);

	invLineType1 := self.myBank.invoiceLineDescriptors["UT_ILT8"];
	debtorType := app.myRoot.allDebtorTypes["SDT4"];	// cargo operator
	beginTransaction;
	invLineType1.setPropertyValue("myDebtorType", debtorType);
	commitTransaction;

	// Yard invoice type, ILT9 invoice line type, used in yard and road release, charged to customs agent, calc type Cargo Quantity
	invType := self.addIfNewInvoiceType("UT_Yard");
	self.addIfNewServiceILD("UT_ServiceX9", "CCT01", "UT_ILT9", null, invType);

	invLineType1 := self.myBank.invoiceLineDescriptors["UT_ILT9"];
	debtorType := app.myRoot.allDebtorTypes["SDT6"];	// customs agent
	beginTransaction;
	invLineType1.setPropertyValue("myDebtorType", debtorType);
	commitTransaction;
	service := self.myBank.services["UT_ServiceX9"];		// for move and road release
	self.setServiceRate(service, debtor, "01/01/2013".Date, 20.00);
	
	// Yard invoice type, ILT10 and ILT11 invoice line type, used in storage, charged to customs agent, calc type Days Since Receival
	invType := self.addIfNewInvoiceType("UT_Yard");
	self.addIfNewServiceILD("UT_ServiceX10", "CCT06", "UT_ILT10", null, invType);
	self.addIfNewServiceILD("UT_ServiceX11", "CCT06", "UT_ILT11", null, invType);

	invLineType1 := self.myBank.invoiceLineDescriptors["UT_ILT10"];
	invLineType2 := self.myBank.invoiceLineDescriptors["UT_ILT11"];
	debtorType := app.myRoot.allDebtorTypes["SDT6"];	// customs agent
	beginTransaction;
	invLineType1.setPropertyValue("myDebtorType", debtorType);
	invLineType2.setPropertyValue("myDebtorType", debtorType);
	commitTransaction;
	service := self.myBank.services["UT_ServiceX10"];		// for storage, rate per day
	self.setServiceRate(service, debtor, "01/01/2013".Date, 20.00);
	service := self.myBank.services["UT_ServiceX11"];		// for double storage, rate per day
	self.setServiceRate(service, debtor, "01/01/2013".Date, 40.00);
	service := self.myBank.services["UT_ServiceX8"];			// receive ship, to get a value on the invoice lines
	self.setServiceRate(service, debtor, "01/01/2013".Date, 100.00);
	
	debtor := operator.debtor;
	service := self.myBank.services["UT_ServiceX8"];			// receive ship, to get a value on the invoice lines
	self.setServiceRate(service, debtor, "01/01/2013".Date, 5.00);
	
	self.myVoyage := self.createVesselVoyageCash("JMT STAR", "JSTAR001", operator.code);
	self.assertTrueMsg(self.myVoyage &lt;&gt; null, "Voyage '" &amp; CashVoyageCode &amp; "' not created...");
	// create carrier and truck
	self.deleteVehicle(VehicleNumOut);
	carrier := self.addCarrier(CarrierName, CarrierName, self.allEmails, false, true, true, self.myDebtor1);
	self.assertNotNull(carrier);
	truckOut := self.addVehicle(VehicleNumOut, carrier, self.myTerminal);
	self.assertTrueMsg(truckOut &lt;&gt; null, "Truck not created...");
	
	self.tranMapLoadDoubleStorage();
	
	//Now create onsite cargo that will be gated out by truck.
	cargoId := "UTTU0010191";
	self.cashTestSplitReceipt(cargoId, drTerm1, truckOut);

	
epilog
	if currentFinClass &lt;&gt; null then
		self.setInvoiceFinancialClass(currentFinClass.class, null);
	endif;

	delete costs;
	delete debtorRate;
	delete cargoIds;

	self.resetDefaultTranMap();
end;</source>
    </JadeMethod>
    <JadeMethod name="tCreateBOLCashCargo" id="855d804d-b2a3-46b7-9d3b-e06a00a3be8d">
        <updating/>
        <source>tCreateBOLCashCargo() updating;

/*	NOTE: For this to work with a different terminal, debtor Cash Debtor 1 to 4 as a cash-only debtors, 
			the user used to run this (typically UnitTest) needs security to create BOLs (set all access is simplest).
			Also needs block stacks BS2 and BS3.
		To get useful invoice lines from this also needs the transaction map set up for Import Release - Ship, Move and Storage at a minimum.
		In John Terminal, have the 'Cash' transaction map as the active one.
		USE THIS ONE to get cargo suitable for Ghana cash collection - containers packed with child cargo

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17/02/2015	cnwjre1	Initial creation

*/

vars
	terminalId	: String;
	root		: CM_Root;
	terminal	: CM_Terminal;
	debtor		: CM_Debtor;
	debtorTerminal	: CM_DebtorTerminal;
	allDebtors	: CM_DebtorSet;
begin
	// clear the cash debtor values
	create allDebtors transient;
	
	root := CM_Root.firstInstance;
	terminalId := "UT";
	terminal := root.allTerminals[terminalId];
	debtor := root.myRootCompany.debtors["UT_Cash Debtor 1"];
	if debtor &lt;&gt; null then
		allDebtors.add(debtor);
	endif;
	debtor := root.myRootCompany.debtors["UT_Cash Debtor 2"];
	if debtor &lt;&gt; null then
		allDebtors.add(debtor);
	endif;
	debtor := root.myRootCompany.debtors["UT_Cash Debtor 3"];
	if debtor &lt;&gt; null then
		allDebtors.add(debtor);
	endif;
	debtor := root.myRootCompany.debtors["UT_Cash Debtor 4"];
	if debtor &lt;&gt; null then
		allDebtors.add(debtor);
	endif;

	foreach debtor in allDebtors do
		debtorTerminal := debtor.allDebtorTerminals[terminal];
	
		beginTransaction;

		debtorTerminal.allCashPayments.purge();
		debtorTerminal.allCashReceipts.purge();
		debtorTerminal.allConsolidatedCashTrx.purge();
		debtorTerminal.setConsolidatedBalance();

		commitTransaction;
	endforeach;
	
	// create import cargo for John's Terminal cash usage
	self.createBOLCargoForCash(terminalId, true, true);		// 1st param = create invoice lines for extra moves, 2nd param = connect reefers for reefer daily charge
epilog
	delete allDebtors;
end;</source>
    </JadeMethod>
    <JadeMethod name="tMultipleMinimumCharges" id="e9d1a281-4a35-458a-ad96-4a551f98048a">
        <updating/>
        <source>tMultipleMinimumCharges()updating;
/*

Purpose:			TFS 1617

Date		Who		Reason
10 May 2016	cnwmk3	Initial creation
10 Sep 2019	cnwrs1	TFS 46030
23 Jan 2023	navma1	ChangeRequest 54349[54262]: EUP - Enable Is Mandatory for ToDo Task Resources
31 Jan 2023	navvt20	TFS CR 56132 Task 56134: UI - Invoice Line Type - UOM

*/

vars
	pxyInvoiceLineDesc	: CM_InvoiceLineDesc;
	newInvLineType		: CM_InvoiceLineDesc;
	chgNum				: Integer;
	debtorType			: CM_DebtorType;
	calType				: CM_CalculationType;
	invType				: CM_InvoiceDesc;
	service				: CM_Service;
	services 			: CM_ServiceByNameDict;
	theBank				: CM_Bank;
	invLineType1		: CM_InvoiceLineDesc;
	invLineType2		: CM_InvoiceLineDesc;
	ti					: CM_TrackedItem;
	tiID				: String;
	proxyCriteria		: CM_YACriteria;
	proxyProCrit 		: CM_ProformaTransactionCriteria;
	realProCrit 		: CM_ProformaTransactionCriteria;
	itemCode 			: String;
	value 				: Any;
	criterias			: CMIF_Array;
	cmifCriteria 		: CMIF_YACriteriaPriority;
	selectedTrxTypes 	: CM_TransactionTypeByType;
	critType 			: CM_YACriteriaType;
	voyage				: CM_Voyage;
	cargoColl			: CM_TISet;
	customsAgent		: CM_CustomsAgent;
	cashReceipt1		: CM_CashReceipt;	
	tiSet				: CM_TISet;
	toDoTaskDesc		: CM_ToDoTaskDesc;
	vessel				: CM_Vessel;
	bol					: CM_BOL;
	cashInvType			: CM_InvoiceDesc;
	trxn				: CM_TITransaction;
	debtorRoot			: CM_DebtorRoot;
	debtorObj			: ObjectArray;
	invoice				: CM_Invoice;
	debtor				: CM_Debtor;
	cargoMap			: CM_TranMap;
	isDoClearanceCheck  : Boolean;
	root                : CM_Root;
begin
	root			   := app.myRoot;
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	
	self.setHarbourIsDoClearanceCheck(false);
	toDoTaskDesc := root.allToDoTaskDescsByShortDesc["WASH"];
	self.assertNotNull(toDoTaskDesc);
	
	//set terminal to be cash enabled.
	self.enableCashOnlyTerminal( self.myTerminal, true );
	cashInvType := self.getInvoiceType("UT_InvType");		// cash receipt invoice type
	self.setDefaultBankCashInvoiceType(cashInvType);
	
	customsAgent := root.allCustomsAgents['UTCA1'];
	debtor := customsAgent.myDebtor;
	self.assertNotNull(debtor);
	
	self.deleteInvoiceLineType("UT_MMC1", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_MMC2", FORCED_ERASE);
	theBank := self.getTerminal.getDefaultCompanyBank();
	
	// Invoice type, UT_LT1 invoice line type, charged to customs agent, calc type Cargo- value of 1
	invType := self.addIfNewInvoiceType("UT_INV");
	self.addIfNewServiceILD("UT_Service01", "CCT00", "UT_LT1", null, invType);

	invLineType1 := self.myBank.invoiceLineDescriptors["UT_LT1"];
	debtorType := root.allDebtorTypes["SDT6"];	// customs agent
	beginTransaction;
	invLineType1.setPropertyValue("myDebtorType", debtorType);
	commitTransaction;
	
	// Yard invoice type, UT_LT2 invoice line type, charged to customs agent, calc type Cargo- value of 1
	invType := self.addIfNewInvoiceType("UT_INV");
	self.addIfNewServiceILD("UT_Service01", "CCT00", "UT_LT2", null, invType);

	invLineType2 := self.myBank.invoiceLineDescriptors["UT_LT2"];
	debtorType := root.allDebtorTypes["SDT6"];	// customs agent
	beginTransaction;
	invLineType2.setPropertyValue("myDebtorType", debtorType);
	commitTransaction;
	
	// Created two invoice line types each with a separate minimum charge invoice line types.All four charged to Customs Agent.
	calType := root.allCalculationTypesByCode["CCT00"];
	
	create services transient;
	service := self.myBank.services["UT_Service01"];
	if service = null then
		service := self.createInvoiceService("UT_Service01", "Remarks", calType, null);
	endif;
	self.setServiceRate(service, debtor, "01/01/2013".Date, 20.00);
	services.add(service);
	
	create pxyInvoiceLineDesc transient;
	pxyInvoiceLineDesc.bank := self.getTerminal().getDefaultCompanyBank();
	
	chgNum  := 0;
	debtorType := root.allDebtorTypes["SDT6"];
	
	/*pxyInvoiceLineDesc.setProxy(false,true,	chgNum,	debtorType,	calType,invType,"UT_MMC1",10,"","Unit Narration",services, false,
							    100, app.getErrorString(Invoice), "UT_LT1", false, false,null,); // 31 Jan 2023 TFS 56134 */
	pxyInvoiceLineDesc.setProxy(false,true,	chgNum,	debtorType,	calType,invType,"UT_MMC1",10,"","Unit Narration",services, false,
								100, app.getErrorString(Invoice), "UT_LT1", false, false,null,null); // 31 Jan 2023 TFS 56134
	app.myTrxCA.trxCreateInvoiceLineDesc(pxyInvoiceLineDesc,  newInvLineType, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	delete pxyInvoiceLineDesc;
	
	// second invoice line type	
	create pxyInvoiceLineDesc transient;
	pxyInvoiceLineDesc.bank := self.getTerminal().getDefaultCompanyBank();
	pxyInvoiceLineDesc.setProxy(false,true,	chgNum,	debtorType,	calType,invType,"UT_MMC2",10,"","Unit Narration",services, false,
								100, app.getErrorString(Invoice), "UT_LT2", false, false,null,null); // 31/01/2023 navvt20 TFS 56134

	app.myTrxCA.trxCreateInvoiceLineDesc(pxyInvoiceLineDesc,  newInvLineType, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	// Set up transaction map to map todo task complete transactions (for two different todo tasks) to the two invoice line types.
	self.transMapLoad();
	
	cargoMap := self.myBank.myCurrentTranMapCargo['UT_MMC'];
	self.assertNotNullMsg(cargoMap,"cargo map should not be null");
	app.myTrxUA.trxUpdateBankTMActive(cargoMap,app.myPassport);

	// Added the transactions to the proforma list in cash config (to indicate that they will be paid for before that actually happen).
	// delete old instances first
	beginTransaction;
	self.myBank.allProformaCriteria.purge();
	commitTransaction;
	
	create criterias transient;
	
	critType := root.allYACriteriaTypes[YACriteriaType_CargoType];
	create proxyCriteria transient;
	value := root.allCargoTypesById[TI_CargoType_Container].CM_CargoType.abbreviation;
	proxyCriteria.setProxy(critType, value, itemCode);
	cmifCriteria := proxyCriteria.getTransient();
	criterias.add(cmifCriteria);
	
	create selectedTrxTypes transient;
	selectedTrxTypes.add( root.allTransactionTypes[TRANS_TYPE_TASKCOMPLETE] );// task complete transaction
	
	create proxyProCrit transient;
	proxyProCrit.setProxy( criterias, selectedTrxTypes, 2, self.myBank, null, null, null, null, null, 0 );
	app.myTrxCA.trxCreateProformaCriteria(proxyProCrit, realProCrit, app.myPassport);
	self.assertTrueMsg(app.myPassport.noErrors, "Pro Forma allocation create failed - " &amp; app.myPassport.getAllErrorsWarningsAsString);
	delete cmifCriteria;
	delete proxyProCrit;
	
	self.allProCriteria.add( realProCrit );
	
	// In cash collection, calculated the charges for a container and paid the cash.
	tiID:="MMC00001";	
	self.deleteContainer(tiID);
	ti := self.addContainer(tiID,self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), "2200","MT",TI_IMEX_STATUS_EXPORT).CM_Container;
	app.myPassport.clearErrorsWarnings;
	
	
	deleteVoyage("UTVOY1");
	deleteVessel("UTBOAT");
	vessel := addVesselCellular("UTBOAT", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	voyage := addVoyageWithContainerStructur("UTVOY1", "UTBOAT", self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	
	bol := self.addBOL("BOL050", voyage, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), null, self.getTerminal);
	self.assertNotNull(bol);
	
	beginTransaction;
	ti.setBOL(bol.number);
	ti.setMyVoyage(voyage, app.myPassport);
	commitTransaction;

	create cargoColl transient;
	self.getCargoByBOL(voyage, "BOL050", cargoColl);
	self.assertNotNull(cargoColl);
	customsAgent := root.allCustomsAgents['UTCA1'];
	cashReceipt1 := self.doCashReceipt(cargoColl, customsAgent, 2, voyage.code, "BOL050");
	
	//Then added and completed both todo tasks to generate the charges.
	create tiSet transient;
	tiSet.add(ti);
	self.addToDoTask(toDoTaskDesc, tiSet);
	self.completeToDoTask(toDoTaskDesc, tiSet,null);						//23.01.2023 navma1 #54349[54262]
	
	toDoTaskDesc := root.allToDoTaskDescsByShortDesc["Damage Ck"];
	self.assertNotNull(toDoTaskDesc);
	self.addToDoTask(toDoTaskDesc, tiSet);
	assertEqual(ti.allToDoTasksToDo.size, 1);
	
	self.completeToDoTask(toDoTaskDesc, tiSet,null);						//23.01.2023 navma1 #54349[54262]
	
	// there should two minimum charges exist.
	create debtorObj transient;
	debtorRoot := root.allDebtors["UT_Cash1"];
	debtorObj.add(debtorRoot);
	invoice := theBank.getMatchingInvoice(invType, null, trxn.CM_TaskComplete, debtorObj[1].CM_Debtor, false);
	self.assertNotNull(invoice);
	self.assertEqual(invoice.invoiceLines.size, 2);
	
	cashReceipt1 := self.doCashReceipt(cargoColl, customsAgent, 2, voyage.code, "BOL050");
	self.assertEqual(cashReceipt1.getAllInvoiceLines.size, 4);
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	delete services;
	delete pxyInvoiceLineDesc;
	delete criterias;
	delete proxyProCrit;
	delete selectedTrxTypes;
	delete cargoColl;
	delete tiSet;
	delete debtorObj;
	self.resetDefaultTranMap();
	self.enableCashOnlyTerminal( self.getTerminal, false );
end;</source>
    </JadeMethod>
    <JadeMethod name="tPayBreakBulkTFS2379" id="839b6096-6e1a-4138-a8c5-e69d418b8061">
        <updating/>
        <source>tPayBreakBulkTFS2379() updating;
// cnwma1
/*

Purpose:		cnwjre1 test cash for break bulk split merge TFS 2379 after 1990.
				Cargo 1 location 1 with charge, split and merged into cargo 2 then zombied.  Cargo 2 location 2 with charge split and merged into Cargo 3 location 3
				then zombied.  No invoice lines should be moved.
Parameters:			

JIRA 35213 - refactored.
*/
constants
	Cargo_Type			: String = "UTREBAR";
vars
	count		: Integer;
	date		: Date;
	tranTS		: TimeStamp;
	cargoTypeObj : CM_CargoType;
	bs1,bs2,bs3 	: CM_BlockStack;
	cargo1,
	cargo2,
	cargo3		: CM_TrackedItem;
	splitCargo	: CM_TrackedItem;
	moveController		: CMIF_MoveController;
	wle 		: CM_WorkListEntry;
	job : CM_Job;
	customsAgent	: CM_CustomsAgent;
	debtor1		: CM_Debtor;
	services	: CM_ServiceByNameDict;
	service1,
	service2	: CM_Service;
	calcType	: CM_CalculationType;
	invType		: CM_InvoiceDesc;
	invLineType1	: CM_InvoiceLineDesc;
	invLine		: CM_InvoiceLine;
begin

	//set terminal to be cash enabled.
	self.enableCashOnlyTerminal( self.myTerminal, true );

	self.deleteInvoiceTransactionMap(1, 'UT_SplitMerge');
	self.deleteInvoiceType("UT_InvTypeWeight");
	self.deleteInvoiceService("UT_ServiceWeight1", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeWeight1", FORCED_ERASE);

	create services transient;
	invType := self.createInvoiceType("UT_InvTypeWeight", InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type UT_InvTypeWeight not created");

	calcType := app.myRoot.allCalculationTypesByCode['CCT04'];		// cargo weight kilos
	self.assertNotNullMsg(calcType, "Calculation type CCT04 not found");
	
	service1 := self.createInvoiceService("UT_ServiceWeight1","weight1", calcType, null);
	self.assertNotNullMsg(service1, "UT_ServiceWeight1 not created");
 	services.add(service1);
	
	// charges customs agent
	invLineType1 := self.createInvoiceLineType("UT_LineTypeWeight1", calcType, invType, services, "SDT6");
	self.assertNotNullMsg(invLineType1, "UT_LineTypeWeight1 not created");
	// agent and debtor, set rates
	customsAgent := app.myRoot.allCustomsAgents['UTCA1'];
	debtor1 := customsAgent.myDebtor;
	self.setServiceRate(service1, debtor1, "01/01/2013".Date, 0.10);
	service2 := self.myBank.services["UT_ServiceX9"];
	self.setServiceRate(service2, debtor1, "01/01/2013".Date, 100.00);

	// Transaction map to charge receive as fixed charge and per-weight charge, and storage as per-weight
	self.tranMapLoadSplitMerge();

	//create bbk cargo type with allow duplicates
	cargoTypeObj	:=	app.myRoot.getCargoTypeFromAbbrev(Cargo_Type);

	
	// create block stackS 1 2 and 3
	self.deleteTerminalArea("UTBS1");
	bs1:=self.addBlockStack("UTBS1",200,null);
	self.assertNotNull(bs1);
	self.deleteTerminalArea("UTBS2");
	bs2:=self.addBlockStack("UTBS2",200,null);
	self.assertNotNull(bs2);
	self.deleteTerminalArea("UTBS3");
	bs3:=self.addBlockStack("UTBS3",200,null);
	self.assertNotNull(bs3);
	
	// create cargo 1 in BS1
	self.deleteAllCargo("UTREBAR1",cargoTypeObj);
	cargo1:=self.addCargoAtLocation("UTREBAR1",cargoTypeObj,self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), bs1.myLocationsController);
	self.assertNotNull(cargo1);
	self.assertEqual(cargo1.myPrimaryActualLocation,bs1.myLocationsController);
	
	beginTransaction;
	cargo1.setTotalQuantity(50);
	cargo1.setMyTotalVolume(50000);
	cargo1.setTotalWeightWithoutTrans(50000);
	cargo1.setImExStatus(TI_IMEX_STATUS_IMPORT);
	cargo1.setCustomsAgent(customsAgent);
	
	commitTransaction;
	
	self.assertEqual(cargo1.totalQuantity,50);
	self.assertEqual(cargo1.totalVolume.Real,50000.Real);
	self.assertEqual(cargo1.totalWeight.Decimal,50000.Decimal);
	// create a receive ship transaction to get the associated charges
	tranTS := app.actualTimeServer;
	date := tranTS.date;
	self.createDatedChargedTransaction(cargo1, tranTS, TRANS_TYPE_REC_SHIP, true);

	// cargo 2 in BS2
	cargo2:=self.addCargoAtLocation("UTREBAR1",cargoTypeObj,self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), bs2.myLocationsController);
	self.assertNotNull(cargo2);
	self.assertEqual(cargo2.myPrimaryActualLocation,bs2.myLocationsController);
	
	beginTransaction;
	cargo2.setTotalQuantity(50);
	cargo2.setMyTotalVolume(50000);
	cargo2.setTotalWeightWithoutTrans(50000);
	cargo2.setImExStatus(TI_IMEX_STATUS_IMPORT);
	cargo2.setCustomsAgent(customsAgent);
	
	commitTransaction;
	// create a receive ship transaction to get the associated charges
	tranTS := app.actualTimeServer;
	date := tranTS.date;
	self.createDatedChargedTransaction(cargo2, tranTS, TRANS_TYPE_REC_SHIP, true);
	
	// cargo 3 in BS3
	cargo3:=self.addCargoAtLocation("UTREBAR1",cargoTypeObj,self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), bs3.myLocationsController);
	self.assertNotNull(cargo3);
	self.assertEqual(cargo3.myPrimaryActualLocation,bs3.myLocationsController);
	
	beginTransaction;
	cargo3.setTotalQuantity(50);
	cargo3.setMyTotalVolume(50000);
	cargo3.setTotalWeightWithoutTrans(50000);
	cargo3.setImExStatus(TI_IMEX_STATUS_IMPORT);
	cargo3.setCustomsAgent(customsAgent);
	
	commitTransaction;
	// create a receive ship transaction to get the associated charges
	tranTS := app.actualTimeServer;
	date := tranTS.date;
	self.createDatedChargedTransaction(cargo3, tranTS, TRANS_TYPE_REC_SHIP, true);
	
	
	self.assertTrueMsg(cargo1.invoiceLines.size = 2, "Cargo 1 should have 2 invoice lines, has " &amp; cargo1.invoiceLines.String);
	self.assertTrueMsg(cargo2.invoiceLines.size = 2, "Cargo 2 should have 2 invoice lines, has " &amp; cargo2.invoiceLines.String);
	self.assertTrueMsg(cargo3.invoiceLines.size = 2, "Cargo 3 should have 2 invoice lines, has " &amp; cargo3.invoiceLines.String);
	
	// split half of cargo 1 to merge into cargo 2
	create moveController transient;
	moveController.setMyTrackedItem(cargo1);	
	moveController.setMyToPrimaryLocation(bs2.myLocationsController);
	
	//queue 25 to bs2
	moveController.setMoveMode(QUEUE_MODE);
	moveController.setQuantity(25);
	
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);
	app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	wle:=cargo1.allQueuedFutureMoves.first.myWorkListEntry;
	job:=wle.job;
	
	//move 25 to bs2 set move wle to 
	moveController.setMyWorkListEntry(wle);
	moveController.setMoveMode(REAL_MODE);
	moveController.setQuantity(25);
	
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);
	app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(cargo1.totalQuantity,25);
	self.assertEqual(cargo1.totalWeight.Decimal,25000.Decimal);
	self.assertEqual(cargo1.totalVolume.Real,25000.Real);
	self.assertEqual(cargo1.myPrimaryActualLocation,bs1.myLocationsController);
	self.assertEqual(bs2.myLocationsController.allTrackedItems.size,1);
	
	// cargo 2 should have 25 merged from cargo 1
	self.assertEqual(cargo2.totalQuantity,75);

	self.assertTrueMsg(cargo1.invoiceLines.size = 2, "Cargo 1 should have 2 invoice lines, has " &amp; cargo1.invoiceLines.String);
	self.assertTrueMsg(cargo2.invoiceLines.size = 4, "Cargo 2 should have 4 invoice lines, has " &amp; cargo2.invoiceLines.String);
	self.assertTrueMsg(cargo3.invoiceLines.size = 2, "Cargo 3 should have 2 invoice lines, has " &amp; cargo3.invoiceLines.String);
	
	//merge the rest of cargo 1 into cargo 2
	//queue it first
	delete moveController;
	create moveController transient;
	moveController.setMyTrackedItem(cargo1);	
	moveController.setMyToPrimaryLocation(bs2.myLocationsController);
	moveController.setMoveMode(QUEUE_MODE);
	moveController.setQuantity(25);
	
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);
	app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	wle:=cargo1.allQueuedFutureMoves.first.myWorkListEntry;
	job:=wle.job;

	moveController.setMyTrackedItem(cargo1);
	moveController.setMyWorkListEntry(wle);
	moveController.setMoveMode(REAL_MODE);
	moveController.setMyToPrimaryLocation(bs2.myLocationsController);
	moveController.setQuantity(25);
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);
	app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	// cargo 1 should now be a zombie
	self.assertEqual(cargo1.totalQuantity,0);
	self.assertEqual(cargo1.totalWeight.Decimal,0.Decimal);
	self.assertEqual(cargo1.totalVolume.Real,0.Real);

	self.assertTrueMsg(cargo1.invoiceLines.size = 2, "Cargo 1 should have 2 invoice lines, has " &amp; cargo1.invoiceLines.String);
	self.assertTrueMsg(cargo2.invoiceLines.size = 4, "Cargo 2 should have 4 invoice lines, has " &amp; cargo2.invoiceLines.String);
	self.assertTrueMsg(cargo3.invoiceLines.size = 2, "Cargo 3 should have 2 invoice lines, has " &amp; cargo3.invoiceLines.String);

	// cargo 2 should have another 25 merged from cargo 1
	self.assertEqual(cargo2.totalQuantity,100);

	// now split and merge cargo 2 into cargo 3, in three steps (it is now 100 so 30, 30 and 40)
	// split half of cargo 2 to merge into cargo 3
	delete moveController;
	create moveController transient;
	moveController.setMyTrackedItem(cargo2);	
	moveController.setMyToPrimaryLocation(bs3.myLocationsController);
	
	//queue 30 to bs3
	moveController.setMoveMode(QUEUE_MODE);
	moveController.setQuantity(30);
	
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);
	app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	wle:=cargo2.allQueuedFutureMoves.first.myWorkListEntry;
	job:=wle.job;
	
	//move 30 to bs3 set move wle to 
	moveController.setMyWorkListEntry(wle);
	moveController.setMoveMode(REAL_MODE);
	moveController.setQuantity(30);
	
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);
	app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(cargo2.totalQuantity,70);
	self.assertEqual(bs3.myLocationsController.allTrackedItems.size,1);
	
	// cargo 3 should have 30 merged from cargo 2
	self.assertEqual(cargo3.totalQuantity,80);
	
	self.assertTrueMsg(cargo1.invoiceLines.size = 2, "Cargo 1 should have 2 invoice lines, has " &amp; cargo1.invoiceLines.String);
	self.assertTrueMsg(cargo2.invoiceLines.size = 4, "Cargo 2 should have 4 invoice lines, has " &amp; cargo2.invoiceLines.String);
	self.assertTrueMsg(cargo3.invoiceLines.size = 6, "Cargo 3 should have 6 invoice lines, has " &amp; cargo3.invoiceLines.String);
	
	//merge another 30
	//queue it first
	delete moveController;
	create moveController transient;
	moveController.setMyTrackedItem(cargo2);	
	moveController.setMyToPrimaryLocation(bs3.myLocationsController);
	moveController.setMoveMode(QUEUE_MODE);
	moveController.setQuantity(30);
	
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);
	app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	wle:=cargo2.allQueuedFutureMoves.first.myWorkListEntry;
	job:=wle.job;

	moveController.setMyTrackedItem(cargo2);
	moveController.setMyWorkListEntry(wle);
	moveController.setMoveMode(REAL_MODE);
	moveController.setMyToPrimaryLocation(bs3.myLocationsController);
	moveController.setQuantity(30);
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);
	app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

	self.assertTrueMsg(cargo1.invoiceLines.size = 2, "Cargo 1 should have 2 invoice lines, has " &amp; cargo1.invoiceLines.String);
	self.assertTrueMsg(cargo2.invoiceLines.size = 4, "Cargo 2 should have 4 invoice lines, has " &amp; cargo2.invoiceLines.String);
	self.assertTrueMsg(cargo3.invoiceLines.size = 6, "Cargo 3 should have 6 invoice lines, has " &amp; cargo3.invoiceLines.String);
	
	//merge the last 40
	
	delete moveController;
	create moveController transient;
	moveController.setMyTrackedItem(cargo2);	
	moveController.setMyToPrimaryLocation(bs3.myLocationsController);
	moveController.setMoveMode(QUEUE_MODE);
	moveController.setQuantity(40);
	
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);
	app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	wle:=cargo2.allQueuedFutureMoves.first.myWorkListEntry;
	job:=wle.job;

	moveController.setMyTrackedItem(cargo2);
	moveController.setMyWorkListEntry(wle);
	moveController.setMoveMode(REAL_MODE);
	moveController.setMyToPrimaryLocation(bs3.myLocationsController);
	moveController.setQuantity(40);
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);
	app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

	// cargo 2 should now be a zombie
	self.assertEqual(cargo2.totalQuantity,0);
	self.assertEqual(cargo2.totalWeight.Decimal,0.Decimal);
	self.assertEqual(cargo2.totalVolume.Real,0.Real);

	// cargo 3 should have all of the cargo
	self.assertEqual(cargo3.totalQuantity,150);

	self.assertTrueMsg(cargo1.invoiceLines.size = 2, "Cargo 1 should have 2 invoice lines, has " &amp; cargo1.invoiceLines.String);
	self.assertTrueMsg(cargo2.invoiceLines.size = 4, "Cargo 2 should have 4 invoice lines, has " &amp; cargo2.invoiceLines.String);
	self.assertTrueMsg(cargo3.invoiceLines.size = 6, "Cargo 3 should have 6 invoice lines, has " &amp; cargo3.invoiceLines.String);
	
	// each item should still have the original 2 invoice lines, with none moved out to other items
	count := 0;
	foreach invLine in cargo1.invoiceLines do
		self.assertTrueMsg(invLine.voided, "Cargo 1 Invoice lines should be voided cos its a zombie");
		
		count := count + 1;
	endforeach;
	self.assertEqualMsg(count, 2, "First cargo item invoice lines");  
	
	count := 0;
	foreach invLine in cargo2.invoiceLines do
		self.assertTrueMsg(invLine.voided, "Cargo 1 Invoice lines should be voided cos its a zombie");
		count := count + 1;
	endforeach;

	self.assertEqualMsg(count,4, "Second cargo item invoice lines"); 
	count := 0;
	foreach invLine in cargo3.invoiceLines do
		count := count + 1;
	endforeach;
	self.assertEqualMsg(count, 6, "Third cargo item invoice lines");  
epilog
	app.isGarbageCollectionProcess:=false;
	delete moveController;
	delete services;
	self.resetDefaultTranMap();
end;</source>
    </JadeMethod>
    <JadeMethod name="tPayBulkSplitMerge" id="5e15da3f-c456-4c33-9342-6c204bd82bf0">
        <updating/>
        <source>tPayBulkSplitMerge() updating;
// cnwma1
/*

Date		Who		Reason
1/06/2016	cnwjre1	TFS 1990 test for bulk

*/
constants
	Cargo_Type			: String = "UTCOAL";
vars
	date		    : Date;
	tranTS		    : TimeStamp;
	cargoTypeObj    : CM_CargoType;
	bs1,
	bs2 	 	    : CM_BlockStack;
	cargo , 
	splitCargo		: CM_TrackedItem;
	moveController	: CMIF_MoveController;
	wle 			: CM_WorkListEntry;
	job 			: CM_Job;
	customsAgent	: CM_CustomsAgent;
	debtor1			: CM_Debtor;
	drTerm			: CM_DebtorTerminal;
	services		: CM_ServiceByNameDict;
	service1,
	service2		: CM_Service;
	calcType		: CM_CalculationType;
	cashInvType,
	invType			: CM_InvoiceDesc;
	invLineType1	: CM_InvoiceLineDesc;
	terminal		: CM_Terminal;
begin


	//set terminal to be cash enabled.
	self.enableCashOnlyTerminal( self.myTerminal, true );

	self.deleteInvoiceTransactionMap(1, 'UT_SplitMerge');
	self.deleteInvoiceType("UT_InvTypeWeight");
	self.deleteInvoiceService("UT_ServiceWeight1", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeWeight1", FORCED_ERASE);

	create services transient;
	invType := self.createInvoiceType("UT_InvTypeWeight", InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type UT_InvTypeWeight not created");

	calcType := app.myRoot.allCalculationTypesByCode['CCT04'];		// cargo weight kilos
	self.assertNotNullMsg(calcType, "Calculation type CCT04 not found");
	
	service1 := self.createInvoiceService("UT_ServiceWeight1","weight1", calcType, null);
	self.assertNotNullMsg(service1, "UT_ServiceWeight1 not created");
 	services.add(service1);
	
	// charges customs agent
	invLineType1 := self.createInvoiceLineType("UT_LineTypeWeight1", calcType, invType, services, "SDT6");
	self.assertNotNullMsg(invLineType1, "UT_LineTypeWeight1 not created");
	// agent and debtor, set rates
	customsAgent := app.myRoot.allCustomsAgents['UTCA1'];
	debtor1 := customsAgent.myDebtor;
	self.setServiceRate(service1, debtor1, "01/01/2013".Date, 0.10);
	service2 := self.myBank.services["UT_ServiceX9"];
	self.setServiceRate(service2, debtor1, "01/01/2013".Date, 100.00);

	// Transaction map to charge receive as fixed charge and per-weight charge, and storage as per-weight
	self.tranMapLoadBulkSplitMerge();

	cargoTypeObj	:=	app.myRoot.getCargoTypeFromAbbrev(Cargo_Type);
	
	// create block stack 1
	// create cargo with quantity
	deleteTerminalArea("UTBS1");
	bs1:=self.addBlockStack("UTBS1",200,null);
	self.assertNotNull(bs1);
	
	self.deleteAllCargo("UTCOAL1",cargoTypeObj);
	cargo:=self.addCargoAtLocation("UTCOAL1",cargoTypeObj,self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), bs1.myLocationsController);
	self.assertNoTrxErrors();
	self.assertNotNull(cargo);
	self.assertEqual(cargo.myPrimaryActualLocation,bs1.myLocationsController);
	terminal := self.getTerminal();
	cashInvType := self.getInvoiceType("UT_CashInvType");		// cash receipt invoice type

	beginTransaction;
	cargo.setTotalQuantity(50);
	cargo.setTotalWeightWithoutTrans(50000); //50000kgs
	cargo .setMyTotalVolume(cargo.totalWeight/cargo.getDensity);
	cargo.setImExStatus(TI_IMEX_STATUS_IMPORT);
	cargo.setCustomsAgent(customsAgent);
	///terminal.setConfig(CashInvoiceType, cashInvType);
	commitTransaction;
	self.setDefaultBankCashInvoiceType(cashInvType);
	self.assertEqual(cargo.totalWeight.Decimal,50000.Decimal);
	
	// create a receive ship transaction to get the associated charges
	tranTS := app.actualTimeServer;
	date := tranTS.date;
	self.createDatedChargedTransaction(cargo, tranTS, TRANS_TYPE_REC_SHIP, true);
	// back-date the transactions 3 days to get storage now
	date := date - 3;
	self.setTransactionDate2(cargo, date);

	// pay for the cargo before split/merge
	drTerm := debtor1.allDebtorTerminals.getAtKey( self.myTerminal );
	self.assertTrueMsg(drTerm &lt;&gt; null, "Debtor/Terminal not found");
	self.cashTestSplitMerge(cargo, drTerm);

	//create block stack 2
	deleteTerminalArea("UTBS2");
	bs2:=self.addBlockStack("UTBS2",200,null);
	self.assertNotNull(bs2);
	
	
	create moveController transient;
	moveController.setMyTrackedItem(cargo);	
	moveController.setMyToPrimaryLocation(bs2.myLocationsController);
	
	//queue the entire 50 to bs2
	moveController.setMoveMode(QUEUE_MODE);
	moveController.setWeight(25000);  //split move 25000 kgs to bs2
	
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);
	app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(cargo.myPrimaryQueuedLocation,bs2.myLocationsController);
	self.assertNotNull(cargo.allQueuedFutureMoves.first);
	wle:=cargo.allQueuedFutureMoves.first.myWorkListEntry;
	self.assertNotNull(wle);
	self.assertEqual(wle.weight,25000.Decimal);
	job:=wle.job;
	self.assertNotNull(job);
	
	
	//move 10000 to bs2 
	moveController.setMyWorkListEntry(wle);
	moveController.setMoveMode(REAL_MODE);
	moveController.setWeight(10000);
	
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);
	app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(cargo.totalWeight.Decimal,40000.Decimal);
	self.assertEqual(cargo.myPrimaryActualLocation,bs1.myLocationsController);
	self.assertEqual(bs2.myLocationsController.allTrackedItems.size,1);
	splitCargo:=bs2.myLocationsController.allTrackedItems.first;
	
	self.assertEqual(splitCargo.myCargoType,cargoTypeObj);
	self.assertEqual(splitCargo.id,cargo.id);
	self.assertEqual(splitCargo.totalWeight.Decimal,10000.Decimal);
	
	self.validateBulkSplitMergeA(cargo, splitCargo);
	
epilog
	delete moveController;
	delete services;
	self.resetDefaultTranMap();
end;</source>
    </JadeMethod>
    <JadeMethod name="tProformaRecieval" id="a34d79d1-149c-4b2f-bfb3-1af508121faa">
        <updating/>
        <source>tProformaRecieval() updating;
/*

Purpose:			Create pro forma invoice lines for all appropriate transaction types to check that all do create invocie lines without error

Parameters:			

Return Value:		


Date		Who		Reason
01 August 2012	cnwer1	Initial creation CCMS MES 1035
// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
*/

vars
	bank : CM_Bank;
	agent : CM_CashInvoiceProformaAgent;
	manual,
	receive : Boolean;
	ti : CM_TrackedItem;
	effectiveDT : TimeStamp;
	trxTypeArray : IntegerArray;
	tiID	:String;
	lines : CM_InvoiceLineBySeqNumDict;
	trxType : CM_TransactionType;
	lineTrxTypes : IntegerArray;
	classNameToCreate : String;
begin

	create agent transient;
	manual := false;
	receive := true;
	bank := self.getTerminal.getDefaultCompanyBank();
	effectiveDT := app.actualTimeServer.addDays(5);	// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
	tiID:="CASH0108121";
	self.deleteContainer(tiID);
	ti := self.addContainer(tiID,self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), "2200","MT",TI_IMEX_STATUS_EXPORT).CM_Container;
	app.myPassport.clearErrorsWarnings;
	agent.init( bank, ti, effectiveDT.date, receive );
	create trxTypeArray transient;
	foreach trxType in app.myRoot.allTransactionTypes do
	
		if trxType.trxGroup &lt;&gt; TRANS_TYPE_GROUP_TI then	//03 May 2016	NDL	TFS 1903
			continue;
		endif;
		
		classNameToCreate := trxType.classNameToCreate;
		
		if classNameToCreate = CM_Storage.name
		or classNameToCreate = CM_AvailableForRelease.name
		or classNameToCreate = CM_GroupAssign.name
		or classNameToCreate = CM_GroupUnassign.name
		or classNameToCreate = CM_LocationCheck.name
		or classNameToCreate = CM_GroupComplete.name	//21 Aug 2015	NDL	Par 36608
		or classNameToCreate = CM_ReeferMonitor.name
		or classNameToCreate = CM_StopAddDocAction.name	//21 Sep 2016	NDL	TFS 2647
		or classNameToCreate = CM_StopClearedDocAction.name	//21 Sep 2016	NDL	TFS 2647
		or classNameToCreate = CM_TaskAddDocAction.name	//21 Sep 2016	NDL	TFS 2647
		or classNameToCreate = CM_TaskCompleteDocAction.name	//21 Sep 2016	NDL	TFS 2647
		then
			continue;
		endif;
		trxTypeArray.add(trxType.trxType);
	endforeach;
	
	self.clearExpectedTrxErrors();
	self.expectTrxError(SetFuelDetailsForNonFuelTI);
	self.expectTrxError(WARN_EDIT_DATE);
	self.expectTrxError(ERR_INVALID_ISOTYPE);
	self.expectTrxError(Docket_correction_only_log);
	
	lines:=app.myTrxCA.trxCreateProformaInvoiceLines(	trxTypeArray,	//_transactionTypes : IntegerArray;
															agent.myTrackedItem,	//_cargoItem : CM_TrackedItem input;
															null,
															agent.effectiveDate,	//_endDate : Date;
															null,
															lineTrxTypes,	//_lineTrxTypes : IntegerArray io;
															app.myPassport	//_passport : CM_Passport input
															);
																													
	self.assertNoTrxErrorsOrWarnings();		
epilog
	
	delete agent;
	delete trxTypeArray;
	
	if lines &lt;&gt; null and not lines.isEmpty then							// 16/04/2013 cnwmh5
		lines.purge();
	endif;
	delete lines;
	app.allReportObjectSet.purge();
end;</source>
    </JadeMethod>
    <JadeMethod name="tReeferDailyProforma" id="81847517-3179-46f7-97a3-012f712525a7">
        <updating/>
        <source>tReeferDailyProforma() updating;
// cnwma1
// cnwjre1
/* ---------------------------------------------------------------------------
Created:     Sep 2013

Purpose:     From contact 32416, checking the charging of reefer connect/disconnect and automatic reefer daily from release.
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars
	cargoMap	: CM_TranMap;
	debtorType	: CM_DebtorType;
	invType			: CM_InvoiceDesc;
	invLineType1,
	invLineType2  	: CM_InvoiceLineDesc;
begin

	cargoMap := self.myBank.myCurrentTranMapCargo['Default'];
	self.assertNotNullMsg(cargoMap,"cargo map should not be null");
	app.myTrxUA.trxUpdateBankTMActive(cargoMap,app.myPassport);

	invType := self.getInvoiceType("UT_InvType");
	self.addIfNewServiceILD("UT_ServReeferPlugUnplug", "CCT01", "UT_ILTReeferPlugUnplug", null, invType);
	self.addIfNewServiceILD("UT_ServReeferPower", "CCT09", "UT_ILTReeferPower", null, invType);
	invLineType1 := self.myBank.invoiceLineDescriptors["UT_ILTReeferPlugUnplug"];
	invLineType2 := self.myBank.invoiceLineDescriptors["UT_ILTReeferPower"];
	debtorType := app.myRoot.allDebtorTypes["SDT4"];	// cargo operator
	beginTransaction;
	invLineType1.setPropertyValue("myDebtorType", debtorType);
	invLineType2.setPropertyValue("myDebtorType", debtorType);
	commitTransaction;
	
	self.tranMapLoadReefer2();
	
	self.createImportCargo(true);
epilog
	// delete this tran map so following tests can delete the invoice line descs etc
	cargoMap := self.myBank.myCurrentTranMapCargo['Default'];
	app.myTrxUA.trxUpdateBankTMActive(cargoMap,app.myPassport);
	self.deleteInvoiceTransactionMap(1, 'UT_Reefer');
	self.resetDefaultTranMap();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tReleaseUnpaidCargoConfig" id="4f933480-fcbb-4413-9abb-4762f285eb7d">
        <updating/>
        <source>tReleaseUnpaidCargoConfig() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03/03/2025	navkc1 JIRA Story MTN-33930: MTN | Cash Additional Charges for Road Exit Checks (UNIT TEST)
// ### JIRA 34988 06JUN2025 NAVAB1 changes to the error messages raised
*/

constants
	CEN = "UTCEN";
	CEN2 = "UTCEN2";
	VOYCODE = "CASHAPIVOY";
	VESSCODE = "CASHAPIVESS";
	CARGOID = "33930-1";
	CARGOID2 = "33930-2";
	CARGOID3 = "33930-3";
	CARGOID4 = "33930-4";
	CARGOID5 = "33930-5";
	TRANMAP = "CASHAPI";
	EXTUSER1 = "USER1";
	EXTUSER2 = "USER2";
	INVLINEDESC1 = "UT33930-1";
	INVLINEDESC2 = "UT33930-2";
	TODOTASKDESC = "33930TDT";
	TRUCKID = "33930T";
	CARRIERID = "33930C";
vars
	err,
	fileContext,				
	itemCode,
	cargoId,
	cargoId2,
	cargoId3,
	cargoId4,
	cargoId5,
	voyCode,
	agentId					: String;
	
	today,
	effectiveDate 			: Date;
	
	ts						: TimeStamp;
	receiptNumber			: Integer;
	
	vvr						: CM_VehicleVisitRecord;
	tm						: CM_TranMap;
	voyage					: CM_Voyage;
	operator				: CM_Operator;
	ti,	ti1,
	ti2, ti3, ti4, ti5		: CM_TrackedItem;
	debtorType				: CM_DebtorType;
	customagent				: CM_CustomsAgent;
	terminal				: CM_Terminal;
	debtorNode				: CM_DebtorNode;
	debtor					: CM_Debtor;
	debtorTerminal			: CM_DebtorTerminal;
	bank					: CM_Bank;
	proxyCriteria			: CM_YACriteria;
	proxyProCrit 			: CM_ProformaTransactionCriteria;
	realProCrit 			: CM_ProformaTransactionCriteria;
	value 					: Any;
	criterias				: CMIF_Array;
	cmifCriteria 			: CMIF_YACriteriaPriority;
	selectedTrxTypes		: CM_TransactionTypeByType;
	critType 				: CM_YACriteriaType;
	pxyTransService 		: CM_TransServiceBroker;
	cashReceipt,
	cashReceipt2,
	cashReceipt3,
	cashReceipt4,
	cashReceipt5,
	cashReceiptForBoth		: CM_CashReceipt;
	invLineDesc1,
	invLineDesc2 			: CM_InvoiceLineDesc;
	services				: CM_ServiceByNameDict;
	cmifCashAgent			: CMIF_CashInvoiceProformaCtrl;
	tiSet					: CM_TISet;
	toDoTaskDesc			: CM_ToDoTaskDesc;
	ta1						: CM_TerminalArea;
	tiTrans					: CM_TITransaction;
	actualMess, expectedMess1, expectedMess2 : String;
begin
	//return;
	create services transient;
	create cmifCashAgent transient;
	create tiSet transient; 
	// Terminal Area
	ta1 := self.addBlockStack("UTPHT1",9999999,null);
	self.assertNotNullMsg(ta1, "Failed to create TA1");
	// Terminal
	terminal := self.getMyTerminal();
	
	// Operator
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	// Custom Agent
	
	customagent := self.addCustomsAgent("APIAGENT", "UTCASHAPI");
	self.assertNotNullMsg(customagent, "Failed to create customs agent");
	
	// Delete Truck
	self.deleteVehicle(TRUCKID);
	self.deleteCarrier(CARRIERID);
	
	// Create To Do Task Desc
	toDoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc[TODOTASKDESC];
	if toDoTaskDesc &lt;&gt; null then
		self.deleteToDoTaskDescription(toDoTaskDesc);
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("CargoType", app.myRoot.allCargoTypesById[TI_CargoType_BreakBulk]);
	toDoTaskDesc := self.createToDoTaskDesc(TODOTASKDESC);
	self.assertNotNullMsg(toDoTaskDesc, "Failed to create to do task desc");
	
	
	// Debtor
	debtor := self.getDebtor("APIDEBT");
	if debtor = null then
		debtorNode := self.addDebtor("APIDEBT", PaymentType_None);
		debtor := debtorNode.CM_Debtor;
	endif;
	beginTransaction;
		customagent.setDebtor(debtor);
	commitTransaction;
	debtorTerminal := debtor.allDebtorTerminals[terminal];
	self.setDebtorCashOnly(debtor, terminal, true);
	
	// Set terminal to Cash config
	self.enableCashOnlyTerminal(terminal, true);
	self.setTerminalConfig(CashRoadExitChkServices, true);
	self.setTerminalConfig(CashOnlyInDebtOption, 1);
	
	// Get Invoice Line Type
	invLineDesc1 := self.getInvoiceLineType(INVLINEDESC1); // Days Since receival
	self.assertNotNullMsg(invLineDesc1, "Failed to get invoice line type 1");
	invLineDesc2 := self.getInvoiceLineType(INVLINEDESC2); // Cargo Value of 1
	self.assertNotNullMsg(invLineDesc1, "Failed to get invoice line type 2");
	
	// Setup transaction mapping
	tm := self.getTransactionMap(TRANMAP);
	if tm = null then
		tm := self.createTransactionMap(TRANMAP);
		self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	endif;	
	self.assertNotNullMsg(tm, "Failed to create transaction mapping");
	app.myTrxUA.trxUpdateBankTMActive(tm, app.myPassport);
	
	fileContext := 'TranMap Type,TranMap Name,CargoType,Cargo Subtype Group,Cargo Subtype,IMEX,Contents Status,Commodity,Transaction,MoveType,Debtor,Quantity Type,Quantity Range,Quantity Sub Type,Quantity Sub Range,Transfer Type,Grouping,Invoice Line,Over Dimsn?,Trans Ship?,Is 40?,Is Reefer?,Req Temp?,,Is 45?,Is 30?,Is 53?,Is Child?,Is Haz?,Direct Delivery?,Is Work Order Requested?
Cargo,CASHAPI,(Default),(Default),(Default),(Default),(Default),(Default),(Default),,(Default),(Default) †,(Default),,,**Any**,All,VOID
Cargo,CASHAPI,(Default),(Default),(Default),(Default),(Default),(Default),Released - Road,,(Default),(Default) †,(Default),,,**Any**,All,UT33930-1
Cargo,CASHAPI,(Default),(Default),(Default),(Default),(Default),(Default),Todo Task Added,,(Default),(Default) ›,(Default),,,**Any**,All,UT33930-2';

	self.transactionMapLoad(fileContext, null);
	self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	
	// Setup cash config
	debtorType := app.myRoot.allDebtorTypes["SDT6"];
	self.assertNotNullMsg(debtorType, "Failed to get cash debtor type");
	self.setTerminalConfig(CashDebtorType, debtorType);
	
	bank := terminal.getDefaultCompanyBank();
	
	create criterias transient;
	critType := app.myRoot.allYACriteriaTypes.getAtKey(19);	//Operator
	create proxyCriteria transient;
	itemCode := critType.description.cnEcUpto(CM_YACriteriaPriority::code.length -1);
	value := operator.code;
	proxyCriteria.setProxy(critType, value, itemCode);
	cmifCriteria := proxyCriteria.getTransient();
	criterias.add(cmifCriteria);
	
	create selectedTrxTypes transient;
	selectedTrxTypes.add( app.myRoot.allTransactionTypes[32] ); // Receive Ship
	
	create proxyProCrit transient;
	proxyProCrit.setProxy( criterias, selectedTrxTypes, 2, bank, null, null, null, null, null,null );
	app.myTrxCA.trxCreateProformaCriteria(proxyProCrit, realProCrit, app.myPassport);
	self.assertTrueMsg(app.myPassport.noErrors, "Pro Forma allocation create failed - " &amp; app.myPassport.getAllErrorsWarningsAsString);
	delete proxyProCrit;
	
	// Setup storage config
	self.deleteStorageConfig(true);
	
	// Create voyage
	self.opts.purge();
	
	self.opts.addAssoc("dateArrival", today.addDays(-30));
	voyage := self.createVesselVoyage(VOYCODE, VESSCODE, operator);
	self.assertNotNullMsg(voyage, "Failed to create voyage");
	cargoId := CARGOID&amp;today.asStringJMT();
	cargoId2 := CARGOID2&amp;today.asStringJMT();
	cargoId3 := CARGOID3&amp;today.asStringJMT();
	cargoId4 := CARGOID4&amp;today.asStringJMT();
	cargoId5 := CARGOID5&amp;today.asStringJMT();
	self.opts.purge();
	// Create cargo 1
	ti1 := self.getTrackedItem(cargoId);
	if ti1 &lt;&gt; null then
		self.deleteTrackedItem(ti1, true);
		self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	endif;
	
	// Cargo 1
	ti1 := self.addCargoForVoyage(voyage, cargoId);
	self.assertNotNullMsg(ti1, "Failed to creatt TI1");
	self.editIMEXStatus(ti1, TI_IMEX_STATUS_IMPORT, true);
	
	// Create cargo 2
