<CollClass name="TimeStampArray">
    <JadeMethod name="jssDoSort" id="1cc5a34a-7e24-4fbb-b786-554f26422a3d">
        <lockReceiver/>
        <updating/>
        <source>jssDoSort(pTheSorter : JSSSorter) lockReceiver, updating, protected;
// --------------------------------------------------------------------------------
// Created:		08 February 2001 by cnwdad1
//
// Purpose:		Refer to method implementation on the Array class.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	arrayPointer	: Integer;
	timestampValue	: TimeStamp;
	theSortKey		: Object;
	anyValue		: Any;

begin
	foreach timestampValue in self do
		pTheSorter.addValue(timestampValue);
	endforeach;
	
	self.purge();
	
	foreach theSortKey in pTheSorter.mySortColl do
		self.add(theSortKey.JSSSortKey.getValue().TimeStamp);
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="pTheSorter" type="JSSSorter"/>
    </JadeMethod>
</CollClass>
