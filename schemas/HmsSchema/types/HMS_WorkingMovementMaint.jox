    <JadeMethod name="doResizeTopSheet" id="31e2c40e-814c-4fa7-978d-8266f6659a00">
        <updating/>
        <source>doResizeTopSheet() updating, protected;
//--------------------------------------------------
// Created:	22 January 2004 By: cnwgd1
//--------------------------------------------------
vars
	topSheet : Sheet;
begin

	topSheet := self.fldMovements.topSheet;
	if topSheet = self.shtGeneral then
		self.doResizeShtGeneral(topSheet);
	elseif topSheet = self.shtMarineService then
		self.doResizeShtMarineServices(topSheet);
	elseif topSheet = self.shtWharfServices then
		self.doResizeShtWharfServices(topSheet);		
	elseif topSheet = self.shtTidalInfo then
		self.doResizeShtTidalInfo(topSheet);	
	elseif topSheet = self.shtCustomer then
		self.doResizeShtCustomer(topSheet);	
	elseif topSheet = self.shtResources then
		self.doResizeShtResource(topSheet);			
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResourceAdd" id="c5f3e30a-fad6-4f9a-ba49-22a848a8901a">
        <updating/>
        <source>doResourceAdd()updating, protected;
//--------------------------------------------------
// Created:	15 February 2005 By: cnwgd1
//--------------------------------------------------
// 10/12/2014  cnwdb2	PAR 35364
// 11 Aug 2025 navhn30 	MTN-35592: 14050 Error when adding Resources on the Movement Maintenance form in Harbour Management

vars
	tmpRsType : HMS_ResourceType;
	workResourceUsed : CMIF_HMS_ResourceUsed;
	resourceType : Integer;
begin
	resourceType := self.tblResources.getColumnByRowName(ETRow_MyResourceType);
	if self.tblResources.row &gt; self.tblResources.fixedRows then
		if self.tblResources.accessRow(self.tblResources.row).enabled then
			if resourceType &lt;&gt; null then	//11.08.2025	navhn30		MTN-35592
				tmpRsType := self.tblResources.accessCell(self.tblResources.row, resourceType).cellControl.CMUI_ComboBox.listObject.HMS_ResourceType;
			endif;
		endif;
	endif;


	if tmpRsType = null then			
		// search for default capable of being displayed (first one). 
		foreach tmpRsType in app.myRoot.allResourceTypes discreteLock do 
			if tmpRsType.isNotAvailableForEntry or tmpRsType.isMarineService then 		
				// if either 'not available' or is a marine service then look for the next one to use. 
				continue; 
			endif;
			break; // get this far then must have Resource Type that can be displayed. 
		endforeach;
//		commented out as was returning ones that it shouldnt. 
//		tmpRsType := app.myRoot.allResourceTypes.first;
	endif;
	
	if tmpRsType = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Resource Type', null, null);
		app.raiseCMException(Input_required_field_resorceTy, null, null); // cnwdb2	PAR 35364

		return;
	endif;
	
	create workResourceUsed transient;
	
	workResourceUsed.myResourceType := tmpRsType;
	workResourceUsed.myWorkingMovement := self.aMySelectedMovement;
	workResourceUsed.myViewController := self.aMyViewController;
	workResourceUsed.notYetSaved := true;	
				
	self.addResourceUsedToTable(workResourceUsed);

	self.tblResources.selected := false;
	self.tblResources.row := self.tblResources.rows;
	self.tblResources.column := 1;	

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResourceClick" id="f44fbfca-cfca-4642-8940-66fdece61b3f">
        <source>doResourceClick() protected;
//--------------------------------------------------
// Created:	16 February 2005 By: cnwgd1
//--------------------------------------------------
vars
	tmpCellR : JadeTableCell;
	defQty : Real;
	cM : CMIF_HMS_WorkingMovement;
begin

	tmpCellR := self.tblResources.accessCell(self.tblResources.row, self.aColResource);
	tmpCellR.text := tmpCellR.cellControl.CMUI_ComboBox.text;



	// ### Default the number of crew to the units used IF the resource is the Line Company's resource
	cM := self.aMySelectedMovement;

	if cM.myLineCompany &lt;&gt; null 
	and tmpCellR.cellControl.CMUI_ComboBox.listObject = cM.myLineCompany.getResourceForHarbourMovement(cM.myHarbour,cM.moveType) then
		defQty := self.txtLineCrewReqd.text.Integer;
		tmpCellR := self.tblResources.accessCell(self.tblResources.row, self.aColUnitsUsed);
		tmpCellR.text := defQty.String;
		tmpCellR.cellControl.TextBox.text := defQty.String;
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResourceDelete" id="080fba51-0327-4cfd-805f-4ccf9c2ac7ac">
        <source>doResourceDelete() protected;
//--------------------------------------------------
// Created:	15 February 2005 By: cnwgd1
//--------------------------------------------------
vars
	theRow : Integer;
begin
	self.tblResources.findObjectInRow(self.mnuResourceDelete.userObject, theRow);
	if theRow &gt; self.tblResources.fixedRows then
		if self.tblResources.accessRow(theRow).enabled then
			//Ok to delete row
			self.tblResources.removeItemObject(self.mnuResourceDelete.userObject);
		endif;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResourceTypeClick" id="5d929f45-161b-4424-9513-425bf3c5a719">
        <updating/>
        <source>doResourceTypeClick()updating, protected;
//--------------------------------------------------
// Created:	16 February 2005 By: cnwgd1
//	11 Aug 2025	  navhn30 MTN-35592: 14050 Error when adding Resources on the Movement Maintenance form in Harbour Management
//--------------------------------------------------
vars
	theRow : Integer;
	tmpCell : JadeTableCell;
	tmpCmbRT : CMUI_ComboBox;
	tmpCmbR : CMUI_ComboResources;
	tmpRType : HMS_ResourceType;
	tmpRes : HMS_Resource;
	defDateTime : TimeStamp;
	defDTString, defTMString : String;
	tmpDateBox : CMUI_DateMask;
	tmpTimeBox : CMUI_TimeMask;
	defQty : Real;
	sM : CMIF_HMS_WorkingMovement;
	newTxtBox : CMUI_TextBox;
begin
	
	theRow  := self.tblResources.row;
	
	tmpCell := self.tblResources.tryAccessCell(theRow, self.aColResourceType);	//11.08.2025	navhn30 	MTN-35592
	if tmpCell &lt;&gt; null then
		tmpCmbRT := tmpCell.cellControl.CMUI_ComboBox;
	endif;
	
	tmpCell := self.tblResources.tryAccessCell(theRow, self.aColResource);		//11.08.2025	navhn30 	MTN-35592
	if tmpCell &lt;&gt; null then
		tmpCmbR := tmpCell.cellControl.CMUI_ComboResources;
	endif;
	
	tmpRType := tmpCmbRT.listObject.HMS_ResourceType;

	// ### PAR 10220 set defaults
	if tmpRType.allResources.size = 1 then 
		tmpRes := tmpRType.allResources.first;
		if tmpRes.isNotAvailableForEntry then 
			tmpRes := null;
		endif;
		if tmpRes &lt;&gt; null then
			sM := self.aMySelectedMovement;
			if sM.myLineCompany &lt;&gt; null
			and tmpRes = sM.myLineCompany.getResourceForHarbourMovement(sM.myHarbour,sM.moveType) then
				defQty := self.txtLineCrewReqd.text.Integer; 
			endif;
		endif;
	endif;
	if tmpRType.isActionDateTimeRequired then
		defDateTime := self.aMySelectedMovement.occursOnDT;
		
		if defDateTime.isValid() then
			defDTString := defDateTime.date().shortFormatJMT();
			tmpCell := self.tblResources.tryAccessCell(theRow, self.aColDateFrom);		//11.08.2025	navhn30 	MTN-35592
			if tmpCell &lt;&gt; null then
				tmpCell.text := defDateTime.date().shortFormatJMT();
			endif;
//rs			tmpDateBox := tmpCell.cellControl.CMUI_DateMask;
//rs			tmpDateBox.setDate(defDateTime.date);
			
			defTMString := defDateTime.time().shortFormatJMT();
			tmpCell := self.tblResources.tryAccessCell(theRow, self.aColTimeFrom);		//11.08.2025	navhn30 	MTN-35592	
			if tmpCell &lt;&gt; null then
				tmpCell.text := defDateTime.time().shortFormatJMT();
			endif;
//rs			tmpTimeBox := 	tmpCell.cellControl.CMUI_TimeMask;
//rs			tmpTimeBox.setTime(defDateTime.time);
		endif;
	endif;
	
	//Re-populate cmbResource for the newly selected resource type
//	self.myAssistant.comboBoxHMSResource(tmpCmbR, tmpRes, tmpRType, null);
	tmpCmbR.setObjectAndResourceType(tmpRes, tmpRType, self.myTerminal.myHarbour); // PAR 31709 pass in harbour
	
	tmpCell := self.tblResources.tryAccessCell(theRow, self.aColResourceType);		//11.08.2025	navhn30 	MTN-35592
//	tmpCell.text := tmpCmbRT.text &amp; Tab &amp; '' &amp; Tab &amp; '' &amp; Tab &amp; tmpRType.quantityUnits;



	// ### PAR 10220
	if tmpCell &lt;&gt; null then
		tmpCell.text := tmpCmbRT.text &amp; Tab 
						&amp; '' &amp; Tab 
						&amp; defQty.String &amp; Tab 
						&amp; tmpRType.quantityUnits &amp; Tab 
						&amp; defDTString &amp; Tab 
						&amp; defTMString &amp; Tab 
						&amp; '' &amp; Tab 
						&amp; '';
	endif;

	tmpCell := self.tblResources.tryAccessCell(theRow, self.aColUnitsUsed);		//11.08.2025	navhn30 	MTN-35592
	/* PAR 14889 WAS
	tmpCell.cellControl.TextBox.text := "";// clear old value as can cause error if changing decimals
	tmpCell.cellControl.TextBox.decimals := tmpRType.numDecimalPlaces;
	tmpCell.cellControl.TextBox.text := defQty.String;
	NOW*/
	if tmpCell &lt;&gt; null then //11.08.2025	navhn30 	MTN-35592
		newTxtBox := tmpCell.cellControl.CMUI_TextBox;
		newTxtBox.dataType := TextBox.DataType_AlphaNumeric;
		newTxtBox.text := "";
		newTxtBox.decimals := 0;
		newTxtBox.dataType := TextBox.DataType_Numeric;
		newTxtBox.decimals := tmpRType.numDecimalPlaces;
		newTxtBox.text := defQty.String;
	endif;
	
	self.setTblResourceCells(theRow, self.tblResources.accessRow(theRow).itemObject.CMIF_HMS_ResourceUsed, tmpRType);

			
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResourceTypeClickOLD" id="10c2d18d-7c54-47ad-b824-0316ff156d53">
        <updating/>
        <source>doResourceTypeClickOLD()updating, protected;
//--------------------------------------------------
// Created:	16 February 2005 By: cnwgd1
//--------------------------------------------------
vars
	theRow : Integer;
	tmpCell : JadeTableCell;
	tmpCmbRT,
	tmpCmbR : CMUI_ComboBox;
	tmpRType : HMS_ResourceType;
begin
	
	theRow  := self.tblResources.row;
	
	tmpCell := self.tblResources.accessCell(theRow, self.aColResourceType);
	tmpCmbRT := tmpCell.cellControl.CMUI_ComboBox;
	
	tmpCell := self.tblResources.accessCell(theRow, self.aColResource);
	tmpCmbR := tmpCell.cellControl.CMUI_ComboBox;
	
	tmpRType := tmpCmbRT.listObject.HMS_ResourceType;
	
	//Re-populate cmbResource for the newly selected resource type
	self.myAssistant.comboBoxHMSResource(tmpCmbR, null, tmpRType, null);
	
	tmpCell := self.tblResources.accessCell(theRow, self.aColResourceType);	
	tmpCell.text := tmpCmbRT.text &amp; Tab &amp; '' &amp; Tab &amp; '' &amp; Tab &amp; tmpRType.quantityUnits;

	self.setTblResourceCells(theRow, self.tblResources.accessRow(theRow).itemObject.CMIF_HMS_ResourceUsed, tmpRType);

			
end;</source>
        <access>protected</access>
    </JadeMethod>
