    <JadeMethod name="appliesToDebtor" id="f9c325d8-0478-436f-8e0f-bee48cb898ba">
        <source>appliesToDebtor(_theDebtor: CM_Object): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 May 2009	cnwer1	Initial creation

*/

vars

begin
	return self.lineGroupDebtor = _theDebtor;

epilog

end;</source>
