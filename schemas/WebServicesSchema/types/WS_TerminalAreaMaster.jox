<Class name="WS_TerminalAreaMaster" id="59027bfd-11ad-4837-a6bb-b98afa73216a">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Represents a yard area within a terminal</text>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="description" id="0e074a46-a61f-455d-9fef-f2340d21811e">
        <length>51</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
        <text>Concatenated ID and Terminal Area Type. ex. [BS1 Block Stack]</text>
    </PrimAttribute>
    <PrimAttribute name="hasSubLocations" id="190af64d-e742-4b9f-bde3-caf8cb836e10">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="id" id="e4ff08b2-c746-418b-8437-2431917b16db">
        <length>14</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
        <text>Id of the Terminal Area</text>
    </PrimAttribute>
    <PrimAttribute name="type" id="6fb36e58-14e7-41d6-96ef-88ce11fc6aaf">
