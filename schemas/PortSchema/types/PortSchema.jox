    <JadeMethod name="zGetTranslatedText" id="9d4d5135-484e-44f8-a87a-eb9e40f5d1e5">
        <source>zGetTranslatedText(category : String; translationId : Integer) : XLAT_Translation;
// ---------------------------------------------------------------------------
// Created:     8/8/2006 RBarr
//
// Purpose:     Return translated text for the given category and id
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
01 Apr 2008	cnwkpd1	PAR #16399 - Get rid of global.isValidObject
08/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
*/

vars
	cachedTranslation,
	translation		: XLAT_Translation;
	tmpX			: PortSchema;
	invalidLocale	: Boolean;
	currentLocale	: CM_Locale;
	
	//11 Jan 2021	NDL	Unit Test tracking
	oldValue : String;
	newValue : String;
	changeString : String;
begin

	//11 Jan 2021	NDL	Unit Test tracking
	if self.myCurrentLocale = null then
		oldValue := "null";
	else
		oldValue := self.myCurrentLocale.localeDescription;
	endif;
	
	
	//th2 added 12/03/07 - check for cached before travelling to server
	/*
	translation := app.allXlatTranslationsByCatNumber[category, translationId];
	if translation &lt;&gt; null then
		return translation;
	endif;
	*/

	// PAR #16399 - handle null reference specifically first
//	if (not global.isValidObject(self.myCurrentLocale)) then
	currentLocale := self.myCurrentLocale;
	if currentLocale = null then
		tmpX := self;
		if tmpX.myRoot = null then
			// can get here if running stuff from Painter
			tmpX.myRoot := CM_Root.firstInstance;
		endif;
		tmpX.myCurrentLocale := self.myRoot.getLocale(StandardTextLocaleStr, false);
	endif;
	
	// get error message defined for current locale
	if currentLocale &lt;&gt; null then
					
		// PAR #16399 - arm exception handler instead to handle deleted locale
		on Exception do self.handleDeletedObject(exception, currentLocale, invalidLocale);
		translation := currentLocale.getTranslatedText(category, translationId);
		
		// If the current locale has been deleted, then clear out the current reference
		// The next call to this method will set it up again
		if invalidLocale then
			tmpX := self;
			tmpX.myCurrentLocale := null;
		endif;
	endif;

	if translation = null then
		// Fall back to default (JMT Manf. Plant) locale
		translation := self.myRoot.getLocale(StandardTextLocaleStr, true).getTranslatedText(category, translationId);
	endif;
	/*
	if translation &lt;&gt; null then
		create cachedTranslation transient;
		cachedTranslation := translation.cloneSelf(true);
		cachedTranslation.setMyTranslatableText
	//	app.allXlatTranslationsByCatNumber.add(translation);
	endif;
	*/
	
	//11 Jan 2021	NDL	Unit Test tracking
	if self.myCurrentLocale = null then
		newValue := "null";
	else
		newValue := self.myCurrentLocale.localeDescription;
	endif;
	
	return translation;

epilog

	//11 Jan 2021	NDL	Unit Test tracking
	if app.myUtilityCA &lt;&gt; null and app.myTrxCA &lt;&gt; null then
		if oldValue &lt;&gt; newValue then
			changeString := "App.myCurrentLocale, was:'" &amp; oldValue &amp; "' now:'" &amp; newValue &amp; "' [" &amp; method.qualifiedName &amp; "]";
			app.createActivityHistory(	ActivityHistoryGeneralSys,	//_type : Integer;
										null,	//_terminal : CM_Terminal;
										null,	//_objectForExtraDetail : Object;
										changeString,	//_description : String;
										process.isInTransactionState,	//_insideTransaction : Boolean;
										false	//_temp: Boolean
										);
		endif;
	endif;
	
end;</source>
        <Parameter name="category" type="String"/>
        <Parameter name="translationId" type="Integer"/>
        <ReturnType type="XLAT_Translation"/>
    </JadeMethod>
    <JadeMethod name="zGetUntranslatedText" id="2ed4ce4b-46d3-4fcd-9cf6-a7af00aa600b">
        <source>zGetUntranslatedText(_category : String; 
					 _translationId : Integer) : XLAT_Translation;
/*

Purpose:			Return the translation for the passed in category and id from the standard locale

Parameters:			translation category and translation itentifier

Return Value:		Translation for the given identifier from the standard text locale

Date		Who		Reason
22 May 2014	cnwkpd1	PAR #34210 - CCMS SFW 1350 - Online Documentation

*/

vars
	
begin
	if self.myRoot = null then
		return null;
	endif;
	
	return self.myRoot.getLocale(StandardTextLocaleStr, true).getTranslatedText(_category, _translationId);
	
epilog

end;</source>
        <Parameter name="_category" type="String"/>
        <Parameter name="_translationId" type="Integer"/>
        <ReturnType type="XLAT_Translation"/>
    </JadeMethod>
</Class>
