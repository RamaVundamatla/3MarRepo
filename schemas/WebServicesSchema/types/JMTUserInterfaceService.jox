    <JadeWebServicesMethod name="getUnpackedCargo" id="4d1c4492-700b-43aa-8f62-6f1103021d79">
        <source>getUnpackedCargo(request: WS_UnpackedCargoRequest) : WS_UnpackedCargoResponse webService;
/*

Purpose:			
	to return the recently unpacked cargo from a container
Parameters:			
	WS_UnpackedCargoRequest
		- dateTime: the starting point to check the transactions
		- containerOid: the parent container's object id 
Return Value:		

Date		Who		Reason
12 December 2017	jlghl1	Initial creation
28 Aug 2020		NDL		TFS 49977 - removed the time date and added in location so that split cargo was more correctly accounted for.
20 Oct 2020		NDL		TFS 47356 - change from attempting to show unpacked quantity to showing totals in unpacked locations 
12 Apr 2021		navmd1	TFS 51050 - fix 1086 class invalid when converting OID to CM_TrackedItem (previously, CM_Container)

*/

vars
//	objectArray : ObjectArray;
	//parentContainer : CM_Container;
	parentContainer : CM_TrackedItem;		// TFS 51050 navmd1 12/04/21
//	fromTs, toTs : TimeStamp;
//	childTrans : Object;
	child : CM_TrackedItem;
	
	response : WS_UnpackedCargoResponse;
	completedOK : Boolean;
	proxyUnpackedCargo : WS_UnpackedCargo;
//	allPackedCargo : ObjectSet;
	
	allTrx : CM_TITransactionByTypeDateDict;
	childTrans : CM_TITransaction;

begin

	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	//parentContainer := app.myPassport.getObjectOfTypeFromOid(request.containerOid,CM_TrackedItem).CM_Container;
	parentContainer := app.myPassport.getObjectOfTypeFromOid(request.containerOid,CM_TrackedItem).CM_TrackedItem;		// TFS 51050 navmd1 12/04/21
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;
	
	create response transient;
	
//	fromTs.setDate(request.dateFrom.asDateFromWebInterface);
//	fromTs.setTime(request.timeFrom.asTimeFromWebInterface);
	
//	toTs := app.actualTimeServer();

	
//	create objectArray transient;
//	parentContainer.getTITxnsByTypeDate(TRANS_TYPE_UNPACK, fromTs, null, null, null, objectArray);
	create allTrx transient;	//27 Aug 2020	NDL	TFS 47356
	parentContainer.allTransactions.getAllTransactionsOfClass( CM_Unpack, allTrx, false );		//27 Aug 2020	NDL	TFS 47356

//	create allPackedCargo transient;
	
	//////////////////////////////////////////////////
	
	//20 Oct 2020	NDL	TFS 47356 - Change of plans we are just going to show what is actually in teh locations that we unpacked to.
	foreach childTrans in allTrx do
		child := childTrans.CM_Unpack.getOtherTrackedItem;
		if child = null then	//14 Sep 2020	NDL	TFS 48662
			continue;
		endif;
		child := child.getMergedIntoCargo; // this is the current ti at that location that this was merged into.
		if child = null then
			continue;
		endif;
			
		proxyUnpackedCargo := response.allUnpackedCargo.findUnpackedProxyIdTypeLoc( child.id, child.myCargoType, child.locationId );
		if proxyUnpackedCargo &lt;&gt; null then
			//we've already got one representing this guy
			continue;
		endif;
		
		//create the proxy unpacked object
		create proxyUnpackedCargo transient;
		proxyUnpackedCargo.setProxyFromObject(childTrans.CM_Unpack);
		proxyUnpackedCargo.setDetailsFromChild(child);
		
		//now set the old "unpacked" values to the totals of the current object at the location.
		proxyUnpackedCargo.totalAmount := child.totalQuantity;
		proxyUnpackedCargo.totalWeight := child.totalWeight;
		if child.getDensity &gt; 0 then
			proxyUnpackedCargo.totalVolume := proxyUnpackedCargo.totalWeight / child.getDensity;
		endif;
		if child.myCargoType.isBreakBulkMulti then
			proxyUnpackedCargo.amountString := proxyUnpackedCargo.totalAmount.asStringJMT;
		elseif child.myCargoType.isBulkMulti then
			proxyUnpackedCargo.amountString := child.myCargoType.getBulkTrackByDisplayForWeight( proxyUnpackedCargo.totalWeight,child.getDensity,true) ;	
		endif;
		
		response.allUnpackedCargo.add(proxyUnpackedCargo);
		
	endforeach;
	
	
	//////////////////////////////////////////////////	
	//Old code.
	
//	foreach childTrans in objectArray do
/*	foreach childTrans in allTrx do	//27 Aug 2020	NDL	TFS 47356
		child := childTrans.CM_Unpack.getOtherTrackedItem;
		if child = null then	//14 Sep 2020	NDL	TFS 48662
			continue;
		endif;
		child := child.getMergedIntoCargo;
		if child = null then
			continue;
		endif;
			
		//epr TFS 37510 14/3/18 
		
	//	proxyUnpackedCargo:=response.allUnpackedCargo.findUnpackedProxyWithId( child.id );
		proxyUnpackedCargo := response.allUnpackedCargo.findUnpackedProxyIdTypeLoc( child.id, child.myCargoType, child.locationId );	//27 Aug 2020	NDL	TFS 47356
	
		if proxyUnpackedCargo &lt;&gt; null then
			proxyUnpackedCargo.totalAmount := proxyUnpackedCargo.totalAmount + childTrans.CM_Unpack.totalQuantity;
			proxyUnpackedCargo.totalWeight := proxyUnpackedCargo.totalWeight + childTrans.CM_Unpack.totalWeight;
			if child.myCargoType.isBreakBulkMulti then
				proxyUnpackedCargo.amountString := proxyUnpackedCargo.totalAmount.asStringJMT;
			elseif child.myCargoType.isBulkMulti then
				proxyUnpackedCargo.amountString := child.myCargoType.getBulkTrackByDisplayForWeight( proxyUnpackedCargo.totalWeight,child.getDensity,true) ;	
			endif;
			continue;
		endif;
		
		create proxyUnpackedCargo transient;
		proxyUnpackedCargo.setProxyFromObject(childTrans.CM_Unpack);
		proxyUnpackedCargo.setDetailsFromChild(child);
		if child.getDensity &gt; 0 then
			proxyUnpackedCargo.totalVolume := proxyUnpackedCargo.totalWeight / child.getDensity;
		endif;
		
		response.allUnpackedCargo.add(proxyUnpackedCargo);
		allPackedCargo.add(child);
	endforeach;
	
	//epr TFS 37510 14/3/18 
	//check the repack
	//objectArray.clear;
	allTrx.clear();			//27 Aug 2020	NDL	TFS 47356

//	parentContainer.getTITxnsByTypeDate(TRANS_TYPE_PACK, fromTs, null, null, null, objectArray);
	parentContainer.allTransactions.getAllTransactionsOfClass( CM_Pack, allTrx, false );		//27 Aug 2020	NDL	TFS 47356
//	foreach childTrans in objectArray do
	foreach childTrans in allTrx do	//27 Aug 2020	NDL	TFS 47356
		child := childTrans.CM_Pack.getOtherTrackedItem;
		if child = null then
			continue;
		endif;
		
		if not child.myCargoType.allowDuplicates then
			continue;
		endif;
	
	//	proxyUnpackedCargo:=response.allUnpackedCargo.findUnpackedProxyWithId(child.id);
	//	proxyUnpackedCargo := response.allUnpackedCargo.findUnpackedProxyIdTypeLoc( child.id, child.myCargoType, child.locationId );	//27 Aug 2020	NDL	TFS 47356
		proxyUnpackedCargo := response.allUnpackedCargo.findUnpackedProxyIdTypeLoc( child.id, child.myCargoType, childTrans.CM_Pack.priorLocation );	//27 Aug 2020	NDL	TFS 47356
		if proxyUnpackedCargo &lt;&gt; null then
			proxyUnpackedCargo.totalAmount := proxyUnpackedCargo.totalAmount - childTrans.CM_Pack.totalQuantity;
			proxyUnpackedCargo.totalWeight := proxyUnpackedCargo.totalWeight - childTrans.CM_Pack.totalWeight;
			if child.myCargoType.isBreakBulkMulti then
				proxyUnpackedCargo.amountString := proxyUnpackedCargo.totalAmount.asStringJMT;
				//packed more than unpacked in session then don't return at all
				//epr TFS 37906 18/4/18
				if proxyUnpackedCargo.totalAmount &lt;= 0 then
					response.allUnpackedCargo.remove(proxyUnpackedCargo);
					delete proxyUnpackedCargo;
				endif;
			elseif child.myCargoType.isBulkMulti then
				//packed more than unpacked in session then don't return at all
				//epr TFS 37906 18/4/18
				if proxyUnpackedCargo.totalWeight &lt;= 0 then
					response.allUnpackedCargo.remove(proxyUnpackedCargo);
					delete proxyUnpackedCargo;
				else
					proxyUnpackedCargo.amountString := child.myCargoType.getBulkTrackByDisplayForWeight( proxyUnpackedCargo.totalWeight,child.getDensity,true) ;
				endif;			
			endif;
		endif;
	
	endforeach;  */
	
	completedOK := true;
	return response;

epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
		
//	delete objectArray;
	delete allTrx;			//27 Aug 2020	NDL	TFS 47356
//	delete allPackedCargo;
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="request" type="WS_UnpackedCargoRequest"/>
        <ReturnType type="WS_UnpackedCargoResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getUserDetails" id="f23ac0eb-498e-457e-8a6d-b5c994ad08cb">
        <source>getUserDetails() : WS_UsersResponse webService;
/*

Purpose:	Gets user name, email address of the current logged-in user		

Parameters:			None

Return Value:		ws_user

Date			Who		Reason
12 October 2017	jlgam15	Initial creation

*/

vars
	response 	: WS_UsersResponse;
	completedOK	: Boolean;
	proxyUser 	: WS_User;

begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	create proxyUser transient;
	proxyUser.setProxyFromObject(currentSession.myUser);
	
	response.allUsers.add(proxyUser);
	
	completedOK := true;
	return response;
		
epilog

	if not completedOK then
		cnSetTransactionError(true);
		delete response;	// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

end;</source>
        <ReturnType type="WS_UsersResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getUserLocale" id="a77d3cc9-a382-4c84-ad09-405769bad80f">
        <source>getUserLocale() : WS_UserLocaleResponse webService;
/*

Purpose: Gets the last set user's locale

Parameters:		None	

Return Value:		locale

Date			Who		Reason
28 June 2017	cnwam15	Initial creation TFS#5193 Get user's last set locale

*/

vars
	response 	: WS_UserLocaleResponse;
	completedOK	: Boolean;
	userLocale	: WS_Locale;
	sysLocale, defaultLocale 	: CM_Locale;
	
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	create userLocale transient;
	
	sysLocale := currentSession.myUser.myLocale;	
	if sysLocale &lt;&gt; null then		
		userLocale.setProxyFromObject(sysLocale);
		response.userLocale := userLocale;
	else
		defaultLocale := app.myRoot.myDefaultLocale;
		if defaultLocale = null then
			defaultLocale := app.myRoot.getDefaultLocale(false);
		endif;
		userLocale.setProxyFromObject(defaultLocale);
		response.userLocale := userLocale;
	endif;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog

	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

end;</source>
        <ReturnType type="WS_UserLocaleResponse"/>
    </JadeWebServicesMethod>
