    <JadeMethod name="getFirstWithNumber" id="2447f9b6-5220-42b4-9975-1e267f2ec874">
        <source>getFirstWithNumber( _number : String ):CM_BOL;
/*

Purpose:			Only for here for unit tests

Parameters:			

Return Value:		

Date		Who		Reason
09 January 2018	jlgndl1	Initial creation	TFS 8165

*/

vars

	iter : Iterator;
	bol : CM_BOL;

begin

	iter := self.createIterator;
	while iter.next( bol ) do
		if bol.number = _number then
			return bol;
		endif;
	endwhile;
	
	return null;

epilog

	delete iter;

end;</source>
        <Parameter name="_number" type="String"/>
        <ReturnType type="CM_BOL"/>
    </JadeMethod>
