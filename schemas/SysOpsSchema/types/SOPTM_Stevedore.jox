    <JadeMethod name="doDelete" id="fc229429-ee64-4c95-9e89-4bf705de1aa8">
        <updating/>
        <source>doDelete(pObj: CM_Object io) updating;
// ---------------------------------------------------------------------------
// Created:     03 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
