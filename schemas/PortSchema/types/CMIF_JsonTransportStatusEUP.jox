<Class name="CMIF_JsonTransportStatusEUP" id="91c8a44c-b657-4cdb-bf4e-5c511effc3ca">
    <superclass name="CMIF_JsonTransform"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cams"/>
    <ImplicitInverseRef name="carrierParty" id="6aedab0a-01ae-4e8f-9ec7-ad2da0bc84c0">
        <embedded/>
        <type name="CMIF_JsonCarrierPartyEUP"/>
    </ImplicitInverseRef>
    <PrimAttribute name="dateTimeOfArrival" id="054c1cea-b375-43ea-92c5-0b068bd6fc44">
        <embedded/>
        <type name="TimeStamp"/>
        <text>Truck Arrived Time</text>
    </PrimAttribute>
    <PrimAttribute name="dateTimeOfDeparture" id="15538a6a-ea20-4c50-af90-73147393b95c">
        <embedded/>
        <type name="TimeStamp"/>
        <text>Truck Departed Time. Only valid for Truck Departure events.</text>
    </PrimAttribute>
    <PrimAttribute name="endDateTime" id="5fbee2d6-fa3c-4347-b697-978a248dfdbe">
        <embedded/>
        <type name="TimeStamp"/>
        <text>Truck Job End Time. Only Valid for Departure Events.</text>
    </PrimAttribute>
    <PrimAttribute name="startDateTime" id="5efca8a9-ca8d-4500-b9c2-5bfd335dee8d">
        <embedded/>
        <type name="TimeStamp"/>
        <text>Truck Job Start Time. Only valid for Departure Events.</text>
    </PrimAttribute>
    <PrimAttribute name="status" id="a1e1e473-bb27-4183-982d-c0f446c130b0">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <text>Status of the Transport - either arrived or departed.</text>
    </PrimAttribute>
    <PrimAttribute name="transportType" id="51f8b608-4bbd-4ae1-8799-13d84fb8af7a">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <text>Transport type (E.g. Truck or Train). Only Truck is supported.</text>
    </PrimAttribute>
    <PrimAttribute name="transportationMode" id="eb35ca0d-bcfb-4d0c-8c2e-2d0342e7b805">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <text>Transport mode (e.g. Road or Rail). Only Road is supported.</text>
    </PrimAttribute>
    <ImplicitInverseRef name="truckInfo" id="eb7cd2f1-bbb1-480d-b4fe-66d56d24cb17">
        <embedded/>
        <type name="CMIF_JsonTruckInfoEUP"/>
    </ImplicitInverseRef>
</Class>
