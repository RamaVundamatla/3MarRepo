    <JadeMethod name="pxyCreateUpdateProxy" id="46d67f30-e14c-499e-b899-6d8c2fbc063f">
        <source>pxyCreateUpdateProxy(): SelfType;
// -------------------------------------------
// Created 18 September 2003 by cnwdvb1
// -------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars

	proxyEmailGroup : CM_EmailGroup;
	completedOK		: Boolean;
	
begin
	
	proxyEmailGroup := inheritMethod();
	
	self.allEmailAddresses.copy(proxyEmailGroup.allEmailAddresses);
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyEmailGroup;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyEmailGroup;
	endif;	

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="05040c22-f8d1-4140-9b52-891e7437eba1">
        <updating/>
        <source>setForUpdate(_proxyEmailGroup : CM_EmailGroup) updating;
// -------------------------------------------
// Created 17 September 2003 by cnwdvb1
// -------------------------------------------
vars

	user : CM_User;

begin

	if not self.isTransient then	//20 Jan 2014	NDL	Par 33264
		//15 Jan 2014	NDL	Par 33264
		foreach user in self.allUsers do
			self.updateObjectEdition(user);
		endforeach;
	endif;

	self.allEmailAddresses.clear();
	_proxyEmailGroup.allEmailAddresses.copy(self.allEmailAddresses);
	inheritMethod(_proxyEmailGroup);

end;</source>
        <Parameter name="_proxyEmailGroup" type="CM_EmailGroup"/>
    </JadeMethod>
    <JadeMethod name="setProxyForEmailGroup" id="8f8129ca-2c82-4730-85d9-06a935c8f8f0">
        <updating/>
        <source>setProxyForEmailGroup(_name : String; _allEmailAddresses : CM_EmailAddress2ByNameDict) updating;
// -------------------------------------------
// Created 17 September 2003 by cnwdvb1
// -------------------------------------------
vars

begin

	self.raiseExceptionIfNotTransient(method);
	self.allEmailAddresses.clear();
	_allEmailAddresses.copy(self.allEmailAddresses);
	self.setForProxy(_name, Email_Group);
	
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_allEmailAddresses" type="CM_EmailAddress2ByNameDict"/>
    </JadeMethod>
    <JadeMethod name="validate" id="195707ab-17ff-4706-a537-7bd3ee5a8500">
        <source>validate();
// ---------------------------------------------------------------------------
// Created:     30 March 2007 by cnwaer1
//
// Purpose:     

// 08/12/2014 cnwdb2	PAR 35364 
// ---------------------------------------------------------------------------
vars

	entity	: CM_EmailEntity;
	iter	: Iterator;
	theType	: Integer;
	theName	: String;
	realObj	: SelfType;

begin

	if self.name = null then
//	 	app.raiseCMException1(REQUIRED_FIELD, 'Email Title', null, null);
		app.raiseCMException(Input_required_field_emailType, null, null); // cnwdb2	PAR 35364
	endif;
	
	realObj := self.pxyGetRealObject();
	iter := app.myRoot.allEmailEntities.createIterator();
	app.myRoot.allEmailEntities.startKeyGeq(Email_Group, self.name, iter);
	while iter.next(entity) do
		app.myRoot.allEmailEntities.getIteratorKeys(theType, theName, iter);
		if theName = self.name then
			if realObj = null or entity &lt;&gt; realObj then
			//	app.raiseCMException3(ERR_DUPLICATE_KEY, "Email Group " , self.name, null, null, null);
				app.raiseCMException1(Already_exists_email_group, self.name, null, null); //cnwdb2 08/12/2014
				break;
			endif;
		endif;
	endwhile;
	
	if self.type &lt;&gt; Email_Address and self.type &lt;&gt; Email_Group then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Type', null, null);
		app.raiseCMException(Input_required_field_type, null, null); // cnwdb2	PAR 35364
	endif;

epilog
	delete iter;
end;</source>
    </JadeMethod>
</Class>
