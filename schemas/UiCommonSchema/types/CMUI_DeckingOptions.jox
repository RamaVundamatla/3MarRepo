    <JadeMethod name="clearTable" id="7eb2d267-b36e-4b2f-99b3-41f3c49df010">
        <updating/>
        <source>clearTable(_tbl: CM_Table input) updating;
//----------------------------------------------------------------
//	Created:	27 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	pxy	: Object;
begin
	while _tbl.rows &gt; _tbl.fixedRows do
		pxy	:= _tbl.accessRow(2).itemObject;
		delete pxy;
		_tbl.removeItem(2);
	endwhile;

end;</source>
        <Parameter name="_tbl" type="CM_Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="copyCellsToLocationList" id="c028acc9-221b-4782-808a-732813baf890">
        <source>copyCellsToLocationList(_fromCollection: CM_YALocationCellArray; _showHeights: Boolean);
//----------------------------------------------------------------
//	Created:	22 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	yaLocnCell		: CM_YALocationCell;
	yaLocnCellList	: CMUI_ListBox;
	idx				: Integer;
	showHeight		: Boolean;
begin
	
	showHeight := _showHeights;
	yaLocnCellList := self.lstDeckingLocns;
	
	yaLocnCellList.clear;

	if showHeight then
		foreach yaLocnCell in _fromCollection do
			idx := yaLocnCellList.addItem(yaLocnCell.getListDisplayWithHeight());
			yaLocnCellList.itemObject[idx] := yaLocnCell;
		endforeach;
	else
		foreach yaLocnCell in _fromCollection do
			if yaLocnCell.height = 1 then
				idx := yaLocnCellList.addItem(yaLocnCell.getListDisplay());
				yaLocnCellList.itemObject[idx] := yaLocnCell;
			endif;
		endforeach;
	endif;
	

end;</source>
        <Parameter name="_fromCollection" type="CM_YALocationCellArray"/>
        <Parameter name="_showHeights" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="create" id="0cf170cb-de4a-45c4-af9d-b47f51d929a7">
