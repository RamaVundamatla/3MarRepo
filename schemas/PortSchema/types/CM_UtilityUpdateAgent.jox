        <source>utlUpdateShiftRemarks( _shift : CM_Shift input; _remarks : String; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 July 2017	cnwndl1	Initial creation	TFS 5222

*/

vars

begin

	self.initialiseActivity();
	
	if _shift = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, "Shift", null, null);
		return;
	endif;

	exclusiveLock(_shift);

	if (not _passport.noErrors) then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Voyage Job', null, null);
		return;
	endif;
	
	_shift.setRemarks(_remarks);
	
	_shift.causeEvent(_shift.myTerminal.getTerminalEvent(Event_Shift_Update), false, null);	

	
epilog

end;</source>
