    <JadeMethod name="getDataTypeFromDefName" id="d26bac90-4b93-40a2-8307-02a79b167217">
        <source>getDataTypeFromDefName(_name: String): Integer;
// ---------------------------------------------------------------------------
// Created:     24 September 2009 by cnwcs5:1
// Purpose:     Par 20320 - multiple user record types  
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 15 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
// ---------------------------------------------------------------------------
begin
	if _name = ETDef_EDITITrain then
		return EDIDataType_Train;
	elseif _name = ETDef_EDITIWagonTC then
		return EDIDataType_Wagon;
	elseif _name = ETDef_EDITIPrenote then
		return EDIDataType_Prenote;
	elseif _name = ETDef_EDITISeal then
		return EDIDataType_TISeal;
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStrForDefName" id="eaaf26e7-449a-4452-a592-e2c08eedd7fb">
        <source>getDisplayStrForDefName(_name: String): String;
//
// 15 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
//
begin
	if _name = ETDef_EDITITrain then
		return app.getErrorString(Train);
	elseif _name = ETDef_EDITIWagonTC then
		return app.getErrorString(Wagon);
	elseif _name = ETDef_EDITIPrenote then
		return app.getErrorString(Prenote);
	elseif _name = ETDef_EDITISeal then
		return "Seals";
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEDIChildDataTypes" id="5fb7cdfd-2499-45cd-b638-b8b847b36bdc">
        <source>getEDIChildDataTypes(_types: IntegerArray input);
// ---------------------------------------------------------------------------
// Created:	25 September 2009 By Graeme Black cnwgb1
// Status: 	
// Purpose:	Returns a list of Data Types that make up this data type.
//			It will return the code for itself if not structured
// ---------------------------------------------------------------------------
// 15 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
vars
begin
	_types.add(EDIDataType_Train);
	_types.add(EDIDataType_Wagon);
	_types.add(EDIDataType_Prenote);
	_types.add(EDIDataType_TISeal);
epilog
end;</source>
        <Parameter name="_types" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getEDIDataType" id="f212f729-bfd6-40f5-8b70-753f689197f8">
        <source>getEDIDataType(): Integer;
// ---------------------------------------------------------------------------
// Created:	12 October 2009 By Graeme Black cnwgb1 PAR 20920 
// Purpose:	Override - the Integer code associated with a data type
