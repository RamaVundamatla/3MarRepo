    <JadeMethod name="showRecipientSelector" id="b2e5a21b-566a-44c8-b19e-a80e59c7cc6a">
        <source>showRecipientSelector(_emailController : CMIF_EmailTemplateController; _mode : Integer; _canOnlyAccessMode : Boolean ) : Integer;
/*

Purpose:			mode should be  either 	
					CMUI_RecipientSelector.Mode_BCC
					CMUI_RecipientSelector.Mode_CC
					CMUI_RecipientSelector.Mode_To
Return Value:		


Date		Who		Reason
12 October 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	form : CMUI_RecipientSelector;
	user : CM_User;	//18 Sep 2017	NDL	TFS 6984
	tmpTerm : CM_Terminal;//18 Sep 2017	NDL	TFS 6984
begin

	if _emailController = null then
		return IDCANCEL;
	endif;
	
	//18 Sep 2017	NDL	TFS 6984
	user := app.myPassport.myUser;
	if user &lt;&gt; null and not user.allUserTerminals.isEmpty then
		tmpTerm := user.allUserTerminals.first.myTerminal;
	endif;

	create form;
	form.setMyTerminal( tmpTerm );	//18 Sep 2017	NDL	TFS 6984
	form.myEmailController:=_emailController;
	form.mode:=_mode;
	form.canOnlyAccessMode:=_canOnlyAccessMode;
	form.centreWindow;
	form.showModal;
	
	return form.modalResult; 

epilog

end;</source>
        <Parameter name="_emailController" type="CMIF_EmailTemplateController"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_canOnlyAccessMode" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showReeferConnectAttachForm" id="d3987445-c106-4fd7-95fc-1a4dcb3a1705">
        <source>showReeferConnectAttachForm(_ti : CM_Container input;
							_parentForm : CM_BaseForm);
/*

Date		Who		Reason
22 April 2015	cnwer1	Initial creation PAR

*/

vars
	
	lConnectAttach	: CMUI_ConnectAttach;
begin

	if _ti = null then
		return;
	endif;
	
	create lConnectAttach;
	lConnectAttach.centreWindow;
	lConnectAttach.allTrackedItems.add(_ti);
	if _ti.isConnected then
		lConnectAttach.action := ACTION_DISCONNECT;
	else
		lConnectAttach.action := ACTION_CONNECT;
	endif;

	if _ti.requiresPower then
		lConnectAttach.startupMode :=CMUI_ConnectAttach.StarupMode_TowerPower;
	elseif _ti.hasCOU or _ti.isPortHole then
		lConnectAttach.startupMode := CMUI_ConnectAttach.StarupMode_COU;
	endif;
		
	
	lConnectAttach.setMyTerminal(_ti.myTerminal);
	lConnectAttach.myParent := _parentForm;
	lConnectAttach.showModal;
epilog

end;</source>
        <Parameter name="_ti" type="CM_Container" usage="input"/>
        <Parameter name="_parentForm" type="CM_BaseForm"/>
    </JadeMethod>
