    <JadeMethod name="cnEcAppendErrorMsg" id="99152fa7-08e9-4fe3-9029-c52242ffc165">
        <source>cnEcAppendErrorMsg(pErrorMsg:String):String;
// --------------------------------------------------------------------------------
// Created:		07 June 2008 by cnwdad1
//
// Purpose:		Appends the specified error message to the receiver, with two CrLf
//				characters.
//
// Parameters:	pErrorMsg - The error message to append.
//
// Returns:		The total appended string.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.trimBlanks() = null then
		return pErrorMsg;
	else
		return self &amp; CrLf &amp; CrLf &amp; pErrorMsg;
	endif;
end;</source>
        <Parameter name="pErrorMsg" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcAsHtml" id="ddee86b8-fe87-47e6-adfa-0e043a72deff">
        <source>cnEcAsHtml():String;
// --------------------------------------------------------------------------------
// Created:		12 October 2000 by cnwdad1
//
// Purpose:		Converts the value of the receiver's "text" into an HTML format by
//				converting certain "non-printable" characters into the equivalent
//				HTML value(s).
//
// Parameters:	None.
//
// Returns:		The HTML-compatible value of the "text" property.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tempString		: String;
	htmlText		: String;
	charPos			: Integer;

begin
	tempString	:=	self;
	htmlText	:=	"";

	foreach charPos in 1 to tempString.length - 1 do
		if tempString[charPos:2] = CrLf then					// check for CrLf combination
			htmlText	:=	htmlText &amp; "&lt;BR&gt;";
			charPos		:=	charPos + 1;
		elseif tempString[charPos:1] = Tab then					// check for Tab combination
			htmlText	:=	htmlText &amp; "&amp;nbsp;&amp;nbsp;&amp;nbsp;";
		elseif tempString[charPos:1] = "&gt;" then					// check for '&gt;' character
			htmlText	:=	htmlText &amp; "&amp;gt;";
		elseif tempString[charPos:1] = "&lt;" then					// check for '&lt;' character
			htmlText	:=	htmlText &amp; "&amp;lt;";
		elseif tempString[charPos:1] = 34.Character.String then	// check for '"' character
			htmlText	:=	htmlText &amp; "&amp;quot;";
		else
			htmlText	:=	htmlText &amp; tempString[charPos];
		endif;
	endforeach;
epilog
	return htmlText;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcAsNumeric" id="6fd8d043-b39e-4bed-89a6-dc756bd6c16c">
        <source>cnEcAsNumeric(pNumberFormatObj:NumberFormat):String;
// --------------------------------------------------------------------------------
// Created:		09 October 2001 by cnwdad1
//
// Purpose:		Using the current Locale's numeric information, strips all non-
//				numeric characters and returns the result.
//
// Parameters:	pNumberFormatObj - A reference to the current process's Number Format
//					object.
//
// Returns:		The stripped receiver.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	returnValue	: String;
	
begin
	if pNumberFormatObj = null then
		returnValue	:=	app.currentLocaleInfo.numericInfo.cnEcStripNonNumeric(self);
	else
		returnValue	:=	pNumberFormatObj.cnEcStripNonNumeric(self);
	endif;
epilog
	return returnValue;
end;</source>
        <Parameter name="pNumberFormatObj" type="NumberFormat"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcAsXml" id="6ea0157e-ab28-4aee-9746-acec26452d76">
        <source>cnEcAsXml():String;
// Returns the receiver as an XML string.
vars
	xmlString	: String;
	
begin
	xmlString	:=	self;
	xmlString	:=	xmlString.cnEcXmlUseCDATA();
epilog
	return xmlString;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcCompareToMask" id="18e20fee-05cc-4228-8a76-5b7c90d90fe2">
        <source>cnEcCompareToMask(pMask:String;
				pIgnoreCase:Boolean;
				pMatchLength:Boolean):Integer;
// --------------------------------------------------------------------------------
// Created:		13 June 1999 by cnwdad1
//
// Purpose:		Validate a string value against a string format mask.
//
// Parameters:	pMask (String) - The mask to match against the string in question.
//				pIgnoreCase (Boolean) - Indicates whether upper and lower case is significant.
//				pMatchLength (Boolean) - Indicates whether the string being compared can be
//					longer than the length of the mask string.
//
// Returns:		The position of an invalid character (zero if the string successfully
//				matches the mask).
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	mask		: String;
	value		: String;
	pos			: Integer;
	maskLen		: Integer;
	valLen		: Integer;
	maskAscii	: Integer;
	valAscii	: Integer;

begin
	mask	:=	pMask.trimBlanks;
	value	:=	self.trimBlanks;
	maskLen	:=	mask.length;
	valLen	:=	value.length;

	if (valLen = 0) and (maskLen = 0) then
		return 0;
	endif;

	if (valLen &gt; maskLen) then
		return maskLen + 1;
	endif;

	if (pMatchLength) and (valLen &lt; maskLen) then
		return valLen + 1;
	endif;

	if (pIgnoreCase) then
		mask	:=	mask.toUpper;
		value	:=	value.toUpper;
	endif;

	pos	:=	1;

	while (pos &lt;= valLen) do
		maskAscii	:=	mask[pos:1].Character.cnEcGetMaskType();
		valAscii	:=	value[pos:1].Character.cnEcGetMaskedCharacterType();

		if (maskAscii = CHAR_ALPHA_LOWER) then
			if (not valAscii = CHAR_ALPHA_LOWER) then
				return pos;
			endif;

		elseif (maskAscii = CHAR_ALPHA_UPPER) then
			if (not valAscii = CHAR_ALPHA_UPPER) then
				return pos;
			endif;

		elseif (maskAscii = CHAR_ALPHANUM_LOWER) then
			if	(not valAscii = CHAR_ALPHANUM_LOWER)	and
				(not valAscii = CHAR_ALPHA_LOWER)		and
				(not valAscii = CHAR_NUMERIC)			then
				return pos;
			endif;

		elseif (maskAscii = CHAR_ALPHANUM_UPPER) then
			if	(not valAscii = CHAR_ALPHANUM_UPPER)	and
				(not valAscii = CHAR_ALPHA_UPPER)		and
				(not valAscii = CHAR_NUMERIC)			then
				return pos;
			endif;

		elseif (maskAscii = CHAR_NUMERIC) then
			if (not valAscii = CHAR_NUMERIC) then
				return pos;
			endif;

		elseif (maskAscii = CHAR_SPECIAL) then
			if	(not value[pos:1] = mask[pos:1]) then
				return pos;
			endif;
		endif;

		pos	:=	pos + 1;
	endwhile;

	return 0;
end;</source>
        <Parameter name="pMask" type="String"/>
        <Parameter name="pIgnoreCase" type="Boolean"/>
        <Parameter name="pMatchLength" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcConcat" id="09264293-014e-43cd-8504-f459dd54a7fd">
        <updating/>
        <source>cnEcConcat(pValue:String):String updating;
// --------------------------------------------------------------------------------
// Purpose:		Appends the specified value to the receiver.
//
// Parameters:	pValue - The string to append.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self = null then
		self	:=	pValue;
	else
		self	:=	self &amp; pValue;
	endif;

	return self;
end;</source>
        <Parameter name="pValue" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcCopyFromClipboard" id="9692be47-2cc0-43af-8102-c001dbfc1e3a">
        <updating/>
        <source>cnEcCopyFromClipboard() updating;
