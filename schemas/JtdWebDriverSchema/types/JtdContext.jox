    <JadeMethod name="jtdSetTrxSelectionState" id="a371afc4-0591-47ff-a50b-257ce993b8d5">
        <updating/>
        <source>jtdSetTrxSelectionState(state : Integer) : Integer updating;

vars
	previousState : Integer;
	
begin
	previousState := self.jtdTrxSelectionState;

	if state = self.JtdSelectFromProlog or
	   state = self.JtdSelectFromMain or
	   state = self.JtdSelectFromEpilog
	then
		self.jtdTrxSelectionState := state;
	else
		// invalid new state: just re-enter the current state
	endif;
			
	self.jtdLastSelectedTrxIndex := 0;
	self.jtdLastSelectedTrxCallCount := 0;
	self.jtdMyLastSelectedTrxMthProfile := null;
	
	return previousState;
end;</source>
        <Parameter name="state" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jtdStartAllClocks" id="7e110b44-7f78-4b00-b602-a6484d9c7f60">
        <updating/>
        <source>jtdStartAllClocks() : Integer updating;

vars
	n : Integer;
	
begin
	self.jtdClearAllClocks;
	
	n := app.clock;
	
	self.jtdGenStartClock := n;
	self.jtdTrxStartClock := n;
	
	return n;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
