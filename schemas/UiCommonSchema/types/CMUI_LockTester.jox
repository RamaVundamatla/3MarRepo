    </JadeMethod>
    <JadeMethod name="setupForm" id="5d675052-0ecb-408c-954f-75871b1c9908">
        <updating/>
        <source>setupForm() updating;

vars

begin
	inheritMethod();
	
	self.handleMenusForModalDisplay();
	
	self.cmbInstance01.addItem(InstanceFirst);
	self.cmbInstance01.addItem(InstanceLast);
	self.cmbInstance01.text := InstanceFirst;

	self.cmbInstance02.addItem(InstanceFirst);
	self.cmbInstance02.addItem(InstanceLast);
	self.cmbInstance02.text := InstanceFirst;
	
	self.optExclusive01.value := true;
	self.optExclusive02.value := true;

	btnLock01.enabled := true;
	btnUnlock01.enabled := false;

	btnLock02.enabled := true;
	btnUnlock02.enabled := false;

end;</source>
    </JadeMethod>
    <JadeMethod name="showError" id="04773531-d47f-4d81-b0f8-6fd95407d4a1">
        <source>showError(_msg : String);

vars

begin

	app.msgBox(_msg, 'Error', MsgBox_OK_Only);

end;</source>
        <Parameter name="_msg" type="String"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="6d0b274e-ff6d-439d-a40f-b05009d95b82">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0007785, locale);
	btnInspect01.translateCaption(Xlat_0000519, locale);
	btnInspect02.translateCaption(Xlat_0000520, locale);
	btnLock01.translateCaption(Xlat_0000521, locale);
	btnLock02.translateCaption(Xlat_0000522, locale);
	btnUnlock01.translateCaption(Xlat_0000523, locale);
	btnUnlock02.translateCaption(Xlat_0000524, locale);
	grpObject01.translateCaption(Xlat_0000525, locale);
	grpObject02.translateCaption(Xlat_0000526, locale);
	lblClass01.translateCaption(Xlat_0000527, locale);
	lblClass02.translateCaption(Xlat_0000528, locale);
	lblInstance01.translateCaption(Xlat_0000529, locale);
	lblInstance02.translateCaption(Xlat_0000530, locale);
	lblOid01.translateCaption(Xlat_0000531, locale);
	lblOid02.translateCaption(Xlat_0000532, locale);
	optExclusive01.translateCaption(Xlat_0000534, locale);
	optExclusive02.translateCaption(Xlat_0000533, locale);
	optShare01.translateCaption(Xlat_0000535, locale);
	optShare02.translateCaption(Xlat_0000536, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="txtOid01_firstChange" id="65b778ae-4c7f-4f3e-9da5-7d523f0bc59d">
