    <JadeMethod name="addKey" id="6b349c0b-c3af-41d1-bbaf-6e0c25506d18">
        <source>addKey(pValue:Any);
// --------------------------------------------------------------------------------
// Created:		08 February 2001 by cnwdad1
//
// Purpose:		Add a sort key to the receiver's collection.
//
// Parameters:	pValue - The key value.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	sortKeyObj	: CnEcSortKey;
	
begin
	create sortKeyObj transient;
	sortKeyObj.setKey(pValue, self.typeOfSort);
	self.allKeys.add(sortKeyObj);
end;</source>
        <Parameter name="pValue" type="Any"/>
    </JadeMethod>
    <JadeMethod name="addKeyWithObject" id="e1943431-a959-443c-9c99-e90f66217fbf">
        <updating/>
        <source>addKeyWithObject(pValue:Any; pObject:Object) updating;
// --------------------------------------------------------------------------------
// Created:		26 October 2005 by cnwdad1
//
// Purpose:		Add a sort key to the receiver's collection.
//
// Parameters:	pValue - The key value.
//				pObject - A reference to an object that is associated with the key.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	sortKeyObj	: CnEcSortKey;
	
begin
	self.isWithObject	:=	true;
	create sortKeyObj transient;
	sortKeyObj.setKeyWithObject(pValue, pObject, self.typeOfSort);
	self.allKeys.add(sortKeyObj);
end;</source>
        <Parameter name="pValue" type="Any"/>
        <Parameter name="pObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="create" id="73c0652b-93be-43ab-9b64-40de3e33bfae">
        <updating/>
        <source>create() updating;
// --------------------------------------------------------------------------------
// Created:		08 February 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	create self.allKeys transient;
	self.allKeys.setMembership(CnEcSortKey);
end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="1ac44d7d-7630-43c7-9808-353758256fd4">
        <updating/>
        <source>delete() updating;
// --------------------------------------------------------------------------------
// Created:		08 February 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.allKeys.purge();
	delete self.allKeys;
end;</source>
    </JadeMethod>
    <JadeMethod name="setSortType" id="c7e1b815-9b51-41e0-9427-037d03189d7e">
        <updating/>
        <source>setSortType(pSortType:String; pIsDescending:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		08 February 2001 by cnwdad1
//
// Purpose:		Set the (primitive) type of sort that is required.
//
// Parameters:	pSortType - The type of sort.  Refer to the class constants for
//					a list of valid sort types.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.typeOfSort	:=	pSortType;
	
	if pSortType = self.AS_BOOLEAN then
		self.allKeys.addMemberKey(CnEcSortKey::booleanValue.name, pIsDescending, false);
		
	elseif pSortType = self.AS_CHARACTER then
		self.allKeys.addMemberKey(CnEcSortKey::charValue.name, pIsDescending, false);
		
	elseif pSortType = self.AS_DATE then
		self.allKeys.addMemberKey(CnEcSortKey::dateValue.name, pIsDescending, false);
		
	elseif pSortType = self.AS_DECIMAL then
		self.allKeys.addMemberKey(CnEcSortKey::decimalValue.name, pIsDescending, false);
		
	elseif pSortType = self.AS_INTEGER then
		self.allKeys.addMemberKey(CnEcSortKey::integerValue.name, pIsDescending, false);
		
	elseif pSortType = self.AS_REAL then
		self.allKeys.addMemberKey(CnEcSortKey::realValue.name, pIsDescending, false);
		
	elseif pSortType = self.AS_STRING then
		self.allKeys.addMemberKey(CnEcSortKey::stringValue.name, pIsDescending, false);
		
	elseif pSortType = self.AS_TIME then
		self.allKeys.addMemberKey(CnEcSortKey::timeValue.name, pIsDescending, false);
		
	elseif pSortType = self.AS_TIMESTAMP then
		self.allKeys.addMemberKey(CnEcSortKey::timestampValue.name, pIsDescending, false);
		
	else
		CnEcBaseSchemaException.raise_(CNEC_X_20000, "Invalid primitive sort type.");
		return;
		
	endif;
	
	self.allKeys.endKeys(true);
end;</source>
        <Parameter name="pSortType" type="String"/>
        <Parameter name="pIsDescending" type="Boolean"/>
    </JadeMethod>
</Class>
