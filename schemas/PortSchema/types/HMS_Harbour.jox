    <JadeMethod name="getCheckPtsUnassignedToRegion" id="d8b86da5-2880-45ec-81fb-d1a26c9af11d">
        <source>getCheckPtsUnassignedToRegion(_checkPoints : ObjectSet input);
//--------------------------------------------------------------
//Created: 10 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	checkPt	: HMS_CheckPoint;
begin
	if _checkPoints = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null _checkPoints passed to method');
