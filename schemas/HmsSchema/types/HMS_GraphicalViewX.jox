    <JadeMethod name="doCentreAtTime" id="6c5dd4e9-76ce-4bb5-9088-3c7c97190a24">
        <updating/>
        <source>doCentreAtTime(ts : TimeStamp) updating;
//-----------------------------------------------------------------------
//	Created:	22 November 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars
	newStartDT, 
	newEndDT		: TimeStamp;
begin

	// assume a week so time should add/subtract 3.5 days i.e. 84 hours
	newStartDT := ts;
	newStartDT := newStartDT.cnEcAddHours(-82);
	newStartDT.setDate(newStartDT.Date );
	newStartDT.setTime(newStartDT.Time);
	
	newEndDT := ts;
	newEndDT := newEndDT.cnEcAddHours(82);
	newEndDT.setDate(newEndDT.Date );
	newEndDT.setTime(newEndDT.Time);

	self.myViewController.viewStartDT := newStartDT;
	self.myViewController.viewFinishDT :=newEndDT;
	self.myViewController.setSelectedTerminals(self.lstTerminal.allSelectedObjects);
	
epilog

end;

</source>
        <Parameter name="ts" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="doMnuSnapBerthClick" id="195cfd70-4508-4128-a4ee-3fd86442c870">
        <updating/>
        <source>doMnuSnapBerthClick(menuItem : MenuItem input) updating, protected;
//--------------------------------------------------
// Created:	03 September 2004 By: cnwgd1
//--------------------------------------------------
vars
	tmpBerth : HMS_Berth;
begin

	if menuItem = self.mnuSnapBerthSub then
		return;
	endif;
	
	tmpBerth := menuItem.userObject.HMS_Berth;
	
