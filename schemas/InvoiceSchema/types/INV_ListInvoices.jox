    <JadeMethod name="btnIncludeArchive_click" id="c0974900-365e-4593-bbb3-2500efee86c1">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnIncludeArchive_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Sep 2023 navhl20 ChangeRequest 59376: CPL - Invoice Generation Clocking (avg 25 secs)

*/

vars
	allOtherCombo : ObjectArray;
	
begin
	
	//17/04/2024	navkc1 Bug 63717
	create allOtherCombo transient;
	allOtherCombo.add(self.cmbCargoVoyage_);

	if self.btnIncludeArchive.value then
		self.btnIncludeArchive.myToolbarButton.drawButtonDown();
	else
		self.btnIncludeArchive.myToolbarButton.clearGraphics();
	endif;
	
	self.doCmbVoyageBuild(self.cmbVoyage, self.btnIncludeArchive.value, allOtherCombo); //17/04/2024	navkc1 Bug 63717
	
	/* //17/04/2024	navkc1 Bug 63717
	if not self.btnIncludeArchive.value then
		if self.cmbVoyage.listObject &lt;&gt; null and
			self.cmbVoyage.listObject.CM_Voyage.archived then
				self.cmbVoyage.listIndex := -1;
		endif;
		if self.cmbCargoVoyage_.listObject &lt;&gt; null and
			self.cmbCargoVoyage_.listObject.CM_Voyage.archived then
				self.cmbCargoVoyage_.listIndex := -1;
		endif;
	endif;
	*/
epilog
	delete allOtherCombo;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
