	write ETDef_GeneralCargoReefer;
	write ETRow_PackDate;
	write ETRow_PackTime;
	write ETDef_CreateNewCargo;
	write ETDef_ContainerData;
	write ETGrp_GateReceivals;
	write ETDef_PreNoteDataTbl;
	
	write Transit_DT_Must_After_Pack_DT;
	write Trans_Power_Date_Time_Required;
	write Trans_Power_Date_Time_Blank;
	write Trans_Power_Date_Time_In_Past;
	write Packed_Date_Time_In_Past;

epilog
	delete etAgent;
	delete array;
	delete transAgent;
	delete tmpArray;
end;</source>
