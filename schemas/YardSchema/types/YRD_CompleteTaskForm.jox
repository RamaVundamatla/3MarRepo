    </JadeMethod>
    <JadeMethod name="optPickupTask_click" id="6927b3f5-e5d2-417f-9db0-2601f2b34c58">
        <controlMethod name="OptionButton::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>optPickupTask_click(optionbutton: OptionButton input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 March 2011	cnwer1	Initial creation

*/

vars

begin
	self.lblMach.enabled:=true;
	self.cmbMach.enabled:=true;
	

	self.lblIMV.visible:=self.isIMVneeded;
	self.cmbIMV.visible:=self.isIMVneeded;

	
	
	
	
epilog

end;</source>
        <Parameter name="optionbutton" type="OptionButton" usage="input"/>
    </JadeMethod>
    <JadeMethod name="resizeControls" id="20547417-1ce3-46cc-8357-8ba5df7ef6a5">
        <updating/>
        <source>resizeControls() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 March 2011	cnwer1	Initial creation

*/

vars
	bottomControl : Control;
begin
	if self.optMove.visible then
		lblMove.height:= lblMove.getTextHeightForWidth(lblMove.caption,lblMove.clientWidth);
		self.optPickSetTask.top:=self.lblMove.top + lblMove.height + 5;
		self.lblPickSetTask.top:=self.optPickSetTask.top;	
	else
		 self.optPickSetTask.top:=self.optMove.top;
		 self.lblPickSetTask.top:= self.optPickSetTask.top;
	endif; 
	

	if not self.optPickSetTask.visible then
		self.optPickupTask.top:=self.optPickSetTask.top;
		self.lblPickupTask.top:=self.lblPickSetTask.top;
	else
		self.lblPickSetTask.height:=self.lblPickSetTask.getTextHeightForWidth(self.lblPickSetTask.caption,self.lblPickSetTask.clientWidth);
		self.optPickupTask.top:= self.lblPickSetTask.top + self.lblPickSetTask.clientHeight +5;
		self.lblPickupTask.top:=self.optPickupTask.top;
	endif;
	

	
	self.lblMach.top:=self.lblPickupTask.top + self.lblPickupTask.clientHeight + 5;
	
	self.cmbMach.top:=self.lblMach.top;
	bottomControl:=self.lblMach;
	if self.lblIMV.visible then
		self.lblIMV.top:=self.lblMach.top + self.lblMach.clientHeight + 5;
		self.cmbIMV.top:=self.lblIMV.top;
		bottomControl:=self.lblIMV;
	endif;
	
	if self.lblQuantity.visible then
		self.lblQuantity.top:=bottomControl.top + bottomControl.clientHeight + 5;
		self.txtQuantity.top:=self.lblQuantity.top;
		bottomControl:=self.lblQuantity;
	endif;
	
	if self.lblWeight.visible then
		self.lblWeight.top:=bottomControl.top + bottomControl.clientHeight + 5;
		self.tblWeight.top:=self.lblWeight.top;
		bottomControl:=self.lblWeight;
	endif;
	
	self.height:=bottomControl.top + (bottomControl.clientHeight + 5) * 2;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="eda1b9f6-59a2-49d8-b82d-a89ec8e21ca7">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 24 March 2014.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0016313, locale);
	lblIMV.translateCaption(Xlat_0016314, locale);
	lblMach.translateCaption(Xlat_0016315, locale);
	lblQuantity.translateCaption(Xlat_0019131, locale);
	lblWeight.translateCaption(Xlat_0019586, locale);
end;</source>
    </JadeMethod>
</GUIClass>
