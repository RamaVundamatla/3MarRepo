    <JadeMethod name="getTransactionType" id="22f47a2e-64a9-41ab-91ae-f6b269d10d69">
        <source>getTransactionType():CM_TransactionType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 July 2020	jlgndl1	Initial creation	TFS 49747

*/

vars

begin

	if app = null then
		return CM_Root.firstInstance.allTransactionTypes[self.type];
	else
		return app.myRoot.allTransactionTypes[self.type];
	endif;

epilog

end;</source>
