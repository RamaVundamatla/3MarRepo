<CollClass name="CM_YardControllerSet" id="7cea7b7f-cf3c-4927-a577-775a43511771">
    <loadFactor>98</loadFactor>
    <memberType name="CM_YardController"/>
    <superclass name="CM_LCSet"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="yardAllocations"/>
    <JadeMethod name="getDisplay" id="0b2ccc46-4556-49b7-9b50-e3f0d8b405af">
        <source>getDisplay():String;
// --------------------------------------------------------------------------------
// Created:		09 May 2005 by cnwdad1
//
// Purpose:		Returns a display string of the receiver's elements.
//
// Parameters:	None
//
// Returns:		The display value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	controllerObj	: CM_YardController;
	displayValue	: String;
	
begin
	foreach controllerObj in self do
		if displayValue = null then
			displayValue	:=	controllerObj.ident;
		else
			displayValue	:=	displayValue &amp; ", " &amp; controllerObj.ident;
		endif;
	endforeach;
	
	return displayValue;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</CollClass>
