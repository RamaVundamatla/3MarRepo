end;</source>
        <Parameter name="pIndex" type="Integer"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="removeBinary" id="65bac4da-ed66-4049-bd0c-59e8d5f03d72">
        <lockReceiver/>
        <updating/>
        <source>removeBinary(pBinaryValue: Binary): Boolean updating, lockReceiver;
// --------------------------------------------------------------------------------
// Created:		03 September 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return false;
end;</source>
        <Parameter name="pBinaryValue" type="Binary"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="removeString" id="a1fc5504-2cf9-4c0b-b5dc-091461edda59">
        <lockReceiver/>
        <updating/>
        <source>removeString(pStringValue: String): Boolean updating, lockReceiver;
// --------------------------------------------------------------------------------
// Created:		30 June 2001 by cnwdad1
//
// Purpose:		Removes an array element which has a specified string value.
//
// Parameters:	pStringValue (String) - The value to scan for in the array.
//
// Returns:		Boolean - True is an element was removed, false if not.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	elementsToDelete	: ObjectArray;
	object				: Object;
	theSubstring		: JSSSubstringElement;
	isRemoved			: Boolean;

begin
	create elementsToDelete transient;

	// Find the array elements to be removed.

	foreach theSubstring in self do
		if theSubstring.getStringValue() = pStringValue then
			elementsToDelete.add(theSubstring);
		endif;
	endforeach;

	// Now removed the matching array elements.

	foreach object in elementsToDelete do
		self.remove(object.JSSSubstringElement);

		if (not isRemoved) then
			isRemoved	:=	true;
		endif;
	endforeach;
epilog
	delete elementsToDelete;

	return isRemoved;
end;</source>
        <Parameter name="pStringValue" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</CollClass>
