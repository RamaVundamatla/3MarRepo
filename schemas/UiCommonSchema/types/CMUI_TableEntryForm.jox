    <JadeMethod name="queryUnload" id="f0748c73-fe17-4f4f-b5f1-25174e2af51c">
        <controlMethod name="Form::queryUnload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>queryUnload(cancel: Integer io; reason: Integer) updating;
//--------------------------------------------------
// Created:	15 July 2004 By: cnwgd1
//--------------------------------------------------
vars

begin

	if self.tblItem.hasChanged 
       and self.modalResult &lt;&gt; MsgBox_Return_OK then
		if reason = QueryUnload_User or
		   reason = QueryUnload_UnloadMethod or
		   reason = QueryUnload_MdiChild then
			if (not self.confirmCancel(self.caption)) then
				cancel := 1;	//Do not close form
			endif;
		endif;
	endif;
end;</source>
        <Parameter name="cancel" type="Integer" usage="io"/>
        <Parameter name="reason" type="Integer"/>
    </JadeMethod>
