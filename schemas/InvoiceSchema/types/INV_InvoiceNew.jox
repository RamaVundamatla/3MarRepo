    <JadeMethod name="txtNarr_lostFocus" id="ed8c1f5a-6e4f-4783-ba19-e66fb3e3a910">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtNarr_lostFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14/08/2023	navkc1	Bug 59803: FR | EUP 53978 - Invoicing - Configuration Enhancements - Invoice Update - missing items

*/

vars
	height : Integer;
	theNarrRow : Integer;
begin
	height := self.txtNarr.height.Integer;
	self.tblInvProperties.setValueByControlName(textbox.name, textbox.text);
	if self.tblInvProperties.getRowByName(ETRow_Narration) &gt; 0 then
		theNarrRow := self.tblInvProperties.getRowByName(ETRow_Narration);
		self.tblInvProperties.accessRow(theNarrRow).height := height;
		self.txtNarr.height := height;
		self.doResize();
	endif;
	
	
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
