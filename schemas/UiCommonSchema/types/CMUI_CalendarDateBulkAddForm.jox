    <JadeMethod name="populateTblDayData" id="27693b85-1937-4f0d-a55b-1eb450412bfd">
        <source>populateTblDayData();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 October 2010	cnwndl1	Initial creation

*/

vars

	calendarDate : CM_CalendarDate;
	iter : Iterator;
	jadTableRow : JadeTableRow;
	invalidObject : Boolean;
	lastAddedStr : String;
	tableDisplay : String;
	dups : Boolean;
	errString : String;

begin

	self.initTblDayData();
	
	iter := self.allTransCalendarDates.createIterator;
	
	on Exception do app.handleDeletedObject(exception, calendarDate, invalidObject);
	
	while iter.next( calendarDate ) do
		self.tblDayData.rows := self.tblDayData.rows + 1;
		jadTableRow := self.tblDayData.accessRow( self.tblDayData.rows );
		jadTableRow.itemObject := calendarDate;
		tableDisplay := calendarDate.getStringForTable;
		if invalidObject then
			self.tblDayData.rows := self.tblDayData.rows - 1;
			invalidObject := false;
			continue;
		endif;
		self.tblDayData.setCellText( self.tblDayData.rows, 1, tableDisplay );
		if tableDisplay = lastAddedStr then
			jadTableRow.backColor := Grey;
			dups := true;
		endif;
		lastAddedStr := tableDisplay;
	endwhile;
	
	self.showButtons();
	
	if dups then
		errString := app.getErrorString(Possible_duplicates);
		app.msgBox(errString, app.getErrorString(Warning), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
	endif;

epilog

	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="setMyCalendar" id="e7ae4cfb-5f83-4290-b0fb-0aa02df4aa26">
        <updating/>
        <source>setMyCalendar( _calendar : CM_Calendar; _defaultYear : Integer ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 October 2010	cnwndl1	Initial creation

*/

vars

	date : Date;

begin

	self.myCalendar := _calendar;
	self.defaultYear := _defaultYear;
	
	if self.defaultYear &gt; 0 then
		date.setDate(1,1,self.defaultYear);
		self.txtDateFrom.setDate( date );
		date.setDate(31,12,self.defaultYear);
		self.txtDateTo.setDate( date );
	else
		self.txtDateFrom.setDate( date );
		self.txtDateTo.setDate( date );
	endif;

epilog

end;</source>
        <Parameter name="_calendar" type="CM_Calendar"/>
        <Parameter name="_defaultYear" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="df649a88-e353-4420-b8ae-307be4281973">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 October 2010	cnwndl1	Initial creation

*/

vars

	monday : Date;
	date : Date;
	pos : Integer;
	allTerminals : CM_TerminalByCodeDict;
begin

	baseCaption := self.caption;

	if self.myCalendar &lt;&gt; null then
		self.caption := baseCaption &amp; " - " &amp; myCalendar.description;
	endif;
	
	monday := date.lastMonday;
	date := monday;
	foreach pos in 1 to 7 do
		self.dayListArray.add( date.format("dddd") );
		date := date + 1;
	endforeach;
	
	txtYear.visible := false;

	self.doResize();
	
	inheritMethod();
	
	self.minimumWidth := 620;
	self.minimumHeight := 510;
	
	self.populateTblDayData();
	self.optMonth.value := true; // TFS 215
	
	self.clickOption();
	
	self.showButtons();
	
	if self.financialPeriodMode then // TFS 215
	
		//06 Dec 2018	NDL	TFS 42131 - Only Steve would do this....
		if self.myCurrentFinancialPeriodType = null then
			app.msgBox("No Current Financial Period Type!", app.getErrorString(Error), MsgBox_OK_Only );
			self.unloadForm;
			return;
		endif;
		
		self.optYear.visible := false;
		self.caption :=  app.getErrorString(FinPerBulkAdd) &amp; " (" &amp; self.myCurrentFinancialPeriodType.description &amp; ")";
		create self.myCalendar transient;
		create allTerminals transient;
		self.myCalendar.setProxy("FINPER",app.getErrorString(FinPerBulkAdd),false,true,null,null,null,allTerminals);
		delete allTerminals;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showButtons" id="fe350bef-a3a8-45de-a7d9-9dcebb86c16a">
        <source>showButtons();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 October 2010	cnwndl1	Initial creation

*/

vars

	toDate : Date;
	fromDate : Date;
	toTime : Time;
	fromTime : Time;
	errorMess : String;

begin

	if self.myCalendar &lt;&gt; null and self.myCalendar.hasTime then
		self.txtTimeFrom.enabled := true;
		self.txtTimeTo.enabled := self.myCalendar.hasEndTime;
	else
		self.txtTimeFrom.enabled := false;
		self.txtTimeFrom.setTime(null);
		self.txtTimeTo.enabled := false;
		self.txtTimeTo.setTime(null);
	endif;
	
	
	toDate := txtDateTo.getDate;
	fromDate := txtDateFrom.getDate;
	toTime := txtTimeTo.getTime;
	fromTime := txtTimeFrom.getTime;

	self.btnGenDate.enabled := fromDate.isValid and toDate.isValid and not tblTemplates.allSelectedObjects.isEmpty;
	self.btnClear.enabled := tblDayData.rows &gt; tblDayData.fixedRows;
	
	self.btnProcess.enabled := tblDayData.rows &gt; tblDayData.fixedRows;
	self.btnRemDate.enabled := not tblDayData.allSelectedObjects.isEmpty;
	self.btnUpdDate.enabled := tblDayData.allSelectedObjects.size = 1;
	self.btnCancel.enabled := true;
	
	if toDate.isValid and fromDate.isValid then
		if toDate &lt; fromDate then
			errorMess := app.getErrorString1(EndBeforeStart, fromDate.asStringJMT);
			app.msgBox(errorMess, app.getErrorString(Warning), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		elseif toDate = fromDate then
			if toTime &lt; fromTime then
				errorMess := app.getErrorString1(EndBeforeStart, fromTime.asStringJMT);
				app.msgBox(errorMess, app.getErrorString(Warning), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			endif;
		endif;
	endif;
	
	self.lblSave.visible := self.tblDayData.rows &gt; self.tblDayData.fixedRows;

epilog

end;</source>
    </JadeMethod>
