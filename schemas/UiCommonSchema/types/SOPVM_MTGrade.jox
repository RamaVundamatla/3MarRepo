<Class name="SOPVM_MTGrade" id="ed09eff0-3a17-4899-b8bc-d6943fe53994">
    <superclass name="SOP_ViewModelObject"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <JadeMethod name="create" id="6cddfa4f-cc07-48b3-bdc6-4b378a32b8b2">
        <updating/>
        <source>create() updating;
// -------------------------------------------
// Created 26 October 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	self.canAddChild 	:= false;
	self.canAddPeer 	:= true;
	self.canEdit 		:= true;
	self.canDelete 		:= true;
	self.expanded 		:= false;


end;</source>
    </JadeMethod>
    <JadeMethod name="createEmptyChild" id="26535571-f29c-48f3-91a8-bd26c32e7f01">
        <updating/>
        <source>createEmptyChild(_parent: SOP_ViewModelObject) updating;
// -------------------------------------------
// Created 26 October 2004 by cnwdvb1
// -------------------------------------------
vars

	proxyMTGrade : CM_MTGradeCode;

begin

	create proxyMTGrade transient;
	proxyMTGrade.setForProxy(null, null, _parent.myObject.CM_CodeGroup, null);
	self.myObject := proxyMTGrade;	
	self.myParent := _parent;


end;</source>
        <Parameter name="_parent" type="SOP_ViewModelObject"/>
    </JadeMethod>
    <JadeMethod name="createEmptyPeer" id="034637e7-a64a-4315-b633-e5921e135aec">
        <updating/>
        <source>createEmptyPeer(_parent: SOP_ViewModelObject) updating;

vars

	proxyMTGrade : CM_MTGradeCode;

begin

	create proxyMTGrade transient;
	proxyMTGrade.setForProxy(null, null, _parent.myObject.CM_CodeGroup, null);
	self.myObject := proxyMTGrade;	
	self.myParent := _parent;
end;</source>
        <Parameter name="_parent" type="SOP_ViewModelObject"/>
    </JadeMethod>
    <JadeMethod name="doDelete" id="d4518128-743d-4308-a208-edcc3bb26e3b">
        <updating/>
        <source>doDelete(): Boolean updating;
// -------------------------------------------
// Created 27 October 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	app.myTrxDA.trxDeleteAvailabilityGradeCode(self.myObject.CM_MTGradeCode, app.myPassport);
	return app.myPassport.trxCompletedOK;


end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="efd4196c-e46e-4985-97d8-3390993a2268">
        <updating/>
        <source>doSave(): Boolean updating;

vars

	proxyMTGrade,
	realMTGrade : CM_MTGradeCode;
	
begin

	if self.myForm.mode = self.myForm.Mode_Add then
		if self.myForm.myProxyObject &lt;&gt; null then
			self.myForm.myProxyObject.erase(NORMAL_ERASE);
		endif;
		create self.myForm.myProxyObject as CM_MTGradeCode transient;
	endif;
	
	proxyMTGrade := self.myForm.myProxyObject.CM_MTGradeCode;
	
	proxyMTGrade.setForProxy(	self.myForm.tblInput1.getValueByName('code').String.removeTabCrLfs(),	// 18/04/2013 cnwar2 #27130
								self.myForm.tblInput1.getValueByName('description').String,
								self.myObject.CM_MTGradeCode.myCodeGroup,
								self.myForm.cmbAvailability.myObject.CM_MTGrade);
								
	if self.myForm.mode = self.myForm.Mode_Add then
		app.myTrxCA.trxCreateAvailabilityGradeCode(proxyMTGrade, realMTGrade, app.myPassport);
		if app.myPassport.trxCompletedOK then
			delete self.myObject;  // delete the transient holder
			self.myObject := realMTGrade;
			return true;
		endif;
	elseif self.myForm.mode = self.myForm.Mode_Update then
		app.myTrxUA.trxUpdateAvailabilityGradeCode(proxyMTGrade, app.myPassport);
		if app.myPassport.trxCompletedOK then
			return true;
		endif;
	endif;
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getChildClass" id="311e3970-1a2c-4e37-941f-bbbff87501cc">
        <source>getChildClass(): Class protected;
// -------------------------------------------
// Created 26 October 2004 by cnwdvb1
// -------------------------------------------
vars

begin
	return self.class;


end;</source>
        <access>protected</access>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="8fad94c3-1594-4211-b473-7de510c141f8">
        <updating/>
        <source>showThumbnail(_obj: CM_MTGradeCode) updating;

vars

	tbl : CM_EntryTable;

begin
	self.myForm.shtTblInput1.caption := 'Details';
	self.myForm.shtTblInput1.visible := true;
	self.myForm.shtMultiSelect1.visible := false;
	self.myForm.shtMultiSelect2.visible := false;
	self.myForm.shtMultiSelect3.visible := false;

	tbl := myForm.tblInput1;
	self.myForm.initTblInput(tbl, ETDef_CodeMaintAvailability);
	tbl.clearValues;
	tbl.setValueByName(ETRow_Code, _obj.code);
	tbl.setValueByName(ETRow_Description, _obj.description);
	
	if _obj.myMTGrade &lt;&gt; null then
		tbl.setValueByName(ETRow_AvailabilityGrade, _obj.myMTGrade.code.String);
		self.myForm.cmbAvailability.setObject(_obj.myMTGrade);
	endif;
end;</source>
        <Parameter name="_obj" type="CM_MTGradeCode"/>
    </JadeMethod>
</Class>
