        <source>utlCreateVoyageProgress(_voyage : CM_Voyage input; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 July 2024	navra1	Initial creation for //navra1 - CR-65068/Task-64641 - Auto Comparison - 15th July 2024

*/

vars
	voyageProgress : CM_VoyageProgress;
begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(false);

	create voyageProgress persistent;
	
	voyageProgress.setForCreate(_voyage);
	
epilog

end;</source>
