    <JadeMethod name="cmbDestinPort_lostFocus" id="344c02b6-600a-4a51-95ae-865010bbca23">
        <controlMethod name="CMUI_ComboBoxObject::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbDestinPort_lostFocus(combobox: ComboBox input) updating;
//19 November 2010	cnwml2
//+cnwml2 PAR26346
vars
	destination : CM_Port;
	discharge : CM_Port;
	voyage : CM_Voyage;
	operator : CM_Operator;
begin
	destination := self.cmbDestinPort.listObject.CM_Port;
	if destination = null then	// #26475 08/12/2010. Avoid null object error when discharge = destination = null
		return;
	endif;
	
	discharge := self.cmbDischargePort.listObject.CM_Port;
	
	if discharge = null or discharge = destination then
		voyage := self.cmbVoyage.listObject.CM_Voyage;
		operator := self.cmbOperator.listObject.CM_Operator;
		if operator &lt;&gt; null then
			discharge := operator.getDischargePortFromDest(destination.code, voyage, null);	
			if discharge &lt;&gt; null then
				self.cmbDischargePort.setObject(discharge);
			endif;	
		endif;
	endif;
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbDischargePort_click" id="1ed2a3f7-e745-4246-af09-246259537ced">
        <controlMethod name="CMUI_ComboBoxObject::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbDischargePort_click(combobox: ComboBox input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 November 2009	cnwas3	Initial creation

*/

vars
	voyage :CM_Voyage;
	currentDischargePort : CM_Port;
begin

	voyage := self.cmbVoyage.listObject.CM_Voyage;
	
	if voyage = null then					//+cnwml2 PAR22130
		return;
	endif;
	
	if voyage.isNullVoyage then
		voyage:= null;
	endif;
	
	
	
	// Discharge port	
	currentDischargePort:=self.cmbDischargePort.listObject.CM_Port;
	
	self.cmbTranshipPort.setObjectAndVoyageDischPort(currentDischargePort,voyage);
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
