    <JadeMethod name="allowsSealType" id="fc8b9f0e-55cb-4d0b-9d72-3a6d5000ea95">
        <source>allowsSealType( _sealType : String ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 March 2015	cnwndl1	Initial creation

*/

vars

	iter : Iterator;
	sealType : CM_SealType;

begin

	iter := self.allSelectedSealTypes.createIterator;
	while iter.next( sealType ) do
		if sealType.notAvailableForEntry then
			continue;
		endif;
		if sealType.sealType = _sealType then
			return true;
		endif;
	endwhile;
	
	return false;

epilog

	delete iter;

end;</source>
        <Parameter name="_sealType" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
