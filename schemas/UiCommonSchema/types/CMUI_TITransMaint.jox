    <JadeMethod name="doBtnCancelClick" id="2db00eb2-7022-4050-bf0b-4a0295886e49">
        <updating/>
        <source>doBtnCancelClick() protected, updating;
// ---------------------------------------------------------------------------
// Created:     01 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if self.state = State_Add or self.state = State_Update then
		if self.editModeOnly then
			self.unloadForm();
		else
			self.setState(self.State_View);
		endif;
	else
		self.unloadForm();
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBtnUpdateClick" id="0d26785d-ff06-47b6-9bd1-7012d4c142cb">
        <updating/>
        <source>doBtnUpdateClick() updating, protected;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if self.tblList.accessRow(self.tblList.row).itemObject = null then
		app.msgBox('Please select a transaction to update first', 'Nothing selected',0);
		return;
	endif;

	self.setState(self.State_Update);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBuildComboContainers" id="a2a3b7e5-f3c3-45b1-8bb6-ba3fec5c8c9e">
        <updating/>
        <source>doBuildComboContainers() updating;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//30 Mar 2016	cnwrs1	TFS 1546 POL - Unpacking Process Options
// ---------------------------------------------------------------------------

vars

begin
	self.cmbContainers.clear;
	
	if self.myCurrentTrackedItem = null and
	   not self.isBulkUpdate then
		return;
	endif;
	
	self.cmbContainers.itemObject[self.cmbContainers.addItem(self.myCurrentTrackedItem.id)] := self.myCurrentTrackedItem;

end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildComboFromSubTerm" id="41e63115-1c69-4a90-9da2-94fca4e1c5d1">
        <source>doBuildComboFromSubTerm(_transType : Integer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//18 Aug 2017		cnwma1	TFS #5027:POL - CAMS Transaction not being correctly processed

*/

vars

	aSubTerm  :CM_SubTerminal;
	idx : Integer;
	subTermType: Integer;
begin

	self.cmbSubTermFrom.clear();
	self.cmbSubTermFrom.sorted := true;
	self.cmbSubTermFrom.itemData[self.cmbSubTermFrom.addItem(" ")] := -1;
	if isSubTerminalsOn then
		subTermType := self.getSubTermType(_transType);
		foreach aSubTerm in self.myTerminal.allSubTerminals do
			if aSubTerm &lt;&gt;  null then
				if not self.isReleaseSubTerm(_transType) then
					if 	aSubTerm.type &lt;&gt; subTermType then
						continue;
					endif;
				endif;
				
				idx := self.cmbSubTermFrom.addItem(aSubTerm.code);
				self.cmbSubTermFrom.itemObject[idx] := aSubTerm;
			endif;
		endforeach;
	endif;
epilog

end;</source>
        <Parameter name="_transType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doBuildComboHireType" id="9197017b-e293-42bc-9a3b-824d92ef3ce5">
        <updating/>
        <source>doBuildComboHireType() updating;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.cmbHireType.clear();
	self.cmbHireType.sorted := false;
	
	self.cmbHireType.addItem(Hire_Type_OnHire_Str);
	self.cmbHireType.addItem(Hire_Type_HireOutReturn_Str);
	self.cmbHireType.addItem(Hire_Type_OffHire_Str);
	self.cmbHireType.addItem(Hire_Type_HireOut_Str);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildComboMachine" id="7ea0b882-8301-4aaf-8859-e57eeb24d55f">
        <updating/>
        <source>doBuildComboMachine() updating;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aMachine : CM_Machine;
	idx : Integer;
begin
	self.cmbMachine.clear();
	self.cmbMachine.sorted := true;
	
	foreach aMachine in self.myTerminal.machines where not aMachine.isNotAvailableForEntry do
		if aMachine.machineType &lt;&gt; MACHINETYPE_WAGONRAIL and
			aMachine.machineType &lt;&gt;  MACHINETYPE_PORTAINER_CRANE and
			aMachine.machineType &lt;&gt;  MACHINETYPE_TRUCK_TRACTOR then
			idx := self.cmbMachine.addItem(aMachine.id);
			self.cmbMachine.itemObject[idx] := aMachine;
		endif;
	endforeach;
	
end;</source>
    </JadeMethod>
