    <JadeMethod name="setForCreate" id="fd566636-2bba-411d-b820-4759b2f3bcfd">
        <updating/>
        <source>setForCreate(_pxyBOL : CM_BOL; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     11 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	self.raiseExceptionIfTransient(method);
	_pxyBOL.raiseExceptionIfNotTransient(method);
	
	self.bolType		:= _pxyBOL.bolType;
	self.dateTime		:= app.serverTimestampAtTrxStart;
	
	self.setFromProxy(_pxyBOL, _passport);
	//always 'unarchive' or 'unrepack' the status if they create or update
	self.status			:= BOL_STATUS_NORMAL;
	
	// call this to force CM_BOLTerminal to be created for this terminal if required.
	self.getBOLTerminal(self.myTerminal, true);
	
	//cnwmc5 - 14 April 2014 - CCMS 2352
	self.setStopsToBeApplied();
	
	if _pxyBOL.myExtension &lt;&gt; null then
		create self.myExtension as _pxyBOL.myExtension.class persistent;
		self.myExtension.setForCreate(_pxyBOL.myExtension);
	endif;
	//Not using transactions at the moment, just audits.
	//self.created(app.myPassport);
	self.setTIsForCreate(_pxyBOL.allTrackedItems, _passport);
	
	
end;</source>
        <Parameter name="_pxyBOL" type="CM_BOL"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="3e64c550-0a44-48e1-8f70-c113b992c5ca">
        <updating/>
        <source>setForUpdate(_pxyBOL : CM_BOL; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     11 March 2002 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	savePlannedLC	: CM_LocationsController;
	tiUpdateCntrl	: CMIF_TIUpdateController;
	weightChanged : Boolean;
begin

	self.raiseExceptionIfTransient(method);
	_pxyBOL.raiseExceptionIfNotProxy(method);
	
	if self.weightNet &lt;&gt; _pxyBOL.weightNet then
		weightChanged := true;
	endif;

	self.setFromProxy(_pxyBOL, _passport);

	//always 'unarchive' or 'unrepack' the status if they create or update
	self.status			:= BOL_STATUS_NORMAL;
	self.setTIsForUpdate(_pxyBOL.allTrackedItems, _passport);

	if _pxyBOL.myExtension &lt;&gt; null then
		if self.myExtension = null then
			app.raiseUnexpectedProgramError(class.name, method.name, 'Persistent ext does not exist for ' &amp; self.String);
			return;
		elseif _pxyBOL.myExtension.class &lt;&gt; self.myExtension.class then
			app.raiseUnexpectedProgramError(class.name, method.name, 'Persistent ext class (' &amp;
						self.myExtension.class.name &amp; ') not same as proxy ext class (' &amp;
						_pxyBOL.myExtension.class.name &amp; ')');
			return;
		endif;
		self.myExtension.setForUpdate(_pxyBOL.myExtension);
		if weightChanged then
			tiUpdateCntrl := app.createTIUpdateControl(TI_UPDMODE_NORMAL, _passport.userCode, null);
			self.myExtension.setWeightForLogs(tiUpdateCntrl, _passport);
		endif;
	else
		if self.myExtension &lt;&gt; null then
			app.raiseUnexpectedProgramError(class.name, method.name, 'Transient ext does not exist for ' &amp; self.String);
			return;
		endif;
	endif;

	self.doUpdateLocation(PLANNING_MODE, self.myPlannedLocation, _passport);

	
epilog
	if tiUpdateCntrl &lt;&gt; null then
		delete tiUpdateCntrl;
	endif;
end;</source>
        <Parameter name="_pxyBOL" type="CM_BOL"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateBOLDtl" id="893923d8-b23a-4fba-b69b-898d5e16bd05">
        <updating/>
        <source>setForUpdateBOLDtl(	_pxyBOL : CM_BOL;
					_allNewBOLDtlProxies : CM_ObjectArrayActual input;
					_context : Object //06 Nov 2019	NDL	TFS 47100
					)updating;
//15 January 2010	cnwml2


vars
	pxyBOLDtl ,
	realBOLDtl,
	newBOLDtl: CM_BOLDtl;
	deleteBOLDtls : CM_BOLDtlSet;
	realTI : CM_TrackedItem;
begin
	//all current booking ref items
	create deleteBOLDtls transient;
	 self.allBOLDtls.copy(deleteBOLDtls);
	foreach pxyBOLDtl in _pxyBOL.allBOLDtls do
		realBOLDtl := app.myProxyManager.getRealObject(pxyBOLDtl).CM_BOLDtl;
	
		if realBOLDtl = null then
			//create it 
			create newBOLDtl persistent;
			newBOLDtl.setForCreate(pxyBOLDtl, self);
			app.myProxyManager.createProxyLink(newBOLDtl, pxyBOLDtl);
			_allNewBOLDtlProxies.add(pxyBOLDtl);
			foreach realTI in pxyBOLDtl.allTrackedItems do// cnwrs par 22855 Mar 2010
				realTI.setBOLDtl(newBOLDtl);
			endforeach;
		else
			//06 Nov 2019	NDL	TFS 47100
			if _context &lt;&gt; null then
				self.createUpdConsigneeOrBOLTrxs( pxyBOLDtl, realBOLDtl, app.myPassport );	
			endif;
			//update it remove from delete set
			realBOLDtl.setForUpdate(pxyBOLDtl, self);
			deleteBOLDtls.removeIfPresent(realBOLDtl);	
			foreach realTI in pxyBOLDtl.allTrackedItems do// cnwrs par 22855 Mar 2010
				realTI.setBOLDtl(realBOLDtl);
			endforeach;
		endif;
				
	endforeach;
	
	foreach realBOLDtl in deleteBOLDtls do
		realBOLDtl.validateForDelete();
	endforeach;
	deleteBOLDtls.purge;
	
epilog
	delete deleteBOLDtls;


end;</source>
        <Parameter name="_pxyBOL" type="CM_BOL"/>
        <Parameter name="_allNewBOLDtlProxies" type="CM_ObjectArrayActual" usage="input"/>
        <Parameter name="_context" type="Object"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateGeneralDocket" id="2a68fb10-d7ab-405c-b4d6-b34fe1034502">
        <updating/>
        <source>setForUpdateGeneralDocket(_pxyBOL : CM_BOL;  _cmifBOLIn: CMIF_BOLIn; _passport : CM_Passport input) updating;
//----------------------------------------------------------------
//	Created:	11 April 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	app.writeStatement(class.name &amp; " " &amp; method.name &amp; " " &amp; "");
end;</source>
        <Parameter name="_pxyBOL" type="CM_BOL"/>
        <Parameter name="_cmifBOLIn" type="CMIF_BOLIn"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateHeader" id="1f49f5df-0621-4da1-a451-59c36163df0a">
        <updating/>
        <source>setForUpdateHeader(_pxyBOL : CM_BOL; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     19 Jul 2002 by cnwsb1
// ---------------------------------------------------------------------------
vars
	currentNumItems : Integer;

begin

	self.raiseExceptionIfTransient(method);
	_pxyBOL.raiseExceptionIfNotProxy(method);
	
	currentNumItems := self.numItems;
	self.setFromProxy(_pxyBOL, _passport);
	self.numItems := currentNumItems;

	// Header update does not change the TIs
	//self.setTIsForUpdate(_pxyBOL.allTrackedItems);

	if _pxyBOL.myExtension &lt;&gt; null then
		if self.myExtension = null then
			app.raiseUnexpectedProgramError(class.name, method.name, 'Persistent ext does not exist for ' &amp; self.String);
			return;
		elseif _pxyBOL.myExtension.class &lt;&gt; self.myExtension.class then
			app.raiseUnexpectedProgramError(class.name, method.name, 'Persistent ext class (' &amp;
						self.myExtension.class.name &amp; ') not same as proxy ext class (' &amp;
						_pxyBOL.myExtension.class.name &amp; ')');
			return;
		endif;
		self.myExtension.setForUpdate(_pxyBOL.myExtension);
	else
		if self.myExtension &lt;&gt; null then
			app.raiseUnexpectedProgramError(class.name, method.name, 'Transient ext does not exist for ' &amp; self.String);
			return;
		endif;
	endif;

	self.doUpdateLocation(PLANNING_MODE, self.myPlannedLocation, _passport);

end;</source>
        <Parameter name="_pxyBOL" type="CM_BOL"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setFromProxy" id="2be453d8-8cf4-45ae-9a8f-b752f1f438b2">
        <updating/>
        <source>setFromProxy(_pxyBOL : CM_BOL; _passport : CM_Passport input) updating, protected;
//--------------------------------------------------------------
//Created: 21 January 2002 By: cnwgd1
//--------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	-------------------------------------------------------------
// 25/11/2013	cnwdap1		PAR #33019 CCMS DPH 2285 New BOL Fields
// 29 Nov 2013	cnwkpd1		PAR #33107 - Docket number changes corrupting dictionary keys
// 19/07/2022   navmv20     ChangeRequest 54095: EUP - Outturn Remarks on BOL
vars
	product : CM_Product;

begin
	self.raiseExceptionIfTransient(method);
	_pxyBOL.raiseExceptionIfNotTransient(method);

	self.carrierCode				:= _pxyBOL.carrierCode;
	self.clientRef1					:= _pxyBOL.clientRef1;					// PAR #33019
	self.clientRef2					:= _pxyBOL.clientRef2;					// PAR #33019
	self.consignee					:= _pxyBOL.consignee;
	self.consignor					:= _pxyBOL.consignor;
	self.destinationPort			:= _pxyBOL.destinationPort;
	self.setDirectDelivery( _pxyBOL.directDelivery );	//29 Jan 2013	NDL	Par 31102
	self.dischargePort				:= _pxyBOL.dischargePort;
	self.handlingContractor1Code	:= _pxyBOL.handlingContractor1Code;
	self.handlingContractor2Code	:= _pxyBOL.handlingContractor2Code;
	self.handlingSubContractor1Code	:= _pxyBOL.handlingSubContractor1Code;
	self.isCharged					:= _pxyBOL.isCharged;		
	self.loadPortCode				:= _pxyBOL.loadPortCode;	
	
	self.myPlannedLocation 			:= _pxyBOL.myPlannedLocation; 
	self.myManifest					:= _pxyBOL.myManifest;
	self.notifyParty				:= _pxyBOL.notifyParty;
	
	self.numItems					:= _pxyBOL.numItems;
	
	if self.bolType = BOLType_GeneralDocket and app.getMyTerminalConfigDO_NOT_USE(GateInAutoBOLNumber).Boolean then
//		self.number := app.getMyTerminalDO_NOT_USE.bolInNextSeqNumber;
		self.setNumber(app.getMyTerminalDO_NOT_USE.bolInNextSeqNumber);		// PAR #33107
	elseif self.number &lt;&gt; _pxyBOL.number then
		// do this to avoid locking the dict if don't have to
//		self.number						:= _pxyBOL.number;
		self.setNumber(_pxyBOL.number);										// PAR #33107
	endif;
		

	self.processOption				:= _pxyBOL.processOption;
//	self.purchaseOrder				:= _pxyBOL.purchaseOrder;
	self.remarks					:= _pxyBOL.remarks;
	self.referenceDate				:= _pxyBOL.referenceDate;
	self.sourceLocation				:= _pxyBOL.sourceLocation;
	self.sourceSubLocation			:= _pxyBOL.sourceSubLocation;
	self.sourceSubSubLocation		:= _pxyBOL.sourceSubSubLocation;	
	self.status						:= _pxyBOL.status;
	self.trailerNumber				:= _pxyBOL.trailerNumber;
	self.transportMode				:= _pxyBOL.transportMode;
	self.truckNumber				:= _pxyBOL.truckNumber;
	self.vehicle					:= _pxyBOL.vehicle;
	self.weightGross				:= _pxyBOL.weightGross;
	self.weightNet					:= _pxyBOL.weightNet;
	self.weightTare					:= _pxyBOL.weightTare;
	
	if (_pxyBOL.myProduct &lt;&gt; null) then
		if (_pxyBOL.myProduct.isTransient) then
			// DVB 26/03/04
			// Because we can enter multiple dockets with the same potential new product we have to check
			// whether the previous docket has already created the new product object for us.
			product := _pxyBOL.myOperator.allProducts[_pxyBOL.myProduct.cargoType, _pxyBOL.myProduct.code];
			
			if product &lt;&gt; null then
				self.myProduct := product;
			else
				app.myUtilityCA.utlCreateProduct(_pxyBOL.myProduct, self.myProduct, _passport);
			endif;
		else
			self.myProduct := _pxyBOL.myProduct;
		endif;
	endif;
	
	self.setSubTerminal(_pxyBOL.mySubTerminal);
	self.myTerminal					:= _pxyBOL.myTerminal;
	self.myOperator 				:= _pxyBOL.myOperator;
	
	if _pxyBOL.myOperatorTerminal = null then
		self.myOperatorTerminal		:= _pxyBOL.myOperator.getOperatorTerminal(_pxyBOL.myTerminal, true);
	else
		self.myOperatorTerminal		:= _pxyBOL.myOperatorTerminal;
	endif;
	
	self.reconciledDate := _pxyBOL.reconciledDate;
	self.reconciledReason := _pxyBOL.reconciledReason;
	
	//cnwmc5 - 23 July 2014 - CCMS 2353 PEN
	self.customsQuantityEntered := _pxyBOL.customsQuantityEntered;
	self.customsQuantityReleased := _pxyBOL.customsQuantityReleased;
	
	
	self.createGLDateChangeTransaction(_pxyBOL.generalLandingDate); // TFS 4272
	self.generalLandingDate := _pxyBOL.generalLandingDate; // TFS 4272
	self.outturnRemarks		:= _pxyBOL.outturnRemarks;	//13/07/2022 navgm20	TFS 54095
	
end;</source>
        <access>protected</access>
        <Parameter name="_pxyBOL" type="CM_BOL"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setLogDocketData" id="d8e9d174-28e7-4d0f-8f15-ecb370842059">
        <updating/>
        <source>setLogDocketData(_value : CM_LogDocketData)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 November 2016	cnwma1	TFS #2892:PAR38364 C3 - CreateLogDocket Webservice

*/

vars

begin
	self.myLogDocketData :=_value;
epilog

end;</source>
