    <JadeMethod name="trxInterTerminalMove" id="b287632e-12f3-439d-b31c-f2379a2a57f1">
        <updating/>
        <source>trxInterTerminalMove(_ta : CM_InterTerminalTransferArea; _tiSet : CM_TISet input; _passport : CM_Passport input) updating;
// -------------------------------------------
// Created 23 July 2004 by cnwdvb1
// -------------------------------------------
vars

begin

