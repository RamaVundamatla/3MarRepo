    <JadeMethod name="valImportServPayTypesXML" id="d222edf2-6f89-4a3f-82bf-1a4396a8846e">
        <source>valImportServPayTypesXML(	_bank : CM_Bank;
						_element : JadeXMLElement;
						_allDebtors : CM_DebtorByNameDict input;
						_allNewProxys : CM_ServicePayTypeMapDebtorServ input;
						_passport : CM_Passport input
						);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 December 2018	jlgndl1	Initial creation	TFS 42060

*/

vars

	voidDebtor : CM_VoidDebtor;
	
	servicePayTypeMapping : CM_ServicePayTypeMapping;
	paymentType : Integer;
	service  : CM_Service;
	sptService  : CM_Service;
	debtor : CM_DebtorNode;
	sptDebtor : CM_Debtor;
	
	iter : Iterator;
	xmlNode : JadeXMLNode;
	xmlElement : JadeXMLElement;
	tagName : String;
	textData : String;

begin

	voidDebtor := CM_VoidDebtor.firstInstance;
	
	//One CM_InvoiceTypeSurchargeExempt per complete set.
	create servicePayTypeMapping transient;
	
	iter := _element.childNodes.createIterator;
	while iter.next( xmlNode ) do
		if not xmlNode.isKindOf(JadeXMLElement) then
			continue;
		endif;
		
		xmlElement := xmlNode.JadeXMLElement;
		tagName := xmlElement.tagName;
		textData := xmlElement.textData.trimBlanks();
		
		if tagName = "myDebtorName" then
			debtor := _allDebtors.getAtKey( textData );
			if debtor = null or not debtor.isKindOf( CM_Debtor ) then
				app.raiseCMException2(Must_exist_befor_servi_payme_t, "Debtor", textData, null, null );
			else
				sptDebtor := debtor.CM_Debtor;
				continue;
			endif;
			
		elseif tagName = "myServiceName" then
			service := _bank.services.getAtKey( textData );
			if service = null then
				app.raiseCMException2(Must_exist_befor_servi_payme_t, "Service", textData, null, null );
			else
				sptService := service;
				continue;
			endif;
			
		elseif tagName = "paymentType" then
			// no validation on this one.
			paymentType := textData.Integer;
			continue;
			
		endif; 
		
	endwhile;
	
	if _passport.noErrors then
		//populate the transient from the collected data
		servicePayTypeMapping.setProxy(	_bank,	//_bank : CM_Bank;
										sptService,	//_service : CM_Service;
										sptDebtor,	//_debtor : CM_Debtor;
										paymentType	//_paymentType : Integer
										);
		_allNewProxys.add( servicePayTypeMapping );
	else
		delete servicePayTypeMapping;
	endif;

epilog

	delete iter;

end;</source>
        <Parameter name="_bank" type="CM_Bank"/>
        <Parameter name="_element" type="JadeXMLElement"/>
        <Parameter name="_allDebtors" type="CM_DebtorByNameDict" usage="input"/>
        <Parameter name="_allNewProxys" type="CM_ServicePayTypeMapDebtorServ" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="valImportSurchargesXML" id="bdd8e583-c1c4-4ae0-985b-7f72ea2d8100">
        <source>valImportSurchargesXML(	_bank			: CM_Bank;
						_element		: JadeXMLElement;
						_allDebtors		: CM_DebtorByNameDict input;
						_allNewProxys	: CM_InvTypeSurchargeExemptSet input;
						_passport		: CM_Passport input
						);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 December 2018	jlgndl1	Initial creation	TFS 42061
15 September 2022	navpw1 	TFS 54565 (54385) - EUP - Inv Config - Invoice Surcharges

*/

vars
	iter						: Iterator;
	xmlNode						: JadeXMLNode;
	xmlElement					: JadeXMLElement;
	tagName						: String;
	textData					: String;
	
	invoiceType					: CM_InvoiceDesc;
	invLineType					: CM_InvoiceLineDesc;
	currency					: CM_CurrencyType;
	
	subElements					: JadeXMLElementArray;
	subElement					: JadeXMLElement;
	iter2						: Iterator;
	xmlNode2					: JadeXMLNode;
	xmlElement2					: JadeXMLElement;
	tagName2					: String;
	textData2					: String;
	
	debtor						: CM_DebtorNode;
	
	iter3						: Iterator;
	xmlNode3					: JadeXMLNode;
	xmlElement3					: JadeXMLElement;
	tagName3					: String;
	textData3					: String;
	
	cargoType					: CM_CargoType;
	subCargoType				: CM_Product;
	commodity					: CM_Commodity;
	vessel						: CM_Vessel;
	nullVessel					: CM_NullVessel;
	voidDebtor					: CM_VoidDebtor;
	
	surchargeExempt				: CM_InvoiceTypeSurchargeExempt;
	seMinChargeAmount			: Real;
	seInvoiceType				: CM_InvoiceDesc;
	seMinChargeInvoiceLineType	: CM_InvoiceLineDesc;
	seCurrencyType				: CM_CurrencyType;
	invType						: CM_InvoiceDesc;
	seTaxExeInvType				: CM_InvoiceDesc;	//07 May 2019	NDL	TFS 44651
	
	drSurchargeRateObj			: CM_DebtorSurchargeRate;
	drDebtor					: CM_Debtor;	
	drSurInvLineType			: CM_InvoiceLineDesc;
	drSurchargeRateRate			: Decimal[23,6];
	
	externalTax					: CM_InvoiceTypeExternalTax;
	extTaxCode					: String;
	extTaxRule					: Integer;
	extTaxDebtor				: CM_Debtor;
	extTaxRangeStart			: Real;
	extTaxRangeEnd				: Real;
	
	addFees						: CM_InvTypeAdditionalCharges;
	addFeesAllInvTypes			: CM_InvoiceLineDescSet;
	addFeesDebtor				: CM_Debtor;
	addFeesRangeStart			: Real;
	addFeesRangeEnd				: Real;
	
	cargoSurcharge				: CM_InvTypeCargoSurcharge;
	csCargoType					: CM_CargoType;
	csSurInvLineType			: CM_InvoiceLineDesc;
	csSurchargeRate				: Decimal[23,6];
	csCargoSubType				: CM_Product;
	csCommodity					: CM_Commodity;
	csAllInvLineDescs			: CM_InvoiceLineDescSet;
	
	vesselMinCharge				: CM_InvTypeVesselMinCharge;
	vesselMinChargeAmount		: Real;
	vesselMinChgInvoiceLineType	: CM_InvoiceLineDesc;
	vesselVessel				: CM_Vessel;
	
	drMinCharge					: CM_InvTypeDebtorMinCharge;
	drMinChgDebtor				: CM_Debtor;
	drMinChgAmount				: Real;
	drMinChgInvoiceLineType		: CM_InvoiceLineDesc;
	
	pilotSurcharge				: CM_InvTypePilotSurcharge;
	notReadyLineType			: CM_InvoiceLineDesc;
	tooSoonLineType				: CM_InvoiceLineDesc;
	
begin
	nullVessel := CM_NullVessel.firstInstance;
	voidDebtor := CM_VoidDebtor.firstInstance;
	
	//One CM_InvoiceTypeSurchargeExempt per complete set.
	create surchargeExempt transient;
	create addFeesAllInvTypes transient;
	create csAllInvLineDescs transient;
	
	create subElements transient;
	
	iter := _element.childNodes.createIterator;
	while iter.next( xmlNode ) do
		if not xmlNode.isKindOf(JadeXMLElement) then
			continue;
		endif;
		
		delete iter2;
		xmlElement := xmlNode.JadeXMLElement;
		tagName := xmlElement.tagName;
		textData := xmlElement.textData.trimBlanks();
		
		subElements.clear();
		
		if tagName = "myInvoiceTypeDescription" then
			invoiceType := _bank.findInvoiceType( textData );
			if invoiceType = null then
				app.raiseCMException2(Must_exist_befor_surch_import, "Invoice Type", textData, null, null );
			else
				seInvoiceType := invoiceType;
				continue;
			endif;
			
		elseif tagName = "myMinChargeInvLineTypeNarr" then
			invLineType := _bank.invoiceLineDescriptors.getAtKey( textData );
			if invLineType = null then
				app.raiseCMException2(Must_exist_befor_surch_import, "Invoice Line Type", textData, null, null );
			else
				seMinChargeInvoiceLineType := invLineType;
				continue;
			endif;
			
		elseif tagName = "myCurrencyTypeCode" then
			currency := app.myRoot.allCurrencyTypes.getAtKey( textData );
			if currency = null then
				app.raiseCMException2(Must_exist_befor_surch_import, "Currency Type", textData, null, null );
			else
				seCurrencyType := currency;
				continue;
			endif;
			
		//07 May 2019	NDL	TFS 44651 - seTaxExeInvLineType
		elseif tagName = "mySepTaxInvTypeDesc" then
			invType := _bank.findInvoiceType( textData );
			if invType = null then
				app.raiseCMException2(Must_exist_befor_surch_import, "Invoice Type", textData, null, null );
			else
				seTaxExeInvType := invType;
				continue;
			endif;
			
		elseif tagName = "minimumChargeAmount" then
			// no validation on this one.
			seMinChargeAmount := textData.Real;
			continue;
			
		elseif tagName = "drSurchargeRates" then
			xmlElement.getAllElementsByTagName("drSurchargeRateObj", subElements );
		
			if not subElements.isEmpty then
				foreach subElement in subElements do
				
					create drSurchargeRateObj transient; 
					drDebtor := null;	
					drSurInvLineType := null;
					drSurchargeRateRate := 0;
					
					iter2 := subElement.childNodes.createIterator;
					while iter2.next( xmlNode2 ) do
						if not xmlNode2.isKindOf(JadeXMLElement) then
							continue;
						endif;
						xmlElement2 := xmlNode2.JadeXMLElement;
						tagName2 := xmlElement2.tagName;
						textData2 := xmlElement2.textData.trimBlanks();
						
						if tagName2 = "drSurchargeDebtorName" then
							debtor := _allDebtors.getAtKey( textData2 );
							if debtor = null or not debtor.isKindOf( CM_Debtor ) then
								app.raiseCMException2(Must_exist_befor_surch_import, "Debtor", textData2, null, null );
							else
								drDebtor := debtor.CM_Debtor;
								continue;
							endif;
							
						elseif tagName2 = "drSurchargeRate" then
							// no validation on this one.
							drSurchargeRateRate := textData2.Decimal;
							continue;
							
						elseif tagName2 = "drSurchargeInvLineTypeNarr" then
							invLineType := _bank.invoiceLineDescriptors.getAtKey( textData2 );
							if invLineType = null then
								app.raiseCMException2(Must_exist_befor_surch_import, "Invoice Line Type", textData2, null, null );
							else
								drSurInvLineType := invLineType;
								continue;
							endif;
							
						endif;
		
					endwhile;
					delete iter2;
					
					if _passport.noErrors then
						drSurchargeRateObj.setProxy(	drDebtor,	//_dr : CM_Debtor;
														surchargeExempt,	//_mySurAndExempt : CM_InvoiceTypeSurchargeExempt;
														drSurInvLineType,	//_mySurInvLineType : CM_InvoiceLineDesc;
														drSurchargeRateRate	//_surchargeRate : Decimal
														);
					else
						delete drSurchargeRateObj;
					endif;
					
				endforeach;
			endif;
			
			continue;
			
		
		elseif tagName = "externalTaxs" then
			xmlElement.getAllElementsByTagName("externalTax", subElements );
			
			if not subElements.isEmpty then
				foreach subElement in subElements do
					
					create externalTax transient; 
					extTaxCode := null;
					extTaxRule := 0;
					extTaxDebtor := null;
					extTaxRangeStart := 0;
					extTaxRangeEnd := 0;
					
					iter2 := subElement.childNodes.createIterator;
					while iter2.next( xmlNode2 ) do
						if not xmlNode2.isKindOf(JadeXMLElement) then
							continue;
						endif;
						xmlElement2 := xmlNode2.JadeXMLElement;
						tagName2 := xmlElement2.tagName;
						textData2 := xmlElement2.textData.trimBlanks();
						
						if tagName2 = "extTaxCode" then
							// no validation on this one.
							extTaxCode := textData2;
							continue;
							
						elseif tagName2 = "extTaxRule" then
							// no validation on this one.
							extTaxRule := textData2.Integer;
							continue;
							
						elseif tagName2 = "extTaxRangeStart" then
							// no validation on this one.
							extTaxRangeStart := textData2.Real;
							continue;
							
						elseif tagName2 = "extTaxRangeEnd" then
							// no validation on this one.
							extTaxRangeEnd := textData2.Real;
							continue;
							
						elseif tagName2 = "extTaxDebtorName" then
							debtor := _allDebtors.getAtKey( textData2 );
							if debtor = null or not debtor.isKindOf(CM_Debtor) then
								app.raiseCMException2(Must_exist_befor_surch_import, "Debtor", textData2, null, null );
							else
								extTaxDebtor := debtor.CM_Debtor;
								continue;
							endif;
							
						endif;
					
					endwhile; 
					delete iter2;
					
					if _passport.noErrors then
						externalTax.setProxy(	extTaxCode,	//_extTaxCode : String;
												extTaxRule,	//_extTaxRule : Integer;
												extTaxDebtor,	//_myDebtor : CM_Debtor;
												surchargeExempt,	//_mySurchargeExemption : CM_InvoiceTypeSurchargeExempt;
												extTaxRangeStart,	//_rangeStart : Real;
												extTaxRangeEnd	//_rangeEnd : Real
												);
					else
						delete externalTax;
					endif;
					
				endforeach;
			endif;
			
			continue;
		
		
		elseif tagName = "additionalFees" then
			xmlElement.getAllElementsByTagName("additionalFee", subElements );
			
			if not subElements.isEmpty then
				foreach subElement in subElements do
				
					create addFees transient; 
					addFeesAllInvTypes.clear;
					addFeesDebtor := null;
					addFeesRangeStart := 0;
					addFeesRangeEnd := 0;
					
					iter2 := subElement.childNodes.createIterator;
					while iter2.next( xmlNode2 ) do
						if not xmlNode2.isKindOf(JadeXMLElement) then
							continue;
						endif;
						xmlElement2 := xmlNode2.JadeXMLElement;
						tagName2 := xmlElement2.tagName;
						textData2 := xmlElement2.textData.trimBlanks();
						
						if tagName2 = "addFeeRangeStart" then
							// no validation on this one.
							addFeesRangeStart := textData2.Real;
							continue;
							
						elseif tagName2 = "addFeeRangeEnd" then
							// no validation on this one.
							addFeesRangeEnd := textData2.Real;
							continue;
							
						elseif tagName2 = "addFeeDebtorName" then
							debtor := _allDebtors.getAtKey( textData2 );
							if debtor = null or not debtor.isKindOf(CM_Debtor) then
								app.raiseCMException2(Must_exist_befor_surch_import, "Debtor", textData2, null, null );
							else
								addFeesDebtor := debtor.CM_Debtor;
								continue;
							endif;
							
						elseif tagName2 = "addFeeLineTypes" then
							iter3 := xmlElement2.childNodes.createIterator;
							while iter3.next( xmlNode3 ) do
								if not xmlNode3.isKindOf(JadeXMLElement) then
									continue;
								endif;
								xmlElement3 := xmlNode3.JadeXMLElement;
								tagName3 := xmlElement3.tagName;
								textData3 := xmlElement3.textData.trimBlanks();
								
								if tagName3 = "addFeeInvLineTypeNarr" then
									invLineType := _bank.invoiceLineDescriptors.getAtKey( textData3 );
									if invLineType = null then
										app.raiseCMException2(Must_exist_befor_surch_import, "Invoice Line Type", textData3, null, null );
									else
										addFeesAllInvTypes.addNoDuplicates( invLineType, false );
										continue;
									endif;
								endif;
							
							endwhile;
							
							delete iter3;
							continue;
							
						endif; 
		
					endwhile;
					delete iter2;
					
					if _passport.noErrors then
						addFees.setProxy(	addFeesAllInvTypes,	//_allAdditionalInvTypes : CM_InvoiceLineDescSet input;
											addFeesDebtor,	//_myDebtor : CM_Debtor;
											surchargeExempt,	//_mySurchargeExemption : CM_InvoiceTypeSurchargeExempt;
											addFeesRangeStart,	//_rangeStart : Real;
											addFeesRangeEnd	//_rangeEnd : Real
											);
					else
						delete addFees;
					endif;
					
				endforeach;
			endif;
			
			continue;
			
		elseif tagName = "cargoSurcharges" then
			xmlElement.getAllElementsByTagName("cargoSurcharge", subElements );
			
			if not subElements.isEmpty then
				foreach subElement in subElements do
					
					create cargoSurcharge transient; 
					csAllInvLineDescs.clear;
					csCargoType := null;
					csSurInvLineType := null;
					csSurchargeRate := 0;
					csCargoSubType := null;
					csCommodity := null;
					
					iter2 := subElement.childNodes.createIterator;
					while iter2.next( xmlNode2 ) do
						if not xmlNode2.isKindOf(JadeXMLElement) then
							continue;
						endif;
						xmlElement2 := xmlNode2.JadeXMLElement;
						tagName2 := xmlElement2.tagName;
						textData2 := xmlElement2.textData.trimBlanks();
						
						if tagName2 = "cargoSurchargeRate" then
							// no validation on this one.
							csSurchargeRate := textData2.Decimal;
							continue;
							
						elseif tagName2 = "cargoSurchgInvLineTypeNarrCreate" then
							invLineType := _bank.invoiceLineDescriptors.getAtKey( textData2 );
							if invLineType = null then
								app.raiseCMException2(Must_exist_befor_surch_import, "Invoice Line Type", textData2, null, null );
							else
								csSurInvLineType := invLineType;
								continue;
							endif;
							
						elseif tagName2 = "cargoSurchargeCargoTypeAbbr" then
							if textData2 &lt;&gt; "ALLCARGOTYPES" then // ### TFS 51219 03JUN2021 NAVAB1
								cargoType := app.myRoot.getCargoTypeFromAbbrev( textData2 ).CM_CargoType;
								if cargoType = null then
									app.raiseCMException2(Must_exist_befor_surch_import, "Cargo Type", textData2, null, null );
								else
									csCargoType := cargoType;
									continue;
								endif;
							endif;
							
						elseif tagName2 = "cargoSurchargeSubCargoTypeCode" then
							if cargoType &lt;&gt; null then
								subCargoType := cargoType.getProductFromCode( textData2 ).CM_Product;
							endif;
							if subCargoType = null then
								app.raiseCMException2(Must_exist_befor_surch_import, "Product", textData2, null, null );
							else
								csCargoSubType := subCargoType;
								continue;
							endif;
							
						elseif tagName2 = "cargoSurchargeCommCode" then
							commodity := app.myRoot.allCommodities.getAtKey( textData2 ).CM_Commodity;
							if commodity = null then
								app.raiseCMException2(Must_exist_befor_surch_import, "Commodity", textData2, null, null );
							else
								csCommodity := commodity;
								continue;
							endif;
							
						elseif tagName2 = "cargoSurchargeLineTypes" then
							iter3 := xmlElement2.childNodes.createIterator;
							while iter3.next( xmlNode3 ) do
								if not xmlNode3.isKindOf(JadeXMLElement) then
									continue;
								endif;
								xmlElement3 := xmlNode3.JadeXMLElement;
								tagName3 := xmlElement3.tagName;
								textData3 := xmlElement3.textData.trimBlanks();
								
								if tagName3 = "cargoSurchargeInvLineTypeNarr" then
									invLineType := _bank.invoiceLineDescriptors.getAtKey( textData3 );
									if invLineType = null then
										app.raiseCMException2(Must_exist_befor_surch_import, "Invoice Line Type", textData3, null, null );
									else
										csAllInvLineDescs.addNoDuplicates( invLineType, false );
										continue;
									endif;
								endif;
					
							endwhile;
							
							delete iter3;
							continue; 
							
						endif; 
						
					endwhile;
					delete iter2;
					
					if _passport.noErrors then
						cargoSurcharge.setProxy(	csCargoType,	//_cargoType : CM_CargoType;
													surchargeExempt,	//_mySurAndExempt : CM_InvoiceTypeSurchargeExempt;
													csSurInvLineType,	//_mySurInvLineType : CM_InvoiceLineDesc;
													csSurchargeRate,	//_surchargeRate : Decimal;
													subCargoType,	//_cargoSubType : CM_Product;
													csCommodity,	//_commodity : CM_Commodity;
													csAllInvLineDescs	//_allSelectedInvLineDescs : CM_InvoiceLineDescSet
													);
					else
						delete cargoSurcharge;
					endif;
					
				endforeach;
			endif;
			
			continue;
		
		elseif tagName = "vesselMinCharges" then
			xmlElement.getAllElementsByTagName("vesselMinCharge", subElements );
			
			if not subElements.isEmpty then
				foreach subElement in subElements do
					
					create vesselMinCharge transient; 
					vesselMinChargeAmount := 0;
					vesselMinChgInvoiceLineType := null;
					vesselVessel := null;
					
					iter2 := subElement.childNodes.createIterator;
					while iter2.next( xmlNode2 ) do
						if not xmlNode2.isKindOf(JadeXMLElement) then
							continue;
						endif;
						xmlElement2 := xmlNode2.JadeXMLElement;
						tagName2 := xmlElement2.tagName;
						textData2 := xmlElement2.textData.trimBlanks();
						
						if tagName2 = "vesselMinChgAmount" then
							// no validation on this one.
							vesselMinChargeAmount := textData2.Real;
							continue;
							
						elseif tagName2 = "vesselMinVesselName" then
							if nullVessel &lt;&gt; null and textData2 = nullVessel.name then
								vessel := nullVessel; 
							else
								vessel := app.myRoot.allVesselsByName.getAtKeyGeq( textData2 );
								if vessel &lt;&gt; null and vessel.name &lt;&gt; textData2 then
									vessel := null;
								endif;
							endif;
							if vessel = null then
								app.raiseCMException2(Must_exist_befor_surch_import, "Vessel", textData2, null, null );
							else
								vesselVessel := vessel;
								continue;
							endif;
							
						elseif tagName2 = "vesselMinInvLineTypeNarr" then
							invLineType := _bank.invoiceLineDescriptors.getAtKey( textData2 );
							if invLineType = null then
								app.raiseCMException2(Must_exist_befor_surch_import, "Invoice Line Type", textData2, null, null );
							else
								vesselMinChgInvoiceLineType:= invLineType;
								continue;
							endif;
							
						endif;
		
					endwhile;
					delete iter2;
					
					if _passport.noErrors then
						vesselMinCharge.setProxy(	vesselMinChargeAmount,	//_minimumChargeAmount : Real;
													vesselMinChgInvoiceLineType,	//_myMinimumChargeInvoiceLineType : CM_InvoiceLineDesc;
													vesselVessel,	//_myVessel : CM_Vessel;
													surchargeExempt	//_mySurchargesAndExemptions : CM_InvoiceTypeSurchargeExempt
													);
					else
						delete vesselMinCharge;
					endif;
					
				endforeach;
			endif;
			
			continue;
		
		elseif tagName = "drMinCharges" then
			xmlElement.getAllElementsByTagName("drMinCharge", subElements );
			
			if not subElements.isEmpty then
				foreach subElement in subElements do
					
					create drMinCharge transient; 
					drMinChgDebtor := null;
					drMinChgAmount := 0;
					drMinChgInvoiceLineType := null;
					
					iter2 := subElement.childNodes.createIterator;
					while iter2.next( xmlNode2 ) do
						if not xmlNode2.isKindOf(JadeXMLElement) then
							continue;
						endif;
						xmlElement2 := xmlNode2.JadeXMLElement;
						tagName2 := xmlElement2.tagName;
						textData2 := xmlElement2.textData.trimBlanks();
						
						if tagName2 = "drMinChgAmount" then
							// no validation on this one.
							drMinChgAmount := textData2.Real;
							continue;
							
						elseif tagName2 = "drMinDebtorName" then
							if voidDebtor &lt;&gt; null and textData2 = voidDebtor.name then
								debtor := voidDebtor; 
							else
								debtor := _allDebtors.getAtKey( textData2 );
							endif;
							if debtor = null or not debtor.isKindOf(CM_Debtor) then
								app.raiseCMException2(Must_exist_befor_surch_import, "Debtor", textData2, null, null );
							else
								drMinChgDebtor := debtor.CM_Debtor;
								continue;
							endif;
							
						elseif tagName2 = "drMinInvLineTypeNarr" then
							invLineType := _bank.invoiceLineDescriptors.getAtKey( textData2 );
							if invLineType = null then
								app.raiseCMException2(Must_exist_befor_surch_import, "Invoice Line Type", textData2, null, null );
							else
								drMinChgInvoiceLineType := invLineType;
								continue;
							endif;
							
						endif;
		
					endwhile;
					delete iter2;
					
					if _passport.noErrors then
						drMinCharge.setProxy(	drMinChgDebtor,	//_myDebtor : CM_Debtor;
												drMinChgAmount,	//_minimumChargeAmount : Real;
												drMinChgInvoiceLineType,	//_myMinimumChargeInvoiceLineType : CM_InvoiceLineDesc;
												surchargeExempt	//_mySurchargesAndExemptions : CM_InvoiceTypeSurchargeExempt
												);
					else
						delete drMinCharge;
					endif;
					
				endforeach;
			endif;
			
			continue;
		
		elseif tagName = "pilotSurcharges" then
			xmlElement.getAllElementsByTagName("pilotSurcharge", subElements );
			
			if not subElements.isEmpty then
				foreach subElement in subElements do
					
					create pilotSurcharge transient; 
					notReadyLineType := null;
					tooSoonLineType := null;
					
					iter2 := subElement.childNodes.createIterator;
					while iter2.next( xmlNode2 ) do
						if not xmlNode2.isKindOf(JadeXMLElement) then
							continue;
						endif;
						xmlElement2 := xmlNode2.JadeXMLElement;
						tagName2 := xmlElement2.tagName;
						textData2 := xmlElement2.textData.trimBlanks();
						
						if tagName2 = "rtsInvLineTypeNarr" then
							invLineType := _bank.invoiceLineDescriptors.getAtKey( textData2 );
							if invLineType = null then
								app.raiseCMException2(Must_exist_befor_surch_import, "Invoice Line Type", textData2, null, null );
							else
								tooSoonLineType := invLineType;
								continue;
							endif;
							
						elseif tagName2 = "vnrInvLineTypeNarr" then
							invLineType := _bank.invoiceLineDescriptors.getAtKey( textData2 );
							if invLineType = null then
								app.raiseCMException2(Must_exist_befor_surch_import, "Invoice Line Type", textData2, null, null );
							else
								notReadyLineType := invLineType;
								continue;
							endif;
							
						endif;
		
					endwhile;
					delete iter2;
					
					if _passport.noErrors then
						pilotSurcharge.setProxy(	surchargeExempt,	//surchargeExempt : CM_InvoiceTypeSurchargeExempt;
													notReadyLineType,	//_notReadyLineType : CM_InvoiceLineDesc;
													tooSoonLineType	//_tooSoonLineType : CM_InvoiceLineDesc
													);
					else
						delete pilotSurcharge;
					endif;
					
				endforeach;
				
			endif;
			
			continue;
			
		endif;
		
	endwhile;	
	
	if _passport.noErrors then
		//populate the transient from the collected data
		surchargeExempt.setProxy(	seMinChargeAmount,	//_minimumChargeAmount : Real;
									seInvoiceType,	//_myInvoiceType : CM_InvoiceDesc;
									seMinChargeInvoiceLineType,	//_myMinimumChargeInvoiceLineType : CM_InvoiceLineDesc;
									seCurrencyType,	//_myCurrencyType : CM_CurrencyType
									seTaxExeInvType	//_taxExemptInvType : CM_InvoiceDesc
									);
		_allNewProxys.add( surchargeExempt );
	else
		delete surchargeExempt;
	endif;
	
epilog
	delete iter;
	delete iter2;
	delete subElements;
	delete iter3;
	delete addFeesAllInvTypes;
	delete csAllInvLineDescs;
	
end;</source>
        <Parameter name="_bank" type="CM_Bank"/>
        <Parameter name="_element" type="JadeXMLElement"/>
        <Parameter name="_allDebtors" type="CM_DebtorByNameDict" usage="input"/>
        <Parameter name="_allNewProxys" type="CM_InvTypeSurchargeExemptSet" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
