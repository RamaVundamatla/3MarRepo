    <JadeMethod name="wsRESTGetReleaseRequest" id="26989f0b-b331-41d4-8a0f-87dbcfe62390">
        <source>wsRESTGetReleaseRequest(_queryParamString: String; _pathParamString: String; _response : String io ): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
06 Apr 2023		navak20	Task 57524: CUX - MTN-EDBIC - 100 - Process Release Request - GET Unit Test
17 Jun 2024		navdap1	TFS 63107 CUX | GET /releaseRequest API to return release request line items
*/

vars
	webService			: MasterTerminalAPIService;	
	response 			: WS_RestResponse;					// TFS 63107
	jsonHelper 			: JMTJadeJson;						// TFS 63107
	ref 				: String;
	id 					: String;
	reqDT 				: Integer64;
	pos 				: Integer;
	dict 				: WS_QueryStringParamDict;
begin
	create webService transient;
	
	self.loginREST(webService);	
	webService.qsData.parseNameValuePair(_queryParamString);
	
	pos := 2;
	id := _pathParamString.scanUntil('/', pos);
	pos += 1;
	reqDT := _pathParamString.scanUntil('/', pos).Integer64;
	response := webService.getReleaseRequest(id, reqDT);
	
	if response.allErrors.isNotEmpty then
		return response.allErrors.first.text;			// TFS 63107
	endif;
	
	// TFS 63107 return the resulting JSON essage for checking
	if response &lt;&gt; null then
		create jsonHelper transient;
		_response := jsonHelper.generateJson(response.WS_RestReleaseRequestRes, JadeJson.Format_Json_Microsoft);
	endif;
	return null;
	
	// Not used,just here to provide a reference from the super schema super class method 
	ref := CM_UnitTestAgent::wsRESTGetReleaseRequest.name;

epilog
	dict := webService.qsData;
	dict.purge();
	webService.unitTestData.removeAssoc("HTTP_AUTHORIZATION");	
	delete webService;
	delete jsonHelper;		// TFS 63107
	delete response;
end;</source>
