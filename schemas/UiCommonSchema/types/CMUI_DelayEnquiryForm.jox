    <JadeMethod name="addToolbarControls" id="aa8e9b38-1500-4df9-b240-dd04667b932c">
        <updating/>
        <source>addToolbarControls() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	23 February 2007 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	toolbar		: CMUI_Toolbar;
	showCaptions	: Boolean;
begin
	inheritMethod;
	
	toolbar := self.frmToolbar;
	showCaptions := toolbar.showCaptions;

	toolbar.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addButton(self.btnExportCSVQE, CMUI_Toolbar.Control_Alignment_Left);	

	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);

	if self.usesQueryFrame then
		toolbar.addButton(self.btnShowSearcher, CMUI_Toolbar.Control_Alignment_Left);
	endif;
	
	if app.getMyUser.canDo (self.myTerminal, PmShpDelaysMaint) then
		toolbar.addButton(self.btnAddDelay, CMUI_Toolbar.Control_Alignment_Left);	
	endif;
	
	// if they don't have update access they can view the delay
	toolbar.addButton(self.btnEditItem, CMUI_Toolbar.Control_Alignment_Left);	
	
	if app.getMyUser.canDo (self.myTerminal, PmShpDelaysMaint) then	
		toolbar.addButton(self.btnDelete, CMUI_Toolbar.Control_Alignment_Left);	
	endif;
	//toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);	
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="addToolbarControlsQuery" id="8357820a-62c2-42f3-8d3d-6f91a4c5c17a">
        <source>addToolbarControlsQuery() protected;
// ---------------------------------------------------------------------------
// Created:     04 April 2011 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	toolbar	: CMUI_Toolbar;
begin
	// no query frame if showing selected delays
	if self.initialiseWithObject then
		return;
	endif;
	
	toolbar := self.frmQueryToolbar;
	
	toolbar.addButton(self.btnQuery, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnResetSearch, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnHideSearcher, CMUI_Toolbar.Control_Alignment_Left);
	
end;</source>
        <access>protected</access>
    </JadeMethod>
