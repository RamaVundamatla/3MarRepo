    <JadeMethod name="txtArgFind_keyDown" id="450ef861-f76b-4c6e-b208-b0ea82e56069">
        <controlMethod name="TextBox::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtArgFind_keyDown(textbox: TextBox input; keyCode: Integer io; shift: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
19 October 2022	navgm20	ChangeRequest 55106: EUP - Filtered Drop-downs and Lists FIND LISTS

*/

vars
	type,
	remaining		: Integer;
begin
	if self.getTimerStatus(self.Timer_TableData_Filter, type, remaining) then
		self.endTimer(self.Timer_TableData_Filter);
	endif;
	
	self.beginTimer(500, Timer_OneShot, self.Timer_TableData_Filter);
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
