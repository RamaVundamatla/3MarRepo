    <JadeMethod name="doUpdate" id="45d439bb-c09e-40a9-827c-31f346e24677">
        <updating/>
        <source>doUpdate(_passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 06 September 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	if (not self.canAllocateToOrder) then
		return;		
	endif;
	
	if self.mode = Mode_SummaryAllocation then
		self.updateStockOrderSummary(_passport);
	elseif self.mode = Mode_LineAllocation then
		self.updateStockOrderLine(_passport);
	elseif self.mode = Mode_SummarySplit then
		self.updateSummarySplit();
	endif;
	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setAllocAmountType" id="23b388fc-bd47-401e-82fb-4976410c9a71">
        <updating/>
        <source>setAllocAmountType()updating;
//--------------------------------------------------------------
//Created: 25 November 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	if self.volume[1:1].toUpper = "A" then
		self.allocTypeStr := CM_StockOrderAllocation.AllocTypeStr_All;
		self.allocAmount := self.mySOHLocation.currentVolume; //self.mySOHLocation.calRemainingAllocAmount(null);
		/*if self.mode = self.Mode_SummarySplit then
			self.allocType := CM_StockOrderAllocation.AllocType_Quantity;
		else*/
			self.allocType := CM_StockOrderAllocation.AllocType_All;
		//endif;
	elseif self.volume[1:1].toUpper = "R" then
		self.allocTypeStr := CM_StockOrderAllocation.AllocTypeStr_Remaining;
		
		/*if self.mode = self.Mode_SummarySplit then
			self.allocType := CM_StockOrderAllocation.AllocType_Quantity;
		else*/
			self.allocType := CM_StockOrderAllocation.AllocType_Remaining;
		//endif;

		if self.mode = self.Mode_LineAllocation then
			self.allocAmount := self.mySOHLocation.calAvailableVolumeForStkOrder(self.myLogStockOrderLine, false);
			//self.allocAmount := self.mySOHLocation.calRemainingAllocAmount(self.myLogStockOrderLine.getLineAllocationObject(self.mySOHLocation));
		elseif self.mode = self.Mode_SummaryAllocation then
			self.allocAmount := self.mySOHLocation.calRemainingAllocAmount(self.mySummaryAllocation);		
		else
			self.allocAmount := self.mySOHLocation.currentVolume - self.mySOHLocation.calAllocatedAmountToLines();
			//self.allocAmount := self.mySOHLocation.calRemainingAllocAmount(null);		
		endif;
	else
		self.allocAmount := self.volume.Decimal;
		self.allocTypeStr := CM_StockOrderAllocation.AllocTypeStr_Quantity;
		self.allocType := CM_StockOrderAllocation.AllocType_Quantity;				
	endif;		

	//Unscalled logs can cause a negative value as they are created with a volume of -1
	if self.allocAmount &lt; 0 then
		self.allocAmount := 0;
	endif;
			
end;</source>
    </JadeMethod>
    <JadeMethod name="setValues" id="9309143a-a4e2-46cd-9a08-a9eebe8bda5b">
        <updating/>
        <source>setValues()updating;
//--------------------------------------------------------------
//Created: 22 November 2002 By: cnwgd1
//--------------------------------------------------------------
// These properties need to be set before the validation
vars
	isSplit 	: Boolean;
	allocation 	: CM_StockOrderAllocation;
begin

	if self.mode = Mode_SummaryAllocation then
		self.mySummaryAllocation := self.myStockOrderSummary.getSummaryAllocationObject(self.mySOHLocation);
	elseif self.mode = Mode_LineAllocation then
		self.mySummaryAllocation := self.myLogStockOrderLine.myStockOrderSummary.getSummaryAllocationObject(self.mySOHLocation);
		self.myStockOrderSummary := self.myLogStockOrderLine.myStockOrderSummary;
	elseif self.mode = Mode_SummarySplit then
		isSplit := true;
		self.myStockOrderSummary := self.myLogStockOrderLine.myStockOrderSummary;
	endif;

	self.setAllocAmountType();
	
	//Check if OK to allocate row to order
	if self.mySOHLocation &lt;&gt; null then
		if self.myLogStockOrderLine &lt;&gt; null then
			allocation := self.myLogStockOrderLine.getLineAllocationObject(self.mySOHLocation);
		endif;
		if allocation = null then
			allocation := self.mySummaryAllocation;
		endif;
		self.canAllocateToOrder := self.mySOHLocation.canAllocateToOrder(allocation, isSplit, self.allocType);		
	endif;		

end;</source>
    </JadeMethod>
    <JadeMethod name="updateStockOrderLine" id="be8c672f-a712-4c6b-8023-1421ea594583">
        <updating/>
        <source>updateStockOrderLine(_passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 06 September 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	subTot,
	saveAllocAmount,
	summAmt				: Decimal[16,4];
	otherLineAlloc,
	existingAlloc		: CM_StockOrderAllocation;
	existLineAlloc,
	realLineAlloc 		: CM_StockOrderLineAlloc;
	saveAllocType		: Integer;
	saveAllocTypeStr	: String;
	terminal			: CM_Terminal;	
begin

	if (not self.canAllocateToOrder) then
		return;		
	endif;

	if self.mode &lt;&gt; Mode_LineAllocation then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid mode (' &amp; self.mode.String &amp; ')');
		return;
	endif;
	
	existLineAlloc := self.myLogStockOrderLine.getLineAllocationObject(self.mySOHLocation);

	if existLineAlloc &lt;&gt; null 
	and self.allocAmount &lt;= 0 
	and self.allocTypeStr = existLineAlloc.AllocTypeStr_Quantity then
		existingAlloc := existLineAlloc;
		// Summary checked for deleting here as well.
		app.myUtilityDA.utlDeleteStockOrderAllocation(existingAlloc, _passport);
		return;
	endif;

	if self.allocAmount &lt;= 0 then
		return;
	endif;

	terminal := self.myLogStockOrderLine.myStockOrderHeader.myTerminal;

	if existLineAlloc &lt;&gt; null then
		// Update if volume to allocate has changed
		if existLineAlloc.allocQuantity &lt;&gt; self.allocAmount then
			if self.mySummaryAllocation &lt;&gt; null
			and self.allocType = self.mySummaryAllocation.AllocType_Quantity 
			and self.allocType = self.mySummaryAllocation.allocType then
			// if a exsisting detail line being updated so re calc the summary total.
			//Both summary and line allocation are quantity based so update allocated quantity
				
				// new value from updated detail 
				subTot := self.allocAmount;
				
				// get values from other details.
				foreach otherLineAlloc in self.mySummaryAllocation.allStockOrderLineAllocations do
					if otherLineAlloc = existLineAlloc then 
						// dont add old value 
						continue;
					endif;
					subTot := subTot +	otherLineAlloc.allocQuantity; 
				endforeach;		
				
				// update summary
				self.mySummaryAllocation.updateAllocQuantity(subTot);
			endif;
			
			/*
				//Both summary and line allocation are quantity based so update allocated quantity
				summAmt := self.mySummaryAllocation.allocQuantity - existLineAlloc.allocQuantity;
				summAmt := summAmt + self.allocAmount;
				self.mySummaryAllocation.updateAllocQuantity(summAmt);
			endif;
			*/
			existLineAlloc.setFromCMIF_StockOrderAlloc(self);
			global.causeEvent(terminal.getTerminalEvent(StockOrderAlloc_Update_Event), false, existLineAlloc);			
		endif;
	else
		//Create new line allocation
		if self.mySummaryAllocation = null then
			//No summary alocation for line, create one
			create self.mySummaryAllocation persistent;
			
			saveAllocType := self.allocType;
			//saveAllocAmount := self.allocAmount;
			saveAllocTypeStr := self.allocTypeStr;
	
			//self.allocAmount := 0;
			self.allocTypeStr := self.mySummaryAllocation.AllocTypeStr_Quantity;
			self.allocType := self.mySummaryAllocation.AllocType_Quantity;
			
			self.mySummaryAllocation.setFromCMIF_StockOrderAlloc(self);
			
			self.allocType := saveAllocType;
			self.allocTypeStr := saveAllocTypeStr;
			//self.allocAmount := saveAllocAmount;									 

			if _passport.noErrors then
				global.causeEvent(terminal.getTerminalEvent(StockOrderAlloc_Create_Event), false, self.mySummaryAllocation);				
			endif;
			
		elseif self.allocType = self.mySummaryAllocation.AllocType_Quantity 
			and self.allocType = self.mySummaryAllocation.allocType then
			// is a new detail line being added.	// checkother lines and recalculate the summary total.
			//Both summary and line allocation are quantity based so update allocated quantity
		
			// new amount 
			subTot := self.allocAmount;
		
			// plus exsisting amounts 
			foreach otherLineAlloc in self.mySummaryAllocation.allStockOrderLineAllocations do
				subTot := subTot +	otherLineAlloc.allocQuantity; 
			endforeach;			

			//if total is less than what is avialable in loctaion then redo summary total
			if subTot &lt; self.mySummaryAllocation.mySOHLocation.currentVolume then
				self.mySummaryAllocation.updateAllocQuantity(subTot);
			endif;
		endif;					
/*		
		elseif self.allocType = self.mySummaryAllocation.AllocType_Quantity 
		and self.allocType = self.mySummaryAllocation.allocType then
			//Both summary and line allocation are quantity based so update allocated quantity
			summAmt := self.mySummaryAllocation.allocQuantity;
			summAmt := summAmt + self.allocAmount;
			if summAmt &lt; self.mySummaryAllocation.mySOHLocation.currentVolume then 
			// if total is more than is in summary line but less than what available in row then update summary. 
				self.mySummaryAllocation.updateAllocQuantity(summAmt);
			endif;
		endif;
*/
		create realLineAlloc persistent;		
		realLineAlloc.setFromCMIF_StockOrderAlloc(self);
		global.causeEvent(terminal.getTerminalEvent(StockOrderAlloc_Create_Event), false, realLineAlloc);			

	endif;

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateStockOrderSummary" id="4c12b92a-4eaa-482b-9e37-80a1c3ecdbd1">
        <updating/>
        <source>updateStockOrderSummary(_passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 06 September 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	tmpAlloc,
	existingAlloc		: CM_StockOrderAllocation;
	existSummaryAlloc,
	newSummaryAlloc	 	: CM_StockOrderSummaryAlloc;
	summAmt				: Decimal[16,4];
begin

	if (not self.canAllocateToOrder) then
		return;		
	endif;
	
	if self.mode &lt;&gt; Mode_SummaryAllocation then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid mode (' &amp; self.mode.String &amp; ')');
		return;
	endif;
	
	//see if already allocated
	existSummaryAlloc := self.myStockOrderSummary.getSummaryAllocationObject(self.mySOHLocation);

	if existSummaryAlloc &lt;&gt; null and
	   self.allocAmount &lt;= 0 and 
   	   self.allocTypeStr = existSummaryAlloc.AllocTypeStr_Quantity then 
		existingAlloc := existSummaryAlloc;
		app.myUtilityDA.utlDeleteStockOrderAllocation(existingAlloc, _passport);
		return;
	endif;
	
	if self.allocAmount &lt;= 0 then
		return;
	endif;

	if existSummaryAlloc &lt;&gt; null then
		// Update if volume to allocate has changed
		if existSummaryAlloc.allocQuantity &lt;&gt; self.allocAmount then
			if not existSummaryAlloc.allStockOrderLineAllocations.isEmpty then 
				// need to check that total of detail lines are not more than summary cause then should not be able to change.
				foreach tmpAlloc in existSummaryAlloc.allStockOrderLineAllocations discreteLock do 
					summAmt := summAmt + tmpAlloc.allocQuantity;
				endforeach;
				
				if summAmt &gt; self.allocAmount then 
				// ammount in details is more than the summary amount. So need to update summ amount or not allow change to it. 	
				// so can increase total amount for all details but not decrease what is already there. 
					self.allocAmount := summAmt; 
				endif;
										
			endif;
		
			existSummaryAlloc.setFromCMIF_StockOrderAlloc(self);
			global.causeEvent(existSummaryAlloc.myStockOrderHeader.myTerminal.getTerminalEvent(StockOrderAlloc_Update_Event), false, existSummaryAlloc);
		endif;	
		
		/*
		if existSummaryAlloc.allocQuantity &lt;&gt; self.allocAmount then
			existSummaryAlloc.setFromCMIF_StockOrderAlloc(self);
			global.causeEvent(existSummaryAlloc.myStockOrderHeader.myTerminal.getTerminalEvent(StockOrderAlloc_Update_Event), false, existSummaryAlloc);
		endif;
		*/
		return;
	endif;

	// No Summary so create new one
	create newSummaryAlloc persistent;
	newSummaryAlloc.setFromCMIF_StockOrderAlloc(self);
								 
	if _passport.noErrors then
		global.causeEvent(newSummaryAlloc.myStockOrderHeader.myTerminal.getTerminalEvent(StockOrderAlloc_Create_Event), false, newSummaryAlloc);				
	endif;

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateSummarySplit" id="0cd08cf9-ace9-410f-bd75-780dfc432c7c">
        <updating/>
        <source>updateSummarySplit() updating;
//--------------------------------------------------------------
//Created: November 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	existingAlloc	 	: CM_StockOrderAllocation;
	existLineAlloc,
	realLineAlloc 		: CM_StockOrderLineAlloc;	
	terminal			: CM_Terminal;
begin

	if (not self.canAllocateToOrder) then
		return;		
	endif;
	
	if self.mode &lt;&gt; Mode_SummarySplit then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid mode (' &amp; self.mode.String &amp; ')');
		return;
	endif;

	existLineAlloc := self.myLogStockOrderLine.getLineAllocationObject(self.mySOHLocation);

	if existLineAlloc &lt;&gt; null 
	and self.allocAmount &lt;= 0
	//and self.allocTypeStr = existLineAlloc.AllocTypeStr_Quantity then
	and self.allocTypeStr &lt;&gt; existLineAlloc.AllocTypeStr_Remaining then	   
		delete existLineAlloc;
		return;
	endif;

	if self.allocAmount &lt;= 0 then
		return;
	endif;

	terminal := self.myLogStockOrderLine.myStockOrderHeader.myTerminal;

	if existLineAlloc &lt;&gt; null then
		existLineAlloc.setFromCMIF_StockOrderAlloc(self);
		global.causeEvent(terminal.getTerminalEvent(StockOrderAlloc_Update_Event), false, existLineAlloc);
	else
		create realLineAlloc persistent;		
		realLineAlloc.setFromCMIF_StockOrderAlloc(self);
		global.causeEvent(terminal.getTerminalEvent(StockOrderAlloc_Create_Event), false, realLineAlloc);			
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="validate" id="93dd79ba-5ee8-4430-b6b9-10e6c24efaf6">
        <updating/>
        <source>validate(_passport : CM_Passport input)updating;
//--------------------------------------------------------------
//Created: 06 September 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	totalRemaining,
	totalAllocated	: Decimal[16,4];
	existingAlloc	: CM_StockOrderAllocation;
begin

	if self.mySOHLocation &lt;&gt; null then
		exclusiveLock(self.mySOHLocation);
		if _passport.noErrors and self.mySOHLocation.edition &lt;&gt; self.expectedEditionSOHLocn then
			app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Row', null, null);
		endif;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null SOH Location. Contact Developer.');
		return;	
	endif;
	
	if self.mode = Mode_SummaryAllocation then
		self.validateSummary();
	elseif self.mode = Mode_LineAllocation then
		self.validateLine(_passport);
	elseif self.mode = Mode_SummarySplit then
		self.validateLine(_passport);
		return;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid mode (' &amp; self.mode.String &amp; ')');
		return;
	endif;
	
	if (not _passport.noErrors) then
		return;
	endif;

	self.validateQtyTotal();
	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateLine" id="886dba4d-4038-4901-8634-06e3c9547a88">
        <updating/>
        <source>validateLine(_passport : CM_Passport input)updating;
//--------------------------------------------------------------
//Created: 06 September 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	availVol : Real;
	tmpProduct,
	tmpSOHProduct : CM_Product;
	existLineAlloc: CM_StockOrderLineAlloc;
	tmpLotIDs,
	tmpSummaryID,
	tmpOrderIDs : String;		
begin

	if (not self.canAllocateToOrder) and self.allocAmount &gt; 0 then
		self.mySOHLocation.getAllocatedLotAndSummaryIDs(tmpLotIDs, tmpSummaryID);
		if tmpLotIDs &lt;&gt; null then
			tmpOrderIDs := '(Order: ' &amp; tmpLotIDs &amp; ' )';
		else
			tmpOrderIDs := '(Order: ' &amp; tmpSummaryID &amp; ' )';
		endif;		
		app.raiseCMWarning3(ERR_CANNOT_ALLOCATE, self.mySOHLocation.myLocationsController.getID,
							self.myLogStockOrderLine.dischargePort, tmpOrderIDs, ETRow_Location, null, self.mySOHLocation);
		return;		
	endif;
	
	if self.mode &lt;&gt; Mode_LineAllocation and self.mode &lt;&gt; Mode_SummarySplit then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid mode (' &amp; self.mode.String &amp; ')');
		return;
	endif;
	
	if self.myLogStockOrderLine = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null Stock Order Line. Contact Developer.');
 		return;
	else exclusiveLock(self.myLogStockOrderLine);	
		if _passport.noErrors and
		   self.myLogStockOrderLine.edition &lt;&gt; self.expectedEditionStockOrder then
			app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Stock order Allocation', null, null);
			return;
		endif;
	endif;		

	tmpProduct 		:= self.myLogStockOrderLine.myProduct;
	tmpSOHProduct 	:= self.mySOHLocation.myProduct;		
	
	if tmpProduct &lt;&gt; tmpSOHProduct and self.allocAmount &gt; 0 then
		app.raiseCMWarning2(ProductInconsistancyWarning,  tmpSOHProduct.getDisplayStringForAttribute(ETRow_OperatorCode, true) &amp; ' ' &amp;	tmpSOHProduct.code &amp; ' in row ' &amp; 
							self.mySOHLocation.myLocationsController.getID, ' order ' &amp; tmpProduct.getDisplayStringForAttribute(ETRow_OperatorCode, true) &amp; ' ' &amp;
							tmpProduct.code, app.getErrorString(Product), null, tmpSOHProduct);
	endif;	
	
	if self.mode = Mode_SummarySplit then
		if self.mySummaryAllocation = null then
			app.raiseUnexpectedProgramError(class.name, method.name, 'Null Summary Allocation. Contact Developer.');
			return;
		endif;
	elseif self.myStockOrderSummary = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null Stock Order Summary. Contact Developer.');
		return;
	else 
		exclusiveLock(self.myStockOrderSummary);	
	endif;

	//if self.mode = Mode_LineAllocation then
		availVol := self.mySOHLocation.calAvailableVolumeForStkOrder(self.myLogStockOrderLine, false);
		existLineAlloc := self.myLogStockOrderLine.getLineAllocationObject(self.mySOHLocation);		
		if existLineAlloc &lt;&gt; null then 
			availVol := availVol + existLineAlloc.allocQuantity;				
		endif;
		if self.allocAmount &gt; availVol then
			app.raiseCMException4(StockOrderAllocExceedsAvailVol, self.allocAmount.jasVolumeString, self.myLogStockOrderLine.getDisplayDetails(true), availVol.jasVolumeString, self.mySOHLocation.getID(), ETRow_AllocQuantity, null);		
		endif;
	//endif;		
	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateQtyLine" id="2630bb76-48cb-444a-b251-8ad69c3a6184">
        <source>validateQtyLine(_totalAlloc : Real; _passport : CM_Passport input) ;
//--------------------------------------------------------------
//Created: 06 September 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	lineCode		: String;
begin

	if self.mode &lt;&gt; Mode_LineAllocation and
	   self.mode &lt;&gt; Mode_SummarySplit then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid mode (' &amp; self.mode.String &amp; ')');
		return;
	endif;
	
	if self.myLogStockOrderLine.lotNo &lt;&gt; null then
		lineCode := self.myLogStockOrderLine.lotNo;
	else
		lineCode := self.myLogStockOrderLine.consigneeCode &amp; '/' &amp; self.myLogStockOrderLine.dischargePort;
	endif;
	
	if self.myLogStockOrderLine.maxContractQuantity &gt; 0 and _totalAlloc &gt; self.myLogStockOrderLine.maxContractQuantity then
		app.raiseCMWarning3(StockOrderAllocMaxQty, _totalAlloc.jasVolumeString, lineCode, self.myLogStockOrderLine.maxContractQuantity.String,
							ETRow_AllocQuantity, null, myLogStockOrderLine);
		return;			
	endif;
	if self.myLogStockOrderLine.minContractQuantity &gt; 0 and _totalAlloc &lt; self.myLogStockOrderLine.minContractQuantity then
		app.raiseCMWarning3(StockOrderAllocMinQty, _totalAlloc.jasVolumeString, lineCode, self.myLogStockOrderLine.minContractQuantity.String,
							ETRow_AllocQuantity, null, self.myLogStockOrderLine);
		return;										
	endif;
	
	if _passport.noErrors then
	//	if _totalAlloc &gt; self.myStockOrderSummary.reqdQuantity then
		if _totalAlloc &gt; self.myLogStockOrderLine.reqdQuantity then//par 15388
			app.raiseCMWarning2(AllocateQtyWarning, _totalAlloc.jasVolumeString,
						//		self.myStockOrderSummary.reqdQuantity.jasVolumeString,
								self.myLogStockOrderLine.reqdQuantity.jasVolumeString,
								ETRow_AllocQuantity, null, self.myLogStockOrderLine);		
			return;
		endif;
	endif;

end;</source>
        <Parameter name="_totalAlloc" type="Real"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateQtySummary" id="ef74f191-d9d8-48ed-bef7-a22044b73b9d">
        <source>validateQtySummary(_totalQty : Real) ;
//--------------------------------------------------------------
//Created: November 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	if self.mode &lt;&gt; Mode_SummaryAllocation then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid mode (' &amp; self.mode.String &amp; ')');	
		return;
	endif;
	
	if _totalQty &gt; self.myStockOrderSummary.reqdQuantity then
		app.raiseCMWarning2(AllocateQtyWarning, _totalQty.jasVolumeString,
							self.myStockOrderSummary.reqdQuantity.jasVolumeString,
							ETRow_AllocQuantity, null, self.myStockOrderSummary);		
	endif;

end;</source>
        <Parameter name="_totalQty" type="Real"/>
    </JadeMethod>
    <JadeMethod name="validateQtyTotal" id="d87d848c-a4bc-4876-b0d9-7d2e233ddb01">
        <source>validateQtyTotal();
//--------------------------------------------------------------
//Created: 06 September 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	totalRemaining,
	totalAvail		: Decimal[16,4];
	existingAlloc	: CM_StockOrderAllocation;
begin

	if self.myLogStockOrderLine &lt;&gt; null then
		existingAlloc := self.myLogStockOrderLine.getLineAllocationObject(self.mySOHLocation);
	else
		existingAlloc := self.mySummaryAllocation;
	endif;

	//totalAllocated := self.mySOHLocation.calAllocatedForSummary(self.mySummaryAllocation);
	//totalAllocated := self.mySummaryAllocation.allocQuantity;
	totalAvail := self.mySOHLocation.calAvailableVolumeForStkOrder(self.myLogStockOrderLine, false);

	if existingAlloc &lt;&gt; null then
		totalAvail := totalAvail + existingAlloc.allocQuantity;
	endif;
	
	/*if self.allocType = CM_StockOrderAllocation.AllocType_Quantity then
		totalAllocated := totalAllocated + self.allocAmount;
	endif;*/

	//if totalAllocated &gt; self.mySOHLocation.currentVolume then
	if self.allocAmount &gt; totalAvail then
		app.raiseCMException3(StockOrderAllocAmountExceeded, self.allocAmount.jasVolumeString,
		                      self.mySOHLocation.myLocationsController.getID(),
		                      self.mySOHLocation.currentVolume.jasVolumeString, null, null);
		return;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="validateQuantity" id="1bed0895-e81c-41a8-b832-493e56e4c977">
        <source>validateQuantity(_totalQty : Real; _passport : CM_Passport input);
//--------------------------------------------------------------
//Created: 25 November 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	availVol : Real;
begin
	
	if self.mode = Mode_SummaryAllocation then
		self.validateQtySummary(_totalQty);
	else
		self.validateQtyLine(_totalQty, _passport);
	endif;
	
	/*if self.mode = Mode_SummarySplit then
		availVol := self.mySummaryAllocation.allocQuantity;
		if _totalQty &gt; availVol then
			app.raiseCMException4(StockOrderAllocExceedsAvailVol, _totalQty.jasVolumeString, self.myLogStockOrderLine.getDisplayDetails(true), availVol.jasVolumeString, self.mySOHLocation.getID(), ETRow_AllocQuantity, null);		
		endif;		
	endif;*/

end;</source>
        <Parameter name="_totalQty" type="Real"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateSummary" id="ec5d4e01-8d17-442e-9d4f-bf0cb545f22c">
        <updating/>
        <source>validateSummary()updating;
//--------------------------------------------------------------
//Created: 06 September 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	tmpLotIDs,
	tmpSummaryID,
	tmpOrderIDs : String;		
begin

	if (not canAllocateToOrder) and self.allocAmount &gt; 0 then
		self.mySOHLocation.getAllocatedLotAndSummaryIDs(tmpLotIDs, tmpSummaryID);
		if tmpLotIDs &lt;&gt; null then
			tmpOrderIDs := '(Order: ' &amp; tmpLotIDs &amp; ' )';
		else
			tmpOrderIDs := '(Order: ' &amp; tmpSummaryID &amp; ' )';
		endif;		
		app.raiseCMWarning3(ERR_CANNOT_ALLOCATE, self.mySOHLocation.myLocationsController.getID(),
							  self.myStockOrderSummary.myProduct.code, tmpOrderIDs, ETRow_Location, null, mySOHLocation);
		return;		
	endif;			
	
	if self.mode &lt;&gt; Mode_SummaryAllocation then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid mode (' &amp; self.mode.String &amp; ')');	
		return;
	endif;
	
	if self.myStockOrderSummary = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null Stock Order Summary. Contact Developer.');
		return;
	else 
		exclusiveLock(self.myStockOrderSummary);	
	endif;
	
	if self.myStockOrderSummary.myProduct &lt;&gt; self.mySOHLocation.myProduct and self.allocAmount &gt; 0 then
		app.raiseCMWarning2(ProductInconsistancyWarning, self.mySOHLocation.myProduct.code &amp; ' in row ' &amp;
							self.mySOHLocation.myLocationsController.getID,
							' order ' &amp; self.myStockOrderSummary.myProduct.code, app.getErrorString(Product), null, self.mySOHLocation);
	endif;
	
end;</source>
    </JadeMethod>
</Class>
