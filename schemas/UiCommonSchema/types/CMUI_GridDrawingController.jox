    <JadeMethod name="getTILoadJobNumber" id="f713378f-e5a8-4170-85fe-2f8e77775e72">
        <source>getTILoadJobNumber(_theTI : CM_TrackedItem) : String;
/*
Purpose:			
Date		Who		Reason
06 May 2014	cnwab1	Initial creation
17 Dec 2024 navma1	MTN-33679 POL | Error (1090). Attempted access via null object reference
*/

vars
	jobStr : String;
	fm 	   : CM_FutureMove;
	wle	   : CM_WorkListEntry;
begin
	
	jobStr := _theTI.loadJobNum;

	if _theTI.allJobsShipRelease.isNotEmpty and _theTI.allJobsShipSOB.isNotEmpty then
		fm := _theTI.allPlannedFutureMoves.last;
		
		if fm &lt;&gt; null then
			wle := fm.myWorkListEntry;
			if wle &lt;&gt; null then										//17.12.2024 navma1 #MTN-33679
				jobStr := wle.job.CM_VoyageJob.jobNum;
			endif;
		endif;
	endif;
	
	return jobStr;

epilog

end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getViewModeFromObject" id="90ee05bd-66b5-4e83-a647-303299c687ed">
        <source>getViewModeFromObject(_anObject : Object) : Integer;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//06-06-2022 navtnr20	53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
// ---------------------------------------------------------------------------

vars

begin
	if _anObject.isKindOf(CM_CommodityGroup) then
		return TI_ColourMode_CommodityGroup;
	elseif _anObject.isKindOf(CM_Voyage) then
		return TI_ColourMode_Voyage;
	elseif _anObject.isKindOf(CM_Operator) then
		return TI_ColourMode_Operator;
	elseif _anObject.isKindOf(CM_Product) then
		return TI_ColourMode_Product;
	elseif _anObject.isKindOf(CM_Port) then
		return TI_ColourMode_DischargePort;
	elseif _anObject.isKindOf(CM_ConsigneeConsignor) then
		return TI_ColourMode_Consignee;
	elseif _anObject.isKindOf(CM_ISOTypeGroup) then
		return TI_ColourMode_ISOTypeGroup;
	elseif _anObject.isKindOf(CM_ContentsStatus) then
		return TI_ColourMode_Status;
	elseif _anObject.isKindOf(CM_TempRange) then
		return TI_ColourMode_Temperature;
	elseif _anObject.isKindOf(CM_WeightRange) then
		return TI_ColourMode_Weight;
	elseif _anObject.isKindOf(CM_DwellDayRange) then	//20 Jul 2011	NDL	Par 27890
		return TI_ColourMode_DwellDays;
	elseif _anObject.isKindOf(CM_MTGrade) then	//29 Jul 2011	NDL	Par 27890
		return TI_ColourMode_MTGrade;
	elseif _anObject.isKindOf(CM_ShippingLine) then		//07-06-2022 navtnr20 53204
		return TI_ColourMode_ShippingLine;
	endif;
end;</source>
        <Parameter name="_anObject" type="Object"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getViewModeString" id="ae8e8e21-f36d-4603-9753-c5223f28dffc">
