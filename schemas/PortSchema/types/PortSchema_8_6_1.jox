    <JadeMethod name="updateLicenseMigrateChildren" id="60b9d0de-11e3-49b9-9ec1-1cb236d6367c">
        <source>updateLicenseMigrateChildren( _controller : CnEcReleaseController ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 October 2019	jlgndl1	Initial creation	TFS 46169

*/

vars

	modulesPermAgent : CM_PermissionAgent;
	module : CM_PermissionObject;
	baseModule : CM_PermissionObject;
	
	permsAgent : CM_PermissionAgent;
	permObject : CM_PermissionObject;
	
	movingFromModuleArray : IntegerArray;
	movingFromInt : Integer;
	
	permsNeedingUpdate : CM_PermissionObjectByValueDict;

begin

	app.writeLog( method.qualifiedName &amp; 'Migating Child Permissions from De-commissioned Licenses... ', LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Migating Child Permissions from De-commissioned Licenses...") ;	
	endif;


	create permsAgent transient;
	permsAgent.populatePermissionDict(true, false, 0); // PERMISSIONS

	create permsNeedingUpdate transient;
	
	//Going to PmBaseSystem
	create movingFromModuleArray transient;
	movingFromModuleArray.add( PmCargoNotificationReq );
	movingFromModuleArray.add( PmCargoNotificationWeb ); 
	movingFromModuleArray.add( PmCargoStopsReq );
	movingFromModuleArray.add( PmCargoStopsWeb );
	movingFromModuleArray.add( PmExtTCPIntFace ); 
	movingFromModuleArray.add( PmKPIModule ); 
	movingFromModuleArray.add( PmReeferMonitorMod );
	movingFromModuleArray.add( PmRefCon );
	movingFromModuleArray.add( PmTrailer );
	movingFromModuleArray.add( PmUserCodeHookMod );
	movingFromModuleArray.add( PmVehicleHandling );
	movingFromModuleArray.add( PmVehicleMountedIMV );
	
	//for each permission using any of these modules, move them to base and remove the relationship with the moving from module.
	foreach movingFromInt in movingFromModuleArray do
		foreach permObject in permsAgent.allPermsByCategoryDescrName do
			if permObject.allChildValues.includes( movingFromInt ) then
				//This permission is a child of the moving from module
				if not permObject.allChildValues.includes( Mod_BaseSystem ) then
					//Add it to the base module
					permObject.allChildValues.add( Mod_BaseSystem );
				endif;
				permObject.allChildValues.remove( movingFromInt );
				permsNeedingUpdate.addNoDuplicates( permObject,false );
			endif;
		endforeach;	
	endforeach;
	
	movingFromModuleArray.clear();
	
	
	
	//Going to PmCargoShipMod
	movingFromModuleArray.add( PmAutoShipPlanning );
	movingFromModuleArray.add( PmShipJobControllerModule );
	movingFromModuleArray.add( PmShipPlanning );
	
	foreach movingFromInt in movingFromModuleArray do
		foreach permObject in permsAgent.allPermsByCategoryDescrName do
			if permObject.allChildValues.includes( movingFromInt ) then
				if not permObject.allChildValues.includes( Mod_CargoShip ) then
					permObject.allChildValues.add( Mod_CargoShip );
				endif;
				permObject.allChildValues.remove( movingFromInt );
				permsNeedingUpdate.addNoDuplicates( permObject,false );
			endif;
		endforeach;	
	endforeach;
	
	movingFromModuleArray.clear();
	
	
	
	//Going to PmRTMobileClient
	movingFromModuleArray.add( PmHandHeldGateClient );
	movingFromModuleArray.add( PmHandHeldShip1Client );
	movingFromModuleArray.add( PmStwOmanBespoke );
	
	foreach movingFromInt in movingFromModuleArray do
		foreach permObject in permsAgent.allPermsByCategoryDescrName do
			if permObject.allChildValues.includes( movingFromInt ) then
				if not permObject.allChildValues.includes( Mod_WebApps ) then
					permObject.allChildValues.add( Mod_WebApps );
				endif;
				permObject.allChildValues.remove( movingFromInt );
				permsNeedingUpdate.addNoDuplicates( permObject,false );
			endif;
		endforeach;	
	endforeach;
	
	movingFromModuleArray.clear();
	
	
	
	//Going to PmVTMISMod &amp; PmBaseSystem
	movingFromModuleArray.add( PmBackup );
	
	foreach movingFromInt in movingFromModuleArray do
		foreach permObject in permsAgent.allPermsByCategoryDescrName do
			if permObject.allChildValues.includes( movingFromInt ) then
				if not permObject.allChildValues.includes( Mod_Harbour ) then
					permObject.allChildValues.add( Mod_Harbour );
				endif;
				if not permObject.allChildValues.includes( Mod_BaseSystem ) then
					permObject.allChildValues.add( Mod_BaseSystem );
				endif;
				permObject.allChildValues.remove( movingFromInt );
				permsNeedingUpdate.addNoDuplicates( permObject,false );
			endif;
		endforeach;	
	endforeach;
	
	movingFromModuleArray.clear();

	
	
	//Going to PmDSS
	movingFromModuleArray.add( PmODBCModule );
	
	foreach movingFromInt in movingFromModuleArray do
		foreach permObject in permsAgent.allPermsByCategoryDescrName do
			if permObject.allChildValues.includes( movingFromInt ) then
				if not permObject.allChildValues.includes( Mod_DataExtract ) then
					permObject.allChildValues.add( Mod_DataExtract );
				endif;
				permObject.allChildValues.remove( movingFromInt );
				permsNeedingUpdate.addNoDuplicates( permObject,false );
			endif;
		endforeach;	
	endforeach;
	
	movingFromModuleArray.clear();
	
	
	
	//Going to PmVehicleSchedMod
	movingFromModuleArray.add( PmTruckBooking );
	
	foreach movingFromInt in movingFromModuleArray do
		foreach permObject in permsAgent.allPermsByCategoryDescrName do
			if permObject.allChildValues.includes( movingFromInt ) then
				if not permObject.allChildValues.includes( Mod_VehicleBooking ) then
					permObject.allChildValues.add( Mod_VehicleBooking );
				endif;
				permObject.allChildValues.remove( movingFromInt );
				permsNeedingUpdate.addNoDuplicates( permObject,false );
			endif;
		endforeach;	
	endforeach;
	
	movingFromModuleArray.clear();
	
	
	//update the constants associated with these permissions
	if not permsNeedingUpdate.isEmpty then
		beginTransaction;
		foreach permObject in permsNeedingUpdate do
			if permObject.myConstant = null then
				continue;
			endif;
			permObject.myConstant.setText(permObject.outputAsXML);
		endforeach;
		commitTransaction;
	endif;
	
	
	app.writeLog( method.qualifiedName &amp; 'Completed Migating Child Permissions from De-commissioned Licenses ', LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry('Completed Migating Child Permissions from De-commissioned Licenses') ;	
	endif;

epilog

	delete modulesPermAgent;
	delete permsAgent;
	delete movingFromModuleArray;
	delete permsNeedingUpdate;
	

end;</source>
        <access>protected</access>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="updateLicenseModuleNames" id="0b7e7518-a04b-47a1-a57a-c26f128098fd">
        <source>updateLicenseModuleNames( _controller : CnEcReleaseController ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 October 2019	jlgndl1	Initial creation	TFS 46169

*/

vars

	category : ConstantCategory;
	const : Constant;
	constDict : ConstantNDict;

	constantToUpdate : Constant;
	oldText : String;
	newText : String;
	updateText : String;

begin

	app.writeLog( method.qualifiedName &amp; 'Updating License Module Names... ', LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Updating License Module Names...") ;	
	endif;
	
	category := currentSchema.getCategory(XLAT_Permissions);		
	constDict := category.getConstants();
	
	foreach const in constDict do
		updateText := null;
		oldText := null;
		newText := null;
		if const.getSource = Mod_Cash.String then
			oldText := "Cash Only Debtor Module";
			newText := "Cash Module";
		elseif const.getSource = Mod_DataExtract.String then
			oldText := "Decision Support System";
			newText := "Data Extract Module";
		elseif const.getSource = Mod_Invoicing.String then
			oldText := "Invoicing Mod";
			newText := "Invoice Module";
		elseif const.getSource = Mod_Harbour.String then
			oldText := "VTMIS Module";
			newText := "Harbour Management Module";
		elseif const.getSource = Mod_YardPlanning.String then
			oldText := "Auto Yard Planning";
			newText := "Yard Allocations Module";
		elseif const.getSource = Mod_Weighing.String then
			oldText := "In Machine Weighing (Loadrite, iScale etc)";
			newText := "Machine Weighing Module";
		elseif const.getSource = Mod_CargoShip.String then
			oldText := "Cargo Ship Module";
			newText := "Voyage Definition Module";
		elseif const.getSource = Mod_VesselRORO.String then
			oldText := "Vessel RORO Module";
			newText := "RORO Decks Module";
		elseif const.getSource = Mod_Queuing.String then
			oldText := "RT Module";
			newText := "Machine and Queueing Module";
		elseif const.getSource = Mod_WebApps.String then
			oldText := "Radio Telemetry Mobile Client";
			newText := "Handheld Apps Module";
		endif;
		if oldText = null or newText = null then
			continue;
		endif;
		if const.text.pos(oldText,1) &gt; 0 then
			updateText := const.text.replaceString(oldText, newText);
		endif;
		if updateText &lt;&gt; null then
			beginTransaction;
			const.setText( updateText );
			commitTransaction;
		endif;
	endforeach;
	
	app.writeLog( method.qualifiedName &amp; 'Completed Updating License Module Names ', LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry('Completed Updating License Module Names') ;	
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="updateLicenseModules" id="c03f7d7c-009f-4f12-85cd-6e88c2815353">
        <source>updateLicenseModules( _controller : CnEcReleaseController );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 October 2019	jlgndl1	Initial creation	TFS 46169

*/

vars

begin

	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog( method.qualifiedName &amp; 'Updating License Modules ', LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Updating License Modules") ;	
	endif;
	
	//Re-names the ones changing name
	self.updateLicenseModuleNames( _controller );
	
	//Transfers the permissions from Licence Modules to be de-implemented
	self.updateLicenseMigrateChildren( _controller );
	
	//Decommissionm Licence Modules to be de-implemented by changing the type to '3' (No Longer Used)
	self.updateLicenseDecommissions( _controller );
	
	app.writeLog( method.qualifiedName &amp; 'Completed Updating License Modules ', LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry('Completed Updating License Modules') ;	
	endif;
	
	self.addScriptRun(method.name);

epilog

end;</source>
