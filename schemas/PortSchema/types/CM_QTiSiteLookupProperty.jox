    <JadeMethod name="create" id="aeee9079-1b4c-4862-a10c-1d1c49d9509c">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     04 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	oper : CM_QueryOperator;

begin
	if self.isTransient then 
		return;
	endif;
		
	create oper as CM_QIntegerLookupEqual persistent;
	self.allAllowedOperators.add(oper);
	
	create oper as CM_QIntegerLookupNotEqual persistent;
	self.allAllowedOperators.add(oper);

	create oper as CM_QIntegerIsOneOf persistent;
	self.allAllowedOperators.add(oper);

end;</source>
    </JadeMethod>
    <JadeMethod name="getKeyLengthForXTABDictionary" id="726bf23c-dad2-4214-bfdf-371700011631">
        <source>getKeyLengthForXTABDictionary(): Integer;
// ---------------------------------------------------------------------------
// Created:     04 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	length	:Integer;
begin
	// just incase the global constant values change !!!
	length := TI_SITE_ONSITE_str.length;
	length := length.max (TI_SITE_ONSHIP_str.length);
	length := length.max (TI_SITE_OFFSITE_str.length);
	length := length.max (TI_SITE_TBA_str.length);
	length := length.max (TI_SITE_UNDEFINED_str.length);
	length := length.max (SEL_QUERYSITE_NOTIFIED_STR.length);	//11 Apr 2018	NDL	TFS 37919
	
	return length;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
