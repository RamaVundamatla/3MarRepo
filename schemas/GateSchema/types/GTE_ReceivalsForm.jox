//
//********************************************************************
vars
	voyage 				 : CM_Voyage;
	currentDischargePort : CM_Port;
	
begin
	self.myAssistant.GTE_Assistant.mainExtraSetValueByControl(tblMain, tblExtra, combobox.name, combobox.text);
	
	//+cnwml2, PAR 20030 start
	voyage := combobox.listObject.CM_Voyage;
	self.loadOptDischargePorts(voyage);
	
	// Discharge port	
	currentDischargePort := self.cmbDischarge.listObject.CM_Port;
	self.cmbDischarge.setObjectAndVoyage(currentDischargePort, voyage);	
	//+cnwml2, PAR20030 end
	
	if self.cmbDischarge.myObject = null then	// 25/09/2009 cnwar2 #20721 - above will clear combo if object not in list
		self.cmbDischarge.text := null;	
		self.myAssistant.GTE_Assistant.mainExtraSetValueByControl(tblMain, tblExtra, self.cmbDischarge.name, null);
	endif;
	self.cmbTranship.setObjectAndVoyageDischPort(self.cmbDischarge.listObject.CM_Port,combobox.listObject.CM_Voyage);
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
