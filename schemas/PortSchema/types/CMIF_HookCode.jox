    <JadeMethod name="addHookHistory" id="42cf6557-8d8e-4e80-a954-ddfdd7f6de11">
        <source>addHookHistory() protected;
// -------------------------------------------
// Created 07 February 2005 by cnwdvb1
// -------------------------------------------
vars

	history	: CM_HookCodeHistory;

begin

	self.myProxyHookCode.allHookCodeHistory.purge();
	create history transient;
	history.setForProxy(self.jadeCode, app.getMyUserCode(), self.myProxyHookCode);
	

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="addHookLinks" id="d06a1bfd-3ad9-4f57-98c1-a0d91e245499">
        <source>addHookLinks() protected;
// -------------------------------------------
// Created 07 February 2005 by cnwdvb1
// -------------------------------------------
vars

	link	: CM_HookLink;
	linkSet	: CM_HookLinkSet;
	obj		: Object;
	obj2	: CM_Object;
	hookType: Integer;
	
	
begin

	create linkSet transient;
	hookType := self.myHookType.hookType;

	// Get existing links.
	self.myProxyHookCode.allHookLinks.copy(linkSet);
	
	foreach obj in self.allLinkObjects do
		if hookType = HookType_CargoIdConversion then	//05 Jul 2016	NDL	TFS 2275
			obj2 := null;
		else
			obj2 := obj.CM_Object;
		endif;
		link :=	self.myProxyHookCode.allHookLinks[hookType, obj2];
		// Create new one.
		if link = null then
			create link transient;
		else
			// Found old one to renew.
			linkSet.remove(link);
		endif;	
		// Set details
		link.setForProxy(hookType, obj2, self.myProxyHookCode);

	endforeach;
	
	// Delete not used set.
	linkSet.purge();
		
	

epilog
	delete linkSet;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="delete" id="44d11a86-2dfa-408d-84f5-c1eb323ccf69">
        <updating/>
        <source>delete() updating;
// -------------------------------------------
// Created 07 February 2005 by cnwdvb1
// -------------------------------------------
vars

	myProcess : Process;
	
begin

	myProcess := process;
	if self.myJadeMethod &lt;&gt; null then
		myProcess.deleteTransientMethod(self.myJadeMethod);
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="runHookMethod" id="243db818-60df-42d1-90fc-a9e8a7a91301">
        <source>runHookMethod(_receiver : Object; _ioParams : Boolean; _paramListType : ParamListType io) : Any;
// -------------------------------------------
// Created 07 February 2005 by cnwdvb1
// -------------------------------------------
vars
	tmpProcess	: Process;
	receiver : Object;
begin
	receiver := _receiver;
	tmpProcess := process;
	if _ioParams then
		return tmpProcess.executeTransientIOMethod(self.myJadeMethod, receiver, _paramListType);
	else
		return tmpProcess.executeTransientMethod(self.myJadeMethod, receiver, _paramListType);
	endif;
end;
</source>
        <Parameter name="_receiver" type="Object"/>
        <Parameter name="_ioParams" type="Boolean"/>
        <Parameter name="_paramListType" type="ParamListType" usage="io"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="472cf9eb-3cde-43ac-999c-bbd4d4dbd697">
        <source>setForUpdate();
// -------------------------------------------
// Created 07 February 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	if self.myHookType = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'Hook Type', null, null);
		app.raiseCMException(Input_required_field_hookType, null, null);// cnwdb2	PAR 35364
		return;
	endif;
	
	self.myProxyHookCode.setForProxy(self.code, self.myHookType);
	self.addHookLinks();
	self.addHookHistory();

end;</source>
    </JadeMethod>
    <JadeMethod name="setRunAttributes" id="6c86b83d-4a70-478a-ac1d-1065987bdcc8">
        <updating/>
        <source>setRunAttributes(_hookLink : CM_HookLink; _jadeMethod : JadeMethod; _hookAgent : CM_HookAgent input) updating;
// -------------------------------------------
// Created 07 February 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	self.myJadeMethod	:= _jadeMethod;
	self.myHookLink		:= _hookLink;
	_hookAgent.allCMIFHookCodes.add(self);

end;</source>
        <Parameter name="_hookLink" type="CM_HookLink"/>
        <Parameter name="_jadeMethod" type="JadeMethod"/>
        <Parameter name="_hookAgent" type="CM_HookAgent" usage="input"/>
    </JadeMethod>
</Class>
