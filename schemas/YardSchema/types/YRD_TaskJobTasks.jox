    <JadeMethod name="create" id="d02fdbdd-3de9-42ac-9ab5-f256f3007749">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>create() updating, clientExecution;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04/08/2009	cnwrd1	Initial creation
11/06/2018	jlgdap1	TFS 38560 PEl1 Voyage Work Orders
*/

vars

begin
	self.permissionView		:= PmAdmWorkOrderEnquiry;
	//self.permissionMaint	:= PmAdmWorkOrderEnquiry;		// TFS 38560
	self.permissionMaint	:= PmAdmWorkOrderEnqMaint;		// TFS 38560
	self.helpFileName 		:= HelpFile_Yard;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="createResourceUsedPxys" id="a6bdc0e0-c1c0-48ab-b45f-535c56d8a94b">
        <source>createResourceUsedPxys( _table : CM_DataTable input; _resourceUsedSet : HMS_ResourceUsedSet input ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 June 2018	jlgndl1	Initial creation	TFS 39248

*/

vars

	rowIndex : Integer;
	inclColIndex : Integer;
	rtColIndex : Integer;
	rColIndex : Integer;
	uColIndex : Integer;
	fdColIndex : Integer;
	ftColIndex : Integer;
	tdColIndex : Integer;
	ttColIndex : Integer;
	drColIndex : Integer;
	
	resource : HMS_Resource;
	resourceType : HMS_ResourceType;
	wodMarineServiceDet : CM_WodMarineServiceDetail;
	units : Decimal[23,6];
	fromDate : Date;
	fromTime : Time;
	fromTS : TimeStamp;
	toDate : Date;
	toTime : Time;
	toTS : TimeStamp;
	sysFromTS : TimeStamp;
	sysToTS : TimeStamp;
	
	resourceUsed : HMS_ResourceUsed;
	include : Boolean;
	
	drName : String;
	drIndex : Integer;
	debtor: CM_Debtor;
	
	resourceDesc : String;
	resIndex : Integer;
	
	harbour : HMS_Harbour;
	
begin

	harbour := self.myTerminal.myHarbour;
	
	inclColIndex := _table.getColumnByRowName( ETRow_Include );
	rtColIndex := _table.getColumnByRowName( ETRow_MyResourceType );
	rColIndex := _table.getColumnByRowName( ETRow_MyResource );
	uColIndex := _table.getColumnByRowName( ETRow_UnitsUsed );
	fdColIndex := _table.getColumnByRowName( ETRow_FromDate );
	ftColIndex := _table.getColumnByRowName( ETRow_FromTime );
	tdColIndex := _table.getColumnByRowName( ETRow_ToDate );
	ttColIndex := _table.getColumnByRowName( ETRow_ToTime );
	drColIndex := _table.getColumnByRowName( ETRow_Debtor );	//26 Nov 2018	NDL	TFS 41980


	foreach rowIndex in 1 to _table.rows do
		if rowIndex &lt;= _table.fixedRows then
			continue;
		endif;
		if _table = self.tblResourcesCR then	//26 Nov 2018	NDL	TFS 41980
			include := true;
		else
			include := _table.accessCell( rowIndex, inclColIndex ).text = "1"; //Selected
		endif;
		if not include then
			continue;
		endif;
		sysFromTS := null;
		sysToTS := null;
		//collect up the raw data
		resourceType := _table.accessCell( rowIndex, rtColIndex ).itemObject.HMS_ResourceType;
		if _table = self.tblResourcesCR then
			resource := null;
			debtor := null;
		else
			resource := _table.accessCell( rowIndex, rColIndex ).itemObject.HMS_Resource;
		endif;
		wodMarineServiceDet := _table.accessCell( rowIndex, uColIndex ).itemObject.CM_WodMarineServiceDetail;
		units := _table.accessCell( rowIndex, uColIndex ).text.asDecimalJMT;
		fromDate := _table.accessCell( rowIndex, fdColIndex ).text.asDateJMT;
		fromTime := _table.accessCell( rowIndex, ftColIndex ).text.asTimeJMT;
		if fromDate.isValid then
			fromTS.setDate( fromDate );
			fromTS.setTime( fromTime );
			sysFromTS := fromTS.localToSystemTimeUsingObject(self.myTerminal);
		endif;
		toDate := _table.accessCell( rowIndex, tdColIndex ).text.asDateJMT;
		toTime := _table.accessCell( rowIndex, ttColIndex ).text.asTimeJMT;
		if toDate.isValid then
			toTS.setDate( toDate );
			toTS.setTime( toTime );
			sysToTS := toTS.localToSystemTimeUsingObject(self.myTerminal);
		endif;
		
		//26 Nov 2018	NDL	TFS 41980
		if _table = self.tblResourcesCR then
			resourceDesc := _table.accessCell( rowIndex, rColIndex ).text;
			if resourceDesc &lt;&gt; null and resourceType &lt;&gt; null then
				//re-populate teh combo, because it may have been used for something else
				resourceType.getResourcesForCmbList( self.cmbResource, harbour );
				resIndex := self.cmbResource.findStringExact( 1, resourceDesc );
				if resIndex &gt; 0 then
					resource := self.cmbResource.itemObject[resIndex].HMS_Resource;
				endif;
			endif;
			if resource = null then
				app.msgBox( app.getErrorString( Input_require_resourc_field ), app.getErrorString(Error), MsgBox_OK_Only );
				return false;
			endif;
			drName := _table.accessCell( rowIndex, drColIndex ).text;
			if drName &lt;&gt; null then
				drIndex := self.cmbDebtor.findStringExact( 1, drName );
				if drIndex &gt; 0 then
					debtor := self.cmbDebtor.itemObject[drIndex].CM_Debtor;
				endif;
			endif;
			if debtor = null then
				app.msgBox( app.getErrorString1( Debtor_required_resource, resourceDesc ), app.getErrorString(Error), MsgBox_OK_Only );
				return false;
			endif;
		endif;
		
		if resource = null or resourceType = null then
			// should never happen....
			continue;
		endif;
		
		//validation
		if resourceType.isQuantityRequired  and units &lt;= 0 then
			app.msgBox( app.getErrorString1( Input_required_field_untsUsed, resourceType.description), app.getErrorString(Error), MsgBox_OK_Only );
			return false;
		endif;
		if resourceType.isActionDateTimeRequired and sysFromTS = null then
			app.msgBox( app.getErrorString1( Action_date_time_require, resourceType.description), app.getErrorString(Error), MsgBox_OK_Only );
			return false;
		endif;
		if resourceType.isFromToDateTimeRequired and ( sysFromTS = null or sysToTS = null ) then
			if sysFromTS = null then
				app.msgBox( app.getErrorString1( Input_required_field_frmDate, resourceType.description), app.getErrorString(Error), MsgBox_OK_Only );
				return false;
			endif;
			if sysToTS = null then
				app.msgBox( app.getErrorString1( Input_required_field_toDate, resourceType.description), app.getErrorString(Error), MsgBox_OK_Only );
				return false;
			endif;
		endif;
		
		//26 Nov 2018	NDL	TFS 41980
		if _table = self.tblResourcesCR and wodMarineServiceDet &lt;&gt; null then
			// This is either a Permit type with cargo details and marinve service deatils or a Voyage Cargo type with the same.
			wodMarineServiceDet.setProxyBaseValues(	sysFromTS,	//_fromDateTime : TimeStamp;
													sysToTS,	//_toDateTime : TimeStamp;
													units.Real,	//_unitsUsed : Real;
													resourceType,	//_myResourceType : HMS_ResourceType;
													resource,	//_myResource : HMS_Resource;
													debtor	//_myDebtor : CM_Debtor
													);
		
		else
			//proxy create
			create resourceUsed transient;
			resourceUsed.setUnitsUsed( units.Real );
			resourceUsed.setDetailsFromWorkOrder( sysFromTS, sysToTS );
			resourceUsed.setMyResource( resource );
			_resourceUsedSet.add( resourceUsed );
		
		endif;
		
	endforeach;
	
	return true;
	

epilog

end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_resourceUsedSet" type="HMS_ResourceUsedSet" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="defaultShiftDetails" id="e4b1972d-dc8d-4939-b2ac-37d84f464c12">
        <updating/>
        <source>defaultShiftDetails() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 22/05/2018	jlgdap1		Initial creation TFS 38560 PEL1 Voyage Work Orders
//
vars
	occursOnDT : TimeStamp;
	movement : HMS_VoyageMovement;
	seaHarbourRegion : HMS_HarbourRegion;
	seaHRArrivalBerth, berth, berthFrom, berthTo : HMS_Berth;
	lastValidBowMark, lastValidSternMark : Decimal [12,2];
	harbour : HMS_Harbour;
	baseTime : TimeStamp;
	
begin
	if not self.txtMoveOnDate.getDate.isValid or not self.txtMoveOnTime.getTime.isValid then
		return;
	endif;
	occursOnDT.setDate(self.txtMoveOnDate.getDate);
	occursOnDT.setTime(self.txtMoveOnTime.getTime);
	// if the date/time hasn't changed, just leave everything alone
	if occursOnDT = self.shiftDateTime then
		return;
	endif;
	
	// find the voyage movement that occurs before the entered date/time
	if self.myVoyage = null then
		return;
	endif;
	
	if occursOnDT &lt; self.myVoyage.arrivedDT then
		app.raiseCMException(MSGBOX_ShiftADTError, null, null);
	elseif occursOnDT &gt; self.myVoyage.departedDT then
		app.raiseCMException(MSGBOX_ShiftDDTError, null, null);
	endif;
	
	movement := self.myVoyage.myHMSVoyageData.allVoyageMovements.getAtKeyLeq(occursOnDT);
	if movement = null then
		movement := self.myVoyage.getMovementArrival;
	endif;
	self.myCurrentMovement := movement;
	
	// default things from the movement we found
	self.txtDraftFwd.text := movement.draftFwd.asStringJMT();
	self.txtDraftAft.text := movement.draftAft.asStringJMT();
	
	self.txtBerthFrom.text := movement.getMyBerth.getDisplayString();
	if movement.isLogicalBerth then
		self.txtBowMarkFrom.text := app.getErrorString(NotApplicable);
		self.txtSternMarkFrom.text := app.getErrorString(NotApplicable);
	else
		self.txtBowMarkFrom.text := movement.bowMarkTo.asStringJMT();
		self.txtSternMarkFrom.text := movement.sternMarkTo.asStringJMT();
	endif;
	
	// default times
	harbour := movement.myHarbour;
	baseTime := movement.occursOnDTNEW;
	berthFrom := movement.getMyBerth;
	if movement.moveType = HMSMovementTypeArrival 
	or (movement.moveType = HMSMovementTypeShift and berthFrom.noMarineServices) then
		if harbour.defaultOrderTimesArrive[1] &gt; -1 then
    		self.txtLineRelative.text := "+" &amp; harbour.defaultOrderTimesArrive[1].String;
   		else
    		self.txtLineRelative.text := harbour.defaultOrderTimesArrive[1].String;
		endif;
		if harbour.defaultOrderTimesArrive[2] &gt; -1 then
    		self.txtLaunchRelative.text := "+" &amp; harbour.defaultOrderTimesArrive[2].String;
   		else
    		self.txtLaunchRelative.text := harbour.defaultOrderTimesArrive[2].String;
		endif;
		if harbour.defaultOrderTimesArrive[3] &gt; -1 then
    		self.txtTugRelative.text := "+" &amp; harbour.defaultOrderTimesArrive[3].String;
   		else
    		self.txtTugRelative.text := harbour.defaultOrderTimesArrive[3].String;
		endif;
	elseif self.myCurrentMovement.moveType = HMSMovementTypeShift then
		if harbour.defaultOrderTimesShift[1] &gt; -1 then
    		self.txtLineRelative.text := "+" &amp; harbour.defaultOrderTimesShift[1].String;
   		else
    		self.txtLineRelative.text := harbour.defaultOrderTimesShift[1].String;
		endif;
		if harbour.defaultOrderTimesShift[2] &gt; -1 then
    		self.txtTugRelative.text := "+" &amp; harbour.defaultOrderTimesShift[2].String;
   		else
    		self.txtTugRelative.text := harbour.defaultOrderTimesShift[2].String;
		endif;
	endif;
	
	// Load specific relative times for movement services
    if movement.relativeOrderTimeLines &gt; -1 then
    	self.txtLineRelative.text := "+" &amp; movement.relativeOrderTimeLines.asStringJMT();
    else
    	self.txtLineRelative.text := movement.relativeOrderTimeLines.asStringJMT();
	endif;
	if movement.relativeOrderTimePlaunch &gt; -1 then
		self.txtLaunchRelative.text := "+" &amp; movement.relativeOrderTimePlaunch.asStringJMT();
	else
		self.txtLaunchRelative.text := movement.relativeOrderTimePlaunch.asStringJMT();
	endif;
	if movement.relativeOrderTimeTugs &gt; -1 then 
		self.txtTugRelative.text := "+" &amp; movement.relativeOrderTimeTugs.asStringJMT();
	else
		self.txtTugRelative.text := movement.relativeOrderTimeTugs.asStringJMT();
	endif; 
	
	self.shiftDateTime := occursOnDT;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="027298d2-a912-4048-b3d1-3aa62adaa923">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>delete() updating, clientExecution;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 August 2009	cnwmd1	Initial creation

*/

vars
	dtl : CM_WorkOrderDtl;
begin
	if self.deleteProxy then
		dtl:=self.myProxyWorkOrder.allWoDtls.first;
		delete self.myProxyWorkOrder;
	endif;
	if self.dateMaskArray &lt;&gt; null and not self.dateMaskArray.isEmpty then
		self.dateMaskArray.purge;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="displayBillingAdjustment" id="3094a570-2b2d-4d6f-a6bb-63479776ea28">
        <source>displayBillingAdjustment(_billing : CM_WodBillingAdjustment) protected;
/*
Purpose:	TFS 42241		
Date				Who			Reason
NOVEMBER 2018		CNWAB1		Initial creation
*/

vars
	period, totalExtension : Decimal[6,2];
	idx, newrow : Integer;
	voyage : CM_Voyage;
	workorder : CM_WorkOrder;
	wod : CM_WorkOrderDtl;
	tmpTS : TimeStamp;
	resused : HMS_ResourceUsed;
	
	timespanmin, quarterdayminutes : Integer;
	timespanqdays : Decimal [12,2];
	newFromDateTime, newToDateTime, oldFromDateTime, oldToDateTime : TimeStamp;
begin
	voyage := _billing.getMyVoyageObject();
	
	// display the voyage
	self.displayVoyageCombo(self.shtBillingAdj);
	
	self.shtBillingAdj.showMySheet();
	
	
	
	resused := voyage.getExtensionResourceUsed();
	
	if resused &lt;&gt; null then
		if resused.fromDateTime.isValid
		and resused.toDateTime.isValid
		and resused.toDateTime &gt; resused.fromDateTime then


			timespanmin := resused.fromDateTime.getDifferenceInMinutes(resused.toDateTime);
		//quarterdayminutes := 360;
			timespanqdays := timespanmin / 1440;
			
			// ### Build captions
			self.lblBillingAdjExplain.caption := app.getErrorString1(Current_extensi_period_days,timespanqdays.String);

			tmpTS := self.systemToLocalTime(resused.fromDateTime);
			oldFromDateTime := resused.fromDateTime;
			self.lblBillingAdjExplain.caption := self.lblBillingAdjExplain.caption &amp; CrLf &amp; app.getErrorString1(Current_extension_start, tmpTS.asStringJMT());
			
			tmpTS := self.systemToLocalTime(voyage.departedDT);
			oldToDateTime := voyage.departedDT;
			newToDateTime := voyage.departedDT;
			newFromDateTime := _billing.newFromDateTime;
			
			self.lblBillingAdjExplain.caption := self.lblBillingAdjExplain.caption &amp; CrLf &amp; app.getErrorString1(Current_extension, tmpTS.asStringJMT());
			
			self.cmbBillingAdjPeriod.clear();
			self.cmbBillingAdjPeriod.sorted := false;
			
			idx := -1;
			while true do
				period := period + 0.25;
				if period &gt; timespanqdays then
					break;
				endif;
				
				if period &gt; 100 then
					break;
				endif;
				
				newrow := self.cmbBillingAdjPeriod.addItem(period.String &amp; " Days");
			 
				 if _billing.newUnitsUsed = period then
					idx := newrow;
				endif;
			endwhile;
			self.cmbBillingAdjPeriod.listIndex := idx;
			
			if timespanqdays &lt; 0.25 then
				app.msgBox(app.getErrorString(Exten_perio_less_than_quart_sm), app.getErrorString(Problem),MsgBox_OK_Only);
			endif;
		endif;
	endif;
	
	if self.myCurrentProxyTask &lt;&gt; null then
		self.myCurrentProxyTask.CM_WodBillingAdjustment.setProxyBillingAdjustment(_billing.remarks,timespanqdays, _billing.oldUnitsUsed,
								newFromDateTime, newToDateTime, oldFromDateTime, oldToDateTime);
	endif;
	
	self.txtBillingAdjReason.text := _billing.remarks;
	
	self.lblBillingAdjStart.caption :="";
	
	
	if _billing.isComplete then
		self.shtBillingAdj.enabled := false;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_billing" type="CM_WodBillingAdjustment"/>
    </JadeMethod>
    <JadeMethod name="displayCargoRequest" id="9c576213-aa78-49a5-bbab-913b29eabcab">
        <updating/>
        <source>displayCargoRequest(_cargoRequest : CM_WodCargoRequest) updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 21/05/2018	jlgdap1		Initial creation TFS 38560 PEL1 Voyage Work Orders
// 19 Dec 2018	NDL	TFS Protect against deleted Workpoint object
// 11 Oct 2021	jlier1		TFS 51963
vars
	weightMeasure, volumeMeasure : CM_MeasurementType;
	weight, volume : String;
	imexStatus : CM_IMEXStatus;
	dischargePort : CM_Port;
	transferType : CM_VoyageJobTransferType;
	loadPort : CM_Port;	//20 Jul 2018	NDL	TFS 39837
	estStartTS : TimeStamp;	//20 Jul 2018	NDL	TFS 39837
	estEndTS : TimeStamp;	//20 Jul 2018	NDL	TFS 39837
	localRequiredByDT : TimeStamp;	//31 Jul 2018	NDL	TFS 39930
	voyageProcess : CM_VoyageProcess;
	harbour : HMS_Harbour;
//	processHarbour : CM_ProcessHarbour;
//	equipResourceType : HMS_ResourceType;	//	13 Nov 2018	NDL	TFS 41980 - Remove use of some local resource refs
	resources : HMS_ResourceByTypeDict;	//23 Nov 2018	NDL	TFS 41980

begin
	// display the voyage
	self.displayVoyageCombo(self.shtCargoRequest);
	
	//31 Jul 2018	NDL	TFS 39930	-	reset the alignment
	self.lblVoyage.left := self.lblCargoType.left;
	self.lblVoyage.width := self.lblCargoType.width;
	self.cmbVoyage.left := self.cmbCargoType.left;
	self.cmbVoyage.width := self.cmbCargoType.width;
	
	self.shtCargoRequest.showMySheet();
	
	if self.myVoyage &lt;&gt; null then
		voyageProcess := self.myVoyage.myVoyageProcess;		
	endif;
	
	harbour := self.myTerminal.myHarbour;
	//	13 Nov 2018	NDL	TFS 41980 - Remove use of some local resource refs
/*	if harbour &lt;&gt; null and voyageProcess &lt;&gt; null then 
		processHarbour := voyageProcess.allProcessHarbours.getAtKey(voyageProcess,harbour);
		if processHarbour &lt;&gt; null then
			equipResourceType := processHarbour.myHMSResourceForEquipment;
		endif; 
	endif; */
	
	//31 Jul 2018	NDL	TFS 39930
	if _cargoRequest.myVoyageCargoRequest &lt;&gt; null then
		//Part of total voyage cargo request
		if _cargoRequest.myVoyageCargoRequest.myBerth &lt;&gt; null then
			self.cmbBerthCR.listIndex := self.cmbBerthCR.findObject( _cargoRequest.myVoyageCargoRequest.myBerth );
		endif; 
		self.lblBerthCR.visible := true;
		self.cmbBerthCR.visible := true;
		
		localRequiredByDT := self.systemToLocalTime(_cargoRequest.myVoyageCargoRequest.requiredByDT);
		self.dtReqBy.setDate(localRequiredByDT.date);
		self.tmReqBy.setTime(localRequiredByDT.time);
	else
		//An individual additional cargo request
		self.lblBerthCR.visible := false;
		self.cmbBerthCR.visible := false;
	endif;
	
	self.cmbCargoType.listIndex := self.cmbCargoType.findObject(_cargoRequest.myCargoType);
	self.cmbCargoType_click(self.cmbCargoType);
	self.cmbCargoSubType.listIndex := self.cmbCargoSubType.findObject(_cargoRequest.myCargoSubType);
	self.cmbCommodity.listIndex := self.cmbCommodity.findObject(_cargoRequest.myCommodity);
	self.cmbOperator.listIndex := self.cmbOperator.findObject(_cargoRequest.myOperator);
	self.cmbConsignee.listIndex := self.cmbConsignee.findObject(_cargoRequest.myConsignee);
	self.cmbConsignor.listIndex := self.cmbConsignor.findObject(_cargoRequest.myConsignor);
	self.cmbFreightFwdr.listIndex := self.cmbFreightFwdr.findObject(_cargoRequest.myFreightForwarder);
	self.myAssistant.comboBoxSpecialStow(self.cmbSpecialStow,_cargoRequest.getSpecialStowObject);	//07 Sep 2018	NDL	TFS 40699
	
	weightMeasure := app.getDefaultMeasurementForType(Type_Weight);
	volumeMeasure := app.getDefaultMeasurementForType(Type_Volume);
	if _cargoRequest.myCargoType &lt;&gt; null then
		weightMeasure := _cargoRequest.myCargoType.getDefaultMeasurementForType(Type_Weight);
		volumeMeasure := _cargoRequest.myCargoType.getDefaultMeasurementForType(Type_Volume);
	endif;
	if _cargoRequest.myCargoSubType &lt;&gt; null then
		weightMeasure := _cargoRequest.myCargoSubType.getDefaultMeasurementForType(Type_Weight);
		volumeMeasure := _cargoRequest.myCargoSubType.getDefaultMeasurementForType(Type_Volume);
	endif;
	self.txtTotalQuantity.text := _cargoRequest.totalQuantity.String;
	weight := app.convertMeasurementForDisplay(weightMeasure.shortName, _cargoRequest.totalWeight);
	volume := app.convertMeasurementForDisplay(volumeMeasure.shortName, _cargoRequest.totalVolume);
	self.txtTotalWeight.setValues(weight &amp; Space &amp; weightMeasure.shortName);
	self.txtTotalVolume.setValues(volume &amp; Space &amp; volumeMeasure.shortName);
	if _cargoRequest.weightTare &lt;&gt; null then
		weight := app.convertMeasurementForDisplay(weightMeasure.shortName, _cargoRequest.weightTare);
		self.txtTareWeight.setValues(weight &amp; Space &amp; weightMeasure.shortName);
	endif;
	if _cargoRequest.weightCargo &lt;&gt; null then
		weight := app.convertMeasurementForDisplay(weightMeasure.shortName, _cargoRequest.weightCargo);
		self.txtCargoWeight.setValues(weight &amp; Space &amp; weightMeasure.shortName);
	endif;
	
	imexStatus := app.myRoot.allImexStatuses[_cargoRequest.imexStatus];
	if imexStatus &lt;&gt; null then
		self.cmbImexStatus.listIndex := self.cmbImexStatus.findObject(imexStatus);
		if imexStatus.code = TI_IMEX_STATUS_IMPORT then
			self.cmbDischargePort.enabled := false;
		else	//30 Oct 2018	NDL	TFS 41648
			self.cmbDischargePort.enabled := true;
		endif;
	endif;
	dischargePort := app.myRoot.allPorts[_cargoRequest.dischargePort];
	if dischargePort &lt;&gt; null then
		self.cmbDischargePort.listIndex := self.cmbDischargePort.findObject(dischargePort);
	endif;
	self.cmbWorkPoint.listIndex := self.cmbWorkPoint.findObject(_cargoRequest.getMyWorkPoint);
	transferType := app.myRoot.allVoyageJobTransferTypes[_cargoRequest.transferType];
	if transferType &lt;&gt; null then
		self.cmbTransferType.listIndex := self.cmbTransferType.findStringExact(1, transferType.description);
	endif;
	self.txtNumGangs.text := _cargoRequest.numGangs.String;
	self.cmbLocation.listIndex := self.cmbLocation.findObject(_cargoRequest.myLocationsController);
	
	//27 Jun 2018	NDL	TFS 39246
/*	self.cmbPermitType.clear();
	self.cmbPermitType.itemData[self.cmbPermitType.addItem( app.workOrderPermitsString(INV_WO_PERMIT_MANUALETMAL) )] := INV_WO_PERMIT_MANUALETMAL;	//1
	self.cmbPermitType.itemData[self.cmbPermitType.addItem( app.workOrderPermitsString(INV_WO_PERMIT_CARGOPENALTY) )] := INV_WO_PERMIT_CARGOPENALTY;	//2
	self.cmbPermitType.itemData[self.cmbPermitType.addItem( app.workOrderPermitsString(INV_WO_PERMIT_CARGONOPENALTY) )] := INV_WO_PERMIT_CARGONOPENALTY;	//3
	self.cmbPermitType.itemData[self.cmbPermitType.addItem( app.workOrderPermitsString(INV_WO_PERMIT_CONTINUNOPENALTY) )] := INV_WO_PERMIT_CONTINUNOPENALTY;	//4
	self.cmbPermitType.itemData[self.cmbPermitType.addItem( app.workOrderPermitsString(INV_WO_PERMIT_CONTINUEPENALTY) )] := INV_WO_PERMIT_CONTINUEPENALTY;	//5
	
	if _cargoRequest.permitType &gt; 0 then
		self.cmbPermitType.listIndex := self.cmbPermitType.findItemData( _cargoRequest.permitType );
	else
		if process.isJLGAB1() then
			self.cmbPermitType.listIndex := self.cmbPermitType.findItemData( INV_WO_PERMIT_CARGOPENALTY );
		else
			self.cmbPermitType.listIndex := self.cmbPermitType.findItemData( INV_WO_PERMIT_MANUALETMAL );
		endif;
	endif;*/
	
	if _cargoRequest.isComplete then
		self.shtCargoRequest.enabled := false;
	endif;
	
	//20 Jul 2018	NDL	TFS 39837
	loadPort := app.myRoot.allPorts[_cargoRequest.loadPort];
	if loadPort &lt;&gt; null then
		self.cmbLoadPort.listIndex := self.cmbLoadPort.findObject(loadPort);
	endif;
	//20 Jul 2018	NDL	TFS 39837
	self.txtBOLNumber.text := _cargoRequest.bolNumber;
	
	//20 Jul 2018	NDL	TFS 39837
	estStartTS := self.systemToLocalTime(_cargoRequest.estimatedStartTS);
	estEndTS := self.systemToLocalTime(_cargoRequest.estimatedEndTS);
	self.txtEstStartDate.setDate(estStartTS.date);
	self.txtEstStartTime.setTime(estStartTS.time);
	self.txtEstEndDate.setDate(estEndTS.date);
	self.txtEstEndTime.setTime(estEndTS.time);
	
	//17 Aug 2018	NDL	TFS 40127
//	if voyageProcess &lt;&gt; null then
//		self.popTblResources( self.tblResourcesCR, _cargoRequest, null );	//	13 Nov 2018	NDL	TFS 41980 - Remove use of some local resource refs	
//	endif;
	//23 Nov 2018	NDL	TFS 41980
	self.populateCmbDebtor();
	self.popTblResourcesCrV3( self.tblResourcesCR, _cargoRequest, harbour );
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_cargoRequest" type="CM_WodCargoRequest"/>
    </JadeMethod>
    <JadeMethod name="displayCargoRequests" id="5ffbfc82-90df-4d30-9579-cfe6b8f639ff">
        <updating/>
        <source>displayCargoRequests( _wodtl : CM_WodVoyageCargoRequest ) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 July 2018	jlgndl1	Initial creation	TFS 39742

*/

vars

	wodtl : CM_WorkOrderDtl;
	pos : Integer;

begin

	self.lstTasks.clear();
	
	foreach wodtl in _wodtl.allCargoDetails do
		pos := pos + 1;
		self.lstTasks.addObjectAt(wodtl.getDisplayString(true), pos, wodtl, 1, false);
	endforeach;
	
	if self.lstTasks.listCount &gt; 0 then
		self.lstTasks.listIndex := 1;	
		self.lstTasks.click(self.lstTasks);
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_wodtl" type="CM_WodVoyageCargoRequest"/>
    </JadeMethod>
    <JadeMethod name="displayDetail" id="0dfa556f-c4c2-4887-ba11-623e1e08fe25">
        <updating/>
        <source>displayDetail()protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12/08/2009	cnwmd1	Initial creation
29/04/2016	cnwns1	TFS 488 - Multi Timezone Support
07/05/2018	jlgdap1	TFS 38501 PEL1 Work Order Changes
18/05/2018	jlgdap1	TFS 38560 PEL1 Voyage Work Orders
*/

vars
	//wodtl : CM_WorkOrderTIDtl;				// TFS 38560
	wodtl : CM_WorkOrderDtl;					// TFS 38560
	localStartByDT :TimeStamp;
	loaclRequiredByDT : TimeStamp;
begin
	//wodtl := self.lstTasks.listObject.CM_WorkOrderTIDtl;			// TFS 38560
	wodtl := self.lstTasks.listObject.CM_WorkOrderDtl;				// TFS 38560
	self.myCurrentProxyTask :=wodtl;
	if wodtl = null then
		return;
	endif;
	
	self.lblTaskCaption.caption := self.lstTasks.text;
	
	self.tbDetails.setTableFromObject ( wodtl,  YRD_TaskJobTasks::setDefaultsCallBack.name );
	
	self.chkAutoQueue.value := wodtl.autoQueueTask;
	//29 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
	localStartByDT 	  := self.systemToLocalTime(wodtl.startByDT);
	loaclRequiredByDT := self.systemToLocalTime(wodtl.requiredByDT);
	
	self.dtStartBy.setDate(localStartByDT.date);
	self.tmStartBy.setTime(localStartByDT.time);
	self.dtReqBy.setDate(loaclRequiredByDT.date);
	self.tmReqBy.setTime(loaclRequiredByDT.time);
	
	if wodtl.class = CM_WodMove then
		self.displayMove(wodtl.CM_WodMove);
	elseif wodtl.class = CM_WodToDo then
		self.displayToDo(wodtl.CM_WodToDo);
	elseif wodtl.class = CM_WodUnpack then
		self.displayUnpack(wodtl.CM_WodUnpack);
	elseif wodtl.class = CM_WodPack then
		self.displayPack(wodtl.CM_WodPack);
		self.minimumHeight := 520;//TFS 1766 cnwns1
		
	elseif wodtl.class = CM_WodNullVoyage then			// TFS 38501
		self.displayNullVoyage(wodtl.CM_WodNullVoyage);	// TFS 38501
	elseif wodtl.class = CM_WodReceive then				// TFS 38501
		self.displayReceival(wodtl.CM_WodReceive);		// TFS 38501
	elseif wodtl.class = CM_WodRelease then				// TFS 38501
		self.displayRelease(wodtl.CM_WodRelease);		// TFS 38501
	elseif wodtl.class = CM_WodReleaseExtension then	//12 Mar 2019	NDL	TFS 43405
		self.displayReleaseExtension(wodtl.CM_WodReleaseExtension);
	elseif wodtl.class = CM_WodExportReturn then		// TFS 38501
		self.shtBlank.showMySheet();					// TFS 38501
	
	elseif wodtl.class = CM_WodShiftMovement then					// TFS 38560
		self.displayShiftMovement(wodtl.CM_WodShiftMovement);		// TFS 38560
	elseif wodtl.class = CM_WodCargoRequest then					// TFS 38560
		self.displayCargoRequest(wodtl.CM_WodCargoRequest);			// TFS 38560
	elseif wodtl.class = CM_WodTimeChange then						// TFS 38560
		self.displayTimeChange(wodtl.CM_WodTimeChange);				// TFS 38560
	elseif wodtl.class = CM_WodExtension then						// TFS 38560
		self.displayExtension(wodtl.CM_WodExtension);				// TFS 38560
	elseif wodtl.class = CM_WodWaterRequest then					// TFS 38560
		self.displayWaterRequest(wodtl.CM_WodWaterRequest);			// TFS 38560
	elseif wodtl.class = CM_WodHMSRequestCancel then				// TFS 38560
		self.displayHMSRequestCancel(wodtl.CM_WodHMSRequestCancel);	// TFS 38560
	elseif wodtl.class = CM_WodVoyageCargoRequest then	//16 Jul 2018	NDL	TFS 39742
		self.displayCargoRequests(wodtl.CM_WodVoyageCargoRequest);	
	elseif wodtl.class = CM_WodMarineServicesInitial then	//16 Jul 2018	NDL	TFS 39742
		self.displayMarineInitial(wodtl.CM_WodMarineServicesInitial);
	elseif wodtl.class = CM_WodMarineServicesDepart then	//16 Jul 2018	NDL	TFS 39742
		self.displayMarineDepart(wodtl.CM_WodMarineServicesDepart);
	elseif wodtl.class = CM_WodVoyageRequest then	// TFS 40029
		self.displayVoyageRequest(wodtl.CM_WodVoyageRequest); // TFS 40029
	elseif wodtl.class = CM_WodPermitRequest then
		self.displayPermitRequest(wodtl.CM_WodPermitRequest);
	elseif wodtl.class = CM_WodBillingAdjustment then // TFS 42241
		self.displayBillingAdjustment(wodtl.CM_WodBillingAdjustment); // TFS 42241
		
	else
		app.raiseUnexpectedProgramError(self.class.name, method.name, "Unknown task type");
	endif;
	
	self.enableControls();
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="displayExtension" id="f7dadfcb-714e-4a2b-801e-67406dff4ff2">
        <source>displayExtension(_extension : CM_WodExtension) protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 21/05/2018	jlgdap1		Initial creation TFS 38560 PEl1 Voyage Work Orders
// 28/03/2019	jlgdap1		TFS 43694 PEL1 Charging for Vessels that use a Ramp
//
vars

	processHarbour : CM_ProcessHarbour;
	resources : HMS_ResourceByTypeDict;

begin
	// display the voyage
	self.displayVoyageCombo(self.shtExtension);
	
	self.shtExtension.showMySheet();
	
	if _extension.occursOnDT.isValid then
		self.txtMoveOnDateNew.setDate(_extension.occursOnDT.date);
		self.txtMoveOnTimeNew.setTime(_extension.occursOnDT.time);
	endif;
	
	//19 Feb 2019	NDL	TFS 43374
	if self.myVoyage &lt;&gt; null and  self.myVoyage.myVoyageProcess &lt;&gt; null then
		processHarbour := self.myVoyage.myVoyageProcess.allProcessHarbours[self.myVoyage.myVoyageProcess, self.myTerminal.myHarbour];
		if processHarbour &lt;&gt; null then 
			resources := processHarbour.allHMSResourcesForExt;									
			self.popTblResourcesForShift( self.tblResourcesEx, null, _extension, resources);		
		endif;
	endif;
	
	if _extension.isComplete then
		self.shtExtension.enabled := false;
	endif;
	
	self.chkHasRamp.value := _extension.hasRamp;				// TFS 43694
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_extension" type="CM_WodExtension"/>
    </JadeMethod>
    <JadeMethod name="displayHMSRequestCancel" id="4ed510a3-e962-4cbe-8b2e-1f3eb3abdb72">
        <source>displayHMSRequestCancel(_hmsCancel : CM_WodHMSRequestCancel) protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 21/05/2018	jlgdap1		Initial creation TFS 38560 PEL1 Voyage Work Orders
//
vars

begin
	// display the voyage
	self.displayVoyageCombo(self.shtHMSCancel);
	
	self.shtHMSCancel.showMySheet();
	
	self.cmbWorkOrderC.listIndex := self.cmbWorkOrderC.findObject(_hmsCancel.myWorkOrderToCancel);
	
	if _hmsCancel.isComplete then
		self.shtHMSCancel.enabled := false;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_hmsCancel" type="CM_WodHMSRequestCancel"/>
    </JadeMethod>
    <JadeMethod name="displayMarineDepart" id="875ec9cc-d2e6-4c87-acef-b139a2e0bd77">
        <source>displayMarineDepart( _wodtl : CM_WodMarineServicesDepart ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 July 2018	jlgndl1	Initial creation	TFS 39742
01/10/2021	jlier1	TFS 51963 - changes voyage process
*/

vars

	voyageStatus : CM_VoyageStatus;

begin

	// display the voyage
	self.displayVoyageCombo(self.shtMarineD);
	
	self.shtMarineD.showMySheet();
	
	if self.myVoyage &lt;&gt; null then
		if self.myVoyage.myVoyageProcess.isMTNWOProcess then //jlier1 TFS 51963 1/10/21
			voyageStatus := self.myVoyage.myVoyageProcess.allStatusesById[ Voyage_Status_DepServPending ];
		endif;
		self.popTblResources( self.tblResourcesMD, _wodtl, voyageStatus );
	endif;
	
	//19 Sep 2018	NDL	TFS 40810
	if _wodtl.draftFwd &lt;&gt; null then
		self.txtDraftFwdMD.text := _wodtl.draftFwd.String;
	endif;
	if _wodtl.draftAft &lt;&gt; null then
		self.txtDraftAftMD.text := _wodtl.draftAft.String;
	endif;
	if _wodtl.bowMarkTo &lt;&gt; null then
		self.txtBowMarkToMD.text := _wodtl.bowMarkTo.String;
	endif; 
	if self.myVoyage &lt;&gt; null and self.myVoyage.myHMSVoyageData &lt;&gt; null then
		self.cmbTowVoyageMD.visible := self.myVoyage.myHMSVoyageData.requiresTow;
		self.lblTowingVoyMD.visible := self.cmbTowVoyageMD.visible;
		self.cmbTowVoyageMD.setObject( _wodtl.myTowingVoyage );
	endif;


epilog

end;</source>
        <access>protected</access>
        <Parameter name="_wodtl" type="CM_WodMarineServicesDepart"/>
    </JadeMethod>
    <JadeMethod name="displayMarineInitial" id="5f8fbca2-55e7-475f-ab97-db9ab8fee16a">
        <source>displayMarineInitial( _wodtl : CM_WodMarineServicesInitial ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 July 2018	jlgndl1	Initial creation	TFS 39742
01/10/2021	jlier1	TFS 51963 - changes voyage process
*/

vars

	voyageStatus : CM_VoyageStatus;
	wodVoyageCargoRequest : CM_WodVoyageCargoRequest;
	localRequiredByDT: TimeStamp;
	
begin

	// display the voyage
	self.displayVoyageCombo(self.shtMarineI);
	
	self.shtMarineI.showMySheet();
	
	//31 Jul 2018	NDL	TFS 39930
	if self.myVoyage &lt;&gt; null then
		wodVoyageCargoRequest := self.myVoyage.allWorkOrders.getWorkOrderDetailOfType(WO_TASK_CARGOINITIAL).CM_WodVoyageCargoRequest;
	endif;
	if wodVoyageCargoRequest &lt;&gt; null then
	//	if wodVoyageCargoRequest.myBerth &lt;&gt; null then
	//		self.cmbBerthMI.listIndex := self.cmbBerthMI.findObject( wodVoyageCargoRequest.myBerth );
	//	endif;
		//01 Nov 2018	NDL	TFS 41687
		self.cmbBerthMI.listIndex := self.cmbBerthMI.findObject( _wodtl.myBerth );
		
		if _wodtl.requiredByDT.isValid then
			localRequiredByDT := self.systemToLocalTime(_wodtl.requiredByDT);
			self.dtReqBy.setDate(localRequiredByDT.date);
			self.tmReqBy.setTime(localRequiredByDT.time);
		else
		localRequiredByDT := self.systemToLocalTime(wodVoyageCargoRequest.requiredByDT);
		self.dtReqBy.setDate(localRequiredByDT.date);
		self.tmReqBy.setTime(localRequiredByDT.time);
		
	//	self.cmbBerthMI.enabled := false;
	//	self.dtReqBy.enabled := false;
	//	self.tmReqBy.enabled := false;
		endif;
	elseif _wodtl.myBerth &lt;&gt; null then
		self.cmbBerthMI.listIndex := self.cmbBerthMI.findObject( _wodtl.myBerth );
	endif;
	
	
	// TFS 40236
	if _wodtl.draftFwd &lt;&gt; null then
		self.txtDraftFwdMI.text := _wodtl.draftFwd.String;
	endif;
	if _wodtl.draftAft &lt;&gt; null then
		self.txtDraftAftMI.text := _wodtl.draftAft.String;
	endif;
	if _wodtl.bowMarkTo &lt;&gt; null then
		self.txtBowMarkToMI.text := _wodtl.bowMarkTo.String;
	endif;
	self.chkHasRampMI.value := _wodtl.hasRamp;
	self.optStarboardMI.value := _wodtl.starboardBerthed;
	
	
	if self.myVoyage &lt;&gt; null then
		if self.myVoyage.myVoyageProcess.isMTNWOProcess then //jlier1 TFS 51963 1/10/21
			voyageStatus := self.myVoyage.myVoyageProcess.allStatusesById[ Voyage_Status_ServicesPending ];		// TFS 39741
		endif;
		self.popTblResources( self.tblResourcesMI, _wodtl, voyageStatus );
	endif;
	
	//20 Sep 2018	NDL	TFS 40810
	if self.myVoyage &lt;&gt; null and self.myVoyage.myHMSVoyageData &lt;&gt; null then
		self.cmbTowVoyageMI.visible := self.myVoyage.myHMSVoyageData.requiresTow;
		self.lblTowingVoyMI.visible := self.cmbTowVoyageMI.visible;
		self.cmbTowVoyageMI.setObject( _wodtl.myTowingVoyage );
	endif;
	
	//14 Dec 2018	NDL	TFS 42541
	if _wodtl.isComplete then
		self.shtMarineI.enabled := false;
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_wodtl" type="CM_WodMarineServicesInitial"/>
    </JadeMethod>
    <JadeMethod name="displayMove" id="0bb0bf34-718a-4095-bd17-f1dfe4941413">
        <source>displayMove(_wodtl : CM_WodMove)protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 Aug 2009	cnwmd1	Initial creation
29 Sep 2021 navma1 ChangeRequest 51925: SAL - Web Portal Cargo Work Orders
*/

vars
	ta : CM_TerminalArea;
begin
	self.shtMove.showMySheet();
	
	self.cmbMoveSrcArea.listObject  := null;
	self.cmbMoveTargArea.listObject := null;
	
	if _wodtl.mySourceLocation &lt;&gt; null then
		ta := _wodtl.mySourceLocation.myTerminalArea;
		self.cmbMoveSrcArea.listObject := ta;
	endif;
	
	if _wodtl.myTargetLocation &lt;&gt; null then
		ta := _wodtl.myTargetLocation.myTerminalArea;
		self.cmbMoveTargArea.listObject := ta;
	elseif _wodtl.targetLocation &lt;&gt; null then
		self.cmbMoveTargArea.listIndex :=  self.cmbMoveTargArea.findStringExact(1, _wodtl.targetLocation);
	endif;
	
		
	if app.getMyUser().myOrganisation.isExternal or not self.myTerminal.isUseYardJobsForCargoWo  then //29.09.2021 navma1 #51925
		self.chkMoveAutoRTQ.visible := false;
	endif;
		
	self.chkMoveAutoRTQ.value := _wodtl.autoRTQ;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_wodtl" type="CM_WodMove"/>
    </JadeMethod>
    <JadeMethod name="displayNullVoyage" id="d6a6a8d6-f67b-4cdc-aa8a-89f9b10065f8">
        <source>displayNullVoyage(_wodtl : CM_WodNullVoyage) protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 08/05/2018	jlgdap1		Initial creation TFS 38501 PEL1 Work Order Changes
//
vars

begin
	self.shtNullVoyage.showMySheet;
	self.cmbVoyage.listObject := null;
	
	if _wodtl.myNewVoyage &lt;&gt; null then
		//self.cmbVoyage.listObject :=  _wodtl.myNewVoyage;
		self.cmbVoyage.listIndex := self.cmbVoyage.findObject(_wodtl.myNewVoyage);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_wodtl" type="CM_WodNullVoyage"/>
    </JadeMethod>
    <JadeMethod name="displayPack" id="9775f73a-dc41-4ea6-8fb4-b525391e415c">
        <source>displayPack(_wodtl : CM_WodPack) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 August 2009	cnwmd1	Initial creation

*/

vars
	imexStatus : CM_IMEXStatus;
	commodity : CM_Commodity;
begin
	self.shtPack.showMySheet();
	
	self.chkPackIsChild.value := _wodtl.isSelectedItemsPackingChild;
	
	if _wodtl.mySource &lt;&gt; null then
		self.cmbPackCargoType.setObject(_wodtl.mySource.getMyCargoType());
	endif;
	self.displayPackSource(_wodtl);
	self.cmbPackVoyage.setObject(_wodtl.myVoyage);
	self.cmbPackOperator.setObject(_wodtl.myOperator);
	self.cmbPackDishPort.setObject(_wodtl.myDischargePort);
	self.cmbPackBookRef.setObject(_wodtl.myBookingRef);
	
	imexStatus := app.myRoot.allImexStatuses[_wodtl.imexStatus].CM_IMEXStatus;
	self.cmbPackImExStats.listObject := imexStatus;
	
	commodity := app.myRoot.allCommodities[_wodtl.commodity].CM_Commodity;
	self.cmbPackCommodity.listObject := commodity;
	
	if self.myTerminal.isSubTerminalsOn() then
		self.cmbPackSubTerm.visible := true;
		self.lblPackSubTerm.visible := true;
		self.cmbPackSubTerm.listObject := _wodtl.mySubTerminal;
	else
		self.cmbPackSubTerm.visible := false;
		self.lblPackSubTerm.visible := false;
	endif;
	
	self.cmbPackConsignee.setObject(_wodtl.myConsignee);
	self.cmbPackConsignor.setObject(_wodtl.myConsignor);
	self.cmbPackConStatus.listObject := _wodtl.myContentsStatus;
	
	//29.09.2021 navma1 #51925
	self.grpToDoTask.parent    := self.shtPack;
	self.grpToDoTask.height	   := 120;
	self.grpToDoTask.top       := self.grpPackAttr.top    + 190;
	self.grpToDoTask.left      := self.grpPackAttr.left;
	self.grpToDoTask.width     := self.grpPackAttr.width ;
	self.mulReceiveToDo.height := self.grpToDoTask.height - 40 ;
	self.mulReceiveToDo.top	   := self.mulReceiveToDo.top +10 ;
	self.mulReceiveToDo.left   := 17;
	//29.09.2021 navma1 #51925
	
	self.displayWorkOrderToDoTaks(_wodtl);		//29.09.2021 navma1 #51925
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_wodtl" type="CM_WodPack"/>
    </JadeMethod>
    <JadeMethod name="displayPackSource" id="86878010-a9d8-4e36-9f94-74dc8de4389b">
        <source>displayPackSource(_wodtl : CM_WodPack) protected;

/*

Purpose:			
		Still Used by Old Screen
Parameters:			

Return Value:		


Date		Who		Reason
20 Aug 2009	cnwmd1	Initial creation
12 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
*/

vars
	table : Table;
begin
	self.txtPackCargo.text := _wodtl.getSourceString();
	self.cmbPackCargoType.setObject(_wodtl.mySource.getMyCargoType());
	
	self.tbPackCargo.rows := 0;
	table 				  := self.tbPackCargo ;
	
	_wodtl.populateSourceDisplayTable( table );

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_wodtl" type="CM_WodPack"/>
    </JadeMethod>
    <JadeMethod name="displayPermitRequest" id="e54051f5-18c2-4e6d-bf9c-c3dca23261ec">
        <source>displayPermitRequest(_wodtl : CM_WodPermitRequest) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 October 2018	jlger1	Initial creation

*/

vars
	pos,
	initialMarineStatus : Integer;
	wodtl : CM_WodCargoRequest;
begin
	// display the voyage
	self.displayVoyageCombo(self.shtPermit);
	self.shtPermit.showMySheet();
	//self.myAssistant.comboBox
	self.cmbPermitType.clear();
	
	if _wodtl &lt;&gt; null and _wodtl.isAdditionalCargo then
		self.cmbPermitType.addItemWithData(app.workOrderPermitsString(INV_WO_PERMIT_CARGOPENALTY), INV_WO_PERMIT_CARGOPENALTY);	//2
		self.cmbPermitType.addItemWithData( app.workOrderPermitsString(INV_WO_PERMIT_CARGONOPENALTY), INV_WO_PERMIT_CARGONOPENALTY);	//3
	else
	
		self.cmbPermitType.addItemWithData( app.workOrderPermitsString(INV_WO_PERMIT_MANUALETMAL),INV_WO_PERMIT_MANUALETMAL);	//1
	
		if self.myVoyage.myGeneralCargoVoyage &lt;&gt; null then
			self.cmbPermitType.addItemWithData(app.workOrderPermitsString(INV_WO_PERMIT_CARGOPENALTY), INV_WO_PERMIT_CARGOPENALTY);	//2
			self.cmbPermitType.addItemWithData( app.workOrderPermitsString(INV_WO_PERMIT_CARGONOPENALTY), INV_WO_PERMIT_CARGONOPENALTY);	//3
			self.cmbPermitType.addItemWithData( app.workOrderPermitsString(INV_WO_PERMIT_CONTINUNOPENALTY), INV_WO_PERMIT_CONTINUNOPENALTY);	//4
			self.cmbPermitType.addItemWithData( app.workOrderPermitsString(INV_WO_PERMIT_CONTINUEPENALTY), INV_WO_PERMIT_CONTINUEPENALTY);	//5
		endif;
	endif;
	
	if _wodtl.permitType &gt; 0 then
		self.cmbPermitType.listIndex := self.cmbPermitType.findItemData( _wodtl.permitType );
	else
		self.cmbPermitType.listIndex :=self.cmbPermitType.findItemData( INV_WO_PERMIT_MANUALETMAL);
	endif;


	self.selectPermitType();
	
	self.cmbPermitType.enabled:=not _wodtl.isComplete;
	if _wodtl.permitDetailType &gt; 0 then
		self.cmbPermitFor.setIndexForItemData(_wodtl.permitDetailType);
		self.cmbPermitFor.enabled:=not _wodtl.isComplete;
	endif;
	
	self.cmbRelatedWO.enabled := not _wodtl.isComplete;
	self.selectPermitFor();
	
	
	self.myAssistant.comboBoxOperator(self.cmbPermitOperator,_wodtl.myOperator,self.myVoyage);
	
	self.txtPermitTotalDays.text:=_wodtl.myParent.CM_WorkOrderVoyage.lengthOfTime.asStringJMT;
	
	
	
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_wodtl" type="CM_WodPermitRequest"/>
    </JadeMethod>
    <JadeMethod name="displayReceival" id="3054ea56-78d9-4c27-aec2-3e94b1096990">
        <source>displayReceival(_wodtl : CM_WodReceive) protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 08/05/2018	jlgdap1		Initial creation TFS 38501 PEL1 Work Order Changes
// 20/06/2018   cnwma1		ChangeRequest 38815: PEL1 - WP TI Work Order Changes
// 10 Sep 2021  navma1		ChangeRequest 51002: MTN - Web Portal Cargo Work Orders
vars

	todoSet 		: CM_ToDoTaskDescSet;
	invalid		: Boolean;
begin
	on Exception do app.handleDeletedObject(exception, _wodtl.myBookingRef, invalid);
	
	self.shtReceival.showMySheet;
	self.cmbBooking.listObject := null;
	
	if _wodtl.myBookingRef &lt;&gt; null then
		_wodtl.myBookingRef.edition();          //10.09.2021 navma1 #51002
			if not invalid then
				self.cmbBooking.listObject := _wodtl.myBookingRef;
			endif;
	endif;
	
	if _wodtl.customExportEntryNumber &lt;&gt; null then //20.6.2018 cnwma1 TFS #38815
		self.txtCustomExportEntryNumber.text := _wodtl.customExportEntryNumber; 
	endif;
	
	//11 Jul 2018	NDL	TFS 39638
	if not _wodtl.allToDoRequests.isEmpty then
		create todoSet transient;
		_wodtl.getAllToDoTaksDescsUsed( todoSet );
		self.mulReceiveToDo.setSelected( todoSet );
	endif; 
	
epilog

	delete todoSet;

end;</source>
        <access>protected</access>
        <Parameter name="_wodtl" type="CM_WodReceive"/>
    </JadeMethod>
    <JadeMethod name="displayRelease" id="5a8c71f1-950c-43bd-bfba-56c137ee3817">
        <source>displayRelease(_wodtl : CM_WodRelease) protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 08/05/2018	jlgdap1		Initial creation TFS 38501 PEL1 Work Order Changes
// 12/02/2019	jlgdap1		TFS 43062 PEL1 Container Serrvices - Changes in Web Portal
//1/04/2019		JLGNS1		Bug 44134: PEL1 - Container Services - Release Extension (Release Work Order drop down not responding)
//29/09/2021	 navma1 	ChangeRequest 51925: SAL - Web Portal Cargo Work Orders
//
vars
	
	todoSet : CM_ToDoTaskDescSet;
	relReq  : CM_BulkRelease;
begin
	self.shtRelease.showMySheet;
	self.cmbRelease.listObject := null;
	relReq := _wodtl.getMyReleaseRequest();				//Bug 44134
	
	if relReq &lt;&gt; null then								//Bug 44134
		self.cmbRelease.setIndexFromObject(relReq);		//Bug 44134
	endif;
	
	self.txtCustoms.text := _wodtl.customsClearanceNumber;			// TFS 43062
	
	//29.09.2021 navma1 #51925
	self.mulReleaseToDo.visible:= false;
	self.grpToDoTask.parent    := self.shtRelease;
	self.grpToDoTask.height	   := 350;
	self.grpToDoTask.top       := self.txtCustomExportEntryNumber.top  + 50;
	self.grpToDoTask.left      := self.grpPackAttr.left;
	self.grpToDoTask.width     := self.grpPackAttr.width ;
	self.mulReceiveToDo.height := self.grpToDoTask.height - 40 ;
	self.mulReceiveToDo.left   := 17;
	//29.09.2021 navma1 #51925
	
	self.displayWorkOrderToDoTaks(_wodtl);		//29.09.2021 navma1 #51925
epilog

	delete todoSet;

end;</source>
        <access>protected</access>
        <Parameter name="_wodtl" type="CM_WodRelease"/>
    </JadeMethod>
    <JadeMethod name="displayReleaseExtension" id="8b2d76a0-4966-460f-986e-a7fb4623e82a">
        <source>displayReleaseExtension(_wodtl : CM_WodReleaseExtension) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Mar 2019	jlgndl1	Initial creation	TFS 43405
29 Sep 2021 navma1  ChangeRequest 51925: SAL - Web Portal Cargo Work Orders
*/

vars
	todoSet : CM_ToDoTaskDescSet;
begin

	self.chkAutoQueue.visible := false;
	if _wodtl &lt;&gt; null
	and _wodtl.getMyParent &lt;&gt; null
	and _wodtl.getMyParent.taskStatus &gt; WO_STATUS_PENDING
	then
		//self.mulRelExtToDo.enabled := false;              //29.09.2021 navma1 #51925 Pending
		self.mulReceiveToDo.enabled   := false;             //29.09.2021 navma1 #51925
		self.dtReqBy.enabled 		  := false;
		self.tmReqBy.enabled 		  := false;
		self.butOK.enabled 			  := false;
	endif;

	self.populateAvailableWORels( _wodtl );
	
	self.shtRelExtension.showMySheet;
	self.cmbRelExtWORel.listIndex := -1;	 // Work order cargo release
	self.cmbRelExtRel.listIndex   := -1;	// Bulk Release
	
	if _wodtl.myReleaseWorkOrder &lt;&gt; null then
		self.cmbRelExtWORel.setIndexFromObject( _wodtl.myReleaseWorkOrder);
		self.cmbRelExtWORel.click( self.cmbRelExtWORel );
	endif;
	
	
	//29.09.2021 navma1 #51925
	self.mulRelExtToDo.visible := false;
	self.grpToDoTask.parent    := self.shtRelExtension;
	self.grpToDoTask.height	   := 350;
	self.grpToDoTask.top       := self.cmbRelExtWORel.top    + 100;
	self.grpToDoTask.left      := self.grpPackAttr.left;
	self.grpToDoTask.width     := self.grpPackAttr.width ;
	self.mulReceiveToDo.height := self.grpToDoTask.height - 40 ;
	self.mulReceiveToDo.left   := 17;
	//29.09.2021 navma1 #51925
	
	self.displayWorkOrderToDoTaks(_wodtl);		//29.09.2021 navma1 #51925
epilog

	delete todoSet;

end;</source>
        <access>protected</access>
        <Parameter name="_wodtl" type="CM_WodReleaseExtension"/>
    </JadeMethod>
    <JadeMethod name="displayShiftMovement" id="d6d31f7e-9418-4997-8b6d-6560b2157f51">
        <updating/>
        <source>displayShiftMovement(_shiftDtl : CM_WodShiftMovement) updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 18/05/2018	jlgdap1		Initial creation TFS 38560 PEL1 Voyage Work Orders
// 29/08/2018	jlgdap1		TFS 40488 PEL1 Resources for Shift Movements
//  1/10/21		jlier1 		TFS 51963
// 19/10/2021	navmd1		TFS 52224 Always populate Resources table columns for Shift Movements, even if there are no resources available
vars
	movement : HMS_VoyageMovement;
	seaHarbourRegion : HMS_HarbourRegion;
	seaHRArrivalBerth : HMS_Berth;
	localOccursOnDT : TimeStamp;
	processHarbour : CM_ProcessHarbour;					// TFS 40488
	resources : HMS_ResourceByTypeDict;					// TFS 40488
	berthArrival : TimeStamp;	//26 Oct 2018	NDL	TFS 41413
begin
	// display the voyage
	self.displayVoyageCombo(self.shtShift);
	
	self.shtShift.showMySheet();
	
	if self.myVoyage &lt;&gt; null then
		self.txtDraftFwd.text := self.myVoyage.draftBow.String;
		self.txtDraftAft.text := self.myVoyage.draftStern.String;
		
		// TFS 40236
		if self.mode = self.Mode_Add then
			// DEFAULTS
			self.chkHasRampSM.value := self.myVoyage.myHMSVoyageData.hasRamp;
			self.optStarboardSM.value := self.myVoyage.starboardBerthed;
		else
			self.chkHasRampSM.value := _shiftDtl.hasRamp;
			self.optStarboardSM.value := _shiftDtl.starboardBerthed;
		
		endif;
	endif;
	
	
	
	
	
	// get the movement corresponding to the work order occursOnDT
	
	if _shiftDtl.occursOnDT.isValid then
		localOccursOnDT := self.systemToLocalTime( _shiftDtl.occursOnDT );
		self.txtMoveOnDate.setDate( localOccursOnDT.date );
		self.txtMoveOnTime.setTime( localOccursOnDT.time );
		if self.myVoyage &lt;&gt; null then
			movement := self.myVoyage.myHMSVoyageData.allVoyageMovements[_shiftDtl.occursOnDT];
		endif;
	endif;
	
	//26 Oct 2018	NDL	TFS 41413
	if _shiftDtl.berthArrival.date.isValid then
		berthArrival := self.systemToLocalTime( _shiftDtl.berthArrival );
		self.txtBerthArrDate.setDate( berthArrival.date );
		self.txtBerthArrTime.setTime( berthArrival.time );
	endif;
	
	
	if _shiftDtl.draftFwd &lt;&gt; null then
		self.txtDraftFwd.text := _shiftDtl.draftFwd.String;
	endif;
	if _shiftDtl.draftAft &lt;&gt; null then
		self.txtDraftAft.text := _shiftDtl.draftAft.String;
	endif;
	if _shiftDtl.myFromBerth &lt;&gt; null then
		self.txtBerthFrom.text := _shiftDtl.myFromBerth.code;
		if movement &lt;&gt; null and movement.myPreviousMovement &lt;&gt; null then
			if movement.myPreviousMovement.isLogicalBerth then
				self.txtBowMarkFrom.text := app.getErrorString(NotApplicable);
				self.txtSternMarkFrom.text := app.getErrorString(NotApplicable);
			else
				self.txtBowMarkFrom.text := movement.myPreviousMovement.HMS_VoyageMovement.bowMarkTo.String;
				self.txtSternMarkFrom.text := movement.myPreviousMovement.HMS_VoyageMovement.sternMarkTo.String;
			endif;
		else
			self.txtBowMarkFrom.text := app.getErrorString(NotApplicable);
			self.txtSternMarkFrom.text := app.getErrorString(NotApplicable);
		endif;
	else
		self.txtBerthFrom.text := null;
		seaHarbourRegion := app.myRoot.getSeaHarbourRegion;
		if seaHarbourRegion &lt;&gt; null then
			seaHRArrivalBerth := seaHarbourRegion.getArrivalBerth();
			if seaHRArrivalBerth &lt;&gt; null then
				self.txtBerthFrom.text := seaHRArrivalBerth.getDisplayString();
			endif;
	 	endif;
		
		self.txtBowMarkFrom.text := app.getErrorString(NotApplicable);
		self.txtSternMarkFrom.text := app.getErrorString(NotApplicable);
	endif;
	if _shiftDtl.myToBerth &lt;&gt; null then
		self.cmbToBerth.listIndex := self.cmbToBerth.findObject(_shiftDtl.myToBerth);
		self.txtBowMarkTo.text := _shiftDtl.bowMarkTo.String;
		self.txtSternMarkTo.text := _shiftDtl.sternMarkTo.String;
	endif;
	if _shiftDtl.relativeOrderTimePlaunch &lt;&gt; null then
		self.txtLaunchRelative.text := _shiftDtl.relativeOrderTimePlaunch.String;
	endif;
	if _shiftDtl.relativeOrderTimeTugs &lt;&gt; null then
		self.txtTugRelative.text := _shiftDtl.relativeOrderTimeTugs.String;
	endif;
	if _shiftDtl.relativeOrderTimeLines &lt;&gt; null then
		self.txtLineRelative.text := _shiftDtl.relativeOrderTimeLines.String;
	endif;
	
	self.shiftDateTime := _shiftDtl.occursOnDT;
//	if movement = null then
	if movement = null and self.myVoyage &lt;&gt; null then //21 Sep 2018	NDL found during testing
		if self.myVoyage.myHMSVoyageData &lt;&gt; null and self.myVoyage.myHMSVoyageData.allVoyageMovements &lt;&gt; null then
			movement := self.myVoyage.myHMSVoyageData.allVoyageMovements.getAtKeyLeq(_shiftDtl.occursOnDT);
		endif;
	endif;
	if movement &lt;&gt; null then
		self.myCurrentMovement := movement;
	endif;
	
	//22 Jun 2018	NDL	TFS 39248
	if self.myVoyage &lt;&gt; null and self.myVoyage.myHMSVoyageData &lt;&gt; null then
		self.cmbTowVoyage.visible := self.myVoyage.myHMSVoyageData.requiresTow;
		self.lblTowingVoy.visible := self.cmbTowVoyage.visible;
		self.cmbTowVoyage.setObject( _shiftDtl.myTowingVoyage );	//20 Sep 2018	NDL	TFS 40810
	endif;
	//21 Jun 2018	NDL	TFS 39248
	if self.myVoyage &lt;&gt; null then
		processHarbour := self.myVoyage.myVoyageProcess.allProcessHarbours[self.myVoyage.myVoyageProcess, self.myTerminal.myHarbour];	// TFS 40488
		if processHarbour &lt;&gt; null then
			resources := processHarbour.allHMSResourcesForShift;											// TFS 40488
		endif;
		self.popTblResourcesForShift( self.tblResources, _shiftDtl, null, resources);						// TFS 40488
	endif;
	
	if _shiftDtl.isComplete then
		self.shtShift.enabled := false;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_shiftDtl" type="CM_WodShiftMovement"/>
    </JadeMethod>
    <JadeMethod name="displayTasks" id="85420c76-e73e-4db0-a0c0-30dd78422b67">
        <source>displayTasks(_newTask : CM_WorkOrderDtl) protected;

/*

Purpose:			Display All Tasks in task listbox (on left side of form)

Parameters:			

Return Value:		


Date		Who		Reason
12 Aug 2009	cnwmd1	Initial creation
29 Sep 2021 navma1 ChangeRequest 51925: SAL - Web Portal Cargo Work Orders
*/

vars
	cargoRequest : CM_WodCargoRequest;
	wodtl 		: CM_WorkOrderDtl;
	idx,
	pos 		: Integer;
	
begin
	self.lstTasks.clear();
	
	foreach wodtl in self.myProxyWorkOrder.allWoDtls do
		pos := pos + 1;
		self.lstTasks.addObjectAt(wodtl.getDisplayString(true), pos, wodtl, 1, false);
	
		if wodtl.isKindOf(CM_WodPermitRequest) then
			// TFS 42221 19DEC18 only new cargo.
			if wodtl.CM_WodPermitRequest.permitType = INV_WO_PERMIT_CARGOPENALTY 
			or wodtl.CM_WodPermitRequest.permitType = INV_WO_PERMIT_CARGONOPENALTY then

				foreach cargoRequest in wodtl.CM_WodPermitRequest.allCargoDetails do
					idx := self.lstTasks.addItem(cargoRequest.getDisplayString(false));
					self.lstTasks.itemObject[idx]:=cargoRequest;
				endforeach;
				
			endif;
		endif;
	
	endforeach;
	
	if _newTask &lt;&gt; null then
		self.lstTasks.listObject := _newTask;
		self.lstTasks.selectObject(_newTask);
		self.lstTasks.click(self.lstTasks);
		//self.lstTasks.enabled	:= false;				//29.09.2021 navma1 #51925 Pending
		
	else
		if self.lstTasks.listCount &gt; 0 then
			self.lstTasks.listIndex := 1;
			self.lstTasks.click(self.lstTasks);		 
		//	self.lstTasks.enabled	:= false;		    //29.09.2021 navma1 #51925 Pending
		endif;
	endif;
	
	self.enableControls();
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_newTask" type="CM_WorkOrderDtl"/>
    </JadeMethod>
    <JadeMethod name="displayTimeChange" id="26fcf5c3-e685-459c-8237-0e1e31315e7f">
        <source>displayTimeChange(_timeChange : CM_WodTimeChange) protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 21/05/2018	jlgdap1		Initial creation TFS 38560 PEL1 Voyage Work Orders
//
vars

begin
