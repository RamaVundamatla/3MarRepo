    <JadeMethod name="stackValueControls" id="6bb546b7-816b-42ba-b9cf-4bb8b9f6011c">
        <source>stackValueControls(_initialSetup : Boolean);
/*

Date		Who		Reason
12 Apr2016	cnwer1	Initial creation PAR
18 Oct 2017	jlgrh7  TFS40904  GUQ - Read only Label currency Translation not Available on JMT#851.220
25 Sep 2019 cnwma1 Bug 46707: JMT - Payment Method combo box being cropped
*/

vars
	gap		: Integer;
	stackControls : ObjectArray;
	paymentHeight : Real;
begin
	gap := 0;	// was 4 but need 0 to fit everything in

	create stackControls transient;
	stackControls.add(self.lblZeroTax);
	stackControls.add(self.lblTax1);
	stackControls.add(self.lblTax2);
	stackControls.add(self.lblTax3);
	stackControls.add(self.lblRoundUp);
	stackControls.add(self.lblCreditUsed);
	stackControls.add(self.lblCashPayReqd);
	stackControls.add(self.lblCashPayment);
	stackControls.add(self.lblMoP);
	self.lblSubTotal1.stackVertical(stackControls, gap);
	
	stackControls.clear;
	stackControls.add(self.lblZeroTax);
	stackControls.add(self.lblTaxValue1);
	stackControls.add(self.lblTaxValue2);
	stackControls.add(self.lblTaxValue3);
	stackControls.add(self.lblRoundUpValue);
	stackControls.add(self.lblCreditValue);
	stackControls.add(self.lblCashPayReqd2);
	stackControls.add(self.txtCashPayment);
	stackControls.add(self.cmbMOP);
	self.lblSubTotal2.stackVertical(stackControls, gap);
	
	
	
	if   self.allowSecondCurrency then
		self.lblTaxValue12nd.visible:=self.lblTaxValue1.visible;
		self.lblTaxValue22nd.visible:=self.lblTaxValue2.visible;
		self.lblTaxValue32nd.visible:=self.lblTaxValue3.visible;
		self.lblRoundUp2nd.visible:=self.lblRoundUpValue.visible;
		self.lblCredit2nd.visible:=self.lblCreditValue.visible;	
	else
		self.frmPay2nd.visible:=false;
		self.frmPaymentValues.left:= self.frmPayment.clientWidth - self.frmPaymentValues.clientWidth - 10;
		
	endif;
		
	
	if self.allowSecondCurrency then
		stackControls.clear;
		stackControls.add(self.lblZeroTax);
		stackControls.add(self.lblTaxValue12nd);
		stackControls.add(self.lblTaxValue22nd);
		stackControls.add(self.lblTaxValue32nd);
		stackControls.add(self.lblRoundUp2nd);
		stackControls.add(self.lblCredit2nd);
		stackControls.add(self.lblCashPayReqd2nd);
		stackControls.add(self.txtCashPayment2nd);
		stackControls.add(self.lblPayC2);				//+TFS40904
		
		self.lblSubTotal2nd.stackVertical(stackControls, gap);
		self.lblCashPayment2nd.top:=txtCashPayment2nd.top;
	endif;
	
	//if _initialSetup then  // 25.09.2019 cnwma1 #46707
		paymentHeight:= self.frmPaymentValues.top + ((self.cmbMOP.top + self.cmbMOP.height));// - (self.lblSubTotal2.top)); // 25.09.2019 cnwma1 #46707

		///self.frmPaymentValues.height:=paymentHeight + 20;  // keep this at the full height

		self.frmPayment.height:=paymentHeight.max(self.frmChqDetails.top + self.frmChqDetails.clientHeight); 
	
		self.frmPayment.top:= (self.btnSave.top  - 20) - self.frmPayment.clientHeight; 
		self.frmTables.height:= self.frmPayment.top - self.frmTables.top;
	
	//endif;              // 25.09.2019 cnwma1 #46707

epilog
	delete stackControls;
end;</source>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
