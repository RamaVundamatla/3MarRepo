    <JadeMethod name="getDisplayStringForAttribute" id="7dd1fbd8-f3dd-4119-bd66-12854cec0c63">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 July 2009	cnwrd1	Initial creation
// 10 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

begin
	if _attrName = ETRow_RequiredByDT then
		return self.systemToLocalTime(self.requiredByDT).date.String;// 10 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	elseif _attrName = ETRow_TargetSubTerminal then
		if self.myTargetSubTerminal &lt;&gt; null then
			return self.myTargetSubTerminal.code;
		else 
			return null;
		endif;
	else
		return inheritMethod(_attrName, _short);
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="024c2f8c-a070-4f4a-95ed-4de75f386589">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
// ---------------------------------------------------------------------------
// Created:		April 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 08/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception

vars
	block : CM_DataContainerBlock;
	str : String;
	locFullId : String;
	invalidSourceLocation : Boolean;
	srcLocation	: CM_LocationsController;
begin
	inheritMethod(_dataContainer);
	//26/02/2010 cnwdz2 par21933
	on Exception do app.handleDeletedObject(exception,srcLocation, invalidSourceLocation);
	srcLocation := self.sourceLocation;
	if srcLocation &lt;&gt; null then
		locFullId := srcLocation.getFullId();
		if not invalidSourceLocation then
			block := _dataContainer.addNewBlock;
			block.addNewItem(app.getErrorString(CM_Source_Location), DC_Label, 1, null);
			block.addNewItem(locFullId, DC_Data, 1, null);
		endif;
	endif;

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Target_Location), DC_Label, 1, null);
	block.addNewItem(self.targetLocation, DC_Data, 1, null);

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getNextUnallocatedWLE" id="6ddd58c7-2f7b-40f1-9fbc-6e15bdae0ff3">
        <source>getNextUnallocatedWLE() : CM_YardWLE;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 July 2009	cnwrd1	Initial creation

*/

vars
	wle : CM_WorkListEntry;
begin

	foreach wle in self.allWorkListEntries do
		if wle.myTrackedItem = null then
			return wle.CM_YardWLE;
		endif;
	endforeach;
	
	return null;

epilog

end;</source>
        <ReturnType type="CM_YardWLE"/>
    </JadeMethod>
