    <JadeMethod name="trxUpdateFutureStorageDays" id="1f81995f-818e-4ac9-892b-6062b337b696">
        <updating/>
        <source>trxUpdateFutureStorageDays(_tiArray 			   : CM_TIArray input;
					  _additionalStorageDays : Integer;
					  _changeReason          : String;
					  _passport 			   : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 June 2023 navmv20 CR 58373 Task 58381: Jade - Future Storage Additional Days

*/

vars
	ti : CM_TrackedItem;
begin
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	_passport.useTITransactionDeferUpdate	:= true;
	_passport.useTIDictDeferUpdate			:= true;

	beginTransaction;
	
	foreach ti in _tiArray do
		app.myUtilityUA.utlUpdateFutureStorageDays(ti,_additionalStorageDays,_changeReason,_passport);
		if (not self.checkValidationWithPassport(_passport)) then
			return;
		endif;
	endforeach;
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
