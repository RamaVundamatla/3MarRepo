    <JadeMethod name="addToolbarControls" id="900247de-9678-429a-b7d2-c4610a249749">
        <updating/>
        <source>addToolbarControls() updating, protected;
//--------------------------------------------------
// Created:	23 January 2004 By: cnwgd1
//03 Oct 2017	cnwma1  TFS #7257 JMT - Refactoring - Commodity Planning
//--------------------------------------------------
vars
	toolbar		: CMUI_Toolbar;
begin
	inheritMethod();
	
	toolbar := self.frmToolbar;
	toolbar.addButton(self.btnStepBack, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnStepForward, CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnNewVoyage, CMUI_Toolbar.Control_Alignment_Left);	
	//epr par 16813 26/5/08
	toolbar.addButton(self.btnSenarioVoyage, CMUI_Toolbar.Control_Alignment_Left);	

	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);

	self.btnSaveBase.enabled := false;

	//=======================================
	// now setup meterMarkToolbar
	//=======================================
	toolbar := self.frmMarksToolbar;

	toolbar.addButton(self.btnSaveExtra, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addFrame(self.frmMeterMark, CMUI_Toolbar.Control_Alignment_Left);		
	toolbar.addButton(self.btnCancel, CMUI_Toolbar.Control_Alignment_Right);			
	
	toolbar.positionToolbarControls();
	toolbar.visible := true;	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="applyMovementChange" id="3fde44d9-66a7-467d-b16c-c8d6bd9190c1">
        <updating/>
        <source>applyMovementChange(oldMovement : CMIF_HMS_WorkingMovement; newMovement : CMIF_HMS_WorkingMovement) updating;

vars

begin

 	// Determine whether movement is ADD, DELETE or EDIT
 	if oldMovement=null then
 		// Add
 		if newMovement.myBerth=currBerthForView then
 			buildEntireForeground;
 		endif;
 	elseif newMovement=null then
 		// Delete
 		if oldMovement.myBerth=currBerthForView then
 			buildEntireForeground;
 		endif;
 	else
 		// Edit
 		if oldMovement.myBerth=currBerthForView or newMovement.myBerth=currBerthForView then
 			buildEntireForeground;
 		endif;
 	endif;
end;</source>
        <Parameter name="oldMovement" type="CMIF_HMS_WorkingMovement"/>
        <Parameter name="newMovement" type="CMIF_HMS_WorkingMovement"/>
    </JadeMethod>
