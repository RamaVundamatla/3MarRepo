    <JadeMethod name="initializeForActivity" id="8b8378b7-76c9-40a8-88e8-d497c53c6c7b">
        <updating/>
        <source>initializeForActivity(_ewsOpsView: CM_EWSActivityOpsview; _opsViewTable : CMIF_OpsViewTables) updating;
/*
Purpose:			

Date		Who		Reason
04 May 2022	navab1	TFS 53569
*/

vars
	visitDetails : CMIF_ArgoVisitDetails;
	carrierVisit : CMIF_ArgoCarrierVisit;
	vesselDetails : CMIF_VslVesselVisitDetails;
	berthDetails : CMIF_VslVesselBerthings;
	vesVessel : CMIF_VslVessels;
	hasHmsMove : Boolean;
	movement : HMS_Movement;
	seq : Integer;
begin

	if _opsViewTable.isKindOf(CMIF_ArgoVisitDetails) then
		visitDetails := _opsViewTable.CMIF_ArgoVisitDetails;
		
		visitDetails.tableName := visitDetails.Argo_visit_details;
		visitDetails.gkey := visitDetails.generateFullGKey(self, "");
		visitDetails.eta := self.estimatedArrivalDT.asEpochFormat();
		visitDetails.etd := self.estimatedDepartureDT.asEpochFormat();
		visitDetails.service := visitDetails.generateFullGKey(self.myTrade, "");
		
	
		create vesselDetails transient;
		vesselDetails.termOid := visitDetails.termOid;
		vesselDetails.oid := visitDetails.oid;
		
		
		self.initializeForActivity(_ewsOpsView, vesselDetails); 
		visitDetails.vslVesselVisitDetails := vesselDetails;
		
		
	elseif _opsViewTable.isKindOf(CMIF_ArgoCarrierVisit) then
		carrierVisit :=  _opsViewTable.CMIF_ArgoCarrierVisit;

		carrierVisit.tableName := carrierVisit.Argo_carrier_visit;
		carrierVisit.gkey := carrierVisit.generateFullGKey(self, "");
		carrierVisit.cvcvd_gkey := carrierVisit.generateFullGKey(self, "");
		
		//carrierVisit.ata := self.arrivedDT.asEpochFormat();	// navra1 - TFS 53569 - 5th May 2022
		if self.hasDeparted then
			carrierVisit.atd := self.departedDT.asEpochFormat();
		else
			carrierVisit.atd := null;
		endif;
		
		carrierVisit.carrier_mode  := carrierVisit.Carrier_mode_Vessel;
		carrierVisit.cpx_gkey := carrierVisit.generateCpxGKey();
		carrierVisit.fcy_gkey := carrierVisit.generateFullGKey(self.myTerminal, "");
		carrierVisit.id  := self.code;
		carrierVisit.operator_gkey := carrierVisit.generateFullGKey(self.myOperator, "");
		if self.isDefaultVoyageProcess() then
			carrierVisit.phase := carrierVisit.n4VoyageStatus(self.status);
			
			// navra1 - TFS 53569 - 5th May 2022
			//We dont want to have an ata without the vessel arriving
			if self.status = Voyage_Status_Pending then
				carrierVisit.ata := null;
			else
				carrierVisit.ata := self.arrivedDT.asEpochFormat();
			endif;	
			
		else
			carrierVisit.phase := carrierVisit.n4VoyageStatusWO(self.status);
			// navra1 - TFS 53569 - 5th May 2022
			//We dont want to have an ata without the vessel arriving
			if self.status &lt;= Voyage_Status_VoyageApproved then
				carrierVisit.ata := null;
			else
				carrierVisit.ata := self.arrivedDT.asEpochFormat();
			endif;	
		endif;
		
	
		create visitDetails transient;
		visitDetails.termOid := carrierVisit.termOid;
		visitDetails.oid := carrierVisit.oid;
		
		
		self.initializeForActivity(_ewsOpsView, visitDetails); 
		carrierVisit.argoVisitDetails := visitDetails;
	elseif _opsViewTable.isKindOf(CMIF_VslVesselVisitDetails) then
		vesselDetails :=  _opsViewTable.CMIF_VslVesselVisitDetails;

		vesselDetails.tableName := vesselDetails.Vsl_vessel_visit_details;
		vesselDetails.gkey := vesselDetails.generateFullGKey(self, "");
		vesselDetails.vvd_gkey := vesselDetails.generateFullGKey(self, "");
		vesselDetails.classification := vesselDetails.n4VoyageClassification(self);
		vesselDetails.vessel_gkey := vesselDetails.generateFullGKey(self.getMyVessel(), ""); 
		
		hasHmsMove  := self.hasHmsMovement();
		
		if hasHmsMove then
			foreach movement in self.myHMSVoyageData.allVoyageMovements discreteLock do 
				create berthDetails transient;
				berthDetails.termOid := vesselDetails.termOid;
				berthDetails.oid := vesselDetails.oid;
				
//					seq := seq +1;
//					berthDetails.seq := seq;
					movement.initializeForActivity(_ewsOpsView, berthDetails);
					vesselDetails.allVslVesselBerthings.add(berthDetails);	
			endforeach;
		endif;	
	elseif _opsViewTable.isKindOf(CMIF_VslVessels) then // ### TFS 53105 14SEP2022 NAVAB1
		vesVessel := _opsViewTable.CMIF_VslVessels;
		vesVessel.gkey := vesVessel.generateFullGKey(self.getMyVessel(), ""); 
		vesVessel.id	:= self.vesselCode; 
		vesVessel.name	:= self.vesselName; 
		vesVessel.vesclass_gkey := vesVessel.generateFullGKey(self.getMyVessel(), ""); // navra1 - 8th Sep 2022 - TFS53105
	endif;
	
epilog

end;</source>
        <Parameter name="_ewsOpsView" type="CM_EWSActivityOpsview"/>
        <Parameter name="_opsViewTable" type="CMIF_OpsViewTables"/>
    </JadeMethod>
    <JadeMethod name="is30FooterVisibleForReports" id="a56e3abd-621d-4975-be97-249d5e5037b0">
        <source>is30FooterVisibleForReports() : Boolean;
// ----------------------------------------------------------------------------------
// Created:     23 May 2008 by cnwvu1
//
// Purpose:     Designed for the report: CM_VoygaeJobSeq[Med/Large/LargeLandscape]
//				Checks whether the column for 30 ISO Type footers is visible
// ----------------------------------------------------------------------------------

vars
	isOwn	: Boolean;
	
begin
	
	if app.is30IncludedForReportsAsColumn( isOwn ) then
		if isOwn then
			return true;
		endif;
	endif;
	
	return false;

end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="is30FooterVisibleIn40Total" id="df06b2b6-67a6-457f-a8a1-236b69992fa5">
        <source>is30FooterVisibleIn40Total() : Boolean;
// --------------------------------------------------------------------------------------------
// Created:     26 May 2008 by cnwvu1
//
// Purpose:     Designed for the report: CM_VoygaeJobSeq[Med/Large/LargeLandscape]
//				Checks whether the name for 30 ISO Type footers is visible
//				in the caption "40 Total" according to the Terminal Configuration:
//					30'	: 	Not Included- caption = "40 Total"
//							Own column	- caption = "40/30 Total"
//							Other column- caption = "40/30 Total"
// --------------------------------------------------------------------------------------------

vars
	isOwn	: Boolean;
	
begin
	
	if app.is30IncludedForReportsAsColumn( isOwn ) then	//should "45" be included as part in the caption "40 Total" ?
		return true;	// we have '40/45 Total' column, when 45' is included as Own/Separate column
	endif;
	
	return false;
	
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="is45FooterVisibleForReports" id="47ca12de-54e2-4855-87df-607e070271e0">
        <source>is45FooterVisibleForReports() : Boolean;
// --------------------------------------------------------------------------------------------
// Created:     26 May 2008 by cnwvu1
//
// Purpose:     Designed for the report: CM_VoygaeJobSeq[Med/Large/LargeLandscape]
//				Checks whether the name for 45 ISO Type footers is visible
//				in the captions according to the Terminal Configuration:
//					45'	: 	Not Included- captions = "40 Single" and "40 Total"
//							Own column	- captions = "40/45 Single" and "40/45 Total"
//							Other column- captions = "40 Single" and "40/45 Total"
//								("40 Single" - because 45' included as part in the Other column
//				Note. 45' hasn't got its own column, because it is counted in the 40' column.
//					So, we just are interested in the captions for the reports.  
//				See  is45FooterVisibleIn40Total() as well.
// --------------------------------------------------------------------------------------------

vars
	isOwn	: Boolean;
	
begin
	
	if app.is45IncludedForReportsAsColumn( isOwn ) then
		if isOwn then
			return true;	// we have '40/45 Single' column, when 45' is considered as Own column
		endif;
	endif;
	
	return false;
	
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="is45FooterVisibleIn40Total" id="58eb4a40-169b-4d38-b027-ef444d4f4c1f">
        <source>is45FooterVisibleIn40Total() : Boolean;
// --------------------------------------------------------------------------------------------
// Created:     26 May 2008 by cnwvu1
//
// Purpose:     Designed for the report: CM_VoygaeJobSeq[Med/Large/LargeLandscape]
//				Checks whether the name for 45 ISO Type footers is visible
//				in the captions according to the Terminal Configuration:
//					45'	: 	Not Included- captions = "40 Single" and "40 Total"
//							Own column	- captions = "40/45 Single" and "40/45 Total"
//							Other column- captions = "40 Single" and "40/45 Total"
//								("40 Single" - because 45' included as part in the Other column
//				Note. 45' hasn't got its own column, because it is counted in the 40' column.
//					So, we just are interested in the captions for the reports.
//				See  is45FooterVisibleIn40Single() as well.
// --------------------------------------------------------------------------------------------

vars
	isOwn	: Boolean;
	
begin
	
	if app.is45IncludedForReportsAsColumn( isOwn ) then	//should "45" be included as part in the caption "40 Total" ?
		return true;	// we have '40/45 Total' column, when 45' is included as Own/Separate column
	endif;
	
	return false;
	
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="is53FooterVisibleForReports" id="17664b63-cc95-4f77-8e59-5ba0e66921c2">
