KJBHUhTE/bOz+WNjI/S/t/gpx/o/lV3k4f5nlUVTI4jg52fCoFIKaOhIHbii06AXw9xG0Vn4Yvaw
r5jkKRYU2YbGR3p7YZamYYoyKXGQQ03CVGIxkN4ko1YkKMJW5/lBZ25nopS5PAVWjsPAwUE0YSJL
/WUpvVzMLVCR2CjYOX58/j6AbBRcnJwcnBQWf8C4KX59Uzj8HQNycf0JY/9Z7X/BQLx/xrh5gH/C
eEG8/4oBgTw8f8LYQX/yBbLzgv4U74f3XzwH+19gHH+Bgf4C4/wLjOsva/UnjO1PNQXycv3p2diB
vJz/grFz8/5Y/TPGAWTj/teacgCBf9wjNxdjaztzl1+H/rejzvF/+3z/doSNXdx+O1McQBDbj0NF
QyOpLPWPc8b2/4Uaq4qLuQfFL0a/fv2v3OwpfhXsXzmz/9iW3zn/D2i3qR0=";

vars
	parent	 	 		: CM_CargoType;
	outputFile			: File;
	logDir,
	csvBase64			: String;
	fileData 	 		: CM_FileData;
	fileStorageDetail 	: CM_FileDataStorageDetail;

begin
	/*
	** Clean Up After Last test
	*/
	self.deleteUnitTestFiles(CargoType);
	
	create outputFile transient;
	outputFile.usePresentationFileSystem := false;
	outputFile.fileName := logDir &amp; "my-dummy-ut-pdf.pdf";
	
	//Delete our originally created file
	if outputFile.isAvailable() then
		outputFile.purge();
	endif;
	
	//Clean up transient
	delete outputFile;
	
	/*
	**	Setup Test
	*/
	parent	:= getRoot.getCargoTypeFromAbbrevOrDescr(CargoType);
	logDir	:= app.getAppServerLogDir() &amp; '/tmpFiles/';
	
	//Export Base64 Encoded String to a Binary file. In this case a PDF
	create outputFile transient;
	outputFile.kind					     := File.Kind_Binary;
	outputFile.maxRecordSize 			 := 100000;
	outputFile.usePresentationFileSystem := false;
	outputFile.openOutput(logDir &amp; "my-dummy-ut-pdf.pdf");
	outputFile.writeBinary(FILEDATA.base64Decode().uncompressToBinary());
	outputFile.close();
	
	/*
	**	Run Test
	*/
	//app.myTrxUA.trxAddFile(parent, logDir &amp; "my-dummy-ut-pdf.pdf", "My Dummy File", "My Dummy File", null, "My Dummy File",app.myPassport);					//22.2.2023 navhl20	#56625[56517]
	app.myTrxUA.trxAddFile(parent, logDir &amp; "my-dummy-ut-pdf.pdf", "My Dummy File", "My Dummy File", null, "My Dummy File",FileContext_Null ,app.myPassport);	//22.2.2023 navhl20	#56625[56517]
	
	//Delete our originally created file
	outputFile.purge();
	
	fileData := parent.allFiles.first;
	
	if fileData &lt;&gt; null then
		fileStorageDetail := fileData.allFileDataStorageDetail.first;
		csvBase64 := fileStorageDetail.csvBlob.base64Encode();
	endif;
	
	/*
	**	Assert Test
	*/
	//Check Trx has no errors
	self.assertNoTrxErrorsOrWarnings();
	
	//Check saved data matches our original data
	self.assertTrueMsg(csvBase64 = FILEDATA, "File Data does not match what is expected");

epilog
	delete outputFile;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tAddCargoTypeAndProduct" id="1ddb14b5-65e4-4ba2-9ca8-b1d2a63e73a9">
        <source>tAddCargoTypeAndProduct();

/*

Purpose:		Add Cargo Type and Product.  Update Product,

Date			Who		Reason
15/05/2015		cnwmh5	Initial creation

*/
constants

	CargoTypeId						: String = "UTMDHCT";
	ProductId						: String = "UTMDHCTP";
	
vars

	cargoType						: CM_CargoType;
	product							: CM_Product;
	operator						: CM_Operator;
	
	selectedDamagePos				: CM_ObjectSet;

begin

	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString());
	self.assertNotNull(operator);

	cargoType := self.addCargoType(CargoTypeId, true);
	self.assertNotNull(cargoType);
		
	product := self.addProduct(ProductId, operator, cargoType);
	self.assertNotNull(product);
	
	self.opts.purge();
	self.opts.addAssoc("isReefer", true);
	self.updateProduct(product, operator, cargoType);
	self.assertEqual(product.isReefer, true);
	
	// 21/05/2015 cnwmh5 - Add trxUpdateCargoType
	create selectedDamagePos transient;
	selectedDamagePos.add(app.myRoot.allDamagePositionsByCode["Back"]);
	selectedDamagePos.add(app.myRoot.allDamagePositionsByCode["Right"]);
	selectedDamagePos.add(app.myRoot.allDamagePositionsByCode["Left"]);
	
	self.opts.purge();
	self.opts.addAssoc("DamagePosition", selectedDamagePos);
	self.updateCargoType(cargoType);
	self.assertEqual(cargoType.allDamagePositions.size, 3);

epilog

	delete selectedDamagePos;

end;</source>
    </JadeMethod>
    <JadeMethod name="tAddUserDefinedCargoType" id="fa5185eb-8666-48d1-8dd9-30163b42af59">
        <source>tAddUserDefinedCargoType();
// cnwer1
//06 August 2009	cnwdw1	
//
vars
	cargoType: CM_CargoType;
begin
	self.deleteCargoType("UT_USR");
	
	cargoType := self.addCargoType("UT_USR", false);
	assertNotNull(cargoType);
end;</source>
    </JadeMethod>
    <JadeMethod name="tChassisCargoType" id="2ba2ce40-af89-4342-8129-df743b018ef8">
        <source>tChassisCargoType();
/*

Purpose:			Testlink 01-1101

Date		Who		Reason
07 April 2016	cnwmk3	Initial creation
10/03/2023	jlika1	Add width to Trailer Type
*/
constants
	Cargo_Type			= "UT_Chassis";
	TrailerId			= "UT_TRAILER";
vars
	ct					: CM_CargoType;
	trailer				: CM_TILCType;
	selectedDamageCodes	: CM_ObjectSet;
begin
	// Create a User Defined Chassis cargo type (Track As set to Trailer)
	self.opts.purge;
	self.opts.addAssoc("TrackAs",ProductType_Trailer);
	ct:=self.addCargoType(Cargo_Type, false);
	
	self.assertNotNull(ct);
	self.assertEqual(ct.productType,ProductType_Trailer);
	self.assertEqual(ct.myClassToCreate, CM_TILC);
	
	// Add Damage codes to User Defined Chassis
	create selectedDamageCodes transient;
	selectedDamageCodes.add(app.myRoot.allDamageDefinitionCodes["BENT"]);
	selectedDamageCodes.add(app.myRoot.allDamageDefinitionCodes["DENT"]);
	selectedDamageCodes.add(app.myRoot.allDamageDefinitionCodes["HOLE"]);
	
	self.opts.purge();
	self.opts.addAssoc("DamageCodes", selectedDamageCodes);
	self.updateCargoType(ct);
	self.assertEqual(ct.allDamageDefinitionCodes.size, 3);
	
	//Add new trailer type
	trailer :=self.addTrailerType(TrailerId,TrailerId,ct,500,1,50,30000,13000,null,null,500);
	self.assertNotNull(trailer);
	self.assertEqual(trailer.numControllers,1);
	self.assertEqual(trailer.myCargoType, ct);
	self.assertEqual(trailer.width.asStringJMT,"500.0000");
epilog
	delete selectedDamageCodes;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCommodityCargoNonISO" id="818382bb-bb09-41d5-a054-1fa044385650">
        <updating/>
        <source>tCommodityCargoNonISO() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 February 2016	cnwns1	Initial creation

TESTLINK 01-1250

Find a Cargo Type that requires Commodity and Subtypes, where there is more than one commodity selected.


*/

constants

	CargoTypeId		: String = "UTNSCT";
	ProductId1		: String = "UTNSCTP1";
	ProductId2		: String = "UTNSCTP2";
	CargoId1		: String = "NICK6666661";
	CargoId2		: String = "NICK6666662";
	CargoId3		: String = "NICK6666663";
	BsID			: String = "NICKBS2";
    ComodityID1 	: String = "COM1";
    ComodityID2 	: String = "COM2";
vars

	cargoType		: CM_CargoType;		
	product1		: CM_Product;
	product2		: CM_Product;
	operator		: CM_Operator;
	bs1				: CM_BlockStack;
	cargo1			: CM_TrackedItem;
	cargo2			: CM_TrackedItem;
	cargo3			: CM_TrackedItem;	
	pxyTI1			: CM_TrackedItem;
	pxyTI2			: CM_TrackedItem;
	pxyTI3			: CM_TrackedItem;	
	allComodities	: CM_CommodityByCodeDict;
	comod1			: CM_Commodity;
	comod2			: CM_Commodity;
	allCargoTypes	: ObjectArray;
begin

	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString());
	self.assertNotNull(operator);
	
	bs1 := self.addBlockStack(BsID, 999, null);
	self.assertNotNull(bs1);
	
	create allComodities transient;
	
	comod1 := self.addCommodity(ComodityID1,"Comodity One",allCargoTypes);
	comod2 := self.addCommodity(ComodityID2,"Comodity Two",allCargoTypes);
	
	allComodities.add(comod1);
	allComodities.add(comod2);
	
	self.opts.purge();
	self.opts.addAssoc("Comodities",allComodities);
	
	cargoType := self.addCargoType(CargoTypeId, true);
	self.assertNotNull(cargoType);
	self.assertEqual(cargoType.allCommodities.size(),2);
	
	self.assertEqual(cargoType.defaultCommodityCode,comod1.code);
	
		
	product1 := self.addProduct(ProductId1, operator, cargoType);	
	self.assertNotNull(product1);
		
	product2 := self.addProduct(ProductId2, operator, cargoType);
	self.assertNotNull(product2);
	
	
	self.opts.purge();
	self.opts.addAssoc("CargoComodity",comod1.code);
	
	cargo1 := self.addCargoAtLocation(CargoId1,product1,operator,bs1.myLocationsController);
	self.assertNotNull(cargo1);
	self.assertEqual(cargo1.getCommodityDesc,product1.description);
	
	
	cargo2 := self.addCargoAtLocation(CargoId2,product1,operator,bs1.myLocationsController);
	self.assertNotNull(cargo2);
	self.assertEqual(cargo2.getCommodityDesc,product1.description);
	
	
	cargo3 := self.addCargoAtLocation(CargoId3,product1,operator,bs1.myLocationsController);
	self.assertNotNull(cargo3);
	self.assertEqual(cargo3.getCommodityDesc,product1.description);
	
	self.assertEqual(cargo1.myProduct,product1);
		
	pxyTI1 := app.createUpdateProxy(cargo1).CM_TrackedItem;
	pxyTI2 := app.createUpdateProxy(cargo2).CM_TrackedItem;
	pxyTI3 := app.createUpdateProxy(cargo3).CM_TrackedItem;
	
	pxyTI1.setPropertyValue(CM_TrackedItem::totalWeight.name, 2000.Decimal);
	pxyTI2.setPropertyValue(CM_TrackedItem::totalWeight.name, 2000.Decimal);
	pxyTI3.setPropertyValue(CM_TrackedItem::totalWeight.name, 2000.Decimal);
	
	
	pxyTI1.setMyProduct(product2);
	pxyTI2.setMyProduct(product2);
	pxyTI3.setMyProduct(product2);

	pxyTI1.setCommodity(comod2.code);	
	pxyTI2.setCommodity(comod2.code);
	pxyTI3.setCommodity(comod2.code);
	
	app.myTrxUA.trxUpdateTrackedItem(pxyTI1, null, TI_UPDMODE_NORMAL, null, app.myPassport);
	app.myTrxUA.trxUpdateTrackedItem(pxyTI2, null, TI_UPDMODE_NORMAL, null, app.myPassport);
	app.myTrxUA.trxUpdateTrackedItem(pxyTI3, null, TI_UPDMODE_NORMAL, null, app.myPassport);
	
	
	self.assertEqual(cargo1.myProduct,product2);
	self.assertEqual(cargo1.myCargoType.allCommodities.size,2);
	self.assertEqual(cargo1.commodity,comod2.code);
	
	self.assertEqual(cargo2.myProduct,product2);
	self.assertEqual(cargo2.myCargoType.allCommodities.size,2);
	self.assertEqual(cargo2.commodity,comod2.code);
	
	self.assertEqual(cargo3.myProduct,product2);
	self.assertEqual(cargo3.myCargoType.allCommodities.size,2);
	self.assertEqual(cargo3.commodity,comod2.code);
	

epilog

	delete pxyTI1;
	delete pxyTI2;
	delete pxyTI3;

end;</source>
    </JadeMethod>
    <JadeMethod name="tSysCargoTypeQuantityCheck" id="450c49a3-63f5-42a8-a9f1-c7f16e3ab043">
        <source>tSysCargoTypeQuantityCheck();
// cnwer1
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 November 2013	cnwdw1	Initial creation
*/
vars
	bs: CM_BlockStack;
	cargoType: CM_CargoType;
	cargo: CM_TrackedItem;
begin
	bs := self.addBlockStack("UTBS1", 99, null);
	cargoType := self.getCargoType("CAR");
	self.deleteCargo("CAR0000004", cargoType);
	
	self.opts.addAssoc("quantity", 10);
	cargo := self.addCargoOpts("CAR0000004", "", "", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), cargoType.id);
	self.assertEqualMsg(cargo.totalQuantity, 1, "TotalQuantity wrong");
	self.assertEqualMsg(cargo.quantity, 10, "Quantity wrong");
epilog

end;</source>
