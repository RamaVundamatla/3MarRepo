    <JadeMethod name="isSuspended" id="ee4cded9-b00c-4e8a-b197-e313567c478f">
        <source>isSuspended() : Boolean;
// ---------------------------------------------------------------------------
// Created:     26 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
05 Apr 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration
21 Sep 2020 cnwma1  ChangeRequest 49758: MTN - Navis Smart Data API - Snapshot Data
*/

begin
	// added disabled by admin to this method. PAR 10954 HG 17/11/2005
	// TFS 37190 - Changed to isDisabled to include notAvailableForEntry
//	if self.status = SuspendedBadPasswordsUser or self.isDisabled() then 
	if self.status = SuspendedBadPasswordsUser then //23 Nov 2020	NDL TFS 50378
