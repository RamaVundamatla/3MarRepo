    <JadeMethod name="addTableData" id="3a30c709-e971-46c9-b76a-faa2a981276b">
        <updating/>
        <source>addTableData( _mtPoolEnqLine : CM_MTPoolingEnquiryLine ) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 June 2011	cnwndl1	Initial creation

*/

vars

	index : Integer;
	col : Integer;
	cell : JadeTableCell;
	row : JadeTableRow;
	entTableRow : EntTableRow;

begin
	
	self.tblData.rows := self.tblData.rows + 1;
	index := self.tblData.rows;
	row := self.tblData.accessRow(index);
	if row &lt;&gt; null then
		row.itemObject := _mtPoolEnqLine;
	endif;
	
	foreach col in 1 to self.tblData.columns do
		cell := self.tblData.accessCell(index,col);
		entTableRow := self.tblData.allTblDataEntRows[col];
		_mtPoolEnqLine.populateCell( cell, entTableRow );
	endforeach;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_mtPoolEnqLine" type="CM_MTPoolingEnquiryLine"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="20d48fdf-1260-4a06-b47c-0788b481bb07">
        <updating/>
        <source>addToolbarControls() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 June 2011	cnwndl1	Initial creation	Par 27731

*/

vars

	toolbar	: CMUI_Toolbar;

begin

	inheritMethod();
	
	toolbar := self.frmToolbar;
	toolbar.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnShowSearcher, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnRefresh, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addFrame(self.frmLastUpdated, CMUI_Toolbar.Control_Alignment_Right);
	
	
	
	toolbar := self.frmQueryToolbar;
	
	toolbar.showCaptions := false;
	toolbar.addButton(self.btnQuery, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnResetSearch, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnHideSearcher, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.positionToolbarControls();
	toolbar.visible := true;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
