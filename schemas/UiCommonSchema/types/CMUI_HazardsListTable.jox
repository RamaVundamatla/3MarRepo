        <source>'listTable'</source>
        <type name="String"/>
    </Constant>
    <Constant name="XMLTag_SelectedValue" id="a2757801-5290-44fe-89f6-cf21ff366914">
        <source>'selectedValue'</source>
        <type name="String"/>
    </Constant>
    <ImplicitInverseRef name="allRowTransients" id="5103b25e-6b2b-4f35-a005-0607aa7ff794">
