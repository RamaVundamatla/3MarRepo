    <JadeMethod name="hasUnpackTask" id="cf45d6af-8d9e-47b1-8eb0-13d3a28f871c">
        <source>hasUnpackTask() : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 Jul 2009	cnwrd1	Initial creation
28 May 2024 navma1	Bug 64224: MTN - DeadLocks Caused by Future Actors
*/

vars
	found : Boolean;
	task : CM_WorkOrderDtl;
begin

	found := false;
	
	//jlier1 TFS 59748 17/8/23	
	foreach task in self.allWoDtls discreteLock where task.isWorkOrderTIDtl do 	//28.05.2024 navma1 #64224
		if  task.detailType = WO_TASK_UNPACK then
			found := true;
			break;
		endif;
	endforeach;
	
	return found;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
