    <JadeMethod name="create" id="ba2a1e26-e2f0-4187-b5bf-3d0591e50d96">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 August 2016	cnwrh7	Initial creation

// Purpose:		make sure we have a TCPIPConnection object to play with and see exception handler
*/

vars

begin
	on ConnectionException do self.handleConnectionException(exception) global;
	create myTCPConnection;
	self.diagnosticLog(method.qualifiedName &amp; " myTCPPort=" &amp; self.myTCPConnection.String);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="cbc10df3-d4f8-48e7-af2f-a8313806a3ba">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 August 2016	cnwrh7	Initial creation

*/

vars

begin
		self.diagnosticLog(method.qualifiedName &amp; " myTcpConnection=" &amp; self.myTCPConnection.String &amp; " connectingState=" &amp; self.connectingState.String);
		self.tcpConnectReady := false;
		
		delete myTCPConnection;
		
		on ConnectionException do null global;
		
		if self.myTCPDetails &lt;&gt; null and self.myTCPDetails.isTransient then	//no doing this as myTCPDetails is not created as transient in initializeWithParam
				delete self.myTCPDetails;
		endif;
		
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="diagnosticLog" id="e628e324-37e9-443d-9a23-1a71cd5600ec">
        <source>diagnosticLog(_msg : String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 August 2016	cnwrh7	Initial creation

*/

vars

begin

	app.writeLog(_msg, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053

epilog

end;</source>
