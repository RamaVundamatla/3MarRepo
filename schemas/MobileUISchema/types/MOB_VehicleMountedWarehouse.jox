    <JadeMethod name="doAccept" id="88501060-35c7-4cf9-93a8-f032fb2276a2">
        <updating/>
        <source>doAccept() protected,updating;
/*

Date		Who		Reason
06 August 2014	cnwer1	Initial creation PAR

*/

vars
	allSelectedQEntries : CM_RTQueueEntryArray;
begin

	if self.tblSelectTasks.visible then	
		create allSelectedQEntries transient;
		self.getSelectedRTQueueEntries(allSelectedQEntries);
		if allSelectedQEntries.size &gt; 0 then	
			if app.myVMAgent.doAcceptRTQueueEntries(allSelectedQEntries) then
				self.showWorkingTasks(false);
			endif;		
		endif;
	else
		self.showSelectTasks;
	endif;
epilog
	self.doResize();
	delete allSelectedQEntries;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doActionForFunctionKey" id="7309b237-f697-4ac5-8dd4-3dcb0fda1818">
        <updating/>
        <source>doActionForFunctionKey(_key : Integer) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 May 2010	cnwjk3	Initial creation

*/

vars
	action : Integer;
begin
	action := self.getActionForFunctionKey(_key);
	
	if action = self.ACTION_REFRESH then
		self.doResetSearch();
	elseif action = self.ACTION_ACCEPT then
		self.btnAccept.click(self.btnAccept);
	elseif action = self.ACTION_REJECT then
		self.btnReject.click(self.btnReject);
	elseif action = self.ACTION_HELP then
		if not self.frmF1Help.visible then
			self.showF1Help();
		else
			self.frmF1Help.visible:=false;
			self.enableAllControls(); //cnwrd1 par 24940 9.7.2010
		endif ;
	endif;
	
	if _key = J_key_F11 then
		self.inspect;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_key" type="Integer"/>
    </JadeMethod>
