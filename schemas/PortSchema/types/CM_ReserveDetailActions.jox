    <JadeMethod name="getAllTisFromDocument" id="30303ab2-d45e-4678-b433-fd2a77a2dbd0">
        <source>getAllTisFromDocument(_tiArray : CM_TIArray input);
/*
Purpose:			
Date		Who		Reason
28 March 2017	cnwab1	Initial creation
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
*/

vars
	ti : CM_TrackedItem;
	allTis	: CM_TISet; 
begin
	if self.myReserveDetail = null then
		return;
	endif;
	
	create allTis transient; //23/06/2023	navkc1	CR 58406 Task 58408
	
	self.myReserveDetail.getAllTrackedItems(allTis, false); //23/06/2023	navkc1	CR 58406 Task 58408
	
	//foreach ti in self.myReserveDetail.allTrackedItems discreteLock do
	foreach ti in allTis discreteLock do //23/06/2023	navkc1	CR 58406 Task 58408
		_tiArray.addExclusive(ti);
	endforeach;
	
epilog
	delete allTis; //23/06/2023	navkc1	CR 58406 Task 58408
end;</source>
        <Parameter name="_tiArray" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getCargoType" id="fb0a6e23-5a8a-46af-bd73-8154e30c9633">
        <source>getCargoType(): CM_CargoType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 September 2016	cnwndl1	Initial creation

*/

vars

begin
	
	if self.myReserveDetail &lt;&gt; null then
		return self.myReserveDetail.getCargoType;
	endif;
	
	return null;
	
epilog

end;</source>
        <ReturnType type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="getDocumentAmount" id="7cc2ed05-ec99-495b-b69d-221c685add19">
        <source>getDocumentAmount() : Integer;
/*
Purpose:		 // ### TFS 3283	
Date		Who		Reason
24 March 2017	cnwab1	Initial creation
*/

vars

begin
	if self.myReserveDetail = null then
		return 0;
	endif;
	
	return self.myReserveDetail.totalRequested;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDocumentId" id="ec827b05-4f19-41ff-83c5-f1f7e53efc8b">
        <source>getDocumentId(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 September 2016	cnwndl1	Initial creation	TFS 2647 / 2001

*/

vars

	str : String;
	ti : CM_TrackedItem;

begin

	if self.myReserveDetail.isKindOf(CM_ReserveSelection) then
		str := self.myReserveDetail.getTotalRequestedDisplay() &amp; ' x ' &amp; self.myReserveDetail.getProductISOTypeDescr();
		if self.getCargoType = null then	
			str := str &amp; " " &amp; app.getErrorString(Unspecified_Cargo_Type);
		endif;
		
	elseif self.myReserveDetail.isKindOf(CM_ReserveTI) then
		ti := self.myReserveDetail.CM_ReserveTI.getTI;
		if ti = null then
			return null;
		endif;
		str := self.myReserveDetail.CM_ReserveTI.getTotalRequestedDisplay();
		if str = 0.String then
			str := null;
		endif;
		if str &lt;&gt; null then
			str := str &amp; " x " ;
		endif;
		str := str &amp; ti.id;
	
	endif;
	
	return str;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getParentDocId" id="2a07180a-4f3a-4281-81f8-27d1292d1a8e">
        <source>getParentDocId(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 September 2016	cnwndl1	Initial creation

*/

vars

	bulkRel : CM_BulkRelease;

begin

	if self.myReserveDetail &lt;&gt; null then
		bulkRel := self.myReserveDetail.myReserveHeader;
		if bulkRel &lt;&gt; null then
			return bulkRel.getDescription(false);
		endif;
	endif;


	return null;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
