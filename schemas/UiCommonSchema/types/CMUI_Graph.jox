    <JadeMethod name="clearGraph" id="b5555b19-f145-4b5e-bf71-029177627e64">
        <updating/>
        <source>clearGraph()updating;

begin
	self.graphTitle	:=	null;
	self.allGraphValues.purge();
	self.allGraphColors.purge();
	self.allGraphLegends.purge();
	self.maxValue	:=	1;
	self.clearGraphics();
	
	if self.myTitleLabel &lt;&gt; null then
		self.myTitleLabel.caption := null;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="createTitleLabel" id="03bb074e-e9e9-42bf-9570-228755d2b67e">
        <updating/>
        <source>createTitleLabel() updating, protected;

vars
	theLabel	: Label;
	
begin
	if self.myTitleLabel &lt;&gt; null then
		delete self.myTitleLabel;
	endif;
	
	create theLabel transient;
	
	theLabel.name := self.TITLE_LABEL;
	theLabel.parent := self;
	theLabel.left := 1;
	theLabel.top := 1;
	
	if self.graphTitle &lt;&gt; null then		
		theLabel.visible := true;		
	else
		self.graphTitle := "No Title";
		theLabel.visible := false;
	endif;
	
	theLabel.caption := self.graphTitle;
	theLabel.height := theLabel.getTextHeight(self.graphTitle);
	theLabel.width := self.clientWidth;
	theLabel.backColor := self.backColor;
	theLabel.foreColor := Black;
	theLabel.transparent := true;
	theLabel.alignment := Label.Alignment_Center_Middle;
	
	form.addControl(theLabel);
	
	self.myTitleLabel := theLabel;
	self.graphLabelHeight :=	theLabel.height.Integer;				
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doDataError" id="ba1ff951-684b-4fd0-bbf3-6fefccef943f">
        <updating/>
        <source>doDataError(pErrorMessage : String) updating, protected;

begin
	self.myTitleLabel.height	:=	self.getTextHeight(pErrorMessage);
	self.myTitleLabel.parent	:=	self;
	self.myTitleLabel.caption	:=	pErrorMessage;
end;</source>
        <access>protected</access>
        <Parameter name="pErrorMessage" type="String"/>
    </JadeMethod>
    <JadeMethod name="doRounding" id="d3c4579c-e0dd-4d09-8b63-52d659d93094">
        <source>doRounding(_value : Integer);
//--------------------------------------------------
// Created:	06 December 2005 By: cnwgd1
//--------------------------------------------------
vars
	newValue,
	maxIdx,
	idx	: Integer;
begin

	foreach idx in self.allGraphValues do
		if idx &gt; maxIdx then
			maxIdx := idx;
		endif;
	endforeach;

	if maxIdx &gt; 0 then
		idx := self.allGraphValues.indexOf(maxIdx);
		newValue := maxIdx + _value;
		self.allGraphValues.atPut(idx, newValue);		
	endif;

end;</source>
        <Parameter name="_value" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawDemo" id="319ce372-d72f-444c-9303-ce7cde9c6867">
        <updating/>
        <source>drawDemo() updating;
/*
------------------------------------------------------------------------
Created:			19 March 2004 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/

vars

begin
	self.setDefaultsInPainter();
	self.drawGraph();
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="drawGraph" id="5b6d948b-d3ea-49c6-b533-5f525fc38ed0">
        <updating/>
        <source>drawGraph()updating;

begin
	if self.isInPainter() then
		self.setDefaultsInPainter();
	endif;
	
	self.createTitleLabel();
	
	if self.myLegend &lt;&gt; null then
		self.myLegend.setGraph(self, self.graphTitle);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="getDataSize" id="2e56f60e-c18b-49ae-aa48-38b5cc7c0289">
        <source>getDataSize():Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 February 2012	cnwndl1	Initial creation	Par 29120

*/

vars

begin

	return self.allGraphColors.size;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getLegendWidth" id="f9009136-3238-41e8-9761-92c4f3242d9c">
        <source>getLegendWidth() : Integer;
// ---------------------------------------------------------------------------
// Created:     23 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	return self.GraphLegendSpacing + self.GraphLegendLineLength + self.GraphLegendSpacing +
			self.getMaxLegendWidth + self.GraphLegendSpacing;

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getMaxLegendWidth" id="0926edd8-7073-4313-8188-dcc977563a17">
        <source>getMaxLegendWidth() : Integer protected;
// ---------------------------------------------------------------------------
// Created:     23 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	str			: String;
	maxWidth	: Integer;

begin

	foreach str in self.allGraphLegends do
		maxWidth := self.getTextExtent(str).max(maxWidth);
	endforeach;

	return maxWidth;
end;</source>
        <access>protected</access>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="inUse" id="35752da6-38cb-49c8-9eac-a7126fa4e38f">
        <source>inUse() : Boolean;
// ---------------------------------------------------------------------------
// Created:		January 2004 By Andrew Bishop cnwab1
//
// Purpose:		Use clearGraph to initialise
//
// ---------------------------------------------------------------------------

vars

begin
	return not self.allGraphValues.isEmpty;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="printGraph" id="89253fb6-aebe-4b8d-94d8-f1c3949c604e">
        <updating/>
        <source>printGraph(_orientation : Integer; _closePrinter : Boolean; _jadeReport : JadeReport io) updating;
// ---------------------------------------------------------------------------
// Created:     14 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	pxyJadeReport	: JadeReport;
	saveHeight,
	saveWidth		: Real;

begin

	saveHeight		:= self.height;
	saveWidth		:= self.width;

	if _jadeReport &lt;&gt; null then
		pxyJadeReport := _jadeReport;
	else
		create pxyJadeReport transient;
	endif;

	if _orientation = Print_Landscape then
		self.height := 500;
		self.width := 950;
	else
		self.height := 1100;
		self.width := 690;
	endif;
	
	self.redrawGraph();
	
	app.printer.printPreview := false;
	app.printer.setReport(pxyJadeReport);
	app.printer.setMargins(_orientation, 25, 25, 25, 25);
	
	app.printer.printActive(self);

	if _closePrinter then
		app.printer.close;
		app.printPreview(pxyJadeReport, true);
		_jadeReport := null;		// null this out so the calling program does not delete then pxy we are viewing
	endif;

epilog
	app.printer.close;
	self.height	:= saveHeight;
	self.width		:= saveWidth;
	self.redrawGraph();

end;</source>
        <Parameter name="_orientation" type="Integer"/>
        <Parameter name="_closePrinter" type="Boolean"/>
        <Parameter name="_jadeReport" type="JadeReport" usage="io"/>
    </JadeMethod>
    <JadeMethod name="redrawGraph" id="ff7e416a-3ea0-46d5-871d-e3933e73caa3">
        <updating/>
        <source>redrawGraph() updating;
// ---------------------------------------------------------------------------
// Created:     13 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	self.clearGraphics();
	self.drawGraph();

end;</source>
    </JadeMethod>
    <JadeMethod name="repositionAfterResize" id="00bee637-96e7-4bb8-a2cc-200b596f33cc">
        <updating/>
        <source>repositionAfterResize() updating;
// ---------------------------------------------------------------------------
// Created:     16 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
   	newLeft, newTop, newWidth, newHeight,
   	parentWidth,
   	parentHeight	: Real;

begin

	if self.parent.isKindOf(Form) then
		parentWidth  := self.parent.Form.clientWidth;
		parentHeight := self.parent.Form.clientHeight;
	elseif self.parent.isKindOf(Control) then
		parentWidth  := self.parent.Control.clientWidth;
		parentHeight := self.parent.Control.clientHeight;
	else
		parentWidth  := self.parent.width;
		parentHeight := self.parent.height;
	endif;
	
	newLeft 	:= self.left;
	newTop 		:= self.top;
	newWidth 	:= self.width;
	newHeight 	:= self.height;

	if self.lockRight then
		newLeft := (parentWidth - newWidth - self.distanceFromRight).max(0);
	endif;
	if self.lockBottom then
		newTop := (parentHeight - newHeight - self.distanceFromBottom).max(0);
	endif;
	if self.stretchWidth then
		newWidth := (parentWidth - newLeft - self.distanceFromRight).max(0);
	endif;
	if self.stretchHeight then
		newHeight := (parentHeight - newTop - self.distanceFromBottom).max(0);
	endif;
		
	if newLeft &lt;&gt; self.left or newTop &lt;&gt; self.top or newWidth &lt;&gt; self.width or newHeight &lt;&gt; self.height then
		self.move(newLeft, newTop, newWidth, newHeight);
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="setAndShowGraphTitle" id="02e2375e-83e8-45c7-b1df-d67defcd1247">
        <updating/>
        <source>setAndShowGraphTitle(_str : String) updating;
// ---------------------------------------------------------------------------
// Created:     14 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpLabel	: Label;

begin

	self.graphTitle	:= _str;

	tmpLabel := self.myTitleLabel;
	
	if tmpLabel = null then
		return;
	endif;
	tmpLabel.transparent := true;
	tmpLabel.caption := _str;
	tmpLabel.height := tmpLabel.getTextHeight(_str);

end;</source>
        <Parameter name="_str" type="String"/>
    </JadeMethod>
    <JadeMethod name="setDefaultsInPainter" id="cd1c2d62-daa6-43b1-a0be-47a4aaaa85a8">
        <updating/>
        <source>setDefaultsInPainter() updating, protected;

begin
	self.graphTitle	:=	self.name &amp; " - Sample data";
	 
	self.allGraphValues.add(10);
	self.allGraphValues.add(20);
	self.allGraphValues.add(50);
	self.allGraphValues.add(30);
	self.allGraphValues.add(40);
	
	self.allGraphColors.add(Red);	
	self.allGraphColors.add(Green);
	self.allGraphColors.add(Blue);
	self.allGraphColors.add(Purple);
	self.allGraphColors.add(Yellow);
	
	self.transparent	:=	false;	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setMaxScaleLength" id="ddab3ff3-677c-4c66-be35-6aaf4060de2c">
        <updating/>
        <source>setMaxScaleLength() updating, protected;

vars
	theLabel	: Label;
	scaleValue	: Integer;
	
begin
	self.maxScaleLabelWidth	:=	0;
	
	foreach scaleValue in self.allGraphValues do
		if scaleValue &gt; self.maxValue then
			self.maxValue	:=	scaleValue;
		endif;
	endforeach;
	
	create theLabel transient;
	theLabel.caption		:=	scaleValue.String;
	self.maxScaleLabelWidth	:=	theLabel.width.Integer + 4;	
epilog
	delete theLabel;	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setMaxScaleLengthToValue" id="eba4d500-054e-483b-9433-ad414161e078">
        <updating/>
        <source>setMaxScaleLengthToValue(_maxValue : Integer) updating;
//--------------------------------------------------
// Created:	07 December 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.maxValue := _maxValue;
end;</source>
        <Parameter name="_maxValue" type="Integer"/>
    </JadeMethod>
