    <JadeMethod name="getRowColumnPoints" id="ff564f8e-ea4f-4109-a8ec-b79afae15a72">
        <source>getRowColumnPoints(_rows, _cols : PointArray input);
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

constants
	TopTextMargin	: Integer = 10;
	LeftTextMargin	: Integer = 5;

	TopMargin		: Integer = 10;
	BottomMargin	: Integer = 10;
	LeftMargin		: Integer = 10;
	RightMargin		: Integer = 10;
	RowSpacing		: Integer = 10;

	RowHeight		: Integer = 12;
	ColWidth		: Integer = 24;

vars
	rowIdx,
	colIdx,rowNum,colNum	: Integer;
	theRowHeight,
	theColWidth,
	yPos1, yPos2,
	xPos1, xPos2	: Integer;	
	tmpTA	: CM_GridArea;
	tmpPoint : Point;
	ydc : YRD_ContainerDrawingController;
	spaceRow : Integer;
	aGCol : CM_GridColumn;
begin
	_rows.clear;
	_cols.clear;
	
	ydc := self;

	if not ydc.myTerminalArea.isKindOf(CM_GridArea) then
		return;
	endif;
	 // PAR 16415 CCMS 1029
	spaceRow := self.getRowSpacing();
	
	tmpTA := ydc.myTerminalArea.CM_GridArea;
	colNum := tmpTA.allGridColumns.size;
	rowNum := tmpTA.allGridRows.size;
	theColWidth	 := (ColWidth * ydc.scaleFactor).Integer;
	theRowHeight := (RowHeight * ydc.getHeightOfStack * ydc.scaleFactor).Integer;	// PAR 21532 CCMS SFW 1025

	xPos2 := self.LABELGAP;
	// ##### COLUMNS
	if self.flipHorizontal then
		foreach aGCol in tmpTA.allGridColumns reversed do
			xPos1 :=  xPos2;
			if aGCol.hasGap then
				xPos2 := xPos1 + (self.getGapDrawWidth(aGCol) + self.columnSpacing).Integer;
			else
				xPos2 := xPos1 + theColWidth + self.columnSpacing;
			endif;
			
			if xPos1 &lt;= 0 then
				xPos1 := 1;
			endif;
			
			tmpPoint.set(xPos1,xPos2);
			_cols.add(tmpPoint);
		endforeach;
	else
		foreach aGCol in tmpTA.allGridColumns do
			xPos1 :=  xPos2;
			if aGCol.hasGap then
				xPos2 := xPos1 + (self.getGapDrawWidth(aGCol) + self.columnSpacing).Integer;
			else
				xPos2 := xPos1 + theColWidth + self.columnSpacing;
			endif;
			
			if xPos1 &lt;= 0 then
				xPos1 := 1;
			endif;
			
			tmpPoint.set(xPos1,xPos2);
			_cols.add(tmpPoint);
		endforeach;
	endif;
	
	yPos2 := self.LABELGAP;
	foreach rowIdx in 1 to rowNum do
		yPos1 :=  yPos2;
		yPos2 := yPos1 + theRowHeight + spaceRow;

		if yPos1 &lt;= 0 then
			yPos1 := 1;
		endif;

		tmpPoint.set(yPos1,yPos2);
		_rows.add(tmpPoint);
	endforeach;
	
end;</source>
        <Parameter name="_rows" type="PointArray" usage="input"/>
        <Parameter name="_cols" type="PointArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getRowColumnPointsALL" id="e492cdce-2073-4a01-b47f-ee739fe7c35a">
        <source>getRowColumnPointsALL(_rows, _cols : PointArray input);
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

constants
	TopTextMargin	: Integer = 10;
	LeftTextMargin	: Integer = 5;

