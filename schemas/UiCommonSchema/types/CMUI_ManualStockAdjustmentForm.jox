    <JadeMethod name="createNewTrackedItem" id="b9a40ff3-80b7-4586-9df6-fb4c23ff86d2">
        <updating/>
        <source>createNewTrackedItem(_product : CM_Product input) : Boolean updating;

// Created by cnwdvb1 on 08 November 2006

begin
	//lets make cargo
	
	if self.myTrackedItem &lt;&gt; null then
		return true;
	endif;
	
	self.myTrackedItem := self.myLocationsController.createNewCargoForLocation(_product.myCargoType, _product, null, _product.myOperator);
	
	return (self.myTrackedItem &lt;&gt; null);
end;</source>
        <Parameter name="_product" type="CM_Product" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doBaseFormCancel" id="75e4c6bc-ecc4-4eba-8edb-a7bbdd0cbe4d">
