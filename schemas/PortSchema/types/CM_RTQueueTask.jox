    <JadeMethod name="isFirstTask" id="0def8ebb-b595-4bdc-990a-e663be2368c4">
        <methodInvocation>mapping</methodInvocation>
        <source>isFirstTask(set: Boolean; value: Boolean io) mapping;
//04 Mar 2025 navma1	MTN - [Performance Issue] - 1081 with multiple gate in/gate out processes running
vars
	currIndex	:	Integer;
begin
	value := false;
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	if self.status = TASK_COMPLETE then	//Dont show completed
		if relatedTasks.last = self then
			value := true;	//We are last task, even tho we are completed, show us!
		endif;
		return;
	endif;
	
	if relatedTasks = null then	//No other tasks, this must be 1st!
		value := true;
		return;
	endif;
	
	if relatedTasks.isEmpty then		//No other tasks, this must be 1st!		//04.03.2024 navma1	MTN-33569
		value := true;
		return;
	endif;
	
	currIndex := relatedTasks.indexOf(self);
	if currIndex = 1 then
		value := true;
		return;
	endif;
	
	if currIndex &gt; 1 then
		if relatedTasks[currIndex -1].status = TASK_COMPLETE then
			value := true;
			return;
		endif;
		return;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="isMachineTask" id="c0a603d0-575f-42e1-814f-04916c9a59c0">
        <source>isMachineTask() :	Boolean;
//Returns true if this is a machine task (NOT A CRANE type)
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// 15 May 2014	cnwrs1	Par 34154 - handle invalid object for ti
// 21 May 2019	jlgzm1	TFS 42840 MSL Direct Release between Voyages and Rail
vars
	site 	: Integer;
	invalid : Boolean;
	theTI 	: CM_TrackedItem;
	vjob 	: CM_VoyageJob; 	// tfs42840
	wle 	: CM_WorkListEntry;	// tfs42840
	
begin

	if self.taskType = TASK_PICKUP or
		self.taskType = TASK_SETDOWN or
		self.taskType = TASK_MOVE or 
		self.taskType = TASK_BREAKBULK then
		if self.ti = null then
			return false;
		endif;
		theTI:=self.ti; //epr par 34257 16/6/14
		on Exception do app.handleDeletedObject(exception, theTI, invalid);
		site := self.ti.site;
		if invalid then
			return false;
		endif;
		//tfs42840 start
		if self.myEntry.myJob.isKindOf(CM_VoyageJob) then
			vjob := self.myEntry.myJob.CM_VoyageJob;
		endif;
		if vjob = null then
			wle := self.myEntry.myWorkListEntry;
			if wle &lt;&gt; null then
				vjob := wle.getDRLinkedVoyageJob();
			endif;
		endif;
		//tfs42840 end
		if vjob &lt;&gt; null then
			if site = TI_SITE_ONSITE or site = TI_SITE_ONSHIP then
		 		return true;
		 	endif;
		else
		 	if site = TI_SITE_ONSITE then
		 		return true;
		 	endif;
		endif;
	endif;
	return false;	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isMove" id="b46eadc5-b5c3-4c24-beae-b2c2d75c1738">
