    <JadeMethod name="getHazardsAsString" id="f4eb7d32-182f-48b4-9c2c-79c1be1a6708">
        <source>getHazardsAsString() : String;
//-----------------------------------------------------------------------
//	Created:	14 June 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars
	haz 	: CM_Hazard;
	hazDict			: CM_HazardByCodeDict;

	tmpStr 	: String;
begin
	create hazDict transient;
	self.getAllItemTIIHazards(hazDict);
	foreach haz in hazDict do
		if tmpStr &lt;&gt; null then
			tmpStr := tmpStr &amp; '; ';
		endif;
		tmpStr := tmpStr &amp; haz.getTableDisplay(false, true);
	endforeach;
	return tmpStr;
epilog
	delete hazDict;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getHumidity" id="77ba53ee-139c-41bd-9ae8-f0f8af890f21">
        <source>getHumidity():Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 April 2020	jlgndl1	Initial creation	TFS 47958

*/

vars

begin

	//All Humidity display fields are limited to Decimal 6,2  so don't returm bigger than that
	if self.humidity &gt; 999.99 then
		return 999.99;
	endif;

	return self.humidity;

epilog

end;</source>
