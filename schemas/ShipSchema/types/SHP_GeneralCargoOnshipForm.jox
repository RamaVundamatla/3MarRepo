    <JadeMethod name="displaySearchSelection" id="6e7c03ce-0628-4a85-8199-81b9f65a4279">
        <updating/>
        <source>displaySearchSelection() updating, protected;
// show BOL, (Stowage) and Cargo search criteria
//
// 04/12/12 	PJS		PAR #30787
//
vars
	len	: Integer;
	msg	: String;
begin
	// set search properties
	if self.searchType = Search_BOL  or self.searchType = Search_BOL_Detail then
		if self.filterBOL = null and
		   self.filterBOLCargoType = null and
		   self.filterBOLCommodity = null and
		   self.filterBOLMarks = null and 
		   self.filterBOLOperator = null and
		   self.filterBOLReconciled = null then
			self.lblBOLSearch.caption := "";
			self.lblBOLSearch.visible := false;
			self.btnBOLSReset.visible := false;
			self.tblBOL.top := 20;
		else
			msg := app.getErrorString(Search_selection) &amp; " : ";
			if self.filterBOL &lt;&gt; null then
				msg := msg &amp; app.getErrorString(BillOfLading) &amp; " = " &amp; self.filterBOL.number &amp; ", ";
			endif;
			if self.filterBOLCargoType &lt;&gt; null then
				msg := msg &amp; app.getErrorString(CargoType) &amp; " = " &amp; self.filterBOLCargoType.description &amp; ", ";
			endif;
			if self.filterBOLMarks &lt;&gt; null then
				msg := msg &amp; app.getErrorString(Marks) &amp; " = " &amp; self.filterBOLMarks &amp; ", ";
			endif;
			if self.filterBOLCommodity &lt;&gt; null then
				msg := msg &amp; app.getErrorString(Commodity) &amp; " = " &amp; self.filterBOLCommodity.code &amp; " " &amp; self.filterBOLCommodity.description;
			endif;
			if self.filterBOLOperator &lt;&gt; null then
				msg := msg &amp; app.getErrorString(Operator) &amp; " = " &amp; self.filterBOLOperator.code &amp; " " &amp; self.filterBOLOperator.description;
			endif;
			
			if self.filterBOLReconciled &lt;&gt; null then
				msg := msg &amp; app.getErrorString(Reconciled) &amp; " = " &amp; self.filterBOLReconciled;
			endif;
					
			
			
			len := msg.length;
			if len &gt; 2 then
				if msg[len-1:2] = ", " then
					msg := msg[1:len-2];
				endif;
			endif;
			self.lblBOLSearch.caption := msg;
			self.lblBOLSearch.visible := true;
			self.btnBOLSReset.visible := true;
			self.tblBOL.top := 20 + self.lblBOLSearch.height;
		endif;
	elseif self.searchType = Search_BOL_Item then
		if self.filterBOLItemId = null and
		   self.filterBOLItemLocation = null and
		    self.filterBOLItemCargoType = null and
		   self.filterBOLItemMarks = null and
		   self.filterBOLItemCommodity = null and
		   self.filterBOLItemOperator = null then
			self.lblBOLItemSearch.caption := "";
			self.lblBOLItemSearch.visible := false;
			self.btnBISReset.visible := false;
			self.tblBOLItems.top := 20;
		else
			msg := app.getErrorString(Search_selection) &amp; " : ";
			if self.filterBOLItemId &lt;&gt; null then
				msg := msg &amp; app.getErrorString(Id) &amp; " = " &amp; self.filterBOLItemId &amp; ", ";
			endif;
			if self.filterBOLItemLocation &lt;&gt; null then
				msg := msg &amp; app.getErrorString(Location) &amp; " = " &amp; self.filterBOLItemLocation &amp; ", ";
			endif;
			
			if self.filterBOLItemCargoType &lt;&gt; null then
				msg := msg &amp; app.getErrorString(CargoType) &amp; " = " &amp; self.filterBOLItemCargoType.description &amp; ", ";
			endif;
			if self.filterBOLItemMarks &lt;&gt; null then
				msg := msg &amp; app.getErrorString(Marks) &amp; " = " &amp; self.filterBOLItemMarks &amp; ", ";
			endif;
			if self.filterBOLItemCommodity &lt;&gt; null then
				msg := msg &amp; app.getErrorString(Commodity) &amp; " = " &amp; self.filterBOLItemCommodity.code &amp; " " &amp; self.filterBOLItemCommodity.description &amp; ", ";
			endif;
			if self.filterBOLItemOperator &lt;&gt; null then
				msg := msg &amp; app.getErrorString(Operator) &amp; " = " &amp; self.filterBOLItemOperator.code &amp; " " &amp; self.filterBOLItemOperator.description;
			endif;
			len := msg.length;
			if len &gt; 2 then
				if msg[len-1:2] = ", " then
					msg := msg[1:len-2];
				endif;
			endif;
			self.lblBOLItemSearch.caption := msg;
			self.lblBOLItemSearch.visible := true;
			self.btnBISReset.visible := true;
			self.tblBOLItems.top := 20 + self.lblBOLItemSearch.height;
		endif;
	elseif self.searchType = Search_COB then
		if self.filterCOBItemId = null and
		   self.filterCOBLocation = null and
		   self.filterCOBBOLNumber = null and
		   self.filterCOBCargoType = null and
		   self.filterCOBMarks = null and
		   self.filterCOBCommodity = null and
		   self.filterCOBOperator = null then
			self.lblCOBSearch.caption := "";
			self.lblCOBSearch.visible := false;
			self.btnCOBSReset.visible := false;
			self.tblCargo.top := 20;
		else
			msg := app.getErrorString(Search_selection) &amp; " : ";
			if self.filterCOBItemId &lt;&gt; null then
				msg := msg &amp; app.getErrorString(Id) &amp; " = " &amp; self.filterCOBItemId &amp; ", ";
			endif;
			if self.filterCOBLocation &lt;&gt; null then
				msg := msg &amp; app.getErrorString(Location) &amp; " = " &amp; self.filterCOBLocation &amp; ", ";
			endif;
			if self.filterCOBBOLNumber &lt;&gt; null then
				msg := msg &amp; app.getErrorString(BillOfLading) &amp; " = " &amp; self.filterCOBBOLNumber &amp; ", ";
			endif;
			if self.filterCOBCargoType &lt;&gt; null then
				msg := msg &amp; app.getErrorString(CargoType) &amp; " = " &amp; self.filterCOBCargoType.description &amp; ", ";
			endif;
			if self.filterCOBMarks &lt;&gt; null then
				msg := msg &amp; app.getErrorString(Marks) &amp; " = " &amp; self.filterCOBMarks &amp; ", ";
			endif;
			if self.filterCOBCommodity &lt;&gt; null then
				msg := msg &amp; app.getErrorString(Commodity) &amp; " = " &amp; self.filterCOBCommodity.code &amp; " " &amp; self.filterCOBCommodity.description &amp; ", ";
			endif;
			if self.filterCOBOperator &lt;&gt; null then
				msg := msg &amp; app.getErrorString(Operator) &amp; " = " &amp; self.filterCOBOperator.code &amp; " " &amp; self.filterCOBOperator.description;
			endif;
			len := msg.length;
			if len &gt; 2 then
				if msg[len-1:2] = ", " then
					msg := msg[1:len-2];
				endif;
			endif;
			self.lblCOBSearch.caption := msg;
			self.lblCOBSearch.visible := true;
			self.btnCOBSReset.visible := true;
			self.tblCargo.top := 20 + self.lblCOBSearch.height;
		endif;
		/* 7.8.2+
	elseif self.searchType = Search_Stowage_Item then
	elseif self.searchType = Search_Stowage then
		*/
	endif;

end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doAddEditBOL" id="fdbc667a-75c9-49e4-aa61-680a948256b0">
        <source>doAddEditBOL(_add : Boolean) protected;


// 29/11/12		PJS		PAr #30787
// Purpose:
// Date				Who		Reason
// 8 February 2023	navmk20	Bug 56397: EUP Testing | Voyage removed from BOL if not current
// ---------------------------------------------------------------------------

vars
	form : CMUI_BOLMaintForm;
begin

	form := app.loadForm(CMUI_BOLMaintForm,
									self.myAssistant.class,
									false,
									false,
									false,
									self.myTerminal, null).CMUI_BOLMaintForm;
	
	// 27/04/2010 cnwmh5 PAR23821
	// if we don't have view permission then form is set to null so don't display
	if form = null then
		return;
	endif;
	form.setMyVoyage(self.myCurrentVoyage); //8.2.2023 navmk20 TFS 56397
	if _add then
		form.setCaption(app.getErrorString(Add_ship_BOL));   //("Add ship BOL");
		form.setMode(Mode_Add);
		form.setMyCurrentBOL(null);
		//form.setMyVoyage(self.myCurrentVoyage); //8.2.2023 navmk20 TFS 56397
		//new blank form
	else

		form.setCaption(app.getErrorString(Edit_ship_BOL));    //("Edit ship BOL");
		form.setMode(Mode_Update);
		// 23144 handle cargo linked to BOL but not BOL detail
		if self.isBOLDetailMode() then
			form.setMyCurrentBOL(self.myCurrentBOLDetail.myBOL);
		else
			form.setMyCurrentBOL(self.myCurrentBOL);
		endif;
	endif;
	
	form.fromOnshipForm := true;
	form.setMyBOLType(app.myRoot.allBOLTypes[BOLType_GeneralBillOfLading]);
	
	form.show();
	
end;
</source>
        <access>protected</access>
        <Parameter name="_add" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doAddEditCargo" id="b617c4d8-8c5e-4a8e-a445-512112e2598b">
        <updating/>
        <source>doAddEditCargo(_tbl : CM_DataTable; _bolDetail : CM_BOLDtl; _ti : CM_TrackedItem) updating, protected;

vars

begin
	
	if _ti = null then
		self.myAssistant.showCargoAddFromOnship(self, (_ti = null), 3, 160, _bolDetail, null, _ti, null, self.myCurrentVoyage, false, null); // TFS 3218 CNWAB1
	else
		//+cnwml2 PAR22997
		if _tbl.allSelectedObjects.size &gt; 0 then
			self.myAssistant.showCargoEnquiryForTIs(_tbl.allSelectedObjects.first.CM_TrackedItem, _tbl.allSelectedObjects, self.myMasterMenuAction, true);	
		else
			app.msgBox(app.getString(SelectItem), app.getString(Select_Item), MsgBox_OK_Only);
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_tbl" type="CM_DataTable"/>
        <Parameter name="_bolDetail" type="CM_BOLDtl"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
