    <JadeMethod name="displayCranes" id="7db582d2-e3da-402d-ac63-52ce65d2a1c8">
        <source>displayCranes(_theObject : Object) : String;
// ---------------------------------------------------------------------------
// Created:		March 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theString : String;
	workPointInterface : IF_VoyageWorkPoint;
begin
	
	if _theObject &lt;&gt; null then
		workPointInterface:=_theObject.IF_VoyageWorkPoint;
		theString := workPointInterface.getID &amp; " " &amp; workPointInterface.getDescription;
		return  theString;
	else
		return null;
	endif;
end;</source>
        <Parameter name="_theObject" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doBtnCloseClick" id="94ede94b-7734-4087-b514-66ba4bba8e5e">
        <updating/>
        <source>doBtnCloseClick() updating;
// ---------------------------------------------------------------------------
// Created:		March 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.unloadForm();
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnShowClick" id="34308f45-4952-465b-b4c3-605edbb46803">
        <updating/>
        <source>doBtnShowClick() updating;
// ---------------------------------------------------------------------------
// Created:		March 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	theCRANES : ObjectArray;
	theReturn : Integer;
begin
	app.mousePointer := Window.MousePointer_HourGlass;

	create theCRANES transient;
	self.msgCranes.getSelected(theCRANES);
	
	while true do
		
		app.myTrxUA.trxUpdateVoyageJobSheet(theCRANES,self.myCurrentVoyage,self.workPointJobSheetClassToCreate, app.myPassport); // TFS 3646
		
		if app.myPassport.trxCompletedOK then
			global.beep;
			self.unloadForm();
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Voyage_sheet_creation), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;

epilog
	delete theCRANES;
	app.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doEdit" id="4c5b191e-c739-4770-8cc2-0840c0ea500f">
        <source>doEdit();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 August 2009	cnwndl1	Initial creation CCMS 1031 / Par 20474

*/

vars

	workPoint : CM_Object;
	msg : String;
	
begin
	
	workPoint := self.msgCranes.getFirstSelectedObjInSelected().CM_Object;
	
	if workPoint = null then
		msg := app.getErrorString2(CMUI_Please_Select,app.getErrorString(CM_Crane_GC),app.getErrorString(Edit));
		app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	self.myAssistant.SHP_Assistant.showOOWCraneDetailsForm(workPoint,self.myCurrentVoyage);
		
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="a9a580b2-f947-4689-a4fc-0442c468706b">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:		March 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if self.width &lt; 350 then
		self.width := 350;
	endif;
	if self.height &lt; 400 then
		self.height := 400;
	endif;
	self.btnClose.move(self.clientWidth - self.btnClose.width - 5,self.clientHeight - self.btnClose.height - 5, 70,25);
	self.btnShow.move(self.btnClose.left - self.btnClose.width - 5,self.btnClose.top, self.btnClose.width, self.btnClose.height);
	self.btnEdit.move(5,self.btnClose.top, self.btnClose.width, self.btnClose.height);	//10 Aug 2009	NDL	CCMS 1031 rework. par 20474

	self.msgCranes.move(5,5,self.clientWidth - 10, self.btnClose.top - 10);
	self.msgCranes.cnEcResizeContents();

end;</source>
    </JadeMethod>
    <JadeMethod name="initGroupBox" id="a2b41df1-e042-474c-8f52-b07165db957e">
        <source>initGroupBox();
// ---------------------------------------------------------------------------
// Created:		March 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.msgCranes.caption := null;
	self.msgCranes.distanceFromBottom 	:= 5;
	self.msgCranes.distanceFromRight 		:= 5;
	self.msgCranes.lockBottom 				:= false;
	self.msgCranes.lockRight				:= false;
	self.msgCranes.stretchHeight 			:= true;
	self.msgCranes.stretchWidth 			:= true;
	self.msgCranes.multiSelect 	:= ListBox.MultiSelect_Extended;
	self.msgCranes.myBaseForm	:= self;
	self.msgCranes.mySelectedListBox.sorted := false;
	self.msgCranes.cnEcResizeContents();
	self.msgCranes.readOnly := false;

end;</source>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="d2cb2ea6-6d4b-4e70-b927-91154784a132">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
// ---------------------------------------------------------------------------
// Created:		July 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(_colorControl);
	self.msgCranes.backColor := self.backColor;

end;</source>
        <Parameter name="_colorControl" type="CM_ColorController"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="e376a324-5e7c-4fb0-8d78-28d557d0f35e">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		March 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theCranesOrder : ObjectArray;
	theMachine : CM_Machine;
	aJS : CM_VoyageJobSheet;
	workPoint : CM_Object;
begin
	self.createMyAssistant(SHP_Assistant);
	inheritMethod();
	app.mousePointer := Window.MousePointer_Default;

	self.centreWindow();
	self.initGroupBox();
	self.frmToolbarBtns.visible := false;
	if self.myCurrentVoyage &lt;&gt; null then
		
		self.myCurrentVoyage.getAllAvailableWorkPoints(allAvailableCranes);
		self.msgCranes.setupControl(app.getErrorString(Cranes),allAvailableCranes, SHP_SelectCranes::displayCranes.name);
		self.msgCranes.setVisibleButtons(true,true,true);
		create theCranesOrder transient;	
		// have we got a job sheet for this crane?		
		foreach aJS in self.myCurrentVoyage.allJobSheetsInOrder do
			workPoint:=aJS.getMyWorkPointObject;
			if workPoint = null then
				continue;
			endif;
			if self.myCurrentVoyage.allJobSheets[workPoint.IF_VoyageWorkPoint.getID] &lt;&gt; null then
				theCranesOrder.add(workPoint);
			endif;
		endforeach;
		self.msgCranes.setSelected(theCranesOrder);
	endif;

epilog
	delete theCranesOrder;
	app.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="1c31282e-435c-473d-9dda-582c724cf7f1">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0006675, locale);
	btnClose.translateCaption(Xlat_0003078, locale);
	btnEdit.translateCaption(Xlat_0011540, locale);
	btnShow.translateCaption(Xlat_0003079, locale);
	msgCranes.translateCaption(Xlat_0003080, locale);
end;</source>
    </JadeMethod>
</GUIClass>
