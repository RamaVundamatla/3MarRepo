    <JadeMethod name="pxyCreateUpdateProxy" id="b7d07bd2-e07a-4b49-abdc-219887d96a64">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 December 2022	jlier1	Initial creation

*/

vars
	proxy 		: CM_HSCodeCode;
	completedOK	: Boolean;
	
begin

	proxy := inheritMethod();
	
	proxy.myHSHeading := self.myHSHeading;

	completedOK := true;
	return proxy;
	
epilog

	if not completedOK then
		delete proxy;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
