    <JadeMethod name="doMnuShowCaptions" id="bf51f2c1-fc22-43fb-af4d-c4ef30b7ab9b">
        <updating/>
        <source>doMnuShowCaptions(menuItem: MenuItem input) updating;

/*

Purpose:		Resize the form based on whether show captions or not		

Parameters:			

Return Value:		


Date		Who		Reason
03 December 2009	cnwmh5	Initial creation
//20 Dec 2016	cnwrs1	TFS 3137 - resize the find/trplace form when show captions is on
*/

vars
	
	tmpControl	: Control;
	numControls,
	i			: Integer;
	tmpParent	: Window;
	
	currentHeight	: Real;
	newHeight		: Real;
	heightDiff		: Real;
	
begin

	if menuItem &lt;&gt; null then
		// get the current height
		currentHeight := self.frmToolbar.height;
		
		// set whether show captions is set
		self.frmToolbar.showCaptions := not self.frmToolbar.showCaptions;
	
		// get the new height
		newHeight := self.frmToolbar.height;
		
		// get the difference in heights
		heightDiff := newHeight - currentHeight;
		
		
		
	else
		if self.frmToolbar.showCaptions then
			heightDiff := 58;
		else
			heightDiff := 10; // ### TFS 50421 17SEP2021 NAVAB1
		endif;
	endif;

	// read through the controls and update top by heightDiff if required
	numControls := self.controlCount;
	
	foreach i in 1 to numControls do
	
		tmpControl := self.controls(i);
		tmpParent := tmpControl.parent;

		if tmpParent.isKindOf(CMUI_Toolbar) or tmpParent.isKindOf(CMUI_ToolbarButton) then
			continue;
		endif;
		
		if tmpControl.isKindOf(CMUI_Toolbar) or tmpControl.isKindOf(CMUI_ToolbarPicture) then
			continue;
		endif;
		
		if tmpParent.isKindOf(GroupBox) or tmpParent.isKindOf(Sheet) then
			continue;
		endif;
	
		// add heightDiff to controls top
		tmpControl.top := tmpControl.top + heightDiff;
	
	endforeach;

	// change frmLoadFile height by the difference
	self.height := self.height + heightDiff;
	
epilog
	
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doQueryUnload" id="f444ea67-b0c1-47e7-98e3-a782ca1b4c6c">
        <updating/>
        <source>doQueryUnload(cancel: Integer io; reason: Integer) updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	31 July 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
constants
	CANCEL_UNLOAD = 1;
vars
	result : Integer;
begin

	if self.mode = MODE_ADD or self.mode = MODE_UPDATE then
		if reason = QueryUnload_User or
		   reason = QueryUnload_UnloadMethod or
		   reason = QueryUnload_MdiChild then
		   result := app.msgBox(app.getErrorString(EditChangedAndClosing), self.caption &amp; " Window Closing !", MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
			if result = MsgBox_Return_No then
				cancel := CANCEL_UNLOAD;	//Do not close form
			endif;
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="cancel" type="Integer" usage="io"/>
        <Parameter name="reason" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doRenumberRows" id="fee90a4f-e82f-4a0d-91fd-94e2f6cb927f">
        <source>doRenumberRows(_table :CM_DataTable input) protected;
/*
Date		Who		Reason
28 May 2013	cnwcs5	Initial Creation - par 31618
*/
vars
	row	:Integer;
begin
	foreach row in _table.fixedRows + 1 to _table.rows do
		_table.setCellText (row, 1, (row - 1).String);
	endforeach;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="3449f7b8-3b8e-4545-a535-5629cb878632">
        <updating/>
        <source>doSave() : CM_EDIFileTypeUser updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	31 July 2006 By cnwth2

Purpose:	

Changed On	Changed By  Reason
08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state	
----------  ----------  --------------------------------------------------
*/
vars
	pxyFileType,
	fileType			: CM_EDIFileTypeUser;
	dataType,
	result				: Integer;
	pxyLineHookCode			: CM_HookCode;
	searchWords			: StringArray;
begin

	fileType := self.cmbFileDef.listObject.CM_EDIFileTypeUser;
	if fileType &lt;&gt; null then
		beginLoad;
		pxyFileType := fileType.pxyCreateUpdateProxy();
		endLoad;
	else//adding new
		create pxyFileType transient;
	endif;
	
	if self.cmbFormatType.listIndex &lt; 1 then
		app.msgBox('You must specify a file format before saving.','No file format specified.',MsgBox_Exclamation_Mark_Icon);
		return null;
	endif;
	
	//self.createMappingProxies(pxyFileType)
	//21 Jan 2013	NDL	Par 29760 - Cater for error being presented during proxy creation
	if not self.createMappingProxies(pxyFileType) then
		return null;
	endif;
	
	create searchWords transient;
	self.getSearchWords(searchWords);
	
	if self.chkActive.value and searchWords.isEmpty then
		app.msgBox('You must specify some email search words if auto-emailing is checked as active.','No search words specified.',MsgBox_Exclamation_Mark_Icon);
		return null;
	endif;
	
	if self.cmbEDIDataType.listIndex &gt; 0 then
		dataType := self.cmbEDIDataType.itemData[self.cmbEDIDataType.listIndex];
	endif;
	
	
	//self.myFileLineHookCode
	if self.myFileLineHookCode &lt;&gt; null then
		create pxyLineHookCode transient;
		pxyLineHookCode.setForProxy ( self.myFileLineHookCode.code, self.myFileLineHookCode.myHookType);
		pxyLineHookCode.setJadeCodeForProxy(self.myFileLineHookCode.getCurrentJadeCode , self.myFileLineHookCode.code  ) ;
	endif;
	
	
	pxyFileType.setProxy(self.txtName.text.trimBlanks(),
						self.cmbFormatType.itemData[self.cmbFormatType.listIndex],
						self.txtDelim.text.trimBlanks().Character,
						self.cmbDateFormat.text,
						self.cmbDateDelimiter.text.Character,
						dataType,
						self.txtIgnore.text.Integer,
						self.chkXlations.value,
						self.cmbXlationOp.listObject.CM_Operator,
						self.chkActive.value,
						self.txtNumSearch.text.Integer,
						searchWords,
						pxyLineHookCode,
						self.txtControlCol.text.Integer);	// cnwcs5 24/09/2009 par 20320
	
	if pxyFileType.myIncludeLineHookCode &lt;&gt; null then
		pxyFileType.myIncludeLineHookCode.createProxyHookLinkForParent(HookType_EDIFileIncludeLine, pxyFileType);	
	endif;
	
	if canHaveSettings then
		pxyFileType.setConfig(GeneratePins, blnSettingPin);
		pxyFileType.setConfig(SkipDuplicates, blnSettingSkip);
		if dataType = EDIDataType_Prenote then
			pxyFileType.setConfig(CreateBookings, blnSettingsBookings);
		endif;
		if dataType = EDIDataType_Prenote then		//03 Jan 2019	NDL	TFS 42303
			pxyFileType.setConfig(InvalidVoyageDefaultNull, blnSettingsVoyage);
		endif;
		pxyFileType.setConfigWarningsToIgnore( allSelectedErrors );	 // cnwrd1 ccms 1660 8.8.2008
	endif;
	
	while true do
		if fileType = null then
			app.myTrxCA.trxCreateEDIFileTypeUser(fileType, pxyFileType, app.myPassport);
		else
			app.myTrxUA.trxUpdateEDIFileTypeUser(pxyFileType, app.myPassport);
		endif;

		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			return fileType;
		else
			result := app.showErrorWarningDialog('EDI File Type User', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings windo
		endif;
		
		return null;
	endwhile;

epilog
	endLoad;				// 08/04/2011 cnwmh5 #27347
	delete searchWords;
	delete pxyFileType;	
end;</source>
        <access>protected</access>
        <ReturnType type="CM_EDIFileTypeUser"/>
    </JadeMethod>
    <JadeMethod name="doUpdateControlColumn" id="d96cdcd1-6571-4eca-a1f5-fcc047338d82">
        <source>doUpdateControlColumn()protected;
// ---------------------------------------------------------------------------
// Created:     24 September 2009 by cnwcs5
// Purpose:     par 20323 - multiple record types
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	col, index,
	value		:Integer;
	textbox		:CMUI_TextBox;
begin
	// update # field to be at least value of control column
	col := self.txtControlCol.text.Integer;
	
	while true do
		textbox := self.txtNumFields.getControl (index);
		
		if textbox = null then
			break;
		endif;
		
		value := textbox.text.Integer;
		
		if value &lt; col then
			textbox.text := col.String;
			self.doUpdateNumberOfFields (textbox);
		endif;
		
		index := index + 1;
	endwhile;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doUpdateNumberOfFields" id="64c69b43-0d29-4ee3-b741-c761986adbe4">
        <source>doUpdateNumberOfFields(_textbox :CMUI_TextBox) protected;
/*
----------   ----------  --------------------------------------------------
Created:	20 July 2006 By cnwth2

Changed On  Changed By  Reason
28/05/2013	cnwcs5		par 31618
----------   ----------  --------------------------------------------------
*/
vars
	totalRowsRequired,
	currentRows,
	count,	row		: Integer;
	tbl				: CM_DataTable;
begin
	count	:= _textbox.text.Integer;
	tbl 	:= self.tblFieldMap.getControl (_textbox.index);

	if count &lt; 1 then
		tbl.rows := tbl.fixedRows;
		return;
	endif;
	
	totalRowsRequired := count + tbl.fixedRows;
	
	if totalRowsRequired &lt;= tbl.rows then
		tbl.rows := totalRowsRequired;
		return;
	endif;
	
	currentRows := tbl.rows;
	
	foreach row in currentRows + 1 to totalRowsRequired do
		self.addFieldMapping(tbl, null, null);	// par 31618
	endforeach; 
end;</source>
        <access>protected</access>
        <Parameter name="_textbox" type="CMUI_TextBox"/>
    </JadeMethod>
    <JadeMethod name="fieldHasHookCode" id="20a546b2-4e90-4a3e-b856-03f3a0c5b34d">
        <source>fieldHasHookCode(_fieldName : String; _table : CM_DataTable input) : Boolean;
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
11 September 2008	cnwrd1	Initial creation
23/09/2009			cnwcs5	par20320 - multiple record types using cloned controls
*/
vars
	row,
	numRows,
	colFieldDescr 	: Integer;
begin
	numRows 		:= _table.rows;
	colFieldDescr 	:= _table.getColumnByRowName(ETRow_FieldType);
	
	foreach row in _table.fixedRows + 1 to numRows do
		if _table.accessCell(row, colFieldDescr).text[1:30].trimBlanks() = _fieldName then
			return true;
		endif;		
	endforeach;
	
	return false;
epilog

end;</source>
        <Parameter name="_fieldName" type="String"/>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getEDIDisplayStrForDefName" id="47170701-4b8b-4b8e-b2db-c6ca91a0c523">
        <source>getEDIDisplayStrForDefName(_name :String; _ediData : CM_EDIData): String;
// ---------------------------------------------------------------------------
// Created:     24 September 2009 by cnwcs5
// Purpose:     Par 20320
// Parameters:  _name is ignored
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 22/04/2010	cnwcs5		Use method on CM_EDIControllerAgent instead of CMUI_Assistant
// ---------------------------------------------------------------------------
vars
	agent : CM_EDIControllerAgent;	// was assistant :CMUI_Assistant;
begin
	if _ediData.isComposite then
		return _ediData.getDisplayStrForDefName(_name);
	endif;
		
	create agent transient;
	return agent.getEDIDisplayStrForType(_ediData.getEDIDataType());
epilog
	delete agent;
end;
</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_ediData" type="CM_EDIData"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSearchWords" id="41c15405-ccac-42f5-95f2-8c61dc566a0a">
        <source>getSearchWords(_strArray : StringArray input) protected;
/*
----------   ----------  --------------------------------------------------
Created:	08 January 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	len,
	idx,
	previousPos,
	pos			: Integer;
	subStr,
	str			: String;
	
begin
	
	str := self.txtSearchWords.text.trimBlanks;
	if str = null then
		return;
	endif;
	
	pos := 1;
	previousPos := 1;
	len := str.length;
	while pos &lt; len do
		subStr := str.cnEcNextDelimitedField(',', pos).trimBlanks();
		
		if subStr = null then
			break;
		endif;
		
		_strArray.add(subStr);
		
		if pos &lt;= previousPos then
			break;
		else
			previousPos := pos;
		endif;
	endwhile;
	

end;


</source>
        <access>protected</access>
        <Parameter name="_strArray" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTINamesForDataType" id="98c986b6-5821-4d23-933b-4fb5d4ef1854">
        <source>getTINamesForDataType(_type :Integer; _coll :StringArray input) protected;
// ---------------------------------------------------------------------------
// Created:     24 September 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 26 Sep 2023	jlirs1	TFS 59171 Support TransManifest userDefined
//28 Nov 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
//16 Jan 2024	jlirs1	TFS 59172 User Defined Call Off
 // ---------------------------------------------------------------------------
vars
	ediData			: CM_EDIData;
	ediDataTransManifest : CM_EDIDataTransManifest;
begin
	ediData := self.createEDIData (_type);
	
	if _type = EDIDataType_TransportManifest then
		ediDataTransManifest := ediData.CM_EDIDataTransManifest;
		ediDataTransManifest.createTransientChildrenClasses();
		_coll.add(ETDef_EDIDataTransportManifest);
	endif;
	if _type = EDIDataType_CallOff then
		_coll.add(ETDef_EDIDataCallOff);
		create ediData.CM_EDIDataCallOff.myRequestMultiLine transient;
	endif;
	ediData.getMyTIDisplayDefNames (_coll); 
	if ediData.isKindOf(CM_EDIDataShipManifest) then
		_coll.remove(ETDef_EDITICargo); //jlier1 TFS 56234 20/2/22
	endif;
	if ediData.isKindOf(CM_EDIDataTransManifest) then	//28 Nov 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
		_coll.removeDuplicates();		//11 Dec 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
		_coll.remove(ETDef_EDITISeal);
		_coll.remove(ETDef_EDIHazDetailsTI);
//		_coll.remove(ETDef_EDITIBookingHeader);
//		_coll.remove(ETDef_EDITIBookingItem);
//		_coll.remove(ETDef_EDITIBOLHdr);
//		_coll.remove(ETDef_EDITIBOLDtl);
	endif;
	if ediData.isKindOf(CM_EDIDataCallOff) then
		_coll.remove(ETDef_EDITITaskActionRelReq);
	endif;
epilog
	if _type = EDIDataType_TransportManifest then
		ediDataTransManifest.deleteTransientChildrenClasses();
	endif;
	if _type = EDIDataType_CallOff then
		delete ediData.CM_EDIDataCallOff.myRequestMultiLine;
	endif;
	delete ediData;
end;</source>
        <access>protected</access>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_coll" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="handleMeasurementTypes" id="429ed0b5-0e1e-471d-bb31-fd80e71f904c">
        <updating/>
        <source>handleMeasurementTypes(_pxyFileTypeUser : CM_EDIFileTypeUser) updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 23/04/2014	cnwdap1		Initial creation PAR #33005 CCMS SFW 1381 Imperial measurements for EDI user defined layouts
// 9/06/2016	cnwjre1		TFS 2134 use the actual measurement type where possible not the default one to get the resulting data values correct
//
vars
	entTableGroup		: EntTableGroup;
	fieldMappingType	: CM_EDIFieldMappingType;
	fieldMapping		: CM_EDIFieldMapping;
	len,
	pos					: Integer;
	shortName			: String;
	fieldDesc			: String;
	propNameStr			: String;
	entTableRow			: EntTableRow;
	measure				: CM_MeasurementType;

begin
	if _pxyFileTypeUser.allEDIFieldMappingTypes.isEmpty() then
		// this is unlikely to be the case but might happen, so return now to save time.
		return;
	endif;
	
	entTableGroup := app.myRoot.myEntTableDataRoot.allEntTableGroups[ETGrp_EdiMaint];
	if entTableGroup = null then
		return;
	endif;
	
	foreach fieldMappingType in _pxyFileTypeUser.allEDIFieldMappingTypes do
	
		if fieldMappingType.allEDIFieldMappings.isEmpty() then
			// no field mapings to process
			continue;
		endif;
		
		foreach fieldMapping in fieldMappingType.allEDIFieldMappings do
			propNameStr	:= fieldMapping.propName;
			
			// find the ent table row for this propName in the EDIMaint Ent Table Group 
			// and see if it has a measurement type
			entTableRow := entTableGroup.allEntTableRowsByName[propNameStr];
			if entTableRow = null or entTableRow.measurementType = null then
				continue;
			endif;
			shortName := "";
			pos := 0;
			// TFS 2134 get the measurement type short name from the end of the field description and use this to get the measurement type
			fieldDesc := fieldMapping.fieldDescr;
			if fieldDesc[fieldDesc.length:1] = ")" then
				pos := fieldDesc.reversePos("(");
				if pos &gt; 0 then
					len := fieldDesc.length-(pos+1);
					if len &gt; 0 then
						shortName := fieldDesc[pos+1:len];
					endif;
				endif;
			endif;
			measure := null;
			if shortName &lt;&gt; "" then
				measure := app.myRoot.allMeasurementTypesByShortName[shortName];
			endif;
			// if not found then use the default measurement type
			if measure = null then
				measure := app.getDefaultMeasurementForType(entTableRow.measurementType);
				// if the default one is used, change the field description to match to make it clear what has happened
				if measure &lt;&gt; null then
					if pos &gt; 1 then
						fieldDesc := fieldDesc[1:pos] &amp; measure.shortName &amp; ")";
						fieldMapping.setFieldDescr(fieldDesc);
					endif;
				endif;
			endif;
			if measure = null then
				continue;
			endif;
			
			// update the field mapping with the found measurement type 
			fieldMapping.setMeasurementType(measure);
		endforeach;
		
	endforeach;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_pxyFileTypeUser" type="CM_EDIFileTypeUser"/>
    </JadeMethod>
    <JadeMethod name="handlePossibleCargoTypeMapping" id="770b0f74-f113-4dfd-a446-22cf98f899bc">
        <updating/>
        <source>handlePossibleCargoTypeMapping( _pxyFileTypeUser : CM_EDIFileTypeUser ) updating, protected;

/*
Purpose:	This method will go through the new field mappings and for any that is for CargoType
			will either change the entry to ignore if that mapping already has one for CargoTypeDescr
			else rename the CargoType one to CargoTypeDescr.

Date				Who		Reason
27 November 2009	cnwrl1	Initial creation as part of PAR 21713
*/
	
vars
	foundCargoTypeDescr	: Boolean;
	propNameStr			: String;
	fieldMappingType	: CM_EDIFieldMappingType;
	fieldMapping		: CM_EDIFieldMapping;
	dynaDict			: DynaDictionary;
	iter1				: Iterator;
	
begin
	if _pxyFileTypeUser.allEDIFieldMappingTypes.isEmpty() then
		// this is unlikely to be the case but might happen, so return now to save time.
		return;
	endif;
	
	create dynaDict transient;
	
	// set the membership of our dynamic dictionary
	dynaDict.setMembership(CM_EDIFieldMapping);
	
	// specify the required dictionary keys (descending and case insensitive)
	// descending means the cargoTypeDescr will be before cargoType
	dynaDict.addMemberKey(CM_EDIFieldMapping::propName.name, true, true);
	
	// complete key definition, duplicates allowed.
	dynaDict.endKeys(true);
	iter1	:= dynaDict.createIterator();
	
	foreach fieldMappingType in _pxyFileTypeUser.allEDIFieldMappingTypes do : mappingType_loop
		if fieldMappingType.allEDIFieldMappings.isEmpty() then
			// no field mapings to process
			continue mappingType_loop;
		endif;
		
		// populate the required instances into the dynamic dictionary.
		foundCargoTypeDescr	:= false;
		dynaDict.clear();
		fieldMappingType.allEDIFieldMappings.copy(dynaDict);
		iter1.reset();
		dynaDict.startKeyGeq(ETRow_CargoTypeDescr, iter1);
		
		while iter1.next(fieldMapping) do : mapping_loop
			propNameStr	:= fieldMapping.propName;
			
			// break once can have no more CargoType entries
			if propNameStr &lt; ETRow_CargoType then
				break mapping_loop;
			endif;
			
			// skip those not interested in
			if propNameStr &lt;&gt; ETRow_CargoType and propNameStr &lt;&gt; ETRow_CargoTypeDescr then
				continue mapping_loop;
			endif;
			
			// now if cargoTypeDescr set the boolean.
			if propNameStr = ETRow_CargoTypeDescr then
				foundCargoTypeDescr	:= true;
				continue mapping_loop;
			endif;
			
			// now must have the cargoType,
			if foundCargoTypeDescr then
				// already have a cargoTypeDescr so just set this entry to ignore, this keeps the sequence correct.
				fieldMapping.setPropertyValue(CM_EDIFieldMapping::propName.name, ETRow_Ignore);
				fieldMapping.setPropertyValue(CM_EDIFieldMapping::fieldDescr.name, '**Ignore**');
				fieldMapping.setPropertyValue(CM_EDIFieldMapping::userDesc.name, 'was Cargo Type');
			else
				// no descr so change the cargo type to descr.
				fieldMapping.setPropertyValue(CM_EDIFieldMapping::propName.name, ETRow_CargoTypeDescr);
				fieldMapping.setPropertyValue(CM_EDIFieldMapping::fieldDescr.name, 'Cargo Type Descr');
				fieldMapping.setPropertyValue(CM_EDIFieldMapping::userDesc.name, 'Cargo Type Descr');
			endif;
			// continue processing all mappings just in case cargoType is defined more than once!
		endwhile mapping_loop;
	endforeach mappingType_loop;
epilog
	delete iter1;
	delete dynaDict;
end;</source>
        <access>protected</access>
        <Parameter name="_pxyFileTypeUser" type="CM_EDIFileTypeUser"/>
    </JadeMethod>
    <JadeMethod name="handleReleaseTypeMappings" id="0e5f9792-5b78-4be9-a2bf-ba9120bd314f">
        <updating/>
        <source>handleReleaseTypeMappings( _pxyFileTypeUser : CM_EDIFileTypeUser ) updating, protected;

/*
Purpose:	This method will go through the new field mappings and for any that is for releaseType
			will either change the entry to ignore if that mapping already has one for releaseTypeStr
			else rename the releaseType one to releaseTypeStr.
			Note:
			The DynaDict is defined as descending this means any releaseTypeStr(s) are read before releaseType(s).
	
Date			Who		Reason
26 May 2010		cnwrl1	Initial creation as part of PAR 24131 - EDI Release Request Type to be translatable string.
*/
	
vars
	foundReleaseTypeStr	: Boolean;
	propNameStr			: String;
	startStr			: String;
	fieldMappingType	: CM_EDIFieldMappingType;
	fieldMapping		: CM_EDIFieldMapping;
	dynaDict			: DynaDictionary;
	iter1				: Iterator;
	
begin
	if _pxyFileTypeUser.allEDIFieldMappingTypes.isEmpty() then
		// this is unlikely to be the case but might happen, so return now to save time.
		return;
	endif;
	
	if _pxyFileTypeUser.dataType &lt;&gt; EDIDataType_ReleaseRequest then
		// only interested if importing a ReleaseRequest definition.
		return;
	endif;
	
	create dynaDict transient;
	
	// set the membership of our dynamic dictionary
	dynaDict.setMembership( CM_EDIFieldMapping );
	
	// specify the required dictionary keys (descending and case insensitive)
	// descending gives releaseTypeStr before releaseType
	dynaDict.addMemberKey( CM_EDIFieldMapping::propName.name, true, true );
	
	// complete key definition, duplicates allowed.
	dynaDict.endKeys( true );
	iter1		:= dynaDict.createIterator;
	startStr	:= ETRow_ReleaseTypeStr;			// do once out side loop
	
	foreach fieldMappingType in _pxyFileTypeUser.allEDIFieldMappingTypes do : mappingType_loop
		if fieldMappingType.allEDIFieldMappings.isEmpty() then
			// no field mapings to process
			continue mappingType_loop;
		endif;
		
		// populate the required instances into the dynamic dictionary.
		foundReleaseTypeStr	:= false;
		dynaDict.clear();
		fieldMappingType.allEDIFieldMappings.copy( dynaDict );
		iter1.reset();
		dynaDict.startKeyGeq( startStr, iter1 );
		
		while iter1.next( fieldMapping ) do : mapping_loop
			propNameStr	:= fieldMapping.propName;
			
			// break once can have no more releaseType entries
			if propNameStr &lt; ETRow_ReleaseType then
				break mapping_loop;
			endif;
			
			// skip those not interested in
			if propNameStr &lt;&gt; ETRow_ReleaseType and propNameStr &lt;&gt; ETRow_ReleaseTypeStr then
				continue mapping_loop;
			endif;
			
			// now if releaseTypeStr set the boolean.
			if propNameStr = ETRow_ReleaseTypeStr then
				foundReleaseTypeStr	:= true;
				continue mapping_loop;
			endif;
			
			// now must have the releaseType,
			if foundReleaseTypeStr then
				// already have a releaseTypeStr so just set this entry to ignore, this keeps the sequence correct.
				fieldMapping.setPropertyValue( CM_EDIFieldMapping::propName.name, ETRow_Ignore );
				fieldMapping.setPropertyValue( CM_EDIFieldMapping::fieldDescr.name, '**Ignore**' );
				fieldMapping.setPropertyValue( CM_EDIFieldMapping::userDesc.name, 'was releaseType' );
			else
				// no releaseTypeStr so change the releaseType to releaseTypeStr.
				fieldMapping.setPropertyValue( CM_EDIFieldMapping::propName.name, ETRow_ReleaseTypeStr );
				fieldMapping.setPropertyValue( CM_EDIFieldMapping::fieldDescr.name, 'Release Type (string)' );
				fieldMapping.setPropertyValue( CM_EDIFieldMapping::userDesc.name, ETRow_ReleaseTypeStr );
			endif;
			// continue processing all mappings just in case releaseType is defined more than once!
		endwhile mapping_loop;
	endforeach mappingType_loop;
	
epilog
	delete iter1;
	delete dynaDict;
	
end;
</source>
        <access>protected</access>
        <Parameter name="_pxyFileTypeUser" type="CM_EDIFileTypeUser"/>
    </JadeMethod>
    <JadeMethod name="hasFieldMapped" id="f001f2e0-193d-4d0d-91bd-20791a397296">
        <source>hasFieldMapped( _fieldName : String; _table :CM_DataTable input) : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 September 2008	cnwrd1	Initial creation
23/09/2009			cnwcs5	par20320 - new parameter
*/

vars
	row,
	numRows,
	colFieldDescr : Integer;
begin
	numRows 		:= _table.rows;
	colFieldDescr 	:= _table.getColumnByRowName(ETRow_FieldType);
	
	foreach row in _table.fixedRows + 1 to numRows do
		if _table.accessCell(row, colFieldDescr).text[1:30].trimBlanks() = _fieldName then
			return true;
		endif;		
	endforeach;
	
	return false;
epilog

end;</source>
        <Parameter name="_fieldName" type="String"/>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initTblFieldMap" id="c9bdab87-b84d-42b1-9f8e-205ace82f32a">
        <source>initTblFieldMap(_table :CM_DataTable input) protected;
/*
----------   ----------  --------------------------------------------------
Created:	20 July 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
22/09/2009	cnwcs5		par 20320 - changed table format
24/09/2009	cnwcs5		Pass table as parameter
*/
vars
	col	: Integer;
begin
	_table.clear;
	_table.setTblDataEntRowsFromDef(app.myController.getEntTableDef(ETDef_UserFileMapping));
	
	col := _table.getColumnByRowName(ETRow_FieldNo);
	
	_table.accessColumn(col).alignment	:= Table.Alignment_Center_Middle;
	_table.accessColumn(col).width		:= 50;
	
	_table.accessColumn(_table.getColumnByRowName(ETRow_Length)).maxLength 	:= 9;
	
	_table.rows 			:= 1;
	_table.inputType 		:= CM_BaseTable.InputType_TextBox;
	_table.fixedRows 		:= 1;	
	_table.fixedColumns		:= 1;
	_table.sortColumn[1] 	:= null;
	_table.sortType[1] 		:= null;
	_table.sortColumn[2] 	:= null;
	_table.sortType[2] 		:= null;
	_table.sortColumn[3] 	:= null;
	_table.sortType[3] 		:= null;
	
	_table.tabKey := J_key_Tab;
	

	
end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="initTblFieldUserCode" id="914f854d-9d8d-4b6b-9a46-90ec1a4cbeed">
        <source>initTblFieldUserCode(_table :CM_DataTable input)protected;
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
04 September 2008	cnwrd1	Initial creation
24/09/2009			cnwcs5	Pass table as parameter
*/

vars
	
begin
	_table.clear;
	_table.setTblDataEntRowsFromDef(app.myController.getEntTableDef(ETDef_UserFieldCode));
	
	_table.rows := 1;
	_table.inputType := CM_BaseTable.InputType_TextBox;

	_table.fixedRows 				:= 1;
	_table.fixedColumns 			:= 1;
	_table.accessColumn(1).width 	:= 50;
	_table.accessedColumn.alignment	:= Table.Alignment_Center;
	_table.clearSort;
	
	_table.tabKey := J_key_Tab;	
end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
