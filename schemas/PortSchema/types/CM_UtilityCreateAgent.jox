    <JadeMethod name="utlCreateVessel" id="fdb9a7a3-6be6-4643-91b8-d59d81976bff">
        <source>utlCreateVessel(_proxyVessel:CM_Vessel; _newVessel:CM_Vessel output; _conflictManager : CMIF_HMS_ConflictsManager output; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 January 2002 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 21 Sep 2020 cnwma1 		ChangeRequest 49906: MTN - Ops View External Webservice
// ---------------------------------------------------------------------------
vars
	jpController : CMIF_JobPriorityController;


begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	app.myValCA.valVessel(_proxyVessel, _conflictManager, _passport);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	app.setContinueCMExceptions(false);
	create _newVessel as _proxyVessel.class persistent;
	_newVessel.setForCreate(_proxyVessel);


	create jpController transient;
	jpController.init(false,_newVessel,CM_JobPriorityVessel);
	jpController.populateDefaults();
	
	app.myUtilityCA.utlCreateVoyageJobPriority(jpController,  _passport);


		
	if _passport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(_newVessel);
	endif;
	
	//21.09.2020 cnwma1 TFS #49906
	if _passport.isOpsViewEnabled(null) then
		_newVessel.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_CREATE,
								 BGP_OpsViewWSRequest.OPS_TYPE_VESSEL,
								 _newVessel);
	endif;
	//21.09.2020 cnwma1 TFS #49906
epilog
	if jpController &lt;&gt; null then
		jpController.allJobPriorities.purge; // proxies
		delete jpController;
	endif;
	
end;</source>
        <Parameter name="_proxyVessel" type="CM_Vessel"/>
        <Parameter name="_newVessel" type="CM_Vessel" usage="output"/>
        <Parameter name="_conflictManager" type="CMIF_HMS_ConflictsManager" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateVesselClone" id="47337c71-f88a-4815-9e27-b3e3ea8b8668">
        <updating/>
        <source>utlCreateVesselClone(_newVesselCode : String; _oldVessel:CM_Vessel; _newVessel:CM_Vessel output; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 23 Oct 2020  cnwma1      Bug 50234: MTN - Ops view message not created when creating new vessel
// ---------------------------------------------------------------------------

begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);

	_newVessel := _oldVessel.cloneMySelf(false, _newVesselCode);
	
	//23.10.2020 cnwma1 #50234
	if _passport.isOpsViewEnabled(null) then
		_newVessel.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_CREATE,
								 BGP_OpsViewWSRequest.OPS_TYPE_VESSEL,
								 _newVessel);
	endif;
	//23.10.2020 cnwma1 #50234
end;</source>
