    <JadeMethod name="getOperationsEndDTLocalTZ" id="fa33e148-0851-4882-aa69-e277243823f4">
        <source>getOperationsEndDTLocalTZ() : TimeStamp;
//
// Purpose:			Return the latest date for any receivals / releases for all cargo associated with this invoice
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
 // 13/12/2018	jlgdap1		Initial creation TFS 42474 PEL1 new fields for invoice reporting view
//
vars
	invoiceLine : CM_InvoiceLine;
	ti : CM_TrackedItem;
	wo : CM_WorkOrder;
	latestEnd : TimeStamp;
	allTis : CM_TISet;
	tran : CM_TITransaction;

begin
	create allTis transient;
	latestEnd := null;
	
	// if the invoice has a ti, just use that
	// if the invoice has a work order, check all tis from the work order
	// if the invoice has a voyage, check all tis from the voyage
	if self.myTrackedItem &lt;&gt; null then
		allTis.add(self.myTrackedItem);
	elseif self.myWorkOrder &lt;&gt; null then
		self.myWorkOrder.getAllTIs(allTis);
	elseif self.myVoyage &lt;&gt; null then
		self.myVoyage.getAllTrackedItems(allTis);
	endif;
	
	foreach ti in allTis discreteLock do
		tran := ti.getLastTransOfType(TRANS_TYPE_REC_SHIP);
		if tran &lt;&gt; null and tran.dateTime &gt; latestEnd then
			latestEnd := tran.dateTime;
		endif;
		
		tran := ti.getLastTransOfType(TRANS_TYPE_REL_SHIP);
		if tran &lt;&gt; null and tran.dateTime &gt; latestEnd then
			latestEnd := tran.dateTime;
		endif;
	endforeach;
	
	return self.systemToLocalTime(latestEnd);
	
epilog
	delete allTis;
end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getOperationsStartDTLocalTZ" id="162addda-33cd-4ba9-80e5-ac6b9483940c">
        <source>getOperationsStartDTLocalTZ() : TimeStamp;
//
// Purpose:			Return the earliest date for any receivals / releases for all cargo associated with this invoice
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 13/12/2018	jlgdap1		Initial creation TFS 42474 PEL1 new fields for invoice reporting view
//
constants
	DUMMY = "31 Dec 2500 10:00";
	
vars
	invoiceLine : CM_InvoiceLine;
	ti : CM_TrackedItem;
	wo : CM_WorkOrder;
	earliestStart : TimeStamp;
	allTis : CM_TISet;
	tran : CM_TITransaction;

begin
	create allTis transient;
	earliestStart := DUMMY.TimeStamp;
	
	// if the invoice has a ti, just use this
	// if the invoice has a work order, check all tis from the work order
	// if the invoice has a voyage, check all tis from the voyage
	if self.myTrackedItem &lt;&gt; null then
		allTis.add(self.myTrackedItem);
	elseif self.myWorkOrder &lt;&gt; null then
		self.myWorkOrder.getAllTIs(allTis);
	elseif self.myVoyage &lt;&gt; null then
		self.myVoyage.getAllTrackedItems(allTis);
	endif;
	
	foreach ti in allTis discreteLock do
		tran := ti.getTransactionOfType(TRANS_TYPE_REC_SHIP);
		if tran &lt;&gt; null and tran.dateTime &lt; earliestStart then
			earliestStart := tran.dateTime;
		endif;
		
		tran := ti.getTransactionOfType(TRANS_TYPE_REL_SHIP);
		if tran &lt;&gt; null and tran.dateTime &lt; earliestStart then
			earliestStart := tran.dateTime;
		endif;
	endforeach;
	
	if earliestStart = DUMMY.TimeStamp then
		earliestStart := null;
	endif;
	return self.systemToLocalTime(earliestStart);
	
epilog
	delete allTis;
end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getOtherInvoicesExternal" id="8a9f17cc-2c61-4078-9651-731286864310">
        <source>getOtherInvoicesExternal(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 Dec 2022 navtnr20	TFS CR 55308 TASK 55552: UI - Add new attribute to Invoice List columns
// 01/02/2023	navkc1	TFS CR 55305 Task 55537 UI - Invoice List UI changes
06 June 2023 navmv20 Bug 58390: EUP - Copied Invoice Other Invoice
*/

vars
	invoice,
	otherInvoice	: CM_Invoice;
	str				: String;
	trailStr		: String;
begin
	
	//23/08/2024	navkc1 Bug 65766
	otherInvoice := self.myOtherInvoice;
	if otherInvoice &lt;&gt; null and otherInvoice.externalNumber &lt;&gt; null then 
		if otherInvoice.isCreditNote() then
			trailStr := " (cn)";
		else
			trailStr := " (iv)";
		endif;
		str := otherInvoice.externalNumber &amp; trailStr;
	endif;
	
	//23/08/2024	navkc1 Bug 65766
	foreach invoice in self.allOtherInvoices discreteLock do
		if invoice.externalNumber = null then
			continue;
		endif;
		if invoice.isCreditNote() then
			trailStr := " (cn)";
		else
			trailStr := " (iv)";
		endif;
		
		if str = null then
			str := invoice.externalNumber &amp; trailStr;
		else
			str := str &amp; ", " &amp; invoice.externalNumber &amp; trailStr;
		endif;
	endforeach;
	
	return str;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPaymentStatusStr" id="6b653618-23e6-4a54-b3ab-0c65fed3d61f">
        <source>getPaymentStatusStr():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 Aug 2018  cnwma1	ChangeRequest 39698: PEL1 - SAP Enable SAP interfaces

*/

vars

begin
	if self.paymentStatus = CM_Invoice.INVOICE_PAYMENT_PAID then
		return app.getErrorString(Invoice_payment_paid);
	elseif self.paymentStatus = CM_Invoice.INVOICE_PAYMENT_CANCEL then
	  return app.getErrorString(Invoice_payment_cancelled);
	elseif self.paymentStatus = CM_Invoice.INVOICE_PAYMENT_NOTPAID then
	  return app.getErrorString(Invoice_payment_Notpaid);
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPaymentType" id="5eb309e5-d253-4f67-a20c-14ae034f4dcc">
        <source>getPaymentType() : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 June 2018	jlgab1	Initial creation	TFS39250
27 September 2018	cnwma1	ChangeRequest 41132: PEL1 - SAP Integration : Additional Changes
*/

vars
//	paymentType : Integer;
//	debtorTerminal : CM_DebtorTerminal;
//	firstInvoiceLine : CM_InvoiceLine;
begin

	return self.paymentType;	//10 Oct 2018	NDL	TFS 41281
/*	if self.myVoyage &lt;&gt; null then
		paymentType := self.myVoyage.paymentType;
		if paymentType = PaymentType_AutoCollection
		or paymentType = PaymentType_PrePay
		or paymentType = PaymentType_PostPay then
			return paymentType;
		endif;
		
	endif;
	
	if self.debtor &lt;&gt; null then
		debtorTerminal:= self.debtor.allDebtorTerminals[self.myTerminal];
		if debtorTerminal &lt;&gt; null then
			paymentType := debtorTerminal.paymentType;
		endif;
		
		if paymentType = PaymentType_AutoCollection
		or paymentType = PaymentType_PrePay
		or paymentType = PaymentType_PostPay then
			return paymentType;
		endif;
		
		
	endif;

	//return PaymentType_AutoCollection; // Default  //27.09.2018 cnwma1 TFS #41132
	return PaymentType_None;           // Default  //27.09.2018 cnwma1 TFS #41132 */
	
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getPelindoTaxCode" id="c387a287-4d42-4630-a28f-02df16cb4fbd">
        <source>getPelindoTaxCode() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 December 2018	jlger1	Initial creation 42116

*/

vars

	finIOClass : CM_ExtFinanceIO;
	headerText ,
	taxCode     : String;
	
begin
	
	if self.externalTaxNumber &lt;&gt; null then
		headerText := self.externalTaxNumber;
	else
		finIOClass := self.myTerminal.getConfig(FinancialIOClass).CM_ExtFinanceIO;
		if finIOClass.isKindOf(CM_Pelindo1Interface) then
			headerText := finIOClass.CM_Pelindo1Interface.getPelindoInvTaxStatusStr(self);
		endif;
	endif;
	if headerText[1:3] = "010" then
		taxCode := "A0";
	elseif headerText[1:3] = "030" then
		taxCode := "A1";
	elseif headerText[1:3] = "070" then
		taxCode := "A2";
	elseif headerText[1:3] = "080" then
		taxCode := "A3";
	endif;
	
	return taxCode;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
