        <source>dkbExtraInfo_userResize(dockBar: JadeDockBar input) updating;
//--------------------------------------------------
// Created:	05 September 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.doResizeTblInfo();
end;</source>
        <Parameter name="dockBar" type="JadeDockBar" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doArchive" id="550e808c-0b30-4d34-bb58-9295a8fbfc93">
        <updating/>
        <source>doArchive() updating, protected;
//-----------------------------------------
// Created: August 2005 By: cnwgd1
//-----------------------------------------
vars
	allVoyages	: CM_VoyageArray;
	selectedObj	: Object;
	voyageObj	: CM_Voyage;
	errorMsg	: String;
	
begin
	create allVoyages transient;
	
	foreach selectedObj in tblData.allSelectedObjects do
		voyageObj	:=	selectedObj.CM_Voyage;
		
		if not voyageObj.checkAllResourcesAreCharged() then
			if errorMsg = null then
		//		errorMsg	:=	'Cannot Archive.' &amp; Cr &amp; 'Voyage ' &amp; self.myCurrentVoyage.code &amp;
				errorMsg	:=	'Cannot Archive.' &amp; Cr &amp; 'Voyage ' &amp; voyageObj.code &amp;	//18 Jun 2021	NDL	TSF 51261
								' has outstanding Resources that have not been charged.';
			else
		//		errorMsg	:=	errorMsg &amp; CrLf &amp; CrLf &amp; 'Cannot Archive.' &amp; Cr &amp; 'Voyage ' &amp; self.myCurrentVoyage.code &amp;
				errorMsg	:=	errorMsg &amp; CrLf &amp; CrLf &amp; 'Cannot Archive.' &amp; Cr &amp; 'Voyage ' &amp; voyageObj.code &amp;	//18 Jun 2021	NDL	TSF 51261
								' has outstanding Resources that have not been charged.';
			endif;
		endif;
		
		allVoyages.add(selectedObj.CM_Voyage);
	endforeach;
	
	if errorMsg &lt;&gt; null then
		app.msgBox(errorMsg, 'Select Voyage', MsgBox_OK_Only+MsgBox_Information_Icon);
		return;
	endif;
	
	if allVoyages.isEmpty() then
		app.msgBox('Please select a Voyage to archive.', 'Select Voyage', MsgBox_OK_Only+MsgBox_Information_Icon);
		return;
// cnwdad1 06/09/2006 - CCMS #1039.
//	elseif self.tblData.allSelectedObjects.size &gt; 1 then
//		app.msgBox('Please one voyage at a time to archive.', 'Select Voyage', MsgBox_OK_Only+MsgBox_Information_Icon);
//		return;
	endif;
	
	self.myAssistant.showVoyageArchiveForm(allVoyages, self.myMasterMenuAction, self.filterIsNoDates);
epilog
	delete allVoyages;
end;</source>
        <access>protected</access>
    </JadeMethod>
