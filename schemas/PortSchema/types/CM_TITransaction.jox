    <JadeMethod name="hsCode" id="efb197e2-1223-4929-946b-0791b4a37f23">
        <methodInvocation>mapping</methodInvocation>
        <source>hsCode(set: Boolean; _value: String io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
25 November 2022		jlizm1	Initial creation TFS 55280 Harmonized System Codes

*/

vars

begin
	if set then
		global.setExtraData(self.allExtraData, self, HSCode, _value);
	else
		global.getExtraData(self.allExtraData, HSCode, _value);
	endif;

epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
