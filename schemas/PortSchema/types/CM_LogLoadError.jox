<Class name="CM_LogLoadError" id="81f0bbeb-a49a-43d1-a635-48823242e6d7">
    <superclass name="CM_LogObject"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="logObjs"/>
    <CompAttribute name="allErrorMsgs" id="6f50a347-5808-4c15-a2a4-f6923437841c">
        <type name="HugeStringArray"/>
        <access>readonly</access>
    </CompAttribute>
    <CompAttribute name="allErrorNos" id="661f9fa7-615d-4d19-bd8c-31a7c4bae761">
        <type name="IntegerArray"/>
        <access>readonly</access>
    </CompAttribute>
    <PrimAttribute name="id" id="8cc5d7b0-00b2-4b2f-a4ec-c1f540c03cbd">
        <length>21</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
        <text>
The id of the log with the error</text>
    </PrimAttribute>
    <ExplicitInverseRef name="myBOLExtLogOut" id="55178001-671d-41b8-a731-ce08ab7b8df9">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_BOLExtLogOut"/>
        <access>readonly</access>
        <Inverse name="CM_BOLExtLogOut::allLogLoadErrors"/>
    </ExplicitInverseRef>
    <ImplicitInverseRef name="myLog" id="64505d01-5ae1-4cb4-8e41-5a75b25af291">
        <embedded/>
        <type name="CM_Log"/>
        <access>readonly</access>
        <text>
This can be null, dependent on the error</text>
    </ImplicitInverseRef>
    <JadeMethod name="addErrorMsgNo" id="cfcac344-2f31-4621-8bfd-effeeead380a">
        <updating/>
        <source>addErrorMsgNo(_errorMsg : String; _errorNo : Integer)updating, protected;
//--------------------------------------------------------------
//Created: 24 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	self.allErrorMsgs.add(_errorMsg);
	self.allErrorNos.add(_errorNo);
end;</source>
        <access>protected</access>
        <Parameter name="_errorMsg" type="String"/>
        <Parameter name="_errorNo" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="set" id="6231ff7b-018e-4572-9dea-e96499c446ac">
        <updating/>
        <source>set(_id : String; _bol : CM_BOLExtLogOut; _log : CM_Log; _errorMsg: String; _errorNo : Integer)updating;
//--------------------------------------------------------------
//Created: 24 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	self.id 			:= _id;
	self.myBOLExtLogOut := _bol;
	self.myLog 			:= _log;
	
	self.allErrorMsgs.clear;
	self.allErrorNos.clear;
	
	self.allErrorMsgs.add(_errorMsg);	
	self.allErrorNos.add(_errorNo);	

end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_bol" type="CM_BOLExtLogOut"/>
        <Parameter name="_log" type="CM_Log"/>
        <Parameter name="_errorMsg" type="String"/>
        <Parameter name="_errorNo" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="c30fa231-9728-4f12-9577-3bf2454c1ed1">
        <updating/>
        <source>setForUpdate(_log : CM_Log; _errorMsg: String; _errorNo : Integer)updating;
//--------------------------------------------------------------
//Created: 24 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	self.myLog := _log;
	self.addErrorMsgNo(_errorMsg, _errorNo);	

end;</source>
        <Parameter name="_log" type="CM_Log"/>
        <Parameter name="_errorMsg" type="String"/>
        <Parameter name="_errorNo" type="Integer"/>
    </JadeMethod>
</Class>
