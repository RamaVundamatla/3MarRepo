    <JadeMethod name="saveGroupProxyData" id="0388ca32-87fd-456e-8ef7-519757fa0377">
        <source>saveGroupProxyData() protected;
// ---------------------------------------------------------------------------
// Created:     05 March 2001 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 12/02/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
// 12 Jan 2026  navlc30     JIRA 36954 Story MTN | Highlight Mandatory fields

vars
	idx,
	numRows	: Integer;
	proxyEntTableRow	: EntTableRowProxy;
	rowName,
	heading,
	shortHeading,
	controlName,
	clickMethodName,
	gotFocusMethodName,
	lostFocusMethodName,
	sortFieldName,
	errReturnStr	: String;
	//colWidthFactor,
	//minColWidth,
	inputType,
	inputTypeWeb	: Integer;
	displayNullIfZero,
	rowVisible	: Boolean;
	termType	: CM_TerminologyType;
	measurementType : String;				// PAR #3115
	isMandatoryField : Boolean;
begin

	numRows := tblGroup.rows;

	// Update the proxy objects with the values entered on the form.
		
	foreach idx in 2 to numRows do
		proxyEntTableRow := tblGroup.accessRow(idx).itemObject.EntTableRowProxy;
		if proxyEntTableRow &lt;&gt; null then
			rowName 		:= tblGroup.accessCell(idx, 1).text;
			heading 		:= tblGroup.accessCell(idx, 2).text;
			shortHeading	:=  tblGroup.accessCell(idx, 3).text;
			inputType 		:= self.inTypeStringToEnum(tblGroup.accessCell(idx, Col_InputType).text);
			controlName 	:= tblGroup.accessCell(idx, 5).text;
			inputTypeWeb	:= self.inputTypeWebStringToEnum(tblGroup.accessCell(idx, Col_InputTypeWeb).text);
			termType		:= app.myRoot.allTerminologyTypes[tblGroup.accessCell(idx, Col_TerminologyType).text];
			rowVisible 		:= tblGroup.accessCell(idx, 8).text.Integer.Boolean;
			displayNullIfZero := tblGroup.accessCell(idx, 9).text.Integer.Boolean;
			clickMethodName  	:= tblGroup.accessCell(idx, 10).text;
			gotFocusMethodName  := tblGroup.accessCell(idx, 11).text;
			lostFocusMethodName := tblGroup.accessCell(idx, 12).text;
			errReturnStr		:= tblGroup.accessCell(idx, 13).text;
			measurementType		:= tblGroup.accessCell(idx, 14).text;			// PAR #31155
			isMandatoryField	:= tblGroup.accessCell(idx, 15).text.Integer.Boolean;	//12.01.2026 navlc30 #36954

			proxyEntTableRow.setForProxy(rowName, heading, shortHeading, controlName, inputType, inputTypeWeb, termType, rowVisible, 
								//displayNullIfZero, sortFieldName, clickMethodName,	gotFocusMethodName, lostFocusMethodName, errReturnStr, null);					// PAR #31155
								//displayNullIfZero, sortFieldName, clickMethodName,	gotFocusMethodName, lostFocusMethodName, errReturnStr, measurementType, null);		// PAR #31155  //12.01.2026 navlc30 #36954
								displayNullIfZero, sortFieldName, clickMethodName,	gotFocusMethodName, lostFocusMethodName, errReturnStr, measurementType,isMandatoryField, null);		   //12.01.2026 navlc30 #36954
		else
			app.writeStatement( 'Error &gt;&gt; no proxyEntTableRow found for row ' &amp; idx.String &amp; '  (' &amp; tblGroup.accessCell(idx, 1).text &amp; ')');
		endif;
	endforeach;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="saveView" id="681f4e28-0d84-4145-89af-9f707089b6bd">
        <updating/>
        <source>saveView() updating;
// ---------------------------------------------------------------------------
// Created:     15 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	view		: EntTableView;
	entTableRow	: EntTableRow;
	viewName	: String;
	numRows		: Integer;
	idx			: Integer;
	oa			: ObjectArray;
	obj			: Object;
		
begin
	viewName := cmbView.text;
	
	if myCurrentDef = null then
		app.msgBox('You must have selected a definition first', 'Error', MsgBox_OK_Only);
		return;
	endif;
	/*//already checked in add view
	if not self.checkViewName(viewName) then
		return;
	endif;
		*/
	beginTransaction;

	if not checkGroupEdition() then
		abortTransaction;
		return;
	endif;

	if myCurrentView &lt;&gt; null then
		if myCurrentView.name = viewName then
			view := myCurrentView;
		else
			create view;
		endif;
	else
		create view;
	endif;
	
	view.set(viewName, null, self.myCurrentDef);

	numRows := tblView.rows;
	
	create oa transient;

	foreach idx in 2 to numRows do
		entTableRow := tblView.accessRow(idx).itemObject.EntTableRow;
		if entTableRow &lt;&gt; null then
			oa.add(entTableRow);
		endif;
	endforeach;
	
	view.clearRows();
	foreach obj in oa do
		if not view.addRow(obj.EntTableRow) then
			app.msgBox('The row ' &amp; obj.EntTableRow.name &amp; ' has already been entered', 'Error', MsgBox_OK_Only);
		endif;
	endforeach;
	
	commitTransaction;

	self.isDataChanged := true;
	self.setView(view);
	cmbView.text := viewName;	
epilog
	if oa &lt;&gt; null then
		delete oa;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="searchAll" id="3fc76fc7-4e89-44ad-b0e0-542d7af50a5d">
        <updating/>
        <source>searchAll(_searchStr :String) updating;
// ---------------------------------------------------------------------------
// Created:     17 May 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	groupColl	:EntTableGroupDictByName;
	defColl 	:EntTableDefDictByName;
	viewCol   :EntTableViewDictByName;
	
	tmpGrp 		:EntTableGroup;
	tmpDef 		:EntTableDef;
	tmpView		:EntTableView;
	i					:Integer;
	found 		:Boolean;
begin
	found := false;
	
	groupColl := self.myEntTableDataRoot.allEntTableGroups;
	
	foreach tmpGrp in groupColl do
		if _searchStr = tmpGrp.name.toUpper then
			found := true;
			self.setGroup(tmpGrp, self.currentSortKey);
			self.setDefinition(null);
			break;
		endif;
		
		defColl := tmpGrp.allEntTableDefsByName;
		foreach	tmpDef in defColl do
			if _searchStr = tmpDef.name.toUpper then
				found := true;
				self.setGroup(tmpGrp, 'name');
				self.setDefinition(tmpDef);
				break;		
			endif;
			
			viewCol := tmpDef.allEntTableViews;
			foreach tmpView in viewCol do
				if _searchStr = tmpView.name.toUpper then
					found := true;
					self.setGroup(tmpGrp, 'name');
					self.setDefinition(tmpDef);
					self.setView(tmpView);
					break;
				endif;
			endforeach;
		endforeach;
	endforeach;
	
	if not found then
		app.msgBox("Couldn't find a group/definition or view by that name","Sorry",0);
	endif;
end;</source>
        <Parameter name="_searchStr" type="String"/>
    </JadeMethod>
    <JadeMethod name="setControlDistances" id="f68ec830-1514-4b8d-b119-96b9b9ee81e0">
        <source>setControlDistances();

vars
	vertGap,horzGap :Integer;
begin
	vertGap := 30;
	horzGap := 20;
	
	btnDeleteView.distanceFromBottom := staMain.height + vertGap + grpAll.height + 10;
	btnSaveView.distanceFromBottom := staMain.height + vertGap + grpAll.height + 10;
	btnSaveDef.distanceFromBottom :=staMain.height + vertGap + grpAll.height + 10;
	btnDeleteDef.distanceFromBottom := staMain.height + vertGap + grpAll.height + 10;
	 
	btnDeleteView.distanceFromRight := horzGap;
	btnSaveView.distanceFromRight := horzGap + btnDeleteView.width + horzGap;
	btnSaveDef.distanceFromRight := horzGap + btnDeleteView.width + horzGap + btnSaveView.width + horzGap;
	btnDeleteDef.distanceFromRight := horzGap + btnDeleteView.width + horzGap + btnSaveView.width + horzGap + btnSaveDef.width + horzGap;
	
	tblView.setDistanceFromRight(horzGap);
	
	btnViewInclAll.distanceFromRight := horzGap + tblView.width + horzGap;
	btnViewInclOne.distanceFromRight := horzGap + tblView.width + horzGap;
	btnViewExclAll.distanceFromRight := horzGap + tblView.width + horzGap;
	btnViewExclOne.distanceFromRight := horzGap + tblView.width + horzGap;
	
	tblDef.setDistanceFromRight(tblView.width + horzGap + btnViewInclAll.width + horzGap);
	
	btnDefInclAll.distanceFromRight := tblDef.distanceFromRight + tblDef.width + horzGap;
	btnDefInclOne.distanceFromRight := tblDef.distanceFromRight + tblDef.width + horzGap;
	btnDefExclAll.distanceFromRight := tblDef.distanceFromRight + tblDef.width + horzGap;
	btnDefExclOne.distanceFromRight := tblDef.distanceFromRight + tblDef.width + horzGap; 
	
	//calced after controls above to use their correct distancesFromRight attribs
	btnDeleteView.distanceFromRight := horzGap;
	btnSaveView.distanceFromRight := btnDeleteView.distanceFromRight + btnDeleteView.width + horzGap;
	btnDeleteDef.distanceFromRight := btnSaveView.distanceFromRight + btnSaveView.width + btnViewInclAll.width + horzGap;//so they are directly under tables
	btnSaveDef.distanceFromRight := btnDeleteDef.distanceFromRight + btnDeleteDef.width + horzGap;
	
	//Allthis stuff are controls above the tables
	btnAddView.distanceFromRight := horzGap;

	btnAddDefinition.distanceFromRight := btnViewInclAll.distanceFromRight + horzGap;
	txtDefDescr.distanceFromRight := btnAddDefinition.distanceFromRight + btnAddDefinition.width + 5;
	txtDefName.distanceFromRight := txtDefDescr.distanceFromRight;
	lblDefName.distanceFromRight := txtDefDescr.distanceFromRight + txtDefDescr.width +5;
	lblDefDescr.distanceFromRight := txtDefDescr.distanceFromRight + txtDefDescr.width +5;
	
	cmbView.distanceFromRight := horzGap;
	lblView.distanceFromRight := cmbView.distanceFromRight + cmbView.width + horzGap;
	cmbDefinition.distanceFromRight := btnAddDefinition.distanceFromRight + btnAddDefinition.width;
	lblDefinition.distanceFromRight := txtDefDescr.distanceFromRight + txtDefDescr.width +5; 
	//tables are stretchy so:
	tblGroup.setDistanceFromRight(btnDefInclAll.distanceFromRight + btnDefInclAll.width);
//	tblGroup.setDistanceFromBottom(btnDeleteGroup.distanceFromBottom + btnDeleteGroup.height);
	tblDef.setDistanceFromBottom(btnDeleteView.distanceFromBottom + btnDeleteView.height);
	tblView.setDistanceFromBottom(btnDeleteView.distanceFromBottom + btnDeleteView.height);
	
	tblView.stretchHeight := true;
	tblDef.stretchHeight := true;
	tblGroup.stretchHeight := true;
	tblGroup.stretchWidth := true;
	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setDefinition" id="c685d601-12b3-46eb-964c-d6c83540533b">
        <updating/>
        <source>setDefinition(pDef : EntTableDef) updating;
// ---------------------------------------------------------------------------
// Created:     19 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	entTableRow	: EntTableRow;
	tblRow		: Integer;
	
begin

	self.initTables(tblDef, false);

	if pDef &lt;&gt; null then
		if myCurrentDef &lt;&gt; pDef then
			self.myCurrentDef := pDef;
			self.setView(null);
			cmbView.listCollection(pDef.allEntTableViews, true, 0);
		endif;
		
		cmbDefinition.text 	:= pDef.name;
		txtDefDescr.text	:= pDef.description;
		
		foreach entTableRow in myCurrentDef.allEntTableRows do
			tblRow := tblDef.addItem(displayEntTableRow(entTableRow, false));
			tblDef.accessRow(tblRow).itemObject := entTableRow;
			
			// AKB2011NOV
			if entTableRow.isGroupRow then
				tblDef.accessRow(tblRow).backColor := LightRed;
			endif;
			
		endforeach;
		
		self.enableDefEdit();
	else
		myCurrentDef := null;
		self.initTables(tblDef, false);
		self.disableDefEdit();
		self.setView(null);
	endif;

end;</source>
        <Parameter name="pDef" type="EntTableDef"/>
    </JadeMethod>
    <JadeMethod name="setGroup" id="d55112ae-4baf-412a-96b8-cd8e7fd9c780">
        <updating/>
        <source>setGroup(pGroup : EntTableGroup; _orderKey : String) updating;
// ---------------------------------------------------------------------------
// Created:     19 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	entTableRow		: EntTableRow;
	dynaDict		: DynaDictionary;
	iter			: Iterator;
	
begin

	if pGroup &lt;&gt; null then
		if self.myCurrentGroup &lt;&gt; pGroup then
			self.myCurrentGroup := pGroup;
			cmbGroup.text := pGroup.name;
			self.setDefinition(null);
			cmbDefinition.listCollection(pGroup.allEntTableDefsByName, true, 0);
			txtDefName.text := "";
			txtDefDescr.text := "";
		endif;
		
		tblGroup.rows := tblGroup.fixedRows;
		self.myRowDynaDict.clear();
		self.myRowDynaDict.clearKeys();
		self.myRowDynaDict.setMembership(EntTableRow);
		self.myRowDynaDict.addMemberKey(_orderKey, false, false);
		self.myRowDynaDict.endKeys(true);
		pGroup.allEntTableRowsByName.copy(self.myRowDynaDict);
		
		iter := self.myRowDynaDict.createIterator;
		
		while iter.next(entTableRow) do
			tblGroupAddRow(entTableRow);
		endwhile;
				
		tblGroup.enabled := true;
	else
		myCurrentGroup := null;
		self.initTables(tblGroup, true);
		cmbDefinition.clear;
		tblGroup.enabled := false;
		self.disableDefEdit();
		self.disableViewEdit();
	endif;

epilog
	delete iter;
end;</source>
        <Parameter name="pGroup" type="EntTableGroup"/>
        <Parameter name="_orderKey" type="String"/>
    </JadeMethod>
    <JadeMethod name="setView" id="95b6daa8-fd91-4053-a827-23b5ce53d419">
        <updating/>
        <source>setView(pView : EntTableView) updating;
// ---------------------------------------------------------------------------
// Created:     19 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	entTableRow	: EntTableRow;
	tblRow		: Integer;
	
begin

	self.initTables(tblView, false);
	
	if pView &lt;&gt; null then
		if self.myCurrentView &lt;&gt; pView then
			self.myCurrentView := pView;
		endif;
		
		cmbView.text := pView.name;
		
		foreach entTableRow in myCurrentView.allEntTableRows do
			tblRow := tblView.addItem(displayEntTableRow(entTableRow, false));
			tblView.accessRow(tblRow).itemObject := entTableRow;
		endforeach;
		
		self.enableViewEdit();
	else
		myCurrentView := null;
		self.initTables(tblView, false);
		self.disableViewEdit();
	endif;

end;</source>
        <Parameter name="pView" type="EntTableView"/>
    </JadeMethod>
