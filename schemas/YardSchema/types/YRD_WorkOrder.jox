    <JadeMethod name="showTrackedItem" id="c8267c7d-5aa4-4502-b179-8959dc85d1cc">
        <source>showTrackedItem();

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
14/07/2022		navcs2	ChangeRequest 53932: MTN - Jobs Changes
18 May 2023 	navhl20	ChangeRequest 56631:[56185] EUP - Transport Mode change - UI Changes
*/

vars
	cargoEnquiry 	: CM_ContainerEnqForm;
	tiColl, tis			: CM_TISet;
	iter			: Iterator;
	ti				: CM_TrackedItem;
begin

	create tiColl transient;
	create tis transient;
	
	myPxyWorkOrder.getAllTIs(tis);
	
	//iter := tis.createIterator();												//18.5.2023 navhl20 #56631[56185]
	iter := self.tblSelectedCargo.allSelectedObjects.createIterator;			//18.5.2023 navhl20 #56631[56185]
	
	if myTerminal &lt;&gt; null  then
	
		cargoEnquiry := app.loadForm(CM_ContainerEnqForm, CMUI_Assistant, false, false, false, myTerminal , null).CM_ContainerEnqForm;	
		cargoEnquiry.setMyTerminal(myTerminal);	
		cargoEnquiry.setFilterCargoTypeId (true);
			
		if cargoEnquiry = null then
			return;
		endif;
		
		while iter.next(ti) do
			if ti.myTerminal = myTerminal then
				tiColl.add(ti);
			endif;
		endwhile;
	
		cargoEnquiry.show(); 
		cargoEnquiry.displaySelectorResults(tiColl, null);
	
	endif;

epilog
	delete tiColl;
	delete iter;
end;</source>
    </JadeMethod>
