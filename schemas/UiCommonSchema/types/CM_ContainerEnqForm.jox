	elseif _sht.name = self.shtEdit1.name then
		return self.tblEdit1;
	elseif _sht.name = self.shtEdit2.name then
		return self.tblEdit2;	
	elseif _sht.name = self.shtEdit3.name then
		return self.tblEdit3;	
	elseif _sht.name = self.shtEdit4.name then
