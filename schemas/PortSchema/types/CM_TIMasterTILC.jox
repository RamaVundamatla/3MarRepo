    <JadeMethod name="setForProxyMasterTILC" id="c989481a-9a1c-467c-8cf3-f0c9a60d6d35">
        <updating/>
        <source>setForProxyMasterTILC(	_id				: String;
						_description 	: String;
						_root			: CM_Root;
						_licenseIssuer	: String;
						_licenseNumber	: String;
						//_tareWeight 	: Integer;					// PAR #31155
						_tareWeight 	: Decimal;					// PAR #31155
						_tilcType 		: CM_TILCType;
						_operator 		: CM_Operator;
						_owner	 		: CM_Operator;
						_stopTables		:CM_StopsTableByIdDict;
						_toDoTaskDesc	: CM_ToDoTaskDescByCode;
						_offHireDate	: Date;
						_onHireDate		: Date;
						_remarks		: String;
						_genMaster      : CM_TIMaster;
						_floorType		: Integer					// 09 May 2025	navcs2	MTN-34844		
						) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
11 April 2007	cnwer1	Initial creation - PAR#xxxx
12 march 2013	cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements - change weight parameter from integer to decimal
27 Feb 2018		cnwma1  ChangeRequest 36813: PEN - Gen Sets, Chassis &amp; Reefers
09 May 2025	navcs2	MTN-34844 [MTN-26256] Development - Portschema Implementation

*/
vars
	cargoId : Integer;
begin
	if _tilcType &lt;&gt; null then
		cargoId := _tilcType.myCargoType.id;
	endif;
	
	self.setForProxyMaster( cargoId,
							_id,
							_description,
							_tareWeight,
							_operator,
							_owner,
							_stopTables,
							_toDoTaskDesc,
							_root);
	self.licenseIssuer:=_licenseIssuer;
	self.licenseNumber:=_licenseNumber;
	self.myTILCType:=_tilcType;
	
	//+cnwml2 MSL CCMS 1027
	self.offHireDate := _offHireDate;
	self.onHireDate := _onHireDate;
	self.remarks := _remarks;
	if _genMaster &lt;&gt; null then    //27.02.2018 cnwma1 ChangeRequest #36813
		self.allTIMasterAttachees.add(_genMaster);
	endif;
	self.floorType := _floorType;		// 09 May 2025	navcs2	MTN-34844
epilog

end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_root" type="CM_Root"/>
        <Parameter name="_licenseIssuer" type="String"/>
        <Parameter name="_licenseNumber" type="String"/>
        <Parameter name="_tareWeight" type="Decimal"/>
        <Parameter name="_tilcType" type="CM_TILCType"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_owner" type="CM_Operator"/>
        <Parameter name="_stopTables" type="CM_StopsTableByIdDict"/>
        <Parameter name="_toDoTaskDesc" type="CM_ToDoTaskDescByCode"/>
        <Parameter name="_offHireDate" type="Date"/>
        <Parameter name="_onHireDate" type="Date"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_genMaster" type="CM_TIMaster"/>
        <Parameter name="_floorType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="82326cfd-f90b-4330-88dd-0170714ddd7f">
        <updating/>
        <source>setForUpdate(_proxyTiMaster: SelfType) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
11 April 2007	cnwer1	Initial creation - PAR#xxxx
// cnwrd1 ccms 1034 13.8.2008
09 May 2025	navcs2	MTN-34844
*/
vars
	damageInstance,
	newDamageInstance: CM_DamageInstance;
begin
	inheritMethod(_proxyTiMaster);
	self.licenseIssuer:=_proxyTiMaster.licenseIssuer;
	self.licenseNumber:=_proxyTiMaster.licenseNumber;
	self.tWeight:=_proxyTiMaster.tWeight;
	self.myTILCType:=_proxyTiMaster.myTILCType;
	
	//+cnwml2 MSL CCMS 1027
	self.offHireDate := _proxyTiMaster.offHireDate;
	self.onHireDate := _proxyTiMaster.onHireDate;
	self.remarks := _proxyTiMaster.remarks;
	self.floorType	:= _proxyTiMaster.floorType;		//09 May 2025	navcs2	MTN-34844
	
	self.causeEvent(Event_TiMaster_Update, false, null);
epilog

end;</source>
        <Parameter name="_proxyTiMaster" type="SelfType"/>
