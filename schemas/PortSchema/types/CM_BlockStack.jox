        <source>getColumns( _forDrawing : Boolean ):Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 August 2011	cnwndl1	Initial creation	Par 28076

*/

vars

begin
	
	if self.columns &gt; 0 then
		return self.columns;
	elseif _forDrawing then
		return 5;	//YRD_ContainerDrawingController.BlockStackSize;
	endif;
	
	return self.columns;

epilog

