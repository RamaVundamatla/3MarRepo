    <JadeMethod name="getTerminalSecRoles" id="db2ffb80-e8ca-4c17-808c-39803ddf77e9">
        <source>getTerminalSecRoles():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 August 2019	jlgndl1	Initial creation	TFS 45057

*/

vars

	str : String;
	userTerm : CM_UserTerminal;

begin

	foreach userTerm in self.allUserTerminals do
		if str = "" then        
			str := userTerm.myTerminal.code &amp; " (" &amp; userTerm.mySecurityRole.name &amp; ")";	
		else	
			str := str &amp; ", " &amp; userTerm.myTerminal.code &amp; " (" &amp; userTerm.mySecurityRole.name &amp; ")";	
		endif;
	endforeach;

	return str;

epilog

end;</source>
