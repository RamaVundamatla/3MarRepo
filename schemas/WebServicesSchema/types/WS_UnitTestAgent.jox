	if not provider.sendMsgWithParams(JMTUserInterfaceService::validateCurrentSession.name, checkUser).Boolean then
		_errors &amp;= "JMTUserInterfaceService::validateCurrentSession for Public access to " &amp; methodName &amp; " failed" &amp; CrLf;
	endif;
	methodName := JMTUserInterfaceService::getVesselSchedule.name;
	provider.setPropertyValue("_methodName", methodName);
	if not provider.sendMsgWithParams(JMTUserInterfaceService::validateCurrentSession.name, checkUser).Boolean then
		_errors &amp;= "JMTUserInterfaceService::validateCurrentSession for Public access to " &amp; methodName &amp; " failed" &amp; CrLf;
	endif;
	methodName := JMTUserInterfaceService::checkPermissions.name;
	provider.setPropertyValue("_methodName", methodName);
	if not provider.sendMsgWithParams(JMTUserInterfaceService::validateCurrentSession.name, checkUser).Boolean then
		_errors &amp;= "JMTUserInterfaceService::validateCurrentSession for Public access to " &amp; methodName &amp; " failed" &amp; CrLf;
	endif;
	methodName := JMTUserInterfaceService::getTerminalConfig.name;
	provider.setPropertyValue("_methodName", methodName);
	if not provider.sendMsgWithParams(JMTUserInterfaceService::validateCurrentSession.name, checkUser).Boolean then
		_errors &amp;= "JMTUserInterfaceService::validateCurrentSession for Public access to " &amp; methodName &amp; " failed" &amp; CrLf;
	endif;
	methodName := JMTUserInterfaceService::getVoyageProcessDepot.name;
	provider.setPropertyValue("_methodName", methodName);
	if not provider.sendMsgWithParams(JMTUserInterfaceService::validateCurrentSession.name, checkUser).Boolean then
		_errors &amp;= "JMTUserInterfaceService::validateCurrentSession for Public access to " &amp; methodName &amp; " failed" &amp; CrLf;
	endif;
	methodName := JMTUserInterfaceService::getUserStateData.name;
	provider.setPropertyValue("_methodName", methodName);
	if not provider.sendMsgWithParams(JMTUserInterfaceService::validateCurrentSession.name, checkUser).Boolean then
		_errors &amp;= "JMTUserInterfaceService::validateCurrentSession for Public access to " &amp; methodName &amp; " failed" &amp; CrLf;
	endif;
	methodName := JMTUserInterfaceService::findCargoQuickView.name;
	provider.setPropertyValue("_methodName", methodName);
	if not provider.sendMsgWithParams(JMTUserInterfaceService::validateCurrentSession.name, checkUser).Boolean then
		_errors &amp;= "JMTUserInterfaceService::validateCurrentSession for Public access to " &amp; methodName &amp; " failed" &amp; CrLf;
	endif;
	methodName := JMTUserInterfaceService::findCargoByUID.name;
