    <JadeMethod name="myTerminalArea" id="71995cc3-6d44-4851-86c9-3ab43096d550">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>myTerminalArea(set: Boolean; _value: CM_TerminalArea io) mapping,updating;
// ---------------------------------------------------------------------------
// Created:     18 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	inheritMethod(set, _value);

	if (not set) then
		// Jade will return value of attribute
		return;
	endif;
	
	if _value = null then
		self.myRow		:= null;
		self.myRowArea 	:= null;
		return;
	endif;
	
	if (not _value.isKindOf(CM_RowArea)) then 
		self.myRowArea := null;
		return;
	endif;
	//----------------------
	//Set the parent reference at the same time the myTerminalArea ref is being set.
	//We do this to get an inverse to a dict on the CM_RowArea class.
	//----------------------
	self.myRowArea := _value.CM_RowArea;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_TerminalArea" usage="io"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="deb2120d-f771-43d8-8199-23e9c56ccc31">
        <source>pxyCreateUpdateProxy(): SelfType;

// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars

	proxyRowController	: CM_RowController;
	proxyRowAreaRow		: CM_RowAreaRow;
	completedOK		: Boolean;
	
begin

	proxyRowController := inheritMethod();
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyRowController;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyRowController;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
