    <JadeMethod name="populateGnrcIfaceDvc" id="6bd46b40-5fc2-4fed-adda-ade19508c9b7">
        <updating/>
        <source>populateGnrcIfaceDvc() updating;
/*

Purpose:			Populates the Generic Interface API Device dictionary

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
03 May 2022	navpw1	Initial creation TFS: 52773

*/

vars
	root 		: CM_Root;
	terminal	: CM_Terminal;
	weighBridge	: CM_WeighBridgeObj;
	scanReader	: CM_ScanReaderObj;
	
begin
	root := app.myRoot; //Get root object
	
	if not self.allGnrcIfaceDvcById.isValid then
		self.allGnrcIfaceDvcById.setMembership(CM_Object);
		self.allGnrcIfaceDvcById.addExternalKey(String, CM_WeighBridgeObj::deviceId.length-1, false, true); //WeighBridge or Scan Reader DeviceId
		self.allGnrcIfaceDvcById.addExternalKey(String, CM_Terminal::code.length-1, false, true); //Terminal Code
		self.allGnrcIfaceDvcById.addExternalKey(String, CM_WeighBridgeObj::name.length-1, false, true); //Scan Reader Code or WeighBridge Name
		self.allGnrcIfaceDvcById.endKeys(true);
		
	else
		self.allGnrcIfaceDvcById.clear();
		
	endif;

	foreach terminal in root.allTerminals do //Loop all terminals
		foreach weighBridge in terminal.allWeighBridges where weighBridge.deviceId &lt;&gt; null do //foreach weighbridge that has a deviceId
			self.allGnrcIfaceDvcById[weighBridge.deviceId, terminal.code, weighBridge.name] := weighBridge; //Add to collection
		endforeach;
		
		foreach scanReader in terminal.allScanReaders where scanReader.deviceId &lt;&gt; null do //foreach scan reader that has a deviceId
			self.allGnrcIfaceDvcById[scanReader.deviceId, terminal.code, scanReader.code] := scanReader; //Add to collection
		endforeach;
		
	endforeach;
	
	self.gnrcIfaceDvcDictNeedsRefresh := false; //Set refresh to false as we populated the dictionary already

end;</source>
    </JadeMethod>
