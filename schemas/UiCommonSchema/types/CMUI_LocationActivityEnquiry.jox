    <JadeMethod name="tblLocActivity_contextMenu" id="2a8be23e-29c0-4444-a8d2-4c11a9dbc188">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblLocActivity_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 April 2021	navndl1	Initial creation	TFS 50906

*/

vars
	
	rowIndex : Integer;
	locAct : CMEVT_LocationActivity;
	hasInvoiceLines : Boolean; // ### TFS 51219 02JUN2021 NAVAB1
					

begin

	rowIndex :=  self.tblLocActivity.row;
	if rowIndex &gt; self.tblLocActivity.fixedRows then
		locAct :=  self.tblLocActivity.accessRow( rowIndex ).itemObject.CMEVT_LocationActivity;
	endif;
	
	if locAct &lt;&gt; null and locAct.isAbleToBeEdited and app.myCurrentUserCan(self.myTerminal, self.permissionMaint ) then
		self.mnuEditLocAct.visible := true;
		self.mnuEditLocAct.userObject := locAct;
	else
		self.mnuEditLocAct.visible := false;
		self.mnuEditLocAct.userObject := null;
	endif;
	
	self.mnuColOrg.visible := true;
	
	self.mnuInspect.visible := app.isAllowedToInspect and locAct &lt;&gt; null;
	self.mnuInspect.userObject := locAct;
	
	self.mnuAudits.visible := locAct &lt;&gt; null and locAct.hasAudits;
	self.mnuAudits.userObject := locAct;
	
	if locAct &lt;&gt; null then
		hasInvoiceLines := not locAct.allInvoiceLines.isEmpty(); // ### TFS 51219 28MAY2021 NAVAB1
	endif;
	self.mnuInvoiceShow.visible := hasInvoiceLines; // ### TFS 51219 28MAY2021 NAVAB1
	self.mnuInvoiceLineShow.visible := hasInvoiceLines; // ### TFS 51219 28MAY2021 NAVAB1
	self.mnuResync.visible := true; // ### TFS 51219 28MAY2021 NAVAB1 - always show incase billing had not been set up
	
	self.popupMenu( self.mnuContext, x, y  + table.top.Integer); // ### TFS 51219 03JUN2021 NAVAB1 added ' + table.top.Integer'
	
	return false;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
