    <JadeMethod name="tblMatchesFound_contextMenu" id="37735b4c-3090-41a8-b007-6d6f136ed2bb">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblMatchesFound_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
// -------------------------------------------
// -------------------------------------------
// Created 18 May 2004 by cnwdvb1
// -------------------------------------------
vars

	x1, y1 : Real;

begin

	x1 := x;
	y1 := y;
	if not mouse then  // if keyboard, use current listIndex value
	    x1 := 1;
	    y1 := 1;
	endif;

	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   // convert x, y relative to form
	
	popupMenu(self.mnuContext, x1.Integer, y1.Integer);
	return false;


end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblMatchesFound_dblClick" id="4d3059b3-58ff-4b35-b81c-df01bc9dc6b3">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblMatchesFound_dblClick(table: Table input) updating;
// -------------------------------------------
// Created 20 May 2004 by cnwdvb1
// -------------------------------------------
vars

begin


	if table.row = table.fixedRows then
		self.doResortSelectedColumn();
		return;
	endif;

	self.goToVoyageNew();


end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblMatchesFound_rowColumnChg" id="00554d10-bd87-4ceb-84e0-f5e109343f74">
        <controlMethod name="CM_DataTable::rowColumnChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblMatchesFound_rowColumnChg(table: Table input) updating;

vars
 	currentColumn	: Integer;
 	count			: Integer;
 	selectedObject	: Object;
 	jadeRow			: JadeTableRow;
begin


	if table.row &gt; table.fixedRows then
		table.clearAllSelected();
		jadeRow := table.accessRow(table.row);
		if jadeRow &lt;&gt; null then	
			jadeRow.selected := true;
		endif;
	endif;

 	


end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="12c70fa4-7f74-403d-97c5-1763cf5ba688">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0005932, locale);
	btnExportData.translateBubbleHelp(Xlat_0001577, locale);
	btnExportData.translateCaption(Xlat_0001578, locale);
	btnFind.translateBubbleHelp(Xlat_0001594, locale);
	btnFind.translateCaption(Xlat_0001595, locale);
	btnFindAll.translateBubbleHelp(Xlat_0001590, locale);
	btnFindAll.translateCaption(Xlat_0001591, locale);
	gbDateCriteria.translateCaption(Xlat_0001601, locale);
	gbGenCriteria.translateCaption(Xlat_0001579, locale);
	lblAgent.translateCaption(Xlat_0001596, locale);
	lblAnd.translateCaption(Xlat_0001597, locale);
	lblAtAfter.translateCaption(Xlat_0001592, locale);
	lblAtBefore.translateCaption(Xlat_0001583, locale);
	lblAtBetwnA.translateCaption(Xlat_0001585, locale);
	lblAtBetwnB.translateCaption(Xlat_0001584, locale);
	lblBerth.translateCaption(Xlat_0001598, locale);
	lblPilot.translateCaption(Xlat_0001599, locale);
	lblSearch.translateCaption(Xlat_0001600, locale);
	lblSearch_1.translateCaption(Xlat_0001586, locale);
	lblShipLineCo.translateCaption(Xlat_0001580, locale);
	lblShipName.translateCaption(Xlat_0001587, locale);
	lblShipType.translateCaption(Xlat_0001588, locale);
	mnuColumnOrganiser.translateCaption(Xlat_0005933, locale);
	mnuContext.translateCaption(Xlat_0005934, locale);
	optArrvAfter.translateCaption(Xlat_0001582, locale);
	optArrvBefore.translateCaption(Xlat_0001581, locale);
	optArrvBetween.translateCaption(Xlat_0001602, locale);
	shtCriteria.translateCaption(Xlat_0001589, locale);
	shtResults.translateCaption(Xlat_0001593, locale);
end;</source>
    </JadeMethod>
