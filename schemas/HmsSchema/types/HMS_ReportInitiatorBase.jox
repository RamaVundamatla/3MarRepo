    <JadeMethod name="translateForm" id="c2073917-e877-46f0-9aa0-f784bf9043f3">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 15 August 2018 16:39:50.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0022927, locale);
	btnPrint.translateBubbleHelp(Xlat_0001562, locale);
	btnPrint.translateCaption(Xlat_0001563, locale);
	chkReportEmail.translateCaption(Xlat_0001558, locale);
	chkReportToFile.translateCaption(Xlat_0001557, locale);
	frmPrinter.translateCaption(Xlat_0001561, locale);
	lblDescription.translateCaption(Xlat_0001559, locale);
	lblFileFormat.translateCaption(Xlat_0001560, locale);
end;</source>
    </JadeMethod>
</GUIClass>
