    <JadeMethod name="setupForm" id="66105e7e-e6df-44eb-8c90-bb0248801b6a">
        <updating/>
        <source>setupForm() updating;
/*
Date		    Who			Reason
25 April 2011	cnwas3	  Initial creation: CCMS 1031
*/

vars

begin
	inheritMethod();
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;	
	self.caption:=self.myCurrentDeck.description &amp; " - " &amp; self.caption; 

	self.mnuFile.visible := false;
	self.mnuHelp.visible := false;
	self.mnuOptions.visible := false;
	self.mnuWindows.visible := false;
	self.mnuTerminal.visible := false;
	self.mnuView1.visible := false;
	
	self.setupRemarksTable();
	self.loadRemarksTable();
	
	
	self.minimumHeight := 150;
	self.minimumWidth := 500;
	self.tblRemarks.left := 2;	
	if self.frmToolbar.showCaptions then
		self.tblRemarks.top:= self.frmToolbar.top + self.frmToolbar.clientHeight + 20;
		self.tblRemarks.height := self.clientHeight - self.frmToolbar.clientHeight - 3;
	else
		self.tblRemarks.top:= self.frmToolbar.top + self.frmToolbar.clientHeight + 4;
		self.tblRemarks.height := self.clientHeight - self.frmToolbar.clientHeight + 12;
	endif;
	self.tblRemarks.width := self.width - 12;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupRemarksTable" id="67cc19b9-9d4a-4d72-ad29-8ac50b95ff70">
        <source>setupRemarksTable() protected;
/*
Date		    Who			Reason
21 April 2011	cnwas3	  Initial creation: CCMS 1031
*/

vars
	entDef : EntTableDef;
begin

	self.tblRemarks.fixedRows:=1;
	self.tblRemarks.selectMode:= Table.SelectMode_WholeRows;
	//self.tblRemarks.allowColumnSorter	:=	true;
	entDef := app.myController.getEntTableDef(ETDef_DeckItemRemarks);
	if entDef = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'EntDef ETDef_DeckItemRemarks not found');
		return;
	endif;
	
	self.tblRemarks.setTblDataEntRowsFromDef(entDef);

	
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
