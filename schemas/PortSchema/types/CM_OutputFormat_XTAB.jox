    <JadeMethod name="cloneSelf" id="fed709b2-cf50-4c60-ae8a-7560e21d74e7">
        <source>cloneSelf( _transient : Boolean ) : SelfType;
// ---------------------------------------------------------------------------
// Created:     02 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 15/12/2009	cnwcs5		1023 - snapshot summaries
// ---------------------------------------------------------------------------
vars
	clone	: SelfType;
	element	: CM_XTABGrouping;
	field	: CM_XTABField;
	
begin
	clone := inheritMethod( _transient );
	
	clone.myOutputFormat_SS := self.myOutputFormat_SS;	// cnwcs5 15/12/2009

	foreach element in self.allTabs do
		clone.allTabs.add( element.cloneSelf( _transient ) );
	endforeach;
	
	foreach element in self.allRows do
		clone.allRows.add( element.cloneSelf( _transient ) );
	endforeach;
	
	foreach element in self.allColumns do
		clone.allColumns.add( element.cloneSelf( _transient ) );
	endforeach;
	
	foreach field in self.allFields do
		clone.allFields.add( field.cloneSelf( _transient ) );
	endforeach;
	
	return clone;
epilog

end;</source>
        <Parameter name="_transient" type="Boolean"/>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="erase" id="6eccaabb-3ea5-4a12-a9d6-366c9a1ad50b">
        <updating/>
        <source>erase( _eraseLevel : Integer ) updating;

/*

Purpose:		
Parameters:		
Return Value:	

Date				Who		Reason
19 February 2009	cnwrl1	Initial creation (CCMS SFW 1047 - Totals Only Lists)

*/
	
vars
	
begin
	// cause the required user notification immediately
	self.causeEvent( EVENT_SummaryTable_Delete, false, process.userCode );
	inheritMethod( _eraseLevel );
epilog
	
end;
</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="findColumn" id="7841b578-3cb5-4133-b997-b89109c447a5">
        <source>findColumn(_propertyName :String):CM_XTABGrouping;
// ---------------------------------------------------------------------------
// Created:     01 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	col	:CM_XTABGrouping;
begin
	foreach col in self.allColumns do
		if col.propertyName = _propertyName then
			return col;
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_propertyName" type="String"/>
        <ReturnType type="CM_XTABGrouping"/>
    </JadeMethod>
    <JadeMethod name="findRow" id="2c8f0527-b901-4ca8-83c9-ddfda1307560">
        <source>findRow(_propertyName :String):CM_XTABGrouping;
// ---------------------------------------------------------------------------
// Created:     01 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	row	:CM_XTABGrouping;
begin
	foreach row in self.allRows do
		if row.propertyName = _propertyName then
			return row;
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_propertyName" type="String"/>
        <ReturnType type="CM_XTABGrouping"/>
    </JadeMethod>
