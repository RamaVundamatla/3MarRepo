    <JadeMethod name="setExtraActivityHistory" id="f75aa83f-de79-4ddb-ac9b-e38a2addfc66">
        <source>setExtraActivityHistory(_activityHistory: CM_ActivityHistoryCams input);
// -------------------------------------------
// Created 30 March 2004 by cnwdvb1
// -------------------------------------------
//18 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
vars

begin

	_activityHistory.setCamsAttributes(	self.camProtocol.code,
										self.fileName,
										self.statusString(),
										self.runDateTime,
										self.seqNumber,
										self.uniqueEmailID);
end;</source>
