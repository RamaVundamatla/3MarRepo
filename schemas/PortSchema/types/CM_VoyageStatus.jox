    <JadeMethod name="userCanSet" id="cdf81588-0298-4481-a8a5-4663c2ccefe6">
        <source>userCanSet(_terminal : CM_Terminal) : Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 21/03/2018	jlgdap1		Initial creation TFS 37445 PEL1 Voyage Status Security
// 09 Sep 2019	jlgdi1	45802 Added condition check for JMTSupport user 
vars
	user : CM_User;
	userTerm : CM_UserTerminal;
begin
	user := app.getMyUser();
	if user = null then
		return false;
	endif;
	
	// 45802
	if user.isJmtSupportUser() then 
		return false;
	endif;
	
	userTerm := user.getUserTerminal(_terminal);
	if userTerm = null then
		return false;
	endif;
	
	if userTerm.mySecurityRole = null then
		return false;
	endif;
	
	// ### JIRA 33001 03OCT2024 NAVAB1
	if self.myProcess.isAutomaticProcess
	and not app.myRoot.canDo(Mod_VoyageAutoClosure) then
		return false;
	endif;
	
	if not userTerm.mySecurityRole.allVoyageStatusesMaint.includes(self) then
		return false;
	endif;
	

	return true;

epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="usesHMSResources" id="b5808c3a-0ac1-4930-bcb6-ac2639bc20d8">
        <source>usesHMSResources() :Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 16/03/2018	jlgdap1		Initial creation TFS 37540 PEL1 Voyage Statuses Pelindo 1
// 22/03/2017	jlgdap1		TFS 37544 PEL1 Voyage Statuses InaPortNet
// 11 OCt 2021	jlier1 	TFS 51963 removed inapornet 
vars

begin
	if self.id.isOneOf(Voyage_Status_ServicesPending, Voyage_Status_DepServPending) then		// TFS 37544
		return true;
	endif;
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="9b6d962e-54f9-4b5a-8cac-69e34f77073a">
        <source>validateForCreate(_passport : CM_Passport);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 07/03/2018	jlgdap1		Initial creation TFS 37427 PEL1 Voyage Status Enhancements
//
vars

begin
	if app.myRoot.allVoyageStatuses[self.id] &lt;&gt; null then
		app.raiseCMException1(Gate_Error16, self.id.String, null, null);
	endif;
	self.validateMe;
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport"/>
