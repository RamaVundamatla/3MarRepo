    <JadeMethod name="mnuTrxPopSaveAsText_click" id="fca6aa68-54f0-49fd-ae65-785534fe0f34">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuTrxPopSaveAsText_click(menuItem: MenuItem input) updating;

vars
	errTxt, fileName : String;
	errNo : Integer;
	
begin
	fileName := self.getSaveTableAsTextFileName(self.lastSaveTrxTblFileName);
	
	if fileName = null then
		return;
	endif;

	app.mousePointer := Busy;
		
	on Exception do app.resumeNextExHandler(exception, errNo, errTxt);
	
	self.doSaveTableAsText(self.tblTrans, self.tblTrans.fixedRows, fileName);
	
	if errNo &lt;&gt; 0 or errTxt &lt;&gt; null then
		app.msgBox("Error saving file: " &amp; fileName &amp; CrLf &amp; CrLf &amp;
			'[' &amp; errNo.String &amp; "] " &amp; errTxt, "Error Saving File",
			MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
	else
		self.lastSaveTrxTblFileName := fileName;
	endif;
	
epilog
	app.mousePointer := Idle;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
