// Created:     16 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	inheritMethod();

	self.tblHdrEntry.userInputEnabled := false;
	self.tblTermHdr.userInputEnabled := false;
	
end;</source>
    </JadeMethod>
