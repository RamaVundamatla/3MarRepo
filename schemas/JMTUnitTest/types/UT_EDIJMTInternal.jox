    <JadeMethod name="tCommodityAction" id="8afe3a12-063e-4d41-ad61-0a7def516ab7">
        <source>tCommodityAction();
//
// 18 Jul 2018	jlgrs1	TFS PLI01
//
constants
	USER_DEF_NAME : String = "JMTInternalCommodity";
	CommodityCode : String = "COMD";
	Commodity01 : String = "Commodity01";
vars
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	passportObj : CM_Passport;
	commodity : CM_Commodity;
	ediText : String;
	errorMsg : String;
begin
	passportObj := app.myPassport;
	self.deleteCommodity(CommodityCode);
	commodity := self.getCommodity(CommodityCode);
	self.assertIsDeleted(commodity);
	ediText :=
'&lt;?xml version="1.0"?&gt;
&lt;JMTInternalCommodity xmlns:xsi="http://www.jademasterterminallogistics.com/JMTInternal" xsi:noNamespaceSchemaLocation="JMTInternalCommodity.xsd"&gt;
	&lt;AllCommodity&gt;
		&lt;Commodity&gt;
			&lt;shortDescription&gt;Commod&lt;/shortDescription&gt;
			&lt;bayplanPrintAs&gt;BAY&lt;/bayplanPrintAs&gt;
			&lt;hasTemp&gt;&lt;/hasTemp&gt;
			&lt;showOOWRemarks&gt;&lt;/showOOWRemarks&gt;
			&lt;colour&gt;12&lt;/colour&gt;
			&lt;requiresPower&gt;&lt;/requiresPower&gt;
			&lt;requiresMAFFields&gt;false&lt;/requiresMAFFields&gt;
			&lt;isEmpty&gt;&lt;/isEmpty&gt;
			&lt;maxTemp&gt;&lt;/maxTemp&gt;
			&lt;minTemp&gt;&lt;/minTemp&gt;
			&lt;commodityGroupCode&gt;COMM&lt;/commodityGroupCode&gt;
			&lt;specialStowCode&gt;&lt;/specialStowCode&gt;
			&lt;code&gt;'&amp;CommodityCode&amp;'&lt;/code&gt;
			&lt;isUsedForPacking&gt;true&lt;/isUsedForPacking&gt;
			&lt;description&gt;'&amp;Commodity01&amp;'&lt;/description&gt;
			&lt;id&gt;&lt;/id&gt;
			&lt;messageMode&gt;A&lt;/messageMode&gt;
		&lt;/Commodity&gt;
	&lt;/AllCommodity&gt;
&lt;/JMTInternalCommodity&gt;';

	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						errorMsg,
//						CM_EDIFile.EDI_STATUS_VERIFIED,
//						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, errorMsg);
	ediDataObj := ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						"Load Failed",
//						CM_EDIFile.EDI_STATUS_DBLOADED,
//						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	errorMsg := "DB Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 1, "incorrect number of EDI trackedItems");
	commodity := self.getCommodity(CommodityCode);
	self.assertNotNull(commodity);
	self.assertEqualMsg(commodity.colour, 12, "wrong colour");
	
	ediText :=
'&lt;?xml version="1.0"?&gt;
&lt;JMTInternalCommodity xmlns:xsi="http://www.jademasterterminallogistics.com/JMTInternal" xsi:noNamespaceSchemaLocation="JMTInternalCommodity.xsd"&gt;
	&lt;AllCommodity&gt;
		&lt;Commodity&gt;
			&lt;shortDescription&gt;Commod&lt;/shortDescription&gt;
			&lt;bayplanPrintAs&gt;BAY&lt;/bayplanPrintAs&gt;
			&lt;hasTemp&gt;&lt;/hasTemp&gt;
			&lt;showOOWRemarks&gt;&lt;/showOOWRemarks&gt;
			&lt;colour&gt;1200&lt;/colour&gt;
			&lt;requiresPower&gt;&lt;/requiresPower&gt;
			&lt;requiresMAFFields&gt;false&lt;/requiresMAFFields&gt;
			&lt;isEmpty&gt;&lt;/isEmpty&gt;
			&lt;maxTemp&gt;&lt;/maxTemp&gt;
			&lt;minTemp&gt;&lt;/minTemp&gt;
			&lt;commodityGroupCode&gt;COMM&lt;/commodityGroupCode&gt;
			&lt;specialStowCode&gt;&lt;/specialStowCode&gt;
			&lt;code&gt;'&amp;CommodityCode&amp;'&lt;/code&gt;
			&lt;isUsedForPacking&gt;true&lt;/isUsedForPacking&gt;
			&lt;description&gt;'&amp;Commodity01&amp;'&lt;/description&gt;
			&lt;id&gt;&lt;/id&gt;
			&lt;messageMode&gt;U&lt;/messageMode&gt;
		&lt;/Commodity&gt;
	&lt;/AllCommodity&gt;
&lt;/JMTInternalCommodity&gt;';

	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						errorMsg,
//						CM_EDIFile.EDI_STATUS_VERIFIED,
//						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, errorMsg);
	ediDataObj := ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						"Load Failed",
//						CM_EDIFile.EDI_STATUS_DBLOADED,
//						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	errorMsg := "DB Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 1, "incorrect number of EDI trackedItems");
	commodity := self.getCommodity(CommodityCode);
	self.assertNotNull(commodity);
	self.assertEqualMsg(commodity.colour, 1200, "wrong colour");

	ediText :=
'&lt;?xml version="1.0"?&gt;
&lt;JMTInternalCommodity xmlns:xsi="http://www.jademasterterminallogistics.com/JMTInternal" xsi:noNamespaceSchemaLocation="JMTInternalCommodity.xsd"&gt;
	&lt;AllCommodity&gt;
		&lt;Commodity&gt;
			&lt;shortDescription&gt;Commod&lt;/shortDescription&gt;
			&lt;bayplanPrintAs&gt;BAY&lt;/bayplanPrintAs&gt;
			&lt;hasTemp&gt;&lt;/hasTemp&gt;
			&lt;showOOWRemarks&gt;&lt;/showOOWRemarks&gt;
			&lt;colour&gt;1200&lt;/colour&gt;
			&lt;requiresPower&gt;&lt;/requiresPower&gt;
			&lt;requiresMAFFields&gt;false&lt;/requiresMAFFields&gt;
			&lt;isEmpty&gt;&lt;/isEmpty&gt;
			&lt;maxTemp&gt;&lt;/maxTemp&gt;
			&lt;minTemp&gt;&lt;/minTemp&gt;
			&lt;commodityGroupCode&gt;COMM&lt;/commodityGroupCode&gt;
			&lt;specialStowCode&gt;&lt;/specialStowCode&gt;
			&lt;code&gt;'&amp;CommodityCode&amp;'&lt;/code&gt;
			&lt;isUsedForPacking&gt;true&lt;/isUsedForPacking&gt;
			&lt;description&gt;'&amp;Commodity01&amp;'&lt;/description&gt;
			&lt;id&gt;&lt;/id&gt;
			&lt;messageMode&gt;D&lt;/messageMode&gt;
		&lt;/Commodity&gt;
	&lt;/AllCommodity&gt;
&lt;/JMTInternalCommodity&gt;';

	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						errorMsg,
//						CM_EDIFile.EDI_STATUS_VERIFIED,
//						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, errorMsg);
	ediDataObj := ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						"Load Failed",
//						CM_EDIFile.EDI_STATUS_DBLOADED,
//						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	errorMsg := "DB Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 1, "incorrect number of EDI trackedItems");
	commodity := self.getCommodity(CommodityCode);
	self.assertNull(commodity);
end;
</source>
