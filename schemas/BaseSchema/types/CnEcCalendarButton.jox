    <DbClassMap file="_usergui"/>
    <ExplicitInverseRef name="calendar" id="21d9f594-4667-4dc8-af4c-82f34ea10daa">
        <kind>child</kind>
        <embedded/>
        <type name="CnEcCalendar"/>
        <access>readonly</access>
        <Inverse name="CnEcCalendar::nextMonthButton"/>
        <Inverse name="CnEcCalendar::nextYearButton"/>
        <Inverse name="CnEcCalendar::prevMonthButton"/>
        <Inverse name="CnEcCalendar::prevYearButton"/>
    </ExplicitInverseRef>
    <JadeMethod name="click" id="dac7a477-e835-45dd-982a-17448e1c13b8">
        <updating/>
        <source>click(btn: CnEcCalendarButton input) updating;

vars
	dayNum		: Integer;
	monthNum	: Integer;
	yearNum		: Integer;
	
begin
	inheritMethod(btn);

	if calendar = null then		// cnwdad1 09/10/2000.
		return;					// cnwdad1 09/10/2000.
	endif;						// cnwdad1 09/10/2000.

	dayNum		:=	calendar.date.day;
	monthNum	:=	calendar.date.month;
	yearNum		:=	calendar.date.year;
	
	if btn = calendar.prevMonthButton then
		monthNum	:=	monthNum - 1;
		
		if monthNum &lt; 1 then
			monthNum	:=	12;
			yearNum		:=	yearNum - 1;
		endif;
		
		calendar.changeType	:=	calendar.ChangeType_Month;
		
	elseif btn = calendar.nextMonthButton then
		monthNum	:=	monthNum + 1;
		
		if monthNum &gt; 12 then
			monthNum	:=	1;
			yearNum		:=	yearNum + 1;
		endif;
		
		calendar.changeType	:=	calendar.ChangeType_Month;
		
	elseif btn = calendar.prevYearButton then
		yearNum				:=	yearNum - 1;
		calendar.changeType	:=	calendar.ChangeType_Year;
		
	else
		yearNum				:=	yearNum + 1;
		calendar.changeType	:=	calendar.ChangeType_Year;
	endif;
	
	if (dayNum.String &amp; "/" &amp; monthNum.String &amp; "/" &amp; yearNum.String).Date.isValid then
		calendar.date.setDate(dayNum, monthNum, yearNum);
	else
		calendar.date.setDate(1, monthNum, yearNum);
	endif;
end;</source>
        <Parameter name="btn" type="CnEcCalendarButton" usage="input"/>
    </JadeMethod>
