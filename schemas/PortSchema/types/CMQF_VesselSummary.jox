<Class name="CMQF_VesselSummary" id="818a7f22-234e-489f-9b92-fd5f621d1fad">
    <superclass name="CMQF_FilterReports"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <PrimAttribute name="reportDate" id="5b4829d7-65e9-49d8-9606-109eb8116ebf">
        <embedded/>
        <type name="Date"/>
    </PrimAttribute>
    <JadeMethod name="filterObjects" id="f2b90cfd-9c63-4d12-a3ff-228e4e79d62c">
        <updating/>
        <source>filterObjects(_collection: Collection input; _passport: CM_Passport) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30/08/2012	cnwdap1	Initial creation PAR #30146
*/
vars
	iter		: Iterator;
	iterVoy		: Iterator;
	terminal	: CM_Terminal;
	voyage		: CM_Voyage;
	runDate		: Date;
	param		: CM_QueryReportParam;

begin
	if self.reportDate &lt;&gt; null then
		runDate := self.reportDate;
	else
		runDate := app.actualTimeServer.Date;
	endif;
	create param transient;
	param.setProxy("reportDate", "Report Name", false, Date.number, runDate);
	self.allQueryReportParams.add(param);
	
	iter := self.allTerminals.createIterator();
	
	// Go through all selected terminals
	while iter.next(terminal) do
	
		// Set up starting point in voyages dict.
		delete iterVoy;
		iterVoy := terminal.allVoyagesByArrivalDTCode.createIterator;

		while iterVoy.next(voyage) do
			if voyage.departedDT.Date &lt; runDate then
				continue;
			endif;
			
			_collection.add(voyage);
		endwhile;
	endwhile;	

epilog	
	delete iterVoy;
	delete iter;
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="getOIDAndDescForAttribute" id="ff2b6235-d873-4d17-8388-be7f663fdc1a">
        <source>getOIDAndDescForAttribute(_attrName: String; _getCalculatedDate: Boolean; _oid: String output): String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 September 2012	cnwer1	Initial creation CCMS MES 1035

*/

vars
	runDate : Date;
begin
	runDate := app.actualTimeServer().Date;	// 28/4/16 cnwmp6 TFS 488 - Multi timezone support
	
	if _attrName = ETRow_ReportDate then
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.baseDateTplType, self.baseDateTplFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.baseDateTplType,self.baseDateTplFactor);
		endif;
	endif;
	
	return inheritMethod(_attrName, _getCalculatedDate, _oid);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_getCalculatedDate" type="Boolean"/>
        <Parameter name="_oid" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setFromTemplate" id="7d42cc58-4cf5-459f-8941-ab60a86ef240">
        <updating/>
        <source>setFromTemplate(_obj: CMQF_FilterReports; _runDate: Date; _allEventData: CM_EventDataByTypeDict) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 November 2017	jlgma1	TFS# 7648: DQM - Vessel Schedule Report

*/

vars

begin
	inheritMethod(_obj, _runDate, _allEventData);
	self.reportDate	:= self.setDateFromTemplate(_obj.baseDateTplType, _obj.baseDateTplFactor, _runDate);
epilog

end;</source>
        <Parameter name="_obj" type="CMQF_FilterReports"/>
        <Parameter name="_runDate" type="Date"/>
        <Parameter name="_allEventData" type="CM_EventDataByTypeDict"/>
    </JadeMethod>
</Class>
