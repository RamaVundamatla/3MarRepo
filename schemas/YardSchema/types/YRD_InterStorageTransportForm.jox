    <JadeMethod name="doSave" id="d2dd872a-bf14-4677-b2e0-9629b143f43a">
        <updating/>
        <source>doSave(): Boolean updating;
//--------------------------------------------------
// Created:	27 January 2004 By: cnwgd1
//--------------------------------------------------
vars
	istParam : CMIF_InterStorageTransport;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin

	create istParam transient;
	self.tblInputTop.setObjectFromTable(istParam, 'saveISTParamSpecial', null);
	self.getAllTrackedItemsForUpdate(istParam.allTrackedItems);
	istParam.userCode := app.getMyUserCode();
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateTICompanyOid(istParam, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Inter Storage Transport', app.myPassport, ErrWarnMode_Add);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return false;
		
	endwhile;
	
	self.tblInputTop.clearValues();
	
epilog
	delete istParam;
	return app.myPassport.trxCompletedOK();
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
