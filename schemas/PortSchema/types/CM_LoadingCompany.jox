    <JadeMethod name="setProxy" id="8ccba1d8-6b85-4282-abcc-a2a3dd269d34">
        <updating/>
        <source>setProxy(_code, _description : String; _notAvailable : Boolean;
		 _root : CM_Root; _passport : CM_Passport input) updating;
//------------------------------------------------
// Created: 06 April 2006 By: cnwgd1
//29/07/2016 cnwma1 TFS #2447:Adding duplicate gives error
//------------------------------------------------
vars

begin
	self.raiseExceptionIfNotTransient(method);
	self.code := _code.toUpper(); //29/07/2016 cnwma1 TFS #2447
	self.description := _description;
	self.isNotAvailableForEntry := _notAvailable;
	self.myRoot := _root;
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_notAvailable" type="Boolean"/>
        <Parameter name="_root" type="CM_Root"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateCreate" id="9abde758-0610-4f20-a801-be0a75488da9">
        <source>validateCreate(_passport: CM_Passport input);
//------------------------------------------------
// Created: 06 April 2006 By: cnwgd1
//29/07/2016 cnwma1 TFS #2447:Adding duplicate gives error
//------------------------------------------------
vars
	loadingCompany : CM_LoadingCompany;
begin
	/*if app.myRoot.allLoader[code] &lt;&gt; null then  //29/07/2016 cnwma1 TFS #2447
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.code, null, null);
	endif;*/
	foreach  loadingCompany in app.myRoot.allLoader do            //29/07/2016 cnwma1 TFS #2447
		if loadingCompany.code.toUpper = self.code.toUpper then
			app.raiseCMException1(VB_DUPLICATED_ITEM, self.code, null, null);
		endif;
	endforeach;

	self.validateMe(_passport);
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
