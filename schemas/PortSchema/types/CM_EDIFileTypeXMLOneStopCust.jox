    <JadeMethod name="addErrorMessEmptyTag" id="74e8e5c6-50b7-42d5-aa0b-3a45f3bc6227">
        <source>addErrorMessEmptyTag(	_parentTagSet : String; _tagSetName : String; _ediFile: CM_EDIFile input; _ediTIErrors : HugeStringArray input ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 September 2016	cnwndl1	Initial creation	TFS 2278 / 2670

*/

vars
	
	mess : String;

begin

	mess := "&lt;" &amp; _tagSetName &amp; "&gt; within &lt;" &amp; _parentTagSet &amp; "&gt; is empty.";
	if _ediTIErrors &lt;&gt; null then
		_ediTIErrors.add( mess );
	else
		self.addFileErrors( mess, 1, _ediFile);
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_parentTagSet" type="String"/>
        <Parameter name="_tagSetName" type="String"/>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_ediTIErrors" type="HugeStringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="addErrorMessNoMatchingObj" id="5d079a02-6414-4a8f-b646-86593e36170a">
        <source>addErrorMessNoMatchingObj( _objectType : String; _parentTagSet : String; _tagSetName : String; _str : String; _ediFile: CM_EDIFile input; _ediTIErrors : HugeStringArray input ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 September 2016	cnwndl1	Initial creation	TFS 2278 / 2670

*/

vars

	mess : String;

begin
	mess := "&lt;" &amp; _tagSetName &amp; "&gt; within &lt;" &amp; _parentTagSet &amp; "&gt; with a value of '" &amp; _str &amp; "' could not be resolved to a '" &amp; _objectType &amp; "' object in JMT.";
	if _ediTIErrors &lt;&gt; null then
		_ediTIErrors.add( mess );
	else
		self.addFileErrors( mess, 1, _ediFile);
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_objectType" type="String"/>
        <Parameter name="_parentTagSet" type="String"/>
        <Parameter name="_tagSetName" type="String"/>
        <Parameter name="_str" type="String"/>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_ediTIErrors" type="HugeStringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="addErrorMessTagSetMissing" id="30540611-2bd0-45cf-ab30-fa7c8de6dfe4">
        <source>addErrorMessTagSetMissing(	_parentTagSet : String; _tagSetName : String; _ediFile: CM_EDIFile input; _ediTIErrors : HugeStringArray input ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 September 2016	cnwndl1	Initial creation	TFS 2278 / 2670

*/

vars

	mess : String;

begin

	mess := "&lt;" &amp;_parentTagSet &amp; "&gt; is missing a &lt;" &amp; _tagSetName &amp; "&gt; tag set.";
	if _ediTIErrors &lt;&gt; null then
		_ediTIErrors.add( mess );
	else
		self.addFileErrors( mess, 1, _ediFile);
	endif;

epilog

end;</source>
