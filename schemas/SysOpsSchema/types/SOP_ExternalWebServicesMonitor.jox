    <JadeMethod name="mnuDelete_click" id="eef022ff-1c2e-472b-8e52-379c96683a72">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuDelete_click(menuItem: MenuItem input) updating;
/*
Purpose:			

Date		Who		Reason
30 July 2021	navab1	TFS 50669
*/

vars

	pxyActivity, ewsactOV : CM_EWSActivityOpsview;
	theReturn : Integer;
begin

	if self.tblData.row &lt;= self.tblData.fixedRows then
		return;
	endif;
	
	if isOpsView() then

		ewsactOV := self.tblData.accessRow(self.tblData.row).itemObject.CM_EWSActivityOpsview;

		pxyActivity := app.createUpdateProxy(ewsactOV).CM_EWSActivityOpsview;
		if pxyActivity &lt;&gt; null then
			pxyActivity.setProxyStatus(BGP_OpsViewWSRequest.EWS_STATUS_DELETED);
			
			
			
		while true do
			app.myTrxUA.trxUpdateEWSActivity(pxyActivity, app.myPassport);
			if app.myPassport.trxCompletedOK then
				// Clear errors/warnings from form and err/warnings window
				self.clearErrorWarnings();
				global.beep;
				break;
			else
				theReturn := app.showErrorWarningDialog("Virtual Delete", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   theReturn = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
				return;
			endif;
			break;
		endwhile;
			
		endif;
	endif;
	

epilog
	delete pxyActivity;

end;</source>
