    <JadeMethod name="getInstructionsForContext" id="73931526-fc8e-45ac-8184-eff25af5c64f">
        <source>getInstructionsForContext(_instructions   : CM_InstructionsIssuedSet io;
						  _passingObject  : Object;
						  _context		  : String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Sep 2023	navma1 ChangeRequest 60066: FR 53127 | EUP - Additional Operational Instructions on the Order (Web)

*/

vars
	bookingItem : CM_BookingRefItem;
begin
	_instructions.tryAddIfNotNull(self.myInstructions);
	
	if _passingObject &lt;&gt; null then
		_instructions.tryAddIfNotNull(_passingObject.CM_BookingRefItem.myInstructions);
	else		
		foreach bookingItem in self.allBookingRefItems do
			bookingItem.getInstructionsForContext(_instructions,_passingObject,_context);
		endforeach;
	endif;
epilog

end;
</source>
        <Parameter name="_instructions" type="CM_InstructionsIssuedSet" usage="io"/>
        <Parameter name="_passingObject" type="Object"/>
        <Parameter name="_context" type="String"/>
    </JadeMethod>
