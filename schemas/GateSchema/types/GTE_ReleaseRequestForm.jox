    <JadeMethod name="getBulkRelease" id="e7027c43-dcf2-4ead-a233-1b13c1ea21f8">
        <source>getBulkRelease():CM_BulkRelease protected;
// --------------------------------------------------------------------------------
// Created:		30 May 2007 by cnwdad1
//
// Purpose:		Returns a reference to the Bulk Release being edited.
//
// Parameters:	None
//
// Returns:		A reference to a Bulk Release object, or null.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	objectCM	: CM_Object;
	tiObj		: CM_TrackedItem;
	
begin
	objectCM	:=	self.myProxyObject;
	
	if objectCM.isKindOf(CM_BulkRelease) then
		return objectCM.CM_BulkRelease;
	else
		tiObj	:=	self.myProxyObject.CM_TrackedItem;
	endif;
	
	if tiObj = null then
		return null;
	else
		return tiObj.allBulkReleasesAssigned.first();
	endif;
end;</source>
        <access>protected</access>
        <ReturnType type="CM_BulkRelease"/>
    </JadeMethod>
    <JadeMethod name="getCSVFileName" id="ea6bf87e-d34f-464b-bde8-b770ca5d78ff">
        <source>getCSVFileName() protected;
/*
----------   ----------  --------------------------------------------------
Created:	07 February 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	fileCSV		 		: CMDFileSave;
	
begin

	create fileCSV transient;
	if fileCSV.open = 0 then
		self.txtFileName.text := fileCSV.fileName;
	endif;

epilog
	delete fileCSV;	
end;

</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getCurrentBulkRelease" id="5c8f80f9-e9ad-4831-8c98-e932b143a174">
        <source>getCurrentBulkRelease(): CM_BulkRelease;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 July 2011	cnwrd1	Initial creation

*/

vars
	obj : Object;
	theBR : CM_BulkRelease;
begin
	
	/*if self.tblData.allSelectedObjects.size &gt; 1 then
		//only for 1 release for now
		return;
	endif;

	obj :=  self.tblData.allSelectedObjects.first.CM_Object;
	*/
	
	obj := self.myCurrentObject;
	
	if CM_BulkRelease.hasInstance(obj) then
			theBR := obj.CM_BulkRelease;
	elseif CM_ReserveDetail.hasInstance(obj) then
		theBR := obj.CM_ReserveDetail.myReserveHeader;
	endif;
	
	return theBR;

epilog

end;</source>
        <ReturnType type="CM_BulkRelease"/>
