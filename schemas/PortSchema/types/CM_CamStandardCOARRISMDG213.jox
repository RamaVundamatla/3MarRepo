    <JadeMethod name="outputHeader_UNB" id="7789c7f8-91e7-4316-8c5c-680eaa4794c0">
        <updating/>
        <source>outputHeader_UNB(_protocol: CM_CamProtocol; _camTaskHistory: CM_CamTaskHistory input; _seqNumber: Integer; _coll: HugeStringArray input): String updating, protected;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 10 April 2019
TFS#		: 44294
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

begin
	return self.outputFileMessage (_camTaskHistory, 
									self.makeUNBSegment (_protocol, "UNOA", 2, self.getSenderCode_UNB (_protocol), null, 
									_protocol.camGroup.recipient.trimBlanks, null, _seqNumber, null, false, _camTaskHistory.runDateTime),
									_coll);	
end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_seqNumber" type="Integer"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
