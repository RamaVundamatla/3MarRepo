    <JadeMethod name="tCamCodecoECNMOT_PackComplete" id="b61162d6-6a5c-4d15-aaa3-6e8bb27a76fa">
        <source>tCamCodecoECNMOT_PackComplete();
// cnwrs1
// par 27653
//30 Jan 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
//17/06/2016    cnwma1  TFS# 2159:CPL - Wrong Header for CODECO D.95B
constants
	VoyageName		= 'VYPAR27653';				// all upper case!
	BoatName		= 'VSPAR27653';
	ContainerName	= 'PARC1230001';
	TestOperator	= 'UTOP';
//	BlockStackName	= 'BS27653';
	CamGroup = "P27653";
	CamProtocol = "PAR27653";
vars
	runDateTime : TimeStamp;
	lRegisteredCargoTypes : IntegerArray;
	tempStr	: String;
	idx : Integer;
	container : CM_Container;
	operator : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	passport : CM_Passport;
//	bs : CM_BlockStack;
	terminal : CM_Terminal;
	startDateTime : TimeStamp;
	endDateTime : TimeStamp;
	camGroup : CM_CamGroup;
	camProtocol : CM_CamProtocol;
	camTaskHistory : CM_CamTaskHistory;
	operatorDict : CM_OperatorByCodeDict;
	emailEntity : CM_EmailEntity;
	camProtocolDesc : CM_CamProtocolDesc;
	registeredTransactions : StringArray;
	scheduleTimes : TimeArray;
	freightForwarders : CM_ConsigneeConsignorSet;
	allCoarriExportPorts : CM_PortByCodeDict;
	emailCopyAddresses : CM_EmailEntityByTypeNameDict;
	packOperators : CM_OperatorByCodeDict;
	packExportConsignees : CM_ConsignByCodeDict;
	camEditTriggerFields : CM_CamEditTriggerFieldDict;
	camTrainEventTypes : CM_EventTypeByNameDict;
	allPackAreas : CM_TAByIdDict;
//	time : Time;
	objArray : CM_ObjectArray;	//transaction are added to this array and this array is purged at the end to ensure the transactions dont affect other unit tests
	transObj : CM_TITransaction;
	strArray : StringArray;
	str : String;
	theLines : HugeStringArray;
begin
	create theLines transient;
	startDateTime := app.actualTimeServer;
	passport := app.myPassport;
	operator := self.getOperator(TestOperator);
	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; TestOperator.display);
	create objArray transient;
	
	// delete required voyages and vessels
	self.deleteVoyage(VoyageName);
	voyage := self.getVoyage(VoyageName);
	self.assertIsDeleted(voyage);
	
	self.deleteVessel(BoatName);
	vessel := self.getVessel(BoatName);
	self.assertIsDeleted(vessel);
	
	// delete the cargo - this should have already been done if on the voyage, but just in case.
	self.deleteContainer(ContainerName);
	container := self.getTrackedItem(ContainerName).CM_Container;
	self.assertIsDeleted(container);
	
//	self.deleteTerminalArea(BlockStackName);
//	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
//	self.assertIsDeleted(bs);

	// Now create the required voyages and vessels
	vessel := self.addVesselCellular(BoatName, operator);
	self.assertNotNullMsg(vessel, 'Add vessel ' &amp; BoatName.display &amp; ' failed');
	
	voyage := self.addVoyageNonPlannedNonWorked(VoyageName,
													BoatName,
													TestOperator, 
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage ' &amp; VoyageName &amp; ' failed');

	// Add the container to the voyage
	container := self.addContainerForExport(ContainerName,
										operator,
										"2200",					// ISOType is not needed
										"GENL",					// commodity is not needed
										TI_IMEX_STATUS_EXPORT,	// import not export
										"PAR27653",					// booking id
										voyage.code,
										null,					// dischargePort
										null).CM_Container;			// transhipToPort
	tempStr	:= 'Adding Container ' &amp; ContainerName.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container, tempStr);
	self.assertNotNull(voyage.myShipBlockStack);
	self.move(container, voyage.myShipBlockStack);
	transObj := self.createTransaction(container, global.getTiTxnTypeForClass(CM_PackComplete), null);
	objArray.add(transObj);
	self.deleteCamProtocol(CamProtocol);
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	create operatorDict transient;
	create freightForwarders transient;
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, "REP", "UT", "NZCHC", "FAC", false, false, false, operatorDict, freightForwarders, 16, "SHIP");
	self.assertNotNull(camGroup);
	
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);
	create allCoarriExportPorts transient;
	create emailCopyAddresses transient;
	create packOperators transient;
	create packExportConsignees transient;
	create registeredTransactions transient;
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_PackComplete).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTermReceiveDepotRail).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTermReceiveDepotRoad).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTermReleaseDepotIntern).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTermReleaseDepotRail).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTermReleaseDepotRoad).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTerminalReceiveDepot).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTerminalReleaseDepot).asStringJMT);
	create scheduleTimes transient;
	create camEditTriggerFields transient;
	create camTrainEventTypes transient;
	create allPackAreas transient;
	create lRegisteredCargoTypes transient;
	lRegisteredCargoTypes.add(TI_CargoType_Container);
	camProtocolDesc := app.myRoot.allCamProtocolDescs["MOT-ECN CODECO"];
	emailEntity := app.myRoot.allEmailEntities[1, "Mr. Testing"];
	camProtocol := self.addCamProtocol(CamProtocol, CamProtocol, allCoarriExportPorts, camGroup, "NZCHC", emailEntity, false, emailCopyAddresses, false, "CamMessage", "CamSubject",
	                                   startDateTime, startDateTime, false, null, "txt", TestOperator, packOperators, packExportConsignees, '', camProtocolDesc, registeredTransactions,
									   false, 1, false, scheduleTimes, false, false, false, false, false, false, false, false, false, false, false, false, 
									   false, false, false, false, false, false, false, false, false, false, false, false, 
									   0, 0, 0, 0, '', '', '', camEditTriggerFields, camTrainEventTypes, null, false, 0, self.getTerminal, true, true, false, true, false, false, false, false, true, 
									   allPackAreas, null, null, lRegisteredCargoTypes);
	tempStr	:= 'Add failed ' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString();
	self.assertNotNullMsg(camProtocol, tempStr);
	self.assertNotNull(camProtocol);

	endDateTime := startDateTime.addMinutes(1);
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);

	create strArray transient;
	strArray.add("UNA:+.? '");
	strArray.add("UNB+UNOA:2+");
	//strArray.add("UNH+1+CODECO:D:95B:UN:ITG12'");     //17/06/2016 cnwma1  TFS#2159
	strArray.add("UNH+1+CODECO:D:95B:UN:SMDG16'");	 //17/06/2016 cnwma1  TFS#2159
	strArray.add("BGM+34+1+9'");
	strArray.add("TDT+20+VYPAR27653+1++UTOP:172:20+++:146::VSPAR27653'");
	strArray.add("LOC+9+NZPOE:139:6'");
	strArray.add("NAD+CF+UTOP:160:20'");
	strArray.add("NAD+MS+NZCHC:160:87'");
	strArray.add("GID+1'");
	strArray.add("FTX+AAA+++General'");
	strArray.add("PIA+5+GENL:ZZZ'");
	strArray.add("SGP+PARC1230001'");
	strArray.add("EQD+CN+PARC1230001+2200:102:5++2+5'");
	strArray.add("RFF+BN:PAR27653'");
	strArray.add("DTM+7:");
	strArray.add("LOC+165+NZPOE:160:20'");
	strArray.add("MEA+AAE+G+KGM:4000'");
	strArray.add("TDT+1'");
	strArray.add("LOC+7+NZPOE:139:6'");
	strArray.add("NAD+CF+SHIP:172:20'");
	strArray.add("CNT+16:1'");
	strArray.add("UNT+20+1'");
	strArray.add("UNZ+1+0'");
	theLines.clear();
	camTaskHistory.rawDataToHSA(theLines);
	foreach tempStr in theLines do
		idx := idx + 1;
		str := strArray[idx];
		self.assertEqual(tempStr[1:str.length], str);
	endforeach;
	beginTransaction;
	objArray.purge;
	commitTransaction;
epilog
	delete operatorDict;
	delete freightForwarders;
	delete allCoarriExportPorts;
	delete emailCopyAddresses;
	delete packOperators;
	delete packExportConsignees;
	delete registeredTransactions;
	delete scheduleTimes;
	delete camEditTriggerFields;
	delete camTrainEventTypes;
	delete allPackAreas;
	delete objArray;
	delete strArray;
	delete lRegisteredCargoTypes;
	delete theLines;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCamCodecoLockTest" id="5fac5529-db9b-462c-aeab-e1d540a682d3">
        <source>tCamCodecoLockTest();
//
// cnwrs1 [par 30142]
// Test that locking a conatiner stop cams from running
// work in progress
constants
	VoyageName		= 'VYPAR30142';				// all upper case!
	BoatName		= 'VSPAR30142';
	ContainerName1	= 'PARC1301421';
	ContainerName2	= 'PARC1301422';
	TestOperator	= 'MSL';
	BlockStackName	= 'BS30142';
	CamGroup = "P30142";
	CamProtocol1 = "PAR301421";
	CamProtocol2 = "PAR301422";
vars
	lRegisteredCargoTypes : IntegerArray;
	tempStr	: String;
	idx : Integer;
	container1 : CM_Container;
	container2 : CM_Container;
	operator : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	passport : CM_Passport;
	bs : CM_BlockStack;
	terminal : CM_Terminal;
	startDateTime : TimeStamp;
	endDateTime : TimeStamp;
	camGroup : CM_CamGroup;
	camProtocol1 : CM_CamProtocol;
	camProtocol2 : CM_CamProtocol;
	camTaskHistory1 : CM_CamTaskHistory;
	camTaskHistory2 : CM_CamTaskHistory;
	operatorDict : CM_OperatorByCodeDict;
	emailEntity : CM_EmailEntity;
	camProtocolDesc : CM_CamProtocolDesc;
	registeredTransactions : StringArray;
	scheduleTimes : TimeArray;
	freightForwarders : CM_ConsigneeConsignorSet;
	allCoarriExportPorts : CM_PortByCodeDict;
	emailCopyAddresses : CM_EmailEntityByTypeNameDict;
	packOperators : CM_OperatorByCodeDict;
	packExportConsignees : CM_ConsignByCodeDict;
	camEditTriggerFields : CM_CamEditTriggerFieldDict;
	camTrainEventTypes : CM_EventTypeByNameDict;
	allPackAreas : CM_TAByIdDict;
	transObj : CM_TITransaction;
	aTime : Time;
begin
	startDateTime := app.actualTimeServer;
	passport := app.myPassport;
	operator := self.getOperator(TestOperator);
	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; TestOperator.display);
	
	// delete required voyages and vessels
	self.deleteVoyage(VoyageName);
	voyage := self.getVoyage(VoyageName);
	self.assertIsDeleted(voyage);
	
	self.deleteVessel(BoatName);
	vessel := self.getVessel(BoatName);
	self.assertIsDeleted(vessel);
	
	// delete the cargo - this should have already been done if on the voyage, but just in case.
	self.deleteContainer(ContainerName1);
	container1 := self.getTrackedItem(ContainerName1).CM_Container;
	self.assertIsDeleted(container1);
	self.deleteContainer(ContainerName2);
	container2 := self.getTrackedItem(ContainerName2).CM_Container;
	self.assertIsDeleted(container2);
	
	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);

	// Now create the required voyages and vessels
	vessel := self.addVesselCellular(BoatName, operator);
	self.assertNotNullMsg(vessel, 'Add vessel ' &amp; BoatName.display &amp; ' failed');
	
	voyage := self.addVoyageNonPlannedNonWorked(VoyageName,
													BoatName,
													TestOperator, 
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage ' &amp; VoyageName &amp; ' failed');

	// Create and add the container1 to the voyage
	container1 := self.addContainerForExport(ContainerName1,
										operator,
										"2232",					// ISOType is not needed
										"REEF",					// commodity is not needed
										TI_IMEX_STATUS_EXPORT,	// import not export
										null,					// booking id
										voyage.code,
										null,					// dischargePort
										null).CM_Container;			// transhipToPort
	beginTransaction;
	container1.setTemperature(-21.1);
	commitTransaction;
	tempStr	:= 'Adding Container ' &amp; ContainerName1.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container1, tempStr);
	self.assertNotNull(voyage.myShipBlockStack);
	self.move(container1, voyage.myShipBlockStack);
	
	// Create and add the container2 to the voyage
	container2 := self.addContainerForExport(ContainerName2,
										operator,
										"2232",					// ISOType is not needed
										"REEF",					// commodity is not needed
										TI_IMEX_STATUS_EXPORT,	// import not export
										null,					// booking id
										voyage.code,
										null,					// dischargePort
										null).CM_Container;			// transhipToPort
	beginTransaction;
	container2.setTemperature(-21.2);
	commitTransaction;
	tempStr	:= 'Adding Container ' &amp; ContainerName2.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container2, tempStr);
	self.assertNotNull(voyage.myShipBlockStack);
	self.move(container2, voyage.myShipBlockStack);

	// delete and create cams group and protocols
	self.deleteCamProtocol(CamProtocol1);
	camProtocol1 := self.getCamProtocol(CamProtocol1);
	self.assertIsDeleted(camProtocol1);
	self.deleteCamProtocol(CamProtocol2);
	camProtocol2 := self.getCamProtocol(CamProtocol2);
	self.assertIsDeleted(camProtocol2);
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	create operatorDict transient;
	create freightForwarders transient;
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, "REP", "UT", "NZCHC", "FAC", false, false, false, operatorDict, freightForwarders, 16, "SHIP");
	self.assertNotNull(camGroup);
	
	create allCoarriExportPorts transient;
	create emailCopyAddresses transient;
	create packOperators transient;
	create packExportConsignees transient;
	create registeredTransactions transient;
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReceiveRoad).asStringJMT);
	create scheduleTimes transient;
	aTime := startDateTime.addMinutes(1).time;
	create camEditTriggerFields transient;
	create camTrainEventTypes transient;
	create allPackAreas transient;
	create lRegisteredCargoTypes transient;
	lRegisteredCargoTypes.add(TI_CargoType_Container);
	camProtocolDesc := app.myRoot.allCamProtocolDescs["UN/EDIFACT Codeco"];
	emailEntity := app.myRoot.allEmailEntities[1, "Mr. Testing"];
	//create first camProtocol
	camProtocol1 := self.addCamProtocol(CamProtocol1, CamProtocol1, allCoarriExportPorts, camGroup, "NZCHC", emailEntity, false, emailCopyAddresses, false, "CamMessage", "CamSubject",
	                                   startDateTime, startDateTime, false, null, "txt", TestOperator, packOperators, packExportConsignees, '', camProtocolDesc, registeredTransactions,
									   false, 1, false, scheduleTimes, false, false, false, false, false, false, false, false, false, false, false, false, 
									   false, false, false, false, false, false, false, false, false, false, false, false, 
									   0, 0, 0, 0, '', '', '', camEditTriggerFields, camTrainEventTypes, null, false, 0, self.getTerminal, true, true, false, false, false, false, false, false, true, 
									   allPackAreas, null, null, lRegisteredCargoTypes);
	tempStr	:= 'Add failed ' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString();
	self.assertNotNullMsg(camProtocol1, tempStr);
	self.assertNotNull(camProtocol1);
	endDateTime := startDateTime.addMinutes(1);
//	beginTransaction;
//	camProtocol1.setPropertyValue(CM_CamProtocol::specialField9.name, false);
//	commitTransaction;
	// create second cam protocol
	camProtocol1 := self.addCamProtocol(CamProtocol2, CamProtocol2, allCoarriExportPorts, camGroup, "NZCHC", emailEntity, false, emailCopyAddresses, false, "CamMessage", "CamSubject",
	                                   startDateTime, startDateTime, false, null, "txt", TestOperator, packOperators, packExportConsignees, '', camProtocolDesc, registeredTransactions,
									   false, 1, false, scheduleTimes, false, false, false, false, false, false, false, false, false, false, false, false, 
									   false, false, false, false, false, false, false, false, false, false, false, false,
									   0, 0, 0, 0, '', '', '', camEditTriggerFields, camTrainEventTypes, null, false, CAM_IDLESTATUS, self.getTerminal, true, true, false, false, false, false, false, false, true, 
									   allPackAreas, null, null, lRegisteredCargoTypes);
	tempStr	:= 'Add failed ' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString();
	self.assertNotNullMsg(camProtocol1, tempStr);
	self.assertNotNull(camProtocol1);
//	endDateTime := endDateTime.addMinutes(1);
//	beginTransaction;
//	camProtocol1.setPropertyValue(CM_CamProtocol::specialField9.name, false);
//	commitTransaction;

	// lock container1 and run cams a couple of times
	self.runCamsRequest();
	self.runCamsRequest();
	
	// now check the output
	camTaskHistory1 := camProtocol1.taskHistoryByProtocolSeq.last;

	idx := 0;
	
	//now unlock the container and run cams again and check the output
epilog
	delete operatorDict;
	delete freightForwarders;
	delete allCoarriExportPorts;
	delete emailCopyAddresses;
	delete packOperators;
	delete packExportConsignees;
	delete registeredTransactions;
	delete scheduleTimes;
	delete camEditTriggerFields;
	delete camTrainEventTypes;
	delete allPackAreas;
	delete lRegisteredCargoTypes;
end;

</source>
    </JadeMethod>
    <JadeMethod name="tCamCodecoMSC_PackComplete" id="44f2a7f6-5d25-40ea-ba74-5674cf2b0020">
        <source>tCamCodecoMSC_PackComplete();
// cnwrs1
// par 30360
// 09/08/2013	cnwcs5	par 32148 - check times are not equal
//30 Jan 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
//17/06/2016    cnwma1  TFS# 2159:CPL - Wrong Header for CODECO D.95B
constants
	VoyageName		= 'VYPAR30360';				// all upper case!
	BoatName		= 'VSPAR30360';
	ContainerName	= 'PARC1230001';
	TestOperator	= 'UTOP';
	BlockStackName	= 'BS30360';
	CamGroup = "P30360";
	CamProtocol = "PAR30360";
vars
	runDateTime : TimeStamp;
	lRegisteredCargoTypes : IntegerArray;
	tempStr	: String;
	idx : Integer;
	container : CM_Container;
	operator : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	passport : CM_Passport;
	bs : CM_BlockStack;
	terminal : CM_Terminal;
	startDateTime : TimeStamp;
	endDateTime : TimeStamp;
	camGroup : CM_CamGroup;
	camProtocol : CM_CamProtocol;
	camTaskHistory : CM_CamTaskHistory;
	operatorDict : CM_OperatorByCodeDict;
	emailEntity : CM_EmailEntity;
	camProtocolDesc : CM_CamProtocolDesc;
	registeredTransactions : StringArray;
	scheduleTimes : TimeArray;
	freightForwarders : CM_ConsigneeConsignorSet;
	allCoarriExportPorts : CM_PortByCodeDict;
	emailCopyAddresses : CM_EmailEntityByTypeNameDict;
	packOperators : CM_OperatorByCodeDict;
	packExportConsignees : CM_ConsignByCodeDict;
	camEditTriggerFields : CM_CamEditTriggerFieldDict;
	camTrainEventTypes : CM_EventTypeByNameDict;
	allPackAreas : CM_TAByIdDict;
//	time : Time;
	transObj : CM_TITransaction;
	time1 : String;
	time2 : String;
	strArray : StringArray;
	str : String;
	theLines : HugeStringArray;
begin
	create theLines transient;
	startDateTime := app.actualTimeServer;
	passport := app.myPassport;
	operator := self.getOperator(TestOperator);
	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; TestOperator.display);
	
	// delete required voyages and vessels
	self.deleteVoyage(VoyageName);
	voyage := self.getVoyage(VoyageName);
	self.assertIsDeleted(voyage);
	
	self.deleteVessel(BoatName);
	vessel := self.getVessel(BoatName);
	self.assertIsDeleted(vessel);
	
	// delete the cargo - this should have already been done if on the voyage, but just in case.
	self.deleteContainer(ContainerName);
	container := self.getTrackedItem(ContainerName).CM_Container;
	self.assertIsDeleted(container);
	
	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);

	// Now create the required voyages and vessels
	vessel := self.addVesselCellular(BoatName, operator);
	self.assertNotNullMsg(vessel, 'Add vessel ' &amp; BoatName.display &amp; ' failed');
	
	voyage := self.addVoyageNonPlannedNonWorked(VoyageName,
													BoatName,
													TestOperator, 
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage ' &amp; VoyageName &amp; ' failed');

	// Add the container to the voyage
	container := self.addContainerForExport(ContainerName,
										operator,
										"2200",					// ISOType is not needed
										"GENL",					// commodity is not needed
										TI_IMEX_STATUS_EXPORT,	// import not export
										"PAR30360",					// booking id
										voyage.code,
										null,					// dischargePort
										null).CM_Container;			// transhipToPort
	tempStr	:= 'Adding Container ' &amp; ContainerName.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container, tempStr);
	self.assertNotNull(voyage.myShipBlockStack);
	self.move(container, voyage.myShipBlockStack);
	transObj := self.createTransaction(container, global.getTiTxnTypeForClass(CM_PackComplete), null);
	self.deleteCamProtocol(CamProtocol);
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	create operatorDict transient;
	create freightForwarders transient;
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, "REP", "UT", "NZCHC", "FAC", false, false, false, operatorDict, freightForwarders, 16, "SHIP");
	self.assertNotNull(camGroup);
	
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);
	create allCoarriExportPorts transient;
	create emailCopyAddresses transient;
	create packOperators transient;
	create packExportConsignees transient;
	create registeredTransactions transient;
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_PackComplete).asStringJMT);
	create scheduleTimes transient;
	create camEditTriggerFields transient;
	create camTrainEventTypes transient;
	create allPackAreas transient;
	create lRegisteredCargoTypes transient;
	lRegisteredCargoTypes.add(TI_CargoType_Container);
	camProtocolDesc := app.myRoot.allCamProtocolDescs["MSC Codeco"];
	emailEntity := app.myRoot.allEmailEntities[1, "Mr. Testing"];
	self.opts.purge();
	self.opts.addAssoc("DelayMins", 20);
	camProtocol := self.addCamProtocol(CamProtocol, CamProtocol, allCoarriExportPorts, camGroup, "NZCHC", emailEntity, false, emailCopyAddresses, false, "CamMessage", "CamSubject",
	                                   startDateTime, startDateTime, false, null, "txt", TestOperator, packOperators, packExportConsignees, '', camProtocolDesc, registeredTransactions,
									   false, 1, false, scheduleTimes, false, false, false, false, false, false, false, false, false, false, false, false, 
									   false, false, false, false, false, false, false, false, false, false, false, false, 
									   0, 0, 0, 0, '', '', '', camEditTriggerFields, camTrainEventTypes, null, false, 0, self.getTerminal, true, true, false, true, true, false, false, false, true, 
									   allPackAreas, null, null, lRegisteredCargoTypes);
	tempStr	:= 'Add failed ' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString();
	self.assertNotNullMsg(camProtocol, tempStr);
	self.assertNotNull(camProtocol);

	endDateTime := startDateTime.addMinutes(1);
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);
	camTaskHistory.rawDataToHSA(theLines);
	
	create strArray transient;
	strArray.add("UNB+UNOA:2+");
	//strArray.add("UNH+1+CODECO:D:95B:UN:ITG12'");     //17/06/2016 cnwma1  TFS#2159
	strArray.add("UNH+1+CODECO:D:95B:UN:SMDG16'");	 //17/06/2016 cnwma1  TFS#2159
	strArray.add("BGM+34+1+9'");
	strArray.add("TDT+20+VYPAR30360+1+++++:146::VSPAR30360'");
	strArray.add("LOC+9+NZPOE:139:6'");
	strArray.add("NAD+CF+SHIP:160:20'");
	strArray.add("NAD+MS+NZCHC:160:87'");
	strArray.add("EQD+CN+PARC1230001+2200:102:5++2+5'");
	strArray.add("RFF+BN:PAR30360'");
	strArray.add("DTM+7:");
	strArray.add("LOC+165+NZPOE:160:20'");
	strArray.add("MEA+AAE+G+KGM:4000'");
	strArray.add("CNT+16:1'");
	strArray.add("UNT+13+1'");
	//strArray.add("UNH+2+CODECO:D:95B:UN:ITG12'");     //17/06/2016 cnwma1  TFS#2159
	strArray.add("UNH+2+CODECO:D:95B:UN:SMDG16'");	 //17/06/2016 cnwma1  TFS#2159	
	strArray.add("BGM+36+2+9'");
	strArray.add("TDT+20+VYPAR30360+1+++++:146::VSPAR30360'");
	strArray.add("LOC+11+NZPOE:139:6'");
	strArray.add("NAD+CF+SHIP:160:20'");
	strArray.add("NAD+MS+NZCHC:160:87'");
	strArray.add("EQD+CN+PARC1230001+2200:102:5+++4'");
	strArray.add("RFF+BN:PAR30360'");
	strArray.add("DTM+7:");
	strArray.add("LOC+165+NZPOE:160:20'");
	strArray.add("MEA+AAE+G+KGM:4000'");
	strArray.add("CNT+16:1'");
	strArray.add("UNT+13+2'");
	strArray.add("UNZ+2+0'");
	theLines.clear();
	camTaskHistory.rawDataToHSA(theLines);
	foreach tempStr in theLines do
		idx := idx + 1;
		str := strArray[idx];
		self.assertEqual(tempStr[1:str.length], str);
		if idx = 10 then
			time1 := tempStr[7:12];
		elseif idx = 23 then
			time2 := tempStr[7:12];
		endif;
	endforeach;
	if time1 &lt;= time2 then
		self.assertEqual(null, "the gate out Full must be before the gate in MT");
	endif;
epilog
	delete operatorDict;
	delete freightForwarders;
	delete allCoarriExportPorts;
	delete emailCopyAddresses;
	delete packOperators;
	delete packExportConsignees;
	delete registeredTransactions;
	delete scheduleTimes;
	delete camEditTriggerFields;
	delete camTrainEventTypes;
	delete allPackAreas;
	delete strArray;
	delete lRegisteredCargoTypes;
	delete theLines;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCamCodecoMSC_UnpackComplete" id="32a6eab8-614e-414e-98b7-b635d910de08">
        <source>tCamCodecoMSC_UnpackComplete();
// cnwrs1
// par 30360
// 09/08/2013	cnwcs5	par 32148 - check times are not equal 
//30 Jan 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
constants
	VoyageName		= 'VYPAR30360';				// all upper case!
	BoatName		= 'VSPAR30360';
	ContainerName	= 'PARC1230001';
	TestOperator	= 'UTOP';
	BlockStackName	= 'BS30360';
	CamGroup = "P30360";
	CamProtocol = "PAR30360";
vars
	runDateTime : TimeStamp;
	lRegisteredCargoTypes : IntegerArray;
	tempStr	: String;
	idx : Integer;
	container : CM_Container;
	operator : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	passport : CM_Passport;
	bs : CM_BlockStack;
	terminal : CM_Terminal;
	startDateTime : TimeStamp;
	endDateTime : TimeStamp;
	camGroup : CM_CamGroup;
	camProtocol : CM_CamProtocol;
	camTaskHistory : CM_CamTaskHistory;
	operatorDict : CM_OperatorByCodeDict;
	emailEntity : CM_EmailEntity;
	camProtocolDesc : CM_CamProtocolDesc;
	registeredTransactions : StringArray;
	scheduleTimes : TimeArray;
	freightForwarders : CM_ConsigneeConsignorSet;
	allCoarriExportPorts : CM_PortByCodeDict;
	emailCopyAddresses : CM_EmailEntityByTypeNameDict;
	packOperators : CM_OperatorByCodeDict;
	packExportConsignees : CM_ConsignByCodeDict;
	camEditTriggerFields : CM_CamEditTriggerFieldDict;
	camTrainEventTypes : CM_EventTypeByNameDict;
	allPackAreas : CM_TAByIdDict;
//	time : Time;
	transObj : CM_TITransaction;
	time1 : String;
	time2 : String;
	strArray : StringArray;
	str : String;
	theLines : HugeStringArray;
begin
	create theLines transient;
	startDateTime := app.actualTimeServer;
	passport := app.myPassport;
	operator := self.getOperator(TestOperator);
	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; TestOperator.display);
	
	// delete required voyages and vessels
	self.deleteVoyage(VoyageName);
	voyage := self.getVoyage(VoyageName);
	self.assertIsDeleted(voyage);
	
	self.deleteVessel(BoatName);
	vessel := self.getVessel(BoatName);
	self.assertIsDeleted(vessel);
	
	// delete the cargo - this should have already been done if on the voyage, but just in case.
	self.deleteContainer(ContainerName);
	container := self.getTrackedItem(ContainerName).CM_Container;
	self.assertIsDeleted(container);
	
	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);

	// Now create the required voyages and vessels
	vessel := self.addVesselCellular(BoatName, operator);
	self.assertNotNullMsg(vessel, 'Add vessel ' &amp; BoatName.display &amp; ' failed');
	
	voyage := self.addVoyageNonPlannedNonWorked(VoyageName,
													BoatName,
													TestOperator, 
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage ' &amp; VoyageName &amp; ' failed');

	// Add the container to the voyage
	container := self.addContainerForExport(ContainerName,
										operator,
										"2200",					// ISOType is not needed
										"MT",					// commodity is not needed
										TI_IMEX_STATUS_STORAGE,	// import not export
										"PAR30360",					// booking id
										voyage.code,
										null,					// dischargePort
										null).CM_Container;			// transhipToPort
	tempStr	:= 'Adding Container ' &amp; ContainerName.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container, tempStr);
	self.assertNotNull(voyage.myShipBlockStack);
	self.move(container, voyage.myShipBlockStack);
	transObj := self.createTransaction(container, global.getTiTxnTypeForClass(CM_UnpackComplete), null);
	self.deleteCamProtocol(CamProtocol);
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	create operatorDict transient;
	create freightForwarders transient;
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, "REP", "UT", "NZCHC", "FAC", false, false, false, operatorDict, freightForwarders, 16, "SHIP");
	self.assertNotNull(camGroup);
	
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);
	create allCoarriExportPorts transient;
	create emailCopyAddresses transient;
	create packOperators transient;
	create packExportConsignees transient;
	create registeredTransactions transient;
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_UnpackComplete).asStringJMT);
	create scheduleTimes transient;
	create camEditTriggerFields transient;
	create camTrainEventTypes transient;
	create allPackAreas transient;
	create lRegisteredCargoTypes transient;
	lRegisteredCargoTypes.add(TI_CargoType_Container);
	camProtocolDesc := app.myRoot.allCamProtocolDescs["MSC Codeco"];
	emailEntity := app.myRoot.allEmailEntities[1, "Mr. Testing"];
	camProtocol := self.addCamProtocol(CamProtocol, CamProtocol, allCoarriExportPorts, camGroup, "NZCHC", emailEntity, false, emailCopyAddresses, false, "CamMessage", "CamSubject",
	                                   startDateTime, startDateTime, false, null, "txt", TestOperator, packOperators, packExportConsignees, '', camProtocolDesc, registeredTransactions,
									   false, 1, false, scheduleTimes, false, false, false, false, false, false, false, false, false, false, false, false, 
									   false, false, false, false, false, false, false, false, false, false, false, false, 
									   0, 0, 0, 0, '', '', '', camEditTriggerFields, camTrainEventTypes, null, false, 0, self.getTerminal, true, true, false, false, false, true, true, false, true, 
									   allPackAreas, null, null, lRegisteredCargoTypes);
	tempStr	:= 'Add failed ' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString();
	self.assertNotNullMsg(camProtocol, tempStr);
	self.assertNotNull(camProtocol);

	endDateTime := startDateTime.addMinutes(1);
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);

	create strArray transient;
	strArray.add("UNB+UNOA:2+");
	strArray.add("UNH+1+CODECO:D:95B:UN:SMDG16'");	
	strArray.add("BGM+34+1+9'");
	strArray.add("TDT+20++1+++++:146::'");
	strArray.add("LOC+9+NZPOE:139:6'");
	strArray.add("NAD+CF+SHIP:160:20'");
	strArray.add("NAD+MS+NZCHC:160:87'");
	strArray.add("EQD+CN+PARC1230001+2200:102:5+++4'");
	strArray.add("RFF+BN:PAR30360'");
	strArray.add("DTM+7:");
	strArray.add("LOC+165+NZPOE:160:20'");
	strArray.add("MEA+AAE+G+KGM:4000'");
	strArray.add("CNT+16:1'");
	strArray.add("UNT+13+1'");
	strArray.add("UNH+2+CODECO:D:95B:UN:SMDG16'");	
	strArray.add("BGM+36+2+9'");
	strArray.add("TDT+20+VYPAR30360+1+++++:146::VSPAR30360'");
	strArray.add("LOC+11+NZPOE:139:6'");
	strArray.add("NAD+CF+SHIP:160:20'");
	strArray.add("NAD+MS+NZCHC:160:87'");
	strArray.add("EQD+CN+PARC1230001+2200:102:5++2+5'");
	strArray.add("RFF+BN:PAR30360'");
	strArray.add("DTM+7:");
	strArray.add("LOC+165+NZPOE:160:20'");
	strArray.add("MEA+AAE+G+KGM:4000'");
	strArray.add("CNT+16:1'");
	strArray.add("UNT+13+2'");
	strArray.add("UNZ+2+0'");
	theLines.clear();
	camTaskHistory.rawDataToHSA(theLines);
	foreach tempStr in theLines do
		idx := idx + 1;
		str := strArray[idx];
		
		self.assertEqual(tempStr[1:str.length], str);
		
		if idx = 10 then
			time1 := tempStr[7:12];
		elseif idx = 23 then
			time2 := tempStr[7:12];
		endif;
	endforeach;
	
	if time1 &lt;= time2 then
		self.assertEqual(null, "the gate out Full must be before the gate in MT");
	endif;
epilog
	delete operatorDict;
	delete freightForwarders;
	delete allCoarriExportPorts;
	delete emailCopyAddresses;
	delete packOperators;
	delete packExportConsignees;
	delete registeredTransactions;
	delete scheduleTimes;
	delete camEditTriggerFields;
	delete camTrainEventTypes;
	delete allPackAreas;
	delete strArray;
	delete lRegisteredCargoTypes;
	delete theLines;
end;</source>
