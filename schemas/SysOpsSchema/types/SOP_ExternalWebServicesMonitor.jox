	self.filterText := self.txtSearchBox.text;	// 14/08/2024	navcs2	Bug 65590
	self.getResponses(); 						// 26/05/2024	navcs2	ChangeRequest 59188
	self.getStatus(); 							// 26/05/2024	navcs2	ChangeRequest 59188
	
	self.filterClass:= CM_EWSActivityAPIEndpoint;
	self.filterInterfaceName := ExternalWebServiceAPIEndpoint;
	
	self.populateTable(terminals,app.myRoot.allEWSActivities);			// 26/05/2024	navcs2	ChangeRequest 59188
	
epilog
