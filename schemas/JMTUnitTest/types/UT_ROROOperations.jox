    <JadeMethod name="tOvertoppedTruck" id="7437f563-ee52-4807-8759-69ae4d1469fa">
        <updating/>
        <source>tOvertoppedTruck() updating;
/*

Purpose:			
Truck and trailer are cargo items.  Trailer is loaded onto truck, which are then loaded onto vessel.

Parameters:			

Return Value:		

Date		Who		Reason
15 February 2016	cnwmp6	Initial creation

*/

constants
	CommodityId			= "UTMP";
	CargoTypeTruckId	= "UTMPCTTK";
	CargoTypeTrailerId	= "UTMPCTTR";
	VoyageId			= "UTMPVOY";
	BookingTruckId		= "UTMPBE";
	BookingTrailerId	= "UTMPBS";
	DeliveryTruckId		= "UTMPDEL";
	TruckId				= "UTMPTK";
	TrailerId			= "UTMPTR";
	InterchangeAreaId	= "UTMPIA";
	GateId				= "UTMPG";
	TerminalAreaID		= "UTMPTA";
	DischargePortId		= "NZAKL";

vars
	operator:			CM_Operator;
	voyage:				CM_Voyage;
	vehicleArray:		ObjectArray;
	bookingTruck:		CM_BookingRef;
	bookingTrailer:		CM_BookingRef;
	pxyTruck:			CM_TrackedItem;
	truck:				CM_TrackedItem;
	truckCargoType:		CM_CargoType;
	truckCommodity:		CM_Commodity;
	trailer:			CM_TrackedItem;
	trailerCargoType:	CM_CargoType;
	trailerCommodity:	CM_Commodity;
	interchangeArea:	CM_InterchangeArea;
	gate:				CM_Gate;
	gateAreas:			StringArray;
	pack:				CM_TIArray;
	unpack:				CM_TIArray;
	moveCont:			CMIF_MoveController;
	bs:					CM_BlockStack;
	vvr:				CM_VehicleVisitRecord;
	loadTIs:			CM_TIArray;
	workPoint:			CM_WorkPoint;
	
begin
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNullMsg(operator, "Operator");
	
	interchangeArea := self.addInterchangeArea(InterchangeAreaId, null);
	self.assertNotNullMsg(interchangeArea, "Interchange area");
	bs := self.addBlockStack("UTMPBS", 10, interchangeArea);
	
	create gateAreas transient;
	gateAreas.add(TerminalAreaID &amp; ";;0;true;true;0");
	gate := self.addGate(GateId, false, true, false, false, interchangeArea, gateAreas);
	self.assertNotNullMsg(gate, "Gate");
	
	self.deleteVoyage(VoyageId);
	self.opts.purge();
	voyage := self.addVoyageWithConRORO(VoyageId, "MESDIAM", operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString, 
		self.getProfileSetting(UT_Profile.P_TRADE).asString, 0, true, false);
	self.assertNotNullMsg(voyage, "Voyage");	

	// create commodity, cargo types
	self.opts.purge();
	self.opts.addAssoc("Description", "Used trucks");
	self.opts.addAssoc("CommodityRequired", true);
	truckCargoType := self.addCargoType(CargoTypeTruckId, false);
	self.assertNotNullMsg(truckCargoType, "Truck cargo type");
	self.opts.purge();
	self.opts.addAssoc("Description", "Used trailers");
	self.opts.addAssoc("CommodityRequired", true);
	trailerCargoType := self.addCargoType(CargoTypeTrailerId, false);
	self.assertNotNullMsg(trailerCargoType, "Trailer cargo type");
	self.deleteCommodity(CommodityId);
	create vehicleArray transient;
	self.opts.purge();
	vehicleArray.add(truckCargoType);
	vehicleArray.add(trailerCargoType);
	self.addCommodity(CommodityId, "Used vehicles", vehicleArray);

	// export booking for truck cargo item
	self.deleteBooking(BookingTruckId);
	self.opts.purge();
	bookingTruck := self.addBookingForGeneralCargo(BookingTruckId, operator, voyage, DischargePortId, truckCargoType.id, 1);
	self.assertNotNullMsg(bookingTruck, "Truck export booking");

	// stock booking for trailer cargo item
	self.deleteBooking(BookingTrailerId);
	self.opts.purge();
	self.opts.addAssoc("Stock", true);
	bookingTrailer := self.addBookingForGeneralCargo(BookingTrailerId, operator, voyage, DischargePortId, trailerCargoType.id, 1);
	self.assertNotNullMsg(bookingTrailer, "Trailer stock booking");
	
	// vehicle actually delivering truck &amp; trailer cargo items
	self.deleteVehicle(DeliveryTruckId);
	
	// create truck cargo item and receive
	truck := self.getTrackedItem(TruckId);
	self.deleteTrackedItem(truck, false);
	truckCommodity := self.getCommodity(CommodityId);
	self.assertNotNullMsg(truckCommodity, "Truck commodity");
	self.opts.purge();
	self.opts.addAssoc("Voyage", voyage.code);
	self.opts.addAssoc("DischargePort", DischargePortId);
	self.opts.addAssoc("IMEX", TI_IMEX_STATUS_EXPORT);
	self.opts.addAssoc("BookingItem", bookingTruck.allBookingRefItems.first);
	vvr := self.gateInGC(DeliveryTruckId, "", self.getDriverName(), TruckId, truckCargoType.description, operator.code, truckCommodity.code, gate, 1);
	truck := self.getTrackedItem(TruckId);
	self.moveVehicleToYard(vvr.vehicle);
	self.moveWLE(truck.allWorklistEntries.first);
	self.roadExit(vvr);

	// create trailer cargo item and receive
	trailer := self.getTrackedItem(TrailerId);
	self.deleteTrackedItem(trailer, false);
	trailerCommodity := self.getCommodity(CommodityId);
	self.assertNotNullMsg(trailerCommodity, "Trailer commodity");
	self.opts.purge();
	self.opts.addAssoc("Voyage", voyage.code);
	self.opts.addAssoc("DischargePort", DischargePortId);
	self.opts.addAssoc("IMEX", TI_IMEX_STATUS_EXPORT);
	self.opts.addAssoc("BookingItem", bookingTrailer.allBookingRefItems.first);
	vvr := self.gateInGC(DeliveryTruckId, "", self.getDriverName(), TrailerId, trailerCargoType.description, operator.code, trailerCommodity.code, gate, 1);
	trailer := self.getTrackedItem(TrailerId);
	self.moveWLE(trailer.allWorklistEntries.first);
	self.moveVehicleToYard(vvr.vehicle);
	self.roadExit(vvr);
	
	// pack trailer onto truck
	create pack transient;
	self.assertNotNullMsg(pack, "Pack array");
	pack.add(trailer);
	self.assertEqualMsg(pack.size, 1, "Cargo not added to pack array");

	pxyTruck := app.createUpdateProxy(truck).CM_TrackedItem;

	create moveCont transient;
	moveCont.setMyToPrimaryLocation(null);
	moveCont.setMyOriginatingLocation(truck.getPrimaryLocation(REAL_MODE));
	moveCont.setMoveMode(REAL_MODE);
	moveCont.isSystemMove := true;
	moveCont.isForcedMove := true;

	app.myTrxUA.trxUpdatePackUnpack(moveCont, false, pack, unpack, false, pxyTruck, app.myPassport);
	
	// create the job
	workPoint := self.addWorkPoint("WPM", true);
	self.assertNotNullMsg(workPoint, "Work point");
	
	create loadTIs transient;
	loadTIs.add(truck);
	
	self.opts.purge();
	self.opts.addAssoc("myTi", truck);
	self.createGCLoadJobForRORO(voyage, workPoint, voyage.myROROStructure.allDecksByCode["4"], 98, -11, DischargePortId, truckCargoType, 
		operator, "", 0, 0, bs, loadTIs);
	
	self.loadAllJobsToOps(voyage, true);
	
	// move item to the slot or gc area
	self.moveAllCargoOnVoyage(voyage, REAL_MODE);
	
	self.assertEqualMsg(truck.site, TI_SITE_ONSHIP, "Truck should be on ship");
	self.assertEqualMsg(truck.locationId, VoyageId &amp; " D4001G", "Truck location should be " &amp; VoyageId &amp; " D4001G");
	self.assertEqualMsg(trailer.site, TI_SITE_ONSHIP, "Trailer should be on ship");
	self.assertEqualMsg(trailer.locationId, VoyageId &amp; " D4001G", "Trailer location should be " &amp; VoyageId &amp; " D4001G");
	self.assertTrueMsg(truck.allChildren.size = 1 and truck.allChildren.first.id = TrailerId, "Truck should contain " &amp; TrailerId);

epilog
	delete gateAreas;
	delete pack;
	delete moveCont;
	delete pxyTruck;
	delete loadTIs;
	delete vehicleArray;
end;</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;WorkPointDeleteIssue&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="tROROConfig" id="64cd5e51-27ea-4062-b539-ac25ccdec925">
        <source>tROROConfig();

/*

Purpose:		CHeck the RORO Vessel Config screen

Date			Who		Reason
07/08/2014		cnwmh5	Initial creation

*/



constants

	VesselId						: String = "MESINDA";
	VoyageId						: String = "UTMHMINDA";
	UserDefinedROROBaplie			: String = 'Unit Test RORO Baplie MSL';

vars

	vessel							: CM_Vessel;
	voyage							: CM_Voyage;
	fileTypeUser 					: CM_EDIFileTypeUser;
	pxyFileTypeUser 				: CM_EDIFileTypeUser;
	ediControllerAgent 				: CM_EDIControllerAgent;
	ediFile 						: CM_EDIFile;
	
	allStateData 					: CM_StateDataDict;
	fieldNameArray					: StringArray;
	fieldNameValueArray				: StringArray;
	tempArray						: StringArray;
	
	index							: Integer;
	value							: Any;
	ediText							: String;
	tempStr : String;
begin

	create ediControllerAgent transient;
	create pxyFileTypeUser transient;
	
	ediControllerAgent.setTerminal( self.getTerminal );	// cnwrl1 24/05/2010 PAR 24276
	
	// create the required user definition format.
	app.myTrxCA.trxCreateEDIFileTypeUser(fileTypeUser, pxyFileTypeUser, app.myPassport);
	fileTypeUser := app.myRoot.allEDIFileTypes.getAtKey(EDIFileType_UserDefined, UserDefinedROROBaplie).CM_EDIFileTypeUser;
	self.assertNotNullMsg(fileTypeUser, 'User Type ' &amp; UserDefinedROROBaplie &amp; ' is missing');

	vessel := app.myRoot.allVessels[VesselId];
	self.assertNotNull(vessel);
	
	allStateData := vessel.allStateData;
	if allStateData = null or allStateData.isEmpty() then
		allStateData := app.myRoot.getStateObject(ConfigGrp_System).allStateData;
	endif;
	
	create fieldNameArray transient;
	create fieldNameValueArray transient;
	create tempArray transient;
	fieldNameArray.add(RoRoDeckLabelPrefix);					fieldNameValueArray.add(null);
	fieldNameArray.add(RoRoAutoGenerateStartEnd);				fieldNameValueArray.add(null);
	fieldNameArray.add(RoRoLaneCodeIsZeroFilled);				fieldNameValueArray.add(null);
	fieldNameArray.add(RoRoLaneLabelPrefix);					fieldNameValueArray.add(null);
	fieldNameArray.add(RoRoLaneNumberLength);					fieldNameValueArray.add(null);
	fieldNameArray.add(RoRoLocationCodeIsZeroFilled);			fieldNameValueArray.add(null);
	fieldNameArray.add(RoRoLocationNumberLength);				fieldNameValueArray.add(null);
	fieldNameArray.add(RoRoRotatedLabel);						fieldNameValueArray.add(null);
	fieldNameArray.add(RoRoSubDeckLabelPrefix);					fieldNameValueArray.add(null);
	fieldNameArray.add(RoRoOutOfTwistLockSuffix);				fieldNameValueArray.add(null);
	fieldNameArray.add(RoRoGeneralCargoSuffix);					fieldNameValueArray.add(null);
	fieldNameArray.add(RoRoLaneWidth);							fieldNameValueArray.add(null);
	fieldNameArray.add(RoRoLaneLength);							fieldNameValueArray.add(null);
	fieldNameArray.add(RoRoLaneGap);							fieldNameValueArray.add(null);
	fieldNameArray.add(RoRoLocationWidth);						fieldNameValueArray.add(null);
	fieldNameArray.add(RoRoLocationLength);						fieldNameValueArray.add(null);
	fieldNameArray.add(RoRoLocationGap);						fieldNameValueArray.add(null);
	
	foreach index in 1 to fieldNameArray.size do
		global.getExtraData(allStateData, fieldNameArray[index], value);
		fieldNameValueArray[index] := value.String;
	endforeach;
	fieldNameValueArray.copy(tempArray);
	
	self.updateVesselROROConfig(vessel, allStateData, fieldNameArray, null);
	
	// create the voyage
	self.deleteVoyage(VoyageId);
	voyage := self.addVoyageWithConRORO(VoyageId, VesselId, self.getProfileSetting(UT_Profile.P_OPERATOR).asString(), 
		self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), self.getProfileSetting(UT_Profile.P_TRADE).asString(), 
		0, true, false);
	self.assertNotNull(voyage);
	
	//  now add the ship roro deck plan via EDI
	delete ediControllerAgent;
	create ediControllerAgent transient;
	ediControllerAgent.setTerminal( self.getTerminal );	
	
	// setup the add ship roro deck plan here
	ediText := self.xConfigBaplie(voyage);
		
	ediFile := self.ediLoadFileName(ediText, EDIFileType_UserDefined, UserDefinedROROBaplie, UserDefinedROROBaplie&amp;method.name);		
	self.assertNotNull(ediFile);
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_LOADED, "Load failed");
	self.clearExpectedTrxErrors();
	self.expectTrxError(Valid_deck_code_could_not_deri);
	self.ediVerify(ediFile);
	tempStr	:= 'Verify Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS, tempStr);
	
	
	// Set the Vessel RORO Config to the following details;
	fieldNameValueArray[fieldNameArray.indexOf(RoRoDeckLabelPrefix)] := "D";
	fieldNameValueArray[fieldNameArray.indexOf(RoRoAutoGenerateStartEnd)] := 4.String;				
	fieldNameValueArray[fieldNameArray.indexOf(RoRoLaneCodeIsZeroFilled)] := true.String;				
	fieldNameValueArray[fieldNameArray.indexOf(RoRoLaneLabelPrefix)] := "LN";					
	fieldNameValueArray[fieldNameArray.indexOf(RoRoLaneNumberLength)] := 2.String;					
	fieldNameValueArray[fieldNameArray.indexOf(RoRoLocationCodeIsZeroFilled)] := true.String;			
	fieldNameValueArray[fieldNameArray.indexOf(RoRoLocationNumberLength)] := 3.String;				
	fieldNameValueArray[fieldNameArray.indexOf(RoRoRotatedLabel)] := "R";						
	fieldNameValueArray[fieldNameArray.indexOf(RoRoSubDeckLabelPrefix)] := "S";					
	fieldNameValueArray[fieldNameArray.indexOf(RoRoOutOfTwistLockSuffix)] := "O";				
	fieldNameValueArray[fieldNameArray.indexOf(RoRoGeneralCargoSuffix)] := "G";					
	fieldNameValueArray[fieldNameArray.indexOf(RoRoLaneWidth)] := 3.0.String;							
	fieldNameValueArray[fieldNameArray.indexOf(RoRoLaneLength)] := 75.0.String;							
	fieldNameValueArray[fieldNameArray.indexOf(RoRoLaneGap)] := 0.5.String;							
	fieldNameValueArray[fieldNameArray.indexOf(RoRoLocationWidth)] := 2.4.String;						
	fieldNameValueArray[fieldNameArray.indexOf(RoRoLocationLength)] := 6.0.String;						
	fieldNameValueArray[fieldNameArray.indexOf(RoRoLocationGap)] := 0.0.String;		
	
	self.updateVesselROROConfig(vessel, allStateData, fieldNameArray, fieldNameValueArray);
	
	// verify again.  Shouldn't have an error
	self.clearExpectedTrxErrors();
	self.ediVerify(ediFile);
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, "Verify failed");
	
epilog

	// set the back to their orginal values
	tempArray.copy(fieldNameValueArray);
	self.updateVesselROROConfig(vessel, allStateData, fieldNameArray, fieldNameValueArray);	

	delete fieldNameArray;
	delete fieldNameValueArray;	
	delete tempArray;
	
	delete ediControllerAgent;
	delete pxyFileTypeUser;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="tROROLanes" id="2faa3ed4-ce58-41f6-b190-c3955c3baf9e">
        <updating/>
