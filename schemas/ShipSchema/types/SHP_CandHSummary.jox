    <JadeMethod name="doCmbVoyageBuild" id="b492e667-db8f-4851-a052-9ed0744a5b33">
        <updating/>
        <source>doCmbVoyageBuild() updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	aVoyage 		: CM_Voyage;
	idx 			: Integer;
	theVoyages 		: CM_VoyageSet;
	theVoy : CM_Voyage;
	theTerm : CM_Terminal;
	theCombo : CMUI_ComboBox;
begin
	theTerm := self.myTerminal;
	theCombo := self.cmbVoyage;
//	theCombo.armNotification(self.myTerminal);
	theCombo.clear;
	theCombo.sorted := true;
	
	create theVoyages transient;
	// Par 11314 cnwrs1 allow this to see all voyages not just current
	self.myTerminal.getAllCellularVoyages(theVoyages, false, false);

	foreach aVoyage in theVoyages do
		
		idx := theCombo.addItem(aVoyage.code &amp; " - " &amp; aVoyage.description);
		theCombo.itemObject[idx] := aVoyage;
	endforeach;

	//if app.myCurrentVoyage &lt;&gt; null then
	if app.getMyCurrentVoyage() &lt;&gt; null then
		//self.myCurrentVoyage := app.myCurrentVoyage;
		//cwnjo3 par 23105
		self.myCurrentVoyage := app.getMyCurrentVoyage;
		
//		self.beginNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(VoyageJob_Create_Event), Response_Continuous, null);
//		self.beginNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(VoyageJob_Update_Event), Response_Continuous, null);
//		self.beginNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(VoyageJob_Delete_Event), Response_Continuous, null);
//		self.beginNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(EVENT_STOP_CARGO_RECEIVAL), Response_Continuous, null);
		//idx := theCombo.findObject(app.myCurrentVoyage);
		//cnwjo3 par 23105
		idx := theCombo.findObject(app.getMyCurrentVoyage);
		if idx &gt; 0 then
			theCombo.listIndex := idx;
			self.doCmbVoyageClick();
		endif;
	endif;
epilog
	delete theVoyages;

end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbVoyageClick" id="9d678eaa-5ee6-48cb-ab77-2aac4f51471c">
        <updating/>
        <source>doCmbVoyageClick() updating;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	
	self.endNotificationForSubscriber(self);
	
	if self.cmbVoyage.listObject = null then
		return;
	endif;
	
	self.myCurrentVoyage := self.cmbVoyage.listObject.CM_Voyage;
	self.cmbVoyOperator.setObjectAndVoyage(null, self.myCurrentVoyage);

//app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' reg for note ' &amp; self.myCurrentVoyage.asStringJMT);
	self.beginNotification(self.myCurrentVoyage, Event_HatchSummary_Update, Response_Continuous, null);

	self.setCaption("C&amp;H. " &amp; self.myCurrentVoyage.code &amp; " " &amp; app.getErrorString(SHP_Container_Hatch_Summary)); //epr TFS 2362 4/8/16
	self.setNavigatorHeading(self.myCurrentVoyage.code &amp; " C&amp;H Summary");
end;</source>
    </JadeMethod>
    <JadeMethod name="doNotableClear" id="f0688ec0-7167-41e6-a01d-cb66cd3febed">
        <source>doNotableClear();
// ---------------------------------------------------------------------------
// Created:		23 February 2010 cnwjo3
//
// Purpose:		par 21915.  Each form should implement doNotableClear without an inheritMethod();
//
vars
	removedNotification : Integer;
	anObject : Object;
begin

	foreach anObject in self.allNotableObjects do
		/*if anObject.isKindOf(____OBJECT TYPE____) then
			endNotification(anObject, self.myTerminal.getTerminalEvent(____EVENT_NAME_____));
			removedNotification := removedNotification + 1;
		endif;*/
	endforeach;

	validateNotificationRemoval(removedNotification,self.allNotableObjects.size);
	
	self.allNotableObjects.clear;
end;</source>
    </JadeMethod>
    <JadeMethod name="doPrint" id="506bb27d-de2c-4427-a175-2ebecc6cf394">
        <updating/>
        <source>doPrint() updating;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	gtp:        CM_GenericTablePrint;
	pd:                  CMS_Progress;
	idx :               Integer;
	now:                 TimeStamp;
	rateTable : Table;
	tmpJadeReport  : JadeReport;
	strs : HugeStringArray;
begin
	now := self.systemToLocalTime(app.actualTimeServer());	// 9/5/16 cnwmp6 TFS 488 - Multi timezone support
	
	if self.myCurrentVoyage = null then
		app.msgBox(app.getErrorString(SHP_You_Must_Choose_A_Voyage), app.getErrorString(SHP_Query_Error), MsgBox_OK_Only+MsgBox_Information_Icon);
		return;
	endif;
	
	rateTable := self.tblData;
	
	app.mousePointer := MP_HOURGLASS;
//	app.printer.printPreview := true;
	app.printer.suppressDialog := true;

	create gtp;
	create pd;
	pd.setBackground(self.backColor);
	pd.show;
	pd.raiseExceptionOnAbort := false;
	pd.setAction("Printing " &amp; app.getErrorString(SHP_Container_Hatch_Summary));

	app.printer.setMargins(Print_Landscape,0,0,10,10);

	pd.progress.partsInJob := rateTable.rows - 1;

	// setup header information

	// set header
	gtp.frHeader.width := app.printer.pageWidth;

	gtp.setHeaders(self.getReportHeader1(), self.getReportHeader2());
	create tmpJadeReport transient;
	tmpJadeReport.description := app.getErrorString(SHP_Container_Hatch_Summary);
	app.printer.setReport(tmpJadeReport);

	app.printer.setHeader(gtp.frHeader);

	// set footer
	gtp.frFooter.width := app.printer.pageWidth;
	gtp.lblTheUser.caption := app.getMyUserCode;
	gtp.lblTheDatePrinted.caption := now.asStringJMT;
	app.printer.setFooter(gtp.frFooter);

	gtp.printTable(rateTable, true, pd);

	//app.printer.print(gtp.frTable);

	app.printer.newPage;
	self.lblPrint.caption := "REMARKS:" &amp; Cr &amp; Cr &amp; self.myCurrentVoyage.remarks;
	app.printer.print(self.frmPrint);
	
//	self.lblPrint.height := self.lblPrint.height * 2;
//	self.lblPrint.caption := "DISCREPANCIES:" &amp; Cr &amp; Cr &amp; self.discrepancies;
//	app.printer.print(self.frmPrint);

	// ### changed to this during 741 testing, above was only printing first 6 discrepancies.
	app.printer.print(self.frmPrint);
	create strs transient;
	self.discrepancies.getTokensForDelimiterHuge(Cr,strs); //getTokensForDelimiter(CrLf, strs);
	self.lblPrint.height := 30;
	self.lblPrint.top := 0;
	self.frmPrint.height := 30;
	foreach idx in 1 to strs.size do
		self.lblPrint.caption := strs[idx];
		if idx  = 1 then
			self.lblPrint.caption := self.lblPrint.caption.toUpper();
		endif;
		app.printer.print(self.frmPrint);
	
	endforeach;
	

	if pd.aborted then
		app.printer.abort;
		return;
	endif;

epilog
	app.printer.close;
	if tmpJadeReport &lt;&gt; null then
		app.printPreview(tmpJadeReport, true);
	endif;
	if pd &lt;&gt; null then
		pd.unloadForm;
		delete pd;
	endif;
	delete gtp;
	delete strs;
	app.mousePointer := MP_DEFAULT;

end;</source>
    </JadeMethod>
    <JadeMethod name="doQuery" id="c846f298-44ee-4af0-9e97-90f0752a9a28">
        <updating/>
        <source>doQuery() updating;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
30 Jun 2008	cnwkpd1	PAR #17361 - ensure Progress dialog deleted unconditionally

*/

vars
	dynaDict:   DynaDictionary;
	obj:        Object;
	voyage:     CM_Voyage;
	progress:   CMS_Progress;
	operator:   CM_Operator;
//	ha:         CM_ExtHatchSummary;
	ia:         IntegerArray;
	i:          Integer;
	j:          Integer;
	spg:        CM_ShipPortGroup;
	lgd:        CM_LineGroupDebtor;
	str:        String;
	colTotal:   Integer;
	tbl			: CM_DataTable;
	tmpTLG		: CMIF_CandHTradeLineGeo;

begin

if app.isSpecial then
	if app.msgBox('Use old method', '', MsgBox_Yes_No) = MsgBox_Return_Yes then
		self.doQueryOLD();
		return;
	endif;
endif;

	app.mousePointer := MP_HOURGLASS;
	self.frmQuery.visible := false;
	endLoad;
	beginLoad;
	
	on CM_ProgressException do handleGetDataCancel(exception);
	on NormalException do handleNormalException(exception);

	if cmbVoyage.listIndex = -1 then
		app.msgBox(app.getErrorString(SHP_You_Must_Choose_A_Voyage), app.getErrorString(SHP_Query_Error), MsgBox_OK_Only+MsgBox_Information_Icon);
		return;
	endif;

	tbl := self.tblData;
	
	voyage := self.cmbVoyage.itemObject[cmbVoyage.listIndex].CM_Voyage; //bank.terminal.allVoyages[cmbVoyage.itemText[cmbVoyage.listIndex]];
	if not global.isValidObject(voyage.myShippingLine) then
		app.setContinueCMExceptions(false);
		app.raiseCMException1(ERR_SHIPPINGLINE_INVALID, voyage.code, null, null);
		return;		
	endif;

	operator := self.cmbVoyOperator.myObject.CM_Operator;
	if self.cmbSumariseTo.listIndex &gt; 0 then
		self.sumariseTo := self.cmbSumariseTo.itemData[self.cmbSumariseTo.listIndex];
	endif;

	create progress transient;
	progress.show;
	
	delete self.myCandHReport;
	create self.myCandHReport transient;
	self.myCandHReport.useSnapShots := optActual.value;
	self.myCandHReport.myVoyage := voyage;
	self.myCandHReport.myOperator := operator;
	self.myCandHReport.sumariseTo := self.sumariseTo;

	tbl.clear;
	tbl.rows := 55;
	self.loadServiceStrings(); // &lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;

	progress.setAction("Acquiring Data...");

	self.hideColours := true;
	if self.myCandHReport.useSnapShots then	//actual
		self.showOriginalData := self.chkHideEdits.value;
		self.myCandHReport.useOrginialLDG := self.showOriginalData;
		self.hideColours := self.chkHideColours.enabled and self.chkHideColours.value;
		//use snapshots
		voyage.getCandHStatsFromSnapShots(self.myCandHReport, progress); // &lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;
	else	//proposed
		self.myCandHReport.useOrginialLDG := true;
		self.showOriginalData := false;	//only applies to actual mode
		//do old way using wles
		voyage.getCandHStats(self.myCandHReport, progress); // &lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;
	endif;
	
	progress.setAction("Formating Data...");

	tbl.rows := 55;
	tbl.columns := self.myCandHReport.allSummaryTLGColumnsByCode.size + 4;
	tbl.row := 1;
	tbl.column := 3;

	foreach tmpTLG in self.myCandHReport.allSummaryTLGColumnsByCode do
		self.showColumnDataForTLG(tmpTLG, tbl.column, colTotal);
		//Don't add the column if there is nothing to show
		if colTotal &gt; 0 then
			tbl.column := tbl.column + 1;
		endif;
		//tbl.column := tbl.column + 1;
	endforeach;

	tbl.columns := tbl.column + 1;
	self.discrepancies := "Discrepancies for voyage " &amp; voyage.code &amp; ". "&amp;CrLf &amp; self.myCandHReport.errorString;

	self.calcTotals;
	self.loadNone(tbl, tbl.columns - 1);
	
epilog
	endLoad;
	// fixup transient leaks
	delete dynaDict;
	delete progress;		// PAR #17361
	// to here	
	self.setEnableObjects();
	self.frmQuery.visible := (self.tblData.columns &lt; 5);
	app.mousePointer := MP_DEFAULT;	

end;</source>
    </JadeMethod>
    <JadeMethod name="doQueryOLD" id="f4697d0a-4405-419f-b70d-e52bd00f28e8">
        <updating/>
        <source>doQueryOLD() updating;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		This is the per CCMS-1468 code.  Has been left here for initial testing
// ---------------------------------------------------------------------------
vars
	dynaDict:   DynaDictionary;
	obj:        Object;
	voyage:     CM_Voyage;
	progress:   CMS_Progress;
	operator:   CM_Operator;
//	ha:         CM_ExtHatchSummary;
	ia:         IntegerArray;
	i:          Integer;
	j:          Integer;
	numLGD:     Integer;
	spg:        CM_ShipPortGroup;
	lgd:        CM_LineGroupDebtor;
	str:        String;
	colTotal:   Integer;
	ls			: Boolean;
//	codeArray	: StringArray;
//	summaryTLG	: CMIF_CandHTradeLineGeo;
//	summItem	: CMIF_CandHSummaryItem;
//	cell		: JadeTableCell;
	tbl			: CM_DataTable;
begin

self.caption := "C&amp;H. " &amp; self.myCurrentVoyage.code &amp; " " &amp; app.getErrorString(SHP_Container_Hatch_Summary) &amp; ' ** OLD **';

	app.mousePointer := MP_HOURGLASS;
	self.frmQuery.visible := false;
	app.cmsBeginLoad(ls);
	
	on CM_ProgressException do handleGetDataCancel(exception);
	on NormalException do handleNormalException(exception);

	if cmbVoyage.listIndex = -1 then
		app.msgBox(app.getErrorString(SHP_You_Must_Choose_A_Voyage), app.getErrorString(SHP_Query_Error), MsgBox_OK_Only+MsgBox_Information_Icon);
		return;
	endif;

	tbl := self.tblData;
	
	voyage := self.cmbVoyage.itemObject[cmbVoyage.listIndex].CM_Voyage; //bank.terminal.allVoyages[cmbVoyage.itemText[cmbVoyage.listIndex]];
	if not global.isValidObject(voyage.myShippingLine) then
		app.setContinueCMExceptions(false);
		app.raiseCMException1(ERR_SHIPPINGLINE_INVALID, voyage.code, null, null);
		return;		
	endif;

	operator := self.cmbVoyOperator.myObject.CM_Operator;

	create progress;
	progress.show;
	
	delete self.myCandHReport;
	create self.myCandHReport transient;
self.myCandHReport.usePRE_CCMS1468 := true;
	self.myCandHReport.useSnapShots := optActual.value;
	self.myCandHReport.myVoyage := voyage;
	self.myCandHReport.myOperator := operator;
	
	tbl.clear;
	tbl.rows := 55;
	self.loadServiceStrings(); // &lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;

	progress.setAction("Acquiring Data...");

	self.hideColours := true;
	if self.myCandHReport.useSnapShots then	//actual
		self.showOriginalData := self.chkHideEdits.value;
		self.myCandHReport.useOrginialLDG := self.showOriginalData;
		self.hideColours := self.chkHideColours.enabled and self.chkHideColours.value;
		//use snapshots
		voyage.getCandHStatsFromSnapShots(self.myCandHReport, progress); // &lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;
	else	//proposed
		self.myCandHReport.useOrginialLDG := true;
		self.showOriginalData := false;	//only applies to actual mode
		//do old way using wles
		voyage.getCandHStats(self.myCandHReport, progress); // &lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;
	endif;
	
	progress.setAction("Formating Data...");

	voyage.myShippingLine.getTotalCount(numLGD);
	tbl.rows := 55;
	tbl.columns := numLGD + 4;
	tbl.row := 1;
	tbl.column := 3;

	create dynaDict transient;
	dynaDict.setMembership(CM_LineGroupDebtor);
	dynaDict.addExternalKey(String, 32, false, true);
	dynaDict.endKeys(true);

	foreach spg in voyage.myShippingLine.shipPortGroups do
		foreach lgd in spg.lineGroupDebtors do
			dynaDict.putAtKey(lgd.debtor.name, lgd);
		endforeach;
	endforeach;

	foreach obj in dynaDict do
		lgd := obj.CM_LineGroupDebtor;
		
		self.showColumnDataForLGD(lgd, tbl.column, colTotal);
		
		if colTotal &gt; 0 then
			tbl.column := tbl.column + 1;
		endif;
	endforeach;

	tbl.columns := tbl.column + 1;
	self.discrepancies := "Discrepancies for voyage " &amp; voyage.code &amp; ". "&amp;CrLf &amp; self.myCandHReport.errorString;

	self.calcTotals;
	self.loadNone(tbl, tbl.columns - 1);
epilog
	app.cmsEndLoad(ls);
	// fixup transient leaks
	delete dynaDict;
	// to here	
	self.setEnableObjects();
	delete progress;
	self.frmQuery.visible := (self.tblData.columns &lt; 5);
	app.mousePointer := MP_DEFAULT;	

end;</source>
    </JadeMethod>
    <JadeMethod name="doTblDataContextMenu" id="a1d4dd58-6fcd-4f06-970f-6bb8750cb445">
        <updating/>
        <source>doTblDataContextMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.mnuContextColourLegend.visible := false;
	self.mnuContextHide.visible := false;
