    <JadeMethod name="affectsTIAvailability" id="9b213db4-7b60-4cac-b51e-fe819ec0aaf5">
        <source>affectsTIAvailability(): Boolean;
// --------------------------------------------------------------------------------
// Created:		04 June 2010 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the receiver affects the
//				availability of its Tracked Item.
//
// Parameters:	None
//
// Returns:		True, by default.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canView" id="36d6d460-dfa1-4d82-a686-fecf77153b77">
        <source>canView(_user: CM_User): Boolean;
// --------------------------------------------------------------------------------
// Created:		04 June 2010 by cnwdad1
//
// Purpose:		Returns a boolean flag top indicate whether the specified User can
//				view the receiver.
//
// Parameters:	_user - A reference to the user to check.
//
// Returns:		True if the user can view the receiver, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if _user = null then
		return false;
	endif;
	
	return _user.canViewStop(self.myTerminal, app.myRoot.allStopsTable[self.stopID]);
end;</source>
        <Parameter name="_user" type="CM_User"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCCEventProperties" id="1cfcee6b-55b4-4320-ac00-71648b3257e4">
        <source>getCCEventProperties(ccEvent: CMIF_CCEvent) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 August 2019	jlgndl1	Initial creation	TFS 45963

*/

vars

	stopType : String;
	requiredInfo : String;
begin

	stopType := self.getStopDescription;

	inheritMethod(ccEvent);
	
	ccEvent.addText( "stopType", stopType );

epilog

end;</source>
        <access>protected</access>
        <Parameter name="ccEvent" type="CMIF_CCEvent"/>
    </JadeMethod>
