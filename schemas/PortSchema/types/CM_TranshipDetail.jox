    <JadeMethod name="setExportBookingReference" id="c4de0a44-5752-4017-97da-e67f149d7776">
        <updating/>
        <source>setExportBookingReference(_bookingRef : String) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28/06/2010	cnwdap1	Initial creation PAR #24516
*/
vars

begin
	if self.exportBookingReference &lt;&gt; _bookingRef then
		self.exportBookingReference := _bookingRef;
	endif;
epilog

end;</source>
