    <JadeMethod name="initSealsControls" id="856b20b1-610f-4538-b8b7-61e8a095f435">
        <updating/>
        <source>initSealsControls( _entTableDef: EntTableDef ) protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 September 2010	cnwndl1	Initial creation	- Par 25608 - moved to its own method.

*/

vars

	cargoType		: CM_CargoType;
	captions,
	controlNames	: StringArray;
	sealType		: CM_SealType;
	cargoId : String;

begin

	create captions transient;
	create controlNames transient;
	
	if self.flexiCargoType = self.FLEXI_CARGO_EMPTY or self.flexiCargoType = self.FLEXI_CARGO_FULL then
		cargoType := app.myRoot.allCargoTypesById[TI_CargoType_Container];
	else
		cargoType := self.cmbType.getObject.CM_CargoType;
	endif;
	//cargoId := self.txtCargoID.getString;
	
	//if cargoType &lt;&gt; null and not cargoType.allSealTypes.isEmpty and cargoId &lt;&gt; null then
	if cargoType &lt;&gt; null and not cargoType.allSealTypes.isEmpty then	// 06/03/2013 cnwar2 #31206 - should not require Cargo ID to show seal fields
		// store the seal descriptions in the caption array

		foreach sealType in cargoType.allSealTypes do
			if sealType.notAvailableForEntry then
				continue;
			endif;
			captions.add(sealType.description);
			controlNames.add(sealType.sealType);
		endforeach;
	endif;
	
	self.doAddExtraControls(_entTableDef, ETRow_SealNum, captions, controlNames);

epilog

	delete captions;
	delete controlNames;

end;</source>
        <access>protected</access>
        <Parameter name="_entTableDef" type="EntTableDef"/>
    </JadeMethod>
    <JadeMethod name="initTrainDetails" id="d95ae20b-949b-4305-a357-958353549887">
        <source>initTrainDetails(_train : CM_Train; _wagon : CM_Wagon; _wagonClass: CM_WagonClass);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 April 2023	navhl20	ChangeRequest 56628:[54992] EUP - Receive Cargo Form- Enhancement

*/

vars

begin
	self.txtWagonTrain.setValue(_train.code);
	self.txtWagon.setValue(_wagon.id);
	self.cmbWagonClass.setForObject(_wagonClass);
epilog

end;</source>
        <Parameter name="_train" type="CM_Train"/>
        <Parameter name="_wagon" type="CM_Wagon"/>
        <Parameter name="_wagonClass" type="CM_WagonClass"/>
    </JadeMethod>
    <JadeMethod name="isAdditionalGTEEntityOnVVR" id="795a369c-ad67-4e4c-8d7c-9086eeb5fc86">
        <source>isAdditionalGTEEntityOnVVR():Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 May 2011	cnwndl1	Initial creation	Par 27585

*/

vars

	vvr	: CM_VehicleVisitRecord;

begin

	if self.permissionMaint &lt;&gt; 0 then
		if not app.myPassport.myUser.canDo(self.myTerminal, self.permissionMaint) then
			return false;
		endif;
	endif;
	
	if self.isFlexiGateForm and self.myRealGTEEntity &lt;&gt; null then
		if app.isValidObject(self.myParentForm) and self.isKindOf(self.myParentForm.class) then
			vvr := self.myRealGTEEntity.myParent.myVehicleVisitRecord;
		else
			vvr := self.myRealGTEEntity.myVehicleVisitRecord;
		endif;
	endif;
	
	if vvr = null then
		return false;
	endif;
	
	if self.myRealGTEEntity &lt;&gt; null then
		return vvr.getWLEForGateEntity( self.myRealGTEEntity ) = null;
	endif;
	
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isAttachmentForm" id="ca84749f-2344-4e82-819e-ed20b5e7b4ec">
        <source>isAttachmentForm() : Boolean;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04/09/2009	cnwdap1	Initial creation
20/10/2009	cnwdap1	PAR #21445 Attachment form not recognising it was an attachment
						(Attachment form is now a modal subclass of CMUI_ReceiveCargoForm)
*/
vars

begin
//	if self.myParentForm.isKindOf(self.class) then	// PAR #21445
	if app.isValidObject(myParentForm) and self.isKindOf(myParentForm.class) then		// PAR #21445
		return true;
	else
		return false;
	endif;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isAutoVolumeCalcCT" id="05305ac7-4497-4cb8-9d11-3bfe3b7416c8">
        <source>isAutoVolumeCalcCT(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Aug 2017	cnwma1	TFS #5695:STWO - Re-Calculate Volumes on Forms and EDI

*/

vars
	cargoType : CM_CargoType;
	product	  : CM_Product;
begin
	
	product	   :=  self.cmbSubCargo.getObject().CM_Product;
	cargoType := self.getCargoType;
	
/*	if cargoType&lt;&gt; null and 
		cargoType.allowAutoVolumeCalc and
		(cargoType.isBulk or cargoType.isBreakBulk)    and 
		(product &lt;&gt; null and not product.autoVolumeCalculate )then
		return true;
	endif;
	return false;
*/
	return cargoType &lt;&gt; null and cargoType.allowAutoVolumeCalc;		// 26/3/19 MAP TFS41707
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="keyDown" id="2e5a2400-3ef4-47ce-949e-ff283765d2c7">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 September 2009	cnwdap1	Initial creation
*/
vars

begin
	inheritMethod(keyCode, shift);
	// CTRL-Shift-A switches between full detail and minimum
	if keyCode = J_key_A and shift.bitAnd(1) &lt;&gt; 0 and shift.bitAnd(2) &lt;&gt; 0 then
		if self.currentEntTableDef = ETDef_MinContainerDetails then
			self.numberOfColumns := 3;
			self.initFieldsForEntDefName(self.oldEntTableDef, true);
			self.oldEntTableDef := null;
		else
			self.oldEntTableDef := self.currentEntTableDef;
			self.numberOfColumns := 2;
			self.initFieldsForEntDefName(ETDef_MinContainerDetails, true);
		endif;
		
		self.doShowPicture();
		self.doSetCaption();
	endif;
epilog

end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="lblAddDetails_doAlignCtrls" id="0cc352a9-06e7-455a-80f4-645f7d5d3adc">
