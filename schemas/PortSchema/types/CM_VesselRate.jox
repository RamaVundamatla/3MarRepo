    <JadeMethod name="auditIdDisplay" id="6e6c33b8-d1c2-4d74-992d-fff3afb0928a">
        <source>auditIdDisplay(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 October 2019	jlgndl1	Initial creation	TFS 47013

*/

vars

begin

	if self.auditId() &lt;&gt; null then
		return app.getErrorString(Rate) &amp; Space &amp; Hyphen &amp; Space &amp; app.getErrorString(CM_Vessel_GC) &amp; ": "&amp; self.auditId();
	else
		return app.getErrorString(Rate);
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCode" id="56115275-e7fd-4bf6-8610-92f63b0180bd">
        <source>getCode(): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 28/03/2018	jlgdap1		Initial creation TFS 37794 PEL1 Vessel Rates
//
vars

	invalidObject : Boolean;
	edition : Integer;

begin
	
	if self.myVessel &lt;&gt; null then
		on Exception do app.handleDeletedObject( exception, self.myVessel, invalidObject );	//16 Oct 2019	NDL	TFS 47013
		edition := self.myVessel.edition;
		if invalidObject then
			return null;
		endif;
		return self.myVessel.code;
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
