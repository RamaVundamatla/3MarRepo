    <JadeMethod name="getComboIndex" id="1811c585-ea36-4bc5-9060-ebdccc5fe9d6">
        <source>getComboIndex(_index : Integer) : Integer;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 04/01/2013	cnwdap1		PAR #30860 CCMS QNS 2236 New narration types
vars
	narrStr : String;
	narrIdx : Integer;
begin
		if self.arrNarrationDesc.size &lt; _index then
			return 1;
		else
			narrStr := self.arrNarrationDesc[_index];
			narrIdx := narrStr[11: end].Integer;
			if narrIdx = CM_InvoiceDesc.Field_None then
				return 1;
			elseif narrIdx = CM_InvoiceDesc.Field_Debtor_Name then
				return 2;
			elseif narrIdx = CM_InvoiceDesc.Field_Voyage_Code then
				return 3;
			elseif narrIdx = CM_InvoiceDesc.Field_Vessel_Name then
				return 4;
			elseif narrIdx = CM_InvoiceDesc.Field_Business_Unit then
				return 5;
			elseif narrIdx = CM_InvoiceDesc.Field_Closing_Date then
				return 6;
			elseif narrIdx = CM_InvoiceDesc.Field_Closing_Date_And_Time then
				return 7;
			elseif narrIdx = CM_InvoiceDesc.Field_Voyage_Operator_Code then		// PAR #30860
				return 8;														// PAR #30860
			elseif narrIdx = CM_InvoiceDesc.Field_Voyage_Operator_Desc then		// PAR #30860
				return 9;														// PAR #30860
			elseif narrIdx = CM_InvoiceDesc.Field_Voyage_Arrival_Date then		// PAR #30860
				return 10;														// PAR #30860
			elseif narrIdx = CM_InvoiceDesc.Field_Voyage_Departure_Date then	// PAR #30860
				return 11;														// PAR #30860
			endif;
			
		endif;
end;</source>
        <Parameter name="_index" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDebtorSeparation" id="d7558296-c240-4540-9ad8-bccb0c59f9f3">
        <source>getDebtorSeparation(_debtor : CM_Debtor) : CM_InvTypeDebtorSeparation;
 // ### BUG 56925 07MAR2023 NAVAB1
vars
	surchargesAndExemptions		: CM_InvoiceTypeSurchargeExempt;
	invoiceTypeDebtorSeparation	: CM_InvTypeDebtorSeparation;
	
begin
	surchargesAndExemptions := self.mySurchargeAndExemptions;
	
	if surchargesAndExemptions = null then
		return null;
	endif;
	
	if surchargesAndExemptions.allInvoiceTypeDebtorSeparation.isEmpty then
		return null;
	endif;
	
	invoiceTypeDebtorSeparation := surchargesAndExemptions.allInvoiceTypeDebtorSeparation[_debtor];
	
	if invoiceTypeDebtorSeparation = null then
		//Check for default debtor
		invoiceTypeDebtorSeparation := surchargesAndExemptions.allInvoiceTypeDebtorSeparation[self.company.rootDebtor];
		if invoiceTypeDebtorSeparation = null then
			return null;
		endif;
	endif;
	
	return invoiceTypeDebtorSeparation;
	
end;</source>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <ReturnType type="CM_InvTypeDebtorSeparation"/>
    </JadeMethod>
    <JadeMethod name="getDebtorSeparationAccrual" id="c3500c80-799b-47e5-8f77-48b7b703f973">
        <source>getDebtorSeparationAccrual(_debtor : CM_Debtor) : CM_FinancialPeriodEnd;
/*

Purpose:			Gets the financial period end/accrual type for the debtor

Parameters:			_debtor	CM_Debtor	The debtor to check

Return Value:		CM_FinancialPeriodEnd	Returns a financial period end/accrual type, if we have one set for the debtor

Date				Who		Reason
06 October 2022		navpw1	Initial creation TFS: 54565 (54384)
01 November 2022	navpw1	TFS: 55285 - Added a lookup for the default debtor (RDT) in case a config exists for this debtor but not the debtor we are searching for
*/

vars
	surchargesAndExemptions		: CM_InvoiceTypeSurchargeExempt;
	invoiceTypeDebtorSeparation	: CM_InvTypeDebtorSeparation;
	
begin
	surchargesAndExemptions := self.mySurchargeAndExemptions;
	
	if surchargesAndExemptions = null then
		return null;
	endif;
	
	invoiceTypeDebtorSeparation := surchargesAndExemptions.allInvoiceTypeDebtorSeparation[_debtor];
	
	if invoiceTypeDebtorSeparation = null then
		//Check for default debtor
		invoiceTypeDebtorSeparation := surchargesAndExemptions.allInvoiceTypeDebtorSeparation[self.company.rootDebtor];
		if invoiceTypeDebtorSeparation = null then
			return null;
		endif;
	endif;
	
	return invoiceTypeDebtorSeparation.myAccrualType;
	
end;</source>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <ReturnType type="CM_FinancialPeriodEnd"/>
    </JadeMethod>
    <JadeMethod name="getDescriptionWithTerminalStr" id="f4598433-61b0-4ddd-ad42-52fad690af8a">
        <source>getDescriptionWithTerminalStr() : String;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		22 April 2010
//
// Implemented version: JMT 7.8.2
// Date  		User  		Change
// SFW CCMS 1115 PAR23680   cnwsh3 - Invoice JRW Interface
//----------------------------------------------------------------------
vars
	
begin
	if self.company = null or 
	   self.company.terminal = null then
		return self.description;
	endif;
	
	return self.description &amp; " (" &amp; self.company.getTerminalCode() &amp; ")";
epilog
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayDetails" id="f6fb81bd-721d-4a97-a686-1f8c2ce7930e">
        <source>getDisplayDetails(_short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     Aug 2004	cnwrs1
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------

vars

begin
	if _short then
		return self.number.String;
	else
		return '('&amp;self.number.String&amp;')  '&amp;self.description;
	endif;
end;</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="5b0e77d7-4a74-4897-a699-9d371cbd5233">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 22 Sept 2022	navrk21 Bug 54896: EUP - GL Code External Reference field limit
// 01 Nov 2022	navpw1	TFS: 55235 - Changed the row ETRow_SeperateInvoicesFor to show the invoice key and ETRow_Key to show separation criteria.
// 15/06/2023	navcs2	ChangeRequest 58434: [58452]: EUP | TAS Invoicing - Invoice Type Configuration

vars
	narrStr : String;
	narrIdx,narrPos : Integer;
begin
	if _attrName = ETRow_Description  
	or _attrName = ETRow_Description30  then // PAR 21146
		return self.description;
	elseif _attrName = ETRow_InvNarr  then
		return "InvNarr"; //self.getNarrationFieldDesc(); // not displayed
	elseif _attrName = ETRow_AccuralType  then
		return self.getAccrualTypeDescription();
	elseif _attrName = ETRow_SeperateInvoicesFor  then
		return self.getSeparationsDescription();	// ### TFS 55235 01Nov2022 NAVPW1
	elseif _attrName = ETRow_TriggerOnAction  then
		return self.getTriggerOnActionString();
	elseif _attrName = ETRow_IsStorageInvoice  then
		return (self.invoiceType = InvoiceTypeStorage).getYesNo;
	elseif _attrName = ETRow_Terms  then
		if self.myInvTermsOfTrade = null then
			return null;
		else
			return self.myInvTermsOfTrade.description;
		endif;
	elseif _attrName = ETRow_PeriodType  then
		if self.myFinancialPeriodEnd = null then
			return null;
		else
			return self.myFinancialPeriodEnd.description;
		endif;
	
	elseif _attrName = ETRow_Print1LineDay  then
		return self.printSingleLineForDayType.getYesNo;
	elseif _attrName = ETRow_Key  then
		return self.getKeyDescription();
	elseif _attrName = ETRow_Field1  then
		return self.getDisplayStringNarr(2);
	elseif _attrName = ETRow_Field2  then
		return self.getDisplayStringNarr(4);
	elseif _attrName = ETRow_Field3  then
		return self.getDisplayStringNarr(6);
	elseif _attrName = ETRow_Field4  then
		return self.getDisplayStringNarr(8);
	elseif _attrName = ETRow_Field5  then
		return self.getDisplayStringNarr(10);
	elseif _attrName = ETRow_FreeText1 then
		return self.arrNarrationDesc[1];
	elseif _attrName = ETRow_FreeText2 then
		return self.arrNarrationDesc[3];
	elseif _attrName = ETRow_FreeText3 then
		return self.arrNarrationDesc[5];
	elseif _attrName = ETRow_FreeText4 then
		return self.arrNarrationDesc[7];
	elseif _attrName = ETRow_FreeText5 then
		return self.arrNarrationDesc[9];
	elseif _attrName = ETRow_ExternalReference then  //cnwjo3 par 25387 ccms 1970
		//return self.externalReference;								// 22.09.2022 navrk21 TFS 54896
		return self.externalReference.formatWithEllipsis(1,100,true);	// 22.09.2022 navrk21 TFS 54896
	elseif _attrName = ETRow_Print1LineDayChk then  //cnwjo3 par 25387 ccms 1970
		return self.printSingleLineForDayType.getYesNo();
	elseif _attrName = ETRow_IsStorageInvoiceChk then  //cnwjo3 par 25387 ccms 1970
		return (self.invoiceType = InvoiceTypeStorage).getYesNo();
	elseif _attrName = ETRow_IsNotAvailableForEntryCk then
		return self.isNotAvailableForEntry.String;
	elseif _attrName = ETRow_IsApiCreditNote then		// 15.06.2023	navcs2	#58434:[58452]
		if self.useForApiCn then						// 15.06.2023	navcs2	#58434:[58452]
			return "Yes";								// 15.06.2023	navcs2	#58434:[58452]
		else											// 15.06.2023	navcs2	#58434:[58452]
			return "No";								// 15.06.2023	navcs2	#58434:[58452]
		endif;											// 15.06.2023	navcs2	#58434:[58452]
	elseif _attrName = ETRow_IsApiInvType then			// 15.06.2023	navcs2	#58434:[58452]
		if self.useForApiInv then						// 15.06.2023	navcs2	#58434:[58452]
			return "Yes";								// 15.06.2023	navcs2	#58434:[58452]
		else											// 15.06.2023	navcs2	#58434:[58452]
			return "No";								// 15.06.2023	navcs2	#58434:[58452]
		endif;											// 15.06.2023	navcs2	#58434:[58452]
	elseif 	_attrName = ETRow_AllowManEditExtRefChk or 
			_attrName = ETRow_AllowManEditExtRefTxt 
												then		//08/12/2025	navkc1 JIRA 36262
		return self.allowManualEditExternalRef.getYesNo(); 	//08/12/2025	navkc1 JIRA 36262
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringNarr" id="a7e6fe4a-e7ab-4413-bd6c-df932867f192">
        <source>getDisplayStringNarr(_index : Integer) : String;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	narrStr : String;
	narrIdx : Integer;
begin
		if self.arrNarrationDesc.size &lt; _index then
			return null;
		else
			narrStr := self.arrNarrationDesc[_index];
			narrIdx := narrStr[11: end].Integer;
			return self.getNarrationFieldDesc(narrIdx);
		endif;
end;</source>
        <Parameter name="_index" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getInvoiceString" id="9bfc313d-3b6d-4a1a-b29c-3c8093366208">
        <source>getInvoiceString(invoice: CM_Invoice): String;
// ---------------------------------------------------------------------------
// Created:		September 2008 By Andrew Bishop cnwvu1
//
// Purpose:		
//
// Change Date		Who			Reason
// 13/09/2022	navpw1	TFS: 54565 (54384) - EUP - Inv Config - Invoice Surcharges
// 16 March 2023  navmv20 TFS 56128 Task 56129: UI - Manual Invoice Lines - Multi TI Invoice Line Type
// ---------------------------------------------------------------------------
vars
	str							: String;
	surchargesAndExemptions		: CM_InvoiceTypeSurchargeExempt;	// ### TFS 54565 (54384) 13Sep2022 NAVPW1
	invoiceTypeDebtorSeparation	: CM_InvTypeDebtorSeparation;		// ### TFS 54565 (54384) 13Sep2022 NAVPW1
	hasSeparations				: Boolean;							// ### TFS 54565 (54384) 23Sep2022 NAVPW1
	
begin
	str := description.trimRight;

	// ### TFS 54565 (54384) 13Sep2022 NAVPW1
	surchargesAndExemptions := self.mySurchargeAndExemptions;
	if surchargesAndExemptions &lt;&gt; null then
		invoiceTypeDebtorSeparation := surchargesAndExemptions.allInvoiceTypeDebtorSeparation[invoice.debtor];
		
		if invoiceTypeDebtorSeparation &lt;&gt; null then
			hasSeparations := invoiceTypeDebtorSeparation.getHasSeparations();
		endif;
		
	endif;
	// ### TFS 54565 (54384) 13Sep2022 NAVPW1
	
	// ### TFS 54565 (54384) 14Sep2022 NAVPW1
	//16 March 2023  navmv20 TFS 56128 Task 56129 - START
	if self.getMyTerminal() &lt;&gt; null and self.getMyTerminal().getConfig(InvShowAllSeparation).Boolean then
		if invoice.voyageCode &lt;&gt; null then
			str &amp;= " " &amp; invoice.voyageCode.trimRight;
		endif;
		if invoice.myVoyage &lt;&gt; null then
			str &amp;= " " &amp; invoice.myVoyage.voyageGroupCode.trimRight;
		endif;
		if invoice.myTrackedItem &lt;&gt; null then
			str &amp;= " " &amp; invoice.myTrackedItem.id.trimRight;
		endif;
		if invoice.myBOL &lt;&gt; null then
			str &amp;= " " &amp; invoice.myBOL.number.trimRight;
		endif;
		if invoice.myBookingRef &lt;&gt; null then
			str &amp;= " " &amp; invoice.myBookingRef.bookingReference.trimRight;
		endif;
		if invoice.myCargoGroup &lt;&gt; null then
			str &amp;= " " &amp; invoice.myCargoGroup.id.trimRight;
		endif;
		if invoice.myReleaseRequest &lt;&gt; null then
			str &amp;= " " &amp; invoice.myReleaseRequest.code.trimRight;
		endif;
		if invoice.purchaseOrderNumber &lt;&gt; null then
			str &amp;= " " &amp; invoice.purchaseOrderNumber.trimRight;
		endif;
	elseif hasSeparations then
	//if hasSeparations then
	//16 March 2023  navmv20 TFS 56128 Task 56129 - END
		if invoiceTypeDebtorSeparation.separatedByVoyage then
			str &amp;= " " &amp; invoice.voyageCode.trimRight;
		endif;
		
		if invoiceTypeDebtorSeparation.separatedByVoyageGroup then
			if invoice.myVoyage &lt;&gt; null then
				str &amp;= " " &amp; invoice.myVoyage.voyageGroupCode.trimRight;
			endif;
		endif;
		
		if invoiceTypeDebtorSeparation.separatedByCargoId then
			if invoice.myTrackedItem &lt;&gt; null then
				str &amp;= " " &amp; invoice.myTrackedItem.id.trimRight;
			endif;
		endif;
		
		if invoiceTypeDebtorSeparation.separatedByBillOfLading then
			if invoice.myBOL &lt;&gt; null then
				str &amp;= " " &amp; invoice.myBOL.number.trimRight;
			endif;
		endif;
		
		if invoiceTypeDebtorSeparation.separatedByBooking then
			if invoice.myBookingRef &lt;&gt; null then
				str &amp;= " " &amp; invoice.myBookingRef.bookingReference.trimRight;
			endif;
		endif;
		
		if invoiceTypeDebtorSeparation.separatedByCargoGroupId then
			if invoice.myCargoGroup &lt;&gt; null then
				str &amp;= " " &amp; invoice.myCargoGroup.id.trimRight;
			endif;
		endif;
		
		if invoiceTypeDebtorSeparation.separatedByReleaseRequest then
			if invoice.myReleaseRequest &lt;&gt; null then
				str &amp;= " " &amp; invoice.myReleaseRequest.code.trimRight;
			endif;
		endif;
		
		 // ### BUG 56925 07MAR2023 NAVAB1
		if invoiceTypeDebtorSeparation.separatedByPONumber then
			if invoice.purchaseOrderNumber &lt;&gt; null then
				str &amp;= " " &amp; invoice.purchaseOrderNumber.trimRight;
			endif;
		endif;
	else	
		// ### TFS 54565 (54384) 14Sep2022 NAVPW1
		
		if self.isVoyageSpecific() then
		// ### BUG 56925 07MAR2023 NAVAB1elseif self.isVoyageSpecificDebtor(invoice.debtor) then				// ### TFS 54565 (54384) 22Sep2022 NAVPW1
			str := str &amp; " " &amp; invoice.voyageCode.trimRight;
		elseif self.isVoyageGroupSpecific()								// ### TFS 51219 25MAY2021 NAVAB1
		// ### BUG 56925 07MAR2023 NAVAB1elseif self.isVoyageGroupSpecificDebtor(invoice.debtor)				// ### TFS 51219 25MAY2021 NAVAB1 // ### TFS 54565 (54384) 22Sep2022 NAVPW1
		and invoice.myVoyage &lt;&gt; null then									// ### TFS 51219 25MAY2021 NAVAB1
			str := str &amp; " " &amp; invoice.myVoyage.voyageGroupCode.trimRight;	// ### TFS 51219 25MAY2021 NAVAB1
		elseif self.isCargoItemSpecific()
		// ### BUG 56925 07MAR2023 NAVAB1elseif self.isCargoItemSpecificDebtor(invoice.debtor)				// ### TFS 54565 (54384) 22Sep2022 NAVPW1
		then																//Par 17895, September 2008
			if invoice.myTrackedItem &lt;&gt; null then
				str := str &amp; " " &amp; invoice.myTrackedItem.id.trimRight;
			endif;
		endif;
	endif;
	
	if invoice.isManual then
		str := str &amp; ' ' &amp; "(Manual)";
	endif;

	return str;
	
end;</source>
        <Parameter name="invoice" type="CM_Invoice"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getKeyDescription" id="40c97cd2-1f90-4a0f-b647-aba2ae7c86e0">
        <source>getKeyDescription(): String;
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 15/09/2015	cnwdap1		PAR #36909 CCMS ADP 2537 New Invoice Type of BOL
// 22/09/2022	navpw1		TFS: 54565 (54384) - EUP - Inv Config - Invoice Surcharges
vars
	str							: String;
	debtor						: CM_Debtor; 						// ### TFS 54565 (54384) 22Sep2022 NAVPW1
	surchargesAndExemptions		: CM_InvoiceTypeSurchargeExempt;	// ### TFS 54565 (54384) 13Sep2022 NAVPW1
	invoiceTypeDebtorSeparation	: CM_InvTypeDebtorSeparation;		// ### TFS 54565 (54384) 13Sep2022 NAVPW1
	hasSeparations				: Boolean;							// ### TFS 54565 (54384) 23Sep2022 NAVPW1
	debtorSep : CM_InvTypeDebtorSeparation;

begin
	// ### TFS 54565 (54384) 13Sep2022 NAVPW1
	surchargesAndExemptions := self.mySurchargeAndExemptions;
	if surchargesAndExemptions &lt;&gt; null then
		
		foreach invoiceTypeDebtorSeparation in surchargesAndExemptions.allInvoiceTypeDebtorSeparation do
			if str.cnContains(app.getErrorString(Voyage)) 
			and str.cnContains(app.getErrorString(Voyage_group))
			and str.cnContains(app.getErrorString(CargoItem_Name))
			and str.cnContains(app.getErrorString(BillOfLading))
			and str.cnContains(app.getErrorString(Booking))
			and str.cnContains(app.getErrorString(Cargo_group_id))
			and str.cnContains(app.getErrorString(Release_request)) then
				break;
			endif;
			
			if invoiceTypeDebtorSeparation.separatedByVoyage and not str.cnContains(app.getErrorString(Voyage)) then
				str &amp;= app.getErrorString(Voyage) &amp; ", ";
			endif;
			
			if invoiceTypeDebtorSeparation.separatedByVoyageGroup and not str.cnContains(app.getErrorString(Voyage_group)) then
				str &amp;= app.getErrorString(Voyage_group) &amp; ", ";
			endif;
			
			if invoiceTypeDebtorSeparation.separatedByCargoId and not str.cnContains(app.getErrorString(CargoItem_Name)) then
				str &amp;= app.getErrorString(CargoItem_Name) &amp; ", ";
			endif;
			
			if invoiceTypeDebtorSeparation.separatedByBillOfLading and not str.cnContains(app.getErrorString(BillOfLading)) then
				str &amp;= app.getErrorString(BillOfLading) &amp; ", ";
			endif;
			
			if invoiceTypeDebtorSeparation.separatedByBooking and not str.cnContains(app.getErrorString(Booking)) then
				str &amp;= app.getErrorString(Booking) &amp; ", ";
			endif;
			
			if invoiceTypeDebtorSeparation.separatedByCargoGroupId and not str.cnContains(app.getErrorString(Cargo_group_id)) then
				str &amp;= app.getErrorString(Cargo_group_id) &amp; ", ";
			endif;
			
			if invoiceTypeDebtorSeparation.separatedByReleaseRequest and not str.cnContains(app.getErrorString(Release_request)) then
				str &amp;= app.getErrorString(Release_request) &amp; ", ";
			endif;
			
			 // ### BUG 56925 07MAR2023 NAVAB1
			if invoiceTypeDebtorSeparation.separatedByPONumber and not str.cnContains(app.getErrorString(Purchase_order_number)) then
				str &amp;= app.getErrorString(Purchase_order_number) &amp; ", ";
			endif;
			
		endforeach;
		
		if str &lt;&gt; null then
			return str.stripTrailingChar(",");
		endif;
		
	endif;
	// ### TFS 54565 (54384) 13Sep2022 NAVPW1
	
	if self.isVoyageSpecific() then
	 // ### BUG 56925 07MAR2023 NAVAB1if self.isVoyageSpecificDebtor(null) then				// ### TFS 54565 (54384) 22Sep2022 NAVPW1 - Passes null as we do not have an invoice at this stage
		str := app.getErrorString(Voyage);
	elseif self.isVoyageGroupSpecific() then				// ### TFS 51219 25MAY2021 NAVAB1
	 // ### BUG 56925 07MAR2023 NAVAB1elseif self.isVoyageGroupSpecificDebtor(null) then		// ### TFS 54565 (54384) 22Sep2022 NAVPW1 - Passes null as we do not have an invoice at this stage
		str := app.getErrorString(Voyage_group);			// ### TFS 51219 25MAY2021 NAVAB1
	elseif self.isCargoItemSpecific() then
	 // ### BUG 56925 07MAR2023 NAVAB1elseif self.isCargoItemSpecificDebtor(null) then		// ### TFS 54565 (54384) 22Sep2022 NAVPW1 - Passes null as we do not have an invoice at this stage
		str := app.getErrorString( CargoItem_Name );
	elseif self.isBOLSpecific then// PAR #36909
	 // ### BUG 56925 07MAR2023 NAVAB1elseif self.isBOLSpecificDebtor(null) then				// ### TFS 54565 (54384) 22Sep2022 NAVPW1 - Passes null as we do not have an invoice at this stage
		str := app.getErrorString(BillOfLading);			// PAR #36909
	else
		str := app.getErrorString(None);
	endif;

	return str;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNarrationExample" id="bf47aa36-17d2-4622-9ce8-bd317fced2d3">
        <source>getNarrationExample(fieldNo : Integer) : String;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 21 Dec 2016	cnwma1	TFS #2643 :JMT - Audit of Invoice Maintenance Set-up

constants
	None            = "";
	Debtor_Name     = "CAR";
	Voyage_Code     = "3822SWB";
	Vessel_Name     = "Southern Wandering Belle";
	Operator_Code	= "OPER";							// PAR #30860
	Operator_Desc	= "Southern Operators";				// PAR #30860
	
vars
	str : String;
begin
	if fieldNo = CM_InvoiceDesc.Field_None then
		str := None;
	elseif fieldNo = CM_InvoiceDesc.Field_Debtor_Name then
		str := Debtor_Name.trimBlanks;
	elseif fieldNo = CM_InvoiceDesc.Field_Voyage_Code then
		str := Voyage_Code.trimBlanks;
	elseif fieldNo = CM_InvoiceDesc.Field_Vessel_Name then
		str := Vessel_Name.trimBlanks;
	elseif fieldNo = CM_InvoiceDesc.Field_Business_Unit then
		str := app.getProductName() &amp; " Technologies".trimBlanks;
		
		
	elseif fieldNo = CM_InvoiceDesc.Field_Closing_Date then
		str := app.actualTimeServer.date.String;
	elseif fieldNo = CM_InvoiceDesc.Field_Closing_Date_And_Time then
		str := app.actualTimeServer.String;
		
	elseif fieldNo = CM_InvoiceDesc.Field_Voyage_Operator_Code then		// PAR #30860
		str := Operator_Code.trimBlanks;								// PAR #30860
	elseif fieldNo = CM_InvoiceDesc.Field_Voyage_Operator_Desc then		// PAR #30860
		str := Operator_Desc.trimBlanks;								// PAR #30860
	elseif fieldNo = CM_InvoiceDesc.Field_Voyage_Arrival_Date then		// PAR #30860
		str := app.actualTimeServer.date.String;						// PAR #30860
	elseif fieldNo = CM_InvoiceDesc.Field_Voyage_Departure_Date then	// PAR #30860
		str := app.actualTimeServer.date.String;						// PAR #30860
	endif;

	return str;
end;</source>
        <Parameter name="fieldNo" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNarrationFieldDesc" id="cba7de47-b1eb-492b-95de-6731ed4a36dc">
        <source>getNarrationFieldDesc(fieldNo : Integer) : String;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 04/01/2013	cnwdap1		PAR #30860 CCMS QNS 2236 New narrative types
constants
	FIELD_LIST = '"None"' &amp; Tab &amp;
	             '"Debtor name"' &amp; Tab &amp;
	             '"Voyage code"' &amp; Tab &amp;
	             '"Vessel name"' &amp; Tab &amp;
	             '"Business unit name"' &amp; Tab &amp;
	             '"End date"' &amp; Tab &amp;
	             '"End date and time"' &amp; Tab &amp;
				 '"Voyage Operator Code"' &amp; Tab &amp;				// PAR #30860
				 '"Voyage Operator Description"' &amp; Tab &amp;		// PAR #30860
				 '"Voyage Arrival Date (no time)"' &amp; Tab &amp;		// PAR #30860
				 '"Voyage Departure Date (no time)"';			// PAR #30860
vars

begin
	if fieldNo = CM_InvoiceDesc.Field_None then
		return null;
	elseif fieldNo = CM_InvoiceDesc.Field_Debtor_Name then
		return '"Debtor name"';
	elseif fieldNo = CM_InvoiceDesc.Field_Voyage_Code then
		return '"Voyage code"';
	elseif fieldNo = CM_InvoiceDesc.Field_Vessel_Name then
		return '"Vessel name"';
	elseif fieldNo = CM_InvoiceDesc.Field_Business_Unit then
		return '"Business unit name"';
	elseif fieldNo = CM_InvoiceDesc.Field_Closing_Date then
		return '"End date"';
	elseif fieldNo = CM_InvoiceDesc.Field_Closing_Date_And_Time then
		return '"End date and time"';
	elseif fieldNo = CM_InvoiceDesc.Field_Voyage_Operator_Code then		// PAR #30860
		return '"Voyage Operator Code"';								// PAR #30860
	elseif fieldNo = CM_InvoiceDesc.Field_Voyage_Operator_Desc then		// PAR #30860
		return '"Voyage Operator Description"';							// PAR #30860
	elseif fieldNo = CM_InvoiceDesc.Field_Voyage_Arrival_Date then		// PAR #30860
		return '"Voyage Arrival Date (no time)"';						// PAR #30860
	elseif fieldNo = CM_InvoiceDesc.Field_Voyage_Departure_Date then	// PAR #30860
		return '"Voyage Departure Date (no time)"';						// PAR #30860
	endif;

end;</source>
        <Parameter name="fieldNo" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSeparationsDescription" id="01fe9dfe-dfda-4939-95c8-17378dbd8dd9">
        <source>getSeparationsDescription() : String;
/*

Purpose:			Gets the Separations Description (Invoice Key) for the invoice type that is set. Appends "Debtor Separations exist" if it has debtor seprations configured that override this

Parameters:			NONE

Return Value:		String	Representing the invoice key set on the invoice type

Date		Who		Reason
01 November 2022	navpw1	Initial creation TFS: 55235

*/

vars
	str : String;
	
begin
	if self.isVoyageSpecific() then
		str := app.getErrorString(Voyage);
	elseif self.isVoyageGroupSpecific() then
		str := app.getErrorString(Voyage_group);
	elseif self.isCargoItemSpecific() then
		str := app.getErrorString(CargoItem_Name);
	elseif self.isBOLSpecific() then
		str := app.getErrorString(BillOfLading);
	else
		str := app.getErrorString(None);
	endif;
	
	if self.mySurchargeAndExemptions &lt;&gt; null and self.mySurchargeAndExemptions.allInvoiceTypeDebtorSeparation.isNotEmpty then
		str &amp;= " (Debtor Separations Exist)";
	endif;
	
	return str;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getStatusForNewInvoice" id="17333b8b-3f73-4612-94e6-6f191df44440">
        <source>getStatusForNewInvoice( _forcedStatusOpen : Boolean ) : Integer;
// ---------------------------------------------------------------------------
// Created:     12 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	if _forcedStatusOpen then	// Par 17895. We use this when moving invoice lines from Suspense to Open invoices
		return CM_Invoice.INVOICE_OPEN;
	endif;
	
	// Par17895. Every invoice can have Suspense status
	if self.isTriggerOnRelease() then
		return CM_Invoice.INVOICE_SUSPENSE;
	endif;

	return CM_Invoice.INVOICE_OPEN;
epilog

end;</source>
        <Parameter name="_forcedStatusOpen" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getSurcharges" id="a28e9f1d-d272-4b6b-a0c7-e7565e4e954c">
        <updating/>
        <source>getSurcharges( _proformaLinesDebtor : CMIF_ProformaInvLinesForDebtor; _invLineSet : CM_InvoiceLineBySeqNumDict input; _additionalInvoiceLines : CM_InvoiceLineBySeqNumDict input ) updating;
/*
Purpose:	TFS 39349		
Date			Who			Reason
AUGUST 2018		CNWAB1		Initial creation
08.12.2018      cnwma1		Bug 42400: PEL1 - Cash Receipt - Invoice Total and Autocollection Surcharge Line
18 Dec 2018	NDL	TFS 42577 - Lets try another way...
07 May 2019	NDL	TFS 4651 - Tax free invoices with tax!!
06 March 2023	navmk20		Task 56140: EUP Inv Config - Surcharge Logging
23 Oct 2024		navlw1		JIRA-33107: Invoice Logging Use Levels
25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
JIRA 35766 15AUG2025 NAVAB1 added 'SURG' to logging and changed logging levels and added more information.
*/

vars

	debtor : CM_Debtor;
	bank : CM_Bank;
	
	surChgExempt : CM_InvoiceTypeSurchargeExempt;
	minChg : Real;
	minChgInvLineType : CM_InvoiceLineDesc;
	diff : Real;
	remDiff ,
	truncatedDiff: Real;
	
	newLine : CM_InvoiceLine;
	seqNum : Integer;
	charge : CM_Charge;
	
	drSurChgRate : CM_DebtorSurchargeRate;
	drSurchargeRate : Decimal [12,6];
	drSurchgInvLineType : CM_InvoiceLineDesc;
	
	totalSetChgs : Real;
	
	ctSurChgRate : CM_InvTypeCargoSurcharge;
	ctSurchargeRate : Decimal [12,6];
	ctSurchgInvLineType : CM_InvoiceLineDesc;
	
	addFees : CM_InvTypeAdditionalCharges;
	addFeeInvType : CM_InvoiceLineDesc;
	firstinv : CM_InvoiceLine;
	remark : String;
	
	//TFS 38914
	voyage : CM_Voyage;
	vessel : CM_Vessel;
	vessMinCharge : CM_InvTypeVesselMinCharge;
	drMinCharge : CM_InvTypeDebtorMinCharge;
	defaultDebtor : CM_Debtor;
	defaultVessel : CM_Vessel;
	
	//20 Jun 2018	NDL	TFS 39305
	surchargeSet : CM_InvTypeCargoSurchargeSet;
	invoiceLine : CM_InvoiceLine;
	invLineTotal : Decimal [16,6];
	
	//01 Nov 2018	NDL	TFS 41684
	rawDiff : Real;
	effectiveDT : TimeStamp;
	conversionRate : CM_CurrencyRate;
	
//	paymentType : Integer;	//17 Dec 2018	NDL	TFS 42577

	paymentType : Integer;	//26 Mar 2019	NDL	TFS 43687
	workOrder : CM_WorkOrder;	//26 Mar 2019	NDL	TFS 43687
	canLogExtra			: Boolean;	//27.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//27.02.2025 navah1	#34141
	//26 Mar 2019	NDL	TFS 43687
	if _proformaLinesDebtor = null then
		return;
	else
		 debtor := _proformaLinesDebtor.myDebtor;
		 voyage := _proformaLinesDebtor.myVoyage;
		 paymentType := _proformaLinesDebtor.paymentType;
		 workOrder := _proformaLinesDebtor.myWorkOrder;
	endif;

	if self.mySurchargeAndExemptions = null then
		return;
	endif;
	
	if debtor= null then
		return;
	endif;
	
	if _invLineSet = null or _invLineSet.isEmpty then
		return;
	endif;
	
	surChgExempt := self.mySurchargeAndExemptions;
	
	
	//01 Nov 2018	NDL	TFS 41684
	if surChgExempt.myCurrencyType &lt;&gt; null then
		effectiveDT := app.actualTimeAppServer;
		conversionRate := surChgExempt.myCurrencyType.getRate( effectiveDT );
	endif;
	
	defaultDebtor := CM_VoidDebtor.firstInstance;
	defaultVessel := CM_NullVessel.firstInstance;

	firstinv := _invLineSet.first;
	if firstinv &lt;&gt; null then
		bank := firstinv.bank;
	endif;
	
	//17 Dec 2018	NDL	TFS 42577
//	if _workOrder &lt;&gt; null then
//		paymentType := _workOrder.getMyPaymentType();
//	endif;
	
	if paymentType = PaymentType_AutoCollection then	//17 Dec 2018	NDL	TFS 42577, &amp; 18 Dec 2018
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog("SURG - PaymentType is PaymentType_AutoCollection to get Debtor Surcharge Rate", LogINFO.String);	// 6.3.2023 navmk20 TFS 56140
		endif;
		drSurChgRate := surChgExempt.getDebtorSurchargeRate( debtor, defaultDebtor );
		if drSurChgRate &lt;&gt; null then
			drSurchargeRate := drSurChgRate.surchargeRate;
			drSurchgInvLineType := drSurChgRate.getSurchargeInvoiceLineType;
		endif;
	endif;
	
	//26 Mar 2019	NDL	TFS 43687
	self.createMovementMinCharge( _invLineSet, surChgExempt, voyage, effectiveDT, conversionRate, debtor, bank, workOrder );
	
	//Minimum charge code
	//05 Jun 2018	NDL	TFS 38914
	// Only do the firsat one found in order.  Vessel,  Debtor,  or Invoice.
	if voyage &lt;&gt; null then
		vessel := voyage.myVessel;
		if vessel &lt;&gt; null then
			if canLogExtra then	//27.02.2025 navah1	#34141
				app.invLog("SURG - Get surcharges for vessel based minimum charge for debtor/defaultDebtor", LogINFO.String);	// 6.3.2023 navmk20 TFS 56140
			endif;
			vessMinCharge := surChgExempt.getMinVessCharge( vessel, defaultVessel );
			if vessMinCharge &lt;&gt; null then
				minChgInvLineType := vessMinCharge.myMinimumChargeInvoiceLineType;
				minChg := vessMinCharge.minimumChargeAmount;
			endif;
		endif;
		if canLogExtra then	//27.02.2025 navah1	#34141
			if minChgInvLineType = null then
				app.invLog("SURG - No related Vessel based minium charge found", LogINFO.String);
			else
				app.invLog("SURG - Vessel based minium charge found", LogINFO.String);
			endif;
		endif;
	endif;
	
	if minChgInvLineType = null and debtor &lt;&gt; null then
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog("SURG - Get Debtor based minimum charge for debtor/defaultDebtor", LogINFO.String);	// 6.3.2023 navmk20 TFS 56140
		endif;
		drMinCharge := surChgExempt.getMinDebtorCharges( debtor, defaultDebtor );
		if drMinCharge &lt;&gt; null then
			minChgInvLineType := drMinCharge.myMinimumChargeInvoiceLineType;
			minChg := drMinCharge.minimumChargeAmount;
		endif;
		if canLogExtra then	//27.02.2025 navah1	#34141
			if minChgInvLineType = null then
				app.invLog("SURG - No related Debtor based minium charge found", LogINFO.String);
			else
				app.invLog("SURG - Debtor based minium charge found", LogINFO.String);
			endif;
		endif;
	endif;
	
	if minChgInvLineType = null then
		minChgInvLineType := surChgExempt.getMinChargeInvoiceLineType;
		minChg := surChgExempt.minimumChargeAmount;
		if canLogExtra then	//27.02.2025 navah1	#34141
			if minChgInvLineType = null then
				app.invLog("SURG - No Invoice minium charge found", LogINFO.String);
			else
				app.invLog("SURG - Invoice minium charge found", LogINFO.String);
			endif;
		endif;
	endif;
	
	//Minimum charge code
	if minChg &gt; 0 and minChgInvLineType &lt;&gt; null then
		//There is a minimum charge associated with this Invoice Type
		//totalSetChgs := _invLineSet.getTotalAmount();
		totalSetChgs := _invLineSet.getTotalAmountConverted( surChgExempt.myCurrencyType );	//01 Nov 2018	NDL	TFS 41684
		if totalSetChgs &lt;= 0 then	//18 Dec 2018	NDL	TFS 42608
			if canLogExtra then	//27.02.2025 navah1	#34141
				app.invLog("SURG - Invoice Minimum Charge ignored, Invoice total = " &amp; totalSetChgs.String, LogINFO.String);
			endif;
		elseif minChg &gt; totalSetChgs then
			if canLogExtra then	//27.02.2025 navah1	#34141
				app.invLog("SURG - Creating Proforma Invoice line to meet Invoice Minimum Charge", LogINFO.String);
			endif;
			diff := minChg - totalSetChgs;
			seqNum := _invLineSet.getNextSeqNum( _additionalInvoiceLines ); //size + 1;
			remark := "Invoice Total = " &amp; totalSetChgs.String &amp; " " &amp; CM_Invoice.MinCharge &amp;" " &amp; minChg.String &amp; " Difference = " &amp; diff.String; // TFS 38168
			
			//01 Nov 2018	NDL	TFS 41684
			if minChgInvLineType.currencyConversionNotRequired or conversionRate = null or conversionRate.rate = 0 then
				// all good, generate the line as is
			else
				// convert diff to other currency
				rawDiff := diff;
				//diff := rawDiff / conversionRate.rate;
				diff := conversionRate.convertBaseCurrencyToMe( rawDiff, 0 );	//28 Nov 2018	NDL	TFS 42218
				remark := remark &amp; " converted to " &amp; diff.String &amp; "( using " &amp; conversionRate.getDisplayDetails(false) &amp; ")"; 
				if canLogExtra then	//27.02.2025 navah1	#34141
					app.invLog("SURG -  " &amp; remark, LogINFO.String);
				endif;
			endif;
			
			create newLine transient;
			newLine.setForCreate(	seqNum,
									true,
									remark,
									minChgInvLineType,
									null,
									null,
									bank,
									1,
									app.actualTimeServer()
									);
			
			create charge transient;
			charge.setForCreate(	null,
									newLine, 
									Max_Integer,
									null);
			charge.total := diff;
	
			_invLineSet.add( newLine );
			
		endif;
	endif;
	
	//Debtor Surcharge Code
	if drSurchargeRate &gt; 0 and drSurchgInvLineType &lt;&gt; null then
		//There is a surcharge associated with this Invoice Type for this debtor
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog("SURG - Creating Proforma Invoice line for debtor surcharge", LogINFO.String);
		endif;
		//totalSetChgs := _invLineSet.getTotalAmount();
		totalSetChgs := _invLineSet.getTotalAmountConverted( surChgExempt.myCurrencyType );	//01 Nov 2018	NDL	TFS 41684
		
		diff := totalSetChgs * ( drSurchargeRate / 100 );
		
		
		
		//8.12.2018 cnwma1 BuG #42400
		truncatedDiff := diff.truncatedTo(0);
		remDiff := diff - truncatedDiff;
		if remDiff &gt;= .5 then
			truncatedDiff := truncatedDiff +1;
			diff := truncatedDiff;
		endif;
		diff := truncatedDiff;
		 //8.12.2018 cnwma1 BuG #42400
		seqNum := _invLineSet.getNextSeqNum( _additionalInvoiceLines ); //size + 1;
		remark := "Invoice Total = " &amp; totalSetChgs.String &amp; " " &amp; CM_Invoice.DebtorSurchargeRate &amp;" " &amp; drSurchargeRate.String &amp; " Surcharge = " &amp; diff.String; // TFS 38168
		
		//01 Nov 2018	NDL	TFS 41684
		if drSurchgInvLineType.currencyConversionNotRequired or conversionRate = null or conversionRate.rate = 0 then
			// all good, generate the line as is
		else
			// convert diff to other currency
			rawDiff := diff;
			//diff := rawDiff / conversionRate.rate;
			diff := conversionRate.convertBaseCurrencyToMe( rawDiff, 0 );	//28 Nov 2018	NDL	TFS 42218
			remark := remark &amp; " converted to " &amp; diff.String &amp; "( using " &amp; conversionRate.getDisplayDetails(false) &amp; ")"; 
			if canLogExtra then	//27.02.2025 navah1	#34141
				app.invLog("SURG - " &amp; remark, LogINFO.String);
			endif;
		endif;
			
		create newLine transient;
		newLine.setForCreate(	seqNum,
								true,
								remark,
								drSurchgInvLineType,
								null,
								null,
								bank,
								1,
								app.actualTimeServer()
								);
		
		create charge transient;
		charge.setForCreate(	null,
								newLine, 
								Max_Integer,
								null);
		charge.total := diff;
		
		_invLineSet.add( newLine );
		
	endif;
	
	//Cargo Surcharge code	- 20 Jun 2018	NDL	TFS 39305
	if voyage &lt;&gt; null then
		create surchargeSet transient;
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog("SURG - Surcharge charges set and voyage is found and get Cargo Type Surcharges For Voyage", LogINFO.String);	// 6.3.2023 navmk20 TFS 56140
		endif;
		surChgExempt.getCargoTypeSurchargesForVoy( voyage, surchargeSet );
		if not surchargeSet.isEmpty then
			foreach invoiceLine in _invLineSet discreteLock do
				if invoiceLine.status = CM_InvoiceLine.STATUS_VOIDED then
					continue;
				endif;
				ctSurChgRate := surchargeSet.findFirstUsing( invoiceLine.invoiceLineDesc );
				if ctSurChgRate = null then
					//no surcharge to apply
					continue;
				endif;
				
				ctSurchargeRate := ctSurChgRate.surchargeRate;
				ctSurchgInvLineType := ctSurChgRate.getCargoSurchargeInvLineType();
				
				if ctSurchargeRate &gt; 0 and ctSurchgInvLineType &lt;&gt; null then
					//There is a surcharge associated with this Invoice Type for this cargo type
					if canLogExtra then	//27.02.2025 navah1	#34141
						app.invLog("SURG - Creating Proforma Invoice line for cargo type surcharge", LogINFO.String);
					endif;
				//	invLineTotal := invoiceLine.lineTotal;
					invLineTotal := invoiceLine.getLineTotalConverted( conversionRate );	//01 Nov 2018	NDL	TFS 41684
					
					diff := invLineTotal * ( ctSurchargeRate / 100 );	//01 Nov 2018	NDL	TFS 41684
					
					seqNum := _invLineSet.getNextSeqNum( _additionalInvoiceLines ); //size + 1;
					remark := "SURG - Invoice Line Total = " &amp; invLineTotal.String &amp; " " &amp; CM_Invoice.CargoSurchargeRate &amp; " " &amp; ctSurchargeRate.String &amp; " Surcharge = " &amp; diff.String;
					if canLogExtra then	//27.02.2025 navah1	#34141
						app.invLog(remark, LogINFO.String);
					endif;
					//01 Nov 2018	NDL	TFS 41684
					if ctSurchgInvLineType.currencyConversionNotRequired or conversionRate = null or conversionRate.rate = 0 then
						// all good, generate the line as is
					else
						// convert diff to other currency
						rawDiff := diff;
						//diff := rawDiff / conversionRate.rate;
						diff := conversionRate.convertBaseCurrencyToMe( rawDiff, 0 );	//28 Nov 2018	NDL	TFS 42218
						remark := remark &amp; " converted to " &amp; diff.String &amp; "( using " &amp; conversionRate.getDisplayDetails(false) &amp; ")"; 
						if canLogExtra then	//27.02.2025 navah1	#34141
							app.invLog("SURG - " &amp; remark, LogINFO.String);
						endif;
					endif;
						
					create newLine transient;
					newLine.setForCreate(	seqNum,
											true,
											remark,
											ctSurchgInvLineType,
											null,
											debtor,
											bank,
											1,
											app.actualTimeServer()
											);
					
					create charge transient;
					charge.setForCreate(	null,
											newLine, 
											Max_Integer,
											null);
					charge.total := diff;
					
					_invLineSet.add( newLine );
				endif;
				
			endforeach;
		endif;
	endif;
	
	
	//Additional Fees	TFS 37819
	totalSetChgs := _invLineSet.getTotalAmountConverted( surChgExempt.myCurrencyType );
	if canLogExtra then	//27.02.2025 navah1	#34141
		app.invLog("SURG - Get surcharges for debtor/totalSetChgs/defaultDebtor to get Invoice Type Add Fees For Invoice Total", LogINFO.String);	// 6.3.2023 navmk20 TFS 56140
	endif;
	addFees := surChgExempt.getInvTypeAddFeesForInvTotal( debtor, totalSetChgs, defaultDebtor );
	if addFees &lt;&gt; null then
		foreach addFeeInvType in addFees.allAdditionChargeInvTypes do
			if canLogExtra then	//27.02.2025 navah1	#34141
				app.invLog("SURG - Creating Proforma Invoice line for debtor additional fees", LogINFO.String);
			endif;
			seqNum := _invLineSet.getNextSeqNum( _additionalInvoiceLines ); //size + 1;
			
			create newLine transient; // TFS 38168
			remark := "Debtor = " &amp; addFees.getNiceName(); // TFS 38168

			newLine.setForCreate(	seqNum,
									true,
									remark,
									addFeeInvType,
									null,
									debtor,
									bank,
									1,
									app.actualTimeServer()
									);
									
			newLine.createChargesProforma(seqNum);
			_additionalInvoiceLines.add( newLine );
			
		endforeach;
	endif;

epilog

	delete surchargeSet;

end;</source>
        <Parameter name="_proformaLinesDebtor" type="CMIF_ProformaInvLinesForDebtor"/>
        <Parameter name="_invLineSet" type="CM_InvoiceLineBySeqNumDict" usage="input"/>
        <Parameter name="_additionalInvoiceLines" type="CM_InvoiceLineBySeqNumDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTriggerOnActionString" id="ec0279df-96fe-4f83-aa79-555f45507616">
        <source>getTriggerOnActionString() : String;
/* ---------------------------------------------------------------------------
Created:	08 September 2008	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	str : String;

begin

	return app.invTypeTriggerEnumToString( self.triggerOnAction );

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="hasDebtorSeparationAccrual" id="9d7b94ec-f470-4e2d-88ae-e8dea272a1e4">
        <source>hasDebtorSeparationAccrual(_debtor : CM_Debtor) : Boolean;
/*

Purpose:			Checks whether we have an accrual type for a debtor separation. If we do returns true, else returns false

Parameters:			_debtor	CM_Debtor	The debtor to check

Return Value:		Boolean	Returns true if we have an accrual type for the debtor

Date				Who		Reason
06 October 2022		navpw1	Initial creation TFS: 54565 (54384)
01 November 2022	navpw1	TFS: 55285 - Added a lookup for the default debtor (RDT) in case a config exists for this debtor but not the debtor we are searching for
*/

vars
	surchargesAndExemptions		: CM_InvoiceTypeSurchargeExempt;
	invoiceTypeDebtorSeparation	: CM_InvTypeDebtorSeparation;
	
begin
	surchargesAndExemptions := self.mySurchargeAndExemptions;
	
	if surchargesAndExemptions = null then
		return false;
	endif;
	
	invoiceTypeDebtorSeparation := surchargesAndExemptions.allInvoiceTypeDebtorSeparation[_debtor];
	
	if invoiceTypeDebtorSeparation = null then
		//Check for default debtor
		invoiceTypeDebtorSeparation := surchargesAndExemptions.allInvoiceTypeDebtorSeparation[self.company.rootDebtor];
		if invoiceTypeDebtorSeparation = null then
			return false;
		endif;
	endif;
	
	if invoiceTypeDebtorSeparation.myAccrualType = null then
		return false;
	endif;
	
	return true;
	
end;</source>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="healthCheckIsValid" id="b76abaf1-16fe-4140-9604-696db7022243">
        <source>healthCheckIsValid(_agent : CMIF_InvoiceHealthAgent) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 November 2017	jlgab1	Initial creation

*/

vars

	message : String;
	resultType : Integer;
	detail : CMIF_InvoiceHealthAgentDetail;
	term : CM_Terminal;
	bu : CM_Bank;
begin
	
	bu := self.getBank();
	if bu = null then
		return true;
	endif;
	if not _agent.allBusinessUnits.includes(bu) then
		return true;
	endif;
	
	// ### INVOICE LINE TYPE
	if _agent.checkTypesToQuery.includes(CMIF_InvoiceHealthAgent.CheckType_InvoiceLineType)
	and not self.healthCheckCollection(self.invoiceLineDescriptors, resultType) then
		create detail transient;
		detail.setForCreate(_agent, CMIF_InvoiceHealthAgent.CheckType_InvoiceLineType, self.description, CMIF_InvoiceHealthAgent.ItemType_InvoiceType, self.getMyTerminal(), resultType, self);
		return false;
	endif;
	
	// ### FINANCIAL PERIODS
	if _agent.checkTypesToQuery.includes(CMIF_InvoiceHealthAgent.CheckType_FinancialPeriods)
	and not self.healthCheckObject(self.myFinancialPeriodEnd, resultType) then
		create detail transient;
		detail.setForCreate(_agent, CMIF_InvoiceHealthAgent.CheckType_FinancialPeriods, self.description, CMIF_InvoiceHealthAgent.ItemType_InvoiceType, self.getMyTerminal(), resultType, self);
		return false;
	endif;
	
	// ### TERMS OF TRADE
	if _agent.checkTypesToQuery.includes(CMIF_InvoiceHealthAgent.CheckType_TermsTrade)
	and not self.healthCheckObject(self.myInvTermsOfTrade, resultType) then
		create detail transient;
		detail.setForCreate(_agent, CMIF_InvoiceHealthAgent.CheckType_TermsTrade, self.description, CMIF_InvoiceHealthAgent.ItemType_InvoiceType, self.getMyTerminal(), resultType, self);
		return false;
	endif;

epilog

end;</source>
        <Parameter name="_agent" type="CMIF_InvoiceHealthAgent"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initialise" id="090fc07c-447a-4db0-b2a9-1c01109f1439">
        <updating/>
        <source>initialise(_pxyInvoiceDesc : CM_InvoiceDesc) updating;
// parameter added for 35872 to get the company
vars

begin
	self.number := _pxyInvoiceDesc.company.getSeqNum(SN_INVOICETYPE);
end;</source>
        <Parameter name="_pxyInvoiceDesc" type="CM_InvoiceDesc"/>
    </JadeMethod>
    <JadeMethod name="initialiseSelectionParameter" id="29ee9569-1333-4bff-8308-c37ea6cedd94">
        <source>initialiseSelectionParameter(param: CMIF_InvoiceSelection input; tran: CM_TITransaction;
				_isManual : Boolean; _voyageCode, _tiId, _bolNumber : String );
//
// Changed On	By			Reason
// ----------	--------	------------------------------------------------
// 16/09/2015	cnwdap1		PAR #36909 CCMS ADP 2537 Added Bill of Lading options, _bolNumber parameter
// 28/07/2017	cnwdap1		TFS 5397 PKT Merge transactions taking wrong quantity for invoice line
// 22/09/2022	navpw1		TFS: 54565 (54384) - EUP - Inv Config - Invoice Surcharges
vars
	cargoSpecific	: Boolean;
	voyage			: CM_Voyage;
	
begin
	param.myBank := self.company;
	
	if param.myBank &lt;&gt; null then
		param.myTerminal := param.myBank.terminal;
	endif;
	param.invoiceTypeNumber := number;
	param.myInvoiceType := self.company.invoiceTypes[number];	// ### TFS 54565 (54384) 29Aug2022 NAVPW1
	// Note: the code below under the cargoSpecific test does the cargo tests - don't need to repeat here
	//cargoSpecific := self.isCargoItemSpecific();
	cargoSpecific := self.isCargoItemSpecific();				// ### TFS 54565 (54384) 22Sep2022 NAVPW1 - Passes null as theres no invoice
	
	// ### TFS 54565 (54384) 29Aug2022 NAVPW1
	if param.hasinvDebtorSeparation() then
		param.populateSelectionParameters(tran, _isManual, _voyageCode, _tiId, _bolNumber);
		
	// ### TFS 54565 (54384) 29Aug2022 NAVPW1
		
	//if self.isVoyageSpecific() then
	elseif self.isVoyageSpecific() then			// ### TFS 54565 (54384) 29Aug2022 NAVPW1
		if _isManual then
			param.voyageCode := _voyageCode;
		else
			if tran &lt;&gt; null then
				//and tran.myTrackedItem.myVoyage &lt;&gt; null then
				// 29752 sometimes using export voyage not import for tranships
				//  	transaction voyage has already been adjusted for tranships
				// modified for 29957 to keep the ability to change TI voyage and re-evaluate invoice line to new invoice (based on the new voyage)
				//		only use the transaction voyage for a tranship
				if tran.myTrackedItem &lt;&gt; null then
					if tran.myTrackedItem.isTranshipItem then
						voyage := tran.getVoyage();
						if voyage &lt;&gt; null then
							param.voyageCode := voyage.code;
						endif;
					elseif tran.myTrackedItem.myVoyage &lt;&gt; null then
						param.voyageCode := tran.myTrackedItem.myVoyage.code;
					endif;
				endif;
			endif;
		endif;
	// ### TFS 51219 25MAY2021 NAVAB1
	elseif self.isVoyageGroupSpecific() then
		if tran &lt;&gt; null then
			if tran.myTrackedItem &lt;&gt; null then
				if tran.myTrackedItem.isTranshipItem then
					voyage := tran.getVoyage();
					if voyage &lt;&gt; null then
						param.voyageGroupCode := voyage.voyageGroupCode;
						param.invoiceKey := self.invoiceKey; // ### TFS 51219 28MAY2021 NAVAB1
					endif;
				elseif tran.myTrackedItem.myVoyage &lt;&gt; null then
					param.voyageGroupCode := tran.myTrackedItem.myVoyage.voyageGroupCode;
					param.invoiceKey := self.invoiceKey; // ### TFS 51219 28MAY2021 NAVAB1

				endif;
			endif;
		endif;
	elseif cargoSpecific then	// Par 17895, September 2008
		if _isManual then
			param.trackedItemId := _tiId;
		else
			if tran &lt;&gt; null and
			   tran.myTrackedItem &lt;&gt; null then
				// TFS 5397 For Merge transactions where one TI is being merged into another		// TFS 5397
				// (NOT the same ID), we want the search to look for an invoice line for			// TFS 5397
				// the TI we're merging into														// TFS 5397
				if tran.isKindOf(CM_Merge) 															// TFS 5397
				and ((tran.myTrackedItem.totalWeight = null and tran.myTrackedItem.isBulkByWeight) 	// TFS 5397
				or (tran.myTrackedItem.totalVolume = null and tran.myTrackedItem.isBulkByVolume))	// TFS 5397
				and tran.CM_Merge.getOtherTrackedItem &lt;&gt; null then									// TFS 5397
					param.trackedItemId := tran.CM_Merge.getOtherTrackedItem.id;					// TFS 5397
				else																				// TFS 5397
					param.trackedItemId := tran.myTrackedItem.id;
				endif;																				// TFS 5397
			endif;
		endif;
		
	elseif self.isBOLSpecific then										// PAR #36909
		if _isManual then												// PAR #36909
			param.bolNumber := _bolNumber;								// PAR #36909
		else															// PAR #36909
			if tran &lt;&gt; null and tran.myTrackedItem &lt;&gt; null then			// PAR #36909
				param.bolNumber := tran.myTrackedItem.billOfLading;		// PAR #36909
			endif;														// PAR #36909
		endif;															// PAR #36909
		
	endif;
	
end;</source>
        <Parameter name="param" type="CMIF_InvoiceSelection" usage="input"/>
        <Parameter name="tran" type="CM_TITransaction"/>
        <Parameter name="_isManual" type="Boolean"/>
        <Parameter name="_voyageCode" type="String"/>
        <Parameter name="_tiId" type="String"/>
        <Parameter name="_bolNumber" type="String"/>
    </JadeMethod>
    <JadeMethod name="isBOLSpecific" id="2d6f3b0e-1c49-4dd7-8313-22b48b879b8a">
        <source>isBOLSpecific() : Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 15/09/015	cnwdap1		Initial creation PAR #36909 CCMS ADP 2537 New Invoice Type of BOL
//
vars

begin
	return self.invoiceKey = self.Key_BOL;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isBOLSpecificDebtor" id="1a21a695-dd39-4356-afe4-81f52b2289a7">
        <source>isBOLSpecificDebtor(_debtor : CM_Debtor) : Boolean;
/*

Purpose:			Checks if a Debtor Separation exists for BOL

Parameters:			_debtor	CM_Debtor	The debtor to check

Return Value:		Boolean Representing whether the debtor does or doesn't have spearations

Date				Who		Reason
21 September 2022	navpw1	Initial creation TFS: 54565 (54384)
01 November 2022	navpw1	TFS: 55285 - Added a lookup for the default debtor (RDT) in case a config exists for this debtor but not the debtor we are searching for
*/

vars
	surchargesAndExemptions		: CM_InvoiceTypeSurchargeExempt;
	invoiceTypeDebtorSeparation	: CM_InvTypeDebtorSeparation;
	
begin
	surchargesAndExemptions := self.mySurchargeAndExemptions;
	
	if surchargesAndExemptions = null then
		return self.isBOLSpecific();
	endif;
	
	if surchargesAndExemptions.allInvoiceTypeDebtorSeparation.isEmpty then
		return self.isBOLSpecific();
	endif;
	
	invoiceTypeDebtorSeparation := surchargesAndExemptions.allInvoiceTypeDebtorSeparation[_debtor];
	
	if invoiceTypeDebtorSeparation = null then
		//Check for default debtor
		invoiceTypeDebtorSeparation := surchargesAndExemptions.allInvoiceTypeDebtorSeparation[self.company.rootDebtor];
		if invoiceTypeDebtorSeparation = null then
			return self.isBOLSpecific();
		endif;
	endif;
	
	return invoiceTypeDebtorSeparation.separatedByBillOfLading;
	
end;</source>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isBOLSpecificSeparation" id="6adadbd3-e97a-4911-bdee-ad1748594d58">
