    <JadeMethod name="doRemoveGateArea" id="d7397c17-89e4-4836-8c9e-c30be8c76729">
        <source>doRemoveGateArea()protected;
// ---------------------------------------------------------------------------
// Created:     22 July 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	usage	:CM_GateAreaUsage;
begin
	usage	:= self.getSelected_GateAreaUsage;
	
	if usage = null then
		return;
	endif;
	
	self.myProxyObject.CM_Gate.pxyRemoveGateAreaUsage (usage);
	
	// redisplay gate areas
	self.loadGateAreas (self.myProxyObject.CM_Gate);
epilog

end;</source>
