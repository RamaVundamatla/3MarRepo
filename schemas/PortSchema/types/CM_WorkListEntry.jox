    <JadeMethod name="getRequestSourceLocnTI" id="ae62f916-6826-4957-afc9-65a3d4e9bea3">
        <source>getRequestSourceLocnTI(_ti : CM_TrackedItem output) : CM_LocationsController;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 December 2012	cnwer1	Initial creation par 30385
10 Jul 2025	navhl20 Bug MTN-35305: MTN - Optimize Saving Road Jobs to Avoid Redundant Yard Allocation Checks
06 Oct 2025 navhl20 Story MTN-36133: MTN - Optimize Saving Road Jobs to Avoid Redundant Yard Allocation Checks when auto plan is failed
*/

vars
	sourceTa		: CM_TerminalArea;
	yaPlan			: CMIF_YAAutoPlan;
	sourceLocn 		: CM_LocationsController;
	terminal 		: CM_Terminal;
	foundHeight		: Integer;
begin
	
	
	if self.myRequest = null then
		return null;
	endif;
	terminal:=self.getMyTerminal;
	terminal.findLocationFromString(self.locationSource,true,sourceLocn,foundHeight);				//10.07.2025 navhl20 #35305
	if sourceLocn &lt;&gt; null then																		//10.07.2025 navhl20 #35305
		return sourceLocn;
	endif;
	
	// 23023 do director task if not best-pick; also just scan this area
	// 26671 Refactored code to remove duplication
	if self.isBestPick then		// 23098
		//jlier1 MTN-35637 17/9/25  - this now takes into account request terminal areas
		_ti := app.sourceTisForRequestBestPick(terminal, self, sourceTa, true,null);
		if _ti &lt;&gt; null then
			sourceLocn := _ti.allLocations.first;
		endif;
	endif;
		
	// If we are best pick we should have a source location or have exited
	/*
	//06.10.2025 navhl20 #36133 Already doing YA check from arbiter
	if sourceLocn = null then
		sourceLocn	:= app.sourceTisForRequestYA(terminal, self.myRequest);
		//28 June 2012	NDL	Par 29778 - Check for YA being a best pick
		if app.myYAAgent &lt;&gt; null then
			yaPlan := app.myYAAgent.myCurrentCMIFYAAutoPlan;
			if yaPlan &lt;&gt; null and yaPlan.myFirstUsedYA &lt;&gt; null and yaPlan.myFirstUsedYA.fillOptionOut = YAFillOption_BestPick then // best pick YA
				_ti := yaPlan.allFoundTis.first;
			endif;
		endif;
	endif;*/

	return sourceLocn;
epilog
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="output"/>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="getRequestType" id="42e84aae-da14-4a30-81bc-4d809a9dc6ee">
        <source>getRequestType() : Integer;
/*
Method:			getRequestType();	
Author:     cnwspg1 created on 24 January 2000
Description: Used to replace the functionality of getWLStat function in vb

Fixes:
Date        User      Description
--------    --------  ------------------
*/

constants

vars
	ioType : Integer;
	reqType : Integer;

begin
	//epr par 33221 3/3/14
	if self.myRequest = null then
		return REQ_UNDEFINED;
	endif;
	
	sharedLock(self.myRequest);
	if self.myRequest.isKindOf(CM_DeliveryRequest) then
		reqType := REQ_ISO_RELEASE;
	else
		ioType := getIoType;
		if ioType = Rail_JSIO_Type_Out then
			reqType := REQ_TI_RELEASE;
		elseif ioType = Rail_JSIO_Type_In then
			reqType := REQ_TI_RECEIPT;
		else
			reqType := REQ_UNDEFINED;
		endif;
	endif;
	return reqType;
epilog
	unlock(self.myRequest);
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getRequestTypeString" id="a3d1189e-5d37-46fd-9ba6-719777c0cfe0">
        <source>getRequestTypeString() : String;
/*
Method:			getRequestType();	
Author:     cnwspg1 created on 24 January 2000
Description: Used to replace the functionality of getWLStat function in vb

Fixes:
Date        User      Description
--------    --------  ------------------
*/

constants

vars
	reqType : Integer;
	str		: String;
begin

	if self.myTrackedItem &lt;&gt; null then
		str := self.myTrackedItem.myCargoType.description;
	endif;
	
	if str &lt;&gt; null then
		return str;
	endif;
	
	reqType := self.getRequestType();
	
	if reqType = REQ_ISO_RELEASE then
		str := 'Container';
	elseif reqType = REQ_TI_RELEASE then
		str := 'Generic';
	elseif reqType = REQ_TI_RECEIPT then
		str := 'Generic';
	elseif reqType = REQ_TI_WORKORDER then //cnwrd1 1075 6.8.09
		str := 'Work Order';
	elseif reqType = REQ_UNDEFINED then
		str := 'Undefined';
	endif;
	
	return str;
end; </source>
        <ReturnType type="String"/>
    </JadeMethod>
