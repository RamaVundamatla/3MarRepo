        <source>zDoUpdateDetailShow()updating, protected;
// ---------------------------------------------------------------------------
// Created:     02 April 2004	cnwth2
//
// Purpose:     Shows the detail entry frame for updating the currently selected detail line
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if self.mode = self.Mode_View then
		if self.myCurrentMasterObject = null then
			app.msgBox('There is no currently selected ' &amp; self.getDataEntityDescription(true) &amp; ' to add a line to', app.getErrorString(Nothing_Selected), MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
		
		if self.myCurrentDetailObject = null then
			app.msgBox('There is no currently selected ' &amp; self.getDataEntityDescription(false) &amp; ' to update', app.getErrorString(Nothing_Selected), MsgBox_Exclamation_Mark_Icon);
