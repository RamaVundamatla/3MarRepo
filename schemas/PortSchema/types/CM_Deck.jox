    <JadeMethod name="getAllStateDataObject" id="a61f057a-be62-4a94-ae3b-79c6aed36156">
        <source>getAllStateDataObject() : CM_StateDataDict;
/*
Purpose:			
Date		Who		Reason
17 January 2012	cnwab1	Initial creation
*/

vars
	allStateData : CM_StateDataDict;
	tmpVessel : CM_Vessel;
	newCode : String;
begin


	tmpVessel := self.getVessel();
	
	if tmpVessel  &lt;&gt; null then
		allStateData:= tmpVessel.allStateData;
		if allStateData = null or allStateData.size = 0 then
			allStateData:= app.myRoot.getStateObject(ConfigGrp_System).allStateData;
		endif;
	else
		allStateData:= app.myRoot.getStateObject(ConfigGrp_System).allStateData;
	endif;

	return allStateData;
epilog

end;</source>
        <ReturnType type="CM_StateDataDict"/>
    </JadeMethod>
