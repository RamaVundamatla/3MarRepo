    <JadeMethod name="wsRESTPostVoyage" id="6d8d343c-a672-4979-b4de-0081beae5652">
        <source>wsRESTPostVoyage(_loginString: String; json: String; expectErrors: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
19 April 2023	navlw1	Initial creation CR 57560 CUX - MTN-EDBIC - Process Voyage - Unit Tests

*/

vars
	request				: WS_RestVoyageArray;
	requestLogin		: WS_RESTLoginAuthRequest;
	webService			: MasterTerminalAPIService;
	parser				: JadeJson;
	transientJSONObjs	: ObjectArray;
	response 			: WS_Response;
	login 				: WS_InterfaceObject;
	jsonLogin			: String;
	responseLogin  		: WS_NAuthTokenResponse;
	ref 				: String;
	jsonFormat			: String;
	newJson 			: String;
begin

	create webService transient;
	create transientJSONObjs transient;
	create parser transient;
	
	// call PUT /login
	requestLogin := parser.parse(_loginString, WS_RESTLoginAuthRequest, transientJSONObjs).WS_RESTLoginAuthRequest;
	webService.setPropertyValue(WS_RestWebServiceProvider::requestPath.name, "/login");
	
	login := webService.postLogin(requestLogin);
	if not login.isKindOf(WS_NAuthTokenResponse) then
		delete login;
		if webService.httpStatusCode = HttpResponseUnauthorized then
			return HttpResponseUnauthorized.String &amp; " Unauthorized - Username / Password not OK";
		endif;
		return "Login failed";
	endif;
	
	responseLogin := login.WS_NAuthTokenResponse;
	webService.unitTestData.addAssoc("HTTP_AUTHORIZATION", "Bearer " &amp; responseLogin.accessToken);
	
	// set up the WS_Request object
	webService.setPropertyValue(WS_RestWebServiceProvider::requestPath.name, "/voyage");
	request := parser.parse(json, WS_RestVoyageArray, transientJSONObjs).WS_RestVoyageArray;
	
	// call the post/voyage
	response := webService.postVoyage(request);
	
	// If we're expecting to fail, then return early
	if expectErrors then
		if webService.httpStatusCode = HttpResponseOK then
			return "Failure expected, got 200 OK";
		endif;
		return response.WS_Response.allErrors.first.text;
	endif;
	
	if webService.httpStatusCode &lt;&gt; HttpResponseOK then
		if response.allErrors.size &gt; 0 then
			app.writeLog(response.allErrors.first.text, LogERROR);
		endif;
		return method.qualifiedName &amp; " Bad Response Code, expecting 200 OK, got " &amp; webService.httpStatusCode.String &amp; ". Check UnitTest runner logs for more details" &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	endif;
	
	return null;
	
	// Not used,just here to provide a reference from the super schema super class method 
	ref := CM_UnitTestAgent::wsRESTPostVoyage.name;

epilog
	if webService.objectsToBeDeleted.isNotEmpty then
		webService.objectsToBeDeleted.purge;
	endif;
	delete webService;
	delete parser;
	delete requestLogin;
	delete request;
	transientJSONObjs.purge();
	delete transientJSONObjs;
end;</source>
