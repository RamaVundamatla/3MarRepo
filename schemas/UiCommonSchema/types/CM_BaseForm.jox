	self.lblModalInfo.caption := _lblInfo;
	self.lblModalInfo.alignment := Frame.Alignment_Center_Middle;
	self.lblModalInfo.fontBold := false;
	self.lblModalInfo.move(lblModalMessage.left, pbProgressBar.top + pbProgressBar.height + 2, lblModalInfo.width, lblModalInfo.height);
	self.lblModalInfo.visible := true;
	
