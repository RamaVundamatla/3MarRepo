    <JadeMethod name="valUpdateJobAction" id="31699fbe-d42c-4691-805f-be6c5f83e14a">
        <source>valUpdateJobAction(_job : CM_Job; _action : Integer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14/03/2024	navkc1 CR 62896 Task 62897: Jade - Job Create Transactions and Events

*/

vars

begin
	if 	_action &lt;&gt; Job_Action_Start and
		_action &lt;&gt; Job_Action_Stop and
		_action &lt;&gt; Job_Action_Resume and
		_action &lt;&gt; Job_Action_Complete 
		then
		
		app.raiseCMException(InvalidJobAction, null, null);
		
	endif;
epilog

end;</source>
