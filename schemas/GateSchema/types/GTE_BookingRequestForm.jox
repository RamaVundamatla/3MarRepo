    <JadeMethod name="loadBooking" id="6ccf5333-c53a-41f1-bdd2-928dcdb0f5da">
        <updating/>
        <source>loadBooking()updating;

vars
	br : CM_BookingRef;
	bulkRel : CM_BulkRelease;
	str : String;
	obj : Object;
begin
	
	if self.myCurrentBookingRef = null then
		//self.lblBookStatusVal.caption := " Pending";							//-cnwml2 PAR19782 CCMS SFW 1079
		return;
	endif;
	
	if self.myCurrentBookingRef &lt;&gt; null then
		self.loadFromBookingRef(self.myCurrentBookingRef);
	endif;
	
	bulkRel := self.myRealReleaseRequest;
	if bulkRel &lt;&gt; null then
		self.loadFromBulkRelease(bulkRel);
	endif;
	if self.hasAdditionalDetails() then
		self.chkAdditionalReq.value := true;
		self.showHideAdditionalDetails();
	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="loadBookingItemTable" id="c4952653-be67-4e36-823f-62343210e9d2">
        <source>loadBookingItemTable();

vars
	proxy	: CM_BookingRef;
	table	: CM_DataTable;
	idx		: Integer;
	item 	: CM_BookingRefItem;
begin 
	proxy := self.myProxyBookingRef;
	
	if proxy = null then
		return;
	endif;
	
	table := self.tblBookingItems;
	
	table.rows 						:= 1;
	table.accessSheet(1).scrollMode := Table.ScrollMode_HorzPixel_VertCell;
	table.multiSelect 				:= CM_BaseTable.MultiSelect_Simple;							//+cnwml2 PAR19782 CCMS SFW 1079

	foreach item in proxy.allBookingRefItems do
		idx := table.updateItemObject(item, self.colorRow1, self.colorRow2, app.myPassport);
	endforeach;
	
	table.allSelectedObjects.clear; // cnwrd1 par 28792 5.12.2011
	
	self.loadTotals(proxy);
end;
	</source>
    </JadeMethod>
    <JadeMethod name="loadCmbBookStatus" id="cc65cab7-276f-4010-b4f8-edbda3efeb65">
        <source>loadCmbBookStatus();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 May 2009	cnwml2	Initial creation			//+cnwml2 PAR19782 CCMS SFW 1079
23 Jun 2009	cnwdad1	PAR #20032 - default to "Active".
*/
begin
	self.cmbBookingStatus.sorted := false;
	self.cmbBookingStatus.addItem(app.getErrorString(Pending));
	self.cmbBookingStatus.addItem(app.getErrorString(Active));
	self.cmbBookingStatus.addItem(app.getErrorString(Closed));
	self.cmbBookingStatus.addItem(app.getErrorString(Archived));
	
	if self.myCurrentBookingRef = null then
		self.cmbBookingStatus.text := app.bookingRefStatusEnumToString(BOOKING_REF_ACTIVE);
	elseif self.myCurrentBookingRef.status = BOOKING_REF_PENDING then
		cmbBookingStatus.text := app.bookingRefStatusEnumToString(BOOKING_REF_PENDING);
	elseif self.myCurrentBookingRef.status = BOOKING_REF_ACTIVE then
		cmbBookingStatus.text := app.bookingRefStatusEnumToString(BOOKING_REF_ACTIVE);
	elseif self.myCurrentBookingRef.status = BOOKING_REF_CLOSED then
		cmbBookingStatus.text := app.bookingRefStatusEnumToString(BOOKING_REF_CLOSED);
	elseif self.myCurrentBookingRef.status = BOOKING_REF_ARCHIVED then
		cmbBookingStatus.text := app.bookingRefStatusEnumToString(BOOKING_REF_ARCHIVED);
	else
		cmbBookingStatus.text := app.bookingRefStatusEnumToString(BOOKING_REF_ACTIVE);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadCmbCustomsAgent" id="bfe3de15-b239-49ea-b2f5-3d46a1bfdbd1">
        <source>loadCmbCustomsAgent() protected;

/*
Purpose:	Load all of the possible customsAgents and select the one chosen

Date				Who		Reason
18 February 2010	cnwrl1	Initial creation as part of PAR 22393 = CCMS 1073 - Enhanced Interfaces for Messina Go Live
14 March 2016		cnwdap1	PAR #37606 Allow a previously valid but now "not available for entry" customs agent to be displayed
*/
	
vars
	customsAgent, agent	: CM_CustomsAgent;
	
begin
	if self.myCurrentBookingRef &lt;&gt; null then
		//customsAgent := app.myRoot.allCustomsAgents[ self.myCurrentBookingRef.customsAgent ];
		// PAR 26922 - change to use new method
		customsAgent := self.myCurrentBookingRef.getCustomsAgentObject();
	endif;
	
	self.cmbCustomsAgent.setObject(customsAgent);									// PAR #37606
	self.myAssistant.comboBoxCustomsAgent( self.cmbCustomsAgent, customsAgent );
epilog
	
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadCmbFromVoyage" id="d7ede160-3eec-4acd-bf2c-a6b93b3eaf4b">
        <source>loadCmbFromVoyage();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 May 2009	cnwml2	Initial creation		//+cnwml2 PAR19782 CCMS SFW 1079

*/

vars
	voy : CM_Voyage;
	operator : CM_Operator;
	iter : Iterator;
	passport : CM_Passport;
	failedDAC  :CM_DataAccessController;
	tmpStr	: String;
	idx 	: Integer;
	
	gracePeriod : Integer;
	checkDT : TimeStamp;
begin
	passport    := app.myPassport;
	checkDT     := app.actualTimeServer();
	operator    := self.cmbOperator.listObject.CM_Operator;
	gracePeriod := self.myTerminal.getConfig(VoyDepartedGracePeriod).Integer;
	
	if gracePeriod = null then
		gracePeriod := 24;
	endif;
	checkDT := checkDT.changeByXXHours(-gracePeriod);	
	
	self.cmbFromVoyage.clear;
	
	if operator &lt;&gt; null then	
		iter := self.myTerminal.allVoyagesByCode.createIterator;			//+cnwml2 PAR22407

		while iter.next(voy) do
			if voy.myTerminal &lt;&gt; self.myTerminal then									//+cnwml2  PAR20835
				continue;																//+cnwml2  PAR20835
			endif;																		//+cnwml2  PAR20835
			
			if voy.isCancelled then  //jlier1 TFS51963 5/10/21
				continue;
			endif;
			
			if not voy.isActiveDisplay(checkDT) then		
				continue;
			endif;	

			if voy = self.cmbVoyage.listObject.CM_Voyage then
				continue;
			endif;
			
			if not voy.allOperators.includes(operator) then								//+cnwml2 PAR22407
				continue;																//+cnwml2 PAR22407
			endif;																		//+cnwml2 PAR22407
			
			if not voy.canUserAccessSelf(null, failedDAC, passport) then
				continue;
			endif;
			
			tmpStr := voy.code &amp; Tab &amp; voy.description;
			idx    := cmbFromVoyage.addItem(tmpStr);
			self.cmbFromVoyage.itemObject[idx] := voy;
	
		endwhile;
	else
		iter := self.myTerminal.allVoyagesNew.createIterator;
	
		while iter.next(voy) do
			if voy.myTerminal &lt;&gt; self.myTerminal then									//+cnwml2  PAR20835
				continue;																//+cnwml2  PAR20835
			endif;																		//+cnwml2  PAR20835
						
			if voy.isCancelled then //epr tfs 51963 5/10/21
				continue;
			endif;

			if not voy.isActiveDisplay(checkDT) then		
				continue;
			endif;	
			
			if voy = self.cmbVoyage.listObject.CM_Voyage then
				continue;
			endif;
			
			if not voy.canUserAccessSelf(null, failedDAC, passport) then
				continue;
			endif;
			
			tmpStr := voy.code &amp; Tab &amp; voy.description;
			idx    := cmbFromVoyage.addItem(tmpStr);
			self.cmbFromVoyage.itemObject[idx] := voy;
	
		endwhile;
	endif;
		
epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadCmbPackAs" id="be48dc0e-51a9-4e95-8ed3-a8b055d1333b">
        <source>loadCmbPackAs();
//06 November 2009	cnwml2
//+cnwml2 MSL CCMS 1012

vars

begin
	self.cmbPackAs.sorted := false;
	self.cmbPackAs.addItem("");
	self.cmbPackAs.addItem(app.getErrorString(PackAs_FCL));
	self.cmbPackAs.addItem(app.getErrorString(PackAs_LCL));
	self.cmbPackAs.addItem(app.getErrorString(PackAs_S));

	
	if self.myCurrentBookingRef = null then
		self.cmbPackAs.text := "";
	elseif self.myCurrentBookingRef.packAs = BOOKING_PACKAS_FCL then
		self.cmbPackAs.text := app.bookingPackAsEnumToString(BOOKING_PACKAS_FCL);
	elseif self.myCurrentBookingRef.packAs = BOOKING_PACKAS_LCL then
		self.cmbPackAs.text := app.bookingPackAsEnumToString(BOOKING_PACKAS_LCL);
	elseif self.myCurrentBookingRef.packAs = BOOKING_PACKAS_S then
		self.cmbPackAs.text := app.bookingPackAsEnumToString(BOOKING_PACKAS_S);
	else
		self.cmbPackAs.text := "";
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadCmbTransType" id="012f7f47-5eaf-42f7-88f5-312f9fe5f2e3">
        <source>loadCmbTransType();
//29 September 2009	cnwml2
//
// Changed on	By			Reason
// ==========	========	====================================================
// 11/08/2011	cnwdap1		PAR #27972 Bulk Release type no longer translatable, changed value of BR_TYPE_PACKING
//										so it will find the right string value in app.transModeToString

vars

begin
	self.cmbTransType.sorted := false;
	// PAR #27972 translatable request type replaced by string value
	self.cmbTransType.addItem(BR_TYPE_ROAD_STR);
	self.cmbTransType.addItem(BR_TYPE_RAIL_STR);
	self.cmbTransType.addItem(BR_TYPE_PACKING_STR); // cnwrd1 POL packing stuff CCMS 2103 par 27856
	
	if	self.myCurrentBookingRef = null then
		self.cmbTransType.text := app.transModeToString(BR_TYPE_ROAD);
	elseif self.myCurrentBookingRef.allReleaseRequests.first = null then
		self.cmbTransType.text := app.transModeToString(BR_TYPE_ROAD);
	elseif self.myCurrentBookingRef.allReleaseRequests.first.type = BR_TYPE_ROAD then
		self.cmbTransType.text := app.transModeToString(BR_TYPE_ROAD);
	elseif self.myCurrentBookingRef.allReleaseRequests.first.type = BR_TYPE_RAIL then
		self.cmbTransType.text := app.transModeToString(BR_TYPE_RAIL);
	elseif self.myCurrentBookingRef.allReleaseRequests.first.type = BR_TYPE_PACKING then // cnwrd1 POL packing stuff CCMS 2103 par 27856
		self.cmbTransType.text := app.transModeToString(BR_TYPE_PACKING);		
	else
		self.cmbTransType.text := app.transModeToString(BR_TYPE_ROAD);
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadCmbVoyage" id="f8e81a6f-e4c8-458d-87cb-e42121c70469">
        <source>loadCmbVoyage();
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 May 2009	cnwml2	Initial creation		//+cnwml2 PAR19782 CCMS SFW 1079
01 Nov 2011	cnwdap1	PAR #28524 CCMS POL 2096 Display "Hold" Voyage 
07 Jul 2018 cnwma1	Bug 39476: SNO - "No info voyage" during booking creation
*/
vars
	voy : CM_Voyage;
	operator : CM_Operator;
	iter : Iterator;
	passport : CM_Passport;
	failedDAC  :CM_DataAccessController;
	tmpStr	: String;
	idx 	: Integer;
	
	gracePeriod : Integer;
	checkDT : TimeStamp;
	foundMatch : Boolean;
	selectedVoy : CM_Voyage;
	holdVoyStr : String;		// PAR #28524
	holdVoyage : CM_Voyage;		// PAR #28524
begin
	operator	 := self.cmbOperator.listObject.CM_Operator;
	iter     	:= self.myTerminal.allVoyagesByCode.createIterator;			//+cnwml2 PAR22407
	selectedVoy := self.cmbVoyage.listObject.CM_Voyage;						//09/03/2010 cnwdz2 par22564
	
	self.cmbVoyage.clear;
	
	passport := app.myPassport;
	
	gracePeriod := self.myTerminal.getConfig(VoyDepartedGracePeriod).Integer;
	if gracePeriod = null then
		gracePeriod := 24;
	endif;
	
	checkDT := app.actualTimeServer();
	checkDT := checkDT.changeByXXHours(-gracePeriod);	
	
	while iter.next(voy) do
		
		if voy.myTerminal &lt;&gt; self.myTerminal then									//+cnwml2  PAR20835
			continue;																//+cnwml2  PAR20835
		endif;				
		//+cnwml2  PAR20835
		
		if voy.isCancelled then  //jlier1 TFS51963 5/10/21
			continue;
		endif;
		
		if not voy.isActiveDisplay(checkDT) then		
			continue;
		endif;	
		//07.07.2018 TFS #39476 
		if not voy.isNullVoyage () then
			if not voy.allOperators.includes(operator) then								//+cnwml2 PAR22407
				continue;																//+cnwml2 PAR22407
			endif;																		//+cnwml2 PAR22407
		endif;
		
		if not voy.canUserAccessSelf(null, failedDAC, passport) then
			continue;
		endif;
		
		tmpStr  := voy.code &amp; Tab &amp; voy.description;
		idx 	:= cmbVoyage.addItem(tmpStr);
		self.cmbVoyage.itemObject[idx] := voy;
		if selectedVoy = voy then  //09/03/2010 cnwdz2 par22564
			foundMatch := true;    //09/03/2010 cnwdz2 par22564
		endif;
	endwhile;
	
	// PAR #28524 if operator has "Bookings are Unique by Number" set, display "Hold" voyage in combo
	if operator &lt;&gt; null then	//29 Mar 2012	NDL	Par 29294
		if operator.bookingsUniqueByNumber then
			holdVoyStr := self.myTerminal.getConfig(HoldVoyageCode).String;
			if holdVoyStr &lt;&gt; null then
				holdVoyage := self.myTerminal.allVoyagesByCode.getAtKeyGeq(holdVoyStr, null);
				if holdVoyage &lt;&gt; null and holdVoyage.code = holdVoyStr then
					idx := self.cmbVoyage.addItem(holdVoyage.code &amp; Tab &amp; holdVoyage.description);
					self.cmbVoyage.itemObject[idx] := holdVoyage;
				endif;
			endif;
		endif;
	endif;

	//09/03/2010 cnwdz2 par22564
	if foundMatch then
		self.cmbVoyage.listObject := selectedVoy;
	else
		self.cmbVoyage.listObject := null;
	endif;
epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadCombos" id="ebe80d81-614b-476c-a4cc-5df85e6ce052">
        <source>loadCombos();
//
// 13/10/209	cnwdap1	PAR #20872 Consignee and Consignor combo boxes showed ALL consignees AND consignors in both combos
//									Now just display appropriate entries
vars
	assistant : GTE_Assistant;
begin
	assistant := self.myAssistant.GTE_Assistant;
	// Destination Port
	self.cmbDestinPort.myAssistant := assistant;
	// Discharge port	
	self.cmbDischargePort.myAssistant := assistant;
	
	self.cmbTranshipPort.myAssistant := assistant;
	// Load Port
	self.cmbLoadPort.myAssistant := assistant;
	
	self.loadCmbCustomsAgent();					// cnwrl1 17/02/2010 PAR 22393
	
	assistant.comboSpecialStow(self.cmbSpecialStow);
	assistant.comboCustomerPriority(self.cmbPriority);
	assistant.comboDeliveryRelReason(self.cmbDelivRelReasn);
	
	// load Optional Ports List
	assistant.listTableDischarge(self.lstOptionalPorts, null, null);	
	// load Hazards List
	self.lstHazards.loadHazardObjects;
	assistant.resetHazardListTable(self.lstHazards);
	
	//load Special Lift List
	assistant.listTableSpecialLift(self.lstSpecialLift);						//+cnwml2 PAR20173 SFW CCMS 1091
	
	// Voyage
	assistant.comboBoxVoyageCurrent(cmbVoyage,
									null,
									true,
									false,
									false,
									true,
									true,
									false,
									true,
									false,
									false); //epr par 34857 CCMS 2374
									
	//From Voyage
		assistant.comboBoxVoyageCurrent(self.cmbFromVoyage,
									null,
									true,
									false,
									false,
									true,
									true,
									false,
									true,
									false,
									true);
	
	self.loadCmbBookStatus();
	
	self.loadCmbTransType();
	
	self.loadCmbPackAs();
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="f17a41cf-f9b7-4df0-ab67-072470cb7d7f">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 May 2009	cnwml2	Initial creation		//+cnwml2 PAR19782 CCMS SFW 1079

*/

vars

begin
	
	inheritMethod();
	//self.loadCmbBookStatus();
	

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadFromBookingRef" id="d149ed2f-9efe-43eb-bac1-9a74bc968f99">
        <updating/>
        <source>loadFromBookingRef(br :CM_BookingRef )updating;
//-----------------------------------------
// Created : by cnwaer1 25 August 2008
//-----------------------------------------
// 21 May 2011	cnwcs5		CCMS SCT 2058/par 27460 - add carrier reference
// 27 May 2013	cnwdap1		PAR #31596 Added Freight Forwarder
// 14 Mar 2016	cnwdap1		PAR #37606 Allow for "not available for entry" entries
// 02 Oct 2020  cnwma1 		ChangeRequest 50112: ASPA - GCI Stevedores
vars
	assistant : GTE_Assistant;
	str : String;
	obj : Object;
	haz : CM_Hazard;
	hazard : CM_TIHazard;
	bulk : CM_BulkRelease;
	intStatus : Integer;
	strArray : StringArray;
	spLift : CM_SpecialLift;

begin
	assistant := self.myAssistant.GTE_Assistant;
	
	
	// Booking Reference name
	self.txtBookingRef.text := br.bookingReference;	
	
	// Operator
	self.cmbOperator.setObject(br.myOperator);
	
	// Voyage
	assistant.comboBoxVoyageCurrent(cmbVoyage,
									br.myVoyage,
									true,
									false,
									false,
									true,
									true,
									false,
									true,
									false,
									false); //epr par 34857 CCMS 2374
	
	// Vessel Name - Arrival Date Time
	if br.myVoyage &lt;&gt; null then
		self.lblVoyageDisplay.caption := "  " &amp; br.vesselName &amp;"        "&amp; self.systemToLocalTime(br.myVoyage.arrivedDT).asStringJMT;	// 13/7/16 cnwmp6 TFS 488 - Multi timezone support
		// Optional Ports
		assistant.listTableDischarge(self.lstOptionalPorts, br.myVoyage, null);
		assistant.setListTablePorts(self.lstOptionalPorts, br.allDischargePorts);
		str := self.lstOptionalPorts.getSelectedString('code');
		if str.length &gt; 30 then
			self.txtOptDischPort.text := str[1:29]&amp; '...';
		else
			self.txtOptDischPort.text := str;
		endif;
	else
		self.lblVoyageDisplay.caption :=br.vesselName;
	endif;
	str := null;
	
	//Special Lift
	assistant.listTableSpecialLift(self.lstSpecialLift);
	create strArray transient;
	foreach spLift in br.allSpecialLifts do
		strArray.add(spLift.code);
	endforeach;
	assistant.setListTableSpecialLift(self.lstSpecialLift, strArray);
	str := self.lstSpecialLift.getSelectedString('code');
	if str.length &gt; 30 then
		self.txtSpecialLift.text := str[1:29]&amp; '...';
	else
		self.txtSpecialLift.text := str;
	endif;
	
	// Hazards
	self.lstHazards.loadHazardObjects;
	self.lstHazards.setSelectedFromObject(self.myCurrentBookingRef);
	self.closeLstAndDisplayTxtHazards();
	
	// Destination Port
	self.cmbDestinPort.myAssistant := assistant;
	self.cmbDestinPort.showAllDestinations := true;
	if br.destinationPort &lt;&gt; null then
		 self.cmbDestinPort.setObject(app.myRoot.allPorts[br.destinationPort]);	
	endif;
	
	//Load Port
	//self.cmbLoadPort.setObject(app.myRoot.allPorts[app.getMyTerminalConfig(PortDestCode).String]);					//+cnwml2 PAR19782 CCMS SFW 1079  		//-cnwml2 PAR20164 SFW CCMS 1091
	
	// Discharge port	
	self.cmbDischargePort.myAssistant := assistant;
	self.cmbDischargePort.myVoyage:=br.myVoyage;
	self.cmbTranshipPort.myAssistant := assistant;
	self.cmbTranshipPort.myVoyage:=br.myVoyage;
	if br.dischargePort &lt;&gt; null then
		self.cmbDischargePort.setObject(app.myRoot.allPorts[br.dischargePort]);
	endif;
	self.cmbTranshipPort.setObjectAndVoyageDischPort(self.cmbDischargePort.listObject.CM_Port,null);
	if br.myTranshipToPort &lt;&gt; null then
		self.cmbTranshipPort.setObject(br.myTranshipToPort);
	endif;
	
	// Shipper
	if br.myConsignor &lt;&gt; null then
		self.cmbConsignor.setObject(app.myRoot.allConsigneeConsignors[br.myConsignor.code]);						//+cnwml2 PAR22371
	else
		self.cmbConsignor.setObject(app.myRoot.allConsigneeConsignors[br.consignorDesc]);							//+cnwml2 PAR22371
	endif;
	
	// Consignee
	if br.myConsignee &lt;&gt; null then
		self.cmbConsignee.setObject(app.myRoot.allConsigneeConsignors[br.myConsignee.code]);						//+cnwml2 PAR22371
	else
		self.cmbConsignee.setObject(app.myRoot.allConsigneeConsignors[br.consigneeDesc]);							//+cnwml2 PAR22371
	endif;
	
	// Freight Forwarder
	if br.myFreightForwarder &lt;&gt; null then																			// PAR #31596
		self.cmbFreightFwdr.setObject(app.myRoot.allConsigneeConsignors[br.myFreightForwarder.code]);				// PAR #31596
	endif;																											// PAR #31596
	
	// Stevedore
	if br.myStevedore &lt;&gt; null then
		self.cmbStevedore.setObject(app.myRoot.allStevedores[br.myStevedore.code]);                                 //02.10.2020 cnwma1 TFS #50112
	endif;
	
	// SpecialStow
	if br.mySpecialStow &lt;&gt; null then
		self.cmbSpecialStow.setIndexFromObject(br.mySpecialStow);  //CCMS 1028 par 21746, cnwjo3
	endif;
	
	//Shipping Reference
	if br.shippingReference &lt;&gt; null then
		self.txtShipRef.text := br.shippingReference;
	endif;
	
	// Carrier reference
	if br.operatorReferenceNumber &lt;&gt; null then					// par 27460 cnwcs5
		self.txtCarrierRef.text	:= br.operatorReferenceNumber;	// par 27460 cnwcs5
	endif;														// par 27460 cnwcs5
	
	// Customer Priority
	if br.myCustomerPriority &lt;&gt; null then
		self.cmbPriority.setIndexFromObject(app.myRoot.allCustomerPriorities[br.myCustomerPriority.code]);
	endif;
	
	// Customs Agent																				// PAR #37606
	if br.customsAgent &lt;&gt; null then																	// PAR #37606
		self.cmbCustomsAgent.setIndexFromObject(app.myRoot.allCustomsAgents[br.customsAgent]);		// PAR #37606
	endif;																							// PAR #37606
	
	// All the checkboxes
	self.chkHoldPartials.value 	:= br.holdPartials;
	self.chkNoFullsIn.value 	:= br.noFullIsAllowedIn;
	self.chkNoEmptiesOut.value 	:= br.noEmptiesOut;
	self.chkMilitary.value 		:= br.isMilitary;
	if self.chkMilitary.value = false 	then
		self.lblMilitaryVNum.enabled := false;
		self.txtVNum.enabled := false;
	endif;

	self.chkReconciled.value	:= br.reconciliation;
	self.chkOverrideCut.value 	:= br.overrideCutoff;
	self.chkOverDimension.value := br.overDimension;
	self.chkFumigation.value	:= br.fumigationNeeded;
	self.chkStopped.value 		:= br.isStopped;
	self.chkReceiveAsStoc.value := br.isStockBookingRef;											//+cnwml2 PAR19782 CCMS SFW 1079
	self.chkReceiveAsStoc.change(self.chkReceiveAsStoc);
	self.chkDirDel.value := br.directDelivery;
	
	//+cnwml2 PAR19782 CCMS SFW 1079
	
	//+cnwml2 MSL CCMS 1012
	self.chkRecieveAsTran.value := br.receiveAsTranship;
	self.chkRecieveAsTran.change(self.chkRecieveAsTran);
	
	if br.myTranshipVoyage &lt;&gt; null then
		assistant.comboBoxVoyageCurrent(self.cmbFromVoyage,
									br.myTranshipVoyage,
									true,
									false,
									false,
									true,
									true,
									false,
									true,
									false,
									true);
	endif;
	
	self.txtVNum.text := br.vNumber;
	self.txtVNum.enabled := br.isMilitary;
	self.lblMilitaryVNum.enabled := br.isMilitary;
	//Remarks
	self.txtRemarks.text := br.bookingRefRemarks;
	self.doRemarksChange;
	
	self.loadTotals(br);
	
epilog
	delete strArray;
end;</source>
        <Parameter name="br" type="CM_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="loadFromBulkRelease" id="4852533b-075d-49ce-84f9-fbad72ddeeb4">
        <updating/>
        <source>loadFromBulkRelease(_bulkRel : CM_BulkRelease) updating;
//-----------------------------------------
//
// Created : by cnwaer1 25 August 2008
//-----------------------------------------
vars
	carrier : CM_Carrier;
	packLocn,
 	str,
	taString	: String;
	termArea : CM_TerminalArea;
	taSet : CM_TerminalAreaSet;
begin
	// Load Port
	self.cmbLoadPort.myAssistant := self.myAssistant;
	self.cmbLoadPort.showAllDestinations := true;
	if _bulkRel.myLoadPort &lt;&gt; null then
		 self.cmbLoadPort.setObject(app.myRoot.allPorts[_bulkRel.myLoadPort.code]);	
	endif;
	self.txtDispatchLocn.text := _bulkRel.dispatchLocation;
	self.cmbDelivRelReasn.setObject(app.myRoot.getDeliveryReleaseReason(_bulkRel.deliveryReasonDescr));
	self.cmbPoolPartner.setObject(_bulkRel.myPoolPartner);
	//self.chkReservedOnly.value := not _bulkRel.releaseByType;
	//self.btnReserve.enabled:=self.chkReservedOnly.value;
	//self.mnuReserve.enabled:=self.chkReservedOnly.value;
	//self.chkPreventSubs.value := _bulkRel.preventEquivTypes;
	//Carrier
	carrier := app.myRoot.allCarriers[_bulkRel.carrierId];
	self.myAssistant.comboBoxCarrier(self.cmbCarrier, carrier);
	// Dispatch Locn - not yet defined
	
	//Release Status
	self.lblRelStatusVal.caption := "  " &amp; _bulkRel.statusString;
	

	// cnwrd1 ccms pol 2103 par 27856 14.7.2011
	if _bulkRel.dateEstimatedRequired &lt;&gt; null then
		self.dtPackBy.setDate( _bulkRel.dateEstimatedRequired.date );
	endif;
	
	self.txtDelReleaseNo.text := _bulkRel.deliveryReleaseNumber;
	
	self.myAssistant.listTablePackLocations(self.lstPackLocations);
	self.lstPackLocations.clearAllSelected();
	
	create taSet transient;
	
	foreach taString in _bulkRel.allPackLocations do
		termArea := self.myTerminal.allTerminalAreas[taString];
		if termArea &lt;&gt; null then
			taSet.add(termArea);
		endif;
	endforeach;
	self.lstPackLocations.setSelected(taSet);
/*
	foreach packLocn in _bulkRel.allPackLocations do
		self.lstPackLocations.setSelectedString( packLocn);
	endforeach;	
	*/

	str := self.lstPackLocations.getSelectedString('id');
	if str.length &gt; 30 then
		self.txtPackLocations.text := str[1:29]&amp; '...';
	else
		self.txtPackLocations.text := str;
	endif;
	
epilog
	delete taSet;
end;</source>
        <Parameter name="_bulkRel" type="CM_BulkRelease"/>
    </JadeMethod>
    <JadeMethod name="loadTotals" id="efc0e1ab-4141-4a82-b138-e81e06545fda">
        <source>loadTotals(_br : CM_BookingRef);
/*
Date		Who		Reason
26 Nov 2008	cnwer1	Initial creation
12 Jun 2013	cnwcs5	par 31670 - used getReceivedCount instead of numOnsiteTIs
*/

vars
	bulk : CM_BulkRelease;
begin 
	self.lblQuanVal.caption		:= _br.getTotalQuantity.asStringJMT;
	self.lblRecVal.caption		:= _br.getRecievedCount.asStringJMT;									// cnwcs5 par 31670
	self.lblWeightVal.caption 	:= _br.getTotalWeight.roundedTo(0).asStringJMT;							//+cnwml2 PAR19782 CCMS SFW 1079

	bulk := _br.allReleaseRequests.first.CM_BulkRelease;
	
	if bulk &lt;&gt; null then
		self.lblRelVa.caption		:= bulk.getTotalReleased.asStringJMT;
		self.lblMaxVal.caption		:= bulk.getTotalMaxToRelease.asStringJMT;
		self.lblReserveVal.caption	:= bulk.getTotalAssigned.asStringJMT;
	else
		self.lblRelVa.caption 		:= "0";																//+cnwml2 PAR20819
		self.lblMaxVal.caption 		:= "0";																//+cnwml2 PAR20819
		self.lblReserveVal.caption 	:= "0";																//+cnwml2 PAR20819
	endif;
	
epilog

end;</source>
        <Parameter name="_br" type="CM_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="loadValidOptDischargePort" id="d7aefcbd-dc33-4e15-8505-4f0df555a580">
        <source>loadValidOptDischargePort(_selVoyage		: CM_Voyage);
//-----------------------------------------
//
// Created : by cnwaer1 22 August 2008
//-----------------------------------------
vars
	
	assistant		: GTE_Assistant;

	str 			: String;
	portsArray 		: StringArray;
	port 			: Object;
begin
	create portsArray transient;
	
	assistant := self.myAssistant.GTE_Assistant;

	
	assistant.listTableDischarge(self.lstOptionalPorts, _selVoyage, null);
	// if existing bookingRef then tick boxes only for the saved ones
	
	foreach port in self.lstOptionalPorts.allSelectedObjects do
		if _selVoyage = null or 
			 _selVoyage.allPorts.includes(port.CM_Port) then
				portsArray.add(port.CM_Port.code);
			endif;
	endforeach;
	
	
	assistant.setListTablePorts(self.lstOptionalPorts, portsArray);
	str := self.lstOptionalPorts.getSelectedString('code');
	if str.length &gt; 30 then
		self.txtOptDischPort.text := str[1:29]&amp; '...';
	else
		self.txtOptDischPort.text := str;
	endif;
	
epilog
	delete portsArray;
end;</source>
        <Parameter name="_selVoyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="loadValidSpecialLifts" id="7240b940-7344-4590-8f10-398758f6697f">
        <source>loadValidSpecialLifts();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 July 2009	cnwml2	Initial creation

*/

vars
	assistant		: GTE_Assistant;

	str 			: String;
	spLiftArray		: StringArray;
	specialLift 			: Object;
begin
	create spLiftArray transient;
	
	assistant := self.myAssistant.GTE_Assistant;

	
	assistant.listTableSpecialLift(self.lstSpecialLift);
	// if existing bookingRef then tick boxes only for the saved ones
	
	foreach specialLift in self.lstSpecialLift.allSelectedObjects do
		spLiftArray.add(specialLift.CM_SpecialLift.code);
	endforeach;
	
	
	//assistant.setListTablePorts(self.lstOptionalPorts, portsArray);
	str := self.lstSpecialLift.getSelectedString('code');
	if str.length &gt; 30 then
		self.txtSpecialLift.text := str[1:29]&amp; '...';
	else
		self.txtSpecialLift.text := str;
	endif;
	
epilog
	delete spLiftArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="lstHazardsGotFocus" id="91187098-b4ad-4f5c-82c7-bd70dbb2df3c">
        <source>lstHazardsGotFocus();
//-----------------------------------------
//
// Created : by cnwaer1 25 August 2008
//-----------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------
// 08/07/2015	cnwdap1		PAR #36421 Hazardous Materials Handling 
vars

begin
	//frame setup
	
	self.frmHazards.top := self.txtHazards.top + 1;
	self.frmHazards.height := 100;
	//self.frmHazards.width := self.txtHazards.width;			// PAR #36421
	self.frmHazards.width := self.txtHazards.width + 50;		// PAR #36421
	self.frmHazards.left := self.txtHazards.left +3;
	
	//list setup
	self.lstHazards.top :=0;
	self.lstHazards.left := 0;
	self.lstHazards.height :=self.frmHazards.height-1;
	self.lstHazards.width := self.frmHazards.width-1;
	
	self.frmHazards.visible := true;
	//self.frmHazards.tabStop:= false;							//-cnwml2 PAR19884 SFW CCMS 1079
	self.frmHazards.zOrder(1);
	//self.lstHazards.setFocus();
	self.lstHazards.setFocus();									//+cnwml2 PAR19884 SFW CCMS 1079
	self.lstHazards.selectMode := 6;
	self.txtHazards.visible := false;

end;</source>
    </JadeMethod>
