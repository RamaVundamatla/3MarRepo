    <JadeMethod name="validateForCreate" id="bd68f43a-1e47-43d7-a11e-c9d7d08d98fd">
        <source>validateForCreate(_includeStructure : Boolean; _conflictManager : CMIF_HMS_ConflictsManager output; _passport : CM_Passport input);
//--------------------------------------------------------------
//Created: 10 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	if app.myRoot.allVessels[self.code] &lt;&gt; null then
		app.raiseCMException2(ERR_INVALID_VALUE, 'Vessel Code', self.code &amp; " Is Already in Use",null, null);
	
	endif;
	self.validateMe(_includeStructure, _conflictManager, _passport);
end;</source>
        <Parameter name="_includeStructure" type="Boolean"/>
        <Parameter name="_conflictManager" type="CMIF_HMS_ConflictsManager" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="ee8bee59-20b9-4c86-8a6b-67db0b4a119c">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:     16 January 2002 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//06 Oct 2017	cnwma1  TFS #7257 JMT - Refactoring - Commodity Planning
// ---------------------------------------------------------------------------
vars
	whereUsed : String;

begin
	
	// PAR 11529
	// Need to warn users if vessel has future voyages
	// As per converstion with Toni Henderson 23/03/2006
	if self.myHMSVesselData &lt;&gt; null then
		//epr par 16379 only allow deletion when all voyages have been deleted
		if self.myRootForVessel.checkVesselHasHMSVoyage(self.code.trimBlanks, app.actualTimeServer) then
			app.raiseCMWarning2(HMSConfirmDelete, 'Vessel ' &amp; self.name, 'Voyage', null, null, self);		
			return;
		endif;
	endif;
	
	if app.myRoot.client = Client_JadeMaster then
		//Don't delete this vessel as it is used for benchmarking
		if self.code = "PTN" and not app.isJMTUnitTest then					// 30/05/2012 cnwmh5
			/*app.raiseCMStringOnlyException(self.class.name &amp;  '::' &amp; method.name &amp; ' &gt;&gt; Please do not delete vessel ' &amp; self.name &amp; ' ' &amp;
			 ' ' &amp; 'as it is being used for benchmark testing.');		 */ //- cnwmd1, Par 20524
			 //Dev system exception - no translation required
			app.raiseUnexpectedProgramError(self.class.name, method.name, ' &gt;&gt; Please do not delete vessel ' &amp; self.name &amp; ' ' &amp;
			 ' ' &amp; 'as it is being used for benchmark testing.');
			return;
		endif;
	endif;
	
	//10 Nov 2020	NDL	TFS 50279
	if self.isUsedinConfig( whereUsed ) then
		app.raiseCMException2(ERR_CANNOT_DELETE, self.code, whereUsed, null, self);
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="f067cd97-53f0-4def-80cf-40de27bac62b">
        <source>validateForUpdate(_includeStructure : Boolean; _conflictManager : CMIF_HMS_ConflictsManager output; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     10 July 2002 by cnwrs2
// ---------------------------------------------------------------------------
vars
	realVessel,
	existingVessel : CM_Vessel;
begin

	self.validateMe(_includeStructure, _conflictManager, _passport);

	if _passport.noErrors then
		existingVessel := app.myRoot.allVessels[self.code];
		realVessel := self.pxyGetRealObject();
		if existingVessel &lt;&gt; null then
			if realVessel &lt;&gt; null then
				if existingVessel &lt;&gt; realVessel then
					app.raiseCMException1(VB_DUPLICATED_ITEM, self.code, null, null);
				endif;
			else
				app.raiseCMException1(VB_DUPLICATED_ITEM, self.code, null, null);
			endif;
		endif;
		if realVessel &lt;&gt; null then
			if self.code &lt;&gt; realVessel.code then
			endif;
		endif;
	endif;
	
end;</source>
        <Parameter name="_includeStructure" type="Boolean"/>
        <Parameter name="_conflictManager" type="CMIF_HMS_ConflictsManager" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="e0cc7447-51a4-4396-be6d-d1ee7894d469">
        <source>validateMe(_includeStructure : Boolean; _conflictManager : CMIF_HMS_ConflictsManager output; _passport : CM_Passport input) protected;
//--------------------------------------------------------------
//Created: 10 July 2002 By: cnwgd1
//06 Oct 2017	cnwma1  TFS #7257 JMT - Refactoring - Commodity Planning
//10/09/2019 	JLGNS1	Bug 46446: ADP - RE: JMT Error

//--------------------------------------------------------------
vars
	tmpStr 		: String;
	proxyTData	: CM_VesselTerminalData;
	
begin

	if self.code = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Vessel Code', null, null);
		app.raiseCMException(Input_required_field_VesselCod, null, null); // cnwdb2	PAR 35364
	endif;
	
	if self.name = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'Vessel Name', null, null);
	 	app.raiseCMException(Input_required_field_vesName, null, null); // cnwdb2	PAR 35364
	endif;
	
	if self.lloydsNumber &lt;&gt; null and not self.lloydsNumber.cnIsNumeric then
		app.raiseCMException1(Value_field_must_integer,app.getErrorString(Lloyds_number),"",null);	//Bug 46446
	endif;
	
	//epr 11/3/14 removing voyage commodity planning as part of bulk CCMS 1366
	
	if self.myHMSVesselData &lt;&gt; null then
		self.myHMSVesselData.validate(_conflictManager, _passport);
	endif;

	if self.myGeneralCargoVesselStructure &lt;&gt; null then
		self.myGeneralCargoVesselStructure.validateUpdate(_passport);
	endif;	

	if self.myOperator = null then
		tmpStr := app.getTerminologyAlternate(null,	_passport.myTerminal, CM_TerminologyOperator, CM_TermExpressionSingular, 'Operator');
	//	app.raiseCMException1(REQUIRED_FIELD, tmpStr, null, null);
		app.raiseCMException1(Input_required_field_Required, tmpStr, null, null); // cnwdb2	PAR 35364
	endif;	
	
	if self.yearOfBuild &lt;&gt; null and (self.yearOfBuild &lt; 1900 or self.yearOfBuild &gt; 2100) then	//cnwas3 par 27454
	//	app.raiseCMWarning1(INVALID_FIELD,app.getErrorString(Year_build),null,null,null);
		app.raiseCMWarning(Year_build35364,null,null,null); // cnwdb2 PAR 35364
	endif;
	
	/*//06.10.2017	cnwma1  TFS #7257
	foreach proxyTData in self.allTerminalDatas do
		proxyTData.validateMe();
	endforeach;
	*/
end;</source>
        <access>protected</access>
        <Parameter name="_includeStructure" type="Boolean"/>
        <Parameter name="_conflictManager" type="CMIF_HMS_ConflictsManager" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateUpdateForSLWS" id="b4edd51a-272f-4fd0-a09c-f1d235a7a3ef">
        <source>validateUpdateForSLWS();
/*
Purpose:			
Date		Who		Reason
21 January 2014	cnwab1	Initial creation
*/

vars

begin
	if self.myCellularVesselStructure = null then
		app.raiseCMException2(ERR_INVALID_VALUE,"Vessel Update", "Vessel " &amp; self.code &amp; "  does not have a LOLO structure. For this reason it cannot be edited.", null, null);
	
	endif;
	
	self.myCellularVesselStructure.validateUpdateForSLWS();
epilog

end;</source>
    </JadeMethod>
</Class>
