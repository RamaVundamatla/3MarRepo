<CollClass name="StringArray">
    <JadeMethod name="addTruncated" id="68732640-e4b9-4b29-b4ab-3ace30379293">
        <lockReceiver/>
        <updating/>
        <source>addTruncated(_value : String) updating;

/*

Purpose:		Add the passed string into the array, truncating it if necessary


Return Value:	None


Date		Who		Reason
21 May 2008	cnwkpd1	PAR #16687 - Correct String too long errors in error messages

*/

vars
  	maxLength 		: Integer;

begin
   	maxLength := getMaxLength;
   	if _value.length &gt; maxLength then
   		self.add(_value[1:maxLength]);
   	else
   		self.add(_value);
   	endif;

	
epilog	

end;</source>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="asCSV" id="0686560b-474b-4e9b-8b0e-8942e3de3a79">
        <source>asCSV(_withQuotes : Boolean) : String;

// cnwdvb1 20 November 2002 

vars

	str, output	: String;
	
begin

	foreach str in self do
		str := str.trimBlanks;
		if _withQuotes then
			str := '"' &amp; str &amp; '"';
		endif;
		output := output &amp; ',' &amp; str;
	endforeach;	
	if output.length &gt; 1 then
		return output[2:end];
	endif;
	return '';
end;</source>
        <Parameter name="_withQuotes" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="asLongString" id="640a0e8e-a2ba-4dcd-a2cf-b02879ec5d66">
        <source>asLongString() : String;
/*

Purpose:			Return the contents of the receiver as a single string, with all the array elements
					concatenated together

Parameters:			None

Return Value:		String containing the contents of the receiver

Date		Who		Reason
27 Feb 2012	cnwkpd1	23 Feb 2012	cnwkpd1	PAR #29165 - CCMS SFW 1272 - Reduce physical database size

*/

vars
	element,
	returnVal		: String;
	
begin
	foreach element in self do
		returnVal := returnVal &amp; element;
	endforeach;
	
	return returnVal;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="asXmlString" id="96960fc1-4d1d-47bb-8055-6968cd032bfa">
        <source>asXmlString(_headerTag, 
			_detailTag : String) : String;
/*

Purpose:			Return the contents of the receiver as an XML document string, using the 
					passed in header and detail element names

Parameters:			Document header tag, tag for each array element

Return Value:		String representing the contents of the receiver in XML format

Date		Who		Reason
27 Feb 2012	cnwkpd1	23 Feb 2012	cnwkpd1	PAR #29165 - CCMS SFW 1272 - Reduce physical database size

*/

vars
	arrayElement	: String;
	result			: String;
	startDetail,
	endDetail,
	nullDetail,
	elementText		: String;
	
begin
	result := "&lt;" &amp; _headerTag &amp; "&gt;";
	
	startDetail := "&lt;" &amp; _detailTag &amp; "&gt;";
	endDetail := "&lt;/" &amp; _detailTag &amp; "&gt;";
	nullDetail := "&lt;" &amp; _detailTag &amp; "/&gt;";
	
	foreach arrayElement in self do
		if arrayElement = null then
			result := result &amp; nullDetail;
		else
			elementText := arrayElement.asXML();
			result := result &amp; startDetail &amp; elementText &amp; endDetail;
		endif;
	endforeach;
	
	result := result &amp; "&lt;/" &amp; _headerTag &amp; "&gt;";
	
	return result;
	
epilog

end;</source>
        <Parameter name="_headerTag" type="String"/>
        <Parameter name="_detailTag" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="compareIds" id="5f162179-73f1-4de7-881c-936c1b10a776">
        <source>compareIds(_tiKey	: String) : Boolean;
// -------------------------------------------
// Created 12 May 2005 by cnwdvb1
// -------------------------------------------
vars

	searchKey	: String;
	isNottedKey	: Boolean;
	keyLen		: Integer;
	
begin

	if _tiKey = null then
		return false;
	endif;
	
	if self.isEmpty() then
		return false;
	endif;

	foreach searchKey in self do
		isNottedKey := false;
		if searchKey.trimRight &lt;&gt; null and searchKey.length &gt;= 2 then
			if searchKey[1 : 1] = "!" then
				//--------------
				//NOT key Chop off the "!" ("not" symbol)
				//--------------
				searchKey := searchKey[2 : end];
				isNottedKey := true;
			endif;
			keyLen := searchKey.length;
			if isNottedKey then
				//This is a MUST NOT = key, return straight away!
				if _tiKey[1 : keyLen] = searchKey then
					return false;
				endif;
			else
				//This is a MUST = key
				if _tiKey[1 : keyLen] = searchKey then
					return true;
				endif;
			endif;
		endif;
	endforeach;
	
	
	return false;

end;</source>
        <Parameter name="_tiKey" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="concatenate" id="85c60fa2-1f95-4aee-809e-bd4d9163f585">
        <source>concatenate(_delimiter : String) : String;

/*

Purpose:			Return the members of the receiver concatenated together, separated by the 
					passed in delimiter


Return Value:		String with all the members


Date		Who		Reason
08 May 2008	cnwkpd1	Initial creation

*/

vars
	element,
	result			: String;
	
begin
	foreach element in self do
		if result = null then
			result := element;
		else
			result := result &amp; _delimiter &amp; element;
		endif;
	endforeach;
	
	return result;
	
	
epilog

end;</source>
        <Parameter name="_delimiter" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="displaySelf" id="979aeba6-4b58-46a5-93cc-dc4d1a8f150e">
        <source>displaySelf() : String;

vars
	str : String;
	msg : String;
begin
	if self.size = 0 then
		return null;
	endif;
	foreach str in self do
		msg := msg&amp;'::'&amp;str;
	endforeach;
	return msg;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doSort" id="4cb1e665-1a38-40ce-b499-fa7339389136">
        <lockReceiver/>
        <updating/>
        <source>doSort(pTheSorter: CnEcSorter) updating;

vars

begin

	self.cnEcDoSort(pTheSorter);

end;</source>
        <Parameter name="pTheSorter" type="CnEcSorter"/>
    </JadeMethod>
    <JadeMethod name="getFirstElementsDelimited" id="5b7bacff-ba77-4cb7-91bc-b20401533292">
        <source>getFirstElementsDelimited(_numElements: Integer; _delimiter: String): String;
//----------------------------------------------------------------
//	Created:	16 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	str,
	retStr			: String;
	elementCount,
	numToReturn		: Integer;
	tmpDelim		: String;
begin
	elementCount := 0;
	if _numElements &lt; 1 then
		numToReturn := self.size;
	else
		numToReturn := _numElements;
	endif;
	tmpDelim := _delimiter;
	
	foreach str in self do
		elementCount := elementCount + 1;
		if elementCount &gt; numToReturn then
			break;
		endif;
		
		retStr := retStr &amp; tmpDelim &amp; str;
		
	endforeach;

	if retStr.length &gt; tmpDelim.length then
		return retStr[tmpDelim.length + 1:end];
	endif;
	
end;</source>
        <Parameter name="_numElements" type="Integer"/>
        <Parameter name="_delimiter" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMaxLength" id="1732fa84-3379-4cd0-afdb-060c2bc178bc">
        <source>getMaxLength() : Integer;

/*

Purpose:			Get the maximum String length of the memebers in the receiver


Return Value:		Max length of elements


Date		Who		Reason
21 May 2008	cnwkpd1	PAR #16687 - Correct String too long errors in error messages
27 Apr 2021 navmd1	TFS 51086 - Workaround JADE 2020 variable string arrays by defaulting member size back to pre-2020 values

*/

vars
	size	: Integer;
begin
	size := self.class.CollClass.memberTypeSize;
	if size &lt; 0 then
		size := 16000; //jlier1 TFS 55280 7/11/22 jade 2022 max string length is 15999
	endif;
	
	return size - 1;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleXMLException" id="9b0f86ae-5155-4fd0-9ef4-33f97534bc0a">
        <source>handleXMLException(_exc : JadeXMLException; _parserError : Boolean io) : Integer protected;
/*

Purpose:			Handle any errors parsing XML strings

Parameters:			Exception object 

Return Value:		Exception return value

Date		Who		Reason
28 February 2012	cnwkpd1	23 Feb 2012	cnwkpd1	PAR #29165 - CCMS SFW 1272 - Reduce physical database size

*/

vars

begin
	app.writeLog(method.qualifiedName &amp; 
							 " " &amp; _exc.class.name &amp; 
							 " " &amp; _exc.errorCode.String &amp; 
							 " " &amp; _exc.text &amp; 
							 " " &amp; _exc.extendedErrorText, LogERROR);	//26 Nov 2019	NDL	TFS 47053
	
	if _exc.resumable then
		_parserError := true;
		return Ex_Resume_Next;
	else
		return Ex_Pass_Back;
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_exc" type="JadeXMLException"/>
        <Parameter name="_parserError" type="Boolean" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="hasOnlyBlanks" id="870a960a-3134-441c-96c3-1157bdd3176f">
        <source>hasOnlyBlanks(): Boolean;
//----------------------------------------------------------------
//	Created:	17 November 2004	by Jason Chapman  (cnwjc2)
//
//  is the array full of blanks?
//----------------------------------------------------------------
vars
	str		: String;
begin
	foreach str in self do
		if str.trimBlanks &lt;&gt; null then
			return false;
		endif;	
	endforeach;
	
	return true;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="removeDuplicates" id="82141419-35e0-4055-adff-ce1392ec6890">
        <lockReceiver/>
        <updating/>
        <source>removeDuplicates() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//11 Dec 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
*/

vars
	keepColl : StringArray;
	str : String;
begin
	create keepColl transient;
	
	//find the unique ones.
	foreach str in self do
		if not keepColl.includes(str) then
			keepColl.add(str);
		endif;
	endforeach;
	self.clear;
	keepColl.copy(self);
epilog
	delete keepColl;
end;</source>
    </JadeMethod>
    <JadeMethod name="setFromLongString" id="28fa329c-436a-4ec5-aa87-fdac450e309b">
        <lockReceiver/>
        <updating/>
        <source>setFromLongString(_value, _delim : String) updating;
/*

Purpose:			Clear the receiver and populate from the input _value, splitting the _value over
					the first n entries in the reciever, as required to stor it all
					
Parameters:			Long string, to be stored in the receiver
					(Optional) A delimiter to try and split by first

Return Value:		Receiver populated with the contents of the passed in value

Date				Who		Reason
27 February 2012	cnwkpd1	23 Feb 2012	cnwkpd1	PAR #29165 - CCMS SFW 1272 - Reduce physical database size
22 March 2024		navmd1	TFS 63103 Allow large .NET errors to be displayed in the System Alerts details screen

*/

vars
	pos,
	maxLength,
	valueLen,
	idx,
	strLen			: Integer;
	splitByDelim	: Boolean;
	str				: String;
	
begin
	self.clear();
	maxLength := self.getMaxLength();
	valueLen := _value.length();
	
	splitByDelim := _delim &lt;&gt; null;
	
	pos := 1;
	while pos &lt;= valueLen do
		if pos + maxLength &gt; valueLen then
			self.add(_value[pos:end]);
			break;
		endif;
		
		if not splitByDelim then
			self.add(_value[pos:maxLength]);
			pos := pos + maxLength;
		else
			idx := pos;
			str := _value.scanUntil(_delim, idx);
			if idx &gt; 0 then
				_value.scanWhile(_delim, idx);
			endif;
			
			strLen := str.length();
			if strLen &lt;= maxLength then
				self.add(str);
				pos := idx;
			else
				while strLen &gt; maxLength do
					self.add(str[1:maxLength]);
					str := str[maxLength+1:end];
					strLen := strLen - maxLength;
				endwhile;
				if strLen &gt; 0 then
					self.add(str[1:strLen]);
					pos := idx;
				endif;
				// If the end of our string contains a delimiter then pos will end up being 0
				if pos = 0 then
					break;
				endif;
			endif;
				
		endif;
		
		
	endwhile;
	
epilog

end;</source>
        <Parameter name="_value" type="String"/>
        <Parameter name="_delim" type="String"/>
    </JadeMethod>
    <JadeMethod name="setFromXmlString" id="9fdb7043-bc9a-4ccc-b956-4970c62fa5a7">
        <lockReceiver/>
        <updating/>
        <source>setFromXmlString(_xmlDocString,
				 _headerTag,
				 _detailTag : String) updating;
/*

Purpose:			Clear the receiver and populate from the input _xmlDoc, populating the 
					array elements of the receiver with the text data from the detail tag elements
					found in the xml document

Parameters:			xmlDocument string, header and detail tags it contains

Return Value:		Receiver populated from the elements of the input document

Date		Who		Reason
27 Feb 2012	cnwkpd1	23 Feb 2012	cnwkpd1	PAR #29165 - CCMS SFW 1272 - Reduce physical database size
22 Mar 2024	navmd1	TFS 63103 Allow large .NET errors to be displayed in the System Alerts details screen

*/

vars
	xmlDoc			: JadeXMLDocument;
	headerElement	: JadeXMLElement;
	xmlElements		: JadeXMLElementArray;
	xmlElement		: JadeXMLElement;
	parserError		: Boolean;

begin
	self.clear();
	
	on JadeXMLException do self.handleXMLException(exception, parserError);
	create xmlDoc transient;
	xmlDoc.parseString(_xmlDocString);

	if not parserError then
		headerElement := xmlDoc.getElementByTagName(_headerTag);
		if headerElement &lt;&gt; null then
			create xmlElements transient;
			headerElement.getAllElementsByTagName(_detailTag, xmlElements);
			
			foreach xmlElement in xmlElements do
				self.addTruncated(xmlElement.text());
			endforeach;
		endif;
	else
		// If there is an error parsing the XML, then just set the contents using the input string
		self.setFromLongString(_xmlDocString, null);
	endif;
	
epilog
	delete xmlElements;
	delete xmlDoc;
	
end;</source>
        <Parameter name="_xmlDocString" type="String"/>
        <Parameter name="_headerTag" type="String"/>
        <Parameter name="_detailTag" type="String"/>
    </JadeMethod>
</CollClass>
