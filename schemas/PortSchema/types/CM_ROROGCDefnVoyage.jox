    <JadeMethod name="getAllVoyageRequests" id="4793578e-3724-4966-92d1-56c22a128c0a">
        <source>getAllVoyageRequests(_allRequests: CM_VoyageRequestArray io);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 September 2011	cnwer1	Initial creation CCMS MES 1033
13 Sep 2012	cnwrs1	Par 29388 don't add null requests
*/
vars
	req : CM_RORORequest;
begin
	if self.myGCController = null then
		return;
	endif;
	
	req := self.myGCController.myRORORequestLoad;
	if req = null then
		req := self.myGCController.myRORORequestDischarge;
	endif;
	if req &lt;&gt; null then
		_allRequests.add(req);
	endif;
epilog

end;</source>
        <Parameter name="_allRequests" type="CM_VoyageRequestArray" usage="io"/>
    </JadeMethod>
