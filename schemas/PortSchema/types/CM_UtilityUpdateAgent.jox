        <source>utlUpdateTerminalAreaInUse(_proxyTA : CM_TerminalAreaMaster input; _passport : CM_Passport input);
//utlUpdateTerminalAreaInUse(pProxyTA : CM_TerminalArea input; _realTA: CM_TerminalArea output; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		02 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// update a terminal area that currently has ti's
vars
	realTA		 	: CM_TerminalAreaMaster;
	expectedEdition : Integer;
begin
	
	self.initialiseActivity();

	_proxyTA.raiseExceptionIfNotProxy(method);
	_proxyTA.pxyGetRealObjectAndEdition(realTA, expectedEdition);

	if realTA = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_TerminalArea.name, null, null);
		return;
	endif;

	if expectedEdition &lt; 1 then
		app.raiseCMException2(ExpectedEditionInvalid, expectedEdition.String, method.name, null, null);
		return;
	endif;

	app.setContinueCMExceptions(true);
	app.myValUA.valTerminalAreaInUse(_proxyTA, realTA); 

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	exclusiveLock(realTA);

	if _passport.noErrors then
		if expectedEdition &lt;&gt; realTA.edition then
			app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Terminal Area', null, null);
			return;
		endif;
	endif;
	
	// cnwrd1 4.7.2008 par #17374
	if _passport.noErrors then
		// This is only required if the class is being auditted
		self.myUpdateAuditAgent.audUpdateGeneric(realTA, true);
	endif;
	
	if _passport.noErrors then
		realTA.setForUpdateInUse(_proxyTA,_passport);
//		_realTA := realTA;
	endif;

	// cnwrd1 4.7.2008 par #17374
	if _passport.noErrors then
		// This is only required if the class is being auditted
		self.myUpdateAuditAgent.audUpdateGeneric(realTA, false);
	endif;
end;</source>
