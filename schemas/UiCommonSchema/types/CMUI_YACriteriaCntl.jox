    <JadeMethod name="loadCriteriaTypes" id="f383f6e6-2cab-46b6-87fa-f96a97102021">
        <source>loadCriteriaTypes(_criteriaType: CM_YACriteriaType);
//21 July 2008	cnwdw1	
// Load the criterias types into the combo and preselect
// 1 Aug 2022 	navhl20 	ChangeRequest 53697: EUP - VBS MTN - [1] - VBS Slot Types
// 05 Feb 2023 	navhl20 	ChangeRequest 61960: FR | 57937 - [TKT: 61898] - Kiosk - US.080 'c' - Coded Instructions Missing from Additional question Criteria
// 14 Jan 2025	navlw1		JIRA-12608: MTN - Invoice Cargo Allocations Review (Mapping and Extract/Load)
vars
	index			: Integer;
	critType 		: CM_YACriteriaType;
	parentForm		: CM_BaseForm;
	isYardAlloc,
	isForVBS,
	isKiosk			: Boolean;
begin
	self.cmbCriteriaType.clear();
//	self.cmbCriteriaType.listCollection(app.myRoot.allYACriteriaTypes,	true, Collection.CNEC_DISPLAY_ORDER_COLLECTION);

	//TFS 52538 NAVLW1 20DEC2021
	if self.form &lt;&gt; null and self.form.isKindOf(CM_BaseForm) then
		if self.form.CM_BaseForm.myParentForm &lt;&gt; null then 
			parentForm := self.form.CM_BaseForm.myParentForm ;
			if parentForm.isKindOf(CMUI_YAMaintForm) then
				isYardAlloc := true;
			endif;
		endif;
	endif;
	
	//navlw1 #JIRA-12608 added a isKindOf check for CMUI_YAMaintInvoiceAllocation
	if self.form.isKindOf(CMUI_YAMaintInvoiceAllocation) or (self.form.isKindOf(CMUI_YACriteriaMaintForm) and self.form.CMUI_YACriteriaMaintForm.context = CMUI_YACriteriaMaintForm.KioskCriteria) then		//05.02.2023 navhl20 #61960
		isKiosk := true;
	endif;
	
	if self.form &lt;&gt; null and self.form.isKindOf(CMUI_ObjectCriteriaLineForm) and self.form.CMUI_ObjectCriteriaLineForm.context = CM_ObjectMatchCriteria.VBSMatchingCriteriaInt then
		isForVBS := true;
	endif;

	//19 Jun 2015	NDL	Par 36338
	foreach critType in app.myRoot.allYACriteriaTypes do
		if not critType.isUsed then
			continue;
		endif;
		if critType.type = YACriteriaType_CommReefer then
			continue;
		endif;
		
		//TFS 52538 NAVLW1 20DEC2021 If we come from the CMUI_YACriteriaSearchForm then we do not want to show the prenote. 
		//But do want to show the prenote from the voyage Cut-off in termianal ops
		if isYardAlloc then
			if critType.type = YACriteriaType_IsPrenote then
				continue;
			endif;
			//jlier1 TFS 63834 14/5/24
			if critType.type = YACriteriaType_TrxToDoResource then
				continue;
			endif;
		endif;
		
		// TFS 51219 - do not show invoice allocation types e.g. transaction type
		// For yard allocations we do not want transaction type or location event stuff, but for invoice allocations we do want transaction type
		if self.form &lt;&gt; null and self.form.isKindOf(CMUI_YAMaintInvoiceAllocation) then
			if not form.CMUI_YAMaintInvoiceAllocation.includeCriteria(critType) then
				continue;
			endif;
		// ### TFS 51515 13JUL2021 NAVAB1
		elseif self.form &lt;&gt; null and self.form.isKindOf(CMUI_LocationActivityEnquiry) then
			if not critType.isForLocationActivity() then
				continue;
			endif;
		else
			if not critType.isForCargo() then
				continue;
			endif;
		endif;
		
		//Start 1.08.2022 navhl20 TFS 53697
		if isForVBS then 
			if critType.type &lt;&gt; YACriteriaType_Carrier 
			and critType.type &lt;&gt; YACriteriaType_CargoType 
			and critType.type &lt;&gt; YACriteriaType_Commodity
			and critType.type &lt;&gt; YACriteriaType_OperatorItem
			and critType.type &lt;&gt; YACriteriaType_Product then
				continue;
			endif;
			if critType.type = YACriteriaType_Carrier then
				self.cmbCriteriaType.itemObject[self.cmbCriteriaType.addItem( app.getErrorString(Carrier) )] := critType;
				continue;
			endif;
		endif;
		//End 1.08.2022 navhl20 TFS 53697
		
		if not isKiosk then																						//05.02.2023 navhl20 #61960
			if critType.type = YACriteriaType_InstructionType then
				continue;
			endif;
		endif;
		
		self.cmbCriteriaType.itemObject[self.cmbCriteriaType.addItem( critType.description )] := critType;
	endforeach;
	
	self.cmbCriteriaType.listIndex := self.cmbCriteriaType.findObject(_criteriaType);
	
	self.lblCriteriaType.caption := self.cmbCriteriaType.text;
end;</source>
        <Parameter name="_criteriaType" type="CM_YACriteriaType"/>
    </JadeMethod>
    <JadeMethod name="setBooleanValue" id="b82df847-fb5b-4399-9204-6a00c39a32fc">
        <source>setBooleanValue( _booleanTypeValue: Integer ) protected;

/*

Purpose:		Set value of Boolean controls

Parameters:		Integer representation of boolean value	

Return Value:		


Date			Who		Reason
14 August 2008	consw1	Initial creation

*/

vars
	cntlOptYes, cntlOptNo, cntlOptEither : CMUI_OptionButton;

begin
	self.getYesNoOptionButtons( cntlOptYes, cntlOptNo, cntlOptEither );

	if cntlOptYes = null then	
		if _booleanTypeValue = CM_YADataBoolean.VALUE_TRUE then	
			self.chkCriteriaValue.value := true;
		else
			self.chkCriteriaValue.value := false;
		endif;
		return;
	endif;
	
	if _booleanTypeValue = CM_YADataBoolean.VALUE_EITHER then	
		if cntlOptEither &lt;&gt; null then
			cntlOptEither.value := true;
			cntlOptYes.value := false;
		else
			cntlOptYes.value := true;
		endif;
		cntlOptNo.value := false;
	elseif _booleanTypeValue = CM_YADataBoolean.VALUE_TRUE then	
		cntlOptYes.value := true;
		cntlOptNo.value := false;
		if cntlOptEither &lt;&gt; null then
			cntlOptEither.value := false;
		endif;
	else
		cntlOptYes.value := false;
		cntlOptNo.value := true;
		if cntlOptEither &lt;&gt; null then
			cntlOptEither.value := false;
		endif;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_booleanTypeValue" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setBooleanVisible" id="ebe6cd98-1db0-45c1-97ed-10f236fd3263">
        <source>setBooleanVisible( _value : Boolean ) protected;

/*

Purpose:		Set visiblity for boolean controls

Parameters:			

Return Value:		


Date			Who		Reason
14 August 2008	consw1	Initial creation

*/

vars
	cntlOptYes, cntlOptNo, cntlOptEither : CMUI_OptionButton;

begin
	self.getYesNoOptionButtons( cntlOptYes, cntlOptNo, cntlOptEither );

	if cntlOptYes = null then
		self.chkCriteriaValue.visible := _value;
		return;
	endif;
	
	cntlOptYes.visible := _value;
	cntlOptNo.visible := _value;
	if cntlOptEither &lt;&gt; null then
		cntlOptEither.visible := _value;
	endif;
	
	self.chkCriteriaValue.visible := false;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setCriteria" id="ea3a901d-275a-496f-a574-b6b05842273b">
        <updating/>
        <source>setCriteria(_criteria: CM_YACriteriaPriority) updating;
//31 July 2008	cnwdw1	
// 12/07/2011	cnwmh5	#27772 Set txtCriteriaValue's tag attribute
// 09/09/2011 	cnwmh5  #28095 - Add seting of text if CM_YADataPattern
// 15/01/2025	navlw1	JIRA-12608: MTN - Invoice Cargo Allocations Review (Mapping and Extract/Load)
// 28/05/2025	navdap1	MTN-34981 MTN -Yard Allocations - Storing Cargo Based on a Date Range
vars
	criteriaType: CM_YACriteriaType;

begin
	if _criteria &lt;&gt; null then
		criteriaType := _criteria.myYACriteriaType;
	endif;

	self.loadCriteriaTypes(criteriaType);
	self.doCriteriaTypeSelected();

	if criteriaType &lt;&gt; null then
		// start navlw1 #JIRA-12608
		if criteriaType.saveCodeInUpper() then
			self.txtCriteriaValue.case := TextBox.Case_Upper;
		else
			self.txtCriteriaValue.case := TextBox.Case_None;
		endif;
		// end navlw1 #JIRA-12608
		if criteriaType.isBooleanType then
			// Boolean type is stored as an integer (not boolean) to allow for values of true/false/either.			
			self.setBooleanValue( _criteria.myYAData.getDataValue().Integer );
		elseif criteriaType.isDateRangeType() then							// MTN-34981
			self.setDateRangeValues(_criteria.myYAData.getYAIdentifier);
		else
			self.txtCriteriaValue.text := _criteria.myYAData.getYAIdentifier;
			//epr TFS 1822 28/4/16
			
		endif;
	endif;

	self.oldGroupName := self.getDisplayForGroupName;
	
	self.doCriteriaChanged();
end;</source>
        <Parameter name="_criteria" type="CM_YACriteriaPriority"/>
    </JadeMethod>
    <JadeMethod name="setCriteriaType" id="6c6a057f-5cc0-46a1-8c54-094f8d0b073d">
        <updating/>
        <source>setCriteriaType(_criteriaType: CM_YACriteriaType) updating;
//04 August 2008	cnwdw1	
//
begin
	self.loadCriteriaTypes(_criteriaType);
	self.doCriteriaTypeSelected();
end;</source>
        <Parameter name="_criteriaType" type="CM_YACriteriaType"/>
    </JadeMethod>
    <JadeMethod name="setDateRangeValues" id="02ee688b-60cc-4777-b9d6-ea77ce200047">
        <source>setDateRangeValues(_yaIdentifier : String);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 28/05/2025	navdap1		Initial creation MTN-34981 MTN -Yard Allocations - Storing Cargo Based on a Date Range
//
vars
	startMask, endMask : CMUI_DateMaskYACriteriaCtrl;
	startDate, endDate : Date;
	pos : Integer;

begin
	self.getDateRangeMasks(startMask, endMask);
	pos := _yaIdentifier.pos("|", 1);
	if pos = 1 then
		startDate := null;
	else
		startDate := _yaIdentifier[1:pos-1].Date;
	endif;
	if pos = _yaIdentifier.length then
		endDate := null;
	else
		endDate := _yaIdentifier[pos+1:end].Date;
	endif;
	
	startMask.setDate(startDate);
	endMask.setDate(endDate);
epilog

end;</source>
        <Parameter name="_yaIdentifier" type="String"/>
    </JadeMethod>
    <JadeMethod name="setInitialValues" id="88a000f8-fbe5-4c67-b12d-4a1f978777cd">
        <source>setInitialValues();

/*

Purpose:		Reset controls to initial values

Parameters:			

Return Value:		


Date			Who		Reason
21 August 2008	consw1	Initial creation

*/

vars
	criteriaType: CM_YACriteriaType;
begin
	//  Reset to initial values
	self.txtCriteriaValue.text := null;
	self.setBooleanValue(CM_YADataBoolean.VALUE_TRUE);
	criteriaType :=	self.cmbCriteriaType.listObject.CM_YACriteriaType;
	if criteriaType &lt;&gt; null and self.form.isKindOf(CMUI_YAMaintForm) then
		if criteriaType.isBooleanType then
			if criteriaType.getValueFromObject(self.form.CMUI_YAMaintForm.getTrackedItem()).Boolean then
				self.setBooleanValue(CM_YADataBoolean.VALUE_TRUE);
			else
				self.setBooleanValue(CM_YADataBoolean.VALUE_FALSE);
			endif;
		else
			self.txtCriteriaValue.text := criteriaType.getValueFromObject(self.form.CMUI_YAMaintForm.getTrackedItem()).String;
		endif;	
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setLabel" id="1b2e4ffb-bbea-4ff8-8d81-8a4b4f8a3404">
