    <JadeMethod name="getAuditText" id="e4ee1069-15d3-49da-a8c2-8f542a8b53e2">
        <source>getAuditText(): String;

vars
	txt	: String;
begin
	txt := inheritMethod();
	
	if self.myExtension &lt;&gt; null then
		txt := txt &amp; self.myExtension.getAuditText();
	endif;
	
	if not self.allDocketErrors.isEmpty() then
		txt := txt &amp; self.allDocketErrors.first().getAuditText();
	endif;
	
	return txt;
	
end;
</source>
        <ReturnType type="String"/>
