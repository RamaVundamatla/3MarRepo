    <JadeMethod name="redisplayTI" id="e6f5e258-680d-4f56-b177-4ed3935f8a80">
        <updating/>
        <source>redisplayTI(_ti: CM_TrackedItem) updating;
// ---------------------------------------------------------------------------
// Created:		11 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// 10/12/2009	cnwdap1		CCMS MES 1007 Any TI can now be a reefer
vars
	bCont		: Boolean;
	strDisplay	: String;
	rowIdx		: Integer;
	items		: Integer;
begin


	
	
	if self.tblData.findObjectInRow(_ti, rowIdx) then
		//check for removal
		if _ti.site &lt;&gt; TI_SITE_ONSITE
		or (not self.includeObject(_ti, app.myPassport)) then
			//remove
			self.tblData.removeItemObject(_ti);
			if self.myDisplayedReefer = _ti then
				self.myDisplayedReefer := null;
				self.myCurrentObject := null;
				self.clearThumbnailData();
			endif;
		else	
			//update
			strDisplay := self.tblDataDisplayRow(self.tblData, _ti);
			self.tblData.setCellText(rowIdx, 1, strDisplay);
			self.tblDataShowDataSpecial(rowIdx, _ti);
			if self.myDisplayedReefer = _ti then
				self.doShowReeferInfo();
			endif;
		endif;
	else
		//check to see we should add
		if self.includeObject(_ti, app.myPassport) then
//			global.beep();
			self.addObjectToTable(_ti, items, bCont);
		endif;
	endif;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
