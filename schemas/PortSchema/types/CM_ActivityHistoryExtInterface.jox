    <JadeMethod name="canReprocessSapResponse" id="10ea94d0-d322-4bd2-883d-7f257013a3b9">
        <source>canReprocessSapResponse():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 September 2019	jlgndl1	Initial creation	TFS 46758

*/

vars

begin

	if self.isSend  and success and errors &lt;&gt; null and not self.reprocessDT.Date.isValid then
		return true;
	else
		return false;
	endif;
				

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="copyForReprocess" id="a2f1821e-da29-4064-9446-16c0e3ca989e">
        <source>copyForReprocess( _passport : CM_Passport input ): CM_ActivityHistoryExtInterface;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 September 2019	jlgndl1	Initial creation	TFS 46758

*/

vars

	proxyActHistory : CM_ActivityHistoryExtInterface;
	newActivityHistory : CM_ActivityHistoryExtInterface;

begin

	create proxyActHistory transient;
	proxyActHistory.setProxy(ActivityHistoryExtInterface, self.myTerminal, false);
	proxyActHistory.setDescription( "Re-Process " &amp; self.description );	
	proxyActHistory.setMessageData(self.request, self.response);
	proxyActHistory.setRequestName(self.requestName );
	proxyActHistory.setMyCashReceipt(self.myCashReceipt);
	proxyActHistory.setMyInvoice(self.myInvoice);
	proxyActHistory.setMyVoyage(self.myVoyage);
	proxyActHistory.setVoyageCode(self.voyageCode);
	proxyActHistory.setDebtorCode(self.debtorCode);
	self.allInvoiceLines.copy( proxyActHistory.allInvoiceLines );
	proxyActHistory.interfaceName := self.interfaceName;
	
	newActivityHistory := app.myUtilityCA.utlCreateActivityHistory( proxyActHistory, _passport ).CM_ActivityHistoryExtInterface;
	
	return newActivityHistory;

epilog

	delete proxyActHistory;

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_ActivityHistoryExtInterface"/>
    </JadeMethod>
    <JadeMethod name="getDebtorName" id="05bfc788-2fbd-4263-b5e2-fdb68d07fe40">
        <source>getDebtorName(_code: Boolean) : String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 02/05/2019	jlgdap1		Initial creation TFS 44298 PEL1 Host-to-Host (H2H) Monitoring
//
vars
	debtor : CM_Debtor;

begin
	if self.myCashReceipt &lt;&gt; null then
		debtor := self.myCashReceipt.getDebtor;
	elseif self.myInvoice &lt;&gt; null then
		debtor := self.myInvoice.getDebtor;
	endif;
	if debtor &lt;&gt; null then
		if _code then				// 24/5/19 MAP TFS44298
			return debtor.code;
		else
			return debtor.name;
		endif;
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_code" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDetailForDisplay" id="656a43f2-6c5a-4cde-9fee-7decade08735">
        <source>getDetailForDisplay(_array: HugeStringArray input): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Apr 2018	jlgndl1	Initial creation	TFS 38135
13 Jun 2018	jlgkpd	TFS 39164 - rework to use Strings for performance and database space optimisation

*/

vars
	hsa				: HugeStringArray;
	
begin
	if _array = null then
		return false;
	endif;

	create hsa transient;
	
	_array.add(app.getErrorString(SOAP_Request));
	if self.request &lt;&gt; null then
		hsa.clear();
		hsa.populateFromXMLDocOrStr(null, self.request);
		hsa.copy(_array);
	else
		_array.add("&lt;empty&gt;");
	endif;
	
	_array.add( " " );
	_array.add( " " );
	
	_array.add(app.getErrorString(SOAP_Response));
	if self.response &lt;&gt; null then
		hsa.clear();
		hsa.populateFromXMLDocOrStr(null, self.response);
		hsa.copy(_array);
	else
		_array.add("&lt;empty&gt;");
	endif;
	
	return true;

epilog
	delete hsa;
	
end;</source>
        <Parameter name="_array" type="HugeStringArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="55c54b9b-47a4-44a2-937d-2b01a964b721">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 September 2019	jlgndl1	Initial creation

*/

vars

begin

	if _attrName = ETRow_InterfaceName then	//30 Sep 2019	NDL TFS 46758
		return self.interfaceName;
	elseif _attrName = ETRow_ReprocessDT then	//30 Sep 2019	NDL TFS 46758
		return self.systemToLocalTime(self.reprocessDT).shortCurrentLocaleFormatSecs();
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMarineTimings" id="ed5eae3d-f8e2-4faf-9dde-c530ddaf48ea">
        <source>getMarineTimings( _timings : HMS_MarineServicesTimings output; _pilotTimingType : Integer output);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 December 2018	jlger1	Initial creation

*/

vars
	xmlDoc :  JadeXMLDocument;
	xmlElement : JadeXMLElement;
	workOrderDtl : CM_WorkOrderVoyageDtl;
	nomorSpk : String;
	obj : Object;
	workOrderOid : String;
	pos : Integer;
	movement : HMS_VoyageMovement;
	jenisKegiatan  : String;
	invalidObj : Boolean;
begin
	if not self.requestName = CM_InaportnetWSConsumerAgent::monitorPandu.name then
		
		return;
	endif;
	
	create xmlDoc transient;
xmlDoc.parseString( request);

	xmlElement:=xmlDoc.getElementByTagName(CMIF_IPNMonitorPanduRequest::nomorSpk.name);
	nomorSpk:= xmlElement.textData;
	pos:=nomorSpk.pos("SPK-",1);
	if pos &gt; 0 then
		workOrderOid:=nomorSpk[pos+4:end];
	endif;

	obj:=workOrderOid.asOid;
	if obj &lt;&gt; null and obj.isKindOf(CM_WorkOrderVoyageDtl) then
		workOrderDtl:=obj.CM_WorkOrderVoyageDtl;
	endif;
	
	if workOrderDtl = null then
		return;
	endif;
	on Exception do app.handleDeletedObject(exception,workOrderDtl,invalidObj);
	if workOrderDtl &lt;&gt; null then
		movement :=workOrderDtl.getMyParent.getMyHMSVoyageMovement;
		if invalidObj  then
			return;
		endif;
		if movement = null then
			return;
		endif;
		if movement &lt;&gt; null then
			_timings :=movement.myMarineServiceTimings;
			
		endif;
	endif;

	if _timings = null then
		return;
	endif;
	
	xmlElement:=xmlDoc.getElementByTagName(CMIF_IPNMonitorPanduRequest::jenisKegiatan.name);
	jenisKegiatan :=xmlElement.textData;
	if jenisKegiatan = "LEPAS" then
		_pilotTimingType := BGP_InaportnetWSRequest.PilotTimeFinishMove;
	elseif jenisKegiatan = "IKAT" then
		_pilotTimingType := BGP_InaportnetWSRequest.PilotTimeStartMove;
	elseif jenisKegiatan = "NAIK" then
		_pilotTimingType := BGP_InaportnetWSRequest.PilotTimeOnboard ;
	elseif jenisKegiatan = "TURUN" then
		_pilotTimingType := BGP_InaportnetWSRequest.PilotTimeOffboard;
	endif;
		



epilog
	delete xmlDoc;
end;</source>
        <Parameter name="_timings" type="HMS_MarineServicesTimings" usage="output"/>
        <Parameter name="_pilotTimingType" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getSAPStatus" id="094d67d2-dde4-4e48-b127-d1eb252aea29">
        <source>getSAPStatus() : String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 02/05/2019	jlgdap1		Initial creation TFS 44298 PEL1 Host-to-Host (H2H) Monitoring
//
vars

begin
	if self.requestName = CM_SAPWSConsumerAgent::autocollEstimationRequest_SI.name then
		return app.getErrorString(SAP_Hold);
	elseif self.requestName = CM_SAPWSConsumerAgent::autocollCancellationRequest_SI.name then
		return app.getErrorString(Cancelled);
	elseif self.requestName = CM_SAPWSConsumerAgent::autocollPreInvoiceNewRequest_SI.name then
		return app.getErrorString(Debit);
	endif;
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getStatusDescription" id="75fcda0a-5a74-4f5b-8abe-12b01bc1546a">
        <source>getStatusDescription(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 September 2019	jlgndl1	Initial creation	TFS 46758

*/

vars

	returnString : String;

begin
	
	
	if self.reprocessDT.Date.isValid then
		returnString := app.getErrorString(ExtInt_Sent_success_reprocess);
			
	elseif self.isSend then
		if response = null then
			returnString := app.getErrorString(ExtInt_Sent_timed_out);
			
		elseif not success then
			returnString := app.getErrorString(ExtInt_Sent_errors);
			
		elseif success then 
			if errors &lt;&gt; null then
				returnString := app.getErrorString(ExtInt_Sent_succes_failed_resp);
				
			elseif errors = null then 
				returnString := app.getErrorString(ExtInt_Sent_success);
				
			endif;
			
		endif;
		
	else
		returnString := app.getErrorString(ExtInt_Received);
		
	endif;
	
	if returnString &lt;&gt; null then
		return returnString;
	else
		return inheritMethod();
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTypeDescription" id="64f95c6e-a438-45e5-84ab-6a7470cb07e2">
        <source>getTypeDescription(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 April 2018	jlgndl1	Initial creation	TFS 38135

*/

vars

begin
	return app.getErrorString(External_interface);

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVesselCode" id="297c2383-ac00-4b59-af53-45b4fa30140f">
        <source>getVesselCode() : String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 02/05/2019	jlgdap1		Initial creation TFS 44298 PEL1 Host-to-Host (H2H) Monitoring
//
vars
	voyage : CM_Voyage;

begin
	if self.myVoyage &lt;&gt; null then
		return self.myVoyage.vesselCode;
	elseif self.voyageCode &lt;&gt; null then
		voyage := self.myTerminal.allVoyagesByCode.getAtKeyGeq(self.voyageCode, null);
		if voyage &lt;&gt; null and voyage.code = self.voyageCode then
			return voyage.vesselCode;
		endif;
	endif;
	
	return null;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
