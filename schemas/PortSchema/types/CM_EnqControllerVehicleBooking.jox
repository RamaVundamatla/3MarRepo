        <source>setMyFilterClass() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 May 2023 navlw1 	ChangeRequest 53902: EUP - VBS MTN - [6] - Selector Query and JRW

*/

vars

begin	
	self.myFilterClass := CM_VehicleBookingTimeSlot;
epilog

end;
</source>
    </JadeMethod>
</Class>
