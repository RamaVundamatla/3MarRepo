    <JadeMethod name="init" id="edbc9841-f08c-46e8-bea7-a59fd495953b">
        <updating/>
        <source>init(_process : Process) updating;
// ---------------------------------------------------------------------------
// Created:     30 March 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if _process = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_process', null, null);
		return;
	endif;
	self.myProcessToSendRequestTo := _process;
end;</source>
        <Parameter name="_process" type="Process"/>
    </JadeMethod>
