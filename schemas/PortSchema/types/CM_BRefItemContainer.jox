    <JadeMethod name="updateBRefItemConainerDetails" id="e6d4b005-9c7a-46f1-8352-1bf9d2e9b228">
        <updating/>
        <source>updateBRefItemConainerDetails(	cmifBookingRefItem  : CMIF_BookingRefItem ) updating, protected;
/*

Date		Who		Reason
05/02/2016	cnwer1	Initial creation PAR 37551
05/05/2016	cnwdap1	TFS #1699 Verified Gross Mass changes
07/11/2022 	navrk21 Bug 55167: MTN - Booking Item not saving CO2, O2 and Curtains In/Out unless a commodity is specified
*/

vars
	commodity : CM_Commodity;
	ediBookingItem : CM_EDIBookingItemTI;
	eventRequest : CM_EventRequestStops;
	pxyRequestStops : CM_EventRequestStops;	
	cmifEventReq : CMIF_EventRequestController;
	org : CM_Organisation;
	terminal : CM_Terminal;
begin
	commodity := self.getCommodityObj();
	//if commodity &lt;&gt; null and commodity.hasTemp then															//07.11.2022 navrk21 TFS 55167
	if (self.myISOType &lt;&gt; null and self.myISOType.isReefer) or (commodity &lt;&gt; null and commodity.hasTemp) then	//07.11.2022 navrk21 TFS 55167
		self.setHumidity(cmifBookingRefItem.getHumidity);
		self.setTemperature(cmifBookingRefItem.temperature);
		self.setVentilation(cmifBookingRefItem.ventilation);
		self.setVentilationUnits(cmifBookingRefItem.ventilationUnits);
		self.setCarbonDioxide(cmifBookingRefItem.getCarbonDioxide);
		self.setOxygen(cmifBookingRefItem.getOxygen);  // dh comment : please, please correct this spelling asap  !!!
		self.setCurtainsIn(cmifBookingRefItem.curtainsIn);
	else
		self.setHumidity(NULL_HUMIDITY);	
		self.setTemperature(NULL_TEMPERATURE);
		self.setVentilation(NULL_VENTILATION); //par19252 cnwrs1 may 2009	
		self.setVentilationUnits(null);
		self.setCarbonDioxide(NULL_CARBON_DIOXIDE);	
		self.setOxygen(NULL_OXYGEN);	
		self.setCurtainsIn(null);
	endif;
	
	terminal:=self.myBookingReference.myTerminal;
	//epr par 37551 17/2/16
	//should only do this if licensed check 
	/* replaced by VGM file type
	if app.myRoot.canDo(PmEDIVGM) then
		if app.myPassport.myUser &lt;&gt; null then
			org:=app.myPassport.myUser.myOrganisation;
		endif;
		
		ediBookingItem:=cmifBookingRefItem.myEDIBookingItemTI;
		if ediBookingItem &lt;&gt; null then
			
			if ediBookingItem.isVerifiedWeight and ediBookingItem.cargoId &lt;&gt; null then
				create cmifEventReq transient;
				
				//epr TFS 1787 7/4/16
				eventRequest:= terminal.findCargoUpdateRequest(ediBookingItem.cargoId,EventRequestTypeWeight,EventRequestPending);
				if eventRequest &lt;&gt; null then
					pxyRequestStops:=eventRequest.pxyCreateUpdateProxy;
				else
					create pxyRequestStops transient;
				endif;
				pxyRequestStops.setProxyRequestStops(	EventRequestTypeWeight,
											null,
											null	, //trx remarks
											ediBookingItem.cargoId,
											app.myPassport.myUser,
											app.myRoot.allCargoTypesById[TI_CargoType_Container],
											org, //organisation
											terminal,
											EventRequestPending,
											false,
											false,												
											"EDI Sender", //reference
											true,// from EDI 
											null,
											null,
											null,
											true,
											null,null, null, //remarks
											null,	//_custAgent : CM_CustomsAgent 30 Jun 2015	NDL	Par 36543
											null,	//_toDoRemarks		: String	//06 Oct 2015	NDL	Par 37011
											null,	//_tiBOL		//cnwmc5 - 11 Jan 2016 - PAR 37275
											null	//_clearCustAgent		//cnwmc5 - 11 Jan 2016 - PAR 37275
											);
											
				//pxyRequestStops.setProxyWeightCertified(ediBookingItem.weight,true);					// TFS #1699
				pxyRequestStops.setProxyWeightCertified(ediBookingItem.weight, true, null, null);		// TFS #1699
				cmifEventReq.allPxyCargoUpdateRequests.add(pxyRequestStops);
				cmifEventReq.action(app.myPassport);

			endif;
		endif;
	endif;
	*/
epilog
	//delete pxyRequestStops;
	//delete cmifEventReq;
end;</source>
        <access>protected</access>
        <Parameter name="cmifBookingRefItem" type="CMIF_BookingRefItem"/>
    </JadeMethod>
    <JadeMethod name="validate" id="085616e6-b90b-4a48-85d4-0814c6860046">
        <updating/>
        <source>validate(_passport: CM_Passport input; _terminal: CM_Terminal) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


/****Changes

Date		Name	TFS#		Description
============================================================================
25/11/2008	cnwer1				Initial creation
09/01/2019	jlgka1	42811		Use operator display fahrenheit to display 
								temperature warning message.
17/03/2020	jlgdap1	47457		If cargo type is Container, ensure either ISO type or ISO group is entered
============================================================================*/

vars
	tmpCommodity		: CM_Commodity;	
	operator			: CM_Operator; // jlgka1 TFS 42811
	displayFahrenheit	: Boolean;	   // jlgka1 TFS 42811	
begin
	inheritMethod(_passport, _terminal);
	
	tmpCommodity:=	self.getMyCommodity();
	if tmpCommodity &lt;&gt; null then
		// jlgka1 TFS 42811 --&gt;
		operator := self.myBookingReference.myOperator;
		if operator &lt;&gt; null then
			displayFahrenheit := operator.displayTempFahrenheit;
		endif;
		// jlgka1 TFS 42811 &lt;--
		//is in celcius don't have any pack temp so if the commodity requires that we just ignore
		tmpCommodity.validateTemperature(self.getTemperature(), displayFahrenheit, null, null, self.myBookingReference.bookingReference, false, true, true, false, false, null);
	endif;
	
	if self.getOxygen() &lt;&gt; NULL_OXYGEN or self.getCarbonDioxide() &lt;&gt; NULL_CARBON_DIOXIDE then
		tmpCommodity := app.myRoot.allCommodities[self.commodity];
		if tmpCommodity &lt;&gt; null then
			if tmpCommodity.isEmpty then	
				app.raiseCMException2(ERR_Commodity_does_not_require, null, "oxygen or carbon dioxide", ETRow_Oxygen, null);
			endif;
		endif;
	endif;

	if self.getOxygen() = NULL_OXYGEN then
		if self.isControlledAtmosphere then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Oxygen', ETRow_Oxygen, null);
			app.raiseCMException(Input_required_field_oxygen, ETRow_Oxygen, null); // cnwdb2	PAR 35364
			return;
		endif;
	elseif self.getOxygen() &lt; 0 or self.getOxygen &gt; 100 then
		app.raiseCMException(ERR_CA_OUT_OF_RANGE, ETRow_Oxygen, null);
	endif;

	if self.getCarbonDioxide() = NULL_INTEGER then
		if self.isControlledAtmosphere then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Carbon Dioxide', ETRow_CarbonDioxide, null);
			app.raiseCMException(Input_required_field_carbondio, ETRow_CarbonDioxide, null); // cnwdb2	PAR 35364
			return;
		endif;
	elseif self.getCarbonDioxide() &lt; 0 or self.getCarbonDioxide() &gt; 100 then
		app.raiseCMException(ERR_CA_OUT_OF_RANGE, ETRow_CarbonDioxide, null);
	endif;
	
	// TFS 47457 Check one of ISO type or ISO group is entered
	if self.cargoType = TI_CargoType_Container then
		if self.isoType = null and self.isoTypeGroup = null then
			app.raiseCMException(Unspecified_ISO, app.getErrorString(Unspecified_ISO), null);
		endif;
	endif;
	// TFS 47457 end
end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
