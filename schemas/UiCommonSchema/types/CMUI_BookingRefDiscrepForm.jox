    <JadeMethod name="addToolbarControls" id="250d39ee-60cc-4d09-bd83-b4d0ac10c099">
        <updating/>
        <source>addToolbarControls() updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/08/2009	cnwndl1	Initial creation	CCMS 1609 Par 20521
27/10/2011	cnwdap1	PAR #28524 CCMS POL 2096 Add "Resolve" toolbar button
*/
vars
	frm : CMUI_Toolbar;
	queryToolbar : CMUI_Toolbar;
begin

	frm := self.frmToolbar;
	queryToolbar := self.frmQueryToolbar;
	
	frm.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnExportCSVQE, CMUI_Toolbar.Control_Alignment_Left);		// change to use button on superform (PAR 2078)
	
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	frm.addButton(self.btnShowSearcher, CMUI_Toolbar.Control_Alignment_Left);
	
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	frm.addButton(self.btnEditTI, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnEditBookRef, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnEditRemarks, CMUI_Toolbar.Control_Alignment_Left);
	
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);							// PAR #28524
	frm.addButton(self.btnResolve, CMUI_Toolbar.Control_Alignment_Left);			// PAR #28524
	
	inheritMethod();
	
	self.btnCancelBase.enabled := false;
	self.btnCancelBase.visible := false;


epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="addToolbarControlsQuery" id="1ec7e0e3-751b-4f8c-9802-6a37f53eeedb">
        <source>addToolbarControlsQuery() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 August 2009	cnwndl1	Initial creation	CCMS 1609 Par 20521

*/

vars
	queryToolbar			: CMUI_Toolbar;
begin
	queryToolbar := self.frmQueryToolbar;
	queryToolbar.addButton(self.btnQuery, CMUI_Toolbar.Control_Alignment_Left);
	queryToolbar.addButton(self.btnResetSearch, CMUI_Toolbar.Control_Alignment_Left);
	queryToolbar.addButton(self.btnHideSearcher, CMUI_Toolbar.Control_Alignment_Left);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="btnEditBookRef_click" id="d9b66d54-e466-4a2e-bec6-a42044d321d7">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnEditBookRef_click(btn: Button input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 August 2009	cnwndl1	Initial creation

*/

vars
	obj : Object;
	eventDiscrep : CMEVT_BookingRefDiscrep;
	bookingRef : CM_BookingRef;
begin

	obj := tblData.accessRow(tblData.row).itemObject;
	if CMEVT_BookingRefDiscrep.hasInstance( obj ) then
		eventDiscrep := obj.CMEVT_BookingRefDiscrep; 
	endif;
	if eventDiscrep &lt;&gt; null then
		bookingRef := eventDiscrep.myBookingRef;
	endif;

	if CM_BookingRef.hasInstance(bookingRef) then
		doEditBookingRef(bookingRef);
	endif;

epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
