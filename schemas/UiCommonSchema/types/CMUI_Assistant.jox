    <JadeMethod name="comboBoxVoyageWorkOrderTasks" id="e554ac09-b709-4f55-a1c6-02865bdca687">
        <source>comboBoxVoyageWorkOrderTasks(_combo : CMUI_ComboBox input; _terminal : CM_Terminal);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17/05/2018	jlgdap1		Initial creation TFS 38560 PEL1 Voyage Work Orders
// 29/09/2021   navma1 		ChangeRequest 51925: SAL - Web Portal Cargo Work Orders
//
vars
	workOrderDetail : CM_WorkOrderDetailType;
begin
	_combo.clear;
	_combo.sorted := false;
	
	//29.09.2021 navma1 #51925
	_combo.addItemWithData(app.myRoot.getWorkOrderTaskDescByType(WorkOrderMode_Voyage,WO_TASK_SHIFTMOVEMENT), WO_TASK_SHIFTMOVEMENT);
	_combo.addItemWithData(app.myRoot.getWorkOrderTaskDescByType(WorkOrderMode_Voyage,WO_TASK_PERMIT), WO_TASK_PERMIT);
	_combo.addItemWithData(app.myRoot.getWorkOrderTaskDescByType(WorkOrderMode_Voyage,WO_TASK_TIMECHANGE), WO_TASK_TIMECHANGE);
	_combo.addItemWithData(app.myRoot.getWorkOrderTaskDescByType(WorkOrderMode_Voyage,WO_TASK_EXTENSION), WO_TASK_EXTENSION);
	_combo.addItemWithData(app.myRoot.getWorkOrderTaskDescByType(WorkOrderMode_Voyage,WO_TASK_WATER), WO_TASK_WATER);
	_combo.addItemWithData(app.myRoot.getWorkOrderTaskDescByType(WorkOrderMode_Voyage,WO_TASK_HMSCANCEL), WO_TASK_HMSCANCEL);
		
	//29.09.2021 navma1 #51925
	if app.getMyUser.canDo(self.myTerminal,PmAdmWorkOrderBillingAdjust) then
		workOrderDetail := app.myRoot.allWorkOrderTaskTypes[WorkOrderMode_Voyage,WO_TASK_BILLINGADJ];
		if workOrderDetail &lt;&gt; null then	
			_combo.addItemWithData(workOrderDetail.description, workOrderDetail.id);
		endif;
	endif;
	
	
epilog

end;</source>
        <Parameter name="_combo" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="comboBoxVoyageWorkOrders" id="29812f09-3940-402e-ada6-0121d6419f02">
        <source>comboBoxVoyageWorkOrders(	_cmb : CMUI_ComboBox input;
							_voyage : CM_Voyage;
							_workOrder : CM_WorkOrder; _status : Integer);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 22/05/2018	jlgdap1		Initial creation TFS 38560 PEL1 Voyage Work Orders
// 18/07/2018 	jlger1	 	tfs 39810 should only be  the voyage selected work orders	
// 25/08/2022	navcs2		Bug 54417: MTN - Work Order Maintenance - Invalid Shift Task Can Be Selected in Time Change Voyage Task
vars
	wo : CM_WorkOrder;
	movement : HMS_VoyageMovement;
begin
	if _voyage = null then
		return;
	endif;
	
	_cmb.clear;
	foreach wo in _voyage.allWorkOrders discreteLock do
		if not wo.isVoyageWorkOrder then
			continue;
		endif;
		if not wo.canCancel and wo &lt;&gt; _workOrder then
			continue;
		endif;
		if wo.taskStatus = WO_STATUS_CANCELLED then
			continue;
		endif;
		
		if wo.allWoDtls.first.isKindOf(CM_WodPermitRequest) then
			continue;
		endif;
		
		if wo.archived then
			continue;
		endif;
		if _status &lt;&gt; null and wo.taskStatus &lt;&gt; _status then
			continue;
		endif;
		
		// 25/08/2022 navcs2 #54417
		_cmb.addItemObject(wo.id.String &amp; " " &amp;  wo.getDisplayString(), wo);
	endforeach;
	
	if _workOrder &lt;&gt; null then
		_cmb.listIndex := _cmb.findObject(_workOrder);
	endif;
epilog

end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_workOrder" type="CM_WorkOrder"/>
        <Parameter name="_status" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="comboBoxVoyageWorkPoints" id="158e4740-a0c9-4e11-b827-23b52b7e4672">
        <source>comboBoxVoyageWorkPoints(	_combo : CMUI_ComboBox input;
							_voyage : CM_Voyage input;
							_inlcudeCranes,
							_includeWorkPoints  : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 February 2013	cnwer1	Initial creation par 31094

*/

vars
	jobSheet : CM_VoyageJobSheet;
	wpObject : Object;
begin
	
	if _voyage = null then
		return;
	endif;
	
	if not _inlcudeCranes  and not _includeWorkPoints then
		return;
	endif;
	
	foreach jobSheet in _voyage.allJobSheets discreteLock do
		wpObject:=jobSheet.getMyWorkPointObject;
		if wpObject = null then
			continue;
		endif;
		if wpObject.isKindOf(CM_Crane) and not _inlcudeCranes then
			continue;
		elseif wpObject.isKindOf(CM_WorkPoint) and not _includeWorkPoints then
			continue;
		endif;
		
		_combo.addItemObject(jobSheet.crane,wpObject);
	endforeach;
	
epilog

end;</source>
        <Parameter name="_combo" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
        <Parameter name="_inlcudeCranes" type="Boolean"/>
        <Parameter name="_includeWorkPoints" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="comboBoxWagonClass" id="455008d0-bef1-46fb-809d-aa20734c140f">
        <source>comboBoxWagonClass(_cmb : ComboBox input; _wagonClass : CM_WagonClass);
// ---------------------------------------------------------------------------
// Created:     18 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	iter	: Iterator;
	wagonC : CM_WagonClass;	
	ls		: Boolean;
	idx 	: Integer; 	
begin
	
	/*
	_cmb.listCollection(app.myRoot.allWagonClasses, true, 0);
	
	if _wagonClass &lt;&gt; null and
	   app.myRoot.allWagonClasses.includes(_wagonClass) then
		_cmb.text := self.displayEntryWagonClass(_wagonClass);
	   	_cmb.listObject := _wagonClass;
	endif;
	
	*/
	
	
	//cnwrd1 16.3.2010 par 22818 - filter out not available wagon classes unless we are displaying one.
	_cmb.clear();
	
	app.cmsBeginLoad(ls);
		
	iter :=app.myRoot.allWagonClasses.createIterator;
	
	while iter.next(wagonC) do	
		if wagonC.isNotAvailableForEntry  then
			if _wagonClass &lt;&gt; null then
				if _wagonClass.code = wagonC.code then
					idx := _cmb.addItem(  wagonC.code );
					_cmb.itemObject[idx] := wagonC;
				endif;
			endif;	
		else
			idx := _cmb.addItem(  wagonC.code );
			_cmb.itemObject[idx] := wagonC;
		endif;
		
	endwhile;
	
	
	if _wagonClass &lt;&gt; null and
	   app.myRoot.allWagonClasses.includes(_wagonClass) then
		_cmb.text := self.displayEntryWagonClass(_wagonClass);
	   	_cmb.listObject := _wagonClass;
	endif;

epilog
	app.cmsEndLoad(ls);
	delete iter;
end;


</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_wagonClass" type="CM_WagonClass"/>
    </JadeMethod>
    <JadeMethod name="comboBoxWeighBridges" id="634a7316-a783-45fa-94a8-1f615ecf13f0">
        <source>comboBoxWeighBridges(_cmb : CMUI_ComboBox input; _term : CM_Terminal; _weighBridge	: CM_WeighBridgeObj );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 March 2014	cnwndl1	Initial creation	Par 33268

*/

vars

	idx		: Integer;
	lstIdx	: Integer;
	weighBridge	: CM_WeighBridgeObj;

begin

	_cmb.clear;
	_cmb.addItem("");
	
	foreach weighBridge in _term.allWeighBridges do

	//	if not weighBridge.isSerialPort then
		if weighBridge.myWeighBridgeType.code &lt;&gt; CM_WeighBridgeObjType.MT226 then	//08 Jul 2019	NDl	TFS 44965
			idx := _cmb.addItemObject(weighBridge.name, weighBridge);
			if weighBridge = _weighBridge then
				lstIdx := idx;
			endif;
		endif;
	endforeach;
	
	if lstIdx &lt;&gt; 0 then
		_cmb.listIndex := lstIdx;
	endif;

epilog

end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_weighBridge" type="CM_WeighBridgeObj"/>
    </JadeMethod>
    <JadeMethod name="comboBoxWorkOrderStatus" id="429133db-9421-48e8-8df5-65256064831d">
        <source>comboBoxWorkOrderStatus(_combo : CMUI_ComboBox input; _isExternalUser : Boolean; _currentStatus : Integer);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 Jul 2009	cnwmd1	Initial creation
14 Aug 2018 cnwma1	ChangeRequest 39698: PEL1 - SAP Enable SAP interfaces
11 Oct 2021	jlier1	TFS 51963
15 Feb 2023 navma1  ChangeRequest 56561: FR 53944 | EUP - Simplified Voyage Work Order
*/

vars
	userTerm		 	: CM_UserTerminal;
	securityRole     	: CM_SecurityRole;
	user			 	: CM_User;
	term				: CM_Terminal;
begin
	term			 := self.myTerminal;					//15.02.2023 navma1 #56561 
	user			 := app.getMyUser();					//15.02.2023 navma1 #56561
	userTerm		 := user.getUserTerminal(term);			//15.02.2023 navma1 #56561
	securityRole	 := userTerm.mySecurityRole;			//15.02.2023 navma1 #56561
	
	_combo.clear();

	if _currentStatus = null then
		_combo.addItem(app.getErrorString(WO_STATUS_USERENTRY_DESC));		
		_combo.addItem(app.getErrorString(WO_STATUS_PENDING_DESC));		
		
		if not _isExternalUser then
			if securityRole.allWorkOrderStatusMaint.includes(WO_STATUS_APPROVED) then			//15.02.2023 navma1 #56561
				_combo.addItem(app.getErrorString(WO_STATUS_APPROVED_DESC));
			endif;
		endif;
		
	elseif _currentStatus &lt;  WO_STATUS_APPROVED then
		_combo.addItem(app.getErrorString(WO_STATUS_USERENTRY_DESC));			
		_combo.addItem(app.getErrorString(WO_STATUS_PENDING_DESC));			

		if not _isExternalUser then
			if securityRole.allWorkOrderStatusMaint.includes(WO_STATUS_APPROVED) then				//15.02.2023 navma1 #56561
				_combo.addItem(app.getErrorString(WO_STATUS_APPROVED_DESC));
			endif;
			if securityRole.allWorkOrderStatusMaint.includes(WO_STATUS_NOTAPPROVED) then			//15.02.2023 navma1 #56561
				_combo.addItem(app.getErrorString(WO_STATUS_NOTAPPROVED_DESC));	
			endif;
			
			if securityRole.allWorkOrderStatusMaint.includes(WO_STATUS_CANCELLED) then				//15.02.2023 navma1 #56561
				_combo.addItem(app.getErrorString(WO_STATUS_CANCELLED_DESC));
			endif;
		endif;
		
	elseif _currentStatus = WO_STATUS_APPROVED then
		_combo.addItem(app.getErrorString(WO_STATUS_APPROVED_DESC));			
		
		if _isExternalUser then
			_combo.addItem(app.getErrorString(WO_STATUS_PENDING_HOLD_DESC));	
			_combo.addItem(app.getErrorString(WO_STATUS_PENDING_CANCEL_DESC));										
		else
			_combo.addItem(app.getErrorString(WO_STATUS_HELD_DESC));
			if securityRole.allWorkOrderStatusMaint.includes(WO_STATUS_CANCELLED) then				//15.02.2023 navma1 #56561
				_combo.addItem(app.getErrorString(WO_STATUS_CANCELLED_DESC));
			endif;
		endif;
		
	elseif  _currentStatus =  WO_STATUS_PARTCOMPLETE then
	
		_combo.addItem(app.getErrorString(WO_STATUS_PARTCOMPLETE_DESC));
		
		if _isExternalUser then
			_combo.addItem(app.getErrorString(WO_STATUS_PENDING_HOLD_DESC));
			_combo.addItem(app.getErrorString(WO_STATUS_PENDING_CANCEL_DESC));											
		else
			_combo.addItem(app.getErrorString(WO_STATUS_HELD_DESC));
			if securityRole.allWorkOrderStatusMaint.includes(WO_STATUS_CANCELLED) then				//15.02.2023 navma1 #56561
				_combo.addItem(app.getErrorString(WO_STATUS_CANCELLED_DESC));
			endif;
		endif;
		
	elseif  _currentStatus =  WO_STATUS_COMPLETE then
		_combo.addItem(app.getErrorString(WO_STATUS_COMPLETE_DESC));
	elseif  _currentStatus =  WO_STATUS_CANCELLED then
		_combo.addItem(app.getErrorString(WO_STATUS_CANCELLED_DESC));			
		
	// new statuses
	
	elseif  _currentStatus =  WO_STATUS_PENDING_CANCEL then
	
		_combo.addItem(app.getErrorString(WO_STATUS_PENDING_CANCEL_DESC));	
	
		if _isExternalUser then									
		else
			_combo.addItem(app.getErrorString(WO_STATUS_PARTCOMPLETE_DESC));
			if securityRole.allWorkOrderStatusMaint.includes(WO_STATUS_CANCELLED) then				//15.02.2023 navma1 #56561
				_combo.addItem(app.getErrorString(WO_STATUS_CANCELLED_DESC));
			endif;
		endif;
		
	elseif  _currentStatus =  WO_STATUS_PENDING_HOLD then
	
		_combo.addItem(app.getErrorString(WO_STATUS_PENDING_HOLD_DESC));	
	
		if _isExternalUser then
			_combo.addItem(app.getErrorString(WO_STATUS_PENDING_CANCEL_DESC));	
		else
			_combo.addItem(app.getErrorString(WO_STATUS_HELD_DESC));
			_combo.addItem(app.getErrorString(WO_STATUS_PARTCOMPLETE_DESC));	
			if securityRole.allWorkOrderStatusMaint.includes(WO_STATUS_CANCELLED) then				//15.02.2023 navma1 #56561
				_combo.addItem(app.getErrorString(WO_STATUS_CANCELLED_DESC));	
			endif;
		endif;
	
	elseif  _currentStatus =  WO_STATUS_HELD then
		_combo.addItem(app.getErrorString(WO_STATUS_HELD_DESC));	
	
		if _isExternalUser then
			_combo.addItem(app.getErrorString(WO_STATUS_PENDING_CANCEL_DESC));	
		else
			_combo.addItem(app.getErrorString(WO_STATUS_PARTCOMPLETE_DESC));				
			if securityRole.allWorkOrderStatusMaint.includes(WO_STATUS_CANCELLED) then				//15.02.2023 navma1 #56561
				_combo.addItem(app.getErrorString(WO_STATUS_CANCELLED_DESC));					
			endif;
		endif;
	
	//14.08.2018 cnwma1 TFS #39698
	elseif  _currentStatus =  WO_STATUS_PENDING_FIN then
		_combo.addItem(app.getErrorString(WO_STATUS_PENDING_FIN_DESC));
	
	//14.08.2018 cnwma1 TFS #39698
	elseif  _currentStatus =  WO_STATUS_REJECTED_FIN then
		_combo.addItem(app.getErrorString(WO_STATUS_REJECTED_FIN_DESC));
	endif;
	
epilog

end;</source>
        <Parameter name="_combo" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_isExternalUser" type="Boolean"/>
        <Parameter name="_currentStatus" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="comboBoxWorkPoint" id="41347049-4f5d-4dbd-b297-4c0311f8182f">
        <source>comboBoxWorkPoint(_cmb : CMUI_ComboBox input; _terminal : CM_Terminal);
/*

Purpose:			

