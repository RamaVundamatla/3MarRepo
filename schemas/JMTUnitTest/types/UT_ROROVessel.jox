    <JadeMethod name="tGraphicStretchDown" id="136bd874-7a4e-4db7-b9fc-5deb806eb0c9">
        <source>tGraphicStretchDown();
// cnwmp6
// CNWMC5
// ---------------------------------------------------------------------------
// Created:     24 March 2011 by NAVAB1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------
constants
	XLEFT = 20;
	XRIGHT = 120;
	YTOP = 20;
	YBOT = 120;
vars
	pxyItemLayout, realItemLayout: CM_DeckItemLayout;
	pointsPolygon : PointArray;
	pxyLayout : CM_DeckLayerLayout;
	pxyDeckLayout : CM_DeckLayout;
	controller : CMIF_RectangleStretch;

	tmpPoint : Point;
	idx : Integer;
begin
	create controller transient;
	// ## PROXY
	create pointsPolygon transient;
	create pxyDeckLayout transient;
	// ## PROXY
	create pxyLayout transient;
	pxyLayout.setProxy("Layer 1", "Layer One", null, pxyDeckLayout, true,ROROLayerType_Structure);


	// ## CREATE 1
	create pxyItemLayout transient;
	pxyItemLayout.setDefaultOutline4(XLEFT,YTOP, XRIGHT, YBOT,pointsPolygon);
	pxyItemLayout.setProxyRORO(DEFAULT_YARD_X, DEFAULT_YARD_Y, null, Black, 0, 0, null, pointsPolygon,"UT_NEW", pxyLayout, Black, Frame.DrawFillStyle_Transparent, 1, true, DeckItemLayoutType_Graphic);
	
	controller.setup(XLEFT, YTOP, pxyItemLayout.pointsPolygon);// XLEFT, YTOP, are not used in stretching
	controller.setupStretch(3,4, false,true);
	// ### STRETCH down to 300
	controller.doStretch(100,300);
	pxyItemLayout.setPointsPolygon(controller.newPoints);

	tmpPoint := pxyItemLayout.getExtremePoint(CM_Graphic.Position_Bottom);
	self.assertTrueMsg(tmpPoint.y = 300,  " Stretch down FAILED");
	
epilog
	delete pointsPolygon;
	delete pxyItemLayout;
	delete pxyLayout;
	delete pxyDeckLayout;
	delete controller;
end;</source>
    </JadeMethod>
    <JadeMethod name="tGraphicStretchLeft" id="974065b8-4596-4aa2-b83e-41ff6db10f73">
        <source>tGraphicStretchLeft();
// cnwmp6
// CNWMC5
// ---------------------------------------------------------------------------
// Created:     24 March 2011 by NAVAB1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------
constants
	XLEFT = 20;
	XRIGHT = 120;
	YTOP = 20;
	YBOT = 120;
vars
	pxyItemLayout, realItemLayout: CM_DeckItemLayout;
	pointsPolygon : PointArray;
	pxyLayout : CM_DeckLayerLayout;
	pxyDeckLayout : CM_DeckLayout;
	controller : CMIF_RectangleStretch;

	tmpPoint : Point;
	idx : Integer;
begin
	create controller transient;
	// ## PROXY
	create pointsPolygon transient;
	create pxyDeckLayout transient;
	// ## PROXY
	create pxyLayout transient;
	pxyLayout.setProxy("Layer 1", "Layer One", null, pxyDeckLayout, true,ROROLayerType_Structure);


	// ## CREATE 1
	create pxyItemLayout transient;
	pxyItemLayout.setDefaultOutline4(XLEFT,YTOP, XRIGHT, YBOT,pointsPolygon);
	pxyItemLayout.setProxyRORO(DEFAULT_YARD_X, DEFAULT_YARD_Y, null, Black, 0, 0, null, pointsPolygon,"UT_NEW", pxyLayout, Black, Frame.DrawFillStyle_Transparent, 1, true, DeckItemLayoutType_Graphic);
	
	controller.setup(XLEFT, YTOP, pxyItemLayout.pointsPolygon);// XLEFT, YTOP, are not used in stretching
	controller.setupStretch(4,5, true, false);
	// ### STRETCH LEFT to 10
	controller.doStretch(10,100);
	pxyItemLayout.setPointsPolygon(controller.newPoints);

	tmpPoint := pxyItemLayout.getExtremePoint(CM_Graphic.Position_Left);
	self.assertTrueMsg(tmpPoint.x = 10,  " Stretch Right FAILED");
	
epilog
	delete pointsPolygon;
	delete pxyItemLayout;
	delete pxyLayout;
	delete pxyDeckLayout;
	delete controller;
end;</source>
    </JadeMethod>
    <JadeMethod name="tGraphicStretchRight" id="5705d211-7234-4d4e-9d5c-6c089a13956c">
        <source>tGraphicStretchRight();
// cnwmp6
// CNWMC5
// ---------------------------------------------------------------------------
// Created:     24 March 2011 by NAVAB1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------
constants
	XLEFT = 20;
	XRIGHT = 120;
	YTOP = 20;
	YBOT = 120;
vars
	pxyItemLayout, realItemLayout: CM_DeckItemLayout;
	pointsPolygon : PointArray;
	pxyLayout : CM_DeckLayerLayout;
	pxyDeckLayout : CM_DeckLayout;
	controller : CMIF_RectangleStretch;

	tmpPoint : Point;
	idx : Integer;
begin
	create controller transient;
	// ## PROXY
	create pointsPolygon transient;
	create pxyDeckLayout transient;
	// ## PROXY
	create pxyLayout transient;
	pxyLayout.setProxy("Layer 1", "Layer One", null, pxyDeckLayout, true,ROROLayerType_Structure);


	// ## CREATE 1
	create pxyItemLayout transient;
	pxyItemLayout.setDefaultOutline4(XLEFT,YTOP, XRIGHT, YBOT,pointsPolygon);
	pxyItemLayout.setProxyRORO(DEFAULT_YARD_X, DEFAULT_YARD_Y, null, Black, 0, 0, null, pointsPolygon,"UT_NEW", pxyLayout, Black, Frame.DrawFillStyle_Transparent, 1, true, DeckItemLayoutType_Graphic);
	
	controller.setup(XLEFT, YTOP, pxyItemLayout.pointsPolygon);// XLEFT, YTOP, are not used in stretching
	controller.setupStretch(2,3, true, false);

	// ### STRETCH RIGHT to 300
	controller.doStretch(300,100);
	pxyItemLayout.setPointsPolygon(controller.newPoints);

	tmpPoint := pxyItemLayout.getExtremePoint(CM_Graphic.Position_Right);
	self.assertTrueMsg(tmpPoint.x = 300,  " Stretch Right FAILED");
	
epilog
	delete pointsPolygon;
	delete pxyItemLayout;
	delete pxyLayout;
	delete pxyDeckLayout;
	delete controller;
end;</source>
    </JadeMethod>
    <JadeMethod name="tGraphicStretchUp" id="46e77e91-10ad-4449-ae9c-3d5f6b3f099d">
        <source>tGraphicStretchUp();
// cnwmp6
// CNWMC5
// ---------------------------------------------------------------------------
// Created:     24 March 2011 by NAVAB1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------
constants
	XLEFT = 20;
	XRIGHT = 120;
	YTOP = 20;
	YBOT = 120;
vars
	pxyItemLayout, realItemLayout: CM_DeckItemLayout;
	pointsPolygon : PointArray;
	pxyLayout : CM_DeckLayerLayout;
	pxyDeckLayout : CM_DeckLayout;
	controller : CMIF_RectangleStretch;

	tmpPoint : Point;
	idx : Integer;
begin
	create controller transient;
	// ## PROXY
	create pointsPolygon transient;
	create pxyDeckLayout transient;
	// ## PROXY
	create pxyLayout transient;
	pxyLayout.setProxy("Layer 1", "Layer One", null, pxyDeckLayout, true,ROROLayerType_Structure);


	// ## CREATE 1
	create pxyItemLayout transient;
	pxyItemLayout.setDefaultOutline4(XLEFT,YTOP, XRIGHT, YBOT,pointsPolygon);
	pxyItemLayout.setProxyRORO(DEFAULT_YARD_X, DEFAULT_YARD_Y, null, Black, 0, 0, null, pointsPolygon,"UT_NEW", pxyLayout, Black, Frame.DrawFillStyle_Transparent, 1, true, DeckItemLayoutType_Graphic);
	
	controller.setup(XLEFT, YTOP, pxyItemLayout.pointsPolygon);// XLEFT, YTOP, are not used in stretching
	controller.setupStretch(1,2, false,true);
	// ### STRETCH up to 10
	controller.doStretch(100,10);
	pxyItemLayout.setPointsPolygon(controller.newPoints);

	tmpPoint := pxyItemLayout.getExtremePoint(CM_Graphic.Position_Top);
	self.assertTrueMsg(tmpPoint.y = 10,  " Stretch Up FAILED");
	
epilog
	delete pointsPolygon;
	delete pxyItemLayout;
	delete pxyLayout;
	delete pxyDeckLayout;
	delete controller;
end;</source>
    </JadeMethod>
    <JadeMethod name="tImportROROVesselStructure" id="f09b7519-5ed8-4d35-8138-58823ae12d01">
        <source>tImportROROVesselStructure();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 April 2011	cnwer1	Initial creation

*/

vars
	vessel : CM_Vessel;
	roroVesselStructure : CM_ROROVesselStructure;
	xmlDocument 	: JadeXMLDocument;
	rootElement 	: JadeXMLElement;
	xmlAttribute 	: JadeXMLAttribute;
	classToCreate	: Class;
	pxyDeck,
	deck			: CM_DeckVessel;
	proxy			: CM_Object;
		theXMLFile : File;	
	xmlParser : JadeXMLDocumentParser;
	xmlString 	: String;
begin
	self.tCreateROROVesselSubDeck();
	vessel:=self.getVessel("UT_RORO" );
	self.assertNotNullMsg(vessel,"Vessel = null!");
	
	roroVesselStructure:=vessel.myROROVesselStructure;
	self.assertNotNullMsg(roroVesselStructure,"RORO Vessel Structure = null!");
	
	//export need fileName , obj to export 
	
	// for unit test sake will test the CM_Object method
	// in the trx i don't want to have to pass in the jadeXMLDocument that will be the reponsibility of the trx method
	// However i do want to validate that the jade xml document is correct
	
	//create xmlDocument transient;
	create theXMLFile transient;
	//theXMLFile.mode:=File.Mode_IO;
	theXMLFile.mode :=	File.Mode_Output;	// 25/2/16 cnwmp6 PAR 36286 unicode version
	//theXMLFile.fileName:="C:\Temp\" &amp; method.name &amp; ".xml";
	theXMLFile.fileName:="C:\Temp\" &amp; method.name &amp; "_" &amp;app.myRoot.getConfig(SystemTitle).String &amp; ".xml";
	theXMLFile.writeLine('&lt;?xml version="1.0"?&gt;');
	theXMLFile.writeLine(J_key_LessThan.Character &amp; roroVesselStructure.class.name &amp; " " &amp; 'type="' &amp;  roroVesselStructure.class.name &amp; '"'&amp;J_key_GreaterThan.Character);
	
	roroVesselStructure.exportAsXMLDoc(theXMLFile);
	theXMLFile.writeString(self.formatAsXMLSuffix( roroVesselStructure.class.name));
	theXMLFile.close;
	theXMLFile.mode := File.Mode_Input;	// 25/2/16 cnwmp6 PAR 36286 unicode version
	theXMLFile.kind := File.Kind_Unknown_Text;	// 25/2/16 cnwmp6 PAR 36286 unicode version
	theXMLFile.open;
	xmlString:= theXMLFile.readString(theXMLFile.fileLength);
	create xmlParser transient;
	create xmlDocument transient;
	xmlParser.parseDocumentString(xmlDocument,xmlString);
	// do the import first create a proxy
	
	rootElement:=xmlDocument.rootElement;
	//get the class to create 
	xmlAttribute:=rootElement.getAttributeByName('type');
	
	classToCreate:=self.getClass(xmlAttribute.value);
	
	create proxy as classToCreate transient;
	proxy.importFromXMLDoc(rootElement);
	
	self.assertEqualMsg(proxy.class,CM_ROROVesselStructure,"imported correct class");
	self.assertEqualMsg(proxy.CM_ROROVesselStructure.type,roroVesselStructure.type,"imported CM_ROROVesselStructure type !=");
	
	self.assertEqualMsg(proxy.CM_ROROVesselStructure.allDecks.size, roroVesselStructure.allDecks.size, "imported CM_ROROVesselStructure alLDecks size !=");
	
	pxyDeck:=proxy.CM_ROROVesselStructure.allDecks.first;
	deck:=roroVesselStructure.allDecks.first;
	
	

	
epilog
	
	delete proxy;
	delete xmlDocument;
	delete theXMLFile;
	delete xmlParser;
end;</source>
    </JadeMethod>
    <JadeMethod name="tUpdateVesselRORODeck" id="5717d24e-c79b-4e19-bc9f-1012834bd6b1">
        <source>tUpdateVesselRORODeck();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 March 2011	cnwer1	Initial creation

*/

vars
	pxyDeck, 
	realDeck : CM_DeckVessel;
	code : String;
	description : String;
	remarks : String;
	maxClearHeight,
	totalArea : Decimal[12,2];
	ordinal: Integer;
	totalVolume : Decimal[12,2];
	totalTEU : Integer;
	totalLM,
	maxLoadStack20,
	maxLoadStack40,
	maxLoadAxel,
	maxLoadM2   : Decimal[12,2];
	numTier : Integer;
	heightFromBL : Decimal[12,2];
	vessel : CM_Vessel;
begin

	self.tCreateROROVesselDeck();
	vessel:=self.getVessel("UT_RORO" );
	realDeck:=vessel.myROROVesselStructure.allDecks[1];
	
	code:=DECK1;
	description:="DECK1 Description2";
	remarks:="Some decking remarks2";
	maxClearHeight:=20.52;
	totalArea:=20000.67;
	totalVolume:=232.89;
	totalTEU:=20000;
	totalLM:=23423.42;
	maxLoadStack20:=12342.62;
	maxLoadStack40:=62423.52;
	maxLoadAxel:=87534.42;
	maxLoadM2:=234.52;
	numTier:=2;
	heightFromBL:=63455.62;
	ordinal:=realDeck.ordinal;
	
	
	pxyDeck:=app.createUpdateProxy( realDeck).CM_DeckVessel;
	
	pxyDeck.setProxy(	code ,
						description,
						remarks,
						maxClearHeight,
						totalArea,
						totalVolume,
						totalTEU,
						totalLM,
						maxLoadStack20,
						maxLoadStack40,
						maxLoadAxel,
						maxLoadM2 ,
						numTier ,
						heightFromBL );
	
	app.myTrxUA.trxUpdateRORODeck(pxyDeck,app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	
	self.assertNotNullMsg(realDeck, " Real deck = null");
	self.assertEqualMsg(realDeck.myROROStructure, vessel.myROROVesselStructure, " myROROStructure ref = null");
	self.assertEqualMsg(realDeck.code, code,"code !=");
	self.assertEqualMsg(realDeck.description, description,"description !=");
	self.assertEqualMsg(realDeck.remarks, remarks,"remarks !=");
	self.assertEqualMsg(realDeck.maxClearHeight, maxClearHeight,"maxClearHeight !=");
	self.assertEqualMsg(realDeck.totalArea, totalArea,"totalArea !=");
	self.assertEqualMsg(realDeck.ordinal, ordinal,"ordinal !=");
	self.assertEqualMsg(realDeck.totalVolume, totalVolume,"totalVolume !=");
	self.assertEqualMsg(realDeck.totalTEU, totalTEU,"totalTEU !=");
	self.assertEqualMsg(realDeck.maxLoadStack20, maxLoadStack20,"maxLoadStack20 !=");
	self.assertEqualMsg(realDeck.maxLoadStack40, maxLoadStack40,"maxLoadStack40 !=");
	self.assertEqualMsg(realDeck.maxLoadAxel, maxLoadAxel,"maxLoadAxel !=");
	self.assertEqualMsg(realDeck.maxLoadM2, maxLoadM2,"maxLoadM2 !=");
	self.assertEqualMsg(realDeck.numTier, numTier,"numTier !=");
	self.assertEqualMsg(realDeck.heightFromBL, heightFromBL,"heightFromBL !=");
	
	
	
	
epilog
	delete pxyDeck;
end;</source>
    </JadeMethod>
    <JadeMethod name="tVesselExternalRamp" id="8287af39-b569-4102-b85f-ee1474976e19">
        <source>tVesselExternalRamp();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	vessel : CM_Vessel;
	vesselStructure :  CM_VesselStructuralElements;
	roroRampExternalVessel, realRamp : CM_RORORampExternalVessel;
	realDeckItem : CM_DeckItem;
	code,
	description,
	remarks  :String;
	isMovable : Boolean;
	length,
	maxClearHeight,
	maxLoadAxel ,
	maxLoadM2,
	maxLoadTotal ,
	width : Decimal[12,2];
begin
	self.tCreateROROVesselDeck();
	vessel:=self.getVessel("UT_RORO" );
	self.assertNotNullMsg(vessel, "vessel = null");
	vesselStructure:=vessel.myStructuralElements;
	
	create roroRampExternalVessel transient;
	code:="External Ramp";
	description :="External Ramp description";
	remarks:="Some External Ramp remarks blah blah blah";
	roroRampExternalVessel.setProxyDeckItem(code,description,remarks,null,null);
	
	isMovable :=false;
	length :=23123;
	maxClearHeight:=2341;
	maxLoadAxel:=456.34;
	maxLoadM2:=234.11;
	maxLoadTotal:=2134.66;
	width:=1234.12;
	
	roroRampExternalVessel.setProxyRamp(isMovable,length,maxClearHeight,maxLoadAxel,maxLoadM2,maxLoadTotal,width);
	
	roroRampExternalVessel.setMyRampPosition(null);
	roroRampExternalVessel.setMyROROStructure(vesselStructure);
	
	app.myTrxCA.trxCreateRORODeckItem(roroRampExternalVessel,realDeckItem,app.myPassport);
	
	
	
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(realDeckItem,"realRamp is null");
	self.assertTrueMsg(realDeckItem.isKindOf(CM_RORORampExternalVessel), "realRamp is kindOf CM_RORORampExternalVessel");
	realRamp:=realDeckItem.CM_RORORampExternalVessel;
	self.assertEqualMsg(realRamp.code,code,"realRamp code !=");
	self.assertEqualMsg(realRamp.description,description,"realRamp description !=");
	self.assertEqualMsg(realRamp.remarks,remarks,"realRamp remarks !=");
	self.assertEqualMsg(realRamp.myVesselStructuralElement,vesselStructure,"realRamp vesselStructure !=");
	self.assertEqualMsg(realRamp.isMovable,isMovable,"realRamp isMovable !=");
	self.assertEqualMsg(realRamp.length,length,"realRamp length !=");
	self.assertEqualMsg(realRamp.maxClearHeight,maxClearHeight,"realRamp maxClearHeight !=");
	self.assertEqualMsg(realRamp.maxLoadAxel,maxLoadAxel,"realRamp maxLoadAxel !=");
	self.assertEqualMsg(realRamp.maxLoadM2,maxLoadM2,"realRamp maxLoadM2 !=");
	self.assertEqualMsg(realRamp.maxLoadTotal,maxLoadTotal,"realRamp maxLoadTotal !=");
	self.assertEqualMsg(realRamp.width,width,"realRamp width !=");
	
	delete roroRampExternalVessel;
	
	code:="lift2";
	description :="lift description2";
	remarks:="Some lift remarks2 blah blah blah";
	isMovable :=true;
	length :=23.64;
	maxClearHeight:=234.98;
	maxLoadAxel:=426.34;
	maxLoadM2:=234.19;
	maxLoadTotal:=2134.69;
	width:=1234.19;
	
	
	roroRampExternalVessel:=app.createUpdateProxy(realRamp).CM_RORORampExternalVessel;
	self.assertNotNullMsg(roroRampExternalVessel,"proxy ramp is null");
	
	roroRampExternalVessel.setProxyDeckItem(code,description,remarks,null,null);
	roroRampExternalVessel.setProxyRamp(isMovable,length,maxClearHeight,maxLoadAxel,maxLoadM2,maxLoadTotal,width);
	
	app.myTrxUA.trxUpdateRORODeckItem(roroRampExternalVessel,app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	
	self.assertEqualMsg(realRamp.code,code,"realRamp code !=");
	self.assertEqualMsg(realRamp.description,description,"realLift description !=");
	self.assertEqualMsg(realRamp.remarks,remarks,"realRamp remarks !=");
	self.assertEqualMsg(realRamp.isMovable,isMovable,"realRamp isMovable !=");
	self.assertEqualMsg(realRamp.length,length,"realRamp length !=");
	self.assertEqualMsg(realRamp.maxClearHeight,maxClearHeight,"realRamp maxClearHeight !=");
	self.assertEqualMsg(realRamp.maxLoadAxel,maxLoadAxel,"realRamp maxLoadAxel !=");
	self.assertEqualMsg(realRamp.maxLoadM2,maxLoadM2,"realRamp maxLoadM2 !=");
	self.assertEqualMsg(realRamp.maxLoadTotal,maxLoadTotal,"realRamp maxLoadTotal !=");
	self.assertEqualMsg(realRamp.width,width,"realRamp width !=");
	
	return;

	app.myTrxDA.trxDeleteRORODeckItem(realRamp,app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	
	self.assertIsDeleted(realRamp);
	
	
epilog
	delete roroRampExternalVessel;
end;</source>
    </JadeMethod>
    <JadeMethod name="tVesselLift" id="40b79a24-312a-42e9-adbd-32889d800e27">
        <source>tVesselLift();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	lift , realLift: CM_ROROLift;
	 realDeckItem : CM_DeckItem;
	vessel : CM_Vessel;
	vesselStructure : CM_VesselStructure;
	realDeck : CM_DeckVessel;
	code,
	description,
	remarks  :String;
	isMovable : Boolean;
	length,
	maxClearHeight,
	maxLoadAxel ,
	maxLoadM2,
	maxLoadTotal ,
	width : Decimal[12,2];
begin


	self.tCreateROROVesselDeck();
	vessel:=self.getVessel("UT_RORO" );
	self.assertNotNullMsg(vessel, "vessel = null");
	vesselStructure:=vessel.myROROVesselStructure;
	realDeck:=vessel.myROROVesselStructure.allDecks[1];
	
	create lift transient;
	
	code:="lift";
	description :="lift description";
	remarks:="Some lift remarks blah blah blah";
	lift.setProxyDeckItem(code,description,remarks,realDeck,null);
	
	isMovable :=false;
	length :=23123;
	maxClearHeight:=2341;
	maxLoadAxel:=456.34;
	maxLoadM2:=234.11;
	maxLoadTotal:=2134.66;
	width:=1234.12;
	
	lift.setProxyRamp(isMovable,length,maxClearHeight,maxLoadAxel,maxLoadM2,maxLoadTotal,width);
	
	app.myTrxCA.trxCreateRORODeckItem(lift,realDeckItem,app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(realDeckItem,"realLift is null");
	self.assertTrueMsg(realDeckItem.isKindOf(CM_ROROLift),"realLift is kind of CM_ROROLift");
	realLift:=realDeckItem.CM_ROROLift;
	self.assertEqualMsg(realLift.code,code,"realLift code !=");
	self.assertEqualMsg(realLift.description,description,"realLift description !=");
	self.assertEqualMsg(realLift.remarks,remarks,"realLift remarks !=");
	self.assertEqualMsg(realLift.myDeck,realDeck,"realLift realDeck !=");
	self.assertEqualMsg(realLift.isMovable,isMovable,"realLift isMovable !=");
	self.assertEqualMsg(realLift.length,length,"realLift length !=");
	self.assertEqualMsg(realLift.maxClearHeight,maxClearHeight,"realLift maxClearHeight !=");
	self.assertEqualMsg(realLift.maxLoadAxel,maxLoadAxel,"realLift maxLoadAxel !=");
	self.assertEqualMsg(realLift.maxLoadM2,maxLoadM2,"realLift maxLoadM2 !=");
	self.assertEqualMsg(realLift.maxLoadTotal,maxLoadTotal,"realLift maxLoadTotal !=");
	self.assertEqualMsg(realLift.width,width,"realLift width !=");
	
	delete lift;
	
	code:="lift2";
	description :="lift description2";
	remarks:="Some lift remarks2 blah blah blah";
	isMovable :=true;
	length :=23.64;
	maxClearHeight:=234.98;
	maxLoadAxel:=426.34;
	maxLoadM2:=234.19;
	maxLoadTotal:=2134.69;
	width:=1234.19;
	
	
	lift:=app.createUpdateProxy(realLift).CM_ROROLift;
	self.assertNotNullMsg(lift,"proxy lift is null");
	
	lift.setProxyDeckItem(code,description,remarks,realDeck,null);
	lift.setProxyRamp(isMovable,length,maxClearHeight,maxLoadAxel,maxLoadM2,maxLoadTotal,width);
	
	app.myTrxUA.trxUpdateRORODeckItem(lift,app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	
	self.assertEqualMsg(realLift.code,code,"realLift code !=");
	self.assertEqualMsg(realLift.description,description,"realLift description !=");
	self.assertEqualMsg(realLift.remarks,remarks,"realLift remarks !=");
	self.assertEqualMsg(realLift.isMovable,isMovable,"realLift isMovable !=");
	self.assertEqualMsg(realLift.length,length,"realLift length !=");
	self.assertEqualMsg(realLift.maxClearHeight,maxClearHeight,"realLift maxClearHeight !=");
	self.assertEqualMsg(realLift.maxLoadAxel,maxLoadAxel,"realLift maxLoadAxel !=");
	self.assertEqualMsg(realLift.maxLoadM2,maxLoadM2,"realLift maxLoadM2 !=");
	self.assertEqualMsg(realLift.maxLoadTotal,maxLoadTotal,"realLift maxLoadTotal !=");
	self.assertEqualMsg(realLift.width,width,"realLift width !=");
	
	
/*
	app.myTrxDA.trxDeleteRORODeckItem(realLift,app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	
	self.assertIsDeleted(realLift);*/
epilog
	delete lift;

end;</source>
    </JadeMethod>
    <JadeMethod name="tVesselSection" id="987c1cde-07e0-4f11-8c3b-543838be411d">
        <source>tVesselSection();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

	section 	: CM_VesselSectionVessel;
	realSection	: CM_VesselSection;
	vessel : CM_Vessel;
	vesselStructure : CM_VesselStructuralElements;
	code,
	description,
	remarks  :String;
	position : Decimal[12,2];
begin


	self.tCreateROROVesselDeck();
	vessel:=self.getVessel("UT_RORO" );
	self.assertNotNullMsg(vessel, "vessel = null");
	vesselStructure:=vessel.myStructuralElements;
	
	create section transient;
	
	code:="Sec1";
	remarks:="Some section remarks blah blah blah";
	position:=126.65;
	section.setProxy(code,position,remarks);
	section.setMyVesselStructure(vesselStructure);
	
	app.myTrxCA.trxCreateVesselSection(section,realSection,app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(realSection,"real CM_VesselSectionVessel is null");
	self.assertEqualMsg(realSection.code,code,"Section code !=");
	self.assertEqualMsg(realSection.remarks,remarks,"Section remarks !=");
	self.assertEqualMsg(realSection.position,position,"Section volume !=");
	self.assertEqualMsg(realSection.CM_VesselSectionVessel.myVesselStructuralElement,vesselStructure,"Section vesselStructure !=");
	
	delete section;
	
	code:="Sec2";
	remarks:="Some Section remarks2 blah blah blah";
	position:=2121.213;
	
	section:=app.createUpdateProxy(realSection).CM_VesselSectionVessel;
	self.assertNotNullMsg(section,"proxy section is null");
	
	section.setProxy(code,position,remarks);
	
	app.myTrxUA.trxUpdateVesselSection(section,app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	
	self.assertEqualMsg(realSection.code,code,"Section code !=");
	self.assertEqualMsg(realSection.remarks,remarks,"Section remarks !=");
	self.assertEqualMsg(realSection.position,position,"Section position !=");
	self.assertEqualMsg(realSection.CM_VesselSectionVessel.myVesselStructuralElement,vesselStructure,"Section vesselStructure !=");

	
	app.myTrxDA.trxDeleteVesselSection(realSection,app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	
	self.assertIsDeleted(realSection);
epilog
	delete section;
end;</source>
    </JadeMethod>
    <JadeMethod name="tVesselStructElementsUpdateVoy" id="dc8a1ade-2bcb-4d06-b2d3-b833a3ec17f4">
        <source>tVesselStructElementsUpdateVoy();
// CNWMA1
// ---------------------------------------------------------------------------
// Created:     NAVAB1 PAR 33365 check that a voyage update does not error with duplicate structural element (tanks, ramp) errors
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------
constants
	VESSEL_NAME = "UT_RORO";
	RAMP_NAME = "UT_RAMP";
	TANK_NAME = "UT_TANK";
	TANK_TYPE= "UT_TANKTYPE";
	SECTION_NAME1 = "UT1";
	VOYAGE_NAME= "UT_STRUCTURE";
vars
	vessel : CM_Vessel;
	vesselStructure :  CM_VesselStructuralElements;
	realRamp : CM_RORORampExternalVessel;
	tankType : CM_VesselTankContentsType;
	pxyVoyage, realVoyage : CM_Voyage;
	conflictManager : CMIF_HMS_ConflictsManager;
begin

	// #### VESSEL
	self.tCreateROROVesselDeck();
	vessel:=self.getVessel(VESSEL_NAME);
	self.assertNotNullMsg(vessel, "vessel = null");
	vesselStructure:=vessel.myStructuralElements;
	
	// #### RAMP
	self.deleteVesselRamp(vesselStructure, RAMP_NAME);
	realRamp := self.addVesselRamp(vesselStructure, RAMP_NAME);

	// #### TANK
	self.deleteVesselTankContentType(TANK_TYPE);
	tankType := self.addVesselTankContentType(TANK_TYPE);

	self.deleteVesselTank(vesselStructure, TANK_NAME);
	self.addVesselTank(vesselStructure, TANK_NAME, tankType);
	
	// #### SECTIONS
	self.deleteVesselSection(vesselStructure, SECTION_NAME1);
	self.addVesselSection(vesselStructure, SECTION_NAME1, 12.0);
	
	// ### VOYAGE
	self.deleteVoyage(VOYAGE_NAME);
	realVoyage := self.addVoyageWithConRORO(VOYAGE_NAME, VESSEL_NAME, "MSL","MSC","Unit Test Trade", 3, false,false);
	
	pxyVoyage := app.createUpdateProxy(realVoyage).CM_Voyage;
	app.myTrxUA.trxUpdateVoyage(false, false, pxyVoyage, conflictManager,null,false, app.myPassport); 
	self.assertNoTrxErrorsOrWarnings();
epilog
	delete pxyVoyage;
end;</source>
    </JadeMethod>
    <JadeMethod name="tVesselTank" id="a32b232b-2762-4eb7-932d-614b3aa37e52">
        <source>tVesselTank();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	tank : CM_VesselTankVessel;
	realTank : CM_VesselTank;
	vessel : CM_Vessel;
	vesselStructure : CM_VesselStructuralElements;
	code,
	description,
	remarks  :String;
	volume : Decimal[12,2];
begin


	self.tCreateROROVesselDeck();
	vessel:=self.getVessel("UT_RORO" );
	self.assertNotNullMsg(vessel, "vessel = null");
	vesselStructure:=vessel.myStructuralElements;
	
	create tank transient;
	
	code:="Tank";
	description :="Tank description";
	remarks:="Some Tank remarks blah blah blah";
	volume:=121.213;
	tank.setProxy(code,description,remarks,volume,null);
	tank.setMyVesselStructure(vesselStructure);
	
	app.myTrxCA.trxCreateVesselTank(tank,realTank,app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(realTank,"real tank is null");
	self.assertTrueMsg(realTank.isKindOf(CM_VesselTankVessel),"Tank is kindof vesselTankVessel");
	self.assertEqualMsg(realTank.code,code,"Tank code !=");
	self.assertEqualMsg(realTank.description,description,"Tank description !=");
	self.assertEqualMsg(realTank.remarks,remarks,"Tank remarks !=");
	self.assertEqualMsg(realTank.volume,volume,"Tank volume !=");
	self.assertEqualMsg(realTank.CM_VesselTankVessel.myVesselStructuralElement,vesselStructure,"Tank vesselStructure !=");
	
	delete tank;
	
	code:="Tank2";
	description :="Tank description2";
	remarks:="Some Tank remarks2 blah blah blah";
	volume:=2121.213;
	
	tank:=app.createUpdateProxy(realTank).CM_VesselTankVessel;
	self.assertNotNullMsg(tank,"proxy tank is null");
	
	tank.setProxy(code,description,remarks,volume,null);
	
	app.myTrxUA.trxUpdateVesselTank(tank,app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	
	self.assertEqualMsg(realTank.code,code,"Tank code !=");
	self.assertEqualMsg(realTank.description,description,"Tank description !=");
	self.assertEqualMsg(realTank.remarks,remarks,"Tank remarks !=");
	self.assertEqualMsg(realTank.volume,volume,"Tank volume !=");
	self.assertEqualMsg(realTank.CM_VesselTankVessel.myVesselStructuralElement,vesselStructure,"Tank vesselStructure !=");
	
	

	app.myTrxDA.trxDeleteVesselTank(realTank,app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	
	self.assertIsDeleted(realTank);
epilog
	delete tank;
end;</source>
    </JadeMethod>
    <JadeMethod name="tVoyageGetNextNumWorkPoint" id="f2dbb915-35a4-4afe-ab1b-07c3a6c1477c">
        <source>tVoyageGetNextNumWorkPoint();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 August 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars
	voyage : CM_Voyage;
	workPoint : CM_WorkPoint;
	nextNum : String;
	jobSheet : CM_VoyageDeckJobSheet;
begin

	
	jobSheet:=self.xCreateDeckJobSheet("UT_ROROOP","UT_ROROOP1","UT_WP");
	voyage:= jobSheet.myVoyage;
	workPoint:=jobSheet.myWorkPoint;
	
	//add a job sheet
	//no work point should return 200 still as looks at it from the job sheet
	nextNum:=voyage.getNextJobNumber(jobSheet,null);
	
	self.assertEqualMsg(nextNum,"200","job next num != 200");
	
	nextNum:=voyage.getNextJobNumber(jobSheet,workPoint);
	
	self.assertEqualMsg(nextNum,"200","job next num != 200");
	
epilog

end;</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;WorkPointDeleteIssue&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="uCreateDIAMDLRSOBJobs" id="6e282ca1-2ed4-48ee-9487-0c55036908c2">
        <source>uCreateDIAMDLRSOBJobs();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 February 2012	cnwer1	Initial creation CCMS MES 1033

*/

vars
	iter : Iterator;
	 lcSet : CM_LCSet;
	sobSlots,
	altSOBSlots, 
	altDLRSlots,
	dlrSlots : CM_LCArray;
	vc, vc2 : CM_VoyageROROController;
	editions : CM_ObjectByOidEditionDict;
	voyage : CM_Voyage;
		deck : CM_DeckVoyage; 
		i : Integer;
		lc : CM_LocationsController;
begin

	voyage:= self.getVoyage("EPRDIAM3");
	deck:=voyage.myROROStructure.allDecksByCode["2"];
	create lcSet transient;
	deck.allROROSlotControllers.copy(lcSet);
	
	// take some of the on board cargo created and set aside for sob and dlr
	create sobSlots transient;
	create dlrSlots transient;
	create altSOBSlots transient;
	create altDLRSlots transient;
	
	delete iter;
	iter:=lcSet.createIterator;
	i := 1;
	while iter.back(lc) do
		if i &lt; 6 then
			sobSlots.add(lc.CM_VoyageROROController);
		elseif i &lt; 11 then
			dlrSlots.add(lc.CM_VoyageROROController);
		else 
			break;
		endif;
		i:=i+1;
	endwhile;
		create editions transient;
	
	deck:=voyage.myROROStructure.allDecksByCode["1"];
	delete iter;
	iter:= deck.allROROSlotControllers.createIterator;
	iter.next(vc2);
	foreach lc in sobSlots do
		vc := lc.CM_VoyageROROController;
		
		editions.add(vc);
		
		iter.next(vc2);
		altSOBSlots.add(vc2);
		editions.add(vc2);
	endforeach;
	//create some SOB jobs
	app.myTrxUA.doRORORequestDLRSoB(sobSlots, altSOBSlots, false,SOB_MOVETYPE, editions, app.myPassport);	
	self.assertNoTrxErrorsOrWarnings;
	
	editions.clear;
	foreach lc in dlrSlots do
		vc := lc.CM_VoyageROROController;
		editions.add(vc);
		
		iter.next(vc2);
		altDLRSlots.add(vc2);
		editions.add(vc2);
	endforeach;
	//create some DLR jobs
	app.myTrxUA.doRORORequestDLRSoB(dlrSlots, altDLRSlots, false,DLR_MOVETYPE, editions, app.myPassport);	
	self.assertNoTrxErrorsOrWarnings;
epilog
	delete iter;
	delete lcSet;

	delete sobSlots;
	delete dlrSlots;
	delete editions;
	delete altSOBSlots;
	delete altDLRSlots;
end;</source>
    </JadeMethod>
    <JadeMethod name="uCreateDischJobsForDIAM" id="475cd453-d2ee-45a4-8287-c02a33218194">
        <source>uCreateDischJobsForDIAM();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 December 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars
	iter : Iterator;
	 lcSet : CM_LCSet;
	deck : CM_DeckVoyage;
	voyage : CM_Voyage;
	wpB, wpA :  CM_WorkPoint;
	i :Integer;
	sobSlots,
	altSOBSlots, 
	altDLRSlots,
	dlrSlots : CM_VoyageROROControllerArray;
	lc : CM_LocationsController;
	
	vc : CM_VoyageROROController;
	voyageCode : String;
begin
	
	voyageCode := "EPRDIAM3";
	read voyageCode;
	voyage:= self.getVoyage(voyageCode);
	deck:=voyage.myROROStructure.allDecksByCode["2"];
	wpA:=self.getTerminal.allWorkPointsByCode["DIAMA"];
	wpB:= self.getTerminal.allWorkPointsByCode["DIAMB"];
	
/*	create lcSet transient;
	deck.allROROSlotControllers.copy(lcSet);
	
	// take some of the on board cargo created and set aside for sob and dlr
	create sobSlots transient;
	create dlrSlots transient;
	
	delete iter;
	iter:=lcSet.createIterator;
	i := 1;
	while iter.back(lc) do
		if i &lt; 6 then
			sobSlots.add(lc.CM_VoyageROROController);
		elseif i &lt; 11 then
			dlrSlots.add(lc.CM_VoyageROROController);
		else 
			break;
		endif;
		i:=i+1;
	endwhile;
	
	foreach vc  in sobSlots do
		lcSet.remove(vc);
	endforeach;
	
	foreach vc  in dlrSlots do
		lcSet.remove(vc);
	endforeach;
	
	self.ignoreTrxWarnings(true);
	app.myTrxCA.trxCreateRORODischargeCCs(lcSet,app.myPassport);
	*/
	
	self.createDischJobsForRORO(voyage,deck,wpA, wpB);
	
		
epilog
	delete iter;
	delete lcSet;
	delete sobSlots;
	delete dlrSlots;
end;</source>
    </JadeMethod>
    <JadeMethod name="uCreatePlannedDIAMVoyage" id="d7b0ab87-ce48-4e76-bb55-b478f65f8d5f">
        <updating/>
        <source>uCreatePlannedDIAMVoyage() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 November 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	voyageCode : String;
	trade		: CM_Trade;
	portRotation : CM_PortRotation;
	port 		: CM_Port;
	voyAlloc20s 	: ObjectArray;
	voyAlloc40s		: ObjectArray;
	deck 			: CM_DeckVoyage;
	all40FrontSlotDefn,
	all20SlotDefns		 : CM_ROROSlotLCsByOrdDict;
	iter				: Iterator;
	slotController 	: CM_ROROSlotController;
	slotDefn			: CM_ROROSlotDefn;
	locnDefn			: CM_ROROLocnDefn;
	ccSize, ccIndex				: Integer;
	allJobSlots ,altSlots	: CM_LCArray;
	voyAlloc		: CM_VoyageAllocation;
	workPoints : ObjectArray;
	wpA,
	wpB,
	wpC: CM_WorkPoint;
	oowController : CMIF_OOWCreationAutoUpdate;
	jobController : CMIF_VoyageJobParams;
	request : CM_RORORequest;
	i : Integer;
	operator : CM_Operator;
	ti : CM_TrackedItem;
	bs 	: CM_BlockStack;
	lcs, lcSet : CM_LCSet;
	theJobParams : CMIF_VoyageJobParams;
	job : CM_Job;
	lc : CM_LocationsController;
	ct: CM_CargoType;
	sobSlots,
	altSOBSlots, 
	altDLRSlots,
	dlrSlots : CM_LCArray;
	vc, vc2 : CM_VoyageROROController;
	editions : CM_ObjectByOidEditionDict;
begin
	//DIAM is a vessel loaded from XML from MESSINA 
	vessel	:= self.getVessel( "JDIA" );
	
	if vessel = null then
		return;
	endif;
	
	trade:= app.myRoot.allTradesByDescription["Maersk"];
	
	if trade = null then
		return;
	endif;
	
	voyageCode := "UTDIAM1";
	read voyageCode;
	
	self.deleteVoyage(voyageCode);
	self.assertNull( self.getVoyage(voyageCode));
	
	voyage:=self.addVoyageWithConRORO(voyageCode, vessel.code, "ANL", "ANZ", null, 0, false, true);
	operator:=voyage.myOperator;

	beginTransaction;
	voyage.setMyTrade(trade);
	commitTransaction;
	
	create voyAlloc20s transient;
	create voyAlloc40s transient;
	// create voyage allocations for each port in the trade	
	foreach portRotation in trade.allPortRotations discreteLock do
		port:=portRotation.myPort;
		//add 20 ft container voyage allocation for port 
		voyAlloc20s.add(self.addVoyageAllocation(voyage, port.code,"GEN2",null,1,false,false));
		//add 40 ft container voyage allocation for port 
		voyAlloc40s.add(self.addVoyageAllocation(voyage, port.code,"GEN4",null,1,false,false));
	endforeach;
	
	bs:=self.addBlockStack("DIAM",10000,null);	

	// create the work points
	wpA :=self.addWorkPoint("DIAMA", true);
	wpB :=self.addWorkPoint("DIAMB", true);
	wpC :=self.addWorkPoint("DIAMC", true);
	//create the job sheets
	
	create workPoints transient;
	workPoints.add(wpA);
	workPoints.add(wpB);
	workPoints.add(wpC);
	
	app.myTrxUA.trxUpdateVoyageJobSheet(workPoints,voyage,CM_VoyageDeckJobSheet,app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings;
	
	// Container
	create all40FrontSlotDefn  transient;
	create all20SlotDefns	transient;

	deck:=voyage.myROROStructure.allDecksByCode["3"];
	iter:= deck.allROROSlotControllers.createIterator;
	while iter.next(slotController) do
		locnDefn:=slotController.mySlotDefn.myROROLocnDen;
		if locnDefn.myAdjacentSlotAft &lt;&gt; null or locnDefn.myAdjacentSlotFwd &lt;&gt; null then
			if locnDefn.myAdjacentSlotAft &lt;&gt; null then
				if not all40FrontSlotDefn.includes(locnDefn.myAdjacentSlotAft.allROROSlotDefnByOrdinal.first.CM_ROROSlotDefnVoyage.mySlotController) then
					all40FrontSlotDefn.add(slotController);
				endif;
			endif;
		else
			all20SlotDefns.add(slotController);
		endif;	
	endwhile;
	
	delete iter;
	deck:=voyage.myROROStructure.allDecksByCode["4"];  // Lets plan some 5 and 6 high slots
	iter:= deck.allROROSlotControllers.createIterator;
	i := 0;
	create lcs transient;
	while iter.next(slotController) and i &lt;= 200 do
		locnDefn:=slotController.mySlotDefn.myROROLocnDen;
		locnDefn.getLCs(lcs, true);
		if lcs.size &lt; 6 then
			continue;
		endif;
		if locnDefn.myAdjacentSlotAft &lt;&gt; null or locnDefn.myAdjacentSlotFwd &lt;&gt; null then
			if locnDefn.myAdjacentSlotAft &lt;&gt; null then
				if not all40FrontSlotDefn.includes(locnDefn.myAdjacentSlotAft.allROROSlotDefnByOrdinal.first.CM_ROROSlotDefnVoyage.mySlotController) then
					all40FrontSlotDefn.add(slotController);
					i := i + 1;
				endif;
			endif;
		else
			all20SlotDefns.add(slotController);
			i := i + 1;
		endif;
	endwhile;
	
	//do all 20ft slots hoping that because they are ordered by ordinal the slots will be positioned close to each other
	create allJobSlots transient;
	create altSlots transient;
	write all20SlotDefns.size;
	write voyAlloc20s.size;
	
	ccSize:=(all20SlotDefns.size/(voyAlloc20s.size)).roundedUp;
	write ccSize;
	
	self.ignoreTrxWarnings(true);
	
	ccIndex:=1;
	delete iter;
	iter:=all20SlotDefns.createIterator;
	while iter.next(slotController) do
		allJobSlots.add(slotController);
		
		// once we get size for color coding CC the sucker
		if allJobSlots.size = ccSize then
			voyAlloc:=voyAlloc20s[ccIndex].CM_VoyageAllocation;
			self.ignoreTrxWarnings(true);
			slotDefn:=slotController.mySlotDefn;
			locnDefn:=slotDefn.myROROLocnDen;
			while true do
				slotDefn:=slotController.mySlotDefn;
				if slotDefn &lt;&gt; locnDefn.allROROSlotDefnByOrdinal.last then
					iter.next(slotController);
					allJobSlots.add(slotController);
				else
					break;
				endif;
			endwhile;
			
			self.addLCsToROROAllocation(true,voyAlloc,allJobSlots,altSlots,1);
			allJobSlots.clear;
			ccIndex:=ccIndex+1;
		endif;
	endwhile;
	
	if allJobSlots.size &gt; 0 then
		voyAlloc:=voyAlloc20s[ccIndex].CM_VoyageAllocation;
		self.ignoreTrxWarnings(true);
	
		self.addLCsToROROAllocation(true,voyAlloc,allJobSlots,altSlots,1);
		allJobSlots.clear;
	endif;
	
	allJobSlots.clear;
	write all40FrontSlotDefn.size;
	write voyAlloc40s.size;
	ccSize:=(all40FrontSlotDefn.size/voyAlloc40s.size).roundedUp;
	ccIndex:=1;
	write ccSize;
	delete iter;
	iter:=all40FrontSlotDefn.createIterator;
	while iter.next(slotController) do
		allJobSlots.add(slotController);
		
		// once we get size for color coding CC the sucker
		if allJobSlots.size = ccSize then
			voyAlloc:=voyAlloc40s[ccIndex].CM_VoyageAllocation;
			self.ignoreTrxWarnings(true);
			slotDefn:=slotController.mySlotDefn;
			locnDefn:=slotDefn.myROROLocnDen;
			while true do
				slotDefn:=slotController.mySlotDefn;
				if slotDefn &lt;&gt; locnDefn.allROROSlotDefnByOrdinal.last then
					iter.next(slotController);
					allJobSlots.add(slotController);
				else
					break;
				endif;
			endwhile;	
			self.addLCsToROROAllocation(true,voyAlloc,allJobSlots,altSlots,1);
			allJobSlots.clear;
			ccIndex:=ccIndex+1;
		endif;
	endwhile;
	
	if allJobSlots.size &gt; 0 then
		voyAlloc:=voyAlloc40s[ccIndex].CM_VoyageAllocation;
		self.ignoreTrxWarnings(true);
		self.addLCsToROROAllocation(true,voyAlloc,allJobSlots,altSlots,1);
		allJobSlots.clear;
	endif;
	
	
	// create the oowCreations for the Voyage
	
	app.myTrxCA.trxCreateVoyageOOWCreationRORO(voyage.myROROStructure,app.myPassport);
	self.assertNoTrxErrorsOrWarnings;
	
	// Allocate OOWCreations to Voyage Allocations slots
	
	create oowController transient;
	oowController.myCellularStructure :=voyage.myCellularVoyageStructure;
	oowController.myROROStructure:=voyage.myROROStructure;
	app.myTrxUA.trxUpdateVoyageOOWAuto(false,oowController,app.myPassport);
	self.assertNoTrxErrorsOrWarnings;
	
	create jobController transient;
	app.myTrxCA.trxCreateVoyageJobOOW(voyage.allJobSheets,app.myPassport,jobController);
	self.assertNoTrxErrorsOrWarnings;
	
	// Create a Terminal Area and fill with cargo based on the Voyage Allocations
	// Will just for this example create a unlimited Block Stack the DIAM block stack
	delete iter;
	iter:=all20SlotDefns.createIterator;
	self.opts.addAssoc(UTTI_VoyageCode,voyageCode);
	self.opts.addAssoc("CENum","1234");
	i:=1;
	while iter.next(slotController) do
		request := slotController.myRORORequestLoad;
		self.opts.addAssoc(UTTI_DischargePort,request.getDischargePort);
		ti :=self.addContainerOpts("DIAM" &amp; i.padLeadingWith("0",7), "2200", "GENL",operator);
		self.assertNoTrxErrorsOrWarnings;
		self.ignoreTrxWarnings(true);
		self.move(ti,bs.myLocationsController);
		self.assertNoTrxErrorsOrWarnings;
		self.ignoreTrxWarnings(true);
		self.deleteStops(ti);
		self.assertNoTrxErrorsOrWarnings;
		self.ignoreTrxWarnings(true);
		self.movePlannedRequestToJob(ti,slotController, slotController.myRORORequestLoad);
		self.assertNoTrxErrorsOrWarnings;
		i:=i+1;
	endwhile;
	
	delete iter;
	iter:=all40FrontSlotDefn.createIterator;

	while iter.next(slotController) do
		request := slotController.myRORORequestLoad;
		self.opts.addAssoc(UTTI_DischargePort,request.getDischargePort);
		ti :=self.addContainerOpts("DIAM" &amp; i.padLeadingWith("0",7), "4200", "GENL",operator);
		self.assertNoTrxErrorsOrWarnings;
		self.ignoreTrxWarnings(true);
		self.move(ti,bs.myLocationsController);
		self.assertNoTrxErrorsOrWarnings;
		
		self.ignoreTrxWarnings(true);
		self.deleteStops(ti);
		self.assertNoTrxErrorsOrWarnings;
		
		self.ignoreTrxWarnings(true);
		self.movePlannedRequestToJob(ti,slotController, slotController.myRORORequestLoad);
		self.assertNoTrxErrorsOrWarnings;
		i:=i+1;
	endwhile;
	
		// GC
	/*deck:=voyage.myROROStructure.allDecksByCode["5"];
	ct := self.getCargoType("CANNONBALL");														// 28/06/2013 cnwmh5
	if ct &lt;&gt; null then
		createGCLoadJobForRORO(voyage, wpC, deck, 5, -10, trade.allPortRotations.first.myPort.code, ct, operator,"CANB", 10, 20, bs, null);
		createGCLoadJobForRORO(voyage, wpC, deck, 30, -10, trade.allPortRotations.first.myPort.code, ct, operator, "CANB", 50, 70, bs, null);
	endif;
	//xCreateGCDischargJobForRORO(voyage, wpC, deck, 50, -10, ct, 10);
*/
	deck:=voyage.myROROStructure.allDecksByCode["2"];
	if deck &lt;&gt; null then
		self.ignoreTrxWarnings(true);
		self.addROROVoyageContainers(deck,true, 0);
	endif;
	create lcSet transient;
	deck.allROROSlotControllers.copy(lcSet);
	
	// take some of the on board cargo created and set aside for sob and dlr
	create sobSlots transient;
	create dlrSlots transient;
	create altSOBSlots transient;
	create altDLRSlots transient;
	
	delete iter;
	iter:=lcSet.createIterator;
	i := 1;
	while iter.back(lc) do
		if i &lt; 6 then
			sobSlots.add(lc.CM_VoyageROROController);
		elseif i &lt; 11 then
			dlrSlots.add(lc.CM_VoyageROROController);
		else 
			break;
		endif;
		i:=i+1;
	endwhile;
	
	foreach lc  in sobSlots do
		vc := lc.CM_VoyageROROController;
		lcSet.remove(vc);
	endforeach;
	
	foreach lc  in dlrSlots do
		vc := lc.CM_VoyageROROController;
		lcSet.remove(vc);
	endforeach;
	
	self.ignoreTrxWarnings(true);
	app.myTrxCA.trxCreateRORODischargeCCs(lcSet,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.createDischJobsForRORO(voyage, deck, wpA, wpB);

	create editions transient;
	
	deck:=voyage.myROROStructure.allDecksByCode["1"];
	delete iter;
	iter:= deck.allROROSlotControllers.createIterator;
	iter.next(vc2);
	foreach lc in sobSlots do
		vc := lc.CM_VoyageROROController;
		editions.add(vc);
		
		iter.next(vc2);
		altSOBSlots.add(vc2);
		editions.add(vc2);
	endforeach;
	//create some SOB jobs
	app.myTrxUA.doRORORequestDLRSoB(sobSlots, altSOBSlots, false,SOB_MOVETYPE, editions, app.myPassport);	
	self.assertNoTrxErrorsOrWarnings;
	
	
	self.addVoyageROROJob(voyage,voyage.myROROStructure.allDecksByCode["2"],"DIAMA",sobSlots,true);
	self.assertNoTrxErrorsOrWarnings;
	
	editions.clear;
	foreach lc in dlrSlots do
		vc := lc.CM_VoyageROROController;
		editions.add(vc);	
		iter.next(vc2);
		altDLRSlots.add(vc2);
		editions.add(vc2);
	endforeach;
	//create some DLR jobs
	app.myTrxUA.doRORORequestDLRSoB(dlrSlots, altDLRSlots, false,DLR_MOVETYPE, editions, app.myPassport);	
	self.assertNoTrxErrorsOrWarnings;
	
	self.addVoyageROROJob(voyage,voyage.myROROStructure.allDecksByCode["2"],"DIAMB",dlrSlots,true);
	self.assertNoTrxErrorsOrWarnings;
	// Release all jobs to ops
	foreach job in voyage.allVoyageJobs discreteLock do
		beginTransaction;
		job.CM_VoyageJob.setShipOpsLoad();
		commitTransaction;
	endforeach;
epilog
	delete voyAlloc20s;
	delete voyAlloc40s;
	delete all40FrontSlotDefn;
	delete all20SlotDefns;
	delete allJobSlots;
	delete altSlots;
	delete workPoints;
	delete oowController;
	delete jobController;
	delete iter;
	delete lcSet;
	delete theJobParams;
	delete lcs;
	delete sobSlots;
	delete dlrSlots;
	delete editions;
	delete altSOBSlots;
	delete altDLRSlots;
end;</source>
    </JadeMethod>
    <JadeMethod name="xAddROROVoyageGC" id="4600d016-6ce9-4ac0-ab7c-d228d11fc618">
