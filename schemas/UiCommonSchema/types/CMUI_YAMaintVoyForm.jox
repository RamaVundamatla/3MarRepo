    <JadeMethod name="handleNoColourException" id="7704f861-b9c8-4e6e-9c4f-fa1fcc1f307e">
        <source>handleNoColourException(_exc : Exception) : Integer;
// ---------------------------------------------------------------------------
// Created:     August 2009 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

constants
	InvalidProperty	= 1011; 
	
vars
	returnVal		: Integer;
	
begin
	returnVal := Ex_Pass_Back;
	if _exc.errorCode = InvalidProperty then
		returnVal := Ex_Resume_Next;
	endif;


epilog
	return returnVal;
	

end;</source>
        <Parameter name="_exc" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="noteUser" id="11daf248-f32e-4147-abd4-3e523e03f10a">
        <updating/>
        <source>noteUser(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;

/*

Date		    Who			Reason
02 February 2011	cnwas3	  par26840a

*/


vars

	actualEvent : Integer;
begin
	actualEvent := self.myTerminal.getEventFromTerminalEvent(eventType);

	// PAR 23405
	if actualEvent = EVENT_VOY_ALLOC_DELETE and userInfo.isKindOf(CM_VoyageAllocation) then
		if userInfo.CM_VoyageAllocation = self.myYardAllocation then
			self.myYardAllocation := null;
			if self.updateMode then
				self.updateMode := false;
				self.doCriteriaReset();				
			endif;
		endif;
	elseif actualEvent = ShowHide_VoyageAllocationsCC and userInfo.isKindOf(Boolean) then //cnwa3 23840a
		if userInfo.Boolean &lt;&gt; self.visible then
			self.visible := userInfo.Boolean;
		endif;		
	endif;


epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="populateForm" id="f0891279-812e-4c4c-8d23-ca67228ac1d2">
        <updating/>
        <source>populateForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 December 2009	cnwas3	Initial creation
//26 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	criteria : CM_YACriteria;
	expiryTS : TimeStamp;
begin
	on Exception do self.handleBadCriteriaValue(exception);  //cnwrd1 par  19084 18.3.09
	
	defaultYACodeChanged	:= false;
//	self.populateIMEX();
	self.doIMEXSelected();
	self.populateOptions();
	
	if self.myYardAllocation &lt;&gt; null then
		self.populateCriteriaFrames(true);
	endif;

	if self.myProxyYA = null then
		return;
	endif;
	
	self.cmbYATemplate.setIndexFromObject( self.myProxyYA.myYATemplate );
	//self.doTemplateSelected( self.myProxyYA.myYATemplate ); //cnwrd1 par 19062 17.3.09 --  // purging trmplate critera after loading above??
	self.displayCriteriaDesc(); //cnwrd1 par 19062 17.3.09 ++
	
	if self.myProxyYA.checkIfDefaultYACode(self.txtYACode.text) then	
		defaultYACodeChanged	:= false;
	else
		defaultYACodeChanged	:= true;
	endif;
	self.txtYACode.text		:= self.myProxyYA.code;
	self.txtYADescription.text		:= self.myProxyYA.description;
	self.txtRemarks.text			:= self.myProxyYA.remarks;
	self.populateExpiryType( self.myProxyYA.expiryType );
	
	//26 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
	expiryTS.cnEcSetDateAndTime(self.myProxyYA.expiryDate,TimeEndOfDay);
	self.dateExpiryDate.setDate(self.systemToLocalTime( expiryTS).date());
	//self.dateExpiryDate.setDate( self.myProxyYA.expiryDate );
	
	// cnwjk3 SFW1030
	//self.clrYAColour.setColor( self.myProxyYA.color );
	self.setIMEXDefaultColour();
	
	self.chkDisableYA.value			:= self.myProxyYA.isDisabled;

	if self.myProxyYA.remarks &lt;&gt; null then
		shtRemarks.caption := shtRemarks.caption &amp; " (*)";
	endif;
	
	if not self.isBulkEdit() then
		self.shtLocation.visible := true;
		self.populateLocations();
	endif;

	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, PmVoyagePlanningMaint) then
		self.btnRemove.enabled:= false;
		self.shtCriteria.enabled := false;
		self.btnNew.enabled:= false;
		self.btnNext.enabled:= false;
		self.btnSave.enabled:= false;
		self.btnSaveAs.enabled:= false;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="reloadCCVoyageData" id="19b67365-8101-48dc-8726-15a3973cfebf">
        <updating/>
        <source>reloadCCVoyageData(_voyAlloc : CM_VoyageAllocation) updating; //_voyage : CM_Voyage; _description : String) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 December 2009	cnwas3	Initial creation

*/

vars
	descStr : String;
	yas : ObjectArray;
	
begin
		
	if _voyAlloc &lt;&gt; null then
		create yas transient;
		yas.add(_voyAlloc);
		descStr := _voyAlloc.description;
	endif;	
	
	self.myVoyage := _voyAlloc.myVoyage;
	
	if not self.allVoyages.includes(self.myVoyage) then
		self.allVoyages.add(self.myVoyage);
	endif;
	
	self.setYardAllocation(yas);
	
	self.txtDescription.text := descStr;
	self.doIMEXSelected();	
	
		// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, PmVoyagePlanningMaint) then
		self.btnRemove.enabled:= false;
		self.shtCriteria.enabled := false;
		self.btnNew.enabled:= false;
		self.btnNext.enabled:= false;
		self.btnSave.enabled:= false;
		self.btnSaveAs.enabled:= false;
	endif;

	
epilog

	delete yas;
end;</source>
        <Parameter name="_voyAlloc" type="CM_VoyageAllocation"/>
    </JadeMethod>
    <JadeMethod name="resizeForVoyage" id="861a62c2-16d5-4d11-87a9-8af15851c6ff">
        <updating/>
        <source>resizeForVoyage() updating;
/*
Date		Who		Reason
04 December 2009	cnwas3	Initial creation

*/
vars

	maxIndex : Integer;
	criteriaFrame		: CMUI_YACriteriaCntl;
	index				: Integer;
	topOfLastControl 	: Real;
	topOfNextControl 	: Real;
begin


	self.minimumWidth := 420; // PAR 35325
	self.minimumHeight := 450;

	self.lblDescription.top := self.shtCriteria.clientHeight - 60;
	self.txtDescription.top := self.lblDescription.top;
	self.lblDescription.left := 20;
	self.txtDescription.left := 157;
	self.lblDescription.parentAspect := Label.ParentAspect_AnchorBottom;
	self.txtDescription.parentAspect := TextBox.ParentAspect_AnchorBottom;
	
	self.lblYAColour.top := self.shtCriteria.clientHeight - 30;
	self.clrYAColour.top := self.lblYAColour.top;
	self.lblYAColour.left := 20;
	self.clrYAColour.left := 157;
	self.clrYAColour.width := 40;
	
	self.picCriteria.height := 240;
	self.picCriteria.top := 10;
//	self.picCriteria.backColor := Red;
//	self.picCriteria.transparent := false;
	
	self.lblYAColour.parentAspect := Label.ParentAspect_AnchorBottom;
	self.clrYAColour.parentAspect := TextBox.ParentAspect_AnchorBottom;
	self.picCriteria.parentAspect := Picture.ParentAspect_StretchBoth;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="saveData" id="dbb1537c-e6d4-43ae-b7c2-d4ef25a402e5">
        <updating/>
        <source>saveData(_saveAs: Boolean): Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 December 2009	cnwas3	Initial creation

*/
vars
	terminalObj				: CM_Terminal;
	yardAllocationObj		: CM_YardAllocation;
	proxyYAObj				: CM_VoyageAllocation;
	cmif_object : CMIF_Object;
	cmif_criteria : CMIF_YACriteriaPriority;
	pxyCriteria : CM_YACriteria;
	fillOptionIn			: Integer;
	fillOptionOut			: Integer;
	yaCode					: String;
	yaDescription			: String;
	yaRemarks				: String;
	expiryType				: Integer;
	expiryDate				: Date;
	allowOthers				: Integer;
	noLocation				: Integer;
	priorityAdj				: Integer;
	isTestOverstowWeight	: Boolean;
	isDisabled				: Boolean;
	allTransientCriteriaObj	: CMIF_Array;
	yaColor					: Integer;
	overstowRule			: CM_YAOverstowRule;
	blockGroupsInColl		: CM_YABlockGroupArray;
	blockGroupsOutColl		: CM_YABlockGroupArray;
	result					: Integer;
	createYA				: Boolean;
	mode					: Integer;
	yardAllocation			: CM_YardAllocation;
	realAlloc 				: CM_VoyageAllocation;
	wagon						: CM_Wagon;
	voyCode : String;
	va						: CM_YardAllocation;
	pxyCriteriaToDelete		: ObjectArray;	//27 Mar 2012	NDL	Par 29109
begin
	if self.myVoyage = null then
		return false;
	else
		voyCode := self.myVoyage.code;
	endif;
	
	if self.updateMode then
		if self.myYardAllocation = null then
			return false;
		endif;
		realAlloc := self.myVoyage.getAllocationWithSameCriteria(self.myYardAllocation.CM_VoyageAllocation);
	endif;
	
	proxyYAObj			:=	self.myProxyYA.CM_VoyageAllocation;

	if _saveAs then
		proxyYAObj.setProxyProjectedValues(0,0,0,0,0,0);
	endif;
	
	
	create allTransientCriteriaObj transient;
	self.getCriteriaAllCMIF( allTransientCriteriaObj );
	
	create pxyCriteriaToDelete transient;	//27 Mar 2012	NDL	Par 29109
	
	foreach cmif_object in allTransientCriteriaObj do
		cmif_criteria := cmif_object.CMIF_YACriteriaPriority;
		pxyCriteria := cmif_criteria.myProxy.CM_YACriteria;
		pxyCriteria.setYardAllocation(proxyYAObj);
		if cmif_criteria.isDeleted and realAlloc = null then	//27 Mar 2012	NDL	Par 29109
			pxyCriteria.setYardAllocation(null);
			pxyCriteriaToDelete.add(pxyCriteria);
		endif;
	endforeach;
	
	proxyYAObj.setProxy(self.txtDescription.text,self.txtDescription.text,
								null,
								YAFillOption_InOrder,
								YAFillOption_InOrder,
								YAExpiryType_Never,
								null,
								self.clrYAColour.getColor(), 			//+ cnwmd1, CCMS 1067, Par 19710
								//0,//colour					//- cnwmd1, CCMS 1067, Par 19710
								null,  //cnwjo3 par 24145
								YAOverlap_Never,//allow others
								YANoLocation_Continue,
								null,
								0, //priority adjustment
								false,
								false,
								null,
								null,
								true,
								self.myTerminal);

	// 07/11/2011 cnwmh5 #28627
	if _saveAs then
		if self.myVoyage &lt;&gt; null and proxyYAObj.description &lt;&gt; null then
			va := self.myVoyage.getVoyageAllocation(proxyYAObj.description);
			if va &lt;&gt; null and va.code = proxyYAObj.code then
				app.raiseCMException1(Voyage_Alloc_Exists_With_Code, proxyYAObj.code, null, null);
				self.txtDescription.setFocus();
				return false;
			endif;
		endif;
	endif;
	
	// PAR 23405
	if not self.updateMode then
		realAlloc := self.myVoyage.getAllocationWithSameCriteria(proxyYAObj.CM_VoyageAllocation);
		if realAlloc &lt;&gt; null then
			self.updateMode := not self.updateMode;
		endif;
	endif;
								
	
	while true do
		app.myTrxUA.trxUpdateVoyageAlloc(self.updateMode,self.myVoyage, proxyYAObj,realAlloc,app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			if self.myParentForm &lt;&gt; null then
				if self.myParentForm.isKindOf(CMUI_GridAreaForm2) then // PAR 27749
					self.myParentForm.CMUI_GridAreaForm2.refreshColourCodingPallette();
				elseif self.myParentForm.class().name = "SHP_ROROPlanningForm" then
					self.myParentForm.sendMsgWithParams("refreshColourCodingPallette");
				endif;
			endif;
			self.updateMode := false;
			self.doCriteriaReset();
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Voyage_load_colour_coding), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		
		break;
	endwhile;	
	
	//self.unloadForm;
epilog

	//27 Mar 2012	NDL	Par 29109
	if pxyCriteriaToDelete &lt;&gt; null then
		if not pxyCriteriaToDelete.isEmpty then
			pxyCriteriaToDelete.purge();
		endif;
		delete pxyCriteriaToDelete;
	endif;
end;</source>
        <Parameter name="_saveAs" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setCriteriaResizeScrollBar" id="669f548c-754f-4063-98c2-23f1996ac013">
        <updating/>
        <source>setCriteriaResizeScrollBar() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28/11/2023	navkc1 Bug 60782: FR | 54089 EUP -Invoice Contracts - Criteria screen width issues

*/

vars
	max			: Integer;
	numOfCrit	: Integer;
	
begin
	
	if self.myYAVoyageConfig &lt;&gt; null then
		numOfCrit := self.myYAVoyageConfig.allOpCriteria.size();
	else
		numOfCrit := self.getNumCriteriaToDisplay();
	endif;
	
	max := (numOfCrit * (self.frmCriteria.height)).Integer;
	
	if self.picCriteria.height &lt; max then
		self.picCriteria.scrollBars := Picture.ScrollBar_Vertical;
		self.picCriteria.setScrollRange(ScrollBar_Vertical, 0, max, 20, 100);
	else
		self.picCriteria.scrollBars := 0;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setPosition" id="2a561508-0630-427b-b32f-fb8697be76f1">
        <updating/>
        <source>setPosition(_left : Real; _top : Real) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 January 2010	cnwas3	Initial creation

*/

vars

begin
	self.top := 10;
	self.left := 10;
	self.refresh();
	self.refreshNow();
epilog

end;</source>
        <Parameter name="_left" type="Real"/>
        <Parameter name="_top" type="Real"/>
    </JadeMethod>
    <JadeMethod name="setYardAllocation" id="5e2fbb6c-32c6-4368-8013-3d8d839be8b7">
        <updating/>
        <source>setYardAllocation(_yas: ObjectArray) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 December 2009	cnwas3	Initial creation

*/
vars
	ya, proxyObj		: CM_VoyageAllocation;
	blockGroupObj	: CM_YABlockGroup;
	isLoadSet		: Boolean;
	criteria		: CM_YACriteria;
	imex			: CM_YACriteria;
	proxyCriteria	: CM_YACriteria;
	imexStatus		: CM_IMEXStatus;
	yaIMEXConfig	: CM_YAIMEXConfig;
	criteriaType: CM_YACriteriaType;
	opCriteria: CM_YACriteriaArray;
begin
	self.doClearCurrentYA();
	
	
	if _yas = null then
		create proxyObj transient;
		create blockGroupObj transient;
		proxyObj.allYABlockGroupsIn.add(blockGroupObj);
		proxyObj.allYABlockGroupsOut.add(blockGroupObj);
		self.myProxyYA	:=	proxyObj;
		self.myProxyYA.setTerminal(self.myTerminal);
		self.updateMode := false;
	elseif _yas.size = 1 then
		ya := _yas.first.CM_VoyageAllocation;
		proxyObj	:=	app.createUpdateProxy(ya).CM_VoyageAllocation;
		//  Also save off flag indicating if template criteria has been modified
		self.isTemplateModified := ya.isTemplateModified;
		self.myProxyYA			:=	proxyObj;
		self.myYardAllocation	:=	ya;
		self.updateMode := true;
	else
		_yas.copy(self.allBulkEditYAs);
	endif;
	self.setCmbYATemplateBehaviour();
epilog
	delete opCriteria;
end;</source>
        <Parameter name="_yas" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="6c02ff14-e4cd-4750-a290-478dea1700e0">
        <updating/>
        <source>setupForm() updating;
/*
Date		Who		Reason
04 December 2009	cnwas3	Initial creation
12 Jun 2013	cnwcs5	par 31712 - 
*/

vars

begin
	inheritMethod();
	self.openWithSavedSettings();
	self.resizeForVoyage();
	
	self.grpTemplate.visible 	:= false;
	self.cmbIMEX.visible 		:= false;
	self.lblHeader.visible 		:= false;
	self.chkDisableYA.visible 	:= false;
	self.btnFindImex.visible 	:= false;
	self.shtLocation.visible 	:= false;
	self.shtOptions.visible 	:= false;
	self.txtGroupName.visible 	:= false;
	self.lblGroupName.visible 	:= false;
	self.txtImex.visible 		:= false;
	self.btnNext.visible 		:= false;
	self.btnSave.left 			:= self.btnNext.left;
	self.btnCancel.setCaptionForTranslation("&amp;Close");
	
	self.updateMode := false;
	
	self.formatCaption();
	
	self.frmHeader.transparent 	:= true;
	// must set height before fldYardAlloc height
	self.height 				:= self.fldYardAlloc.top + self.clrYAColour.top + 60 + 80;
	self.fldYardAlloc.height 	:= self.clrYAColour.top + 60;
	self.shtRemarks.visible 	:= false;
	self.fldYardAlloc.top 		:= 25;
	self.btnRemove.left 		:= 22;	
	
	self.mnuFile.visible 		:= false;
	self.mnuHelp.visible 		:= false;
	self.mnuOptions.visible 	:= false;
	self.mnuWindows.visible 	:= false;
	self.mnuTerminal.visible 	:= false;
	self.mnuView1.visible 		:= false;
	self.isOpened 				:= true;
	
	self.beginNotification(self.myVoyage, self.myTerminal.getTerminalEvent(EVENT_VOY_ALLOC_DELETE), Response_Continuous, null); // PAR 23405
	self.beginNotification(self.myParentForm, self.myTerminal.getTerminalEvent(ShowHide_VoyageAllocationsCC), Response_Continuous, null); //cnwas3 par 27769
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="176896e1-b261-4f89-8dcf-bbc3b503c3ec">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0017525, locale);
	btnNew.translateCaption(Xlat_0013576, locale);
	btnRemove.translateCaption(Xlat_0013577, locale);
	btnSaveAs.translateCaption(Xlat_0017526, locale);
	lblDescription.translateCaption(Xlat_0013578, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="unload" id="6657d08f-c042-42d4-8765-1bb295922553">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 December 2009	cnwas3	Initial creation

*/

vars

begin
	self.isOpened := false;
	
	if self.myParentForm &lt;&gt; null then
		if self.myParentForm.isKindOf(CMUI_GridAreaForm2) then // PAR 27749
			self.myParentForm.CMUI_GridAreaForm2.hideLAC(false);
		elseif self.myParentForm.class().name = "SHP_ROROPlanningForm" then
			self.myParentForm.sendMsgWithParams("hideLAC", false);
		endif;
	endif;
	
	inheritMethod();
epilog

end;</source>
    </JadeMethod>
