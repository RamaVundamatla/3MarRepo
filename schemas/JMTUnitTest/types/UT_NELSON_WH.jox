    <JadeMethod name="sCreateProductBookingAndPack" id="4515ec98-ce96-4bcf-abec-cb8ebe5cbb5b">
        <source>sCreateProductBookingAndPack();
//26 January 2009	cnwdw1	
//  Test to be completed
vars
	product: CM_Product;
	vessel: CM_Vessel;
	voyage: CM_Voyage;
	booking: CM_BookingRef;
	release: CM_BulkRelease;
begin
	self.deleteBooking("UTBR100");
	self.deleteReleaseRequest("UTRR100");
	voyage := self.getVoyage("UTV001");
	if voyage = null then
		vessel := addVesselCellular("UTBOAT", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
		assertNotNull(vessel);
		voyage := addVoyageWithContainerStructur("UTV001", "UTBOAT", self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
		assertNotNull(voyage);
	endif;
	self.deleteProduct("UT-25MM", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), self.getCargoType(self.getProfileSetting(UT_Profile.P_CARGO_TYPE).asString));
	product := self.addProduct("UT-25MM", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), self.getCargoType(self.getProfileSetting(UT_Profile.P_CARGO_TYPE).asString));
	
	booking := self.addBookingForProduct("UTBR100", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), product, 1, voyage);
	assertNotNull(booking);
	assertEqual(booking.allBookingRefItems.size, 1);
	
	self.opts.addAssociation("Booking", booking);
	self.opts.addAssociation("BookingItem", booking.allBookingRefItems.first);
	self.opts.addAssociation("Product", product);
	release := self.addReleaseByTypeRequestOpts("UTRR100",  BR_TYPE_PACKING, 
						self.getCargoType(self.getProfileSetting(UT_Profile.P_CARGO_TYPE).asString).id);
	assertNotNull(release);
	assertEqual(release.allReservePackingChildren.size, 1);
	assertEqual(release.allReservePackingChildren.first.CM_ReserveSelection.myProduct, product);
	assertEqual(release.allReservePackingChildren.first.myBookingRefItem, booking.allBookingRefItems.first);
	
end;</source>
    </JadeMethod>
