    <DbClassMap file="sysops"/>
    <JadeMethod name="addResourceCombosToTblData1" id="473d5bf4-7017-483d-9adf-ddb1f33d4803">
        <source>addResourceCombosToTblData1(_row : Integer; _harbour : HMS_Harbour;  _arrResource, _depResource, _shiftResource : HMS_Resource);
// ---------------------------------------------------------------------------
// Created:     29 September 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

	tmpTable : CM_DataTable;
	newCombo : CMUI_ComboResourcesForHarbour;
//	cell : JadeTableCell;	
	theForm 		: SOP_HMS_TableMaintForm;
//	int, idx				: Integer;	
	
begin

  	theForm := self.myForm.SOP_HMS_TableMaintForm;
	//harbour := theForm.cmbFiltHarbour.listObject.HMS_Harbour;	
	tmpTable := theForm.tblData1;

	theForm.newIndex := theForm.newIndex + 1;
	newCombo := theForm.cmbResourceArr.loadControl(theForm.newIndex).CMUI_ComboResourcesForHarbour;
	theForm.allClonedControls.add(newCombo);
	tmpTable.accessCell(_row, 2).cellControl := newCombo;
	newCombo.myHarbour := _harbour;
	newCombo.setObject(_arrResource);
	
	
	theForm.newIndex := theForm.newIndex + 1;
	newCombo := theForm.cmbResourceDep.loadControl(theForm.newIndex).CMUI_ComboResourcesForHarbour;
	theForm.allClonedControls.add(newCombo);
	tmpTable.accessCell(_row, 3).cellControl := newCombo;
	newCombo.myHarbour := _harbour;
	newCombo.setObject(_depResource);

	theForm.newIndex := theForm.newIndex + 1;	
	newCombo := theForm.cmbResourceShift.loadControl(theForm.newIndex).CMUI_ComboResourcesForHarbour;
	theForm.allClonedControls.add(newCombo);
	tmpTable.accessCell(_row, 4).cellControl := newCombo;
	newCombo.myHarbour := _harbour;
	newCombo.setObject(_shiftResource);
	
	
//	newCombo.CMUI_ComboResourceTypes.setObject(_resourceUsed.myResourceType);
//	tmpTable.accessCell(rowIdx, self.colResourceType).text := newCombo.text;	
end;</source>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_harbour" type="HMS_Harbour"/>
        <Parameter name="_arrResource" type="HMS_Resource"/>
        <Parameter name="_depResource" type="HMS_Resource"/>
        <Parameter name="_shiftResource" type="HMS_Resource"/>
    </JadeMethod>
    <JadeMethod name="clearThumbnailData" id="adc14186-d035-4232-810a-865b662730e8">
        <updating/>
        <source>clearThumbnailData() updating;
//--------------------------------------------------------------
//Created: 04 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	theForm : SOP_TableMaintForm;
begin
	inheritMethod();
	theForm := self.myForm;
	theForm.tblInput1.clearValues();
	theForm.mulSelect1.setSelected(null);  	
 	theForm.mulSelect2.setSelected(null);
end;</source>
    </JadeMethod>
