    <JadeMethod name="trxUpdateJobAndRequest" id="b37d6afa-fbc8-4181-9667-103c9213506b">
        <updating/>
        <source>trxUpdateJobAndRequest(	pProxyJob : CM_Job input;
						pProxyRequest:CM_Request input;
						pTI: CM_TrackedItem input; 
						pNewCon : CM_ConsigneeConsignor;
						_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);

	beginTransaction;

	app.myUtilityUA.utlUpdateJob(pProxyJob, _passport);
	if _passport.hasErrors() then
		return;
	endif;
	app.myUtilityUA.utlUpdateRequest(pProxyRequest, _passport);
	if _passport.hasErrors() then
		return;
	endif;

	// this is called for TI Requests and Delivery Requests, the latter does not have a TI to update as yet, (a null consignee means no update required)
	if pTI &lt;&gt; null and pNewCon &lt;&gt; null then
		app.myUtilityUA.utlUpdateTIConsignee(pTI, pNewCon, _passport);
	endif;

epilog
	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="pProxyJob" type="CM_Job" usage="input"/>
        <Parameter name="pProxyRequest" type="CM_Request" usage="input"/>
        <Parameter name="pTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="pNewCon" type="CM_ConsigneeConsignor"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
