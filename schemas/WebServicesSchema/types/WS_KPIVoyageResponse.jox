    <ImplicitInverseRef name="allVoyageKPIs" id="1aeaa8f2-873b-4c61-9af3-23b7e3508aaa">
        <memberTypeInverse/>
        <type name="WS_KPIVoyageArray"/>
    </ImplicitInverseRef>
    <JadeMethod name="delete" id="af01e738-c60f-4433-8b10-f1901109f3d8">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 January 2026	navcs2	MTN-36746 MTN | KPI REST APIs - Voyage [1]

*/

vars
begin
	self.allVoyageKPIs.purge();
