    <JadeMethod name="populateSuggestedWords" id="f5bad799-c336-4a17-ba1d-a55de1ad2916">
        <source>populateSuggestedWords() protected;
// --------------------------------------------------------------------------------
// Created:		06 September 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	wordName	: String;
	
begin
	lstProspectWords.clear();

	if optSoundex.value then
		foreach wordName in self.aAllSuggestedSoundexWords do
			lstProspectWords.addItem(wordName);
		endforeach;
		
		if self.aMySpellCheck &lt;&gt; null then
			self.aMySpellCheck.setIsMetaphoneSearch(false);
		endif;
		
	elseif optMetaphone.value then
		foreach wordName in self.aAllSuggestedMetaphoneWords do
			lstProspectWords.addItem(wordName);
		endforeach;
		
		if self.aMySpellCheck &lt;&gt; null then
			self.aMySpellCheck.setIsMetaphoneSearch(true);
		endif;
	endif;
	
	if self.aAllSuggestedSoundexWords.size() = 0 then
		lstProspectWords.enabled	:=	false;
		lstProspectWords.addItem("No suggestions available...");
	else
		lstProspectWords.enabled	:=	true;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="replaceWordOnce" id="40f08d4a-b530-483a-a39f-f62f8f71c478">
        <updating/>
        <source>replaceWordOnce() updating, protected;
// --------------------------------------------------------------------------------
// Created:		06 September 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if txtReplace.text &lt;&gt; null then
		if self.aMySpellCheck &lt;&gt; null then
			self.aMySpellCheck.setReplaceOnce(txtReplace.text.trimBlanks());
		endif;
	endif;
	
	unloadForm();
end;</source>
        <access>protected</access>
    </JadeMethod>
