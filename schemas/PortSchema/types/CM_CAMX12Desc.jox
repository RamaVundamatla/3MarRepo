    <JadeMethod name="makeHeader_GS" id="20d7c197-696e-4367-a6bd-5164b74ce1b2">
        <source>makeHeader_GS(_protocol :CM_CamProtocol ; _senderID , _receiverID : String ; _controlNumber : String; _runDateTime : TimeStamp): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 February 2014	cnwrd1	Initial creation

*/

/*

Functional Group Header (GS) 


Functional Identifier Code			GS01 	SO
Application Sender's Code			GS02	&lt;Configurable&gt;
Application Receivers Code			GS03	_receiver
Date								GS04	(ISA08) YYYYMMDD
Time								GS05	(ISA09) HHMM
Group Control Number				GS06	&lt;Determined by Run&gt;
Responsible Agency Code				GS07	X
Version/Release/Industry Identifier Code	GS08	004010
*/
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time

constants
	MESSAGE	= "GS";
vars
	msg	:String;
	plus, colon, singleQuote	:Character;
begin
	plus		:= _protocol.elementSeparator;
	//colon		:= _protocol.subElementSeparator;
	singleQuote	:= _protocol.segmentTerminator;
	

	msg := MESSAGE &amp; 
			plus &amp; 'SO' &amp; //01
			plus &amp; _senderID &amp; //02
			plus &amp; _receiverID &amp; //03		//	 plus &amp; 'SFL' &amp; 			
			plus &amp; _runDateTime.date.formatAsYYYYMMDD &amp; //04
			plus &amp; _runDateTime.time.shortFormatEDI &amp; //05
			plus &amp; _controlNumber &amp; //06 Group Control Number		
			plus &amp; 'X' &amp; //03
			plus &amp; '004010' &amp;
			singleQuote;

	
			
	return msg;
end;</source>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_senderID" type="String"/>
        <Parameter name="_receiverID" type="String"/>
        <Parameter name="_controlNumber" type="String"/>
        <Parameter name="_runDateTime" type="TimeStamp"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeHeader_ISA" id="9389ce3a-b6d4-4379-b866-4eb331724981">
        <source>makeHeader_ISA( _protocol :CM_CamProtocol  ; _seqNumber :Integer; _senderID , _receiverID : String; _runDateTime : TimeStamp):String protected;

/*

Purpose:		Make ISA segment	

Parameters:			

Return Value:		


Date		Who		Reason
25 February 2014	cnwrd1	Initial creation
*/
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
constants
	MESSAGE	= "ISA";
vars
	msg	:String;
	plus, colon, singleQuote	:Character;
begin
	plus		:= _protocol.elementSeparator;
	//colon		:= _protocol.subElementSeparator;
	singleQuote	:= _protocol.segmentTerminator;
	

	

	
/*
Authorization Information Qualifier 		ISA01 		00
Authorization Information  					ISA02 
Security Information Qualifier				ISA03		00
Security Information 						ISA04 
Interchange ID Qualifier					ISA05		ZZ
Interchange Sender ID						ISA06		&lt;Configurable&gt;
Interchange ID Qualifier					ISA07		ZZ
Interchange Receiver ID						ISA08		&lt;Configurable&gt;
Interchange Date							ISA09		Send Date (YYMMDD)
Interchange Time							ISA10		Send Time (HHMM)
Interchange Control Standards IdentifierI	ISA11		U
Interchange Control Version Number			ISA12		00401
Interchange Control Number					ISA13		&lt;Unique ascending number&gt;
Acknowledgment Requested					ISA14		0
Usage Indicator								ISA15		P
Component Element							ISA16		 &gt;
*/
	
//	_protocol.

	// ccms 2451 - ISA is a fixed length segment needs padding etc.
	msg := MESSAGE &amp; 
			plus &amp; '00' &amp; //01
			plus &amp; '          ' &amp; //02
			plus &amp; '00' &amp; //03
			plus &amp; '          ' &amp; //04
			plus &amp; 'ZZ' &amp; //05
			plus &amp; _senderID.padBlanks(15) &amp; //06 ******************** sender ID
			plus &amp; 'ZZ' &amp; //07			
			plus &amp; _receiverID.padBlanks(15) &amp; //08 ********************* receiver ID
			plus &amp; _runDateTime.date.formatAsYYMMDD &amp; //09
			plus &amp; _runDateTime.time.shortFormatEDI &amp; //10
			plus &amp; 'U' &amp; //11
			plus &amp; '00401' &amp; //12
			plus &amp; _seqNumber.padLeadingWith('0',9).String &amp; //13 - ******* control number //cnwrd1 par 35645
			plus &amp; '0' &amp; //14
			plus &amp; 'P' &amp; //15
			plus &amp; '&gt;' &amp; //16
			singleQuote;
			
			
			
	/*msg := MESSAGE &amp; 
			plus &amp; '00' &amp; //01
			plus &amp; '' &amp; //02
			plus &amp; '00' &amp; //03
			plus &amp; '' &amp; //04
			plus &amp; 'ZZ' &amp; //05
			plus &amp; _senderID &amp; //06 ******************** sender ID
			plus &amp; _receiverID &amp; //07 ********************* receiver ID
			plus &amp; today.formatAsYYYYMMDD &amp; //08
			plus &amp; now.shortFormatEDI &amp; //09
			plus &amp; 'U' &amp; //10
			plus &amp; '0401' &amp; //11
			plus &amp; _seqNumber.String &amp; //12 - ******* control number
			plus &amp; 'O' &amp; //13
			plus &amp; 'P' &amp; //14
			plus &amp; '&gt;' &amp; //05
			singleQuote;*/
			
	
			
	return msg;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_seqNumber" type="Integer"/>
        <Parameter name="_senderID" type="String"/>
        <Parameter name="_receiverID" type="String"/>
        <Parameter name="_runDateTime" type="TimeStamp"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeHeader_ST" id="307a14ee-4d1a-4a70-916d-af791e8f45ab">
        <source>makeHeader_ST(_protocol :CM_CamProtocol ; _controlNumber : String): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 February 2014	cnwrd1	Initial creation

Transaction Set Header (ST)

Transaction Set Identifier Code ST01 322
Transaction Set Control Number ST02 &lt;Determined by Run&gt;
*/
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time

constants
	MESSAGE	= "ST";
vars
	msg	:String;
	plus, colon, singleQuote	:Character;
begin
	plus		:= _protocol.elementSeparator;
	singleQuote	:= _protocol.segmentTerminator;
	

	msg := MESSAGE &amp; 
			plus &amp; '322' &amp; //01
			plus &amp; _controlNumber &amp; //02
			singleQuote;
			
	return msg;
end;</source>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_controlNumber" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMessage_DTM" id="9f017862-a188-4883-b2f5-d3d00abca030">
        <source>makeMessage_DTM( _protocol :CM_CamProtocol ; _tranDate : Date; _tranTime : Time; _timeCode : String) : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 February 2014	cnwrd1	Initial creation
Date/Time Qualifier DTM01 152
Date DTM02 (Q502)
Time DTM03 (Q503)
Time Code DTM04 (Q504)
Date Time Period Format Qualifier DTM05
Date Time Period DTM06
*/
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time

constants
	MESSAGE	= "DTM";
vars
	msg	:String;
	plus, colon, singleQuote	:Character;
begin
	plus		:= _protocol.elementSeparator;
	//colon		:= _protocol.subElementSeparator;
	singleQuote	:= _protocol.segmentTerminator;
	

	msg := MESSAGE &amp; 
			plus &amp; '152' &amp; //qualifier
			plus &amp; _tranDate.formatAsYYYYMMDD &amp; //Transaction Date YYYYMMDD
			plus &amp; _tranTime.shortFormatEDI &amp; //Transaction Time HHMMSS
			plus &amp; _timeCode &amp; //Time Code
			plus &amp; //date time format qualifier
			plus &amp; //date time period
			singleQuote;
		
	return msg;

epilog

end;

</source>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_tranDate" type="Date"/>
        <Parameter name="_tranTime" type="Time"/>
        <Parameter name="_timeCode" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMessage_H1" id="d252f9b5-b3f9-4512-ba42-22d7e66acf46">
        <source>makeMessage_H1(_protocol :CM_CamProtocol ; _undgCode, _imdgClass, _hazDesc : String): String;
/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
25 February 2014	cnwrd1	Initial creation

Hazardous Material (H1) (&lt;= 3)
Hazardous Material Code 			H101	UNDG Code
Hazardous Material Class Code		H102	IMDG Class
Hazardous Material Code Qualifier	H103	I Intergovernmental Maritime Organization (IMO) Code
Hazardous Material Description		H104
Hazardous Material Contact 			H105
Hazardous Materials Page			H106
Flashpoint Temperature				H107
Unit or Basis for Measurement Code	H108
Packing Group Code					H109
*/
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
// 08 Aug 2017	cnwrs1	TFS 5727 Penn Seaboard fixups
// 15 May 2018	jlgsl4	TFS 38636 - PEN - Swap Class Qualifier and Class Code order

constants
	MESSAGE	= "H1";
vars
	msg	:String;
	plus, colon, singleQuote	:Character;
begin
	plus		:= _protocol.elementSeparator;
	singleQuote	:= _protocol.segmentTerminator;

	msg := MESSAGE &amp; 
			plus &amp; _undgCode &amp; 
			plus &amp; _imdgClass &amp; // plus &amp; "I" &amp; // TFS 38636
			plus &amp; "I" &amp; // plus &amp; _imdgClass &amp; // TFS 38636
			plus &amp; _hazDesc &amp;
			plus &amp; //haz mat contact
			plus &amp; //haz mat page
			plus &amp; //flashpoint temp
			plus &amp; //unit or basis of measurement code
			plus &amp; //packing group code
			singleQuote;
			
	return msg;

epilog

end;</source>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_undgCode" type="String"/>
        <Parameter name="_imdgClass" type="String"/>
        <Parameter name="_hazDesc" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMessage_H3" id="617b5011-c8d4-4c9a-af81-c49b78964b90">
        <source>makeMessage_H3(_protocol :CM_CamProtocol ; _handleingCode, _handlingInstructions : String): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 February 2014	cnwrd1	Initial creation


Special Handling Instructions (H3)

Special Handling Code			H301	IP/XP
Special Handling Description	H302	Handling Instructions
Protective Service Code			H303
Vent Instruction Code			H304
Tariff Application Code			H305
*/
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time

constants
	MESSAGE	= "H3";
vars
	msg	:String;
	plus, colon, singleQuote	:Character;
begin
	plus		:= _protocol.elementSeparator;
	singleQuote	:= _protocol.segmentTerminator;
	

	msg := MESSAGE &amp; 
			plus &amp; _handleingCode &amp; 
			plus &amp; _handlingInstructions &amp;
			plus &amp; //protective service code
			plus &amp; //vent instruction code
			plus &amp; // tariff application code
			singleQuote;
			
	return msg;

epilog

end;</source>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_handleingCode" type="String"/>
        <Parameter name="_handlingInstructions" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMessage_K1" id="5fc56eac-8d9d-43f7-9ae4-5952be6e44a9">
        <source>makeMessage_K1(_protocol :CM_CamProtocol ; _messagePart1, _messagePart2 : String): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 February 2014	cnwrd1	Initial creation


Remarks (K1)

Free-Form Message K101	ISIS Move Code8
Free-Form Message K102


Notes
8The move code is determined by the release received if available. It is unclear exactly how this move code is inserted into our system or where it is stored. (TBD)

OR 

Remarks (K1)
Free-Form Message	K101	NOTES
Free-Form Message	K102	Remarks
?
*/
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
//15 May 2018	jlgsl4	TFS 38636 - PEN - K1 maximum 30 chars data

constants
	MESSAGE	= "K1";
vars
	msg	:String;
	plus, colon, singleQuote	:Character;
begin
	plus		:= _protocol.elementSeparator;
	singleQuote	:= _protocol.segmentTerminator;
	

	msg := MESSAGE &amp; 
			plus &amp;_messagePart1  &amp; 
			plus &amp; _messagePart2[1:30] &amp; //free form message // TFS 38636
			singleQuote;
			
	return msg;

epilog

end;</source>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_messagePart1" type="String"/>
        <Parameter name="_messagePart2" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMessage_L0" id="3c7f4778-b90d-43e3-abfc-a9503be4d04e">
        <source>makeMessage_L0(_protocol :CM_CamProtocol; _ladingItemNumber, _weight, _weightQual,  _ladingQuant,	_packingFormCode : String ): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 February 2014	cnwrd1	Initial creation

Line Item – Quantity and Weight (L0)

Lading Line Item Number		L001	1
Billed/Rated-as Quantity	L002
Billed/Rated-as Qualifier	L003
Weight						L004
Weigth Qual					L005
Volume						L006
Volume Unit Qualifier		L007
Lading quant				L008
Packing form code			L009
Dunnage Desc				L010
Weight unit code			L011
Type of service code		L012
Quantity					L013
Packing form code			L014
Yes no condition			L015
*/
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time

constants
	MESSAGE	= "L0";
vars
	msg	:String;
	plus, colon, singleQuote	:Character;
begin
	plus		:= _protocol.elementSeparator;
	singleQuote	:= _protocol.segmentTerminator;
	
	msg := MESSAGE &amp; 
			plus &amp; _ladingItemNumber &amp;  //Lading Line Item Number		L001  - 1
			plus &amp;  //billed quant 						L002
			plus &amp;  //billed qual						L003
			plus &amp; _weight &amp; 	// weight				L004
			plus &amp; _weightQual &amp; // weigth qual			L005
			plus &amp; // volume 							L006
			plus &amp; //volume unit qual					L007 
			plus &amp; _ladingQuant	&amp;//						L008
			plus &amp; _packingFormCode &amp; 		//			L009
			singleQuote;
			
	return msg;

epilog

end;</source>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_ladingItemNumber" type="String"/>
        <Parameter name="_weight" type="String"/>
        <Parameter name="_weightQual" type="String"/>
        <Parameter name="_ladingQuant" type="String"/>
        <Parameter name="_packingFormCode" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMessage_L5" id="3516293c-7f1c-4e6c-9cad-97d1d5dfa54b">
        <source>makeMessage_L5(_protocol :CM_CamProtocol ; _ladingItemNumber, _ladingDesc,_commodityCode,_commodityCodeQual : String ): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 January 2015	cnwrd1	Initial creation
*/
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time

constants
