    <JadeMethod name="displayCriteria" id="e3236876-9731-45cb-9265-6c02400cd067">
        <source>displayCriteria( _criteriaType : CM_YACriteriaType ) : String;

/*

Purpose:		Call back method for display for criteria type (refer CMUI_MultiSelectGroupBox::displayEntry)	

Parameters:			

Return Value:		


Date			Who		Reason
