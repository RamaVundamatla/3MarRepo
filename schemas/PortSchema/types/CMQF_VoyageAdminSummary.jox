<Class name="CMQF_VoyageAdminSummary" id="38ef7b5b-7729-4ec4-b571-39971686c04d">
    <superclass name="CMQF_VoyageSummary"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="filterForActual" id="6f663cbb-a216-4727-94d1-12ef2e141b8d">
        <updating/>
        <source>filterForActual(_voySummaryDict: CMIF_VoyageSummaryByValueDict input; _passport: CM_Passport) protected, updating;
// ---------------------------------------------------------------------------
// Created:     22 July 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	startTS,
	endTS			: TimeStamp;
	txnBucket		: CM_TITransactionByTypeDateDict;
	breakOut		: Boolean;
begin

	if (not self.startDate.isValid()) then
		startTS.setDate('01/01/0001'.Date);
	else
		startTS.setDate(self.startDate);
	endif;
	startTS.setTime('00:00:00:000'.Time);
	
	if (not self.endDate.isValid()) then
		endTS.setDate(app.actualTimeServer.date);
	else
		endTS.setDate(self.endDate);
	endif;
	
	endTS.setTime('23:59:59:999'.Time);
	
	create txnBucket transient;
	
	self.getMyVoyage.getTITxns(TRANS_TYPE_REC_SHIP, startTS, endTS, true, null, self, txnBucket);
	self.getMyVoyage.getTITxns(TRANS_TYPE_REL_SHIP, startTS, endTS, true, null, self, txnBucket);
	self.getMyVoyage.getTITxns(TRANS_TYPE_MOVE, startTS, endTS, true, null, self, txnBucket);
	
	self.processTxns(txnBucket, _voySummaryDict, _passport);

epilog
	delete txnBucket;
end;</source>
        <access>protected</access>
        <Parameter name="_voySummaryDict" type="CMIF_VoyageSummaryByValueDict" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="filterObjects" id="d0909be9-84bb-4dcf-82fe-958c134eb5fd">
        <updating/>
        <source>filterObjects(_collection: Collection input; _passport: CM_Passport) updating;
// ---------------------------------------------------------------------------
// Created:     20 July 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

	voySummaryDict	: CMIF_VoyageSummaryByValueDict;
begin
	if self.getMyVoyage = null then
		return;
	endif;

	if not _collection.isKindOf(CMIF_VoyageSummaryByValueDict) then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid collection type for query method');
		return;
	endif;

	voySummaryDict := _collection.CMIF_VoyageSummaryByValueDict;
	
	//if self.actualProposedOption = null or self.actualProposedOption = self.MODE_OPT_ACTUAL then
	self.filterForActual(voySummaryDict, _passport);
	//else
	//	self.filterForProposed(voySummaryDict, _passport);
	//endif;


end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="getKeyFromTxn" id="18e6a5bd-a262-4270-b897-b3e427556ceb">
        <source>getKeyFromTxn(_orderKey : String; _txn : CM_TITransaction) : String protected;
// ---------------------------------------------------------------------------
// Created:     07 November 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// 22/08/2008	concms1		par 17360 - report DLR/SOB as TRAFCL or TRAMT
vars
	bayId				: String;
	slotController		: CM_SlotController;
	lc					: CM_LocationsController;
	consignCode			: String;
	ti					: CM_TrackedItem;
	snapShot			: CM_TISnapShot;
	strStatus, strContent	: String;
	imex				: CM_IMEXStatus;
begin
	if _orderKey = null then
		return null;
	endif;
	
	snapShot := _txn.mySnapShot.CM_TISnapShot;
	
	if _orderKey = self.ORDERED_BY_IMEXANDCONTENT then
		// return snapShot.getStatusCode() &amp; snapShot.getContentsCode(); par 17360
		// put this here till i know what to do
		strStatus 	:= snapShot.getStatusCode;					// par 17360
		
		if snapShot.transitStatus = TI_TransitStatusDLR or		// par 17360
			snapShot.transitStatus = TI_TransitStatusSOB then	// par 17360
			
			imex := app.myRoot.allImexStatuses[TI_IMEX_STATUS_REMAINONBOARD];	// par 17360
			
			if imex &lt;&gt; null then								// par 17360
				strStatus := imex.abbreviation;					// par 17360
			endif;												// par 17360
			
		endif;													// par 17360
		
		strContent	:= snapShot.getContentsCode;				// par 17360
		
		return strStatus &amp; strContent;							// par 17360
		
	elseif  _orderKey = self.ORDERED_BY_ISO then
		return snapShot.getISOGroupDesc();
	endif;
	

end;</source>
        <access>protected</access>
        <Parameter name="_orderKey" type="String"/>
        <Parameter name="_txn" type="CM_TITransaction"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="processTxns" id="dcc1d5c2-d1aa-40d2-8e48-08ad7705a52b">
        <source>processTxns(_txnBucket : CM_TITransactionByTypeDateDict;
					_voySummaryDict : CMIF_VoyageSummaryByValueDict input;
					_passport : CM_Passport) protected;
// ---------------------------------------------------------------------------
// Created:     20 July 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// 09/11/2005	cnwmh5		PAR21537 - Don't require child items to be included
//
vars
	txn			: CM_TITransaction;
	summaryObj	: CMIF_VoyageSummary;	
	key2,
	key1			: String;
	allProcessedIDs	: StringArray;
	snapShot		: CM_TISnapShot;

begin

	create allProcessedIDs transient;//used to not count DLRs and SOBs twice

	foreach txn in _txnBucket do
		snapShot := txn.mySnapShot.CM_TISnapShot;
				
		if snapShot = null 
		or snapShot.deleted then
			continue;
		endif;
		
		//for whatever reason users can discharge and delete and then redischarge
		//don't want these deleted ones to add to the totals - hopefully these will be dealt with soon
		if (txn.myTrackedItem &lt;&gt; null
		and txn.myTrackedItem.state = TI_STATE_DELETED)
		or txn.deleted then
			continue;
		endif;
	
		// 09/11/2009 cnwmh5 PAR21537 - Start
		if txn.myTrackedItem.isChild or
		   txn.isChild then		// par 27796 Aug 2011 extend test for items unpacked since
			continue;
		endif;
		// 09/11/2009 cnwmh5 PAR21537 - End
	
		if snapShot.transitStatus = TI_TransitStatusDLR or
		   snapShot.transitStatus = TI_TransitStatusSOB then
			if allProcessedIDs.includes(snapShot.id) then
				continue;
			endif;
			
			allProcessedIDs.add(snapShot.id);
		endif;
		
		key1 := self.getKeyFromTxn(self.ORDERED_BY_ISO, txn);
		key2 := self.getKeyFromTxn(self.ORDERED_BY_IMEXANDCONTENT, txn);

		summaryObj := _voySummaryDict[key1, key2];

		if summaryObj = null then
			create summaryObj transient;
			summaryObj.keyValue1 := key1;
			summaryObj.keyValue2 := key2;
			_voySummaryDict.add(summaryObj);
		endif;
		summaryObj.numGeneral := summaryObj.numGeneral + 1;
	endforeach;

epilog
	delete allProcessedIDs;
end;</source>
        <access>protected</access>
        <Parameter name="_txnBucket" type="CM_TITransactionByTypeDateDict"/>
        <Parameter name="_voySummaryDict" type="CMIF_VoyageSummaryByValueDict" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
</Class>
