    <JadeMethod name="getRawMeasurementValue" id="7b795aa3-2836-4816-8149-a1fd7025843d">
        <source>getRawMeasurementValue(_rowName: String): Decimal;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 07 June 2022
TFS#		: 53316
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

begin
	if _rowName = ETRow_Diameter then
