    <JadeMethod name="getAuditText" id="c39af16a-2624-45d1-8e5c-9eb1f2e55045">
        <source>getAuditText(): String;
// ---------------------------------------------------------------------------
// Created:     11 June 2007 by cnwaer1
//02/08/2016 cnwma1 TFS #2447:Adding duplicate gives error
// Purpose:     
// ---------------------------------------------------------------------------

vars
	txt		: String;
	tmpStr	: String;
	email    : CM_EmailAddress2;
	invalidEmail : Boolean;
begin
	txt[10000] := '*';
	txt := null;
	txt := inheritMethod();
	
	foreach email in self.allContacts do
		on Exception do app.handleDeletedObject(exception, email, invalidEmail); //02/08/2016 cnwma1 TFS #2447
		if not invalidEmail then
			if tmpStr = null then
				tmpStr := email.name;
			else
				tmpStr := tmpStr &amp; ', ' &amp; email.name;
			endif;
			invalidEmail :=false;
		endif;
	endforeach;

	txt := txt &amp; 'Contacts Selected' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;

	return txt;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="5b41b403-aa6c-4e17-9434-1ac5550b0948">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     25 October 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// Created - PAR 12727
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	tmpLoadingCompany	: CM_LoadingCompany;
	completedOK		: Boolean;
	
begin

	tmpLoadingCompany := inheritMethod();
	
	self.allContacts.copy(tmpLoadingCompany.allContacts);

	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return tmpLoadingCompany;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete tmpLoadingCompany;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="b6e68119-e29e-42de-a20e-04c84c85246e">
        <updating/>
        <source>setForCreate(_pxyLoader : CM_LoadingCompany; _passport : CM_Passport input) updating;
