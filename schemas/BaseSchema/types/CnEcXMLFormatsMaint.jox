    <JadeMethod name="addFormat" id="ff67ff43-7dcc-40fb-8f85-9a722dc26e7f">
        <updating/>
        <source>addFormat(): Boolean updating, protected;

vars
	formatObj	: CnEcXmlFormat;
	
begin
	if txtTextGeneral.text.trimBlanks = "" then
		lblGeneral.caption := "Enter the name of the new Format and Press Update" &amp;
								CrLf &amp; "The name may NOT be blank.";
		lblPerforming.caption := "Input Error: see detail above";						
		return false;							
	elseif app.cnEcGetXmlFormat(txtTextGeneral.text.trimBlanks) &lt;&gt; null then
		lblGeneral.caption := "Enter the name of the new Format and Press Update" &amp;
								CrLf &amp; "'" &amp;txtTextGeneral.text.trimBlanks &amp; "' already used.";
		lblPerforming.caption := "Input Error: see detail above";						
		return false;			
	else
		beginTransaction;
			create formatObj;
			formatObj.initializeMe(txtTextGeneral.text,0,app.myCnEcXmlSchema);
		commitTransaction;
		
		fraGeneralUpdate.enabled := false;
		return true;
	endif;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="addFormatClick" id="e6f37008-81a2-4ad9-b83f-86433e9632fd">
        <updating/>
        <source>addFormatClick()updating, protected;

begin
	self.clearExtrasPanel();

	btnGeneralUpdate.caption	:= "Perform Add";	
	fraGeneralUpdate.enabled	:= true;		
	lblGeneral.caption			:= "Enter the name of the new Format and Press 'Perform Add'";
	lblClassFormat.caption		:= "Add new format.";	
	txtTextGeneral.enabled		:= true;
	txtTextGeneral.visible		:= true;
	self.aUpdateType := 1;
end;</source>
        <access>protected</access>
    </JadeMethod>
