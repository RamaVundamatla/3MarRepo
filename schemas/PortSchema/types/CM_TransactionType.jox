	txt := inheritMethod();
	return txt;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="8def3120-7e83-4c5e-ad30-34941144ceac">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     10 March 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if _attrName = ETRow_TranTypeGroup then // ### TFS CR 60699 TASK 60700 28SEP2023 NAVAB1
		return app.transactionTypeEnumToString(self.trxGroup);
	elseif _attrName =	ETRow_TranTypeClass then // ### TFS CR 60699 TASK 60700 27SEP2023 NAVAB1
		return self.classNameToCreate;
	endif;
	
	return inheritMethod(_attrName, _short);

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getName" id="ce363589-f580-4fd5-8e1f-220d2a13309d">
