    <JadeMethod name="setSelectedTZ" id="87c2667f-908a-468c-a80d-0d8cda729bb7">
        <source>setSelectedTZ( terminal : CM_Terminal input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 April 2016	cnwns1	Initial creation

*/

vars
timeZones : CMIF_TimeZoneInfoArray;
timeZone : CMIF_TimeZoneInfo;
foundTZ : Boolean;
begin
    create timeZones transient;
	app.myTimeZoneHelper.getSystemTimeZones(timeZones);
	
	
	foreach timeZone in timeZones do
		if timeZone.id = terminal.timeZoneID then	
			cMUI_ComboBoxTimezone1.setObject(timeZone);
			foundTZ := true;
		endif;
	endforeach;
	
	if foundTZ = false then
		cMUI_ComboBoxTimezone1.setObject(null);
	endif;
epilog
	if timeZones &lt;&gt; null then
		timeZones.purge();
		delete timeZones;
	endif;
end;
</source>
        <Parameter name="terminal" type="CM_Terminal" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setTimeZone" id="9f015d16-8cef-441e-92c0-6b8f6aca7950">
        <updating/>
        <source>setTimeZone(_terminal : CM_Terminal; _timeZoneID :String ; _shortID :String ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 April 2016	cnwns1	Initial creation

*/

vars
	messageString : String;
	shortID : String;
	terminal : CM_Terminal;
	terminalTimeString : String;
begin
	
	terminal := _terminal;
	shortID := _shortID.toUpper().trimBlanks();
	
	if _terminal = null or _timeZoneID.trimBlanks = "" then
		return;
	endif; 
	

	messageString := "Terminal:" &amp;  _terminal.code &amp; Tab &amp; _terminal.name &amp; CrLf &amp; 
					 "Current TZ:" &amp; _terminal.timeZoneID &amp; "-" &amp; _terminal.timeZoneShortID &amp; "." &amp; CrLf &amp;
					 "New TZ:      " &amp; _timeZoneID &amp; "-"  &amp; shortID&amp; ".";
	
	if  app.msgBox(messageString,"You are changing the timezone for terminal " &amp; _terminal.name,305) = MsgBox_Return_OK then
		
		beginTransaction;
			terminal.setTimeZoneID(_timeZoneID);
			terminal.setPropertyValue(CM_Terminal::timeZoneShortID.name, shortID);
		commitTransaction;
		
	if app.actualTimeServer = 	terminal.systemToLocalTime(app.actualTimeServer ) then
		terminalTimeString := "Server time";
	elseif	app.actualTimeServer &lt; 	terminal.systemToLocalTime(app.actualTimeServer )then

		terminalTimeString :=	"Server time + " &amp;	(terminal.systemToLocalTime(app.actualTimeServer ) - app.actualTimeServer).asStringJMT;
	else
	
		terminalTimeString :=	"Server time - " &amp;	(app.actualTimeServer - 	terminal.systemToLocalTime(app.actualTimeServer )).asStringJMT;
	
	endif;
	
		if _terminal.timeZoneShortID &lt;&gt; "" then
			shortID := _terminal.timeZoneShortID;
		else
			shortID := "&lt;null&gt;";
		endif;
	
		labelTermTZ.caption :=  "Term Code "  &amp; _terminal.code &amp; CrLf &amp;
								"TZ ID           " &amp; _terminal.timeZoneID &amp; CrLf &amp;
								"TZ Short     "  &amp; shortID&amp; CrLf &amp;
								terminalTimeString;
							
		shortID := _terminal.timeZoneShortID;
		
		textBoxTZshort.text := shortID;
		self.setSelectedTZ(terminal);
	endif;
	

epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_timeZoneID" type="String"/>
        <Parameter name="_shortID" type="String"/>
    </JadeMethod>
</GUIClass>
