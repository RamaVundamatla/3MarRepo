    <JadeMethod name="total" id="a6c923e9-0f02-4f21-94ac-935b6e0881a6">
        <source>total():Integer;
// ---------------------------------------------------------------------------
// Created:		17 February 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
tot : Integer;
begin
	tot := self.shipGen20 	
	+self.shipGen20DLR 		
	+self.shipGen40 		
	+self.shipGen40DLR 		
	+self.shipMT20 			
	+self.shipMT20DLR 		
	+self.shipMT40 			
	+self.shipMT40DLR 		
	+self.shipOther 		
	+self.shipPortHole 		
	+self.shipPortHoleDLR 	
	+self.shipPowered 		
	+self.shipPoweredDLR 	
	+self.shipReefer20 		
	+self.shipReefer20DLR 	
	+self.shipReefer40 		
	+self.shipReefer40DLR 	
	+self.shipSOB 			
	+self.yardGen20 		
	+self.yardGen40 		
	+self.yardMT20 			
	+self.yardMT40 			
	+self.yardOther 		
	+self.yardPortHole 		
	+self.yardPowered 		
	+self.yardReefer20 		
	+self.yardReefer40; 
	
	
	return tot;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
