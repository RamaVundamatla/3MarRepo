    <JadeMethod name="getAllDrawingIconsByPriority" id="11784a6f-8c98-47e5-ac9f-3aafc2407255">
        <source>getAllDrawingIconsByPriority(_iconArray: StringArray input; _maxIcons: Integer; _planning : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07/12/2017	jlgmp6	Initial creation	TFS7493
11/11/2019	jlgdap1	TFS 46405 AAT Flat Rack and OOG in LOLO Planning
*/

vars
	root: CM_Root;
	attr,
	startObject: CM_DrawingAttribute;
	lController: CM_LocationsController;
	iter: Iterator;
	attrCode: String;
begin
	root := app.getMyRoot();
	if root = null then
		return;
	endif;
	lController := self.getPrimaryLocation(QUEUE_MODE);
	
	iter := root.allDrawingAttributesByTypePri.createIterator();
	startObject := root.allDrawingAttributesByTypePri.getAtKeyGtr(DrawingAttrType_TrackedItem, null);
	if startObject &lt;&gt; null then
		iter.startAtObject(startObject);
		while iter.next(attr) and attr.drawingAttrType = DrawingAttrType_TrackedItem do
			attrCode := attr.code;
			// tracked item
			if attrCode = PicTIInTransit then
				if self.isInTransitOnShip and self.isOnWagon() then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTIReadyToShip then
				if self.readyToShip then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTICustomHold then
				if self.isStopSetToBeProcessed(StopProcessEDICustomExport) then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTIHazard then
				if self.isHazardous then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicSpecialStow then
				if self.specialStow &lt;&gt; null then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTITBA then
				if self.myMatchedTBA &lt;&gt; null then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTIQueued then
				if lController &lt;&gt; null or self.hasMembers(self.allQueuedFutureMoves) then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTIPlanned then
				if _planning then					// TFS 46405
					continue;						// TFS 46405
				endif;								// TFS 46405
				if self.hasMembers(self.allPlannedFutureMoves) then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTIActual then
				if self.getFirstAvailableLoadJob() &lt;&gt; null then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTIControlledAtmos then
				if self.isControlledAtmosphere then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTIReefer then
				if self.isReefer then
					_iconArray.add(attrCode);
				endif;
			// breakbulk
			elseif attrCode = PicTIBreakBulk then
				_iconArray.add(attrCode);
			endif;
	
			if _maxIcons &lt;&gt; 0 and _iconArray.size() &gt;= _maxIcons then
				break;
			endif;
		endwhile;
	endif;
	
epilog
	delete iter;
end;
</source>
        <Parameter name="_iconArray" type="StringArray" usage="input"/>
        <Parameter name="_maxIcons" type="Integer"/>
        <Parameter name="_planning" type="Boolean"/>
    </JadeMethod>
