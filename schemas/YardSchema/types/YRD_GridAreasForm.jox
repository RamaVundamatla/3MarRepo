    <JadeMethod name="doMnuSummariseSelected" id="19876e71-91bf-47f3-a44b-ea7633e3ee0d">
        <updating/>
        <source>doMnuSummariseSelected() updating;

/*

Purpose:		
Parameters:		
Return Value:	

Date				Who		Reason
16 February 2009	cnwrl1	Initial creation (CCMS SFW 1047 - Totals Only Lists)

*/
	
vars
	coll				: ObjectSet;
	
begin
	self.mousePointer	:= Busy;
	create coll transient;
	
	// Get a collection of all the objects (containers) SELECTED to pass to the Summary Definition form.
	if self.myCurrentDrawingController &lt;&gt; null then
		self.myCurrentDrawingController.allSelectedObjects.copy( coll );
	endif;
	self.myAssistant.showXTABSummaryDefinitionForm( coll, false, false, false, true );
	
epilog
	delete coll;
	self.mousePointer	:= Idle;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="doMnuTaskAdd" id="fb001eef-bc34-4593-a4a7-1e7cc278312b">
        <updating/>
        <source>doMnuTaskAdd(menuItem : MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	lTI	: CM_TrackedItem;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin

	lTI := menuItem.userObject.CM_TrackedItem;
	if lTI = null then
		return;
	endif;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateTIToDoTaskAdd(lTI, menuItem.index, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Add Todo Task', app.myPassport, ErrWarnMode_AddUpdate);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
	//refresh table
	self.showExtraInfoForObject(lTI);

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuTaskComplete" id="fc93237b-17be-4d41-8459-de5a0eaac763">
        <updating/>
        <source>doMnuTaskComplete(menuItem : MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:		April  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	lTI	: CM_TrackedItem;
	realTiSet : CM_TISet;
	pxyTiSet : CM_TISet;
	resourceUsageProxys : CM_ResourceTypeUsageSet;
	toDoTaskDesc : CM_ToDoTaskDesc;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin

	lTI := menuItem.userObject.CM_TrackedItem;
	if lTI = null or menuItem = self.mnuTaskComplete then
		return;
	endif;
	
	toDoTaskDesc := app.myRoot.allToDoTaskDescriptions[menuItem.index];
	
	create realTiSet transient;
	realTiSet.add(lTI);

	//+cnwml2 MSL CCMS 1017
	create pxyTiSet transient;
	
	//31 Dec 2009 NDL CCMS MES 1006	- Common code migrated up to assistant
	if not self.myAssistant.doTaskProxySetForComplete( menuItem.index, pxyTiSet, lTI, realTiSet, resourceUsageProxys) = IDOK then
		return;
	endif;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateTIToDoTaskCmpltBulk(toDoTaskDesc, pxyTiSet, resourceUsageProxys, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('GridArea Form', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
	//refresh table
	self.showExtraInfoForObject(lTI);
	
epilog

	if pxyTiSet &lt;&gt; null and not pxyTiSet.isEmpty then
		pxyTiSet.purge;
	endif;
	delete pxyTiSet;
	delete realTiSet;
	
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuTaskRemoveClick" id="cf8a2a97-3f46-44c1-bc90-c159206b232a">
        <updating/>
        <source>doMnuTaskRemoveClick(_menuItem : MenuItem input) updating;
//----------------------------------------------------------------
//	Created:	August 2005	by Russell Sargent  (cnwrs1)
//----------------------------------------------------------------

vars

	lTI		: CM_TrackedItem;
	answer	: Integer;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin

	lTI := _menuItem.userObject.CM_TrackedItem;
	if lTI = null or 
	   _menuItem = self.mnuTaskRemove then
		return;
	endif;

	answer := app.msgBox(app.getErrorString(TaskRemoveConfirm), app.getErrorString(Remove_Task), MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
	
	if answer = MsgBox_Return_No then
		return;
	endif;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateTIToDoTaskRemove(lTI, _menuItem.index, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog(app.getErrorString(Remove_Task), app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
end;</source>
        <Parameter name="_menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuUnplanClick" id="54c175ec-e7f1-42fc-8136-978069591762">
        <updating/>
        <source>doMnuUnplanClick(_menuItem : MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if _menuItem.helpKeyword = self.UnplanMenu_TypeMain then
		return;
	endif;
	if _menuItem.helpKeyword = self.UnplanMenu_TypeRehandle then
		 return;
	endif;
	
	if _menuItem.userObject.isKindOf(CM_FutureMove) then // PAR 18596
		self.doUnqueueTIbyFM(_menuItem.userObject.CM_FutureMove);// PAR 18596
	elseif _menuItem.userObject.CM_TrackedItem.getPrimaryLocation(QUEUE_MODE) &lt;&gt; null then 
		self.doUnqueueTI(_menuItem.userObject.CM_TrackedItem,(_menuItem.helpContextId = TI_FutureMoveOverstow));
	else
		self.doUnplanTI(_menuItem.userObject.CM_TrackedItem,(_menuItem.helpKeyword = self.UnplanMenu_TypeLoad));
	endif;

end;</source>
        <Parameter name="_menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
