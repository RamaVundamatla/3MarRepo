<Class name="CM_EDIFileTypeVSLStow" id="9c86272d-dffb-44aa-bd61-b51945f7c356">
    <superclass name="CM_EDIFileType"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
