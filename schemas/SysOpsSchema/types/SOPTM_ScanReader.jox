<Class name="SOPTM_ScanReader" id="5f29fbca-b462-4f9e-a2a1-b9f10554cf8f">
    <superclass name="SOP_TableMaintItem"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="sysops"/>
    <JadeMethod name="clearThumbnailData" id="215dfa7f-09a1-4c92-9353-4b685ce4a680">
        <updating/>
        <source>clearThumbnailData() updating;
/*

Purpose:			Clears the Thumbnail Data

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
29 April 2022	navpw1	Initial creation TFS: 52773

*/

vars
	theForm : SOP_TableMaintForm;
	
begin
  theForm := self.myForm;
  theForm.tblInput1.clearValues();

end;</source>
    </JadeMethod>
    <JadeMethod name="create" id="639547e4-cc2b-4340-b81d-7a1e189648bb">
        <updating/>
        <source>create() updating;
/*

Purpose:			Creates the SOPTM_ScanReader object

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
29 April 2022	navpw1	Initial creation TFS: 52773

*/

begin
	self.name 				:= SOP_TableMaintForm.Table_ScanReaderObj;
	self.permissionView 	:= PmAdmScanReaderView;
	self.permissionMaint 	:= PmAdmScanReaderMaint;
	self.myDataClass 		:= CM_ScanReaderObj;

end;</source>
    </JadeMethod>
    <JadeMethod name="doDelete" id="5009d279-b482-416d-b9ec-df898e116d62">
        <updating/>
        <source>doDelete(pObj: Object io) updating;
/*

Purpose:			Deletes a Scan Reader Object

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
29 April 2022	navpw1	Initial creation TFS: 52773

*/

begin
	app.myTrxDA.trxDeleteScanReaderObj(pObj.CM_ScanReaderObj, app.myPassport);

end;</source>
        <Parameter name="pObj" type="Object" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="aeb3f1df-5965-4dca-93d7-c12330bd53b1">
        <updating/>
        <source>doSave(): Boolean updating;
/*

Purpose:			Saves a Scan Reader object

Parameters:			NONE

Return Value:		Boolean	Whether it was successful or not

Date			Who		Reason
29 April 2022	navpw1	Initial creation TFS: 52773
28 July 2022	navmd1	TFS 52773 Tidy up/review code

*/

vars
	pxyScanReader 		: CM_ScanReaderObj;
	lName,
	lCode,
	lDeviceID			: String;
	theForm 			: SOP_TableMaintForm;
	
begin
	theForm 			:= self.myForm; 
	lName 				:= theForm.tblInput1.getValueByName(ETRow_Name).String;
	lCode 				:= theForm.tblInput1.getValueByName(ETRow_Code).String;
	lDeviceID 			:= theForm.tblInput1.getValueByName(ETRow_DeviceID).String;
	
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_ScanReaderObj transient;
			
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
			
		endif;
		
	endif;
	
	pxyScanReader := theForm.myProxyObject.CM_ScanReaderObj;
	pxyScanReader.setProxy(lName,					//_name 				: String;
							lCode,					//_code 				: String;
							lDeviceID,				//_deviceId 			: String;
							theForm.myTerminal		//_myTerminal 			: CM_Terminal;
							);

	if theForm.mode = theForm.Mode_Add then
		 app.myTrxCA.trxCreateScanReaderObj(pxyScanReader, theForm.myCurrentObject,app.myPassport);
		 
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateScanReaderObj(pxyScanReader, app.myPassport);
		
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
		
	endif;
	
	return app.myPassport.trxCompletedOK;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCollection" id="ce8d4780-51d8-4771-ad3f-8eab4b7a92a3">
        <source>getCollection(): Collection;
/*

Purpose:			Gets the collection of scan readers from the terminal

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
29 April 2022	navpw1	Initial creation TFS: 52773

*/

begin
	return self.myForm.myTerminal.allScanReaders;

end;</source>
        <ReturnType type="Collection"/>
    </JadeMethod>
    <JadeMethod name="getEntTableDef" id="b8f8f001-ee4f-476c-b842-b9d28752c7cd">
        <source>getEntTableDef(): String;
/*

Purpose:			Gets the EnTableDef to use for this form

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
29 April 2022	navpw1	Initial creation TFS: 52773

*/

begin
	return ETDef_ScanReader;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="31d501eb-0b12-4664-9a78-4322ee0a932d">
        <updating/>
        <source>setControlsForAddEdit() updating;
/*

Purpose:			Sets the controls for Adding and Editing a Scan Reader object

Parameters:			NONE

Return Value:		NONE

Date			Who		Reason
29 April 2022	navpw1	Initial creation TFS: 52773
28 July 2022	navmd1	TFS 52773 Tidy up/review code

*/

vars
	theForm : SOP_TableMaintForm;

begin
	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
	theForm.mulSelect1.userInputEnabled := false;	
	
	if theForm.mode = theForm.Mode_Add then
		theForm.tblInput1.clearValues;
		
		theForm.loadCmbGateLane();
		
		theForm.tblInput1.enableRowByName(ETRow_Name);
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_DeviceID);
		theForm.tblInput1.moveFirst();
		// call this last as sets cell input type (case etc)
		// if not called can get problems with case on entry. 
		//self.changeViews(null);
		
		theForm.tblInput1.gotFocus(theForm.tblInput1);
		
	else
		// refresh the data from the newly created proxy
		self.showThumbnail(theForm.myProxyObject.CM_ScanReaderObj);
		// cannot update code		
		theForm.tblInput1.disableRowByName(ETRow_Code);
		
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="c80c1aeb-79c0-429d-b92d-4e969b76738a">
        <updating/>
        <source>setCtrlsForView() updating;
/*

Purpose:			Sets the controls for Viewing a Scan Reader object

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
29 April 2022	navpw1	Initial creation TFS: 52773

*/

vars
	theForm : SOP_TableMaintForm;
	
begin
	inheritMethod();
	
	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := false;

end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="403fef28-7cf6-4626-89d6-a10278cafd00">
        <updating/>
        <source>setupThumbnailDetails() updating;
/*

Purpose:			Initially sets up the Thumbnail Details

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
29 April 2022	navpw1	Initial creation TFS:52773

*/

vars
	theForm : SOP_TableMaintForm;
	
begin
  
  	theForm := self.myForm;
	theForm.useProxyObject := true;
	
	theForm.setTblDataEntRows(ETDef_ScanReader);
	
	theForm.shtTblInput1.caption := app.getErrorString(Details);
	theForm.initTblInput(theForm.tblInput1, ETDef_ScanReader);
	theForm.shtTblInput1.visible := true;

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="7a7f59a3-4a57-498b-9bbc-a8509081229f">
        <updating/>
        <source>showThumbnail(pObj: CM_ScanReaderObj) updating;
/*

Purpose:			Shows the thubnail details for the currently selected Scan Reader

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
29 April 2022	navpw1	Initial creation TFS: 52773

*/

vars
	theForm : SOP_TableMaintForm;
	
begin
    theForm := self.myForm;
	theForm.tblInput1.clearValues;
	
	theForm.loadCmbWBridgeType();
	theForm.loadCmbGateLane();

	theForm.tblInput1.setValueByName(ETRow_Code, pObj.code);
	
	theForm.tblInput1.setValueByName(ETRow_Name, pObj.name);
	theForm.tblInput1.setValueByName(ETRow_DeviceID, pObj.deviceId);
	
end;</source>
        <Parameter name="pObj" type="CM_ScanReaderObj"/>
    </JadeMethod>
</Class>
