    <JadeMethod name="includeObject" id="068c8ae0-ef72-461c-971c-a9a14454945e">
        <updating/>
        <source>includeObject(_obj: Object; _passport: CM_Passport): Boolean updating;
/*
Date		    Who			Reason
11 April 2011	cnwas3	  Initial creation: CCMS 1031
*/

vars

begin
	if self.includeNotAvailableEntries then
		return true;
	else
		return _obj.CM_VesselRampPositionType.isAvailableForEntry;
	endif;
epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
