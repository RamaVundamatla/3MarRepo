    <JadeMethod name="assessMainFile" id="c1014153-d55b-4e6e-9f00-ea7b493d8543">
        <source>assessMainFile();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 September 2014	cnwndl1	Initial creation

*/

constants

	BLOCK_SIZE		: Integer = 1024;
	
vars

	inputFileName : String;
	inFile : File;
	block : String;
	tag : String;
	loadData : String;
	isNewTag : Boolean;
	index : Integer;
	tagData : String;
	count : Integer;
	tagArray : StringArray;
	intArray : IntegerArray;
	arrayIndex : Integer;
	msg : String;

begin

	inputFileName := self.txtMain.text;
	if inputFileName = null then
		return;
	endif;
	
	create inFile;
	inFile.fileName := inputFileName;
	inFile.kind := File.Kind_Unknown_Text;	// 1/3/16 cnwmp6 PAR 36286 unicode version
	inFile.open;
	
	loadData := null;
	isNewTag := true; 
	create tagArray transient;
	create intArray transient;
	
	
	while not inFile.endOfFile() do
    	block := inFile.readString(BLOCK_SIZE);
    	loadData := loadData &amp; block;
    	///
    	while true do
	    	if isNewTag then
	    		tag := loadData.cnEcXmlExtractFirstTag();
	    		
                if tag = null then
                	break;
                endif;
                
	    		isNewTag := false;
	    	endif;
	    	
	        index := loadData.pos("&lt;/" &amp; tag &amp; "&gt;", 1);
	        
	        if index &gt; 0 then
	        	index := index + ("&lt;/" &amp; tag &amp; "&gt;").length;
	      //  	tagData := loadData[1:index];
	        	
	    /*    	if pType = CNEC_DATA_LOAD_NOID then 
		        	self.loadNoids(tag, tagData, logFile);
		        elseif pType = CNEC_DATA_LOAD_ATTRIBUTE then 
		        	self.loadAttributes(tag, tagData, logFile);
		        elseif pType = CNEC_DATA_LOAD_SINGLETON  then
                    self.loadSingletonReference(tagData, logFile);
		        elseif pType = CNEC_DATA_LOAD_COLLECTION then
					self.loadCollection(tagData, logFile);
				endif;		*/        

	        	if tagArray.includes(tag) then
					arrayIndex := tagArray.indexOf(tag);
					intArray[arrayIndex] := intArray[arrayIndex] + 1;
				else
					tagArray.add(tag);
					intArray.add(1);
				endif;
	        	
	        	if index &lt; loadData.length then
					loadData := loadData[index+1: end];
				else
					loadData := null;
				endif;
				
				isNewTag := true;
			else
				break;
			endif;
		endwhile;
		///
	endwhile;
	
	
	foreach index in 1 to tagArray.size do
		if msg &lt;&gt; null then
			msg := msg &amp; ", ";
		endif;
		msg := msg &amp; " " &amp; tagArray[index] &amp; " (x" &amp; intArray[index].String &amp; ")"; 
	endforeach;
	
	self.lblMessage.caption := "File has: " &amp; msg;

epilog

	if inFile &lt;&gt; null then
		inFile.close;
	endif;
	delete inFile;
	delete tagArray;
	delete intArray;

end;</source>
    </JadeMethod>
