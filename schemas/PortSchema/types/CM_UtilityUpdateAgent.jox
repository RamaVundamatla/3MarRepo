    <JadeMethod name="utlUpdateTIToDoTaskRemove" id="a6ac348b-4ec6-49ee-8181-4cac58c1e682">
        <updating/>
        <source>utlUpdateTIToDoTaskRemove(_theTI : CM_TrackedItem input; _toDoCode : Integer;
					_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     10 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// 12 Oct 2016	cnwkpd1	TFS 2815 - JADE 7.1.08 causeEvent changes

vars
	taskDesc : CM_ToDoTaskDesc;
begin

	taskDesc := app.myRoot.allToDoTaskDescriptions[_toDoCode];
	if taskDesc = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'No todo task found for (' &amp; _toDoCode.String &amp; ')');
		return;
	endif;

	_theTI.removeToDoTask(taskDesc.description, _passport);
	
//	_theTI.causeEvent(Object_Update_Event, false, _theTI);
	self.updateObjectEdition(_theTI);
	
end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem" usage="input"/>
