    <JadeMethod name="doSave" id="b7fd6793-7e37-4477-b3fc-63b2bf17c3eb">
        <updating/>
        <source>doSave() : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     12 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	navObject	: CMUI_NavigatorObject;
	errObj		: CM_Error;
	rtnValue	: Boolean;
				
begin
	//to pick the last change (no lost_focus fired)
	self.tblMain.doChangedComparison(self.tblMain.row);

	if self.mode = Mode_Add then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Attempt to add a Cargo Release - This is not permitted');
		return false;
	elseif self.mode = Mode_Update then
		if self.myProxyObject = null then
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy is null for update');
			return false;
		endif;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Unhandled mode (' &amp; self.mode.String &amp; ')');
		return false;
	endif;

	if self.userPermissionMode = PmGteFullReleaseCarrierMaint then//for external users who are carriers
		// For security reasons, users who only have this permission can update the pin number
		// Normal full release maint permission does not have to ability to update pin number
		// This is to prevent non-carriers obtaining pin numbers and releasing cargo
		rtnValue := self.doSaveCarrier();

	elseif self.userPermissionMode = PmGteFullReleaseForward then//for external users who are freight forwarders
		// For security reasons, users who only have this permission can update the pin number
		// Normal full release maint permission does not have to ability to update pin number
		// This is to prevent non-carriers obtaining pin numbers and releasing cargo
		rtnValue := self.doSaveForwarder();

	elseif self.userPermissionMode = PmGteFullReleaseOperatorMaint then
		rtnValue := self.doSaveOperator();
	else
		rtnValue := self.doSaveNormal();
	endif;

	if not rtnValue then
		self.setAllErrorWarnings(app.myPassport);

		errObj := app.myPassport.getFirstErrorWarning();
		if errObj &lt;&gt; null then
			navObject := errObj.myUserObject.CMUI_NavigatorObject;
			if navObject &lt;&gt; null then
				navObject.goToObject(errObj.myUserObject.Control, errObj.fieldName, true);
			endif;
		endif;
				
		return false;
	else
		return true;
	endif;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveCarrier" id="027335aa-d823-41d4-a9f5-16de5d99e74b">
        <updating/>
        <source>doSaveCarrier() : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     12 December 2000 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	navObject	: CMUI_NavigatorObject;
	intFaceArray: CMIF_TIObjectArray;
	intFaceObj	: CMIF_CarrierRelease;
	ti			: CM_TrackedItem;
	idx			: Integer;
	rtnValue	: Boolean;
	tmpCarrierCode,
	tmpCarrierRemarks, //par16225 Mar 2008 cnwrs1
	tmpCustomsChkNo,
	operatorImpReleasePIN,
	tmpDelvRel	: String;
	obj			: Object;
	result		: Integer;
	origRelCarrier : CM_Carrier;	//17 Nov 2014	NDL	Par 35174
	updCarrier : Boolean;	//17 Nov 2014	NDL	Par 35174
	failedDAC : CM_DataAccessController;	//17 Nov 2014	NDL	Par 35174
	
				
begin

	tmpCarrierCode 	:= tblMain.getValueByName(ETRow_ReleaseCarrier).String;
	tmpDelvRel		:= tblMain.getValueByName(ETRow_DeliveryReleaseNumber).String;
	tmpCustomsChkNo := tblMain.getValueByName(ETRow_CustomsEntryCheckNo).String;
	tmpCarrierRemarks := tblMain.getValueByName(ETRow_CarrierRemarks).String;
	operatorImpReleasePIN	:= tblMain.getValueByName(ETRow_OperatorImportReleasePIN).String;  //cnwrd1 6.11.08 CCMS JMT 1743/1764 

	//17 Nov 2014	NDL	Par 35174
	origRelCarrier := app.myRoot.allCarriers[self.myCurrentObject.CM_TrackedItem.releaseCarrier];
	if origRelCarrier &lt;&gt; null and (not origRelCarrier.canUserAccessSelf(null, failedDAC, app.myPassport)) then
		origRelCarrier := null;
	endif;
	updCarrier := self.cmbCarrier.listObject &lt;&gt; origRelCarrier;
	
	
	create intFaceArray transient;

	foreach obj in self.allProxyObjects do
		ti := obj.CM_TrackedItem;
		create intFaceObj transient;
		intFaceObj.customsEntryCheckNo := tmpCustomsChkNo;
		intFaceObj.operatorImportReleasePIN := operatorImpReleasePIN;
		intFaceObj.myProxyTrackedItem := ti;
		
		if tblMain.hasRowChangedByName(ETRow_ReleaseCarrier, false) and updCarrier then
			ti.setReleaseCarrier(tmpCarrierCode);
		endif;
		if tblMain.hasRowChangedByName(ETRow_DeliveryReleaseNumber, false) then
			ti.setDeliveryRelease(tmpDelvRel);
		endif;
		if tblMain.hasRowChangedByName(ETRow_CarrierRemarks, false) then
			ti.setCarrierRemarks(tmpCarrierRemarks);
		endif;
		
		intFaceArray.add(intFaceObj);
	endforeach;

	// sgp 27 June 2003 : show warnings
	while true do
		app.myTrxUA.trxUpdateCarrierRelease(ReleaseAgent_Carrier, intFaceArray, app.myPassport);
		if app.myPassport.trxCompletedOK then
			rtnValue := true;
			break;
		else
			result := app.showErrorWarningDialog('Releases', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		
		rtnValue := false;
		break;

	endwhile;

	if rtnValue then
		self.addUpdateTransactionComplete := true;
		app.msgBox(intFaceArray.size.String &amp; ' items successfully updated', 'Information', MsgBox_OK_Only + MsgBox_Information_Icon);
	endif;

epilog
	if intFaceArray &lt;&gt; null then
		delete intFaceArray;
	endif;
	return app.myPassport.trxCompletedOK;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveForwarder" id="431a5367-0f62-4303-ba01-e72fef2dd118">
        <updating/>
        <source>doSaveForwarder() : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     12 December 2000 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	navObject	: CMUI_NavigatorObject;
	intFaceArray: CMIF_TIObjectArray;
	intFaceObj	: CMIF_CarrierRelease;
	ti			: CM_TrackedItem;
	idx			: Integer;
	rtnValue	: Boolean;
	tmpFreightForwarderCode,
	tmpCarrierCode,
	tmpCarrierRemarks,
	tmpCustomsChkNo,
	tmpRemarks,						// CCMS 1853 #20099
	tmpDelvRel	: String;
	obj			: Object;
	result		: Integer;
	numNominated	: Integer;
	msgStr	: String;
	tmpFF	: CM_ConsigneeConsignor;
	bookingRef	: String;
	operatorImpReleasePIN	: String; //cnwrd1 6.11.08 CCMS JMT 1743/1764 
	origRelCarrier : CM_Carrier;	//17 Nov 2014	NDL	Par 35174
	updCarrier : Boolean;	//17 Nov 2014	NDL	Par 35174
	origFForwarder : CM_ConsigneeConsignor;	//17 Nov 2014	NDL	Par 35174
	updFForwarder : Boolean;	//17 Nov 2014	NDL	Par 35174
	failedDAC : CM_DataAccessController;	//17 Nov 2014	NDL	Par 35174
	
begin
	tmpFF := self.cmbFreightFwdr.listObject.CM_ConsigneeConsignor;
	
	if tmpFF &lt;&gt; null then
		tmpFreightForwarderCode := tmpFF.code;
	endif;
	
	tmpDelvRel		:= tblMain.getValueByName(ETRow_DeliveryReleaseNumber).String;
	tmpCustomsChkNo := tblMain.getValueByName(ETRow_CustomsEntryCheckNo).String;
	
	// CCMS 1648 - add in carrier and carrier remarks
	tmpCarrierCode		:=	tblMain.getValueByName(ETRow_ReleaseCarrier).String;
	bookingRef			:=	tblMain.getValueByName(ETRow_BookingReference).String;	// cnwdad1 29/08/2008 - CCMS 1739.
	tmpCarrierRemarks	:=	tblMain.getValueByName(ETRow_CarrierRemarks).String;
	operatorImpReleasePIN	:= tblMain.getValueByName(ETRow_OperatorImportReleasePIN).String;  //cnwrd1 6.11.08 CCMS JMT 1743/1764 
	
	// CCMS 1853 #20099
	tmpRemarks		:= tblMain.getValueByName(ETRow_Remarks).String;
	
	//17 Nov 2014	NDL	Par 35174
	origRelCarrier := app.myRoot.allCarriers[self.myCurrentObject.CM_TrackedItem.releaseCarrier];
	if origRelCarrier &lt;&gt; null and (not origRelCarrier.canUserAccessSelf(null, failedDAC, app.myPassport)) then
		origRelCarrier := null;
	endif;
	updCarrier := self.cmbCarrier.listObject &lt;&gt; origRelCarrier;
	origFForwarder := self.myCurrentObject.CM_TrackedItem.myFreightForwarder;	
	updFForwarder := self.cmbFreightFwdr.listObject &lt;&gt; origFForwarder;

	create intFaceArray transient;

	foreach obj in self.allProxyObjects do
		ti := obj.CM_TrackedItem;
		create intFaceObj transient;
		intFaceObj.customsEntryCheckNo := tmpCustomsChkNo;
		intFaceObj.operatorImportReleasePIN := operatorImpReleasePIN;
		intFaceObj.myProxyTrackedItem := ti;
		
		//ti.setFreightForwarder(tmpFreightForwarderCode);
		//ti.setDeliveryRelease(tmpDelvRel);
		
		if tblMain.hasRowChangedByName(ETRow_FreightForwarder, false) and updFForwarder then
			ti.setFreightForwarder(tmpFreightForwarderCode);
		endif;
		if tblMain.hasRowChangedByName(ETRow_DeliveryReleaseNumber, false) then
			ti.setDeliveryRelease(tmpDelvRel);
		endif;
		if tblMain.hasRowChangedByName(ETRow_ReleaseCarrier, false) and updCarrier then
			ti.setReleaseCarrier(tmpCarrierCode);
		endif;
		
		// cnwdad1 29/08/2008 - CCMS 1739.
		if tblMain.isRowVisible(ETRow_BookingReference) and 
		   tblMain.hasRowChangedByName(ETRow_BookingReference, false) then
			ti.setBookingReference(bookingRef);
		endif;
		if tblMain.hasRowChangedByName(ETRow_CarrierRemarks, false) then
			ti.setCarrierRemarks(tmpCarrierRemarks);
		endif;

		// CCMS 1853 #20099
		if tblMain.hasRowChangedByName(ETRow_Remarks, false) then
			ti.setRemarks(tmpRemarks, false);
		endif;
		
		//cnwrd1 6.11.08 CCMS JMT 1743/1764 
		// validate Operator import release PIN!
		//ti.validateOpImpReleasePIN (operatorImpReleasePIN ) ;
		
		intFaceArray.add(intFaceObj);
	endforeach;

	// sgp 27 June 2003 : show warnings
	while true do
		app.myTrxUA.trxUpdateCarrierRelease(ReleaseAgent_FreightForwarder, intFaceArray, app.myPassport);
		if app.myPassport.trxCompletedOK() then
			rtnValue := true;
			break;
		else
			result := app.showErrorWarningDialog('Releases', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		
		rtnValue := false;
		break;

	endwhile;

	if rtnValue then
		self.addUpdateTransactionComplete := true;
		foreach obj in intFaceArray do
			intFaceObj := obj.CMIF_CarrierRelease;
			if intFaceObj.pinNo &lt;&gt; null then
				numNominated := numNominated + 1;
			endif;
		endforeach;
		
		if numNominated &gt; 0 then
			// If any have been nominated (i.e. a PIN added) when
			// we assume that all have for the purposes of this messageg
			msgStr := intFaceArray.size.String &amp; ' item(s) nominated.';
		else
			// just an update.  Maybe removed freightforwarder
			msgStr := intFaceArray.size.String &amp; ' item(s) successfully updated';
		endif;
		app.msgBox(msgStr, 'Information', MsgBox_OK_Only + MsgBox_Information_Icon);
	endif;
epilog
	if intFaceArray &lt;&gt; null then
		delete intFaceArray;
	endif;
	
	return app.myPassport.trxCompletedOK();
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveNormal" id="07766ed2-4b7c-4769-90f7-7b00fbe1d6d9">
        <updating/>
        <source>doSaveNormal() : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     12 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	realTISet,
	pxyTISet				: CM_TISet;
	ti						: CM_TrackedItem;
	rtnValue				: Boolean;
	tiStop					: CM_Stops;
	tmpFreightFowarderCode,
	tmpCarrierCode,
	tmpRemarks,
	tmpCarrierRemarks,
	tmpCustomsNo,
	clientRef,
	tmpDelvRel				: String;
	sa						: StringArray;
	genPin,
	tmpStop					: Boolean;
	originalStops,
	additionalStops,
	removeStops				: IntegerArray;				
	aStopTable				: CM_StopsTable;
	result					: Integer;
	heading					: String;
	allStops				: CM_StopsByIdDict;
	origRelCarrier : CM_Carrier;	//17 Nov 2014	NDL	Par 35174
	updCarrier : Boolean;	//17 Nov 2014	NDL	Par 35174
	origFForwarder : CM_ConsigneeConsignor;	//17 Nov 2014	NDL	Par 35174
	updFForwarder : Boolean;	//17 Nov 2014	NDL	Par 35174
	failedDAC : CM_DataAccessController;	//17 Nov 2014	NDL	Par 35174
	
begin
	create originalStops transient;
	if CM_TrackedItem.hasInstance(self.myCurrentObject) then
		ti := self.myCurrentObject.CM_TrackedItem;
//		foreach tiStop in ti.getAllStops() do	// cnwrl1 15/12/2009 PAR 21889 - what it was
		create allStops transient;
		ti.getAllActiveStops( allStops );
		foreach tiStop in allStops do
			originalStops.add(tiStop.id);
		endforeach;
	endif;
	
	if self.cmbFreightFwdr.listObject &lt;&gt; null then
		tmpFreightFowarderCode := self.cmbFreightFwdr.listObject.CM_ConsigneeConsignor.code.String;
	endif;
	
	tmpCarrierCode 	:= tblMain.getValueByName(ETRow_ReleaseCarrier).String;
	tmpCarrierRemarks:= tblMain.getValueByName(ETRow_CarrierRemarks).String;
	tmpDelvRel		:= tblMain.getValueByName(ETRow_DeliveryReleaseNumber).String;
	tmpCustomsNo 	:= tblMain.getValueByName(ETRow_CustomsEntryNumber).String;
	tmpRemarks		:= tblMain.getValueByName(ETRow_Remarks).String;
	clientRef		:= tblMain.getValueByName(ETRow_ClientRef).String; //cnwrd1 par 23337 17.5.2010

	//tmpCustomsAgent := tblMain.getValueByName(ETRow_MyCustomsAgent).String;
	

	// Only generate if the user has tick the generate pin check box	
	genPin := tblMain.getValueByName(ETRow_GeneratePinNo).Boolean;
	
	// cnwrd1 hack to do some validation here.
	if genPin and not self.doValidateOperReleasePin() then  // cnwrd1 par 27170 check this only if we are asking for a JMT release PIN?!
		return false;
	endif;
	

	
	// CCMS 1017 NEW from here
	create additionalStops transient;
	create removeStops transient;

	foreach aStopTable in app.myRoot.allStopsTable do
		//heading := aStop.heading &amp; " Stop";
		heading := aStopTable.getAttrName();
		if tblMain.isRowVisible(heading) then
			tmpStop := tblMain.getValueByName(heading).Boolean; // PAR 7753 added space to "Stop"
			if tmpStop then
				if not originalStops.includes(aStopTable.id) then
					//has been a change - new stop
					additionalStops.add(aStopTable.id);
				endif;
			else
				if originalStops.includes(aStopTable.id) then
					//has been a change - stop taken off
					removeStops.add(aStopTable.id);
				endif;
			endif;
		endif;
	endforeach;

	// CCMS 1017 NEW to here
	if tblMain.getValueByName(ETRow_GeneratePinNo).Boolean then
		create realTISet transient;
	endif;
	
	//17 Nov 2014	NDL	Par 35174
	origRelCarrier := app.myRoot.allCarriers[self.myCurrentObject.CM_TrackedItem.releaseCarrier];
	if origRelCarrier &lt;&gt; null and (not origRelCarrier.canUserAccessSelf(null, failedDAC, app.myPassport)) then
		origRelCarrier := null;
	endif;
	updCarrier := self.cmbCarrier.listObject &lt;&gt; origRelCarrier;
	origFForwarder := self.myCurrentObject.CM_TrackedItem.myFreightForwarder;	
	updFForwarder := self.cmbFreightFwdr.listObject &lt;&gt; origFForwarder;
	
	create pxyTISet transient;
	self.allProxyObjects.copy(pxyTISet);
	foreach ti in pxyTISet do
		if tblMain.hasRowChangedByName(ETRow_ReleaseCarrier, false) and updCarrier then
			ti.setReleaseCarrier(tmpCarrierCode);
		endif;
		if tblMain.hasRowChangedByName(ETRow_FreightForwarder, false) and updFForwarder then
			ti.setFreightForwarder(tmpFreightFowarderCode);
		endif;
		if tblMain.hasRowChangedByName(ETRow_CarrierRemarks, false) then
			ti.setCarrierRemarks(tmpCarrierRemarks);
		endif;
		if tblMain.hasRowChangedByName(ETRow_DeliveryReleaseNumber, false) then
			ti.setDeliveryRelease(tmpDelvRel);
		endif;
		if tblMain.hasRowChangedByName(ETRow_CustomsEntryNumber, false) then
	//		ti.setCustomsEntryNumber(tmpCustomsNo);
	//		ti.allCustomsEntryNumbers := sa;
			self.tblMain.setObjectFromTable(ti, GTE_FullReleaseForm::setTIFromTableSpecial.name, false);
		endif; // dh 26/11/2007 ccms 1616 replaced with special save
		if tblMain.hasRowChangedByName(ETRow_Remarks, false) then
			ti.setRemarks(tmpRemarks, false);
		endif;
		
		if tblMain.hasRowChangedByName(ETRow_ClientRef, false) then
			ti.setClientRef(clientRef);//cnwrd1 par 23337 17.5.2010
		endif;
		
		ti.zSetPxyCustomsAgent(self.cmbCustomsAgent.myObject.CM_CustomsAgent);
		
		ti.createStopsProxyBulkEdit(additionalStops, removeStops); // CCMS 1017 NEW
		if realTISet &lt;&gt; null then
			realTISet.add(ti.pxyGetRealObject());
		endif;
	endforeach;

	// sgp 27 June 2003 : show warnings

	while true do

		app.myTrxUA.trxUpdateTrackedItems(pxyTISet, TI_UPDMODE_NORMAL, null, app.myPassport);

		if app.myPassport.trxCompletedOK then
			rtnValue := true;
			break;
		else
			result := app.showErrorWarningDialog('Releases', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		
		rtnValue := false;
		break;
	endwhile;

/*
	if self.myEmailDefaults = null then
		//create a clone of the terminal default to add to the IntFacePreNote
		//there may already be one if the terminal defaults have been changed by the user in this mode 
		termEmailDefaults := self.myTerminal.getCarrierEmailDefaultsForType(PINEmail_Prenote);
		self.myEmailDefaults := termEmailDefaults.cloneSelf(true).CM_PINObjectDefaultEmail;
		carrier := self.cmbCarrier.myObject.CM_Carrier;
		if carrier &lt;&gt; null then
			carrier.allPINNotifyEmailAddresses.copy(self.myEmailDefaults.allCarrierAddresses);
		endif;
	endif;
*/
	if rtnValue and genPin then
		self.generatingPIN := true;
		self.doGeneratePin(realTISet, self.myEmailDefaults);
	endif;
	
epilog
	if self.generatingPIN then
		self.generatingPIN := false;
	endif;
		
	if pxyTISet &lt;&gt; null then
		delete pxyTISet;
	endif;
	delete removeStops;
	delete additionalStops;
	delete originalStops;
	delete realTISet;
	delete sa ;
	delete allStops;
	
	return rtnValue;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveOperator" id="1d2a35f2-a948-48da-9937-5726fb89f865">
        <updating/>
        <source>doSaveOperator() : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     12 December 2000 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tiSet					: CM_TISet;
	ti						: CM_TrackedItem;
	rtnValue				: Boolean;
	tmpFreightForwarderCode	: String;
	tmpCarrierCode			: String;
	tmpDelvRel				: String;
	tmpCarrierRemarks		: String;
	result					: Integer;
	stopsArray				: IntegerArray;		
	tmpFF					: CM_ConsigneeConsignor;
	ffChanged				: Boolean;
	carrierRemarksChanged	: Boolean;
	bookingRef				: String;
	operatorImpReleasePIN	: String; //cnwrd1 6.11.08 CCMS JMT 1743/1764
	origRelCarrier : CM_Carrier;	//17 Nov 2014	NDL	Par 35174
	updCarrier : Boolean;	//17 Nov 2014	NDL	Par 35174
	origFForwarder : CM_ConsigneeConsignor;	//17 Nov 2014	NDL	Par 35174
	updFForwarder : Boolean;	//17 Nov 2014	NDL	Par 35174
	failedDAC : CM_DataAccessController;	//17 Nov 2014	NDL	Par 35174

begin
	// As at 7.5.3, April 2008, the Operator Stop row was NOT in the ETDef_FullReleaseMain (or OperatorView), so 
	// not displayed on the screen.  If this is required then need to dynamically add the stops that the user
	// has access to maintain and in here have code similar to doSaveNormal.
	//tmpOperatorStop		:= tblMain.getValueByName(ETRow_OperatorStop).Boolean;

	tmpCarrierCode		:=	tblMain.getValueByName(ETRow_ReleaseCarrier).String;
	tmpDelvRel			:=	tblMain.getValueByName(ETRow_DeliveryReleaseNumber).String;
	tmpCarrierRemarks 	:=	tblMain.getValueByName(ETRow_CarrierRemarks).String;
	bookingRef			:=	tblMain.getValueByName(ETRow_BookingReference).String;	// cnwdad1 29/08/2008 - CCMS 1739.
	operatorImpReleasePIN	:= tblMain.getValueByName(ETRow_OperatorImportReleasePIN).String;  //cnwrd1 6.11.08 CCMS JMT 1743/1764 
	tmpFF				:=	self.cmbFreightFwdr.listObject.CM_ConsigneeConsignor; 
	
	if tmpFF &lt;&gt; null then
		tmpFreightForwarderCode := tmpFF.code;
	endif;

	create tiSet transient;
	self.allProxyObjects.copy(tiSet);

	create stopsArray transient;
	
	ffChanged := tblMain.hasRowChangedByName(ETRow_FreightForwarder, false);
	carrierRemarksChanged := tblMain.hasRowChangedByName(ETRow_CarrierRemarks, false);
	
	//17 Nov 2014	NDL	Par 35174
	origRelCarrier := app.myRoot.allCarriers[self.myCurrentObject.CM_TrackedItem.releaseCarrier];
	if origRelCarrier &lt;&gt; null and (not origRelCarrier.canUserAccessSelf(null, failedDAC, app.myPassport)) then
		origRelCarrier := null;
	endif;
	updCarrier := self.cmbCarrier.listObject &lt;&gt; origRelCarrier;
	origFForwarder := self.myCurrentObject.CM_TrackedItem.myFreightForwarder;	
	updFForwarder := self.cmbFreightFwdr.listObject &lt;&gt; origFForwarder;
	
	foreach ti in tiSet do
		if ffChanged and updFForwarder then
			ti.setFreightForwarder(tmpFreightForwarderCode);
		endif;
		if carrierRemarksChanged then
			ti.setCarrierRemarks(tmpCarrierRemarks);
		endif;
		if tblMain.hasRowChangedByName(ETRow_ReleaseCarrier, false) and updCarrier then
			ti.setReleaseCarrier(tmpCarrierCode);
		endif;
		if tblMain.hasRowChangedByName(ETRow_DeliveryReleaseNumber, false) then
			ti.setDeliveryRelease(tmpDelvRel);
		endif;
// cnwdad1 29/08/2008 - CCMS 1739.
		if tblMain.isRowVisible(ETRow_BookingReference) and 
		   tblMain.hasRowChangedByName(ETRow_BookingReference, false) then
			ti.setBookingReference(bookingRef);
		endif;
		
		//cnwrd1 6.11.08 CCMS JMT 1743/1764 
		// set operator release pin
		ti.setOperatorImportReleasePIN(operatorImpReleasePIN);
	//	ti.validateOpImpReleasePIN (operatorImpReleasePIN ) ;
		
		/*  WAS AKB2002JULY
		ti.setOperatorStop(tmpOperatorStop);
		NOW CCMS 1051 AKB2002JUNE */
		
		/* - refer comment (April 2008) above re Stops
		stopsArray.clear;
		ti.getStopsToBeProcessed(StopProcessOperatorRel, stopsArray);
		
		if tmpOperatorStop then
			app.myTrxCA.trxCreateStops(ti, stopsArray, true, app.myPassport);
		else
			app.myTrxDA.trxDeleteStops(ti, stopsArray, app.myPassport);
		endif;
		
		// CCMS 1051 AKB2002JUNE
		//aStop := self.myTerminal.getConfig(ConfigStopCustoms).CM_StopsTable;
		//ti.setStop(aStop ,tmpOperatorStop);
		*/
		
	endforeach;

	while true do
		app.myTrxUA.trxUpdateTrackedItems(tiSet, TI_UPDMODE_NORMAL, null, app.myPassport);
		if app.myPassport.trxCompletedOK then
			rtnValue := true;
			break;
		else
			result := app.showErrorWarningDialog('Releases', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		
		rtnValue := false;
		break;

	endwhile;
epilog
	if tiSet &lt;&gt; null then
		delete tiSet;
	endif;
	delete stopsArray;
	return rtnValue;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTblMainDblClick" id="97bc13c0-a86d-4a64-a240-322d76b56356">
        <updating/>
        <source>doTblMainDblClick(table: CM_EntryTable input) updating;
//----------------------------------------------------------------
//	Created:	01 March 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	carrier				: CM_Carrier;
	termEmailDefaults	: CM_PINObjectDefaultEmail;
	modalResult			: Integer;
	
begin
		if table.row &lt;&gt; table.getRowByName(ETRow_EmailOptions) then
			return;
		endif;

		carrier 	:= self.cmbCarrier.myObject.CM_Carrier;

//		if carrier = null and self.myTerminal.getConfig(DefaultCarrierEmail).Boolean then	// cnwrl1 30/07/2009 PAR 20349 - what it was
		if carrier = null and self.myTerminal.getEmailDefaultCarrier( PINEmail_CargoRelease ) then
			app.msgBox("You need to set the Carrier before modifying the email defaults.","E-mail Options",null);
			return;
		endif;
	
		if self.myEmailDefaults = null then
			//set from terminal for this type of object
//			termEmailDefaults := self.myTerminal.getCarrierEmailDefaultsForType(PINEmail_CargoRelease);	// cnwrl1 30/07/2009 PAR 20349 - what it was
			termEmailDefaults := self.myTerminal.getEmailDefaultsSettings( PINEmail_CargoRelease );
			self.myEmailDefaults := termEmailDefaults.cloneSelf(true).CM_PINObjectDefaultEmail;
		endif;

		if self.myEmailDefaults = null then
			app.raiseUnexpectedProgramError(class.name, method.name, 'email defaults proxy creation failed');
			return;
		endif;

//		self.myEmailDefaults.setAddresses(self.myTerminal, carrier, null);	// cnwrl1 30/07/2009 PAR 20349 - what it was
		self.myEmailDefaults.setAddresses( self.myTerminal, carrier, null, PINEmail_CargoRelease );
		//always reset these to the current carrier in case user changes carrier
		modalResult := self.myAssistant.showCarrierEmailOptions(carrier, self.myEmailDefaults, false, null);
 
end;</source>
        <Parameter name="table" type="CM_EntryTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doValidateOperReleasePin" id="96df7770-2feb-4dfd-a0ef-b12e9454ecb6">
        <source>doValidateOperReleasePin() : Boolean;

/*

Purpose:	Bit of a hack to do some validaiton on operator release pin numbers outside of the trx for normal updates		

Parameters:			

Return Value:		


Date		Who		Reason
13 January 2011	cnwrd1	Initial creation
ccms 2032
*/

vars
	operatorImpReleasePIN	: String;
	pxyTISet				: CM_TISet;
	pxyTi					: CM_TrackedItem;
begin

	operatorImpReleasePIN	:= self.tblMain.getValueByName(ETRow_OperatorImportReleasePIN).String;  
	
	
	create pxyTISet transient;
	self.allProxyObjects.copy(pxyTISet);

	self.clearErrorWarnings();
	
	//pxyTISet now has all selected ti proxies.
	
	foreach pxyTi in pxyTISet do
		pxyTi.validateOpImpReleasePIN(operatorImpReleasePIN);

	endforeach;

	if app.myPassport.hasErrors then
		app.showErrorWarningDialog(null, app.myPassport, ErrWarnMode_Add);
		return false;
	endif;

	return true;
	
epilog
	delete pxyTISet;
	app.myPassport.clearErrorsWarnings();
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getBOLsFromFilter" id="4f3598da-704f-4463-9632-e4af3aa97e51">
        <source>getBOLsFromFilter(_tiDict : CM_TIByIdCargoTypeDict input) ;
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 18 August 2008
//
// Implemented version:
// 
//----------------------------------------------------------------------
vars
	bolSet: CM_BOLSet;
	ti : CM_TrackedItem;
	bol : CM_BOL;
begin
	create bolSet transient;
	//Get all BOLs that match the number bol number entered in the filter.
	self.myTerminal.getBOLInsFromNumber(bolSet, BOLType_GeneralBillOfLading, self.filterBOL, true, null);
	
	//Add the tis to the dict.  We'll check if they're imports in the receiver.
	foreach bol in bolSet discreteLock do
		//There is a possibility at this stage we are looking at a many to many between BOLs and Tracked Items and we
		//only need to display each item once.
		foreach ti in bol.allTrackedItems where not _tiDict.includes(ti) do
			_tiDict.add(ti); 
		endforeach;
	endforeach;
	
epilog
	delete bolSet;
end;</source>
        <Parameter name="_tiDict" type="CM_TIByIdCargoTypeDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getExtraPermissions" id="1c4a9ec7-d659-4b03-aa96-65a4bb427e2d">
        <source>getExtraPermissions(permArray: IntegerArray input);
// ---------------------------------------------------------------------------
// Created:     27 June 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(permArray);

	permArray.add(PmGteFullReleaseMaint);
	permArray.add(PmGteFullReleaseCarrierMaint);
	permArray.add(PmGteFullReleaseForward);
	permArray.add(PmGteFullReleaseOperatorMaint);

end;</source>
        <Parameter name="permArray" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="handleTblDataDblClick" id="056bb947-ed8f-4d81-8ab6-46a9651f9a1c">
        <updating/>
        <source>handleTblDataDblClick(_row: Integer) updating;
//--------------------------------------------------
// Created:	07 July 2004 By: cnwgd1
//--------------------------------------------------
vars
	theTI	: CM_TrackedItem;
	failedDAC	: CM_DataAccessController;
begin
	
	theTI := tblData.accessRow(_row).itemObject.CM_TrackedItem;
	if theTI &lt;&gt; null then
		// want to open cargo edit with this object
		if theTI.canUserAccessSelf(null, failedDAC, app.myPassport) then
			self.myAssistant.showCargoEnquiryForm(theTI, self.myMasterMenuAction, true, false);
		else
			// PAR 16522
			app.msgBox('Warning, you do not have security access to view ' &amp; theTI.cargoTypeDescr &amp; ' ' &amp;
						theTI.id &amp; '. Please check the number and try again.', 'Warning', MsgBox_OK_Only);
			//app.raiseCMException1(Full_Replacement_Message, 
			//		'You are not authorised to view the full details for this container', null, null);
		endif;
	endif;

end;</source>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="includeObject" id="d9c628a4-9afd-4513-9de1-64bd63ea3ed8">
        <updating/>
        <source>includeObject(_ti : CM_TrackedItem; _passport : CM_Passport): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     22 October 2003 by cnwrs2
//
// Changes: 	PAR 22119 - change to exclude tranship items
//						  - removed global.isValidObject at same time    
// ---------------------------------------------------------------------------
vars
	failedDAC	: CM_DataAccessController;
	invalidTI : Boolean; 

begin

	//if global.isValidObject(_obj) then		//PAR #4104 JC 18/11/2002
	//	if _obj.isKindOf(CM_TrackedItem) then
	//		ti := _obj.CM_TrackedItem;
	//	endif;
	//endif;
	
	on Exception do app.handleDeletedObject(exception, _ti, invalidTI); 
	
	if _ti = null then
		return false;
	endif;
	
	if self.filterIncludeOnShip then
		//22 July 2014	NDl	Par 34036
		if ( _ti.site &lt;&gt; TI_SITE_ONSITE and  _ti.site &lt;&gt; TI_SITE_ONSHIP ) or
		   _ti.isTranshipItem or			
		   _ti.isChild then	
			return false;
		endif;
	
	else
		if _ti.site &lt;&gt; TI_SITE_ONSITE or
		   _ti.isTranshipItem or			// PAR 22119 - added
		   _ti.isChild then					// moved up from lower down
			return false;
		endif;
	endif;

	if invalidTI then 
		return false; 
	endif; 

	if (not _ti.canUserViewMe(null, _passport, true, true, true, false, true, failedDAC)) then
		return false;
	endif;

	if not _ti.isImport then
		return false;
	endif;
	

	// this is done above in canUserViewMe
	//if (not ti.canUserAccessSelf(null, failedDAC, _passport)) then
	//	return false;
	//endif;

	if (self.filterId &lt;&gt; null and not _ti.id.startsWith(filterId)) or
	   (self.filterCarrierCode &lt;&gt; null and _ti.releaseCarrier.trimRight &lt;&gt; self.filterCarrierCode) or
	   (self.filterConsigneeCode &lt;&gt; null and _ti.consignee.trimRight &lt;&gt; self.filterConsigneeCode) or
	   (self.filterOperatorCode &lt;&gt; null and _ti.operatorCode.trimRight &lt;&gt; self.filterOperatorCode) or
	   (self.filterCargoType &lt;&gt; TI_CargoType_Null and _ti.cargoType &lt;&gt; self.filterCargoType) or
	   (self.filterVoyageCode &lt;&gt; null and _ti.voyageCode.trimRight &lt;&gt; self.filterVoyageCode) or 
	   (self.filterBOL &lt;&gt; null and not _ti.getReceivalBOLNumber.startsWith(self.filterBOL)) then
	   	return false;
	endif;

	
	if _ti.isChild then
		return null;
	endif;
	
	return true;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initDataTable" id="d9b6f253-bea5-424c-83e2-fe0892708d24">
