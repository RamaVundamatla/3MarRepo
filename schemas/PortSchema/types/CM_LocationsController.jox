// 03/03/2011	cnwcs5	CCMS 2027/PAR 27126 - audit location changes
vars

begin
	// add in auditing of container lengths
	self.createTALocationsAudits_Length (_pxyLC, _ta);
	
	self.ignoreArchiving	:= _pxyLC.ignoreArchiving;
	self.offset45		:= _pxyLC.offset45;
