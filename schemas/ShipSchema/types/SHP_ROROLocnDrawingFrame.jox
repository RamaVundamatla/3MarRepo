    <JadeMethod name="setSelectedSlot" id="d5960a24-d2cd-4a12-aac5-68fb8009b2a7">
        <updating/>
        <source>setSelectedSlot(_obj: Object; shift: Integer) updating;
/*
Date		    Who			Reason
27 July 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars
	is40, switchToFwd : Boolean;
	theObject : Object;
	theReq : CM_RORORequest;
	theSlot : CM_ROROSlotController;
	theTI : CM_TrackedItem;
	
	//cnwmc5 - PAR 31651
	chkDischReq : Boolean;
	tis : CM_TIArray;
begin
	theObject := _obj;
	
	// PAR 28939 when clicking on the aft of a 40 foot switch to the forward
	if theObject.isKindOf(CM_ROROSlotController) then
		theSlot := theObject.CM_ROROSlotController;
		
		if self.myROROLocnDrawingController.modeView = ShpDisplayMode_Actual then
			if theSlot.hasTIsOfMode40(REAL_MODE,false) then
				theObject := theSlot.getFwdLC();
			endif;
		elseif self.myROROLocnDrawingController.modeView = ShpDisplayMode_Proposed then
			/*
			****************************
				cnwmc5 - PAR 31651
			****************************
			*/
			create tis transient;
			
			theSlot.getProposedTIs(tis);
			if not tis.isEmpty then
				theReq := theSlot.myRORORequestLoad;
				theTI := tis.first;
				if theReq &lt;&gt; null
				and (theTI.isPlannedToShip() or theReq.isComplete) then
					if not theTI.is20
					and theReq.getAttrIsBackend() then
						theObject := theSlot.getFwdLC();
					endif;
				else
					if not theTI.is20
					and theSlot.isBackEnd(theTI, REAL_MODE) then
						theObject := theSlot.getFwdLC();
					endif;
				endif;
			endif;
			
			
			/*if theSlot.hasTIsOfMode40(REAL_MODE,false) then
				if theSlot.myRORORequestDischarge = null then // no discharge CC so draw a 40'
					theObject := theSlot.getFwdLC();
				elseif theSlot.myRORORequestLoad &lt;&gt; null then // has load CC so draw a 40'
//					if theSlot.myRORORequestLoad.getAttrIs40() then
					theReq := theSlot.myRORORequestLoad;
	//				is40 := (theReq.getAttrIs40() or theReq.getAttrIs30() or theReq.getAttrIs45() or theReq.getAttrIs53()); // PAR 30022 
					is40 := theReq.getAttrIsNOT20(); // PAR 30253
					if is40 then // PAR 30022 

						theObject := theSlot.getFwdLC();
					endif;
				endif;
			else
				if theSlot.hasTIsOfMode40(PLANNING_MODE,false) then // maybe some load planning
					theObject := theSlot.getFwdLC();
				endif;
			endif;*/
		/*
		****************************
			cnwmc5 - PAR 31651
		****************************
		*/
		elseif self.myROROLocnDrawingController.modeView = ShpDisplayMode_ColCodeLoad then
			theReq := theSlot.myRORORequestLoad;
			if theReq &lt;&gt; null then
				is40 := theReq.getAttrIsNOT20();
				if is40 and theReq.getAttrIsBackend() then
					theObject := theSlot.getFwdLC();
				endif;
			endif;
		elseif self.myROROLocnDrawingController.modeView = ShpDisplayMode_ColCodeDisch then
			if self.myROROLocnDrawingController.modeViewSubSub = ShpDisplayModeSub_ExportsShow then
				theReq := theSlot.myRORORequestLoad;
				if theReq &lt;&gt; null then
					chkDischReq := false;
					is40 := theReq.getAttrIsNOT20();
					if is40 and theReq.getAttrIsBackend() then
						theReq := theReq.getFwdSlotReq().CM_RORORequest;
						if theReq.isComplete then
							theObject := theSlot.getFwdLC();
						else
							chkDischReq := true;
						endif;
					else 
						chkDischReq := true;
					endif;
				endif;
				
				if theReq = null or chkDischReq then
					theReq := theSlot.myRORORequestDischarge;
					if theReq &lt;&gt; null then
						is40 := theReq.getAttrIsNOT20();
						if is40 and theReq.getAttrIsBackend() then
							switchToFwd := true;
							
							if theSlot.getFwdLC().myRORORequestLoad &lt;&gt; null 
							and theSlot.getFwdLC().myRORORequestLoad.isComplete then
								if not theSlot.getFwdLC().myRORORequestLoad.getAttrIsNOT20() then
									switchToFwd := false;
								endif;
							else
								theTI := theReq.getTrackedItem();
								if theTI &lt;&gt; null and theTI.hasBeenLoadedToShip then
									switchToFwd := false;
								endif;
							endif;
							
							if switchToFwd then
								theObject := theSlot.getFwdLC();
							endif;
						endif;
					else
						if theSlot.hasTIsOfMode40(REAL_MODE,false) then
							theObject := theSlot.getFwdLC();
						endif;
					endif;
				endif;
			elseif self.myROROLocnDrawingController.modeViewSubSub = ShpDisplayModeSub_ExportsHide then
				theReq := theSlot.myRORORequestDischarge;
				if theReq &lt;&gt; null then
					is40 := theReq.getAttrIsNOT20();
					if is40 and theReq.getAttrIsBackend() then
						theObject := theSlot.getFwdLC();
					endif;
				else
					if theSlot.hasTIsOfMode40(REAL_MODE,false) then
						theObject := theSlot.getFwdLC();
					endif;
				endif;
			endif;
		endif;
		/*else
			if self.myROROLocnDrawingController.modeView = ShpDisplayMode_ColCodeLoad then
				theReq := theSlot.myRORORequestLoad;
			elseif	 self.myROROLocnDrawingController.modeView = ShpDisplayMode_ColCodeDisch then
				theReq := theSlot.myRORORequestDischarge;
			endif;
			if theReq &lt;&gt; null then
//				is40 := (theReq.getAttrIs40() or theReq.getAttrIs30() or theReq.getAttrIs45() or theReq.getAttrIs53()); // PAR 30022 
				is40 := theReq.getAttrIsNOT20(); // PAR 30253
				if is40  // PAR 30022 
	//			if theReq.getAttrIs40() 
				and theReq.getAttrIsBackend() then
					// PAR 31073
					switchToFwd := true;
					if self.myROROLocnDrawingController.modeView = ShpDisplayMode_ColCodeDisch and self.myROROLocnDrawingController.modeViewSubSub = ShpDisplayModeSub_ExportsShow then 
						theTI := theReq.getTrackedItem();
						if theTI &lt;&gt; null and theTI.hasBeenLoadedToShip then		//cnwmc5 - 1 August 2013 - PAR 31651
							switchToFwd := false;
						endif;
					endif;
				
				
				
					if switchToFwd then
						theObject := theSlot.getFwdLC();
					endif;
				endif;
			elseif self.myROROLocnDrawingController.modeView = ShpDisplayMode_ColCodeDisch then // PAR 29052
				switchToFwd := false;
				if theSlot.hasTIsOfMode40(REAL_MODE,false) then
					switchToFwd := true;
				endif;
				
				if self.myROROLocnDrawingController.modeViewSubSub = ShpDisplayModeSub_ExportsHide then 
					theTI := theSlot.allTrackedItems.first();
					if theTI &lt;&gt; null and (theTI.isExport or theTI.isRehandle or theTI.isSOB) then
						switchToFwd := false;
					endif;
				endif;
				
				if switchToFwd then
						theObject := theSlot.getFwdLC();
				endif;
			endif;
		endif;*/
	endif;

	self.myCargoSideViewForm.handleSlotsMouseUpEvent(theObject, shift);
epilog
	//cnwmc5 - PAR 31651
	delete tis;
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="b21ab4e9-b496-46e4-9b72-5655d08b04c4">
        <controlMethod name="CMUI_GridAreaDrawingFrame::windowCreated"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>windowCreated(cntrl: SHP_ROROLocnDrawingFrame input; persistCntrl: Control) updating, clientExecution;
/*
Date		    Who			Reason
12 July 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars

begin
	
	//cntrl.autoRedraw := true;

	inheritMethod(cntrl, persistCntrl);
	
	if (self.isInPainter) then
		return;
	endif;	
	
	if self.parent.isA(SHP_CargoSideViewForm) then
		self.myCargoSideViewForm := self.parent.SHP_CargoSideViewForm;
	endif;
	
	//self.createScrollFrame();
	cntrl.createScrollableFrame();
	cntrl.createScrollingFrame();
	
	self.myScrollableFrame.setScrollingFrame(myScrollingFrame);
	
	//self.myScrollingFrame.alignContainer := Frame.AlignContainer_All;
	
	self.myScrollableFrame.hideHLabels();
	self.myScrollableFrame.hideVLabels();
	
	//self.myScrollableFrame.changeBackColor(White);
	//self.myScrollingFrame.backColor:=White;
	
	self.minDrawingHeight := 0;
	self.minDrawingWidth := 0;

epilog

end;</source>
