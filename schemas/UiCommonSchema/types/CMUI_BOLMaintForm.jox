    <JadeMethod name="saveBOLDetails" id="d9f20b9f-b92c-4c34-aec8-e2bb2df42015">
        <source>saveBOLDetails();
//18 January 2010	cnwml2
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------------------
// 27/11/2013	cnwdap1		PAR #33019 CCMS DPH 2285 new BOL Fields
//19/07/2022    navgm20     ChangeRequest 54095: EUP - Outturn Remarks on BOL
vars
	bolNumber : String;
	voyage : CM_Voyage;
	operator : CM_Operator;
	notifyParty : String;
	
	numItems : Integer;
	bolType : Integer;
	terminal : CM_Terminal;
	subTerminal : CM_SubTerminal;
	destination : String;
	dischargePort : String;
	loadPort : String;
	serviceOrder : String;									// PAR # 33019
	pONbr : String;											// PAR # 33019
	gdate : Date; // TFS 4272
	outturnRemarks : String; //19/07/2022 navgm20 54095
	row : Integer; //19/07/2022 navgm20 54095
begin
	bolNumber := self.txtBOL.text;
	if self.cmbVoyage.listObject &lt;&gt; null then
		voyage := self.cmbVoyage.listObject.CM_Voyage;
	endif;
	
	if self.cmbOperator.listObject &lt;&gt; null then
		operator := self.cmbOperator.listObject.CM_Operator;
	endif;
	
	if self.cmbDestination.listObject &lt;&gt; null then
		destination := self.cmbDestination.listObject.CM_Port.code;
	endif;
	
	if self.cmbDischargePort.listObject &lt;&gt; null then
		dischargePort := self.cmbDischargePort.listObject.CM_Port.code;
	endif;
	
	if self.cmbLoadPort.listObject &lt;&gt; null then
		loadPort := self.cmbLoadPort.listObject.CM_Port.code;
	endif;
	
	
	if self.cmbNofiyParty.listObject &lt;&gt; null then
		notifyParty := self.cmbNofiyParty.listObject.CM_ConsigneeConsignor.code;
	endif;
	
	numItems := self.myProxyBOL.allBOLDtls.size;
	bolType := app.bolTypeToEnum(self.myBOLType);
	terminal := self.myTerminal;
	subTerminal := self.myTerminal.getConfig(MySubTerminalForBOLIn).CM_SubTerminal;
	
	serviceOrder := self.txtServiceOrder.text.trimBlanks;								// PAR #33019
	pONbr := self.txtPONbr.text.trimBlanks;												// PAR #33019
	
	gdate := self.dateGenLanding.getDate(); // TFS 4272
	
	//19/07/2022 navgm20 54095 - start
	foreach row in self.tblOutturn.fixedRows + 1 to self.tblOutturn.rows do
	if self.tblOutturn.accessCell(row, 1).text &lt;&gt; null then
		if outturnRemarks &lt;&gt; null then
			outturnRemarks := outturnRemarks &amp; "^";
		endif;
			outturnRemarks := outturnRemarks &amp; self.tblOutturn.accessCell(row, 1).text;
	endif;
	endforeach;
	//19/07/2022 navgm20 54095 - end
	
	//self.myProxyBOL.setProxy(bolNumber, voyage, operator, notifyParty, numItems, bolType, terminal, subTerminal, destination, dischargePort, loadPort, self.chkDirDel.value);	// PAR #33019
	self.myProxyBOL.setProxy(	bolNumber, 
								voyage, 
								operator, 
								notifyParty, 
								numItems, 
								bolType, 
								terminal, 
								subTerminal, 
								destination, 
								dischargePort, 
								loadPort, 
								self.chkDirDel.value,
								serviceOrder,
								pONbr,
								outturnRemarks,	//19/07/2022 navgm20 Tfs 54095
								gdate	);
	
epilog

end;</source>
    </JadeMethod>
