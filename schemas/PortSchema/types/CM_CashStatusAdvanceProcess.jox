<Class name="CM_CashStatusAdvanceProcess" id="6941af03-5f1f-4d12-8775-ca09eb11785c">
    <superclass name="CM_OfflineFutureActor"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="backgroundprocess"/>
    <ImplicitInverseRef name="myCashReceipt" id="9d4c1b02-1c7e-4fd3-96cd-cd2d67e0e304">
        <embedded/>
        <type name="CM_CashReceipt"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="doAction" id="e5af9483-765c-4601-9d45-a5fa2789e961">
        <updating/>
        <source>doAction(): Boolean updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 10/09/2018	jlgdap1		Initial creation TFS 40202 PEL1 Estimation SAP Integration
//
vars

	invalid : Boolean;	//11 Feb 2019	NDL	TFS 43318
	voyage : CM_Voyage;
	voyageProcess  : CM_VoyageProcess;
	isWorkOrder	: Boolean;
begin
	if self.myCashReceipt = null then
		return true;
	endif;
	
	if not app.isValidObject(self.myCashReceipt) then  //28.01.2019 cnwma1  #40202 
		delete self;
		return true;
	endif;
	
	//11/07/2024	navkc1 CR 64837 Task 64851
	voyage := self.myCashReceipt.getMyVoyage();
	
	if voyage &lt;&gt; null then
		voyageProcess := voyage.myVoyageProcess;
		if voyageProcess &lt;&gt; null then
			isWorkOrder := voyageProcess.isMTNWOProcess();
		endif;
	endif;
	
	//11/07/2024	navkc1 CR 64837 Task 64851
	if isWorkOrder then 
		if self.myCashReceipt.myWorkOrder = null then
			delete self;
			return true;
		endif;
		if not self.getAndLockValidObject(self.myCashReceipt, Share_Lock, invalid) then
			return true;
		endif;
		
		//11 Feb 2019	NDL	TFS 43295
		if self.myCashReceipt.myWorkOrder.taskStatus = WO_STATUS_APPROVED then
			delete self;
			return true;
		endif;
		
		self.myCashReceipt.myWorkOrder.setTaskStatus(WO_STATUS_APPROVED);
		return true;
	else
		//11/07/2024	navkc1 CR 64837 Task 64851 - Times up and user hasn't make payment for this receipt, delete it. User has to request again
		// This Cash Receipt should only have a temp seqNumber (oid)
		if self.myCashReceipt.paymentStatus = CM_CashReceipt.API_RECEIPT_DRAFT then
			app.myUtilityDA.utlDeleteCashReceipt(self.myCashReceipt);
			if app.myPassport.noErrors() then
				//delete self;
				return true;
			endif;
		endif;
	endif;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
