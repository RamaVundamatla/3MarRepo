    <JadeMethod name="displayForXlation" id="7376dc50-ed99-4d61-b540-0099970cd72c">
        <source>displayForXlation(_codeFirst : Boolean) : String;

vars

begin
	if _codeFirst then
		return self.code.trimBlanks&amp;' ['&amp;self.name.trimBlanks&amp;']';
	else
		return self.name.trimBlanks&amp;' ['&amp;self.code.trimBlanks&amp;']';
	endif;
end;
</source>
        <Parameter name="_codeFirst" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="erase" id="791f4303-7785-421f-88ad-b13e54d238f9">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
/*
Date		Who		Reason
25 March 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
*/
vars

begin
	self.exclusiveLock(self);

	self.eraseXlations (self.allXlations, NORMAL_ERASE);
	
	inheritMethod(_eraseLevel);

epilog

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="c81f6e90-3b0c-49f6-b6e6-54d182e10c50">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:		22 February 2006  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	
	if _attrName = ETRow_MyDebtor then
		if self.myDebtor &lt;&gt; null then
			return self.myDebtor.getListName(); // so default debtor is not 'RDG'
		else
			return null;
		endif;
	elseif _attrName = ETRow_FinancialId then	//04.Mar.24 navsp1 TFS 57177
		if self.myDebtor &lt;&gt; null then
			return self.myDebtor.code;
		endif;
		return null;
	endif;
	
	return inheritMethod(_attrName, _short);

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="hasBadCredit" id="15c3d081-073e-4ab5-9449-a5a7db52892b">
        <source>hasBadCredit() : Boolean;
// ---------------------------------------------------------------------------
// Created:		27 October 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if self.myDebtor = null then
		return false;
	endif;
	return self.myDebtor.hasBadCredit();
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="9fc5814f-13ef-43fd-8130-46a816432037">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:		February 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	proxyCustomsAgent	: CM_CustomsAgent;
	completedOK		: Boolean;	
begin
	
	proxyCustomsAgent := inheritMethod();
	proxyCustomsAgent.myDebtor := self.myDebtor;
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyCustomsAgent;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyCustomsAgent;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
