    <JadeMethod name="testSameAsByEntTable" id="1e03ee9e-3c0e-4a63-84df-e26cd2899565">
        <source>testSameAsByEntTable( _primaryObject : Object; _allTestObjects : ObjectArray; _theEntTable : EntTableDef; _etDefString : String; _compareID : Boolean; _msgValue : String output): Boolean;

/*

Purpose:	By using an ent table and get displaystringfor attribute we can compare if a set of fields for a listof objects are the same. 
			This should allow us to compare 2 or more items for the same form and determine if the are funtionally equal.

			If the class doesnt have a getdisplaystringforattribute that covers some of the entdef columns it wil throw an error dialog you need to stop this in CM_Object handleUnknownPropertyValue
Parameters:			

Return Value:		


Date		Who		Reason
23 December 2013	cnwrd1	Initial creation

*/

vars
	aEntTable : EntTableDef;
	entRow : EntTableRow;
	thing : Object;
	firstObject : CM_Object;
	value1, value2 : String;
begin

	if _allTestObjects = null then
		return false;
	endif;
	
	if _allTestObjects.size = 1 then
		return true;
	endif;
	
	if _theEntTable = null and _etDefString = null then 
		return false;
	endif;
	
	if _theEntTable = null then 		
		aEntTable := app.myRoot.myEntTableDataRoot.allEntTableDefs[_etDefString];
	
	
		
		if aEntTable = null then
			return false;
		endif;
	else
		aEntTable := _theEntTable;
	endif;
	
		
	if _primaryObject = null then
		firstObject := _allTestObjects.first.CM_Object;
	elseif _primaryObject.isKindOf(CM_Object) then
		firstObject := _primaryObject.CM_Object;
	else	
		return false;
	endif;
	
	foreach thing in _allTestObjects do	
	
		if thing = firstObject then // no point testing ourselves.
			continue;
		endif;
		
		
		if not thing.isKindOf(firstObject.class) then //should be the same class
			_msgValue := app.getErrorString(CM_Type);
			return false;
		endif;
		
		foreach entRow in aEntTable.allEntTableRows do
		
			if entRow.isGroupRow then
				continue;
			endif;
		
			if not _compareID and entRow.name = 'ID' or entRow.name = 'cargoId' then
				continue;
			endif;
			
			value1 := thing.CM_Object.getDisplayStringForAttribute(entRow.name, false);
			value2 := firstObject.getDisplayStringForAttribute(entRow.name, false);
			
			
			if value1 &lt;&gt; value2 then
				_msgValue := entRow.getHeading(null, null, app.myCurrentLocale);
				
				return false;
			endif;
		
		endforeach;
	endforeach;
	
	return true;
epilog

end;</source>
        <Parameter name="_primaryObject" type="Object"/>
        <Parameter name="_allTestObjects" type="ObjectArray"/>
        <Parameter name="_theEntTable" type="EntTableDef"/>
        <Parameter name="_etDefString" type="String"/>
        <Parameter name="_compareID" type="Boolean"/>
        <Parameter name="_msgValue" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tidalDataMultiplierForType" id="891874f5-426e-4ecd-9028-14766298877a">
        <source>tidalDataMultiplierForType(_valueType : String) : Real;
/*
----------   ----------  --------------------------------------------------
Created:	17 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if _valueType = HMS_TidalModelDefinition.VALUE_TYPE_MM then
		return HMS_TidalModelDefinition.VALUE_MULTIPLIER_MM;
	elseif _valueType = HMS_TidalModelDefinition.VALUE_TYPE_CM then
		return HMS_TidalModelDefinition.VALUE_MULTIPLIER_CM;
	elseif _valueType = HMS_TidalModelDefinition.VALUE_TYPE_METERS then
		return HMS_TidalModelDefinition.VALUE_MULTIPLIER_METERS;
	elseif _valueType = HMS_TidalModelDefinition.VALUE_TYPE_FEET then
		return HMS_TidalModelDefinition.VALUE_MULTIPLIER_FEET;
	elseif _valueType = HMS_TidalModelDefinition.VALUE_TYPE_INCHES then
		return HMS_TidalModelDefinition.VALUE_MULTIPLIER_INCHES;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Unhandled value type');
	endif;
	

end;


</source>
        <Parameter name="_valueType" type="String"/>
        <ReturnType type="Real"/>
    </JadeMethod>
