    <JadeMethod name="setForCreateImport" id="83d96cd3-1cdc-4c4f-946a-1e26c110c7fc">
        <updating/>
        <source>setForCreateImport(_proxyDeck : CM_Deck input;
					_passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:		_proxy has everthing linked to it i.e. layout items aswell	




Date		Who		Reason
06 April 2011	cnwer1	Initial creation

*/

vars
	realDeckLayout 				: CM_DeckLayout;
	realRamp, pxyRamp 			: CM_RORORampInternal;
	realLift, pxyLift 			: CM_ROROLift;
	realMachinery, pxyMachinery : CM_ROROEquipment;
	realGenItems, pxyGenItems	: CM_ROROGeneralArea;
begin
	self.code:=_proxyDeck.code;
	self.description:=_proxyDeck.description;
	self.heightFromBL:=_proxyDeck.heightFromBL;
	self.maxClearHeight:=_proxyDeck.maxClearHeight;
	self.maxLoadAxel:=_proxyDeck.maxLoadAxel;
	self.maxLoadM2:=_proxyDeck.maxLoadM2;
	self.maxLoadStack20:=_proxyDeck.maxLoadStack20;
	self.maxLoadStack40:=_proxyDeck.maxLoadStack40;
	self.numTier:=_proxyDeck.numTier;
	self.remarks:=_proxyDeck.remarks;
	self.totalArea:=_proxyDeck.totalArea;
	self.totalLM:=_proxyDeck.totalLM;
	self.totalTEU:=_proxyDeck.totalTEU;
	self.totalVolume:=_proxyDeck.totalVolume;
	self.heightFromBL:=_proxyDeck.heightFromBL;
	
	
	// update the deck layout items;
	if _proxyDeck.myDeckLayout &lt;&gt; null then
		create realDeckLayout persistent;
		realDeckLayout.setMyDeck(self);	
		realDeckLayout.setForCreateImport(_proxyDeck.myDeckLayout,_passport);
		
	endif;
		
	if _proxyDeck.allRamps &lt;&gt; null then
		foreach pxyRamp in _proxyDeck.allRamps do
			realRamp:=self.allRamps[pxyRamp.code];
			if realRamp &lt;&gt; null then
				continue;
			endif;
			create realRamp persistent;
			realRamp.setForCreateImport(pxyRamp,_passport);
			realRamp.setMyDeck(self);
		endforeach;
	endif;
	
	if _proxyDeck.allLifts &lt;&gt; null then
		foreach pxyLift in _proxyDeck.allLifts do
			realLift:=self.allLifts[pxyLift.code];
			if realLift &lt;&gt; null then
				continue;
			endif;
			create realLift persistent;
			realLift.setForCreateImport(pxyLift,_passport);
			realLift.setMyDeck(self);
		endforeach;
	endif;
	
	if _proxyDeck.allMachinery &lt;&gt; null then
		foreach pxyMachinery in _proxyDeck.allMachinery do
			realMachinery:=self.allMachinery[pxyMachinery.code];
			if realMachinery &lt;&gt; null then
				continue;
			endif;
			create realMachinery persistent;
			realMachinery.setForCreateImport(pxyMachinery,_passport);
			realMachinery.setMyDeck(self);
		endforeach;
	endif;
	
	if _proxyDeck.allGeneralItems &lt;&gt; null then
		foreach pxyGenItems in _proxyDeck.allGeneralItems do
			realGenItems:=self.allGeneralItems[pxyGenItems.code];
			if realGenItems &lt;&gt; null then
				continue;
			endif;
			create realGenItems persistent;
			realGenItems.setForCreateImport(pxyGenItems,_passport);
			realGenItems.setMyDeck(self);
		endforeach;
	endif;
	
	
	
	
	
epilog

end;</source>
        <Parameter name="_proxyDeck" type="CM_Deck" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="c842239a-4bd2-46ec-aa9a-88b6aeb16cfb">
        <updating/>
        <source>setForUpdate(_proxyDeck : CM_Deck input; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 March 2011	cnwer1	Initial creation

*/

vars
	
begin
	
	self.code:=_proxyDeck.code;
	self.description:=_proxyDeck.description;
	self.heightFromBL:=_proxyDeck.heightFromBL;
	self.maxClearHeight:=_proxyDeck.maxClearHeight;
	self.maxLoadAxel:=_proxyDeck.maxLoadAxel;
	self.maxLoadM2:=_proxyDeck.maxLoadM2;
	self.maxLoadStack20:=_proxyDeck.maxLoadStack20;
	self.maxLoadStack40:=_proxyDeck.maxLoadStack40;
	self.numTier:=_proxyDeck.numTier;
	self.remarks:=_proxyDeck.remarks;
	self.totalArea:=_proxyDeck.totalArea;
	self.totalLM:=_proxyDeck.totalLM;
	self.totalTEU:=_proxyDeck.totalTEU;
	self.totalVolume:=_proxyDeck.totalVolume;
	self.heightFromBL:=_proxyDeck.heightFromBL;
	self.deckImage:=_proxyDeck.deckImage;

	self.setForUpdateLayers(_proxyDeck ,_passport);
epilog

end;</source>
