    <JadeMethod name="getNumColumns" id="f710989c-80f7-4a0d-b582-c2568d942995">
        <source>getNumColumns(): Integer;
// ---------------------------------------------------------------------------
// Created:	18 February 2010 By Graeme Black cnwgb1
// Status: 	
// Purpose:	cnwgb1 PAR 22022 Messina CCMS 1069 CR 06
// ---------------------------------------------------------------------------
vars
	propColl: PropertyNDict;
begin
	propColl := CM_EDIToDoTaskTI.getProperties;

	return propColl.size + inheritMethod();
end;
</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTIProperties" id="aae1864f-66d0-457d-b16b-9e74b985f73e">
        <source>getTIProperties(_propArray: ObjectArray io);
// ---------------------------------------------------------------------------
// Created:	18 February 2010 By Graeme Black cnwgb1
// Status: 	
// Purpose:	PAR 22022 Messina CCMS 1069 CR 06
// ---------------------------------------------------------------------------
vars
	allPropsObj	: PropertyNDict;
	propertyObj	: Property;
	
begin
	inheritMethod(_propArray);
	allPropsObj	:=	CM_EDIToDoTaskTI.getProperties();
	
	foreach propertyObj in allPropsObj do
		_propArray.add(propertyObj);
	endforeach;
end;</source>
        <Parameter name="_propArray" type="ObjectArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="loadDB" id="25f5dd65-3253-44bf-bab7-8470bf95dbe2">
        <updating/>
        <source>loadDB(_mergeCargo: Boolean; _passport: CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:	18 February 2010 By Graeme Black cnwgb1
// Purpose:	cnwgb1 PAR 22022 Messina CCMS 1969 CR 06
// ---------------------------------------------------------------------------
vars
	cmifList : DynaDictionary;
begin
	// Arm our base exception handlers
	
	on Exception do validationExceptionHandler( exception, _passport );
	app.setContinueCMExceptions( false );
	
	create cmifList transient;
	self.constructCMIFDictDefinition( cmifList );
	self.constructCMIFs( cmifList );

	
	if _passport.hasErrors then 
		return;
	endif;
	
	app.myTrxUA.trxProcessEDIToDoTasks(cmifList, false, self, _passport);
	
epilog
	cmifList.purge();
	delete cmifList;
end;</source>
        <Parameter name="_mergeCargo" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="verifyEDIData" id="386c91e5-2be6-426d-bebb-71954d8c22b5">
        <updating/>
        <source>verifyEDIData(): Integer updating;
// ---------------------------------------------------------------------------
// Created:	18 February 2010 By Graeme Black cnwgb1
// Purpose:	Nothing to verify cnwgb1 PAR 22022 Messina CCMS 1069 CR 06
// ---------------------------------------------------------------------------
vars
begin
	return 0;
epilog
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="verifyEDIDataTIs" id="215b2bfb-d75b-4bf9-a27d-4e8fbfcd22f1">
        <updating/>
        <source>verifyEDIDataTIs(_passport: CM_Passport input): Integer updating;
// ---------------------------------------------------------------------------
// Created:	18 February 2010 By Graeme Black cnwgb1 PAR 22022 MSL CCMS 1069
// Purpose:	Returns a full list of errors, does not update db
// ---------------------------------------------------------------------------
vars
	cmifList : DynaDictionary;
begin
	// Arm our base exception handlers
	
	on Exception do validationExceptionHandler( exception, _passport );
	app.setContinueCMExceptions( false );
	
	create cmifList transient;
	self.constructCMIFDictDefinition( cmifList );
	self.constructCMIFs( cmifList );

	
	if not _passport.hasErrors then 
		app.myTrxUA.trxProcessEDIToDoTasks(cmifList, true, self, _passport);
	endif;
	
	return _passport.allErrors.size;
	
epilog
	cmifList.purge();
	delete cmifList;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
