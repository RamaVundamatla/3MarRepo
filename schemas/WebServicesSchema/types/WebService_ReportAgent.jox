    <JadeMethod name="getSelectedRowFumigate" id="50b8b626-dd38-48f6-b839-cb30c72d10a2">
        <source>getSelectedRowFumigate(): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 March 2018	jlger1	Initial creation

*/

vars
	tmpStr		: String;
	reportParam	: WS_ReportParameter;	
begin
	reportParam := self.allWSReportParams.getAtKey(ETRow_IsLocationFumigated);
	if reportParam &lt;&gt; null then
		tmpStr := reportParam.value;
	endif;	

	if tmpStr = app.getErrorString(Fumigated) then
		return LOG_ROW_FUMIGATED;
	elseif tmpStr = app.getErrorString(NotFumigated) then
		return LOG_ROW_NOTFUMIGATED;
	endif;
	
	return 0;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
