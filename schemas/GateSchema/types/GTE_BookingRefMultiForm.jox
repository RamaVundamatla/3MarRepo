	/* //05 Nov 2012	NDL	Par 29859
	if rowName = ETRow_MultiItem then
		blnMulti := assistant.mainExtraGetValue(tblMain, tblExtra, ETRow_MultiItem).Boolean;
		if blnMulti then
			if myCurrentBRItemInterface &lt;&gt; null then
				setBRItemInterfaceFromTable(self.myCurrentBRItemInterface); // save 'extra' table details to the transient
			endif;
			loadBookRefItems(null, true, false);  // load transient items to the 'text' table
			myCurrentBRItemInterface := null;
			tblExtra.clearValues;
		else
			if myInterfaceBookingRef.allCMIF_BRItems.size = 0 then 		// dh 27/3/2008 par 16306
				myInterfaceBookingRef.createInterfaceItem(null, null);	// dh
			endif;														// dh
			loadTableFromBRItem(myInterfaceBookingRef.allCMIF_BRItems.first);  // loads the extra table
		endif;
		setControlsForMultiEdit(tblMain.getValue(tmpRow).Boolean);
	endif;
	*/

end;</source>
