    <JadeMethod name="createActivityForReqDelete" id="8419c71b-4692-46e5-b30e-dba91085bb2e">
        <source>createActivityForReqDelete(_request : BGP_Request);
// -------------------------------------------
// Created 28 February 2005 by cnwdvb1
// -------------------------------------------
vars

	display,
	userCode	: String;
	type		: Integer;
begin
	
	userCode	:= app.getMyUserCode();
	display		:= _request.class.text.cnEcGetTagValueOfName('display');
	
	if BGP_DatabasePurgeRequest.hasInstance(_request) then
		type := ActivityHistoryDBPurge;
	else
		type := ActivityHistoryGeneral;
	endif;
	
	//app.createActivityHistory(ActivityHistoryGeneral, null, _request, 'Delete ' &amp; display &amp; ' request by user ' &amp; userCode, true, false);
	//	30 Sep 2008	cnwdz2	Par16937	
	//app.createActivityHistory(ActivityHistoryDBPurge, null, _request, 'Delete ' &amp; display &amp; ' request by user ' &amp; userCode, true, false);
	//PAR18062 - 14/10/2008 cnwsh3 Pass through the type based on the object's class.
	if _request.isKindOf(BGP_ActivityHistoryRequest) then	//18 Apr 2012	cnwrs1	Par 29441
		app.writeLog('Delete ' &amp; display &amp; ' request by user ' &amp; userCode&amp;'.', LogINFO);	//25 Nov 2019	NDL	TFS 47053
		
	else
		app.createActivityHistory(type, null, _request, 'Delete ' &amp; display &amp; ' request by user ' &amp; userCode, true, false);
	endif;
end;</source>
        <Parameter name="_request" type="BGP_Request"/>
    </JadeMethod>
    <JadeMethod name="createChildren" id="3ebde9ba-bc06-4ef3-b7e4-fc0fb1ae383b">
        <updating/>
        <source>createChildren(_cmif : CMIF_BGPManagerChildren) protected, updating;

// cnwdvb1 25 October 2002 
//
//28 Apr 2016	cnwrs1	TFS Push Events Geneva
// 10 May 2017	cnwrs1	TFS 3518 remove Push Events
// 11 June 2018	jlgrs1	TFS 39013 (37190) Pelindo BGP Web Service
vars
	idx	: Integer;
begin
	if _cmif.isBackupJournal then
		self.createController(BGP_BackupJournal);
	endif;
	if _cmif.isCalendarCheck then								//02 Nov 2010	NDL	Par 25530
		self.createController(BGP_CalendarCheckController);		
	endif;
	if _cmif.isChangeTracker then
		self.createController(BGP_ChangeTrackerController);
	endif;
	// BGP_ExternalWSController
	foreach idx in 1 to _cmif.numberOfExtWSServices do
		self.createController(BGP_ExternalWSController);
	endforeach;
	foreach idx in 1 to _cmif.numberOfRemotes do
		self.createController(BGP_GenericController);
	endforeach;
	if _cmif.isLocationStatistics then
		self.createController(BGP_LocationStatistics);
	endif;
	if _cmif.isLockKeeper then
		self.createController(BGP_LockKeeperController);
	endif;
	if _cmif.isRFIDListenController then
		self.createController(BGP_RFIDListenController);
	endif;
	foreach idx in 1 to _cmif.numberOfReports do
		self.createController(BGP_ReportController);
	endforeach;
	foreach idx in 1 to _cmif.numberOfTcpIpClients do
		self.createController(BGP_TCPClient);
	endforeach;
	if _cmif.isAutoTimer then
		self.createController(BGP_AutoTimerController);
	endif;
	if _cmif.isAutoWarning then
		self.createController(BGP_AutoWarningController);
	endif;
	foreach idx in 1 to _cmif.numberOfDirectories do
		self.createController(BGP_DirectoryController);
	endforeach;
	if _cmif.isFutureTimer then
		self.createController(BGP_FutureTimerController);		// CCMS DPH 2278
	endif;
	//15 Apr 2013	NDL	Par 31393
	if _cmif.isVSBookGen then
		self.createController(BGP_VehicleBookingSlotCont);
	endif;
	//06 Jul 2021	NDL	TSF 51443
	if _cmif.isDeferred then
		self.createController(BGP_DeferredChargingController);
	endif;
	if _cmif.isWorkOrderScheduler then
		self.createController(BGP_WorkOrderScheduler);
	endif;
	foreach idx in 1 to _cmif.numberOfTcpIpServers do
		self.createController(BGP_XMLListenController);
	endforeach;
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_cmif" type="CMIF_BGPManagerChildren"/>
    </JadeMethod>
