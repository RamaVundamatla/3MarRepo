    <JadeMethod name="doBtnStatusCloseClick" id="66b2bf33-16d6-426b-8cf2-34f003adc29c">
        <updating/>
        <source>doBtnStatusCloseClick() updating;
/*
Purpose:	TFS 39618		 861.010
Date				Who			Reason
JANUARY 2019		CNWAB1		Initial creation
22 July 2019	cnwma1	ChangeRequest 45577: ASPA - JMT Interface to AR Oracle
24/10/2019		JLGNS1	Bug 47154: ADP - Invoice Status Permission (Pending) not working
14/08/2023		navkc1	Bug 59803: FR | EUP 53978 - Invoicing - Configuration Enhancements - Invoice Update - missing items
*/

vars
	form : INV_InvoiceUpdateStatus;
	finIOClass		: CM_ExtFinanceIO;
begin
	app.mousePointer := MP_HOURGLASS;
	
	finIOClass := self.myTerminal.getConfig(FinancialIOClass).CM_ExtFinanceIO;
	
	if not self.myCurrentBank.userCanSet(CM_Invoice.INVOICE_PENDING) then	//Bug 47154

		app.msgBox(app.getErrorString1(VB_SECMOVE,"Invoice Status Close") ,
										"Invoice Security",
										MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);

		return;
	endif;
	
	if self.myCurrentInvoice &lt;&gt; null and self.myCurrentInvoice.isVoided and self.myTerminal.allInvoiceStatusReasons.size &gt; 0 then
		self.showInvoicePropFrame(ETView_InvListInvPropVoid); 
	else
		//22.07.2019 cnwma1 TFS #45577
		if self.myCurrentInvoice.debtor.allAddressesByCode.size &gt; 0 then
			//14/08/2023	navkc1	Bug 59803 - MTN Default use form
			if self.isMTNDefaultProcess and not finIOClass.isKindOf(CM_ASPAInterface) then
				form := app.loadForm(INV_InvoiceUpdateStatus, INV_Assistant, false, false, false, self.myTerminal, null).INV_InvoiceUpdateStatus;
				form.setMyCurrentBank(self.myCurrentBank);
				form.setCurrentInvoice(self.myCurrentInvoice);
				form.setMyTerminal(self.myTerminal);
				self.tblData.allSelectedObjects.copy(form.allInvoices);
				form.newStatus := CM_Invoice.INVOICE_PENDING;
				form.myParentForm := self;
				form.showModal();
			//14/08/2023	navkc1	Bug 59803 All other process use frame. ie ASPA/WO Process/Linx
			else
				self.showInvoicePropFrame(ETView_InvListInvPropPending); 
			endif;
		else
			self.doSaveChangeStatus(CM_Invoice.INVOICE_PENDING);
		endif;
	endif;
epilog
	app.mousePointer := MP_DEFAULT;


end;</source>
    </JadeMethod>
