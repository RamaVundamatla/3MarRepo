    <JadeMethod name="sessionObject" id="1abd547d-23d1-4561-a854-863541c366d9">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>sessionObject(set_:Boolean; value_:IDispatch io) updating, mapping;
	// Returns or sets a reference to the Active Messaging Session object.

vars
	v : IDispatch;

begin
	if not set_ then
		_jadeActiveXProperty('SessionObject', '', set_, v);
		if v = null then
			value_ := null;
		else
			value_ := v.IDispatch._morph(IDispatch).IDispatch;
		endif;
	else
		_jadeActiveXProperty('SessionObject', '', set_, value_);
	endif;
end;
</source>
