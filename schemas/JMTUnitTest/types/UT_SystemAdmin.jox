    <JadeMethod name="tOrganisation" id="8fbb6e5d-58a9-4643-96ea-d436db3e3298">
        <source>tOrganisation();

/*

Purpose:		Organisation add / delete / update

Date			Who		Reason
14/05/2015		cnwmh5	Initial creation

*/

vars

	orgInternal						: CM_Organisation;
	orgExternal						: CM_Organisation;
	
	name							: String;

begin

	orgInternal := self.addOrganisation("UTMDHORGINT", true);
	self.assertNotNull(orgInternal);
	
	self.opts.purge();
	self.opts.addAssoc("AvailableForEntry", true);
	self.updateOrganisation(orgInternal);
	self.assertEqual(orgInternal.isNotAvailableForEntry, true);
	
	orgExternal := self.addOrganisation("UTMDHORGEXT", false);
	self.assertNotNull(orgExternal);

	self.opts.purge();
	self.opts.addAssoc('AvailableForLabourRestrictions', true);
	name := orgExternal.name;
	self.updateOrganisation(name);
	self.assertEqual(orgExternal.isAvailableForLabourRestiction, true);
	
	self.opts.purge();
	self.opts.addAssoc('AvailableForLabourRestrictions', false);
	self.updateOrganisation(orgExternal);
	self.assertEqual(orgExternal.isAvailableForLabourRestiction, false);

epilog

end;</source>
    </JadeMethod>
