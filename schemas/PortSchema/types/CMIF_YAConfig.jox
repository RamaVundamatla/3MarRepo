    <JadeMethod name="setFromTerminal" id="05af89e7-b162-4fe7-9d71-643487642625">
        <updating/>
        <source>setFromTerminal( _terminal : CM_Terminal ) updating;

/*

Purpose:			Load values from given terminal

Parameters:			

Return Value:		


Date			Who		Reason
31 July 2008	consw1	Initial creation
16 June 2022	navhl20	TFS 53765 EUP - Warehouse Yard Allocation Desktop Application

*/

vars

begin
	beginLoad;
//	sharedLock(_terminal); // Not included lock as all values below derived from StateData (resynchObject is done in StateData get method)

	self.autoPlanAllowLogging				:= _terminal.isAutoPlanAllowLogging();
	self.autoPlanEnabled					:= _terminal.isAutoPlanningEnabled();
	self.autoPlanGenerateSwapForYardInt		:= _terminal.isAutoPlanGenSwapForYardInt();
	self.autoPlanGenerateSwapJob			:= _terminal.isAutoPlanGenerateSwapJob();
	self.autoPlanPreNotiEmail				:= _terminal.getAutoPlanPreNotifyEmail();
	self.autoPlanPreNotifications			:= _terminal.isAutoPlanPreNotifications();
	self.autoPlanUseOverstowRules 			:= _terminal.isAutoPlanUseOverstowRules;
	self.autoPlanOsIgnorePandQ				:= _terminal.isAutoPlanOsIgnorePandQ();	//16 Jan 2019	NDL	TFS 42292
	
	self.autoPlanUserRestrictions			:= _terminal.isAutoPlanUserRestrictions();
	self.autoPlanYAGroupedBlocks			:= _terminal.isAutoPlanYAGroupedBlocks();
	//self.autoPlanOverstowsUsingYA			:= _terminal.isAutoPlanOverstowsUsingYA(); // CCMS 1025
	self.fillOption							:= _terminal.getFillOption();
	self.autoPlanMTReleaseStrategy			:= _terminal.getAutoPlanMTReleaseStrategy(); // PAR 23677
	self.autoPlanUsePriorityLookup			:= _terminal.isAutoPlanUsePriorityLookup(); // PAR 24673
	self.autoPlanUseBestPickDirector		:= _terminal.isAutoPlanUseBestPickDirector(); //cnwrd1 par 28628 2.11.11
	self.autoPlanAllowFullGCArea			:= _terminal.getAutoPlanAllowFullGCArea(); 				//16 June 2022	navhl20	TFS 53765

	if self.fillOption = 0 then
		self.fillOption := YAFillOption_InOrder;
	endif;		

	self.allRTAllocationCriteriaTypes.clear;
	_terminal.allRTAllocationCriteriaTypes.copy(self.allRTAllocationCriteriaTypes);
	
epilog
	endLoad;
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
</Class>
