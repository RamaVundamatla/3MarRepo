    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="ad472107-e4ab-4e78-b362-48c3a0b454c4">
        <source>validateForUpdate();
// ##### CR 64617 TASK 65065 NAVAB1 09JUL2024
vars
	chkMapping, mapping : CM_EDIIssueMapping;
	fileType : CM_EDIFileType;
	realMe, chkIssue : CM_EDIIssue;
begin

	if self.code = null then
		app.raiseCMException(Issue_must_have_code,null,null);
	endif;
	
	if self.description = null then
		app.raiseCMException(Issue_must_have_descrip,null,null);
	
	endif;
	
	realMe := self.pxyGetRealObject();
	
	if self.myTerminal &lt;&gt; null then
		chkIssue := self.myTerminal.allEDIIssues[self.code.trimBlanks()];
		if chkIssue &lt;&gt; null and chkIssue &lt;&gt; realMe then
			app.raiseCMException1(Issue_with_code_alread_exists,self.code.trimBlanks(),null,null);
		endif;
	endif;
	
	
	foreach mapping in self.allEDIIssueMappings do
		fileType := mapping.myEDIFileType;
		
		chkMapping := self.myTerminal.allEDIIssueMappings[fileType];
		if chkMapping &lt;&gt; null then
			if realMe &lt;&gt; null 
			and chkMapping.myEDIIssue = realMe then
				continue;
			endif;
		
			app.raiseCMException2(File_type_alrea_mappi_termi_on, fileType.name, self.myTerminal.code,  null,null);
		endif;
	endforeach;
	
epilog

end;</source>
    </JadeMethod>
</Class>
