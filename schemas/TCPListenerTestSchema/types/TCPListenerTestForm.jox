    <JadeMethod name="sendTCPMessage" id="c69e2934-aa72-49c9-8753-9344cc87143e">
        <updating/>
        <source>sendTCPMessage(_tcpPayload : TCPMessagePayload) : Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 Sep 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition

*/

vars
	outgoingMsgString	: String;
	
	tranID				: String;
	tranStarted			: Boolean;

begin
	outgoingMsgString := _tcpPayload.operationName &amp; "(" &amp; _tcpPayload.message &amp; ")";

	tranID := method.name &amp; "_" &amp; _tcpPayload.operationName;
	cnStartTransaction(tranID);
	tranStarted := true;
	
	if self.sendTCPString(outgoingMsgString) then
		cnEndTransaction;
		tranStarted := false;

		return true;
	else
		cnSetTransactionError(true);
		return false;
	endif;
	

epilog
	if tranStarted then
		cnEndTransaction;
	endif;
	
end;</source>
        <Parameter name="_tcpPayload" type="TCPMessagePayload"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="sendTCPString" id="285cb06a-4ab3-4db7-bd10-bb973385619b">
        <source>sendTCPString(_messageString : String) : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 September 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition

*/

constants
	RequestDelim		= #[0D 0A 0A];	// 14/3/16 cnwmp6 PAR 36286 unicode version
	ResponseDelim		= #[0D 0A 0D 0A];	// 14/3/16 cnwmp6 PAR 36286 unicode version
	
vars
	outgoingMsgString	: String;
	outgoingMessage		: Binary;
	response			: Binary;
	responseString		: String;
	
	connection			: TcpIpConnection;
	
begin
	on ConnectionException do self.messageExceptionHandler(exception);

	logMessage("Sending " &amp; _messageString &amp; " to " &amp; self.getRemoteHostname() &amp; ":" &amp; self.getRemotePort().String);

	create connection transient;
	
	connection.name := self.getRemoteHostname();
	connection.port := self.getRemotePort();
	connection.timeout := self.getTCPTimeout();
	connection.usePresentationClient := self.getUsePresentation;
	connection.open;
	
	if connection.state = TcpIpConnection.Connected then
	
		//outgoingMsgString := _messageString &amp; RequestDelim;	// 14/3/16 cnwmp6 PAR 36286 unicode version
			
		outgoingMessage := _messageString.asANSI(0) &amp; RequestDelim;	// 14/3/16 cnwmp6 PAR 36286 unicode version
		
		connection.writeBinary(outgoingMessage);
		
		if connection.state = TcpIpConnection.Connected then
			response := connection.readUntil(ResponseDelim, 0);	// 14/3/16 cnwmp6 PAR 36286 unicode version
			
			connection.close;
		endif;
	endif;
			
	// Response could be null if we had an exception
	if response &lt;&gt; null then
		responseString := response.ansiToString();	// 16/3/16 cnwmp6 PAR 36286 unicode version
		
		self.processTCPResponse(responseString);
		
		logMessage("Response received " &amp; responseString);
		return true;
	else
		return false;
	endif;
	

epilog
	delete connection;
	
end;</source>
        <Parameter name="_messageString" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
