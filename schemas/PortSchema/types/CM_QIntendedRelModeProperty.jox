    <JadeMethod name="setComboValues" id="cc2a41b5-8589-4420-87a0-05211b4df43d">
        <source>setComboValues(_combo : ComboBox input; _params : CM_QueryCriteriaLineHolder; _queryOperator : CM_QueryOperator; _passport : CM_Passport);
// ---------------------------------------------------------------------------
// Created:     05 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
// Modified:
// PAR 20216    09/07/2009          cnwas3
// ----------   ----------  --------------------------------------------------
vars
	searchValue : Integer;  // PAR 20216                                                   
begin
	_combo.clear();
	_combo.addItem(app.intendedReleaseModeEnum2String(TI_IntendedReleaseMode_RAIL));
	_combo.addItem(app.intendedReleaseModeEnum2String(TI_IntendedReleaseMode_ROAD));
	_combo.addItem(app.intendedReleaseModeEnum2String(TI_IntendedReleaseMode_SHIP));
	_combo.addItem(app.intendedReleaseModeEnum2String(TI_IntendedReleaseMode_NULL));
	
	/*if CM_QIntegerLookupEqual.hasInstance(_queryOperator) then												// PAR 20216 commented out 
		_combo.text := app.intendedReleaseModeEnum2String(_queryOperator.CM_QIntegerLookupEqual.searchValue);
	elseif CM_QIntegerLookupNotEqual.hasInstance(_queryOperator) then
		_combo.text := app.intendedReleaseModeEnum2String(_queryOperator.CM_QIntegerLookupNotEqual.searchValue);
	endif;*/
	
	
	if CM_QIntegerLookupEqual.hasInstance(_queryOperator) then													// PAR 20216 new code begin
		searchValue := _queryOperator.CM_QIntegerLookupEqual.searchValue; 
		_combo.text := app.intendedReleaseModeEnum2String(searchValue);		
	elseif CM_QIntegerLookupNotEqual.hasInstance(_queryOperator) then
		searchValue := _queryOperator.CM_QIntegerLookupNotEqual.searchValue;   
		_combo.text := app.intendedReleaseModeEnum2String(searchValue);		
	endif;
	
	if searchValue = 0 then	                                                 
		_combo.listIndex:=-1;                                                 
	endif;																										// PAR 20216 new code end											
	
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="d3c214c0-542c-4473-b6b7-714c452ee8e8">
        <source>setListValues(_tbl : Table input; _params : CM_QueryCriteriaLineHolder; _operator : CM_QIntegerIsOneOf; _passport : CM_Passport);
// ---------------------------------------------------------------------------
// Created:     14 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	intArray	: IntegerArray;
	idx,intSite	: Integer;
	strObj		: CM_String;
begin

	_tbl.purgeTableObjects();
	_tbl.clear;
	_tbl.rows := _tbl.fixedRows;
	
	create intArray transient;
	
	intArray.add(TI_IntendedReleaseMode_RAIL);
	intArray.add(TI_IntendedReleaseMode_ROAD);
	intArray.add(TI_IntendedReleaseMode_SHIP);
	intArray.add(TI_IntendedReleaseMode_NULL);

	self.setListTableFromIntConstants(_tbl, _operator, intArray, TI_INTENDRELEASEMODE_Constant);	

epilog
	delete intArray;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QIntegerIsOneOf"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="1293c1c5-73b0-4096-9ebc-bc5c950f7e87">
        <source>setValuesFromList(_tbl : Table input; _op: CM_QueryOperator input);
// ---------------------------------------------------------------------------
// Created:     14 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	stat		: CM_IMEXStatus;
	str			: String;
	numRows,
	idx			: Integer;
	ia			: IntegerArray;
begin
	create ia transient;
	
	numRows := _tbl.rows;
	foreach idx in (_tbl.fixedRows + 1) to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			str := _tbl.accessCell(idx, 2).text;
			ia.add(self.translateToSearchValue(str).Integer);
		endif;
	endforeach;
	
	_op.setSearchValue(ia);
	
epilog
	delete ia;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateStringToSearchValue" id="436ff96e-30ac-4f37-97d7-70360fbd1b2a">
        <source>translateStringToSearchValue(_value: Any; _criteriaLine : CM_SelectorCriteriaLine ): Any;
// ----------------------------------------------------------------------
// Created 12 May 2008 by cnwvu1
//
// Purpose:	Gets value as String from RT screen and returns value
//			 into criteriaLineLine for running a query
// ----------------------------------------------------------------------

vars
	intendRelMode : Integer;	
begin
	
	if _value.String.isInteger then
		return _value;
	endif;
	
	intendRelMode := app.intendedReleaseModeString2Enum(_value.String);
	
	if intendRelMode = null and _value &lt;&gt; null then	 //Par 17092	cnwvu1, June 2008
		app.raiseCMException2( ERR_FIELD_VALUE, _value.String, _criteriaLine.myQueryProperty.niceName, null, self );
	endif;
	
	return intendRelMode;

end;
</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_criteriaLine" type="CM_SelectorCriteriaLine"/>
        <ReturnType type="Any"/>
    </JadeMethod>
