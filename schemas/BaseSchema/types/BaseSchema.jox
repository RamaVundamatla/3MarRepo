end;</source>
    </JadeMethod>
    <JadeMethod name="cnEcInitializeBaseRelease" id="d1a2eec1-249c-4abd-a4cf-ff0fe6e31ae9">
        <updating/>
        <source>cnEcInitializeBaseRelease() updating;
// --------------------------------------------------------------------------------
// Created:		12 August 2001 by cnwdad1
//
// Purpose:		Initialize method for the JADE Release Maintenance application.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	releaseControllerObj	: CnEcReleaseController;
//	initialClassObj			: Class;
	currentRelease			: String;
	historyMasterObj		: CnEcReleaseHistoryMaster;
	
begin
	app.cnActivateKarmaControl(Cn_Fat_Client, null, null);
	self.cnEcInitializeBaseSchema();
	
	create releaseControllerObj transient;
	
	releaseControllerObj.processRelease(BaseSchemaRelease, currentRelease, historyMasterObj);
	releaseControllerObj.myTA.trxHistoryMasterUpdateVersion(self.myBaseRoot, historyMasterObj, 0, currentRelease);
	
	terminate;
epilog
	delete releaseControllerObj;
end;</source>
    </JadeMethod>
