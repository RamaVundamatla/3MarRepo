    <JadeMethod name="getEDIWagonMatching" id="01f35968-3188-4082-beba-1d66cb2bfef1">
        <source>getEDIWagonMatching( _wagon : CM_Wagon ):CM_EDIWagonTI;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 March 2015	cnwndl1	Initial creation

*/

vars

	invalidObj : Boolean;
	iter : Iterator;
	ediObj : CM_EDITrackedItem;
	ediWagon : CM_EDIWagonTI;

begin

	
	
	if self.allEDITrackedItems.isEmpty or _wagon = null then
		return null;
	endif;

	on Exception do app.handleDeletedObject( exception, ediObj, invalidObj );
	on Exception do app.handleDeletedObject( exception, _wagon, invalidObj );
	
	iter := self.allEDITrackedItems.createIterator;
	
	while iter.next( ediObj ) do
		invalidObj := false;
		if ediObj.isKindOf( CM_EDIWagonTI ) then
			ediWagon :=  ediObj.CM_EDIWagonTI;
			if ediWagon.wagonNumber.toUpper = _wagon.id.toUpper then
				return ediWagon;
			endif;
		endif;
	endwhile;
	
	return null;

epilog

	delete iter;

end;</source>
        <Parameter name="_wagon" type="CM_Wagon"/>
        <ReturnType type="CM_EDIWagonTI"/>
    </JadeMethod>
    <JadeMethod name="getMyTIDisplayDefNames" id="d4d6bdbe-0392-44af-be06-dea0aeebafe7">
