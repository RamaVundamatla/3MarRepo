    <JadeMethod name="pxyCreateUpdateProxy" id="7b63339f-9b00-4299-aa47-ef819cb776f7">
        <source>pxyCreateUpdateProxy(): SelfType;
// --------------------------------------------------------------------------------
// Created:		13 October 2006 by cnwdad1
//
// Purpose:		Standard method for instantiating a proxy of the receiver.
//
// Parameters:	None
//
// Returns:		A reference to the proxy object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// --------------------------------------------------------------------------------
vars
	proxyObj	: SelfType;
	completedOK		: Boolean;
	
begin
	proxyObj	:=	inheritMethod();
	
	proxyObj.code			:=	self.code;
	proxyObj.description	:=	self.description;
	proxyObj.myRoot			:=	self.myRoot;
	
	self.allMovementPaths.copy(proxyObj.allMovementPaths);
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyObj;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyObj;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
