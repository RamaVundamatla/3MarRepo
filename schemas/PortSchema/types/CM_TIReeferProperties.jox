    <JadeMethod name="createDefaults" id="8d17af5f-7936-4bc8-be8b-a2bac869e5e8">
        <updating/>
        <source>createDefaults() updating;
/*

Date		    Who			Reason
17/11/2010		cnwas3	  	par 26199
23/01/2013		cnwdap1		PAR #31018 CCMS POL 2223
*/

vars

begin
	self.allowableTimeOffPower := NULL_ALLOWABLE_TIME_OFF_POWER;
	self.remainingTimeOffPower := NULL_ALLOWABLE_TIME_OFF_POWER;		// PAR #31018
epilog

end;</source>
