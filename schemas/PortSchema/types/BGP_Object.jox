    <JadeMethod name="getFileName" id="b3c11c68-a647-4c44-bde6-8c2d3960f0b5">
        <source>getFileName(_filePath : String) : String protected;

vars

	tmp	: String;
	c	: Character;
	i	: Integer;

begin

	i := _filePath.length;
	while i &gt; 0 do
		c := _filePath[i];
		if c = '/' or c='\' then
			break;
		endif;
		tmp := tmp &amp; c;
		i := i - 1;
	endwhile;
	return tmp.reverse();
	

end;</source>
        <access>protected</access>
        <Parameter name="_filePath" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initAutoManager" id="2ff8a3ee-904b-418f-83c2-42cb3f892611">
        <source>initAutoManager(_user : CM_User);
// -------------------------------------------
// Created 08 September 2003 by cnwdvb1
// -------------------------------------------
vars

	cmif		: CMIF_BGPManagerChildren;
	controllers	: BGP_ControllersByNameDict;
	controller	: BGP_Controller;
	error		: CM_Error;

begin

	if _user = null then
		return;
	endif;
	create cmif transient;
	// Setup Auto timer with one generic controller;
	cmif.myUser := _user;
	cmif.isServer 				:= true;
	cmif.managerName			:= 'AUTO';
	cmif.numberOfRemotes		:= 1;
	cmif.numberOfReports		:= 0;
	cmif.numberOfDirectories	:= 0;
	cmif.numberOfTcpIpServers	:= 0;
	cmif.isAutoTimer			:= true;
	cmif.numberOfTcpIpClients	:= 0;
	cmif.isLockKeeper			:= true;
	cmif.isChangeTracker		:= false;
	controllers := self.defaultSetup(cmif);
	if controllers = null then
		return;
	endif;
	controller := controllers.getControllerOfType(BGP_AutoTimerController);
	if controller &lt;&gt; null then
		self.defaultUpdate(controller, cmif);
	endif;
	
	controller := controllers.getControllerOfType(BGP_LockKeeperController);
	if controller &lt;&gt; null then
		self.defaultUpdate(controller, cmif);
	endif;
	
	controller := controllers.getControllerOfType(BGP_GenericController);
	if controller &lt;&gt; null then
		cmif.allClasses.clear();
		cmif.allClasses.add(BGP_AutoReportRequests.name);
		cmif.allClasses.add(BGP_CheckDiskSpaceRequest.name);
		cmif.allClasses.add(BGP_ClearAlertsRequest.name);
		cmif.allClasses.add(BGP_GateInOutRequest.name);
		cmif.allClasses.add(BGP_AutoProcessExpiredPTI.name);
		cmif.allClasses.add(BGP_AutoProcessExpiredWash.name);
		cmif.allClasses.add(BGP_CountProcessesRequest.name);
		cmif.allClasses.add(BGP_SpecificReportRequest.name);
		self.defaultUpdate(controller, cmif);
	endif;
	
epilog
	delete cmif;

end;</source>
        <Parameter name="_user" type="CM_User"/>
    </JadeMethod>
    <JadeMethod name="initBackup" id="71a694ee-b56b-4ba4-b134-3b7af6975500">
        <source>initBackup(_user : CM_User);
// -------------------------------------------
// Created October 2004 by cnwrs1

vars

	cmif: CMIF_BGPManagerChildren;
	controllers: BGP_ControllersByNameDict;
	controller: BGP_Controller;
	error: CM_Error;
	i: Integer;
begin

	if _user = null then
		return;
	endif;
	create cmif transient;
	// Setup Auto timer with one generic controller;
	cmif.myUser := _user;
	cmif.isServer := false;
	cmif.managerName := 'BACKUP';
	cmif.numberOfRemotes := 1;
	cmif.numberOfReports := 0;
	cmif.numberOfDirectories := 0;
	cmif.numberOfTcpIpServers := 0;
	cmif.isAutoTimer := false;
	cmif.isFutureTimer := false;
	cmif.numberOfTcpIpClients := 0;
	cmif.isLockKeeper := false;
	cmif.isChangeTracker := false;
	cmif.isBackupJournal := true;
	controllers := self.defaultSetup(cmif);
	if controllers = null then
		return;
	endif;
	cmif.allClasses.add(BGP_BackupDB.name);
	controller := controllers.getControllerOfType(BGP_GenericController);
	if controller &lt;&gt; null then
		self.defaultUpdate(controller, cmif);
	endif;
		
	controller := controllers.getControllerOfType(BGP_BackupJournal);
	if controller &lt;&gt; null then
		self.defaultUpdate(controller, cmif);
	endif;
epilog
	delete cmif;
end;</source>
        <Parameter name="_user" type="CM_User"/>
    </JadeMethod>
    <JadeMethod name="initCamsRefEdiEtc" id="3dddafb8-7f04-4467-9aad-7fb76331c401">
        <source>initCamsRefEdiEtc(_numberOfControllers : Integer; _user : CM_User);
// -------------------------------------------
// Created 08 September 2003 by cnwdvb1
// -------------------------------------------
// 28 May 2013		cnwrs1	ccms 1336 Par 31389 separate BGP EmailRequest to seperate read and send
vars

	cmif		: CMIF_BGPManagerChildren;
	controllers	: BGP_ControllersByNameDict;
	controller	: BGP_Controller;
	error		: CM_Error;
	i			: Integer;

begin

	if _user = null then
		return;
	endif;
	create cmif transient;
	// Setup Auto timer with one generic controller;
	cmif.myUser := _user;
	cmif.isServer 				:= false;
	cmif.managerName			:= 'CLIENT WORKERS';
	cmif.numberOfRemotes		:= _numberOfControllers + 1;
	cmif.numberOfReports		:= 0;
	cmif.numberOfDirectories	:= 0;
	cmif.numberOfTcpIpServers	:= 0;
	cmif.isAutoTimer			:= false;
	cmif.isFutureTimer 			:= false;
//	if _user.canDo(null, PmRefCon) then
	if _user.canDo(null, Mod_BaseSystem) then	//07 Oct 2019	NDL	TFS 46169
		cmif.numberOfTcpIpClients	:= 1;
	endif;
	cmif.isLockKeeper			:= false;
	cmif.isChangeTracker		:= false;
	controllers := self.defaultSetup(cmif);
	if controllers = null then
		return;
	endif;
	cmif.allClasses.add(BGP_CamsRequest.name);
	cmif.allClasses.add(BGP_EdiRequest.name);
	cmif.allClasses.add(BGP_StorageProcessorRequest.name);
	cmif.allClasses.add(BGP_KPISpaceUtilisationRequest.name);
	foreach i in 1 to _numberOfControllers do
		controller := controllers.getControllerOfType(BGP_GenericController);
		if controller &lt;&gt; null then
			self.defaultUpdate(controller, cmif);
		endif;
	endforeach;
	
	controller := controllers.getControllerOfType(BGP_GenericController);
	if controller &lt;&gt; null then
		cmif.allClasses.clear();
		cmif.allClasses.add(BGP_EmailSendRequest.name);
		cmif.allClasses.add(BGP_EmailReadRequest.name);
		self.defaultUpdate(controller, cmif);
	endif;
	
epilog
	delete cmif;

end;</source>
        <Parameter name="_numberOfControllers" type="Integer"/>
        <Parameter name="_user" type="CM_User"/>
    </JadeMethod>
    <JadeMethod name="initChangeControl" id="b1338984-96b1-46da-8bd5-97e1f1ea8821">
        <source>initChangeControl(_user : CM_User);
// -------------------------------------------
// Created 09 September 2003 by cnwdvb1

vars

	cmif		: CMIF_BGPManagerChildren;
	controllers	: BGP_ControllersByNameDict;
	controller	: BGP_Controller;
	error		: CM_Error;
	i			: Integer;

begin

	if _user = null then
		return;
	endif;
	create cmif transient;
	// Setup Auto timer with one generic controller;
	cmif.myUser := _user;
	cmif.isServer 				:= false;
	cmif.managerName			:= 'CHANGE CONTROL';
	cmif.numberOfRemotes		:= 1;
	cmif.numberOfReports		:= 0;
	cmif.numberOfDirectories	:= 0;
	cmif.numberOfTcpIpServers	:= 0;
	cmif.isAutoTimer			:= false;
	cmif.isFutureTimer			:= false;
	cmif.numberOfTcpIpClients	:= 0;
	cmif.isLockKeeper			:= false;
	cmif.isChangeTracker		:= true;
	controllers := self.defaultSetup(cmif);
	if controllers = null then
		return;
	endif;
	cmif.allClasses.add(BGP_ExternalDBRequest.name);
	controller := controllers.getControllerOfType(BGP_GenericController);
	if controller &lt;&gt; null then
		self.defaultUpdate(controller, cmif);
	endif;
		
	controller := controllers.getControllerOfType(BGP_ChangeTrackerController);
	if controller &lt;&gt; null then
		self.defaultUpdate(controller, cmif);
	endif;
	
epilog
	delete cmif;

end;</source>
        <Parameter name="_user" type="CM_User"/>
    </JadeMethod>
    <JadeMethod name="initReports" id="0d537781-6687-48c2-bbec-b5877177c78b">
        <source>initReports(_numberOfControllers : Integer; _user : CM_User);
// -------------------------------------------
// Created 08 September 2003 by cnwdvb1
vars

	cmif		: CMIF_BGPManagerChildren;
	controllers	: BGP_ControllersByNameDict;
	controller	: BGP_Controller;
	error		: CM_Error;
	i			: Integer;

begin

	if _user = null then
		return;
	endif;
	create cmif transient;
	// Setup Auto timer with one generic controller;
	cmif.myUser 				:= _user;
	cmif.isServer 				:= false;
	cmif.managerName			:= 'REPORTS';
	cmif.numberOfRemotes		:= 0;
	cmif.numberOfReports		:= _numberOfControllers;
	cmif.numberOfDirectories	:= 0;
	cmif.numberOfTcpIpServers	:= 0;
	cmif.isAutoTimer			:= false;
	cmif.isFutureTimer 			:= false;
	cmif.numberOfTcpIpClients	:= 0;
	cmif.isLockKeeper			:= false;
	cmif.isChangeTracker		:= false;
	controllers := self.defaultSetup(cmif);
	if controllers = null then
		return;
	endif;
	
	foreach i in 1 to _numberOfControllers do
		controller := controllers.getControllerOfType(BGP_ReportController);
		if controller &lt;&gt; null then
			self.defaultUpdate(controller, cmif);
		endif;
	endforeach;
	
epilog
	delete cmif;

end;</source>
        <Parameter name="_numberOfControllers" type="Integer"/>
        <Parameter name="_user" type="CM_User"/>
    </JadeMethod>
