    <JadeMethod name="doDragOverAutoScrolling" id="35097a3a-09cd-489a-88b0-068853c13bc0">
        <updating/>
        <source>doDragOverAutoScrolling(frame: Frame input; win: Window input; x: Real; y: Real; state: Integer) updating;
// ---------------------------------------------------------------------------
// Created:		February 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
constants
	SMALL_CHANGE = 180;
vars
	theSDF : CMUI_GridAreaScrollableFrame;
	horizontalScroll, verticalScroll, pluss : Boolean;
	realXValue, realYValue, smallChange,theXDiff : Integer;	
	now : TimeStamp;
begin
	if not self.doAutoScrolling then
		return;
	endif;
	now := app.actualTimeServer();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support

	if state = Frame.DragOver_Enter then
		self.enteredTS := now;
		self.leaveTS := null;
		app.setMouseMoveTime(10);
		return;
	endif;
	if state = Frame.DragOver_Leave then
		self.leaveTS := now;
		self.enteredTS := null;
		app.setMouseMoveTime(200);
		return;
	endif;

	if state = Window.DragOver_Continue then
		// have they hovered long enough?
		if now.cnEcDiff(self.enteredTS) &lt; 400 then
			return;
		endif;
		
		theSDF := self.getScrollingFrame();
		if theSDF = null then
			return;
		endif;

		// ### work out if I need to AUTO scroll. i.e. am I within 35 pixels of the edge?
		realXValue := ((x - theSDF.clientWidth) + theSDF.myVLabels.width).Integer;
		realYValue := ((theSDF.clientHeight + theSDF.getVScrollValue()).Integer - y - theSDF.myHLabels.height).Integer;
		theXDiff := theSDF.getHScrollValue() - realXValue;
		if theXDiff &lt; 35 then
			horizontalScroll := true;
			pluss := true;
		elseif (x - theSDF.getHScrollValue()) &lt; 35 then
			horizontalScroll := true;
			pluss := false;
		elseif realYValue &lt; 35 then
			verticalScroll := true;
			pluss := true;
		elseif (y - theSDF.getVScrollValue()) &lt; 35 then
			verticalScroll := true;
			pluss := false;
		endif;

		// if I am to scroll, how long is it since I was just dragOver continueing and not scrolling?
		if horizontalScroll or verticalScroll then
			if now.cnEcDiff(self.lastTS) &lt; 400 then
				return;
			endif;
			self.lastMouseX := x.Integer;
			self.lastMouseY := y.Integer;
//			self.endTimer(567);
//			self.beginTimer(250,Timer_Continuous,567);
		endif;
		if horizontalScroll and theSDF.hasHScroll() then
			smallChange := SMALL_CHANGE;
			if not pluss then
				smallChange := smallChange * -1;
			endif;
//			theSDF.myHScroll.value := theSDF.myHScroll.value + smallChange;
			theSDF.scrollTo(theSDF.getHScrollValue() + smallChange,theSDF.getVScrollValue());
			theSDF.scrollControl(ScrollBar_Horizontal, theSDF.getHScrollValue());
		elseif verticalScroll and theSDF.hasVScroll() then
			smallChange := SMALL_CHANGE;
			if not pluss then
				smallChange := smallChange * -1;
			endif;
//			theSDF.myVScroll.value := theSDF.myVScroll.value + smallChange;
			theSDF.scrollTo(theSDF.getHScrollValue(),theSDF.getVScrollValue() + smallChange);
			theSDF.scrollControl(ScrollBar_Vertical, theSDF.getVScrollValue());
		// no scrolling so set the time.
		else
			self.lastTS := now;
//			self.endTimer(567);
		endif;
	endif;
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="state" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doDragOverDrawDeskTopRectangle" id="af265dda-c43d-4855-abad-df0ffd0983d0">
        <updating/>
        <source>doDragOverDrawDeskTopRectangle(frame: Frame input; win: Window input; x: Real; y: Real; state: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     21 April 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
constants
	WIDTH	= 1;
vars
	theHeight, theWidth : Integer;
begin
	theHeight := (self.clientHeight / 2).Integer;
	theWidth := (self.clientWidth / 2).Integer;

	if self.amDrawingDeskTopRectangle then
		frame.drawDeskTopRectangle(0, self.firstMouseX, self.firstMouseY,
											self.lastMouseX, self.lastMouseY, Black, WIDTH);
	endif;
		
	self.amDrawingDeskTopRectangle := true;
	
	self.lastMouseY := y.Integer;
	self.lastMouseX := x.Integer;

	frame.drawDeskTopRectangle(0, self.firstMouseX, self.firstMouseY,
										self.lastMouseX, self.lastMouseY, Black, WIDTH);

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="state" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="dragOver" id="7f989a56-46d8-44cc-836f-7692623c8aa3">
        <updating/>
        <source>dragOver(frame: Frame input; win: Window input; x: Real; y: Real; state: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     01 March 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpParent	: Window;
	scrollingFrame	: CMUI_ScrollingFrame;
begin
	inheritMethod(frame, win, x, y, state);
	/*
	Date		Who		Reason			
	8 sep 2008	cnwdz2	Par 15842 A configurable option at terminal level that will allow 
                    a user to set the setting of autoscrolling for the Yard Grid form on or off. 
	1 Oct 2008	consw1	Par 17090 Replace app.getMyTerminal with form's myTerminal
	*/				
	if self.getMyTerminalFromForm().getConfig("yardDisableAutoScroll").Boolean then 
	//if app.getMyUserCode = 'CNWSH3' then
		//process.debug;
		//app.writeStatement(self.class.name &amp; ' &gt;&gt;' &amp; method.name &amp; " 2. ");
		//global.schToDo;
		return;
	endif;
	tmpParent := self.parent;

	if self.doAutoScrolling then
		self.doDragOverAutoScrolling(frame, win,x,y,state);
	endif;

//	if self.isDrawDeskTopRectangle then
//		self.doDragOverDrawDeskTopRectangle(frame, win, x, y, state);
//		return;
//	endif;

	if CMUI_ScrollingFrame.hasInstance(tmpParent) then
		scrollingFrame	:= tmpParent.CMUI_ScrollingFrame;
		scrollingFrame.dragOver(scrollingFrame, win, x + self.left, y + self.top, DragOver_Continue);
	endif;

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="state" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawObject" id="2b26f029-6e4c-48ac-94f2-b0de27bd1637">
        <updating/>
        <source>drawObject(_obj : Object; _drawingController : CMUI_GridDrawingController input) updating;
// ---------------------------------------------------------------------------
// Created:     29 January 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	x1, y1, x2, y2	: Integer;

begin

	if self.getPointsForObject(_obj, x1, y1, x2, y2) then
	
		self.drawObjectAt(_obj, x1, y1, x2, y2, _drawingController);
	else

	endif;

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_drawingController" type="CMUI_GridDrawingController" usage="input"/>
    </JadeMethod>
