<GUIClass name="CMUI_ComboLogSpecies" id="10a0013f-265b-48b2-881b-752f34eab9af">
    <superclass name="CMUI_ComboBoxObject"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="_usergui"/>
    <JadeMethod name="displayEntry" id="cc8efb2e-1238-4f6b-a7f1-11edb4faf1e4">
        <updating/>
        <source>displayEntry(combobox: ComboBox input; obj: CM_LogSpecies; lstIndex: Integer): String updating;
// ---------------------------------------------------------------------------
// Created:     29 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	
	if obj = null then
		return null;
	endif;

	if obj.notAvailableForEntry then
		if self.myObject &lt;&gt; obj then
			return null;
		else
			self.hasDirtyObject := true;
		endif;
	endif;
	
	return obj.code.String &amp; Tab &amp; obj.description;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="obj" type="CM_LogSpecies"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCollectionJMT" id="25c617d8-3dfd-4e23-9be1-cc6ef34ce137">
        <source>getCollectionJMT(): Collection protected;
// ---------------------------------------------------------------------------
// Created:     29 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if self.myOperator &lt;&gt; null then 
		return self.myOperator.getAllLogSpecies();
	endif;

	return null;
end;</source>
        <access>protected</access>
        <ReturnType type="Collection"/>
    </JadeMethod>
    <JadeMethod name="setObjectAndOperator" id="43cad8d6-5cf7-426b-9fac-8bc2275321c2">
        <updating/>
        <source>setObjectAndOperator(_obj : CM_LogSpecies; _operator : CM_Operator) updating;
// -------------------------------------------
// Created 29 september 2005 by cnwhjg1
// -------------------------------------------
vars

begin

	if self.myOperator &lt;&gt; _operator or _obj &lt;&gt; self.myObject then
		self.myOperator := _operator;

		if _obj = null then
			self.text := null;
			self.amInitialised := false;
		// want collection to reset itslef which does not happen if obj is null. 
			self.myObject := _obj;
			self.zInit();
			
			if self.findObject(_obj) &gt; 0 then
				self.listObject := _obj;
			else
				self.clear();
			endif;	
			return;
		endif;
		
		
	endif;
	// Forces a clear because we want new .
	self.amInitialised := false;
	
	self.setObject(_obj);
	

end;</source>
        <Parameter name="_obj" type="CM_LogSpecies"/>
        <Parameter name="_operator" type="CM_Operator"/>
    </JadeMethod>
