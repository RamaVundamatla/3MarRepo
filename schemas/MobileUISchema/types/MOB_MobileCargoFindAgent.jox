    <JadeMethod name="clearHistory" id="54ba319c-5969-4681-bc30-4abf74d4fd50">
        <updating/>
        <source>clearHistory( _clearProcessTi : Boolean ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 February 2010	cnwndl1	Initial creation

*/

vars

begin

	if _clearProcessTi then
		self.setMyTrackedItemToProcess(null);
		self.setMyDeliveryRequest(null);	//01 Jun 2010	NDL Par 23903
	endif;

	self.setDoSearchImmediate(false);
	self.setHidePackItems(false);	//17 July 2014	NDL	Par 34571
	self.setID(null);
	self.setMyBOL(null);
	self.setMyBookingRef(null);
	self.setMyCargoType(null);
	self.setMyCraneTransferArea(null);	// Par 23761	NDL	28 Jul 2010
	self.setMyDischargePort(null);
	self.setMyIMEX(null);
	self.setMyIsoType(null);
	self.setMyOperator(null);
	self.setMyProduct(null);
	self.setMyTAType(null);
	self.setMyTermArea(null);
	self.setMyTrackedItemToView(null);
	self.setMyVoyage(null);
	self.setMyYardLoc(null);
	self.setPreventSiteChange(false);
	self.setReefersOnly(false);
	self.setSearchSite(TI_SITE_ONSITE);
	self.allSearchResults.clear();
	self.setStringField1(null);
	self.setStringField2(null);	//01 Aug 2013	NDL	Par 32140
	self.setDecimalField1(0.00);	//02 Apr 2014	NDL	CCMS 1366
	self.setCanSplitOnly(false);
	self.setCanMergeOnly(false);
	self.setMyTILCType(null);	//24 Sep 2013	NDL	Par 32556
	self.setFiltAvailGardes(null);
	self.onlyShowResults:=false; //epr par 36908 22/9/15
	self.setColourString(null);	//27 Oct 2016	NDL	TFS 2850 / 2370
	self.setMark(null);	//27 Oct 2016	NDL	TFS 2850 / 2370
	self.setCargoWeightKgs(0);	//14 Nov 2016	NLD	TFS 2959 / 2420
	self.setTareWeightKgs(0);	//14 Nov 2016	NLD	TFS 2959 / 2420
	
epilog

end;</source>
        <Parameter name="_clearProcessTi" type="Boolean"/>
    </JadeMethod>
