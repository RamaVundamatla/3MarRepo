    <JadeMethod name="setupForm" id="132b84c6-d28d-475e-aa93-9100704e2c7e">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 July 2012	cnwndl1	Initial creation	Par 29968

*/

vars

begin

	if not app.isCashOnlyEnabled then
		self.unloadForm;
		return;
		
	elseif self.myTerminal = null or not self.myTerminal.isCashOnlyEnabled then
		app.msgBox(app.getErrorString(Term_not_cash_enabled), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
		self.unloadForm;
		return;
		
	elseif not self.myTerminal.isDutyDocEnabled then
		return;
		
	endif;
	
	self.selectedString := true.cnEcGetTableCheckBoxValue;
	self.unSelectedString := false.cnEcGetTableCheckBoxValue;

	inheritMethod();
	
	self.isSelectorCapable:=true;
	self.setInitialControlValues();
	
	self.doChangeMOP();
	
	setMyDebtor( null );
	self.enableButtonsSetBalances();

	self.loadFromInitDutyDoc();
	
	self.doOptClick();
	
epilog

end;</source>
    </JadeMethod>
