    <JadeMethod name="doLoadISOTypes" id="73b72542-373e-40cb-9ad4-ddd9f326746a">
        <source>doLoadISOTypes() protected;
// ---------------------------------------------------------------------------
// Created:     12 March 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	userWindow				: CM_UserWindow;
	isoType					: CM_ISOType;
	isoTypeGroup			: CM_ISOTypeGroup;

begin
	userWindow := self.myUserWindow;
	isoTypeGroup := self.cmbISOGroup.listObject.CM_ISOTypeGroup;

	if userWindow &lt;&gt; null then
		if isoTypeGroup &lt;&gt; null then
			isoType := isoTypeGroup.allISOTypes[userWindow.xmlInfo.cnEcGetTagValueOfName(ETRow_FiltISOType)];		
		else
			isoType := app.myRoot.allISOTypes[userWindow.xmlInfo.cnEcGetTagValueOfName(ETRow_FiltISOType)];
		endif;
	endif;

	self.myAssistant.comboBoxISOTypeByGroup(self.cmbISOType,
											isoTypeGroup,
											isoType);

	self.tblSearch.setValueByName(ETRow_FiltISOType, self.cmbISOType.text);

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doLoadOperators" id="d65ca663-1775-49de-8be0-251cb6b67f39">
        <updating/>
        <source>doLoadOperators() protected, updating;
// ---------------------------------------------------------------------------
// Created:     12 March 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	operatorsToSelect 		: CM_OperatorByCodeDict;
	userWindow				: CM_UserWindow;
	opCode,
	block					: String;
	lstTbl					: CMUI_ListTable;
	op						: CM_Operator;
	opDict					: CM_OperatorByCodeDict;
	startPos				: Integer;
begin

	opDict := app.myRoot.allOperators;
	create operatorsToSelect transient;
	userWindow := self.myUserWindow;
	
	lstTbl := self.lstOperators;
	if userWindow &lt;&gt; null then
		block := userWindow.xmlInfo.cnEcGetTagValueOfName(CMUI_ListTable.XMLTag_ListTable &amp; lstTbl.name);
		startPos := 1;

		while startPos &lt;&gt; 0 do
			opCode := block.cnEcGetNextTagValueOfName(CMUI_ListTable.XMLTag_SelectedValue, startPos);
			op := opDict[opCode];
			if op &lt;&gt; null then
				operatorsToSelect.add(op);
			endif;
		endwhile;
	endif;
	
	self.myAssistant.listTableOperators(lstTbl, true, true, operatorsToSelect);
	self.myAssistant.listTableLostFocus(self.tblSearch, self.saveRowHeight, lstTbl, 'code', false);

epilog
	delete operatorsToSelect;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doLoadStockAdjustmentForm" id="c82d973d-1a22-42c0-ae3e-dbe43162bd57">
        <source>doLoadStockAdjustmentForm() protected;

// Created by cnwdvb1 on 09 November 2006

vars

	rowNum	: Integer;
	theTA	: CM_TerminalArea;

begin

	rowNum := tblData.row;
	
	if rowNum &lt;= tblData.fixedRows then
		return;
	endif;

	theTA := tblData.accessRow(rowNum).itemObject.CM_TerminalArea;
	
	if theTA = null or (not theTA.isBulkArea()) then
		return;
	endif;

	self.myAssistant.showManualStockAdjustmentForm(theTA.CM_BulkArea.myLocationsController);

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doLoadTATypes" id="f761b1f0-d97c-4324-84ec-b02bf2df8ae2">
        <source>doLoadTATypes() protected;
// ---------------------------------------------------------------------------
// Created:     11 March 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// 09/03/2010	cnwcs5		par 22687 - refactored code to exclude terminal area type
vars
	tbl			: CMUI_ListTable;
	ls			: Boolean;
	taType		: CM_TerminalAreaType;
	tmpType		: Integer;
	taTypeDict	: CM_TATypeByTypeDict;
begin

	taTypeDict := app.myRoot.allTerminalAreaTypes;
	tbl := self.tblFloatingList;
	tbl.rows := 0;
	
	tbl.sortColumn[1] := 2;
	app.cmsBeginLoad(ls);
	
	foreach taType in taTypeDict do
		// par 22687 code previously inline has been moved into following method
		if not self.includeType (taType) then	// par 22687 cnwcs5 09/03/2010
			continue;							// par 22687 cnwcs5 09/03/2010
		endif;									// par 22687 cnwcs5 09/03/2010
		
		tbl.addItemObject(taType.description, taType);
	endforeach;
	
epilog
	app.cmsEndLoad(ls);

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doMnuLabRestrictclick" id="f0c3ec75-9594-4d5e-a52e-bedb3c40ba80">
        <updating/>
        <source>doMnuLabRestrictclick(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:     02 June 2005	cnwhjg1
// ----------   ----------  --------------------------------------------------
vars
	table	: CM_DataTable;
	ta 		: CM_TerminalArea;
	row 	: Integer;
begin
	if menuItem.helpKeyword &lt;&gt; "MAIN" then
		if menuItem.helpKeyword = "DEFINE" then 
			self.doRestrictionOpenLabour();
			
		elseif menuItem.helpKeyword = "ALL" then 	
			table	:= self.tblData;
			row 	:= table.row;
			
			if row &lt;= table.fixedRows then
				return;
			endif;

			ta := table.accessRow(row).itemObject.CM_TerminalArea;
	
			if ta = null then
				return;
			endif;
			
			self.showLabourRestrictionForm(null, ta);
		else
			self.showLabourRestrictionForm(menuItem.userObject.CM_TerminalSubArea, null);
		endif;
	endif;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuLabourRestrictBuild" id="e63e8a62-6fb2-4006-95ee-bd6e48c8b139">
        <source>doMnuLabourRestrictBuild(_ta : CM_TerminalArea);
// ---------------------------------------------------------------------------
// Created:     25 May 2005	cnwhjg1
//
// Purpose:     CCMS 1314
// ----------   ----------  --------------------------------------------------
// 01/11/2012	cnwcs5	par 30475 - translate menu captions
//								  - also improve performance of building menus by hiding rather than deleting
vars
	mnuChild,mnuMaster	: MenuItem;
	mnuIndex 			: Integer;
	termSubArea 		: CM_TerminalSubArea;
begin
	mnuMaster := self.mnuAddLabRestriction;

	if not app.myCurrentUserCan(self.myTerminal,PmAdmLabrestrMaint) then
		mnuMaster.enabled := false;
		mnuMaster.visible := false;
		return;
	endif;

	mnuMaster.visible 		:= true;
	mnuMaster.enabled 		:= true;
	mnuMaster.userObject 	:= null;
	mnuMaster.helpKeyword 	:= "MAIN";

	// hide any cloned menu items - fatser than deleting and readdding them
	self.hideClonedMenuItems (mnuMaster);		// par 30475 Nov 2012

	// add sub-menu for each sub-area
	foreach termSubArea in _ta.allSubAreas do
		mnuIndex 	:= mnuIndex + 1;
		mnuChild 	:= mnuMaster.getMenuItem(mnuIndex); // check if the menu is already cloned
		
		if mnuChild = null then
			mnuChild := mnuMaster.loadSubMenu(mnuIndex); // Clone menu
		endif;
		
		mnuChild.caption 		:= termSubArea.id;
		mnuChild.visible 		:= true;
		mnuChild.enabled 		:= true;
		mnuChild.helpKeyword 	:= termSubArea.id;
		mnuChild.userObject 	:= termSubArea;
	endforeach; 
	
	// add seperator if there were sub-areas
	if mnuIndex &gt; 0 then // index has not been set as no termsubareas added above 
		mnuIndex := mnuIndex + 1;
		mnuChild := mnuMaster.getMenuItem(mnuIndex); // check if the menu is already cloned	
		
		if mnuChild = null then
			mnuChild := mnuMaster.loadSubMenu(mnuIndex); // Clone menu
		endif;
		
		mnuChild.caption 	:= "-";
		mnuChild.visible	:= true;
	endif;
	
	mnuIndex := mnuIndex + 1; 
	
	mnuChild := mnuMaster.getMenuItem(mnuIndex); // check if the menu is already cloned
	
	if mnuChild = null then
		mnuChild := mnuMaster.loadSubMenu(mnuIndex); // Clone menu
	endif;
	
	mnuChild.caption 		:= app.getErrorString (YRD_TAEnq_All);	// par 30475 Nov 2012
	mnuChild.visible 		:= true;
	mnuChild.enabled 		:= true;
	mnuChild.helpKeyword 	:= "ALL";
	mnuChild.userObject 	:= null;
	
	mnuIndex := mnuIndex + 1; 
		
	mnuChild := mnuMaster.getMenuItem(mnuIndex); // check if the menu is already cloned
	
	if mnuChild = null then
		mnuChild := mnuMaster.loadSubMenu(mnuIndex); // Clone menu
	endif;
	
	mnuChild.caption 		:= app.getErrorString (YRD_TAEnq_DefArea);	// par 30475 Nov 2012
	mnuChild.visible 		:= true;
	mnuChild.enabled 		:= true;
	mnuChild.helpKeyword 	:= "DEFINE";
	mnuChild.userObject 	:= null;
end;</source>
        <Parameter name="_ta" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="doMnuRemoveLabRestrictClick" id="0b809abb-3c70-4e82-b784-ca5e2d61d5e7">
        <updating/>
        <source>doMnuRemoveLabRestrictClick(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:     02 June 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	rowNum		: Integer;
	theTA		: CM_TerminalArea;
	restrictionLabour	: CM_LabourRestriction;
begin

	if menuItem.helpKeyword &lt;&gt; "MAIN" then
		if menuItem.helpKeyword = "VIEW" then 			
			self.doRestrictionOpenLabour();
			
		elseif menuItem.helpKeyword = "ALL" then 
			self.deleteAllLabourRestriction();
		else 		
			self.deleteLabourRestriction(menuItem.userObject.CM_LabourRestriction);
		endif;	
	endif;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuRemoveLabourRestrictBuild" id="e83ba88c-4fdd-4d69-a777-8a6a39732cd1">
        <source>doMnuRemoveLabourRestrictBuild(_ta : CM_TerminalArea);
// ---------------------------------------------------------------------------
// Created:     25 May 2005	cnwhjg1
//   
// ----------   ----------  --------------------------------------------------
// 01/11/2012	cnwcs5	par 30475 - translate menu captions
//								  - also improve performance of building menus by hiding rather than deleting

vars
	mnuChild, mnuMaster : MenuItem;
	mnuIndex 			: Integer;
	labourRestriction 	: CM_LabourRestriction;
begin
	mnuMaster 				:= self.mnuRemoveLabRestrict;

	if not app.myCurrentUserCan(self.myTerminal,PmAdmLabrestrMaint) or _ta.allRestrictionsLabour.isEmpty then
		mnuMaster.enabled := false;
		mnuMaster.visible := false;
		return;
	endif;

	mnuMaster.visible 		:= true;
	mnuMaster.enabled 		:= true;
	mnuMaster.userObject 	:= null;
	mnuMaster.helpKeyword 	:= "MAIN";

	// hide any cloned menu items - fatser than deleting and readdding them
	self.hideClonedMenuItems (mnuMaster);		// par 30475 Nov 2012

	foreach labourRestriction in _ta.allRestrictionsLabour do
		mnuIndex 	:= mnuIndex + 1;
		mnuChild 	:= mnuMaster.getMenuItem(mnuIndex); // check if the menu is already cloned
		
		if mnuChild = null then
			mnuChild := mnuMaster.loadSubMenu(mnuIndex); // Clone menu
		endif; 

		mnuChild.caption 		:= labourRestriction.getDisplayStringFull;
		mnuChild.visible 		:= true;
		mnuChild.enabled 		:= true;
		mnuChild.helpKeyword 	:= labourRestriction.id ;
		mnuChild.userObject 	:= labourRestriction;
	endforeach; 
	
	// add seperator is we have already added some submenus
	if mnuIndex &gt; 0 then 								// index has not been set as no termsubareas added above 
		mnuIndex := mnuIndex + 1;
		mnuChild := mnuMaster.getMenuItem(mnuIndex); 	// check if the menu is already cloned	
		
		if mnuChild = null then
			mnuChild := mnuMaster.loadSubMenu(mnuIndex); // Clone menu
		endif;
		
		mnuChild.caption 	:= "-";
		mnuChild.visible	:= true;
	endif;
	
	mnuIndex := mnuIndex + 1; 
	
	mnuChild := mnuMaster.getMenuItem(mnuIndex); // check if the menu is already cloned
	
	if mnuChild = null then
		mnuChild := mnuMaster.loadSubMenu(mnuIndex); // Clone menu
	endif;
	
	mnuChild.caption 		:= app.getErrorString (YRD_TAEnq_All);	// par 30475 Nov 2012
	mnuChild.visible 		:= true;
	mnuChild.enabled 		:= true;
	mnuChild.helpKeyword 	:= "ALL";
	mnuChild.userObject 	:= _ta;
	
	mnuIndex := mnuIndex + 1; 
		
	mnuChild := mnuMaster.getMenuItem(mnuIndex); // check if the menu is already cloned
	
	if mnuChild = null then
		mnuChild := mnuMaster.loadSubMenu(mnuIndex); // Clone menu
	endif;
	
	mnuChild.caption 		:= app.getErrorString (YRD_TAEnq_ViewRes);	// par 30475 Nov 2012
	mnuChild.visible 		:= true;
	mnuChild.enabled 		:= true;
	mnuChild.helpKeyword 	:= "VIEW";
	mnuChild.userObject 	:= _ta;
end;</source>
        <Parameter name="_ta" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="doMnuYardAllocBuild" id="583bc23b-0ce3-4e88-a14c-c39354848a5a">
        <source>doMnuYardAllocBuild(_ta : CM_TerminalArea);
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 30/10/2008	consw1		SFW1030 - Remove unused auto plan flags
// ---------------------------------------------------------------------------
// 31/10/2012	cnwcs5	par 30475 - translate menu captions
//								  - also improve performance of building menus by hiding rather than deleting
vars
	index 		: Integer;
	mnuChild,
	mnuMaster	: MenuItem;
	yalloc 		: CM_YardAllocation;
begin
	
	mnuMaster 				:= self.mnuYardAllocations;		
	mnuMaster.visible 		:= true;
	mnuMaster.enabled 		:= true;
	mnuMaster.userObject 	:= null;
	mnuMaster.helpKeyword 	:= "MAIN";
	
	// hide all existing sub-menu items (much quicker than deleting)
	self.hideClonedMenuItems (mnuMaster);	// par 30475 Nov 2012
	
	// load the "New Allocation..." sub-menu
	index := 1;
	
	mnuChild := mnuMaster.getMenuItem(index); // check if the menu is already cloned
	
	if mnuChild = null then
		mnuChild := mnuMaster.loadSubMenu(index); // Clone menu
	endif;
	
	mnuChild.caption 		:= app.getErrorString (YRD_TAMaint_NewAlloc);	// par 30475 Oct 2012
	mnuChild.visible 		:= true;
	mnuChild.enabled 		:= true;
	mnuChild.helpKeyword 	:= "NEW";
	mnuChild.userObject 	:= null;

	// Load a sub-menu for each existing allocation 
	foreach yalloc in _ta.allYardAllocations where yalloc.includeInYardDisplays() do
		index 		:= index + 1;
		mnuChild 	:= mnuMaster.getMenuItem(index); // check if the menu is already cloned
		
		if mnuChild = null then
			mnuChild := mnuMaster.loadSubMenu(index); // Clone menu
		endif;

		mnuChild.caption 		:= yalloc.code &amp; "...";
		mnuChild.visible 		:= true;
		mnuChild.enabled 		:= true;
		mnuChild.helpKeyword 	:= yalloc.description;
		mnuChild.userObject 	:= yalloc;
	endforeach; 
end;</source>
        <Parameter name="_ta" type="CM_TerminalArea"/>
    </JadeMethod>
