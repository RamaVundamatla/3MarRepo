    <JadeMethod name="cnwdad1_Test_ProgressForm" id="7278412c-2f48-451d-a6ca-fc6a740fb90c">
        <source>cnwdad1_Test_ProgressForm();
// --------------------------------------------------------------------------------
// Created:		02 September 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theProgressForm	: CnEcProgressForm;
	jobDescription	: String;
	theDataFile		: File;
	fileRecord		: String;
	bytesRead		: Integer;
	startTime		: Integer;
	
begin
	startTime	:=	app.clock();
	
	// Get the data file.
	create theDataFile transient;
	theDataFile.kind := File.Kind_Unknown_Text; // 26/2/16  cnwns1 PAR 36286 unicode version
	theDataFile.cnEcSetOpenName(true, false, null);
	
	// Set up the progress dialog.
	create theProgressForm;
	jobDescription	:=	"Reading " &amp; theDataFile.fileName &amp; "...";
	theProgressForm.startProgress(jobDescription, theDataFile.fileLength());
	theProgressForm.show();
	
	// Read the data file.
	while theDataFile.cnEcIsNotEndOfFile() do
		fileRecord	:=	theDataFile.readLine();
		bytesRead	:=	bytesRead + fileRecord.length();
		
		// ...process the file record...
		
		theProgressForm.updateProgress(bytesRead);
		
		if theProgressForm.isCancelled then
			if theProgressForm.checkCancel() then
				break;
			endif;
		endif;
	endwhile;
epilog
	delete theDataFile;
	delete theProgressForm;
	
	write "Progress Form completed in " &amp; startTime.cnEcClockDifference().numberFormat() &amp; " seconds.";
end;</source>
    </JadeMethod>
