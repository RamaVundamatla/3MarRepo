<Class name="DEV_SchemaGenericSection" id="2f293c1e-0607-4b9e-9caf-af3d388b6c71">
    <superclass name="DEV_SchemaObjectEntity"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="dev"/>
    <PrimAttribute name="content" id="60764d59-8600-40c6-a62a-3371f448e72d">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <CompAttribute name="contentArray" id="13f09b85-3b5e-43ec-98dd-910441980505">
        <type name="DEV_StringArray"/>
        <access>readonly</access>
    </CompAttribute>
    <ExplicitInverseRef name="mySchema" id="4a0d0fbe-22e7-4b49-a255-dadce9d29fbb">
        <kind>child</kind>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="DEV_Schema"/>
        <access>readonly</access>
        <Inverse name="DEV_Schema::allSections"/>
    </ExplicitInverseRef>
    <JadeMethod name="create" id="817a73e0-5178-4626-9c5c-91e7bf93d7d0">
        <updating/>
        <source>create(_name,
		_content 		: String; 
		_contentArray	: DEV_StringArray;
		_devSchema 		: DEV_Schema)
		::super(_name) updating;
/*

Purpose:			Constructor for DEV_SchemaGenericSection class

Parameters:			_name:			The name of the section
					_content:		The content in the section
					_contentArray:	The data in an array in case we are dealing with a large section
					_devSchema:		The schema the section belongs to

Return Value:		

Date		Who		Reason
27 October 2021	navpw1	Initial creation TFS: 52202

*/

begin
	//Set Attributes
	self.name := _name;
	self.content := _content;
	
	if (_contentArray &lt;&gt; null) then
		_contentArray.copy(self.contentArray);
	endif;
	
	//Set References
	self.mySchema := _devSchema;

end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_content" type="String"/>
        <Parameter name="_contentArray" type="DEV_StringArray"/>
        <Parameter name="_devSchema" type="DEV_Schema"/>
    </JadeMethod>
    <JadeMethod name="extractSection" id="bd68fcc0-0298-4bb3-9d48-d2c2823a8c14">
        <source>extractSection(_outputFile : File io);
/*

Purpose:			Extracts a generic section to file

Parameters:			_outputFile: File to write output string/line to

Return Value:		

Date		Who		Reason
15 November 2021	navpw1	Initial creation TFS: 52202

*/

vars
	outputText,
	contentText : String;
	
begin
	outputText := self.name &amp; CrLf;
	
	if (self.content &lt;&gt; null) then
		outputText &amp;= self.content &amp; CrLf;
		
	elseif (self.contentArray.size &gt; 0) then
		foreach contentText in self.contentArray do
			outputText &amp;= contentText &amp; CrLf;
		endforeach;
		
	endif;
	_outputFile.writeString(outputText);
	
end;</source>
        <Parameter name="_outputFile" type="File" usage="io"/>
    </JadeMethod>
</Class>
