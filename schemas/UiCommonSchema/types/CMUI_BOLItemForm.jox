    <JadeMethod name="doSave" id="dbe6bf3e-caa4-4af8-b329-f72a37d71c04">
        <updating/>
        <source>doSave(_modalResult : Integer) : Boolean updating;
//15 January 2010	cnwml2


vars
	result : Integer;
begin
	if self.myProxyBOLItem = null then
		return false;
	endif;
	
	if not self.myProxyBOLItem.isTransient then
		return false;
	endif;
	
	self.saveBOLItemDtls(self.myProxyBOLItem);
	
	on CM_Exception do app.validationExHandler(exception, app.myPassport);
	app.setContinueCMExceptions(true);
	app.myPassport.clearErrorsWarnings();
	
	self.myProxyBOLItem.validateForCreate(app.myPassport,null);
	if app.myPassport.hasErrorsOrWarnings then
//		result:=app.showErrorWarningDialog('Equipment Item', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);	// cnwrl1 08/06/2009 PAR 19826 - what it was
		result	:= app.showErrorWarningDialog(	"BOL Detail",
												app.myPassport,
												ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings );
		if  app.myPassport.hasErrors  or result &lt;&gt; IDOK  then
			return false;
		endif;
	endif;

	
	if self.isBaseFormModal then
		self.modalResult:=_modalResult;
	endif;

	self.unloadForm;
	
	
	
epilog

end;</source>
        <Parameter name="_modalResult" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doShowHSCodeSearchForm" id="25e542c7-6f8c-4917-a2ca-bc13fa1b1f80">
        <source>doShowHSCodeSearchForm() : CM_HarmonizedSystem;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 19 December 2022
TFS#		: 55584
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

begin
	return self.myAssistant.showHSCodeSearchForm(self, true);
end;</source>
        <ReturnType type="CM_HarmonizedSystem"/>
    </JadeMethod>
    <JadeMethod name="loadBOLItem" id="482cd606-75b9-442b-9005-c6660f2bf1a1">
        <updating/>
        <source>loadBOLItem()updating;
//15 January 2010	cnwml2
//
// Changed On	By			Reason
// ----------	--------	----------------------------------------------------------
// 15/04/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
// 19/12/2022	jlika1		TFS 55584 HS Code Combobox Usage
vars
	typeWeight, typeVolume, typeLength, typeWidth, typeHeight	: String;					// PAR #31155

begin
	typeWeight := app.getDefaultMeasurementForType(Type_Weight).shortName;				// PAR #31155
	typeVolume := app.getDefaultMeasurementForType(Type_Volume).shortName;				// PAR #31155
	typeLength := app.getDefaultMeasurementForType(Type_Length).shortName;				// PAR #31155
	typeWidth := app.getDefaultMeasurementForType(Type_Width).shortName;
	typeHeight := app.getDefaultMeasurementForType(Type_Height).shortName;
	
	self.cmbCargoType.setObject(app.myRoot.allCargoTypesById[self.myCurrentBOLItem.cargoType]);
	self.cmbCommodity.setIndexFromObject(app.myRoot.allCommodities[self.myCurrentBOLItem.commodity]);
	self.txtColour.text := self.myCurrentBOLItem.colour;
	self.txtMark.text := self.myCurrentBOLItem.markNumber;
	self.txtNumbOfItems.text := self.myCurrentBOLItem.quantity.asStringJMT();
	self.cmbHsCode.setIndexFromObject(app.myRoot.allHSCodesActive[self.myCurrentBOLItem.hsCode]);
	
	//self.txtVolume.text := self.myCurrentBOLItem.volume.asStringMeasurementJMT();												// PAR #31155
	//self.txtWeight.text := self.myCurrentBOLItem.weight.asStringMeasurementJMT();												// PAR #31155
	//self.txtLength.text := self.myCurrentBOLItem.length.asStringMeasurementJMT();												// PAR #31155
	//self.txtWidth.text := self.myCurrentBOLItem.width.asStringMeasurementJMT();												// PAR #31155
	//self.txtHeight.text := self.myCurrentBOLItem.height.asStringMeasurementJMT();												// PAR #31155
	self.tblVolume.setValues(app.convertMeasurementForDisplay(typeVolume, self.myCurrentBOLItem.volume) &amp; Space &amp; typeVolume);	// PAR #31155
	self.tblWeight.setValues(app.convertMeasurementForDisplay(typeWeight, self.myCurrentBOLItem.weight) &amp; Space &amp; typeWeight);	// PAR #31155
	self.tblLength.setValues(app.convertMeasurementForDisplay(typeLength, self.myCurrentBOLItem.length) &amp; Space &amp; typeLength);	// PAR #31155
	self.tblWidth.setValues(app.convertMeasurementForDisplay(typeWidth, self.myCurrentBOLItem.width) &amp; Space &amp; typeWidth);	// PAR #31155
	self.tblHeight.setValues(app.convertMeasurementForDisplay(typeHeight, self.myCurrentBOLItem.height) &amp; Space &amp; typeHeight);	// PAR #31155
	self.cmbConsignor.setObject(app.myRoot.allConsigneeConsignors[self.myCurrentBOLItem.consignorCode]);
	self.cmbConsignee.setObject(app.myRoot.allConsigneeConsignors[self.myCurrentBOLItem.consigneeCode]);
	
	self.txtRemarks.text := self.myCurrentBOLItem.remarks;
epilog	

end;</source>
    </JadeMethod>
    <JadeMethod name="loadCommodityCombo" id="d9044931-7e47-4f77-98ca-c1b78da5b637">
        <source>loadCommodityCombo(_firstTime : Boolean);
//27 January 2010	cnwml2
/*

Date		Who		Reason
11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/

vars
	cargoType : CM_CargoType;
	iter : Iterator;
	commodity : CM_Commodity;
	failedDAC  :CM_DataAccessController;
	tmpStr : String;
	idx : Integer;
begin
	if _firstTime then
		if self.myCurrentBOLItem &lt;&gt; null then
			cargoType := self.myCurrentBOLItem.myCargoType;
		endif;
	else
		cargoType := self.cmbCargoType.listObject.CM_CargoType;
	endif;
	
	self.cmbCommodity.clear();

	
	if cargoType &lt;&gt; null and cargoType.isCommodityRequired then
		self.cmbCommodity.enabled := true;
		if cargoType.allCommodities.size &gt; 0 then
			
			iter := cargoType.allCommodities.createIterator;
			
			while iter.next(commodity) do
				if not commodity.canUserAccessSelf(null, failedDAC, app.myPassport) then
					continue;
				endif;
				
				tmpStr := commodity.code &amp; Tab &amp; commodity.description;
				idx := cmbCommodity.addItem(tmpStr);
				self.cmbCommodity.itemObject[idx] := commodity;
			endwhile;
		else
			foreach commodity in app.myRoot.allCommodities do
				if commodity.allCargoTypes.size &gt; 0 then
					tmpStr := commodity.code &amp; Tab &amp; commodity.description;
					idx := self.cmbCommodity.addItem(tmpStr);
					self.cmbCommodity.itemObject[idx] := commodity;
				endif;
			endforeach;
		endif;
	else
		self.cmbCommodity.enabled := false;
	endif;
epilog
	delete iter;		// PAR #26678
end;</source>
        <Parameter name="_firstTime" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadConsigneeConsignorCombo" id="a4cd65f9-5892-48f5-9804-ae64076cf714">
        <source>loadConsigneeConsignorCombo();
//13 October 2009	cnwml2


vars
	con	: CM_ConsigneeConsignor;
	
begin
	foreach con in app.myRoot.allConsigneeConsignors do
		if con.isConsignee then
			self.cmbConsignee.addItemObject(con.code.trimRight &amp; Tab &amp; con.description, con);
		endif;
		
		if con.isConsignor then
			self.cmbConsignor.addItemObject(con.code.trimRight &amp; Tab &amp; con.description, con);
		endif;
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadHSCodeCombo" id="46e33589-b18e-4451-b6d0-a298e6bc0eb5">
        <source>loadHSCodeCombo();
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 19 December 2022
TFS#		: 55584
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	hsCode : CM_HarmonizedSystem;
begin
	self.cmbHsCode.clear();
	
	self.cmbHsCode.addItem("");
	
	foreach hsCode in app.myRoot.allHSCodesActive do
			self.cmbHsCode.itemObject[self.cmbHsCode.addItem(hsCode.getDisplayString())] := hsCode;		
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="saveBOLItemDtls" id="76d868da-7518-47c5-b706-4920d1d3b181">
        <source>saveBOLItemDtls(_pxyBOLDtl : CM_BOLDtl input);
//15 January 2010	cnwml2
//
// Changed On	By			Reason
// ----------	--------	---------------------------------------------------------
// 15/05/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
// 19/12/2022	jlika1		TFS 55584 HS Code Combobox Usage
vars

	cargoType : Integer;
	commodity : String;
	colour : String;
	mark : String;
	numbOfItems : Integer;
	
	volume : Decimal[14,4];
	weight : Decimal[14,4];
	length : Decimal[14,4];
	width : Decimal[14,4];
	height : Decimal[14,4];
	consignor : String;
	consignee : String;
	
	remarks : String;
	hsCode : String;
	myHsCode : CM_HarmonizedSystem;
begin
	if self.cmbCargoType.listObject &lt;&gt; null then
		cargoType := self.cmbCargoType.listObject.CM_CargoType.id; 
	endif;
	
	if self.cmbCommodity.listObject &lt;&gt; null then
		commodity := self.cmbCommodity.listObject.CM_Commodity.code;
	endif;
	
	if self.cmbHsCode.listObject &lt;&gt; null then
		myHsCode := self.cmbHsCode.listObject.CM_HarmonizedSystem;
		hsCode := myHsCode.id;
	endif;
	
	colour := self.txtColour.text;
	mark := self.txtMark.text;
	numbOfItems := self.txtNumbOfItems.text.asIntegerJMT();
	
	//volume := self.tblVolume.text.asDecimalJMT();					// PAR #31155
	//weight := self.tblWeight.text.asDecimalJMT();					// PAR #31155
	//length := self.tblLength.text.asDecimalJMT();					// PAR #31155
	//width := self.tblWidth.text.asDecimalJMT();					// PAR #31155
	//height := self.tblHeight.text.asDecimalJMT();					// PAR #31155
	volume := self.tblVolume.getConvertedValue();					// PAR #31155
	weight := self.tblWeight.getConvertedValue();					// PAR #31155
	length := self.tblLength.getConvertedValue();					// PAR #31155
	width := self.tblWidth.getConvertedValue();						// PAR #31155
	height := self.tblHeight.getConvertedValue();					// PAR #31155
	
	if self.cmbConsignor.listObject &lt;&gt; null then
		consignor := self.cmbConsignor.listObject.CM_ConsigneeConsignor.code;
	endif;
	
	if self.cmbConsignee.listObject &lt;&gt; null then
		consignee := self.cmbConsignee.listObject.CM_ConsigneeConsignor.code;
	endif;
	
	remarks := self.txtRemarks.text;
	
	_pxyBOLDtl.setProxy(myBOL, cargoType, commodity, colour, mark, numbOfItems, volume, weight, length, width, height, consignor, consignee, remarks);
	_pxyBOLDtl.setHSCode(hsCode);	
epilog

end;</source>
        <Parameter name="_pxyBOLDtl" type="CM_BOLDtl" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setCaption" id="7d429271-e55f-4767-b181-e9b414a1b8d5">
        <updating/>
        <source>setCaption(_caption: String) updating;
//27 January 2010	cnwml2


vars

	captionStr : String;
begin
	if self.mode = Mode_Add then
		captionStr:="Add BOL Item";
	else
		captionStr:="Edit BOL Item";
	endif;
	
	inheritMethod(captionStr);
epilog

end;</source>
