    <JadeMethod name="addLicenseDtl" id="b6c95a50-3b43-4051-8af3-77e4072731b0">
        <source>addLicenseDtl(_dtlName : String; _dtlType : Integer) : DEV_LicenseDtl;
// ---------------------------------------------------------------------------
// Created:     13 September 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpDtl	: DEV_LicenseDtl;
begin
//self.inspectModal;
	if _dtlName = null then
		app.msgBox('You must enter a name', 'Error', 0);
		return null;
	endif;
	
	if _dtlType &lt;&gt; LicenseType_System and
	   _dtlType &lt;&gt; LicenseType_EDI and
		_dtlType &lt;&gt; LicenseType_Subscription and
	   _dtlType &lt;&gt; LicenseType_EWS and  // ### JIRA 36920 05JAN2026 NAVAB1
	   _dtlType &lt;&gt; LicenseType_Terminal then
		app.msgBox('Invalid license type (' &amp; _dtlType.String &amp; ')', 'Error', 0);
		return null;
	endif;
	
	if _dtlType = LicenseType_System and
	   self.mySystemLicense &lt;&gt; null then
		app.msgBox('Client (' &amp; self.name &amp; ') already has a system license - you cannot add another', 'Error', 0);
		return null;
	endif;

	if _dtlType = LicenseType_EDI and
	   self.myEDILicense &lt;&gt; null then
		app.msgBox('Client (' &amp; self.name &amp; ') already has an EDI license - you cannot add another', 'Error', 0);
		return null;
	endif;
	
	//17 Jun 2020	NDL	TFS 49569
	if _dtlType = LicenseType_Subscription and
	   self.mySubscriptionLicense &lt;&gt; null then
		app.msgBox('Client (' &amp; self.name &amp; ') already has a Subscription license - you cannot add another', 'Error', 0);
		return null;
	endif;

	// ### JIRA 33543 12DEC2024 NAVAB1
	if _dtlType = LicenseType_EWS and
	   self.myEWSLicense &lt;&gt; null then
		app.msgBox('Client (' &amp; self.name &amp; ') already has a External Web Service license - you cannot add another', 'Error', 0);
		return null;
	endif;

	if _dtlType = LicenseType_Terminal and
	   (not self.canHaveTerminalLicenses()) then
		app.msgBox('Client (' &amp; self.name &amp; ') in only licensed for 1 terminal - you cannot add terminal licenses', 'Error', 0);
		return null;
	endif;
	
	if _dtlType = LicenseType_Terminal then
		if self.allLicenseDtls.includesKey(_dtlType, _dtlName) then
			app.msgBox('Client (' &amp; self.name &amp; ') already has a terminal with license name (' &amp; _dtlName &amp; ') - terminal license names must be unique', 'Error', 0);
			return null;
		endif;
	endif;

	create tmpDtl transient;
	tmpDtl.setForCreate(_dtlName, _dtlType, self);
	
	 // ### JIRA 36920 15JAN2026 NAVAB1
	if tmpDtl.type = LicenseType_EWS then
			tmpDtl.setTEMPEWS(self);
	endif;
	
	return tmpDtl;
	
end;</source>
        <Parameter name="_dtlName" type="String"/>
        <Parameter name="_dtlType" type="Integer"/>
        <ReturnType type="DEV_LicenseDtl"/>
    </JadeMethod>
    <JadeMethod name="canHaveTerminalLicenses" id="ca8cb04f-08ec-446c-9afe-a1ceadaf98d0">
        <source>canHaveTerminalLicenses() : Boolean;
// ---------------------------------------------------------------------------
// Created:     13 September 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	return (self.numTerminals &lt; 1);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createEWSLicense" id="93c491f8-f25f-47a0-aee4-93bb8d2eb9f2">
        <updating/>
        <source>createEWSLicense() updating;
/*
Purpose:	

Date		Who		Reason
16 December 2024	navab1	JIRA 33543
*/

vars

begin
	if self.myEWSLicense &lt;&gt; null then // created from XML
		return;
	endif;
	
	create self.myEWSLicense transient;
	self.myEWSLicense.createEWSLicense(self);
epilog

end;</source>
    </JadeMethod>
