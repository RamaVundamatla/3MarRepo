    <JadeMethod name="disableCriteriaType" id="23b06035-6332-49c4-9101-524bd5aedc22">
        <source>disableCriteriaType( _criteriaType: CM_YACriteriaType );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 November 2015	cnwndl1	Initial creation	Par 37094

*/

vars

	index : Integer;

begin

	index := self.cmbCriteriaType.findObject( _criteriaType );
	if index &gt; 0 then
		self.cmbCriteriaType.itemEnabled[index] := false;
	endif;
	
epilog

end;</source>
        <Parameter name="_criteriaType" type="CM_YACriteriaType"/>
    </JadeMethod>
    <JadeMethod name="doApplyBubbleHelp" id="b56772cc-ffd5-4828-b74b-8c5117b61c18">
        <updating/>
        <source>doApplyBubbleHelp() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 February 2014	cnwndl1	Initial creation	Par 33542

*/

vars

begin

	if self.txtCriteriaValue &lt;&gt; null then
		if cmbCriteriaType &lt;&gt; null and self.cmbCriteriaType.listObject &lt;&gt; null then
			if self.btnValuePicker = null or not self.btnValuePicker.visible then
				self.txtCriteriaValue.bubbleHelp := app.getErrorString(CriteriaValuesStringFormat);
			else
				self.txtCriteriaValue.bubbleHelp := null;
			endif;
		else
			self.txtCriteriaValue.bubbleHelp := null;
		endif;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doCriteriaChanged" id="2f171f58-fd57-4db1-ac7c-f03ecb5eb04a">
        <updating/>
        <source>doCriteriaChanged() updating;

/*

Purpose:		This method is invoked on the form when the criteria value is changed  (initially doing on lostFocus regardless of change)

Parameters:			

Return Value:		


Date			Who		Reason
06 August 2008	consw1	Initial creation

*/

vars
	criteriaType : CM_YACriteriaType;
	
begin
	self.enableValuePicker();

	if self.form.isKindOf(CMUI_YAMaintForm) then
		criteriaType := self.getCriteriaType;
		if criteriaType &lt;&gt; null and criteriaType.isKindOf(CM_YATypeVoyage) then
			self.updateVoyages();
		endif;
	endif;
	if self.form.isKindOf(CMUI_YAMaintInvoiceAllocation) then // PAR 35833
		self.form.CMUI_YAMaintInvoiceAllocation.myCurrentYAControl := self; // PAR 35833
	endif;
	if self.form.isKindOf(CMUI_YAMaintRailForm) then
		self.form.CMUI_YAMaintRailForm.myCurrentYAControl := self;
	endif;
	if self.form.isKindOf(CMUI_YAMaintVoyForm) then
		self.form.CMUI_YAMaintVoyForm.myCurrentYAControl := self;
	endif;
	if self.form.isKindOf(CMUI_YAMaintForm) then //cnwrd1 ccms 2115 par 28185 12.9.2011 - should be all of these now...
		self.form.CMUI_YAMaintForm.myCurrentYAControl := self;
	endif;
	if self.form.isKindOf(CMUI_YAMaintContractFrom) then 
		self.form.CMUI_YAMaintContractFrom.myCurrentYAControl := self;
	endif;
	//epr par 30823 28/1/13 
	if self.form.isKindOf(CMUI_YAMWhatIfForm) then
		self.form.CMUI_YAMWhatIfForm.myCurrentYAControl :=self;
	endif;
	
	if self.formCriteriaChangeMethodName &lt;&gt; null then
		self.form.sendMsg(self.formCriteriaChangeMethodName);
	endif;
	
	//24 Feb 2014	NDL	Par 33542
	self.doApplyBubbleHelp();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doCriteriaTypeSelected" id="3f52325e-7c60-400a-afb9-6e08896a28c3">
        <updating/>
        <source>doCriteriaTypeSelected() updating;
/* Changes

Date		Name	TFS#		Description
============================================================================
13/08/2013	cnwdap1	PAR #32123 	Make Colour a pickable criteia depending on terminal config setting
21/06/2019	jlgka1	TFS 45245	JMT - Unable to edit Criteria Selection in Package Maintenance.
27/05/2025	navdap1	MTN-34981 MTN -Yard Allocations - Storing Cargo Based on a Date Range
============================================================================*/
vars
	criteriaType		: CM_YACriteriaType;
	terminal			: CM_Terminal; // jlgka1 TFS 45245
begin
	criteriaType :=	self.cmbCriteriaType.listObject.CM_YACriteriaType;
	
	if criteriaType = null then
		self.setBooleanVisible(false);
		self.txtCriteriaValue.visible := true;
		self.txtCriteriaValue.enabled := false;
		self.btnValuePicker.visible := true;
	else
		if criteriaType.isBooleanType() then
			self.useYesNoOptionButtons();
			self.setBooleanVisible(true);
			self.txtCriteriaValue.visible := false;
			self.btnValuePicker.visible := false;
		elseif criteriaType.isDateRangeType() then			// MTN-34981
			self.useDateRangeControls();
			self.setBooleanVisible(false);
			self.txtCriteriaValue.visible := false;
			self.btnValuePicker.visible := false;
		else
			self.setBooleanVisible(false);
			self.txtCriteriaValue.visible := true;
			self.txtCriteriaValue.enabled := true;
			//+cnwml2 PAR24472
			if criteriaType.isKindOf(CM_YATypeHazardous) then
				self.btnValuePicker.visible := true;
			else
				// jlgka1 TFS 45245 --&gt;
				if criteriaType.isKindOf(CM_YATypeColour) then
					terminal := self.getMyTerminalFromForm();
					if terminal &lt;&gt; null then 
						if terminal.getConfig(ValidateColour).Boolean then	// PAR #32123
							self.btnValuePicker.visible := true;																		// PAR #32123
							self.txtCriteriaValue.readOnly := true;																		// PAR #32123
						else	
							self.btnValuePicker.visible := false;
							self.txtCriteriaValue.readOnly := false;
						endif;	
					else
						self.btnValuePicker.visible := not criteriaType.canFind();
					endif;
					// jlgka1 TFS 45245 &lt;--
				else																											// PAR #32123
					self.btnValuePicker.visible := not criteriaType.canFind();					//+cnwml2 PAR23882
				endif;	
			endif;
		endif;
	endif;

	self.setInitialValues();
	self.doCriteriaChanged();
end;</source>
    </JadeMethod>
    <JadeMethod name="doDisableInputControls" id="de4b9636-1df3-42c1-8d26-41ed3b90bfd6">
        <source>doDisableInputControls();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
// 04/05/2023	navkc1	Bug 57484: EUP - Cargo Allocation Transaction Map Permissions

*/

vars

begin
	// Left "btnValuePick" enalbe so user can still view what's available
	
	self.chkCriteriaValue.enabled := false;
	self.cmbCriteriaType.enabled := false;
	self.txtCriteriaValue.enabled := false;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doValuePicker" id="39c579f8-dca6-4c91-b96c-9f51ed35faf8">
        <updating/>
        <source>doValuePicker() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
25 August 2008	consw1	Initial creation
04/05/2023		navkc1	Bug 57484: EUP - Cargo Allocation Transaction Map Permissions
*/

vars
	theForm 		: CMUI_YACriteriaSelectForm;
	filter 		: Integer;
begin
	if self.getCriteriaType() = null then
		return;
	endif;
	
	// 04/05/2023	navkc1	Bug 57484 - Use sub class for Invoicing so permissions work correctly
	if self.form.isKindOf(CMUI_YAMaintInvoiceAllocation) then
		theForm := app.loadForm(CMUI_YACriteriaInvSelectForm, CMUI_Assistant, false, false, true, self.form.CM_BaseForm.myTerminal, null).CMUI_YACriteriaInvSelectForm;
	else
		theForm := app.loadForm(CMUI_YACriteriaSelectForm, CMUI_Assistant, false, false, true, self.form.CM_BaseForm.myTerminal, null).CMUI_YACriteriaSelectForm;
	endif;
	
	if theForm = null then
		return;
	endif;
	
	if self.form.isKindOf(CMUI_YAMaintForm) then //+ cnwmd1, Par 21178
		filter := self.form.CMUI_YAMaintForm.getFilter();
	endif;

	//epr par 30823 28/1/13
	if self.form.isKindOf(CMUI_YAMWhatIfForm) then
		//limit cargo type to only be able to select one not many
		if self.getCriteriaType.type = YACriteriaType_CargoType then
			theForm.canOnlySelectOne:=true;
		endif;
		
	endif;
	
	////epr TFS 1822 28/4/16 removed value oids
	theForm.set( self.getCriteriaType(), self.getValue().String, self.myVoyagesReference, filter, self.masterControl );	//cnwmc5 - PAR 32155
	theForm.setParentForm(self.form.CM_BaseForm);
	theForm.centreOverParent(0); // ### TFS 51219 25MAY2021 NAVAB1
	theForm.showModal();
	
	if theForm.modalResult = IDOK then
		//epr TFS 1822 28/4/16 
		self.txtCriteriaValue.text := theForm.criteriaValue;
		self.doCriteriaChanged();
	endif;
	
	//12 Dec 2013	NDL	Par 33184
	if self.form.CM_BaseForm.isKindOf(CMUI_ObjectCriteriaLineForm) then 
		self.form.setFocus();
	endif;

epilog
	delete theForm;
end;</source>
    </JadeMethod>
    <JadeMethod name="enableValuePicker" id="21300bbf-4e48-41d3-9769-9c69d8370814">
        <source>enableValuePicker();

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
25 August 2008	consw1	Initial creation

*/

vars
	pattern: CMIF_YAPattern;
	txt: String;
	
begin
	if self.isBooleanVisible or cmbCriteriaType.listObject = null then
		self.btnValuePicker.enabled := false;
		return;
	endif;

	txt := self.getValue().String;
	
	if txt &lt;&gt; null then
		create pattern transient;
		pattern.setPattern( self.getValue().String, CMIF_YAPattern.YAPattern_Wildcard );
		// If this there are wildcard patterns then just return.
		//if pattern.hasWildcard then
			//self.btnValuePicker.enabled := false;		//-cnwml2 PAR23882
			//return;									//-cnwml2 PAR23882
		//endif;
	endif;
	
	self.btnValuePicker.enabled := true;
	
epilog
	delete pattern;
end;</source>
    </JadeMethod>
    <JadeMethod name="getBooleanValue" id="834c18a7-51d4-4901-9dd9-97491d09d648">
        <source>getBooleanValue() : Integer protected;

/*

Purpose:		Get integer representation of boolean value

Parameters:			

Return Value:		


Date			Who		Reason
14 August 2008	consw1	Initial creation

*/

vars
	cntlOptYes, cntlOptNo, cntlOptEither : CMUI_OptionButton;

begin
	self.getYesNoOptionButtons( cntlOptYes, cntlOptNo, cntlOptEither );

	if cntlOptEither &lt;&gt; null and
	   cntlOptEither.value then
		return CM_YADataBoolean.VALUE_EITHER;
	endif;

	if cntlOptYes = null then	
		if self.chkCriteriaValue.value then
			return CM_YADataBoolean.VALUE_TRUE;
		endif;
		return CM_YADataBoolean.VALUE_FALSE;
	endif;
	
	if cntlOptYes.value then
		return CM_YADataBoolean.VALUE_TRUE;
	endif;

	return CM_YADataBoolean.VALUE_FALSE;

epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getCriteriaType" id="7e9dcb77-1be8-47b9-8c25-9b2ec48889f0">
        <source>getCriteriaType(): CM_YACriteriaType;
//30 July 2008	cnwdw1	
// Return the selected criteria type, or null if none selected
begin
	return cmbCriteriaType.listObject.CM_YACriteriaType;
end;</source>
        <ReturnType type="CM_YACriteriaType"/>
    </JadeMethod>
    <JadeMethod name="getDateRangeMasks" id="bd69e0b2-f2b9-4e64-a78d-6839a1b0d35a">
        <source>getDateRangeMasks(_startDate, _endDate : CMUI_DateMaskYACriteriaCtrl output) protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 27/05/2025	navdap1		MTN-34981 MTN -Yard Allocations - Storing Cargo Based on a Date Range
//
vars

begin
	if self.chkCriteriaValue.userObject = null then
		return;
	endif;
	
	if not self.chkCriteriaValue.userObject.isKindOf(CMUI_DateMaskYACriteriaCtrl) then
		return;
	endif;
	
	_startDate := self.chkCriteriaValue.userObject.CMUI_DateMaskYACriteriaCtrl;
	_endDate := _startDate.userObject.CMUI_DateMaskYACriteriaCtrl;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_startDate" type="CMUI_DateMaskYACriteriaCtrl" usage="output"/>
        <Parameter name="_endDate" type="CMUI_DateMaskYACriteriaCtrl" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getDateRangeValue" id="71b7be24-de56-4526-8281-a37d6d71f496">
        <source>getDateRangeValue() : String protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 28/05/2025	navdap1		Initial creation MTN-34981 MTN -Yard Allocations - Storing Cargo Based on a Date Range
//
vars
	startD, endD : CMUI_DateMaskYACriteriaCtrl;
	value : String;

begin
	self.getDateRangeMasks(startD, endD);
	if startD.getDate &lt;&gt; null then
		value := startD.getDate.asStringJMT;
	endif;
	value := value &amp; "|";
	if endD.getDate &lt;&gt; null then
		value := value &amp; endD.getDate.asStringJMT;
	endif;
	
	return value;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayForGroupName" id="fb56745e-d807-45aa-a882-e51f749b69a4">
        <source>getDisplayForGroupName() : String;

/*

Purpose:		

Parameters:			

Return Value:	Display string for Group Name


Date			Who		Reason
05 August 2008	consw1	Initial creation

*/

vars
	valueText : String;
	
begin
	if self.isBooleanVisible() then
		valueText := self.cmbCriteriaType.text;
		if valueText = "" then
			return "";
		endif;
		if self.getBooleanValue() = CM_YADataBoolean.VALUE_TRUE then
			return valueText;
		endif;
		if valueText[1:3].toLower = "is " then
			valueText := valueText[4:valueText.length-3];
		endif;
		return "Not " &amp; valueText;
	endif;
	
	return self.txtCriteriaValue.text;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayForGroupNameNumbers" id="954e79b7-0244-4b37-b5fd-9e3a844474d9">
        <source>getDisplayForGroupNameNumbers() : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 December 2009	cnwas3	Initial creation

*/

vars
	valueText : String;
	
begin
	if self.isBooleanVisible() then
		valueText := self.cmbCriteriaType.text;
		if valueText = "" then
			return "";
		endif;
		if self.getBooleanValue() = CM_YADataBoolean.VALUE_TRUE then
			valueText := self.getShortDescription(valueText);
			if valueText &lt;&gt; null then
				return valueText;
			else
				return self.cmbCriteriaType.text;
			endif;
		endif;
		if valueText[1:3].toLower = "is " then
			valueText := valueText[4:valueText.length-3];
		endif;
		return "Not " &amp; valueText;
	endif;
	
	return self.txtCriteriaValue.text;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOldGroupName" id="5469ca14-7a35-493f-9a52-8950b7a85390">
        <source>getOldGroupName(): String;
//05 February 2009	cnwdw1	
//
vars

begin
	return self.oldGroupName;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getShortDescription" id="6e40aada-3211-47b0-a409-10ce2241ee0b">
        <source>getShortDescription(_text : String) : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 December 2009	cnwas3	Initial creation

*/

vars
	text : String;
begin
	text := _text.toLower();
	if text = "is forty" then
		return "40";	
	elseif text = "is thirty" then
		return "30";	
	elseif text = "is forty five" then
		return "45";
	elseif text = "is fifty three" then
		return "53";
	elseif text = "requires power" then
		return app.getErrorString(Requires_power);
	elseif text = "is hazardous" then
		return app.getErrorString(Hazardous);
	elseif text = "is over dimensional" then
		return app.getErrorString(Over_dimensional);
	elseif text = "water cooled" then
		return app.getErrorString(Water_cooled);
	else
		return null;
	endif;
epilog

end;</source>
        <Parameter name="_text" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getValue" id="d2495999-a060-4b8d-8df9-992412570d96">
        <source>getValue(): Any;
//30 July 2008	cnwdw1	
// Return the value of the criteria
// Changed On	By			Reason
// ----------	--------	---------------------------------------------
// 28/05/2025	navdap1		MTN-34981 MTN -Yard Allocations - Storing Cargo Based on a Date Range
vars

begin
	if self.isBooleanVisible() then
		return self.getBooleanValue;
	elseif self.isDateRangeVisible() then			// MTN-34981
		return self.getDateRangeValue();
	else
		return self.txtCriteriaValue.text;
	endif;
end;</source>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="getValueTypeProduct" id="94df8c9a-72fa-4ac4-8288-b4d32ee33658">
        <source>getValueTypeProduct(_value : String) : String;

/*

Purpose:		Get the code based on the oid

Date			Who		Reason
11 July 2011	cnwmh5	Initial creation #27772

*/

vars

	subtype		: CM_Product;

	tokens		: StringArray;
	
	str 		: String;
	subtypeStr	: String;

begin

	create tokens transient;
	tokens := _value.getTokens();
	foreach subtypeStr in tokens do 
		if str &lt;&gt; null then
			str := str &amp; ", ";
		endif;
		subtype := subtypeStr.asObject.CM_Product;
		if subtype &lt;&gt; null then
			str := str &amp; subtype.getYADisplay();
		endif;
	endforeach;

	return str;
	
epilog
	delete tokens;
end;</source>
        <Parameter name="_value" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getYesNoOptionButtons" id="9024b5de-de35-4993-922c-3aa89cd1df2f">
        <source>getYesNoOptionButtons( _cntlOptYes, _cntlOptNo, _cntlOptEither : CMUI_OptionButton output ) protected;

/*

Purpose:		Get Yes/No option buttons	

Parameters:			

Return Value:	Returns Yes/No option buttons.  Null values is a valid.	


Date			Who		Reason
14 August 2008	consw1	Initial creation
28 May 2025		navdap1	MTN-34981 MTN -Yard Allocations - Storing Cargo Based on a Date Range
*/

vars

begin
	if self.chkCriteriaValue.userObject = null then
		return;
	endif;
	
	if not self.chkCriteriaValue.userObject.isKindOf(CMUI_OptionButton) then	// MTN-34981
		return;
	endif;
	
	_cntlOptYes := self.chkCriteriaValue.userObject.CMUI_OptionButton;
	
	_cntlOptNo := _cntlOptYes.userObject.CMUI_OptionButton;

	_cntlOptEither := _cntlOptNo.userObject.CMUI_OptionButton;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_cntlOptYes" type="CMUI_OptionButton" usage="output"/>
        <Parameter name="_cntlOptNo" type="CMUI_OptionButton" usage="output"/>
        <Parameter name="_cntlOptEither" type="CMUI_OptionButton" usage="output"/>
    </JadeMethod>
    <JadeMethod name="hasValue" id="c50964bf-07fc-4f08-906b-cceb90d3e685">
        <source>hasValue() : Boolean;

/*

Purpose:		Does the control have a value set?

Parameters:			

Return Value:	Returns true indicating the value requires saving


Date		Who		Reason
06 August 2008	consw1	Initial creation
28 May 2025		navdap1	MTN-34981 MTN -Yard Allocations - Storing Cargo Based on a Date Range
*/

vars

begin
	if not self.visible or cmbCriteriaType.listIndex = -1 then
		return false;
	endif;

	if self.isBooleanVisible() then
		return true;
	endif;
	
	if self.isDateRangeVisible() then		// MTN-34981
		return true;
	endif;
	
	return self.txtCriteriaValue.text.trimBlanks &lt;&gt; null;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isBooleanVisible" id="c12d9b44-8d03-491b-9395-2fb848e0b7e4">
        <source>isBooleanVisible() : Boolean protected;

/*

Purpose:		Get visiblity for Boolean controls

Parameters:			

Return Value:		


Date			Who		Reason
14 August 2008	consw1	Initial creation

*/

vars
	cntlOptYes, cntlOptNo, cntlOptEither : CMUI_OptionButton;

begin
	self.getYesNoOptionButtons( cntlOptYes, cntlOptNo, cntlOptEither );

	if cntlOptYes &lt;&gt; null then
		return cntlOptYes.visible;
	endif;
	
	return self.chkCriteriaValue.visible;
	
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isDateRangeVisible" id="3b6f3aa8-d449-4479-af01-4df75ce27f38">
        <source>isDateRangeVisible() : Boolean protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
