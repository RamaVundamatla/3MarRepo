    <JadeMethod name="getObjectForETRow" id="6e516365-8843-4f92-991b-b69bb9e10fb0">
        <source>getObjectForETRow(pAttrName : String): CM_Object;

/*
	Created on 25 February 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	brItem : CM_BookingRefItem;
begin
	if not isTransient then
		brItem := allBookingRefItems.first;
		if brItem = null then
			return null;
		endif;
	endif;
	if pAttrName = ETRow_Commodity then
		if commodity &lt;&gt; null then
			return app.myRoot.allCommodities[brItem.commodity];
		endif;
//	elseif pAttrName = ETRow_BolType then // adm 160310 Par 22937 remove bolType
//		return brItem.getBOLType;
	elseif pAttrName = ETRow_CargoType then
		return brItem.myCargoType;
	elseif pAttrName = ETRow_CargoTypeDescr then	// dh 11/6/2008 added for par 16953
		return brItem.myCargoType;					//
	elseif pAttrName = ETRow_ConsigneeCode then
		return myConsignee;
	elseif pAttrName = ETRow_ConsignorCode then
		return myConsignor;	
	elseif pAttrName = ETRow_DestinationPort then
		if destinationPort &lt;&gt; null then
			return app.myRoot.allPorts[destinationPort];
		endif;
	elseif pAttrName = ETRow_DischargePort then
		if dischargePort &lt;&gt; null then
			return app.myRoot.allPorts[dischargePort];
		endif;
	elseif pAttrName = ETRow_MyTranshipToPort then
		if myTranshipToPort &lt;&gt; null then
			return app.myRoot.allPorts[myTranshipToPort.code];
		endif;
	elseif pAttrName = ETRow_OperatorCode then
		return myOperator;
	elseif pAttrName = ETRow_MyOperator then
		return myOperator;
	elseif pAttrName = ETRow_VoyageCode then
		return myVoyage;		
	elseif pAttrName = ETRow_IsoType then
		return app.myRoot.allISOTypes[brItem.isoType];
	elseif pAttrName = ETRow_IsoGroup then
		return app.myRoot.allISOTypes[brItem.isoType].myISOTypeGroup;
	elseif pAttrName = ETRow_Carrier then
		return myCarrier;	
	elseif pAttrName = ETRow_Product then
		return brItem.myProduct;	
	elseif pAttrName = ETRow_StatusString then
		return app.myRoot.allImexStatuses[TI_IMEX_STATUS_EXPORT];
	else
		return null;
	endif;
end;</source>
        <Parameter name="pAttrName" type="String"/>
        <ReturnType type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="getOnsiteTrackedItems" id="02d5c997-3171-4417-bcaa-3cf5ba7ba83a">
        <source>getOnsiteTrackedItems(_coll :Collection input;_contextObj : Object);
/*

Purpose:			Get all onsite items

Parameters:			_coll : the collection to be filled

Return Value:		null

Date		Who		Reason
04 Dec 2024	navhl20 Bug MTN-33579: EUP - Attach cargo from booking is not doing anything for release ship work order
*/

vars
	booking		: CM_BookingRef;
	ti			: CM_TrackedItem;
	iter		: Iterator;
begin
	//make sure we're working with the real object
	if self.isTransient then
		booking := app.myProxyManager.getRealObject(self).CM_BookingRef;
		if booking &lt;&gt; null then
			booking.getOnsiteTrackedItems (_coll,_contextObj);
			return;
		endif;
	endif;

	iter := self.allTIsByState.createIterator();
	
	//get all items with state &gt; notified
	self.allTIsByState.startKeyGeq(TI_STATE_UNDEFINED, "", 0,iter);
	while iter.next(ti) do
		//check state key
		if iter.getCurrentKey(1).Integer &gt;= TI_STATE_NOTIFIED then
			break;
		endif;
		_coll.add (ti);
	endwhile;

	//get all items with state &gt; prenote and state &lt; merged
	self.allTIsByState.startKeyGeq(TI_STATE_OFFSITE, "", 0, iter);
	while iter.next(ti) do
		//check state key
		if iter.getCurrentKey(1).Integer &gt;= TI_STATE_MERGED then
			break;
		endif;
		_coll.add (ti);
	endwhile;
epilog
	delete iter;
end;</source>
        <Parameter name="_coll" type="Collection" usage="input"/>
        <Parameter name="_contextObj" type="Object"/>
    </JadeMethod>
