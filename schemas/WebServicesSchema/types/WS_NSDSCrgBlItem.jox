    <JadeMethod name="setProxyObject" id="e3b156fd-84ef-49aa-8931-17c6a98d79be">
        <updating/>
        <source>setProxyObject(_any: Any) updating;
/*
Purpose:			

Date		Who		Reason
31 May 2022	navab1	TFS 53105
*/

vars
	helper 	: CMIF_CrgBlItem;
	ewsOpsView: CM_EWSActivityOpsview;
	sch : Schema;
	cls : Class;
	props : PropertyNDict;
	prop : Property;
	propertyValid : Boolean;
	value : Any;
begin

	
	inheritMethod(_any);
	
	create helper transient;
	create ewsOpsView transient;
	ewsOpsView.initialiseActivity("","",_any.CM_Object.getMyTerminal(),_any.CM_Object, null,null,false,null);
	helper.initializeForActivity(_any, ewsOpsView);
	
	self.bl_gkey := helper.bl_gkey;
	self.brand := helper.brand;
	self.bulk_unit := helper.bulk_unit;
	self.client_id := helper.client_id;
	self.commodity_gkey := helper.commodity_gkey;
	self.equipment_handling_code_gkey := helper.equipment_handling_code_gkey;
	self.gkey := helper.gkey;
	self.handling_code_gkey := helper.handling_code_gkey;
	self.is_bulk := helper.is_bulk;
	self.is_direct := helper.is_direct;
	self.model := helper.model;
	self.nbr := helper.nbr;
	self.oid := helper.oid;
	self.package_height_cm := helper.package_height_cm;
	self.package_length_cm := helper.package_length_cm;
	self.package_type_gkey := helper.package_type_gkey;
	self.package_volume_cu_cm := helper.package_volume_cu_cm;
	self.package_weight_kg := helper.package_weight_kg;
	self.package_width_cm := helper.package_width_cm;
	self.piece_bulk_unit := helper.piece_bulk_unit;
	self.piece_height_cm := helper.piece_height_cm;
	self.piece_is_bulk := helper.piece_is_bulk;
	self.piece_length_cm := helper.piece_length_cm;
	self.piece_package_type_gkey := helper.piece_package_type_gkey;
	self.piece_quantity := helper.piece_quantity;
	self.piece_weight_kg := helper.piece_weight_kg;
	self.piece_width_cm := helper.piece_width_cm;
	self.product_type_gkey := helper.product_type_gkey;
	self.quantity := helper.quantity;
	self.sequence := helper.sequence;
	self.tableName := helper.tableName;
	self.temp_max_C := helper.temp_max_C;
	self.temp_min_C := helper.temp_min_C;
	self.temp_reqd_C := helper.temp_reqd_C;
	self.temp_show_fahrenheit := helper.temp_show_fahrenheit;
	self.weight_total_kg := helper.weight_total_kg;	
	
	/* this works fine:
	sch := rootSchema.getSchema("WebServicesSchema");
	cls := sch.getClass("WS_NSDSCrgBlItem");
	create props transient;
	cls.getPropertiesAllSuperclass(props);
	
	foreach prop in props discreteLock do
		value := helper.tryGetPropertyValue(prop.name,propertyValid);
		if propertyValid then
			self.setPropertyValue(prop.name,value);
		endif;
	endforeach;
	*/

epilog
	delete helper;
	delete ewsOpsView;
	delete props;
end;</source>
        <Parameter name="_any" type="Any"/>
    </JadeMethod>
