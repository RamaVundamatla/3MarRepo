    <JadeMethod name="doOpenCargoEnquiry" id="c8f81369-a841-44ef-90b1-b2173118541a">
        <source>doOpenCargoEnquiry(_job : CM_VoyageJob);
/*

Purpose:			


Return Value:		


Date		Who		Reason
23 January 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	objArray : ObjectArray;
	firstTI : CM_TrackedItem;
	realJob, job : CM_VoyageJob;
begin

	if self.myJobController &lt;&gt; null then
		job:=self.myJobController.currentBubbleJob;
	else
		return;
	endif;
	if job = null then
		return;
	endif;
	
	if job.isTransient then
		realJob:=app.myProxyManager.getRealObject(job).CM_VoyageJob;
	else
		realJob:=job;
	endif;
	
	if realJob = null then 
		return;
	endif;

	create objArray transient;
	realJob.allReceiveTrackedItems.copy(objArray);
	realJob.allReleaseTrackeditems.copy(objArray);
	realJob.allSOBTrackedItems.copy(objArray);
	
	if objArray.size = null then
		return;
	endif;

	self.myAssistant.showCargoEnquiryForTIs(objArray.first.CM_TrackedItem, objArray, self.myMasterMenuAction, false);

epilog
	delete objArray;
end;</source>
        <Parameter name="_job" type="CM_VoyageJob"/>
