    <JadeMethod name="isOpsViewData" id="22e2d0dd-4b10-4167-8d76-c30bb0c22d78">
        <source>isOpsViewData(): Boolean;
/*
Purpose:			

Date		Who		Reason
15 December 2021	navab1	TFS 51855
*/

vars
	nowhere : String;
begin
	nowhere := app.getErrorString(Nowhere);
	
	
	if self.isRealMove() then
		if self.sourceLocn = "" 
		or self.sourceLocn = nowhere
		or self.targetLocn = ""
		or self.targetLocn = nowhere     then
			return false;
		endif;
		
		if self.myTrackedItem &lt;&gt; null then
			if self.myTrackedItem.isOpsViewData() then // ### TFS 53105 02JUN2022 NAVAB1
				
				return true;

			endif;
		endif;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isRealMove" id="8ea7861e-482b-420e-970f-b221ee9f458e">
        <source>isRealMove() : Boolean;
/*
Purpose: Is this a Real Move

Parameters:			

Return Value:		

Date		Who		Reason
27 April 2012	cnwdw1	Initial creation
*/
vars

begin
	if mode &lt;&gt; REAL_MODE then
		return false;
	endif;
	
//	if self.getLocationType(self.sourceLocn) = CM_LocationsController.Location_Type_UNKNOWN or
//	   self.getLocationType(self.targetLocn) = CM_LocationsController.Location_Type_UNKNOWN then
//		return false;
//	endif;
	
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
