    <JadeMethod name="showExtraInfo" id="a7a3f802-9c83-4165-acbf-a65a48fecc41">
        <updating/>
        <source>showExtraInfo(_obj : Object) updating;
// ---------------------------------------------------------------------------
// Created:     22 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 25 June 2003 sgp			Use transient CM_DataContainer instead of arrays
//							to pass data around.
// ---------------------------------------------------------------------------

vars
	dataContainer : CM_DataContainer;
	numberOfColumns : Integer;
	theObject : Object;
	
begin
	theObject := _obj;
	self.tblGridAreaInfo.rows := 0;
	numberOfColumns := self.getNumberOfColumns();
	
	if not global.isValidObject(theObject) then
		return;
	endif;

	if self.myCurrentInfoNoteObject &lt;&gt; null then
		self.endNotification(self.myCurrentInfoNoteObject,Object_Update_Event);
	endif;
	
	if self.isShowingExtraFromNotify then
		if self.myCurrentRoRoLaneLenExceeded &lt;&gt; null then
			// the lane that we are currently showing over-planned/queued info for has been modified
			// so we need to refresh the over-queued/planned info for this lane
			theObject := self.myCurrentRoRoLaneLenExceeded;
		endif;
	endif;
	
	if theObject.isKindOf(CMIF_RoRoLaneLenExceeded) then
		self.myCurrentInfoNoteObject := theObject.CMIF_RoRoLaneLenExceeded.myLocationsController;
	else
		self.myCurrentInfoNoteObject := theObject;
	endif;
	
	self.beginNotification(self.myCurrentInfoNoteObject,Object_Update_Event,Response_Continuous,null);
	
	self.tblGridAreaInfo.alignment := Table.Alignment_Left_Top;
	
	//######################
	// DISPLAY INFO
	create dataContainer transient;
	dataContainer.headerColour := self.colorHeadingColumn;
	dataContainer.valueColour := self.colorValueColumn;
	
	dataContainer.displayMode := self.myCurrentDrawingController.displayMode;
	self.getExtraInfoForObject(theObject, dataContainer);
	self.tblGridAreaInfo.userObject := theObject; // this is used to redraw this info
	
	self.showExtraInformation(dataContainer, self.tblGridAreaInfo, false,
			self.mnuGridBigFont.checked, numberOfColumns, self.getNumberOfColsForData,
			self.getNumberOfColsForHeader, self.getNumberOfColsForIcon,
			self.getNumberOfColsForLabel);

	self.doResizeColumnWidths(self.tblGridAreaInfo, true);

epilog
	if dataContainer &lt;&gt; null then
		delete dataContainer;
	endif;
end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="showExtraInfoForObject" id="f0afd034-c1b5-41c1-aa65-ce35091d1eec">
        <updating/>
        <source>showExtraInfoForObject(_theObject : Object input) updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		This is used to update the macro info if a note comes thru for the object being displayed there
// ---------------------------------------------------------------------------
vars

begin
	self.tblGridAreaInfo.rows := 0;
	if _theObject &lt;&gt; null then
		self.showExtraInfo(_theObject);
	endif;
epilog
end;</source>
        <Parameter name="_theObject" type="Object" usage="input"/>
    </JadeMethod>
    <JadeMethod name="showHideToolbars" id="8ef7cd0f-9d66-4061-9ab1-4fb0e90fde47">
