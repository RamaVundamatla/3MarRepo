    <JadeMethod name="doBaseFormCancel" id="33aa3381-53f4-460f-b274-373b8cccd7da">
        <updating/>
        <source>doBaseFormCancel() updating, protected;
// ---------------------------------------------------------------------------
// Created:		19 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if not self.myTerminal.getConfig(InvoiceMultiTaxRates).Boolean then
		app.msgBox("Multiple tax rates will only be enforced" &amp; Cr &amp; "if the Terminal Configuration setting" &amp; Cr 
						&amp; "'Use Multiple Tax Rates' is set to true.","For Your Information",
			MsgBox_Information_Icon);
	endif;
	inheritMethod();

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBtnPropCancelClick" id="9dac5420-2318-4754-b265-a319ca839964">
        <updating/>
        <source>doBtnPropCancelClick() updating;

/*

Purpose:	To run the correct code if Alt-E is pressed.  It
			will either bring up the edit window or exit the 
			new / edit window you are currently in.

Parameters:			

Return Value:		


Date		Who		Reason
13 October 2009	cnwmh5	Initial creation

*/

vars
	theActiveControl : Control;
begin
	
	theActiveControl := app.activeControl;
	if theActiveControl.isKindOf(CMUI_ButtonForToolbar) and not fromToolbar then
		self.btnEdit.click(btnEdit);
		fromToolbar := true;
	else
		inheritMethod();
		setEnableObjects(true);
		fromToolbar := false;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnPropNextClick" id="c08685f2-a6d5-43a8-abf8-1e10d9e512e5">
        <updating/>
        <source>doBtnPropNextClick() updating;
//------------------------------------------------
// Created: 17 May 2006 By: cnwgd1
//------------------------------------------------
//
// Changed On   Changed By  PAR             Reason
// ----------   ----------  --------------  ------------------------------------
//  09/10/2009	cnwmh5		21243			Need to check whether we are entering
//											a tax code/rate and clicking 'Save &amp; Next...'
//											or whether Alt-N was click and process accordingly
// ---------------------------------------------------------------------------
//
vars

	theActiveControl	: Control;
	
begin

	// 09/10/2009 mhill #21243
	// Need to add check to see if we are on tax code/rate groupbox and pressing 'Save &amp; Next' 
	// If not then we have press Alt-N and need to do what is done when the New button is clicked
	theActiveControl := app.activeControl();
	if theActiveControl.isKindOf(CMUI_ButtonForToolbar) and not fromToolbar then
		self.btnNew.click(btnNew);
		fromToolbar := true;
	else
		self.doBtnPropSaveClick();
		self.setUpdateMode(self.UpdateMode_New);
		if self.grpTaxCode.visible then
			self.showPropertyFrameForObject(null, self.grpTaxCode);
		else
			self.showPropertyFrameForObject(null, self.grpTaxRate);	
		endif;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnPropSaveClick" id="b0da7e55-f8c3-4b98-be6e-ecd64fc873ae">
        <updating/>
        <source>doBtnPropSaveClick() updating;
//------------------------------------------------
// Created: 17 May 2006 By: cnwgd1
//------------------------------------------------
// 08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
// 24 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// 29/3/22  jlier1	TFS 53286
vars
	ls : Boolean;
	theReturn : Integer;
	realTaxRate, pxyTaxRate : CM_TaxRate;	
	realTaxCode, pxyTaxCode : CM_TaxCode;
	tmpEffectiveDT,
	tmpEffectiveDTSystem : TimeStamp;
	
begin
	if self.updateMode = self.UpdateMode_New then
		if self.grpTaxCode.visible then
			create pxyTaxCode as CM_TaxCode transient;
		elseif self.grpTaxRate.visible then
			create pxyTaxRate as CM_TaxRate transient;
		endif;			
	else
		app.cmsBeginLoad(ls);
		if CM_TaxCode.hasInstance(self.myCurrentListObject) then
			pxyTaxCode := app.createUpdateProxy(self.myCurrentListObject).CM_TaxCode;		
		elseif CM_TaxRate.hasInstance(self.myCurrentListObject) then
			pxyTaxRate := app.createUpdateProxy(self.myCurrentListObject).CM_TaxRate;
		endif;
		app.cmsEndLoad(ls);
	endif;
	
	if pxyTaxCode &lt;&gt; null then
		pxyTaxCode.setProxy(self.txtTaxCode.text.trimBlanks, 
							self.txtTaxDescr.text.trimBlanks, 
							self.myCurrentBank, 
							self.cmbGLCode.listObject.CM_GLCode,
							self.ckbNotAvailable.value,
							self.txtExtRef1.text.trimBlanks);
	elseif pxyTaxRate &lt;&gt; null then
		tmpEffectiveDT.setDate(self.effectiveDate.getDate());
		tmpEffectiveDT.setTime(self.effectiveTime.getTime());
		tmpEffectiveDTSystem := self.localToSystemTime(tmpEffectiveDT); 
// cnwdad1 20/05/2009 - PAR #17633.
		pxyTaxRate.setProxy(tmpEffectiveDTSystem, self.myCurrentTaxCode, self.txtTaxRate.text.asDecimalJMT());// 24 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'No proxy object found');
		return;
	endif;
	
	while true do
		if self.updateMode = self.UpdateMode_New then
			if pxyTaxCode &lt;&gt; null then		
				app.myTrxCA.trxCreateTaxCode(pxyTaxCode, realTaxCode, app.myPassport);
			elseif pxyTaxRate &lt;&gt; null then
				app.myTrxCA.trxCreateTaxRate(pxyTaxRate, realTaxRate, app.myPassport);			
			else
				app.raiseUnexpectedProgramError(class.name, method.name, 'No proxy object found');
				return;			
			endif;
		elseif self.updateMode = self.UpdateMode_Update then
			if pxyTaxCode &lt;&gt; null then		
				app.myTrxUA.trxUpdateTaxCode(pxyTaxCode, app.myPassport);
			elseif pxyTaxRate &lt;&gt; null then
				app.myTrxUA.trxUpdateTaxRate(pxyTaxRate, app.myPassport);
			else
				app.raiseUnexpectedProgramError(class.name, method.name, 'No proxy object found');
				return;			
			endif;			
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid mode');		
			return;
		endif;
		
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		
		break;
	endwhile;
	
	self.setEnableObjects(true);
epilog
	app.cmsEndLoad(ls);		// 08/04/2011 cnwmh5 #27347
	delete pxyTaxCode;
	delete pxyTaxRate;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnSearchClick" id="735f23d1-4fdf-4748-b2d8-ca666a423943">
        <updating/>
        <source>doBtnSearchClick() updating;
// 35872
vars

	priorBank	: CM_Bank;
	idx : Integer;
begin
	inheritMethod();
	priorBank := self.myCurrentBank;
	self.myCurrentBank := self.cmbBank.listObject.CM_Bank;
	if self.myCurrentBank = null then
		return;
	endif;
	if self.myCurrentBank &lt;&gt; priorBank then
		self.loadGLCodes();
		self.loadTaxCodes();
		//	TFS 2682self.caption := "Tax Code Maintenance " &amp; self.myCurrentBank.code;
		self.setCaption("Tax Code Maintenance " &amp; self.myCurrentBank.code);
	endif;

end;
</source>
    </JadeMethod>
    <JadeMethod name="doCmbBankBuild" id="8c47edc6-63bd-4c8e-bff5-61f87d3becf7">
        <source>doCmbBankBuild();
//	35874 build combo for business unit query
vars
	company			: CM_Bank;
	businessUnits	: CM_CompanyByCodeDict;
	currentBU		: CM_Bank;
	combo			: CMUI_ComboBox;
begin

	combo := self.cmbBank;
	create businessUnits transient;
	currentBU := self.myTerminal.getAvailableCompanies(businessUnits);
	foreach company in businessUnits do
		combo.addItem(company.code);
		combo.itemObject[combo.newIndex] := company;
	endforeach;
	if currentBU &lt;&gt; null then
		combo.listObject := currentBU;
	endif;
epilog
	delete businessUnits;
end;
</source>
    </JadeMethod>
    <JadeMethod name="doDelete" id="daa5cd78-0d71-4986-b8b9-ab252defed53">
        <updating/>
        <source>doDelete() updating, protected;
//------------------------------------------------
// Created: 18 May 2006 By: cnwgd1
//------------------------------------------------
vars
	theReturn : Integer;
begin
	if self.myCurrentListObject = null or self.myCurrentListObject.isKindOf(CM_Bank) then
		app.msgBox('Please select and item from the list to delete.', app.getErrorString(SelectItem), MsgBox_OK_Only+MsgBox_Information_Icon);
		return;
	endif;
	
	while true do
	 	app.myTrxDA.trxDeleteCMObject(self.myCurrentListObject, app.myPassport);
		 
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			return;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(INV_Company_Delete), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;
	
	self.myCurrentListObject := null;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doLstDataClick" id="24b168ad-b70f-4875-bc3f-5d6781072cbd">
        <updating/>
        <source>doLstDataClick(listbox: ListBox input) updating;
//------------------------------------------------
// Created: 18 May 2006 By: cnwgd1
//------------------------------------------------
vars

begin
	inheritMethod(listbox);
	
	self.myCurrentTaxCode := null;
	self.myCurrentTaxRate := null;	
	
	if CM_TaxCode.hasInstance(self.myCurrentListObject) then
		self.myCurrentTaxCode := self.myCurrentListObject.CM_TaxCode;
	elseif CM_TaxRate.hasInstance(self.myCurrentListObject) then
		self.myCurrentTaxRate := self.myCurrentListObject.CM_TaxRate;
		self.myCurrentTaxCode := self.myCurrentTaxRate.myTaxCode;		
	endif;
	
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doLstDataContextMenu" id="d774fa50-9dae-4c73-8b4a-34186e80c634">
        <updating/>
        <source>doLstDataContextMenu(listbox: ListBox input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;
//------------------------------------------------
// Created: 18 May 2006 By: cnwgd1
//------------------------------------------------
vars

begin
	if listbox.listIndex &lt; 1 then
		return true;
	elseif listbox.listIndex = 1 then
		self.mnuAddTaxRate.visible := false;
		self.mnuDelete.visible := false;
		self.mnuUpdate.visible := false;
		self.mnuAudits.visible := false;		
	elseif listbox.listIndex &gt; 1 then
		self.mnuAddTaxRate.visible := true;
		self.mnuDelete.visible := true;
		self.mnuUpdate.visible := true;	
		self.mnuAudits.visible := true;
	endif;
	// TFS 2734 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnDelete.enabled:= false;
		self.btnNew.enabled:= false;
		self.btnEdit.enabled:= false;
		self.mnuAddTaxCode.visible := false;
		self.mnuAddTaxRate.visible := false;
		self.mnuDelete.visible := false;
		self.mnuUpdate.visible := false;
	endif;
	return self.showContextMenu(self.mnuListContext, listbox, conwin, mouse, x, y);
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
