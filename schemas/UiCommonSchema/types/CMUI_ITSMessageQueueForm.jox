    <JadeMethod name="showHideSearcher" id="5172d50d-2965-471c-b3e6-0118e39e5281">
        <source>showHideSearcher();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 December 2009	#cnwdz2	 par21593

*/
vars

begin
	self.btnSearch.enabled := false;
	
	if self.frmSearch.visible then
		self.frmSearch.visible := false;
	else
		self.btnSearch.enabled := true;
		self.frmSearch.visible := true;
		self.frmSearch.centreHorizontallyInParent();
		self.frmSearch.centreVerticallyInParent();
		self.frmSearch.zOrder(1);
		//We're showing the searcher and want move to the first row ready for new values.
		self.tblSearch.clearAllSelected;
		self.tblSearch.accessColumn(1).width := 100;
		self.tblSearch.setFocus();
		self.tblSearch.moveFirst();
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="tblData_contextMenu" id="7ba58872-a41c-4d56-88b2-b82c3f916ef0">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 January 2010	#cnwdz2	 par21593

*/

vars
	xLeft 	: Real;
	yTop	: Real;
	obj : Object;
begin
	xLeft := x;
	yTop := y;
	
	//12 Feb 2016	NDL	Par 37534
	self.mnuInspect.enabled := true;
	self.mnuInspect.visible := false;
	if not self.tblData.allSelectedObjects.isEmpty then
		obj := self.tblData.allSelectedObjects.first;
		self.mnuInspect.userObject := obj;
		self.mnuInspect.visible := true;
	endif;

	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);   // convert x, y relative to form	
	
	self.popupMenu(self.mnuContextTbl, xLeft.Integer, yTop.Integer);

	return false;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblData_dblClick" id="f0df89fc-be6b-4bc4-909e-3871ecbe1352">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_dblClick(table: Table input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 January 2010	#cnwdz2	 par21593

*/

vars
	theRow	: Integer;
begin
	theRow := table.row;
	
	if theRow &lt;= 0 then
		return;
	endif;
	
	if theRow = 1 then
		self.zTblDataResort();
	endif;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="deec909b-4788-47a7-abfc-84302ab5be07">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 12 February 2016.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0017374, locale);
	btnCloseSearch.translateCaption(Xlat_0013449, locale);
	btnResetSearch.translateCaption(Xlat_0013450, locale);
	btnSearch.translateCaption(Xlat_0013451, locale);
	btnShowSearch.translateCaption(Xlat_0013452, locale);
	mnuColumnOrganiser.translateCaption(Xlat_0013453, locale);
	mnuContextTbl.translateCaption(Xlat_0013454, locale);
	mnuInspect.translateCaption(Xlat_0021152, locale);
end;</source>
    </JadeMethod>
