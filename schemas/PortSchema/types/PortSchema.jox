		app.writeLog("App locale is changing from " &amp; self.myLocaleInfoJMT.localeId.String &amp; " to " &amp; _localeInfoJMT.localeId.String, LogINFO);
		delete self.myLocaleInfoJMT;
		self.myLocaleInfoJMT := _localeInfoJMT;
	endif;
epilog

end;</source>
        <Parameter name="_localeInfoJMT" type="LocaleFullInfo"/>
    </JadeMethod>
