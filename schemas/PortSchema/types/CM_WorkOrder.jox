    <JadeMethod name="doEmailStatusChange" id="63c69d92-68d5-42e6-8bb6-f4f3257f097e">
        <source>doEmailStatusChange( _newStatus : Integer);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 July 2009	cnwrd1	Initial creation

*/

vars
	emailTemplate	: CM_EmailTemplate;
	emailFrom,
	emailTo,
	subject,
	content : String;
begin

	if not self.emailNotification then
		return;
	endif;
	
	emailTo := self.getAllToAddresses();	
	emailFrom := app.myRoot.getConfig(AutoSendersEmailAddress).String;
	
	subject := app.getErrorString1(Work_order_status_change, self.id);
	content := app.getErrorString2(Work_order_status_been_change, self.id,  self.getStatusString());  //hack some email content, should probably use CM_EmailTemplate but not quite there
	
	//should be in transaction here
	app.myUtilityCA.utlCreateEmailSendRequest(true, 
											null, 
											emailTo, 
											emailFrom, 
											null,  //cc
											null, //bcc
											subject, //subject
											content, //message
											null, 
											null, 
											null, 
											null, 
											EmailSource_System,  
											null, 
											app.myPassport);
	

epilog
	delete emailTemplate;	

end;</source>
        <Parameter name="_newStatus" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doResyncAllTransactions" id="c2bca1df-ebbc-4cb4-ad8d-26df280ade39">
        <source>doResyncAllTransactions();
/*

Purpose:			This method resync all the WO transaction

Parameters:			

Return Value:		

Date		Who		Reason
13/11/2024	navkc1 JIRA Story MTN-33012: EUP | WO Transaction Billing Change of Debtor

*/

vars
	controller		: CMIF_TiTransactionResync;
begin
	
	if self.allTransactions.isEmpty() then
		return;
	endif;
	
	create controller transient;
	
	self.allTransactions.copy(controller.allTransactions);
	
	app.myUtilityUA.utlUpdateResyncTrans(controller, app.myPassport);
	
epilog
	
	delete controller;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doStatusChange" id="2ea27799-ce04-4701-b784-12b95eccc047">
        <updating/>
        <source>doStatusChange( _newStatus : Integer) updating;

/*

Purpose:			
	
	// Create Cash Receipt at WO_STATUS_PENDING
	// ### The cash receipt creation cannot be in the TRX because it needs to beginTransaction and AbortTransaction for the proforma process
	// ### The cash receipt is instead created in line, see references for app.myTrxCA.trxCreateProformaPaymentWO
	// Send SAP 
Parameters:			

Return Value:		


Date		Who		Reason
24/06/2009	cnwrd1	Initial creation
11/09/2018	jlgdap1	TFS 40202 PEL1 Estimation SAP Integration
24/01/2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
08 Feb 2023 navma1  ChangeRequest 56457: EUP - Allowing different sets of cargo items per work order task [Refactor]
*/

vars
	usrCode : String; 
begin
	if self.isTransient then				// TFS 40202
		// Just a proxy? No updates			// TFS 40202
		return;								// TFS 40202
	endif;									// TFS 40202
	
	usrCode := app.getMyUser.userName;										//24.01.2023 navma1 #56141 Task#56147	//08.02.2023 navma1 #56457 Task#56458
	
	if _newStatus = WO_STATUS_USERENTRY then	
		self.setUserEntry(); 												//epr tfs 51963 27/9/21
	elseif _newStatus = WO_STATUS_PENDING then
		self.setPendingApproval();								 			//epr tfs 51963 27/9/21
	elseif _newStatus = WO_STATUS_NOTAPPROVED then
		self.setNotApproved(usrCode,null,self.getLengthOfTime());	 		//epr TFS 42924 8/2/19     
	elseif _newStatus = WO_STATUS_APPROVED then
		self.setApproved( usrCode, self.approvedByDT, app.myPassport  );	//24.01.2023 navma1 #56141 Task#56147
	elseif _newStatus = WO_STATUS_PENDING_CANCEL then
		self.sendEmailForPendingCancel();									//24.01.2023 navma1 #56141 Task#56147
	elseif _newStatus = WO_STATUS_CANCELLED then
		self.setCancelled(); 												//epr tfs 51963 27/9/21
	elseif _newStatus = WO_STATUS_PENDING_HOLD then
	elseif _newStatus = WO_STATUS_HELD then
	elseif _newStatus = WO_STATUS_PARTCOMPLETE then
	elseif _newStatus = WO_STATUS_COMPLETE then
	
	endif;
	
	self.doEmailStatusChange( _newStatus );

epilog

end;</source>
        <Parameter name="_newStatus" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doUnapprove" id="0213ff40-bbf4-4b9f-9615-66bb8460f634">
        <updating/>
        <source>doUnapprove(_passport : CM_Passport input)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Apr 2024 navhl20 ChangeRequest 63583: EUP | 54014 - Cargo Work Orders Enhancements - Remedial
*/

vars
	wod 		: CM_WorkOrderDtl;
	doUnApprove	: Boolean;
begin
	doUnApprove := true;
	foreach wod in self.allWoDtls do
		wod.doUnApprove(_passport);
		if not wod.status = WO_STATUS_USERENTRY then
			doUnApprove := false;
		endif;
	endforeach;
	
	if doUnApprove then
		self.setTaskStatus(WO_STATUS_USERENTRY);
	endif;
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
