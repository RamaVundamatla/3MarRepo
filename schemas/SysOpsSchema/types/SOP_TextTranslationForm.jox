    <JadeMethod name="tblFormCaptions_contextMenu" id="4bb55e23-5c3e-423f-b7b2-6b623322f122">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblFormCaptions_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
//--------------------------------------------------
// Created:	10/8/2006 By: cnwrbb1
//--------------------------------------------------
vars
	xLeft 	: Real;
	yTop	: Real;
begin

	xLeft := x;
	yTop := y;

	self.mnuInspectObj.visible := app.isAllowedToInspect();
	self.mnuContextClipboard.visible := app.isSpecial();
	
	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);   // convert x, y relative to form

	self.popupMenu(self.mnuContextTbl, xLeft.Integer, yTop.Integer);

	return false;
end;</source>
