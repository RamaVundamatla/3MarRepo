    <JadeMethod name="trxUpdateYAGroupLastBlock" id="8f84f49d-9dce-4e7c-831f-c1dad1eddce4">
        <updating/>
        <source>trxUpdateYAGroupLastBlock(_yaBlockGroup : CM_YABlockGroup input; _yaBlock : CM_YABlock; _isIn : Boolean; _passport : CM_Passport input) updating;
//-----------------------------------------
//Created: May 2005 By: cnwdvb1
//-----------------------------------------
vars

	isExternalTransaction	: Boolean;

begin

	// Always initialize the activity first
	if process.isInTransactionState then
		isExternalTransaction := true;
	else
		self.initialiseActivityWithPassport(_passport, method);
	endif;

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(true);
	
	if isExternalTransaction then
	else
		beginTransaction;
	endif;
	
	
	_yaBlockGroup.setLastYABlock(_yaBlock, _isIn);
	
		
epilog

	if isExternalTransaction then
	else
		self.finaliseActivityWithPassport(_passport);
	endif;
end;</source>
