    <JadeMethod name="translateForm" id="93c944b6-2e03-4e37-b006-43342f8ae4ad">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0008143, locale);
	btnEnquiry.translateBubbleHelp(Xlat_0005262, locale);
	btnEnquiry.translateCaption(Xlat_0005263, locale);
	btnLocate.translateBubbleHelp(Xlat_0014616, locale);
	btnLocate.translateCaption(Xlat_0014617, locale);
	btnPrint.translateBubbleHelp(Xlat_0005266, locale);
	btnPrint.translateCaption(Xlat_0005267, locale);
	btnRemove.translateBubbleHelp(Xlat_0005268, locale);
	btnRemove.translateCaption(Xlat_0005269, locale);
	mnuContext.translateCaption(Xlat_0008144, locale);
	mnuEnquiry.translateCaption(Xlat_0008145, locale);
	mnuInspect.translateCaption(Xlat_0008146, locale);
	mnuLocate.translateCaption(Xlat_0008147, locale);
	mnuOrganiser.translateCaption(Xlat_0008148, locale);
	mnuPrint.translateCaption(Xlat_0008149, locale);
	mnuRemove.translateCaption(Xlat_0008150, locale);
end;</source>
    </JadeMethod>
</GUIClass>
