    <JadeMethod name="doServerApp" id="614224a9-f507-45c2-a0ad-a1bbcb762230">
        <updating/>
        <source>doServerApp() updating;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	// Disable the button so the user cannot click again before
	// the app is started/stopped
	btnServerApp.enabled := false;

	if app.jacIsAppRunning(JACBackupServerAppName) then
		app.myServerAppObject.stopBackupServerApp();
	else
		app.myServerAppObject.startBackupServerApp();
	endif;
	self.setValidObjects;
end;</source>
    </JadeMethod>
    <JadeMethod name="initBtnServerApp" id="41e817f0-0ba0-46f4-a39d-3808d8cb9226">
        <source>initBtnServerApp(_running: Boolean);
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	if _running then
		self.btnServerApp.caption := 'Stop Server App';
		self.btnServerApp.buttonPicture := Button.ButtonPicture_Stop;
		self.btnServerApp.bubbleHelp := "Click to stop the Server App controlling the backups.";
	else
		self.btnServerApp.caption := 'Start Server App';
		self.btnServerApp.buttonPicture := Button.ButtonPicture_Tick;
		self.btnServerApp.bubbleHelp := "Click to start the Server App controlling the backups.";
	endif;
	self.btnBackupAbort.enabled := false;
	self.btnServerApp.enabled := false;

	// Reenable the button with the new state
//	if app.computerName = app.getServerCompName then
//		self.btnServerApp.enabled := true;
//	else
//		self.btnServerApp.enabled := false;
//	endif;

end;</source>
        <Parameter name="_running" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jdtCurrent_click" id="c14bb555-fcbe-48b3-9042-214c6b6e8791">
