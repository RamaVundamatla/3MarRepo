        <source>cmbGrade_click(combobox: ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:     19 May 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	self.loadRemainingCombos(combobox.listObject.CM_LogGrade,
							tblSelection,
							cmbLogType, cmbLogTreatment, cmbLogLength);
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbGrade_displayEntry" id="c38f9ed7-4191-4154-a7e2-531cc95b6d34">
