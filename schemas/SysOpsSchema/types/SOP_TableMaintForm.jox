    <JadeMethod name="keyDown" id="9790d6d1-d704-482f-95df-e148eebcd684">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 June 2009	cnwar2	Initial creation
04 Mar 2013		cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements
*/
vars
	theActiveControl : Control;
	
begin
	if self.doCheckKeyDownSpecial(keyCode, SOP_TableMaintForm::doCellInputReady.name) then	// PAR #31155
		keyCode := 0;																		// PAR #31155
		return;																				// PAR #31155
	endif;																					// PAR #31155
	
	if self.fldInput.topSheet = self.shtTblInput3 and self.tblData5.visible then
		if keyCode = J_key_Tab then
			theActiveControl := app.activeControl;
						
			if shift = 0 and theActiveControl.parent = self.tblInput3 then
				// moving forward into table
				if self.tblData5.rows &gt; self.tblData5.fixedRows then
					self.tblData5.column := 2;
					self.tblData5.row 	 := self.tblData5.fixedRows + 1;
				endif;
	
			elseif shift = 1 and theActiveControl = self.cmbTerminal then
				// moving back into table
				self.tblData5.column := 4;
				self.tblData5.row    := self.tblData5.rows;
			endif;
		else
			inheritMethod(keyCode, shift);
		endif;
	
	else
		inheritMethod(keyCode, shift);
	endif;
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
