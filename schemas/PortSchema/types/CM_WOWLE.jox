    <JadeMethod name="doCompleteWorkOrderTask" id="3e9facb0-5fc2-43aa-832e-b39903424a16">
        <updating/>
        <source>doCompleteWorkOrderTask()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Jun 2023 navma1 ChangeRequest 58339: EUP | Delivery Dispatch Screen - Road Operation

*/

vars
	operWle : CM_WorkListEntry;
	ti		: CM_TrackedItem;
	wod	    : CM_WorkOrderDtl;
begin
	
	operWle := self.myOperationalWLE;
	if operWle &lt;&gt; null then
		ti := operWle.myTrackedItem;
	endif;
	
	wod := self.job.myWODtl;
	
	if ti &lt;&gt; null and self.myTrackedItem = null then 
		self.myTrackedItem := ti;
		if wod &lt;&gt; null then
			wod.CM_WorkOrderTIDtl.allSelectedTIs.addNoDuplicates(ti,false);
			wod.myParent.CM_WorkOrderTI.allTIs.addNoDuplicates(ti,false);
			wod.doCompleteTask(operWle,self,null);
		endif;
	endif;
	
	
	
	
	
epilog

end;</source>
    </JadeMethod>
