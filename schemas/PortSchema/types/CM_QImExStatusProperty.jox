    <JadeMethod name="setComboValues" id="dda33147-f493-4930-b58b-3588a0b91f84">
        <source>setComboValues(_combo : ComboBox input; _params : CM_QueryCriteriaLineHolder; _queryOperator : CM_QueryOperator; _passport : CM_Passport);
// ---------------------------------------------------------------------------
// Created:     05 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	stat			: CM_IMEXStatus;
	statDict		: CM_IMEXStatusByCodeDict;
begin
	_combo.clear();
	statDict := app.myRoot.allImexStatuses;
	
	foreach stat in statDict do
		_combo.itemObject[_combo.addItem(stat.description)] := stat;
	endforeach;

	if CM_QIntegerLookupEqual.hasInstance(_queryOperator) then
		_combo.listObject := statDict[_queryOperator.CM_QIntegerLookupEqual.searchValue];
	elseif CM_QIntegerLookupNotEqual.hasInstance(_queryOperator) then
		_combo.listObject := statDict[_queryOperator.CM_QIntegerLookupNotEqual.searchValue];
	endif;
	
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="203fcb5a-5007-4356-8bda-2055e65298e0">
        <source>setListValues(_tbl : Table input; _params : CM_QueryCriteriaLineHolder; _operator : CM_QIntegerIsOneOf; _passport : CM_Passport);
// ---------------------------------------------------------------------------
// Created:     14 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	stat			: CM_IMEXStatus;
	statDict		: CM_IMEXStatusByCodeDict;
	idx,
	selectionValue	: Integer;
begin
	_tbl.rows := _tbl.fixedRows;
	statDict := app.myRoot.allImexStatuses;
	
	foreach stat in statDict do
		selectionValue := 0;
		if _operator &lt;&gt; null and _operator.allSelectionValues.includes(stat.code) then
			selectionValue := 1;
		endif;
		idx := _tbl.addItem(selectionValue.String &amp; Tab &amp; stat.description);
		_tbl.accessRow(idx).itemObject := stat;
		_tbl.row := idx;
		_tbl.change(_tbl);
	endforeach;	
	
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QIntegerIsOneOf"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="df2bd478-4f82-4f8f-8d75-0a9353132a87">
        <source>setValuesFromList(_tbl : Table input; _op: CM_QueryOperator input);
// ---------------------------------------------------------------------------
// Created:     14 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	stat		: CM_IMEXStatus;
	str			: String;
	numRows,
	idx			: Integer;
	ia			: IntegerArray;

begin

	create ia transient;
	
	numRows := _tbl.rows;
	foreach idx in (_tbl.fixedRows + 1) to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			stat := _tbl.accessRow(idx).itemObject.CM_IMEXStatus;
			ia.add(stat.code);
		endif;
	endforeach;
	
	_op.setSearchValue(ia);

epilog
	delete ia;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateStringToSearchValue" id="5f4ad240-300c-4850-9e7f-35ff86c82e2a">
        <source>translateStringToSearchValue(_value: Any; _criteriaLine : CM_SelectorCriteriaLine ): Any;
// ----------------------------------------------------------------------
// Created 12 May 2008 by cnwvu1
//
// Purpose:	Gets value as String from RT screen and returns value
//			 into criteriaLineLine for running a query
// ----------------------------------------------------------------------

vars
	stat			: CM_IMEXStatus;
	codeDict		: CM_IMEXStatusByCodeDict;
	tmpDescription	: String;
	
begin
	
	if _value.isKindOf( CM_IMEXStatus ) then
		return _value;
	endif;
	
	tmpDescription	:= _value.String.toUpper();
	codeDict := app.myRoot.allImexStatuses;
	
	foreach stat in codeDict discreteLock do
		if tmpDescription = stat.description.toUpper() then
			return stat.code;
		endif;
	endforeach;
	
	// when not found. Par 17092	cnwvu1, June 2008
	inheritMethod( _value, _criteriaLine );

end;
</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_criteriaLine" type="CM_SelectorCriteriaLine"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="e6018e62-084b-48e5-871b-67311ed1c6b1">
        <source>translateToDisplayValue(_value: Integer): String;
