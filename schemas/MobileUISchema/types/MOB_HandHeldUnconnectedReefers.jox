    <JadeMethod name="populateTable" id="83977768-4a12-4d79-84c1-f065c6fbd217">
        <source>populateTable() protected;
// adm 270509 Par 19483 myTerminal
// 11/12/2009	cnwdap1		CCMS MES 1007 Any tracked item can now be a reefer, not just containers
vars
	term : CM_Terminal;
	ti, selectedTI : CM_TrackedItem;
	st, et : TimeStamp;
	selectedRow : Integer;
	count : Integer;
	
	iter : Iterator;
	
begin
	term := self.myTerminal;
	
	// Find which row the currently selected tracked item is added in the table
	if self.getSessionAgent.mySelectedTI &lt;&gt; null then
		selectedTI := self.getSessionAgent.mySelectedTI;
	endif;
	


/*	foreach ti in term.allOnsiteTIsByIdCargoType 
		where 
			//ti.isKindOf(CM_Container) and ti.CM_Container.requiresPower do // 21.4.09 PAR 19491 cnwgb1 Don't show empties			
		//if not ti.CM_Container.isConnected then
			//self.addDataRow(ti.CM_Container);
			ti.requiresPower do 					// CCMS 1007
		if not ti.isConnected then					// CCMS 1007
			self.addDataRow(ti);					// CCMS 1007
			if selectedTI &lt;&gt; null and selectedRow = 0 and ti = selectedTI then
				selectedRow := tblReefers.rows;
			endif;
		endif;
	endforeach; */
	
	//08 June 2011	NDL	Par 20232 - use iterator to reduce locking potential.
	iter := term.allOnsiteTIsByIdCargoType.createIterator; 
	while iter.next( ti ) do 
		if ti.requiresPower then					
			if not ti.isConnected then					
				self.addDataRow(ti);					
				if selectedTI &lt;&gt; null and selectedRow = 0 and ti = selectedTI then
					selectedRow := tblReefers.rows;
				endif;
			endif;
		endif;
	endwhile; 
	

	// Display the selected TI at the top of the table and select it
	if selectedRow &gt; tblReefers.fixedRows then
		tblReefers.row := selectedRow;
		tblReefers.topRow := selectedRow;
	endif;
	
epilog

	delete iter;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setControlState" id="628d91c3-5eb3-4bd7-98cd-7b30b2b5bd75">
        <source>setControlState() protected;
//
// 11/12/2009	cnwdap1		CCMS MES 1007 Any tracked item can now be a reefer, not just containers
//
vars
	//cont : CM_Container;	// CCMS 1007
	cont : CM_TrackedItem;	// CCMS 1007
begin
	
	if tblReefers.row &gt; tblReefers.fixedRows then
		//cont := tblReefers.accessRow(tblReefers.row).itemObject.CM_Container;	// CCMS 1007
		cont := tblReefers.accessRow(tblReefers.row).itemObject.CM_TrackedItem;	// CCMS 1007
		self.btnOne.enabled := not cont.isConnected;
		self.btnTwo.enabled := true;
		
	else
		self.btnOne.enabled := false;
		self.btnTwo.enabled := false;
	endif;
	
	if not self.getSessionAgent.allAvailableForms.includes(MOB_HHReeferEnquiryForm) then
		self.btnTwo.enabled := false; // if they don't have permission to go to the enquiry form then disable the button
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="bf9aa9d8-ee65-43e3-bad7-4cc77e5d1af8">
        <updating/>
        <source>setupForm() updating, protected;
/*
Date		Who		Reason
12 March 2009	cnwcp2	Initial creation
*/

vars
	
begin
	inheritMethod();
	
	self.setupCmdButtons(3, "Connect", "Enquiry" , "Back",null,null);
	self.setupTable;
	
	self.tblReefers.setFocus;
	app.mousePointer := self.MousePointer_HourGlass;
	self.populateTable;
	self.setControlState;	
	
epilog
	app.mousePointer := self.MousePointer_Default;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupMenu" id="7dbe0c67-23bb-4084-b2e3-e03af0da9342">
        <updating/>
        <source>setupMenu() protected, updating;

vars

begin
	
	if tblReefers.row &gt; tblReefers.fixedRows then
		if tblReefers.accessRow(tblReefers.row).itemObject &lt;&gt; null then
			self.mEnquiry.visible := self.getSessionAgent.allAvailableForms.includes(MOB_HHReeferEnquiryForm);
			self.mConnect.visible := true; // Checks will be made during the transaction to see if they are actually allowed to connect reefers
		endif;
	else
		self.mEnquiry.visible := false;
		self.mConnect.visible := false;
	endif;
		
	self.isMenuItemsVisible := self.mEnquiry.visible or self.mConnect.visible;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupTable" id="e4c89fcd-cfc3-44de-a014-1b8116c89b85">
        <updating/>
        <source>setupTable() protected, updating;

vars

begin

	self.doResizeControls(true);
	
	self.tblReefers.fontName := "Tahoma";
	self.tblReefers.fixedRows := 1;
	self.tblReefers.fixedColumns := 0;
	self.tblReefers.rows := 1;
	self.tblReefers.columns := 4;
	
	self.tblReefers.accessColumn(2).alignment := Table.Alignment_Right_Middle;
	self.tblReefers.accessCell(1,2).marginRight := 3;
	
	self.tblReefers.accessCell(1,1).text := "Container ID";
	self.tblReefers.accessCell(1,2).text := Degrees_C;
	self.tblReefers.accessCell(1,3).text := "Comm";
	self.tblReefers.accessCell(1,4).text := "Location";
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
