<Class name="Schema">
    <JadeMethod name="getConstantName" id="94d0b4e5-78f6-42f3-af51-40ec4befff1f">
        <source>getConstantName(s:String):String;

vars
	const:Constant;
	t,reply:String;
begin
	if s[1] = "-" then
		t := s[2:end];
		reply := " (reply)";
	else
		t := s;
	endif;
	foreach const in consts do
		if const.getSource = t then
			return const.name &amp; reply;
		endif;
	endforeach;
	
	return s;
end;
</source>
        <Parameter name="s" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
