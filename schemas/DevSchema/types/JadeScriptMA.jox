    <JadeMethod name="mTN18222" id="b579856a-d64a-4657-abbc-7910eefa9214">
        <source>mTN18222();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 February 2022		navma1	Initial creation

*/

vars
	dyna : DynaDictionary;
	
	iter : Iterator;
	userCode : String;
	startObject : CM_User;
begin
	app.initialize();
	userCode :='CNWMA1';
	
	create dyna transient;
	dyna.setMembership(CM_User);
	dyna.addMemberKey(CM_User::code.name,false,false);
	dyna.endKeys(true);	
	
	app.myRoot.allUsers.copy(dyna);
	
	iter := dyna.createIterator;
	
	
	startObject := dyna.getAtKeyGeq(userCode ).CM_User; 
	
	if startObject &lt;&gt; null then
		
		write startObject.userName;
	endif;
	
epilog
	delete iter;
end;</source>
