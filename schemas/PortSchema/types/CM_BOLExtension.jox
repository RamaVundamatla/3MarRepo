    <JadeMethod name="getDisplayStringForAttribute" id="d0249e2d-179e-4ae9-a9c8-1b4c647929cd">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     24 June 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if _attrName = ETRow_DocketNumber or
	   _attrName = ETRow_IsHazardous or // AKB2005MAR added during testing
	   _attrName = ETRow_DateTime or		
	   _attrName = ETRow_IsReleaseDocket or
	   _attrName = ETRow_MatchFound or	   	
	   _attrName = ETRow_Supplier or
	   _attrName = ETRow_SssBOLNumber or
	   _attrName = ETRow_SssOpt or
	   _attrName = ETRow_SssDateTime or
	   _attrName = ETRow_SssNumItems or
	   _attrName = ETRow_SssLOFile or
	   _attrName = ETRow_NoLogs then
		return self.myBOL.getDisplayStringForAttribute(_attrName, _short);
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
