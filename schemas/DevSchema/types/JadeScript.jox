    <JadeMethod name="rsCleanupEDIData" id="ddf09de9-9e07-4bcd-9a19-161b85b6dd6a">
        <source>rsCleanupEDIData();
//
//15 November 2017	jlgrs1	Initial creation
//
vars
	objArray : ObjectArray;
	obj : Object;
	ediData : CM_EDIData;
begin
	create objArray transient;
	CM_EDIData.allInstances(objArray, 0, true);
	foreach obj in objArray do
		ediData := obj.CM_EDIData;
		if ediData.myEDIFile &lt;&gt; null and ediData.myEDIFile.computerName = "JLGRS1A" then
//		if ediData.allEDITrackedItems.size = 0 then
			write class.name&amp;'::'&amp;method.name&amp;' '&amp;ediData.display;
			beginTransaction;
			ediData.erase(NORMAL_ERASE);
			commitTransaction;
		endif;
	endforeach;
epilog
	delete objArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="rsCoarri" id="4c706d11-6487-4c93-a14d-048174674fee">
        <source>rsCoarri();

vars
	str : String;
begin
	str := "
&lt;FileHeader&gt;&lt;1&gt;
UNB+UNOA:2+&lt;sender&gt;+&lt;recipient&gt;+&lt;dateyymmdd&gt;:&lt;timehhmm&gt;+&lt;sender&gt;'
&lt;Header&gt;&lt;voyageNum&gt;
UNH+&lt;sequenceNo&gt;+CODECO:D:95B:UN:ITG14+&lt;sender&gt;'
BGM+34+&lt;sequenceNo&gt;+9'
&lt;Group1&gt;&lt;1&gt;
TDT+20+&lt;voyage&gt;+1++PCIU:172+++:103::&lt;vessel&gt;'
&lt;Group2&gt;&lt;1&gt;
NAD+CF+&lt;shipper&gt;:160:87'
&lt;Group3&gt;&lt;contId&gt;
GID+1'
TMP+2+&lt;tempC&gt;:CEL'
SGP+&lt;contId&gt;'
&lt;Group4&gt;&lt;9&gt;
&lt;Group5&gt;&lt;contNumber&gt;
EQD+CN+&lt;contId&gt;+&lt;isoType&gt;:102:5++&lt;imexStatus&gt;+&lt;contentsStatus&gt;'
RFF+BN:&lt;bookingRef&gt;'
TMD+3'
DTM+7:&lt;trDateTime&gt;:203'
LOC+165+&lt;thisPort&gt;:160:20'
MEA+AAE+G+KGM:&lt;weightKG&gt;'
&lt;Group6&gt;&lt;damNum&gt;
&lt;Group7&gt;&lt;numVehicles&gt;
TDT+1+&lt;vehicleRegNo&gt;+3++:::&lt;carrier&gt;+++'
&lt;Group5&gt;&lt;&gt;
&lt;Footer&gt;&lt;voageNum&gt;
CNT+&lt;controlTotal&gt;:2'
UNT+20+&lt;sequenceNo&gt;'
&lt;FileFooter&gt;&lt;1&gt;
UNZ+2+&lt;sender&gt;'";
end;
</source>
    </JadeMethod>
    <JadeMethod name="rsCreateReleaseRequest" id="87faf7fd-553a-4d40-853b-d1b903abfb78">
        <source>rsCreateReleaseRequest();
//
//19 December 2017	jlgrs1	Initial creation
//
vars
	ediConfig : CM_EDIConfig;
	terminal : CM_Terminal;
	ediData : CM_EDIDataRequestMultiLine;
	ediTIHdr : CM_EDIRequestHeaderTI;
	ediTIItem : CM_EDIRequestDetailTI;
	bulkRelease : CM_BulkRelease;
	reserveDetail : CM_ReserveDetail;
	ediFile : CM_EDIFile;
	ediFileType : CM_EDIFileTypeCSV;
begin
	app.initialize;
	ediConfig := app.myRoot.myEdiConfig;
	terminal := app.myRoot.allTerminals["UT"];
	beginTransaction;
	create ediFile;
	create ediFileType as CM_EDIFileTypeCSV;
	ediFile.setEDIFileType(ediFileType);
	create ediData;
	ediData.setType;
	ediData.setForCreateNoProxy(ediConfig, EDIDataType_RequestMultiLine, null, ediFile, null);
	ediData.setEDIConfig(ediConfig);
//	ediData.setMyRoot();
	ediData.setTerminal(terminal.code);
	foreach bulkRelease in terminal.allBulkReleasesByCodeDate do
		create ediTIHdr;
		ediTIHdr.setMyEDIData(ediData);
		ediTIHdr.setMyEDIConfig(ediData.ediConfig);
		ediTIHdr.setFromBulkRelease(bulkRelease);
		foreach reserveDetail in bulkRelease.allReserveDetails do
			if reserveDetail.isKindOf(CM_ReserveSelection) then
				create ediTIItem;
				ediTIItem.setMyEDIData(ediData);
				ediTIItem.setMyEDIConfig(ediData.ediConfig);
				ediTIItem.setFromReserveSelection(reserveDetail.CM_ReserveSelection);
			elseif reserveDetail.isKindOf(CM_ReserveTI) then
				create ediTIItem;
				ediTIItem.setMyEDIData(ediData);
				ediTIItem.setMyEDIConfig(ediData.ediConfig);
				ediTIItem.setFromReserveTi(reserveDetail.CM_ReserveTI);
			endif;
		endforeach;
	endforeach;
	commitTransaction;
epilog

end;</source>
    </JadeMethod>
