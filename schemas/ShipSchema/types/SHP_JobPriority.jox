    <JadeMethod name="populateControllerForDisplay" id="fb759d52-4ff7-4ec8-a1db-412a8fa7bf13">
        <source>populateControllerForDisplay();
// ---------------------------------------------------------------------------
// Created:		06 April 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	controller : CMIF_JobPriorityController;
	theReturn : Integer;
begin

	controller := self.myController;
//	controller.isResetToSystem := self.ckbSystemDefault.value and self.ckbSystemDefault.visible;
//	controller.isResetToVessel := self.ckbVesselDefault.value and self.ckbVesselDefault.visible; // PAR 34655
	controller.isResetToSystem := self.optUseSystem.value and self.optUseSystem.visible;
	controller.isResetToVessel := self.optUseVessel.value and self.optUseVessel.visible; // PAR 34655
	controller.init(false, self.priorityObject, self.priorityClass);
	controller.populatePriorities();
end;</source>
    </JadeMethod>
    <JadeMethod name="populateControllerForSave" id="dea88bab-4d6b-4142-95a4-336521cb4db0">
        <source>populateControllerForSave(_controller : CMIF_JobPriorityController input) : Boolean;
// ---------------------------------------------------------------------------
// Created:		05 April 2006  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	ls : Boolean;
	hdx,fromIDX, toIDX, idx : Integer;
	craneType,jobType,priority : Integer;
	pxyJobType,realJobType : CM_JobPriority;
	list : CM_QueueListBox;
begin

	list := self.lstJobPriority;
	_controller.myObject := self.priorityObject; // root, Vessel, Voyage
	_controller.myClass := self.priorityClass; // root, Vessel, Voyage
	
	fromIDX := 1;
	toIDX := list.listCount();

	foreach idx in fromIDX to toIDX do
		// ###  Get Crane Setting
		if list.itemLevel[idx] = self.LevelCrane then
			craneType := list.itemData[idx];
			continue;
		endif;
		
		// ### Get Priority Setting
		if list.itemLevel[idx] = self.LevelPriority then
			priority := list.itemData[idx];
			continue;
		endif;
		
		// ### Get Job Type Setting
		if list.itemLevel[idx] = self.LevelJobType then
			jobType := list.itemData[idx];
			
		//	if _controller.checkForDuplicates(craneType, jobType) then
		//		app.msgBox('The item is there already', null, MsgBox_OK_Only);
		//		return false;
		//	else
				// ### Create proxy for create
				create pxyJobType  as priorityClass transient;
				
				pxyJobType.setProxy(craneType,jobType,priority,self.priorityObject);
				_controller.allJobPriorities.add(pxyJobType);
		//	endif;	
		endif;
	endforeach;

	_controller.populateControllerWithMissing(JobTypePriority_Crane1);
	_controller.populateControllerWithMissing(JobTypePriority_Crane2);
//	_controller.isResetToSystem := self.ckbSystemDefault.value;//added by cnwyl1
//	_controller.isResetToVessel := self.ckbVesselDefault.value; // PAR 34655
	_controller.isResetToSystem := self.optUseSystem.value; // PAR 34655
	_controller.isResetToVessel := self.optUseVessel.value; // PAR 34655
	
	return true;
end;</source>
        <Parameter name="_controller" type="CMIF_JobPriorityController" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="reNumberPriorities" id="70e07a0a-e179-4096-b754-951e53c1473b">
        <source>reNumberPriorities(_priType : Integer) ;
// ---------------------------------------------------------------------------
// Created:		05 April 2006  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	fromIDX, toIDX, idx : Integer;
	priority : Integer;
	list : CMUI_ListBox;
	aJP : CM_JobPriority;
begin

//	self.ckbVesselDefault.value := false; // PAR 34655
//	self.ckbSystemDefault.value := false; // PAR 34655
	self.optUseSystem.value := false; // PAR 34655
	self.optUseVessel.value := false; // PAR 34655

	list := self.lstJobPriority;

	fromIDX := 1;
	toIDX := list.listCount();

	foreach idx in fromIDX to toIDX do
		if list.itemData[idx] = _priType then
			break;
		endif;
	endforeach;
	fromIDX := idx + 1;
	foreach idx in fromIDX to toIDX do
		if list.itemLevel[idx] = self.LevelPriority then
			priority := priority + 1;
			list.itemText[idx] := self.getPriorityDesc(priority);
			list.itemData[idx] := priority;
			
			aJP := list.itemObject[idx].CM_JobPriority;// PAR 34655
			if aJP &lt;&gt; null then// PAR 34655
				aJP.setTypePriority(aJP.craneType, aJP.jobType, priority);// PAR 34655
			endif;
		endif;
		if list.itemLevel[idx] = self.LevelCrane then
			break;
		endif;
	endforeach;
end;</source>
        <Parameter name="_priType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="7e1897bc-24cf-4e40-becf-e5d6f0bf8019">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		05 April 2006  By Andrew Bishop cnwab1
//
// Purpose:		
//03 August 2016	cnwma1	Initial creation FS # 2230:System Config - Issues
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod();


	create self.myController transient;
	
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;	
	self.showToolbar := true;
	
	if self.priorityClass = null then // ROOT
		self.priorityClass := CM_JobPriorityRoot;
		self.priorityObject := app.myRoot;
		self.btnReset.visible := false;
		// PAR 34655		self.ckbSystemDefault.visible := false;//added by cnwyl1
		
		/*   cnwma1 03/08/2016 TFS #2230
		self.optUseSystem.visible := false; // PAR 34655
		self.optUseVessel.visible := false; // PAR 34655
		self.optUseVoyage.visible := false; // PAR 34655
		self.optUseSystem.value := true; // PAR 34655
		*/
		//  cnwma1 03/08/2016 TFS #2230
		self.optUseSystem.value := true;   //  cnwma1 03/08/2016 TFS #2230
		self.optUseSystem.visible := true; //  cnwma1 03/08/2016 TFS #2230
		self.optUseVessel.visible := true; //  cnwma1 03/08/2016 TFS #2230
		self.optUseVoyage.visible := true; //  cnwma1 03/08/2016 TFS #2230
		self.optUseVessel.enabled :=false; //  cnwma1 03/08/2016 TFS #2230
		self.optUseVoyage.enabled :=false; //  cnwma1 03/08/2016 TFS #2230
	elseif self.priorityClass = CM_JobPriorityVoyage then // PAR 34655
// PAR 34655		self.ckbSystemDefault.visible := true;
// PAR 34655		self.ckbSystemDefault.value := false;//added by cnwyl1
		self.optUseSystem.visible := true; // PAR 34655
		self.optUseVessel.visible := true; // PAR 34655
		self.optUseVoyage.visible := true; // PAR 34655
		self.optUseVoyage.value := true; // PAR 34655
	else // VESSEL
// PAR 34655		self.ckbSystemDefault.visible := true;
// PAR 34655		self.ckbSystemDefault.value := false;//added by cnwyl1
		self.optUseVoyage.visible := false; // PAR 34655
		self.optUseSystem.visible := true; // PAR 34655rew
		self.optUseVessel.visible := true; // PAR 34655
		self.optUseVessel.value := true; // PAR 34655
	endif;

	self.setNavigatorHeading(self.priorityObject.getNiceName());
	
	self.populateControllerForDisplay();
	
	if self.myController.allJobPriorities.isEmpty then // first time for this terminal, voyage, vessel etc. create defaults
		self.myController.populateDefaults();
		app.myTrxCA.trxCreateVoyageJobPriority(self.myController, app.myPassport);
	endif;
	self.lstJobPriority.multiSelect := ListBox.MultiSelect_Extended;//added by cnwyl1 for 12216

	self.initListBox();
	self.caption :=  app.getErrorString1(JoBPriorities,  self.priorityObject.getNiceName() &amp; " " &amp; self.myController.tempLabel); //   "Job Priorities " &amp; self.priorityObject.getNiceName() &amp; " " &amp; self.myController.tempLabel;
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnDelete.enabled:= false;
		self.btnNew.enabled:= false;
		self.btnReset.enabled:= false;
		self.btnSaveBase.enabled:= false;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="bb19997a-5820-45ce-9cd7-17b985f2b7fe">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 05 December 2014.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0006538, locale);
	btnDelete.translateBubbleHelp(Xlat_0002851, locale);
	btnDelete.translateCaption(Xlat_0002854, locale);
	btnNew.translateBubbleHelp(Xlat_0002852, locale);
	btnNew.translateCaption(Xlat_0002855, locale);
	btnReset.translateBubbleHelp(Xlat_0002853, locale);
	btnReset.translateCaption(Xlat_0002856, locale);
	ckbSystemDefault.translateCaption(Xlat_0019996, locale);
	ckbVesselDefault.translateCaption(Xlat_0019997, locale);
	optUseSystem.translateCaption(Xlat_0019998, locale);
	optUseVessel.translateCaption(Xlat_0019999, locale);
	optUseVoyage.translateCaption(Xlat_0020000, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="unloadForm" id="89ca2b16-8eac-49af-85c2-ad1901a8f351">
        <updating/>
        <source>unloadForm(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:		06 April 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
begin

	delete self.myController;
	return inheritMethod();

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="writeListBoxDetails" id="3cf9a172-76a6-45bb-9cc8-db4ab9a6462e">
        <source>writeListBoxDetails(_title : String);

vars
	list : CM_QueueListBox;
	fromIDX, toIDX, idx : Integer;
	aJP : CM_JobPriority;
	priString : String;
begin
	list := self.lstJobPriority;
	
	fromIDX := 1;
	toIDX := list.listCount();
	
	app.writeStatement( _title);
	foreach idx in fromIDX to toIDX do
	
		aJP := list.itemObject[idx].CM_JobPriority;
		priString := "NULL";
		if aJP &lt;&gt; null then
			priString := aJP.priority.String;
		endif;
		///comment for debug
		if list.itemLevel[idx] = self.LevelCrane then
			app.writeStatement( "--" &amp; app.getJobPriorityJobName(list.itemData[idx]).String &amp; "--------" &amp; idx.asStringJMT &amp; " DATA: " &amp; list.itemData[idx].String &amp; " OBJ PRIORITY: " &amp; priString);
		endif;
		
		if list.itemLevel[idx] = self.LevelPriority then
			app.writeStatement( "----" &amp; self.getPriorityDesc (list.itemData[idx]).String &amp; "--------" &amp; idx.asStringJMT &amp; " DATA: " &amp; list.itemData[idx].String &amp; " OBJ PRIORITY: " &amp; priString);
		endif;
		
		if list.itemLevel[idx] = self.LevelJobType then
			app.writeStatement( "--------" &amp; app.getJobPriorityJobName(list.itemData[idx]).String &amp; "--------" &amp; idx.asStringJMT &amp; " DATA: " &amp; list.itemData[idx].String &amp; " OBJ PRIORITY: " &amp; priString);
		endif;
	endforeach;
	app.writeStatement( "-------------------------------------------------------------------------------");
	app.writeStatement( "-------------------------------------------------------------------------------");	
end;
</source>
        <Parameter name="_title" type="String"/>
    </JadeMethod>
</GUIClass>
