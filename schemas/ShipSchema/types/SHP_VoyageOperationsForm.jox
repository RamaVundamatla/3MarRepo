    <JadeMethod name="doLstJobsMouseDown" id="9cf16213-4442-478c-afae-a7637687ec57">
        <updating/>
        <source>doLstJobsMouseDown(_listObject : CM_Object)updating;
//--------------------------------------------------
// Created:	26 January 2004 By: cnwgd1
// 15 Oct 2012	PJS		PAr #30438 - Voyage Rationalisation
//--------------------------------------------------
vars
	job : CM_VoyageJob;
begin
	if CM_VoyageJob.hasInstance(_listObject) then
		job := _listObject.CM_VoyageJob;
		if self.lstJobs.itemSelected[self.lstJobs.listIndex] then
			//must be selecting a job
			if (not self.allSelectedVoyageJobsArray.includes(job)) then
				self.allSelectedVoyageJobsArray.add(job);
			endif;
		else
			//must be unselecting previously selected job
			if self.allSelectedVoyageJobsArray.includes(job) then
				self.allSelectedVoyageJobsArray.remove(job);
			endif;		
		endif;
	else
		// dont allow select of anything other than a job 
		if lstJobs.listIndex &lt;&gt; -1 then
			lstJobs.itemSelected[self.lstJobs.listIndex] := false;
		endif;
	endif;	
	self.lstJobsChange(_listObject);
end;</source>
        <Parameter name="_listObject" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="doMenuChangeDoorsDirections" id="1c92af2d-a335-4791-a79a-23592a2cd75e">
        <updating/>
        <source>doMenuChangeDoorsDirections(menuItem: MenuItem) updating;
/*
----------   ----------  --------------------------------------------------
Created:	14 May 2007 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	theRequest,pxySR : CM_Request;
	theDirection : Integer;
	obj : Object;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin
	//Mohammad CCMS1060
	foreach obj in self.myCurrentTableWLE.allSelectedObjects do
		theRequest := obj.CM_VoyageWLE.myRequest;
		
		if theRequest = null then
			continue;
		endif;	
		
		// epr TFS 7006 29/9/17 
		if self.mnuDoorDirections.helpKeyword = "MOTOR" then
			if menuItem = self.mnuDoorsAft then
				theDirection:=TI_DOORSDIRN_FWD;
			else
				theDirection:=TI_DOORSDIRN_AFT;
			endif;
				
		else
			if menuItem = self.mnuDoorsAft then
				theDirection:=TI_DOORSDIRN_AFT;
			else
				theDirection:=TI_DOORSDIRN_FWD;
			endif;
		endif;	

		pxySR := app.createUpdateProxy(theRequest).CM_Request;
		pxySR.setProxyForDoorDirection(theDirection);
		
		//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			app.myTrxUA.trxUpdateSlotRequestDirection(pxySR, app.myPassport);
		
			if app.myPassport.trxCompletedOK then
				break;
			else
				theResult := app.showErrorWarningDialog(self.mnuDoorDirections.caption, app.myPassport, ErrWarnMode_Update);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			break;
			
		endwhile;
		
		delete pxySR;
	endforeach;
epilog
	delete pxySR;
	
end;</source>
        <Parameter name="menuItem" type="MenuItem"/>
    </JadeMethod>
