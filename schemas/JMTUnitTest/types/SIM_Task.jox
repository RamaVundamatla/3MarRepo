    <JadeMethod name="getTask" id="a6cb65da-1dbb-4393-9669-54c98206f2a4">
        <source>getTask() : CM_RTQueueTask;

vars
	task: SIM_Task;
begin
	if not global.isValidObject(self.myTask) then
		return null;
	endif;

	if self.myTask &lt;&gt; null then
		return self.myTask;
	endif;
	
	// crane
	task := self.getNextMachineFirstTask;
	if task = null then
		task := self.getPrevMachineLastTask;
	endif;
	
	if task = null then
		return null;
	endif;

	return task.getTask;
epilog

end;</source>
        <ReturnType type="CM_RTQueueTask"/>
    </JadeMethod>
    <JadeMethod name="getTrackedItem" id="a488be79-fe02-4fe0-8949-bf73c8742dfa">
        <source>getTrackedItem() : CM_TrackedItem;

vars
	task :CM_RTQueueTask;
begin
	task := self.getTask;
	if task &lt;&gt; null then
		return task.myEntry.myWorkListEntry.myTrackedItem;
	endif;
	
epilog

end;</source>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
