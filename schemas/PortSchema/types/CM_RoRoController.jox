    <JadeMethod name="validateDimensions" id="607607fb-f00e-4501-8ba2-2c8ef51e91e8">
        <source>validateDimensions() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 November 2009	cnwjk3	Initial creation

*/

vars

begin
	if self.length + self.startOffset &gt; self.myRoRoLaneArea.maxLaneLen then
		app.raiseCMException3(RoRo_LaneLenExceedsMax, self.id, (self.length + self.startOffset).String, self.myRoRoLaneArea.maxLaneLen.String, null, null);
	endif;
	
	if self.length &lt; self.myRoRoLaneArea.standardGap then
		app.raiseCMException3(RoRo_LanLenLessThanStdGap, self.id, self.length.String, self.myRoRoLaneArea.standardGap.String, null, null);	
	endif;
	
	if self.length - startOffset &lt; self.usedLengthActual then
		app.raiseCMException3(RoRo_LaneLenLessThanUsed, self.id, (self.length - self.startOffset).String, self.usedLengthActual.String, null, null);		
	endif;
	
	if self.length &lt; self.MIN_LENGTH then
		app.raiseCMException2(RoRo_LaneLengthTooSmall, self.id, self.MIN_LENGTH.String, null, null);		
	endif;
	
	if self.width &lt; self.MIN_WIDTH then
		app.raiseCMException2(RoRo_LaneWidthTooSmall, self.id, self.MIN_WIDTH.String, null, null);		
	endif;	
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
