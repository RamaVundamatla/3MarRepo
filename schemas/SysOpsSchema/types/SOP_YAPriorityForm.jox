    <JadeMethod name="doMovePriority" id="eeed77b5-ca67-47c6-9c61-599b7aa414db">
        <source>doMovePriority(pIsUp:Boolean) protected;
// --------------------------------------------------------------------------------
// Created:		21 March 2005 by cnwdad1
//
// Purpose:		Moves the currently selected Criteria up or down one place in the
//				array.
//
// Parameters:	pIsUp - True if the Criteria is to move up, otherwise move down.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	transientObj	: CMIF_YACriteriaPriority;
	direction		: String;
	row				: Integer;
	
begin
	transientObj	:=	self.yaGetCriteriaPriority();
	
	if pIsUp then
		direction	:=	"up";
	else
		direction	:=	"down";
	endif;
	
	if transientObj = null then
		app.msgBox(	"Please select which Priority to move " &amp; direction &amp; ".",
					"Error",
					MsgBox_Information_Icon + MsgBox_OK_Only);
		return;
	endif;
	
	self.yaCriteria.allSelectedCPs.moveElement(transientObj, pIsUp);
	self.yaRefreshCriteriaPriority(null);

//	row	:=	tblPriorities.cnEcFindObjectRowNo(transientObj);
	
//	if row &lt;=0 or row &gt; tblPriorities.rows then
//		return;
//	endif;

//	tblPriorities.row	:=	row;

end;</source>
        <access>protected</access>
        <Parameter name="pIsUp" type="Boolean"/>
    </JadeMethod>
