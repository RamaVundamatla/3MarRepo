        <source>setForUpdate(_pxy : CM_WebSiteConfig) updating;
// -------------------------------------------
// Created 24 November 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	self.loginPage 				:= _pxy.loginPage;
	self.currentReportsPage		:= _pxy.currentReportsPage;
	self.changePasswordPage		:= _pxy.changePasswordPage;
	self.infoPage				:= _pxy.infoPage;
	self.listPage				:= _pxy.listPage;
	self.outputPage				:= _pxy.outputPage;
	self.criteriaPage			:= _pxy.criteriaPage;
	self.headerInPage			:= _pxy.headerInPage;
	self.headerOutPage			:= _pxy.headerOutPage;
	self.footerPage				:= _pxy.footerPage;
	self.schemaName				:= _pxy.schemaName;
	self.directoryPath			:= _pxy.directoryPath;
	self.name					:= _pxy.name;
	self.isSecure				:= _pxy.isSecure;
	self.publicUser				:= _pxy.publicUser;
	self.sessionTimeoutMinutes	:= _pxy.sessionTimeoutMinutes;
	self.virtualDirectory		:= _pxy.virtualDirectory;
	self.machineName			:= _pxy.machineName;
	self.eventReqStopMaintPage := _pxy.eventReqStopMaintPage;
	self.eventReqStopViewPage := _pxy.eventReqStopViewPage;
	self.eventNotifyMaintPage := _pxy.eventNotifyMaintPage;
	self.eventNotifyViewPage := _pxy.eventNotifyViewPage;
	self.prenoteMaintPage		:= _pxy.prenoteMaintPage;
	self.prenoteViewPage		:= _pxy.prenoteViewPage;
	self.myPDFPrinter			:= _pxy.myPDFPrinter;
	self.webApplicationName		:= _pxy.webApplicationName;
	self.myRoot					:= _pxy.myRoot;
	
	//web service
	self.downloadFileDirectoryPath	:= _pxy.downloadFileDirectoryPath;
	self.downloadFileDirectoryURL	:= _pxy.downloadFileDirectoryURL;
	self.downloadFileTimeout		:= _pxy.downloadFileTimeout;
	self.helpFileURL				:= _pxy.helpFileURL;
	
	self.isWebServiceConfig			:= _pxy.isWebServiceConfig;
	
	self.downloadFileRemoteCopy := _pxy.downloadFileRemoteCopy; //27/07/2010 cnwdz2 24674
	self.defaultLoggingLevel := _pxy.defaultLoggingLevel;	// TFS 51054 navmd1 01/04/21
