    <JadeMethod name="setControlsForAddEdit" id="2f0813be-4404-4957-85c3-f2a292920b19">
        <updating/>
        <source>setControlsForAddEdit() updating;

vars
	theForm : SOP_TableMaintForm;

begin
  
  theForm := self.myForm;
	theForm.tblInput1.userInputEnabled 	:= true;
	theForm.mulSelect1.userInputEnabled := true;

	theForm.btnAddNew.enabled 			:= true;	// cnwvu1	Par12726	27/10/2006
	theForm.txtName.enabled 			:= true;
	theForm.txtName.readOnly			:= false;
	theForm.txtEmailName.enabled 		:= true;
	theForm.txtEmailName.readOnly		:= false;	
	
	if theForm.mode = theForm.Mode_Add then
		theForm.tblInput1.clearValues;
	    theForm.cmbDebtor.setObject(null);
		theForm.tblInput1.setValueByName(ETRow_Colour, White.String);
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);
		theForm.mulSelect1.setSelected(null);		
	   	theForm.cmbDebtor.setObject(null);
	   	theForm.myAssistant.comboBoxConsignGroup(theForm.cmbConsignGroup, null);
		theForm.tblInput1.moveFirst();	   	
		theForm.tblInput1.gotFocus(theForm.tblInput1);	// sets case etc.
	else
		// refresh the data from the newly created proxy
		self.showThumbnail(theForm.myProxyObject.CM_ConsigneeConsignor);
		// cannot update code
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);
				
	endif;
	theForm.tblInput1.disableRowByName(ETRow_FinancialId);		//04.Mar.24 navsp1 TFS 57177
    theForm.btnAction01.visible := false;
	if theForm.mode = theForm.Mode_Update and theForm.mulSelect1.isMySheetVisible then
		theForm.mulSelect1.setFocus;
	else
		theForm.tblInput1.setFocus;
	endif;
	theForm.tblInput1.moveFirst();

end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="4bade1ce-37f1-4ade-85ea-40879d5353cd">
