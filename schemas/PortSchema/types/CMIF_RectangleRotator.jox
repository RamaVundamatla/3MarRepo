<Class name="CMIF_RectangleRotator" id="f2cc0276-70b6-4901-ad25-bc60496bebe2">
    <superclass name="CMIF_RectangleManipulator"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmui"/>
    <PrimAttribute name="startAngle" id="722e9388-8e25-4c7e-a2f9-d78881e41325">
        <embedded/>
        <type name="Real"/>
        <access>protected</access>
    </PrimAttribute>
    <JadeMethod name="adjustedAngle" id="afee29be-439f-44f2-b664-2465c821beee">
        <source>adjustedAngle(x:Real;y:Real):Real protected;
// ---------------------------------------------------------------------------
// Created:		23 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// Returns degrees from 0
// If x,y is a point on a form then 0 = down, 90 = right, 180 = up, 270 = left
vars
	angle : Real;
begin
	if y &lt;&gt; 0 then
		angle := (x/y).abs.arctan;
	else	//avoid div by zero
		if x &gt;= 0 then
	 		return 90;
	 	else
			return 270;
		endif;
	endif;
	
	if x &gt;= 0 then
		if y &gt;0 then
			return 0 + angle;
		else
			return 180 - angle;
		endif;
	else
		if y &gt;0 then
			return 360 - angle;
		else
			return 180 + angle;
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="doRotate" id="a9045aae-30a6-47ab-acb7-a83be6906ba5">
        <updating/>
        <source>doRotate(_currentX,_currentY : Real) updating;
// ---------------------------------------------------------------------------
// Created:		23 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	diff	: Real;
begin
	
	diff := self.startAngle - adjustedAngle(_currentX-self.centrePoint.x,_currentY-self.centrePoint.y);
	
	self.rotatePoints(diff);
	
end;</source>
        <Parameter name="_currentX" type="Real"/>
        <Parameter name="_currentY" type="Real"/>
    </JadeMethod>
    <JadeMethod name="originalAngle" id="402749f1-165d-4d44-ac42-aa9711d548b8">
        <source>originalAngle(): Real protected;
// ---------------------------------------------------------------------------
// Created:		23 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	centre	: Point;
	rStartP	: Point;
begin
	rStartP.set(originalMousePoint.x-centrePoint.x,originalMousePoint.y-centrePoint.y);
	return adjustedAngle(rStartP.x,rStartP.y);
	
end;</source>
        <access>protected</access>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="rotatePoints" id="09af7711-3f94-4714-af08-2c8504e60197">
        <updating/>
        <source>rotatePoints(_deg:Real)updating, protected;
// ---------------------------------------------------------------------------
// Created:		23 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	length 		: Real;
	newDeg 		: Real;
	newX,newY 	: Real;
	idx			: Integer;
	newPoint,
	aPoint,
	oPoint		: Point;
		
begin
		
	self.newPoints.clear;

	foreach idx in 1 to self.originalPoints.size do
		aPoint := self.centredPoints[idx];
	
		newDeg := _deg - adjustedAngle(aPoint.x,aPoint.y) + 90;	//includes some adjustment
		
		length := ((aPoint.x.Real.squared) + (aPoint.y.Real.squared)).sqrt;

		newX := (length * newDeg.cos) + self.centrePoint.x;
		newY := (length * newDeg.sin) + self.centrePoint.y;

		newPoint.set(newX.Integer,newY.Integer);
		
		self.newPoints.add(newPoint);
	endforeach;
	
end;</source>
        <access>protected</access>
        <Parameter name="_deg" type="Real"/>
    </JadeMethod>
    <JadeMethod name="setup" id="27786602-e5bd-4c61-b33f-526e6f825b7c">
        <updating/>
        <source>setup(_originalX: Real; _originalY: Real; _originalPoints: PointArray input) updating;
// ---------------------------------------------------------------------------
// Created:		23 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod(_originalX, _originalY, _originalPoints);
	self.startAngle := self.originalAngle();
end;</source>
        <Parameter name="_originalX" type="Real"/>
        <Parameter name="_originalY" type="Real"/>
        <Parameter name="_originalPoints" type="PointArray" usage="input"/>
    </JadeMethod>
</Class>
