    <JadeMethod name="calculateMaxY" id="2bd5d948-cae2-4e5c-93d0-4f4ece5ca692">
        <updating/>
        <source>calculateMaxY() : Real updating, protected;

constants
	MAX_MULTIPLIER	: Real = 1.50;		// Set a 50% buffer above actual maximum value.
	
vars
	chartValue		: Real;
	maxValue		: Real;
	
begin
	maxValue	:=	self.yMax;
	
	foreach chartValue in self.allValues do
		if chartValue &gt; maxValue then
			maxValue	:=	chartValue * MAX_MULTIPLIER;
		endif;
	endforeach;

	if maxValue &lt; self.minMaxY then
		maxValue	:=	self.minMaxY;
	endif;
	
	self.yMax	:=	maxValue;
	
	return maxValue;
end;</source>
        <access>protected</access>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="clear" id="d076ca75-ae18-4fd4-982b-fbcdf0319141">
        <source>clear(pControlObj : Control) protected;

vars
	dcHandle		: Integer;
	windowHandle	: Integer;
	
begin
	windowHandle	:=	pControlObj.hwnd();
	dcHandle		:=	call cnEcWinGetDC(windowHandle);

	if dcHandle &lt;&gt; 0 then
		call cnEcWinBitBlt(	dcHandle,
							0,
							0,
							pControlObj.clientWidth(),
							pControlObj.clientHeight(),
							0,
							0,
							0,
							self.BLACKNESS);
	endif;

epilog
	if dcHandle &lt;&gt; 0 then
		call cnEcWinReleaseDC(windowHandle, dcHandle);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pControlObj" type="Control"/>
    </JadeMethod>
    <JadeMethod name="copyOffScreenToControl" id="7a97c193-14ae-433c-b8f3-e682a434c2bd">
        <source>copyOffScreenToControl(pControlObj : Control) protected;

vars
	dcHandle		: Integer;
	dcPicHandle		: Integer;
	windowHandle	: Integer;
	
begin
	dcHandle		:=	self.hOffScreenDC;
	windowHandle	:=	pControlObj.hwnd();
	dcPicHandle		:=	call cnEcWinGetDC(windowHandle);

	if dcPicHandle &lt;&gt; 0 and dcHandle &lt;&gt; 0 then
		call cnEcWinBitBlt(	dcPicHandle,
							0,
							0,
							pControlObj.clientWidth(),
							pControlObj.clientHeight(),
							dcHandle,
							0,
							0,
							self.SRCCOPY);
	endif;
epilog
	if dcPicHandle &lt;&gt; 0 then
		call cnEcWinReleaseDC(windowHandle, dcPicHandle);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pControlObj" type="Control"/>
    </JadeMethod>
    <JadeMethod name="create" id="a444361d-8099-4e41-b692-a51fd9c7d499">
        <updating/>
        <source>create() updating;

begin
	self.yMax		:=	5;
	self.hPenAxis	:=	call cnEcWinCreatePen(self.PS_SOLID, 0, self.COLOR_AXIS);
end;</source>
    </JadeMethod>
    <JadeMethod name="createOffScreenResources" id="32820607-5682-4d31-a5bb-dbc84842e981">
        <updating/>
        <source>createOffScreenResources(pControlObj : Control) updating, protected;

vars
	pictureHandle	: Integer;
	dcPicHandle		: Integer;
	dcOffHandle		: Integer;
	fontHeight		: Integer;
	
begin
	self.freeOffScreenResources();
	
	pictureHandle	:=	pControlObj.hwnd();
	dcPicHandle		:=	call cnEcWinGetDC(pictureHandle);
	
	if dcPicHandle = 0 then
		return;
	endif;

	self.hOffScreenDC	:=	call cnEcWinCreateCompatibleDC(dcPicHandle);
	dcOffHandle			:=	self.hOffScreenDC;
	
	if dcOffHandle = 0 then
		return;
	endif;
		
	self.hOffScreenBmp	:=	call cnEcWinCreateCompatibleBitmap(	dcPicHandle,
																pControlObj.clientWidth(),
																pControlObj.clientHeight());
	
	if self.hOffScreenBmp &lt;&gt; 0 then
		call cnEcWinSelectObject(dcOffHandle, self.hOffScreenBmp);
	endif;
			
	fontHeight	:=	-(call cnEcWinMulDiv(	self.TEXT_POINT_SIZE,
											call cnEcWinGetDeviceCaps(dcOffHandle, self.LOGPIXELSY), 72)
					);

	if app.isUnicode() then
		self.hFont	:=	call cnEcWinCreateFontW(fontHeight,
												0,
												0,
												0,
												0,
												0,
												0,
												0,
												self.ANSI_CHARSET,
												0,
												0,
												0,
												0,
												self.TEXT_FONT_TYPEFACE);
	else
		self.hFont	:=	call cnEcWinCreateFontA(fontHeight,
												0,
												0,
												0,
												0,
												0,
												0,
												0,
												self.ANSI_CHARSET,
												0,
												0,
												0,
												0,
												self.TEXT_FONT_TYPEFACE);
	endif;
	
	if self.hFont &lt;&gt; 0 then
		call cnEcWinSelectObject(dcOffHandle, self.hFont);
	endif;
	
	call cnEcWinSetBkColor(dcOffHandle, Black);
	call cnEcWinSetTextColor(dcOffHandle, self.COLOR_TEXT);
epilog
	if dcPicHandle &lt;&gt; 0 then
		call cnEcWinReleaseDC(pictureHandle, dcPicHandle);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pControlObj" type="Control"/>
    </JadeMethod>
    <JadeMethod name="delete" id="1016cdb6-7b12-4aa3-80d3-71a7faed9920">
        <updating/>
        <source>delete() updating;

begin
	self.freeOffScreenResources();

	if self.hPenValue &lt;&gt; 0 then
		call cnEcWinDeleteObject(self.hPenValue);
		self.hPenValue	:=	0;
	endif;

	if self.hPenAxis &lt;&gt; 0 then
		call cnEcWinDeleteObject(self.hPenAxis);
		self.hPenAxis	:=	0;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="de8be60d-33f1-4be5-b1a7-022f9456a81c">
        <updating/>
        <source>doRefresh() updating, protected;

vars
	axisIncrement		: Integer;
	incrementPosition	: Integer;
	graphBottom			: Integer;
	dcHandle			: Integer;
	maxIncrement		: Real;
	textPosition		: Real;
	topPosition			: Real;
	controlObj			: Control;
	
begin
	self.updateCount	:=	0;
	controlObj			:=	self.myControl;

	if (not controlObj.visible) then
		// The window is not visible so don't bother drawing anything.
		self.freeOffScreenResources();
		return;
	endif;

	self.createOffScreenResources(controlObj);
	
	self.clientHeight	:=	controlObj.clientHeight();
	self.clientWidth	:=	controlObj.clientWidth();

	self.graphHeight	:=	self.clientHeight - (self.TOP_BOTTOM_MARGIN * 2);
	self.graphWidth		:=	self.clientWidth - (self.LEFT_MARGIN + self.RIGHT_MARGIN);
	self.yScale			:=	self.graphHeight / self.calculateMaxY();
	self.maxDisplayableValues := (self.graphWidth div self.AXIS_INCREMENT) + 1;
	
	self.isPictureTooSmall	:=	(self.graphHeight &lt;= 0 or self.graphWidth &lt;= 0);
	
	if self.isPictureTooSmall then
		// The window is too small to draw anything of use.
		self.clear(controlObj);
		return;
	endif;

	dcHandle	:=	self.hOffScreenDC;
	
	if dcHandle = 0 then
		// We haven't got an off-screen device context to draw in!
		self.clear(controlObj);
		return;
	endif;

	graphBottom := self.clientHeight - self.TOP_BOTTOM_MARGIN;

	call cnEcWinSelectObject(dcHandle, self.hPenAxis);
	
	foreach incrementPosition in 0 to self.graphWidth step self.AXIS_INCREMENT do
		call cnEcWinMoveToEx(dcHandle, self.LEFT_MARGIN + incrementPosition, graphBottom, 0);
		call cnEcWinLineTo(dcHandle, self.LEFT_MARGIN + incrementPosition, self.TOP_BOTTOM_MARGIN);
	endforeach;

	foreach incrementPosition in 0 to self.graphHeight step self.AXIS_INCREMENT do
		call cnEcWinMoveToEx(dcHandle, self.LEFT_MARGIN, graphBottom - incrementPosition, 0);
		call cnEcWinLineTo(dcHandle, self.clientWidth - self.RIGHT_MARGIN, graphBottom - incrementPosition);
	endforeach;

	self.drawTextRightAligned(dcHandle, '0', graphBottom - 6, self.LEFT_MARGIN - 3);
	self.drawTextRightAligned(dcHandle, "Rate", self.TOP_BOTTOM_MARGIN - 14, self.LEFT_MARGIN + 11);
	self.drawTextRightAligned(dcHandle, "Time", graphBottom + 2, (self.clientWidth - self.RIGHT_MARGIN) + 1);

	incrementPosition	:=	(self.graphHeight div self.AXIS_INCREMENT) * self.AXIS_INCREMENT;
	
	if (graphBottom - incrementPosition) &lt; (graphBottom - (self.graphHeight - 4)) then
		incrementPosition	:=	incrementPosition - self.AXIS_INCREMENT;
	endif;

	axisIncrement	:=	incrementPosition div self.AXIS_INCREMENT;
	
	if axisIncrement &gt;= 1 then	
		maxIncrement	:=	(incrementPosition / self.yScale).roundedTo(0);
		
		if maxIncrement &gt;= 1 then
			self.drawTextRightAligned(dcHandle, maxIncrement.String, graphBottom - incrementPosition - 6, self.LEFT_MARGIN - 3);
			
			if axisIncrement &gt;= 2 then
				textPosition	:=	(maxIncrement / 2).roundedTo(0);
				topPosition		:=	graphBottom - ((textPosition / maxIncrement) * incrementPosition) - 6;
				self.drawTextRightAligned(dcHandle, textPosition.String, topPosition.Integer, self.LEFT_MARGIN - 3);
			endif;
		endif;
	endif;

	self.refreshValues(self.allValues, dcHandle);

	self.copyOffScreenToControl(controlObj);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doUpdate" id="eb153090-e3d9-4f5b-b892-9b421b726d29">
        <updating/>
        <source>doUpdate(pNewValue : Real) updating, protected;

vars
	valueArray		: RealArray;
	maxValues		: Real;
	graphBottom		: Integer;
	valueCount		: Integer;
	dcHandle		: Integer;
	yOffset			: Integer;
	updCount		: Integer;
	controlObj		: Control;
	priorValue  	: Real;
	scaleDecay		: Real;
	
begin
	updCount			:=	self.updateCount + 1;
	self.updateCount	:=	updCount;
	maxValues			:=	self.maxDisplayableValues;
	valueArray			:=	self.allValues;
	valueCount			:=	valueArray.size();
			
	if valueCount &gt; maxValues then
		// Remove the oldest value.
		valueArray.removeAt(1);
	else
		// We're about to add another value to the array.
		valueCount	:=	valueCount + 1;
	endif;

	priorValue	:=	valueArray.last();
	valueArray.add(pNewValue);

	if pNewValue &gt; self.yMax then
		// We need to adjust the y-scale and refresh the graph.
		self.refresh();
		return;
	endif;
	
	if self.isPictureTooSmall then
		// The window is too small to draw anything of use.
		return;
	endif;

	if updCount &gt; maxValues and valueCount &gt; 2 then
		scaleDecay	:=	self.yMax * 0.5;
		
		if priorValue &lt;= scaleDecay and pNewValue &lt;= scaleDecay then
			// We've had a window's worth of updates and the last two values
			// are both in the bottom half of the graph. Decay the y-scale
			// by 25% so that the graph will slowly adjust to be appropriate
			// for the incoming values.
			self.yMax	:=	self.yMax * 0.75;
			self.refresh();
			return;
		endif;
	endif;

	controlObj	:=	self.myControl;
	
	if (not controlObj.visible) then
		// The window is not visible so don't bother drawing anything.
		return;
	endif;
	
	dcHandle	:=	self.hOffScreenDC;
	self.scrollOffScreen();
	graphBottom	:=	self.clientHeight - self.TOP_BOTTOM_MARGIN;
	call cnEcWinSelectObject(dcHandle, self.hPenAxis);

	foreach yOffset in 0 to self.graphHeight step self.AXIS_INCREMENT do
		call cnEcWinMoveToEx(	dcHandle,
								self.LEFT_MARGIN + self.graphWidth - self.AXIS_INCREMENT,
								graphBottom - yOffset,
								0);
								
		call cnEcWinLineTo(		dcHandle,
								self.clientWidth - self.RIGHT_MARGIN,
								graphBottom - yOffset);
	endforeach;

	call cnEcWinMoveToEx(	dcHandle,
							self.LEFT_MARGIN + ((self.graphWidth div self.AXIS_INCREMENT) * self.AXIS_INCREMENT),
							graphBottom,
							0);
		
	call cnEcWinLineTo(		dcHandle,
							self.LEFT_MARGIN + ((self.graphWidth div self.AXIS_INCREMENT) * self.AXIS_INCREMENT),
							graphBottom - self.graphHeight);

	self.updateValue(valueArray, valueCount, graphBottom, dcHandle);
	self.copyOffScreenToControl(controlObj);
end;</source>
        <access>protected</access>
        <Parameter name="pNewValue" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawTextRightAligned" id="8edb202d-2e4b-4fd2-a666-bfed234da33a">
        <source>drawTextRightAligned(pDCHandle : Integer; pText : String; pTop : Integer; pRight : Integer) protected;

vars
	rectangle	: Binary;
	
begin
	rectangle[ 1 : 4]	:=	0.Binary;
	rectangle[ 5 : 4]	:=	pTop.Binary;
	rectangle[ 9 : 4]	:=	pRight.Binary;
	rectangle[13 : 4]	:=	self.clientHeight.Binary;
	
	if app.isUnicode() then
		call cnEcWinDrawTextExW(pDCHandle, pText, pText.length, rectangle, self.DT_RIGHT, 0);
	else
		call cnEcWinDrawTextExA(pDCHandle, pText, pText.length, rectangle, self.DT_RIGHT, 0);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pDCHandle" type="Integer"/>
        <Parameter name="pText" type="String"/>
        <Parameter name="pTop" type="Integer"/>
        <Parameter name="pRight" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="freeOffScreenResources" id="f093554c-5d29-4f68-b590-ad15ac1dd402">
        <updating/>
        <source>freeOffScreenResources() updating, protected;

begin
	if self.hOffScreenDC &lt;&gt; 0 then
		call cnEcWinDeleteDC(self.hOffScreenDC);
		self.hOffScreenDC := 0;
	endif;
	
	if self.hOffScreenBmp &lt;&gt; 0 then
		call cnEcWinDeleteObject(self.hOffScreenBmp);
		self.hOffScreenBmp := 0;
	endif;
	
	if self.hFont &lt;&gt; 0 then
		call cnEcWinDeleteObject(self.hFont);
		self.hFont := 0;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initializeMe" id="950cbc1f-e79a-4d11-bca4-f1680d30cbd8">
        <updating/>
        <source>initializeMe(pPictureObj : Picture; pColor : Integer; pMinY : Real) updating;

begin
	self.freeOffScreenResources();

	if pMinY &lt; 0 then
		self.minMaxY	:=	0;
	else
		self.minMaxY	:=	pMinY;
	endif;
		
	self.yMax	:=	self.minMaxY;
	
	self.myControl				:=	pPictureObj;
	self.myControl.autoRedraw	:=	false;
	    
	if self.hPenValue &lt;&gt; 0 then
		call cnEcWinDeleteObject(self.hPenValue);
		self.hPenValue	:=	0;
	endif;

	self.hPenValue	:=	call cnEcWinCreatePen(self.PS_SOLID, 0, pColor);

	self.refresh();
end;</source>
        <Parameter name="pPictureObj" type="Picture"/>
        <Parameter name="pColor" type="Integer"/>
        <Parameter name="pMinY" type="Real"/>
    </JadeMethod>
    <JadeMethod name="refresh" id="87d20e71-941a-47ff-b57b-5df328bb7378">
        <updating/>
        <source>refresh() updating;

vars
	errorNumber	: Integer; // Initialized to zero.
		
begin
	on Exception do self.xHandlerResumeNext(exception, errorNumber);
	
	self.doRefresh();

	// if the refresh encounters an exception, our handler will
	// resume to here and we'll simply abandon the operation
	if errorNumber &lt;&gt; 0 then
		self.freeOffScreenResources();
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="refreshValues" id="f481acb1-4c3e-440e-8a50-00bd6faf8b4d">
        <source>refreshValues(pValueArray : RealArray; pDCHandle : Integer) protected;

vars
	xCoordinate	: Real;
	xPrior		: Real;
	yCoordinate	: Real;
	yPrior		: Real;
	realValue	: Real;
	graphBase	: Real;
	graphWide	: Real;
	scaleY		: Real;
	maxValues	: Integer;
	valueCount	: Integer;
	
begin
	scaleY		:=	self.yScale;
	maxValues	:=	self.maxDisplayableValues;
	graphBase	:=	self.clientHeight - self.TOP_BOTTOM_MARGIN;
	graphWide	:=	self.graphWidth;
	xPrior		:=	-1;
	yPrior		:=	-1;
	valueCount	:=	0;
	
	call cnEcWinSelectObject(pDCHandle, self.hPenValue);

	foreach realValue in pValueArray reversed do
		xCoordinate	:=	self.LEFT_MARGIN + (graphWide - (self.AXIS_INCREMENT * valueCount));
		yCoordinate	:=	graphBase - (realValue * scaleY);

		if xPrior &gt;= 0 and yPrior &gt;= 0 then
			call cnEcWinMoveToEx(pDCHandle, xPrior.Integer, yPrior.Integer, 0);
			call cnEcWinLineTo(pDCHandle, xCoordinate.Integer, yCoordinate.Integer);
		endif;

		xPrior	:=	xCoordinate;
		yPrior	:=	yCoordinate;

		valueCount	:=	valueCount + 1;
				
		if valueCount &gt;= maxValues then
			break;
		endif;
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="pValueArray" type="RealArray"/>
        <Parameter name="pDCHandle" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="scrollOffScreen" id="73c63d56-d7bf-43ac-987b-65c6bef15787">
        <updating/>
        <source>scrollOffScreen() updating, protected;

vars
	dcHandle	: Integer;
	
begin
	dcHandle	:=	self.hOffScreenDC;
	
	if dcHandle &lt;&gt; 0 then
		call cnEcWinBitBlt(	dcHandle,
							self.LEFT_MARGIN,
							self.TOP_BOTTOM_MARGIN,
							self.graphWidth + 1,
							self.graphHeight + 1,
							dcHandle,
							self.LEFT_MARGIN + self.AXIS_INCREMENT,
							self.TOP_BOTTOM_MARGIN,
							self.SRCCOPY);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="updateMe" id="02f0a198-ec8e-480d-b8e8-1e66728c783f">
        <updating/>
        <source>updateMe(pNewValue : Real) updating;

vars
	errorNumber	: Integer; // Initialized to zero.

begin
	on Exception do self.xHandlerResumeNext(exception, errorNumber);

	self.doUpdate(pNewValue);

	// If the update encounters an exception, our handler will
	// resume to here and we'll simply abandon the operation.
end;</source>
        <Parameter name="pNewValue" type="Real"/>
    </JadeMethod>
    <JadeMethod name="updateValue" id="9a0e763b-49b2-468e-a588-558e52914d58">
        <source>updateValue(pValueArray : RealArray; pValueCount : Integer; pGraphBottom : Integer; pDCHandle : Integer) protected;

vars
	realValue	: Real;
	xCoordinate	: Real;
	yCoordinate	: Real;
	yPrior		: Real;
	scaleY		: Real;
	
begin
	scaleY := self.yScale;
	
	if pValueCount &gt; 1 then
		realValue	:=	pValueArray[pValueCount - 1];
	else
		realValue	:=	0;
	endif;
	
	yPrior		:=	pGraphBottom - (realValue * scaleY);
	realValue	:=	pValueArray.last();
	yCoordinate	:=	pGraphBottom - (realValue * scaleY);
	xCoordinate	:=	self.LEFT_MARGIN + self.graphWidth - self.AXIS_INCREMENT;

	call cnEcWinSelectObject(pDCHandle, self.hPenValue);
	call cnEcWinMoveToEx(pDCHandle, xCoordinate.Integer, yPrior.Integer, 0);
	call cnEcWinLineTo(pDCHandle, (xCoordinate + self.AXIS_INCREMENT).Integer, yCoordinate.Integer);
end;</source>
        <access>protected</access>
        <Parameter name="pValueArray" type="RealArray"/>
        <Parameter name="pValueCount" type="Integer"/>
        <Parameter name="pGraphBottom" type="Integer"/>
        <Parameter name="pDCHandle" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="xHandlerResumeNext" id="507addc0-a7eb-4e2f-bb43-15eb39154428">
        <source>xHandlerResumeNext(pExceptionObj : Exception; pErrorNumber : Integer output) : Integer protected;

begin
	pErrorNumber	:=	pExceptionObj.errorCode;
	return Ex_Resume_Next;
end;</source>
        <access>protected</access>
        <Parameter name="pExceptionObj" type="Exception"/>
        <Parameter name="pErrorNumber" type="Integer" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
