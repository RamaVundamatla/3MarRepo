    <JadeMethod name="getYardInterchangeArea" id="1fd9226a-6f3a-4fd7-9b80-1e1abf97a7b7">
        <source>getYardInterchangeArea() : CM_TerminalArea;
/*
Purpose:			
Parameters:	_useGate 	- if false just returns whatever was entered as override value or
						  null if no override was entered
						- if true will try and work out what IC area the job is destined for
Return Value:		


Date			Who		Reason
18 August 2006	cnwer1	Initial creation - PAR#xxxx
28/08/2009		cnwcs5	ccms 1061 - gate config changes
25/02/2010		cnwcs5	renamed method to reflect purpose
27/05/2010		cnwcs5	par 24292 - use CM_InterchangeArea instead of CM_YardInterchangeArea
18/06/2010		cnwcs5	par 24418 - removed _useGate parameter
*/
vars
	
begin
	if self.myGate = null then   // PAR 25744
		return null;
	endif;

	return self.myGate.getDefaultInterchangeArea_IN (self.myVehicle);	// 17/06/2010 cnwcs5 par 24418
epilog

end;</source>
        <ReturnType type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="hasAnyIdToLoad" id="c62de1f1-5ff7-4b8c-acec-463ef4bab7db">
        <source>hasAnyIdToLoad() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 July 2017	jlger1	Initial creation 5597

*/

vars

	wle : CM_WorkListEntry;
begin
	foreach wle in self.workListEntries discreteLock do
		if not wle.isReceipt then //epr TFS 37814 29/5/18
			if wle.myRequest &lt;&gt; null and (wle.myRequest.isAnyId() and wle.myRequest.isAnyAmount) then
				return true;
			endif;
		endif;
	endforeach;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasCargoToQueue" id="9a06eb72-27d9-4cbb-a76b-7014a5d6bb91">
        <source>hasCargoToQueue(_isRelease : Boolean; _both : Boolean) : Boolean;
// ---------------------------------------------------------------------------
// Created:     15 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tmpTI : CM_TrackedItem;
begin
	// PAR 18699 - Release by type will not have any cargo ids
	if self.isReleaseByType then
		return true;
	endif;
	
	if _isRelease or _both then
		foreach tmpTI in self.allReceiveTrackedItems discreteLock do
			if tmpTI.getImExStatus = TI_IMEX_STATUS_REMAINONBOARD then
				continue;
			endif;
			if tmpTI.myPrimaryQueuedLocation = null then
				return true;
			endif;
		endforeach;
	endif;
		
	if not _isRelease or _both then
		foreach tmpTI in self.allReleaseTrackedItems discreteLock do
			if tmpTI.getImExStatus = TI_IMEX_STATUS_REMAINONBOARD then
				continue;
			endif;
			if tmpTI.myPrimaryQueuedLocation = null then
				return true;
			endif;
		endforeach;
	endif;
	
	return false;
		
epilog

end;</source>
        <Parameter name="_isRelease" type="Boolean"/>
        <Parameter name="_both" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasJobActivityType" id="31a4d3c6-21dd-4982-b107-211910e633f8">
        <source>hasJobActivityType(_type: Integer): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/03/2024	navkc1 CR62696 Task 62944: UI - Retrospective UI Stop Start Option

*/

vars
	vvr			: CM_VehicleVisitRecord;
	
	vvrDtl		: CM_VehicleVisitRecordDetail;
	
	first		: Boolean;
	ts			: TimeStamp;
begin
	vvr := self.myVehicleVisit;
	
	if vvr = null then
		return false;
	endif;
	
	first := true;
	ts := null;
	
	vvrDtl := vvr.getNextVVRDtlJobAction(ts, _type);
	
	return vvrDtl &lt;&gt; null;
epilog

end;</source>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="ignoreUpdateJobStatus" id="c8f054e0-acf6-4d61-a2cf-f418daf043d1">
        <source>ignoreUpdateJobStatus(): Boolean;
/*

Purpose: This method is used to exclude the trailers wle status to update the road job specifically for EUP.		

Parameters:			

Return Value:		

Date		Who		Reason
08 Apr 2024 navhl20 ChangeRequest 63148: EUP* | 53729 - Delivery Dispatch Screen - Should not update job status when trailers got completed.

*/

vars
	chassisIn,
	chassisOut	: CM_TILC;
	hasChassis	: Boolean;
begin
	if not self.myTerminal.getConfig(UseYardJobsCargoWO).Boolean then
		return false;
	endif;
	
	chassisIn := self.getChassis(true,hasChassis);
	if hasChassis and chassisIn &lt;&gt; null then
		return true;
	endif;
	
	chassisOut := self.getChassis(false,hasChassis);
	if hasChassis and chassisOut &lt;&gt; null then
		return true;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initializeForActivity" id="91b85d39-4681-4579-b103-8726e5295698">
        <updating/>
        <source>initializeForActivity(_ewsOpsView: CM_EWSActivityOpsview; _opsViewTable: CMIF_OpsViewTables) updating;
/*
Purpose:			

Date		Who		Reason
04 May 2022	navab1	TFS 53569
*/

vars

	xpsCraneShift	    	: CMIF_XpsCraneshift;

begin
	inheritMethod(_ewsOpsView, _opsViewTable);
	

	if _opsViewTable.isKindOf(CMIF_XpsCraneshift) then
		xpsCraneShift := _opsViewTable.CMIF_XpsCraneshift;
		xpsCraneShift.visit := self.myVehicleVisit.jobNumber;
	endif;
	
	

epilog

end;</source>
        <Parameter name="_ewsOpsView" type="CM_EWSActivityOpsview"/>
        <Parameter name="_opsViewTable" type="CMIF_OpsViewTables"/>
    </JadeMethod>
    <JadeMethod name="isDirectDeliveryJob" id="422d25ad-2adc-442f-ab27-e196fd718c4b">
        <source>isDirectDeliveryJob(): Boolean;
//
// Purpose:			A Road Job is Direct Delivery if any of its WLEs have direct delivery children
//					that belong to a Voyage Hold Direct Delivery job
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 06/12/2021	navdap1		Initial creation TFS 52293 SAL Direct Laoding - Marking Job as Direct Delivery
// 06 Mar 2025  navma1 		MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
//
vars
	ddJob : Boolean;
	wle, voyageWle : CM_WorkListEntry;

begin
	ddJob := false;
	
	foreach wle in self.workListEntries discreteLock do							//06.03.2025 navma1 #MTN-34179
		foreach voyageWle in wle.allDirectDeliveryChildWLEs  discreteLock do	//06.03.2025 navma1 #MTN-34179
			if voyageWle.isKindOf(CM_VoyageWLE) and voyageWle.job.isDirectDeliveryJob then
				ddJob := true;
				break;
			endif;
		endforeach;
	endforeach;
	
	return ddJob;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isInUseByDevices" id="2315e504-77be-40eb-b0d1-4a8ecadaeb64">
