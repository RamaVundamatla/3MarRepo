    <JadeMethod name="addObjectsToTable" id="75ebb37d-f0ef-4188-a0f1-158eddf313bb">
        <updating/>
        <source>addObjectsToTable(_numItems: Integer io) updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aCalculationType : CM_CalculationType;
	theCalculationTypes :	CM_CalculationTypeByCodeDict;
	tmpPassport	: CM_Passport;
	breakOut	: Boolean;
begin

	self.setMyDataClass();
	beginClassNotification(CM_CalculationType, false, Object_Create_Event, Response_Continuous, 0); 

	theCalculationTypes := app.myRoot.allCalculationTypesByCode;
	tmpPassport := app.myPassport;
	
	foreach aCalculationType in theCalculationTypes  do
		if self.includeObject(aCalculationType, tmpPassport) then
			self.addObjectToTable(aCalculationType, _numItems, breakOut);
		endif;
		if breakOut then
			break;
		endif;
	endforeach;

end;</source>
        <Parameter name="_numItems" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="710224aa-a126-48af-aad9-e9b450ea9d13">
        <source>addToolbarControls()  protected;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	toolbar			: CMUI_Toolbar;
	showCaptions	: Boolean;

begin
	inheritMethod();

	toolbar := self.frmRangeTB;
	toolbar.addButton(self.btnSaveRange, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnAddRange, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnDeleteRange, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCancelRange, CMUI_Toolbar.Control_Alignment_Right);

	toolbar.positionToolbarControls();
	toolbar.visible := true;

	// ### TFS 51912 22Sep2021 NAVPW1
	toolbar := self.frmToolbar;
/*	//05/06/2024	navkc1 CR 63736 Task 63770 - Replaced with new control
	// ### TFS 51912 22Sep2021 NAVPW1
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left); 				
	toolbar.addFrame(self.frmFilter, CMUI_Toolbar.Control_Alignment_Left);
	
	// ### TFS 51912 22Sep2021 NAVPW1
	self.txtFilterBox.parent 	:= self.frmFilter;
	self.txtFilterBox.visible 	:= true;
	self.txtFilterBox.left 		:= 0;
	self.txtFilterBox.top 		:= 2;

	// ### TFS 51912 22Sep2021 NAVPW1
	toolbar.addButton(self.btnClearFilter, CMUI_Toolbar.Control_Alignment_Left);
*/	

	self.frmToolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);					//05/06/2024	navkc1 CR 63736 Task 63770
	self.frmToolbar.addFrame(self.frmTableFilter, CMUI_Toolbar.Control_Alignment_Left);	//05/06/2024	navkc1 CR 63736 Task 63770
end;</source>
        <access>protected</access>
    </JadeMethod>
