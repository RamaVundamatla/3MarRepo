        <updating/>
        <source>cmbOutputFormats_click(combobox: ComboBox input) updating;

begin
	app.mousePointer	:=	Busy;
	self.lstFormatClassesPopulate();
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createDefaultFormatProperties" id="2ec65c64-9cf6-4af2-8653-a0956fb46807">
        <updating/>
        <source>createDefaultFormatProperties(	pClassObj : Class;
								pFormatClassObj : CnEcXmlFormatClass;
								pFormatObj : CnEcXmlFormat) updating, protected;

vars
	propertyCollObj		: PropertyColl;
	propertyObj			: Property;
	formatPropertyObj	: CnEcXmlFormatProperty;
	className			: String;
	
begin
	propertyCollObj	:=	pClassObj.allPropertiesUpTo(Object);
	
	foreach propertyObj in propertyCollObj do
		if propertyObj.isKindOf(Attribute) then	  
			// create formatAttribute here	
			create formatPropertyObj as CnEcXmlFormatAttribute;
			formatPropertyObj.initializeMe(propertyObj.getName(), propertyObj.getName(), true, pFormatClassObj);
		else

			if propertyObj.getType().isKindOf(CollClass) then
				// create formatCollection here
				//propertyObj.inspectModal;
				className := propertyObj.getType.CollClass.getMemberType.getName();
				
				if pFormatObj.cnEcGetFormatClass(className) &lt;&gt; null then
					create formatPropertyObj as CnEcXmlFormatCollection;
					formatPropertyObj.initializeMe(propertyObj.getName(), propertyObj.getName(), true, pFormatClassObj);
					formatPropertyObj.CnEcXmlFormatReference.setMyFormat(pFormatObj);
					formatPropertyObj.CnEcXmlFormatCollection.setIsReportSize(false);
				else
					write "Collection no matching format for " &amp; pFormatObj.formatName &amp; " - " &amp; className &amp;
							", referenced by '" &amp; pClassObj.name &amp; "." &amp; propertyObj.name &amp; "'.";
				endif;
			else
				// create formatSingleton here
				className := propertyObj.getType.getName();
				
				if pFormatObj.cnEcGetFormatClass(className) &lt;&gt; null then
					create formatPropertyObj as CnEcXmlFormatSingle;
					formatPropertyObj.initializeMe(propertyObj.getName(), propertyObj.getName(), true, pFormatClassObj);
					formatPropertyObj.CnEcXmlFormatReference.setMyFormat(pFormatObj);
				else
					write "Single no matching format for " &amp; pFormatObj.formatName &amp; " - " &amp; className &amp;
							", referenced by '" &amp; pClassObj.name &amp; "." &amp; propertyObj.name &amp; "'.";
				endif;
			endif;
		endif;
	endforeach;
epilog
	delete propertyCollObj;
end;</source>
        <access>protected</access>
        <Parameter name="pClassObj" type="Class"/>
        <Parameter name="pFormatClassObj" type="CnEcXmlFormatClass"/>
        <Parameter name="pFormatObj" type="CnEcXmlFormat"/>
    </JadeMethod>
    <JadeMethod name="createDefaultFormats" id="e358a69f-b0c0-4df3-b734-95e5dca14dfe">
        <updating/>
        <source>createDefaultFormats() updating;
//
// When this is run, the current formats are renamed as XXX_OLD, then the new formats are
// rebuilt, and finally the XXX_OLD formats are deleted.
//
// On 09/05/2007 a fault was raised because when the formats were renamed, a duplicate
// 1310 exception was raised - this was caused by a previous run being killed off half way
// thru before the XXX_OLD formats were deleted.  In this case, the solution is the write
// a script to delete the XXX_OLD formats, and then restart the rebuild.
//
vars
	formatObj         	: CnEcXmlFormat;
	formatOIDObj      	: CnEcXmlFormat;
	baseRootObj 		: CnEcBaseRoot;
	formatClassObj		: CnEcXmlFormatClass;
	formatPropertyObj	: CnEcXmlFormatProperty;
	formatMethodObj		: CnEcXmlFormatMethod;
	formatRefObj		: CnEcXmlFormatReference;
	classObj		 	: Class;
	allSubclassesObj	: ClassColl;
	className			: String;
	ts					: TimeStamp;
	noDefaultsExist		: Boolean;
	xmlFormatCollObj	: CnEcXmlFormatDict;
	startTime			: Integer;
	pName : String;	//02 Feb 2015	NDL	Par 35619
	
begin
	startTime	:=	app.clock();
	write "##### Database has changed since last update of Default XML Formats, or update requested. #####" &amp; CrLf;
	
	baseRootObj := app.myBaseRoot;
	
	if baseRootObj.getXmlFormat(app.myCnEcXmlSchema.name, CNEC_DEFAULT_FULL) = null and baseRootObj.getXmlFormat(app.myCnEcXmlSchema.name, CNEC_DEFAULT_REF) = null then
		noDefaultsExist := true;
		write "##### No Default XML Formats exist. Will create the Default XML Formats. #####" &amp; CrLf;
	else	
		write "##### Please wait while the Default XML Formats are re-created and re-mapped. #####" &amp; CrLf;
		
		formatObj := baseRootObj.getXmlFormat(app.myCnEcXmlSchema.name, CNEC_DEFAULT_FULL); 
		
		if formatObj &lt;&gt; null then
			beginTransaction;
				formatObj.renameMe(CNEC_DEFAULT_FULL &amp; "_OLD"); 
			commitTransaction;
		endif;
		
		formatObj := baseRootObj.getXmlFormat(app.myCnEcXmlSchema.name, CNEC_DEFAULT_REF); 	
		if formatObj &lt;&gt; null then
			beginTransaction;
				formatObj.renameMe(CNEC_DEFAULT_REF &amp; "_OLD"); 
			commitTransaction;
		endif;	
			
		write "##### Default XML Formats renamed. Will now create the new Formats. #####";
		write "";
	
	endif;
	
	beginTransaction;
	create formatOIDObj;
	formatOIDObj.initializeMe(CNEC_DEFAULT_REF,1,app.myCnEcXmlSchema);
	commitTransaction; 

	create allSubclassesObj transient;
	classObj := app.myCnEcXmlSchema.getClass("Object");
	classObj.allLocalSubclasses(allSubclassesObj);
	
	if not allSubclassesObj.includes(classObj) then
		allSubclassesObj.add(classObj);
	endif;
	
	classObj := app.myCnEcXmlSchema.getClass("Class");
	
	if not allSubclassesObj.includes(classObj) then
		allSubclassesObj.add(classObj);
	endif;
	
	//foreach className in baseRoot.allXmlExcludedClasses do
	if baseRootObj.getAllXmlExcludedClasses() &lt;&gt; null then 
		foreach className in baseRootObj.getAllXmlExcludedClasses() do
			classObj := app.myCnEcXmlSchema.getClass(className);
			
			if allSubclassesObj.includes(classObj) then
				allSubclassesObj.remove(classObj);
			endif;
		endforeach;
	endif;

	beginTransaction;
    foreach classObj in allSubclassesObj do
    	create formatClassObj;
    	formatClassObj.initializeMe(classObj.getName(), classObj.getName(), true, true, null, null, formatOIDObj);
    /*	create formatMethodObj;
    	formatMethodObj.initializeMe("oid", "OID", true, formatClassObj);
    	formatMethodObj.setMethodName("getOidString");
    	
    	if classObj.getName() = CnEcXmlFormat.name then
    		formatClassObj.updateMe(formatClassObj.tagName,
    								formatClassObj.isShowTagData,
    								formatClassObj.isSuppressTag,
    								"formatName",
    								"cnEcXmlImportEpilog"
    								);
    	endif; */
		//02 Feb 2015	NDL	Par 35619
		if classObj.getName() = CnEcXmlFormat.name then
		
			create formatPropertyObj as CnEcXmlFormatAttribute;
			pName := CnEcXmlFormat::formatName.name;
			formatPropertyObj.initializeMe(pName, pName, true, formatClassObj);
		
			create formatMethodObj;
			formatMethodObj.initializeMe("oid", "OID", true, formatClassObj);
			formatMethodObj.setMethodName("getOidString");
		
			formatClassObj.updateMe(formatClassObj.tagName,
    								formatClassObj.isShowTagData,
    								formatClassObj.isSuppressTag,
    								pName,
    								"cnEcXmlImportEpilog"
    								);
		
		else
			create formatMethodObj;
			formatMethodObj.initializeMe("oid", "OID", true, formatClassObj);
			formatMethodObj.setMethodName("getOidString");
    	
    	endif;
		
    endforeach;
    commitTransaction;

	beginTransaction;
	create formatObj;
	formatObj.initializeMe(CNEC_DEFAULT_FULL,1,app.myCnEcXmlSchema);
	commitTransaction;

	beginTransaction;
    foreach classObj in allSubclassesObj do
    	create formatClassObj;
    	formatClassObj.initializeMe(classObj.getName(), classObj.getName(), true, false, null, null, formatObj);
    	
    	if classObj.getName() = CnEcXmlFormat.name then
    		formatClassObj.updateMe(formatClassObj.tagName,
    								formatClassObj.isShowTagData,
    								formatClassObj.isSuppressTag,
    								"formatName",
    								"cnEcXmlImportEpilog");
    	endif;
    	
    	create formatMethodObj;
    	formatMethodObj.initializeMe("oid", "oid", true, formatClassObj);
    	formatMethodObj.setMethodName("getOidString");
	   	self.createDefaultFormatProperties(classObj, formatClassObj, formatOIDObj);
    endforeach;
    
    baseRootObj.setXmlDefaultFormatLastRebuilt(ts);
    commitTransaction;
    
    if noDefaultsExist then
    	write CrLf &amp; "##### New Default XML Formats created. #####";
    	
    else
    	write CrLf &amp; "##### New Default XML Formats created. Will now re-map where necessary. #####";
    	
	    formatObj		:= baseRootObj.getXmlFormat(app.myCnEcXmlSchema.name, CNEC_DEFAULT_FULL);
	    formatOIDObj	:= baseRootObj.getXmlFormat(app.myCnEcXmlSchema.name, CNEC_DEFAULT_REF);
    
	    beginTransaction;
	    create xmlFormatCollObj transient;
		baseRootObj.getAllFormatsForSchema(xmlFormatCollObj, app.myCnEcXmlSchema.name);
		
	    foreach formatObj in xmlFormatCollObj do 	
		    if  formatObj.formatName &lt;&gt; CNEC_DEFAULT_REF &amp; "_OLD"
		    and formatObj.formatName &lt;&gt; CNEC_DEFAULT_FULL &amp; "_OLD"
		    and formatObj.formatName &lt;&gt; CNEC_DEFAULT_REF
		    and formatObj.formatName &lt;&gt; CNEC_DEFAULT_FULL
		    then
				foreach formatClassObj in formatObj.allFormatClasses do
					foreach formatPropertyObj in formatClassObj.allProperties do
						if formatPropertyObj.isKindOf(CnEcXmlFormatReference) then
							formatRefObj := formatPropertyObj.CnEcXmlFormatReference;
							
							if app.isValidObject(formatRefObj.myFormat) then
								if formatRefObj.myFormat.formatName = CNEC_DEFAULT_REF &amp; "_OLD" then
									formatRefObj.setMyFormat(formatOIDObj);
								elseif formatRefObj.myFormat.formatName = CNEC_DEFAULT_FULL &amp; "_OLD" then
									formatRefObj.setMyFormat(formatObj);
								else
									continue;
								endif;
							endif;  
						endif;
					endforeach;
				endforeach;				
			endif;
		endforeach;
		commitTransaction;	

		write "##### Old Format mappings replaced by New. Will now delete the old Formats. #####";
		write "";
    
	    formatObj		:= baseRootObj.getXmlFormat( app.myCnEcXmlSchema.name, CNEC_DEFAULT_FULL &amp; "_OLD");
	    formatOIDObj	:= baseRootObj.getXmlFormat(app.myCnEcXmlSchema.name, CNEC_DEFAULT_REF &amp; "_OLD");
     	
	    if formatObj &lt;&gt; null then
			beginTransaction;
				delete formatObj; 
			commitTransaction;
		endif;
		
		if formatOIDObj &lt;&gt; null then
			beginTransaction;
				delete formatOIDObj; 
			commitTransaction;
		endif;	

		write "##### Old Default XML Formats deleted. #####";
	endif;
epilog 
	delete xmlFormatCollObj;
	
    write CrLf &amp; "##### Update Complete in " &amp; startTime.cnEcClockDifference().String &amp; " seconds. #####";
end;</source>
    </JadeMethod>
    <JadeMethod name="createFormatClass" id="bf89070d-0b9a-4f00-8491-5b92f20881aa">
        <source>createFormatClass(pFormatObj :CnEcXmlFormat) : CnEcXmlFormatClass protected;

vars
	formatClassObj	: CnEcXmlFormatClass;
	
begin
	create formatClassObj;
	
	formatClassObj.initializeMe(lstFormatClasses.text,
								lstFormatClasses.text,
								true,
								false,
								cmbNoidProperty.text,
								cmbEpiMethod.text,
								pFormatObj);
	
	lstFormatClasses.itemForeColor[lstFormatClasses.listIndex] := Black;

	return formatClassObj;
end;</source>
        <access>protected</access>
        <Parameter name="pFormatObj" type="CnEcXmlFormat"/>
        <ReturnType type="CnEcXmlFormatClass"/>
    </JadeMethod>
    <JadeMethod name="displayFormatClass" id="8bb6003e-5f77-4f1e-a10e-94f865dabfc8">
        <source>displayFormatClass() protected;

vars
    formatObj		: CnEcXmlFormat;
	classObj		: Class;
	classFormatObj	: CnEcXmlFormatClass;

begin
	formatObj		:=	cmbOutputFormats.listObject.CnEcXmlFormat; 
	classObj		:=	app.myCnEcXmlSchema.getClass(lstFormatClasses.text);
	classFormatObj	:=	lstFormatClasses.listObject.CnEcXmlFormatClass;

	lblLiteral.visible			:= false;
	txtTagValue.visible			:= false;	 
	cmbIncludeFormat.visible	:= false;
	lblLabel8.visible			:= false;
	fraPropertyPanel.caption	:= "Modify selected Class Format:";	
	btnUpdateProp.caption		:= "Update 'Class' Format";
	lblStatus.caption			:= "";

	if classFormatObj = null then
		beginTransaction;
			classFormatObj := self.createFormatClass(formatObj);
		commitTransaction;
	endif;

	optIncludeNo.value		:= (classFormatObj.isShowTagData = false).Boolean;
	optIncludeYes.value		:= (classFormatObj.isShowTagData = true).Boolean;
	chkSuppressTag.visible	:= true;
	lblSuppress.visible		:= true;
	chkSuppressTag.value	:= classFormatObj.isSuppressTag;
	
	if chkSuppressTag.value then
		txtTagWith.enabled := false;
	else
		txtTagWith.enabled := true;
	endif;
	
	lblNoidProperty.visible := true;
	cmbNoidProperty.visible := true;
	
	if classFormatObj.noidPropertyName &lt;&gt; null then
		cmbNoidProperty.listIndex := cmbNoidProperty.findStringExact(1, classFormatObj.noidPropertyName);
	else
		cmbNoidProperty.listIndex := CNEC_NULL_INDEX;		
	endif;
	
	lblEpiMethod.visible := true;
	cmbEpiMethod.visible := true;
	
	if classFormatObj.epilogMethodName &lt;&gt; null then
		cmbEpiMethod.listIndex := cmbEpiMethod.findStringExact(1, classFormatObj.epilogMethodName);
	else
		cmbEpiMethod.listIndex := CNEC_NULL_INDEX;
	endif;
	
	btnUpdateProp.enabled	:= true;
	btnAddProp.visible		:= false;
	txtTagWith.text			:= classFormatObj.tagName;	

	lblDescription.caption := "Values for '"  &amp; classObj.name &amp; "' Class";
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="displayPropAttribute" id="67f1ea2a-8bea-4491-b571-ef28077dcbb2">
        <source>displayPropAttribute(pListObject : Object) protected;

vars
	formatAttribObj	: CnEcXmlFormatAttribute;
	
begin
	if pListObject &lt;&gt; null then
		formatAttribObj			:= pListObject.CnEcXmlFormatAttribute;
		optIncludeNo.value		:= (formatAttribObj.isShowTagData = false);
		optIncludeYes.value		:= (formatAttribObj.isShowTagData = true); 
		btnUpdateProp.enabled	:= true;
		btnAddProp.enabled		:= false;
		txtTagWith.text			:= formatAttribObj.tagName;
		chkSuppressCData.value	:= formatAttribObj.noCDataCheck;
	endif;
	
	cmbIncludeFormat.visible	:= false;
	lblLabel8.visible			:= false;
	lblStatus.caption			:= "";
end;</source>
        <access>protected</access>
        <Parameter name="pListObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="displayPropCollection" id="60e17910-861b-4504-addc-e92899f5ad23">
        <source>displayPropCollection(pListObject : Object) protected;

vars
	formatCollObj	: CnEcXmlFormatCollection;
	
begin
	if pListObject &lt;&gt; null then
		formatCollObj				:= pListObject.CnEcXmlFormatCollection;
		optIncludeNo.value			:= (formatCollObj.isShowTagData = false);
		optIncludeYes.value			:= (formatCollObj.isShowTagData = true);
		cmbIncludeFormat.listIndex	:= cmbIncludeFormat.findObject(formatCollObj.myFormat); 
		btnUpdateProp.enabled		:= true;
		btnAddProp.enabled			:= false;
		txtTagWith.text				:= formatCollObj.tagName;		
		chkSize.value				:= formatCollObj.isReportSize;
	endif;
	
	lblSize.visible		:= true;
	chkSize.visible		:= true;
	lblStatus.caption	:= "";
end;</source>
        <access>protected</access>
        <Parameter name="pListObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="displayPropLiteral" id="a296f222-e36c-4e74-8d2f-c95b53332ea5">
        <source>displayPropLiteral(pListObject : Object) protected;

vars
	formatLiteralObj	: CnEcXmlFormatLiteral;
	
begin
	formatLiteralObj		:= pListObject.CnEcXmlFormatLiteral;
	optIncludeNo.value		:= (formatLiteralObj.isShowTagData = false);
	optIncludeYes.value		:= (formatLiteralObj.isShowTagData = true); 
	btnUpdateProp.enabled	:= true;
	btnAddProp.enabled		:= false;
	txtTagWith.text			:= formatLiteralObj.tagName;
	lblLiteral.visible		:= true;
	txtTagValue.text		:= formatLiteralObj.tagValue;
	txtTagValue.visible		:= true;
	lblStatus.caption		:= "";
end;</source>
        <access>protected</access>
        <Parameter name="pListObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="displayPropMethod" id="29ecfd2e-0037-4592-bfc4-2a1270ee866c">
        <source>displayPropMethod(pListObject : Object) protected;

vars
	formatMethodObj	: CnEcXmlFormatMethod;
	
begin
	formatMethodObj			:= pListObject.CnEcXmlFormatMethod;
	optIncludeNo.value		:= (formatMethodObj.isShowTagData = false);
	optIncludeYes.value		:= (formatMethodObj.isShowTagData = true);
	btnUpdateProp.enabled	:= true;
	btnAddProp.enabled		:= false;
	txtTagWith.text			:= formatMethodObj.tagName;
	lblStatus.caption		:= "";
end;</source>
        <access>protected</access>
        <Parameter name="pListObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="displayPropSingleton" id="6c099444-4d59-4062-bb23-a010af3e7bc4">
        <source>displayPropSingleton(pListObject : Object) protected;

vars
	formatSingletonObj	: CnEcXmlFormatSingle;
	
begin
	if pListObject &lt;&gt; null then
		formatSingletonObj			:= pListObject.CnEcXmlFormatSingle;	
		optIncludeNo.value			:= (formatSingletonObj.isShowTagData = false);
		optIncludeYes.value			:= (formatSingletonObj.isShowTagData = true); 
		cmbIncludeFormat.listIndex 	:= cmbIncludeFormat.findObject(formatSingletonObj.myFormat); 
		btnUpdateProp.enabled		:= true;
		btnAddProp.enabled			:= false;
		txtTagWith.text				:= formatSingletonObj.tagName;
	endif;
	
	lblStatus.caption	:= ""; 
end;</source>
        <access>protected</access>
        <Parameter name="pListObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="displayProperty" id="b25e8a3d-7834-4a3f-b32e-305ab03e894b">
        <updating/>
        <source>displayProperty(attribName : String) updating, protected;

vars
	propertyObj		: Property;
	classObj		: Class;
	listObject		: Object;

begin
	classObj	:=	app.myCnEcXmlSchema.getClass(lstFormatClasses.text);
	propertyObj	:=	classObj.getProperty(lstFormatAttribs.text);		
	listObject	:=	lstFormatAttribs.listObject;

	self.clearPropertyPanel();

	txtTagWith.enabled			:= true;
	txtTagWith.text				:= lstFormatAttribs.text;
	btnAddProp.visible			:= true;
	btnAddProp.enabled			:= true;
	fraPropertyPanel.caption	:= "Modify selected Property Format:";
	btnUpdateProp.caption		:= "Update 'Property' Format";
	lblDescription.caption		:= classObj.name &amp; "." &amp; lstFormatAttribs.text &amp; "    - is a";

	if listObject &lt;&gt; null and ( listObject.isKindOf(CnEcXmlFormatLiteral) or listObject.isKindOf(CnEcXmlFormatMethod) ) then
		if listObject.isKindOf(CnEcXmlFormatLiteral) then
			lblDescription.caption := lblDescription.caption &amp; " Literal";
			self.displayPropLiteral(listObject);
		else
			lblDescription.caption := lblDescription.caption &amp; " Special value";
			self.displayPropMethod(listObject);
		endif;
		
		return;
	endif;

	while propertyObj = null and classObj.name &lt;&gt; Object.name do	// If we get to here the property is inherited.
		classObj	:=	classObj.getSuperclass();
		propertyObj	:=	classObj.getProperty(lstFormatAttribs.text);
	endwhile;

	if propertyObj = null then// have to assume it has been deleted due to a reorg
		app.msgBox("Property selected appears to have been removed via a re-org."&amp; CrLf &amp;"Property Format will be deleted.","",MsgBox_OK_Only);
		beginTransaction;
			delete lstFormatAttribs.listObject; 
		commitTransaction;
		
		self.lstFormatAttribsPopulate();
	else		
		if propertyObj.isKindOf(Reference) then
			self.cmbIncludeFormatPopulate();
			cmbIncludeFormat.visible	:= true;
			lblLabel8.visible			:= true;
			
			if propertyObj.getType.isKindOf(CollClass) then
				lblDescription.caption := lblDescription.caption &amp; " reference to a collection of ";
				lblDescription.caption := lblDescription.caption &amp;  propertyObj.getType.CollClass.getMemberType().getName() &amp; "(s)"; //NDL 08/sep/00
				self.displayPropCollection(listObject);
			else
				lblDescription.caption := lblDescription.caption &amp; " reference to a singleton ";
				lblDescription.caption := lblDescription.caption &amp;  propertyObj.getType.getName; //NDL 08/sep/00
				self.displayPropSingleton(listObject); 
			endif;
		else							
			lblDescription.caption := lblDescription.caption &amp;  " " &amp; propertyObj.getType.getName; //NDL 08/sep/00
			lblDescription.caption := lblDescription.caption &amp; " attribute";
			
			if propertyObj.getType = String then
				chkSuppressCData.visible := true;
				lblSuppressCData.visible := true;
			endif;
			
			self.displayPropAttribute(listObject);
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="attribName" type="String"/>
    </JadeMethod>
    <JadeMethod name="extrasUpdate" id="4ea8b20f-7c93-4fb7-a25f-d75159ba728f">
        <updating/>
        <source>extrasUpdate()updating, protected;

vars
	isSuccess	: Boolean;
	
begin
	if self.aUpdateType = 2 then	// addMethod
		isSuccess	:=	self.addMethod();
	elseif self.aUpdateType = 3 then	// addLiteral
		isSuccess	:=	self.addLiteral();		
	endif;

	if isSuccess then
		self.clearExtrasPanel();
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
