    <JadeMethod name="getVoyageCode" id="24dd0445-5a80-4789-a92e-663e72b7fa10">
        <source>getVoyageCode() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 Apr 2016	cnwkpd1	TFS 1849 - MES Tranship reporting


*/

vars

begin
	if self.myVoyage &lt;&gt; null then
		return self.myVoyage.code;
	else
		return null;
	endif;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="noOutputReturned" id="54746beb-4262-4b03-af87-8297d83230f4">
        <source>noOutputReturned(): Boolean;
// -------------------------------------------
// Created 21 September 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	if self.allTransactions.isEmpty() then
		return true;
	endif;
	return false;


end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
