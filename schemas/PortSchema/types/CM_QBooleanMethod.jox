    <JadeMethod name="setComboValues" id="df095dd0-1304-44fd-a23c-6a51dc38593b">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 November 2009	cnwas3	Initial creation

*/

vars

begin
	_combo.clear();
	_combo.addItem( true.getYesNo() );		
	_combo.addItem( false.getYesNo() );
//	_combo.addItem( app.getErrorString(NotApplicable) );	//23 Mar 2015	NDL	Par 35886
	
	if CM_QueryBooleanOperator.hasInstance(_queryOperator) then		
	//	if  _queryOperator.CM_QueryBooleanOperator.notApplicable then	//23 Mar 2015	NDL	Par 35886
	//		_combo.text := app.getErrorString(NotApplicable);
	//	else
		if _queryOperator.CM_QueryBooleanOperator.searchValue then
			_combo.text := true.getYesNo();
		else
			_combo.text := false.getYesNo();
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="f77478ba-8ec2-492e-baea-1c746005a473">
        <source>translateToDisplayValue(_value: Any): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 November 2009	cnwas3	Initial creation

*/

vars

begin

	//23 Mar 2015	NDL	Par 35886
	if _value.String = app.getErrorString(NotApplicable) then
		return _value.String;
	endif;
	
	if _value.isKindOf(Integer) then	//25 Jun 2015	NDL	Par 36525
		if _value.Integer = 3 then
			return app.getErrorString(NotApplicable);
		elseif _value.Integer = 1 then
			return true.getYes();
		else
			return false.getYes();
		endif;
	endif;

	return _value.Boolean.getYesNo();

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="585be06e-211f-4081-b917-a9dbb06ca62c">
        <source>translateToSearchValue(_value: Any): Any;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 November 2009	cnwas3	Initial creation

*/

vars

begin
	//23 Mar 2015	NDL	Par 35886
	if _value.String = app.getErrorString(NotApplicable) then
		return _value;
	endif;
	if _value.isKindOf(Integer) then	//25 Jun 2015	NDL	Par 36525
		if _value.Integer = 3 then
			return app.getErrorString(NotApplicable);
		elseif _value.Integer = 1 then
			return true.getYes();
		else
			return false.getYes();
		endif;
	endif;

	return _value.String = true.getYes();

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="6dc944f9-9756-4c91-bae4-1a18b348070a">
        <source>translateToSearchValueForWeb(_value: Any; _sending : Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 06/09/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars

begin
	if _value.isKindOf(Boolean) then
		return _value.asStringJMT;
	elseif _value.isKindOf(String) and _value.String = "true" then
		return true;
	elseif _value.isKindOf(String) and _value.String = "false" then
		return false;
	endif;
	
	return inheritMethod(_value, _sending);

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
