    <JadeMethod name="trxUpdateBlockStackOverlapped" id="7c3bded6-78fe-44fa-9904-3e8dc03017c9">
        <updating/>
        <source>trxUpdateBlockStackOverlapped(_blockStack : CM_BlockStack input; _isOverlapped : Boolean; _passport : CM_Passport input) updating;
//-----------------------------------------
// Created: September 2003 By: cnwgd1
//-----------------------------------------
// 03/03/2011	cnwcs5	CCMS 2027/PAR 27126 - audit terminal area
vars
	mode	:Integer;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	if _blockStack = null then
		app.raiseCMException1(ERR_NO_OBJECT, "Block Stack Area", null, null);
	endif;

	beginTransaction;
	exclusiveLock(_blockStack);

	if _isOverlapped = _blockStack.isOverlapped then
		// nothing to do !!!
		return;
	endif;	
	
	if _isOverlapped then
		mode := AuditCreated;
	else
		mode := AuditDeleted;
	endif;

	// 02/03/2011 cnwcs5 CCMS CPL 2027/PAR 27126 - add auditing
	app.myUtilityUA.myUpdateAuditAgent.audUpdateTALocation(_blockStack, true, null,CM_AuditTALocations.LocnTypeUpdate_Overlapping, mode, null);		
	
	_blockStack.setIsOverlapped(_isOverlapped);
	
	// 02/03/2011 cnwcs5 CCMS CPL 2027/PAR 27126 - add auditing
	app.myUtilityUA.myUpdateAuditAgent.audUpdateTALocation(_blockStack, false, null,CM_AuditTALocations.LocnTypeUpdate_Overlapping, mode, null);		

	if _passport.noErrors then			
		_blockStack.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_REFRESH_GRID_AREA),false,_blockStack);
	endif;
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_blockStack" type="CM_BlockStack" usage="input"/>
        <Parameter name="_isOverlapped" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
