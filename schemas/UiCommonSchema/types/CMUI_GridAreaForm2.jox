    <JadeMethod name="doMnuCargoEnquiryClick" id="732c9c84-71ef-45d8-9f48-64c837873ee6">
        <updating/>
        <source>doMnuCargoEnquiryClick(menuItem: MenuItem input) updating;
/*
Purpose:			
Date				Who			Reason
OCTOBER 2013		CNWAB1		Initial creation
05 Nov2015		    cnwma1		PAR #36723 	Bulk Edit Onship Container error
*/

vars
	theSlot : CM_SlotController;
	obj : Object;
	theTI : CM_TrackedItem;
	objects : ObjectArray;
	tis : CM_TIArray;
begin
	if menuItem.userObject &lt;&gt; null then
		if menuItem.userObject.isKindOf(CM_TrackedItem)  then
			self.myAssistant.showCargoEnquiryForm(menuItem.userObject.CM_TrackedItem, self.myMasterMenuAction, true, false);	
		// PAR 21746 21939
		elseif menuItem.userObject.isKindOf(CMUI_GridDrawingController)  then

			create objects transient;
			foreach obj in menuItem.userObject.CMUI_GridDrawingController.allSelectedObjects do
				if obj.isKindOf(CM_SlotController) then
					theSlot := obj.CM_SlotController;
					// PAR 21939 theTI := obj.CM_SlotController.allTrackedItems.first;
					// PAR 21939 if theTI &lt;&gt; null then
					// PAR 21939 	objects.add(theTI);
					// PAR 21939 endif;

					// PAR 21939 look at actual and proposed
					// PAR 33286 if self.frmStatusLine.displayMode = ShpDisplayMode_Actual then
					if self.frmStatusLine.displayMode = DISPLAY_MODE_ACTUAL then
						foreach theTI in theSlot.allTrackedItemsById do
							objects.addExclusive(theTI);			//05/11/2015 cnwma1 PAR #36723 
						endforeach;
					// PAR 33286 elseif self.frmStatusLine.displayMode = ShpDisplayMode_Proposed then
					elseif self.frmStatusLine.displayMode = DISPLAY_MODE_PLAN then
						create tis transient;
						theSlot.getProposedTIs(tis);
						foreach theTI in tis do						
							objects.addExclusive(theTI); 		//05/11/2015 cnwma1 PAR #36723 
						endforeach;
					endif;
				endif;
			endforeach;
			self.myAssistant.showCargoEnquiryForTIs(theTI,objects, self.myMasterMenuAction,false) ;
		endif;
	endif;
epilog
	delete tis;
	delete objects;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
