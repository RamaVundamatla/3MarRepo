    <JadeMethod name="validateForVoyageRequests" id="fe60e7ca-000f-4ec6-9aaa-430806d6aa2b">
        <source>validateForVoyageRequests(_jobParams : CMIF_VoyageJobParams input);
// ---------------------------------------------------------------------------
// Created:		February 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	aRequest : CM_Request;
	aSlotRequest : CM_RORORequest;
	theJobNum : String;
	tmpJob		: CM_Job;
	theDeck : CM_DeckVoyage;
	problemJobStr : String;
begin
	theJobNum := self.jobNum.trimBlanks;
	
	if theJobNum = null then
		theJobNum := "'Auto'";
	endif;
	
	foreach aSlotRequest in _jobParams.allRORORequests do
		tmpJob := aSlotRequest.myJob;
		
		if tmpJob &lt;&gt; null and
		   tmpJob &lt;&gt; self.pxyGetRealObject and 
		   (not tmpJob.isJobComplete()) then
		   
		   // PAR 29306 the job in question is not this job and can actually be for a different voyage. However the message was showing this job which is confusing
			if tmpJob.CM_VoyageJob.myVoyage &lt;&gt; null then
				problemJobStr := tmpJob.CM_VoyageJob.myVoyage.code &amp; " " &amp; tmpJob.CM_VoyageJob.jobNum;
			else
				problemJobStr :=  tmpJob.CM_VoyageJob.jobNum;
			endif;
			
// PAR 29306			app.raiseCMException2(ERR_SLOT_HASINCOMPLETE_JOB, aSlotRequest.myROROController.getFullId, self.jobNum, null, null);
			app.raiseCMException2(ERR_SLOT_HASINCOMPLETE_JOB, aSlotRequest.myROROController.getFullId, problemJobStr, null, null); //  PAR 29306
		endif;

		if aSlotRequest.getAttrIsBackend() then
			app.raiseCMException2(ERR_40_BACKEND_IN_JOB, aSlotRequest.myROROController.getFullId,theJobNum, null, null);
		endif;
		
		if theDeck &lt;&gt; aSlotRequest.myROROController.myDeck then
			if theDeck = null then
				theDeck := aSlotRequest.myROROController.myDeck;
			else
			// Job %1 has items for deck %2 and deck %3, cannot mixed jobs across decks.
			app.raiseCMException3(Items_deck_deck_canno_mixed_jo, theJobNum, theDeck.code, aSlotRequest.myROROController.myDeck.code, null, null);
			
			endif;
		endif;
	endforeach;
end;</source>
        <Parameter name="_jobParams" type="CMIF_VoyageJobParams" usage="input"/>
    </JadeMethod>
</Class>
