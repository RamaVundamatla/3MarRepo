    <JadeMethod name="doBtnNewClick" id="ed483c85-6d58-4185-9808-8a3a3ac89288">
        <source>doBtnNewClick();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 MAY 2023 navtnr20	TFS CR 57987 Task 57988: EUP - INCO Terms Enquiry

*/

vars
	form : INV_INCOTermMaint;
	bank :CM_Bank;
begin
	form := app.loadForm(INV_INCOTermMaint, INV_Assistant, false, false,false, self.myTerminal,null).INV_INCOTermMaint;
	if form &lt;&gt; null then
		form.mode := false;
		form.btnRemove.enabled := false;
		form.btnAdd.enabled := false;
		form.btnUpdate.enabled := false;
		form.btnAudits.enabled := false;
		form.setMyCurrentBank(self.myCurrentBank);
		//form.setBank(bank);
		form.centreWindow();
		form.show;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnUpdateClick" id="32112c5b-2cfb-4292-a2d6-f343ca9fcbf9">
        <source>doBtnUpdateClick();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 MAY 2023 navtnr20	TFS CR 57987 Task 57988: EUP - INCO Terms Enquiry

*/

vars
	form : INV_INCOTermMaint;
	pxyIncoMapping : CM_InvoiceINCOMapping;
	incoterm:CM_InvoiceINCOTerm;
begin
	incoterm := self.tblINCOTerm.accessRow(self.tblINCOTerm.row).itemObject.CM_InvoiceINCOTerm;
	if incoterm = null then
		app.msgBox("No record selected", "Warning",MsgBox_OK_Only);
		return;
	endif;
	if incoterm &lt;&gt; null then
	//	pxyShipMapping := self.tblShipTerm.allSelectedObjects.first.CM_InvoiceShipTermMapping;
		form := app.loadForm(INV_INCOTermMaint, INV_Assistant, false, false,false, self.myTerminal,null).INV_INCOTermMaint;
		if form &lt;&gt; null then
			form.mode := true;
			form.setINCOTerm(incoterm);
			form.setMyCurrentBank(self.myCurrentBank);
			form.centreWindow();
			form.show;
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbBUBuild" id="f94836a0-3496-4167-b826-eb54f6e8c8d7">
        <source>doCmbBUBuild(_combo : CMUI_ComboBox input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 MAY 2023 navtnr20	TFS CR 57987 Task 57988: EUP - INCO Terms Enquiry

*/

vars
	aTerm : CM_Terminal;
	company:  CM_Bank;
begin
	_combo.clear;
	_combo.sorted := false;


	foreach company in self.myTerminal.companies do
		if company.isBusinessUnit then
			_combo.addItem(company.code);
			_combo.itemObject[_combo.newIndex] := company;
		endif;
	endforeach;

	if self.myCurrentBank &lt;&gt; null then
		_combo.listObject := self.myCurrentBank;
	endif;

end;</source>
        <Parameter name="_combo" type="CMUI_ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doHandleNotification" id="1754f5bf-db92-4e29-92da-d6ae762c602a">
        <updating/>
        <source>doHandleNotification( eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 MAY 2023 navtnr20	TFS CR 57987 Task 57988: EUP - INCO Terms Enquiry

*/

vars
	dataLine	: String;
	iNCOTerm : CM_InvoiceINCOTerm;
	event : Integer;
	idx : Integer;
	theDataLine : String;
begin
	self.mousePointer := Window.MousePointer_HourGlass;

	event := self.myTerminal.getEventFromTerminalEvent(eventType);
	
	if userInfo.isKindOf(CM_InvoiceINCOTerm) then
		iNCOTerm := userInfo.CM_InvoiceINCOTerm;
	elseif theObject.isKindOf(CM_InvoiceINCOTerm) then
		iNCOTerm := theObject.CM_InvoiceINCOTerm;
	endif;
	
	if event = Event_InvINCOTermCreate then
		if iNCOTerm &lt;&gt; null then			
			self.tblDisplayRow();
		endif;
	elseif event = Event_InvINCOTermUpdate then
		if iNCOTerm &lt;&gt; null then
			self.tblINCOTerm.findObjectInRow(iNCOTerm,idx);
			if idx &gt; self.tblINCOTerm.fixedRows then
				theDataLine := iNCOTerm.getAttributeStringForDefArray(self.tblINCOTerm.allTblDataEntRows);
				self.tblINCOTerm.accessCell(idx, 1).text := theDataLine;
			endif;
		endif;
	elseif event = Event_InvINCOTermDelete then
		self.tblINCOTerm.removeItemObject(iNCOTerm);
		self.doNotableClear();
	endif;
epilog
	self.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
