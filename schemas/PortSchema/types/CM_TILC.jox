    <JadeMethod name="getCustomerPriority" id="3218663c-b369-49d7-989a-12b1750bd2d5">
        <source>getCustomerPriority(): CM_CustomerPriority;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 13 November 2023
TFS#		: 61130
Function	:

*** Changes ***
Date		Name	TFS#		Description
26/01/2024	jlika1	TFS 62524 	CUX | MAFI Priority Override and Transactions
****************************************************/
vars
	customerPriority 	: CM_CustomerPriority;
	lowestPrioritySetup	: CM_CustomerPriority;
	loopPriority 		: CM_CustomerPriority;
	cargo				: CM_TrackedItem;
	onboardTIs			: CM_TISet;
begin
	customerPriority  := self.myCustomerPriority;
	lowestPrioritySetup := self.getSystemLowestPriority();
	
	if customerPriority = null or customerPriority = lowestPrioritySetup then		
		create onboardTIs transient;
		self.getAllOnboardTIs(onboardTIs);
		
		foreach cargo in onboardTIs do
			if customerPriority = null and cargo.myCustomerPriority &lt;&gt; null then
				customerPriority := cargo.myCustomerPriority;
			elseif cargo.myCustomerPriority &lt;&gt; null and cargo.myCustomerPriority.priority &lt;&gt; 0 and cargo.myCustomerPriority.priority &lt; customerPriority.priority then
				customerPriority := cargo.myCustomerPriority;
			endif;
		endforeach;		
		
		if customerPriority = null then
			customerPriority := lowestPrioritySetup;
		endif;
	endif;
	
	return customerPriority ;
epilog
	delete onboardTIs;
end;</source>
        <ReturnType type="CM_CustomerPriority"/>
    </JadeMethod>
    <JadeMethod name="getCustomerPriorityCode" id="5798f21e-2c88-43a0-a7d0-52ce6a3d017e">
        <source>getCustomerPriorityCode(): String;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 13 November 2023
TFS#		: 61132
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	customerPriority 	: CM_CustomerPriority;	
begin
	customerPriority  := self.getCustomerPriority;
	
	if customerPriority =  null then
		return null;
	endif;
	
	return customerPriority.code ;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDefaultColour" id="6e6eb6fc-00fa-40dc-bf1c-c6412cdf1ffc">
        <source>getDefaultColour(): Integer;
// ---------------------------------------------------------------------------
// Created:		09 December 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin

	if self.myTILCType = null then	//cnwrd1 19.9.08 par #17201
		return NullColour;
	endif;
	
	if self.myTILCType.colour &lt;&gt; NullColour 
	and self.myTILCType.colour &lt;&gt; Black then
		return self.myTILCType.colour;
	endif;

	return NullColour;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="b1f6017b-96e9-41cf-abf3-dd6561fbcb0b">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			


Return Value:		


Date		Who		Reason
13 April 2007	cnwer1	Initial creation - PAR#xxxx
22 Feb 2023	jlika1	TFS 56496 - CUX - Add attribute to cargo (to allow for conversions of MAFI types)
28 Mar 2023 navmk20 Task 57224: Jade - New MAFI Columns
08 Mar 2024	jlika1	TFS 62803 CUX | Onboard cargo - new get methods and additional locations
18 Mar 2024	jlika1	TFS 62840 CUX | Remove one of the fields displaying onboard cargo IDs
11 Oct 2024	jlizm1	MTN 33002 'Has Stops' column showing as blank for trailers
26 May 2025 navsp1  JIRA-34864 CUX | Data Access Groups for MAFIs and Trailers - Development
*/
vars
	fm : CM_FutureMove;
	lc : CM_LocationsController;
	realTI,
	ti : CM_TrackedItem;
	tmpStr : String;
	subStr : String;
	tmpStatus : CM_ContentsStatus;
begin

	if _attrName = ETRow_Type  or _attrName = ETRow_TrailerType or _attrName = ETRow_MyTrailerType then		
		if self.myTILCType &lt;&gt; null then
			return self.myTILCType.code;
		else
			return null;
		endif;
	elseif _attrName = ETRow_TrailerTypeUpd then			//cnwmc5 - 14 March 2014 - PAR 33659
		if self.myTILCType &lt;&gt; null then
			return self.myTILCType.description;
		else
			return null;
		endif;
	elseif _attrName = ETRow_TrailerMaxWeight then
		return self.getTrailerMaxWeight();	
	elseif _attrName = ETRow_TrailerImageID then
		return self.getTrailerImageID();	
	elseif _attrName = ETRow_Generator then
		if self.myGenerator &lt;&gt; null then
			return self.myGenerator.id;
		endif;
		
		return null;
	elseif _attrName = ETRow_CargoOnboard then
		if self.isTransient then
			realTI:=app.myProxyManager.getRealObject(self).CM_TrackedItem;
			if realTI &lt;&gt; null then
				return realTI.getOnboardCargoId();
			endif;
		endif;
		return getOnboardCargoId();
	elseif _attrName = ETRow_CargoQueuedOnboard then
		if self.isTransient then
			realTI:=app.myProxyManager.getRealObject(self).CM_TrackedItem;
			if realTI &lt;&gt; null then
				return realTI.getOnboardQueuedCargo();
			endif;
		endif;
		return self.getOnboardQueuedCargo();
	elseif _attrName = ETRow_CargoPlannedOnboard then
		if self.isTransient then
			realTI:=app.myProxyManager.getRealObject(self).CM_TrackedItem;
			if realTI &lt;&gt; null then
				return realTI.getOnboardPlannedCargo();
			endif;
		endif;
		return self.getOnboardPlannedCargo();
		
	elseif _attrName = ETRow_OnHireDate then
		if self.myTiMaster &lt;&gt; null then
			return self.onHireDate.asStringJMT();
		endif;
	elseif _attrName = ETRow_OffHireDate then
		if self.myTiMaster &lt;&gt; null then
			return self.offHireDate.asStringJMT();
		endif;
	//26 Sep 2013	NDL	Par 32569	
	elseif _attrName = ETRow_LocationId then
		if self.myPrimaryActualLocation &lt;&gt; null then
			return self.myPrimaryActualLocation.getFullId;
		else
			return self.locationId;
		endif;
	elseif _attrName = ETRow_FirstConnectedDTSort  or _attrName = ETRow_LastConnectedDTSort or _attrName = ETRow_LastDisconnDTSort then //04/08/2016 cnwma1 TFS #2430
	
		return null.String;
	elseif _attrName = ETRow_ContentsStatus then
		tmpStatus := app.myRoot.allContentsStatuses[self.contentsStatus];
		if tmpStatus &lt;&gt; null then
			return tmpStatus.description;
		else
			return null;
		endif;		
	
	elseif _attrName = ETRow_FloorType then
		return self.getFloorTypeDisplay() ;
	// Start 28.3.2023 navmk20 TFS 57224
	elseif _attrName = ETRow_ObCargoSubtypes then
		// Since we have displayed onboard cargo subtypes in edit mode
		if self.isTransient then
			realTI:= app.myProxyManager.getRealObject(self).CM_TrackedItem;
			if realTI &lt;&gt; null then
				return realTI.getOnboardSubTypes();
			endif;
		endif;
		tmpStr := self.getOnboardSubTypes();
		return tmpStr;	
	elseif _attrName = ETRow_ObCargoTypes then 
		// Since we have displayed onboard cargo types in edit mode
		if self.isTransient then
			realTI:= app.myProxyManager.getRealObject(self).CM_TrackedItem;
			if realTI &lt;&gt; null then
				return realTI.getOnboardCargoTypes();	
			endif;
		endif;
		return self.getOnboardCargoTypes();
	elseif _attrName = ETRow_ObISOTypes then 
		// Since we have displayed onboard ISO types in edit mode
		if self.isTransient then
			realTI:= app.myProxyManager.getRealObject(self).CM_TrackedItem;
			if realTI &lt;&gt; null then
				return realTI.getOnboardISOTypes();
			endif;
		endif;
		return self.getOnboardISOTypes();
	elseif _attrName = ETRow_ObHaz then 
		// Since we have displayed onboard Haz in edit mode
		if self.isTransient then
			realTI:= app.myProxyManager.getRealObject(self).CM_TrackedItem;
			if realTI &lt;&gt; null then
				return realTI.getOnboardHazardous();
			endif;
		endif;
		return self.getOnboardHazardous();
	elseif _attrName = ETRow_ObHazDetails then
		// Since we have displayed onboard HazDetails in edit mode
		if self.isTransient then
			realTI:= app.myProxyManager.getRealObject(self).CM_TrackedItem;
			if realTI &lt;&gt; null then
				return realTI.getOnboardHazDetails();
			endif;
		endif;
		return self.getOnboardHazDetails();
	elseif _attrName = ETRow_ObReefer then
		// Since we have displayed onboard reefer in edit mode
		if self.isTransient then
			realTI:= app.myProxyManager.getRealObject(self).CM_TrackedItem;
			if realTI &lt;&gt; null then
				return realTI.getOnboardReefer();
			endif;
		endif;
		return self.getOnboardReefer();
	elseif _attrName = ETRow_ObStops then 
		// Since we have displayed onboard stops in edit mode
		if self.isTransient then
			realTI:= app.myProxyManager.getRealObject(self).CM_TrackedItem;
			if realTI &lt;&gt; null then
				return realTI.getOnboardHasStops();
			endif;
		endif;
		return self.getOnboardHasStops();
	elseif _attrName = ETRow_ObStopTypes then 
		// Since we have displayed onboard stops types in edit mode
		if self.isTransient then
			realTI:= app.myProxyManager.getRealObject(self).CM_TrackedItem;
			if realTI &lt;&gt; null then
				return realTI.getOnboardStopsDetails();
			endif;
		endif;
		return self.getOnboardStopsDetails();
	elseif _attrName = ETRow_ObDamage then 
		// Since we have displayed onboard damage in edit mode
		if self.isTransient then
			realTI:= app.myProxyManager.getRealObject(self).CM_TrackedItem;
			if realTI &lt;&gt; null then
				return realTI.getOnboardDamaged();
			endif;
		endif;
		return self.getOnboardDamaged();
	// End- 28.3.2023 navmk20 TFS 57224
	elseif _attrName = ETRow_ObCommodities then 		
		if self.isTransient then
			realTI:= app.myProxyManager.getRealObject(self).CM_TrackedItem;
			if realTI &lt;&gt; null then
				return realTI.getOnboardCommodities();
			endif;
		endif;
		return self.getOnboardCommodities();
	elseif _attrName = ETRow_ObContentStatus then 		
		if self.isTransient then
			realTI:= app.myProxyManager.getRealObject(self).CM_TrackedItem;
			if realTI &lt;&gt; null then
				return realTI.getOnboardContentStatus();
			endif;
		endif;
		return self.getOnboardContentStatus();
	elseif _attrName = ETRow_ObConsignorConsignee then 		
		if self.isTransient then
			realTI:= app.myProxyManager.getRealObject(self).CM_TrackedItem;
			if realTI &lt;&gt; null then
				return realTI.getOnboardConsigneeConsignor();
			endif;
		endif;
		return self.getOnboardConsigneeConsignor();	
	elseif _attrName = ETRow_ObFreightForwarder then 		
		if self.isTransient then
			realTI:= app.myProxyManager.getRealObject(self).CM_TrackedItem;
			if realTI &lt;&gt; null then
				return realTI.getOnboardFreightForwarder();
			endif;
		endif;
		return self.getOnboardFreightForwarder();	
	elseif _attrName = ETRow_ObSealNumbers then
		if self.isTransient then
			realTI:= app.myProxyManager.getRealObject(self).CM_TrackedItem;
			if realTI &lt;&gt; null then
				return realTI.getOnboardSealNumbers();
			endif;
		endif;
		return self.getOnboardSealNumbers();
	elseif _attrName = ETRow_ObTemperatures then
		if self.isTransient then
			realTI:= app.myProxyManager.getRealObject(self).CM_TrackedItem;
			if realTI &lt;&gt; null then
				return realTI.getOnboardTemperatures();
			endif;
		endif;
		return self.getOnboardTemperatures();
    elseif _attrName = ETRow_ObQuantity then                                //JIRA-34864
		if self.isTransient then                                            //JIRA-34864
			realTI:= app.myProxyManager.getRealObject(self).CM_TrackedItem; //JIRA-34864
			if realTI &lt;&gt; null then                                          //JIRA-34864
				return realTI.getOnboardQuantity().String;                  //JIRA-34864
			endif;                                                          //JIRA-34864
		endif;                                                              //JIRA-34864
		return self.getOnboardQuantity().String;                            //JIRA-34864
	else
		return inheritMethod(_attrName, _short);
	endif;
	
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="2b81cdc9-d3b4-438c-9849-8b6f857a61dd">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
// ---------------------------------------------------------------------------
// Created:		24 January 2006  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	block : CM_DataContainerBlock;
	anLC : CM_TILCController;
	aTI : CM_TrackedItem;
begin

	inheritMethod(_dataContainer);
	
	//jlier1 TFS 54700 15/9/22
	if self.myTILCType &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Trailer_Type), DC_Label, 1, self);
		block.addNewItem(self.myTILCType.description, DC_Data, 1, null);
	endif;
	
	foreach anLC in self.allLCs discreteLock do
		foreach aTI in anLC.allTrackedItems discreteLock do
			block := _dataContainer.addNewBlock;
			block.addNewItem(GridPointStringMoreCargo, DC_MoreInfo, 1, null);

			aTI.getExtraInfo(_dataContainer);
		endforeach;
	endforeach;

	if self.hasGeneratorSetAttached() then	//Par17775. ccms1045. September 2008
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(CM_Attached_GenSet), DC_Label, 1, self.myGenerator);
		block.addNewItem(self.myGenerator.id, DC_Data, 1, self.myGenerator);
	endif;
	
end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getFloorTypeDisplay" id="8344eb28-5b13-4c87-b3d4-29809c1a9ff8">
        <source>getFloorTypeDisplay() : String;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 16 February 2023
TFS#		: 56496
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

begin
	if self.floorType = null then		
		return app.getErrorString(FloorType_UndefinedDesc);
	endif;
	
	if self.floorType = self.FloorType_Floored then
		return app.getErrorString(FloorType_FlooredDesc);
	elseif self.floorType = self.FloorType_Skeleton then
		return app.getErrorString(FloorType_SkeletonDesc);
	endif;
	
	return app.getErrorString(FloorType_UndefinedDesc);
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
