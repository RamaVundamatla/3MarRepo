    <JadeMethod name="initDataExtractFields" id="b7890587-d8b6-4080-9aac-e92ec4de912a">
        <source>initDataExtractFields(_fields: CM_DataExtractFieldSet input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 May 2011	#cnwdz2	 

*/

vars
	fieldName    : String;
begin
	self.extractOrder.clear();
	
	fieldName := CM_Debtor::name.name;	
	
	self.initDataExtractField(_fields, CM_Debtor.name, null, fieldName, STRING, "Name", "Name", STRING, "No more than 40 characters and/or digits");
	
	fieldName := CM_Debtor::getBillingAddressString.name;	
	self.initDataExtractField(_fields, CM_Debtor.name, null, fieldName, STRING, "Address", "Billing address", STRING, "Valid address");
	
	fieldName := CM_Debtor::remarks.name;	
	self.initDataExtractField(_fields, CM_Debtor.name, null, fieldName, STRING, "Remarks", "Remarks", STRING, 'No more than 601 characters and/or digits);');
	
	fieldName := CM_Debtor::decfinName.name;	
	self.initDataExtractField(_fields, CM_Debtor.name, null, fieldName, STRING, "Account Code", "Account code", STRING, 'No more than 40 characters and/or digits');	
	
	fieldName := CM_Debtor::getTermsOfTradeDesc.name;	
	self.initDataExtractField(_fields, CM_Debtor.name, null, fieldName, STRING, "Terms", "Terms of trade", STRING, "No more than 30 characters and/or digits");
	
	fieldName := CM_Debtor::purchaseOrderCode.name;	
	self.initDataExtractField(_fields, CM_Debtor.name, null, fieldName, STRING, "Purchase Order Number", "Purchase order number", STRING, "No more than 10 characters and/or digits");
	
	fieldName := CM_Debtor::isPurchaseOrderMandatory.name;	
	self.initDataExtractField(_fields, CM_Debtor.name, null, fieldName, BOOLEAN, "Purchase Order Mandatory", "Purchase Order Mandatory", BOOLEAN, BOOLEAN_POSSIBLEVAL);
		
	fieldName := CM_Debtor::getCustomsAgentsDesc.name;	
	self.initDataExtractField(_fields, CM_Debtor.name, null, fieldName, STRING, "Customs Agents", "All the customs agents selected for the debtor", STRING, "Comma-separated customs agent codes");
	
	fieldName := CM_Debtor::getOperatorsDesc.name;	
	self.initDataExtractField(_fields, CM_Debtor.name, null, fieldName, STRING, "Operators", "All the operators selected for the debtor", STRING, "Comma-separated operator codes");
	
	fieldName := CM_Debtor::getConsignorsDesc.name;	
	self.initDataExtractField(_fields, CM_Debtor.name, null, fieldName, STRING, "Consignors", "All the consignors selected for the debtor", STRING, "Comma-separated consignor codes");	
	
	fieldName := CM_Debtor::isZeroRatedTax.name;	
	self.initDataExtractField(_fields, CM_Debtor.name, null, fieldName, BOOLEAN, "Zero Rated Tax", "Is zero rated tax", BOOLEAN, BOOLEAN_POSSIBLEVAL);
 
	fieldName := CM_Debtor::hasBadCredit.name;	
	self.initDataExtractField(_fields, CM_Debtor.name, null, fieldName, BOOLEAN, "Bad Credit", "Has bad credit", BOOLEAN, BOOLEAN_POSSIBLEVAL);
	
	fieldName := CM_Debtor::isSuspended.name;	
	self.initDataExtractField(_fields, CM_Debtor.name, null, fieldName, BOOLEAN, "Is suspended", "Is suspended", BOOLEAN, BOOLEAN_POSSIBLEVAL);
	
epilog

end;</source>
        <Parameter name="_fields" type="CM_DataExtractFieldSet" usage="input"/>
    </JadeMethod>
</Class>
