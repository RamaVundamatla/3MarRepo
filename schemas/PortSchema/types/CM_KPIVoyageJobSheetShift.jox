    <JadeMethod name="rebuildStatsTI" id="22f76974-fd9d-48d2-b2ae-663f51e3e3ac">
        <updating/>
        <source>rebuildStatsTI(_ti : CM_TrackedItem) updating;
// ---------------------------------------------------------------------------
// Created:		28 December 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	avGross, avNet 	: Real;
begin
	// ### get min and max moves per hour for the shift
	self.setShiftMinMaxMoves();

	self.movesTI 	:= self.movesTI + 1;
	
	if _ti.isContainer then
		self.movesTEU 	:= self.movesTEU + _ti.getNumTEU();
	endif;

		
	if self.movesTI &gt; 0 then
		avGross := 0;
		avNet := 0;
		if self.hoursGross &gt; 0 then
			avGross := (self.movesTI/self.hoursGross);
		endif;
		if self.hoursNet  &gt; 0 then
			avNet := (self.movesTI/self.hoursNet );
		endif;
	endif;
	
	self.tiGrossRate := avGross;
	self.tiNetRate := avNet;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setFromTransaction" id="060e690e-0ece-4907-842f-d37fd876072b">
        <updating/>
        <source>setFromTransaction(_shipTran : CM_TITransaction) updating;
// ---------------------------------------------------------------------------
// Created:     JUNE 2010 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aTI : CM_TrackedItem;
begin
	if _shipTran &lt;&gt; null and (not _shipTran.isChild) then //27 Jul 2010	NDL	Par 23056
		aTI := _shipTran.myTrackedItem;
		
		if aTI &lt;&gt; null then
			self.allTrackedItems.addNoDuplicates(aTI, false);
			self.allTransactions.addNoDuplicates(_shipTran,false);
		endif;
		
		self.setDetailFromTransaction(_shipTran);
		
		// ######
		self.rebuildStatsTI(aTI);
		// assume this transaction is later than any others
		self.shiftEndTS := _shipTran.dateTime;
		self.setHours();							// 22/10/2010 cnwmh5 #26067
	endif;
end;</source>
        <Parameter name="_shipTran" type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="setHours" id="7d734e88-1f4b-47ad-be25-c92ad6618366">
        <updating/>
        <source>setHours() updating;
/*
Date		Who		Reason
26 October 2010	cnwmh5	Initial creation #26067
*/

vars
	
begin 
	self.hoursGross := null;
	self.hoursGross := self.shiftEndTS.differenceInHoursReal(self.shiftStartTS);
	self.hoursNet 	:= self.hoursGross - self.hoursDelay;
	//04 Apr 2012	NDL	Par 29369
	self.setHoursDown();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setHoursDown" id="b846c7ae-628c-4f55-80c4-d0e3f36c5e05">
        <updating/>
        <source>setHoursDown()updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 April 2012	cnwndl1	Initial creation	Par 29369

*/

vars

begin

	if self.myJobSheet &lt;&gt; null then
		self.hoursDown :=  self.myJobSheet.getDownHoursForTsRange( self.shiftStartTS, self.shiftEndTS );
	endif;

	self.hoursDown := 0;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setKPI" id="b55f2f1f-3440-40a5-9bcf-0dae70a51073">
        <updating/>
        <source>setKPI(_movesTEU: Decimal; _movesTI: Integer; _start: TimeStamp; _end: TimeStamp; _js: CM_VoyageJobSheet; _shift: CM_Shift; _tis: CM_TISet input; _trans: CM_TITransactionSet input) updating;
/*
Date		Who		Reason
08 August 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
11 April 2017		cnwma1	TFS #4027:MSL - Voyage Side Profile - delay not showed
*/
vars
	voyage			: CM_Voyage;
	terminal		: CM_Terminal;
	tran 			: CM_Transaction;
	grossHours, netHours,
	delayHours		: Real;
	delayCol 		: CM_DelayByStartDTDict;
begin
	voyage			:= _js.myVoyage;
	terminal		:= voyage.myTerminal;
	self.code 		:= voyage.code;
	self.myJobSheet := _js;

	_trans.copyNoDuplicates(self.allTransactions, false);
	_tis.copyNoDuplicates(self.allTrackedItems,false);
	
	process.sleep(10); //CNWRD1 par 32772 - we need a unique time for a dictionary key.
	self.dateTime 	:= app.actualTimeServer;
	
	// gross/net/delay hours	
	create delayCol transient;
	//delayHours := _js.getShiftDelayHours(_start, _end, delayCol);   //11/04/2017 cnwma1 TFS #4027
	if _js.isVoyageLOLOJobSheet then								  //11/04/2017 cnwma1 TFS #4027
		delayHours := _js.getShiftDelayHoursLoLo(_start, _end, delayCol);
	else
		delayHours :=_js.getShiftDelayHoursRoRoHold(_start, _end, delayCol);
	endif;
	delayCol.copy(self.allDelays);
	
	self.hoursDelay := delayHours.Decimal.roundedTo(2);	
	grossHours		:= (_end.differenceInHoursReal(_start)).roundedTo(2);	
	self.hoursGross := grossHours;
	netHours	 	:= (grossHours - delayHours).roundedTo(2);
	self.hoursNet	:= netHours;
	//04 Apr 2012	NDL	Par 29369
	self.setHoursDown();

	_js.getShiftMinMaxMoves(_start, _end, self.liftMinPerHour, self.liftMaxPerHour );
	
	self.movesLid 			:= _js.getShiftLids(_shift,_shift.startDateTime,_shift.endDateTime);
	self.movesTI 			:= _movesTI;
	self.movesTEU 			:= _movesTEU;
	self.shiftStartTS 		:= _start; 
	self.shiftEndTS 		:= _end; 

	if grossHours &gt; 0 then
		self.tiGrossRate 	:= (_movesTI/grossHours).Decimal.roundedTo(2);	
	else
		self.tiGrossRate	:= 0;
	endif;
	
	if netHours &gt; 0 then
		self.tiNetRate 	:= (_movesTI/netHours).Decimal.roundedTo(2);	
	else
		self.tiNetRate	:= 0;
	endif;
	
	self.userCode 			:= app.myPassport.userCode;

	self.setMyShift (terminal, _shift);
	
	self.myVoyage 	:= voyage;
	self.myTerminal := terminal;
	self.myVessel 	:= voyage.getMyVessel();
	
	// new 2010 detail KPIs
	foreach tran in self.allTransactions  discreteLock do
		self.setDetailFromTransaction(tran.CM_TITransaction);
	endforeach;
	

epilog
	delete delayCol;
end;</source>
        <Parameter name="_movesTEU" type="Decimal"/>
        <Parameter name="_movesTI" type="Integer"/>
        <Parameter name="_start" type="TimeStamp"/>
        <Parameter name="_end" type="TimeStamp"/>
        <Parameter name="_js" type="CM_VoyageJobSheet"/>
        <Parameter name="_shift" type="CM_Shift"/>
        <Parameter name="_tis" type="CM_TISet" usage="input"/>
        <Parameter name="_trans" type="CM_TITransactionSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setKPIForCreate" id="b54b6c33-116c-4083-8cb4-e80c0f7b7995">
        <updating/>
        <source>setKPIForCreate(_start: TimeStamp; _end: TimeStamp; _js: CM_VoyageJobSheet; _shift: CM_Shift; _voy: CM_Voyage; _terminal: CM_Terminal) updating;
/*
	
Parameters:		

Date		Who		Reason
08 August 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
11 April 2017		cnwma1	TFS #4027:MSL - Voyage Side Profile - delay not showed
*/
vars
	delayCol 		: CM_DelayByStartDTDict;
	delayHours		: Real;
begin
	self.code				:= _voy.code;
	self.dateTime 			:= app.actualTimeServer;// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.userCode 			:= app.myPassport.userCode;
	self.shiftStartTS 		:= _start;	// may not be same as shift start time
	self.shiftEndTS 		:= _end;	// may not be same as shift end time
	
	self.setMyShift (_terminal, _shift);
	
	self.myJobSheet := _js;
	self.myVoyage 	:= _voy;
	self.myTerminal := _terminal;
	self.myVessel 	:= _voy.getMyVessel();
	
	self.hoursGross := _start.differenceInHoursReal(_end); 

	// PAR 22125 ### get delays per shift
	if _js &lt;&gt; null then
		create delayCol transient;
		//delayHours := _js.getShiftDelayHours(_start,_end,delayCol);        //11/04/2017 cnwma1 TFS #4027
		if _js.isVoyageLOLOJobSheet then     								 //11/04/2017 cnwma1 TFS #4027
			delayHours := _js.getShiftDelayHoursLoLo(_start, _end, delayCol);
		else
			delayHours :=_js.getShiftDelayHoursRoRoHold(_start, _end, delayCol);
		endif;
		self.setKPIForDelays(delayHours, delayCol);
	endif;
epilog
	delete delayCol;
end;</source>
        <Parameter name="_start" type="TimeStamp"/>
        <Parameter name="_end" type="TimeStamp"/>
        <Parameter name="_js" type="CM_VoyageJobSheet"/>
        <Parameter name="_shift" type="CM_Shift"/>
        <Parameter name="_voy" type="CM_Voyage"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setMyShift" id="8cd8b267-7617-4e3e-a6ef-17314007ea81">
        <updating/>
        <source>setMyShift(_terminal :CM_Terminal; _shift :CM_Shift) updating, protected;
/*
Date		Who		Reason
02 August 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/
vars
	proxy, shift	:CM_Shift;
	newShift		:CM_ShiftEntity;
begin
	self.shiftCode 			:= _shift.code;
	self.shiftDescription 	:= _shift.description;

	if _shift.isTransient() then
		proxy := _shift;
		// If the passed in shift is transient, then use keys to find real shift on Terminal
		if _terminal &lt;&gt; null then
			shift := _terminal.allShiftsDay[proxy.startDateTime, proxy.code];
		endif;
		
		if shift = null then
			app.myUtilityCA.utlCreateShiftStd(proxy, app.myPassport, newShift);
			
			shift := newShift.CM_Shift;
		endif;
	else
		shift := _shift;
	endif;
	
	self.myShift := shift;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_shift" type="CM_Shift"/>
    </JadeMethod>
    <JadeMethod name="setShiftMinMaxMoves" id="d4d0645f-a261-4a1d-bbfb-6d8962a0e386">
        <updating/>
        <source>setShiftMinMaxMoves() updating;
// ---------------------------------------------------------------------------
// Created:		03 April 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	aDelay 			: CM_Delay;
	numHoursDelaid 	: Real;
	fromTS, toTS 	: TimeStamp;
	aCrane 			: CM_Crane;
	delayIsOnShift 	: Boolean;
	idx, numOfTIs, 
	minTIs, maxTIs	: Integer;
	aTran 			: CM_Transaction;
	localDict : CM_TITransactionByDateDict;	//29 Mar 2016	NDL	TFS 1714 - Use keyed dictionary so we read less.  'where' uses keys...
begin
	if self.allTransactions.isEmpty then
		return;
	endif;
	
	create localDict transient;	//29 Mar 2016	NDL	TFS 1714
	self.allTransactions.copy(localDict);	//29 Mar 2016	NDL	TFS 1714

	fromTS := self.shiftStartTS;
	minTIs := 9999; // PAR 21305 was 99999999
	
	while true do
		toTS := fromTS.addHours(1);
	
		// Just in case of an eternal loop
		idx := idx + 1;
		if idx &gt; 30 then
			break;
		endif;
		numOfTIs := 0;
	
	//	foreach aTran in self.allTransactions discreteLock 
		foreach aTran in localDict discreteLock		//29 Mar 2016	NDL	TFS 1714
			where aTran.CM_TITransaction.dateTime &gt;= fromTS and aTran.CM_TITransaction .dateTime &lt;= toTS do			
			numOfTIs := numOfTIs + 1;
		endforeach;

		if numOfTIs &gt; 0 then
			minTIs := minTIs.min(numOfTIs);
		endif;
		
		maxTIs :=maxTIs.max(numOfTIs);
		fromTS := toTS;
	endwhile;
	
	self.liftMinPerHour := minTIs;
	self.liftMaxPerHour := maxTIs;
	
epilog

	delete localDict;
	
end;</source>
    </JadeMethod>
</Class>
