    <JadeMethod name="trxCreateWOForManifest" id="ba65c5e7-ffe3-43bb-8cee-e4a88ee0051f">
        <updating/>
        <source>trxCreateWOForManifest(_manifestNumber : String; _mode : Integer; _objArray : CM_ObjectArray; _transportObject : CM_Object; _tis : CM_TIByCargoTypeIdDict) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Jul 2023	jlirs1	Initial creation 58884 (57807) work order creation
15 Aug 2023	navdap1	TFS 59844 EUP FR | 53824 - Manifest EDI - Work order must have at least one tracked item error
15/07/2025	navcs2	MTN-35210 Add Deferred Updates for WO Transaction During Transport Manifest and Call-Off Loading to Reduce Deadlocks
*/
vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(app.myPassport, method);
 
	// Set to use deffered updates
	app.myPassport.useTITransactionDeferUpdate := true;							// 15/07/2025	navcs2	MTN-35210
	app.myPassport.useWOTransactionDeferUpdate := true;							// 17/07/2025	navcs2	MTN-35210
	
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, app.myPassport);
	on LockException do agtPassportLockExHandler(exception, app.myPassport);

	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;
	//app.myUtilityCA.utlCreateWOForManifest(_manifestNumber, _mode, _objArray, _transportObject);		// TFS 59844
	app.myUtilityCA.utlCreateWOForManifest(_manifestNumber, _mode, _objArray, _transportObject, _tis);	// TFS 59844
epilog
	self.finaliseActivityWithPassport(app.myPassport);
	if app.myPassport.trxCompletedOK()  then
		app.myPassport.doDeferredUpdates();			// 15/07/2025	navcs2	MTN-35210	
		app.myPassport.doTrxPostActions();		
	endif;
end;</source>
        <Parameter name="_manifestNumber" type="String"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_objArray" type="CM_ObjectArray"/>
        <Parameter name="_transportObject" type="CM_Object"/>
        <Parameter name="_tis" type="CM_TIByCargoTypeIdDict"/>
    </JadeMethod>
    <JadeMethod name="trxCreateWOForManifestTrans" id="90f41d6f-62fd-446b-a394-71188a73e73d">
        <updating/>
        <source>trxCreateWOForManifestTrans(_manifest : CM_EDIDataTransManifest; _mode : Integer; _objArray : CM_ObjectArray; _transportObject : CM_Object; _tis : CM_TIByCargoTypeIdDict) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16/11/2023	navcs2	ChangeRequest 60866: EUP | Manifest - Single Work Order per transport 
23 February 2024	navcs2	ChangeRequest 62250: EUP | FR 53824 - Transport Manifest - Multiple Manifests For a Single Wagon Need to be Possible. 
18/03/2024	navcs2	ChangeRequest 58059[58497]: EUP | Manifest - Change of Transport Mode
11 Apr 2025 navsaa30 12349-EUP - Transport Manifest load after locking does not add all cargo to work order
15/07/2025	navcs2	MTN-35210 Add Deferred Updates for WO Transaction During Transport Manifest and Call-Off Loading to Reduce Deadlocks
*/
vars
	hadLock : Boolean;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(app.myPassport, method);
	
	// Set to use deffered updates
	app.myPassport.useWOTransactionDeferUpdate := true;							// 17/07/2025	navcs2	MTN-35210

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, app.myPassport);
	on LockException do agtPassportLockExHandler(exception, app.myPassport);
	
	on DeadlockException do agtPassportSilDLckExHandlerFlg(exception, hadLock, app.myPassport);			//navsaa30 16/4/25 #12349

	// Set up the deadlock reply values
	app.myPassport.setupForDeadlockReplay(-200, 300 + app.random(300));
	app.myPassport.silentDeadlockLimit := 5;	
	

	app.setContinueCMExceptions(false);
	
	while true do
		// Start the transaction
		beginTransaction;				// MTN-12349
		
		// Clear any Errors/Warnings we might have
		app.myPassport.clearErrorsWarnings();		
		
		if _transportObject.isKindOf(CM_Voyage) then
			app.myUtilityCA.utlCreateWOForShipManifest(_manifest, _mode, _objArray, _transportObject, _tis);	
		elseif _transportObject.isKindOf(CM_Train) then															// 23 February 2024	navcs2	ChangeRequest 62250
			app.myUtilityCA.utlCreateWOForRailManifest(_manifest, _mode, _objArray, _transportObject, _tis);	// 23 February 2024	navcs2	ChangeRequest 62250
		else																									// 23 February 2024	navcs2	ChangeRequest 62250
			app.myUtilityCA.utlCreateWOForRoadManifest(_manifest, _mode, _objArray, _transportObject, _tis);	// 18/03/2024 navcs2 ChangeRequest 58059[58497]	
		endif;																									// 18/03/2024 navcs2 ChangeRequest 58059[58497]
		
		// If we had a deadlock, then try, try and try again &gt;.&gt;
		if hadLock then
			if app.myPassport.silentDeadlockRetryCount &gt; app.myPassport.silentDeadlockLimit then
				// Too many errors!
				break;
			else
				hadLock := false;				
				app.myPassport.silentDeadlockRetryCount := app.myPassport.silentDeadlockRetryCount + 1;
				process.sleep(app.myPassport.silentDeadlockSleepTime);
				continue;
			endif;
		endif;
		
		// All good, job done
		break;
	endwhile;
epilog
	app.myPassport.resetSilentDeadlockHandler;				//11/4/25 navsaa30 #12349
	self.finaliseActivityWithPassport(app.myPassport);
	if app.myPassport.trxCompletedOK()  then
		app.myPassport.doDeferredUpdates();					// 15/07/2025	navcs2	MTN-35210
		app.myPassport.doTrxPostActions();		
	endif;
end;</source>
        <Parameter name="_manifest" type="CM_EDIDataTransManifest"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_objArray" type="CM_ObjectArray"/>
        <Parameter name="_transportObject" type="CM_Object"/>
        <Parameter name="_tis" type="CM_TIByCargoTypeIdDict"/>
    </JadeMethod>
