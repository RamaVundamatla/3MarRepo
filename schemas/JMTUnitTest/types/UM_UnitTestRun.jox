    <JadeMethod name="validRunnableTests" id="91862bd7-41fd-4cd8-b903-8343e8c07640">
        <source>validRunnableTests(_testResults : UM_UnitTestResultByMRunTS) : Integer;

/*

Purpose:		Get teh valid runnable tests

Date			Who		Reason
24/02/2014		cnwmh5	Initial creation

*/
constants
	Alpha						: String = "ABCDEFGHIJKLMNOPQRSTUVWXYZ";
vars
	
	unitTestResult				: UM_UnitTestResult;

	totalRunnableTests			: Integer;
	
begin

	foreach unitTestResult in _testResults do
		if unitTestResult.myClassMethod.methodName[1:1] = 't' and 
				Alpha.cnContains(unitTestResult.myClassMethod.methodName[2:1]) then
			totalRunnableTests := totalRunnableTests + 1;
		endif;	
	endforeach;
	
	return totalRunnableTests;

epilog

end;</source>
        <Parameter name="_testResults" type="UM_UnitTestResultByMRunTS"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="workOutEndTS" id="241aa6d2-be50-4bf4-9a32-b8b9f0ef7454">
        <source>workOutEndTS() : TimeStamp;

/*

Purpose:		Workout what the endTS is
				If an endTS exists then we just return this else
				work out based on the last run of it's type

Date			Who		Reason
24/06/2014		cnwmh5	Initial creation

*/

vars

	root					: UM_Root;
	testRun					: UM_UnitTestRun;
	
	iter					: Iterator;

	returnTS				: TimeStamp;

begin

	// has an endTS then just return this
	if self.endTS &lt;&gt; null then
		return self.endTS;
	endif;

	// logResult runs always finish on the same day and take about 6 hours
	if self.logResult then
		returnTS := self.startTS.addHours(6);
		return returnTS;
	endif;
	
	// SCHEDULE_WEEKLY runs finish on same day and take about 2 hours
	if self.scheduleName &lt;&gt; null and self.scheduleName = "SCHEDULE_Weekly" then
		returnTS := self.startTS.addHours(2);
		return returnTS;
	endif;
	
	// Everything else
	root := UM_Root.firstInstance;
	if root = null then
		returnTS := self.startTS;
	endif;
	
	iter := root.allUnitTestRuns.createIterator;
	root.allUnitTestRuns.startKeyLeq(self.startTS, iter);
	
	while iter.back(testRun) do
		
		// doing the normal weekly run so these aren't included
		if testRun.scheduleName &lt;&gt; null or testRun.logResult then
			continue;
		endif;
		
		// if endTS = null then try next record
		if testRun.endTS = null then
			continue;
		endif;
		
		returnTS := testRun.endTS;
		break;
	
	endwhile;
	
	if returnTS = null then
		// use 3 hours being what it should run under
		returnTS := self.startTS.addHours(3);	
	else
		returnTS := returnTS.addDays(1);
	endif;
	
	return returnTS;	
	
epilog

	delete iter;

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
</Class>
