    <JadeMethod name="isPolyInMyPolys" id="9da5641a-070e-4b13-a6a3-0fcb35b2b595">
        <source>isPolyInMyPolys(_points : PointArray) : Boolean;
/*
Purpose:			
Date		Who		Reason
15 June 2011	cnwab1	Initial creation
*/

vars
	layout : CM_DeckItemLayout;
	aPoint : Point;
begin

	foreach aPoint in _points do
		foreach layout in self.allDeckItemLayouts discreteLock do
			if layout.myPolygonPixels.isPointInPolygon(aPoint.x, aPoint.y,1) then
				return true;
			endif;
		endforeach;
	endforeach;
	
	return false;

epilog

end;</source>
        <Parameter name="_points" type="PointArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="matchOrderOfItemLayouts" id="c3c95fd7-b75c-48e6-b2bb-bf0eaf5adf65">
        <updating/>
        <source>matchOrderOfItemLayouts(_newOrder : CM_RORODeckItemLayoutArray) updating;
/*
Purpose:			
Date				Who			Reason
MAY 2011		CNWAB1		Initial creation
*/

vars
	idx, st, endIDX : Integer;
	tmpItem, realItem : CM_DeckItemLayout;
	obj : Object;
begin
	st := 1;
	endIDX := _newOrder.size;
	
//	foreach tmpItem in _newOrder do
//	if tmpItem &lt;&gt; null then
//		endIDX := endIDX + 1;
//		endif;
//	endforeach;

	// DETTACH ItemS
	foreach idx in st to endIDX do
		tmpItem := _newOrder[idx].CM_DeckItemLayout;
		tmpItem.setMyDeckLayer(null);
	
	endforeach;

	// REORDER ItemS
	foreach idx in st to endIDX do
		tmpItem := _newOrder[idx].CM_DeckItemLayout;
		tmpItem.setMyDeckLayer(self);
	endforeach;
	
end;</source>
        <Parameter name="_newOrder" type="CM_RORODeckItemLayoutArray"/>
    </JadeMethod>
    <JadeMethod name="moveLayer" id="70db9f12-b61b-4214-9e88-5ed88218740b">
        <updating/>
        <source>	moveLayer(_up : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     24 March 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	idx : Integer;
	tmpDeck : CM_DeckLayout;
	tmpLayer : CM_DeckLayerLayout;
	objs : CM_DeckLayerLayoutArray;
begin
	create objs transient;

	tmpDeck := self.myDeckLayout;
	tmpDeck.allDeckLayerLayouts.copy(objs);
	
	objs.moveElement(self, _up);

	// DETTACH LAYERS
	foreach tmpLayer in objs discreteLock do
		tmpLayer.myDeckLayout := null;
	endforeach;
	// REATTACH LAYERS
	foreach tmpLayer in objs discreteLock do
		tmpLayer.myDeckLayout := tmpDeck;
	endforeach;
	
	
	self.causeEvent(EVENT_RORO_LAYER_UPDATE,true,null); // PAR 27595
	
epilog
	delete objs;
end;</source>
        <Parameter name="_up" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="moveLayerToTop" id="922bf4d5-fdc9-4212-b6e8-237a12f7d72c">
        <source>moveLayerToTop();
/*
Purpose:			
Date		Who		Reason
14 June 2011	cnwab1	Initial creation
*/

vars
	idx : Integer;
	tmpDeck : CM_DeckLayout;
	tmpLayer : CM_DeckLayerLayout;
	objs : CM_DeckLayerLayoutArray;
begin
	create objs transient;

	tmpDeck := self.myDeckLayout;
	tmpDeck.allDeckLayerLayouts.copy(objs);
	
	objs.remove(self);
	objs.insert(1,self);

	// DETTACH LAYERS
	foreach tmpLayer in objs discreteLock do
		tmpLayer.myDeckLayout := null;
	endforeach;
	// REATTACH LAYERS
	foreach tmpLayer in objs discreteLock do
		tmpLayer.myDeckLayout := tmpDeck;
	endforeach;
	
	
	self.causeEvent(EVENT_RORO_LAYER_UPDATE,true,null); // PAR 27595
	
epilog
	delete objs;
end;</source>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="421bcd6b-4d58-4239-83f5-e1eed2a2d1c2">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     24 March 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 20/04/2011		cnwmh5			PAR #27401 - Add code to handle prossible exceptions occurring when
//									trying to create the proxy
// ---------------------------------------------------------------------------

vars
	pxyMe : SelfType;
	completedOK		: Boolean;
begin
	pxyMe := inheritMethod();

	pxyMe.myDeckLayout := self.myDeckLayout.pxyGetProxyObject();
	if pxyMe.myDeckLayout = null then
		pxyMe.myDeckLayout := self.myDeckLayout;
	endif;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyMe;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyMe;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setAftLocnByPosition" id="a9bb3ef3-6f5d-417d-977b-c91d4fe689c5">
        <source>setAftLocnByPosition(_fwdLocn : CM_ROROLocnDefn input);
/*
Purpose:	29396		
Date				Who			Reason
APRIL 2012		CNWAB1		Initial creation
*/
//15 Jan 2013	cnwrs1	Par30951 include Exports as ROBs for EDI Proposed
vars
	aft : CM_ROROLocnDefn;
begin
	

	aft := self.getAftLocnByPosition(_fwdLocn);

	if aft &lt;&gt; null then	//15 Jan 2013	cnwrs1	Par30951 include Exports as ROBs for EDI Proposed
		if aft.myAdjacentSlotAft &lt;&gt; null or //the aft found already has an aft cant have 2 so leave it with the first
		   (aft.myAdjacentSlotFwd &lt;&gt; null and	//the aft has a forward and its not use so ignore it 
		    aft.myAdjacentSlotFwd &lt;&gt; _fwdLocn) then
			return;
		endif;
	endif;
	  
	_fwdLocn.setAftLocn(aft);
	return;
epilog

end;</source>
        <Parameter name="_fwdLocn" type="CM_ROROLocnDefn" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setDeckLayout" id="4deb03bf-12e1-4eca-aa91-da97ce4da3a2">
        <updating/>
        <source>setDeckLayout(_deck : CM_DeckLayout) updating;
// ---------------------------------------------------------------------------
// Created:     24 March 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.myDeckLayout := _deck;
epilog

end;</source>
        <Parameter name="_deck" type="CM_DeckLayout"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="d542e38e-2369-4f3e-aa85-e4bd645652a3">
        <updating/>
        <source>setForCreate(_pxyMe : CM_DeckLayerLayout) updating;
// ---------------------------------------------------------------------------
// Created:     24 March 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.code := _pxyMe.code;
	self.description := _pxyMe.description;
	self.remarks := _pxyMe.remarks;
	self.isVisible := _pxyMe.isVisible; //epr 27519 17/5/2011 for copy want to update this
	self.type := _pxyMe.type;
	
	if _pxyMe.myDeckLayout &lt;&gt; null then
		self.myDeckLayout := _pxyMe.myDeckLayout.pxyGetRealObject();
	endif;
	if self.myDeckLayout = null and _pxyMe.myDeckLayout &lt;&gt; null and not _pxyMe.myDeckLayout.isTransient then	// 34541 Oct 2014 prevent persistent - transient error in copy
		self.myDeckLayout := _pxyMe.myDeckLayout;
	endif;
	
	
epilog

end;</source>
        <Parameter name="_pxyMe" type="CM_DeckLayerLayout"/>
    </JadeMethod>
    <JadeMethod name="setForCreateImport" id="45f9d2ab-c07a-4ec8-89e7-e6f7a14b0798">
        <updating/>
        <source>setForCreateImport(_proxyDeckLayoutLayer : CM_DeckLayerLayout input; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 April 2011	cnwer1	Initial creation

*/

vars
	pxyDeckItemLayout , realDeckItemLayout: CM_DeckItemLayout;
	realFwdLocn, 	realAftLocn : CM_ROROLocnDefn;
begin
	self.setForUpdate(_proxyDeckLayoutLayer);
	
	foreach pxyDeckItemLayout in _proxyDeckLayoutLayer.allDeckItemLayouts discreteLock do
		create realDeckItemLayout persistent;
		realDeckItemLayout.setMyDeckLayer(self);
		realDeckItemLayout.setForCreateImport(pxyDeckItemLayout,_passport);
		
	
		if _passport.hasErrors then
			return;
		endif;
		
	endforeach;
	
	// Join up the Locns
	foreach pxyDeckItemLayout in _proxyDeckLayoutLayer.allDeckItemLayouts   discreteLock where pxyDeckItemLayout.type = DeckItemLayoutType_Locn do
		//epr par 28454 12/10/11
		if pxyDeckItemLayout.myDeckItem = null then
			continue;
		endif;


		realFwdLocn := self.myDeckLayout.myDeck.allDeckItems[pxyDeckItemLayout.myDeckItem.CM_ROROLocnDefn.code].CM_ROROLocnDefn;
		if pxyDeckItemLayout.myDeckItem.CM_ROROLocnDefn.myAdjacentSlotAft &lt;&gt; null then
			realAftLocn := self.myDeckLayout.myDeck.allDeckItems[pxyDeckItemLayout.myDeckItem.CM_ROROLocnDefn.myAdjacentSlotAft.code].CM_ROROLocnDefn;
		else
			 realAftLocn := null;
		endif;
		realFwdLocn.setAftLocn(realAftLocn);
	endforeach;
	
epilog

end;</source>
        <Parameter name="_proxyDeckLayoutLayer" type="CM_DeckLayerLayout" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="570a16f6-29e9-49af-8fef-8d5e607733a8">
        <updating/>
        <source>setForUpdate(_pxyMe : CM_DeckLayerLayout) updating;
// ---------------------------------------------------------------------------
// Created:     24 March 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.code := _pxyMe.code;
	self.description := _pxyMe.description;
	self.remarks := _pxyMe.remarks;
	self.isVisible := _pxyMe.isVisible;
	self.type := _pxyMe.type;
	
	
epilog

end;</source>
        <Parameter name="_pxyMe" type="CM_DeckLayerLayout"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateRotate" id="2234149e-389e-4eea-a672-73259bdd4e40">
        <updating/>
        <source>setForUpdateRotate(_startLocn : CM_ROROLocnDefn io; _items, _split : Integer; _cloneLocation : Boolean; _isLoad : Boolean) updating;
/*
Purpose:			
Date		Who		Reason
13 July 2011	cnwab1	Initial creation
*/

vars
	locns : CM_RORODeckItemByOrd1Ord2;
	areaPoints : PointArray;
	origLocn, fwdLocation, aftLocation, locnDefn, preDefn : CM_ROROLocnDefn;
	obj : Object;
	theCargoLayer : CM_DeckLayerLayout;
	idx, stIdx, endIdx, itemPerRow : Integer;
	wasRotated, needToLink : Boolean;
	loadLayer : CM_DeckLayerLayout;
	di : CM_DeckItem;
	isOOTL : Boolean;
	layout : CM_DeckItemLayout;
	coveringItems : CM_RORODeckItemLayoutArray;
begin
	wasRotated := _startLocn.isVerticalOrientation();

	isOOTL := _startLocn.isOOTL();

	create locns transient;
	create coveringItems transient;
	areaPoints := self.getLocnDefnsToRotate(_startLocn, _items, _split,locns, true);
	
	if areaPoints =  null then
		return;
	endif;
	
	// PAR 29749 added the quotes around the code to differenciate from the validation exceptions
	// If happens here may be to do with the number of pixels between each position. This is copnfigurable
	// but Messina are creating their own XML definitions and sometimes have 1 or 2 pixel gaps between 
	// each position when it is configured for 0 pixels.
	if _items &lt;&gt; locns.size then
		app.raiseCMException1(Posit_canno_rotat_becau_does_n, "'" &amp; _startLocn.code &amp; "'", null, null);
		return;
	endif;
	
		
	// PAR 31502 - Get all the current covering GC areas and after the rotation re-evaluate the GC layouts
	self.getAllCoveringLayouts(locns, coveringItems, DeckItemLayoutType_GCDischarge, true);
	self.getAllCoveringLayouts(locns, coveringItems, DeckItemLayoutType_Locn, false); // PAR 32186 MESSINA are loading OOTL over rotated positions in an EDI deckplan

	origLocn := _startLocn; // PAR 28890
	
	if _cloneLocation and not isOOTL then // says whether to do the clone stuff or not PAR 29990 no cloning for OOTL
		self.setLocnDefnsToRotateClone(_startLocn, locns, _isLoad); // PAR 28990 rotate on the load layer not the cargo layer. The contents of 'locns' is changed to new clones on the load layer
	endif;
	
	// Rotate the graphic
	self.setLocnDefnsToRotate(_startLocn,areaPoints, locns);

	foreach di in locns  discreteLock do
		if  _isLoad then
			locnDefn := di.CM_ROROLocnDefn;
		else
			locnDefn := di.CM_ROROLocnDefn.myRotateLoad;
		endif;
		if locnDefn &lt;&gt; null then
			locnDefn.removeRotateLabel("#");
		endif;
	endforeach;

	// This links aft and  forward locations within the rotation.
	// e.g. 1X5 has become 2X2 so link the aft/fwd for the 2X2
	self.setForUpdateRotateLinkAft(locns, _items, _split, wasRotated);

	

	if not isOOTL and (not  _isLoad and _cloneLocation) then // PAR 29990
		// This method links the un rotated clones to the adjacent real unrotated locations.
		self.setForUpdateRotateLinkCloneAft(_items, _split,locns, wasRotated, _isLoad);
/*		
		// Link the aft and forwards on the clones
		if _split = 1 then
			foreach di in locns  discreteLock do
				locnDefn := di.CM_ROROLocnDefn.myRotateLoad;  // Get the clone
				// The actual is being rotated, but only for 1 row. However if they have aft slots we need to link their
				// pre rotate aft slots to our new clonesl so that in the load view we can do 40s
				preDefn := di.CM_ROROLocnDefn.myPreRotateAftLocn;
				locnDefn.setAftLocn(preDefn);
				preDefn := di.CM_ROROLocnDefn.myPreRotateFwdLocn;
				locnDefn.setFwdLocn(preDefn);
			endforeach;
		else
			// Link the clone to each other
			foreach di in locns  discreteLock do
				locnDefn := di.CM_ROROLocnDefn.myRotateLoad;  // Get the clone
				cloneLocns.add(locnDefn);
			endforeach;
			self.setForUpdateRotateLinkAft(cloneLocns, _items, _split, not wasRotated);
			// Link the clones to the actuals that are around them
			foreach di in locns  discreteLock do
				locnDefn := di.CM_ROROLocnDefn.myRotateLoad;  // Get the clone
				// The actual is being rotated. However if they have aft slots we need to link their
				// pre rotate aft slots to our new clones so that in the load view we can do 40s
				if locnDefn.myAdjacentSlotAft = null then
					preDefn := di.CM_ROROLocnDefn.myPreRotateAftLocn;
					if preDefn &lt;&gt; null then
					preDefn.setFwdLocn(null);
					endif;
					locnDefn.setAftLocn(preDefn);
				endif;
				
				if locnDefn.myAdjacentSlotFwd = null then
					preDefn := di.CM_ROROLocnDefn.myPreRotateFwdLocn;
					if preDefn &lt;&gt; null then
					preDefn.setAftLocn(null);
					endif;
					locnDefn.setFwdLocn(preDefn);
				endif;
			endforeach;
		endif;
		*/
	endif;
	
	
	// PAR 28990 // hide the actual locn defns that are under our clone that is on the Load CC layer
	di := locns.first();
	if di.isKindOf(CM_ROROLocnDefn) then
		locnDefn := di.CM_ROROLocnDefn;
		if locnDefn.isRotatedLoadLayer() then
//			if locnDefn.myLayout.myDeckLayer.type = ROROLayerType_CCLoad then
			foreach di in locns  discreteLock do
				locnDefn := di.CM_ROROLocnDefn;
				if not locnDefn.isOOTL() then // PAR 30264
					self.myDeckLayout.hideContainerPositionsUnderGC(locnDefn.myLayout);
				endif;
			endforeach;
		endif;
	endif;
	
	if origLocn.myLayout &lt;&gt; null then
		if origLocn.myLayout.myDeckLayer &lt;&gt; null then
			if origLocn.isOnLayerCargo then // PAR 30264
				loadLayer := origLocn.myLayout.myDeckLayer.myDeckLayout.getCCLoadLayer();
				origLocn.myLayout.myDeckLayer.causeEvent(EVENT_RORO_LAYER_UPDATE,false,loadLayer); // PAR 28890 send the load layer or null
			else
				theCargoLayer := origLocn.myLayout.myDeckLayer.myDeckLayout.getCargoLayer(); // PAR 30264
				origLocn.myLayout.myDeckLayer.causeEvent(EVENT_RORO_LAYER_UPDATE,false,theCargoLayer);  // PAR 30264
			
			endif;
		endif;
	endif;
	
	// PAR 31502
	foreach layout in coveringItems discreteLock do
		self.myDeckLayout.hideContainerPositionsUnderGC(layout);
	endforeach;
epilog
	delete locns;
	delete areaPoints;	// 21 Feb 2012	cnwrs1	Par 29157
	delete coveringItems;

end;</source>
        <Parameter name="_startLocn" type="CM_ROROLocnDefn" usage="io"/>
        <Parameter name="_items" type="Integer"/>
        <Parameter name="_split" type="Integer"/>
        <Parameter name="_cloneLocation" type="Boolean"/>
        <Parameter name="_isLoad" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateRotateLinkAft" id="0d7decc0-afb1-4d61-8c95-1e99b0645479">
        <source>setForUpdateRotateLinkAft(locns : CM_RORODeckItemByOrd1Ord2; _items, _split : Integer; _wasVertical : Boolean);
/*
Purpose:			now we are rotated we need to link 2x20s so that 40s can be moved to the rotated positions.
		// This links aft and  forward locations within the rotation.
		// e.g. 1X5 has become 2X2 so link the aft/fwd for the 2X2

Date		Who		Reason
11 January 2012	cnwab1	Initial creation
21 Feb 2012	cnwrs1	Par 29157 - fixup leaks
*/

vars
	idx, stIdx, endIdx, itemPerRow : Integer;
	di : CM_DeckItem;
	fwdLocation, aftLocation, locnDefn : CM_ROROLocnDefn;
	rotatedLocns : ObjectArray;
	needToLink : Boolean;
begin
		// 28968 Have to delink the rotated location as we are about to relink them how they were, and we will get a duplicate reference error if we do not
		foreach di in locns  discreteLock do
			locnDefn := di.CM_ROROLocnDefn;
			if (locnDefn.isPlannedRotated or locnDefn.hasBeenRotatedForLoad) // PAR 31110
			and not locnDefn.isOOTL then // PAR 28968 do not disconnect OOTL 40 from their aft
				locnDefn.setFwdLocn(null);
				locnDefn.setAftLocn(null);
			endif;
		endforeach;


		// PAR 28880
		needToLink := ( (_items = 5 and _split = 1) or (_items = 10 and _split = 2)); // 1X5 and 2X5
							// PAR 28990 if have rotated on actual 2X3 we need to then link or load 2X3 locns, but they will not have been rotated.
// PAR 29884							or (not locnDefn.isPlannedRotated  and _items = 6 and _split = 2  )); // 2X3
						//	or (_items = 6 and _split = 2  )); // 2X3

		if locnDefn &lt;&gt; null and not locnDefn.isPlannedRotated and locnDefn.hasBeenRotatedForLoad then
			if (_items = 6 and _split = 2  ) then
				needToLink := true;
			endif;
		endif;
	
		if needToLink  then
			// Link the rotated slots, if there are 2 rows, to their forward slots
//	28880		_startLocn.allPlannedRotatedLocnDefns.copy(rotatedLocns);
			create rotatedLocns transient;
			locns.copy(rotatedLocns);
			// PAR 28525
			if _wasVertical then
				if  (_items = 5 and _split = 1) then
					fwdLocation := rotatedLocns[3].CM_ROROLocnDefn;
					aftLocation := rotatedLocns[1].CM_ROROLocnDefn;
					fwdLocation.setAftLocn(aftLocation);
					
					fwdLocation := rotatedLocns[4].CM_ROROLocnDefn;
					aftLocation := rotatedLocns[2].CM_ROROLocnDefn;
					fwdLocation.setAftLocn(aftLocation);
				elseif (_items = 10 and _split = 2) then
					itemPerRow := 5;
					stIdx :=  6;
					endIdx := 10;
					foreach idx in stIdx to endIdx do
						fwdLocation := rotatedLocns[idx].CM_ROROLocnDefn;
						aftLocation := rotatedLocns[idx-itemPerRow].CM_ROROLocnDefn;
						fwdLocation.setAftLocn(aftLocation);
					endforeach;
				elseif (_items = 6 and _split = 2) then
					itemPerRow := 3;
					stIdx :=  4;
					endIdx := 6;
					foreach idx in stIdx to endIdx do
						fwdLocation := rotatedLocns[idx].CM_ROROLocnDefn;
						aftLocation := rotatedLocns[idx-itemPerRow].CM_ROROLocnDefn;
						fwdLocation.setAftLocn(aftLocation);
					endforeach;
				endif;
			else
				// PAR 28880
				if  (_items = 5 and _split = 1) then
					fwdLocation := rotatedLocns[1].CM_ROROLocnDefn;
					aftLocation := rotatedLocns[3].CM_ROROLocnDefn;
					fwdLocation.setAftLocn(aftLocation);
					
					fwdLocation := rotatedLocns[2].CM_ROROLocnDefn;
					aftLocation := rotatedLocns[4].CM_ROROLocnDefn;
					fwdLocation.setAftLocn(aftLocation);
				elseif (_items = 10 and _split = 2) then
					itemPerRow := 5;
					stIdx :=  6;
					endIdx := 10;
					foreach idx in stIdx to endIdx do
						aftLocation := rotatedLocns[idx].CM_ROROLocnDefn;
						fwdLocation := rotatedLocns[idx-itemPerRow].CM_ROROLocnDefn;
						fwdLocation.setAftLocn(aftLocation);
					endforeach;
				
				elseif (_items = 6 and _split = 2) then
					itemPerRow := 3;
					stIdx :=  4;
					endIdx := 6;
					foreach idx in stIdx to endIdx do
						aftLocation := rotatedLocns[idx].CM_ROROLocnDefn;
						fwdLocation := rotatedLocns[idx-itemPerRow].CM_ROROLocnDefn;
						fwdLocation.setAftLocn(aftLocation);
					endforeach;
		
				endif;
				
				
			endif;
		endif;
epilog
	delete rotatedLocns;	// 21 Feb 2012	cnwrs1	Par 29157
end;</source>
        <Parameter name="locns" type="CM_RORODeckItemByOrd1Ord2"/>
        <Parameter name="_items" type="Integer"/>
        <Parameter name="_split" type="Integer"/>
        <Parameter name="_wasVertical" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateRotateLinkCloneAft" id="38c09d93-a31c-43f4-9974-ee06237af300">
        <updating/>
        <source>setForUpdateRotateLinkCloneAft(_items, _split : Integer; locns : CM_RORODeckItemByOrd1Ord2; _wasRotated : Boolean; _isLoad : Boolean) updating;
/*
Purpose:	we have created clones of the unrotated actual locations, we need to link the aft and fwd positions.		
// This method links the un rotated clones to the adjacent real unrotated locations.
Date				Who			Reason
JULY 2012		CNWAB1		Initial creation
*/

vars
	cloneLocns : CM_RORODeckItemByOrd1Ord2;
	locnDefn, preDefn : CM_ROROLocnDefn;
	iter : Iterator;
	di : CM_DeckItem;
	ord1,ord2 : Integer;
begin
	create cloneLocns transient;

	// Link the aft and forwards on the clones
	if _split = 1 then
		foreach di in locns  discreteLock do
			locnDefn := di.CM_ROROLocnDefn.myRotateLoad;  // Get the clone
			// The actual is being rotated, but only for 1 row. However if they have aft slots we need to link their
			// pre rotate aft slots to our new clonesl so that in the load view we can do 40s
//			preDefn := di.CM_ROROLocnDefn.myPreRotateAftLocn;
			preDefn := di.CM_ROROLocnDefn.getPreRotatedAdjacentLocation(true, _isLoad); // PAR 29884
			locnDefn.setAftLocn(preDefn);
//			preDefn := di.CM_ROROLocnDefn.myPreRotateFwdLocn;
			preDefn := di.CM_ROROLocnDefn.getPreRotatedAdjacentLocation(false, _isLoad); // PAR 29884
			locnDefn.setFwdLocn(preDefn);
		endforeach;
	else
		iter := locns.createIterator();
		// Link the clone to each other
		
		while iter.next(di) do
			locns.getIteratorKeys(ord1,ord2,iter);
			locnDefn := di.CM_ROROLocnDefn.myRotateLoad;  // Get the clone
			cloneLocns.putAtKey(ord1,ord2,locnDefn);
		endwhile;
/*
		foreach di in locns  discreteLock do
			locnDefn := di.CM_ROROLocnDefn.myRotateLoad;  // Get the clone
			cloneLocns.add(locnDefn);
		endforeach;
		*/
		// This call is done just before calling this method, but it needs to be done again.
		self.setForUpdateRotateLinkAft(cloneLocns, _items, _split, not _wasRotated);
		
		// Link the clones to the actuals that are around them
		foreach di in locns  discreteLock do
			locnDefn := di.CM_ROROLocnDefn.myRotateLoad;  // Get the clone
			// The actual is being rotated. However if they have aft slots we need to link their
			// pre rotate aft slots to our new clones so that in the load view we can do 40s
			if locnDefn.myAdjacentSlotAft = null then
//				preDefn := di.CM_ROROLocnDefn.myPreRotateAftLocn;
				preDefn := di.CM_ROROLocnDefn.getPreRotatedAdjacentLocation(true, _isLoad); // PAR 29884
				if preDefn &lt;&gt; null then
					preDefn.setFwdLocn(null);
				endif;
				locnDefn.setAftLocn(preDefn);
			endif;
			
			if locnDefn.myAdjacentSlotFwd = null then
//				preDefn := di.CM_ROROLocnDefn.myPreRotateFwdLocn;
				preDefn := di.CM_ROROLocnDefn.getPreRotatedAdjacentLocation(false, _isLoad); // PAR 29884
				if preDefn &lt;&gt; null then
					preDefn.setAftLocn(null);
				endif;
				locnDefn.setFwdLocn(preDefn);
			endif;
		endforeach;
	endif;

epilog
	delete cloneLocns;
	delete iter;

end;</source>
        <Parameter name="_items" type="Integer"/>
        <Parameter name="_split" type="Integer"/>
        <Parameter name="locns" type="CM_RORODeckItemByOrd1Ord2"/>
        <Parameter name="_wasRotated" type="Boolean"/>
        <Parameter name="_isLoad" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setLocnDefnsToRotate" id="4985b65d-6651-4563-9600-d1432a131463">
        <source>setLocnDefnsToRotate(_startLocn : CM_ROROLocnDefn;	_areaPoints : PointArray; _locns : CM_RORODeckItemByOrd1Ord2 );
/*
Purpose:	Take the locnDefns in _locn and rotate them within the area of the _areaPoints polygon. Any that do not fit are made inVisible		
				To make the locns in visible we need to check whether the far, right hand, side is in the area so we have an offset for X or Y
				depending on whether it is going vertical or horizontal
Date		Who		Reason
13 July 2011	cnwab1	Initial creation
*/

vars
	locnDefn : CM_ROROLocnDefn;
	deckItem : CM_DeckItem;
	itemLayout : CM_DeckItemLayout;
	locnGap, locnLength, locnWidth : Decimal[12,2];
	allStateData : CM_StateDataDict;
//	aVes : CM_Vessel;
	startPoint, newPoint, checkPoint, origPoint, tmpPoint : Point;
	startX, startY, checkXOffset, checkYOffset : Integer;
	newPoints : PointArray;
	hide, isRotated : Boolean;
	x1, x2, y1, y2, chkX, chkY : Integer;

	isOOTLLocn : Boolean;
begin
	isOOTLLocn := _startLocn.isOOTL();


	isRotated := _startLocn.isVerticalOrientation();
	tmpPoint.setY(_areaPoints[2].y-2);
	_areaPoints[2].setY(tmpPoint.y);
	_areaPoints[3].setY(tmpPoint.y);
	tmpPoint.setX(_areaPoints[3].x+2);
	_areaPoints[2].setX(tmpPoint.x);
	_areaPoints[3].setX(tmpPoint.x);
	
	create newPoints transient;
	/* PAR 28971
	aVes := self.getVessel();
	if aVes &lt;&gt; null then
		allStateData:= aVes.allStateData;
	endif;
	
	if allStateData.size= 0 then
		allStateData:= app.myRoot.getStateObject(ConfigGrp_System).allStateData;
	endif;
	*/
	allStateData := self.myDeckLayout.myDeck.getAllStateDataObject(); // PAR 28971

	global.getExtraData(allStateData,RoRoLocationGap,locnGap);
	global.getExtraData(allStateData,RoRoLocationWidth,locnWidth);
	global.getExtraData(allStateData,RoRoLocationLength,locnLength);
	
	startPoint := _startLocn.myLayout.myPolygonPixels[4]; // Bottom left corner
	origPoint := startPoint;
	
	startX := startPoint.x;
	startY := startPoint.y;
	
	locnGap := locnGap * ROROStructurePixelsPerMetre;
	locnWidth := (locnWidth * ROROStructurePixelsPerMetre) - 1; // PAR 28317
	locnLength := (locnLength * ROROStructurePixelsPerMetre) - 1; // PAR 28317
	
	if locnGap = 0 then
		locnGap := 1; //  PAR 27749 add 1 pixel so that the locns are no draw overlapping by 1 pixel
	endif;
	if not isRotated then
		checkXOffset := (locnGap + locnWidth).Integer; // this is applied to the new rotated position so it uses the width of the rectangle not the length, because we are checking where the new position is
		checkYOffset := (locnGap + locnLength).Integer; // this is applied to the new rotated position so it uses the length of the rectangle not the width, because we are checking where the new position is
	else
		checkXOffset := (locnGap + locnLength).Integer; // this is applied to the new rotated position so it uses the length of the rectangle not the width, because we are checking where the new position is
		checkYOffset := (locnGap + locnWidth).Integer; // this is applied to the new rotated position so it uses the width of the rectangle not the length, because we are checking where the new position is
	endif;
//app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' 1. AREA: ' &amp; _areaPoints[1].x.String &amp; "/" &amp;  _areaPoints[1].y.String &amp; " &gt; " &amp; _areaPoints[3].x.String &amp; "/" &amp;  _areaPoints[3].y.String);
//app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' 1.START ' &amp; startPoint.x.String &amp; "/" &amp; startPoint.y.String &amp; " checkXOffset: " &amp; checkXOffset.String);

	// PAR 28880
	foreach deckItem in _locns  discreteLock do
		locnDefn := deckItem.CM_ROROLocnDefn;
		if not locnDefn.isRotatable then
			app.raiseCMException1(Posit_canno_rotat_becas_defin_, locnDefn.code, null, null);
		endif;
	endforeach;
	
	
	
	if not app.myPassport.checkValidation() then // PAR 30996
	// PAR 30996 if app.myPassport.hasErrorsOrWarnings() then
		return;
	endif;
	
	foreach deckItem in _locns  discreteLock do
		locnDefn := deckItem.CM_ROROLocnDefn;
	
		itemLayout := locnDefn.myLayout;
		
		newPoints.clear();

		// Do this before the rotate 
		if locnDefn = _startLocn then
			locnDefn.setLocnDefnsToRotate(true, itemLayout.myPolygonPixels, _locns); // on the start locn pass in all the other locns being rotated, so that they can all be un rotated.
		else
			locnDefn.setLocnDefnsToRotate(true, itemLayout.myPolygonPixels, null);
		endif;
		
		if isRotated then // IS Vertical, make Horizontal
			itemLayout.setLocnDefnsToRotate(SPAF_Value, startPoint, hide, allStateData);
			startY := (startY - locnGap - locnWidth).Integer; // Move Up
		else // IS Horizontal, make Vertical
			itemLayout.setLocnDefnsToRotate(AFSP_Value, startPoint, hide, allStateData);
			startX := (startX + locnGap + locnWidth).Integer; // Move Over
		endif;
		
		// move Over and/or Up
		startPoint.setY(startY);
		startPoint.setX(startX);
		
		checkPoint.setY(startY - checkYOffset);
		checkPoint.setX(startX + checkXOffset);
		
//app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' 2. ' &amp; deckItem.code &amp; " checkPoint " &amp; checkPoint.x.String &amp; "/" &amp; checkPoint.y.String);
		if not _areaPoints.isPointInRectangleBLTR(checkPoint.x, checkPoint.y) then

			if isRotated then // IS Vertical, make Horizontal
				startX := (startX + locnGap + locnLength).Integer; // Move Over
				startY := origPoint.y;
			else
				startY := (startY - locnGap - locnLength).Integer; // Move Up
				startX := origPoint.x;
			endif;
			startPoint.setY(startY);
			startPoint.setX(startX);
			checkPoint.setY(startY - checkYOffset);
			checkPoint.setX(startX + checkXOffset);
//app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' 3.checkPoint ' &amp; checkPoint.x.String &amp; "/" &amp; checkPoint.y.String);

			// If still not in area then hide all the other locnDefns.
			chkX := checkPoint.x;
			chkY := checkPoint.y;
			
			if not _areaPoints.isPointInRectangleBLTR(checkPoint.x, checkPoint.y) then

//app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' 4. HIDE: ' &amp; _areaPoints[1].x.String &amp; "/" &amp;  _areaPoints[1].y.String &amp; " &gt; " &amp; _areaPoints[3].x.String &amp; "/" &amp;  _areaPoints[3].y.String);
				hide := true;
			else
				hide := false;
			endif;
		endif;
		
	endforeach;
		

epilog
	delete newPoints;
end;</source>
        <Parameter name="_startLocn" type="CM_ROROLocnDefn"/>
        <Parameter name="_areaPoints" type="PointArray"/>
        <Parameter name="_locns" type="CM_RORODeckItemByOrd1Ord2"/>
    </JadeMethod>
    <JadeMethod name="setLocnDefnsToRotateClone" id="def7be21-44de-49de-bd03-c8206aea7623">
        <updating/>
        <source>setLocnDefnsToRotateClone(_startLocn : CM_ROROLocnDefn io;_locns : CM_RORODeckItemByOrd1Ord2 input; _isLoad : Boolean ) updating;
/*
Purpose:		When rotating pre defined container positions there needs to be a actual and proposed seperation. 
					If we are rotating positions for load colour coding that rotation of pre defined locations must only be in the load/proposed view, the actual/discharge view must remain unrotated.
					If we are rotating positions for discharge colour coding, normally via EDI PLANS, that rotation of pre defined locations must only be in the actual/discharge view, the load/proposed view must remain unrotated.
					
					As the last container is removed from the actual location on the cargo layer we must apply the load colour coding rotation to the actual locations. This may be to unrotate or to rotate, but we basically make them match.
					
Date				Who			Reason
FEB 2012		CNWAB1		Initial creation
*/

vars
	locnDefn, startItem, cloneDefn, aftLocn : CM_ROROLocnDefn;
	layerForClones : CM_DeckLayerLayout;
	deckItem : CM_DeckItem;
	itemLayout : CM_DeckItemLayout;
	locnGap, locnLength, locnWidth : Decimal[12,2];
	allStateData : CM_StateDataDict;
	startPoint, newPoint, checkPoint, origPoint, tmpPoint : Point;
	startX, startY, checkXOffset, checkYOffset : Integer;
	newPoints : PointArray;
	hide, isRotated : Boolean;
	x1, x2, y1, y2, chkX, chkY : Integer;
	clonedLocns : CM_RORODeckItemByOrd1Ord2;
	isOOTLLocn : Boolean;
	roroRotatedSuffix : String;
	items, split : Integer;
begin

	if _startLocn.isOOTL() then
		return;
	endif;
	
	items := _locns.size;
	if items = 10 or items = 6 then
		split := 2;
	else
		split := 1;
	endif;

	
	allStateData := self.getAllStateDataObject();
	
	global.getExtraData(allStateData,RoRoRotatedLabel,roroRotatedSuffix);
	
	
	layerForClones := self.myDeckLayout.getCCLoadLayer(); // gets or creates
	
	create clonedLocns transient;
/*
	// The actual is being rotated, but only for 1 row. However if they have aft slots we need to clone their aft slots as well so that in the load view we can do 40s
	if not _isLoad and split = 1 then
		foreach deckItem in _locns discreteLock do
			locnDefn := deckItem.CM_ROROLocnDefn;
			aftLocn := locnDefn.myAdjacentSlotAft;
			if aftLocn = null then
				continue;
			endif;
			
			
			aftLocn.setRotateCloneLink(aftLocn); // do this so that in the clone of the slots we do can add the "R" so that we do not get duplicates on deck collection
			cloneDefn := aftLocn.cloneMySelf(layerForClones, false, true);
			aftLocn.setRotateCloneLink(null);
	
			cloneDefn.setRotateCloneLink(aftLocn);
			clonedLocns.addNoDuplicates(cloneDefn, false);
			cloneDefn.setCode(aftLocn.code &amp; "#");
		endforeach;
	
	endif;
*/	
	
	foreach deckItem in _locns discreteLock do
		locnDefn := deckItem.CM_ROROLocnDefn;
		locnDefn.setRotateCloneLink(locnDefn); // do this so that in the clone of the slots we do can add the "R" so that we do not get duplicates on deck collection
		cloneDefn := locnDefn.cloneMySelf(layerForClones, false, true);
		locnDefn.setRotateCloneLink(null);

		cloneDefn.setRotateCloneLink(locnDefn);
		clonedLocns.addNoDuplicates(cloneDefn, false);
		if deckItem = _startLocn then
			startItem := cloneDefn;
		endif;
//		if _isLoad then
//			cloneDefn.setCode(locnDefn.code &amp; roroRotatedSuffix);
//		else
			cloneDefn.setCode(locnDefn.code &amp; "#",true);
//		endif;
	endforeach;

	
	foreach deckItem in clonedLocns discreteLock do
		locnDefn := deckItem.CM_ROROLocnDefn;
		locnDefn.setDeckOnSlots();
		self.hideContainerPositionsUnderGC(locnDefn.myLayout); // PAR 29607
	endforeach;	
	
	
	if _isLoad then
		// ### COPY the clones to the locations that are actually being rotated, leaving the passed in locations un rotated
		_locns.clear();
		clonedLocns.copy(_locns);
		_startLocn := startItem; // switch start location so the next call after this method can do the actual rotation
	else
//		if split = 1 then
//		self.setForUpdateRotateLinkAft(clonedLocns, items * 2, 2, _startLocn.isRotated());
//		endif;
	endif;
	
	
	//clonedLocns.purge();
epilog
	delete clonedLocns;
end;</source>
        <Parameter name="_startLocn" type="CM_ROROLocnDefn" usage="io"/>
        <Parameter name="_locns" type="CM_RORODeckItemByOrd1Ord2" usage="input"/>
        <Parameter name="_isLoad" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setLocnDefnsToUnRotate" id="c6ef0e9f-2ffd-4024-bc4f-44ec7a287e57">
        <updating/>
        <source>setLocnDefnsToUnRotate(_isLoad : Boolean; _startLocn : CM_ROROLocnDefn input) updating;
/*
Purpose:			
Date		Who		Reason
15 July 2011	cnwab1	Initial creation
*/

vars
	locnDefn : CM_ROROLocnDefn;
	rotatedLocns : ObjectArray;
	tmpLocn, fwdLocation, aftLocation, linkedLocn, rotateMaster, startLocn : CM_ROROLocnDefn;
	obj : Object;
	idx, stIdx, endIdx, itemPerRow, ord1, ord2 : Integer;
	cargoLayer : CM_DeckLayerLayout;
	locns : CM_RORODeckItemByOrd1Ord2;
	deckItem : CM_DeckItem;
begin
	app.writeVoyageLog(_startLocn, "Unrotation Start"); // PAR 31878 - logging

	// PAR 28990 - if unrotating and the locn defns are on the load cc layer, then delete the locn defn
	if _startLocn.isRotatedLoadLayer() then
		cargoLayer := self.myDeckLayout.getCargoLayer(); // PAR 28890
		_startLocn.myLayout.myDeckLayer.causeEvent(EVENT_RORO_LAYER_UPDATE,false,cargoLayer);
		// PAR 29990
		if _startLocn.isOOTLLocn then
			_startLocn.CM_ROROLocnDefnVoyage.eraseForUnrotate(false);
		else
			_startLocn.CM_ROROLocnDefnVoyage.eraseForUnrotate(true);
		endif;
		return;
	endif;
	
	// PAR 29884 - the start item is on the actual layer, but we are in load mode.
	//					 this means that we have to clone the rotated locations on the actual layer and make them unrotated on the load layer
	if _isLoad then
		cargoLayer := self.myDeckLayout.getCargoLayer(); // PAR 31341
		_startLocn.myLayout.myDeckLayer.causeEvent(EVENT_RORO_LAYER_UPDATE,false,cargoLayer);// PAR 31341
		self.setLocnDefnsToUnRotateLoadClne(_startLocn);
		return;
	endif;

	// Have to delink the rotated location as we are about to relink them how they were, and we will get a duplicate reference error if we do not
	foreach locnDefn in _startLocn.allPlannedRotatedLocnDefns  discreteLock do
		if locnDefn.isPlannedRotated 
		and not locnDefn.isOOTL then // PAR 28886 do not disconnect OOTL 40 from their aft
			locnDefn.setFwdLocn(null);
			locnDefn.setAftLocn(null);
		endif;
	endforeach;
	
	// PAR 28479
	foreach locnDefn in _startLocn.allPlannedRotatedLocnDefns discreteLock do
		locnDefn.setLocnDefnsToRotate(false, null, null); 
	endforeach;
	
	/* 28968 in 811 we added another 'pre rotate' reference so that we do not have to try and re link using pixel values, so we do not need this anymore
	// PAR 28479
//	itemPerRow := (_startLocn.allPlannedRotatedLocnDefns.size / 2).Integer;
//	if itemPerRow = 5 or itemPerRow = 3 then
// PAR 28880
	itemPerRow := _startLocn.allPlannedRotatedLocnDefns.size;
	if itemPerRow = 5 or itemPerRow = 10 then
		create rotatedLocns transient;
		// Link the rotated slots, if there are 2 rows, back to their aft slots
		_startLocn.allPlannedRotatedLocnDefns.copy(rotatedLocns);
		
		// PAR 28525
		if _startLocn.isRotated() then
			stIdx :=  1;
			endIdx := rotatedLocns.size;
			// PAR 28880
			if  itemPerRow = 10 then
				foreach idx in stIdx to endIdx do
					fwdLocation := rotatedLocns[idx].CM_ROROLocnDefn;
					aftLocation := self.getAftLocnByPosition(fwdLocation);
					fwdLocation.setAftLocn(aftLocation);
				endforeach;
			else
				foreach idx in stIdx to endIdx do
					fwdLocation := rotatedLocns[idx].CM_ROROLocnDefn;
					aftLocation := self.getAftLocnByPosition(fwdLocation);
					fwdLocation.setAftLocn(aftLocation);
				endforeach;
			
			endif;
		else
			if  itemPerRow = 5 then
				stIdx := 1;
				endIdx := itemPerRow;
				
				foreach idx in stIdx to endIdx do
					fwdLocation := rotatedLocns[idx].CM_ROROLocnDefn;
					aftLocation := self.getAftLocnByPosition(fwdLocation);
					fwdLocation.setAftLocn(aftLocation);
				endforeach;
			else
				stIdx := 1;
				endIdx := itemPerRow;
				
				foreach idx in stIdx to endIdx step 2 do
					fwdLocation := rotatedLocns[idx].CM_ROROLocnDefn;
					aftLocation := self.getAftLocnByPosition(fwdLocation);
					fwdLocation.setAftLocn(aftLocation);
				endforeach;
			endif;
		endif;
	endif;
	
	*/
	// PAR 28990 - if unrotating and the locn defns are on the cargo layer, then delete the locn defn on the load layer
	if _startLocn.isRotatedCargoLayer() then
		cargoLayer := self.myDeckLayout.getCCLoadLayer(); 
		_startLocn.myLayout.myDeckLayer.causeEvent(EVENT_RORO_LAYER_UPDATE,false,cargoLayer); 
		_startLocn.CM_ROROLocnDefnVoyage.eraseForUnrotate(false);
	endif;
	if _startLocn.isRotateOOTLLayer() then
		cargoLayer := self.myDeckLayout.getOOTLLayer(); 
		_startLocn.myLayout.myDeckLayer.causeEvent(EVENT_RORO_LAYER_UPDATE,false,cargoLayer); 
		// PAR 30264
		cargoLayer := self.myDeckLayout.getCargoLayer(); 
		_startLocn.myLayout.myDeckLayer.causeEvent(EVENT_RORO_LAYER_UPDATE,false,cargoLayer); 
		_startLocn.CM_ROROLocnDefnVoyage.eraseForUnrotate(false);
	endif;
	
	// This is 792 really not needed in 811 and on
// 29884	foreach locnDefn in _startLocn.allPlannedRotatedLocnDefns discreteLock do
//			locnDefn.setRotateCloneLink(null);
//	endforeach;
	
	
//	PAR 31129 DMAST ONLY 821 _startLocn.allPlannedRotatedLocnDefns.clear();
	_startLocn.clearAllPlannedRotatedLocnDefn();
	
//	if _startLocn.myLayout &lt;&gt; null
//	and _startLocn.myLayout.myDeckLayer &lt;&gt; null then
//		_startLocn.myLayout.myDeckLayer.causeEvent(EVENT_RORO_LAYER_UPDATE,false,null); 
//	endif;
epilog
	delete rotatedLocns;
	delete locns;
end;</source>
        <Parameter name="_isLoad" type="Boolean"/>
        <Parameter name="_startLocn" type="CM_ROROLocnDefn" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setLocnDefnsToUnRotateLoadClne" id="e7ae4835-2ed3-48d5-af63-7e0dd5dea86b">
        <updating/>
        <source>setLocnDefnsToUnRotateLoadClne(_startLocn : CM_ROROLocnDefn input) updating;
/*
Purpose:	Rotation of actual and load positions are seperate. However if the same group of positions are rotated in both actual and load, 
				we actually only have the rotation in the actual layer and the load uses this as if that was how the position were defined.
				If in the load view they decide to unrotate, this method has been created to re create the clones of how the positions were before rotation
Date		Who		Reason
25 July 2012	cnwab1	Initial creation
*/

vars
	loadCCLayer : CM_DeckLayerLayout;
	locns, actualLocns : CM_RORODeckItemByOrd1Ord2;
	linkedLocn, tmpLocn, startLocn, origActualLocn : CM_ROROLocnDefn;
	ord1, ord2 : Integer;
	deckItem : CM_DeckItem;
	items, split : Integer;
	startIsRotated : Boolean;
		coveringItems : CM_RORODeckItemLayoutArray;
		layout : CM_DeckItemLayout;
begin
	
	startIsRotated := _startLocn.isVerticalOrientation();
	
	startLocn := _startLocn;
	origActualLocn := _startLocn;
	
	create locns transient;
	create actualLocns transient;
	create coveringItems transient;
	foreach tmpLocn in startLocn.allPlannedRotatedLocnDefns  discreteLock do
	
	
		if startIsRotated then 
			tmpLocn.myLayout.getOrdinalsForSorting(SPAF_Value, ord1, ord2);
		else
			tmpLocn.myLayout.getOrdinalsForSorting(AFSP_Value, ord1, ord2);
		endif;

		locns.putAtKey(ord1, ord2, tmpLocn);
		actualLocns.putAtKey(ord1, ord2, tmpLocn);
	endforeach;
	

	self.setLocnDefnsToRotateClone(startLocn, locns, true); 
	
	// These are the new clones
	foreach deckItem in locns discreteLock do
		tmpLocn := deckItem.CM_ROROLocnDefnVoyage;
		// this linked is the actual locn
		linkedLocn := tmpLocn.getRotatedLinked();
		// update the polygon
		tmpLocn.myLayout.setLocnDefnsToUnrotate(linkedLocn.myPreRotatePoints);
		tmpLocn.setIsPlannedRotated(false);
		tmpLocn.setIsRotatedByPixels();
		// PAR 31129 DMAST ONLY 821 - tmpLocn.allPlannedRotatedLocnDefns.clear();
		tmpLocn.clearAllPlannedRotatedLocnDefn();
		
		//epr par 32488 18/9/13 unrotating in load mode have to check if covered by gc jobs
		if not tmpLocn.isOOTL() then 
			self.myDeckLayout.hideContainerPosUnderGCLoad(tmpLocn.myLayout);
		endif;
	endforeach;
	
	
	
	
	loadCCLayer := self.myDeckLayout.getCCLoadLayer(); 
	startLocn.myLayout.myDeckLayer.causeEvent(EVENT_RORO_LAYER_UPDATE,false,loadCCLayer); 
	
	items := locns.size;
	if items = 10 or items = 6 then
		split := 2;
	else
		split := 1;
	endif;

	// This links aft and  forward locations within the rotation.
	// e.g. 1X5 has become 2X2 so link the aft/fwd for the 2X2
	self.setForUpdateRotateLinkAft(locns, items, split, startIsRotated);
	
	// This method links the clones to the adjacent  locations.
	self.setForUpdateRotateLinkCloneAft(items, split, actualLocns, not startIsRotated, true);

epilog
	delete locns;
	delete actualLocns;
	delete coveringItems;
end;</source>
        <Parameter name="_startLocn" type="CM_ROROLocnDefn" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setOrderOnAllLocations" id="9b2a5f82-2fd5-4a46-b55f-16b2714a4d19">
        <source>setOrderOnAllLocations();
/*
Purpose: allDeckItemLayouts is an array, The locnDefns have an ordinal so this method re orders the graphic array
			to be non locnDefn first then all the locnDefn in ordinal order			
Date		Who		Reason
21 April 2011	cnwab1	Initial creation
*/

vars
	tmpLocnDefn : CM_ROROLocnDefn;
	tmpLaneDefn : CM_ROROLaneDefn;
	tmpGraphic : CM_DeckItemLayout;
	items : CM_RORODeckItemLayoutArray;
	objs : ObjectSet;
	obj : Object;
begin
	create objs transient;
	create items transient; // PAR 28525 the graphics were being re sorted by their OID because they had been put in an object set
	
	self.allDeckItemLayouts.copy(items);
	// detach the location graphic from the array of all graphics
	foreach obj in items discreteLock do
		tmpGraphic := obj.CM_DeckItemLayout;
		tmpGraphic.setMyDeckLayer(null);
	endforeach;
	
	// leave just the non locn and lane graphics
	foreach tmpLocnDefn in self.allROROLocnDefnByOrdinal  discreteLock do
		if items.includes(tmpLocnDefn.myLayout) then
			items.remove(tmpLocnDefn.myLayout);
		endif;
	endforeach;
	foreach tmpLaneDefn in self.allROROLaneDefnByOrdinal  discreteLock do
		if items.includes(tmpLaneDefn.myLayout) then
			items.remove(tmpLaneDefn.myLayout);
		endif;
	endforeach;
	
	// reattach the graphic in the in the order of the location's ordinal 
	foreach obj in items discreteLock do
		tmpGraphic := obj.CM_DeckItemLayout;
		tmpGraphic.setMyDeckLayer(self);
	endforeach;
	
	objs.clear;
	foreach tmpLocnDefn in self.allROROLocnDefnByOrdinal  discreteLock do
		if tmpLocnDefn.myLayout &lt;&gt; null then
			tmpLocnDefn.myLayout.setMyDeckLayer(self);
		else
			objs.add(tmpLocnDefn);
		endif;
	endforeach;
	foreach tmpLaneDefn in self.allROROLaneDefnByOrdinal  discreteLock do
		if tmpLaneDefn.myLayout &lt;&gt; null then
			tmpLaneDefn.myLayout.setMyDeckLayer(self);
		else
			objs.add(tmpLaneDefn);
		endif;
	endforeach;
	
	objs.purge();
epilog
	delete objs;
	delete items;
end;</source>
    </JadeMethod>
    <JadeMethod name="setProxy" id="cd9bc676-cdeb-42b2-b1d0-cf9f58f2901a">
