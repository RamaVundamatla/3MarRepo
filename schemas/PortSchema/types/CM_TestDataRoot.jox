    <JadeMethod name="createBerths" id="105d6981-b071-4a5e-b878-e5d477b3cedb">
        <source>createBerths(_terminal : CM_Terminal);

vars
	tmpHarbour		: HMS_Harbour;
	testBerth		: CM_TestDataBerth;
	tmpBerth		: HMS_Berth;

begin

	tmpHarbour	:= _terminal.myHarbour;

	self.allTestDataBerths.purge();

	foreach tmpBerth in tmpHarbour.allBerths where (not tmpBerth.isLogicalBerth()) do
		create testBerth persistent;
		testBerth.setForCreate(tmpBerth);
		self.allTestDataBerths.add(testBerth);
	endforeach;

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="createChildren" id="ffbf6c50-944f-4a51-90fa-804f24a43d0b">
        <updating/>
        <source>createChildren() updating;
// ---------------------------------------------------------------------------
// Created:     06 June 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	exclusiveLock(self);
	
	if self.myBOLInNum = null then
		create self.myBOLInNum persistent;
	endif;
	
	if self.myBOLInNumUnmatched = null then
		create self.myBOLInNumUnmatched persistent;
	endif;

	if self.myLogId = null then
		create self.myLogId persistent;
	endif;
	
	if self.myTestDataMove = null then
		create self.myTestDataMove persistent;
	endif;
	
	if self.myVoyageCodeNum = null then
		create self.myVoyageCodeNum persistent;
	endif;
	
	self.createTestOperators();

end;</source>
    </JadeMethod>
    <JadeMethod name="createRTDevices" id="43112075-9bf9-4a44-b5eb-deeed49b2cf8">
        <source>createRTDevices(_terminal : CM_Terminal) : CM_TestDataRTDevice protected;
// ---------------------------------------------------------------------------
// Created:     07 April 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpRTDevice	: CM_TestDataRTDevice;
begin
	if _terminal = null then
		return tmpRTDevice;
	endif;
	exclusiveLock(self);
	tmpRTDevice := self.allTestDataRTDevices[_terminal];
	if tmpRTDevice = null then
		create tmpRTDevice persistent;
		tmpRTDevice.setForCreate(_terminal, self);
	endif;
	
	return tmpRTDevice;

end;</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="CM_TestDataRTDevice"/>
    </JadeMethod>
    <JadeMethod name="createTestOperators" id="e9df21e6-edfc-4e38-8c25-905ffc1b62f0">
        <updating/>
        <source>createTestOperators() updating;

vars
	testOperator	: CM_TestDataOperator;
	tmpOperator		: CM_Operator;
	
begin

	tmpOperator := app.myRoot.allOperators['RNZ'];
	if tmpOperator &lt;&gt; null then
		testOperator := self.allTestOperators[tmpOperator.code];
		if testOperator &lt;&gt; null then
			delete testOperator;
		endif;
		create testOperator persistent;
		testOperator.init(tmpOperator, self);
	endif;
	
	tmpOperator := app.myRoot.allOperators['CHH'];
	if tmpOperator &lt;&gt; null then
		testOperator := self.allTestOperators[tmpOperator.code];
		if testOperator &lt;&gt; null then
			delete testOperator;
		endif;
		create testOperator persistent;
		testOperator.init(tmpOperator, self);
	endif;	

end;</source>
    </JadeMethod>
    <JadeMethod name="createVehicles" id="d37ba7c3-d8db-4ff6-8b81-153f281d3da0">
        <source>createVehicles(_terminal : CM_Terminal);

vars
	testVehicle		: CM_TestDataVehicle;
	tmpVehicle		: CM_Vehicle;
	
begin

	foreach tmpVehicle in _terminal.vehicles do
		create testVehicle persistent;
		testVehicle.setForCreate(tmpVehicle);
		self.allVehicles.add(testVehicle);
	endforeach;

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="createVesselsForVTMIS" id="f87e8d5f-f908-4101-a9ca-eb661f287767">
        <source>createVesselsForVTMIS(_numToCreate : Integer);


// 13 Mar 2013	PJS		PAR #31232


vars
	testVessel		: CM_TestDataVesselForVTMIS;
	tmpVessel		: CM_Vessel;
	cnt				: Integer;
begin

	self.allVesselsForVTMIS.purge();

	// 31232
	// 31232 //foreach tmpVessel in app.myRoot.allVessels where tmpVessel.structureType = StructureTypeNull do
	foreach tmpVessel in app.myRoot.allVessels where tmpVessel.structureNotDefined do
		cnt := cnt + 1;
		if cnt &gt; _numToCreate then
			break;
		endif;
		create testVessel persistent;
		testVessel.setForCreate(tmpVessel);
		self.allVesselsForVTMIS.add(testVessel);
	endforeach;

end;</source>
        <Parameter name="_numToCreate" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getLogIds" id="43fcc0af-d27e-4d32-b7aa-d2c2dbde9469">
        <source>getLogIds(_numToGet : Integer) : Integer;
// ---------------------------------------------------------------------------
// Created:     06 June 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	nextNum	: Integer;
begin

	beginTransaction;
	exclusiveLock(self.myLogId);
	nextNum := self.myLogId.incrementNumber(_numToGet);
	commitTransaction;

epilog
	return nextNum;
	
end;</source>
        <Parameter name="_numToGet" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getNextBOLAsBOLToMatch" id="c9827b4b-38fd-48cf-8f86-89e15184c883">
        <source>getNextBOLAsBOLToMatch(_bolNumber : String output; _operator : CM_Operator output; _numLogs : Integer output) : Boolean;
// ---------------------------------------------------------------------------
// Created:     26 April 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpTestBOL	: CM_TestDataLogBOL;
	
begin

	beginTransaction;
	exclusiveLock(self.allLogBolsAsBols);
	tmpTestBOL := self.allLogBolsAsBols.first;
	if tmpTestBOL &lt;&gt; null then
		self.allLogBolsAsBols.remove(tmpTestBOL);
	endif;
	commitTransaction;

	if tmpTestBOL = null then
		return false;
	endif;
	
	_bolNumber 	:= tmpTestBOL.number;
	_operator	:= tmpTestBOL.myOperator;
	_numLogs	:= tmpTestBOL.numLogs;
	
	beginTransaction;
	delete tmpTestBOL;
	commitTransaction;
	
	return true;

end;</source>
        <Parameter name="_bolNumber" type="String" usage="output"/>
        <Parameter name="_operator" type="CM_Operator" usage="output"/>
        <Parameter name="_numLogs" type="Integer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getNextBOLAsScalingDtlsToMatch" id="f561a15f-a1a8-45d5-8333-b5a9510c5b1c">
