    <JadeWebServicesMethod name="getCurrentVoyages" id="51e39862-9c25-4ed2-87d4-2879093f3aed">
        <source>getCurrentVoyages() : WS_VoyagesResponse webService;

/*

Purpose:			Get the current Voyages the current user has access to.

Parameters:			

Return Value:		


Date		Who		Reason
18 Mar 2009	cnwdz2	PAR 19058 
20 Apr 2009	cnwkpd1	PAR #19438 - Remove duplicates from the voyages list returned,
					reorder checks for performance
04/03/2015 CNWAB1 PAR 35795
Voyages have a displayOption which this this call only partially uses.
All voyages now have a ship block stack and a  myHMSVoyageData reference which this request does not take into account.

It has this odd IF statement, which should be saying what it actually wants to reject:
(would like to see this documented)

		if voy.myCellularVoyageStructure = null then
			if voy.myGeneralCargoVoyage &lt;&gt; null
			or voy.isNullVoyage
			or voy.myHMSVoyageData &lt;&gt; null 
			or voy.isKindOf(CM_VoyageInlandTerminal) then

			else
				continue;
			endif;
		endif;

21 Oct 2025 navsp1  MTN-35535 Solution Implementation | Ship to Yard Voyage Filter
*/

vars
	response		: WS_VoyagesResponse;
	completedOK		: Boolean;

	proxyVoyage		: WS_Voyage;
	selectedVoyages	: CM_VoyageSet;
	voy				: CM_Voyage;
	thePassport		: CM_Passport;
	displayWorkingVoyOnly   : Boolean;      //MTN-35535
    terminal        : CM_Terminal;          //MTN-35535
    now				: TimeStamp;            //MTN-35535
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	create selectedVoyages transient;
	
	thePassport := app.myPassport;
	terminal    := thePassport.myTerminal;
    displayWorkingVoyOnly   := terminal.getConfig(ShowWorkingVoyagesOnly).Boolean;          //MTN-35535
    now                     := app.actualTimeServer();                                      //MTN-35535
    
	terminal.getAllCurrentVoyages(selectedVoyages, true, true, false); // PAR 35795
	
	foreach voy in selectedVoyages discreteLock do // PAR 35795
		
		//epr no structure can continue;
	/*	if  voy.myShipBlockStack = null and voy.myROROStructure = null and voy.myCellularVoyageStructure = null and voy.myLogVoyageStructure = null and voy.myGeneralCargoVoyage = null then
			continue;
		endif;*/
		
        if displayWorkingVoyOnly then                                                           //MTN-35535
            if voy.isStatusDeparted() or not voy.arrivedDT.isValid() or voy.arrivedDT &gt; now then//MTN-35535
                continue;                                                                       //MTN-35535
            endif;                                                                              //MTN-35535
        endif;                                                                                  //MTN-35535
        
 		create proxyVoyage transient; // PAR 35795
		proxyVoyage.setProxyFromObject(voy); // PAR 35795
		response.allVoyages.add(proxyVoyage); // PAR 35795
	endforeach; // PAR 35795
	
		
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	// Tidy up local transients

	delete selectedVoyages;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <text>Get the current Voyages the current user has access to.</text>
        <wsdlName>getCurrentVoyages</wsdlName>
        <ReturnType type="WS_VoyagesResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getCustomsAgents" id="22f81cab-09c7-4e9e-ad44-fd48ea8919a4">
        <usesRPC>default</usesRPC>
        <source>getCustomsAgents() : WS_CustomsAgentResponse webService;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 September 2008	cnwkao1	Initial creation - following approach of other methods

*/

vars
	response		: WS_CustomsAgentResponse;
	completedOK		: Boolean;
	
	customsAgent	: CM_CustomsAgent;
	failedDAC  		: CM_DataAccessController;
	pxyAgent		: WS_CustomsAgent;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;

	foreach customsAgent in app.myRoot.allCustomsAgents discreteLock do
		if not customsAgent.canUserAccessSelf(null, failedDAC, app.myPassport) then
			continue;
		endif;
		
		create pxyAgent transient;
		pxyAgent.setProxyFromObject(customsAgent);
		response.allCustomsAgents.add(pxyAgent);
	endforeach;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	
	
epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <wsdlName>getCustomsAgents</wsdlName>
        <ReturnType type="WS_CustomsAgentResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getDamageConfigData" id="4d3f598d-dd8a-4547-94ca-8669bd8a1907">
        <source>getDamageConfigData():WS_DamageConfigResponse webService;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 October 2011	cnwndl1	Initial creation Par 28303

*/

vars

	damRequest : WS_DamageConfigRequest;

begin

	create damRequest transient;
	damRequest.includeCodes := true;
	damRequest.includePositions := true;
	damRequest.includeSeverity := true;
	
	return self.getDamageData(damRequest);

epilog

end;</source>
        <ReturnType type="WS_DamageConfigResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getDamageData" id="d5df53c3-da2b-467f-b829-c9d66ca9b581">
        <source>getDamageData( damRequest : WS_DamageConfigRequest ): WS_DamageConfigResponse webService;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 October 2011	cnwndl1	Initial creation	Par 28303
22 July    2016 cnwma1 TFS #1979 JMT Mobile Apps - Cargo - Damage
28 June 2022 navhl20 TFS 53862 EUP - WMS - Damage Recording Extra Details
06 Dec 2024	navsck1	Initial creation for MTN-33610 Create a new webservice to handle multiple damages and images
*/

vars

	response		: WS_DamageConfigResponse;
	completedOK		: Boolean;
	
	damageCode : CM_DamageDefinitionCode;
	damagePos : CM_DamagePosition;
	//severity : Integer;		// 29.09.2022 navak20 TFS 53862
	
	wsDamCode : WS_DamageCode;
	wsDamPos : WS_DamagePosition;
	wsDamSev : WS_DamageSeverity;
	cargoType : CM_CargoType;  //22/07/2016 cnwma1 TFS #1979
	severity  : CM_DamageSeverity;	// 29.09.2022 navak20 TFS 53862
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	if damRequest.cargoTypeDesc &lt;&gt; null then   //22/07/2016 cnwma1 TFS #1979
		cargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr(damRequest.cargoTypeDesc);
	endif;
	
	// Populate Validate response 
	if damRequest.includeCodes then
		foreach damageCode in app.myRoot.allDamageDefinitionCodes discreteLock do
			if damageCode.isNotAvailableForEntry then
				continue;
			endif;
			
			if damageCode.allCargoTypes.isEmpty then
				continue;
			endif;
			
			if cargoType &lt;&gt; null then    //22/07/2016 cnwma1 TFS #1979
				if not damageCode.allCargoTypes.includes(cargoType)then
					continue;
				endif;
			endif;
			
			create wsDamCode transient;
			wsDamCode.setProxyFromObject(damageCode);
			wsDamCode.setAllCargoTypes(damageCode); //jlier1 TFS 53971 4/7/22
			response.allDamageCodes.add( wsDamCode );
		endforeach;
	endif;
	
	if damRequest.includePositions then
		foreach damagePos in app.myRoot.allDamagePositionsByCode discreteLock do
			if damagePos.isNotAvailableForEntry then
				continue;
			endif;
			if damagePos.allActiveCargoTypes.isEmpty then
				continue;
			endif;
			
			if cargoType &lt;&gt; null then    //22/07/2016 cnwma1 TFS #1979
				if not damagePos.allActiveCargoTypes.includes(cargoType)then
					continue;
				endif;
			endif;
			
			create wsDamPos transient;
			wsDamPos.setProxyFromObject(damagePos);
			wsDamPos.setAllCargoTypes(damagePos); //jlier1 TFS 53971 4/7/22
			response.allDamagePositions.add( wsDamPos );
		endforeach;
	endif;
	
	if damRequest.includeSeverity then
		//foreach severity in 1 to DamageSeverity_MAX do     //07.09.2022 navma1 			 ****Pending****	// 29.09.2022 navak20 TFS 53862
		foreach severity in app.myPassport.myTerminal.allDamageSeverities do		// 29.09.2022 navak20 TFS 53862
			create wsDamSev transient;
			//wsDamSev.setProxyFromValue(severity);			// 29.09.2022 navak20 TFS 53862
			//wsDamSev.setProxyFromValue(severity.level);		// 29.09.2022 navak20 TFS 53862
			wsDamSev.setProxyFromObject(severity);				//06.12.2024 navsck1 JIRA #33610
			response.allDamageSeverities.add( wsDamSev );
		endforeach;
	endif;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	
epilog

	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="damRequest" type="WS_DamageConfigRequest"/>
        <ReturnType type="WS_DamageConfigResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getDebtorTypes" id="592218d7-9704-46ac-88cd-d97175f74829">
        <source>getDebtorTypes() : WS_CodeResponse webService;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 28/08/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars
	response : WS_CodeResponse;
	completedOK : Boolean;
	debtorType : CM_DebtorType;
	iter : Iterator;
	wsCode : WS_Code;

begin
// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	create response transient;
	
	iter := app.myRoot.allDebtorTypes.createIterator;
	while iter.next(debtorType) do
		create wsCode transient;
		wsCode.setProxyDetails(debtorType, debtorType.code, debtorType.description);
		response.allCodes.add(wsCode);
	endwhile;
	
	completedOK := true;
	return response;
	
epilog
	delete iter;
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <ReturnType type="WS_CodeResponse"/>
    </JadeWebServicesMethod>
