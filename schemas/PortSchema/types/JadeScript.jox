    <JadeMethod name="rel842_par37434" id="e9f5fd13-14de-4f6c-b6cb-b4d0f1b012f8">
        <source>rel842_par37434();
// fix up future storage mappings
vars
	count1,
	count2	: Integer;
	fsm		: CM_FutureStorageMapping;
	qrm		: CM_QuantityRangeMap;
	ild		: CM_InvoiceLineDesc;
	lineMapping	: CM_TranMapInvoiceLineMapping;
	
	mapType	: CM_TranMapInvoiceLineGroupType;
	key		: Integer;
	
begin
	foreach mapType in CM_TranMapInvoiceLineGroupType.instances do
		if mapType.type = TranMapInvLineGroupTypeAll then
			break;
		endif;
	endforeach;
	/* TFS 40620 removing all references to qrm.allInvoiceLineMaps

	beginTransaction;
	foreach fsm in CM_FutureStorageMapping.instances do
		if fsm.myQuantityMap &lt;&gt; null then
			foreach qrm in fsm.myQuantityMap.allQuantityRanges do
				if qrm.allInvoiceLineMaps.size &gt;  0 and
				   qrm.allTMInvoiceLineMappings.isEmpty then
					count1 := count1 + 1;
					foreach ild in qrm.allInvoiceLineMaps do
						create lineMapping;
						lineMapping.update(key, ild, qrm, mapType, null, null);
					endforeach;
				endif;
				foreach lineMapping in qrm.allTMInvoiceLineMappings do
					if lineMapping.mapValue &lt;&gt; 0 then
						count2 := count2 + 1;
						lineMapping.update(0, lineMapping.myTMInvoiceLineDesc, lineMapping.myQuantityRangeMap, lineMapping.myTMInvoiceLineGroupType, lineMapping.myTransferType, lineMapping.myVesselCategory);
					endif;
				endforeach;
			endforeach;
		endif;
	endforeach;
	commitTransaction;
	*/
	//write count1.String &amp; " missing TranMapInvoiceMappings";  // - 5
	//write count2.String &amp; " incorrect mapping keys"; // - 27
end;</source>
    </JadeMethod>
