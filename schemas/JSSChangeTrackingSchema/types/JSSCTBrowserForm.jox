    <JadeMethod name="displayTableRow" id="035e8c56-a5f2-46d4-85db-db068d7838d3">
        <updating/>
        <source>displayTableRow(table: Table input; theSheet: Integer; obj: Object; theRow: Integer; bcontinue: Boolean io): String updating, protected;
/*
//24 Sept 2013	cnwrs1	CCMS2238 C3 Change Tracker
*/
vars
	rowString: String;
	ctObject: JSSCTChangeTrackingObject;
begin
	ctObject := obj.JSSCTChangeTrackingObject;

	rowString := ctObject.className &amp; Tab;

	if ctObject.changeAction = JSSCTChangeTrackingObject.ACTION_CREATE then
		rowString := rowString &amp; 'Create' &amp; Tab;
	elseif ctObject.changeAction = JSSCTChangeTrackingObject.ACTION_UPDATE then
		rowString := rowString &amp; 'Update' &amp; Tab;
	elseif ctObject.changeAction = JSSCTChangeTrackingObject.ACTION_DELETE then
		rowString := rowString &amp; 'Delete' &amp; Tab;
	endif;
	rowString := rowString &amp; ctObject.changeObjectID &amp; Tab &amp; ctObject.changeSequence.String &amp; Tab &amp; ctObject.changeTimestamp.String &amp; Tab;
	rowString := rowString &amp; ctObject.changeTransactionID.String &amp; Tab &amp; ctObject.userCode &amp; Tab &amp; ctObject.trxTimestamp.String &amp; Tab &amp; ctObject.previouslyTracked.String &amp; Tab;

//	if ctObject.previouslyTracked then
		if ctObject.priorChangeAction = JSSCTChangeTrackingObject.ACTION_CREATE then
			rowString := rowString &amp; 'Create' &amp; Tab;
		elseif ctObject.priorChangeAction = JSSCTChangeTrackingObject.ACTION_UPDATE then
			rowString := rowString &amp; 'Update' &amp; Tab;
		elseif ctObject.priorChangeAction = JSSCTChangeTrackingObject.ACTION_DELETE then
			rowString := rowString &amp; 'Delete' &amp; Tab;
		endif;
		rowString := rowString &amp; ctObject.priorChangeTimestamp.String;
//	else
//		rowString := rowString &amp; Tab &amp; Tab;
//	endif;
	return (rowString);
end;</source>
        <access>protected</access>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="theSheet" type="Integer"/>
        <Parameter name="obj" type="Object"/>
        <Parameter name="theRow" type="Integer"/>
        <Parameter name="bcontinue" type="Boolean" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doFormLoad" id="0429d645-7836-4a49-a9a9-99e1e3a82e63">
        <updating/>
        <source>doFormLoad() updating, protected;
/*
*/
begin
	inheritMethod();

	self.myChangeTrackingRoot := JSSCTChangeTrackingRoot.firstInstance;
	cmbChangeClasses.listCollection(self.myChangeTrackingRoot.allChangeClasses, true, 0);
	cmbDeleteClasses.listCollection(self.myChangeTrackingRoot.allDeleteClasses, true, 0);

	self.initializeChangeTable();
	self.initializeDeleteTable();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initializeChangeTable" id="17c04d8f-58fa-47c8-93c0-ddea5f017b74">
        <source>initializeChangeTable();
/*
*/
begin
	self.initializeTable(tblChanges);
end;</source>
    </JadeMethod>
    <JadeMethod name="initializeDeleteTable" id="5e35b4bd-8f66-4c4e-bbd6-314fbb7c5ba5">
        <source>initializeDeleteTable();
/*
*/
begin
	self.initializeTable(tblDeletes);
end;</source>
    </JadeMethod>
    <JadeMethod name="initializeTable" id="b608d6d9-f4b9-4e00-bf0d-787ddbe9f862">
        <source>initializeTable(pTable: Table input);
/*
//24 Sept 2013	cnwrs1	CCMS2238 C3 Change Tracker
*/
begin
	pTable.rows := 1;
	pTable.columns := 10;

	pTable.setCellText(1,1,'Class' &amp; Tab &amp; 'Action' &amp; Tab &amp; 'Object' &amp; Tab &amp; 'Sequence' &amp; Tab &amp; 'Timestamp' &amp; Tab &amp; 'Tran ID' &amp; Tab &amp; 'User' &amp; Tab &amp; 'Trx TimeStamp' &amp; Tab &amp; '(Tracked)' &amp; Tab &amp; '(Action)' &amp; Tab &amp; '(Timestamp)');

	pTable.selectMode := Table.SelectMode_CurrentRow;
end;</source>
        <Parameter name="pTable" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblChanges_dblClick" id="ee93f252-bac2-4177-b031-b1d69fa8ad2e">
        <controlMethod name="Table::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblChanges_dblClick(table: Table input) updating;
/*
*/
vars
	ctObject: JSSCTChangeTrackingObject;
begin
	ctObject := table.accessRow(table.row).itemObject.JSSCTChangeTrackingObject;
	if ctObject &lt;&gt; null then
		if global.isValidObject(ctObject.changeObject) then
			ctObject.changeObject.inspectModal;
		endif;
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblChanges_displayRow" id="12901580-3dd4-44d7-8db3-9908bc06eb63">
        <controlMethod name="Table::displayRow"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblChanges_displayRow(table: Table input; theSheet: Integer; obj: Object; theRow: Integer; bcontinue: Boolean io):String updating;
/*
*/
begin
	return (self.displayTableRow(table, theSheet, obj, theRow, bcontinue));
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="theSheet" type="Integer"/>
        <Parameter name="obj" type="Object"/>
        <Parameter name="theRow" type="Integer"/>
        <Parameter name="bcontinue" type="Boolean" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
