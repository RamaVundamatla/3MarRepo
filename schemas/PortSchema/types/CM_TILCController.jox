    <JadeMethod name="validateMoveTo" id="d0e4c539-8561-4173-90c8-d21da9f10bb4">
        <source>validateMoveTo(_control: CMIF_MoveController input);
/*

Purpose:			


Return Value:		


Date		Who		Reason
08 May 2008	cnwer1	Initial creation - PAR#xxxx
29 Sep 2008	consw1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition
05 Sep 2022 jlier1 TFS 54700 - ignore TEU capacity
11/04/2023	navkc1	CR#57036 Task 57546: Jade - MAFI Operator Voyage Discharge Port Checking
30 Oct 2023 jlier1 TFS 60822 - don't return after warnings so you don't miss out on other  warnings or worse errors 
*/
vars
	tmpTi, ti	: CM_TrackedItem;
	indx, numLCs : Integer;
	currentLoad	: Decimal[14,4];
	lc			: CM_TILCController;
	ignoreTEUCap  : Boolean;
begin
	inheritMethod(_control);
	
	tmpTi := _control.myTrackedItem;
	numLCs:=self.myTILC.allLCs.size;
	indx:=self.myTILC.allLCs.indexOf(self);

	ignoreTEUCap:=self.myTerminal.getConfig(IgnoreTrailerTypeTEUCap).Boolean;
	

	if tmpTi.isKindOf(CM_Cargo) and not self.myTerminal.roadProcessIsASPA and not ignoreTEUCap then	//26 Nov 2020	NDL	TFS 50430
		//can't place cargo here if there is a container/car or another trailer
		if self.hasContainers(false,false) then
				app.raiseCMException(ERR_TI_CANNOT_PLACE_INUSE, null, null);
		endif;
	endif;

	if tmpTi.isContainer and not self.myTerminal.roadProcessIsASPA  and not ignoreTEUCap then	//26 Nov 2020	NDL	TFS 50430
		if tmpTi.is20 then		
			//epr par 34576 16/7/14 
			//if container can't place here if cargo is here
			if self.allTIs.size &gt; 0 then
					app.raiseCMException(ERR_TI_CANNOT_PLACE_INUSE, null, null);	
			endif;
		else
	
			// 15 May 2014 DJW 34155
			if numLCs &lt; 2 then
				//raise exception
				app.raiseCMException(ERR_TI_CANNOT_PLACE40_TRAILER, null, null);
				return;
			endif;
			
			if indx = (numLCs - 1) and self.myTILC.allLCs[numLCs].allTrackedItems.size &lt;&gt; 0 then
				app.raiseCMException(ERR_TI_CANNOT_PLACE40_ENDINUSE, null, null);
				return;
			endif;	
		endif;
	endif;
	
	
	// 11/04/2013 cnwar2 #31332
	currentLoad := 0;
	foreach lc in self.myTILC.allLCs discreteLock do
		foreach ti in lc.allTrackedItems discreteLock do
			currentLoad := currentLoad + ti.totalWeight;
		endforeach;
	endforeach;
	
	if tmpTi.isBulkByVolume or tmpTi.isBulkByWeight then
		if currentLoad + _control.weight &gt; self.myTILC.myTILCType.maxWeight then
			//jlier1 TFS 54700 8/9/22 - make it a warning if  
			if ignoreTEUCap then
				app.raiseCMWarning2(ERR_TI_CANNOT_PLACE_WEIGHT, tmpTi.id,self.myTILC.id,null,null,null);
			else
				app.raiseCMException2(ERR_TI_CANNOT_PLACE_WEIGHT, tmpTi.id,self.myTILC.id,null,null);
				return;
			endif;
			
		endif;
	elseif tmpTi.isBulkByQuantity then
		if currentLoad  + _control.getWeightForValidation  &gt; self.myTILC.myTILCType.maxWeight then
			//jlier1 TFS 54703 11/10/22 
			if ignoreTEUCap then
				app.raiseCMWarning2(ERR_TI_CANNOT_PLACE_WEIGHT, tmpTi.id,self.myTILC.id,null,null,null);
			else
				app.raiseCMException2(ERR_TI_CANNOT_PLACE_WEIGHT, tmpTi.id,self.myTILC.id,null,null);
				return;
			endif;
			
		endif;
	
	else
	
		if currentLoad + tmpTi.totalWeight &gt; self.myTILC.myTILCType.maxWeight then
			if ignoreTEUCap then
				app.raiseCMWarning2(ERR_TI_CANNOT_PLACE_WEIGHT, tmpTi.id,self.myTILC.id,null,null,null);
			else
				app.raiseCMException2(ERR_TI_CANNOT_PLACE_WEIGHT, tmpTi.id,self.myTILC.id,null,null);
				return;
			endif;
			
		endif;
	endif;
	
	//11/04/2023	navkc1	CR#57036 Task 57546
	self.myTILC.validateCargoMatchesVoyOpDisch(tmpTi);
	
epilog

end;</source>
        <Parameter name="_control" type="CMIF_MoveController" usage="input"/>
    </JadeMethod>
</Class>
