        <Inverse name="CM_Wagon::allToDoTasksCompleted"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="myWagonToDo" id="fc394ab7-2e74-43b9-aae5-6cd87c589c6d">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
