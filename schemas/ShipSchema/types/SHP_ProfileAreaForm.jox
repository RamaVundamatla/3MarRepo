    <JadeMethod name="initTableStats" id="0658de3f-9834-4490-b760-65014192d37c">
        <source>initTableStats() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 September 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars
	theTable : CM_DataTable;
begin

	theTable := self.tblGridAreaInfo;
	theTable.borderStyle := Frame.BorderStyle_None;
	theTable.scrollBars:=Table.ScrollBars_Both;
	theTable.rows :=0;// 12;
	theTable.columns := 1;
