    <JadeMethod name="pxyCreateUpdateProxy" id="4bf29733-457e-4cb1-aa9c-9141f543eb82">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     09 February 2002 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// ---------------------------------------------------------------------------
vars
	proxyShipBlockController:CM_ShipBlockController;
	completedOK		: Boolean;
	
begin

	proxyShipBlockController := inheritMethod();

	// RJS - need to add other references here, including collections
	// self.ports is inversed and this is the auto end so no need
	// to copy to the proxy
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyShipBlockController;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyShipBlockController;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
