    <JadeMethod name="migratePermissionsPreRelease" id="7538dc3b-09fa-4280-8be9-0310927ea467">
        <source>migratePermissionsPreRelease(	_currPerms	: IntegerArray;
								_newPerms	: IntegerArray );
/*

Purpose:	To migrate permissions with roles 		

Parameters:			_currPerms - the existing permissions
					-newPerms - the permissions that the current permissions
								are being migrated to

Return Value:		

Date		Who		Reason
06 Nov 2012	cnwpjs1	Initial creation  PAR #30631

*/

vars

	role 		: CM_SecurityRole;
	index		: Integer;
	items		: Integer;
	grantPerms	: IntegerArray;
	
begin

	items := _currPerms.size;
	create grantPerms transient;
	
	beginTransaction;

	foreach role in app.myRoot.allRoles do
		
		index := 0;
		grantPerms.clear;
		
		while index &lt; items do
			index := index + 1;
				
			// if the role has the current permission the ensure that we grant the corresponding
			// role (that we are are replacing it with) if the role does not already have it
			//			
			
			if role.canDo(_currPerms[index]) and (not role.canDo(_newPerms[index])) then
				grantPerms.add(_newPerms[index]);	
			endif;
			
			
		endwhile;
		
		if grantPerms.isNotEmpty then
			role.setPermissionsFromIntArray(grantPerms,true);
		endif;
		
	
	endforeach;
	
	commitTransaction;


epilog

	delete grantPerms;

end;</source>
        <Parameter name="_currPerms" type="IntegerArray"/>
        <Parameter name="_newPerms" type="IntegerArray"/>
    </JadeMethod>
