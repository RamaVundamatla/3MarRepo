        <updating/>
        <source>setMyInvoice(_invoice : CM_Invoice) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 13/09/2018	jlgdap1		Initial creation TFS 40030 PEL1 Multiple Estimates and Invoices
//
vars

begin
	self.myInvoice := _invoice;
epilog

end;</source>
