    <JadeMethod name="zInvConsignorCoparnFile" id="5d3e499f-ecc2-4d07-ab21-e73d894fd9dd">
        <source>zInvConsignorCoparnFile(_sender : String;
						_ediParty : String;
						_bookingNum : String;
						_voyageCode : String;
						_vesselCode : String;
						_preNote1 : String;
						_preNote2 : String;
						_consignor : String) : String;
/*
Purpose:  Coparn EDI File configurable with valid/invalid consignor

Date		Who		Reason
05 Aug 2019	jlgdi1	Initial creation
*/

vars
	text : String;
	
begin
	text := "
UNB+UNOB:1+"&amp;_sender&amp;"+PENN+160919:0941+565450++++0++0'
UNH+565450+COPARN:D:95B:UN:ITG14'
BGM+11+20190717075531+5'
RFF+BN:"&amp;_bookingNum&amp;"'
TDT+20+"&amp;_voyageCode&amp;"+1++IILU:172:166+++9470961:146::"&amp;_vesselCode&amp;"'
LOC+88+DEBRE:139:6'
LOC+9+DEBRE:139:6'
DTM+133:201907221400:203'
NAD+CZ+"&amp;_consignor&amp;"+BASE SPA (LI)'
NAD+CA+IILU:172:166'
GID+1'
FTX+AAA+++GENL'
EQD+CN+"&amp;_preNote1&amp;"+42G1:102:5++2+4'
RFF+BN:"&amp;_bookingNum&amp;"'
RFF+SQ:R8SA2ELR4ZP3B'
TMD+3++2'
DTM+181:201907160730:203'
LOC+11+DEBRE:139:6'
MEA+AAE+G+KGM:42000'
MEA+AAE+T+KGM:3740'
FTX+AAA+++GENL'
EQD+CN+"&amp;_preNote2&amp;"+42G1:102:5++2+4'
RFF+BN:"&amp;_bookingNum&amp;"'
LOC+11+DEBRE:139:6'
RFF+SQ:RY0B2ELR4ZP3B'
MEA+AAE+G+KGM:42000'
CNT+16:1'
UNT+55+565450'";
	return text;
end;</source>
        <Parameter name="_sender" type="String"/>
        <Parameter name="_ediParty" type="String"/>
        <Parameter name="_bookingNum" type="String"/>
        <Parameter name="_voyageCode" type="String"/>
        <Parameter name="_vesselCode" type="String"/>
        <Parameter name="_preNote1" type="String"/>
        <Parameter name="_preNote2" type="String"/>
        <Parameter name="_consignor" type="String"/>
