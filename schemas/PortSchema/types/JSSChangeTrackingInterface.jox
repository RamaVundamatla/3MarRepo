    <JadeMethod name="raiseAlert" id="972004b3-e3b5-4d0d-939a-2304380778b3">
        <source>raiseAlert(pShortMsg, pLongMsg : String);

vars

	alert : CM_SystemAlert;
begin

	app.writeLog('Change Tracker exception - ' &amp; pShortMsg &amp; ' (' &amp; pLongMsg &amp; ')', LogINFO);
	
	create alert transient;
	alert.details := 'Change Tracker exception - ';
	alert.setSeverity(SEVERE_ERROR);
	alert.addLogEntry(pShortMsg);
	alert.addLogEntry(pLongMsg);
	alert.add;
	app.commitAlert();

end;</source>
        <Parameter name="pShortMsg" type="String"/>
        <Parameter name="pLongMsg" type="String"/>
    </JadeMethod>
    <JadeMethod name="selectClassChanges" id="9fe93a7b-a8a0-46e0-bc83-3151002bda36">
        <updating/>
        <source>selectClassChanges(pClassName : String; pFromTimeStamp : TimeStamp; pToTimeStamp : TimeStamp; _ignoreDeletesFor : CM_User) : Integer updating;
/*
			JSSChangeTrackingSchema Interface Method - DO NOT CHANGE
			
			Call this method to set up a collection of created/changed instances
			for the specified class, for the specified time period.
			
			This method must be called prior to calling the getNextClassChange() method.
*/
vars
	retValue : Integer;
	userCode : String;
begin

	if _ignoreDeletesFor &lt;&gt; null then	//07 Jan 2014	NDL	Par 33264
		userCode := _ignoreDeletesFor.code.toUpper;
	endif;
	
	retValue := ( self.myExternalInterface.sendMsgWithParams(method.name, pClassName, pFromTimeStamp, pToTimeStamp, userCode).Integer );
	
	return retValue;
	
end;</source>
        <Parameter name="pClassName" type="String"/>
        <Parameter name="pFromTimeStamp" type="TimeStamp"/>
        <Parameter name="pToTimeStamp" type="TimeStamp"/>
        <Parameter name="_ignoreDeletesFor" type="CM_User"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="selectClassDeletes" id="dd356d9d-d83e-4ff4-9670-97cd78214bc9">
        <updating/>
        <source>selectClassDeletes(pClassName : String; pFromTimeStamp : TimeStamp; pToTimeStamp : TimeStamp; _ignoreDeletesFor : CM_User) : Integer updating;
/*
			JSSChangeTrackingSchema Interface Method - DO NOT CHANGE
			
			Call this method to set up a collection of deleted instances
			for the specified class, for the specified time period.
			
			This method must be called prior to calling the getNextClassDelete() method.
*/
vars
	retValue : Integer;
	userCode : String;
begin

	if _ignoreDeletesFor &lt;&gt; null then	//07 Jan 2014	NDL	Par 33264
		userCode := _ignoreDeletesFor.code.toUpper;
	endif;
	
	retValue := ( self.myExternalInterface.sendMsgWithParams(method.name, pClassName, pFromTimeStamp, pToTimeStamp, userCode).Integer );
	
	return retValue;
end;</source>
        <Parameter name="pClassName" type="String"/>
        <Parameter name="pFromTimeStamp" type="TimeStamp"/>
        <Parameter name="pToTimeStamp" type="TimeStamp"/>
        <Parameter name="_ignoreDeletesFor" type="CM_User"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
