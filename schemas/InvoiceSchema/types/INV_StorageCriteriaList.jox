epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doFindNoAniversaryCargo" id="a6e4f825-46f9-415a-acf7-eac7138c0f15">
        <source>doFindNoAniversaryCargo();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 May 2016	cnwndl1	Initial creation	TFS 1981

*/

vars

	taStorageGroup : CM_TerminalAreaStorageGroup;
	iter : Iterator;
	ta : CM_TerminalArea;
	iterTA : Iterator;
	objectSet : ObjectSet;
	iterTi : Iterator;
	ti : CM_TrackedItem;
	anniversary : Date;
	tisToList : CM_TIArray;
	msg : String;
	foundFutureConfig : Boolean;
	storageDetail : CM_StorageDetail;

begin

	create tisToList transient;
	create objectSet transient;
	
	if self.myTerminal.myStorageConfig = null then
		msg := "Terminal has no 'Storage Configuration', so nothing to check.";
		return;
	endif;
	
	iter := self.myTerminal.myStorageConfig.allStorageDetails.createIterator;
	while iter.next( storageDetail ) do
		if not storageDetail.allFutureStorageMappings.isEmpty then
			foundFutureConfig := true;
			break;
		endif;
	endwhile;
	
	if not foundFutureConfig then
		msg := "Terminal has 'Storage Details' but none are set to use future storage, so nothing to check. ";
		return;
	endif;
	
	msg := "About to check " &amp; self.myTerminal.allOnsiteTIsByIdCargoType.size.String &amp; " cargo items." &amp; CrLf &amp; app.getErrorString(Continue);
	if app.msgBox( msg, app.getErrorString(Continue), MsgBox_Yes_No ) &lt;&gt; MsgBox_Return_Yes then
		msg := null;
		return;
	endif;
	

	iter := self.myTerminal.allOnsiteTIsByIdCargoType.createIterator;
	while iter.next( ti ) do
		if ti.isChild then // found during doc review
			continue;
		endif;
		anniversary := ti.getFutureStorageAnniversary();
		if anniversary &lt;&gt; null then
			continue;
		endif;
		storageDetail := null;
		storageDetail := ti.getMatchingFreeStorageDetail( null );
		if storageDetail &lt;&gt; null and not storageDetail.allFutureStorageMappings.isEmpty then
			tisToList.addExclusive( ti );
		endif;
	endwhile;
				
	delete iter;
	
	if tisToList.isEmpty then
		msg := "No cargo found in the terminal that matches a 'Future Storage Config' criteria without an anniversary.";
		return;
	endif;
	
	msg := "Found " &amp; tisToList.size.String &amp; " cargo item(s) found in the terminal without an anniversary." &amp; CrLf &amp; "Do you want to list them";
	if app.msgBox( msg, app.getErrorString(Continue), MsgBox_Yes_No ) &lt;&gt; MsgBox_Return_Yes then
		msg := null;
		return;
	endif;
	
	
	self.myAssistant.showCargoEnquiryForTIs( tisToList.first, tisToList, self.myMasterMenuAction, false );
	msg := null;
	
epilog

	if msg &lt;&gt; null then
		app.msgBox( msg, "Anniversary check", MsgBox_OK_Only );
	endif;

	delete iter;
	delete iterTA;
	delete objectSet;
	delete iterTi;
	
end;</source>
    </JadeMethod>
