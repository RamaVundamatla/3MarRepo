    <JadeMethod name="updateTI" id="e3c3a9d7-d6cd-4291-8ce1-d55b218b7c24">
        <source>updateTI():Boolean;
/*

Purpose:			

Parameters:			Specifically for CM_LocationActivity updating when also changing the amount on a TI 

Return Value:		

Date		Who		Reason
04 May 2021	navndl1	Initial creation	TFS 50906

*/

vars

	newValue : Decimal[14,4];

begin

	if self.type &lt;&gt; TRANS_TYPE_LocationDiscrep then
		return false;
	endif;
	if self.myTrackedItem = null then
		return false;
	endif;
	
	if self.volumeChange &lt;&gt; 0 then
		newValue := self.myTrackedItem.totalVolume + (self.volumeChange * multiplier);
		if newValue &lt;= 0 then
			if self.newTotalVolume &lt;&gt; newValue then
				//its been updated by someone else since the cmif was created
				app.raiseCMWarning1( Cargo_item_just_been_updat_anp, self.myTrackedItem.id, app.getErrorString(CM_Total_Volume), null, null );
			endif;
			app.raiseCMException( Remai_volum_will_less_than_zer, null, null );
			return false;
		endif;
		self.myTrackedItem.setTotalVolumeWithoutTrans( self.newTotalVolume );
		return true;
		
	elseif self.weightChange &lt;&gt; 0 then
		newValue := self.myTrackedItem.totalWeight + (self.weightChange * multiplier);
		if newValue &lt;= 0 then
			if self.newTotalWeight &lt;&gt; newValue then
				//its been updated by someone else since the cmif was created
				app.raiseCMWarning1( Cargo_item_just_been_updat_anp, self.myTrackedItem.id, app.getErrorString(CM_Total_Weight), null, null );
			endif;
			app.raiseCMException( Remai_weigh_will_less_than_zer, null, null );
			return false;
		endif; 
		self.myTrackedItem.setTotalWeightWithoutTrans( self.newTotalWeight );
		return true;
		
	elseif self.quantityChange &lt;&gt; 0 then
		newValue := self.myTrackedItem.totalQuantity + (self.quantityChange * multiplier);
		if newValue &lt;= 0 then
			if self.newTotalQuantity &lt;&gt; newValue then
				//its been updated by someone else since the cmif was created
				app.raiseCMWarning1( Cargo_item_just_been_updat_anp, self.myTrackedItem.id, app.getErrorString(CM_Total_Quantity), null, null );
			endif;
			app.raiseCMException( Remai_quant_will_less_than_zer, null, null );
			return false;
		endif; 
		self.myTrackedItem.setTotalQuantity( self.newTotalQuantity );
		return true;
		
	endif;

	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
