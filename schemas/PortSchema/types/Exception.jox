<ExceptionClass name="Exception">
    <JadeMethod name="isFatalThinClientError" id="e740c51d-e368-4f81-803e-b53c62a1754d">
        <source>isFatalThinClientError() : Boolean;
// ---------------------------------------------------------------------------
// Created:     11 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if (self.errorCode &gt;= 14140) and (self.errorCode &lt;= 14149) then
		// djc, 30 Nov 2000: Bob said that the following error codes are for
		// fatal thin client connection errors and in the event of one, the
		// application process (in the app server) should be terminated.
		app.writeStatement( class.name &amp; '::' &amp; method.name &amp; '  &gt;&gt; FATAL ERROR &gt; FatalThinClientError (' &amp; self.errorCode.String &amp; ')');
		app.writeLog('FATAL ERROR &gt; FatalThinClientError (' &amp; self.errorCode.String &amp; ')', LogINFO);
		return true;
	endif;
	
	return false;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isJadeException" id="47909361-8d98-474f-9e50-2f514341649a">
        <source>isJadeException():Boolean;
// --------------------------------------------------------------------------------
// Created:		02 August 2006 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the receiver is a Jade
//				exception.
//
// Parameters:	None
//
// Returns:		True if the receiver is a Jade exception, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</ExceptionClass>
