    <JadeMethod name="getActualLength" id="ad1694d5-b526-4a46-b19c-9cf43924a3fb">
        <source>getActualLength() : Integer;
// ---------------------------------------------------------------------------
// Created:		30 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if self.getAttrIs20() then
		return 20;
	elseif self.getAttrIs30() then // PAR 16415 CCMS 1029
		return 30;
	elseif self.getAttrIs53() then // PAR 16415 CCMS 1029
		return 53;
	elseif self.getAttrIs45() then // PAR 18682 CCMS 1055
		return 45;
	elseif self.getAttrIs40() then
		return 40;
	endif;
	return 20;
		
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getAllDrawingIcons" id="01e852ee-e191-4a98-924f-9aa7fd0deb75">
        <source>getAllDrawingIcons(_array: StringArray input;
					_maxIcons : Integer);  // 11/10/2022	navkc1	#54935
/*
Purpose:			
Date		Who		Reason
27/06/2011	cnwab1	Initial creation
08/11/2019	jlgdap1	TFS 46405 AT Flat Rack adn OOG in LOLO Planning Screen - rewritten to do icons in priority order
11/10/2022	navkc1	Bug 54935: MSL - Roro planning - Slow on big decks/large vessels
*/

vars
	iter : Iterator;
	attr, startObject: CM_DrawingAttribute;
	attrCode : String;

begin
	inheritMethod(_array, _maxIcons);
	
	iter := app.myRoot.allDrawingAttributesByTypePri.createIterator;
	startObject := app.myRoot.allDrawingAttributesByTypePri.getAtKeyGtr(DrawingAttrType_TrackedItem, null);
	if startObject &lt;&gt; null then
		iter.startAtObject(startObject);
		while iter.next(attr) do
			if attr.drawingAttrType &lt;&gt; DrawingAttrType_TrackedItem then
				break;
			endif;
			
			attrCode := attr.code;
	
			// PAR 28409
			if attrCode = PicTIPlanned and self.getNumTIsOfMode(PLANNING_MODE, true) &gt; 0 then
				_array.add(PicTIPlanned);
			
			elseif
			
			// PAR 31394 this was way down the bottom of this method, but it needs to be at the top as we only show 1 or 2 icons and this is very important
			attrCode = PicTIPlanned and self.isBulkRelease() then  //ccms 1310 par 30807 
				_array.add(PicTIPlanned);
			elseif
			
			// ###########
			// SPECIAL STOW CODE
			attrCode = PicSpecialStow and self.getAttrIsSpecialStow  then // PAR 34899
				_array.add(PicSpecialStow); // PAR 34899
			elseif
		
			// ###########
			// FORTY  FOOT
			attrCode = PicTI40Footer and self.getAttrIs40() then
				_array.add(PicTI40Footer);
			elseif
		
			// ###########
			// POWERED
			attrCode = PicTIConnected and self.getAttrPowerRequired() then
				_array.add(PicTIConnected);
			elseif
			// ###########
			// HAZARD
			attrCode = PicTIHazard and self.getAttrHazardous() then
				_array.add(PicTIHazard);
			elseif
			
			// ###########
			// MTs ONLY
			attrCode = PicTIEmpty and self.getAttrEmpty() then
				_array.add(PicTIEmpty);
			elseif
		
			// ###########
			// OVERSIZED
			attrCode = PicTIOversized and self.getAttrOverDimensioned() then
				_array.add(PicTIOversized);
			elseif
			
			// ###########
			// HIGH CUBED	
			attrCode = PicTIHiCube and self.getAttrHiCubed() then
				_array.add(PicTIHiCube);
			elseif
		
			// ###########
			// WATERCOOLED	
			attrCode = PicTIWaterCooled and self.getAttrWaterCooled() then
				_array.add(PicTIWaterCooled);
			elseif
			
			// 01/02/2013 cnwar2 #31057
			attrCode = PicTIFlat and self.getAttrFlatRack() then
				_array.add(PicTIFlat);
			elseif
			attrCode = PicTICrib and self.getAttrCrib() then
				_array.add(PicTICrib);
			elseif
			attrCode = PicTIOpentop and self.getAttrOpenTop() then
				_array.add(PicTIOpentop);
			elseif
			attrCode = PicTIFantainer and self.getAttrFantainer() then
				_array.add(PicTIFantainer);
			elseif
			attrCode = PicTITank and self.getAttrTank() then
				_array.add(PicTITank);
			elseif
			
			//05 Feb 2018	NDL	TFS 36752
			attrCode = PicTIFrame and self.getAttrFrame() then
				_array.add(PicTIFrame);
			elseif
			
			// ###########
			// FLAT RACK ENDS
			attrCode = PicTIFlatRackEndsUp and self.getAttrFlatRackEnds(true) then
				_array.add(PicTIFlatRackEndsUp);
			elseif
			attrCode = PicTIFlatRackEndsDown and self.getAttrFlatRackEnds(false) then
				_array.add(PicTIFlatRackEndsDown);
			endif;
			
			if _maxIcons &lt;&gt; 0 and _array.size() &gt;= _maxIcons then	
				break;  // 11/10/2022	navkc1	#54935
			endif;
			
		endwhile;
	endif;
epilog
	delete iter;
end;</source>
        <Parameter name="_array" type="StringArray" usage="input"/>
        <Parameter name="_maxIcons" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getAllDrawingIconsByPriority" id="6e3bc439-5e0b-46d6-baf8-e0a7890d80c3">
        <source>getAllDrawingIconsByPriority(_iconArray: StringArray input; _maxIcons: Integer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12/12/2017	jlgmp6	Initial creation	TFS7493
08/11/2019	jlgdap1	TFS 46405 AAT Flat Rack and OOG in LOLO Planning Screen
*/

vars
	root: CM_Root;
	attr,
	startObject: CM_DrawingAttribute;
	iter: Iterator;
	attrCode: String;
begin
	root := app.getMyRoot();
	if root = null then
		return;
	endif;
	
	iter := root.allDrawingAttributesByTypePri.createIterator();
	startObject := root.allDrawingAttributesByTypePri.getAtKeyGtr(DrawingAttrType_TrackedItem, null);
	if startObject &lt;&gt; null then
		iter.startAtObject(startObject);
		while iter.next(attr) and attr.drawingAttrType = DrawingAttrType_TrackedItem do
			attrCode := attr.code;
			if attrCode = PicTIHazard then
				if self.getAttrHazardous() then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicSpecialStow then
				if self.getAttrIsSpecialStow() then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTIPlanned then
				if self.getNumTIsOfMode(PLANNING_MODE, true) &gt; 0 or self.isBulkRelease() then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTIWaterCooled then
				if self.getAttrWaterCooled() then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTI30Footer then
				if self.getAttrIs30() then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTI40Footer then
				if self.getAttrIs40() then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTI45Footer then
				if self.getAttrIs45() then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTI53Footer then
				if self.getAttrIs53() then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTIFlat then
				if self.getAttrFlatRack() then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTIFantainer then
				if self.getAttrFantainer() then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTICrib then
				if self.getAttrCrib() then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTIFrame then	//05 Feb 2018	NDL	TFS 36752
				if self.getAttrFrame() then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTIOpentop then
				if self.getAttrOpenTop() then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTITank then
				if self.getAttrTank() then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTIConnected then
				if self.getAttrPowerRequired() then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTIEmpty then
				if self.getAttrEmpty() then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTIHiCube then
				if self.getAttrHiCubed() then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTIOversized then
				if self.getAttrOverDimensioned() then
					_iconArray.add(attrCode);
				endif;
			// TFS 46405 start
			elseif attrCode = PicTIFlatRackEndsUp then
				if self.getAttrFlatRackEnds(true) then
					_iconArray.add(PicTIFlatRackEndsUp);
				endif;
			elseif attrCode = PicTIFlatRackEndsDown then
				if self.getAttrFlatRackEnds(false) then
					_iconArray.add(PicTIFlatRackEndsDown);
				endif;
			// TFS 46405 end
			endif;	
	
			if _maxIcons &lt;&gt; 0 and _iconArray.size() &gt;= _maxIcons then
				break;
			endif;
		endwhile;
	endif;
	
epilog
end;</source>
        <Parameter name="_iconArray" type="StringArray" usage="input"/>
        <Parameter name="_maxIcons" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getAllocationColour" id="6239e7b6-c052-4306-821d-e3d98ba5eb14">
        <source>getAllocationColour() : Integer;
/*
Purpose:			
Date		Who		Reason
27 June 2011	cnwab1	Initial creation
*/

vars
	allocation : CM_YardAllocation;
begin
	allocation := self.getFirstAllocation();
	if allocation &lt;&gt; null then
		return allocation.color;
	endif;

	return White;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getAllocationHazGroup" id="14b166b2-ef1e-4043-b472-be74fd9f1ec9">
        <source>getAllocationHazGroup() : String;
/*
Purpose:			
Date		Who		Reason
27 June 2011	cnwab1	Initial creation
*/

vars
	criteria : CM_YACriteria;	
	allocName : String;
begin
	criteria := self.getAttrByType(YACriteriaType_Hazardous); 
	if criteria &lt;&gt; null then
		allocName := criteria.myYACriteriaType.getDataDisplay(criteria.myYAData);
	endif;
	
	return allocName;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAllocationISOGroup" id="1cc3108e-3d43-44f4-b061-5600c286fcd5">
        <source>getAllocationISOGroup() : String;
/*
Purpose:			
Date		Who		Reason
27 June 2011	cnwab1	Initial creation
*/

vars
	allocation : CM_YardAllocation;
	criteria : CM_YACriteria;	
	isoGrp : CM_ISOTypeGroup;
	aPort : CM_Port;
	allocName : String;
begin
	criteria := self.getAttrByType(YACriteriaType_DischargePort); 
	if criteria &lt;&gt; null then
		aPort :=  criteria.myYAData.CM_YADataObjects.allObjects.first().CM_Port;		
		if aPort &lt;&gt; null then
			allocName := allocName &amp; aPort.code &amp; " ";
		endif;
	
	endif;
	
	criteria := self.getAttrByType(YACriteriaType_ISOGroup); 
	if criteria &lt;&gt; null then
		isoGrp :=  criteria.myYAData.CM_YADataObjects.allObjects.first().CM_ISOTypeGroup;		
		if isoGrp &lt;&gt; null then
			allocName := allocName &amp; isoGrp.code &amp; " ";
		endif;
	endif;
	
	
	return allocName;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAllocationName" id="ef9596a0-ef88-45b5-bfe0-b6277004dd9d">
