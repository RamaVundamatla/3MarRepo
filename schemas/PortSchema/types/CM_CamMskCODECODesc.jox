    <JadeMethod name="makeMessageRFF_BN" id="3139d867-839e-439d-9fe4-d412ebb898ff">
        <source>makeMessageRFF_BN(_camProtocol :CM_CamProtocol; _group :HugeStringArray input; _activity :Integer;  _ti :CM_TrackedItem; _transaction :CM_TITransaction)protected;
/*
Purpose:	Refactored code	

Date		Who		Reason
19 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
//24 Jan 2018   cnwma1  Bug 36734: PNL - SOLAS VGM EDI Changes - port nelson NZNELPT (PARTNER NZNSN) / R-56595 / R-56933
vars
	booking, release	:String;
begin
	if _camProtocol.isUseCarrierRefForBooking then
		booking := _ti.getCarrierReference;
	else
		booking := _ti.bookingReference.trimRight;
		release := _ti.deliveryRelease.trimRight;	
	endif;
	
	// only include the booking reference number when the container comes in
	if _activity = CODECO_GATEIN or _activity= CODECO_VGM then     //24/01/2018 cnwma1 Bug #36734
		if booking &lt;&gt; null then
			self.makeRFFSegment (_camProtocol, _group, "BN", booking);	
		elseif release &lt;&gt; null then
			self.makeRFFSegment (_camProtocol, _group, "BN", release);	
		endif;				
	endif;
	
	// only include the delivery release number when the container exits
	if _activity = CODECO_GATEOUT then
		if not _transaction.isCamsPackType() and release &lt;&gt; null then //par 12454 cnwrs1 Sept 2006
			self.makeRFFSegment (_camProtocol, _group, "BN", release );		
			
		elseif booking &lt;&gt; null then
			self.makeRFFSegment (_camProtocol, _group, "BN",  booking );			
		endif;
	endif;
	
	// for CCMS1475
	if _activity = CODECO_PACK then
		self.makeRFFSegment (_camProtocol, _group, "BN", booking);			
	endif; 
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_activity" type="Integer"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_transaction" type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="makeMessageSealsData" id="13ee2338-ad6d-4da1-abdd-fca88e2084d9">
        <source>makeMessageSealsData(_ti: CM_TrackedItem; _camMessage: CM_CamMessage input; _group: HugeStringArray input; _camProtocol: CM_CamProtocol; _contentsStatus : String );
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
19 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
23 Jan 2013 cnwmc5	Changes for CCMS 2238
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
vars
	strSeal		: String;
	plus, 
	singleQuote	: Character;	
//	custSeals 	: StringArray;
	sealParty	: String;
	
begin
	//23 Mar 2012	NDL	Par 29144
	if _contentsStatus = '4' then
		//Empty Containers should never include seals data...
		return;
	endif;
	
	plus 		:= _camProtocol.elementSeparator;	
	singleQuote	:= _camProtocol.segmentTerminator;	
	
	if _ti.getSealNum.trimRight &lt;&gt; null then
		strSeal := formatSealMsk(SealType_Operator, _camProtocol.camGroup, _ti.CM_Container, sealParty);
		_group.add("SEL" &amp; plus &amp; _camProtocol.formatSeal(strSeal) &amp; plus &amp; sealParty &amp; singleQuote);
	endif;
	
	if sealParty &lt;&gt; "SH" then
		if _ti.getSealNumShipper.trimRight &lt;&gt; null then
			strSeal := formatSealMsk(SealType_Shipper, _camProtocol.camGroup, _ti.CM_Container, sealParty);
			_group.add("SEL" &amp; plus &amp; _camProtocol.formatSeal(strSeal) &amp; plus &amp; sealParty &amp; singleQuote);
		endif;
	endif;
	
	if _ti.getSealNumCustoms.trimRight &lt;&gt; null then
		//Need better wat to do this...
		strSeal := formatSealMsk(SealType_Customs, _camProtocol.camGroup, _ti.CM_Container, sealParty);
		_group.add("SEL" &amp; plus &amp; _camProtocol.formatSeal(strSeal) &amp; plus &amp; sealParty &amp; singleQuote);
	endif;
	/*// no inheritMethod!
	
	//23 Mar 2012	NDL	Par 29144
	if _contentsStatus = '4' then
		//Empty Containers should never include seals data...
		return;
	endif;
	
	strSeal := self.formatSeal(null, _camProtocol.camGroup, _ti.CM_Container);

	if strSeal &lt;&gt; null then //ccms1393
		plus 		:= _camProtocol.elementSeparator;	
		singleQuote	:= _camProtocol.segmentTerminator;	
		
		_group.add("SEL" &amp; plus &amp; _camProtocol.formatSeal(strSeal) &amp; plus &amp; "SH" &amp; singleQuote);		
	endif;*/
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_camMessage" type="CM_CamMessage" usage="input"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_contentsStatus" type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMessageTDT1Segment" id="b74ae281-9447-492d-b0b6-02e84c46cd3b">
        <source>makeMessageTDT1Segment(_protocol: CM_CamProtocol; _group: HugeStringArray input; _activity: Integer; _transaction: CM_TITransaction; _ti: CM_TrackedItem) protected;
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
18 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
vars
	carrier		:CM_Carrier;
	code, fCode	:String;
	terminal	:CM_Terminal;
begin
	inheritMethod(_protocol, _group, _activity, _transaction, _ti);

	if _ti.cargoType &lt;&gt; TI_CargoType_Container then
		return;
	endif;

	if _activity = CODECO_PACK then//added for CCMS1475
		if _ti.vehicle &lt;&gt; null then
			carrier := _ti.getCarrierReceive();
			
			if carrier = null then
				code := null;
			else
				code := carrier.description.trimRight();
			endif;
			
			self.makeTDT1Segment (_protocol, _group, null, '3', null, code[1:17], null, null, null, null, _ti.vehicle.trimRight(), null, null, null); 			
		endif;
	endif;
	
	if _activity = CODECO_UNPACK then//ccms1499 cnwrs1 nov 2006
		terminal	:= _protocol.terminal;
		code 		:= terminal.getConfig(PortDestCode).String;
		fCode		:= self.getXlatedForeignCode(_protocol.operatorXlationCode, code, XLATION_TYPE_PORT_BYOP, terminal);

		self.makeTDT1Segment (_protocol, _group, null, '3', null, fCode[1:17], null, null, null, null, terminal.code, '172', 'ZZZ', null); 			
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_activity" type="Integer"/>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="makeMessages" id="6eabaac3-1065-41fe-9df5-925bcc15064a">
        <source>makeMessages(_trackedItem:CM_TrackedItem; _transaction: CM_TITransaction; _camProtocol: CM_CamProtocol; _camMessage: CM_CamMessage input; _xlVoyageId: String; _terminal: CM_Terminal; _secondTrx : CM_TITransaction);

// 10/02/2011	cnwcs5	CCMS JMT 1977/PAR 26531 - changed _camMessage parameter usage from io to input
// 18/05/2011	cnwcs5	ccms sct 2058/par27460 - user defined special characters
// 30/05/2016	cnwdap1	TFS #2061 COPARN/CODECO/COARRI/EDI VGM Updates
// 15/07/2016   cnwma1  TFS #2376 POL - CODECO NAD lines in wrong segment and doubling up on information
// 06/12/2016   cnwma1	TFS #3018:POL - LOC+165 line duplicating in Maersk CODECO
// 19/05/2017   cnwma1	TFS #4364:POL - MSK CODECO LOC-165 segments ##2913##
// 07/07/2017	cnwdap1	TFS 4492 SNO VERMAS Changes
//23/08/2017	cnwma1  TFS #5834-PNL - EDI Translation - ISO Code foreign out
// 07/09/2017	jlgdap1	TFS 6880 POL Remove extra VGM details for Maersk
// 11/09/2017	jlgdap1	TFS 6906 Reinstate VGM NAD segments for Gate In messages 
// 19 Sep 2017	jlgrs1	TFS 6957 Codeco/Coarri VGM extra details
// 26 Jan 2048  cnwma1	ChangeRequest 36584: POL - Maersk Codeco Equipment Status Code Update
// 23 Nov 2018	jlgsl4	TFS 41640 - PNL - output IMEX from time of transaction
// 21 Jun 2022	jlizm1	TFS 53754 LNX Different local and server time zones causing incorrect edi outputs
vars
	fCode 			: String;
	code 			: String;
	pCode 			: String;
	imExStatus		: String;
	ti 				: CM_TrackedItem;
	availGrade 		: String;
	contentsStatus 	: String;
	foundMatch : Boolean;
	isoCode,fIsoCode : String;
	includeVGM : Boolean;
	imexStatus 		: String;
	eQDPosvalue	    : String;
	len             : Integer;
	snapshot : CM_TISnapShot; // TFS 41640
begin
// MSK
	ti	:=	_trackedItem;
	if _camProtocol.useVGM and 
	   ti &lt;&gt; null and 
	   ti.isWeightCertified and 
	   not ti.isEmpty then		// TFS #2061
		if _camMessage.activity = CODECO_GATEIN or 
		   _camMessage.activity = CODECO_GATEINFULL then	// TFS 6960
			includeVGM := true;
		endif;
	endif;
	contentsStatus := self.contentsStatusToString(_transaction.contentsStatus, _camMessage.activity, _transaction.type);
	
	if ti.cargoType = TI_CargoType_Container then
		if contentsStatus = "5" then			
			// cnwrl1 19/10/2010 PAR 25867 - start of replacement coding
			// set up the potential group of GID, TMP, SGP and DGS records.
			if ti.CM_Container.getTemperature &lt;&gt; NULL_TEMPERATURE or ti.allTIHazards.isNotEmpty then
				// GID+ - Goods Item Details
				self.makeGIDSegment (_camProtocol, _camMessage.group3, 1);	// par 27460 09/05/2011 cnwcs5 
				// TMP Segment
				self.makeTMPSegment (_camProtocol, _camMessage.group3, 2, ti.getTemperature, "CEL");	// par 27460 17/05/2011 cnwcs5 	
				// Split Goods Placement
				self.makeSGPSegment (_camProtocol, _camMessage.group3, ti.id.trimRight, null);		// par 27460 09/05/2011 cnwcs5 	
				// ie Dangerous Goods
				if not _camProtocol.dgsDetailsInGroup14  then							//JIRA-20814
					self.makeMessageHazardsData (ti, _camProtocol, _camMessage.group3);	// par 27460 09/05/2011 cnwcs5 	
				endif;																	//JIRA-20814
			endif;
		endif;
		// EQD segment
		if contentsStatus = "5" then
			imExStatus := self.imExStatusToString(ti); //full
			self.getRelevantSnapshot(ti, _transaction, snapshot); // TFS 41640
			if snapshot &lt;&gt; null then // TFS 41640 - for snapshotted transactions
				imExStatus := snapshot.getImexCAMS(); // TFS 41640
			endif; // TFS 41640
		else
			if _camMessage.activity = CODECO_UNPACK then //ccms 1499 par 13282 rs1 Jan 2007
				imExStatus := "3";
			else
				imExStatus := ""; //empty
			endif;
		endif;
		//self.makeEQDSegment (_camProtocol, _camMessage.group5, "CN", ti.id.trimRight, ti.CM_Container.isoType, '102', '5', null, imExStatus, contentsStatus);//23/08/2017 cnwma1 TFS #5834
		isoCode := ti.CM_Container.isoType;
		fIsoCode := self.getXlatedForeignCode(_camProtocol.operatorXlationCode, isoCode, XLATION_TYPE_ISOTYPE_BYOP, _terminal);
	
		// 26.01.2018  cnwma1  36584
		eQDPosvalue := _terminal.getConfig(EDIMSKCODECOEQDpos).String;
		if eQDPosvalue &lt;&gt; null then
			len := eQDPosvalue.length();
			if ti.bookingReference &lt;&gt; null 
			and ti.bookingReference.length &gt;= len 
			and ti.bookingReference[1:len] = eQDPosvalue then
				imExStatus := "8"; // POSITIONING
			endif;
		endif;
		// 26.01.2018  cnwma1  36584
		self.makeEQDSegment (_camProtocol, _camMessage.group5, "CN", ti.id.trimRight, fIsoCode, '102', '5', null, imExStatus, contentsStatus); //23/08/2017 cnwma1 TFS #5834
		_camMessage.eqdCount := _camMessage.eqdCount + 1;
		
		// RFF+BN
		self.makeMessageRFF_BN (_camProtocol, _camMessage.group5, _camMessage.activity, ti, _transaction);	// par 27460 cnwcs5

		// RFF+CN - special18 field
		self.makeMessageRFF_CN (_camProtocol, _camMessage.group5, ti);	// par 27460 cnwcs
		
		// RFF+ER CCMS1517 cnwrs1 Jan 2007 
		if _camMessage.activity = CODECO_EDIT then
			self.makeRFFSegment (_camProtocol, _camMessage.group5, "ER",  "SUR" );	// par 27460 17/05/2011 cnwcs5 			
		endif;
	
		// if creating extra messages for pack/unpack add 1 minute to the second message
		self.makeDTMSegment(_camProtocol, _camMessage.group5, '7', self.transDateTime(_transaction, _camMessage.activity, _camProtocol), '203');	// TFS 53754
		
		if includeVGM and
		   _camProtocol.getIncludeExtraVGM then
			self.makeMessageDTM_VGM(_camProtocol, _camMessage.group5, ti);					// TFS 4492
		endif;
	
		if _camMessage.activity = CODECO_GATEIN then
			// LOC segments
			self.makeMessageLOC_GATEIN (_camProtocol, _camMessage.group5, _camMessage.activity, ti, contentsStatus);	// par 27460, cnwcs5
	
		elseif _camMessage.activity = CODECO_GATEOUT then
			// LOC segments
			self.makeMessageLOC_GATEOUT (_camProtocol, _camMessage.group5, _camMessage.activity, ti, contentsStatus);	// par 27460, cnwcs5		
		elseif _camMessage.activity = CODECO_PACK then//for CCMS 1475
			code := ti.dischargePort.trimRight();
			if code = "" then
				code := ti.destinationPort.trimRight();
			endif;
			pCode := self.getXlatedForeignCode(_camProtocol.operatorXlationCode.trimBlanks(), code, XLATION_TYPE_PORT_BYOP, _terminal);
			if pCode = "" then
				pCode := code;
			endif;
			self.makeLOCSegment (_camProtocol, _camMessage.group5, '11', pCode.trimRight, '139', '6', null, null, null);	// par 27460 09/05/2011 cnwcs5 			

		elseif _camMessage.activity = CODECO_UNPACK then//ccms 1499 cnwrs1 nov 2006
			code := ti.loadPort.trimRight();
			pCode := self.getXlatedForeignCode(_camProtocol.operatorXlationCode.trimBlanks(), code, XLATION_TYPE_PORT_BYOP, _terminal);
			if pCode = "" then
				pCode := code;
			endif;
			self.makeLOCSegment (_camProtocol, _camMessage.group5, '9', pCode.trimRight, '139', '6', null, null, null);	// par 27460 09/05/2011 cnwcs5 			
		endif;
		
		code := _terminal.getConfig(PortDestCode).String;
		fCode := self.getXlatedForeignCode(_camProtocol.operatorXlationCode, code, XLATION_TYPE_PORT_BYOP, _terminal);
		
		// LOC+165
		self.makeLOCSegment (_camProtocol, _camMessage.group5, '165', fCode, '160', '20', null, null, null);	// par 27460 09/05/2011 cnwcs5 			
		
		//MEA+ segment
		self.makeMEASegmentForTotalWeight(_camProtocol, _camMessage.group5,ti,_transaction); //epr par 37551 TFS 1429 16/2/16
			
		// DIM+ segements
		self.makeMessageDimensionsData (_camProtocol, _camMessage.group5, ti);		// par 27460 17/05/2011 cnwcs5

		// SEL+ ( ccms 1393 originally)
		self.makeMessageSealsData (ti, _camMessage, _camMessage.group5, _camProtocol, contentsStatus);
		
		// FTX+AAI
		self.makeMessageFTX_DeliveryReason (_camProtocol, _camMessage.group5, ti);	// par 27460 cnwcs5	
		if includeVGM and
		   _camProtocol.getIncludeExtraVGM then
			self.makeMessageFTX_VGM(_camProtocol, _camMessage.group5, ti);					// TFS 4492
		endif;

		// EQA - the only attached equipment is a reefer generator
		self.makeEQASegment (_camProtocol, _camMessage.group5, 'RG', ti);	// par 27460 09/05/2011 cnwcs5
		
		// TDT+1
		self.makeMessageTDT1Segment (_camProtocol, _camMessage.group5, _camMessage.activity, _transaction, ti); // par 27460 09/05/2011 cnwcs5	

		/*if _camMessage.activity = CODECO_UNPACK then//ccms1499 cnwrs1 nov 2006           //06/12/2016 cnwma1	 TFS #3018
			// LOC+165
			code := _terminal.getConfig(PortDestCode).String;
			fCode := self.getXlatedForeignCode(_camProtocol.operatorXlationCode, code, XLATION_TYPE_PORT_BYOP, _terminal);
			self.makeLOCSegment (_camProtocol, _camMessage.group5, '165', fCode, '160', '20', null, null, null);	// par 27460 09/05/2011 cnwcs5 	
		endif;*/
		
	//ccms1500 add generator support to Maersk Codeco rs1 dec 2006
	elseif ti.cargoType = TI_CargoType_Generator then
		// EQD+RG
		//self.makeEQDSegment (_camProtocol, _camMessage.group5, "RG", ti.id.trimRight, ti.CM_Generator.isoType, '102', '5', null, null, '4'); // par 27460 17/05/2011 cnwcs5 
		// 26.01.2018  cnwma1  36584
		imExStatus := "";
		eQDPosvalue := _terminal.getConfig(EDIMSKCODECOEQDpos).String;
		if eQDPosvalue &lt;&gt; null then
			len := eQDPosvalue.length();
			if ti.bookingReference &lt;&gt; null 
			and ti.bookingReference.length &gt;= len 
			and ti.bookingReference[1:len] = eQDPosvalue then
				imExStatus := "8"; // POSITIONING
			endif;
		endif;

		/*// 26.01.2018  cnwma1  36584
		self.makeEQDSegment (_camProtocol, _camMessage.group5, "RG", ti.id.trimRight,    
							ti.CM_Generator.myOperator.getXlationForeignCode(ti.CM_Generator.isoType,XLATION_TYPE_ISOTYPE_BYOP,foundMatch),
							'102', '5', null, null, '4');  //23/08/2017 cnwma1 TFS #5834
		*/
		// 26.01.2018  cnwma1  36584
		self.makeEQDSegment (_camProtocol, _camMessage.group5, "RG", ti.id.trimRight, 
							ti.CM_Generator.myOperator.getXlationForeignCode(ti.CM_Generator.isoType,XLATION_TYPE_ISOTYPE_BYOP,foundMatch),
							'102', '5', null, imExStatus, '4'); 
							
		// DTM+7
		self.makeDTMSegment(_camProtocol, _camMessage.group5, '7', self.transDateTime(_transaction, _camMessage.activity, _camProtocol), '203');	// TFS 53754
		
		// TDT+1
		self.makeMessageTDT1Segment (_camProtocol, _camMessage.group5, _camMessage.activity, _transaction, ti); // par 27460 09/05/2011 cnwcs5
		
		// LOC+165
		code := _terminal.getConfig(PortDestCode).String;
		fCode := self.getXlatedForeignCode(_camProtocol.operatorXlationCode, code, XLATION_TYPE_PORT_BYOP, _terminal);
		self.makeLOCSegment (_camProtocol, _camMessage.group5, '165', fCode, '160', '20', null, null, null);	// par 27460 09/05/2011 cnwcs5 	
	endif;
	
	// CCMS1517 cnwrs1 Jan 2007
	if _camMessage.activity = CODECO_EDIT then
		code := _terminal.getConfig(PortDestCode).String;
		fCode := self.getXlatedForeignCode(_camProtocol.operatorXlationCode.trimBlanks(), code, XLATION_TYPE_PORT_BYOP, _terminal);
	//	self.makeLOCSegment (_camProtocol, _camMessage.group5, '165', fCode, '160', '20', null, null, null);	// par 27460 09/05/2011 cnwcs5 	//19/05/2017 cnwma1 TFS #4364
		self.checkEditForStatusChange(_transaction, availGrade);
		// this next segment used to be RFF but that was wrong so it has changed back to FTX
		self.makeFTXSegment (_camProtocol, _camMessage.group5, "AAA", null, null,availGrade.trimRight()); 	// par 27460 17/05/2011 cnwcs5 
	endif;
	
	// TFS 6880 remove all extra VGM data for Maersk CODECO
	// TFS 6906 Reinstate NAD segments for Gate In messages
	// TFS #2061 NDA for VGM																			// TFS #2061
	if includeVGM then				// TFS #2061
		self.makeMessageNAD_VGM(_camProtocol, _camMessage.group5, ti);									// 15/07/2016 cnwma1  TFS #2376
	endif;																								// TFS #2061
	
	// ie Dangerous Goods													//JIRA-20814
	if _camProtocol.dgsDetailsInGroup14  then								//JIRA-20814
		self.makeMessageHazardsData (ti, _camProtocol, _camMessage.group5);	//JIRA-20814
	endif;																	//JIRA-20814
end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camMessage" type="CM_CamMessage" usage="input"/>
        <Parameter name="_xlVoyageId" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_secondTrx" type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="outputFile" id="558284c5-a6e6-4b91-af96-8a3f5851ce53">
        <updating/>
        <source>outputFile(_protocol : CM_CamProtocol input; _camAgent : CM_CamControllerAgent; _camFile : CM_CamFile input; _runDateTime : TimeStamp; _camTaskHistory : CM_CamTaskHistory input;
		   _unhSeqNumber : Integer io; _seqNumber : Integer; _terminal : CM_Terminal; _contextObj : CM_Object; _transactions : CM_TITransactionSet) updating;
/*
Date		Who		Reason
11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks
10/02/2011	cnwcs5	CCMS JMT 1977/PAR 26531 - changed _camFile/_camTaskHistory parameter usage from io to input
16/05/2011	cnwcs5	CCMS SCT 2058 / PAR 27460 - user defined speecial characters
18 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
30 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
20/12/2012	cnwcs5	CCMS SFW 1294 /par 30855
29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
25 Feb 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
09 Jan 2020	jlgdap1	TFS 48016 SNO Deletion CODECO - new _transactions parameter
*/
vars
	camVoyage 				: CM_CamVoyage;
	camMessage 				: CM_CamMessage;
	dynaDict				: DynaDictionary;
	object					: Object;
	una, unb				: String;
	headerColl, trailerColl	: HugeStringArray;	
	strLine : String;
begin // MSK
/*============================================================
  Maersk Values for element 1001

  Gate In   BGM+34
  Gate Out  BGM+36
--------------------------------------------------------------*/
	create dynaDict transient;
	dynaDict.setMembership(CM_CamMessage);
	dynaDict.addMemberKey(CM_CamMessage::activity.name,true,false);
	dynaDict.addMemberKey(CM_CamMessage::dateTime.name,false,false);
	dynaDict.endKeys(true);
	
	app.writeLog("===================================", LogWARN);

	// UNA Segment
	una := self.outputHeader_UNA (_protocol, _camTaskHistory);
	strLine := strLine &amp; una;
	//UNB header
	unb := self.outputHeader_UNB (_protocol, _camTaskHistory, _seqNumber, null, _contextObj);
	strLine := strLine &amp; unb;
	
	if _camFile.camVoyages.size &gt; 0 then
		foreach camVoyage in _camFile.camVoyages do
		
			dynaDict.clear;
			
			foreach camMessage in camVoyage.camMessages do
				if camMessage.group3.size = 0 and camMessage.group5.size = 0 then
					continue;
				endif;
				
				dynaDict.add(camMessage);
			endforeach;
			
			foreach object in dynaDict do
				camMessage := object.CM_CamMessage;
				
				headerColl 	:= camMessage.header;
				trailerColl	:= camMessage.trailer;
				
				if una &lt;&gt; null then
					headerColl.add (una);
				endif;
				
				if unb &lt;&gt; null then
					headerColl.add (unb);
				endif;
				
				//BGM header
				strLine := strLine &amp; self.outputHeader_UNH_BGM (camMessage, _camTaskHistory, _camFile, _unhSeqNumber, headerColl);

				// CCMS1517 cnwrs1 jan 2007
				if camMessage.activity &lt;&gt; CODECO_EDIT then
					//TDT header
					strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeMessageTDT20Segment (_protocol, camVoyage, 0), headerColl);
	
					camMessage.segmentCount := camMessage.segmentCount + 1;
	
					//LOC1 header
					strLine := strLine &amp; self.outputHeader_LOC (_protocol, camMessage, _camTaskHistory, _terminal, headerColl);
				endif;
				
				//NAD header
				strLine := strLine &amp; self.outputHeader_NAD (_protocol, camMessage, _camTaskHistory, headerColl);
				
				//now give them all of the messages
				strLine := strLine &amp; self.outputFileGroup (_camTaskHistory, camMessage.group3, camMessage.segmentCount);
				strLine := strLine &amp; self.outputFileGroup (_camTaskHistory, camMessage.group5, camMessage.segmentCount);

				//CNT segment for message
				strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeCNTSegment (_protocol, 16, camMessage.eqdCount), trailerColl);

				camMessage.segmentCount := camMessage.segmentCount + 2;
				
				// UNT segment
				strLine := strLine &amp; self.outputTrailer_UNT (_protocol, _camTaskHistory, camMessage.segmentCount, _unhSeqNumber, trailerColl);
				
				camMessage.segmentCount := 0;
			endforeach;
		endforeach;
		
		//set unhSeq here
		_protocol.setUNHSeqNum(_unhSeqNumber);
	endif;
	
	//UNZ segement for file
	strLine := strLine &amp; self.outputTrailer_UNZ (_protocol, _camTaskHistory, _camFile.messageCount, _seqNumber, null);

	app.writeLog(_protocol.code &amp; " File contains " &amp; _camFile.messageCount.String &amp; " messages.", LogWARN);
	app.writeLog("===================================", LogWARN);
	_camTaskHistory.setRawDataString(strLine);
epilog
	delete dynaDict;		// PAR #26678
end;</source>
        <Parameter name="_protocol" type="CM_CamProtocol" usage="input"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent"/>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
        <Parameter name="_runDateTime" type="TimeStamp"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_unhSeqNumber" type="Integer" usage="io"/>
        <Parameter name="_seqNumber" type="Integer"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_contextObj" type="CM_Object"/>
        <Parameter name="_transactions" type="CM_TITransactionSet"/>
    </JadeMethod>
    <JadeMethod name="outputHeader_LOC" id="9803693b-49d1-4368-8a50-5a5cda27f8bb">
        <updating/>
        <source>outputHeader_LOC(_protocol :CM_CamProtocol; _camMessage :CM_CamMessage input; _camTaskHistory :CM_CamTaskHistory input; _terminal :CM_Terminal; _coll :HugeStringArray input) : String updating, protected;
/*
Date		Who		Reason
20/12/2012	cnwcs5	CCMS SFW 1294 /par 30855
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
//25 Feb 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
vars
	code, fCode	:String;
	strLine : String;
begin
	code 	:= _terminal.getConfig(PortDestCode).String.trimRight;
	fCode 	:= self.getXlatedForeignCode(_protocol.operatorXlationCode.trimBlanks, code, XLATION_TYPE_PORT_BYOP, _terminal).trimRight;
	
	if _camMessage.activity = CODECO_GATEOUT or _camMessage.activity = CODECO_UNPACK then
		strLine := strLine &amp; self.outputFileMessage (_camTaskHistory, self.makeLOCSegment (_protocol, null, '11', fCode, '139', '6', null, null, null), _coll);
		
	elseif _camMessage.activity = CODECO_PACK then//for CCMS 1475
		strLine := strLine &amp; self.outputFileMessage (_camTaskHistory, self.makeLOCSegment (_protocol, null, '9', code, '139', '6', null, null, null), _coll);
		
	else
		strLine := strLine &amp; self.outputFileMessage (_camTaskHistory, self.makeLOCSegment (_protocol, null, '9', fCode, '139', '6', null, null, null), _coll);
	endif;
	
	_camMessage.segmentCount := _camMessage.segmentCount + 1;
	return strLine;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_camMessage" type="CM_CamMessage" usage="input"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="outputHeader_NAD" id="173c0b4e-cafd-459a-90ad-161f883fc500">
        <updating/>
        <source>outputHeader_NAD (_protocol :CM_CamProtocol; _camMessage :CM_CamMessage input; _camTaskHistory :CM_CamTaskHistory input; _coll :HugeStringArray input) : String updating, protected;
/*
Date		Who		Reason
20/12/2012	cnwcs5	CCMS SFW 1294 /par 30855
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
//25 Feb 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
vars
	camISOPortDesc :String;
	strLine : String;
begin
	strLine := strLine &amp; self.outputFileMessage (_camTaskHistory, self.makeNADSegment (_protocol, null, "CF", _protocol.camGroup.shippersCode.trimBlanks, '160', '20'), _coll);
	
	_camMessage.segmentCount := _camMessage.segmentCount + 1;
	
	camISOPortDesc := self.getCamISOPortDesc (_protocol);
	
	if _camMessage.activity = CODECO_PACK then//for CCMS 1475			
		strLine := strLine &amp; self.outputFileMessage (_camTaskHistory, self.makeNADSegment (_protocol, null, "SLS", '981003', '172', '20'), _coll);
		
		_camMessage.segmentCount := _camMessage.segmentCount + 1;
	else
		strLine := strLine &amp; self.outputFileMessage (_camTaskHistory, self.makeNADSegment (_protocol, null, "SLS", camISOPortDesc, '172', '20'), _coll);
		
		_camMessage.segmentCount := _camMessage.segmentCount + 1;
	endif;
	return strLine;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_camMessage" type="CM_CamMessage" usage="input"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="outputHeader_UNH_BGM" id="c9c54066-1981-4664-ba79-def1f08a5d2c">
        <updating/>
        <source>outputHeader_UNH_BGM(_camMessage: CM_CamMessage input; _camTaskHistory: CM_CamTaskHistory input; _camFile: CM_CamFile input; _unhSeqNumber: Integer io; _coll: HugeStringArray input) : String updating, protected;
/*
Date		Who		Reason
20/12/2012	cnwcs5	CCMS SFW 1294 /par 30855
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
//25 Feb 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
vars
	strLine : String;
begin
	if _camMessage.activity = CODECO_PACK then//for ccms 1475
		strLine := strLine &amp; self.makeMessageHeader(_camFile, _camTaskHistory, _unhSeqNumber, "999", "CODECO", _coll);
		
		_camMessage.segmentCount := _camMessage.segmentCount + 2;
	elseif _camMessage.activity = CODECO_UNPACK then//ccms1499 cnwrs1 nov 2006
		strLine := strLine &amp; self.makeMessageHeader(_camFile, _camTaskHistory, _unhSeqNumber, "999", "CODECO", _coll);
		
		_camMessage.segmentCount := _camMessage.segmentCount + 2;
	elseif _camMessage.activity = CODECO_EDIT then//for ccms 1475
		strLine := strLine &amp; self.makeMessageHeader(_camFile, _camTaskHistory, _unhSeqNumber, "999", "CODECO", _coll);
		
		_camMessage.segmentCount := _camMessage.segmentCount + 2;
	else
		return inheritMethod(_camMessage, _camTaskHistory, _camFile, _unhSeqNumber, _coll);
	endif;
	return strLine;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_camMessage" type="CM_CamMessage" usage="input"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
        <Parameter name="_unhSeqNumber" type="Integer" usage="io"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="processTransaction" id="371fc314-8636-43d8-9592-ddb136768784">
        <updating/>
        <source>processTransaction(_transaction : CM_TITransaction; _camProtocol : CM_CamProtocol; _camAgent : CM_CamControllerAgent input; _camFile : CM_CamFile input) updating;
// 12/05/2010	cnwcs5	par 23967 - change _camFile paremeter to be input not io so as to correctly reflect its usage
//12 Jul 2012	cnwrs1	CCMS 1269 CAMS reduce number of Trxs
//18 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
//30 Aug 2012	cnwkpd1	PAR #28731 - Transient leaks in JMT
// 04 Feb 2013	cnwcs5	CCMS SFW 1294 /par 30855
//20 dec 2016	cnwrs1	TFS 3158 Cams Exclusion report does not include the rehandles and sobs
vars
	camMessage			: CM_CamMessage;
	messageTypeArray	: IntegerArray;
	messageType			: Integer;
	xlVoyageId			: String;
	contentsStatus		: String;
	arrayPos3			: Integer;
	arrayPos4			: Integer;
	arrayPos5			: Integer;
	theTI				: CM_TrackedItem;
	childObj			: CM_TrackedItem;
	vesselName			: String; //par18987 cnwrs1 Mar 2007
	children			: CM_TISet; //PAR 22954
	firstTime			: Boolean;			// cnwrl1 05/08/2010 PAR 21961
	
begin
	_camAgent.writeDebugLog(class.name&amp;'::'&amp;method.name&amp;" process "&amp;_transaction.getCamsDisplayDetails);

	create messageTypeArray transient;

	//get the translated voyage Code
	xlVoyageId := self.getVoyageCode(_transaction, _camProtocol, vesselName);  //par18987 cnwrs1 Mar 2007
	
	// Only need to clear the camTask tiMessages for each new transaction not each messageType.
	firstTime	:= true;					// cnwrl1 05/08/2010 PAR 21961
	
	self.getMessageType(_transaction, messageTypeArray, _camProtocol, _camAgent);
	
	theTI := _transaction.myTrackedItem;
	
	if messageTypeArray.size &gt; 0 then
		foreach messageType in messageTypeArray do
			//CCMS1517 cnwrs1 Jan 2007
			if messageType = CODECO_EDIT then
				xlVoyageId := null;
			endif;
			
			camMessage := self.getCamMessage(_camFile, xlVoyageId, vesselName, messageType, _camProtocol.singleContainerPerBGM); //ccms1747 cnwrs1 aug 2008 
			
			if camMessage &lt;&gt; null then
				if _transaction.myTrackedItem.cargoType = TI_CargoType_Container then
					//par 16040 cnwrs1 Mar 2008
					contentsStatus := self.contentsStatusToString(_transaction.contentsStatus, camMessage.activity, _transaction.type);
				endif;
				
				arrayPos3 := camMessage.group3.size();
				arrayPos4 := camMessage.group4.size();
				arrayPos5 := camMessage.group5.size();
				
				camMessage.camVoyage.voyageOid := _transaction.myTrackedItem.myVoyage;
				
				camMessage.dateTime := self.transDateTime(_transaction, camMessage.activity, _camProtocol);
				
				self.makeMessages(theTI, _transaction, _camProtocol, camMessage, xlVoyageId, _camProtocol.terminal, null);
				camMessage.setupCAMSInfoDetails(_camProtocol, arrayPos3, arrayPos4, arrayPos5, _transaction);	//12 Jul 2012	cnwrs1	CCMS 1269 CAMS reduce number of Trxs
				
				firstTime	:= false;
				
				delete children;
				create children transient;//PAR 22954
				
				if _camProtocol.isIncludeChild then
					
					foreach childObj in theTI.allChildren do//PAR 25103 - cnwsh3 allChildren is now unprotected so we reference it directly. Reverses PAR22954.
						self.makeMessages(childObj, _transaction, _camProtocol, camMessage, xlVoyageId, _camProtocol.terminal, null);
						camMessage.setupCAMSInfoDetails(_camProtocol, arrayPos3, arrayPos4, arrayPos5, _transaction);	//12 Jul 2012	cnwrs1	CCMS 1269 CAMS reduce number of Trxs
					endforeach;
				endif;
			else
				if _camAgent.logExcludedTransactions then
					_camAgent.logReasonForExclusion(_transaction, "CAM Message is null " &amp; _transaction.String &amp; ".");
				endif;
			endif;
		endforeach;
	endif;
epilog
	if messageTypeArray &lt;&gt; null then
		delete messageTypeArray;
	endif;
	delete children;
end;
</source>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent" usage="input"/>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
    </JadeMethod>
    <JadeMethod name="transDateTime" id="03724f32-8304-40b8-8342-1c6e6d2cf25f">
        <source>transDateTime(_transaction : CM_TITransaction; _activity : Integer; _camProtocol : CM_CamProtocol): TimeStamp;

vars
	dateTime: TimeStamp;
	
begin
	dateTime := _transaction.dateTime;
	
	if (_transaction.isCamsPackType() and
	   _activity = CODECO_GATEIN) or
	   (_transaction.isCamsUnpackType() and
	   _activity = CODECO_GATEOUT) then
		//tranTime.setTime(tranTime.hour, tranTime.minute+1, tranTime.second, 0);// add minute to pack SNT time so it does not match pack RCV time
		//dateTime.setTime(tranTime);
		dateTime.addMinutes(1);		// 12/03/2013 cnwar2 #31281
		
		//08 Sep 2015	NDL	Par 36876
		if _camProtocol &lt;&gt; null then
			if self.useDelayMinutes and _camProtocol.delayMinutes &gt; 0 then
				dateTime := dateTime.addMinutes( _camProtocol.delayMinutes );
			endif;
		endif;
	
		return dateTime;
	endif;

 	return inheritMethod(_transaction, _activity, _camProtocol);
end;</source>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_activity" type="Integer"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
</Class>
