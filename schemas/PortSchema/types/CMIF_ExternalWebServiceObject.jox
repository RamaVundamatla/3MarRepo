    <JadeMethod name="setFromXML" id="e40dc438-72a3-4289-8968-0603c0c7ac9a">
        <updating/>
        <source>setFromXML(_xmlElement: JadeXMLElement input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09/04/2019	jlger1	Initial creation 44298
18/06/2019	jlgdap1	TFS 45221 PEL1 H2H Monitoring Report - Multiple Estimations
*/

vars
	childElement : JadeXMLElement;
	properties : PropertyNDict;
	prop : Property;
	collPropName : String;
	childNode : JadeXMLNode;
	foundChildNode : Boolean;
	childObjects : Collection;
	obj : Object;
	iter: Iterator;
	childClass : Class;
	propertySoapTag : String;
begin
	if _xmlElement = null then
		return;
	endif;
	
	properties:=self.class.getProperties();
	foreach prop in properties do
		childElement:=_xmlElement.getElementByTagName(prop.name.cnToUpperFirst);
		if childElement &lt;&gt; null then
			self.setPropertyValue(prop.name,childElement.textData);
		else
			foundChildNode:=false;
			if  prop.name.startsWith("all") then
				collPropName:=prop.name.trimCharacters("all");
				collPropName:=collPropName.cnToUpperFirst;
				foreach childNode in _xmlElement.childNodes do
					if childNode.isKindOf(JadeXMLElement) then
						if childNode.JadeXMLElement.localName.endsWith(collPropName) then
							
							foundChildNode:=true;
							break;							// TFS 45221
						endif;
					endif;
				endforeach;
				if not foundChildNode then
					propertySoapTag:=self.getSoapTagForProperty(prop);
					if propertySoapTag &lt;&gt; null then
						childNode:=_xmlElement.getElementByTagName(propertySoapTag);
						foundChildNode:=childNode&lt;&gt;null;
					endif;
				endif;
				if foundChildNode then
					if prop.type.isKindOf( CollClass) then
						childClass := prop.type.CollClass.memberType.Class;
						childElement:=childNode.JadeXMLElement;
						foreach childNode in childElement.childNodes do
							if childNode.isKindOf(JadeXMLElement) then
								create obj as childClass transient;
								obj.sendMsgWithParams(method.name,childNode.JadeXMLElement);

								childObjects:= self.getPropertyValue(prop.name).Collection;
								if childObjects &lt;&gt; null then
									childObjects.add(obj);
								endif;
							endif;
						endforeach;
					endif;
				endif;
			endif;
		endif;
		
	endforeach;
	
epilog
	
end;</source>
        <Parameter name="_xmlElement" type="JadeXMLElement" usage="input"/>
    </JadeMethod>
</Class>
