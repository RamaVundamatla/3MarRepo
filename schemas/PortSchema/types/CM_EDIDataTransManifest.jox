    <JadeMethod name="getEDIDataTypeChildren" id="266dec70-26e6-4f05-9ed1-218a93fe0b33">
        <source>getEDIDataTypeChildren(_ediDataType: Integer; _childrenDataTypes: IntegerArray input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Nov 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
*/

vars

begin
	if _ediDataType = EDIDataType_JMTInternal then
		_childrenDataTypes.add(EDIDataType_TransportManifest);
	elseif _ediDataType = EDIDataType_TransportManifest then
		_childrenDataTypes.add(EDIDataType_CargoOnSite);
		_childrenDataTypes.add(EDIDataType_GateDocument);
		_childrenDataTypes.add(EDIDataType_ShipManifest);
		_childrenDataTypes.add(EDIDataType_TrainConsist);
	elseif _ediDataType = EDIDataType_CargoOnSite then
		_childrenDataTypes.add(EDIDataType_TIHazDets);
		_childrenDataTypes.add(EDIDataType_TISeal);
	elseif _ediDataType = EDIDataType_GateDocument then
		_childrenDataTypes.add(EDIDataType_BookingHeader);
		_childrenDataTypes.add(EDIDataType_Prenote);
	elseif _ediDataType = EDIDataType_BookingHeader then
		_childrenDataTypes.add(EDIDataType_BookingItem);
	elseif _ediDataType = EDIDataType_Prenote then
		_childrenDataTypes.add(EDIDataType_TIHazDets);
		_childrenDataTypes.add(EDIDataType_TISeal);
	elseif _ediDataType = EDIDataType_ShipManifest then
		_childrenDataTypes.add(EDIDataType_BOLHdr);
		_childrenDataTypes.add(EDIDataType_CargoOnShip);
	elseif _ediDataType = EDIDataType_BOLHdr then
		_childrenDataTypes.add(EDIDataType_BOLDtl);
	elseif _ediDataType = EDIDataType_CargoOnShip then
		_childrenDataTypes.add(EDIDataType_TIHazDets);	//22 Nov 2016	NDL	TFS 2843 / 2604
		_childrenDataTypes.add(EDIDataType_TISeal);
	elseif _ediDataType = EDIDataType_TrainConsist then
		_childrenDataTypes.add(EDIDataType_Train);
	elseif _ediDataType = EDIDataType_Train then
		_childrenDataTypes.add(EDIDataType_Wagon);
		_childrenDataTypes.add(EDIDataType_Prenote);
	elseif _ediDataType = EDIDataType_Prenote then
		_childrenDataTypes.add(EDIDataType_TISeal);
		_childrenDataTypes.add(EDIDataType_TIHazDets);		//11 Dec 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
	endif;

epilog

end;</source>
        <Parameter name="_ediDataType" type="Integer"/>
        <Parameter name="_childrenDataTypes" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getEDITIType" id="c3d90585-b1c6-4f75-8984-48acc983366e">
        <source>getEDITIType(_ediDataType: Integer): Class;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Oct 2023	jlirs1	TFS 59171 Transport Manifest User Defined Format
13 Nov 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
30 Jan 2024	jlirs1	TFS 62182 XSD Generation
*/

vars
	aSelf : CM_EDIDataTransManifest;
	aClass : Class;
begin
	if _ediDataType = EDIDataType_TransportManifest then
		return null;
	endif;
	if self.isTransient and
	   self.myCargoOnSite = null and
	   self.myGateDocument = null and
	   self.myShipManifest = null and
	   self.myTrainConsist = null then
		aSelf := self;
		aSelf.createTransientChildrenClasses;
	endif;
	if self.myCargoOnSite &lt;&gt; null then		//30 Jan 2024	jlirs1	TFS 62182 XSD Generation
		aClass := self.myCargoOnSite.getEDITIType(_ediDataType);
		if aClass = CM_EDICargoOnSiteTI and
		   _ediDataType &lt;&gt; EDIDataType_CargoOnSite then
			aClass := null;
		endif;
	endif;
	if self.myGateDocument &lt;&gt; null and
	   aClass = null then
		aClass := self.myGateDocument.getEDITIType(_ediDataType);
	endif;
	if self.myShipManifest &lt;&gt; null and
	   aClass = null then
		aClass := self.myShipManifest.getEDITIType(_ediDataType);
	endif;
	if self.myTrainConsist &lt;&gt; null and
	   aClass = null then
		aClass := self.myTrainConsist.getEDITIType(_ediDataType);
	endif;
	if aClass = null then
//		aClass := inheritMethod(_ediDataType);
	endif;
	return aClass;
epilog
	if aSelf &lt;&gt; null then
		aSelf.deleteTransientChildrenClasses;
	endif;
end;</source>
        <Parameter name="_ediDataType" type="Integer"/>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="getEDITITypes" id="92f612ad-811d-4ac7-a74d-0e508141c9b8">
        <source>getEDITITypes(_types: ClassColl input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 June 2023	navsp1	Initial creation TFS ChangeRequest 58054: EUP - Manifest Send EDI Endpoint
13 Nov 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
*/

vars
	aSelf : CM_EDIDataTransManifest;
begin
	if self.isTransient and
	   self.myCargoOnSite = null and
	   self.myGateDocument = null and
	   self.myShipManifest = null and
	   self.myTrainConsist = null then
		aSelf := self;
		aSelf.createTransientChildrenClasses;
	endif;
	if self.myCargoOnSite &lt;&gt; null then
		_types.add(CM_EDICargoOnSiteTI);
	elseif self.myGateDocument &lt;&gt; null then
		_types.add(CM_EDIBookingHeaderTI);
		_types.add(CM_EDIBookingItemTI);//Different in BRD
		_types.add(CM_EDIPrenoteTI);
		_types.add(CM_EDIHazDetailsTI);
		_types.add(CM_EDISealTI);
	elseif self.myShipManifest &lt;&gt; null then
		_types.add(CM_EDIBOLHdrTI);
		_types.add(CM_EDIBOLDtlTI);
		_types.add(CM_EDICargoOnShipTI);
		_types.add(CM_EDIHazDetailsTI);
		_types.add(CM_EDISealTI);
	elseif self.myTrainConsist &lt;&gt; null then
		_types.add(CM_EDIWagonTI);
		_types.add(CM_EDIPrenoteTI);
		_types.add(CM_EDISealTI);
	endif;
epilog
	if aSelf &lt;&gt; null then
		aSelf.deleteTransientChildrenClasses;
	endif;
end;</source>
        <Parameter name="_types" type="ClassColl" usage="input"/>
    </JadeMethod>
