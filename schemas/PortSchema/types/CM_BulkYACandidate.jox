    </ImplicitInverseRef>
    <JadeMethod name="buildCriteriaCMIF" id="0d0b49f0-8cd4-4b09-bbc9-527c237f3c4d">
        <source>buildCriteriaCMIF(_allTransientCriteriaObj : CMIF_Array input);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 20/08/2025	navdap1		Initial creation MTN-35615 ENS | Bulk Creation of Yard Allocations
//
vars
	proxyCriteria: CM_YACriteria;
	type : CM_YACriteriaType;
	itemCode : String;
	cmifCriteria : CMIF_YACriteriaPriority;

begin
	type := app.myRoot.allYACriteriaTypes[self.criteriaType];
	
	create proxyCriteria transient;
	itemCode := type.description.cnEcUpto(CM_YACriteriaPriority::code.length -1);
	proxyCriteria.setProxy(type, self.criteriaValue, itemCode);
	cmifCriteria := proxyCriteria.getTransient();
	cmifCriteria.setFlag(true, false, false);
	_allTransientCriteriaObj.add(cmifCriteria);

epilog

end;</source>
        <Parameter name="_allTransientCriteriaObj" type="CMIF_Array" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getCriteriaValueForDisplay" id="5beffd2e-13c1-45c1-a1c4-8f58d89caaa2">
        <source>getCriteriaValueForDisplay() : String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 08/09/2025	navdap1		Initial creation MTN-35615 ENS | Bulk Creation of Yard Allocations 
//
vars
	yaBoolean : CM_YADataBoolean;
	criteriaTypeObj : CM_YACriteriaType;
	displayValue : String;
	ti : CM_TrackedItem;

begin
	create yaBoolean transient;
	criteriaTypeObj := app.myRoot.allYACriteriaTypes[self.criteriaType];
	if criteriaTypeObj.isBooleanType then
		if self.criteriaValue.Integer = yaBoolean.VALUE_TRUE then
			displayValue := app.getErrorString(Yes);
		elseif self.criteriaValue.Integer = yaBoolean.VALUE_FALSE then
			displayValue := app.getErrorString(No);
		endif;
	elseif not criteriaTypeObj.isPrimitiveValue then
		// The value we have is an Oid - get the object matching the Oid
		if self.criteriaValue.asOid &lt;&gt; null then
			displayValue := criteriaTypeObj.getDisplay(self.criteriaValue.asOid);
		else
			ti := self.allMatchingTIs.first;
			displayValue := criteriaTypeObj.getDisplay(ti);
		endif;
		if criteriaTypeObj.isYATypeProduct then
			// Cargo Subtypes need the cargo type abbreviation as well
			displayValue := self.criteriaValue.asOid.CM_Product.myCargoType.abbreviation &amp; " - " &amp; displayValue;
		endif;
	else
		displayValue := self.criteriaValue;
	endif;
	
	return displayValue;
	
epilog
	delete yaBoolean;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCriteriaValueForYACreation" id="d5f455ce-b91c-4701-a007-d84a22e836f1">
        <source>getCriteriaValueForYACreation() : String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 15/09/2025	navdap1		Initial creation MTN-35615 ENS | Bulk Creation of Yard Allocations 
//
vars
	critType : CM_YACriteriaType;
	stopsByDesc : CM_StopsTableByHeadingIdDict;
	tokens : StringArray;
	str : String;
	stopTable : CM_StopsTable;
	rtnValue : String;
	toDoDesc : CM_ToDoTaskDesc;

begin
	critType := app.myRoot.allYACriteriaTypes[self.criteriaType];
	if critType.isYATypeStops() then
		create tokens transient;
		self.criteriaValue.getTokensForDelimiter(Comma.String, tokens);
		create stopsByDesc transient;
		app.myRoot.allStopsTable.copy(stopsByDesc);
		foreach str in tokens do
			stopTable := stopsByDesc.getAtKeyGeq(str, null);
			if stopTable = null or stopTable.shortHeading &lt;&gt; str then
				continue;
			endif;
			if rtnValue = null then
				rtnValue := stopTable.id.String;
			else
				rtnValue := rtnValue &amp; Comma &amp; stopTable.id.String;
			endif;
		endforeach;
		
		return rtnValue;
		
	elseif critType.isYATypeToDoTasks() then
		create tokens transient;
		self.criteriaValue.getTokensForDelimiter(Comma.String, tokens);
		foreach str in tokens do
			toDoDesc := app.myRoot.allToDoTaskDescsByShortDesc[str];
			if toDoDesc = null then
				continue;
			endif;
			if rtnValue = null then
				rtnValue := toDoDesc.shortDescription;
			else
				rtnValue := rtnValue &amp; Comma &amp; toDoDesc.shortDescription;
			endif;
		endforeach;
		
		return rtnValue;
		
	else
		return self.getCriteriaValueForDisplay();
	endif;
epilog
	delete tokens;
	delete stopsByDesc;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="4591b63a-4b4d-4b32-88f5-fe29bf6bf912">
        <updating/>
        <source>setForCreate(_pxyCandidate : CM_BulkYACandidate) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 19/08/2025	navdap1		Initial creation MTN-35615 ENS | Bulk Creation of Yard Allocations
//
vars

begin
	self.criteriaType := _pxyCandidate.criteriaType;
	self.criteriaValue := _pxyCandidate.criteriaValue;
	self.imexStatus := _pxyCandidate.imexStatus;
	self.myExistingYardAllocation := _pxyCandidate.myExistingYardAllocation;
	self.myTerminal := _pxyCandidate.myTerminal;
	
	_pxyCandidate.allMatchingTIs.copy(self.allMatchingTIs);
epilog

end;</source>
        <Parameter name="_pxyCandidate" type="CM_BulkYACandidate"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="f67ba527-31e8-4c00-bda7-c0edadf64a70">
        <updating/>
        <source>setProxy(	_type : Integer;
			_value : String;
			_imexStatus : Integer;
			_terminal : CM_Terminal;
			_matchingTIs : CM_TISet;
			_existingYACode : String;
			_results : CM_BulkYACandidateResults io	) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 19/08/2025	navdap1		Initial creation MTN-35615 ENS | Bulk Creation of Yard Allocations
//
vars

begin
	self.criteriaType := _type;
	self.criteriaValue := _value;
	self.imexStatus := _imexStatus;
	
	_matchingTIs.copy(self.allMatchingTIs);
	self.myExistingYardAllocation := _terminal.allYardAllocatonsByCode[_existingYACode];
	self.myTerminal := _terminal;
	
	_results.allCandidates.add(self);
epilog

end;</source>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_value" type="String"/>
        <Parameter name="_imexStatus" type="Integer"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_matchingTIs" type="CM_TISet"/>
        <Parameter name="_existingYACode" type="String"/>
        <Parameter name="_results" type="CM_BulkYACandidateResults" usage="io"/>
    </JadeMethod>
</Class>
