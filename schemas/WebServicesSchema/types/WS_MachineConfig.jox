    <JadeMethod name="create" id="353717f1-770f-4b87-bc6f-c6fc7fbd82cc">
        <updating/>
        <source>create() updating;
/* Changes

Date		Name	TFS#		Description
============================================================================
02 Jun 2017	cnwer1				Initial creation TFS
09 Oct 2019	jlgka1 	TFS 46449	JMT - Loadrite for the Vehicle App
15 Jul 2021	navdap1	TFS 51286	STWR Vehicle App Notification Message
01 Sep 2021 navma1 ChangeRequest 51485: PRP - Multi-Roll Pickup Enhancement
11 Nov 2021 navmj1  TFS 52272   POL - Pick Up Delay in Web Based Vehicle App
14 Dec 2021 navma1	ChangeRequest 52212: PRP - Vehicle App MultiMove - Autoplan on Pickup
28 Feb 2023	jlizm1	TFS 56720 	Running weight total for MAFIs
21 Mar 2023	jlika1	TFS 57126	CUX - Make VMT filtering configurable per RT Config
18 Mar 2025	navpw1	JIRA: MTN-34259 - Added a config option to be set on a vehicle basis to Retain Cargo Id in Driver Mode for Overstowed containers
============================================================================*/

vars
	config 		  : CM_RTVehicleConfig;
	machine 	  : CM_Machine;
	canChangeMode : Boolean;
	terminal 	  : CM_Terminal;
	taskField     : WS_QueueTaskField;
	entTableRow   : EntTableRow;
begin

	//jlier1 TFS 52595 20/12/21
	if currentSession = null then
		machine:=app.myPassport.myMachine;
	else
		machine:=currentSession.myCurrentMachine;
	endif;
	if machine = null then
		return;
	endif;
	
	self.cmObjectId 		:= machine.getOidAsString;
	self.cmObjectEdition	:= machine.edition();
	self.machineId 			:= machine.id;
	self.machineType		:= machine.machineTypeString;
	self.machineTypeCode	:= machine.machineType;			// TFS 56720
	//jlgka1 TFS 46449 --&gt;
	self.canCertifyWeight 	:= machine.canCertifyWeight;
	self.canWeigh		 	:= machine.canWeighCargo;
	//jlgka1 TFS 46449 &lt;--
	
	config:=machine.myTerminal.getRTVehicleConfigForObject(machine);
	if config &lt;&gt; null then
		self.canChangeQueue:= config.allowChangeQueue;
		self.canChangeTarget:=config.allowChangeSetdown;
		self.canDoDriverMoves:= config.allowNonRTMoves;
		if 	machine.machineType = MACHINETYPE_IMV then
			self.showList:=false;
		else
			self.showList:=config.isShowingList(canChangeMode);
		endif;
		
		//epr TFS 4830 20/6/17
		if config.myPrimaryTaskFields &lt;&gt; null then
			foreach entTableRow in config.myPrimaryTaskFields.allEntTableRows discreteLock do
				create taskField transient;
				taskField.setProxyFromObject(entTableRow);
				self.allPrimaryTaskFields.add(taskField);				
			endforeach;		
		endif;
		
		//epr TFS 4830 20/6/17
		if config.mySecondaryTaskFields &lt;&gt; null then
			foreach entTableRow in config.mySecondaryTaskFields.allEntTableRows discreteLock do
				create taskField transient;
				taskField.setProxyFromObject(entTableRow);
				self.allSecondaryTaskFields.add(taskField);				
			endforeach;	
		endif;
		
		//epr TFS 4830 20/6/17
		if config.myPrimaryCargoFields &lt;&gt; null then
			foreach entTableRow in config.myPrimaryCargoFields.allEntTableRows discreteLock do
				create taskField transient;
				taskField.setProxyFromObject(entTableRow);
				self.allPrimaryCargoFields.add(taskField);				
			endforeach;	
		endif;
		
		//epr TFS 4830 20/6/17
		if config.mySecondaryCargoFields &lt;&gt; null then
			foreach entTableRow in config.mySecondaryCargoFields.allEntTableRows discreteLock do
				create taskField transient;
				taskField.setProxyFromObject(entTableRow);
				self.allSecondaryCargoFields.add(taskField);				
			endforeach;	
		endif;
		
		//epr TFS 4830 20/6/17
		if config.myPrimaryDirectorFields &lt;&gt; null then
			foreach entTableRow in config.myPrimaryDirectorFields.allEntTableRows discreteLock do
				create taskField transient;
				taskField.setProxyFromObject(entTableRow);
				self.allPrimaryDirectorFields.add(taskField);				
			endforeach;	
		endif;
		
		//epr TFS 4830 20/6/17
		if config.mySecondaryDirectorFields &lt;&gt; null then
			foreach entTableRow in config.mySecondaryDirectorFields.allEntTableRows discreteLock do
				create taskField transient;
				taskField.setProxyFromObject(entTableRow);
				self.allSecondaryDirectorFields.add(taskField);				
			endforeach;	
		endif;
		
		
		self.messagePollingInterval			:= config.messagePollingInterval;
		self.listPollingInterval			:= config.listPollingInterval;
		self.canTandemDiffTargets			:= config.allowTandemToDiffTargets;	   //TFS47394
		self.driverDismissMessages			:= config.driverDismissMessages;		   // TFS 51286
		self.canDoDriverMultiMoves			:= config.allowDriverMultiMoves;          //01.09.2021 navma1 #51485
		self.acceptTimerInterval			:= config.acceptTimerInterval;            // 11.11.2021 navmj1 TFS #52272
		self.pickupTimerInterval			:= config.pickupTimerInterval;            // 11.11.2021 navmj1 TFS #52272
		self.autoplanDriverInitiatedMove	:= config.autoplanDriverInitiatedMove;    // 14.12.2021 navma1 TFS #52212
		self.allowColumnFiltering			:= config.allowColumnFiltering;		   // jlika1 TFS 57126 
		self.retainCargoIdDriverMode		:= config.retainCargoIdDriverMode;			// ### JIRA: MTN-34259 18Mar2025 NAVPW1
		self.doSwapChangeCargo 				:= config.doSwapChangeCargo; 				//29/10/2025	navkc1 JIRA 36186
	endif;
	self.hasFaultQuestions := machine.hasFaultQuestions();
	self.canTwinLift	   := machine.canTwinLift;
	self.canTandemLift     := machine.canTandemLift();
	//night mode is going to get saved on the the user xml state data
	//we will default to false until thats done
	self.showNightMode:= false;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="d9a9517a-0adb-4668-ab65-010a99d42012">
        <updating/>
        <source>delete() updating;
/*

Date		Who		Reason
20 June 2017	cnwer1	Initial creation TFS 7521
*/

vars

begin

	self.allPrimaryTaskFields.purge;
	self.allSecondaryTaskFields.purge;
	self.allPrimaryCargoFields.purge;
	self.allSecondaryCargoFields.purge;
	self.allPrimaryDirectorFields.purge;
	self.allSecondaryDirectorFields.purge;

epilog

end;</source>
    </JadeMethod>
</Class>
