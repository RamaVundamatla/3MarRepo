    <JadeMethod name="addDtl" id="bd42a2fa-626c-4fe5-9a34-6373e3322916">
        <updating/>
        <source>addDtl(keyCargoTypeDescr : String; cargoType, keyType, keySubType,	colNum : Integer;
			_txn : CM_TITransaction; _num : Decimal) updating, protected;
// ---------------------------------------------------------------------------
// Created:     23 November 2007 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpDtl	: CMIF_CommercialQueryDtl;
	tmpTI	: CM_TrackedItem;
begin
	tmpDtl := self.allDtls[keyCargoTypeDescr, keyType, keySubType, colNum];
	tmpTI := _txn.myTrackedItem;
	if tmpDtl = null then
		create tmpDtl transient;
		tmpDtl.init(keyCargoTypeDescr, cargoType, keyType, keySubType, colNum, self);
	endif;
	if not tmpDtl.allDtlTIs.includes(tmpTI)then
		tmpDtl.addTI(tmpTI, _num);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="keyCargoTypeDescr" type="String"/>
        <Parameter name="cargoType" type="Integer"/>
        <Parameter name="keyType" type="Integer"/>
        <Parameter name="keySubType" type="Integer"/>
        <Parameter name="colNum" type="Integer"/>
        <Parameter name="_txn" type="CM_TITransaction"/>
        <Parameter name="_num" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="addSum" id="4c910fc3-7bd5-4319-922a-b3d11338ce6e">
        <updating/>
        <source>addSum(rowType: Integer; rowSortCode: String; cargoType,imexStatus,contentsStatus, cntrType : Integer; _txn : CM_TITransaction; _num : Integer) updating, protected;
// ---------------------------------------------------------------------------
// Created:     14 February 2008 by cnwaer1
//
// Changes:  
// PAR 16898 - RJS June 2008 - get FF from transaction 
// PAR18746 - cnwsh3 Feb 2009 - GDansk requested change back to reporting the ff on the ti and not the txn.    
// ---------------------------------------------------------------------------
vars
	tmpSum	: CMIF_CommercialQuerySmry;
	tmpTI	: CM_TrackedItem;
	operObj : CM_Operator;
	ffObj   : CM_ConsigneeConsignor;
begin 
	tmpSum := self.allSums[rowType, rowSortCode, cargoType, imexStatus, contentsStatus,cntrType];
	tmpTI := _txn.myTrackedItem;
	if rowType = SumRow_Operator then
		//operObj := app.myRoot.allOperators[_txn.operatorCode];
		operObj := app.myRoot.allOperators[tmpTI.operatorCode]; //PAR18963 cnwsh3 3/3/2009
	else
		//ffObj := app.myRoot.allConsigneeConsignors[_txn.freightForwarderCode];	// PAR 16898 - RJS June 2008
		ffObj := app.myRoot.allConsigneeConsignors[tmpTI.freightForwarderCode]; //18746
	endif;
	
	if tmpSum = null then
		// No summary row found so have to create one
		create tmpSum transient;
		tmpSum.init(rowType, rowSortCode, cargoType, imexStatus,contentsStatus,cntrType, self,operObj,ffObj);
	endif;
	if not tmpSum.allSumTIs.includes(tmpTI)then
		tmpSum.addTI(tmpTI, _num);
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="rowType" type="Integer"/>
        <Parameter name="rowSortCode" type="String"/>
        <Parameter name="cargoType" type="Integer"/>
        <Parameter name="imexStatus" type="Integer"/>
        <Parameter name="contentsStatus" type="Integer"/>
        <Parameter name="cntrType" type="Integer"/>
        <Parameter name="_txn" type="CM_TITransaction"/>
        <Parameter name="_num" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addTotalDtls" id="97a00c99-2458-4a85-8f02-59c41b83793b">
        <updating/>
        <source>addTotalDtls(keyCargoTypeDescr : String; cargoType, keyType,colNum : Integer;
			_txn : CM_TITransaction; _num : Decimal) updating, protected;
// ---------------------------------------------------------------------------
// Created:     18 February 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpTDtl	: CMIF_CommercialQueryDtlTotal;
	tmpTI	: CM_TrackedItem;
	operObj : CM_Operator;
	ffObj   : CM_ConsigneeConsignor;
begin
	 
	tmpTDtl := self.allTotalDlts[keyCargoTypeDescr, keyType, colNum];
	tmpTI := _txn.myTrackedItem;
	if tmpTDtl = null then
		create tmpTDtl transient;
		tmpTDtl.init(keyCargoTypeDescr, cargoType, keyType, colNum, self);
	endif;
	if not tmpTDtl.allTotalDtlTIs.includes(tmpTI)then
		tmpTDtl.addTI(tmpTI, _num);
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="keyCargoTypeDescr" type="String"/>
        <Parameter name="cargoType" type="Integer"/>
        <Parameter name="keyType" type="Integer"/>
        <Parameter name="colNum" type="Integer"/>
        <Parameter name="_txn" type="CM_TITransaction"/>
        <Parameter name="_num" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="addTotalSums" id="221da72e-7723-4c09-aa4d-9744cbb21195">
        <updating/>
        <source>addTotalSums(rowType: Integer; cargoType,imexStatus,contentsStatus, cntrType : Integer; _txn : CM_TITransaction; _num : Integer) updating, protected;
// ---------------------------------------------------------------------------
// Created:     18 February 2008 by cnwaer1
//
// Changes:
// PAR 16898 - RJS June 2008 - get FF from transaction     
// PAR18746 - cnwsh3 Feb 2009 - GDansk requested change back to reporting the ff on the ti and not the txn.
// ---------------------------------------------------------------------------
vars
	tmpTSum	: CMIF_CommercialQuerySmryTotal;
	tmpTI	: CM_TrackedItem;
	operObj : CM_Operator;
	ffObj   : CM_ConsigneeConsignor;
begin
	tmpTSum := self.allTotalSums[rowType, cargoType, imexStatus,contentsStatus,cntrType];
	tmpTI := _txn.myTrackedItem;
	//operObj := app.myRoot.allOperators[_txn.operatorCode];
	operObj := app.myRoot.allOperators[tmpTI.operatorCode]; //PAR18963 cnwsh3 3/3/2009
	
	//ffObj := app.myRoot.allConsigneeConsignors[_txn.freightForwarderCode];	// PAR 16898 - RJS June 2008
	ffObj := app.myRoot.allConsigneeConsignors[tmpTI.freightForwarderCode]; //PAR18746
	
	if tmpTSum = null then
		create tmpTSum transient;
		tmpTSum.init(rowType, cargoType, imexStatus,contentsStatus,cntrType, self,operObj,ffObj);
	endif;
	if not tmpTSum.allTotalSumsTis.includes(tmpTI)then
		tmpTSum.addTI(tmpTI, _num);
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="rowType" type="Integer"/>
        <Parameter name="cargoType" type="Integer"/>
        <Parameter name="imexStatus" type="Integer"/>
        <Parameter name="contentsStatus" type="Integer"/>
        <Parameter name="cntrType" type="Integer"/>
        <Parameter name="_txn" type="CM_TITransaction"/>
        <Parameter name="_num" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="createDummySums" id="425e1f5e-6096-429c-a2c5-2063a6d2fbe9">
        <updating/>
        <source>createDummySums() updating, protected;
// ---------------------------------------------------------------------------
// Created:     14 February 2008 by cnwaer1
//
// Purpose:     If we have selected some specific operators or FFs then we
//				create a summary object for each one so that we get a line
//				for them on the table, even if no data is found
// ---------------------------------------------------------------------------
vars
	tmpSum	: CMIF_CommercialQuerySmry;
	operObj : CM_Operator;
	ffObj   : CM_ConsigneeConsignor;
begin 

	foreach ffObj in self.allFreightForwarders do
		create tmpSum transient;
		tmpSum.init(SumRow_FF, ffObj.code, TI_CargoType_Container, TI_IMEX_STATUS_EXPORT, TI_CONTENTS_STATUS_EMPTY, DtlCol_20, self, null, ffObj);
	endforeach;

	foreach operObj in self.allOperators do
		create tmpSum transient;
		tmpSum.init(SumRow_Operator, operObj.code, TI_CargoType_Container, TI_IMEX_STATUS_EXPORT, TI_CONTENTS_STATUS_EMPTY, DtlCol_20, self, operObj, null);
	endforeach;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="displayQuerySelection" id="1392d160-842b-4223-8acb-4671db205a5e">
        <source>displayQuerySelection(_timeFrom, _timeTo : Date; _voyage :CM_Voyage):String;
// ---------------------------------------------------------------------------
// Created:     26 November 2007 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	txt 		: String;
	cargo 		: CM_CargoType;
	ff			: CM_ConsigneeConsignor;
	operator 	: CM_Operator;
	serv 		: CM_TransactionType;
begin
	if self.isDetail then
		txt := txt &amp; app.getErrorString(Query_selection)&amp;" : ";
		txt := txt &amp; app.getErrorString(Contain_OtherCargoDtl);
		if self.isSummary then
			txt := txt &amp; ", " &amp;app.getErrorString(Container_summary);
		endif;
		txt := txt &amp; CrLf ;
	elseif self.isSummary then
		txt := txt &amp; app.getErrorString(Query_selection)&amp;" : ";
		txt := txt &amp; app.getErrorString(Container_summary);
		txt := txt &amp; CrLf ;
	endif;
	if self.hasCargoTypes  then
		txt := txt &amp; app.getErrorString(CargoTypes)&amp;" : ";
		foreach cargo in self.allCargoTypes do
			txt := txt &amp;  cargo.description &amp;', ';
		endforeach;
		txt := txt &amp; CrLf ;
	endif;
	if self.hasFreightForwarders then
		txt := txt &amp;app.getErrorString(FreightForwarder)&amp;"s : ";
		foreach ff in self.allFreightForwarders do
			txt := txt &amp; ff.code &amp; ', ';
		endforeach;
	txt := txt &amp; CrLf ;
	endif;
	if self.hasOperators then
		txt :=txt &amp; app.getErrorString(Operators)&amp;" : ";
		foreach operator in self.allOperators do
			txt := txt &amp; operator.code &amp; ', ';
		endforeach;
	txt := txt &amp; CrLf ;
	endif;
	if self.hasServices then
		txt := txt &amp; app.getErrorString(Services)&amp;" : ";
		foreach serv in self.allServices do
			txt := txt &amp; serv.description&amp; ', ';
		endforeach;
	txt := txt &amp; CrLf ;
	endif;
	
	if _voyage &lt;&gt; null then 
		txt := txt &amp; app.getErrorString(Voyage) &amp;" : "&amp; _voyage.code &amp;'-' &amp;_voyage.description;
	elseif _timeFrom &lt;&gt; null and _timeTo &lt;&gt; null then
		txt := txt &amp; app.getErrorString(Time_from) &amp;": " &amp; _timeFrom.String &amp;"   " &amp; app.getErrorString(CM_To)&amp;"   " &amp;_timeTo.String ;
	endif;

	return txt;
end;</source>
        <Parameter name="_timeFrom" type="Date"/>
        <Parameter name="_timeTo" type="Date"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doQuery" id="39dedafe-a235-48f6-a3b8-9319be227a01">
        <updating/>
        <source>doQuery():  Boolean updating ;
// ---------------------------------------------------------------------------
// Created:     23 November 2007 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tiTxnType			: CM_TransactionType;
	tmpOperator			: CM_Operator;
	constCol 			: Integer;
	trxColection 		: IntegerArray;
begin

	app.myPassport.myActivityCapture.startCaptureSearch(self.String);

	self.allDtls.purge;
	self.allSums.purge;
	self.allTotalSums.purge;
	self.allTotalDlts.purge;
	
	self.setCargoTypeIDs();
	totalOperators := self.allOperators.size;
	totalFF := self.allFreightForwarders.size;
	// setup the protected attributes used for the query
	self.hasCargoTypes := (self.allCargoTypes.size &gt; 0);
	self.hasFreightForwarders := (totalFF &gt; 0);
	self.hasOperators := (totalOperators &gt; 0);
	
	self.hasServices := (self.allServices.size &gt; 0);
	if self.isDetail = false and self.isSummary = false then
		app.msgBox("Please tick at list one check box!", app.getErrorString(Error), MsgBox_Stop_Icon+MsgBox_OK_Only);
		return false;
	endif;
	self.allOperatorCodes.clear;

	if self.hasOperators then
		foreach tmpOperator in self.allOperators do
			self.allOperatorCodes.add(tmpOperator.code);
		endforeach;
	endif;
	
	self.allTiTxnDetailTypes.clear;
	self.allTiTxnSummaryTypes.clear;
	self.allTiTxnJoinTypes.clear;
	
	// Adding all the Release request and Receive request transaction types by default.
	// const : 1 if isSummary, 2 if isDetail and 3 if is Both true
	constCol := self.populateTiTypesByDefault(self.allTiTxnDetailTypes,self.allTiTxnSummaryTypes,self.allTiTxnJoinTypes);
	
	if self.hasServices and self.isDetail = true then
		if self.isSummary then
			foreach tiTxnType in self.allServices do
				self.allTiTxnJoinTypes.add(tiTxnType.trxType);
				self.allTiTxnDetailTypes.add(tiTxnType.trxType);
			endforeach;
		else
			foreach tiTxnType in self.allServices do
				self.allTiTxnDetailTypes.add(tiTxnType.trxType);
			endforeach;
		endif;
	endif;
	
	//Choosing the collection that will be used further on for iterating the transactions valid for the selection.
	
	if constCol = IsSummary then
		trxColection := self.allTiTxnSummaryTypes;
	elseif constCol = IsDetail then
		trxColection := self.allTiTxnDetailTypes;
	elseif constCol = IsDetail_Summary then
		trxColection := self.allTiTxnJoinTypes;
	endif;
	
	
	if self.isSummary then
		self.createDummySums();
	endif;

	// do the query
	if not self.hasCargoTypes then	// Par 16775 cnwvu1 20 May 2008
		app.msgBox( app.getErrorString(No_Cargo_type_selected), null, MsgBox_Stop_Icon+MsgBox_OK_Only);
		return false;
	endif;

	if self.myVoyage &lt;&gt; null then
		self.queryByVoyage := true;
		return self.doQueryByVoyage();
	else
		self.queryByVoyage := false;
		if (not self.timeFrom.isValid()) then
			app.msgBox(app.getErrorString(Date_from_incorrect), app.getErrorString(Validate_time_settings), MsgBox_Stop_Icon+MsgBox_OK_Only);
			return false;
		elseif (not self.timeTo.isValid()) then
			app.msgBox(app.getErrorString(DateTo_incorrect), app.getErrorString(Validate_time_settings), MsgBox_Stop_Icon+MsgBox_OK_Only);
			return false;
		elseif self.timeTo &lt; self.timeFrom then
			app.msgBox(app.getErrorString(DateFromTo), app.getErrorString(Validate_time_settings), MsgBox_Stop_Icon+MsgBox_OK_Only);
			return false;
		endif;
		
		return self.doQueryByDate2(trxColection);
	endif;
	
epilog
	endLoad;
	app.myPassport.myActivityCapture.stopCaptureSearch();
	//delete trxColection;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doQueryByDate2" id="6157c1f1-1075-4523-9e92-9749e41d76b6">
        <updating/>
        <source>doQueryByDate2(trxColection: IntegerArray): Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     23 November 2007 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks
27 Jan 2011	NDL	Par 26415	- Remove beginLoad endLoad
30 Mar 2016	cnwdap1	PAR #35843 Make monitor time-based not object count based
*/

vars
	iter			: Iterator;
	txn				: CM_TITransaction;
	keyDate			: TimeStamp;
	keyType, 
	count,
	monitorReturnValue,
	found,
	tiType,
	clockTime,
	lastTime		: Integer;
	cmifMonitor 	: CMIF_Monitor;
	tmpPassport		: CM_Passport;
	tmpDict			: CM_TITransactionByTypeDateDict;
	tiTypes			: IntegerArray;
	timeStampFrom,
	timeStampTo		: TimeStamp;
	lastUpdated		: Decimal [20];
	localFrom,
	localTo			: TimeStamp;

begin
	tmpPassport := app.myPassport;
	cmifMonitor := tmpPassport.myCMIFMonitor;
	
	tmpDict := self.myTerminal.allTITransactionsByTypeDate;
	iter := tmpDict.createIterator();
	count := 0;
	
	localFrom := self.timeFrom.TimeStamp;
	localTo := self.timeTo.TimeStamp;		// From 19/05/2008 00:00:00 - To 19/05/2008 00:00:00
	localTo	:= localTo.addHours(23);
	localTo	:= localTo.addMinutes(59);
	localTo	:= localTo.addSeconds(59);	// From 19/05/2008 00:00:00 - To 20/05/2008 23:59:59	Par 16775 cnwvu1 20 May 2008
	
	timeStampFrom := self.localToSystemTime(localFrom);	// 26/4/16 cnwmp6 TFS 488 - Multi timezone supportCM
	timeStampTo := self.localToSystemTime(localTo);
	
	foreach tiType in trxColection do
//		endLoad;
		tmpDict.startKeyGeq(tiType, timeStampFrom, iter);
//		beginLoad;
		while iter.next(txn) do
			count := count + 1;
			tmpDict.getIteratorKeys(keyType, keyDate, iter);
			if keyType &gt; tiType or
			   keyDate &gt; timeStampTo then
				break;
			endif;
			
			// 07/05/2010 cnwar2 #23060
			if txn.deleted then
				continue;
			endif;
			
			//if count mod(1000) = 0 then																	// PAR #35843
			//	clockTime := app.clock;																		// PAR #35843
			//	if (clockTime - lastTime).abs &gt; 1000 then													// PAR #35843
			//		lastTime := clockTime;																	// PAR #35843
//					endLoad;
//					beginLoad;
			if (app.relativeMachineTime - lastUpdated) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then		// PAR #35843
				cmifMonitor.updateProgress(app.getErrorString(SearchingForData)&amp;" ... "&amp; count.asStringJMT, null, null);
				monitorReturnValue := cmifMonitor.monitorReturnValue;
				if (monitorReturnValue = CMIF_Monitor.MonitorReturnValue_Return) 
				or (monitorReturnValue = CMIF_Monitor.MonitorReturnValue_Cancel)  then
					//CM_BreakOutException.raise_(cmifMonitor.monitorReturnValue, 'Breaking Out');
					app.raiseCMException( UserAbortedAction, null, null);
					return false;
				endif;
				lastUpdated := app.relativeMachineTime;														// PAR #35843
			endif;	
			//endif;																						// PAR #35843
			if self.isSummary and txn.isVoyageRelivant and txn.myTrackedItem.CM_TrackedItem &lt;&gt; null and self.validateSumTxn(txn, tmpPassport) then
				self.handleTrxSummaryByTimeRange(txn);
			endif;						
			
			if self.isDetail and allTiTxnDetailTypes.includes(txn.type) then
				if self.validateDtlTxn(txn, tmpPassport, false) then
					self.handleTxnForDetail(txn);		
				endif;
			endif;
		endwhile;
	endforeach;
	
	return true;

epilog
//	endLoad;
	delete iter;			// PAR #26678
	
end;</source>
        <access>protected</access>
        <Parameter name="trxColection" type="IntegerArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doQueryByVoyage" id="a1835b70-a83b-4f63-8673-def6e1702f3f">
        <updating/>
        <source>doQueryByVoyage(): Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     23 November 2007 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks
30 Mar 2016	cnwdap1	PAR #35843 Make monitor time-based rather than object count based
*/

vars
	iter				: Iterator;
	txn,
	tiTxn				: CM_TITransaction;
	tmpDict				: CM_TITransactionByTypeDateDict;
	keyDate				: TimeStamp;
	keyType,
	count, 
	monitorReturnValue,
	clockTime,
	lastTime			: Integer;
	ti					: CM_TrackedItem;
	tiTypes				: IntegerArray;
	tiType				: Integer;
	tisDetailHandled,
	tisSummaryHandled 	: CM_TISet;
	cmifMonitor 		: CMIF_Monitor;
	tmpPassport			: CM_Passport;
	doAllOperators,
	doAllFFs			: Boolean;
	lastUpdated			: Decimal [20];
begin

	if self.queryByVoyage then
		if (not self.hasFreightForwarders) then
			doAllFFs := true;
		endif;
		if (not self.hasOperators) then
			doAllOperators := true;
		endif;
	endif;
	
	lastTime := app.clock;
	tmpPassport := app.myPassport;
	cmifMonitor := app.myPassport.myCMIFMonitor;
	// Set that retains all the ti's that we are checking for the selected voyage.
	create tisDetailHandled transient;
	create tisSummaryHandled transient;
	// Creating an iterator for all the transactions belonging to the voyage.
	iter := self.myVoyage.allTITransactionsByTypeDT.createIterator();
	count := 0;
	while iter.next(txn) do
		ti := txn.myTrackedItem;
		if ti = null then
			continue;
		endif;
		count := count + 1;
		//if count mod(1000) = 0 then																// PAR #35843
		//	clockTime := app.clock;																	// PAR #35843
		//	if (clockTime - lastTime).abs &gt; 1000 then												// PAR #35843
		//		lastTime := clockTime;																// PAR #35843
		if(app.relativeMachineTime - lastUpdated) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then	// PAR #35843
			cmifMonitor.updateProgress(app.getErrorString(SearchingForData)&amp;" ... "&amp; count.asStringJMT, null, null);
			monitorReturnValue := cmifMonitor.monitorReturnValue;
			if (monitorReturnValue = CMIF_Monitor.MonitorReturnValue_Return) 
			or (monitorReturnValue = CMIF_Monitor.MonitorReturnValue_Cancel)  then
				app.raiseCMException(UserAbortedAction, null, null);
				return false;
			endif;
			lastUpdated := app.relativeMachineTime;													// PAR #35843
		endif;
		//endif;																					// PAR #35843
		if self.isSummary and txn.myTrackedItem.CM_TrackedItem &lt;&gt; null and self.validateSumTxn(txn, tmpPassport) then
			self.handleTrxSummaryByVoyage(txn, doAllFFs, doAllOperators);	
		endif;
		
		if self.isDetail then
			if ti = null or (not self.allTiTxnDetailTypes.includes(txn.type)) or
			   tisDetailHandled.includes(ti) then
				continue;
			endif;
			foreach tiTxn in ti.allTransactions do
				if self.allTiTxnDetailTypes.includes(tiTxn.type) and
				   self.validateDtlTxn(txn, tmpPassport, true) then
					self.handleTxnForDetail(txn);
				endif;
			endforeach;
		endif;
	endwhile;
	return true;
epilog
	endLoad;
	delete tisDetailHandled;
	delete tisSummaryHandled;
	delete iter;		// PAR #26678
	
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="handleTrxSummaryByTimeRange" id="ce7c8c06-85f4-49c4-a0f4-18f090e7549e">
        <updating/>
        <source>handleTrxSummaryByTimeRange(_txn : CM_TITransaction)updating;
// ---------------------------------------------------------------------------
// Created:     06 March 2008 by cnwaer1
//
// Changes:
// PAR 16898 - RJS June 2008 - get FF from transaction     
// PAR18746 - cnwsh3 Feb 2009 - GDansk requested change back to reporting the ff on the ti and not the txn.
// ---------------------------------------------------------------------------
vars
	cargoType,
	imexStatus,
	contentsStatus,
	teu	,
	rowType,
	colType 		: Integer;
	rowSortCode,
	operator,
	ff 				: String;
	tmpTI			: CM_TrackedItem;
	isOwn				: Boolean;
	dtlCol_n			: Integer;
	
	int : Integer;
begin

	cargoType := _txn.myTrackedItem.cargoType;
	imexStatus  := _txn.imExStatus;
	contentsStatus := _txn.contentsStatus;
	tmpTI := _txn.myTrackedItem;
	//operator := _txn.operatorCode.String;
	operator := _txn.myTrackedItem.operatorCode.String;//PAR18963 cnwsh3 3/3/2009
	
	//ff := _txn.freightForwarderCode.String;		// PAR 16898 - RJS June 2008
	ff := _txn.myTrackedItem.freightForwarderCode.String ; //PAR18746
	
	if (not self.hasFreightForwarders) or self.valiFF(_txn) then
		rowType := SumRow_FF;
		rowSortCode := ff;

		if cargoType = TI_CargoType_Container then
		
			dtlCol_n	:= DtlCol_40; // if the 30, 45 or 53 are not active, the will be considered as 40
			teu			:= 2;
			
			if tmpTI.CM_Container.is20 then
				teu := 1;
				dtlCol_n := DtlCol_20;
			elseif tmpTI.CM_Container.is45 and app.is45IncludedForReportsAsColumn( isOwn ) then
				if isOwn then
					dtlCol_n := DtlCol_45;
				else
					dtlCol_n := DtlCol_40other;
				endif;
			elseif tmpTI.CM_Container.is40 then
				//dtlCol_n := DtlCol_40;	// do nothing - this is default
				
			elseif tmpTI.CM_Container.is30 and app.is30IncludedForReportsAsColumn( isOwn ) then	
				if isOwn then
					dtlCol_n := DtlCol_30;
				else
					dtlCol_n := DtlCol_40other;
				endif;
				
			elseif tmpTI.CM_Container.is53 and app.is53IncludedForReportsAsColumn( isOwn ) then	
				if isOwn then
					dtlCol_n := DtlCol_53;
				else
					dtlCol_n := DtlCol_40other;
				endif;
			endif;

			self.addSum(rowType,rowSortCode,cargoType,imexStatus,contentsStatus, dtlCol_n, _txn, 1);
			colType := dtlCol_n;
			
			self.addSum(rowType, rowSortCode,cargoType,imexStatus,contentsStatus, DtlCol_TEU, _txn, teu);
			// add to Total Sum
			self.addTotalSums(rowType, cargoType,imexStatus,contentsStatus, DtlCol_TEU, _txn, teu);
			self.addTotalSums(rowType, cargoType,imexStatus,contentsStatus, colType, _txn, 1);
		endif;
		
	endif;
	
	if (not self.hasOperators) or self.valOperators(_txn) then
	
		rowType := SumRow_Operator;
		rowSortCode := operator;
		if cargoType = TI_CargoType_Container then

			dtlCol_n:= DtlCol_40;	// if the 30, 45 or 53 are not active, the will be considered as 40
			teu 	:= 2;

			if tmpTI.CM_Container.is20 then
				teu := 1;
				dtlCol_n := DtlCol_20;
				
			elseif tmpTI.CM_Container.is45 and app.is45IncludedForReportsAsColumn( isOwn ) then
				if isOwn then
					dtlCol_n := DtlCol_45;
				else
					dtlCol_n := DtlCol_40other;
				endif;
				
			elseif tmpTI.CM_Container.is40 then
				//dtlCol_n := DtlCol_40;	// do nothing - this is default
				
			elseif tmpTI.CM_Container.is30 and app.is30IncludedForReportsAsColumn( isOwn ) then
				if isOwn then
					dtlCol_n := DtlCol_30;
				else
					dtlCol_n := DtlCol_40other;
				endif;
				
			elseif tmpTI.CM_Container.is53 and app.is53IncludedForReportsAsColumn( isOwn ) then
				if isOwn then
					dtlCol_n := DtlCol_53;
				else
					dtlCol_n := DtlCol_40other;
				endif;
				
			endif;
				
			self.addSum(rowType, rowSortCode,cargoType,imexStatus,contentsStatus, dtlCol_n, _txn, 1);
			colType := dtlCol_n;
			
			self.addSum(rowType, rowSortCode,cargoType,imexStatus,contentsStatus, DtlCol_TEU, _txn, teu);
			// add to Total Sum
			self.addTotalSums(rowType, cargoType,imexStatus,contentsStatus, DtlCol_TEU, _txn, teu);
			self.addTotalSums(rowType, cargoType,imexStatus,contentsStatus, colType, _txn, 1);
			
		endif;
		
	endif;
	
end;</source>
        <Parameter name="_txn" type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="handleTrxSummaryByVoyage" id="f06389cd-5ede-4dfa-b5ac-9914c2a96c72">
        <updating/>
        <source>handleTrxSummaryByVoyage(_txn : CM_TITransaction; _doAllFFs, _doAllOperators : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     06 March 2008 by cnwaer1
//
// Purpose:     Handle Transactions for a voyage
//
// Changes:
// PAR 16898 - RJS June 2008 - get FF from transaction     
// PAR18746 - cnwsh3 Feb 2009 - GDansk requested change back to reporting the ff on the ti and not the txn.
// ---------------------------------------------------------------------------
vars
	cargoType,
	imexStatus,
	contentsStatus,
	teu	,
	rowType,
	colType 		: Integer;
	rowSortCode,
	operator,
	ff 				: String;
	tmpTI			: CM_TrackedItem;
	isOwn				: Boolean;
	dtlCol_n			: Integer;
	
begin
	cargoType := _txn.myTrackedItem.cargoType;
	imexStatus  := _txn.imExStatus;
	contentsStatus := _txn.contentsStatus;
	tmpTI := _txn.myTrackedItem;
	
	//ff := _txn.freightForwarderCode.String;	// PAR 16898 - RJS June 2008
	ff := _txn.myTrackedItem.freightForwarderCode.String; //PAR18746
	if _doAllFFs or ff &lt;&gt; null then
	
		rowType := SumRow_FF;
		rowSortCode := ff;
		
		if cargoType = TI_CargoType_Container then
			teu		:= 2;			
			dtlCol_n:= DtlCol_40;	// if the 30, 45 or 53 are not active, the will be considered as 40
			
			if tmpTI.CM_Container.is20 then
				dtlCol_n := DtlCol_20; 
				teu := 1;
				
			elseif tmpTI.CM_Container.is45 and app.is45IncludedForReportsAsColumn( isOwn ) then
				if isOwn then
					colType := DtlCol_45;
				else
					dtlCol_n := DtlCol_40other;
				endif;
				
			elseif tmpTI.CM_Container.is40 then
				//colType := DtlCol_40;	// do nothing - this is default
				
			elseif tmpTI.CM_Container.is30 and app.is30IncludedForReportsAsColumn( isOwn ) then	
				if isOwn then
					dtlCol_n := DtlCol_30;
				else
					dtlCol_n := DtlCol_40other;
				endif;
				
			elseif tmpTI.CM_Container.is53 and app.is53IncludedForReportsAsColumn( isOwn ) then	
				if isOwn then
					dtlCol_n := DtlCol_53;
				else
					dtlCol_n := DtlCol_40other;
				endif;
				
			endif;	
			
			self.addSum(rowType, rowSortCode,cargoType,imexStatus,contentsStatus, dtlCol_n, _txn, 1);
			colType := dtlCol_n;

			self.addSum(rowType, rowSortCode, cargoType, imexStatus,contentsStatus, DtlCol_TEU, _txn, teu);
			// add to Total Sum
			self.addTotalSums(rowType, cargoType, imexStatus,contentsStatus, DtlCol_TEU, _txn, teu);
			self.addTotalSums(rowType, cargoType, imexStatus,contentsStatus, colType, _txn, 1);
		endif;
	endif;
	
	//operator := _txn.operatorCode.String;
	operator := _txn.myTrackedItem.operatorCode.String; //PAR18963 cnwsh3 3/3/2009
	if _doAllOperators or operator &lt;&gt; null then
	
		rowType := SumRow_Operator;
		rowSortCode := operator;
		
		if cargoType = TI_CargoType_Container then

			teu		:= 2;			
			dtlCol_n:= DtlCol_40;	// if the 30, 45 or 53 are not active, the will be considered as 40
			
			if tmpTI.CM_Container.is20 then
				teu := 1;
				dtlCol_n:= DtlCol_20;

			elseif tmpTI.CM_Container.is45 and app.is45IncludedForReportsAsColumn( isOwn ) then
				if isOwn then
					dtlCol_n := DtlCol_45;
				else
					dtlCol_n := DtlCol_40other;
				endif;
				
			elseif tmpTI.CM_Container.is40 then
				//colType := DtlCol_40;	// do nothing - this is default
				
			elseif tmpTI.CM_Container.is30 and app.is30IncludedForReportsAsColumn( isOwn ) then	//ccms1029	cnwvu1	16 May 2008
				if isOwn then
					dtlCol_n := DtlCol_30;
				else
					dtlCol_n := DtlCol_40other;
				endif;
				
			elseif tmpTI.CM_Container.is53 and app.is53IncludedForReportsAsColumn( isOwn ) then	//ccms1029	cnwvu1	16 May 2008
				if isOwn then
					dtlCol_n := DtlCol_53;
				else
					dtlCol_n := DtlCol_40other;
				endif;
				
			endif;
			
			self.addSum(rowType, rowSortCode,cargoType,imexStatus,contentsStatus, dtlCol_n, _txn, 1);
			colType := dtlCol_n;

			self.addSum(rowType, rowSortCode, cargoType, imexStatus, contentsStatus, DtlCol_TEU, _txn, teu);
			// add to Total Sum
			self.addTotalSums(rowType, cargoType, imexStatus, contentsStatus, DtlCol_TEU, _txn, teu);
			self.addTotalSums(rowType, cargoType, imexStatus, contentsStatus, colType, _txn, 1);
		endif;
	endif;
end;
	/*
	else
		ff := _txn.myTrackedItem.freightForwarderCode.String ;
		if ff &lt;&gt; null then
			rowType := SumRow_FF;
			rowSortCode := ff;
			if cargoType = TI_CargoType_Container then
				teu := 1;
				if tmpTI.CM_Container.is20 then
					self.addSum(rowType, rowSortCode,cargoType,imexStatus,contentsStatus, DtlCol_20, _txn, 1);
					colType := DtlCol_20;
				elseif tmpTI.CM_Container.is45 then
					self.addSum(rowType,rowSortCode,cargoType,imexStatus,contentsStatus, DtlCol_45, _txn, 1);
					teu := 2;
					colType := DtlCol_45;
				elseif tmpTI.CM_Container.is40 then
					self.addSum(rowType, rowSortCode,cargoType,imexStatus,contentsStatus, DtlCol_40, _txn, 1);
					teu := 2;
					colType := DtlCol_40;
				self.addSum(rowType, rowSortCode, cargoType, imexStatus,contentsStatus, DtlCol_TEU, _txn, teu);
				// add to Total Sum
				self.addTotalSums(rowType, cargoType,imexStatus,contentsStatus, DtlCol_TEU, _txn, teu);
				self.addTotalSums(rowType, cargoType,imexStatus,contentsStatus, colType, _txn, 1);
			endif;
		endif;
		operator := _txn.operatorCode.String;
		if operator &lt;&gt; null then
			rowType := SumRow_Operator;
			rowSortCode := operator;
			if cargoType = TI_CargoType_Container then
				teu := 1;
				if tmpTI.CM_Container.is20 then
					self.addSum(rowType, rowSortCode,cargoType,imexStatus,contentsStatus, DtlCol_20, _txn, 1);
					colType := DtlCol_20;
				elseif tmpTI.CM_Container.is45 then
					self.addSum(rowType, rowSortCode,cargoType,imexStatus,contentsStatus, DtlCol_45, _txn, 1);
					teu := 2;
					colType := DtlCol_45;
				elseif tmpTI.CM_Container.is40 then
					self.addSum(rowType, rowSortCode,cargoType,imexStatus,contentsStatus, DtlCol_40, _txn, 1);
					teu := 2;
					colType := DtlCol_40;
				self.addSum(rowType, rowSortCode,cargoType,imexStatus,contentsStatus, DtlCol_TEU, _txn, teu);
				// add to Total Sum
				self.addTotalSums(rowType, cargoType,imexStatus,contentsStatus, DtlCol_TEU, _txn, teu);
				self.addTotalSums(rowType, cargoType,imexStatus,contentsStatus, colType, _txn, 1);
			endif;
		endif;
	endif;
	*/
</source>
        <Parameter name="_txn" type="CM_TITransaction"/>
        <Parameter name="_doAllFFs" type="Boolean"/>
        <Parameter name="_doAllOperators" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="handleTxnForDetail" id="a4f67c60-d191-491c-8fc3-6fcf3e82f7a9">
        <updating/>
        <source>handleTxnForDetail(_txn : CM_TITransaction) updating, protected;
// ---------------------------------------------------------------------------
// Created:     23 November 2007 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpDtl				: CMIF_CommercialQueryDtl;
	keyCargoTypeDescr	: String;
	cargoType,
	txnType,
	keyType,
	keySubType,
	//teu,
	colNum,
	contType 			: Integer;
	tmpTI				: CM_TrackedItem;
	isOwn				: Boolean;
	dtlCol_n			: Integer;
	teu : Real;
begin

	keyCargoTypeDescr := _txn.myTrackedItem.cargoTypeDescr;
	cargoType := _txn.myTrackedItem.cargoType;
	txnType := _txn.type;
	
	if app.isReceivalTypeTransaction(txnType) and txnType &lt;&gt; TRANS_TYPE_CREATED then // ignore created transactions
		keyType := DtlType_Receival;
		
		if txnType = TRANS_TYPE_REC_RAIL or txnType = TRANS_TYPE_REC_RAIL_INTER_TERM then
			keySubType := DtlSubType_Rail;
		elseif txnType = TRANS_TYPE_REC_ROAD or txnType = TRANS_TYPE_REC_ROAD_INTER_TERM then
			keySubType := DtlSubType_Road;
		elseif txnType = TRANS_TYPE_REC_SHIP then
			if _txn.isKindOf(CM_ReceiveShip) and _txn.CM_ReceiveShip.isTransship then			// 04/08/2011 cnwmh5 #278888
				keySubType := DtlSubType_Transships;
			else
				keySubType := DtlSubType_Ship;
			endif;
				/*
				keySubType := DtlSubType_Ship;
				elseif txnType = TRANS_TYPE_REC_TRANSHIP then
					keySubType := DtlSubType_Transships;*/
		else
			keySubType := DtlSubType_Other;
		endif;
	elseif app.isReleaseTypeTransaction(txnType) then
		keyType := DtlType_Release;
		
		if txnType = TRANS_TYPE_REL_RAIL or txnType = TRANS_TYPE_REL_RAIL_INTER_TERM then
			keySubType := DtlSubType_Rail;
		elseif txnType = TRANS_TYPE_REL_ROAD or txnType = TRANS_TYPE_REL_ROAD_INTER_TERM then
			keySubType := DtlSubType_Road;
		elseif txnType = TRANS_TYPE_REL_SHIP then
			if _txn.isKindOf(CM_ReleaseShip) and _txn.CM_ReleaseShip.isTransship then			// 04/08/2011 cnwmh5 #278888
				keySubType := DtlSubType_Transships;
			else
				keySubType := DtlSubType_Ship;
			endif;
						/*	keySubType := DtlSubType_Ship;
						elseif txnType = TRANS_TYPE_REC_TRANSHIP then
							keySubType := DtlSubType_Transships;*/
		else
			keySubType := DtlSubType_Other;
		endif;
	else
		keyType := DtlType_Services;
		keySubType := txnType;
	endif;
	
	tmpTI := _txn.myTrackedItem;

	if tmpTI.cargoType = TI_CargoType_Container then
		
		dtlCol_n := DtlCol_40;	// if the 30, 45 or 53 are not active, the will be considered as 40
		//teu := 2;
		teu := tmpTI.CM_Container.getNumTEU;
		
		if tmpTI.CM_Container.is20 then
			//teu		:= 1;
			
			dtlCol_n:= DtlCol_20;
			
		elseif tmpTI.CM_Container.is45 and app.is45IncludedForReportsAsColumn( isOwn ) then
			if isOwn then
				dtlCol_n := DtlCol_45;
			else
				dtlCol_n := DtlCol_40other;
			endif;
			
		elseif tmpTI.CM_Container.is40 then
			//dtlCol_n := DtlCol_40;	// do nothing - this is default
			
		elseif tmpTI.CM_Container.is30 and app.is30IncludedForReportsAsColumn( isOwn ) then
			if isOwn then
				dtlCol_n := DtlCol_30;
			else
				dtlCol_n := DtlCol_40other;
			endif;
			
		elseif tmpTI.CM_Container.is53 and app.is53IncludedForReportsAsColumn( isOwn ) then
			if isOwn then
				dtlCol_n := DtlCol_53;
			else
				dtlCol_n := DtlCol_40other;
			endif;
		endif;
		
		self.addDtl(keyCargoTypeDescr,cargoType, keyType, keySubType, dtlCol_n, _txn, 1);
		contType := dtlCol_n;

		self.addDtl(keyCargoTypeDescr, cargoType, keyType, keySubType, DtlCol_TEU, _txn, teu);
				
		if tmpTI.CM_Container.isReefer then
			self.addDtl(keyCargoTypeDescr,cargoType, keyType, keySubType, DtlCol_Reefer, _txn, 1);
		endif;
		
		if keyType = DtlType_Receival or
		   keyType = DtlType_Release then
			self.addTotalDtls(keyCargoTypeDescr, cargoType, keyType, contType, _txn, 1);
			self.addTotalDtls(keyCargoTypeDescr, cargoType, keyType, DtlCol_TEU, _txn, teu);
			if tmpTI.CM_Container.isReefer then
				self.addTotalDtls(keyCargoTypeDescr, cargoType, keyType, DtlCol_Reefer, _txn, 1);
			endif;
		endif;
	else
		// Non-container cargo
		self.addDtl(keyCargoTypeDescr,cargoType, keyType, keySubType, DtlCol_Weight, _txn, _txn.totalWeight);
		self.addDtl(keyCargoTypeDescr,cargoType, keyType, keySubType, DtlCol_Quantity, _txn, _txn.totalQuantity);
		self.addDtl(keyCargoTypeDescr,cargoType, keyType, keySubType, DtlCol_Volume, _txn, _txn.totalVolume);
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_txn" type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="init" id="219539db-0495-4f71-bb39-fbbeb9f05994">
        <updating/>
        <source>init(_terminal : CM_Terminal) updating;
// ---------------------------------------------------------------------------
// Created:     23 November 2007 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
begin
	self.myTerminal := _terminal;
	self.allCargoTypes.clear();
	self.allFreightForwarders.clear();
	self.allOperators.clear();
	self.allServices.clear();
	self.timeFrom := null;
	self.timeTo := null;
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="populateTiTypesByDefault" id="bf3ee131-d57b-40b6-bbe3-fcee56e6772c">
        <updating/>
        <source>populateTiTypesByDefault(tiDetailTypes : IntegerArray input; tiSummaryTypes : IntegerArray input ; tiJoinTypes : IntegerArray input): Integer updating, protected;
// ---------------------------------------------------------------------------
// Created:     01 February 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if (not self.isDetail) then
		if self.isSummary then
			// add to the summary collection
			tiSummaryTypes.add(TRANS_TYPE_REL_SHIP);
			tiSummaryTypes.add(TRANS_TYPE_REC_SHIP);
			tiSummaryTypes.add(TRANS_TYPE_MOVE);
			tiSummaryTypes.add(TRANS_TYPE_MOVE_PICKUP);
			tiSummaryTypes.add(TRANS_TYPE_MOVE_SETDOWN);
			return IsSummary; // 1
		else
			// no checkbox was ticked, this should never happend.
			//error;
		endif;
	elseif self.isSummary = true then
		// add to the Summary collection
		tiSummaryTypes.add(TRANS_TYPE_REL_SHIP);
		tiSummaryTypes.add(TRANS_TYPE_REC_SHIP);
		tiSummaryTypes.add(TRANS_TYPE_MOVE);
		tiSummaryTypes.add(TRANS_TYPE_MOVE_PICKUP);
		tiSummaryTypes.add(TRANS_TYPE_MOVE_SETDOWN);
		
		// add to the Detail collection
		tiDetailTypes.add(TRANS_TYPE_REASSEMBLY);
		tiDetailTypes.add(TRANS_TYPE_RECEIVE);
		tiDetailTypes.add(TRANS_TYPE_REC_RAIL);
		tiDetailTypes.add(TRANS_TYPE_REC_RAIL_INTER_TERM);
		tiDetailTypes.add(TRANS_TYPE_REC_ROAD);
		tiDetailTypes.add(TRANS_TYPE_REC_ROAD_INTER_TERM);
		tiDetailTypes.add(TRANS_TYPE_REC_SHIP);
		tiDetailTypes.add(TRANS_TYPE_EXPORT_RETURNED);		
		tiDetailTypes.add(TRANS_TYPE_ReinstateReject);
		tiDetailTypes.add(TRANS_TYPE_BUSINESS_U_RECEIVE);
		tiDetailTypes.add(TRANS_TYPE_REC_TRANSHIP);
		tiDetailTypes.add(TRANS_TYPE_RELEASE);
		tiDetailTypes.add(TRANS_TYPE_REL_RAIL);
		tiDetailTypes.add(TRANS_TYPE_REL_RAIL_INTER_TERM);
		tiDetailTypes.add(TRANS_TYPE_REL_ROAD);
		tiDetailTypes.add(TRANS_TYPE_REL_ROAD_INTER_TERM);
		tiDetailTypes.add(TRANS_TYPE_REL_SHIP);
		tiDetailTypes.add(TRANS_TYPE_DISASSEMBLY);
		tiDetailTypes.add(TRANS_TYPE_REJECT);
		tiDetailTypes.add(TRANS_TYPE_BUSINESS_U_RELEASE);
		tiDetailTypes.add(TRANS_TYPE_REL_TRANSHIP);
		
		// add to the Join txn's collection
		tiJoinTypes.add(TRANS_TYPE_MOVE);
		tiJoinTypes.add(TRANS_TYPE_MOVE_PICKUP);
		tiJoinTypes.add(TRANS_TYPE_MOVE_SETDOWN);
		tiJoinTypes.add(TRANS_TYPE_REASSEMBLY);
		tiJoinTypes.add(TRANS_TYPE_RECEIVE);
		tiJoinTypes.add(TRANS_TYPE_REC_RAIL);
		tiJoinTypes.add(TRANS_TYPE_REC_RAIL_INTER_TERM);
		tiJoinTypes.add(TRANS_TYPE_REC_ROAD);
		tiJoinTypes.add(TRANS_TYPE_REC_ROAD_INTER_TERM);
		tiJoinTypes.add(TRANS_TYPE_REC_SHIP);
		tiJoinTypes.add(TRANS_TYPE_EXPORT_RETURNED);		
		tiJoinTypes.add(TRANS_TYPE_ReinstateReject);
		tiJoinTypes.add(TRANS_TYPE_BUSINESS_U_RECEIVE);
		tiJoinTypes.add(TRANS_TYPE_REC_TRANSHIP);
		tiJoinTypes.add(TRANS_TYPE_RELEASE);
		tiJoinTypes.add(TRANS_TYPE_REL_RAIL);
		tiJoinTypes.add(TRANS_TYPE_REL_RAIL_INTER_TERM);
		tiJoinTypes.add(TRANS_TYPE_REL_ROAD);
		tiJoinTypes.add(TRANS_TYPE_REL_ROAD_INTER_TERM);
		tiJoinTypes.add(TRANS_TYPE_REL_SHIP);
		tiJoinTypes.add(TRANS_TYPE_DISASSEMBLY);
		tiJoinTypes.add(TRANS_TYPE_REJECT);
		tiJoinTypes.add(TRANS_TYPE_BUSINESS_U_RELEASE);
		tiJoinTypes.add(TRANS_TYPE_REL_TRANSHIP);
		return IsDetail_Summary; //3
	else
		//Only  Detail trx'es
		tiDetailTypes.add(TRANS_TYPE_REASSEMBLY);
		tiDetailTypes.add(TRANS_TYPE_RECEIVE);
		tiDetailTypes.add(TRANS_TYPE_REC_RAIL);
		tiDetailTypes.add(TRANS_TYPE_REC_RAIL_INTER_TERM);
		tiDetailTypes.add(TRANS_TYPE_REC_ROAD);
		tiDetailTypes.add(TRANS_TYPE_REC_ROAD_INTER_TERM);
		tiDetailTypes.add(TRANS_TYPE_REC_SHIP);
		tiDetailTypes.add(TRANS_TYPE_EXPORT_RETURNED);		
		tiDetailTypes.add(TRANS_TYPE_ReinstateReject);
		tiDetailTypes.add(TRANS_TYPE_BUSINESS_U_RECEIVE);
		tiDetailTypes.add(TRANS_TYPE_REC_TRANSHIP);
		tiDetailTypes.add(TRANS_TYPE_RELEASE);
		tiDetailTypes.add(TRANS_TYPE_REL_RAIL);
		tiDetailTypes.add(TRANS_TYPE_REL_RAIL_INTER_TERM);
		tiDetailTypes.add(TRANS_TYPE_REL_ROAD);
		tiDetailTypes.add(TRANS_TYPE_REL_ROAD_INTER_TERM);
		tiDetailTypes.add(TRANS_TYPE_REL_SHIP);
		tiDetailTypes.add(TRANS_TYPE_DISASSEMBLY);
		tiDetailTypes.add(TRANS_TYPE_REJECT);
		tiDetailTypes.add(TRANS_TYPE_BUSINESS_U_RELEASE);
		tiDetailTypes.add(TRANS_TYPE_REL_TRANSHIP);
		return IsDetail;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="tiDetailTypes" type="IntegerArray" usage="input"/>
        <Parameter name="tiSummaryTypes" type="IntegerArray" usage="input"/>
        <Parameter name="tiJoinTypes" type="IntegerArray" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setCargoTypeIDs" id="5855f476-73db-4715-8e29-63ad3366fe80">
        <source>setCargoTypeIDs() protected;
// ---------------------------------------------------------------------------
// Created:     01 February 2008 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpCargoType	: CM_CargoType;
begin
	self.allCargoTypeIDs.clear();
	
	foreach tmpCargoType in self.allCargoTypes do
		self.allCargoTypeIDs.add(tmpCargoType.id);
	endforeach;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="valCargoType" id="f3287243-ef0d-4f9f-82d1-15e4dd97c56d">
        <source>valCargoType(_cargoType : Integer) : Boolean protected;
// ---------------------------------------------------------------------------
// Created:     28 November 2007 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	return self.allCargoTypeIDs.includes(_cargoType);
end;</source>
        <access>protected</access>
        <Parameter name="_cargoType" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="valOperators" id="7b2cac05-ac35-4861-a62d-2513a9261654">
        <source>valOperators(_txn: CM_TITransaction): Boolean protected;
// ---------------------------------------------------------------------------
// Created:     28 November 2007 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	ti : CM_TrackedItem;
begin
	//return self.allOperatorCodes.includes(_txn.operatorCode);
	if _txn = null then
		return false;
	endif;
	
	ti := _txn.myTrackedItem;
	//PAR18963.  The operator of the cargo item is required not the operator code of the transaction. 
	//cnwsh3 3/3/2009
	return self.allOperatorCodes.includes(ti.operatorCode);  
end;</source>
        <access>protected</access>
        <Parameter name="_txn" type="CM_TITransaction"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="valServices" id="7a7edbb5-130e-4280-abf8-ba8bcfac429b">
        <source>valServices(_txnType : Integer): Boolean protected;
// ---------------------------------------------------------------------------
// Created:     28 November 2007 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	return self.allTiTxnDetailTypes.includes(_txnType);
end;</source>
        <access>protected</access>
        <Parameter name="_txnType" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="valiFF" id="ed978391-26d0-41f9-a91b-040a686a7eed">
        <source>valiFF(_txn : CM_TITransaction): Boolean protected;
// ---------------------------------------------------------------------------
// Created:     28 November 2007 by cnwaer1
//
// Changes:
// PAR 16898 - RJS June 2008 - change for FF on transaction  
// PAR18746 - cnwsh3 Feb 2009 - GDansk requested change back to reporting the ff on the ti and not the txn.			
// ---------------------------------------------------------------------------
vars
	ti : CM_TrackedItem;
begin
	if _txn = null then
		return false;
	endif;
	
	ti :=_txn.myTrackedItem;
	//return self.allFreightForwarders.includes(_txn.getMyFreightForwarder);  //PAR18746
	return self.allFreightForwarders.includes(ti.myFreightForwarder);
end;</source>
        <access>protected</access>
        <Parameter name="_txn" type="CM_TITransaction"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateDtlTxn" id="fe6bf4db-b5ba-45b7-89d9-ed76238a78c3">
        <source>validateDtlTxn(_txn: CM_TITransaction; _passport : CM_Passport; isVoyage : Boolean) : Boolean protected;
// ---------------------------------------------------------------------------
// Created:     28 November 2007 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	ti	: CM_TrackedItem;
	dac	: CM_DataAccessController;
	txnType	: Integer;
begin
	ti := _txn.myTrackedItem;
	if ti = null then
		return false;
	endif;
	
	if ((not self.hasCargoTypes) or (self.hasCargoTypes and self.valCargoType(ti.cargoType))) and
	   ((not self.hasFreightForwarders) or (self.hasFreightForwarders and self.valiFF(_txn))) and	// PAR 16898 - RJS June 2008
	   //((not self.hasFreightForwarders) or (self.hasFreightForwarders and self.valiFF(ti))) and
	   ((not self.hasOperators) or (self.hasOperators and self.valOperators(_txn)))
	then
		if ti.canUserViewMe(null, _passport, true, true, true, true, true, dac) then
			return true;
		endif;
	endif;

	return false;
end;</source>
        <access>protected</access>
        <Parameter name="_txn" type="CM_TITransaction"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="isVoyage" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateSumTxn" id="e132865b-7184-448c-8f6d-e866ba1de6ab">
        <source>validateSumTxn(_txn: CM_TITransaction; _passport : CM_Passport) : Boolean  protected;
// ---------------------------------------------------------------------------
// Created:     14 February 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
begin
		//imExStatus = (Inport  or Export)            and (contentsStatus = (MT or FCL))       
	if (_txn.imExStatus = 1 or _txn.imExStatus = 2 ) and (_txn.contentsStatus = 3 or _txn.contentsStatus = 1) then
		if (not self.hasFreightForwarders) and (not self.hasOperators) then
			return true;
		endif;
		if self.hasFreightForwarders and 
		   self.hasOperators then
			if self.valiFF(_txn) and		// PAR 16898 - RJS June 2008
			   self.valOperators(_txn) then
				return true;
			endif;
		elseif (((self.hasFreightForwarders and self.valiFF(_txn)) or 		// PAR 16898 - RJS June 2008
		   (self.hasOperators and self.valOperators(_txn)))) then
			return true;
		endif;
		return false;
	else
		return false;
	endif;
end;
</source>
        <access>protected</access>
        <Parameter name="_txn" type="CM_TITransaction"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
