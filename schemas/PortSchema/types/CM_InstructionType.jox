    <JadeMethod name="setForCreate" id="79877ae6-9ace-41f4-8c01-fade28ec9aa1">
        <updating/>
        <source>setForCreate(_pxyIstructionType : CM_InstructionType) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Oct 2022 navtnr20 ChangeRequest 54967: EUP - INB/OUT - Operational Instructions

*/

vars

begin
	self.setForUpdate(_pxyIstructionType);
epilog

end;</source>
        <Parameter name="_pxyIstructionType" type="CM_InstructionType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="6280c544-e69a-471a-9712-6045a43a0cc2">
        <updating/>
        <source>setForUpdate(_pxyInstructionType : CM_InstructionType) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Oct 2022 navtnr20 ChangeRequest 54967: EUP - INB/OUT - Operational Instructions
31 Aug 2023	jlizm1	TFS 59567 Kiosk instruction type maint

*/

vars

begin
	self.description 			:= _pxyInstructionType.description;
	self.code 					:= _pxyInstructionType.code;
	self.notAvailableForEntry  := _pxyInstructionType.notAvailableForEntry;
	self.alwaysToGateOffice		:= _pxyInstructionType.alwaysToGateOffice;
	self.myTerminal				:= _pxyInstructionType.myTerminal;
	
	self.allTrailerTypes.clear();
	_pxyInstructionType.allTrailerTypes.copy(self.allTrailerTypes);
	
epilog

end;</source>
        <Parameter name="_pxyInstructionType" type="CM_InstructionType"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="20ef14c0-04e5-4303-9797-769fd5995508">
        <updating/>
        <source>setProxy( _code, 
		  _description : String;
		  _notAvailableForEntry : Boolean;
		  _alwaysToGateOffice : Boolean;
		  _trailerTypes : CM_TILCTypeByCodeDict;
		  _terminal : CM_Terminal) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Oct 2022 navtnr20 ChangeRequest 54967: EUP - INB/OUT - Operational Instructions
31 Aug 2023	jlizm1	TFS 59567 Kiosk instruction type maint

*/

vars

begin
	self.raiseExceptionIfNotTransient(method);
	self.code 			:= _code;
	self.description 	:= _description;
	self.notAvailableForEntry := _notAvailableForEntry;
	self.alwaysToGateOffice := _alwaysToGateOffice;
	self.myTerminal		:= _terminal;
	
	self.allTrailerTypes.clear();
	if _trailerTypes &lt;&gt; null then
		_trailerTypes.copy(self.allTrailerTypes);
	endif;
	
epilog

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_notAvailableForEntry" type="Boolean"/>
        <Parameter name="_alwaysToGateOffice" type="Boolean"/>
        <Parameter name="_trailerTypes" type="CM_TILCTypeByCodeDict"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="aac4b79a-d309-4bee-91c0-6c1ecaa4cd65">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Oct 2022 navtnr20 ChangeRequest 54967: EUP - INB/OUT - Operational Instructions

*/

vars

begin
	if _property = null then
		return false;
	endif;
	
	return inheritMethod(_rootClass, _property);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
