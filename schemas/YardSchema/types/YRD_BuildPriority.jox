    <JadeMethod name="buildComboCargoType" id="7b4ea0a6-deaf-4d42-819b-85c41062478c">
        <source>buildComboCargoType();
// ---------------------------------------------------------------------------
// Created:		December  2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	defCargoBOLTypeId			: Integer;
begin
	defCargoBOLTypeId := app.myPassport.getDefaultCargoBOLTypeId();
  self.myAssistant.comboBoxCargoBolType(self.cmbTiType, defCargoBOLTypeId, true, true, true, true);
  
  // This is the new one for after 7.4.1 release	
//  self.myAssistant.comboBoxCargoBOLTypeGate(self.cmbTiType, defCargoBOLTypeId, true, true, true);
//	self.myAssistant.comboBoxCargoBolType(self.cmbTiType, defCargoBOLTypeId, true, true, true, true);
	self.cmbTiType.lostFocus(self.cmbTiType);
	self.myAssistant.comboBoxCargoBolType(self.cmbCargoType, defCargoBOLTypeId, true, true, true, true);
	
	// This is the new one for after 7.4.1 release	
	//self.myAssistant.comboBoxCargoBOLTypeGate(self.cmbCargoType, defCargoBOLTypeId, true, true, true);
//	change required to make combo handle general cargo types for demo. HG 2/12/05
//	self.myAssistant.comboBoxCargoBolType(self.cmbCargoType, defCargoBOLTypeId, true, true, true, true);
	self.cmbCargoType.lostFocus(self.cmbCargoType);	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="buildComboConsignor" id="321f14bf-d5ee-4cf3-97d9-78032fc8ac9c">
        <source>buildComboConsignor();
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
begin

	self.cmbConsignee.clear;
	
	self.myAssistant.comboBoxConsignor(self.cmbConsignee, null, CONSIGNEE);
	self.myAssistant.comboBoxConsignor(self.cmbFiltConsignee, null, CONSIGNEE);
//	self.myAssistant.comboBoxConsignor(cmbDestination, null);	
		
end;</source>
    </JadeMethod>
    <JadeMethod name="buildComboFreightForwarder" id="773d0354-54ea-492d-b8ac-13fa4d66e4af">
        <source>buildComboFreightForwarder();
/*
----------   ----------  --------------------------------------------------
Created:	21 November 2006 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	self.cmbFreightFwdr.clear;
	self.cmbFiltFrghtFwdr.clear;
	self.myAssistant.comboBoxConsignor(self.cmbFreightFwdr, null,FREIGHT_FORWARDER);
	self.myAssistant.comboBoxConsignor(self.cmbFiltFrghtFwdr, null,FREIGHT_FORWARDER);

end;
</source>
    </JadeMethod>
