    <JadeMethod name="getNumOfTIsOnBackendAsPrimary" id="b3be87f6-3260-4a93-a0b4-6999f94b5287">
        <source>getNumOfTIsOnBackendAsPrimary(_last : Boolean): Integer;
// ---------------------------------------------------------------------------
// Created:     18 March 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lc : CM_LocationsController;
	tmpTI : CM_TrackedItem;
begin
	if self.allLocationsControllers.size &gt; 1 then
		if _last then
			lc := self.allLocationsControllers.last;
		else
			lc := self.allLocationsControllers.first;
		endif;
		if lc.allTrackedItems.size &gt; 0 then
			tmpTI :=  lc.allTrackedItems[1];
			if tmpTI.myPrimaryActualLocation = lc then
				return lc.allTrackedItems.size ;
			endif;
		endif;
	endif;
	
	return 0;
epilog

end;</source>
        <Parameter name="_last" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getPrimaryLocation" id="0a9a3fa7-c11b-48c9-85d1-681e9ef4aa71">
        <source>getPrimaryLocation() : CM_LocationsController;
/*
------------------------------------------------------------------------
Created:			27 February 2003 by cnwdwq1
Purpose:			Dave Q's code
Parameters:		See Method signature above. Special comment:
Returns:			See Method signature above. Special comment:
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														
------------------------------------------------------------------------
*/
vars

	firstLocation : CM_LocationsController;
	invalidObject : Boolean;
	ed : Integer;

begin

	//return self.allLocationsControllers.first;

	if self.allLocationsControllers = null then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject( exception, self, invalidObject );
	on Exception do app.handleDeletedObject( exception, self.allLocationsControllers, invalidObject );
	on Exception do app.handleDeletedObject( exception, firstLocation, invalidObject );
	firstLocation := self.allLocationsControllers.first();
	
	if invalidObject then
		return null;
	endif;
	
	if firstLocation &lt;&gt; null then
		ed := firstLocation.edition;
	endif;
	
	if invalidObject then
		return null;
	endif;
	
	return firstLocation;
	
	

end;</source>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="getPrimaryLocationId" id="fb3e3c84-8788-46bd-b1d3-02a6b9a8f2c8">
        <source>getPrimaryLocationId(): String;
// ---------------------------------------------------------------------------
// Created:     04 November 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 05/04/2016	cnwdap1		Initial creation PAR #37738 Special wellcar wagon id code
// 11/11/2024	navdap1		MTN-18897 EUP | FR 53485 EUP - Warehouse Yard Allocation
// ---------------------------------------------------------------------------
vars
	lc	: CM_LocationsController;
	id	: String;								// PAR #37738
begin
	
	if self.allLocationsControllers.isEmpty then
		return null;
	endif;
	
	lc := self.allLocationsControllers.first;
	if lc = null then
		return null;
	endif;
	
	if lc.isWagonInUPSPFormat(self.myTrackedItem, id) then		// PAR #37738
		return id;												// PAR #37738
	endif;														// PAR #37738
	
	// MTN-18897
	if self.isMoveToFullGCArea then
		if lc.myTerminalArea &lt;&gt; null then
			return lc.myTerminalArea.id;
		endif;
	endif;
	// MTN-18897 end
	
	return lc.getFullIdForTIForMode(PLANNING_MODE);

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTIFromBackend" id="90c75225-b7b9-4b9d-b732-f2c0ef47d807">
        <source>getTIFromBackend(_index : Integer) : CM_TrackedItem;
// ---------------------------------------------------------------------------
// Created:     18 March 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lc : CM_LocationsController;
begin
	if self.allLocationsControllers.size &gt; 1 then
		lc := self.allLocationsControllers.last;
		if _index &lt;= lc.allTrackedItems.size then
			return lc.allTrackedItems[_index];
		endif;
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_index" type="Integer"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
