    <JadeMethod name="zDoDelete" id="774f00d1-0454-445d-9890-6c20bf0f277c">
        <updating/>
        <source>zDoDelete() updating, protected;
// ---------------------------------------------------------------------------
// Created:     22 July 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
//				Reimplemented as superclass framework does not allow for re-display
//				of list
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if self.lstData.listIndex &lt;&gt; -1 then
		if self.confirmDelete ('this item', null) then
			if self.doDelete() then
				self.myCurrentObject := null;
				self.zLstDataShow();
				self.zLstDataSelectObject(self.myCurrentObject);
			endif;
		endif;
	else
		app.msgBox('You must select an object to delete', 'Error', MsgBox_OK_Only);
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zDoEdit" id="0c0a12e8-ddfb-4b5a-9c82-aa8e7e5db793">
