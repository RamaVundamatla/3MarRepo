			userTerminal := self.myTerminal.allUserTerminals[self.myUser.code];
			if userTerminal &lt;&gt; null and 
			   userTerminal.myDefaultCargoType &lt;&gt; null then
				return userTerminal.myDefaultCargoType;
			endif;
		endif;
		
		foreach bolType in term.allCargoBOLTypes do
			if bolType.id = term.defaultCargoType then
				return bolType.CM_CargoType;
			endif;
		endforeach;
		
//		return term.allCargoBOLTypes[term.defaultCargoType].CM_CargoType;
	endif;

end;</source>
        <ReturnType type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="getErrorsAndWarningsAsString" id="2d43650b-872c-446e-8d6d-91c74cc69f21">
        <source>getErrorsAndWarningsAsString() : String;
// ---------------------------------------------------------------------------
// Created:     cnwrs1 par 28696 ccms 2122 06 Dec 2011
// ---------------------------------------------------------------------------
/*
Date		Who		Reason
05/12/2011  cnwrs1  CCMS POL 2122 / PAR 28696 - add support for EDI Release Request processing
*/
vars
	error : CM_Error;
	str : String;
	
begin
	foreach error in self.allErrorWarnings do
		if str = null then
			str := error.getDetailsAsString;
		else
			str := str &amp; CrLf &amp; error.getDetailsAsString;
		endif;
	endforeach;
	
	return str;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getErrorsAsString" id="96ca8c2d-39f6-42c9-8fa2-4410679fe04e">
