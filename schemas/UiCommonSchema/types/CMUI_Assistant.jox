vars

begin

//	pCmb.listCollection(self.myTerminal.bulkReleases, true, 0); // AKB2005MAY
	// Par 15233
	//self.comboBoxBulkRelByTypeStatus(pCmb, app.getErrorString(BR_TYPE_DESCR_ROAD), BR_ACTIVE_STRING, pRelease);	// PAR #27972
	self.comboBoxBulkRelByTypeStatus(pCmb, BR_TYPE_ROAD_STR, BR_ACTIVE_STRING, pRelease);							// PAR #27972
