<PrimType name="Integer">
    <JadeMethod name="asBinary" id="09ac89eb-f02f-4014-a635-1485f9ed3676">
        <source>asBinary(_numBinaryDigits: Integer) : Binary;
// ---------------------------------------------------------------------------
// Created:     24 June 2003 by cnwsb1
//
// Purpose:		Converts integer into a Hexadecimal-based binary of the
//				required digits (using leading binary zeros if necessary).
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
29 Jun 2015	cnwkpd1	PAR #36286 - Unicode JADE - change use of Character to Byte for
					this calculation
	
*/

constants
	HexMax = 256;

vars
	modValue : Integer;
	remainder : Integer;
	bin : Binary;
	numDigits : Integer;
	idx : Integer;

begin
	remainder := self;
	
	while remainder &gt;= HexMax do
		modValue := remainder mod HexMax;
		remainder := remainder div HexMax;
		bin := modValue.Byte.Binary &amp; bin;
		numDigits := numDigits + 1;
	endwhile;
	
	bin := remainder.Byte.Binary &amp; bin;

	foreach idx in 1 to (_numBinaryDigits - numDigits - 1) do
		bin := 0.Byte.Binary &amp; bin;
	endforeach;
	
	return bin;
end;</source>
        <Parameter name="_numBinaryDigits" type="Integer"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="asBinaryNumber" id="939ac4b0-f29a-468c-a1aa-4d93f9452ab8">
        <source>asBinaryNumber() : String;
// ---------------------------------------------------------------------------
// Created:     11 November 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	quotient	: Integer;
	s		: String;
	
begin

	quotient := self;
	
	while quotient &gt;= 2 do
		s := (quotient mod 2).String &amp; s;
		quotient := (quotient / 2).Integer;
	endwhile;
	
	s := quotient.String &amp; s;

	return s;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="asDHMString" id="7c488a46-5771-47bb-bdad-5cdbbd4750d3">
        <source>asDHMString() :String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 May 2010	cnwer1	Initial creation

*/

vars
	days, 
	hours, 
	minutes,
	hoursleft : Integer;
	returnStr : String;
begin
		// set code here
	days := self div (24 * 60);
	hoursleft := self mod (24 * 60);
	hours := hoursleft div 60;
	minutes := hoursleft mod 60;
	
	if days &gt; 0 then
		returnStr:= days.asStringJMT() &amp; 'D, ';
	endif;
	
	if hours &gt; 0 then
		returnStr:=returnStr &amp; hours.asStringJMT() &amp; 'H ';
	endif;
	
	if minutes &gt; 0 then
		returnStr:=returnStr &amp; minutes.asStringJMT() &amp; 'm';
	endif;
	
	return returnStr;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="asDaysHoursMinutesString" id="ea5280d7-bc1c-49c7-b0c6-8558f41625c6">
        <source>asDaysHoursMinutesString() : String;
// ---------------------------------------------------------------------------
// Created:     18 October 2006 by cnwrs2
//
// Purpose:     self = minutes
//				returns string of days, hours, mins that make up self
// ---------------------------------------------------------------------------
vars
	days, 
	hours, 
	minutes,
	hoursleft : Integer;

begin
		// set code here
	days := self div (24 * 60);
	hoursleft := self mod (24 * 60);
	hours := hoursleft div 60;
	minutes := hoursleft mod 60;
	
	if days &gt; 0 then
		return days.asStringJMT() &amp; ' days, ' &amp;
			hours.asStringJMT() &amp; ' hrs, ' &amp; 
			minutes.asStringJMT() &amp; ' mins';
	elseif hours &gt; 0 then
		return hours.asStringJMT() &amp; ' hrs, ' &amp; 
			minutes.asStringJMT() &amp; ' mins';
	else
		return minutes.asStringJMT() &amp; ' mins';
	endif;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="asHex" id="6ab82fdb-64d9-4637-9b4d-9723a59c276e">
        <source>asHex(_numHexCharacters: Integer) : String;
// ---------------------------------------------------------------------------
// Created:     06 June 2003 by cnwsb1
//
// Purpose:		Converts integer into a Hexadecimal string.  The result will
//				have an even number of hex characters, padded to the
//				_numHexCharacters value given.
// ---------------------------------------------------------------------------
constants
	HexMax = 256;

vars
	modValue : Integer;
	remainder : Integer;
	hexString : String;

begin
	remainder := self;
	
	while remainder &gt;= HexMax do
		modValue := remainder mod HexMax;
		remainder := remainder div HexMax;
		hexString := modValue.Character.toHex &amp; hexString;
	endwhile;
	
	hexString := remainder.Character.toHex &amp; hexString;
	
	return hexString.padLeadingZeros(_numHexCharacters);
end;</source>
        <Parameter name="_numHexCharacters" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="asHexReversed" id="4b4a9d48-f8c6-431f-bfc0-b32a361312a0">
        <source>asHexReversed(_numHexCharacters: Integer) : String;
// ---------------------------------------------------------------------------
// Created:     06 June 2003 by cnwsb1
//				modified by Mohammad
//
// Purpose:		Converts integer into a Hexadecimal string and returns a reversed representation of the Hexadecimal string.  The result will
//				have an even number of hex characters, padded to the
//				_numHexCharacters value given.
// ---------------------------------------------------------------------------
constants
	HexMax = 256;

vars
	modValue : Integer;
	remainder : Integer;
	hexString : String;

begin
	remainder := self;
	
	while remainder &gt;= HexMax do
		modValue := remainder mod HexMax;
		remainder := remainder div HexMax;
		hexString :=  hexString &amp; modValue.Character.toHex ;
	endwhile;
	
	hexString :=  hexString &amp; remainder.Character.toHex ;
	
	return hexString.padLeadingZeros(_numHexCharacters);
end;</source>
        <Parameter name="_numHexCharacters" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="asHexSTUFFED" id="f568873e-ba96-430c-973f-df3c5ce58d2d">
        <source>asHexSTUFFED(_numHexCharacters: Integer) : String;
// ---------------------------------------------------------------------------
// Created:     06 June 2003 by cnwsb1
//
// Purpose:		Converts integer into a Hexadecimal string.  The result will
//				have an even number of hex characters, padded to the
//				_numHexCharacters value given.
// ---------------------------------------------------------------------------
constants
	HexMax = 256;

vars
	modValue : Integer;
	remainder : Integer;
	hexString : String;

begin
	remainder := self;
	
	while remainder &gt; HexMax do
		modValue := remainder mod HexMax;
		remainder := remainder div HexMax;
		hexString := modValue.Character.toHex &amp; hexString;
	endwhile;
	
	hexString := remainder.Character.toHex &amp; hexString;
	
	return hexString.padLeadingZeros(_numHexCharacters);
end;</source>
        <Parameter name="_numHexCharacters" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="asNullInteger" id="2eeffad3-d1ed-4896-834c-dde4cacabf3e">
