<CollClass name="CM_BulkYACandidateSet" id="f07818d7-c42b-4e7e-b4b2-b0cb17755cfd">
    <loadFactor>66</loadFactor>
    <memberType name="CM_BulkYACandidate"/>
    <superclass name="CM_ObjectSet"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="yardAllocations"/>
    <JadeMethod name="getDescription" id="9b9d1a4b-501b-4f6b-aa22-1f4c2f42de7d">
        <source>getDescription() : String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 05/09/2025	navdap1		Initial creation MTN-35615 ENS | Bulk Creation of Yard Allocations
//
vars
	candidate : CM_BulkYACandidate;
	criteriaType : CM_YACriteriaType;
	result : String;

begin
	if self.isEmpty then
		return null;
	endif;
	
	candidate := self.first;
	criteriaType := app.myRoot.allYACriteriaTypes[candidate.criteriaType];
	result := criteriaType.description;
	foreach candidate in self do
		result := result &amp; Space &amp; candidate.getCriteriaValueForDisplay();
	endforeach;
	
	return result;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNumberofTIs" id="c0900dfb-3f44-4131-8c73-039414d658c5">
        <source>getNumberofTIs() : Integer;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 05/09/2025	navdap1		Initial creation MTN-35615 ENS | Bulk Creation of Yard Allocations
//
vars
	candidate : CM_BulkYACandidate;
	total : Integer;

begin
	foreach candidate in self do
		total := total + candidate.allMatchingTIs.size;
	endforeach;
	
	return total;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
</CollClass>
