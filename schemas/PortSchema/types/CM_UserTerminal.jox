    <JadeMethod name="setMyUserForProxy" id="c5dfa9ff-e2ed-45bf-a9fe-0f18eb987def">
        <updating/>
        <source>setMyUserForProxy(_user : CM_User) updating;
// ---------------------------------------------------------------------------
// Created:     11 July 2002 by cnwrs2
