    <JadeMethod name="isValidAreaForRTMoveMethod" id="1d9c2795-ebf8-4c41-9a13-f6a36e69bd10">
        <source>isValidAreaForRTMoveMethod(_rtMoveMethod: CM_RTMoveMethod; _isSource: Boolean): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 February 2010	cnwer1	Initial creation

*/

vars

begin
	if _isSource then
		if _rtMoveMethod.allMachineTypeGroups.first.type &lt;&gt; MACHINETYPEGRP_STRADDLE then
			return false;
		endif;
	else
		if _rtMoveMethod.allMachineTypeGroups.last.type &lt;&gt; MACHINETYPEGRP_STRADDLE then
			return false;
		endif;
	endif;


	return true;


epilog

end;</source>
        <Parameter name="_rtMoveMethod" type="CM_RTMoveMethod"/>
        <Parameter name="_isSource" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="labourRestrictionLightsPOA" id="ecfdd7b1-bcf8-4a67-aeba-a9766a87518d">
        <source>labourRestrictionLightsPOA(_eastLightIsOn, _westLightIsOn :Boolean output);
// Port Otago Area A // Par 17827 CCMS 1507 Hook for Port Otago
// This code is very specific to the set up of the Port Otago A (Alpha) stack.
// It should only be ever called from CM_Terminal::handleWarningLights
// Note that Port Otago use Subareas to apply LOB. The Substation sub area is bits of row 10-13 
// (labelled 20 - 23). 
// Conceivably they could apply LOB to locations in rows 10 -13 - this would not turn on the light. 
// However this is not how Otago use the system.
constants
	HighestRowBeforeSubStation	: Integer = 9; // Row "19"
	LowestRowAfterSubStation	: Integer = 14; // Row "24"
vars
	labourRestriction 		: CM_LabourRestriction;
	stackController			: CM_LocationsController;
	isEastIgnored			: Boolean;
	isWestIgnored			: Boolean;
begin
	foreach labourRestriction in self.allRestrictionsLabour do
// cnwdad1 02/06/2010 - CCMS 1947 - Ignore Warning Lights setting.
		if labourRestriction.ignoreLights then
			continue;
		endif;
		
		foreach stackController in labourRestriction.allLocationControllers do
			if stackController.isKindOf(CM_StackController) then //cnwgb1 PAR 18671 16.12.2008 (Gap controllers!)
				if stackController.CM_StackController.row &lt;= HighestRowBeforeSubStation then
					if not _eastLightIsOn then
						_eastLightIsOn	:= true;
					endif;
				elseif stackController.CM_StackController.row &gt;= LowestRowAfterSubStation then
					if not _westLightIsOn then
						_westLightIsOn	:= true;
					endif;
				endif;
			endif;
			if _eastLightIsOn and _westLightIsOn then
				return;
			endif;
		endforeach;
	endforeach;
end;</source>
        <Parameter name="_eastLightIsOn" type="Boolean" usage="output"/>
        <Parameter name="_westLightIsOn" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="labourRestrictionLightsPOA3" id="268b944f-648b-4943-b3a3-1019f8474242">
        <source>labourRestrictionLightsPOA3(_eastLightIsOn, _westLightIsOn, _aplhaSubLightIsOn :Boolean output);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 September 2019	jlgndl1	Initial creation	TFS 46573 - 3 light version

*/

// Port Otago Area A // Par 17827 CCMS 1507 Hook for Port Otago
// This code is very specific to the set up of the Port Otago A (Alpha) stack.
// It should only be ever called from CM_Terminal::handleWarningLights7

constants
	EastAplhaMax	: Integer = 9; // Row "19"
	SubStationMin	: Integer = 10;	// Row "20"
	SubStationMax	: Integer = 13;	// Row ""23"
	WestAlphaMin	: Integer = 14; // Row "24"	
vars
	labourRestriction 		: CM_LabourRestriction;
	stackController			: CM_LocationsController;
	isEastIgnored			: Boolean;
	isWestIgnored			: Boolean;
begin
	foreach labourRestriction in self.allRestrictionsLabour do
		if labourRestriction.ignoreLights then
			continue;
		endif;
		
		foreach stackController in labourRestriction.allLocationControllers do
			if stackController.isKindOf(CM_StackController) then //cnwgb1 PAR 18671 16.12.2008 (Gap controllers!)
				if stackController.CM_StackController.row &lt;= EastAplhaMax then
					if not _eastLightIsOn then
						_eastLightIsOn	:= true;
					endif;
				elseif stackController.CM_StackController.row &lt;= SubStationMax and stackController.CM_StackController.row &gt;= SubStationMin then
					if not _aplhaSubLightIsOn then
						_aplhaSubLightIsOn	:= true;
					endif;
				elseif stackController.CM_StackController.row &gt;= WestAlphaMin then
					if not _westLightIsOn then
						_westLightIsOn	:= true;
					endif;
				endif;
			endif;
			if _eastLightIsOn and _westLightIsOn and _aplhaSubLightIsOn then
				//They are all on, no point in continuing to check
				return;
			endif;
		endforeach;
		
	endforeach;
end;</source>
        <Parameter name="_eastLightIsOn" type="Boolean" usage="output"/>
        <Parameter name="_westLightIsOn" type="Boolean" usage="output"/>
        <Parameter name="_aplhaSubLightIsOn" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="labourRestrictionLightsPOC" id="1ce92e19-fc4e-4f7a-9f02-e3670367402d">
        <source>labourRestrictionLightsPOC(_southLightIsOn, _northLightIsOn :Boolean output);
// Port Otago Area C // Par 17827 CCMS 1507 Hook for Port Otago
// This code is very specific to the set up of the Port Otago C (Charlie) stack.
// It should only be ever called from CM_Terminal::handleWarningLights
// Note that Port Otago use Subareas to apply LOB. The Substation sub area is row 14-16 
// (labelled 23, SS, 24). 
// Conceivably they could apply LOB to just Row 14 or Row 16 - this would not turn on the light. 
// However this is not how Otago use the system.
constants
	HighestRowBeforeSubStation	: Integer = 13; // Row "22"
	LowestRowAfterSubStation	: Integer = 17;  // Row "25" PAR 19670 cnwgb1 14.5.09
	HighestRowBeforePTIArea		: Integer = 25;  // Row "33" PAR 21433 cnwgb1 16.10.09 CCMS 1897
vars
	labourRestriction 		: CM_LabourRestriction;
	stackController			: CM_LocationsController;		
	isEastIgnored			: Boolean;
	isWestIgnored			: Boolean;
begin
	foreach labourRestriction in self.allRestrictionsLabour do
// cnwdad1 02/06/2010 - CCMS 1947 - Ignore Warning Lights setting.
		if labourRestriction.ignoreLights then
			continue;
		endif;
		
		foreach stackController in labourRestriction.allLocationControllers do
			if stackController.isKindOf(CM_StackController) then //cnwgb1 PAR 18671 16.12.2008 (Gap controllers!)
				if stackController.CM_StackController.row &lt;= HighestRowBeforeSubStation then
					if not _southLightIsOn then
						_southLightIsOn	:= true;
					endif;
				elseif stackController.CM_StackController.row &gt;= LowestRowAfterSubStation and 
				   stackController.CM_StackController.row &lt;= HighestRowBeforePTIArea then //cnwgb1 PAR 21433 16.10.2009
					if not _northLightIsOn then
						_northLightIsOn	:= true;
					endif;
				endif;
			endif;
			if _southLightIsOn and _northLightIsOn then
				return;
			endif;
		endforeach;
	endforeach;
end;
</source>
        <Parameter name="_southLightIsOn" type="Boolean" usage="output"/>
        <Parameter name="_northLightIsOn" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="labourRestrictionLightsPOC4" id="6d570d8e-183b-45d8-a1ef-1bd5845d8839">
        <source>labourRestrictionLightsPOC4(_southLightIsOn, _northLightIsOn, _charlieSubStationIsOn, ptiAreaLightIsOn :Boolean output);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 September 2019	jlgndl1	Initial creation	TFS 46573 - 4 light version

*/

// Port Otago Area C // Par 17827 CCMS 1507 Hook for Port Otago
// This code is very specific to the set up of the Port Otago C (Charlie) stack.
// It should only be ever called from CM_Terminal::handleWarningLights7

constants
	CharlieSouthMax				: Integer = 13; // Row "22"
	CharlieSubStationMin		: Integer = 14;	// Row "23" (15 = "SS")
	CharlieSubStationMax		: Integer = 16; // Row "24"
	CharlieNorthMin				: Integer = 17;  // Row "25" 
	CharlieNorthMax				: Integer = 24;  // Row "32"   - This was 25 / "33"  in teh old one but according to the BRD PTI is "33"-"37" i.e. the last 5 rows now.
	PtiMin						: Integer = 25;	// Row "33"
vars
	labourRestriction 		: CM_LabourRestriction;
	stackController			: CM_LocationsController;		
	isEastIgnored			: Boolean;
	isWestIgnored			: Boolean;
begin
	foreach labourRestriction in self.allRestrictionsLabour do

		if labourRestriction.ignoreLights then
			continue;
		endif;
		
		foreach stackController in labourRestriction.allLocationControllers do
			if stackController.isKindOf(CM_StackController) then //cnwgb1 PAR 18671 16.12.2008 (Gap controllers!)
				if stackController.CM_StackController.row &lt;= CharlieSouthMax then
					if not _southLightIsOn then
						_southLightIsOn	:= true;
					endif;
				elseif stackController.CM_StackController.row &gt;= CharlieSubStationMin and stackController.CM_StackController.row &lt;= CharlieSubStationMax then
					if not _charlieSubStationIsOn then
						_charlieSubStationIsOn	:= true;
					endif;
				elseif stackController.CM_StackController.row &gt;= CharlieNorthMin and stackController.CM_StackController.row &lt;= CharlieNorthMax then
					if not _northLightIsOn then
						_northLightIsOn	:= true;
					endif;
				elseif stackController.CM_StackController.row &gt;= PtiMin then
					if not ptiAreaLightIsOn then
						ptiAreaLightIsOn	:= true;
					endif;
				endif;
			endif;
			if _southLightIsOn and _northLightIsOn and _charlieSubStationIsOn and ptiAreaLightIsOn then
				//They are all on, no point in continuing to check
				return;
			endif;
		endforeach;
	endforeach;
end;</source>
        <Parameter name="_southLightIsOn" type="Boolean" usage="output"/>
        <Parameter name="_northLightIsOn" type="Boolean" usage="output"/>
        <Parameter name="_charlieSubStationIsOn" type="Boolean" usage="output"/>
        <Parameter name="ptiAreaLightIsOn" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="queryConnectPower" id="f61edaad-522b-414f-ab30-1f4b1556148f">
        <source>queryConnectPower(theParams: CMIF_ConnectParams input; ti: CM_TrackedItem; connectMode: Integer; _lc: CM_LocationsController);
// ---------------------------------------------------------------------------
// Created:		29 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------


//Tests this TI against connecting to Power.
//NFS 3814 AA 25/9/01: Connect Mode indicate if this is an attempted connection or an
//attempted move. Attempted connection does not give warnings: you can connect or you can't.
constants
	MSGBOX_TITLE = "Target Location Query";
vars
	term	:	CM_Terminal;
	msgStr	:	String;
	locnId	:	String;
	lc	: CM_YardController;
	cntr : CM_Container;
	yc : CM_YardController;
begin
	if not _lc.isKindOf(CM_YardController) then
		return;
	endif;
	
	yc := _lc.CM_YardController;

	term := self.myTerminal;

	
	if ti = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException1(ERR_NO_OBJECT, "TI Ref in QueryConnectPowerJade", null, null);
		return;	
	endif;
		
	if ti.isKindOf(CM_Container) then
		cntr := ti.CM_Container;	
	else
		return;
	endif;
	
	if not cntr.requiresPower then
		return;
	endif;
	locnId := yc.getFullId;

	if yc.power = false then 

		if connectMode = QUERY_CONNECT then
			if theParams.radioTelemetryUser then
				term.createStringAlert(SEVERE_WARNING, app.getErrorString1(ERR_NO_POWER, locnId), null );		
			endif;
			//app.setContinueCMExceptions(false); changed for multiple connect  JC 10/11/2003
			app.raiseCMException1(ERR_NO_POWER, locnId &amp; ", " &amp; cntr.id &amp; " cannot be connected.", null, null);
			return;
		endif;
		
		if theParams.radioTelemetryIgnoreWarnings then
			return;	//If no power, then no sense in checking for power damaged!
		endif;
		if theParams.radioTelemetryUser then
			//Radio telemetry user. Create an alert, and raise an execption
			term.createStringAlert(SEVERE_WARNING, app.getErrorString(ERR_MOVE_RT_ERR), app.getErrorString1(WARN_NO_POWER, locnId) );
			app.setContinueCMExceptions(false);
			app.raiseCMException(ERR_MOVE_RT_ERR, null, null);
			return;			
		endif;
		app.raiseCMException1(WARN_NO_POWER,locnId, null, null);
		theParams.radioTelemetryGaveWarning := true;
	endif;

	if not yc.powerDamaged then
		return;	//Everything is OK, quit now.
	endif;

	if connectMode = QUERY_CONNECT then
		if theParams.radioTelemetryUser then
			term.createStringAlert(SEVERE_WARNING, app.getErrorString1(ERR_POWER_DAMAGED, locnId), null );		
		endif;
		app.setContinueCMExceptions(false);
		app.raiseCMException1(ERR_POWER_DAMAGED, locnId, null, null);
		return;
	endif;
	
	if theParams.radioTelemetryIgnoreWarnings then
		return;	//They dont want to know
	endif;
	if theParams.radioTelemetryUser then
		//Radio telemetry user. Create an alert, and raise an execption
		term.createStringAlert(SEVERE_WARNING, app.getErrorString(ERR_MOVE_RT_ERR), app.getErrorString1(WARN_POWER_DAMAGED, locnId) );
		app.setContinueCMExceptions(false);
		app.raiseCMException1(ERR_MOVE_RT_ERR, locnId, null, null);
		return;		
	endif;

	app.raiseCMException1(WARN_POWER_DAMAGED, locnId,null, null);
	theParams.radioTelemetryGaveWarning := true;

end;</source>
        <Parameter name="theParams" type="CMIF_ConnectParams" usage="input"/>
        <Parameter name="ti" type="CM_TrackedItem"/>
        <Parameter name="connectMode" type="Integer"/>
        <Parameter name="_lc" type="CM_LocationsController"/>
    </JadeMethod>
