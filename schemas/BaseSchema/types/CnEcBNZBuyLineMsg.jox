end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="checkPassword" id="337b73f9-fb00-4298-b0e6-0ee54dcc4e41">
        <source>checkPassword():String;

vars
	errorMessage	: String;
begin
	if self.password.trimBlanks = "" then
		errorMessage := "Password may not be blank.  ";
	endif;
epilog
	return errorMessage;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="checkResponse" id="87932796-8bd3-4df5-b928-7d133111cf71">
        <updating/>
        <source>checkResponse(pResponse : String; pSuccess : Boolean io) : String updating;

	// returns an error or sets respCode and respText.

vars
	vResponse	: String;
	vMessType	: Character;
	vOPSId		: Integer;
	vSeqNum		: Integer;
	vSettleNum	: Integer;
	vRespCode	: String;
	vRespText	: String;
	vTokens		: CnStringArray;
	vToken		: String;
	vFirstToken	: String;
	vTotal		: Integer;
	vPos		: Integer;
	errorString	: String;
	
begin
	vResponse := pResponse;
	pSuccess := false;
	
	// stripHeaderTrailer if required i.e STX ETX chars page 9.
	
	vTokens := pResponse.cnGetTokens(MESSAGE_DELIMITER);
	
	vTotal := vTokens.size();
	
	if vTotal &gt; 0 then
		vFirstToken := vTokens[1]; 	
		vMessType := vFirstToken[vFirstToken.length : 1].Character;
		
		if vTotal &gt; 2 then
			if vMessType = "D"
			or vMessType = "L"
			or vMessType = "Q"
			or vMessType = "T"
			or vMessType = "X" then
				vSettleNum := vTokens[3].Integer; 		
			elseif vMessType = "A"
			or vMessType = "C"
			or vMessType = "E"
			or vMessType = "P"
			or vMessType = "R"
			or vMessType = "V" then
				vSeqNum := vTokens[3].Integer;
			else
				errorString := "Invalid 'Message Type' in Response.  ";
				return errorString;	 		 
			endif;
		else
			errorString := "No 'settle or sequence number' in Response.  ";
			return errorString;				
		endif;
		
		if vTotal &gt; 3 then
			vRespCode := vTokens[4];
		else
			errorString := "No 'Response Code' in Response.  ";
			return errorString;			
		endif;	 		 
			
		if vTotal &gt; 4 then
			vRespText := vTokens[5];
		endif;
		
		if vTotal &gt; 5 then
			vPos := 6;
			while vPos &lt;= vTotal do
				vRespText := vRespText &amp; MESSAGE_DELIMITER &amp; vTokens[vPos];
				vPos := vPos + 1;
			endwhile;
		endif;		
		 	 
	else
		errorString := "No tokens found in the response.  ";
		return errorString;			
	endif;		
	
	if vSeqNum = self.seqNum and vSettleNum = self.settleNum then
		self.respCode	:=	vRespCode;
		self.respText	:=	vRespText;
		pSuccess		:=	self.isTransactionSuccess(errorString);
	else
		errorString := "Appears to be the wrong response. Sequence or Settle Number in the response, don't match the request.  ";
		return errorString;	
	endif;
epilog
	return errorString;
end;</source>
        <Parameter name="pResponse" type="String"/>
        <Parameter name="pSuccess" type="Boolean" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="checkSeqNum" id="494f3d9f-d67c-498a-9fb5-3484baa7550d">
        <source>checkSeqNum():String;

vars
	errorMessage	: String;
	
begin
	if self.seqNum &lt; 1001 then
		errorMessage := "Sequence Number too low.  ";
	elseif self.seqNum &gt; 999999 then
		errorMessage := "Sequence Number too high.  ";
	endif;		
epilog
	return errorMessage;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="checkSettleNum" id="28d72715-0770-497a-8624-ba2cf62f793f">
        <source>checkSettleNum():String;

vars
	errorMessage	: String;
	
begin
	if self.settleNum &lt; 1001 then
		errorMessage := "Batch Settle Number too low.  ";
	elseif self.settleNum &gt; 999999 then
		errorMessage := "Batch Settle Number too high.  ";
	endif;
epilog
	return errorMessage;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="displayExpiry" id="ea285a24-43ae-42fb-91a6-c79c2b6c5982">
        <source>displayExpiry():String;

vars
	retValue : String;
	
begin
	if self.expiry &lt;&gt; null then
		retValue := self.expiry.format("yyy MM");
	endif;
	
	return retValue;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="emailTheAdministrator" id="77d0fac7-1984-48e9-823e-aabd5850cbd8">
        <source>emailTheAdministrator(pBuyLineMessage : CnEcBNZBuyLineMsg; pError : String io);

vars
	subject			: String;
    message			: String;
    sender			: String;
    recipient		: String;
    reject			: CnEcBNZBuyLineMsg;
    ts				: TimeStamp;
    theTA			: CnEcEmailAgent;
    myEmailBaseData : CnEcEmailBaseData;
    email			: CnEcEmail;
    
//	kc					: CnKarmaCntrl;
//	sm					: CnSmtpConnection;
//	errorMsg			: String;
//	attachment			: CnAttachment;
//	pos					: Integer;
begin
	sender		:=	self.myManager.buyLineAdminEmailAddress;
	recipient	:=	self.myManager.buyLineAdminEmailAddress;
	
	if not pBuyLineMessage.isKindOf(CnEcBNZBuyLineVoid) then
	else
		reject := pBuyLineMessage.CnEcBNZBuyLineVoid.myMessageToVoid; 
		
		subject := "BNZ BuyLine Void message rejected. - Manual action required !";
		
		message := 	"A Credit Card Void transaction has been rejected.  " &amp;
			 		"  at " &amp; ts.String &amp; CrLf;
			 		
		message := message &amp; "A Void (that was attempting to reject a previously transmitted ";
		message := message &amp; "transaction that we received no response from) has been rejected.  ";
		message := message &amp; "It was rejected with the response Code of '" &amp; pBuyLineMessage.getRespCode();
		message := message &amp;  "' interpreted as '" &amp; pBuyLineMessage.getStringForRespCode() &amp; "'.  " &amp; CrLf;   
		message := message &amp; "As no response was received for the original message within the ";
		message := message &amp; "timeout period, the User Application will have assumed the original Message failed.  " &amp; CrLf;
		message := message &amp; "It is possible that the original message was processed within the ";
		message := message &amp; "BuyLine system, and the response was simply lost.  " &amp; CrLf;
		message := message &amp; "The original Transaction should now be checked to ensure that it ";
		message := message &amp; "has not been processed by BNZ BuyLine.  " &amp; CrLf &amp; CrLf;
		message := message &amp; "The details of the original Transaction that we were attempting to Void are:  "; 
		message := message &amp; "Transaction Type =  " &amp; reject.getTrxString() &amp; ".  ";  
		message := message &amp; "Amount =  " &amp; reject.getAmount().String;
		message := message &amp; "Card Number =  " &amp; reject.getCardNum().String; 
		message := message &amp; "Expiry =  " &amp; reject.displayExpiry();
		message := message &amp; "Sequence Number =  " &amp; reject.getSeqNum().String;   
		message := message &amp; "Settle Number =  " &amp; reject.getSettleNum().String &amp; CrLf &amp; CrLf;
		message := message &amp; "No further action will be taken by the User system.";
		message := message &amp; "Dependant upon the transaction type and response code, a Refund may be required to be generated, ";
		message := message &amp; "if so, this must be generated manually from the information above.  " &amp; CrLf;
		message := message &amp; "In addition, the 'Void' message will need to be manually deleted from the User system.  " &amp; CrLf;
	endif;
	
	create theTA transient;
	
	myEmailBaseData := CnEcEmailBaseData.firstInstance();
	
	pError := theTA.trxCnEcEmailCreate(	myEmailBaseData,	//pCnEcEmailBaseDataParent : CnEcEmailBaseData io;
										null,	//pAllAttachmentsArray:StringArray;
										null,	//pBccList:String;
										null,	//pCcList:String;
										null,	//pContentType:String;
										null,	//pEncodingType:String;
										message,	//pMessageBody:String;
										subject,	//pMessageHeader:String;
										myEmailBaseData,	//pMyEmailBaseData:CnEcEmailBaseData;
										ts,	//pSentTime:TimeStamp;
										recipient,	//pSentTo:String;
										email	//pCnEcEmailNew : CnEcEmail output
										);
	
	if pError = null then
		email.sendMeFromCode(recipient);
	endif;
epilog
	delete theTA;
end;</source>
        <Parameter name="pBuyLineMessage" type="CnEcBNZBuyLineMsg"/>
        <Parameter name="pError" type="String" usage="io"/>
    </JadeMethod>
