    <JadeMethod name="cmbLogLocation_gotFocus" id="1957ae28-1e02-4967-abff-5bed413d32ef">
        <controlMethod name="ComboBox::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbLogLocation_gotFocus(combobox: ComboBox input) updating;
// -----------------------------------------------------------------------------
// Created:		22 April 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	assist 		: GTE_Assistant;
	selectedObj	: Object;
	tmpSheet	: GTE_Sheet;
	tmpCompare	: CMIF_SearchTypes;
begin

	selectedObj := combobox.listObject;
	assist		:= self.myAssistant.GTE_Assistant;
	tmpSheet	:= self.topSheet;
	if tmpSheet = null then
		return;
	endif;
	tmpCompare	:= tmpSheet.mySearchTypeCompare;
	
	// PAR-15424 - change to use references on sheet and not assistant

	if 	tmpCompare.myOperator	&lt;&gt; tmpSheet.myOperator or
		tmpCompare.mySpecies	&lt;&gt; tmpSheet.myLogSpecies or
		tmpCompare.myGrade		&lt;&gt; tmpSheet.myLogGrade or
		tmpCompare.myType		&lt;&gt; tmpSheet.myLogType or
		tmpCompare.myTreatment	&lt;&gt; tmpSheet.myLogTreatment or
		tmpCompare.myLength		&lt;&gt; tmpSheet.myLogLength then
	
		tmpCompare.myOperator	:= tmpSheet.myOperator;
		tmpCompare.mySpecies	:= tmpSheet.myLogSpecies;
		tmpCompare.myGrade		:= tmpSheet.myLogGrade;
		tmpCompare.myType 		:= tmpSheet.myLogType;
		tmpCompare.myTreatment	:= tmpSheet.myLogTreatment;
		tmpCompare.myLength		:= tmpSheet.myLogLength;

		self.myTerminal.availableLocationsForType(tmpCompare, tmpSheet.allLogLocations, TA_TYPE_LOGAREA);
		assist.comboBoxLocationControllers(combobox, tmpSheet.allLogLocations, false);
	endif;

	if selectedObj &lt;&gt; null and
	   tmpSheet.allLogLocations.includes(selectedObj.CM_LocationsController) then
		combobox.listObject := selectedObj;
		combobox.text := assist.displayEntryLocationController(selectedObj.CM_LocationsController);
	endif;

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
