    <JadeMethod name="setDateFromTemplate" id="fefa8b11-0543-44ad-9af4-b267ff0b5a1e">
        <source>setDateFromTemplate(_tplType, _tplFactor : Integer; _runDate : Date) : Date protected;
// ---------------------------------------------------------------------------
// Created:     07 March 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpDate			: Date;
begin

	if (not _runDate.isValid) then
	//	app.raiseCMException1(REQUIRED_FIELD, 'run date', null, null);
		app.raiseCMException(Input_required_field_runDate, null, null); // cnwdb2	PAR 35364
		return null;
	endif;

	if _tplType = RTPL_RunDate then
		return _runDate;
	elseif _tplType = RTPL_RunDatePlus then
		return _runDate + _tplFactor;
	elseif _tplType = RTPL_RunDateMinus then
		return _runDate - _tplFactor;
	
	elseif _tplType = RTPL_RunMonthStart then
		tmpDate := _runDate;
		tmpDate.setDate(1, tmpDate.month, tmpDate.year);
		return tmpDate;
	elseif _tplType = RTPL_RunMonthStartPlus then
		tmpDate := _runDate.cnEcAddMonths(_tplFactor);
		tmpDate.setDate(1, tmpDate.month, tmpDate.year);
		return tmpDate;
	elseif _tplType = RTPL_RunMonthStartMinus then
		tmpDate := _runDate.cnEcAddMonths(-_tplFactor);
		tmpDate.setDate(1, tmpDate.month, tmpDate.year);
		return tmpDate;
	
	elseif _tplType = RTPL_RunMonthEnd then
		tmpDate := _runDate;
		tmpDate.setDate(tmpDate.cnEcDaysInMonth, tmpDate.month, tmpDate.year);
		return tmpDate;	
	elseif _tplType = RTPL_RunMonthEndPlus then
		tmpDate := _runDate.cnEcAddMonths(_tplFactor);
		tmpDate.setDate(tmpDate.cnEcDaysInMonth, tmpDate.month, tmpDate.year);
		return tmpDate;
	elseif _tplType = RTPL_RunMonthEndMinus then
		tmpDate := _runDate.cnEcAddMonths(-_tplFactor);
		tmpDate.setDate(tmpDate.cnEcDaysInMonth, tmpDate.month, tmpDate.year);
		return tmpDate;
		
	endif;
	//we don't have template default so just return what we passed in
	//this will mean from the report runner, if no default has been specified, it will
	//be today's date
	return null;
end;</source>
        <access>protected</access>
        <Parameter name="_tplType" type="Integer"/>
        <Parameter name="_tplFactor" type="Integer"/>
        <Parameter name="_runDate" type="Date"/>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="setDatesForTemplateRun" id="fed1c7f8-fa03-4fcd-a230-30b8cf9a81ae">
        <updating/>
        <source>setDatesForTemplateRun(_runDate : Date) updating;
// ---------------------------------------------------------------------------
// Created:     10 March 2003		cnwth2	
//
// Purpose:     Called before actually running the template - sets self's date properties from the template info
// ----------   ----------  --------------------------------------------------
vars

begin
	self.endDate := self.setDateFromTemplate(self.endDateTplType, 
											self.endDateTplFactor, 
											_runDate);

	self.startDate := self.setDateFromTemplate(self.startDateTplType, 
											self.startDateTplFactor, 
											_runDate);

	self.baseDate := self.setDateFromTemplate(self.baseDateTplType, 
											self.baseDateTplFactor, 
											_runDate);
end;</source>
        <Parameter name="_runDate" type="Date"/>
    </JadeMethod>
    <JadeMethod name="setDefaultStartEndDates" id="89fc1169-c38c-4690-af0a-c5ca7ae6f3f7">
        <updating/>
        <source>setDefaultStartEndDates(_startTS, _endTS : TimeStamp output) updating;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		25 February 2010
//
// Implemented version: JMT 7.8.1
// Date  		User  		Change
// Moved common code up to set the default date range for searching.
//----------------------------------------------------------------------
vars

begin
	//Set the time/date range.
	if (not self.startDate.isValid) then
		self.startDate := '01/01/0001'.asDateJMT;
	endif;
	_startTS := null;
	_startTS.setDate(self.startDate);
	
	if (not self.endDate.isValid) then
		self.endDate := app.actualTimeServer().date;	// 28/4/16 cnwmp6 TFS 488 - Multi timezone support
	endif;
	
	_endTS.setDate(self.endDate);
	_endTS.setTime('23:59:59:999'.Time);
epilog
end;</source>
        <Parameter name="_startTS" type="TimeStamp" usage="output"/>
        <Parameter name="_endTS" type="TimeStamp" usage="output"/>
    </JadeMethod>
    <JadeMethod name="setFromTemplate" id="547bebc8-c328-452f-9189-4d124046efc7">
        <updating/>
        <source>setFromTemplate(_obj : CMQF_FilterReports; _runDate : Date; _allEventData : CM_EventDataByTypeDict) updating;
// ---------------------------------------------------------------------------
// Created:     07 March 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	clonedCritHolder	: CM_QueryCriteriaLineHolder;
	critLine,
	clonedCritLine		: CM_SelectorCriteriaLine;
	eventData 			: CM_EventDataVoyage;
	eventDataVVR		: CM_EventDataVVR;

begin

	self.cloneReferences(_obj, true);
	
	//Par 13297
	// This code sets the voyage for event driven schedules.
	// Have to do this for each appropriate class because they have different myVoyage references.
	eventData := _allEventData[EventDataVoyage].CM_EventDataVoyage;
	if eventData &lt;&gt; null and eventData.myVoyage &lt;&gt; null then
		foreach clonedCritHolder in self.allQueryCriteriaHolders do
			// Using foreach will work if class name is different
			foreach critLine in clonedCritHolder.allCriteriaByPropertyName do
				// If critLine is a voyage then set voyage to be what event data voyage is carrying.
				if critLine.propName = CM_TrackedItem::voyageCode.name then
					critLine.myQueryOperator.setSearchValue(eventData.myVoyage.code);
				endif;
			endforeach;
		endforeach;
	endif;
			
	self.endDate := self.setDateFromTemplate(self.endDateTplType, self.endDateTplFactor, _runDate);
	self.startDate := self.setDateFromTemplate(self.startDateTplType, self.startDateTplFactor, _runDate);
	self.baseDate	:= self.setDateFromTemplate(self.baseDateTplType, self.baseDateTplFactor, _runDate);
end;</source>
        <Parameter name="_obj" type="CMQF_FilterReports"/>
        <Parameter name="_runDate" type="Date"/>
        <Parameter name="_allEventData" type="CM_EventDataByTypeDict"/>
    </JadeMethod>
