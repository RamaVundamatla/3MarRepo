    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="dc539be1-3714-44a8-aaf5-6e44e2bcfc24">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     18 June 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if _attrName = ETRow_VMAccessRules then
		return self.getVMAccessRulesDisplay;
	elseif _attrName = ETRow_IsBufferZone then
		return self.isBufferZone.asStringJMT;
	else
		return inheritMethod(_attrName, _short);
	endif;
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
