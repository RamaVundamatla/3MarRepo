        <type name="JSSEventCalendar"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="setAssociatedObject" id="de04c964-aa29-47c4-b4af-c6503d3a8889">
        <updating/>
        <source>setAssociatedObject(pValue:Object) updating;
// --------------------------------------------------------------------------------
// Created:		02 November 2000 by cnwdad1
//
// Purpose:		Sets a reference to an object that is associated with a calendar
//				date/event (CnEcCalendarControl).
//
// Parameters:	pValue - The associated object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin

epilog	
	if self.myAssociatedObject &lt;&gt; pValue then 
		self.myAssociatedObject := pValue;
	endif;
end;</source>
        <Parameter name="pValue" type="Object"/>
    </JadeMethod>
    <JadeMethod name="setCalendarControl" id="802da8e4-2a3e-4b22-9c21-dfe65fe28c90">
        <updating/>
        <source>setCalendarControl(pCalendarObj : JSSEventCalendar) updating;
// --------------------------------------------------------------------------------
// Created:		02 November 2000 by cnwdad1
//
// Purpose:		Sets a reference to the event's Calendar control.
//
// Parameters:	pCalendar - The calendar control.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.myCalendar &lt;&gt; pCalendarObj then
		self.myCalendar	:=	pCalendarObj;
	endif;
end;</source>
        <Parameter name="pCalendarObj" type="JSSEventCalendar"/>
    </JadeMethod>
    <JadeMethod name="setDisplayText" id="6865d9e9-c4fe-428d-9f86-0711ed60a489">
        <updating/>
        <source>setDisplayText(pValue: String) updating;
// --------------------------------------------------------------------------------
// Created:		02 November 2000 by cnwdad1
//
// Purpose:		Sets the display value of a Calendar date/event.
//
// Parameters:	pValue - The display values.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.displayText &lt;&gt; pValue then 
		if pValue.length &gt; 50 then
			self.displayText	:=	pValue[1:50];
		else
			self.displayText	:=	pValue;
		endif;
	endif;
end;</source>
        <Parameter name="pValue" type="String"/>
    </JadeMethod>
    <JadeMethod name="setEventDate" id="46436456-2a0b-489b-bf84-c0df7f84c587">
        <updating/>
        <source>setEventDate(pValue: Date) updating;
// --------------------------------------------------------------------------------
// Created:		02 November 2000 by cnwdad1
//
// Purpose:		Sets the date of a Calendar event.
//
// Parameters:	pValue - The date of the event.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin

epilog	
	if self.eventDate &lt;&gt; pValue then 
		self.eventDate	:=	pValue;
	endif;
end;</source>
        <Parameter name="pValue" type="Date"/>
    </JadeMethod>
</Class>
