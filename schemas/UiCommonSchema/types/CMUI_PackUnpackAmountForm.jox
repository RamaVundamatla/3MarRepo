    <JadeMethod name="doOK" id="12273133-9115-4d91-bf73-71077e27b961">
        <updating/>
        <source>doOK() updating;
/*

Date		Who		Reason
26 March 2014	cnwer1	Initial creation PAR

*/

vars
	
begin

	if self.isPack then
		if self.doPack() then
		
			inheritMethod();
		endif;
	else
		if self.doUnpack() then
		
			inheritMethod();
		endif;
		
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doPack" id="f2689b82-5eaa-46c3-b649-2a6c40dc4bc7">
        <source>doPack() : Boolean protected;
/*

Date		Who		Reason
03 July 2014	cnwer1	Initial creation PAR
// 06 Sep 2016	cnwrs1	TFS 2586 dont always include archived voyages and lookup reveresed even if we found data in non reverese lookup
19 Mar 2024 navhl20 ChangeRequest 62863: EUP | Retrospective Operations - [54177.100] - Pack
*/

vars

	quantity : Integer;
	weight 	 : Decimal[14,4];
	tis : CM_TISet;
	packTI,
	parentTI : CM_TrackedItem;
	result : Integer;
	setParentFromChild : Boolean;	//24 Apr 2015	NDL	Par 36111
	 
begin
	
	if self.lblAmount.visible then
		if self.byQuantity then
			quantity:=self.getQuantity;
		else 
			weight:=self.getWeightMovedKgs;
		endif;
	endif;

	parentTI:=self.myPackToTI;
	if parentTI = null then
		//find container to pack into
		create tis transient;
		self.myTerminal.lookupAllOnsiteTrackedItems(TI_CargoType_Container, self.txtTarget.text, tis, false, null);
		
		if tis.size &lt;&gt; 1 then
			app.msgBox(app.getErrorString2(No_Cargo_Id_Match,self.txtTarget.text,app.getErrorString(Site)),app.getErrorString(Error),MsgBox_OK_Only);
			return false;
		endif;
		parentTI := tis.first;
	endif;
	
	setParentFromChild := ( parentTI.allChildren.isEmptyOrContainsOnlyEquipment and parentTI.isStorage );	//24 Apr 2015	NDL	Par 36111
	
	while true do
		packTI:=self.myTrackedItem;
		app.myTrxUA.trxUpdatePackCargo(parentTI, packTI, quantity, weight, setParentFromChild, null, null, false, null, app.myPassport);		//19.03.2024 navhl20 #62863

		if app.myPassport.trxCompletedOK() then
			return true;
			
		else
			result := app.showErrorWarningDialog(app.getErrorString(PackUnpack), app.myPassport,ErrWarnMode_Update + ErrWarnMode_CanAckWarnings); // ErrWarnMode_Update); ErrWarnMode_AddUpdate
			if app.myPassport.noErrors()
			and result = IDOK
			then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			
		break;
		endif;
	endwhile;


	return false;
epilog
	delete tis;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doUnpack" id="eff3a3c0-18c7-409e-af4c-c8005f8f971d">
        <source>doUnpack() : Boolean protected;
/*

Date		Who		Reason
03 Jul 2014	cnwer1	Initial creation PAR
09 Jan 2024	navma1  Bug 60947: EUP - Cargo Scanning - Work order is not completed on unpacking all the child cargo items from scanning App
14 Mar 2024 navhl20 ChangeRequest 62861: EUP | Retrospective Operations - [54177.090] - UnPack
*/

vars
	quantity 	: Integer;
	weight 	 	: Decimal[14,4];
	foundHeight : Integer;
	targetLC    : CM_LocationsController;
	result      : Integer;
	pxyTI,
	parent,
	unpackCargo : CM_TrackedItem;
	success 	: Boolean;
begin
	
	if self.lblAmount.visible then
		if self.byQuantity then
			quantity:=self.getQuantity;
		else 
			weight:=self.getWeightMovedKgs;
		endif;
	endif;
	
	if self.myUnpackLocation = null then
		//find target location to unpack to 
		self.myTerminal.findLocationFromString(self.txtTarget.text,true,targetLC,foundHeight);
		if targetLC = null then
			app.msgBox(app.getErrorString1(Location_NotFound,self.txtTarget.text),app.getErrorString(Error),MsgBox_OK_Only);
			return false;
		endif;
	else
		targetLC:=self.myUnpackLocation;
	endif;

	success		:= false;
	unpackCargo := self.myTrackedItem;
	parent		:= unpackCargo.myParent;
	
	while true do
		//app.myTrxUA.trxUpdateUnpackCargo(unpackCargo,targetLC, quantity,weight,false, app.myPassport);  //09.01.2023 navma1 #60947	//14.03.2024 navhl20 #62861
		app.myTrxUA.trxUpdateUnpackCargo(unpackCargo,targetLC, quantity,weight,false,null, app.myPassport);  //14.03.2024 navhl20 #62861

		if app.myPassport.trxCompletedOK() then
			success:=true;
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(PackUnpack), app.myPassport,ErrWarnMode_Update + ErrWarnMode_CanAckWarnings); // ErrWarnMode_Update); ErrWarnMode_AddUpdate
			if app.myPassport.noErrors()
			and result = IDOK
			then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			
		break;
		endif;
	endwhile;

	if success and parent.allChildren.isEmpty then
		if self.myTerminal.getConfig(PromptForPackComplete).Boolean then
			if app.msgBox(app.getErrorString( CreateUnpackCompleteNow ),app.getErrorString(Unpack_Complete),MsgBox_Yes_No) = MsgBox_Return_Yes then
				pxyTI		:=	app.createUpdateProxy(parent).CM_TrackedItem;
				while true do
					app.myTrxUA.trxUpdateTIUnpackComplete(pxyTI, app.myPassport, null);
			
					if app.myPassport.trxCompletedOK() then
						return true;
					else
						result := app.showErrorWarningDialog(app.getErrorString(Unpack_Complete), app.myPassport,ErrWarnMode_Update + ErrWarnMode_CanAckWarnings); // ErrWarnMode_Update); ErrWarnMode_AddUpdate
						if app.myPassport.noErrors()
						and result = IDOK
						then
							// there must have just been warnings that the user has acknoledged so ..
							app.myPassport.warningsAcknowledged	:= true;
							continue;
						endif;
						
						break;
					endif;
				endwhile;
			endif;
		endif;
	endif;
	
	
	return success;
epilog
	delete pxyTI;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getQuantity" id="df9c79a3-7c5d-49e0-aa30-21bc27559ab2">
        <source>getQuantity() : Integer;
/*

Date		Who		Reason
20 March 2014	cnwer1	Initial creation PAR

*/

vars
	quantity : Integer;
begin
	quantity:=self.txtQuantity.text.Integer;
	
	if quantity = 0 then
		
		quantity:= self.myTrackedItem.totalQuantity;
	endif;
	
	return quantity;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getWeightMovedKgs" id="a9ee7945-70ee-40d9-8a58-e3559379bee7">
        <source>getWeightMovedKgs() : Decimal;
/*

Date		Who		Reason
19 March 2014	cnwer1	Initial creation PAR

*/

vars
	ct : CM_CargoType;
	kgValue, volume  : Decimal[14,4];

begin
	if self.myTrackedItem = null then
		return null;
	endif;
	
	ct:=self.myTrackedItem.myCargoType;
	if ct.isTrackByWeight then
		kgValue:=self.tblAmount.getConvertedValue();
		
	else
		volume:=self.tblAmount.getConvertedValue();
		kgValue:= volume * self.myTrackedItem.getDensity;

	endif;
	
	if kgValue = null then
		return self.myTrackedItem.totalWeight;
	endif;
	return kgValue;
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="setMyPackToTI" id="2836f497-83e5-47cc-9571-e0b152e1ee02">
        <updating/>
        <source>setMyPackToTI(_packToTI : CM_TrackedItem) updating;
/*

Date		Who		Reason
04 August 2014	cnwer1	Initial creation PAR

*/

vars

begin
	if _packToTI = null then
		return;
	endif;
	self.myPackToTI:=_packToTI;
	self.isPack:=true;
	self.txtTarget.text:=self.myPackToTI.id;
epilog

end;</source>
        <Parameter name="_packToTI" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setMyUnpackLocation" id="cd33aac9-7497-4121-bd56-cc30830d58bd">
        <updating/>
        <source>setMyUnpackLocation(_unpackLocation : CM_LocationsController) updating;
/*

Date		Who		Reason
04 August 2014	cnwer1	Initial creation PAR

*/

vars

begin
	if _unpackLocation = null then
		return;
	endif;
	self.myUnpackLocation :=_unpackLocation;
	self.isPack:=false;
	self.txtTarget.text:=self.myUnpackLocation.getFullId();
	
epilog

end;</source>
        <Parameter name="_unpackLocation" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="dd8d2012-98b1-4ce0-a64b-3ee39252692d">
        <updating/>
        <source>setupForm() updating;
/*

Date		Who		Reason
25 March 2014	cnwer1	Initial creation PAR

*/

vars
	ct : CM_CargoType;
	convertedAmount : String;
begin
	inheritMethod();

	self.byQuantity:=false;
	
	if self.isPack then
		self.lblTarget.caption:=app.getErrorString(Pack_container);
		self.caption:= app.getErrorString1(Pack_cargo,self.myTrackedItem.id);
	else
		self.lblTarget.caption:=app.getErrorString(Unpack_location);
		self.caption:= app.getErrorString1(Unpack_cargo,self.myTrackedItem.id);
		self.txtTarget.scrollHorizontal := true; //jlgzm1 TFS40719
		self.txtTarget.maxLength := 30;
	endif;
	
	self.tblAmount.top:=self.txtQuantity.top;
	self.tblAmount.left:=self.txtQuantity.left;
	self.frmMain.transparent:=true;
	
	self.setMyTerminal(self.myTrackedItem.myTerminal);
	ct:=self.myTrackedItem.myCargoType;
	if ct.isBreakBulkMulti then
		self.byQuantity:=true;
		lblAmount.caption:= app.getErrorString(CM_Quantity);
		self.txtQuantity.visible:=true;
		self.txtQuantity.zOrder(1);
		self.txtQuantity.dataType := TextBox.DataType_Numeric;
		self.txtQuantity.decimals := 0;	
		self.txtQuantity.text:=self.myTrackedItem.totalQuantity.asStringJMT;
		self.tblAmount.visible:=false;
	elseif ct.isBulkMulti then
		self.txtQuantity.visible:=false;
		self.tblAmount.visible:=true;
		self.tblAmount.zOrder(1);
		if ct.isTrackByWeight then
			self.lblAmount.caption:= app.getErrorString(CM_Weight);
			self.tblAmount.setup(Type_Weight, self.backColor);
			convertedAmount:=self.myTrackedItem.getConvertedTotalWeightIn(ct.myWeightMeasurementType.shortName);
			self.tblAmount.setValues(convertedAmount &amp; " " &amp; ct.myWeightMeasurementType.shortName);
		else
			self.lblAmount.caption:= app.getErrorString(CM_Volume);
			convertedAmount:=self.myTrackedItem.getConvertedTotalVolumeIn(ct.myVolumeMeasurementType.shortName);
			self.tblAmount.setup(Type_Volume, self.backColor);		
			self.tblAmount.setValues(convertedAmount &amp; " " &amp; ct.myVolumeMeasurementType.shortName);
		endif;
		self.tblAmount.tabKey:=J_key_Tab;
	else
		self.lblAmount.visible:=false;
		self.tblAmount.visible:=false;
		self.txtQuantity.visible:=false;
	endif;
		
		
		
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="120a83ad-604b-4b3d-8ae6-bd690703db93">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 31 July 2014.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
 //	self.translateCaption(Xlat_0019593, locale);
 //	lblAmount.translateCaption(Xlat_0019594, locale);
	lblTarget.translateCaption(Xlat_0019760, locale);
end;</source>
    </JadeMethod>
</GUIClass>
