    <JadeMethod name="showColumnOrganiser" id="cd97ee43-fb82-41f1-9f26-4f24623532c0">
        <updating/>
        <source>showColumnOrganiser(_dataTable : CM_DataTable input)updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 November 2009	cnwndl1	Initial creation	Par 21519

*/

vars
	defBefore, defAfter, typeTag : String;
begin

	if _dataTable = null then
		return;
	endif;
	
	defBefore := _dataTable.getXmlStrForColumns(true);
	_dataTable.showColumnOrganiserFrm(self.myTerminal, null);
	defAfter := _dataTable.getXmlStrForColumns(true);

	if defBefore &lt;&gt; defAfter then //Update the array if columns have changed via the column organiser.  The array is saved when form is closed
		self.xmlStrTblEvents := defAfter;
		return;
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_dataTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblEvents_click" id="d004d9d0-cd86-49ed-8842-e3012a099e32">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblEvents_click(table: Table input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 November 2009	cnwndl1	Initial creation	Par 21519

*/

vars

	event : CM_EventTransaction;
	
begin

	if table.row &gt; table.fixedRows then
		self.mnuInspectObject.userObject := table.accessRow(table.row).itemObject;	
	else
		self.mnuInspectObject.userObject := null;
	endif;
	
	self.mnuColumnOrganiser.userObject := table;

	event := self.tblEvents.accessRow(self.tblEvents.row).itemObject.CM_EventTransaction;
	
	self.doSelectEvent(event);

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
