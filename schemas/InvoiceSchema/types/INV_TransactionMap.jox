    <JadeMethod name="displayProducts" id="51f31d7d-9f53-4658-a67b-43fff86324c9">
        <updating/>
        <source>displayProducts() updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	prefix	: String;
begin

// modePropertyUpdate = 12
	self.doBuildListProducts();

	// PAR 35833if self.updateMode = self.UpdateMode_Copy then
	// PAR 35833	prefix := "Copy to Cargo Subtype for ";
	// PAR 35833else
	// PAR 35833	prefix := "All Cargo Subtypes for ";
	// PAR 35833endif;

	if self.myCurrentMapProdGrp.myProductGroup = null then
		if self.myCurrentMapProdGrp.myCargoTypeMap.myCargoType = null  then // PAR 21486 default
		// PAR 35833	self.lblList.caption := prefix &amp; "Default";// PAR 21486
			if self.updateMode = self.UpdateMode_Copy then
				self.lblList.caption := app.getErrorString(Copy_cargo_subtype_default);
			else
				self.lblList.caption := app.getErrorString(Cargo_subtypes_default);

			endif;
		else
			//self.lblList.caption := prefix &amp; self.myCurrentMapProdGrp.myCargoTypeMap.myCargoType.description;
			if self.updateMode = self.UpdateMode_Copy then
				self.lblList.caption := app.getErrorString1(Copy_cargo_subtype, self.myCurrentMapProdGrp.myCargoTypeMap.myCargoType.description);
			else
				 
				self.lblList.caption := app.getErrorString1(Cargo_subtypesPOP, self.myCurrentMapProdGrp.myCargoTypeMap.myCargoType.description);
			endif;
		endif;
	else
		self.lblList.caption := prefix &amp; self.myCurrentMapProdGrp.myProductGroup.description;
	endif;
	
	self.showListFrame();

end;</source>
    </JadeMethod>
    <JadeMethod name="displayQuantity" id="c9ac216c-0d05-4bf6-9cab-120fee2a1049">
        <updating/>
        <source>displayQuantity() updating;
// ---------------------------------------------------------------------------
// Created:		03 October 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	calcType	: CM_CalculationType;
begin
	if self.myCurrentMapQuantity = null then
		return;
	endif;
	if self.myCurrentMapTM &lt;&gt; null then
		self.doCmbCalcTypeBuild(self.CalcType_Cargo);
	elseif self.myCurrentMapTMVoyage &lt;&gt; null then
		self.doCmbCalcTypeBuild(self.CalcType_HMS);
	elseif self.myCurrentMapTMEvent &lt;&gt; null then
		self.doCmbCalcTypeBuild(self.CalcType_Event);
	elseif self.myCurrentMapTMWorkOrder &lt;&gt; null then // TFS 39236
		self.doCmbCalcTypeBuild(self.CalcType_WorkOrder); // TFS 39236
	elseif self.myCurrentMapTMBOL &lt;&gt; null then	//01 Nov 2019	NDL	TFS 47100
		self.doCmbCalcTypeBuild(self.CalcType_BOL);
	else
		return;
	endif;

	calcType := self.myCurrentMapQuantity.myCalculationType;
	self.cmbCalcType.listObject := calcType;
	self.chkBoxQtyZero.value := self.myCurrentMapQuantity.chargeZero;
	self.optMapTypeSingle.value := (self.myCurrentMapQuantity.mappingType = CM_QuantityMap.MapType_Single);
	self.optMapTypeEscalt.value := (self.myCurrentMapQuantity.mappingType = CM_QuantityMap.MapType_Escalate);
	self.optMapTypeEscPlu.value := (self.myCurrentMapQuantity.mappingType = CM_QuantityMap.MapType_EscalateFull);
	if calcType &lt;&gt; null and
	   calcType.allQuantityRanges.size &gt; 0 then
		self.optMapTypeEscPlu.visible := true;
	else
		self.optMapTypeEscPlu.visible := false;
	endif;
	self.chkBoxQtyZero.enabled := self.optMapTypeSingle.value;
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.chkBoxQtyZero.enabled := false;
	endif;
	
	self.showQuantityFrame();
end;</source>
    </JadeMethod>
