    <JadeMethod name="translateForm" id="fe7425a1-c058-4b11-adbd-3ef1804bdf07">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0008175, locale);
	btnEventAlarm.translateBubbleHelp(Xlat_0005318, locale);
	btnEventAlarm.translateCaption(Xlat_0005319, locale);
	lblUserName.translateCaption(Xlat_0000941, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="unload" id="16a2df77-a145-4ab2-906d-f5c4aeea3aa6">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
/*
------------------------------------------------------------------------
Created:			17 October 2003 by cnwdwq1
Purpose:			
Parameters:			None
Returns:			Nothing
Changed On			Changed By		Reason
--------------		--------------	---------------------------------------
12 Jan 2009			cnwkpd1			JADE Benchmark Lab Request to facilitate
									JMT performance tests
06 Apr 2011			cnwkpd1			Added JtdMobileDriverSchema for JBL
---------------------------------------------------------------------------
*/

vars

begin
	self.endNotification(system, Event_SendMessage);
	
	if currentSchema.name &lt;&gt; "JtdDriverSchema" and 
	   currentSchema.name &lt;&gt; "JtdMobileDriverSchema" then
		terminate;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="useAnimation" id="17a80653-7f53-4026-820c-a9b84df388d6">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>useAnimation(set: Boolean; _value: Boolean io) mapping, updating;
// ---------------------------------------------------------------------------
// Created:     10 May 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
