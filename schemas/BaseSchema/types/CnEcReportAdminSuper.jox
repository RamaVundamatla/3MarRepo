    <JadeMethod name="doViewErrorStatus" id="ca35575e-be0c-4a63-91a9-66658cf9019f">
        <updating/>
        <source>doViewErrorStatus(pTable:Table) updating, protected;

vars
	theQueueEntry	: CnEcReportQueueEntry;
	table			: Table;
	tableRow		: JadeTableRow;
	reportStatus	: String;

begin
	table	:=	pTable;

	if table.cnEcIsRowSelected(table.row) then
		tableRow		:=	table.accessRow(table.row);
		theQueueEntry	:=	tableRow.itemObject.CnEcReportQueueEntry;

		if theQueueEntry &lt;&gt; null then
			if theQueueEntry.printStatus = CNEC_REPORT_ERROR then
				reportStatus	:=	theQueueEntry.myReportDefinition.reportDescription &amp; ":";
				reportStatus	:=	reportStatus &amp; CrLf &amp; CrLf;
				reportStatus	:=	reportStatus &amp; theQueueEntry.errorMessage;
				
				app.msgBox(reportStatus, "Report Status", MsgBox_Information_Icon + MsgBox_OK_Only);
			endif;
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pTable" type="Table"/>
    </JadeMethod>
    <JadeMethod name="setTableProperties" id="76d52827-8ab0-45ae-adfb-deedcbb9c804">
        <updating/>
        <source>setTableProperties(pTable:Table io; pColumns:Integer) updating, protected;

vars
	columnWidthArray	: IntegerArray;

begin
	pTable.readOnly		:=	true;
	pTable.rows			:=	1;
	pTable.rowHeight[1]	:=	20;
	pTable.columns		:=	pColumns;

	create columnWidthArray transient;
	
	if pColumns = 5 then
		columnWidthArray.add(22);
		columnWidthArray.add(8);
		columnWidthArray.add(48);
		columnWidthArray.add(8);
		columnWidthArray.add(14);
	else
		columnWidthArray.add(20);
		columnWidthArray.add(4);
		columnWidthArray.add(29);
		columnWidthArray.add(29);
		columnWidthArray.add(8);
		columnWidthArray.add(14);
	endif;
	
	pTable.cnEcSetColumnWidths(columnWidthArray);
epilog
	delete columnWidthArray;
end;</source>
        <access>protected</access>
        <Parameter name="pTable" type="Table" usage="io"/>
        <Parameter name="pColumns" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="unload" id="151892c5-37a3-4fe5-98e5-3f8141def1ff">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;

begin
	endNotificationForSubscriber(self);
end;</source>
    </JadeMethod>
</GUIClass>
