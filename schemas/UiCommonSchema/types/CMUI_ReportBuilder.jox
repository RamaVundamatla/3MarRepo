// ----------   ----------  --------------------------------------------------
vars

begin
	if table.userInputEnabled then
		self.doTblCriteriaClick(table);
	endif;
	
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblCriteria_queryRowColChg" id="518e4ddd-3082-4b50-9e57-1ad760f038ac">
        <controlMethod name="Table::queryRowColChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblCriteria_queryRowColChg(table: Table input; newSheet: Integer; newRow: Integer; newCol: Integer):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 August 2019	jlgndl1	Initial creation	TFS 46131

*/

vars

	fromControl : Control;
	toControl : Control;

begin

	
	
	fromControl := table.accessCell( table.row, table.column ).cellControl;
	toControl := table.accessCell( newRow, newCol ).cellControl;
	
	if fromControl &lt;&gt; null then
		if CMUI_ListTable.hasInstance(fromControl) then
			if fromControl = self.lstUnloadEvts
			or fromControl = self.lstBarges
			or fromControl = self.lstNonBarges
			then
				table.accessRow(table.row).height := self.saveRowHeight.Integer;
				table.accessCell( table.row, table.column ).text := fromControl.CMUI_ListTable.getSelectedFromDisplay;
			endif;
		endif;
	endif;
	
	if self.mode = self.Mode_Add
	or self.mode = self.Mode_Update
	then
		//only expand if editing
		if toControl &lt;&gt; null then
			if CMUI_ListTable.hasInstance(toControl) then
				if toControl = self.lstBarges
				or toControl = self.lstUnloadEvts
				or toControl = self.lstNonBarges
				then
					if fromControl &lt;&gt; self.lstBarges
						and toControl = self.lstUnloadEvts
						and toControl = self.lstNonBarges
						then
						self.saveRowHeight := table.accessRow( newRow ).height;
					endif;
					table.accessRow(newRow).height := 5 * self.saveRowHeight.Integer;
					//table.accessRow(newRow).height := 100;
				endif;
			endif;
		endif;
	
	endif;
	
	return true;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="newSheet" type="Integer"/>
        <Parameter name="newRow" type="Integer"/>
        <Parameter name="newCol" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblDataDisplayRow" id="4b28470b-ff1b-4972-9ca5-a62529ca44f2">
        <updating/>
        <source>tblDataDisplayRow(table: CM_DataTable input; obj: Object):String updating;
// -----------------------------------------------------------------------------
// Created:		13 June 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
// 28/05/2020	jlgdap1		TFS 49242 MTN Exclude CarterNote JRW Designs
// -----------------------------------------------------------------------------
vars
	report			: CM_QryReport;
	user			: CM_User;
begin
	report := obj.CM_QryReport;
	
	if report = null then
		return null;
	endif;
	
	user := app.getMyUser();
	if not user.canUserViewReport(report) then
		return null;
	endif;
	
	if report.jrwViewName = CarterNote and 																			// TFS 49242
	not self.cmbReportFilter.itemData[self.cmbReportFilter.listIndex] = CM_QryReport.ReportType_SystemDefined then	// TFS 49242
		return null;																								// TFS 49242
	endif;																											// TFS 49242

//	return report.reportName &amp; Tab &amp; report.reportDescription &amp; Tab &amp; report.jrwReportName[1] &amp; Tab &amp; report.jrwViewName;	
	return report.getAttributeStringForDefArray(table.allTblDataEntRows);
	
end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
        <Parameter name="obj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
