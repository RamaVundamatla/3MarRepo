    <JadeMethod name="doOK" id="49854de8-949a-48c4-947c-cf3185222237">
        <updating/>
        <source>doOK() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 October 2019	jlgmp6	Initial creation	TFS 45590

*/

vars
	tempCarr: Real;
	humidity: Decimal[6,2];
	ventilation: Decimal[14, 4];
	expiryDate: Date;
	remarks: String;
	coolingType,
	voltageType: Integer;
	oxygen,
	carbonDioxide: Decimal[6,2];
	curtainsIn: Boolean;
	packDate: Date;
	packTime: Time;
	remaining: Decimal[12, 2];
	packTemp: Real;
	extMonitor: Boolean;

begin
	tempCarr := self.txtTempCarr.getTextAsReal();
	humidity := self.txtHumidity.getTextAsDecimal();
	ventilation := self.tblVentilation.getConvertedValue();
	expiryDate := self.txtDateExp.getTextAsDate();
	remarks := self.txtRemarks.text;
	coolingType := app.coolingTypeStringToENum(self.cmbCoolingType.text);
	voltageType := app.voltageTypeStringToENum(self.cmbVoltageType.text);
	oxygen := self.txtOxygen.getTextAsDecimal();
	carbonDioxide := self.txtCarbonDioxide.getTextAsDecimal();
	curtainsIn := self.chkCurtainsIn.value;
	if self.txtDatePack.isValid() then
		packDate := self.txtDatePack.getTextAsDate();
	else
		packDate := null;
	endif;
	if self.txtTimePack.isValid() then
		packTime := self.txtTimePack.getTextAsTime();
	else
		packTime := null;
	endif;
	remaining := self.txtAvailable.getTextAsDecimal();
	packTemp := self.txtTempPack.getTextAsReal();
	extMonitor := self.chkExtMonitor.value;

	self.myProxyReeferDetails.setProxyForCreate(tempCarr,
			humidity,
			ventilation,
			expiryDate,
			remarks,
			coolingType,
			voltageType,
			oxygen,
			carbonDioxide,
			curtainsIn,
			packDate,
			packTime,
			remaining,
			packTemp,
			extMonitor);

			
	self.myParentForm.sendMsg("updateReefersFromDetailForm");
	self.unloadForm();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="bc314940-9121-4082-9b7b-06deacde1503">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 October 2019	jlgmp6	Initial creation	TFS 45590

*/

vars
	operator: CM_Operator;
	showFahrenheit: Boolean;
	proxyReeferProp : CM_TIReeferProperties;
begin

	proxyReeferProp:= self.myProxyReeferDetails;
	
	if proxyReeferProp = null then
		return;
	endif;

	operator := self.myOperator;
	if operator &lt;&gt; null then
		showFahrenheit := operator.displayTempFahrenheit;
	endif;

	if proxyReeferProp.temperature &lt;&gt; NULL_TEMPERATURE then
		self.txtTempCarr.setTextFromReal(proxyReeferProp.temperature);
	endif;
	if proxyReeferProp.packTempDetails.tempC &lt;&gt; NULL_TEMPERATURE then
		self.txtTempPack.setTextFromReal(proxyReeferProp.packTempDetails.tempC);
	endif;
	
	if proxyReeferProp.getHumidity &lt;&gt; NULL_HUMIDITY then
		self.txtHumidity.setTextFromDecimal(proxyReeferProp.getHumidity);
	endif;
	if proxyReeferProp.ventilation &lt;&gt; NULL_VENTILATION then
		self.tblVentilation.setValue(proxyReeferProp.ventilation);
	endif;
	if proxyReeferProp.expiryDate.isValid() then
		self.txtDateExp.setTextFromDate(proxyReeferProp.expiryDate);
	endif;
	self.txtRemarks.text := proxyReeferProp.reeferRemarks;
	self.cmbCoolingType.text := app.coolingTypeENumToString(proxyReeferProp.coolingType, false);
	self.cmbVoltageType.text := app.voltageTypeENumToString(proxyReeferProp.voltageType, false);
	if proxyReeferProp.getOxygen &lt;&gt; NULL_OXYGEN then
		self.txtOxygen.setTextFromDecimal(proxyReeferProp.getOxygen);
	endif;
	
	
	if proxyReeferProp.getCarbonDioxide &lt;&gt; NULL_CARBON_DIOXIDE then
		self.txtCarbonDioxide.setTextFromDecimal(proxyReeferProp.getCarbonDioxide);
	endif;
	self.chkCurtainsIn.value := proxyReeferProp.curtainsIn;
	if proxyReeferProp.packTempDetails.dateTime.isValid() then
		self.txtDatePack.setTextFromDate(proxyReeferProp.packTempDetails.dateTime.date());
		self.txtTimePack.setTextFromTime(proxyReeferProp.packTempDetails.dateTime.time());
	endif;
	
	if proxyReeferProp.remainingTimeOffPower &lt;&gt; NULL_ALLOWABLE_TIME_OFF_POWER then
		self.txtAvailable.setTextFromDecimal(proxyReeferProp.remainingTimeOffPower);
	endif;
	self.chkExtMonitor.value := proxyReeferProp.hasExternalMonitoring;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="89f57acc-fe3c-4dd3-a1bd-ea54b3b4ca3c">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 October 2019	jlgmp6	Initial creation

*/

vars

begin
	inheritMethod();

	//Cooling Type Combo
	self.cmbCoolingType.clear();
	self.cmbCoolingType.addItem(ContainerCooledNullStr);
	self.cmbCoolingType.addItem(ContainerAirCooledStr);
	self.cmbCoolingType.addItem(ContainerWaterCooledStr);
	
	//Voltage Type Combo
	self.cmbVoltageType.clear();
	self.cmbVoltageType.addItem(ContainerVoltNullStr);
	self.cmbVoltageType.addItem(ContainerSingleVoltStr);
	self.cmbVoltageType.addItem(ContainerDualVoltStr);

	self.tblVentilation.setup(Type_Density, self.backColor);
	self.tblVentilation.tabKey := J_key_Tab;
	self.tblVentilation.visible := true;
	//self.tblVentilation.setValue();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="67f4eb68-a0dd-47c3-9759-3875c94230ae">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 November 2019 11:23:14.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0023811, locale);
	btnCancel.translateCaption(Xlat_0023812, locale);
	btnOK.translateCaption(Xlat_0023813, locale);
	chkCurtainsIn.translateCaption(Xlat_0023814, locale);
	chkExtMonitor.translateCaption(Xlat_0023815, locale);
	lblAvailable.translateCaption(Xlat_0023816, locale);
	lblCarbonDioxide.translateCaption(Xlat_0023817, locale);
	lblCoolingType.translateCaption(Xlat_0023818, locale);
	lblDateExp.translateCaption(Xlat_0023819, locale);
	lblDatePack.translateCaption(Xlat_0023820, locale);
	lblHumidity.translateCaption(Xlat_0023821, locale);
	lblOxygen.translateCaption(Xlat_0023822, locale);
	lblRemarks.translateCaption(Xlat_0023823, locale);
	lblTempCarr.translateCaption(Xlat_0023824, locale);
	lblTempPack.translateCaption(Xlat_0023825, locale);
	lblVentilation.translateCaption(Xlat_0023826, locale);
	lblVoltageType.translateCaption(Xlat_0023827, locale);
end;</source>
    </JadeMethod>
