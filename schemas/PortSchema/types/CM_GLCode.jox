    <JadeMethod name="getDisplayDetails" id="b09c422a-a96b-41c4-b304-3ad968f98ec2">
        <source>getDisplayDetails(_short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     Aug 2004	cnwrs1
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------

vars

begin
	if _short then
		return self.code;
	else
		return '('&amp;self.code&amp;')  '&amp;self.remarks;
	endif;
end;</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="589d21bf-44c4-4833-980d-42ffecf933bf">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 22 Sept 2022	navrk21 Bug 54896: EUP - GL Code External Reference field limit
vars

begin
	if _attrName = ETRow_CodeGL then
		return self.code;
	elseif _attrName = ETRow_IsNotAvailableForEntryCk then
		return self.isNotAvailableForEntry.getYesNo();
	elseif _attrName = ETRow_ExternalReference then					//28 May 2018	NDL	TFS 38896
		//return self.externalRef;									// 22.09.2022 navrk21 TFS 54896
		return self.externalRef.formatWithEllipsis(1,100,true);		// 22.09.2022 navrk21 TFS 54896
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSegmentValue" id="0efa63ae-4ee7-415b-a978-b77693afc579">
        <source>getSegmentValue(_delimiter : Character;
			    _segmentNo : Integer):String;
/*

Purpose:			
		This method will be used to return GL Code a specific segment value
Parameters:			

Return Value:		

Date		Who		Reason
13 Dec 2019 cnwma1 ChangeRequest 47851: QTS - Integration with Oracle Fusion Cloud
*/

vars
	str,
	tmpStr,
	segmentValue : String;
	pos          : Integer;
	segIndex     : Integer; 
begin
	
	tmpStr := self.code;
	pos    := 1;
	while true do
		str 		 := tmpStr.scanUntil('.', pos);
		segmentValue := str.trimLeft;		
		segIndex     := segIndex +1;
		
		if segIndex = _segmentNo then 
			break; 
		endif;	
		
		pos  		:= pos + 1;
		
		if pos = 20 then
			break;
		endif;
	endwhile;

	return segmentValue;
epilog

end;</source>
        <Parameter name="_delimiter" type="Character"/>
        <Parameter name="_segmentNo" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="398bb14f-1a66-4c6c-9f79-4d6e342accb0">
        <updating/>
        <source>setForCreate(pProxyGLCode : CM_GLCode) updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.bank := pProxyGLCode.bank;
	self.setForUpdate(pProxyGLCode);
end;</source>
        <Parameter name="pProxyGLCode" type="CM_GLCode"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="1da33251-25b4-4a0a-a3ae-1e6b79901911">
        <updating/>
        <source>setForUpdate(pProxyGLCode : CM_GLCode) updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.code := pProxyGLCode.code;
	self.remarks := pProxyGLCode.remarks[1:30];
	self.isNotAvailableForEntry := pProxyGLCode.isNotAvailableForEntry;
	self.externalRef := pProxyGLCode.externalRef;	//28 May 2018	NDL	TFS 38896
end;</source>
        <Parameter name="pProxyGLCode" type="CM_GLCode"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="4453f0c6-d8f1-4586-b0ba-a02081a1d7bf">
        <updating/>
        <source>setProxy(_bank : CM_Bank; _code : String; _remarks : String; _notAvailableForEntry : Boolean; _externalRef : String) updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//			-bank parameter added for 35872
// ---------------------------------------------------------------------------

vars

begin
	self.code 		:= _code;
	self.remarks 	:= _remarks[1:30];
	self.bank 		:= _bank;		// 35872
	self.isNotAvailableForEntry := _notAvailableForEntry;
	self.externalRef := _externalRef;	//28 May 2018	NDLK	TFS 38896
end;</source>
        <Parameter name="_bank" type="CM_Bank"/>
        <Parameter name="_code" type="String"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_notAvailableForEntry" type="Boolean"/>
        <Parameter name="_externalRef" type="String"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="b8a0e904-9811-4540-808c-92b1fab1ff8f">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 December 2016	cnwma1	Initial creation

*/

vars
		propName	: String;
begin
	if _property = null then
		return false;
	endif;
	
	propName := _property.name;
	
	if	propName = CM_GLCode::myChildQuantityMap.name 
		then
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;
	


epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="70a76b2b-ed65-40db-a9e8-00fc72bfe828">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//13/06/2022 navds20 TFS 53760 DuplicateItem not Translatable
// ---------------------------------------------------------------------------

vars

begin

	if self.code = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "Code", null, null);
		app.raiseCMException(Input_required_field_code, null, null); // cnwdb2	PAR 35364
	endif;
	
	if self.bank = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "current business unit", null, null);
		app.raiseCMException(Input_required_field_crtBusUnt, null, null); // cnwdb2	PAR 35364


	endif;
	
	if self.bank.glCodes[self.code] &lt;&gt; null then
		//app.raiseCMException2(DuplicateItem, self.code, 'Bank ' &amp; self.bank.code, null, null); //13.06.2022 navds20 53760
		// %1 Bank already exists for %2 : Bank_already_exists
		app.raiseCMException2(Bank_already_exists_, self.code,  self.bank.code, null, null); //13.06.2022 navds20 53760
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="b355fece-d754-484b-9c38-a5f1fcf7dab9">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if self.charges.size &lt;&gt; 0 then
		app.raiseCMException(ERR_GLCODE_INUSE, null, null);
	endif;
	if self.services.size &lt;&gt; 0 then
		app.raiseCMException(ERR_GLCODE_INUSE, null, null);
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="b3eebb27-876f-40e7-b1fe-c3c923645ce1">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//13/06/2022 navds20 TFS 53760 DuplicateItem not Translatable
// ---------------------------------------------------------------------------

vars

	other,
	real : SelfType;

begin

	if self.code = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "Code", null, null);
		app.raiseCMException(Input_required_field_code, null, null); // cnwdb2	PAR 35364
	endif;
	
	if self.bank = null then
		//app.raiseCMException1(REQUIRED_FIELD, "current business unit", null, null);
		app.raiseCMException(Input_required_field_crtBusUnt, null, null); // cnwdb2	PAR 35364
	endif;
	
	real := self.pxyGetRealObject();
	
	other := self.bank.glCodes[self.code];
	
	if other &lt;&gt; null then
		if (real = null or (real &lt;&gt; null and real &lt;&gt; other)) then
			//app.raiseCMException2(DuplicateItem, self.code, 'Bank ' &amp; self.bank.code, null, null); //13.06.2022 navds20 53760
			//%1 Bank already exists for %2 : Bank_already_exists_for
			app.raiseCMException2(Bank_already_exists_, self.code,  self.bank.code, null, null); //20.06.2022 navds20 53760
		endif;
	endif;
	
	
end;</source>
    </JadeMethod>
</Class>
