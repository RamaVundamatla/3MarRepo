    <JadeMethod name="addStructure" id="3997f2e7-b9df-40d2-a88a-7c163b662d75">
        <updating/>
        <source>addStructure(pStructure: CnEcXmlStructureInstance) updating;
// Method:	addStructure	
// Author:	cnwka1
// Created:	24 May 2000
//
// Purpose:	
//
// Parameters:
//
// Name		Purpose
// ---------------- -----------------------------------------------
//
// Returns:	
//
begin
	self.allFields.add(pStructure);
end;</source>
        <Parameter name="pStructure" type="CnEcXmlStructureInstance"/>
    </JadeMethod>
    <JadeMethod name="asXMLMessage" id="d607757b-7fce-421a-97cd-e71014a72956">
        <source>asXMLMessage(): String;
// --------------------------------------------------------------------------------
// Created:		05 February 2009 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	xmlMessage	: String;
	childObj	: CnEcXmlStructureInstance;
	
begin
	if self.tagName = null then
		return null;
	else
		xmlMessage	:=	"&lt;" &amp; self.tagName;
		
		if self.tagAttribute = null then
			xmlMessage	:=	xmlMessage &amp; "&gt;";
		else
			xmlMessage	:=	xmlMessage &amp; " " &amp; self.tagAttribute &amp; "&gt;";
		endif;
		
		if self.allFields.isEmpty() then
			xmlMessage	:=	xmlMessage &amp; self.tagData &amp; "&lt;/" &amp; self.tagName &amp; "&gt;";
		else
			foreach childObj in self.allFields do
				xmlMessage	:=	xmlMessage &amp; CrLf &amp; childObj.asXMLMessage();
			endforeach;
			
			xmlMessage	:=	xmlMessage &amp; CrLf &amp; self.tagData &amp; "&lt;/" &amp; self.tagName &amp; "&gt;";
		endif;
		
		return xmlMessage;
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetXML" id="cf9392d2-4c9a-454a-a1b3-348c5e8a95ad">
        <source>cnEcGetXML():String;
// --------------------------------------------------------------------------------
// Created:		07 October 2006 by cnwdad1
//
// Purpose:		Returns the receiver's XML string, including any tags contained
//				within.
//
// Parameters:	None
//
// Returns:		The XML string.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	fieldObj	: CnEcXmlStructureInstance;
	xmlString	: String;
	
begin
	xmlString	:=	"&lt;" &amp; self.tagName;
	
	if self.tagAttribute &lt;&gt; null then
		xmlString	:=	xmlString &amp; " " &amp; self.tagAttribute;
	endif;
	
	xmlString	:=	xmlString &amp; "&gt;";
	
	xmlString	:=	xmlString &amp; self.tagData.cnEcAsXml &amp;
					"&lt;/" &amp; self.tagName &amp; "&gt;";
	
	return xmlString;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="delete" id="deb0f5a9-7c2a-4a1a-830a-d253ab2db60b">
        <updating/>
        <source>delete() updating;

begin
	self.allFields.purge();
end;</source>
    </JadeMethod>
    <JadeMethod name="errorFormat" id="c9243215-3d1d-4b49-8a80-aab57301d472">
        <source>errorFormat():String;

vars
	msg		: CnEcXmlStructureInstance;
	output	: String;
	
begin
	if self.tagName &lt;&gt; "" then
		output := "&lt;" &amp; self.tagName &amp; "&gt;";
	endif;
	
	foreach msg in self.allFields do
			output :=  output &amp; msg.errorFormat();
	endforeach;
	
	if self.tagName &lt;&gt; "" then
		output := output &amp;  "&lt;/" &amp; self.tagName &amp; "&gt;";
	endif;
	
	return output;		
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="findAllStructures" id="05c35b0c-75e1-4540-96a2-9ddc4a71f09c">
        <source>findAllStructures(pName: String; pStructureSet: CnEcXmlStructureInstanceSet io);
// Method:	findAllStructures	
// Author:	cnwka1
// Created:	13 June 2000
//
// Purpose:	
//
// Parameters:
//
// Name		Purpose
// ---------------- -----------------------------------------------
//
// Returns:	
//
vars
	field	: CnEcXmlStructureInstance;
	
begin
	if pName = self.tagName then
		pStructureSet.add(self);
	endif;
	
	foreach field in self.allFields do
		field.findAllStructures(pName, pStructureSet);
	endforeach;
end;</source>
        <Parameter name="pName" type="String"/>
        <Parameter name="pStructureSet" type="CnEcXmlStructureInstanceSet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="findStructure" id="32abfb37-ec36-499c-9017-fd0adaf91ac9">
        <source>findStructure(pName: String): CnEcXmlStructureInstance;
// Method:	findStructure	
// Author:	cnwka1
// Created:	13 June 2000
//
// Purpose:	
//
// Parameters:
//
// Name		Purpose
// ---------------- -----------------------------------------------
//
// Returns:	
//
vars
	retVal	: CnEcXmlStructureInstance;
	field	: CnEcXmlStructureInstance;
	
begin
	if self.tagName = pName then
		retVal := self;
	else
		foreach field in self.allFields do
			retVal := field.findStructure(pName);
			if retVal &lt;&gt; null then
				break;
			endif;
		endforeach;
	endif;

	return retVal;			                     	
end;</source>
        <Parameter name="pName" type="String"/>
        <ReturnType type="CnEcXmlStructureInstance"/>
    </JadeMethod>
    <JadeMethod name="loadListBox" id="5fd71a67-16bd-497b-8337-da263a59c84d">
        <updating/>
        <source>loadListBox(pListBox: ListBox input; pLevel: Integer io) updating;

vars
	tag			: CnEcXmlStructureInstance;
	level		: Integer;
	showString	: String;
	
begin
	showString := self.tagName;
	
	if self.tagAttribute &lt;&gt; null then
		showString := showString &amp; " (" &amp; self.tagAttribute &amp; ")";
	endif;
	
	pListBox.addItem(showString);
	pListBox.itemLevel[pListBox.newIndex] := pLevel;
	level := pLevel + 1;
	
	foreach tag in self.allFields do
		tag.loadListBox(pListBox, level);
	endforeach;
end;</source>
        <Parameter name="pListBox" type="ListBox" usage="input"/>
        <Parameter name="pLevel" type="Integer" usage="io"/>
    </JadeMethod>
</Class>
