    <JadeMethod name="validateForm" id="6ffa79c4-de22-47ac-8317-2cb618454d70">
        <source>validateForm():Boolean protected;
// --------------------------------------------------------------------------------
// Created:		05 September 2008 by cnwdad1
//
// Purpose:		Validates the data entered by the User.
//
// Parameters:	None
//
// Returns:		True if the data is valid, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tableObj		: CM_BaseTable;
	cellObj			: JadeTableCell;
	startRow		: Integer;
	maxRow			: Integer;
	rowPointer		: Integer;
	
begin
	// Validation of the definition properties will be done in the model.
	
	// Check the Interface Translations are valid.
	
	tableObj	:=	tblTranslations;
	startRow	:=	tableObj.fixedRows + 1;
	maxRow		:=	tableObj.rows;
	
	foreach rowPointer in startRow to maxRow do
		cellObj	:=	tableObj.accessCell(rowPointer, 1);
		
		if cellObj.itemObject = null then
			tableObj.row			:=	rowPointer;
			tableObj.column			:=	1;
			fldDefinition.topSheet	:=	shtTranslations;
			app.msgBox(app.getString(Input_Required_For_TA), app.getString(Error), MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
			
			return false;
		endif;
		
		if tableObj.getCellText(rowPointer, 2) = null then
			tableObj.row			:=	rowPointer;
			tableObj.column			:=	2;
			fldDefinition.topSheet	:=	shtTranslations;
			app.msgBox("Please enter the text to translate from.", app.getString(Error), MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
			
			return false;
		endif;
		
		if tableObj.getCellText(rowPointer, 3) = null then
			tableObj.row			:=	rowPointer;
			tableObj.column			:=	3;
			fldDefinition.topSheet	:=	shtTranslations;
			app.msgBox("Please enter the text to translate to.", app.getString(Error), MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
			
			return false;
		endif;
	endforeach;
	
	return true;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="viewMessage" id="5df60aac-914b-43ea-a1aa-1f7f98bbad3e">
        <source>viewMessage() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 December 2009	#cnwdz2	 par21593

*/

vars
	messageForm : CMUI_ITSMessageQueueForm;
	interfaceObj : CM_InterfaceDefinition;
begin	
	interfaceObj := self.cmbDefinition.listObject.CM_InterfaceDefinition;
	if interfaceObj = null or (not interfaceObj.isKindOf(CM_ITSInterfaceDefinition)) then
		return;
	endif;
	
	messageForm := app.loadForm(CMUI_ITSMessageQueueForm, 
							CMUI_Assistant, 
							false, 
							false,
							false, 
							self.myTerminal,
							self.myMasterMenuAction).CMUI_ITSMessageQueueForm;	
	if messageForm = null then
		return;
	endif;
	
	messageForm.myInterface := interfaceObj.CM_ITSInterfaceDefinition;
	messageForm.caption := "Message Queue for Interface " &amp;  interfaceObj.name;
	messageForm.show;	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
</GUIClass>
