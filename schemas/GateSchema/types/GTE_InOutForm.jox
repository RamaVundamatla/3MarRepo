// -------------------------------------------
// Created 10 September 2004 by cnwdvb1
// 15/01/2015   cnwma1		 PAR #35462 Carrier Drop-down Fields	
// -------------------------------------------
vars
	tbl			: CM_EntryTable;
begin

//	self.tblCommon.setValueByControlName(combobox.name, combobox.text);
//
//	if self.origValueStr &lt;&gt; combobox.text then
	
	self.fillTblJobs(combobox.listObject.CM_Carrier);
	if not CM_EntryTable.hasInstance(combobox.parent) then     //12/01/2014 cnwma1 PAR #35462
		return;
	endif;

	tbl := combobox.parent.CM_EntryTable;
	
	if combobox.listObject &lt;&gt; null then
		tbl.setValueByControlName(combobox.name, combobox.listObject.CM_Carrier.code);
	else
		tbl.setValueByControlName(combobox.name, null);
	endif;

end;


	
	
	</source>
