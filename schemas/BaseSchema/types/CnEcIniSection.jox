    <DbClassMap file="base"/>
    <ExplicitInverseRef name="allIniKeys" id="9ec48d4d-4bdd-4e7a-b3d0-5c7b422e1cb1">
        <kind>parent</kind>
        <type name="CnEcIniKeyDict"/>
        <access>readonly</access>
        <Inverse name="CnEcIniKey::myIniSection"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="myIniFile" id="878bbbca-9b97-4166-a950-e342f0c6dcd6">
        <kind>child</kind>
        <embedded/>
        <type name="CnEcIniFile"/>
        <access>readonly</access>
