    <JadeMethod name="doUpdateEmailDefaults" id="5bb3067b-bf22-447c-b6cd-f09e01097210">
        <source>doUpdateEmailDefaults(): Boolean;
/*
Purpose - 	
Who - NAVAB1
Date - 08JUL2024
ADO -  CR 64617 TASK 64638
*/

vars
	sa : StringArray;
	returnValue : Boolean;
	
begin
	create sa transient;
	self.mulSelectFields.getSelectedDisplayEntries(sa);	
	
	self.myEmailTemplate.setProxyForEDIIssue(self.txtToAddress.text.trimBlanks(),
												self.txtCcAddress.text.trimBlanks(), 
												self.txtBccAddress.text.trimBlanks(),
												self.txtSubject.text,
												self.txtMessage.text,
												"Email Issue",
												self.chkShowIssues5.value,
												sa
												);

	return true;
	
epilog
	delete sa;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setEmailControllerAddresses" id="3fede06f-956a-40be-ab40-02c6760dd68c">
        <updating/>
        <source>setEmailControllerAddresses() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
18 December 2024	navlw1	JIRA-33657: MTN - Email not defaulting what has already been set in EDI Issue Configuration

*/

vars
	bccs, ccs, tos 	: StringArray;
	str 			: String;
	email 			: CM_EmailEntity;
begin
	create tos transient;
	create bccs transient;
	create ccs transient;
	
	tos.cnGetTokens(self.txtToAddress.text, SemiColon, false);
	bccs.cnGetTokens(self.txtBccAddress.text, SemiColon, false);
	ccs.cnGetTokens(self.txtCcAddress.text, SemiColon, false);
	
	foreach str in tos do
		email := app.myRoot.allEmailAddressesByAddress[str.trimBlanks];
		if email &lt;&gt; null then
			if not self.myEmailController.allToAddresses.includes(email) then
				self.myEmailController.allToAddresses.add(email);
			endif;
		endif;
	endforeach;
	foreach str in ccs do
		email := app.myRoot.allEmailAddressesByAddress[str.trimBlanks];
		if email &lt;&gt; null then
			if not self.myEmailController.allCcAddresses.includes(email) then
				self.myEmailController.allCcAddresses.add(email);
			endif;
		endif;
	endforeach;
	foreach str in bccs do
		email := app.myRoot.allEmailAddressesByAddress[str.trimBlanks];
		if email &lt;&gt; null then
			if not self.myEmailController.allBccAddresses.includes(email) then
				self.myEmailController.allBccAddresses.add(email);
			endif;
		endif;
	endforeach;
epilog
	delete tos;
	delete bccs;
	delete ccs;
end;</source>
    </JadeMethod>
    <JadeMethod name="setTemplate" id="017da0b7-9b43-4bac-9231-bfa4dc1305d2">
        <updating/>
        <source>setTemplate(_template : CM_EmailTemplate) updating;
/*
Purpose:	

Date		Who		Reason
15 July 2024	navab1	CR 64617 TASK 64638
*/

vars
	template : CM_EmailTemplate;
begin
	self.myEmailTemplate := _template;
	template := self.myEmailTemplate;
	
	self.setCaption(template.name &amp; " Email Options");
	
	self.txtToAddress.text := template.toAddresses;
	self.txtCcAddress.text := template.ccAddresses;
	self.txtBccAddress.text := template.bccAddresses;
	self.txtSubject.text := template.subject;
	self.txtMessage.text := template.body;
	self.chkShowIssues5.value := template.sendtoOperatorVoyage;

	self.mulSelectFields.formDisplayEntryMethodName := 'displayEntryEmailFields';
	self.mulSelectFields.availableHeading := 'Fields available';
	self.mulSelectFields.selectedHeading  := 'Fields selected';
	self.myAssistant.multiSelectEntityFields(self.mulSelectFields, ETDef_EDIEmailFields, template.allIncludedFields);	
epilog

end;</source>
        <Parameter name="_template" type="CM_EmailTemplate"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="b10cac36-47c2-4837-a146-e31021a8530b">
        <updating/>
        <source>setupForm() updating;
/*
Purpose - 	
Who - NAVAB1
Date - 08JUL2024
ADO -  CR 64617 TASK 64638
*/

vars

	offSet : Integer;

begin
	create self.myEmailController transient;

	self.modalDialogResize();
	self.resetFirstChangeFlag();
	
	if self.isBaseFormModal then
		self.handleMenusForModalDisplay();
	endif;
	
	self.setCaption(self.caption);
	
	self.modalResult := IDCANCEL;
	self.shtFields.enabled := true;
	
	self.txtSubject.text := self.myEmailTemplate.subject;
	
	self.mulSelectFields.userInputEnabled := true;
	self.mulSelectFields.displayOrderBtns(true, true);
	self.mulSelectFields.multiSelect := ListBox.MultiSelect_Extended;
	self.mulSelectFields.setSorted(false);

	self.btnOk.default := false;
 	self.chkCartersNote.visible := false;
	self.chkSave2Terminal.visible := false;
	
	offSet := 65;
	self.height := self.height + offSet + 7;
	self.fldMain.height := self.fldMain.height + offSet;
	self.frmEmail.height := self.frmEmail.height + offSet;
	self.txtSubject.top := self.txtSubject.top + offSet;
	self.lblSubject.top := self.lblSubject.top + offSet;
	self.lblMessage.top := self.lblMessage.top + offSet;
	self.txtMessage.top := self.txtMessage.top + offSet;
	
	self.chkShowIssues5.top := self.txtBccAddress.top + self.txtBccAddress.height + 5 ;
	self.chkShowIssues5.left := self.txtSubject.left;
	self.chkShowIssues5.width := self.txtSubject.width;
	self.chkShowIssues5.visible := true;
	self.chkShowIssues5.enabled := true;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showSelectRecipients" id="f34280c0-6f88-4d91-b253-c9309ab7bdf1">
        <updating/>
        <source>showSelectRecipients(_mode: Integer) updating, protected;
/*
Purpose - 	
Who - NAVAB1
Date - 08JUL2024
ADO -  CR 64617 TASK 64638
Date				Who		Reason
18 December 2024	navlw1	JIRA-33657: MTN - Email not defaulting what has already been set in EDI Issue Configuration
*/

vars
	form : CMUI_RecipientSelector;
begin
	create form transient;
	
	self.setNavigatorHeading(form.caption);
	form.myEmailController := self.myEmailController;
	form.mode := _mode;
	form.myParentForm := self;
	form.setMyTerminal(self.myTerminal);
	form.centreWindow;
	self.setEmailControllerAddresses(); // JIRA-33657
	form.showModal;

	if form.modalResult = IDOK then
		self.txtToAddress.text := self.myEmailController.allToAddresses.getAddresses();
		self.txtCcAddress.text := self.myEmailController.allCcAddresses.getAddresses();
		self.txtBccAddress.text := self.myEmailController.allBccAddresses.getAddresses();
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="d2aea477-868a-403d-986e-cedde403c231">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 16 July 2024 14:57:30.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0026917, locale);
	chkShowIssues5.translateBubbleHelp(Xlat_0026918, locale);
	chkShowIssues5.translateCaption(Xlat_0026919, locale);
end;</source>
    </JadeMethod>
