    <JadeMethod name="loadRTTaskTable" id="c787ba3e-0ae9-4bb7-9c4d-42f9ff3fbe94">
        <updating/>
        <source>loadRTTaskTable(_table: Table input;_startRTQueueEntry : CM_RTQueueEntry input) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
26 October 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	rtQueueEntry : CM_RTQueueEntry;
	allEntries : CM_RTQueueEntryArray;
	task : CM_RTQueueTask;
	order : Integer;
	invalidTask : Boolean;
begin

	
	on NormalException do app.handleDeletedObject(exception,task,invalidTask);
	order:=1;
	foreach task in self.myMachine.allCurrentQueueTasks  do
		
		rtQueueEntry:=task.myEntry;
		if invalidTask then
			invalidTask:=false;
			continue;
		endif;
		
		self.loadRTTaskTableEntry(rtQueueEntry,_table,order);
		order:=order+1;
	endforeach;
	
	_table.resort;
epilog


end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_startRTQueueEntry" type="CM_RTQueueEntry" usage="input"/>
    </JadeMethod>
    <JadeMethod name="loadRTTaskTableEntry" id="2316861e-ed99-41c1-9099-6e3c6cf16d99">
        <source>loadRTTaskTableEntry(_rtEntry: CM_RTQueueEntry input; _table: Table input; _order : Integer) protected;
/*

Purpose:			


Return Value:		


Date		Who		Reason
26 Oct 2006	cnwer1	Initial creation - PAR#xxxx
02 Nov 2009	CNWER1	PAR 20701
*/
vars
	status : String;
	type : String;
	doorDirection : String;
	containerId : String;
	source,
	target: String;
	time  : String;
	ostow : String;
	hazard : String;
	ti : CM_TrackedItem;
	job : CM_Job;
	row : JadeTableRow;
	index : Integer;
	wle : CM_WorkListEntry;
	tableLine : String;
	cell : JadeTableCell;
	rtTask : CM_RTQueueTask;
	pos,numDays,mins : Integer;
	elapsedTime : Time;
	priority,
	statusColour : Integer;
begin

	job:=_rtEntry.myJob;
	wle:=_rtEntry.myWorkListEntry;
	rtTask:=_rtEntry.allTasks.first;
	if wle &lt;&gt; null then
		type:=job.getJobTypeForWLE(wle);
		status := rtTask.statusString[1];
		ti:=wle.myTrackedItem;
		if wle.myRequest &lt;&gt; null then
			doorDirection:=wle.myRequest.getDoorDirectionDescription(wle.getTargetLocation(), wle.myTrackedItem);
		endif;
		//if type = TypeIn then
		//display where it is going
		source:=wle.getLocationIdForMode(REAL_MODE);
		
		
		if type = "DOOR" then
			target:=rtTask.targetLocation.getFullIdForTIForMode(QUEUE_MODE);
		else
			target:=wle.getLocationIdForMode(QUEUE_MODE);
		endif;
		
		//elseif type = TypeOut then
		//display where it is
		//	locationId:=wle.getLocationIdForMode(REAL_MODE); 
		//endif;
		
		elapsedTime:=app.actualTimeServer.differenceAsTime(rtTask.createdTime, pos, numDays);
		mins:=(numDays * 24 * 60) + (elapsedTime.hour * 60) + elapsedTime.minute + 1;
		time:=mins.String;
		
		containerId:=null;
		
		ostow:=null;
		hazard:=null;
		if ti &lt;&gt; null then
			containerId:=ti.id;
			ostow:=ti.isOverStowed(REAL_MODE).getYes;
			hazard:=ti.isHazardous.getYes;
		endif;	
	endif;
	
	if  status = "W" then
		statusColour:=Red;
		priority:=1;
	elseif status = "A" then
		statusColour:=Green;	
		priority:=2;
	elseif status = "O" then
		statusColour:=Black;
		priority:=3;
	else
		priority:=4;
	endif;
	
	//PAR 20701 concatinated order to priority to make sure still in queue order if 2 or more entrys are accepted for the same machine
	tableLine:=type &amp; Tab &amp; status &amp; Tab  &amp; doorDirection &amp; Tab &amp; containerId &amp; Tab &amp; source &amp; Tab &amp; target &amp; Tab &amp;  time  &amp; Tab &amp;  ostow &amp; Tab &amp; hazard &amp; Tab &amp; priority.String &amp; _order.String;
	index:=_table.addItem(tableLine);
	cell:=_table.accessCell(index,2);
	cell.foreColor:=statusColour;
	
	row:=_table.accessRow(index);
	if row &lt;&gt; null then
		row.itemObject:=_rtEntry;
	endif;


epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rtEntry" type="CM_RTQueueEntry" usage="input"/>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_order" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="resetNotesForQueue" id="0354a37a-ae4a-4f33-89c4-23da0824bd56">
        <source>resetNotesForQueue(_rtQueue: CM_RadioTelemetryQueue input): Boolean protected;
/*

Purpose:			


Return Value:		


Date		Who		Reason
03 August 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	queues : CM_RadioTelemQueueByIdDict;
	queue : CM_RadioTelemetryQueue;
	result ,subResult: Boolean;
begin
	result:= inheritMethod(_rtQueue);
	create queues transient;
	self.getAllQueuesForType(queues,self.Secondary);
	foreach queue in queues discreteLock do
		subResult:=inheritMethod(queue);
		
		result:=result or  subResult;
	endforeach;

//self.myMachine.
	return result;
epilog
	delete queues;
end;</source>
        <access>protected</access>
        <Parameter name="_rtQueue" type="CM_RadioTelemetryQueue" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
