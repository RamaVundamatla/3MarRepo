    <JadeMethod name="doChangeAccessDirection" id="b5c45106-2b06-4bc2-ba2e-78271af65632">
        <updating/>
        <source>doChangeAccessDirection() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 May 2010	cnwer1	Initial creation
23 Feb 2010 cnwer1	PAR 28126
*/

vars
	newDirection : Integer;
begin

	if app.myVMAgent.currentAccessDirection = CM_YABlock.SideAccess_Back then
		newDirection:= CM_YABlock.SideAccess_Front;
	elseif app.myVMAgent.currentAccessDirection = CM_YABlock.SideAccess_Front then
		newDirection:= CM_YABlock.SideAccess_Back;
	endif;
	app.myVMAgent.doChangeAccessDirection(newDirection, null);
	if app.myVMAgent.currentOverstowedTask = null then
		self.isShowOverstowCargo:=false;
		self.doMoveFramesRefresh();
	endif;
epilog

end;</source>
