<CollClass name="SHP_SlotReqSeqCarpetS2PB2T" id="82aaae64-f063-4860-a424-9dea7dd27a1f">
    <duplicatesAllowed/>
    <memberType name="CM_SlotRequest"/>
    <superclass name="MemberKeyDictionary"/>
    <transient/>
