    <JadeMethod name="jlgsh3WorkpointCargoRateFindFirst" id="61a74781-ff85-449d-93cd-fa8d6b6a4963">
        <source>jlgsh3WorkpointCargoRateFindFirst();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 August 2018	jlgsh3	Initial creation

*/

vars
	terminal : CM_Terminal;
	ti : CM_TrackedItem;
	wpRate : CM_WorkPointCargoRates;
begin
	app.initialize();
	foreach terminal in app.myRoot.allTerminals do
		foreach ti in terminal.allOnsiteTIsByIdCargoType do
		//	wpRate := ti.getJobSheetVoyageWorkPointRate;
			if wpRate = null then
				wpRate := ti.getJobShipReceiveWorkPointRate();
			endif;
			
			if wpRate &lt;&gt; null then
				write 'found one ' &amp; ti.getMyTerminal.code;
				ti.inspect;
				wpRate.inspect;
				wpRate := null;
				break;
			endif;
		endforeach;
	endforeach;
	/*terminal := app.getTerminalByName("Terminal Two");
	app.myPassport.setMyTerminal(terminal);*/
	write 'fin';
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="jlgsh3cargoTypeCheck" id="884e4505-b4bd-40a4-ba9c-90189649ceda">
        <source>jlgsh3cargoTypeCheck();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 August 2018	jlgsh3	Initial creation

*/

vars
	terminal : CM_Terminal;
	ti : CM_TrackedItem;
	wpRate : CM_WorkPointCargoRates;
begin
	app.initialize();
	terminal := CM_Root.firstInstance.allTerminals["TRIT"];
	if terminal = null then
		return;
	endif;
	//app.setMyTerminal(terminal);
	
	foreach ti in terminal.allOnsiteTIsByIdCargoType do
			if ti.myCargoType.description = 'ISO Container' then
				write 'yep';
			else
				write 'no';
			endif;
		
	endforeach;
	/*terminal := app.getTerminalByName("Terminal Two");
	app.myPassport.setMyTerminal(terminal);*/
	write 'fin';
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="jlirs1" id="849adab4-a509-474f-b5ce-ced3f9efcba1">
        <source>jlirs1();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 June 2023	jlirs1	Initial creation

*/

vars
	voyage : CM_Voyage;
	cmif : CMIF_EDIShipManifest;
	terminal : CM_Terminal;
	cargoGroupDtl : CM_CargoGroupDetail;
	objArray : CM_ObjectArray;
//	bol : CM_BOL;
//	bolDtl : CM_BOLDtl;
	workOrder : CM_WorkOrder;
	workOrderDtl : CM_WorkOrderDtl;
	cargoGroup : CM_CargoGroup;
begin
	app.initialize();
	terminal := CM_Root.firstInstance.allTerminals['UT'];
	app.myPassport.setMyTerminal(terminal);
	app.myPassport.setMyUserFromCode(SUPERUSER_Str);
	voyage := terminal.allVoyagesByCode.getAtKeyGeq("EUP_VES01VOY01", null);
	if voyage = null or 
	   voyage.code &lt;&gt; "EUP_VES01VOY01" then
		write "Cant find voyage";
		return;
	endif;
	create objArray transient;
//	foreach bol in voyage.allBOLInByTypeStatusNumDT do
//		bolDtl := bol.allBOLDtls.first;
//		if bolDtl &lt;&gt; null then
//			objArray.add(bolDtl.allTrackedItems.first);
//		endif;
//	endforeach;
	foreach cargoGroupDtl in voyage.allCargoGroupDetails do
		objArray.add(cargoGroupDtl.myCargoGroup);
	endforeach;	
//	voyage.allCargoGroupDetails.copy(objArray);
	write "Voyage cargoGroupDetails="&amp;voyage.allCargoGroupDetails.size.String;
	create cmif transient;
	beginTransaction;
//	cmif.createWOFromCargoGroup(objArray);
//	cmif.createWOLFromBOL(voyage);
	commitTransaction;

	// check what has happened
	write "Voyage workOrderReceives="&amp;voyage.allWOReceives.size.String;
	cargoGroup := terminal.allCargoGroupsByIdCargoType.getAtKeyGeq("F100012502/1REEL", null).CM_CargoGroup;
	if cargoGroup &lt;&gt; null and cargoGroup.id = "F100012502/1REEL" then
		write "CargoGroup F100012502/1REEL found";
	endif;
	cargoGroup := terminal.allCargoGroupsByIdCargoType.getAtKeyGeq("F100012502/2REEL", null).CM_CargoGroup;
	if cargoGroup &lt;&gt; null and cargoGroup.id = "F100012502/2REEL" then
		write "CargoGroup F100012502/2REEL found";
	endif;
	workOrder := terminal.allWorkOrders["F100012502/1-A"];
	if workOrder &lt;&gt; null and workOrder.isKindOf(CM_WorkOrderTI) then
		workOrderDtl := workOrder.allWoDtls.first;
		write "Found first workOrder and tis are "&amp;workOrderDtl.CM_WodReceive.allSelectedTIs.size.String;
	endif;
	workOrder := terminal.allWorkOrders["F100012502/2-A"];
	if workOrder &lt;&gt; null and workOrder.isKindOf(CM_WorkOrderTI) then
		workOrderDtl := workOrder.allWoDtls.first;
		write "Found second workOrder and tis are "&amp;workOrderDtl.CM_WodReceive.allSelectedTIs.size.String;
	endif;
epilog
	delete objArray;
	delete cmif;
end;</source>
    </JadeMethod>
