    <JadeMethod name="hasArchivedVoyages" id="3a62a832-3a9b-41fd-a68e-8bc041327040">
        <source>hasArchivedVoyages(_terminal : CM_Terminal; _startDate, _endDate : Date; _passport : CM_Passport; _perm : Integer) : Boolean;
//--------------------------------------------------------------
//Created: 07 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	theUser : CM_User;
	voyage : CM_Voyage;
	systemStart,
	systemEnd: TimeStamp;
begin

	theUser := _passport.myUser;

	if _startDate.isValid() then
		systemStart := self.localToSystemTime(_startDate.TimeStamp);	// 24/6/16 cnwmp6 TFS 488 - Multi timezone support
	else
		systemStart := null;
	endif;
	if _endDate.isValid() then
		systemEnd := self.localToSystemTime((_endDate + 1).TimeStamp);	// 24/6/16 cnwmp6 TFS 488 - Multi timezone support
	else
		systemEnd := null;
	endif;

	foreach	voyage in self.allVoyages do
		
		if (not voyage.archived) then
			continue;
		endif;

		// PAR 10042 - check if only for one terminal
		if _terminal &lt;&gt; null 
		and voyage.myTerminalArchived &lt;&gt; _terminal then
			continue;
		endif;

		// Check they have entered a start date
		if systemStart.isValid() then
			if voyage.archivedDT &lt; systemStart then		// 24/6/16 cnwmp6 TFS 488 - Multi timezone support
				continue;
			endif;
		endif;

		// Check they have entered a end date		
		if systemEnd.isValid() then
			if voyage.archivedDT &gt;= systemEnd then		// 24/6/16 cnwmp6 TFS 488 - Multi timezone support
				continue;
			endif;
		endif;			

		// Check they have terminal access to this voyage			
	   	if theUser.canDo(voyage.myTerminalArchived, _perm) then
			return true;
		endif;

	endforeach;
	
	return false;
	
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_startDate" type="Date"/>
        <Parameter name="_endDate" type="Date"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_perm" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasCurrentVoyageForTerminals" id="78cf7d4b-43d1-407a-bac8-71f4a8ee4a6a">
        <source>hasCurrentVoyageForTerminals(_terminalSet : CM_TerminalSet) : Boolean;
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 21 August 2008
//
// Implemented version: 7.6.2
// 
// 21/08/2008 - Created as part of PAR17722 
// Purpose:  Check for a non archived voyage of a global voyage that matches
// 			 the passed in terminals.
//			 Used for checking whether or not we want to display the global voyage.
//----------------------------------------------------------------------
vars
	foundIt : Boolean;
	voyage 	: CM_Voyage;
	passport : CM_Passport;
	user 	 : CM_User;
	dataAccess : CM_DataAccessController;
begin
	passport := app.myPassport;
	user := passport.myUser;
	if _terminalSet = null then
		app.raiseUnexpectedProgramError(self.class.name, method.name, 'Method requires a terminal.  Please contact developer');
		return false;
	endif;
	foundIt := false;
	//See if we have a voyage for the terminal and make sure it isn't archived.
	foreach voyage in self.allVoyages discreteLock do
		if voyage.myTerminal &lt;&gt; null and
		voyage.myTerminal.canUserAccessSelf(user, dataAccess, passport) and
		not voyage.archived	then
			foundIt := _terminalSet.includes(voyage.myTerminal);
			if foundIt then
				break;
			endif;
		endif;
	endforeach;
	
	return foundIt;
epilog
end;</source>
        <Parameter name="_terminalSet" type="CM_TerminalSet"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasNonArchivedVoyages" id="b22980d4-24f3-4fc7-8c37-712b498f7daf">
        <source>hasNonArchivedVoyages() : Boolean;
// ---------------------------------------------------------------------------
// Created:     11 April 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpVoy	: CM_Voyage;

begin

	foreach tmpVoy in self.allVoyages discreteLock do
		if (not tmpVoy.archived) then
			return true;
		endif;
	endforeach;
	
	return false;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
