<Class name="WS_SendEDIRequest" id="46286c19-7541-4d13-9924-cb9dccf0d79a">
    <superclass name="WS_Request"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="clientRef" id="7b0ad342-1bb9-498d-bf6e-62dcd0b57851">
        <length>501</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
        <text>A user-specified code that identifies a particular EDI Message. </text>
    </PrimAttribute>
    <PrimAttribute name="message" id="a70ff50c-fa61-4d5f-b3ff-7f03a59adf5f">
        <type name="Binary"/>
        <access>readonly</access>
        <text>The body of the message as binary. This has to be encoded to Base64 binary.
This can be done in code or if testing you can use an online Base64 Encoder site.</text>
    </PrimAttribute>
    <PrimAttribute name="messageType" id="888da853-c71b-4b5e-9b04-8750b26b2e10">
        <length>64</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
        <text>The name of the type of a JMT EDI Message.
See JMT documentation for valid types.
If it is a user defined CSV then it is the name of that user defined format. 
If it is an EDIFACT type message then use "SYSTEM".</text>
    </PrimAttribute>
    <PrimAttribute name="synchronous" id="fbbba0f5-89fd-45d9-926e-99daf7e0bd6c">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
        <text>If true, the message will be completely processed by JMT before returning. 
If false, the message will be queued.</text>
    </PrimAttribute>
</Class>
