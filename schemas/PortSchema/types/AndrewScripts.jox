    <JadeMethod name="tfs51219createYAType" id="b29c398c-f322-4417-b681-2f3afd20f25e">
        <source>tfs51219createYAType();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2021	navab1	Initial creation

*/

vars
	proxyObj			: CM_YACriteriaType;
	isBargeObj : CM_YATypeIsBarge; // NAVAB1 24MAY2021
	locationMoveDirObj : CM_YATypeLocnEventMoveDir; // NAVAB1 24MAY2021
	inventTypeObj : CM_YATypeInventoryType;  // ### TFS 51219 25MAY2021 NAVAB1
begin
	
	beginTransaction;
	// ### TFS 51219 NAVAB1 24MAY2021
	if CM_YATypeIsBarge.instances.isEmpty() then							
		create proxyObj as CM_YATypeIsBarge transient;
		proxyObj.setProxy(proxyObj.getTypeName, true, YACriteriaType_IsBarge);
		create isBargeObj;
		isBargeObj.setForCreate(proxyObj);
		delete proxyObj;
	endif;
	
	if CM_YATypeLocnEventMoveDir.instances.isEmpty() then							
		create proxyObj as CM_YATypeLocnEventMoveDir transient;
		proxyObj.setProxy(proxyObj.getTypeName, true, YACriteriaType_LocnActMoveDir);
		create locationMoveDirObj;
		locationMoveDirObj.setForCreate(proxyObj);
		delete proxyObj;
	endif;
	
	if CM_YATypeInventoryType.instances.isEmpty() then							
		create proxyObj as CM_YATypeInventoryType transient;
		proxyObj.setProxy(proxyObj.getTypeName, true, YACriteriaType_InventoryType);
		create inventTypeObj;
		inventTypeObj.setForCreate(proxyObj);
		delete proxyObj;
	endif;
	
	commitTransaction;
epilog

end;</source>
    </JadeMethod>
