    <JadeMethod name="setupForm" id="0d251d44-06fd-4154-81af-3879411db7f7">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Oct 2020	jlgndl1	Initial creation	TF S49189
*/

vars

	msg : String;
	entDef : EntTableDef;
	etRow : EntTableRow; 
	addRowArray : EntTableRowArray;
	debtorType : CM_DebtorType;

begin

	if self.myVehicleVisitRecord &lt;&gt; null and self.myVehicleVisitRecord.vehicle &lt;&gt; null then
		self.caption := self.caption &amp; " - " &amp; self.myVehicleVisitRecord.visitNumber &amp; " - " &amp; self.myVehicleVisitRecord.vehicle.regNumber;
	elseif self.myVehicleVisitRecord &lt;&gt; null and self.myVehicleVisitRecord.vehicle = null then
		msg := "No Truck associated with this vehicle visit";
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Stop_Icon );
		self.unloadForm;
		return;
	else
		msg := "No associated Vehicle Visit to maintain";
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Stop_Icon );
		self.unloadForm;
		return;
	endif;

	inheritMethod();
	
	self.beginNotes();
	
	if self.myVehicleVisitRecord.isIncomplete then
		self.optOps.value := true;
	else
		self.optView.value := true;
		self.optOps.enabled := false;	// Its gated out, nothing more to do.
	endif;
	
	if not app.myPassport.myUser.canDo( self.myTerminal, self.permissionMaint ) then
		self.optOps.enabled := false;
		self.optView.enabled := false;
		self.optView.value := true;
	else
		self.optView.caption := "View / Undo";
	endif;
	
	create addRowArray transient;
	foreach debtorType in app.myRoot.allDebtorTypes discreteLock where not debtorType.isNotAvailableForEntry do
		if not debtorType.allDebtors.isEmpty then
			self.zAddTransientEntTblRow(debtorType.description, ETRow_DebtorTypes &amp; Tab &amp; debtorType.code, Table.InputType_None);
		endif;
	endforeach;
	self.zAddTransientEntTblRow("Amount", ETRow_Amount, Table.InputType_None);
	self.tblCargo.clear();
	entDef := app.myController.getEntTableDef( ETDef_CargoEnqDefaultData );
	self.tblCargo.setTblDataEntRowsArray( entDef, self.allTblDataTransientRows, null );
	self.tblCargo.selectMode := Table.SelectMode_WholeRows;	
	
	self.clickOptionButton();

epilog

	delete addRowArray;

end;</source>
    </JadeMethod>
