    <JadeMethod name="convertBaseToTarget" id="14944425-de9b-4c66-82b8-2605b381c679">
        <source>convertBaseToTarget(pMeasure:Real; pUnitTo: Integer): Real protected;
// --------------------------------------------------------------------------------
// Created:		25 May 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	convertedMeasure	: Real;
	
begin
	if pUnitTo = self.ANGSTROMS then
		convertedMeasure	:=	pMeasure * 10000000000;

	elseif pUnitTo = self.ASTRONOMICAL_UNITS then
		convertedMeasure	:=	pMeasure / 149598550000;

	elseif pUnitTo = self.BARLEYCORNS then
		convertedMeasure	:=	pMeasure / 0.008467;

	elseif pUnitTo = self.CENTIMETRES then
		convertedMeasure	:=	pMeasure / 0.01;
	
	elseif pUnitTo = self.CHAINS_SURVEYORS then
		convertedMeasure	:=	pMeasure / 20.1168;

	elseif pUnitTo = self.CUBITS_ARABIC then
		convertedMeasure	:=	pMeasure / (4.8 * (10 ^ -1));

	elseif pUnitTo = self.CUBITS_GREEK_ATTIC then
		convertedMeasure	:=	pMeasure / (6.171200 * (10 ^ -1));

	elseif pUnitTo = self.CUBITS_ARABIC_HACHEMIC then
		convertedMeasure	:=	pMeasure / (6.40 * (10 ^ -1));

	elseif pUnitTo = self.CUBITS_HEBREW then
		convertedMeasure	:=	pMeasure / 0.555;

	elseif pUnitTo = self.CUBITS_HEBREW_SACRED then
		convertedMeasure	:=	pMeasure / 0.640;

	elseif pUnitTo = self.CUBITS_ARABIC_NEW then
		convertedMeasure	:=	pMeasure / (4.8 * (10 ^ -1));

	elseif pUnitTo = self.CUBITS_PERSIAN then
		convertedMeasure	:=	pMeasure / 0.640;

	elseif pUnitTo = self.CUBITS_ROMAN then
		convertedMeasure	:=	pMeasure / 0.4416;

	elseif pUnitTo = self.CUBITS_UK then
		convertedMeasure	:=	pMeasure / 0.4572;

	elseif pUnitTo = self.ELLS_UK then
		convertedMeasure	:=	pMeasure / 0.975;

	elseif pUnitTo = self.EMS_PICA then
		convertedMeasure	:=	pMeasure / 0.0042333;
	
	elseif pUnitTo = self.FATHOMS then
		convertedMeasure	:=	pMeasure / 1.8288;
	
	elseif pUnitTo = self.FEET then
		convertedMeasure	:=	pMeasure / 0.3048;

	elseif pUnitTo = self.FEET_US_SURVEY then
		convertedMeasure	:=	pMeasure / 0.3048006096;
	
	elseif pUnitTo = self.FURLONGS then
		convertedMeasure	:=	pMeasure / 201.168;

	elseif pUnitTo = self.HANDS then
		convertedMeasure	:=	pMeasure / 0.106;
	
	elseif pUnitTo = self.INCHES then
		convertedMeasure	:=	pMeasure / 0.0254;
	
	elseif pUnitTo = self.KILOMETRES then
		convertedMeasure	:=	pMeasure / 1000;

	elseif pUnitTo = self.LEAGUES then
		convertedMeasure	:=	pMeasure / 5559.55;

	elseif pUnitTo = self.LEAGUES_CANADIAN then
		convertedMeasure	:=	pMeasure / 4827;

	elseif pUnitTo = self.LEAGUES_INT then
		convertedMeasure	:=	pMeasure / 5556;

	elseif pUnitTo = self.LEAGUES_STAT_LAND then
		convertedMeasure	:=	pMeasure / 4828.03;

	elseif pUnitTo = self.LIGHT_YEARS then
		convertedMeasure	:=	pMeasure / 9460500000000000;

	elseif pUnitTo = self.LINKS_SURVEYORS then
		convertedMeasure	:=	pMeasure / 0.201168;
	
	elseif pUnitTo = self.METRES then
		convertedMeasure	:=	pMeasure;

	elseif pUnitTo = self.MICRONS then
		convertedMeasure	:=	pMeasure / 0.000001;
	
	elseif pUnitTo = self.MILES then
		convertedMeasure	:=	pMeasure / 1609.344;

	elseif pUnitTo = self.MILES_NAUTICAL then
		convertedMeasure	:=	pMeasure / 1852;
	
	elseif pUnitTo = self.MILLIMETRES then
		convertedMeasure	:=	pMeasure / 1000;

	elseif pUnitTo = self.MILLI_INCHES then
		convertedMeasure	:=	(pMeasure / 0.000001) / 0.0394;

	elseif pUnitTo = self.PARSECS then
		convertedMeasure	:=	pMeasure / 30856770000000000;

	elseif pUnitTo = self.PERCHES then
		convertedMeasure	:=	pMeasure / 5.0292;

	elseif pUnitTo = self.PICAS_COMPUTER then
		convertedMeasure	:=	pMeasure / 0.004233333;
	
	elseif pUnitTo = self.PICAS_PRINTERS then
		convertedMeasure	:=	pMeasure / 0.004217518;

	elseif pUnitTo = self.POINTS_COMPUTER then
		convertedMeasure	:=	pMeasure / 0.0003527778;

	elseif pUnitTo = self.POINTS_PRINTERS then
		convertedMeasure	:=	pMeasure / 0.0003514598;

	elseif pUnitTo = self.YARDS then
		convertedMeasure	:=	pMeasure / 0.9144;
	
	else
		CnEcBaseSchemaException.raise_(CNEC_X_12004, "[" &amp; pUnitTo.String &amp; "] is an unknown unit of length to convert to.");

	endif;
epilog
	return convertedMeasure;
end;</source>
        <access>protected</access>
        <Parameter name="pMeasure" type="Real"/>
        <Parameter name="pUnitTo" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="convertToBaseUnit" id="b3d3157a-3002-4ac4-ae6e-8283c2f6b77e">
        <source>convertToBaseUnit(pUnitFrom: Integer): Real protected;
// --------------------------------------------------------------------------------
// Created:		25 May 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	convertedMeasure	: Real;
	
begin
	if pUnitFrom = self.ANGSTROMS then
		convertedMeasure	:=	self.measure / 10000000000;

	elseif pUnitFrom = self.ASTRONOMICAL_UNITS then
		convertedMeasure	:=	self.measure * 149598550000;

	elseif pUnitFrom = self.BARLEYCORNS then
		convertedMeasure	:=	self.measure * 0.008467;

	elseif pUnitFrom = self.CENTIMETRES then
		convertedMeasure	:=	self.measure * 0.01;
	
	elseif pUnitFrom = self.CHAINS_SURVEYORS then
		convertedMeasure	:=	self.measure * 20.1168;

	elseif pUnitFrom = self.CUBITS_ARABIC then
		convertedMeasure	:=	self.measure * (4.80 * (10 ^ -1));

	elseif pUnitFrom = self.CUBITS_GREEK_ATTIC then
		convertedMeasure	:=	self.measure * (6.171200 * (10 ^ -1));

	elseif pUnitFrom = self.CUBITS_ARABIC_HACHEMIC then
		convertedMeasure	:=	self.measure * (6.40 * (10 ^ -1));

	elseif pUnitFrom = self.CUBITS_HEBREW then
		convertedMeasure	:=	self.measure * 0.555;

	elseif pUnitFrom = self.CUBITS_HEBREW_SACRED then
		convertedMeasure	:=	self.measure * 0.640;

	elseif pUnitFrom = self.CUBITS_ARABIC_NEW then
		convertedMeasure	:=	self.measure * (4.80 * (10 ^ -1));

	elseif pUnitFrom = self.CUBITS_PERSIAN then
		convertedMeasure	:=	self.measure * 0.640;

	elseif pUnitFrom = self.CUBITS_ROMAN then
		convertedMeasure	:=	self.measure * 0.4416;

	elseif pUnitFrom = self.CUBITS_UK then
		convertedMeasure	:=	self.measure * 0.4572;

	elseif pUnitFrom = self.ELLS_UK then
		convertedMeasure	:=	self.measure * 0.975;

	elseif pUnitFrom = self.EMS_PICA then
		convertedMeasure	:=	self.measure * 0.0042333;
	
	elseif pUnitFrom = self.FATHOMS then
		convertedMeasure	:=	self.measure * 1.8288;
	
	elseif pUnitFrom = self.FEET then
		convertedMeasure	:=	self.measure * 0.3048;

	elseif pUnitFrom = self.FEET_US_SURVEY then
		convertedMeasure	:=	self.measure * 0.3048006096;
	
	elseif pUnitFrom = self.FURLONGS then
		convertedMeasure	:=	self.measure * 201.168;

	elseif pUnitFrom = self.HANDS then
		convertedMeasure	:=	self.measure * 0.106;
	
	elseif pUnitFrom = self.INCHES then
		convertedMeasure	:=	self.measure * 0.0254;
	
	elseif pUnitFrom = self.KILOMETRES then
		convertedMeasure	:=	self.measure * 1000;

	elseif pUnitFrom = self.LEAGUES then
		convertedMeasure	:=	self.measure * 5559.55;

	elseif pUnitFrom = self.LEAGUES_CANADIAN then
		convertedMeasure	:=	self.measure * 4827;

	elseif pUnitFrom = self.LEAGUES_INT then
		convertedMeasure	:=	self.measure * 5556;

	elseif pUnitFrom = self.LEAGUES_STAT_LAND then
		convertedMeasure	:=	self.measure * 4828.03;

	elseif pUnitFrom = self.LIGHT_YEARS then
		convertedMeasure	:=	self.measure * 9460500000000000;

	elseif pUnitFrom = self.LINKS_SURVEYORS then
		convertedMeasure	:=	self.measure * 0.201168;
	
	elseif pUnitFrom = self.METRES then
		convertedMeasure	:=	self.measure;

	elseif pUnitFrom = self.MICRONS then
		convertedMeasure	:=	self.measure * 0.000001;
	
	elseif pUnitFrom = self.MILES then
		convertedMeasure	:=	self.measure * 1609.344;

	elseif pUnitFrom = self.MILES_NAUTICAL then
		convertedMeasure	:=	self.measure * 1852;
	
	elseif pUnitFrom = self.MILLIMETRES then
		convertedMeasure	:=	self.measure * 1000;

	elseif pUnitFrom = self.MILLI_INCHES then
		convertedMeasure	:=	(self.measure * 25.4) * 0.000001;

	elseif pUnitFrom = self.PARSECS then
		convertedMeasure	:=	self.measure * 30856770000000000;

	elseif pUnitFrom = self.PERCHES then
		convertedMeasure	:=	self.measure * 5.0292;

	elseif pUnitFrom = self.PICAS_COMPUTER then
		convertedMeasure	:=	self.measure * 0.004233333;
	
	elseif pUnitFrom = self.PICAS_PRINTERS then
		convertedMeasure	:=	self.measure * 0.004217518;

	elseif pUnitFrom = self.POINTS_COMPUTER then
		convertedMeasure	:=	self.measure * 0.0003527778;

	elseif pUnitFrom = self.POINTS_PRINTERS then
		convertedMeasure	:=	self.measure * 0.0003514598;

	elseif pUnitFrom = self.YARDS then
		convertedMeasure	:=	self.measure * 0.9144;
	
	else
		CnEcBaseSchemaException.raise_(CNEC_X_12003, "[" &amp; pUnitFrom.String &amp; "] is an unknown unit of length to convert from.");

	endif;
epilog
	return convertedMeasure;
end;</source>
        <access>protected</access>
        <Parameter name="pUnitFrom" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getAllUnits" id="a480f374-4d96-464f-b770-522d1e244a55">
        <source>getAllUnits(pAllUnits: IntegerArray input);
// --------------------------------------------------------------------------------
// Created:		10 May 2008 by Darrell
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	pAllUnits.add(self.ANGSTROMS);
	pAllUnits.add(self.ASTRONOMICAL_UNITS);
	pAllUnits.add(self.BARLEYCORNS);
	pAllUnits.add(self.CENTIMETRES);
	pAllUnits.add(self.CHAINS_SURVEYORS);
	pAllUnits.add(self.CUBITS_ARABIC);
	pAllUnits.add(self.CUBITS_ARABIC_HACHEMIC);
	pAllUnits.add(self.CUBITS_ARABIC_NEW);
	pAllUnits.add(self.CUBITS_GREEK_ATTIC);
	pAllUnits.add(self.CUBITS_HEBREW);
	pAllUnits.add(self.CUBITS_HEBREW_SACRED);
	pAllUnits.add(self.CUBITS_PERSIAN);
	pAllUnits.add(self.CUBITS_ROMAN);
	pAllUnits.add(self.CUBITS_UK);
	pAllUnits.add(self.ELLS_UK);
	pAllUnits.add(self.EMS_PICA);
	pAllUnits.add(self.FATHOMS);
	pAllUnits.add(self.FEET);
	pAllUnits.add(self.FEET_US_SURVEY);
	pAllUnits.add(self.FURLONGS);
	pAllUnits.add(self.HANDS);
	pAllUnits.add(self.INCHES);
	pAllUnits.add(self.KILOMETRES);
	pAllUnits.add(self.LEAGUES);
	pAllUnits.add(self.LEAGUES_CANADIAN);
	pAllUnits.add(self.LEAGUES_INT);
	pAllUnits.add(self.LEAGUES_STAT_LAND);
	pAllUnits.add(self.LIGHT_YEARS);
	pAllUnits.add(self.LINKS_SURVEYORS);
	pAllUnits.add(self.METRES);
	pAllUnits.add(self.MICRONS);
	pAllUnits.add(self.MILES);
	pAllUnits.add(self.MILES_NAUTICAL);
	pAllUnits.add(self.MILLIMETRES);
	pAllUnits.add(self.MILLI_INCHES);
	pAllUnits.add(self.PARSECS);
	pAllUnits.add(self.PERCHES);
	pAllUnits.add(self.PICAS_COMPUTER);
	pAllUnits.add(self.PICAS_PRINTERS);
	pAllUnits.add(self.POINTS_COMPUTER);
	pAllUnits.add(self.POINTS_PRINTERS);
	pAllUnits.add(self.YARDS);
end;</source>
        <Parameter name="pAllUnits" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getUnitName" id="361f95e5-71d3-44bd-af5d-dbb7741b0e4c">
        <source>getUnitName(pUnit: Integer): String;
// --------------------------------------------------------------------------------
// Created:		09 May 2008 by Darrell
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pUnit = self.ANGSTROMS then
		return "Angstroms";
	elseif pUnit = self.ASTRONOMICAL_UNITS then
		return "Astronomical Units";
	elseif pUnit = self.BARLEYCORNS then
		return "Barleycorns";
	elseif pUnit = self.CENTIMETRES then
		return "Centimetres";
	elseif pUnit = self.CHAINS_SURVEYORS then
		return "Chains (Surveyors)";
	elseif pUnit = self.CUBITS_ARABIC then
		return "Cubits (Arabic)";
	elseif pUnit = self.CUBITS_ARABIC_HACHEMIC then
		return "Cubits (Arabic Hachemic)";
	elseif pUnit = self.CUBITS_ARABIC_NEW then
		return "Cubits (Arabic New)";
	elseif pUnit = self.CUBITS_GREEK_ATTIC then
		return "Cubits (Greek Attic)";
	elseif pUnit = self.CUBITS_HEBREW then
		return "Cubits (Hebrew)";
	elseif pUnit = self.CUBITS_HEBREW_SACRED then
		return "Cubits (Hebrew Sacred)";
	elseif pUnit = self.CUBITS_PERSIAN then
		return "Cubits (Persian)";
	elseif pUnit = self.CUBITS_ROMAN then
		return "Cubits (Roman)";
	elseif pUnit = self.CUBITS_UK then
		return "Cubits (UK)";
	elseif pUnit = self.ELLS_UK then
		return "Ells";
	elseif pUnit = self.EMS_PICA then
		return "Ems (Pica)";
	elseif pUnit = self.FATHOMS then
		return "Fathoms";
	elseif pUnit = self.FEET then
		return "Feet";
	elseif pUnit = self.FEET_US_SURVEY then
		return "Feet (US Survey)";
	elseif pUnit = self.FURLONGS then
		return "Furlongs";
	elseif pUnit = self.HANDS then
		return "Hands";
	elseif pUnit = self.INCHES then
		return "Inches";
	elseif pUnit = self.KILOMETRES then
		return "Kilometres";
	elseif pUnit = self.LEAGUES then
		return "Leagues";
	elseif pUnit = self.LEAGUES_CANADIAN then
		return "Leagues (Canadian)";
	elseif pUnit = self.LEAGUES_INT then
		return "Leagues (International)";
	elseif pUnit = self.LEAGUES_STAT_LAND then
		return "Leagues (statue land)";
	elseif pUnit = self.LIGHT_YEARS then
		return "Light Years";
	elseif pUnit = self.LINKS_SURVEYORS then
		return "Links (Surveyors)";
	elseif pUnit = self.METRES then
		return "Metres";
	elseif pUnit = self.MICRONS then
		return "Microns";
	elseif pUnit = self.MILES then
		return "Miles";
	elseif pUnit = self.MILES_NAUTICAL then
		return "Miles (Nautical)";
	elseif pUnit = self.MILLIMETRES then
		return "Millimetres";
	elseif pUnit = self.MILLI_INCHES then
		return "Milli Inches";
	elseif pUnit = self.PARSECS then
		return "Parsecs";
	elseif pUnit = self.PERCHES then
		return "Perches";
	elseif pUnit = self.PICAS_COMPUTER then
		return "Picas (computer)";
	elseif pUnit = self.PICAS_PRINTERS then
		return "Picas (printer)";
	elseif pUnit = self.POINTS_COMPUTER then
		return "Points (computer)";
	elseif pUnit = self.POINTS_PRINTERS then
		return "Points (printer)";
	elseif pUnit = self.YARDS then
		return "Yards";
	else
		CnEcBaseSchemaException.raise_(CNEC_X_12003, "[" &amp; pUnit.String &amp; "] is an unknown unit of Length to convert from.");
		return null;
	endif;
end;</source>
        <Parameter name="pUnit" type="Integer"/>
