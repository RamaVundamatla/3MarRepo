    <JadeMethod name="initTblItem" id="c4817d04-106e-48c3-93f1-6edcd363639c">
        <source>initTblItem();
// ---------------------------------------------------------------------------
// Created:     05 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	entTableDef	: EntTableDef;
	theRow		: Integer;
	theTable	: CM_EntryTable;
	
begin

	theTable := self.tblItem;
	entTableDef := app.myController.getEntTableDef(ETDef_ReticketData);
	
	if entTableDef = null then
		return;
	endif;

	theTable.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
	theTable.optimiseHeadingColumn();
	theTable.visible := true;
	theTable.moveFirst();
	theTable.setFocus;
end;</source>
    </JadeMethod>
    <JadeMethod name="removeItem" id="b28bf3eb-5f81-4daa-968a-c2a44446959c">
        <updating/>
        <source>removeItem() updating, protected;
// ---------------------------------------------------------------------------
// Created:     06 November 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	reticket		: CMIF_TIReticket;
	table			: CM_DataTable;
	row				: Integer;
begin
	
	table := self.tblAll;
	row := table.row;
	reticket := table.accessRow(row).itemObject.CMIF_TIReticket;
	if reticket = null then
		app.msgBox('Please select an attachment to remove first','Nothing selected', 0);
		return;
	endif;
	
	table.removeItem(row);
	self.allCMIF_TIRetickets.remove(reticket);
	tblItem.setFocus();
end;</source>
        <access>protected</access>
    </JadeMethod>
