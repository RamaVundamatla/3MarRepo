    </JadeMethod>
    <JadeMethod name="doSaveJob" id="f5cb0e40-4d28-4a29-82c0-5236c57c627b">
        <updating/>
        <source>doSaveJob() : Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 November 2012	cnwrd1	Initial creation

*/

vars

	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815

begin

	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxVoyageJobUpdateAllocCargo(self.myVoyageJob, self.allSelectedCargo, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Voyage Job Cargo', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return false;
		
	endwhile;
		
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSearchAllocation" id="51726af0-d68d-427c-8da0-fdd86e38453b">
        <source>doSearchAllocation();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 December 2012	cnwrd1	Initial creation

*/

vars
	theAllocation 	: CM_VoyageAllocation;
	theVoyage		: CM_Voyage;
	theTIs			: CM_TISet;
	iter 			: Iterator;
	aTI				: CM_TrackedItem;
	idx				: Integer;
begin
	
	theAllocation := self.myAllocation.CM_VoyageAllocation;
	
	if theAllocation = null then
		return;
	endif;

	theVoyage := theAllocation.myVoyage;
	
	//start from scratch
	self.tblResults.clearAllData();
	self.allFoundTIs.clear();

	create theTIs transient;
	
	if theAllocation.isForMTs then
		iter := self.myTerminal.allOnsiteTIsByCargoTypeId.createIterator;
		
		while iter.next(aTI) do
			if aTI.testAgainstYardAllocation(theAllocation, null, null, false) then
				theTIs.addNoDuplicates(aTI, false);
			endif;
		endwhile;
		
		delete iter;
		
		
		iter := self.myTerminal.allNotifiedTIsByCargoTypeId.createIterator;
		
		while iter.next(aTI) do
			if aTI.testAgainstYardAllocation(theAllocation, null, null, false) then
				theTIs.addNoDuplicates(aTI, false);
			endif;
		endwhile;
	
		delete iter;
	else
	//search voyage cargo
	
		iter := theVoyage.allNotifiedTIsByIdCargoType.createIterator;
		
		while iter.next(aTI) do
			if aTI.testAgainstYardAllocation(theAllocation, null, null, false) then
				theTIs.addNoDuplicates(aTI, false);
			endif;
		endwhile;
	
		delete iter;

		iter := theVoyage.allOnsiteTIsByCargoTypeId.createIterator;
		
		while iter.next(aTI) do
			if aTI.testAgainstYardAllocation(theAllocation, null, null, false) then
				theTIs.addNoDuplicates(aTI, false);
			endif;
		endwhile;
	
		delete iter;
	
		iter := theVoyage.allTranshipTIsExport.createIterator;
		
		while iter.next(aTI) do
			if aTI.testAgainstYardAllocation(theAllocation, null, null, false) then
				theTIs.addNoDuplicates(aTI, false);
			endif;
		endwhile;
	
		delete iter;
	endif;

	theTIs.copy(self.allFoundTIs);
	self.displayFoundTIs();
	
epilog
	delete theTIs;
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="doTbSelectedDblClick" id="d3a4966b-b1a4-4736-a4d9-cc021356564c">
        <source>doTbSelectedDblClick();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 December 2012	cnwrd1	Initial creation

*/


vars

	theTi : CM_TrackedItem;
	obj : Object;
begin
	
	obj := self.tblSelectedItems.accessRow(self.tblSelectedItems.row).itemObject;
	
	if CM_TrackedItem.hasInstance(obj) then
		theTi := obj.CM_TrackedItem;
		self.myAssistant.showCargoEnquiry(theTi);
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="de2b18c5-eef3-456d-9e53-e03ac1cd24cd">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 December 2012	cnwrd1	Initial creation

*/

vars

	xmlStr	: String;

begin

	xmlStr := inheritMethod();

	xmlStr := xmlStr &amp; self.tblResults.getXmlStrForColumns(true);
	xmlStr := xmlStr &amp; self.tblSelectedItems.getXmlStrForColumns(true);
	
	return xmlStr;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initForJob" id="7aa415bd-018b-42e0-8502-3289a98bce08">
        <updating/>
        <source>initForJob( _allTis : CM_TISet; _anAllocation: CM_YardAllocation ; _aVoyageJob : CM_VoyageJob) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 November 2012	cnwrd1	Initial creation

*/

vars
	tmpTerminal	: CM_Terminal;
	jobID ,
	formCaption	: String;
begin
	
	if _allTis &lt;&gt; null then
		_allTis.copyNoDuplicates(self.allSelectedCargo , false);
	endif;
	self.myAllocation := _anAllocation;
	self.myVoyageJob := _aVoyageJob;
	
	if self.myVoyageJob &lt;&gt; null then
		jobID := self.myVoyageJob.id &amp; ' (' &amp; self.myVoyageJob.myVoyage.code &amp; ')';
	endif;
	
	self.displaySelectedTIs();
	
	formCaption := self.caption;
	tmpTerminal := self.myTerminal;
	if tmpTerminal &lt;&gt; null then
		self.caption := formCaption &amp; ' ' &amp; jobID &amp;' ' &amp; tmpTerminal.code; 
	else
		self.caption := formCaption &amp; ' ' &amp; jobID;
	endif;


end;</source>
        <Parameter name="_allTis" type="CM_TISet"/>
        <Parameter name="_anAllocation" type="CM_YardAllocation"/>
        <Parameter name="_aVoyageJob" type="CM_VoyageJob"/>
    </JadeMethod>
