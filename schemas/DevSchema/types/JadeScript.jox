    <JadeMethod name="pelSAPKinjera" id="009576dd-7e46-4d2c-9748-51032923278b">
        <source>pelSAPKinjera();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 September 2018	jlgma1	Initial creation

*/

vars
	item 	 : CMIF_SAPDataKinerjaItem;
	term 	 : CM_Terminal;
	wharf    : HMS_Wharf;
	berth    : HMS_Berth;
	obj      : Object;
	hmsMove  : HMS_Movement;
	hmsVoyage: HMS_VoyageData;
	hmsMoveArr : HMS_MovementArray;
	iter				: Iterator;
	moveDict		: HMS_MovementByDateDict;
	startCalFrom     : TimeStamp;
	kin              : CMIF_SAPDataKinerjaReq;
	seq  			 : Integer;
begin
	term := "2351.39".asOid.CM_Terminal;
	startCalFrom := app.actualTimeAppServer.addDays(-30);

	create kin transient;
	create hmsMoveArr transient;
	//foreach obj in _allObjects do
		/*
		if obj.isKindOf(CM_Terminal) then
			term := obj.CM_Terminal;
		endif;
		*/
		if not term.myHarbour.allWharves.isEmpty then
			foreach wharf in term.myHarbour.allWharves do
				if not wharf.allBerths.isEmpty then
					foreach berth in wharf.allBerths do
						moveDict := berth.getAllVoyageMovements();
						iter := moveDict.createIterator();
						moveDict.startKeyGtr(startCalFrom, iter);
						while iter.next(hmsMove) do
							
							hmsMoveArr.add(hmsMove);
							
						endwhile;
						/*if not  berth.getAllVoyageMovements.isEmpty then
							foreach hmsMove in berth.getAllVoyageMovements do
								hmsMoveArr.add(hmsMove);
							endforeach;
						endif;
						*/
					endforeach;
				endif;
			endforeach;
		endif;
	//endforeach;
	// Sample
	foreach hmsMove in hmsMoveArr  do
			create item transient;
		item.aPPROACH_TIME 					:= hmsMove.occursOnDTNEW.String;
		item.bERTHING_TIME  				:= " " ;
		item.bERTHING_WORKING_TIME			:= " ";
		item.bERTH_ID						:= hmsMove.getMyBerth.code;
		item.bERTH_NAME						:= hmsMove.getMyBerth.description;
		item.bERTH_THROUGPUT				:= " ";
		item.bOR							:= " ";
		item.bRANCH_CODE					:=hmsMove.getMyBerth.externalReference1;
		item.dATA_SOURCE					:= "MT";
		item.dWELLING_TIME_BONGKAR			:= " ";
		item.dWELLING_TIME_EXPORT_PELINDO1 	:= " ";
		item.dWELLING_TIME_IMPORT_PELINDO1 	:= " ";
		item.dWELLING_TIME_MUAT 			:= " ";
		item.eFEKTIF_TIME					:= " ";
		item.eT_BT							:= " ";
		item.iDLE_TIME		    			:= " ";
		item.nON_OPERATING_TIME   			:= " ";
		item.pERIODE 						:= " ";
		item.pOSTPONE_TIME  				:= " ";
		item.pRODUKTIVITAS  				:= " ";
		item.pROD_CONTAINER  				:= " ";
		item.pROD_LIQUID_BULK 				:= " ";
		item.rEALIZATION 					:= " ";
		item.sOR 							:= " ";
		item.tOTAL_DWELLING_TIME_EXPORT 	:= " ";
		item.tOTAL_DWELLING_TIME_IMPORT 	:= " ";
		item.tURN_AROUND_TIME 				:= " ";
		item.uOM 							:= " ";
		item.wAITING_TIME_DERMAGA 			:= " ";
		item.wAITING_TIME_PILOT   			:= " ";
		item.yOR 							:= " ";
		kin.allItem.add(item);
	endforeach;
	
	
	
	seq := 1;
	foreach item in kin.allItem do
		
	write "item :" &amp; seq.String;
	write 	item.aPPROACH_TIME 					;
	write	 item.bERTHING_TIME  				;		
	write	item.bERTHING_WORKING_TIME			;	
	write	item.bERTH_ID						;	
	write	item.bERTH_NAME						;
	write	item.bERTH_THROUGPUT				;
	write	item.bOR							;
	write	item.bRANCH_CODE					;
	write	item.dATA_SOURCE					;
	write	item.dWELLING_TIME_BONGKAR			;
	write	item.dWELLING_TIME_EXPORT_PELINDO1  ;
	write	item.dWELLING_TIME_IMPORT_PELINDO1 	;
	write	item.dWELLING_TIME_MUAT 			;
	write	item.eFEKTIF_TIME					;
	write	item.eT_BT							;
	write	item.iDLE_TIME		    			;
	write	item.nON_OPERATING_TIME   			;
	write	item.pERIODE 						;
	write	item.pOSTPONE_TIME  				;
	write	item.pRODUKTIVITAS  				;
	write	item.pROD_CONTAINER  				;
	write	item.pROD_LIQUID_BULK 				;
	write	item.rEALIZATION 					;
	write	item.sOR 							;
	write	item.tOTAL_DWELLING_TIME_EXPORT 	;
	write	item.tOTAL_DWELLING_TIME_IMPORT 	;
	write	item.tURN_AROUND_TIME 				;
	write	item.uOM 							;
	write	item.wAITING_TIME_DERMAGA 			;
	write	item.wAITING_TIME_PILOT   			;
	write	item.yOR 							;
	
	seq := seq+1;
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="pelWo" id="bebd7469-89e5-4b02-ab28-ab81b3102d48">
        <source>pelWo();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 October 2019	jlgma1	Initial creation

*/


vars
	term		: CM_Terminal;
	voyageSet   : CM_VoyageSet;
	iter 		: Iterator;
	workOrder   : CM_WorkOrder;
	index,
	limit,
	count       : Integer;
	voyage      : CM_Voyage;
	user        : CM_User;
	lFile        : File;
begin
		create lFile transient;
	lFile.fileName := "C:\TEMP\" &amp;"Oct7-01.csv";
    lFile.open;
	app.initialize();
		if limit = 0 then					
		limit := 20;					
	endif;								
	if limit &gt; 250 then				
		limit := 250;					
	endif;								
	if index = 0 then					
		index := 1;						
	endif;	
	
	term := app.myRoot.allTerminals["1017"];
	user := app.myRoot.allUsers["SUPERUSER"];
	if term &lt;&gt; null then
		app.setMyTerminal(term);
		app.myPassport.setMyUser(user );
		create voyageSet transient;
		term.getVoyageForVesselSchedule(voyageSet);
	
		iter:=term.allWorkOrders.createIterator;	
		iter.startAtIndex(index);							
	
		while iter.next(workOrder) and count &lt; limit do		
	
			voyage := workOrder.getMyVoyageObject();
			write workOrder.id &amp; Tab&amp;  voyage.code;
			if voyage &lt;&gt; null and not voyageSet.includes( voyage ) then
				continue;
			endif;
			lFile.writeLine(voyage.code.asStringJMT  &amp; voyage.arrivedDT.asStringJMT&amp; Tab &amp; workOrder.id.asStringJMT  &amp;Tab &amp; workOrder.getStatusString &amp; workOrder.createdTime.asStringJMT );
			
			count := count + 1;									
		endwhile;
	
	/*
	foreach voyage in voyageSet discreteLock do 
	
		lFile.writeLine(voyage.code.asStringJMT);
	
	endforeach;
	*/
	endif;
epilog
		lFile.close;
			delete lFile;
		delete voyageSet;
end;</source>
    </JadeMethod>
