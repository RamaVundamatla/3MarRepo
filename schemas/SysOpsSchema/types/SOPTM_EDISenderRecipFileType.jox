    <JadeMethod name="setupThumbnailDefaults" id="25d8e312-2d39-4436-bb9d-5c76c145a1e7">
        <source>setupThumbnailDefaults();
//
//10 Sep 2015	cnwrs1	Par 32883 - EDI File Type sequence number
//
vars

begin
	inheritMethod();
	self.myForm.allowAdd := false;
	self.myForm.allowDelete := false;
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myForm.myTerminal, PmAdmEDISenderMaintMaint) then
		self.myForm.allowUpdate := false;
	endif;
	
	//have to redo this after messing with the buttons
	self.myForm.frmToolbar.positionToolbarControls();
	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="d9cf9b89-e1bc-4ad9-a649-6a26439cda5b">
        <updating/>
        <source>setupThumbnailDetails() updating;
//
//`18 Sep 2015	cnwrs1	Par 32883 - EDI File Type sequence number
//
vars
	theForm : SOP_TableMaintForm;
begin
	theForm := self.myForm;
	theForm.useProxyObject := true;
	
	theForm.setTblDataEntRows(ETDef_EDISenderRecip);
	
	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_EDISenderRecip);
	theForm.shtTblInput1.visible := true;
	
	theForm.myAssistant.comboBoxOperator(theForm.cmbOperator, null, null);
		
	self.colourColumn := theForm.tblData.getColumnByRowName(ETRow_Colour);			
	theForm.shtViewTable1.caption := app.getErrorString(Sender_recip_file_history);//"EDI Sender Recipient File Details";
	theForm.shtViewTable1.enabled := true;
	theForm.shtViewTable1.cnEcResizeContents();
	theForm.tblDataView1.clear;
	theForm.tblDataView1.fixed3D := false;
	
	theForm.tblDataView1.optimiseRowHeight := true;
	
	theForm.tblDataView1.stretchHeight := true;
	theForm.tblDataView1.stretchWidth := true;
	
	theForm.tblDataView1.rows := 2;
	theForm.tblDataView1.fixedRows := 1;
	theForm.tblDataView1.columns := 4;
	theForm.tblDataView1.fixedColumns := 0;
	theForm.tblView1.fixedColumns := 0;
	
	theForm.tblDataView1.selectionType := CM_DataTable.SelectionType_Row;
	theForm.tblDataView1.selectMode := CM_DataTable.SelectMode_FixedRow;
	theForm.tblDataView1.multiSelect := CM_DataTable.MultiSelect_Simple;
	
	theForm.tblDataView1.stretchToParent := true;
	
	theForm.shtViewTable1.cnEcResizeContents();
	
	self.doColumnHeadings(theForm.tblDataView1);

end;</source>
    </JadeMethod>
    <JadeMethod name="sheetChange" id="7e3c5c3c-1c57-4c8f-8a51-9b6ba4c5c52f">
        <updating/>
        <source>sheetChange(_folder: Folder input) updating;
//
//10 Sep 2015	cnwrs1	Par 32883 - EDI File Type sequence number
//
vars
	sheet : Sheet;
	theForm : SOP_TableMaintForm;
	ediSenderRecip: CM_EDISenderRecipFileType;
begin
	sheet := _folder.topSheet;
	theForm := self.myForm; 
	if sheet = theForm.shtViewTable1 then
		// load up the history sheet - we are going in
		ediSenderRecip := theForm.myCurrentObject.CM_EDISenderRecipFileType;
		
		if ediSenderRecip &lt;&gt; null then
			self.displayHistory(ediSenderRecip, theForm.tblDataView1, false); 
		endif;
		return;
	endif;
end;
</source>
        <Parameter name="_folder" type="Folder" usage="input"/>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="fa0c623d-d5ea-4a9c-b66c-05ba7588957f">
        <updating/>
        <source>showThumbnail(_ediFF : CM_EDISenderRecipFileType) updating;
//
//18 Sep 2015	cnwrs1	Par 32883 - EDI File Type sequence number
//
vars
	theForm : SOP_TableMaintForm;
begin
	theForm := self.myForm;
	theForm.tblInput1.clearValues;
	theForm.tblInput1.setValueByName(ETRow_Sender, _ediFF.sender);
	theForm.tblInput1.setValueByName(ETRow_Recipient, _ediFF.recipient);
	theForm.tblInput1.setValueByName(ETRow_FileType, _ediFF.fileType);
//	theForm.tblInput1.setValueByName(ETRow_FileVersion, _ediFF.fileVersion);
	theForm.tblInput1.setValueByName(ETRow_SeqNumber, _ediFF.seqNumber.String);
	theForm.tblInput1.setValueByName(ETRow_FileDateTime, _ediFF.fileDateTime);
	theForm.tblInput1.setValueByName(ETRow_LastFileName, _ediFF.lastFileName);
	theForm.tblInput1.setValueByName(ETRow_ProcessInDateOrder, _ediFF.processInDateOrder);
	theForm.tblInput1.setValueByName(ETRow_ProcessInSeqOrder, _ediFF.processInSeqOrder);

	theForm.tblData.accessColumn(2).width := 130;
	theForm.shtViewTable1.caption := app.getErrorString1(Sender_recip_file_history1, _ediFF.allSenderRecipFileTypeHist.size.String);// 06/05/2010 cnwcs5 par 23801
	self.displayHistory(_ediFF, theForm.tblDataView1, false); 
	


end;</source>
        <Parameter name="_ediFF" type="CM_EDISenderRecipFileType"/>
    </JadeMethod>
