	create locations transient;
	locations.add(taSource.allGridControllersByRowColumn[1, 4]);
	locations.add(taSource.allGridControllersByRowColumn[3, 6]);
	
	
	self.deleteYA("UT");
	containers := "20";
	ya := self.addYA1("UT", YACriteriaType_ContainerLength, containers, locations);
	assertNotNullMsg(ya, "UT Yard Allocation");
	rtQueueEntry:=ti.getQueueEntry();
	assertNotNullMsg(rtQueueEntry, "Q Entry");
	
	//going to still queue in the row  but in the yard allocation
	create tiArray transient;
	tiArray.add(osTI);
	app.myTrxUA.trxAutoPlanOverstowedCargo(ti,tiArray,ti.myTerminalArea,null,null,null,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	rtQueueEntry:=osTI.getQueueEntry;
	assertNotNullMsg(rtQueueEntry, "OS Q Entry");
	self.assertEqualMsg( rtQueueEntry.allTasks.first.targetLocationId,"UTSTRD 030006 1", "Overstow tasks target location is incorrect"  );
epilog
	self.opts.purge();
	delete locations;
	delete tiArray;

end;</source>
    </JadeMethod>
    <JadeMethod name="tStradUseOSRulesYA6" id="8dec5a97-039d-4966-9eb1-12eee3b5ecdd">
        <source>tStradUseOSRulesYA6();
/* cnwer1

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 January 2010	cnwer1	Initial creation

*/

vars


taSource,
	taTarget: CM_StraddleStack;
	locations : CM_LCArray;
	ya: CM_YardAllocation;
	ti, nextTI, osTI: CM_TrackedItem;
	location: CM_LocationsController;
	containers : String;
	rtQueueEntry : CM_RTQueueEntry;
	tiArray		: CM_TIArray;
begin
	deleteTerminalArea("UTSTRD");
	taSource:= addStraddleStack("UTSTRD", 5, 8,1);
	assertNotNullMsg(taSource, "UTSTRD");


	deleteTerminalArea("UTSTRDA");
	taTarget:= addStraddleStack("UTSTRDA", 5, 8, 2);
	assertNotNullMsg(taTarget, "UTSTRD");
	//taSource:=self.getTerminalArea("UTSTRD").CM_StraddleStack;
	//taTarget:=self.getTerminalArea("UTSTRDA").CM_StraddleStack;
	
	self.deleteContainer("TEST0000001");
	ti := self.addContainerOpts("TEST0000001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(ti, "TEST0000001");
	self.move(ti ,taSource.allGridControllersByRowColumn[3, 5]);
	self.assertEqualMsg(ti.myPrimaryActualLocation, taSource.allGridControllersByRowColumn[3, 5], "Did not move TEST0000001 to correct location");
		
	self.moveQueued(ti,taTarget.allGridControllersByRowColumn[3, 5]);
	self.assertEqualMsg(ti.myPrimaryQueuedLocation, taTarget.allGridControllersByRowColumn[3, 5], "Did not queue TEST0000001 to correct location");
	
	
	self.deleteContainer("TEST0000002");
	osTI:= self.addContainerOpts("TEST0000002", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(ti, "TEST0000002");
	self.opts.addAssoc("IsForcedMove",true);
	self.move(osTI ,taSource.allGridControllersByRowColumn[3, 5]);
	self.assertEqualMsg(osTI.myPrimaryActualLocation, taSource.allGridControllersByRowColumn[3, 5], "Did not move TEST0000002 to correct location");
	self.opts.purge();
	//add some move cargo 
	self.deleteContainer("TEST0000003");
	nextTI:= self.addContainerOpts("TEST0000003", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(nextTI, "TEST0000003");
	self.move(nextTI ,taSource.allGridControllersByRowColumn[3, 6]);
	self.assertEqualMsg(nextTI.myPrimaryActualLocation, taSource.allGridControllersByRowColumn[3, 6], "Did not move TEST0000003to correct location");
	
	self.deleteContainer("TEST0000004");
	nextTI:= self.addContainerOpts("TEST0000004", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(nextTI, "TEST0000004");
	self.move(nextTI ,taSource.allGridControllersByRowColumn[3, 4]);
	self.assertEqualMsg(nextTI.myPrimaryActualLocation, taSource.allGridControllersByRowColumn[3, 4], "Did not move TEST0000004 to correct location");
	
	self.deleteContainer("TEST0000005");
	nextTI:= self.addContainerOpts("TEST0000005", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(nextTI, "TEST0000005");
	self.move(nextTI ,taSource.allGridControllersByRowColumn[2, 6]);
	self.assertEqualMsg(nextTI.myPrimaryActualLocation, taSource.allGridControllersByRowColumn[2, 6], "Did not move TEST0000005 to correct location");
	
	
	self.deleteContainer("TEST0000006");
	nextTI:= self.addContainerOpts("TEST0000006", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(nextTI, "TEST0000006");
	self.move(nextTI ,taSource.allGridControllersByRowColumn[4, 6]);
	self.assertEqualMsg(nextTI.myPrimaryActualLocation, taSource.allGridControllersByRowColumn[4, 6], "Did not move TEST0000006 to correct location");
	
	//locations are Top Left &amp; bottom Right
	create locations transient;
	locations.add(taSource.allGridControllersByRowColumn[1, 4]);
	locations.add(taSource.allGridControllersByRowColumn[5, 6]);
	
	
	self.deleteYA("UT");
	containers := "20";
	ya := self.addYA1("UT", YACriteriaType_ContainerLength, containers, locations);
	assertNotNullMsg(ya, "UT Yard Allocation");
	rtQueueEntry:=ti.getQueueEntry();
	assertNotNullMsg(rtQueueEntry, "Q Entry");
	
	//going to still queue in the row  but in the yard allocation
	create tiArray transient;
	tiArray.add(osTI);
	app.myTrxUA.trxAutoPlanOverstowedCargo(ti,tiArray,ti.myTerminalArea,null,null,null,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	rtQueueEntry:=osTI.getQueueEntry;
	assertNotNullMsg(rtQueueEntry, "OS Q Entry");
	self.assertEqualMsg( rtQueueEntry.allTasks.first.targetLocationId,"UTSTRD 020005 1", "Overstow tasks target location is incorrect"  );
epilog
	self.opts.purge();
	delete locations;
	delete tiArray;

end;</source>
    </JadeMethod>
