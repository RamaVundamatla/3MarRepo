    <JadeMethod name="comboBoxHMSRouteTemplate" id="3c7cbb9d-68c2-4a23-8502-1eb22ea7f141">
        <source>comboBoxHMSRouteTemplate(_comboboxObj:ComboBox input; _routeObj:HMS_RouteTemplate);
// --------------------------------------------------------------------------------
// Created:		17 October 2006 by cnwdad1
//
// Purpose:		Populates the specified combobox control with all Route Templates,
//				and optionally sets the combbox's index.
//
// Parameters:	_comboboxObj - A reference to the combobox control.
//				_routeObj - A reference to a Route Template, or null.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	_comboboxObj.listCollection(app.myRoot.allRouteTemplates, true, Collection.CNEC_DISPLAY_ORDER_COLLECTION);
	
	if _routeObj &lt;&gt; null then
		_comboboxObj.cnEcSetObjectIndex(_routeObj);
	endif;
end;</source>
        <Parameter name="_comboboxObj" type="ComboBox" usage="input"/>
        <Parameter name="_routeObj" type="HMS_RouteTemplate"/>
    </JadeMethod>
    <JadeMethod name="comboBoxHMSTidalClass" id="e2e19bb2-b3b1-4230-9235-d0006713cbb7">
        <source>comboBoxHMSTidalClass(pCmb : ComboBox input; _tidalClass : HMS_TidalClass);
//--------------------------------------------------------------
//Created: 15 March 2004 By: cnwgd1
//--------------------------------------------------------------
vars
	tidalClass	: HMS_TidalClass;								// cnwma1  3/7/2014   CCMS SFW 1328
	idx			: Integer;										// cnwma1  3/7/2014   CCMS SFW 1328
begin

	pCmb.clear();
	//pCmb.listCollection(app.myRoot.allTidalClasses, true, 0);														// cnwma1  3/7/2014   CCMS SFW 1328
	foreach tidalClass in app.myRoot.allTidalClasses discreteLock where not tidalClass.isNotAvailableForEntry do	// cnwma1  3/7/2014   CCMS SFW 1328
		if pCmb.isKindOf(CMUI_ComboBox) then
			pCmb.CMUI_ComboBox.addItemObject(tidalClass.description, tidalClass);
		else	
			idx := pCmb.addItem(tidalClass.description);
			pCmb.itemObject[idx] := tidalClass;
		endif;
	endforeach;
	
	if _tidalClass &lt;&gt; null then
		pCmb.text := self.displayEntryHMSTidalClass(_tidalClass);
		if pCmb.text &lt;&gt; null then
			pCmb.listObject := _tidalClass;
		endif;
	endif;
end;</source>
        <Parameter name="pCmb" type="ComboBox" usage="input"/>
        <Parameter name="_tidalClass" type="HMS_TidalClass"/>
    </JadeMethod>
    <JadeMethod name="comboBoxHMSTidalModelDef" id="ac4d865a-a46f-4000-a7ea-1a57bd75adea">
        <source>comboBoxHMSTidalModelDef(_cmbObj : CMUI_ComboBox input; 
						_checkPointType : Integer;
						_modelDefObj : HMS_TidalModelDefinition);
//--------------------------------------------------
// Created:	6 September 2004 By: cnwgd1
//--------------------------------------------------
/* Changes

Date		Name	TFS#		Description
============================================================================
22/07/2019	jlgka1 	TFS 45620	JMT - Refactor remove remaining  Voyage Commodity  Planning
============================================================================*/
vars
	modelDefObj			: HMS_TidalModelDefinition;
	allDefinitionsObj	: HMS_TidalModelDefsByCode;
	
begin
	_cmbObj.clear();
	_cmbObj.sorted	:=	false;
	_cmbObj.addItem('');
	
	if _checkPointType = null then
		return;
	endif;
	
	//if (not app.isVoyageCommodityPlanning) then
	//	_cmb.addItem(app.getErrorString(HMSTidalModelType_Otago));
	//endif;
	
	allDefinitionsObj	:=	app.myRoot.allHMSTidalModelDefinitions;
	
	foreach modelDefObj in allDefinitionsObj do
		if (_checkPointType = HMS_ChkPointType_Current and modelDefObj.dataType = HMS_TidalDataType_Current)
		or (_checkPointType = HMS_ChkPointType_Draft and modelDefObj.dataType = HMS_TidalDataType_Height)
		or (_checkPointType = HMS_ChkPointType_HiLo and modelDefObj.dataType = HMS_TidalDataType_HiLo)
		// jlgka1 TFS 45620 --&gt;
		//or (_checkPointType = HMS_ChkPointType_ShipsDepart and modelDefObj.dataType = HMS_TidalDataType_HiLo) 
		//or (_checkPointType = HMS_ChkPointType_TideRange and modelDefObj.dataType = HMS_TidalDataType_HiLo)
		// jlgka1 TFS 45620 &lt;--
		or (_checkPointType = HMS_ChkPointType_TimeGap and modelDefObj.dataType = HMS_TidalDataType_TimeGap)
		//or (_checkPointType = HMS_ChkPointType_TideState and modelDefObj.dataType = HMS_TidalDataType_HiLo)  //epr par 16884 5/6/08 // jlgka1 TFS 45620
		then
			_cmbObj.itemObject[_cmbObj.addItem(modelDefObj.description)]	:=	modelDefObj;
		endif;
	endforeach;
	
	if _modelDefObj &lt;&gt; null then
		_cmbObj.listIndex	:=	_cmbObj.findObject(_modelDefObj);
	endif;
end;</source>
        <Parameter name="_cmbObj" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_checkPointType" type="Integer"/>
        <Parameter name="_modelDefObj" type="HMS_TidalModelDefinition"/>
    </JadeMethod>
    <JadeMethod name="comboBoxHMSTideDataType" id="db4264ae-4ea9-4ce0-8c3a-c485b666839c">
        <source>comboBoxHMSTideDataType(_cmb : CMUI_ComboBox input; _tideType : Integer);
/*
----------   ----------  --------------------------------------------------
Created:	13 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	lookForStr			: String;
	
begin
	_cmb.clear();
	_cmb.sorted := false;

	_cmb.itemData[_cmb.addItem(app.tidalDataTypeEnumToString(HMS_TidalDataType_Current))]		:=	HMS_TidalDataType_Current;
	_cmb.itemData[_cmb.addItem(app.tidalDataTypeEnumToString(HMS_TidalDataType_Height))]		:=	HMS_TidalDataType_Height;
	_cmb.itemData[_cmb.addItem(app.tidalDataTypeEnumToString(HMS_TidalDataType_HiLo))]			:=	HMS_TidalDataType_HiLo;
	_cmb.itemData[_cmb.addItem(app.tidalDataTypeEnumToString(HMS_TidalDataType_TimeGap))]		:=	HMS_TidalDataType_TimeGap;
	_cmb.itemData[_cmb.addItem(app.tidalDataTypeEnumToString(HMS_TidalDataType_TideRange))]		:=	HMS_TidalDataType_TideRange;
	_cmb.itemData[_cmb.addItem(app.tidalDataTypeEnumToString(HMS_TidalDataType_ShipsDepart))]	:=	HMS_TidalDataType_ShipsDepart;
	
	if _tideType &lt;&gt; null then
		lookForStr := app.tidalDataTypeEnumToString(_tideType);
		_cmb.listIndex := _cmb.findString(1, lookForStr);
	endif;
end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_tideType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="comboBoxHMSTideRange" id="394887c5-7436-461b-934c-616a789ea399">
        <source>comboBoxHMSTideRange(_tableObj:CM_EntryTable input; _attrName:String; _value: String);
// --------------------------------------------------------------------------------
// Created:		15 March 2007 by cnwdad1
//
// Purpose:		Populates a table cell combobox with Tide Range names.
//
// Parameters:	_tableObj - A reference to the table control being populated.
//				_attrName - The name of the attribute to populate.
//				_value - The value of the attribue being populated.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowPointer		: Integer;
	displayValue	: String;
	
begin
	rowPointer	:=	_tableObj.getRow(_attrName);

	if (not _tableObj.isValidRow(rowPointer)) then
		return;
	endif;
	
	displayValue	:=	" " &amp; Tab &amp; app.getString(Ebb) &amp; Tab &amp; app.getString(Flood);	

	_tableObj.setComboValues(rowPointer, displayValue); 
	_tableObj.setValue(rowPointer, _value);
end;</source>
        <Parameter name="_tableObj" type="CM_EntryTable" usage="input"/>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="comboBoxHMSTideState" id="7623c0cd-be8a-49e8-8316-6022eef3be3b">
        <source>comboBoxHMSTideState(_cmb : CMUI_ComboBox input; _tideState : Integer);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 June 2008	cnwer1	Initial creation

*/

vars
	lookForStr : String;
begin
	_cmb.clear();
	_cmb.sorted := false;

	_cmb.itemData[_cmb.addItem(app.getErrorString(Flood))]		:=	HMS_CheckPoint.TideState_Flood;
	_cmb.itemData[_cmb.addItem(app.getErrorString(Ebb))]			:=	HMS_CheckPoint.TideState_Ebb;
	
	if _tideState &lt;&gt; null then
		if _tideState = HMS_CheckPoint.TideState_Flood then
			lookForStr:=app.getErrorString(Flood);
		elseif _tideState = HMS_CheckPoint.TideState_Ebb then
			lookForStr:=app.getErrorString(Ebb);
		endif;	
		_cmb.listIndex := _cmb.findString(1, lookForStr);
	endif;
	
epilog

end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_tideState" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="comboBoxHMSTimeZone" id="e397cba9-9e9d-40cb-a662-de5a470a24f2">
        <source>comboBoxHMSTimeZone(pCmb : CMUI_ComboBox input; _harbour : HMS_Harbour);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 March 2012	cnwndl1	Initial creation	Par 28251

*/
vars
	
begin

	pCmb.clear();

	pCmb.addItem( TimezoneUnknownStr );
	pCmb.addItem( TimezoneNZStr );
	
	if _harbour = null then
		pCmb.listIndex := pCmb.findStringExact(	1, TimezoneUnknownStr );
	else
		pCmb.listIndex := pCmb.findStringExact(	1, _harbour.getTimezoneDescr );
	endif;
	
end;</source>
        <Parameter name="pCmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_harbour" type="HMS_Harbour"/>
    </JadeMethod>
    <JadeMethod name="comboBoxHMSTug" id="a3b9dc32-127e-4e42-bab4-78e4236a1ebd">
        <source>comboBoxHMSTug(pCmb : ComboBox input; _tug : HMS_Tug);
//--------------------------------------------------------------
//Created: April 2004 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	pCmb.clear();
	pCmb.listCollection(app.myRoot.allTugs, true, 0);
	
	if _tug &lt;&gt; null then
		pCmb.text := self.displayEntryHMSTug(_tug);
		if pCmb.text &lt;&gt; null then
