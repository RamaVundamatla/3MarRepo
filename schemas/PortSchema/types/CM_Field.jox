    <JadeMethod name="set" id="c55c23e6-f4ea-4b14-9a59-1c45344164bc">
        <updating/>
        <source>set(_sysName: String; _required: Boolean; _sysTypeName: String; _className: String) updating;
//----------------------------------------------------------------
//	Created:	05 August 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

//	self.name			:= _sysName;
	self.className		:= _className;
	self.required		:= _required;
	self.systemName		:= _sysName;
	self.systemTypeName := _sysTypeName;
	
end;</source>
        <Parameter name="_sysName" type="String"/>
        <Parameter name="_required" type="Boolean"/>
        <Parameter name="_sysTypeName" type="String"/>
        <Parameter name="_className" type="String"/>
    </JadeMethod>
    <JadeMethod name="setFromXML" id="ebc9139d-7352-4375-b5bf-6b3b1407ccbc">
        <updating/>
        <source>setFromXML(_xmlElement: JadeXMLElement) updating;
//----------------------------------------------------------------
//	Created:	16 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	xmlElement		: JadeXMLElement;
begin

	xmlElement := _xmlElement.getElementByTagName('name');
	if xmlElement &lt;&gt; null then
		self.name := xmlElement.textData;
	endif;
	
	xmlElement := _xmlElement.getElementByTagName('stringFormatMethodName');
	if xmlElement &lt;&gt; null then
		self.stringFormatMethodName := xmlElement.textData;
	endif;
	
	xmlElement := _xmlElement.getElementByTagName('systemName');
	if xmlElement &lt;&gt; null then
		self.systemName := xmlElement.textData;
	endif;
	
	xmlElement := _xmlElement.getElementByTagName('systemTypeName');
	if xmlElement &lt;&gt; null then
		self.systemTypeName := xmlElement.textData;
	endif;

	xmlElement := _xmlElement.getElementByTagName('className');
	if xmlElement &lt;&gt; null then
		self.className := xmlElement.textData;
	endif;
	

end;</source>
        <Parameter name="_xmlElement" type="JadeXMLElement"/>
    </JadeMethod>
    <JadeMethod name="setNonSystemAttributes" id="3229ce58-cd23-4bfd-9aaa-852726628af0">
        <updating/>
        <source>setNonSystemAttributes(_name: String; _formatMethodName: String; _fieldAny: Any) updating;
//----------------------------------------------------------------
//	Created:	07 October 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	self.name := _name;
	self.stringFormatMethodName := _formatMethodName;
	self.required := true;

end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_formatMethodName" type="String"/>
        <Parameter name="_fieldAny" type="Any"/>
    </JadeMethod>
</Class>
