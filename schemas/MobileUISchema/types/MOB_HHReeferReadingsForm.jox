    <JadeMethod name="doLocationSearch" id="e0c620dc-c714-4483-a954-0563442c6f01">
        <updating/>
        <source>doLocationSearch() protected,updating;
/*
Date		Who		Reason
27 January 2009	cnwcp2	Initial creation
*/

vars
	ti : CM_TrackedItem;
	retStr : String;
begin
	ti := self.getSessionAgent.getTIAtLocation(txtLocation.text, isReeferOnlyForm, retStr);
	if retStr &lt;&gt; null then
		self.msgBox(retStr, app.getErrorString(Error), MsgBox_OK_Only, false);
		return;
	endif;
	if ti &lt;&gt; null then
		self.setMyTrackedItem( ti );
		self.txtTemperature.setFocus;
	else
	
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doNext" id="a0795909-d8ae-4b43-ac63-4360883e69cb">
        <updating/>
        <source>doNext() protected, updating;
/*
Date		Who		Reason
27 January 2009	cnwcp2	Initial creation
*/

vars
	agent : CM_MobileAgent;
begin
	if somethingChanged then
		if self.doUpdateTemperature() then
			somethingChanged := false;
			self.displayTemperature();
			self.setForView();
		endif;
	endif;
	agent := self.getSessionAgent;
	self.setMyTrackedItem(agent.getNextTI(self.myTrackedItem, self.isReeferOnlyForm));
	
	// Check to see if there is another container after the one that has just been found. If not then disallow
	// the user to click the next button again
	btnThree.enabled := agent.getNextTI(self.myTrackedItem, self.isReeferOnlyForm) &lt;&gt; null;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doPrevious" id="a188c774-abc9-47c7-a050-350d7ffdb16c">
        <updating/>
        <source>doPrevious() protected, updating;
/*
Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 January 2009	cnwcp2	Initial creation
*/

vars
	agent : CM_MobileAgent;
begin
	if somethingChanged then
		if self.doUpdateTemperature() then
			somethingChanged := false;
			self.displayTemperature();
			self.setForView();
		endif;
	endif;
	agent := self.getSessionAgent;
	self.setMyTrackedItem(agent.getPreviousTI(self.myTrackedItem, self.isReeferOnlyForm));
	// Check to see if there is another container previous to the one that has just been found. If not then disallow
	// the user to click the previous button again
	btnFour.enabled := agent.getPreviousTI(self.myTrackedItem, self.isReeferOnlyForm) &lt;&gt; null;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResizeControls" id="ae2e7ec8-9fa2-4544-9169-b73e17e0b139">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19/02/2015	cnwndl1	Initial creation	Par 35604
19/03/2015	cnwdap1	PAR #35874 TFS 265 Added humidity and ventilation fields
*/
vars

	cTop : Real;
	stdWidth : Real;
	cWidth : Real;
	stdHeight : Real;
	cHeight : Real;
	cLeft : Real;
	tabIndex : Integer;

begin

	self.setResizeableMarginAndFontSize();
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
	stdHeight := self.getStdControlHeight;
	
	cTop := self.resizedMargin;
	cWidth := stdWidth - self.getSearchButtonSpace();
	cHeight := stdHeight;
	tabIndex := 4000;
	
	if _initialSetup then
		self.txtCargoId.setAndIncrementTabIndex( tabIndex );
		self.txtCargoId.visible := true;
	endif;
	self.txtCargoId.move( 	self.resizedMargin,
							cTop,
							cWidth,
							cHeight );
						 
	cWidth := self.getStdControlHeight();
	if _initialSetup then
		self.btnPartCargoId.setAndIncrementTabIndex( tabIndex );
		self.btnPartCargoId.visible := true;
	endif;
	self.btnPartCargoId.move(	self.txtCargoId.left + self.txtCargoId.width + self.resizedMargin,
								cTop,
								cWidth,
								cHeight );
								
	cTop := cTop + self.txtCargoId.height + self.resizedMargin;
	if _initialSetup then
		self.lblLocationTitle.setAndIncrementTabIndex( tabIndex );
		self.lblLocationTitle.visible := true;
	endif;
	self.lblLocationTitle.move( self.resizedMargin, 
	                    cTop, 
						stdWidth, 
						cHeight );
	
	cTop := cTop + self.lblLocationTitle.height + self.resizedMargin;
	cLeft := self.resizedMargin + 10;
	cWidth := stdWidth - cLeft - self.getSearchButtonSpace() + self.resizedMargin;
	if _initialSetup then
		self.txtLocation.setAndIncrementTabIndex( tabIndex );
		self.txtLocation.visible := true;
	endif;
	self.txtLocation.move( 	cLeft,
							cTop,
							cWidth,
							cHeight );
	
	cWidth := self.getStdControlHeight();
	if _initialSetup then
		self.btnSearchLocs.setAndIncrementTabIndex( tabIndex );
		self.btnSearchLocs.visible := true;
	endif;
	self.btnSearchLocs.move(	self.txtLocation.left + self.txtLocation.width + self.resizedMargin,
								cTop,
								cWidth,
								cHeight );
	
	cTop := cTop + self.txtLocation.height + self.resizedMargin;
	if _initialSetup then
		self.lblTemperature.setAndIncrementTabIndex( tabIndex );
		self.lblTemperature.visible := true;
	endif;
	self.lblTemperature.move(	self.resizedMargin, 
								cTop, 
								stdWidth, 
								cHeight );
						
	cWidth := stdWidth - cLeft;
	cTop := cTop + self.lblTemperature.height + self.resizedMargin;
	if _initialSetup then
		self.txtTemperature.setAndIncrementTabIndex( tabIndex );
		self.txtTemperature.visible := true;
	endif;
	self.txtTemperature.move( 	cLeft, 
								cTop, 
								cWidth, 
								cHeight );
						
	cTop := cTop + self.txtTemperature.height + self.resizedMargin;
	if _initialSetup then													// PAR #35874
		self.lblHumidity.setAndIncrementTabIndex( tabIndex );				// PAR #35874
		self.lblHumidity.visible := true;									// PAR #35874
	endif;																	// PAR #35874
	self.lblHumidity.move(	self.resizedMargin, 							// PAR #35874
							cTop, 											// PAR #35874
							stdWidth, 										// PAR #35874
							cHeight );										// PAR #35874
																			// PAR #35874
	cWidth := stdWidth - cLeft;												// PAR #35874
	cTop := cTop + self.lblHumidity.height + self.resizedMargin;			// PAR #35874
	if _initialSetup then													// PAR #35874
		self.txtHumidity.setAndIncrementTabIndex( tabIndex );				// PAR #35874
		self.txtHumidity.visible := true;									// PAR #35874
	endif;																	// PAR #35874
	self.txtHumidity.move( 	cLeft, 											// PAR #35874
							cTop, 											// PAR #35874
							cWidth, 										// PAR #35874
							cHeight );										// PAR #35874
																			// PAR #35874
	cTop := cTop + self.txtHumidity.height + self.resizedMargin;			// PAR #35874
	if _initialSetup then													// PAR #35874
		self.lblVentilation.setAndIncrementTabIndex( tabIndex );			// PAR #35874
		self.lblVentilation.visible := true;								// PAR #35874
	endif;																	// PAR #35874
	self.lblVentilation.move(	self.resizedMargin, 						// PAR #35874
								cTop, 										// PAR #35874
								stdWidth, 									// PAR #35874
								cHeight );									// PAR #35874
																			// PAR #35874
	cWidth := stdWidth - cLeft;												// PAR #35874
	cTop := cTop + self.lblVentilation.height + self.resizedMargin;			// PAR #35874
	if _initialSetup then													// PAR #35874
		self.txtVentilation.setAndIncrementTabIndex( tabIndex );			// PAR #35874
		self.txtVentilation.visible := true;								// PAR #35874
	endif;																	// PAR #35874
	self.txtVentilation.move( 	cLeft, 										// PAR #35874
							cTop, 											// PAR #35874
							cWidth, 										// PAR #35874
							cHeight );										// PAR #35874
																			// PAR #35874
	cTop := cTop + self.txtVentilation.height + self.resizedMargin;			// PAR #35874
	if _initialSetup then
		self.chkNoCharge.setAndIncrementTabIndex( tabIndex );
		self.chkNoCharge.visible := true;
	endif;
	self.chkNoCharge.move(	cLeft, 
							cTop, 
							cWidth, 
							cHeight );
						
	cTop := cTop + self.chkNoCharge.height + self.resizedMargin;
	if _initialSetup then
		self.chkTraverseCol.setAndIncrementTabIndex( tabIndex );
		self.chkTraverseCol.visible := true;
	endif;
	self.chkTraverseCol.move(	cLeft, 
								cTop, 
								cWidth, 
								cHeight );
								
	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doUpdateTemperature" id="a1b4b48c-63bd-49e5-8cc9-41d04211ab89">
        <source>doUpdateTemperature() : Boolean protected;
/*
Purpose:
	Update the currently selected Container with the new temperature

Return Value:	
	True if the update was successful, otherwise false

Date		Who		Reason
23/01/2009	cnwcp2	Initial creation
11/12/2009	cnwdap1	CCMS MES 1007 Any TI can now be a reefer, not just containers
19/03/2015	cnwdap1	PAR #35874 TFS 265 Added humidity and ventilation readings 
*/

vars
	
begin
	
	if self.myTrackedItem = null then
		self.msgBox(app.getErrorString(NO_Container_selected), app.getErrorString(Error), MsgBox_OK_Only, false);
		return false;
	endif;
	//return self.getSessionAgent.updateTemperatureOfProxy(chkNoCharge.value, txtTemperature.text.asRealJMT);	// PAR #35874
	return self.getSessionAgent.updateTemperatureOfProxy(	chkNoCharge.value, 									// PAR #35874
															txtTemperature.text,								// PAR #35874
															txtHumidity.text.asDecimalJMT,						// PAR #35874
															txtVentilation.text.asRealJMT	);					// PAR #35874
			
epilog

end;</source>
