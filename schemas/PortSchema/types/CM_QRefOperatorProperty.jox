    <JadeMethod name="setComboValues" id="6d0a8c29-db42-4e17-a24b-3dbb477e54ae">
        <source>setComboValues(_combo : ComboBox input; _params : CM_QueryCriteriaLineHolder; _queryOperator : CM_QueryOperator; _passport : CM_Passport);
// ---------------------------------------------------------------------------
// Created:     18 March 2003		cnwth2	
//
// Purpose:     		 
//
// Changed On	Changed By	Reason
// ----------   ----------  --------------------------------------------------
// 23/06/2022	navdap1		TFS 53362 EUP Master Data Interface Customers Between TOS and ERP
vars
	op			: CM_Operator;
	opDict		: CM_OperatorByCodeDict;
	qrl			: CM_QReferenceLookup;
	byName		: Boolean;					// TFS 53362
begin
	_combo.clear;
	opDict := app.myRoot.allOperators;
	byName := app.myRoot.getConfig(ComboByNameOperator).Boolean;		// TFS 53362
	foreach op in opDict do
		if byName then																	// TFS 53362
			_combo.itemObject[_combo.addItem(op.description &amp; '   ' &amp; op.code)] := op;	// TFS 53362
		else																			// TFS 53362
			_combo.itemObject[_combo.addItem(op.code &amp; '   ' &amp; op.description)] := op;
		endif;																			// TFS 53362
	endforeach;
	
	if CM_QReferenceLookup.hasInstance(_queryOperator) then
		qrl := _queryOperator.CM_QReferenceLookup;
		if global.isValidObject(qrl.mySelectionValue) then
			_combo.listObject := qrl.mySelectionValue;
		endif;
	endif;
	
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="c8e6384e-aa5c-47c0-bd2d-15ad38048962">
        <source>setListValues(_tbl : Table input; _params : CM_QueryCriteriaLineHolder; _operator : CM_QReferenceIsOneOf; _passport : CM_Passport);
// ---------------------------------------------------------------------------
// Created:     18 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	selectionValue, idx		: Integer;
	op						: CM_Operator;
	opDict					: CM_OperatorByCodeDict;
begin
	_tbl.clear;
	_tbl.rows := _tbl.fixedRows;
	_tbl.sortColumn[1] := 2; // TFS 7821

	opDict := app.myRoot.allOperators;

	foreach op in opDict do
		selectionValue := 0;
		if _operator &lt;&gt; null and _operator.allSelectionValues.includes(op) then
			selectionValue := 1;
		endif;
		idx := _tbl.addItem(selectionValue.String &amp; Tab &amp; op.code &amp; '   ' &amp; op.description);
		_tbl.accessRow(idx).itemObject := op;
		_tbl.row := idx;
		_tbl.change(_tbl);
	endforeach;
	
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QReferenceIsOneOf"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="6d8db0b8-b4d9-4978-8a6a-4df25a735e41">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
// ---------------------------------------------------------------------------
// Created:     18 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	str				: String;
	numRows,
	idx				: Integer;
	oa				: CM_ObjectArray;
	op				: CM_Operator;
begin

	create oa transient;
	
	numRows := _tbl.rows;
	foreach idx in (_tbl.fixedRows + 1) to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			op := _tbl.accessRow(idx).itemObject.CM_Operator;
			oa.add(op);
		endif;
	endforeach;
	
	_op.setSearchValue(oa);

epilog
	delete oa;
	
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateStringToSearchValue" id="aa680baa-14eb-4868-b3c7-666f60200ca2">
        <source>translateStringToSearchValue(_value: Any; _criteriaLine : CM_SelectorCriteriaLine ): Any;
// ----------------------------------------------------------------------
// Created 13 May 2008 by cnwvu1
//
// Purpose:	Gets value as String from RT screen and returns value
//			 into criteriaLineLine for running a query
// ----------------------------------------------------------------------

vars
	op		: CM_Operator;
	conDict	: CM_OperatorByCodeDict;
	tmpValue: String;
	
begin

	if _value.isKindOf( CM_Operator ) then
		return _value;
	endif;
	
	tmpValue := _value.String.toUpper();
	conDict	:= app.myRoot.allOperators;
	
	foreach op in conDict do
		if op.code.toUpper() = tmpValue then
			return op;
		endif;
	endforeach;
	
	// when not found. Par 17092	cnwvu1, June 2008
	inheritMethod( _value, _criteriaLine );
	
end;
</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_criteriaLine" type="CM_SelectorCriteriaLine"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="e824ae15-4046-40c7-a3f6-d01f5ac96ff7">
        <source>translateToDisplayValue(_value: Any): String;
// ---------------------------------------------------------------------------
// Created:     18 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
/*

Date		Who		Reason
22 Oct 2008	cnwkpd1	PAR #18099 - Handle null objects in selector queries

*/

vars

begin
	if _value &lt;&gt; null then
		return _value.CM_Operator.code;
	endif;
	
	return null;


end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="bbf512cb-60cb-42da-b034-8007202ba8b5">
        <source>translateToSearchValue(_value: Any): Any;
// ---------------------------------------------------------------------------
// Created:     18 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
/*

Date		Who		Reason
06 Oct 2008	cnwkpd1	PAR #18099 - Correct Selector query processing
22 Oct 2008	cnwkpd1	PAR #18348 - Prevent 1002 exceptions in Selector query processing with isOneOf

*/

vars
	returnVal		: CM_Operator;
	
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then			// PAR #18348
			return _value;
		endif;

		if _value.isKindOf(CM_Operator) then
			returnVal := _value.CM_Operator;
		endif;
	endif;
	
	return returnVal;
	
end;
</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="8d70b260-9663-452d-8c31-03621abe4f96">
        <source>translateToSearchValueForWeb(_value: Any; _sending : Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 24 September 2019	jlgdap1		Initial creation TFS 
//
vars
	operator : CM_Operator;

begin
	if _value &lt;&gt; null and _value.isKindOf(String) then
		operator := app.myRoot.allOperators[_value.String];
		if operator &lt;&gt; null then
			return operator;
		endif;
	endif;

	return inheritMethod(_value, _sending);

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
