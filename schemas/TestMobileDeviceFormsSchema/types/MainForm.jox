    <JadeMethod name="doRefreshCaption" id="c9a83ad7-4ff1-4db1-8680-534a34bd2928">
        <source>doRefreshCaption();

/*

Date		Who		Reason


*/

vars
	i,
	pos,
	architecture,
	platform,
	left, 
	top, 
	width, 
	height 			: Integer;
	message,
	line			: String;
	jdo				: JadeDynamicObject;
	log				: JadeLog;
	
begin
	self.getDeskTopWorkArea(left, top, width, height);

	self.lstMain.clear;
	
	self.lstMain.addItem("Desktop left=" &amp; left.String);
	self.lstMain.addItem("Desktop top=" &amp; top.String);
	self.lstMain.addItem("Desktop width=" &amp; width.String);
	self.lstMain.addItem("Desktop height=" &amp; height.String);
	
	self.lstMain.addItem(null);
	
	self.lstMain.addItem("Form left=" &amp; self.left.String);
	self.lstMain.addItem("Form top=" &amp; self.top.String);
	self.lstMain.addItem("Form width=" &amp; self.width.String);
	self.lstMain.addItem("Form height=" &amp; self.height.String);

	self.lstMain.addItem(null);
	
	self.lstMain.addItem("Form clientWidth=" &amp; self.clientWidth.String);
	self.lstMain.addItem("Form clientHeight=" &amp; self.clientHeight.String);
	
	self.lstMain.addItem(null);
	
	self.lstMain.addItem("getOSPlatform:");
	platform := process.getOSPlatform(message, architecture);
	self.lstMain.addItem("platform=" &amp; platform.String);
	self.lstMain.addItem("version=" &amp; message);
	self.lstMain.addItem("architecture=" &amp; architecture.String);
	
	self.lstMain.addItem(null);
	
	create jdo transient;
	process.getOSDetails(jdo);
	message := jdo.display();
	
	pos := 1;
	while pos &lt;&gt; 0 and pos &lt;= message.length do
		line := message.scanUntil(CrLf, pos);
		self.lstMain.addItem(line);
		if pos = 0 then
			break;
		endif;
		line := message.scanWhile(CrLf, pos);
	endwhile;

	// And log all the output to a file
	create log transient;
	log.fileName := "mobiletest_" &amp; app.computerName &amp; ".log";
		
	foreach i in 1 to self.lstMain.listCount() do
		log.logServer(self.lstMain.itemText[i]);
	endforeach;
	
	
epilog
	delete jdo;
	delete log;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="load" id="cbd9e98f-bd95-459a-8b02-583461285749">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

/*

Date		Who		Reason


*/

vars
	left, 
	top, 
	width, 
	height 			: Integer;
	
begin
//	self.maxButton := false;
//	self.minButton := false;
	self.controlBox := false;
//	self.caption := null;
	
//	self.windowState := self.WindowState_Maximized;
	
	self.getDeskTopWorkArea(left, top, width, height);
	
	self.move(left, top - 26, width, height + 26);
	
	self.doRefreshCaption();
	
	
epilog

end;</source>
    </JadeMethod>
</GUIClass>
