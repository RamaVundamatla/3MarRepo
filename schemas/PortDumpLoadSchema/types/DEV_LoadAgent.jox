    <JadeMethod name="loadVoyageMovement" id="6aa37eac-e3df-495d-9ecb-4120e130c9e4">
        <source>loadVoyageMovement(_voyageMovementProxy:HMS_VoyageMovement io; _phase: Integer) :Boolean protected;

vars
	realObject: HMS_Object;
	proxyObject: HMS_VoyageMovement;
	error: CM_Error;
	countError,countOK: Integer;
begin
	if _phase = 0 then
		if _voyageMovementProxy.moveType = HMSMovementTypeArrival or
		   _voyageMovementProxy.moveType = HMSMovementTypeDeparture then
		else
			return true;
		endif;
	elseif _phase = 1 then
		if _voyageMovementProxy.moveType = HMSMovementTypeArrival or
		   _voyageMovementProxy.moveType = HMSMovementTypeDeparture then
			return true;
		endif;
	endif;
	if _voyageMovementProxy.myTidalClass = null then
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;_voyageMovementProxy.occursOnDTNEW.String&amp;" ERROR: "&amp;"Tidal Class Invalid.",0);
		return false;
	endif;
	if _voyageMovementProxy.myHMSVoyageData = null then
//	   _voyageMovementProxy.myHMSVoyageDataArchived = null then
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;_voyageMovementProxy.occursOnDTNEW.String&amp;" ERROR: "&amp;"Voyage Data Invalid.",0);
		return false;
	endif;
	app.myTrxCA.trxCreateHMSObject(_voyageMovementProxy, realObject, app.myPassport);
	if app.myPassport.trxCompletedOK and
	   app.myPassport.allErrorWarnings.size = 0 then
		beginTransaction;
		realObject.setPropertyValue("myHMSVoyageData",_voyageMovementProxy.myHMSVoyageData);
		commitTransaction;
		return true;
	else
		foreach error in app.myPassport.allWarnings do
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;_voyageMovementProxy.occursOnDTNEW.String&amp;" WARNING: "&amp;error.text,0);
		endforeach;
		foreach error in app.myPassport.allErrors do
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;_voyageMovementProxy.occursOnDTNEW.String&amp;" ERROR: "&amp;error.text,0);
		endforeach;
		return false;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_voyageMovementProxy" type="HMS_VoyageMovement" usage="io"/>
        <Parameter name="_phase" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
