        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getCustomsScanInspectionStops" id="3d4f7226-b6b9-4340-b50d-99de85043e39">
        <source>getCustomsScanInspectionStops(_stopTables : IntegerArray io; _terminal : CM_Terminal);
// ---------------------------------------------------------------------------
// Created:		August 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	stopTable : CM_StopsTable;
begin
	foreach stopTable in self.allAvailableStopsTables do 
		if stopTable.isCustomsScanInspectionStop(_terminal) then
			_stopTables.add(stopTable.id);
		endif;
	endforeach;
end;</source>
        <Parameter name="_stopTables" type="IntegerArray" usage="io"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getDefaultDebtor" id="f891956d-2168-4451-b90b-447e1230e31f">
        <source>getDefaultDebtor( _term : CM_Terminal ):CM_Debtor;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 September 2012	cnwndl1	Initial creation	CCMS SFW 1296 Par 30375

*/

vars

	debtor : CM_Debtor;

begin

	if _term &lt;&gt; null then
		debtor := _term.getConfig(DefDebtor).CM_Debtor;
	endif;
	
	if debtor = null then
		debtor := self.myRootCompany.debtors["RDT"];
	endif;
	
	return debtor;

epilog

end;</source>
