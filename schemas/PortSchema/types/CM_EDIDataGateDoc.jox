    <JadeMethod name="canBePartiallyLoaded" id="1e65872c-b600-43c5-8a38-37ad98226279">
        <source>canBePartiallyLoaded(): Boolean protected;
/*
Date		Who		Reason
16 Aug 2012	cnwcs5	Initial creation - par 30136
11 Oct 2012	cnwrs1	Change to use EdiBookingAllowPartial not EdiReleaseAllowPartial
// 20 Nov 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
// 15 Feb 2018	jlgrs1	TFS 36951 JMT Prenote Partial for GateDoc
*/
vars

begin
	return true;
epilog

end;</source>
