    <JadeMethod name="cnwdad1_Inspect" id="382503a5-83fb-44e0-bb0c-7ad517bc2dd8">
        <source>cnwdad1_Inspect(pObject:Object; pIsModal:Boolean; pIsBaseSchema:Boolean);
// --------------------------------------------------------------------------------
// Created:		13 December 2006 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.computerName().toLower() = "cnwdad1a" then
		if pIsBaseSchema then
			if pIsModal then
				pObject.cnEcInspectModal();
			else
				pObject.cnEcInspect();
			endif;
		else
			if pIsModal then
				pObject.inspectModal();
			else
				pObject.inspect();
			endif;
		endif;
	endif;
end;</source>
        <Parameter name="pObject" type="Object"/>
        <Parameter name="pIsModal" type="Boolean"/>
        <Parameter name="pIsBaseSchema" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_Mail_Server" id="8704849b-2c47-4723-99b2-e9c83f59db53">
        <source>cnwdad1_Test_Mail_Server();
// --------------------------------------------------------------------------------
// Created:		30 September 2008 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 1 Jul 2013		cnwrs1	ccms 1336 Par 31389 separate BGP EmailRequest to seperate read and send
// --------------------------------------------------------------------------------
vars
	popmainObj		: POPMAIN;
	popmsgObj		: POPMSG;
	pop3Server		: String;
	pop3User		: String;
	pop3Password	: String;
	errStr			: String;
	messageId		: String;
	emailContent	: String;
	toAddress			: String;
	fromAddress : String;
	directory		: String;
	subject			: String;
	message			: String;
	connectResult	: Integer;
	emailCount		: Integer;
	i				: Integer;
	nSize			: Integer;
	numAttachments	: Integer;
	timeStamp		: TimeStamp;
	
begin
	app.initialize();
	
	app.writeLog("Checking email...", LogINFO);
	
	// Create transient
	create popmainObj transient;
	
	// Get logon information.
	pop3Server		:=	"imap.cnw.co.nz";
	pop3User		:=	"cnwportstest";
	pop3Password	:=	"password";
	
	// Try and connect to server.
	connectResult	:=	popmainObj.connect(pop3Server, pop3User, pop3Password);
	
	if connectResult = 0 then
		app.writeLog("Successfully connected to email server.", LogINFO);	
	else
		app.writeLog("Error with connecting server ERROR RETURNED: " &amp; connectResult.String &amp; ". SERVER&gt;&gt;"&amp; pop3Server &amp; "&lt;&lt; USER&gt;&gt;" &amp; pop3User &amp; "&lt;&lt; PW&gt;&gt;" &amp; pop3Password &amp; "&lt;&lt; PORT &gt;&gt;" &amp; popmainObj.serverPort.String &amp; "&lt;&lt;", LogINFO);	
		return;
    endif;
	
	// How many emails are there
	emailCount	:=	popmainObj.getTotalOfMails();
	
	if emailCount = -1 then
		app.writeLog("Cannot fetch number of emails.", LogINFO);	
		return;
	elseif emailCount = 0 then
		app.writeLog("The are no emails.", LogINFO);
		return;
	endif;
	
	return;
	
	create popmsgObj transient;
	/* This application utilizes a licensed copy of ADS Objects. ADS
	Objects is copyrighted and owned exclusively by ADMINSYSTEM SOFTWARE
	LIMITED. All rights reserved. Use of the objects outside of the
	context of this application is a violation of federal copyright laws
	and international treaty provisions */
	
	//popmsgObj.registerKey := "AP-OM1105668372-00327-73BE46D57EDCDBDFCCAC6C5FB40F7584";
	// PAR 22506
	app.emailArchitectSetLicensePOP(CM_Terminal.firstInstance, popmsgObj);
	
	// Loop through emails.
	foreach i in 1 to emailCount do
		nSize := popmainObj.getMsgSize(i);
		if nSize = -1 then
		  errStr := "error with GetMsgSize";   
		  app.raiseCMException1(EmailReceiveFailure, errStr, null, null);
			return;
		endif;
		
		// Check message id is ok
		messageId := popmainObj.getMsgID(i);
		if messageId = null then
			errStr := "error with GetMsgId";  
			app.raiseCMException1(EmailReceiveFailure, errStr, null, null);
			return;
		endif;
		
		// Get content of email.
		emailContent := popmainObj.retrieve(i);
		if emailContent = null then
			errStr := "error with Retrieve";
			app.raiseCMException1(EmailReceiveFailure, errStr, null, null);
			return;
		endif;
		
		// Parse content with transient message object.
		popmsgObj.rawContent := emailContent;
		
		// Get information on message.
		fromAddress := popmsgObj.getFromAddress();
		subject := popmsgObj.getSubject();
		message := popmsgObj.getAltBody();
		// Find appropriate edi directory for email.
//		directory := self.sortEmails(address);
		
		if directory = null then
			app.raiseCMException1(EmailReceiveFailure, 'Unable to determine file path.  Check that the EDI directories are valid.', null, null);
			return;
		endif;
		
		// Does message have any attachments.
		numAttachments := popmsgObj.getAttachmentCount();
		
		// If we have attachments then save them.
		if numAttachments &lt;&gt; 0 then
			// Returns number saved
			if popmsgObj.saveAllAttachments(directory) = 0 then
				errStr := "error with saving attachments";
				app.raiseCMException1(EmailReceiveFailure, errStr, null, null);
				return;
			endif;
		else
			// Just dump message to directory.
			popmsgObj.rawContent := emailContent;
//			nRet := popmsgObj.exportFile( directory &amp; '\' &amp; IDENTIFIER &amp; self.getInstanceIdForObjectXX(process).String &amp; timeStamp.Time.second.String &amp; timeStamp.Time.milliSecond.String &amp; '.eml');
			if connectResult &lt;&gt; 0 then
			  errStr := "error with ExportFile";
			  app.writeLog(errStr, LogINFO);
				return;
			endif;
		endif;
		
		// Log and create activity history.
		app.writeLog('Message sent from ' &amp; fromAddress, LogINFO);
		app.writeLog('Message subject ' &amp; subject, LogINFO);
		app.writeLog('Message ' &amp; CrLf &amp; '&lt;' &amp; message &amp; '&gt;', LogINFO);
		app.writeLog('Number of attachments - ' &amp; numAttachments.String, LogINFO);
		app.createActivityHistory(ActivityHistoryEmail, null, null, app.getErrorString(Received_From) &amp; fromAddress &amp; ' ... ' &amp; subject, false, false);
		
		//auto reply?
//		self.autoReply(address, address, subject, message);	
		
		// Delete or mark message for deletion. We have successfully processed it.
		if popmainObj.delete_(i) &lt;&gt; 0 then
			errStr := "error with Delete";
			app.raiseCMException1(EmailReceiveFailure, errStr, null, null);
		endif;
	endforeach;

	
epilog
	popmainObj.close();
	delete popmainObj;
	delete popmsgObj;

	terminate;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_write" id="bd1bc607-86d5-43f1-9df0-627cbe837d6c">
        <source>cnwdad1_write(pDisplay:String; pIsNewWindow:Boolean; pIsClearWindow:Boolean);
// --------------------------------------------------------------------------------
// Created:		17 June 2005 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
// --------------------------------------------------------------------------------
begin
	if self.computerName().toLower() = "cnwdad1a" then
		if pIsNewWindow then
			app.closeWriteWindow();
		elseif pIsClearWindow then
			app.clearWriteWindow();
		endif;
		
		app.writeStatement(app.actualTimeServer().String &amp; ": " &amp; pDisplay);// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	endif;
end;</source>
