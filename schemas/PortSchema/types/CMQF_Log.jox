    <JadeMethod name="getMyLogType" id="24fc75bc-9be8-405a-b958-5f068b2d08c0">
        <source>getMyLogType():CM_LogType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 July 2016	cnwndl1	Initial creation	TFS 2329

*/

vars

	object : CM_LogType;
	edition : Integer;
	invalidObj : Boolean;

begin

	object := self.myLogType;

	if object = null then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject( exception, object, invalidObj );
	edition := object.edition;
	
	if invalidObj then
		return null;
	endif;
	
	return object;

epilog

end;</source>
