    <JadeMethod name="bulkExport" id="ab6eb076-aaee-4437-87a4-51e4b93c17c2">
        <source>bulkExport(pTheTargetFile:File io);
// --------------------------------------------------------------------------------
// Created:		04 September 2002 by cnwdad1
//
// Parameters:	pTheTargetFile - The name of the target file for the export.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theWord		: JSSWord;
	
begin
	foreach theWord in self.allWords do
		pTheTargetFile.writeLine(theWord.wordName);
	endforeach;
end;</source>
        <Parameter name="pTheTargetFile" type="File" usage="io"/>
    </JadeMethod>
    <JadeMethod name="bulkLoad" id="7d4601ac-42f0-45f6-84e6-22a437991f65">
        <updating/>
        <source>bulkLoad(pTheSourceFile:File) updating;
// --------------------------------------------------------------------------------
// Purpose:		Imports all Spell Words from a disk file.
//
// Parameters:	pFileName - The name of the source file for the import.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 17/08/2001	cnwdad1		Change to receive the source file from the requesting
//							method instead of instantiating it from this method.
// 27/08/2001	cnwdad1		Added a progress dialog to the load process.
// --------------------------------------------------------------------------------
constants
	WORDS_PER_TRANSACTION	: Integer = 1000;
	WORDS_PER_PROGRESS		: Integer = 100;
	
vars
	fileRecord			: String;
	recordLength		: Integer;
	wordToCheck			: String;
	theSpellWord		: JSSWord;
	charPosition		: Integer;
	wordCharacter		: Character;
	theProgressForm		: JSSProgressForm;
	fileLength			: Integer;
	partsDone			: Integer;
	messageResponse		: Integer;
	transactionCount	: Integer;
	progressCount		: Integer;
	
begin
	fileLength	:=	pTheSourceFile.fileLength();
	create theProgressForm;
	theProgressForm.startProgress("Loading " &amp; pTheSourceFile.fileName &amp; "...", fileLength);
	theProgressForm.show();
	partsDone	:=	0;

	beginTransaction;
	
	while (not pTheSourceFile.endOfFile()) do
		fileRecord			:=	pTheSourceFile.readLine();
		recordLength		:=	fileRecord.length();
		partsDone			:=	partsDone + recordLength;
		transactionCount	:=	transactionCount + 1;
		progressCount		:=	progressCount + 1;
		
		foreach charPosition in 1 to recordLength do
			wordCharacter	:=	fileRecord[charPosition];
			
			if wordCharacter.isAlpha() or wordCharacter = "-" then
				wordToCheck	:=	wordToCheck &amp; wordCharacter;
				
				if charPosition &lt; recordLength then
					// We are still building a wordToCheck, so skip to the next character.
					continue;
				endif;
			endif;
			
			if wordToCheck.length() &gt; 0 then
				// If we have a word, convert it to lower case.
				wordToCheck	:=	wordToCheck.toLower();
				
				// If the word isn't already in the database, it will be added.
				if self.allWords[wordToCheck] = null then
					self.createWord(wordToCheck, theSpellWord);
				endif;
			endif;
			
			// Reset the processed word and go around again.
			wordToCheck	:=	null;
		endforeach;
		
		// Check whether it's time to commit the transactions to the database.
		if transactionCount = WORDS_PER_TRANSACTION then
			transactionCount	:=	0;
			
			commitTransaction;
			beginTransaction;
		endif;
		
		// Check whether it's time to update the progress form.
		if progressCount = WORDS_PER_PROGRESS then
			progressCount	:=	0;
			theProgressForm.updateProgress(partsDone);
			
			if theProgressForm.isCancelled then
				theProgressForm.visible	:=	false;
				
				messageResponse	:=	app.msgBox(	"Do you stop the data load (some words already imported will be lost) ?",
												"Cancel Import",
												MsgBox_Question_Mark_Icon + MsgBox_Yes_No);
				
				if messageResponse = MsgBox_Return_Yes then
					break;
				elseif messageResponse = MsgBox_Return_No then
					// The user must have changed their mind, so continue with the load.
					theProgressForm.visible	:=	true;
					theProgressForm.resetCancelFlag();
				endif;
			endif;
		endif;
	endwhile;
	
	theProgressForm.updateProgress(fileLength);
	
	commitTransaction;
epilog
	if theProgressForm &lt;&gt; null then
		theProgressForm.unload();
		delete theProgressForm;
	endif;
end;</source>
        <Parameter name="pTheSourceFile" type="File"/>
    </JadeMethod>
    <JadeMethod name="createWord" id="e3d60022-2413-4a8e-a022-2bbef2e5ab53">
        <updating/>
        <source>createWord(pName:String; pNewWord:JSSWord output):String updating;
// --------------------------------------------------------------------------------
// Created:		04 September 2002 by cnwdad1
//
// Purpose:		This method created by JediMethodGenerator at 17:00:46 on 07 June 2001
//				It will create a JSSWord Object.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theWord		: JSSWord;

begin
	create theWord;
	
	theWord.initializeMe(self, pName);
	pNewWord	:=	theWord;
	
	return null;
end;</source>
        <Parameter name="pName" type="String"/>
        <Parameter name="pNewWord" type="JSSWord" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="updateMe" id="8638d89e-d641-49e5-a0cf-34ad76e1f350">
        <updating/>
        <source>updateMe(pDictionaryName:String; pTheRoot:JSSRoot):String updating;
// --------------------------------------------------------------------------------
// Created:		05 September 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	// Update non-key properties.
	
	// Update key properties.
	
	if self.dictionaryName &lt;&gt; pDictionaryName then
		self.dictionaryName	:=	pDictionaryName;
	endif;
	
	// Update references.
	
	if self.myRoot &lt;&gt; pTheRoot then
		self.myRoot			:=	pTheRoot;
	endif;
	
	return null;
end;</source>
        <Parameter name="pDictionaryName" type="String"/>
        <Parameter name="pTheRoot" type="JSSRoot"/>
        <ReturnType type="String"/>
    </JadeMethod>
