        <embedded/>
        <type name="XLAT_Category"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myLog" id="7c3e0cad-dfed-4615-8b78-1aa9e93ceb34">
        <embedded/>
        <type name="JadeLog"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="root" id="11c14611-c88f-4dcb-95de-77cee9a295eb">
