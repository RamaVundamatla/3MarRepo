    <JadeMethod name="getClassForClass" id="280dc9a1-8c24-403c-89ab-d83d15e2cb73">
        <source>getClassForClass(_cls: Class): Class;
//----------------------------------------------------------------
//	Created:	13 October 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	
	if _cls = CM_EDIDataGenCSV
	or _cls = CM_EDIDataGenXML then
		return CM_EDIDataGeneric;
	endif;
	
	return _cls;
end;</source>
