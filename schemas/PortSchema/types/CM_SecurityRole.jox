    <JadeMethod name="getXMLForComparision" id="9fe886c8-8be1-459a-969c-bae0df3db348">
        <source>getXMLForComparision( _xmlElement : JadeXMLElement input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 September 2014	cnwndl1	Initial creation

*/

vars

	xmlElement : JadeXMLElement;
	xmlSubElement : JadeXMLElement;
	size : Integer;
	permissionInt : Integer;

begin

	xmlElement := _xmlElement.addElement("CM_SecurityRole");
	
	xmlSubElement := xmlElement.addElement("name");
	xmlSubElement.setText( self.name );
	
	if self.myParentRole &lt;&gt; null then
		xmlSubElement := xmlElement.addElement("myParentRole");
		xmlSubElement.setText( self.myParentRole.name );
	endif;
	
	size := self.permissions.size;
	foreach permissionInt in 1 to size do
		if self.permissions[permissionInt] then
			xmlSubElement := xmlElement.addElement("permission");
			xmlSubElement.setText( permissionInt.String );
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="_xmlElement" type="JadeXMLElement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="includesSubMaintRoles" id="96181ce6-3c34-42ae-a58f-fa4f7f7991fb">
