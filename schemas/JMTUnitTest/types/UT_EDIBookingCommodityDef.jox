	&lt;number&gt;5&lt;/number&gt;
	&lt;totalWeight&gt;25840&lt;/totalWeight&gt;
	&lt;commodityDescription&gt;'&amp;Commodity4&amp;'&lt;/commodityDescription&gt;
	&lt;cargoTypeDescr&gt;CONT&lt;/cargoTypeDescr&gt;
	&lt;imCodes&gt;1.2 (0450, 0440)&lt;/imCodes&gt;
	&lt;/BookingItem&gt;
	&lt;/AllBookingItem&gt;
	&lt;/BookingHeader&gt;
  &lt;/AllBookingHeader&gt;
&lt;/JMTInternalBooking&gt;';
	ediFile := self.ediLoadFileName(text, EDIFileType_XML, UserDefinedBooking, UserDefinedBooking&amp;method.name);
	self.assertNotNull(ediFile);
	self.ediVerify(ediFile);
	tempStr	:= 'Verified failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS, tempStr);
