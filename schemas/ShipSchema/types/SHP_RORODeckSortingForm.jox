    <JadeMethod name="initDeckTable" id="3a41a274-fcfb-404d-9682-a44fa12eedeb">
        <source>initDeckTable();
/*
Date		    Who			Reason
30 September 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars

begin
	self.tblDecks.selectMode := Table.SelectMode_CurrentRow;
	self.tblDecks.rows := 0;
	self.tblDecks.columns := 4;
	self.tblDecks.addItem(app.getErrorString(Deck) &amp; Tab &amp; app.getErrorString(CM_Description) &amp; Tab &amp; Tab);
	self.tblDecks.fixedRows := 1;
	self.tblDecks.accessColumn(TblCol_Up).width := 15;
	self.tblDecks.accessColumn(TblCol_Down).width := 15;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="0813f792-3611-431b-9544-c4b7caa60fe1">
        <updating/>
        <source>setupForm() updating;
/*
Date		    Who			Reason
30 September 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars

begin
	inheritMethod();

	self.toolbarStyle	:= self.ToolbarStyle_ShowNoHide;
	self.showToolbar 	:= true;	
	self.frmToolbar.bevelShadowColor := self.frmToolbar.backColor;
	
	self.height := self.FORM_HEIGHT;
	self.width :=  self.FORM_WIDTH;
	
	self.tblDecks.width := self.FORM_WIDTH - 20;
	self.tblDecks.height := self.FORM_HEIGHT - 45;
	self.tblDecks.top := 7 + self.frmToolbar.height;
	self.tblDecks.left := 7;
	
	self.mnuFile.visible := false;
	self.mnuHelp.visible := false;
	self.mnuOptions.visible := false;
	self.mnuWindows.visible := false;
	self.mnuTerminal.visible := false;
	self.mnuView1.visible := false;	
	
	self.backColor := self.frmToolbar.backColor;	

	self.initDeckTable();
	self.doDisplayDecks();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tblDecks_click" id="70da3c95-9d07-4fc1-af5c-ffbac642cf17">
