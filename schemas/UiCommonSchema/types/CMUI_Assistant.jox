    <JadeMethod name="comboBoxHMSVoyageData" id="d6d72186-be65-44a3-8398-df399a62377f">
        <source>comboBoxHMSVoyageData(pCmb : ComboBox input; _harbour : HMS_Harbour;
					 _includeArchived : Boolean; _voyageData : HMS_VoyageData);
//--------------------------------------------------------------
//Created: March 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	harbour : HMS_Harbour;
begin
	pCmb.clear();
	if _harbour = null and _voyageData = null then
		return;
	endif;
	harbour := _harbour;
	if harbour = null then
		harbour := _voyageData.myHarbour;
	endif;
	if harbour = null then
		return;
	endif;
	pCmb.listCollection(harbour.allVoyageData, false, 0);
	
	if _voyageData &lt;&gt; null then
		pCmb.text := self.displayEntryHMSVoyageData(_voyageData);
		if pCmb.text &lt;&gt; null then
			pCmb.listObject := _voyageData;
		endif;		
	endif;

end;</source>
