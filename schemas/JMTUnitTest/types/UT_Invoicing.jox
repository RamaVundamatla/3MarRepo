    <JadeMethod name="validateHMSInvoice4" id="b944b0aa-6d7f-4f12-884d-496b4c8d5a25">
        <source>validateHMSInvoice4(_invoice : CM_Invoice; _step : Integer; _calcType : Integer);
// original invoice - base quantity and rate from 2nd range (if any)
vars
	invCount	: Integer;
	qty			: Real;
	rate		: Decimal[12, 6];
	total		: Decimal[16, 6];
	invLine		: CM_InvoiceLine;
begin
	// get the expected values
	rate := 3;
	if _calcType = INV_CALC_TYPE_VESSEL_TON_QTY1 or
	   _calcType = INV_CALC_TYPE_VESSEL_TON_RANGE then
		rate := 4;
	endif;
	if _calcType = INV_CALC_TYPE_VESSEL_TON_QTY1 then
		qty := 1;
	elseif _calcType = INV_CALC_TYPE_VESSEL_TON_RANGE then
		qty := 12;
	elseif _calcType = INV_CALC_TYPE_TIMEBLCK_HRS_UNT or
	   _calcType = INV_CALC_TYPE_TIMEBLCK_HRS_ONE or
	   _calcType = INV_CALC_TYPE_VESSEL_TON then
		if _step = 1 then
			qty := 14400;
		elseif _step = 2 then
			qty := 1200;
		elseif _step = 3 then
			qty := 12000;
		elseif _step = 4 then
			qty := 120;
		elseif _step = 5 then
			qty := 16800;
		endif;
	endif;
	total := qty * rate;
	// the following calc types use the qty * GRT (etc) to multiply the rate for the line total, then set the quantity back to the resource used
//PAR 35940	if _calcType = INV_CALC_TYPE_TIMEBLCK_HRS_UNT or // INV_CALC_TYPE_TIMEBLCK_HRS_UNT now uses the UNIT BLOCK
	if _calcType = INV_CALC_TYPE_TIMEBLCK_HRS_ONE or
	   _calcType = INV_CALC_TYPE_VESSEL_TON then
	//	qty := 12;
	endif;
	// check the actual values
	foreach invLine in _invoice.invoiceLines do
		invCount := invCount + 1;
		if invCount = 1 then
			
			self.assertEqualMsg(invLine.lineTotal, total, "line 1 " &amp; _step.String &amp; " value");
			self.assertEqualMsg(invLine.quantity, qty, "line 1 " &amp; _step.String &amp; " quantity");
			//self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT", "line 1 ILD " &amp; _step.String);
		endif;
	endforeach;
	self.assertEqualMsg(invCount, 1, "Invoice lines, invoice " &amp; _step.String);
end;
</source>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <Parameter name="_step" type="Integer"/>
        <Parameter name="_calcType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validateHMSInvoice4a" id="71188f57-b9eb-43b1-9ad0-78e0234acaee">
        <source>validateHMSInvoice4a(_invoice : CM_Invoice; _step : Integer; _calcType : Integer);
// after rate change
vars
	invCount	: Integer;
	qty			: Real;
	rate		: Decimal[12, 6];
	total		: Decimal[16, 6];
	invLine		: CM_InvoiceLine;
begin
	// get the expected values
	rate := 6;
	if _calcType = INV_CALC_TYPE_VESSEL_TON_QTY1 or
	   _calcType = INV_CALC_TYPE_VESSEL_TON_RANGE then
		rate := 7;
	endif;
	if _calcType = INV_CALC_TYPE_VESSEL_TON_QTY1 then
		qty := 1;
	elseif _calcType = INV_CALC_TYPE_VESSEL_TON_RANGE then
		qty := 12;
	elseif _calcType = INV_CALC_TYPE_TIMEBLCK_HRS_UNT or
	   _calcType = INV_CALC_TYPE_TIMEBLCK_HRS_ONE or
	   _calcType = INV_CALC_TYPE_VESSEL_TON then
		if _step = 1 then
			qty := 14400;
		elseif _step = 2 then
			qty := 1200;
		elseif _step = 3 then
			qty := 12000;
		elseif _step = 4 then
			qty := 120;
		elseif _step = 5 then
			qty := 16800;
		endif;
	endif;
	total := qty * rate;
	// the following calc types use the qty * GRT (etc) to multiply the rate for the line total, then set the quantity back to the resource used
//PAR 35940	if _calcType = INV_CALC_TYPE_TIMEBLCK_HRS_UNT or // INV_CALC_TYPE_TIMEBLCK_HRS_UNT now uses the UNIT BLOCK
	if    _calcType = INV_CALC_TYPE_TIMEBLCK_HRS_ONE or
	   _calcType = INV_CALC_TYPE_VESSEL_TON then
		qty := 12;
	endif;
	// check the actual values
	foreach invLine in _invoice.invoiceLines do
		invCount := invCount + 1;
		if invCount = 1 then
			self.assertEqualMsg(invLine.quantity, qty, "line 1 " &amp; _step.String &amp; " quantity");
			self.assertEqualMsg(invLine.lineTotal, total, "line 1 " &amp; _step.String &amp; " value");
			//self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT", "line 1 ILD " &amp; _step.String);
		endif;
	endforeach;
	self.assertEqualMsg(invCount, 1, "Invoice lines, invoice " &amp; _step.String);
end;
</source>
