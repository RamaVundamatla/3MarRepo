    <JadeMethod name="clearExtrasPanel" id="340cb932-096d-4a0e-925d-f47bbd02c3c7">
        <updating/>
        <source>clearExtrasPanel()updating, protected;

begin
	btnGeneralClose.caption		:= "Cancel";
	btnGeneralUpdate.caption	:= "Update";

	self.populateCmbCopyFromFormat();
	cmbCopyFromFormat.visible	:= false;
	cmbCopyFromFormat.listIndex := CNEC_NULL_INDEX;

	fraGeneralUpdate.enabled	:= false;

	lblGeneral.caption			:= "";	
	lblClassFormat.caption		:= "Format Maintenance";
	lblPerforming.caption		:= "";

	txtTextGeneral.visible		:= false;
	txtTextGeneral.text			:= "";

	self.aUpdateType			:= 0;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="copyFormat" id="77253de3-aa93-49b9-865b-4a32d8659f8b">
        <updating/>
        <source>copyFormat(): Boolean updating, protected;

vars
	newFormatObj		: CnEcXmlFormat;
	copyFromFormatObj	: CnEcXmlFormat;
	
begin
	copyFromFormatObj	:=	cmbCopyFromFormat.listObject.CnEcXmlFormat;

	if txtTextGeneral.text.trimBlanks = "" then
		lblGeneral.caption		:= "The new format name may NOT be blank.";
		lblPerforming.caption	:= "Input Error: see detail above";						
		return false;
	elseif app.cnEcGetXmlFormat(txtTextGeneral.text.trimBlanks) &lt;&gt; null then
		lblGeneral.caption		:= "'" &amp;txtTextGeneral.text.trimBlanks &amp; "' already used.";
		lblPerforming.caption	:= "Input Error: see detail above";						
		return false;
	elseif copyFromFormatObj = null then
		lblGeneral.caption		:= "Must select a Format to copy from.";
		lblPerforming.caption	:= "Input Error: see detail above";						
		return false;
	else
		beginTransaction;
			create newFormatObj;
			newFormatObj.initializeMe(txtTextGeneral.text,0,app.myCnEcXmlSchema);
			newFormatObj.cnEcCreateCopyFormatClass(copyFromFormatObj);
		commitTransaction;
		
		fraGeneralUpdate.enabled := false;
		return true;
	endif;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="copyFormatClick" id="b6ec6a85-e41f-445b-969b-1085e9baf3e1">
        <updating/>
        <source>copyFormatClick() updating, protected;

begin
	self.clearExtrasPanel();

	btnGeneralUpdate.caption	:= "Perform Copy";
	btnGeneralClose.caption		:= "Cancel Copy";
	cmbCopyFromFormat.visible	:= true;
	fraGeneralUpdate.enabled	:= true;			
	lblGeneral.caption			:= "Select an existing format, enter the name of the new Format, and Press 'Perform Copy'";
	lblClassFormat.caption		:= "Copy existing format.";
	txtTextGeneral.enabled		:= true;
	txtTextGeneral.visible		:= true;
	self.aUpdateType := 4;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="createDefaultFormatProperties" id="23686139-650b-4b14-8918-17a712de93e4">
        <updating/>
        <source>createDefaultFormatProperties(	pClassObj : Class;
								pFormatClassObj : CnEcXmlFormatClass;
								pFormatObj : CnEcXmlFormat) updating, protected;

vars
	propertyCollObj		: PropertyColl;
	propertyObj			: Property;
	formatPropertyObj	: CnEcXmlFormatProperty;
	className			: String;
	
begin
	propertyCollObj	:=	pClassObj.allPropertiesUpTo(Object);
	
	foreach propertyObj in propertyCollObj do
		if propertyObj.isKindOf(Attribute) then	  
			// create formatAttribute here
			create formatPropertyObj as CnEcXmlFormatAttribute;
			formatPropertyObj.initializeMe(propertyObj.getName(), propertyObj.getName(), true, pFormatClassObj);
		else
			if propertyObj.getType.isKindOf(CollClass) then
				// create formatCollection here
				//propertyObj.inspectModal;
				className := propertyObj.getType().CollClass.getMemberType().getName();
				
				if pFormatObj.cnEcGetFormatClass(className) &lt;&gt; null then
					create formatPropertyObj as CnEcXmlFormatCollection;
					formatPropertyObj.initializeMe(propertyObj.getName(), propertyObj.getName(), true, pFormatClassObj);
					formatPropertyObj.CnEcXmlFormatReference.setMyFormat(pFormatObj);
					formatPropertyObj.CnEcXmlFormatCollection.setIsReportSize(false);
				else
					write "Collection no matching format for " &amp; pFormatObj.formatName &amp; " - " &amp; className &amp;
							", referenced by '" &amp; pClassObj.name &amp; "." &amp; propertyObj.name &amp; "'.";
				endif;
			else
				// create formatSingleton here
				className := propertyObj.getType().getName();
				
				if pFormatObj.cnEcGetFormatClass(className) &lt;&gt; null then
					create formatPropertyObj as CnEcXmlFormatSingle;
					formatPropertyObj.initializeMe(propertyObj.getName(), propertyObj.getName(), true, pFormatClassObj);
					formatPropertyObj.CnEcXmlFormatReference.setMyFormat(pFormatObj);
				else
					write "Single no matching format for " &amp;
							pFormatObj.formatName &amp; " - " &amp;
							className &amp; ", referenced by '" &amp;
							pClassObj.name &amp; "." &amp; propertyObj.name &amp; "'.";
				endif;
			endif;
		endif;
	endforeach;
epilog
	delete propertyCollObj;
end;</source>
        <access>protected</access>
        <Parameter name="pClassObj" type="Class"/>
        <Parameter name="pFormatClassObj" type="CnEcXmlFormatClass"/>
        <Parameter name="pFormatObj" type="CnEcXmlFormat"/>
    </JadeMethod>
    <JadeMethod name="createDefaultFormats" id="71df671b-4a11-4704-979c-17e7bec5857a">
        <updating/>
        <source>createDefaultFormats() updating, protected;

vars
	formatObj         	: CnEcXmlFormat;
	formatOIDObj      	: CnEcXmlFormat;
	baseRootObj 		: CnEcBaseRoot;
	formatClassObj    	: CnEcXmlFormatClass;
	formatPropertyObj	: CnEcXmlFormatProperty;
	formatMethodObj		: CnEcXmlFormatMethod;
	formatRefObj		: CnEcXmlFormatReference;
	classObj		 	: Class;
	subclassesObj		: ClassColl;
	className			: String;
	ts					: TimeStamp;
	xmlFormatCollObj	: CnEcXmlFormatDict;
	startTime			: Integer;
	pName : String;	//02 Feb 2015	NDL	Par 35619
	
begin
	startTime	:=	app.clock();
	write "##### Database has changed since last update of Default XML Formats, or update requested. #####" &amp; CrLf;
	write "##### Please wait while the Default XML Formats are re-created and re-mapped. #####" &amp; CrLf;
	
	baseRootObj		:=	app.myBaseRoot;
	formatObj		:=	baseRootObj.getXmlFormat(app.myCnEcXmlSchema.name, CNEC_DEFAULT_FULL);
	
	if formatObj &lt;&gt; null then
		beginTransaction;
			formatObj.renameMe(CNEC_DEFAULT_FULL &amp; "_OLD"); 
		commitTransaction;
	endif;
	
	formatObj := baseRootObj.getXmlFormat(app.myCnEcXmlSchema.name, CNEC_DEFAULT_REF);
	
	if formatObj &lt;&gt; null then
		beginTransaction;
			formatObj.renameMe(CNEC_DEFAULT_REF &amp; "_OLD"); 
		commitTransaction;
	endif;
		
	write "##### Default XML Formats renamed. Will now create the new Formats. #####" &amp; CrLf;

	beginTransaction;
	create formatOIDObj;
	formatOIDObj.initializeMe(CNEC_DEFAULT_REF,1,app.myCnEcXmlSchema);
	commitTransaction; 

	create subclassesObj transient;
	classObj := app.myCnEcXmlSchema.getClass("Object");
	classObj.allLocalSubclasses(subclassesObj);
	subclassesObj.add(classObj);
	classObj := app.myCnEcXmlSchema.getClass("Class");
	subclassesObj.add(classObj);
	
	if baseRootObj.getAllXmlExcludedClasses() &lt;&gt; null then
		foreach className in baseRootObj.getAllXmlExcludedClasses() do
			classObj := app.myCnEcXmlSchema.getClass(className);
			
			if subclassesObj.includes(classObj) then
				subclassesObj.remove(classObj);
			endif;
		endforeach;
	endif;

	beginTransaction;
    foreach classObj in subclassesObj do
    	create formatClassObj;
    	formatClassObj.initializeMe(classObj.getName, classObj.getName, true, true, null, null, formatOIDObj);
    
    	if self.class().getName = CnEcXmlFormat.name then
		
			pName := CnEcXmlFormat::formatName.name;	//02 Feb 2015	NDL	Par 35619
		
    		formatClassObj.updateMe(formatClassObj.tagName,
    								formatClassObj.isShowTagData,
    								formatClassObj.isSuppressTag,
    								pName,	//02 Feb 2015	NDL	Par 35619
    								"cnEcXmlImportEpilog");
									
			create formatPropertyObj as CnEcXmlFormatAttribute;	//02 Feb 2015	NDL	Par 35619
			formatPropertyObj.initializeMe(pName, pName, true, formatClassObj);	//02 Feb 2015	NDL	Par 35619
			
    	endif;
    	
    	create formatMethodObj;
    	formatMethodObj.initializeMe("oid", "OID", true, formatClassObj);
    	formatMethodObj.setMethodName("getOidString");
		
    endforeach;
    commitTransaction;

	beginTransaction;
	create formatObj;
	formatObj.initializeMe(CNEC_DEFAULT_FULL, 1, app.myCnEcXmlSchema);
	commitTransaction;

	beginTransaction;
    foreach classObj in subclassesObj do
    	create formatClassObj;
    	formatClassObj.initializeMe(classObj.getName, classObj.getName, true, false, null, null, formatObj);
    	
    	if self.class().getName = CnEcXmlFormat.name then
    		formatClassObj.updateMe(formatClassObj.tagName,
    								formatClassObj.isShowTagData,
    								formatClassObj.isSuppressTag,
    								"formatName",
    								"cnEcXmlImportEpilog");
    	endif;
    	create formatMethodObj;
    	formatMethodObj.initializeMe("oid", "oid", true, formatClassObj);
    	formatMethodObj.setMethodName("getOidString");
	   	self.createDefaultFormatProperties(classObj, formatClassObj, formatOIDObj);
    endforeach;
    
    baseRootObj.setXmlDefaultFormatLastRebuilt(ts);
    commitTransaction;
    
    write CrLf &amp; "##### New Default XML Formats created. Will now re-map where necessary. #####" &amp; CrLf;
    
    formatObj		:=	baseRootObj.getXmlFormat(app.myCnEcXmlSchema.name, CNEC_DEFAULT_FULL);
    formatOIDObj	:=	baseRootObj.getXmlFormat(app.myCnEcXmlSchema.name, CNEC_DEFAULT_REF);
    
    beginTransaction;
    create xmlFormatCollObj transient;
	baseRootObj.getAllFormatsForSchema(xmlFormatCollObj, app.myCnEcXmlSchema.name);
	
    foreach formatObj in xmlFormatCollObj do 	
	    if formatObj.formatName &lt;&gt; CNEC_DEFAULT_REF &amp; "_OLD"
	    and formatObj.formatName &lt;&gt; CNEC_DEFAULT_FULL &amp; "_OLD"
	    and formatObj.formatName &lt;&gt; CNEC_DEFAULT_REF
	    and formatObj.formatName &lt;&gt; CNEC_DEFAULT_FULL
	    then
			foreach formatClassObj in formatObj.allFormatClasses do
				foreach formatPropertyObj in formatClassObj.allProperties do
					if formatPropertyObj.isKindOf(CnEcXmlFormatReference) then
						formatRefObj := formatPropertyObj.CnEcXmlFormatReference;
						
						if app.isValidObject(formatRefObj.myFormat) then
							if formatRefObj.myFormat.formatName = CNEC_DEFAULT_REF &amp; "_OLD" then
								formatRefObj.setMyFormat(formatOIDObj);
							elseif formatRefObj.myFormat.formatName = CNEC_DEFAULT_FULL &amp; "_OLD" then
								formatRefObj.setMyFormat(formatObj);
							else
								continue;
							endif;
						endif;  
					endif;
				endforeach;
			endforeach;				
		endif;
	endforeach;
	commitTransaction;	

	write "##### Old Format mappings replaced by New. Will now delete the old Formats. #####" &amp; CrLf;
    
    formatObj		:=	baseRootObj.getXmlFormat(app.myCnEcXmlSchema.name, CNEC_DEFAULT_FULL &amp; "_OLD");
    formatOIDObj	:=	baseRootObj.getXmlFormat(app.myCnEcXmlSchema.name, CNEC_DEFAULT_REF &amp; "_OLD");
     	
    if formatObj &lt;&gt; null then
		beginTransaction;
			delete formatObj; 
		commitTransaction;
	endif;
	
	if formatOIDObj &lt;&gt; null then
		beginTransaction;
			delete formatOIDObj; 
		commitTransaction;
	endif;

	write "##### Old Default XML Formats deleted. #####" &amp; CrLf;
epilog 
	delete xmlFormatCollObj;
	
    write "##### Update Complete in " &amp; startTime.cnEcClockDifference().String &amp; " seconds. #####";
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="deleteFormat" id="9a5dc556-31e7-44b0-a44d-f7cbee422e89">
        <updating/>
        <source>deleteFormat(): Boolean updating, protected;

vars
	deleteFormatObj	: CnEcXmlFormat;
	
begin
	deleteFormatObj	:=	cmbCopyFromFormat.listObject.CnEcXmlFormat;

	if deleteFormatObj = null then
		lblGeneral.caption := "Must select a Format to delete.";
		return false;			
	else
		beginTransaction;
			delete deleteFormatObj;
		commitTransaction;
		
		fraGeneralUpdate.enabled := false;
		return true;
	endif;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="deleteFormatClick" id="2c996f72-0dcb-47c9-9d97-d06001a767d1">
        <updating/>
        <source>deleteFormatClick() updating, protected;

begin
	self.clearExtrasPanel();

	btnGeneralClose.caption		:= "Cancel Delete";
	btnGeneralUpdate.caption	:= "Perform Delete";
	btnGeneralUpdate.enabled	:= true;
	cmbCopyFromFormat.visible	:= true;
	fraGeneralUpdate.enabled	:= true;	
	lblGeneral.caption			:= "Select a format to delete, and Press 'Perform Delete'";
	lblClassFormat.caption		:= "Delete existing format.";	
	self.aUpdateType := 5;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="exportAllFormats" id="0829e6da-2ef3-4f72-9ae0-5d36c09df03f">
        <updating/>
        <source>exportAllFormats(): Boolean updating, protected;

vars
	baseRootObj			: CnEcBaseRoot;
	exportFormatObj		: CnEcXmlFormat;
	formatClassObj 		: CnEcXmlFormatClass;
	formatPropertyObj	: CnEcXmlFormatProperty;		
	inputFileName		: String;
	noidFileName		: String;
	errorFileName		: String;
	logFileName			: String;
	outputFileName		: String;
	formatName			: String;
	oidTableObj			: CnEcOidTable;
	formatDataArrayObj	: ObjectArray;
	hubbleObj			: CnEcHubble;
	fileOpenObj			: CMDFileOpen;
	xmlFormatCollObj	: CnEcXmlFormatDict;
	
begin
	baseRootObj := app.myBaseRoot;
	
	inputFileName 	:= "";
	errorFileName 	:= "";
	logFileName 	:= "";
	noidFileName	:= "";
	formatName 		:= CNEC_DEFAULT_FULL;
	
	create fileOpenObj transient;
	
	if fileOpenObj.open() = 0 then
		outputFileName 	:= fileOpenObj.fileName; 
		create formatDataArrayObj transient;
		create xmlFormatCollObj transient;
		baseRootObj.getAllFormatsForSchema(xmlFormatCollObj, app.myCnEcXmlSchema.name);
		
		foreach exportFormatObj in xmlFormatCollObj do 
			formatDataArrayObj.add(exportFormatObj);
			
			foreach formatClassObj in exportFormatObj.allFormatClasses do
				formatDataArrayObj.add(formatClassObj);
				
				foreach formatPropertyObj in formatClassObj.allProperties do
					formatDataArrayObj.add(formatPropertyObj);
				endforeach;
			endforeach;
		endforeach;

		create oidTableObj transient;
		create hubbleObj transient;
		
		hubbleObj.initializeMe(	errorFileName,
								inputFileName,
								noidFileName,
								logFileName,
								outputFileName,
								formatName,
								oidTableObj,
								formatDataArrayObj);
		
   		hubbleObj.export(0, true);
   	else
   		lblGeneral.caption := "No file selected for export.";
		lblPerforming.caption := "Input Error: see detail above";						
		return false;
   	endif;
   	
	fraGeneralUpdate.enabled := false;
	return true;
epilog
	delete formatDataArrayObj;
	delete oidTableObj;
	delete hubbleObj;
	delete fileOpenObj;
	delete xmlFormatCollObj;	
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="exportAllFormatsClick" id="b9cd043b-d00d-44f6-8a34-6ae668fa74d6">
        <updating/>
        <source>exportAllFormatsClick() updating, protected;

begin
	self.clearExtrasPanel();

	btnGeneralClose.caption		:= "Cancel Export All";
	btnGeneralUpdate.caption	:= "Perform Export All";
	btnGeneralUpdate.enabled	:= true;
	cmbCopyFromFormat.visible	:= false;
	fraGeneralUpdate.enabled	:= true;	
	lblGeneral.caption			:= "Press 'Perform Export All'";
	lblClassFormat.caption		:= "Export All existing formats.";	
	self.aUpdateType := 9;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="exportFormat" id="f3b6805e-3f72-4e23-a1e0-1c95bd3fe7aa">
        <updating/>
        <source>exportFormat(): Boolean updating, protected;

vars
	exportFormatObj		: CnEcXmlFormat;
	formatClassObj 		: CnEcXmlFormatClass;
	formatPropertyObj	: CnEcXmlFormatProperty;		
	inputFileName		: String;
	noidFileName		: String;
	errorFileName		: String;
	logFileName			: String;
	outputFileName		: String;
	formatName			: String;
	oidTableObj			: CnEcOidTable;
	formatDataArrayObj	: ObjectArray;
	hubbleObj			: CnEcHubble;
	fileOpenObj			: CMDFileOpen;
	
begin
	exportFormatObj := cmbCopyFromFormat.listObject.CnEcXmlFormat;

	if exportFormatObj = null then
		lblGeneral.caption := "Must select a Format to export.";
		lblPerforming.caption := "Input Error: see detail above";						
		return false;		
	else
		inputFileName 	:= "";
		errorFileName 	:= "";
		logFileName 	:= "";
		noidFileName	:= "";
		formatName 		:= CNEC_DEFAULT_FULL;

		create fileOpenObj transient;
		if fileOpenObj.open() = 0 then
			outputFileName 	:= fileOpenObj.fileName; 

			create formatDataArrayObj transient;
			formatDataArrayObj.add(exportFormatObj);
			
			foreach formatClassObj in exportFormatObj.allFormatClasses do
				formatDataArrayObj.add(formatClassObj);
				
				foreach formatPropertyObj in formatClassObj.allProperties do
					formatDataArrayObj.add(formatPropertyObj);
				endforeach;
			endforeach;

			create oidTableObj transient;
			create hubbleObj transient;
			
			hubbleObj.initializeMe(	errorFileName,
									inputFileName,
									noidFileName,
									logFileName,
									outputFileName,
									formatName,
									oidTableObj,
									formatDataArrayObj);
			
    		hubbleObj.export(0, true);
    	else
    		lblGeneral.caption		:= "No file selected for export.";
    		lblPerforming.caption	:= "Error";
			return false;
    	endif;

		fraGeneralUpdate.enabled := false;
		return true;
	endif;
epilog
	delete formatDataArrayObj;
	delete oidTableObj;
	delete hubbleObj;
	delete fileOpenObj;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="exportFormatClick" id="64d2ab12-b9bb-4f44-b76c-7b6a51c8acf7">
        <updating/>
        <source>exportFormatClick() updating, protected;

begin
	self.clearExtrasPanel();

	btnGeneralClose.caption		:= "Cancel Export";
	btnGeneralUpdate.caption	:= "Perform Export";
	btnGeneralUpdate.enabled	:= true;
	cmbCopyFromFormat.visible	:= true;
	fraGeneralUpdate.enabled	:= true;	
	lblGeneral.caption			:= "Select a format to export, and Press 'Perform Export'";
	lblClassFormat.caption		:= "Export existing format.";	
	self.aUpdateType			:= 7;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="importFormat" id="759c0eef-291e-418d-84f4-f7dc821d56aa">
        <updating/>
        <source>importFormat(): Boolean updating, protected;

vars
	fileOpenObj		: CMDFileOpen;
	inputFileName	: String;
	noidFileName	: String;
	errorFileName	: String;
	logFileName		: String;
	outputFileName	: String;
	hubbleId		: String;
	formatName		: String;
	oidTableObj		: CnEcOidTable;
	hubbleObj		: CnEcHubble;
	errorMsg		: String;
	
begin
	create fileOpenObj transient;
	
	if fileOpenObj.open() = 0 then
		oidTableObj	:=  CnEcBaseRoot.firstInstance.allXmlOidTables.getAtKey("FormatImport");
		
		if oidTableObj &lt;&gt; null then
			beginTransaction;
				delete oidTableObj;
			commitTransaction;
		endif;
		
		inputFileName 	:= fileOpenObj.fileName;
		errorFileName 	:= "";
		logFileName 	:= "";
		outputFileName 	:= "";
		noidFileName	:= "";
		hubbleId 		:= CNEC_XML_FormatImport;
		formatName 		:= CNEC_DEFAULT_FULL;
		create hubbleObj transient;
		
		hubbleObj.initializeMe(	errorFileName,
								inputFileName,
								noidFileName,
								logFileName,
								outputFileName,
								formatName,
								oidTableObj,
								null);	
		
		hubbleObj.setMyOidTable(hubbleId);
		
		errorMsg := hubbleObj.checkFormatsDoNotExist(File.Kind_Unknown_Text);	// 23/2/16 cnwmp6 PAR 36286 unicode version
		
		if errorMsg = "" then
			hubbleObj.loader(CNEC_DATA_LOAD_ATTRIBUTE, File.Kind_Unknown_Text);        // 23/2/16 cnwmp6 PAR 36286 unicode version
			hubbleObj.loader(CNEC_DATA_LOAD_SINGLETON, File.Kind_Unknown_Text);        // 23/2/16 cnwmp6 PAR 36286 unicode version
			hubbleObj.loader(CNEC_DATA_LOAD_COLLECTION, File.Kind_Unknown_Text);        // 23/2/16 cnwmp6 PAR 36286 unicode version
			
			hubbleObj.checkFormatsNeedingRemapping();	// this is the partner to hubble.checkFormatsDoNotExist 
			hubbleObj.deleteMyOidTable(hubbleId);
		else
			app.msgBox(errorMsg,"Unable to load Formats",MsgBox_OK_Only);
		endif;
	else
		lblGeneral.caption := "No file selected for import.";
		lblPerforming.caption := "Input Error: see detail above";						
		return false;
	endif;
	
	self.populateCmbCopyFromFormat();
	return true;
epilog
	delete fileOpenObj;
	delete hubbleObj;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="importFormatClick" id="89832438-adf5-4ab4-9ea8-af247d89e94c">
        <updating/>
        <source>importFormatClick()updating, protected;

begin
	self.clearExtrasPanel();

	btnGeneralUpdate.caption	:= "Perform Import";
	btnGeneralUpdate.enabled	:= true;
	btnGeneralClose.caption		:= "Cancel Import";	
	fraGeneralUpdate.enabled	:= true;		
	lblGeneral.caption			:= "Press 'Perform Import'";
	lblClassFormat.caption		:= "Import format.";
	self.aUpdateType := 6;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="load" id="c18aab4d-ab02-440d-8bd6-23883ceb5f8d">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

begin
	app.mousePointer	:=	Busy;
	inheritMethod();
	self.loadForm();
epilog
	app.mousePointer	:=	Idle;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadForm" id="764d4ccd-0b48-425b-9b04-a535e6ccbc8b">
        <updating/>
        <source>loadForm()updating, protected;

vars
	baseRootObj 		: CnEcBaseRoot;
	count 				: Integer;
	xmlFormatCollObj	: CnEcXmlFormatDict;
	
begin
	baseRootObj	:=	app.myBaseRoot;
	self.centreWindow();
	self.clearExtrasPanel();
	
	lblSchemaName.caption := "for schema: " &amp; app.myCnEcXmlSchema.name; 
	
	create xmlFormatCollObj transient;
	app.myBaseRoot.getAllFormatsForSchema(xmlFormatCollObj, app.myCnEcXmlSchema.name);
	
	if xmlFormatCollObj.size() = 0
	or baseRootObj.getXmlFormat(app.myCnEcXmlSchema.name, CNEC_DEFAULT_FULL) = null
	or baseRootObj.getXmlFormat(app.myCnEcXmlSchema.name, CNEC_DEFAULT_REF) = null
	then
		//if baseRoot.allXmlExcludedClasses.size() &gt; 0 then
		if baseRootObj.getAllXmlExcludedClasses() &lt;&gt; null
		and baseRootObj.getAllXmlExcludedClasses().size() &gt; 0
		then
			self.createDefaultFormats();
		else
			app.msgBox("Need to run 'Veto' form to create allExcludedClasses", "", MsgBox_OK_Only);
			self.unloadForm();
		endif;
	endif;
epilog
	delete xmlFormatCollObj;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="performOperation" id="08802513-b17b-486c-bc3e-6ab95a1da44e">
        <updating/>
        <source>performOperation()updating, protected;

vars
	isSuccess	: Boolean;
	
begin
	app.mousePointer := Busy;
	lblPerforming.caption := "Please wait .... while performing ";	

	if aUpdateType = 1 then	// addFormat
		lblPerforming.caption := lblPerforming.caption &amp; "add";
		app.doWindowEvents(0);
		isSuccess := self.addFormat();
	elseif aUpdateType = 4 then	// copyFormat
		lblPerforming.caption := lblPerforming.caption &amp; "copy";
		app.doWindowEvents(0);
		isSuccess := self.copyFormat();		
	elseif aUpdateType = 5 then	// deleteFormat
		lblPerforming.caption := lblPerforming.caption &amp; "delete";
		app.doWindowEvents(0);
		isSuccess := self.deleteFormat();		
	elseif aUpdateType = 6 then	// importFormat
		lblPerforming.caption := lblPerforming.caption &amp; "import";
		app.doWindowEvents(0);
		isSuccess := self.importFormat();		
	elseif aUpdateType = 7 then	// exportFormat
		lblPerforming.caption := lblPerforming.caption &amp; "export";
		app.doWindowEvents(0);
		isSuccess := self.exportFormat();
	elseif aUpdateType = 8 then	// renameFormat
		lblPerforming.caption := lblPerforming.caption &amp; "rename";
		app.doWindowEvents(0);
		isSuccess := self.renameFormat();		
	elseif aUpdateType = 9 then	// exportAllFormats
		lblPerforming.caption := lblPerforming.caption &amp; "export all";
		app.doWindowEvents(0);
		isSuccess := self.exportAllFormats();		
	endif;

	if isSuccess then
		self.clearExtrasPanel();
	endif;
epilog
	app.mousePointer := Idle;		
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateCmbCopyFromFormat" id="6659eca2-30a0-4cff-a06f-5fc4160834a7">
        <source>populateCmbCopyFromFormat() protected;

vars
	formatObj			: CnEcXmlFormat;
	xmlFormatCollObj	: CnEcXmlFormatDict;
	
begin
	cmbCopyFromFormat.clear();
	create xmlFormatCollObj transient;
	app.myBaseRoot.getAllFormatsForSchema(xmlFormatCollObj, app.myCnEcXmlSchema.name);

	foreach formatObj in xmlFormatCollObj do	
    	cmbCopyFromFormat.itemObject[cmbCopyFromFormat.addItem(formatObj.formatName)] := formatObj;
    endforeach;
epilog 
	delete xmlFormatCollObj;	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="reNameFormatClick" id="ddcc200d-c509-426b-b2f4-f153d7031706">
        <updating/>
        <source>reNameFormatClick() updating, protected;

begin
	self.clearExtrasPanel();

	btnGeneralUpdate.caption	:= "Perform Rename";
	btnGeneralClose.caption		:= "Cancel rename";
	cmbCopyFromFormat.visible	:= true;
	fraGeneralUpdate.enabled	:= true;			
	lblGeneral.caption			:= "Select an existing format, enter the new name for that new Format, and Press 'Perform Rename'";
	lblClassFormat.caption		:= "Rename existing format.";
	txtTextGeneral.enabled		:= true;
	txtTextGeneral.visible		:= true;
	self.aUpdateType := 8;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="renameFormat" id="6939aedc-6b6e-4b26-bd27-0b18264cea99">
        <updating/>
        <source>renameFormat() : Boolean updating, protected;

vars
	renameFormatObj 	: CnEcXmlFormat;
	
begin
	renameFormatObj := cmbCopyFromFormat.listObject.CnEcXmlFormat;

	if renameFormatObj = null then
		lblGeneral.caption		:= "Must select a Format to rename.";
		lblPerforming.caption	:= "Input Error: see detail above";						
		return false;
	elseif txtTextGeneral.text.trimBlanks = "" then
		lblGeneral.caption		:= "Must enter a new Format name.";	
		lblPerforming.caption	:= "Input Error: see detail above";						
		return false;
	elseif app.cnEcGetXmlFormat(txtTextGeneral.text.trimBlanks) &lt;&gt; null then
		lblGeneral.caption		:= "May not use the name of another existing Format.";	
		lblPerforming.caption	:= "Input Error: see detail above";						
		return false;				
	else
		beginTransaction;
			renameFormatObj.renameMe(txtTextGeneral.text.trimBlanks());
		commitTransaction;
	endif;
	
	return true;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="txtTextGeneral_change" id="907b33e2-af36-4cae-8739-97c030afc99e">
        <controlMethod name="TextBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtTextGeneral_change(textbox: TextBox input) updating;

begin
	btnGeneralUpdate.enabled := true;
end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
</GUIClass>
