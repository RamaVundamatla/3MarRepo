    <JadeMethod name="trxCreateVVRSecurityGate" id="d7f8b1b9-81c1-45b0-a986-8253399452a6">
        <updating/>
        <source>trxCreateVVRSecurityGate(	_proxyVVR : CM_VehicleVisitRecord;
							_realVVR : CM_VehicleVisitRecord io;
							_batNumber : String;
							_passport : CM_Passport input	) updating;
//
// Purpose:			Create vehicle visit record from new Security Gate
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 17/12/2013	cnwdap1		Initial creation PAR #32849 CCMS PEN 2321 Security Gate
// 10/08/2022	navkc1		Bug 54494: CUX - Drivers with multiple vehicles not saved
vars
	terminal 	: CM_Terminal;
	realVVR		: CM_VehicleVisitRecord;

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	terminal := _passport.myTerminal;
	
	_proxyVVR.validateForCreateSecurityGate(_batNumber, _passport);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	// Start the transaction
	beginTransaction;
	
	app.myUtilityCA.utlCreateVVRSecurityGate(_proxyVVR, realVVR, _batNumber, _passport);
	
	if _passport.noErrorsIgnored() then
		// Create vehicle if required
		if realVVR.vehicle = null then
			if not realVVR.createVehicle(_passport) then
				return;
			endif;
		endif;	
		
		if _passport.hasErrors() then
			return;
		endif;							
		
		// Create driver details if required
		if realVVR.myDriverDetails  = null and realVVR.driverCode &lt;&gt; null and realVVR.driversName &lt;&gt; null then
			if not realVVR.createDriver(_passport) then
				return;
			endif;
			
			if _passport.hasErrors() then
				return;
			endif;
		endif;
		
		if realVVR.myDriverDetails &lt;&gt; null and	// 10/08/2022	navkc1	#54494 --&gt; 	if it's existing driver make sure they are linked
					realVVR.myDriverDetails.allCarriers.includes(realVVR.vehicle.carrier) and	// make sure driver and vehicle have same carrier
						not realVVR.myDriverDetails.allVehicleMachines.includes(realVVR.vehicle) then	// check is vehicle linked to the driver
						
			realVVR.myDriverDetails.allVehicleMachines.add(realVVR.vehicle); // link them if not already.
			// 10/08/2022	navkc1	#54494 &lt;--
		endif;
	endif;	
	
epilog
	self.finaliseActivityWithPassport(_passport);
	if _passport.trxCompletedOK or _realVVR &lt;&gt; null then
		_realVVR := realVVR;
	endif;
end;</source>
        <Parameter name="_proxyVVR" type="CM_VehicleVisitRecord"/>
        <Parameter name="_realVVR" type="CM_VehicleVisitRecord" usage="io"/>
        <Parameter name="_batNumber" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCreateVVRTruckWeigh" id="b4729756-8464-4207-854d-06acb5411029">
        <updating/>
        <source>trxCreateVVRTruckWeigh(_vvr: CM_VehicleVisitRecord input; _weightIn, _weightOut: Decimal; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 June 2017	cnwmp6	Initial creation

*/

vars
	oldWeightInward,
	oldWeightOutward: Decimal[14, 4];
begin
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	oldWeightInward := _vvr.getVehicleWeightInward();
	oldWeightOutward := _vvr.getVehicleWeightOutward();

	beginTransaction;
	
	if _weightIn &lt;&gt; oldWeightInward then
		app.myUtilityCA.utlCreateVVRTruckWeigh(_vvr, VisitRecord_TruckGrsWeightIn, _weightIn, _passport);

		if app.myPassport.hasErrorsOrWarnings then
			return;
		endif;
	endif;

	if _weightOut &lt;&gt; oldWeightOutward then
		app.myUtilityCA.utlCreateVVRTruckWeigh(_vvr, VisitRecord_TruckGrsWeightOut, _weightOut, _passport);
	endif;

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord" usage="input"/>
        <Parameter name="_weightIn" type="Decimal"/>
        <Parameter name="_weightOut" type="Decimal"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
