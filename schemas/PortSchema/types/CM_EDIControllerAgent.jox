    <JadeMethod name="setEdiStatusDesc" id="fa2c2ba6-76eb-4672-8e4b-820261e937b8">
        <updating/>
        <source>setEdiStatusDesc( _value : String ) updating;

/*
Purpose:	Use this method to update the ediStatusDesc to save potential UE 1035 (string too long)
Date				Who		Reason
18 August 2009		cnwrl1	Initial creation as part of PAR 20318 - MES 1011 Web EDI Link
*/
	
vars
	msgMaxLength	: Integer;
	
begin
	msgMaxLength	:= self.ediStatusDesc.maxLength;
	if self.ediStatusDesc &lt;&gt; _value[ 1 : msgMaxLength ] then
		self.ediStatusDesc	:= _value[ 1 : msgMaxLength ];
	endif;
	
epilog
	
end;
