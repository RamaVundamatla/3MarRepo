<Class name="SchemaEntity">
    <JadeMethod name="getModifiedByJMT" id="9599b935-5ba5-4dcd-a7ec-aaa3df2887d6">
        <source>getModifiedByJMT() : String;

/*

Date		Who		Reason
04 Jul 2011	cnwkpd1	Renamed to prevent JADE 7.0 upgrade conflict
	
*/


vars
	modifiedBy	: String;
begin
	modifiedBy := self.getPropertyValue("_modifiedBy").String;
	if modifiedBy &lt;&gt; null then
		return modifiedBy;
	elseif userProfile &lt;&gt; null and app.isValidObject(userProfile) then
		return  userProfile.userName;
	else
		return null;
	endif;		
end;

</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getModifiedTimestamp" id="52ac9701-72a6-4d99-b92c-c30e5f7ce203">
        <source>getModifiedTimestamp() : TimeStamp;

vars

begin
	return self.modifiedTimeStamp;
end;
</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
</Class>
