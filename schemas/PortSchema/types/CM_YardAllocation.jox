    <JadeMethod name="shouldAuditProperty" id="22b53ee7-fd93-464e-8e59-9fd4ade219ee">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;

vars

begin
	if _property.name = CM_YardAllocation::myLastYABlockIn.name or 
	   _property.name = CM_YardAllocation::myLastYABlockOut.name then
	   	return false;
	endif;
	
	//  Do not audit some fields when YA belongs to a YA Template - SFW1030 21/08/2008
	if self.isYATemplate() then
		if _property.name = CM_YardAllocation::code.name or 
		   _property.name = CM_YardAllocation::myTerminal.name or
		   _property.name = CM_YardAllocation::myYATemplate.name then
			return false;
		endif;
	endif;
	
	return inheritMethod(_rootClass, _property);
end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="terminalMarkDictAdd" id="66f5bd8c-e1f5-4837-9873-877b1e44056c">
        <updating/>
        <source>terminalMarkDictAdd() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 10/03/2021	navdap1		Initial creation TFS 50889 PRP Yard Allocation Performance Improvement
//
vars
	crit : CM_YACriteria;
	mark, markData : String;
	data : CM_YADataString;
	marks : StringArray512;

begin
	if self.myTerminal = null then
		// we're here from a template creation - our yard alloction shouldn't be added to the collection
		return;
	endif;
	
	create marks transient;
	foreach crit in self.allCriteria discreteLock do
		if crit.code = self.CRITERIA_MARK then
			marks.clear;
			data := crit.myYAData.CM_YADataString;
			markData := data.value;
			markData.getTokensForDelimiter(Comma, marks);
			foreach mark in marks do
				mark := mark.trimBlanks[1:100];
				if self.myTerminal.allYAsByMark[mark, self.code] = null then
					self.myTerminal.allYAsByMark.putAtKey(mark, self.code, self);
				endif;
			endforeach;
		endif;
	endforeach;
	
epilog
	delete marks;
end;</source>
    </JadeMethod>
    <JadeMethod name="terminalMarkDictRemove" id="8a5d0dae-ad61-4033-a34e-ea5074895fe2">
        <updating/>
        <source>terminalMarkDictRemove(_pxyYA : CM_YardAllocation; _transientCriteriaObjs : CMIF_Array) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 10/03/2021	navdap1		Initial creation TFS 50889 PRP Yard Allocation Performance Improvement
//
vars
	cmifObj : CMIF_Object;
	pxyCrit : CMIF_YACriteriaPriority;
	realCrit : CM_YACriteria;
	realMark, realMarkData : String;
	pxyData, realData : CM_YADataString;
	realMarks : StringArray512;

begin
	create realMarks transient;
	
	foreach cmifObj in _transientCriteriaObjs discreteLock do
		pxyCrit := cmifObj.CMIF_YACriteriaPriority;
		if pxyCrit.myProxy.code = self.CRITERIA_MARK then
			foreach realCrit in self.allCriteria discreteLock where realCrit.code = self.CRITERIA_MARK do
				pxyData := pxyCrit.myProxy.myYAData.CM_YADataString;
				realData := realCrit.myYAData.CM_YADataString;
				if pxyData.value = realData.value and _pxyYA.code = self.code then
					// nothing to do, nothing's changed
					return;
				endif;
				// take out the entry matching the real keys from the terminal's external collection of yard allocations by mark
				// we will put the new (proxy) entries in later
				realMarkData := realData.value;
				realMarkData.getTokensForDelimiter(Comma, realMarks);
				foreach realMark in realMarks do
					realMark := realMark.trimBlanks[1:100];
					if self.myTerminal.allYAsByMark[realMark, self.code] &lt;&gt; null then
						self.myTerminal.allYAsByMark.removeKeyEntry(realMark, self.code, self);
					endif;
				endforeach;
			endforeach;
		endif;
	endforeach;
	
epilog
	delete realMarks;
end;</source>
        <Parameter name="_pxyYA" type="CM_YardAllocation"/>
        <Parameter name="_transientCriteriaObjs" type="CMIF_Array"/>
    </JadeMethod>
    <JadeMethod name="updateLastYABlock" id="df07894d-b478-4f3e-88df-3784414a4484">
        <source>updateLastYABlock(_yardAllocation : CM_YardAllocation input; _block : CM_YABlock; _isIn : Boolean) : Boolean protected;
// -------------------------------------------
// Created 05 May 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	app.myTrxUA.trxUpdateYALastBlock(_yardAllocation, _block, _isIn, app.myPassport);
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="_yardAllocation" type="CM_YardAllocation" usage="input"/>
        <Parameter name="_block" type="CM_YABlock"/>
        <Parameter name="_isIn" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validate" id="5e8e09db-acdc-4736-8d2e-44665822d9e8">
        <source>validate();
// --------------------------------------------------------------------------------
// Created:		05 May 2005 by cnwdad1
//
// Purpose:		Validates the receiver's proxy details.
//
// Parameters:	pYardAllocationObj - A reference to the persistent Yard Allocation object.
//				pProxyObj - A reference to the proxy Yard Allocation object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// 15 Nov 06	cnwth2		Not only was this method passing in self unnecessarily, it was also passing in some other proxy
//							allocation which was never dereferenced. I removed both from the method signature
//							and changed to dereference self. 
// ----------	----------	-------------------------------------------------------
// 18/03/2021	navdap1		TFS 50946 PRP Auto Delete of Yard Allocations
// --------------------------------------------------------------------------------
vars

	testDate : Date;
	cargoType : CM_CargoType;
	
begin
	// Validate the Locations details.

	// We now allow no locations because of Otago requirement.	
//	if pProxyObj.allYABlocksIn.isEmpty() and pProxyObj.allYABlocksOut.isEmpty() then
//		app.raiseCMException(Err_YA_NoLocations, null, null);
//	endif;
	
	if self.fillOptionIn = 0 then
		app.raiseCMException(Err_YA_NoFillIn, null, null);
	endif;
	
	if self.fillOptionOut = 0 then
		app.raiseCMException(Err_YA_NoFillOut, null, null);
	endif;
	
	// Validate the Criteria details.
	// DARRELL THIS HASN'T BEEN SET AT THIS STAGE.
	// TEMPORARILY TURNING OFF SO I CAN CONTINUE TESTING
	if self.allCriteria.isEmpty() then
//		app.raiseCMException(Err_YA_NoCriteria, null, null);
	endif;
	
	if self.code = null then
		app.raiseCMException(Err_YA_NoCode, null, null);
	endif;
	
	if self.description = null then
		app.raiseCMException(Err_YA_NoDescription, null, null);
	endif;
	
	// Validate the Options details.
	
	if self.expiryType = YAExpiryType_SpecifiedDate then
		testDate	:=	self.expiryDate;
		
		if testDate = null
		or not testDate.isValid()
		then
			app.raiseCMException(Err_YA_NoExpiryDate, null, null);
		endif;
		
	elseif self.expiryType &lt;&gt; YAExpiryType_Never
	and self.expiryType &lt;&gt; YAExpiryType_VoyageDepart
	and self.expiryType &lt;&gt; YAExpiryType_VoyageClear	//29 Jun 2011	NDL	Par 27786
	and self.expiryType &lt;&gt; YAExpiryType_WhenEmpty
	and self.expiryType &lt;&gt; YAExpiryType_NoCargo			// TFS 50946
	then
		app.raiseCMException1(Err_YA_InvalidExpiryType, self.expiryType.String, null, null);
	endif;
	
	if self.allowOthersOption = 0 then
		app.raiseCMException(Err_YA_NoAllowOthers, null, null);
	endif;
	
	if self.noLocationOption = 0 then
		app.raiseCMException(Err_YA_NoLocationFound, null, null);
	endif;
	
	if self.projectedGC &gt; 0 then	//31 Mar 2021	NDL	TFS 49912	
		if self.isForGenCargoAllocationRow then
			//We must have a cargo type if we are going to update/create a 'Prod Min Max' object from the projected GC value.
			cargoType := self.getCargotype();
			if cargoType = null then
				app.raiseCMWarning(Proje_value_will_not_appli_sel, null, null, null);
			endif;
		endif;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateBGPForNoCargoExpiry" id="8ecde385-7ecd-4431-8303-6c6e56c67bf1">
        <source>validateBGPForNoCargoExpiry();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 18/03/2021	navdap1		Initial creation TFS 50946 PRP Auto Delete of Yarad Allocations
//
vars
	schedule : CM_AutoSchedule;

begin
	if not self.expiryType = YAExpiryType_NoCargo then
		return;
	endif;
	
	// check the frequency of any YAExpiry schedule - enforce at least a week's gap
	foreach schedule in app.myRoot.allAutoSchedulesByStartTs discreteLock do
		if schedule.allAutoTasks.first.isKindOf(CM_AutoTaskYAExpiry) then
			if schedule.failsYAExpiryCheck then
				app.raiseCMException1(Schedule_incompat_auto_action, schedule.description, null, null);
			endif;
		endif;
	endforeach;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateCriteria" id="b8d4b35e-4923-4b0a-b70a-026e23203abc">
        <source>validateCriteria();

/*

Purpose:		Validate Criteria.
				Performed after criteria patterns have been resolved (i.e. after proxy copied to persistant).

Parameters:			

Return Value:		


Date			Who		Reason
19 August 2008	consw1	Initial creation

*/

vars
	criteria,
	templateCrit		: CM_YACriteria;
	
	criteriaType 		: CM_YACriteriaType;
	criteriaTypeColl	: ObjectSet;
	iterYA				: Iterator;
	yardAllocation		: CM_YardAllocation;

	tempOperDuplicates	: String;
begin
	//  Do not do validation for a yard allocation created prior to the implementation of YA templates.
	if self.myYATemplate = null and not self.isYATemplate then
		return;
	endif;

	//  For yard allocations and templates - ensure there is only one criteria object for any criteria type

	create criteriaTypeColl transient;
	
	foreach criteria in self.allCriteria do
		criteriaType := criteria.myYACriteriaType;
		if criteriaTypeColl.includes(criteriaType) then
			app.raiseCMException1(Err_YA_CriteriaWithSameType, criteriaType.description, null, null);
		else
			criteriaTypeColl.add(criteriaType);
		endif;
	endforeach;
	
	//  For yard allocations - ensure there is not another yard allocation with exactly the same criteria
	
	if not self.isYATemplate() then
		iterYA := self.myTerminal.allYardAllocations.createIterator;
		self.myTerminal.allYardAllocations.startKeyGeq( self.priorityValue, iterYA );
		while iterYA.next( yardAllocation ) do
			if yardAllocation.priorityValue &lt;&gt; self.priorityValue then
				break;
			endif;
			if yardAllocation &lt;&gt; self and not yardAllocation.isYATemplate then
				if yardAllocation.isSameCriteria(self) then
					app.raiseCMException1(Err_YA_WithSameCriteria, yardAllocation.code, null, null);
					break;
				endif;
			endif;
		endwhile;
	endif;
epilog
	delete criteriaTypeColl;
	delete iterYA;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="f141d378-429e-41ce-98c2-f5eb96186dee">
        <source>validateForCreate();
// --------------------------------------------------------------------------------
// Created:		27 April 2005 by cnwdad1
//
// Purpose:		Standard validation method for when the receiver is created.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 18/03/2021	navdap1		TFS 50946 PRP Auto Delete of Yard Allocations
// --------------------------------------------------------------------------------
vars
	ya : CM_YardAllocation;
begin
	//03/04/2009 cnwdz2 PAR 19217
	if self.myTerminal &lt;&gt; null then
		ya := self.myTerminal.allYardAllocatonsByCode[self.code];
		if ya &lt;&gt; null and ya.code = self.code then
			app.raiseCMException1(Err_YA_AlreadyExists, self.code, null, null);
		endif;
	endif;
	
	self.validateBGPForNoCargoExpiry();			// TFS 50946
end;</source>
    </JadeMethod>
