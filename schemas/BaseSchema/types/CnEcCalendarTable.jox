    <JadeMethod name="dblClick" id="a2037314-533a-4751-8ec2-a67819d350d0">
        <updating/>
        <source>dblClick(table: Table input) updating;


vars

begin
	inheritMethod(table);

	if calendar.myCalendarForm &lt;&gt; null then
		calendar.myCalendarForm.btnOk_click(calendar.myCalendarForm.btnOk);
	endif;
end;
</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="dragDrop" id="a2327c7a-383b-4990-8358-468f25df57b0">
        <updating/>
        <source>dragDrop(table: Table input; win: Window input; x: Real; y: Real) updating;

vars

begin
	inheritMethod(table, win, x, y);
	if dragRow &gt; 1 and dragColumn &gt; 0 then
		row := dragRow;
		column := dragColumn;
		if text &lt;&gt; "" then
			calendar.changeType := calendar.ChangeType_Day;
			calendar.date.setDate(text.Integer, calendar.date.month, calendar.date.year);
		endif;
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="mouseDown" id="1ee2aeb4-2cd4-4234-b2d6-dc92f478e54f">
        <updating/>
        <source>mouseDown(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;

vars

begin
	calendar.mouseDown(calendar, button, shift, table.left + x, table.top + y);
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="rowColumnChg" id="66dc07c0-efc3-4a03-866c-549ca6019690">
        <updating/>
        <source>rowColumnChg(table: Table input) updating;

vars
	date : Date;
begin
	inheritMethod(table);
	if row &gt; 1 and text &lt;&gt; "" then
		calendar.changeType := calendar.ChangeType_Day;
		calendar.date.setDate(text.Integer, calendar.date.month, calendar.date.year);
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="selectDay" id="939d662c-847d-48ea-8a94-ba75e5cc1219">
        <updating/>
        <source>selectDay(date : Date) updating;

vars
	r, c : Integer;
begin
	accessMode := 1;
	r := 2;
	while r &lt;= rows do
		row := r;
		c := 1;
		while c &lt;= columns do
			column := c;	
			if text = date.day.String then
				foreColor := calendar.backColor;
				backColor := calendar.foreColor;
			else
				foreColor := calendar.foreColor;
				backColor := calendar.getSystemColor(Window.Color_BtnFace);
			endif;
			c := c + 1;
		endwhile;
		r := r + 1;
	endwhile;
	row := 1;
	column := 1;
end;</source>
        <Parameter name="date" type="Date"/>
    </JadeMethod>
    <JadeMethod name="showDays" id="563550c6-cbf7-4498-8209-a25c845adefc">
        <updating/>
        <source>showDays(date : Date) updating;

vars
	r, c : Integer;
	day : Date;
begin
	r := 1;
	while r &lt;= rows do
		row := r; 
		c := 1;
		while c &lt;= columns do
			column := c; 
			text := ""; 
			c := c + 1;
		endwhile;
			r := r + 1;
	endwhile;
	row := 1;
	day.setDate(1, date.month, date.year);
	while day.day &lt;= CnEcCalendar.DaysOfWeek do
		column := day.dayOfWeek;
		text := day.dayName[1:calendar.dayNameLength];
		day := day + 1;
	endwhile;
	row := 2;
	day.setDate(1, date.month, date.year);
	while day.month = date.month do
		column := day.dayOfWeek;
		text := day.day.String;
		if column &gt;= columns then
			if row &gt;= rows then
				row := 2;
			else			
				row := row + 1;
			endif;
		endif;
		day := day + 1;
	endwhile;
end;</source>
        <Parameter name="date" type="Date"/>
    </JadeMethod>
