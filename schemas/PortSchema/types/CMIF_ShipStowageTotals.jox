    <JadeMethod name="addPcs" id="09068935-f414-4144-a3fe-5c33e26a36b9">
        <updating/>
        <source>addPcs(_pcs : Integer; _place : Integer) updating;

vars

begin

	self.placeTotalPcs := self.placeTotalPcs + _pcs;
	self.supplierTotalPcs := self.supplierTotalPcs + _pcs;
	self.lotTotalPcs := self.lotTotalPcs + _pcs;
	
	if _place = PlaceDeck then
		self.deckGrandTotalPcs := self.deckGrandTotalPcs + _pcs;
	elseif _place = PlaceHold then
		self.holdGrandTotalPcs := self.holdGrandTotalPcs + _pcs;
	endif;
	
	

end;</source>
        <Parameter name="_pcs" type="Integer"/>
        <Parameter name="_place" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addVolume" id="d5e2d2cc-cf0c-416e-b3fa-1a6c7b57dec1">
        <updating/>
        <source>addVolume(_volume : Decimal; _place : Integer) updating;

vars

begin

	self.placeTotalVolume := self.placeTotalVolume + _volume;
	self.supplierTotalVolume := self.supplierTotalVolume + _volume;
	self.lotTotalVolume := self.lotTotalVolume + _volume;
	
	if _place = PlaceDeck then
		self.deckGrandTotalVolume := self.deckGrandTotalVolume + _volume;
	elseif _place = PlaceHold then
		self.holdGrandTotalVolume := self.holdGrandTotalVolume + _volume;
	endif;
	
	
	

end;</source>
        <Parameter name="_volume" type="Decimal"/>
        <Parameter name="_place" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="clear" id="ceae6394-f81b-457e-b6fc-237e1b9ed425">
        <updating/>
        <source>clear(_type : Integer) updating;

vars

begin

	if _type = PlaceTotal then
		self.placeTotalPcs 		:= 0;
		self.placeTotalVolume	:= 0;
	elseif _type = SupplierTotal then
		self.supplierTotalPcs 		:= 0;
		self.supplierTotalVolume	:= 0;
	elseif _type = LotTotal then
		self.lotTotalPcs := 0;
		self.lotTotalVolume := 0;
	endif;
end;</source>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTotals" id="4c52e6b3-8493-43de-846e-cf0b8a15843f">
        <source>getTotals(_type : Integer; _pcs : Integer output; _volume : Decimal output);

vars

begin

	if _type = SupplierTotal then
		_pcs 		:= self.supplierTotalPcs;
		_volume		:= self.supplierTotalVolume;
	elseif _type = PlaceTotal  then
		_pcs		:= self.placeTotalPcs;
		_volume		:= self.placeTotalVolume;
	elseif _type = HoldGrandTotal then
		_pcs		:= self.holdGrandTotalPcs;
		_volume		:= self.holdGrandTotalVolume;
	elseif _type = DeckGrandTotal then
		_pcs		:= self.deckGrandTotalPcs;
		_volume		:= self.deckGrandTotalVolume;
	elseif _type = LotTotal then
		_pcs		:= self.lotTotalPcs;
		_volume		:= self.lotTotalVolume;
	endif;
	

end;</source>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_pcs" type="Integer" usage="output"/>
        <Parameter name="_volume" type="Decimal" usage="output"/>
    </JadeMethod>
</Class>
