//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if _other.isUnavailable &lt;&gt; self.isUnavailable or
	   _other.laneDirection &lt;&gt; self.laneDirection then
	   return true;
	endif;
	  
	return false;  
epilog

end;</source>
