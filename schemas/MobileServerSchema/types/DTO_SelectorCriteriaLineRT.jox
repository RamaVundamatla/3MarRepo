    </JadeMethod>
    <JadeMethod name="setForCreate" id="c80e751f-4fe7-4a3f-ad2c-fe652bd4e8f3">
        <updating/>
        <source>setForCreate( 	_labelCriteria, 
				_searchValueA, _searchValueB : String; _searchValueBoolean : Boolean;
				_myQueryCriteriaLineHolderRT : DTO_QueryCriteriaLineHolderRT;
				_propClassName, _propName, _queryOperatorOid : String ) updating;
// ----------------------------------------------------------------------------------
// Created 07 may 2008 by cnwvu1
// ----------------------------------------------------------------------------------

vars

begin

	self.labelCriteria				:= _labelCriteria;
	
	self.myQueryCriteriaLineHolder	:= _myQueryCriteriaLineHolderRT;
	self.propClassName				:= _propClassName;
	self.propName					:= _propName;
	self.queryOperatorOid			:= _queryOperatorOid;
	
end;
</source>
        <Parameter name="_labelCriteria" type="String"/>
        <Parameter name="_searchValueA" type="String"/>
        <Parameter name="_searchValueB" type="String"/>
        <Parameter name="_searchValueBoolean" type="Boolean"/>
        <Parameter name="_myQueryCriteriaLineHolderRT" type="DTO_QueryCriteriaLineHolderRT"/>
        <Parameter name="_propClassName" type="String"/>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_queryOperatorOid" type="String"/>
    </JadeMethod>
    <JadeMethod name="setForCreateForRT" id="e74caf1d-947c-4a36-adb0-f998aa6655c9">
        <updating/>
        <source>setForCreateForRT( _dtoCriteriaHolder : DTO_QueryCriteriaLineHolderRT; _criteriaLine : CM_SelectorCriteriaLine;
					_searchValueA, _searchValueB : String; _searchValueBoolean : Boolean ) updating;
// -------------------------------------------
// Created 07 may 2008 by cnwvu1
// -------------------------------------------

vars
	labelCriteria	: String;
	
begin

	labelCriteria := _criteriaLine.myQueryProperty.niceName &amp;' '&amp; _criteriaLine.myQueryOperator.description;
	
	self.setForCreate(	labelCriteria, _searchValueA, _searchValueB, _searchValueBoolean,
						_dtoCriteriaHolder,
						_criteriaLine.propClassName, _criteriaLine.propName, _criteriaLine.myQueryOperator.getOidAsString() );

end;
</source>
        <Parameter name="_dtoCriteriaHolder" type="DTO_QueryCriteriaLineHolderRT"/>
        <Parameter name="_criteriaLine" type="CM_SelectorCriteriaLine"/>
        <Parameter name="_searchValueA" type="String"/>
        <Parameter name="_searchValueB" type="String"/>
        <Parameter name="_searchValueBoolean" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreateFromRT" id="e833107f-2bfd-4e3c-b6a5-394dfcec3f9f">
        <updating/>
        <source>setForCreateFromRT( _dtoCriteriaLineHolder : DTO_QueryCriteriaLineHolderRT;
					_queryOperatorOid, _propClassName, _propName,
					_searchValueA, _searchValueB : String; _searchValueBoolean : Boolean ) updating;
// ----------------------------------------------------------------------------------------------------
// Created 07 may 2008 by cnwvu1
// ----------------------------------------------------------------------------------------------------

vars

begin

	self.queryOperatorOid	:= _queryOperatorOid;
	self.propClassName		:= _propClassName;
	self.propName			:= _propName;
	
	self.myQueryCriteriaLineHolder	:= _dtoCriteriaLineHolder;

end;
</source>
        <Parameter name="_dtoCriteriaLineHolder" type="DTO_QueryCriteriaLineHolderRT"/>
        <Parameter name="_queryOperatorOid" type="String"/>
        <Parameter name="_propClassName" type="String"/>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_searchValueA" type="String"/>
        <Parameter name="_searchValueB" type="String"/>
        <Parameter name="_searchValueBoolean" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForQueryRun" id="ab4d6a50-f03d-484a-b587-f4773089fa8c">
        <source>validateForQueryRun( _criteriaLine : CM_SelectorCriteriaLine );
// ------------------------------------------------------------
// Created 08 may 2008 by cnwvu1
// ------------------------------------------------------------

vars

begin

	if self.propName &lt;&gt; _criteriaLine.propName
	or self.propClassName &lt;&gt; _criteriaLine.propClassName
	or self.queryOperatorOid &lt;&gt; _criteriaLine.myQueryOperator.getOidAsString() then
		app.raiseCMException( ERR_QueryForRTChanged, null, null );
	endif;

end;
</source>
        <Parameter name="_criteriaLine" type="CM_SelectorCriteriaLine"/>
    </JadeMethod>
</Class>
