    <JadeMethod name="getTrxQVWvalues" id="51a42a1f-bb6f-4717-9085-4f8656d832db">
        <source>getTrxQVWvalues(_totQ: Integer output; _totV: Decimal output; _totW: Decimal output);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 November 2014	cnwndl1	Initial creation

*/

vars

begin
	
	_totQ := self.oldQuantity - self.quantity;
	_totV := self.oldVolume - self.volume;
	_totW := self.oldWeight - self.weight;

epilog

end;</source>
        <Parameter name="_totQ" type="Integer" usage="output"/>
        <Parameter name="_totV" type="Decimal" usage="output"/>
        <Parameter name="_totW" type="Decimal" usage="output"/>
    </JadeMethod>
    <JadeMethod name="setFromTransaction" id="d19b0621-8652-490b-b62f-0c2be5b3842f">
        <updating/>
        <source>setFromTransaction(_txn: CM_TITransaction) updating;
// -------------------------------------------
// Created 03 April 2006 by cnwdvb1
// -------------------------------------------
vars

begin
	inheritMethod(_txn);

	if CM_Split.hasInstance(_txn) then
		self.action := _txn.CM_Split.action;
	elseif CM_Merge.hasInstance(_txn) then
		self.action := _txn.CM_Merge.action;
	else
		//no action
	endif;
	


end;</source>
        <Parameter name="_txn" type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="setTransactionDetails" id="685e903e-b6a5-4caa-894f-79066a877638">
        <updating/>
        <source>setTransactionDetails(pTrx: CM_TITransaction input) updating, protected;
// -------------------------------------------
// Created 03 April 2006 by cnwdvb1
// -------------------------------------------
vars

begin
	inheritMethod(pTrx);
	
	if CM_Split.hasInstance(pTrx) then
		pTrx.CM_Split.setAction(self.action);
	elseif CM_Merge.hasInstance(pTrx) then
		pTrx.CM_Merge.setAction(self.action);
	else
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="pTrx" type="CM_TITransaction" usage="input"/>
    </JadeMethod>
</Class>
