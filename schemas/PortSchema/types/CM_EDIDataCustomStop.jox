    <JadeMethod name="getStatusFromEDITrackedItems" id="0d59a1af-9703-4617-a45c-3f45211e0d6d">
        <source>getStatusFromEDITrackedItems(_verifyOnly : Boolean) : Integer;
/*
Date		Who		Reason
16 Aug 2012	cnwcs5	Initial creation - par 30136
08/08/2013	cnwcs5	CCMS POL 2221 / par 32094(2)
// 07 Nov 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
// 25 May 2018	jlgrh7 TFS #38667 PNL - Customs File - Unprocessed 0 items
// 14 Jun 2018	jlgrs1	TFS 38667 JMT get load with errors working
*/
vars
	ediTI			: CM_EDITrackedItem;
	status, total, 
	todo			: Integer;
begin
	if not self.canGetStatusFromEDITrackedItem then
		app.raiseUnexpectedProgramError (self.class.name, method.name, "Method called for invalid EDI data type");
		return null;
	endif;
	
	todo 	:= self.allUnprocCustByIDMsgNum.size;	// number not yet processed
	total	:= self.allEDITrackedItems.size;
	
	if total = 0 then
		// nothing to do
		status := CM_EDIFile.EDI_STATUS_UNPROCESSED;
		
	elseif todo = 0 then
		// nothing left to do
//		if _verifyOnly then
//			status := CM_EDIFile.EDI_STATUS_VERIFIED;
//		else
			status := CM_EDIFile.EDI_STATUS_DBLOADED;
//		endif;
	elseif todo &lt;&gt; total then
		// some have processed
		status := CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL;
		
	else
		// nothing has been processed - we may have errors/warnings?
		status := CM_EDIFile.EDI_STATUS_VERIFIED;
	
		foreach ediTI in self.allEDITrackedItems discreteLock do
			if ediTI.status = CM_EDITrackedItem.EDI_STATUS_DBLOADED then
				continue;
			endif;
			
			if ediTI.status = CM_EDITrackedItem.EDI_STATUS_DBLOADED_ERRORS then
				// we can stop now - it wont get worse than this
				status := CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL;
				break;
			elseif ediTI.status = CM_EDITrackedItem.EDI_STATUS_VERIFIED_ERRORS then
				// we can stop now - it wont get worse than this
				status := CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS;
				break;
			
			elseif ediTI.status = CM_EDITrackedItem.EDI_STATUS_LOCKERROR then								//+TFS38667 Locked Error
				 status := CM_EDIFile.EDI_STATUS_LOCKERROR;
				 
			elseif ediTI.status = CM_EDITrackedItem.EDI_STATUS_VERIFIED_WARNINGS then
				// keep looking in case there are errors
				status := CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS;
			endif;
		endforeach;
	endif;

	return status;
epilog

end;</source>
        <Parameter name="_verifyOnly" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTIProperties" id="d27f31f4-67ef-4c0e-b722-deda434e1c39">
        <source>getTIProperties(_propArray: ObjectArray io);

vars
	popColl: PropertyNDict;
	property: Property;
begin
	inheritMethod(_propArray);
	popColl := CM_EDICustomStopTI.getProperties;
	foreach property in popColl do
		_propArray.add(property);
	endforeach;

end;</source>
        <Parameter name="_propArray" type="ObjectArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getValidTisForLoad" id="81ddd08c-1b0d-42ca-bbb0-05bc89046489">
        <source>getValidTisForLoad(_ediCustomStopTi: CM_EDICustomStopTI input; _tiArray : CM_TIArray input; _someIgnored : Boolean io; _bol : CM_BOL output; _passport: CM_Passport input);
//----------------------------------------------------------------
//	Created:	09 June 2004	by Jason Chapman  (cnwjc2)
//
//	Set any related superceded messages or cancelled messages to Status_DBLoaded
//----------------------------------------------------------------
// 26 Jul 2013	cnwcs5	CCMS POL 2221 / par 32094 - 
// 11 Jul 2018	jlgsl4	TFS 39133 - Trade Single Window
// 29 Apr 2024	navpw1	TFS: 63819 (63846) - Added logging for issue whereby house bol is being processed.

vars
	cancel : CM_EDICustomStopTI;
	trackedItem : CM_TrackedItem;
begin
	
	if _ediCustomStopTi.responseStatus = Customs_Deliver_BreakBulk and // TFS 39133 - Customs_Deliver_BreakBulk code
	   _ediCustomStopTi.cargoType &lt;&gt; TI_CargoType_Car and //then // TFS 39133 - 819 is used as clearance code by TSW
	   not _ediCustomStopTi.isValidTSWMessage() then // TFS 39133 - so pass through 819 for TSW...
	   // cnwrs1 Apr 2007 par 13896 flag these as invalid to get then out of the process system
		app.myTrxUA.trxUpdateEDITIStatus(_ediCustomStopTi, CM_EDITrackedItem.EDI_STATUS_INVALID, app.myPassport);
		return;
	endif;
	
	_ediCustomStopTi.getMatchingTI(_passport.myTerminal, _tiArray);
	
	
	if _tiArray.size = 0 then
		app.writeLog("Could not find a ti matching id: '" &amp; _ediCustomStopTi.id &amp; "' looking for a bol that matches the bol number: '" &amp; _ediCustomStopTi.billOfLading &amp; "' instead", LogDEBUG);	// ### TFS 63819 (63846) 29Apr2024 NAVPW1
		_bol := _ediCustomStopTi.getMatchingBOLins(_tiArray, _someIgnored);
	endif;
	
	if _tiArray.size = 0 then
		app.writeLog("Could not find any tis", LogDEBUG);	// ### TFS 63819 (63846) 29Apr2024 NAVPW1
		return;
	endif;

	if not _ediCustomStopTi.isCancel() then
		foreach trackedItem in _tiArray do
			if self.isLockedByMe(trackedItem) then
				self.unlock(trackedItem);
			endif;
		endforeach;
		return;
	endif;	
	
	cancel := _ediCustomStopTi;

	
	foreach trackedItem in _tiArray do
		if cancel.entryNumber.pos(trackedItem.getCustExpEntryNoMinusSlash,1) = 0 then
			//we are processing these in order of generation - the cancel should not be processed if the numbers don't match
			// No match here so don't load it - set it to "DBLoaded"
			app.myTrxUA.trxUpdateEDITIStatus(cancel, CM_EDITrackedItem.EDI_STATUS_DBLOADED, app.myPassport);
			
			if self.isLockedByMe(trackedItem) then
				self.unlock(trackedItem);
			endif;
		endif;
	endforeach;	
end;</source>
        <Parameter name="_ediCustomStopTi" type="CM_EDICustomStopTI" usage="input"/>
        <Parameter name="_tiArray" type="CM_TIArray" usage="input"/>
        <Parameter name="_someIgnored" type="Boolean" usage="io"/>
        <Parameter name="_bol" type="CM_BOL" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="loadDB" id="f90e1996-4dfa-4eb8-8503-624750eeae65">
        <updating/>
        <source>loadDB(_mergeCargo : Boolean; _passport : CM_Passport input) updating;
//
// if changing this method then CM_EDIControllerAgent::actionForAutoTICustoms may also need changing
//
// Rewritten 13/04/2010 cnwdad1 PAR 22153. This is no longer a single data file,
//		and it now also supports partial DB load status.
/* Changes

Date		Name	TFS#		Description
============================================================================
07 Jul 2011	cnwrs1	par 27820 	save off errors from trx so they are displayed in EDI errors
08 Oct 2015	cnwrs1	Par 36863 	make EDI consistant times when refreshing progress bar
13 May 2016	cnwns1	TFS 488  	Multi Timezone Support
25 May 2018 jlgrh7  TFS #38667 	PNL - Customs File - Unprocessed 0 items
14 Jun 2018	jlgrs1	TFS 38667 	JMT get load with errors working
29 Mar 2019 jlgsl4	TFS 44123  	TSW - translate BOL voyage details correctly
30 Apr 2019	jlgrs1	TFS40086 	JMT Not all EDI TrackedItem stringArray are exposed to the EDI JMT Internal
03 Sep 2019 jlgka1 	TFS 45332 	STWR - Better Forms and Interfaces for EDI Module
20 Oct 2020	jlgmd1	TFS 50204	Refactor progress updates to superclass method
05 Jan 2024	navpw1	TFS 61906 (61907) - Fixed warningsIgnored flag being reset at the end of a trx. While we are looping through the tis to process
07 Oct 2024	navpw1	JIRA: MTN-23303 (MTN-23923) - Added exclusive locks upfront to avoid a deadlock scenario happening down in utlUpdateEDICustomStop.
============================================================================*/

vars
	ediTI				: CM_EDITrackedItem;
	proxyTI				: CM_TrackedItem;
	trackedItem			: CM_TrackedItem;
	ediCustomStopTi		: CM_EDICustomStopTI;
	partsTodo			: Integer;
	partsDone			: Integer;
	passport			: CM_Passport;
	tiArray				: CM_TIArray;
	someIgnored 		: Boolean;
	allIgnored          :Boolean;
	bolObj 				: CM_BOL;
	isFullyProcessed	: Boolean;		// cnwdad1 13/04/2010 - PAR #22153.
	isFreeOfErrors		: Boolean;		// cnwdad1 13/04/2010 - PAR #22153.
	errorSet 			: CM_ErrorSet;	//par 27820 cnwrs1 07 July 2011
	progressTS 			: TimeStamp;
	proxyBOL 			: CM_BOL;
	tmpStatus 			: Integer;
begin
	on Exception do validationExceptionHandler(exception, _passport);
	
	progressTS := app.actualTimeServer();// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	passport			:=	_passport;
	partsTodo			:=	self.allEDITrackedItems.size();
	isFullyProcessed	:=	true;
	isFreeOfErrors		:=	true;
	
	app.setContinueCMExceptions(true);
	
	create errorSet transient;
	create tiArray transient;
	
	self.updateProgress(progressTS, "Processing Customs Response", partsTodo, partsDone, true, passport);
		
	foreach ediTI in self.allEDITrackedItems do
		if not ediTI.isKindOf(CM_EDICustomStopTI) then
			continue;
		endif;
		partsDone	:=	partsDone + 1;
		
		self.updateProgress(progressTS, "Processing Customs Response", partsTodo, partsDone, false, passport);
		
		//status can be updated in trx below so need to keep checking this
		if ediTI.status = CM_EDIFile.EDI_STATUS_UNPROCESSED
		or ediTI.status = CM_EDITrackedItem.EDI_STATUS_DBLOADED_ERRORS	//03 Sep 2020	NDL	TFS 49988
		then
			//all good we want to try to process these ones.
		else
			continue;
		endif;

		ediCustomStopTi	:= ediTI.CM_EDICustomStopTI;
		
		app.writeLog("Processing [" &amp; ediCustomStopTi.String &amp; "] customs info for " &amp; ediCustomStopTi.id &amp; ".", LogINFO);
		
		//process cancellations
		tiArray.clear();
		
		app.writeLog("Getting tis for load", LogDEBUG); // ### TFS 63819 (63846) 02May2024 NAVPW1
		
		self.getValidTisForLoad(ediCustomStopTi, tiArray, someIgnored, bolObj, passport);
		
	
		if (( someIgnored or tiArray.isEmpty() ) and bolObj = null) or (bolObj &lt;&gt; null and tiArray.isEmpty() and ediCustomStopTi.isValidTSWMessage()) then // TFS 44123
			isFullyProcessed :=	false;		
			app.writeLog("Setting isFullyProcessed to false. SomeIgnored: '" &amp; someIgnored.String &amp; "' | tiArray Empty: '" &amp; tiArray.isEmpty().String &amp; "' | bolObj is null: '" &amp; (bolObj = null).String &amp; "' | Is Valid TSW Message: '" &amp; ediCustomStopTi.isValidTSWMessage().String &amp; "'", LogDEBUG); // ### TFS 63819 (63846) 02May2024 NAVPW1
		endif;
		
		//27 Mar 2017	NDL	TFS 3857
		if bolObj &lt;&gt; null and ediCustomStopTi.responseStatus = EDIFileType_XMLOneStopCust.String then
			app.writeLog("Loading one stop customs BOL", LogDEBUG); // ### TFS 63819 (63846) 02May2024 NAVPW1
			proxyBOL	:=	app.createUpdateProxy(bolObj).CM_BOL;
			
			app.myTrxUA.trxUpdateEDICustomBolStop(proxyBOL, self, ediCustomStopTi, passport);
			
			if passport.hasErrors() then
				isFreeOfErrors	:=	false;
				
				app.writeLog('Database Load failed for '&amp;proxyBOL.number&amp;' one or more items.', LogINFO);
				app.remoteErrorWarningToAlert('Database load failure - Customs EDI item(s) failed for '&amp;proxyBOL.number&amp;'.', null, passport.allErrors, null, false, true);
				app.myPassport.moveErrorsToSet(errorSet); 
				app.myPassport.clearErrorsWarnings();
			endif;
			
			delete proxyBOL;
			
			if self.isLockedByMe(bolObj) then
				self.unlock(bolObj);
			endif;
		endif;
		
		app.writeLog("Ti's found: " &amp; tiArray.size.String, LogDEBUG); // ### TFS 63819 (63846) 02May2024 NAVPW1
		
		foreach trackedItem in tiArray do
			app.writeLog("Processing Custom Stop for Ti Id: " &amp; trackedItem.id, LogDEBUG); // ### TFS 63819 (63846) 02May2024 NAVPW1
			// ### JIRA: MTN-23303 (MTN-23923) 07Oct2024 NAVPW1
			self.exclusiveLock(trackedItem);
			self.exclusiveLock(trackedItem.allTransactions);
			// ### JIRA: MTN-23303 (MTN-23923) 07Oct2024 NAVPW1
			passport.setIsBackgroundWarningsIgnored(true);	// ### TFS 61906 (61907) 04Jan2024 NAVPW1
			proxyTI	:=	app.createUpdateProxy(trackedItem).CM_TrackedItem;
					
			app.myTrxUA.trxUpdateEDICustomStop(proxyTI, self, ediCustomStopTi, passport);
			
			if passport.hasErrors() then //par 21299 cnwrs1 oct 2009
				isFreeOfErrors	:=	false;
				
				app.writeLog('Database Load failed for '&amp;proxyTI.id&amp;' one or more items.', LogINFO);
				app.remoteErrorWarningToAlert('Database load failure - Customs EDI item(s) failed for '&amp;proxyTI.id&amp;'.', null, passport.allErrors, null, false, true);
				app.myPassport.moveErrorsToSet(errorSet); //save off all current errors par 27820 cnwrs1 07 July 2011
				app.myPassport.clearErrorsWarnings();
			endif;
			
			delete proxyTI;
			
			if self.isLockedByMe(trackedItem) then
				self.unlock(trackedItem);
			endif;
		endforeach;
		if not isFreeOfErrors and
		   ediCustomStopTi.status = CM_EDITrackedItem.EDI_STATUS_UNPROCESSED then	//03 Sep 2020	NDL	TFS 49988
			app.myTrxUA.trxUpdateEDITIStatus(ediCustomStopTi, CM_EDITrackedItem.EDI_STATUS_DBLOADED_ERRORS, _passport);
		endif;
	endforeach;
	
	self.updateProgress(progressTS, "Processing Customs Response", partsTodo, partsDone, true, passport);
	
	app.myPassport.addErrorsFromSet(errorSet);	//restore current errors back par 27820 cnwrs1 07 July 2011
	
	if isFreeOfErrors then
		if isFullyProcessed then
			app.myTrxUA.trxSetEDIDataStatus(self, CM_EDIFile.EDI_STATUS_DBLOADED);
			app.writeLog("Was DB Loaded", LogDEBUG); // ### TFS 63819 (63846) 02May2024 NAVPW1
		else 
			app.myTrxUA.trxSetEDIDataStatus(self, CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
			app.writeLog("Was DB Partially Loaded", LogDEBUG); // ### TFS 63819 (63846) 02May2024 NAVPW1
		endif;
	else
		// If status is not set to partial load, this message will not get re-processed.
		//app.myTrxUA.trxSetEDIDataStatus(self, CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);								//-FTS38667
		tmpStatus := self.getStatusFromEDITrackedItems(false);																									//+TFS38667
		if tmpStatus &lt;&gt; 0 then
			app.myTrxUA.trxSetEDIDataStatusAfterVerify(self, tmpStatus);	
		endif; 
	
	endif;
epilog
	if trackedItem &lt;&gt; null then
		if self.isLockedByMe(trackedItem) then
			self.unlock(trackedItem);
		endif;
	endif;
	delete errorSet;	//par 27820 cnwrs1 07 July 2011
	delete proxyTI;
	delete tiArray;
	delete proxyBOL;
end;</source>
        <Parameter name="_mergeCargo" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="processTIs" id="028cfa06-39d6-47e5-afcc-918b5030ce01">
        <updating/>
        <source>processTIs(_trackedItem : CM_TrackedItem; _type : Integer) updating;
// This method taks TI's from CMS and converts data to EDI TIs
// used to extract data from CMS
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
// 07 Apr2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	ediTrackedItem: CM_EDICustomStopTI;
	commodity: CM_Commodity;
begin
	if _trackedItem &lt;&gt; null then
		if _trackedItem.cargoType = TI_CargoType_Container then
			create ediTrackedItem persistent;
			ediTrackedItem.setForCreateNew(self);
			ediTrackedItem.setCargoType(_trackedItem.cargoType);
		else
			abortTransaction;
			return;
		endif;
		
		ediTrackedItem.setId(_trackedItem.id);
		
		if _trackedItem.isEmpty then
			ediTrackedItem.fullOrMT := "E";
		else
			ediTrackedItem.fullOrMT := "F";
		endif;
		
		// make sure the manual collection on CM_EDIConfig gets maintained
		ediTrackedItem.setVoyageCode( _trackedItem.voyageCode );

		if _trackedItem.myVoyage &lt;&gt; null then
			ediTrackedItem.setVoyage(_trackedItem.myVoyage); //par 12685 cnwrs1 oct 2006
		endif;
	endif;
end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
