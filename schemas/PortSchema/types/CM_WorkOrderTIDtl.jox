    <JadeMethod name="getTotalComplete" id="bc7b79d6-ac5e-4fb4-a8af-c08ab93f7201">
        <source>getTotalComplete(): Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 Jul 2009	cnwmd1	Initial creation
08 Feb 2023 navma1  ChangeRequest 56457: EUP - Allowing different sets of cargo items per work order task [Refactor]
28 May 2024 navma1	Bug 64224: MTN - DeadLocks Caused by Future Actors
*/

vars
	qty  : Integer;
	ti	 : CM_TrackedItem;
	wt   : Decimal[14,4];
begin

	if self.getMyTerminal.isUseYardJobsForCargoWo then
		foreach  ti in self.allCompleteTIs  discreteLock do 	//28.05.2024 navma1 #64224
			qty := qty + ti.totalQuantity;
		endforeach;
		return qty;
	else
		
		return self.allCompleteTIs.size;
	endif;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTotalCompleted" id="c2182897-c858-406e-9692-8542c89cdd05">
        <source>getTotalCompleted(_qty : Boolean):Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Oct 2023	navma1	Initial creation
20 Mar 2024 navma1	Bug 62928: EUP - Demo - Pack Load By Request Froze During Cargo Display for User Selection
28 May 2024 navma1	Bug 64224: MTN - DeadLocks Caused by Future Actors
*/

vars
	qty 	 : Integer;
	ti		 : CM_TrackedItem;
	wt   	 : Decimal[14,4];
	invalid  : Boolean;
	edition  : Integer;
begin
	
	on Exception do app.handleDeletedObject( exception, ti, invalid );
	
	foreach  ti in self.allCompleteTIs discreteLock  do 	//28.05.2024 navma1 #64224
		
		invalid := false;
		edition := ti.edition;
		
		if invalid then
			continue;
		endif;
		
		if _qty then
			qty := qty + ti.totalQuantity;
			
		else
			wt := wt + ti.totalWeight;
		endif;
		
	endforeach;
	
	if _qty then	
		return qty;
	else
		return wt;
	endif;
	
epilog

end;</source>
        <Parameter name="_qty" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
