    <JadeMethod name="parseRowColString" id="0ffea0b4-90c1-46c8-89ec-466a87e62fd9">
        <source>parseRowColString( _rowColText : String; _colFrom, _colTo, _rowFrom, _rowTo : String output );
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27/01/2009	cnwjk3	SFW1030
15/11/2011	cnwdap1	PAR #28514 Need to cope with RR-RR CC-CC or CC-CC RR-RR (in the case of GBS)
*/
vars
	textLength,
	pos			: Integer;
begin
	/*
		Need to cope with the following string patterns:
		RR-RR CC-CC
		RR-RR CC
		RR CC-CC
		RR CC	
		RR
	    This method will expand to RR-RR CC-CC, or just RR-RR
		
		PAR #28514 we now also need to cater for the same patterns with CC first,
		expanded to CC-CC RR-RR, or just CC-CC
	*/
	
	if _rowColText = null then
		return;
	endif;

	pos := 1;
	textLength := _rowColText.length();

	// PAR #28514 if location ids are column first then row, _rowColtext has columns first then rows
	if self.areLocationIdsColThenRow() then
		// columns first 
		_colFrom := _rowColText.scanUntil(" -",pos);
	
		if pos &lt;&gt; 0 and pos &lt; textLength and _rowColText[pos] = '-' then
			// Assume CC-CC
			pos := pos + 1;
			_colTo := _rowColText.scanUntil(" ",pos);	
		else
			// Assume CC
			_colTo := _colFrom;
		endif;
	
		if pos = 0 or pos &gt;= textLength then
			return;
		endif;
		
		// then rows
		pos := pos + 1;
		_rowFrom := _rowColText.scanUntil(" -",pos);
	
		if pos &lt;&gt; 0 and pos &lt; textLength and _rowColText[pos] = '-' then
			// Assume RR-RR
			pos := pos + 1;
			_rowTo := _rowColText.scanUntil(" ",pos);	
		else
			// Assume RR
			_rowTo := _rowFrom;
		endif;
	// PAR #28514 end
	else
		// The rows 
		_rowFrom := _rowColText.scanUntil(" -",pos);
	
		if pos &lt;&gt; 0 and pos &lt; textLength and _rowColText[pos] = '-' then
			// Assume RR-RR
			pos := pos + 1;
			_rowTo := _rowColText.scanUntil(" ",pos);	
		//elseif pos &lt;&gt; 0 then
		else
			// Assume RR
			_rowTo := _rowFrom;
		endif;
	
		if pos = 0 or pos &gt;= textLength then
			return;
		endif;
		
		// The columns
		pos := pos + 1;
		_colFrom := _rowColText.scanUntil(" -",pos);
	
		if pos &lt;&gt; 0 and pos &lt; textLength and _rowColText[pos] = '-' then
			// Assume CC-CC
			pos := pos + 1;
			_colTo := _rowColText.scanUntil(" ",pos);	
		else
			// Assume CC
			_colTo := _colFrom;
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="_rowColText" type="String"/>
        <Parameter name="_colFrom" type="String" usage="output"/>
        <Parameter name="_colTo" type="String" usage="output"/>
        <Parameter name="_rowFrom" type="String" usage="output"/>
        <Parameter name="_rowTo" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="8e3d6dd1-095a-4fb7-8458-c29ff7407b06">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     28 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// ---------------------------------------------------------------------------
vars
	pxyGridArea	: CM_GridArea;
	realGridCol,
	pxyGridCol	: CM_GridColumn;
	realGridRow,
	pxyGridRow	: CM_GridRow;
	realGridCntrl,
	pxyGridCntrl	: CM_GridController;
	completedOK		: Boolean;
	
begin

	pxyGridArea := inheritMethod();

	foreach realGridCol in self.allGridColumns do
		pxyGridCol := realGridCol.pxyCreateUpdateProxy();
		pxyGridCol.setGridAreaForProxy(pxyGridArea);
	endforeach;

	foreach realGridRow in self.allGridRows do
		pxyGridRow := realGridRow.pxyCreateUpdateProxy();
		pxyGridRow.setGridAreaForProxy(pxyGridArea);
	endforeach;
	
	foreach realGridCntrl in self.allGridControllersByRowColumn do
		pxyGridCntrl := realGridCntrl.pxyCreateUpdateProxy();
		pxyGridCntrl.setGridAreaForProxy(pxyGridArea, realGridCntrl.row, realGridCntrl.column, null, realGridCntrl.width);//realGridCntrl.ident
	endforeach;
	
	pxyGridArea.defaultDeckingStartType := self.defaultDeckingStartType;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyGridArea;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyGridArea;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="set20Controller" id="e85fdbd1-0663-4a2b-a159-9b5136ee5d3c">
        <source>set20Controller(_row, _col, _offset : Integer; _cntrl20Dict : CM_RTGControllerBySeqRowCol) protected;
/*
----------   ----------  --------------------------------------------------
Created:	May 2008 Andrew Bishop

Purpose:	 // PAR 18682

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	gridLC			: CM_GridController;
	
begin
	gridLC := self.allGridControllersByRowColumn[_row, _col];
	
	if gridLC = null 
	or (not _cntrl20Dict.includes(gridLC))then
		return;
	endif;
	
	gridLC.setIs20ft(true);
	
end;


</source>
        <access>protected</access>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_col" type="Integer"/>
        <Parameter name="_offset" type="Integer"/>
        <Parameter name="_cntrl20Dict" type="CM_RTGControllerBySeqRowCol"/>
    </JadeMethod>
    <JadeMethod name="set20ftControllers" id="8a3ef6ed-dd37-4d4e-b0ec-0fd7d660ef53">
        <source>set20ftControllers(_gridLCDict : CM_RTGControllerBySeqRowCol input);
/*
----------   ----------  --------------------------------------------------
Created:	May 2008 Andrew Bishop

Purpose:	Sets the is40ft and 40ftOffest properties of the controllers passed in 
			and potential ANY RELATED CONTROLLERS that aren't passed in on the same
			row (they must be in lots of 3 - see offsets)

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
 // PAR 16415 CCMS 1029
*/
vars
	
	gridLC			: CM_GridController;
	row,
	column				: Integer;
		gridRow : CM_GridRow;
begin
	//reset attributes incase they were previously 40ft, but a different offset!
//PAR 18682	foreach gridLC in _gridLCDict do
	foreach gridRow in self.allGridRows  discreteLock do // PAR 18682
		foreach gridLC in gridRow.allControllersByColumn do // PAR 18682
			gridLC.setIs20ft(false);
		endforeach;
	endforeach;
	
	
	foreach gridLC in _gridLCDict do
		if  gridLC.is20ft then
			continue;//already been set in finding anothers matching 8 below
		endif;
		
		row := gridLC.myGridRow.row;
		column := gridLC.myGridColumn.column;
		
		self.set20Controller(row, column, CM_LocationsController.Offset40_1, _gridLCDict);
	endforeach;


	
end;


</source>
        <Parameter name="_gridLCDict" type="CM_RTGControllerBySeqRowCol" usage="input"/>
    </JadeMethod>
    <JadeMethod name="set30Controller" id="2893b271-aa7f-4816-9083-136a0074df03">
        <source>set30Controller(_row, _col, _offset : Integer; _cntrl30Dict : CM_RTGControllerBySeqRowCol) protected;
/*
----------   ----------  --------------------------------------------------
Created:	May 2008 Andrew Bishop

Purpose:	 // PAR 16415 CCMS 1029

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	gridLC			: CM_GridController;
	
begin
	gridLC := self.allGridControllersByRowColumn[_row, _col];
	
	if gridLC = null 
	or (not _cntrl30Dict.includes(gridLC))then
		return;
	endif;
	
	gridLC.setIs30ft(true);
	gridLC.setOffset30ft(_offset);
	
end;


</source>
        <access>protected</access>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_col" type="Integer"/>
        <Parameter name="_offset" type="Integer"/>
        <Parameter name="_cntrl30Dict" type="CM_RTGControllerBySeqRowCol"/>
