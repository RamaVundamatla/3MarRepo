<Class name="CMIF_CargoManifest" id="4b3eaac2-f00b-4e95-ac5a-35dcbd2eaec6">
    <superclass name="CMIF_Object"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="voyages"/>
    <PrimAttribute name="code" id="38c50d94-95f6-4a5a-b160-2804f6369e6a">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="mode" id="0d27b6a1-7ee7-43bd-845d-1dbce7d8cdfe">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <ImplicitInverseRef name="myCargoType" id="60dcd13e-966d-4167-bd16-5ba6802560db">
        <embedded/>
        <type name="CM_CargoType"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myCommodity" id="f5fb33e1-c117-40c8-9920-8cf498f41a18">
        <embedded/>
        <type name="CM_Commodity"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <PrimAttribute name="totalWeight" id="81b7e990-9028-46fa-88f5-fb6e333ca874">
        <precision>23</precision>
        <scaleFactor>6</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getDefaultMeasureTotalWeight" id="dae2a77e-75ec-4316-9577-dc7316ef1824">
        <source>getDefaultMeasureTotalWeight() : String;
/*

Purpose:			Gets the total weight converted to the default measurement type

Parameters:			NONE

Return Value:		String representing the converted weight

Date		Who		Reason
13 April 2022	navpw1	Initial creation TFS: 53132

*/

vars
	measureType : CM_MeasurementType;

begin
	measureType := app.getDefaultMeasurementForType(Type_Weight);
	if measureType = null then
		return self.totalWeight.asStringWeightJMT;
	endif;
	return app.convertMeasurementForDisplay(measureType.shortName, self.totalWeight);

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setProxyForCreate" id="9f38e0eb-b0ca-4b04-ba21-ff5261e58d8c">
        <updating/>
        <source>setProxyForCreate(_code : String; _cargoType : CM_CargoType; _commodity : CM_Commodity; _totalWeight : Decimal; _mode : String) updating;
/*

Purpose:			Sets properties within our proxy object. This class is a transient class used for summarising Tracked Item data

Parameters:			_code			String			
					_cargoType		CM_CargoType	The cargo type we are using
					_commodity		CM_Commodity	
					_totalWeight	Decimal			The total weight for the Tracked Item
					_mode			String			Cargo Forecast/Manifest Mode CM_CargoForecast.Mode_Discharge/CM_CargoForecast.Mode_Load

Return Value:		NONE

Date		Who		Reason
13 April 2022	navpw1	Initial creation TFS: 53132

*/

begin
	self.code			:= _code;
	self.myCargoType	:= _cargoType;
	self.myCommodity	:= _commodity;
	self.totalWeight	:= _totalWeight;
	self.mode			:= _mode;

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_commodity" type="CM_Commodity"/>
        <Parameter name="_totalWeight" type="Decimal"/>
        <Parameter name="_mode" type="String"/>
    </JadeMethod>
    <JadeMethod name="setTotalWeight" id="e2301184-984e-42b8-8628-5b99a3d25794">
        <updating/>
        <source>setTotalWeight(_totalWeight	: Decimal) updating;
/*

Purpose:			SWets the total weight of the summary class by incrementing it

Parameters:			_totalWeight	Decimal	The total weight of the tracked item we want to increment

Return Value:		NONE

Date		Who		Reason
13 April 2022	navpw1	Initial creation TFS: 53132

*/

begin
	self.totalWeight += _totalWeight;

end;</source>
        <Parameter name="_totalWeight" type="Decimal"/>
    </JadeMethod>
</Class>
