<CollClass name="CM_CashReceiptDict" id="c68e8d11-0774-497f-a651-8d76c9b15547">
    <loadFactor>66</loadFactor>
    <memberType name="CM_CashReceipt"/>
    <superclass name="CM_MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cashReceipt"/>
    <MemberKey>
