    <JadeMethod name="doSystemNotification" id="953e8415-6476-44fe-b316-72e1ee1a32e3">
        <updating/>
        <source>doSystemNotification(_event: Integer; _object: CM_Object; _tag: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     26 April 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 15/09/2010	cnwcs5		par 25738 - handle deleted file  types in this method
// ---------------------------------------------------------------------------
vars
	table				:CM_DataTable;
	row					:Integer;
	str 				:String;
	invalid, isSelected	:Boolean;
begin
	table := self.tblData;
	
	if _event = Object_Update_Event and _object.isKindOf (CM_EDIData) then // 14/09/2010 cnwcs5 par 25738	
		isSelected := self.tblData.allSelectedObjects.includes (_object);
		
		on Exception do app.handleDeletedObject (exception, _object, invalid);
		
		if table.findObjectInRow(_object, row) then
			str := _object.getAttributeStringForDefArray(table.allTblDataEntRows);	// will cause exception if invalid
			
			self.tblData.removeItem(row);
			
			if invalid then
				self.doNotableRemove (_object.CM_EDIData);				// 14/09/2010 cnwcs5 par 25738
				table.colourRows (self.colorRow1, self.colorRow2);
				return;
			endif;
			
			table.addItemObjectAt(_object, str, row);
			
			if isSelected then
				table.selectObject (_object, false);
			endif;
			
			table.colourAddedRow (row, self.colorRow1, self.colorRow2);
		endif;
	elseif _event = Object_Delete_Event then
		if _object.isKindOf( CM_EDIFileTypeUser ) then					// 14/09/2010 cnwcs5 par 25738					
			self.doSystemNotification_FileType (_event, _object, _tag);	// 14/09/2010 cnwcs5 par 25738

		elseif _object.isKindOf (CM_EDIData) then						// 14/09/2010 cnwcs5 par 25738			
			if table.findObjectInRow(_object, row) then
				table.removeItem(row);
			endif;
			self.doNotableRemove (_object.CM_EDIData);					// 14/09/2010 cnwcs5 par 25738
			table.colourRows (self.colorRow1, self.colorRow2);
		endif;															// 14/09/2010 cnwcs5 par 25738
	endif;
epilog

end;</source>
        <Parameter name="_event" type="Integer"/>
        <Parameter name="_object" type="CM_Object"/>
        <Parameter name="_tag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doSystemNotification_FileType" id="38731cb0-b089-49b6-9483-cafaaf9b1bfc">
        <updating/>
        <source>doSystemNotification_FileType( eventType : Integer; theObject : Object; eventTag : Integer ) updating, protected;

/*
Date		Who		Reason
28/07/2010	cnwrl1	PAR 24415 - EDI Admin form does not handle deleted of EDI File Types.
15/09/2010	cnwcs5	par 25738 - renamed method
*/
	
vars
	ediFileTypeAvailable	: CM_ObjectSet;
	ediFileTypeSelected		: CM_ObjectSet;
	
begin
	// Currently we are only interested in deletes to EDI File Types.
	// In fact these are the only ones currently registered for, so should not get others?
	if eventType &lt;&gt; Object_Delete_Event or not theObject.isKindOf( CM_EDIFileTypeUser ) then
		return;
	endif;
	
	// Rebuild the EDI File Types.
	create ediFileTypeAvailable transient;
	create ediFileTypeSelected transient;
	
	// get the valid EDI File Types available and already selected
	self.mulQFileType.getAvailable( ediFileTypeAvailable );
	self.mulQFileType.getSelected( ediFileTypeSelected );
	
	// now refresh the listboxes with the valid available and already selected (ie minus any invalid ones)
	self.mulQFileType.setAvailable( ediFileTypeAvailable, false );		// do not clear selected first
	self.mulQFileType.setSelected( ediFileTypeSelected );
	
epilog
	delete ediFileTypeAvailable;
	delete ediFileTypeSelected;
	
end;</source>
        <access>protected</access>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doTblDataContextMenu" id="0118b522-ff9e-4b45-bd90-1fde41afefc2">
        <updating/>
        <source>doTblDataContextMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     22 April 2010 by cnwcs5
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 24/06/2010	cnwcs5		par 24298 - multi-select for verify/load to DB
// 13/09/2010	cnwcs5		par 25665 - allow view of multiple customs stops/operator stops
// 08 Aug 2013	cnwcs5		CCMS POL 2221 / par 32094
// 16 Dec 2014	cnwkpd1		PAR #34713 - Changes for .NET EDI Integration
// 05 Dec 2017	jlgrs1		TFS 8195 - SNO - EDI Release Comparison add support for ReleaseRequestMulti
// 09 Jul 2018  cnwma1		Bug 39483: JMT - EDI Operations View Raw Data and Internal XML
// 21 Apr 2020  cnwma1      Bug 49078: MTN - UE Floods
// 17 Oct 2022 navsj20		ChangeRequest 55084: EUP - EDI Administration Usability Requirements
// 26 Oct 2022 navvt20		ChangeRequest 55084: EUP - EDI Administration Usability Requirements
// 24 Aug 2023	navmd1		TFS 59451 Refactor EDI Ops/EDI Web Service viewer to call this one method too
// ---------------------------------------------------------------------------
vars
	ediData			: CM_EDIData;
	voyage			: CM_Voyage;
	xLeft, yTop		: Real;
	canUpdate, 
	singleSelect, 
	canReprocess,
	releaseRequest,
	generic		 	: Boolean;
	coll			: CM_ObjectSet;
	obj				: Object;
	user			: CM_User; 		//14.10.2022	navsj20	TFS 55084
	terminal		: CM_Terminal;	//14.10.2022	navsj20	TFS 55084
	ediFile			: CM_EDIFile;	//14.10.2022	navsj20	TFS 55084
begin
	ediData 		:= self.getSelectedEDIData;
	
	if ediData = null then   //21.04.2020 cnwma1 #49078
		return false;
	endif;
	
	create coll transient;
	
	self.tblData.allSelectedObjects.copy (coll);
	
	foreach obj in coll do		
		if obj.CM_EDIData.isKindOf (CM_EDIDataGeneric) then
			generic := true;
			break;					
		endif;
	endforeach;
	
	singleSelect	:= self.tblData.allSelectedObjects.size = 1;
	canUpdate		:= app.myCurrentUserCan(self.myTerminal, self.permissionMaint);	
	releaseRequest	:= ediData.isKindOf (CM_EDIDataReleaseRequest);

	// hide any menu items they don't have permission to see
	self.mnuViewRawData.visible			:= true; // TFS 2734
	
	//self.mnuViewInternalXML.visible		:= true; 			  // TFS 2734; //09.07.2018 cnwma1 TFS #39483
	ediFile := ediData.myEDIFile;
	if ediFile &lt;&gt; null then                             //09.07.2018 cnwma1 TFS #39483
		if ediFile.getOriginalFileDataString() &lt;&gt; null then
			if ediFile.myEDIFileType &lt;&gt; null and ediFile.myEDIFileType.isJSON() then
				self.mnuViewInternalXML.visible		:= false;
				self.mnuViewInternalJSON.visible	:= true;
			else
				self.mnuViewInternalXML.visible		:= true;
				self.mnuViewInternalJSON.visible	:= false;
			endif;
		else
			self.mnuViewInternalXML.visible			:= false;
			self.mnuViewInternalJSON.visible		:= false;
		endif;
	endif;
	self.mnuDelete.visible				:= canUpdate;
	self.mnuExtractNewEDIData.visible	:= true; // TFS 2734;
	self.mnuExtractSelectedEDI.visible	:= true; // TFS 2734;
	self.mnuMakeActual.visible			:= canUpdate;
	self.mnuReprocess.visible			:= canReprocess;
	self.mnuVerify.visible				:= canUpdate;
	self.mnuLoadNew.visible				:= canUpdate;
	self.mnuLoadToDB.visible			:= canUpdate;
	self.mnuRetranslateFile.visible		:= canUpdate;
	self.mnuLeaveMyContainers.visible	:= canUpdate;
	
	// disable anything that needs an item to be selected in the table
	self.mnuViewRawData.enabled			:= ediData &lt;&gt; null and singleSelect;
	self.mnuViewInternalXML.enabled		:= ediData &lt;&gt; null and singleSelect;
	self.mnuViewInternalJSON.enabled	:= ediData &lt;&gt; null and singleSelect;
	self.mnuDelete.enabled				:= ediData &lt;&gt; null;
	self.mnuViewItems.enabled			:= ediData &lt;&gt; null; /*and singleSelect;*/	// 13/09/2019 cnscw5 par 25665
	self.mnuExtractNewEDIData.enabled	:= true;
	self.mnuExtractSelectedEDI.enabled	:= ediData &lt;&gt; null and singleSelect and not releaseRequest;
	self.mnuEDIComparison.enabled		:= ediData &lt;&gt; null and singleSelect and ediData.status &lt;&gt; CM_EDIFile.EDI_STATUS_DBLOADED and 
	(ediData.isKindOf(CM_EDIDataReleaseRequest) or ediData.isKindOf(CM_EDIDataRequestMultiLine) or (ediData.isKindOf(CM_EDIDataGateDoc) and ediData.CM_EDIDataGateDoc.hasReleaseReq()));
	self.mnuVerify.enabled				:= ediData &lt;&gt; null /*and singleSelect*/ and not generic;	// par 24298
	self.mnuLoadNew.enabled				:= true;
	self.mnuLoadToDB.enabled			:= ediData &lt;&gt; null /* and singleSelect*/ and not generic;	// par 24298
	self.mnuRetranslateFile.enabled		:= ediData &lt;&gt; null and not generic;
	
	// some menu items relate just to bay plans
	self.mnuMakeActual.enabled 			:= false;
	self.mnuLeaveMyContainers.enabled	:= false;
	
	if ediData &lt;&gt; null and ediData.isKindOf(CM_EDIDataBayPlan) then
		voyage := ediData.CM_EDIDataBayPlan.getVoyageFromCode(ediData.CM_EDIDataBayPlan.voyageCode);
		if voyage &lt;&gt; null and 
			voyage.isHOLDSorSHIP() then
			self.mnuLeaveMyContainers.enabled := singleSelect;
		else
			if self.myTerminal.getConfig(EDICanRemovePlanned).Boolean then
				self.mnuLeaveMyContainers.enabled := singleSelect;
			endif;
			if ediData.CM_EDIDataBayPlan.myBayPlanController &lt;&gt; null then
				self.mnuMakeActual.enabled 	:= singleSelect;
			endif;
		endif;
	endif;
	
	// reprocess relates only to operator/customs stops and only those that have
	// been loaded to the DB
	self.mnuReprocess.enabled	:= false;
	
	if app.isSpecial then
		self.mnuDevOnlySep.visible		:= true;
		self.mnuDEVCreateCargo.visible	:= true;
		self.mnuDEVResetStatus.visible	:= true;
		self.mnuInspect.visible 		:= true;
		
		self.mnuDEVCreateCargo.enabled	:= singleSelect;
		self.mnuDEVResetStatus.enabled	:= singleSelect;
	else
		self.mnuDevOnlySep.visible		:= false;
		self.mnuDEVCreateCargo.visible	:= false;
		self.mnuDEVResetStatus.visible	:= false;
		self.mnuInspect.visible 		:= false;	
	endif;
	//START 14.10.2022	navsj20	TFS 55084
	self.mnuCancel.visible := false;
	self.mnuRevoke.visible := false;	
	user := app.getMyUser();
	terminal := self.myTerminal;
	if ediData.canBeCancelled() and user.canDo(terminal, PmAdmEDICancel) then
		self.mnuCancel.visible:= true;
	endif;
	if ediData.canBeRevoked then 
		if user.canDo(terminal, PmAdmEDIRevoke) then
			self.mnuRevoke.visible:= true;
		endif;
		self.mnuVerify.enabled := false;
		self.mnuLoadToDB.enabled := false;
		self.mnuMakeActual.enabled := false;
	endif;
	//END 14.10.2022  navsj20  TFS 55084
	// hide any seperators that should not be there
	if not self.mnuLoadNew.visible and
		not	self.mnuCancel.visible and // 26 Oct 2022 navvt20 TFS 55084
		not	self.mnuRevoke.visible and // 26 Oct 2022 navvt20 TFS 55084
		not self.mnuRetranslateFile.visible and
		not self.mnuVerify.visible and
		not self.mnuLoadToDB.visible and
		not self.mnuReprocess.visible and
		not self.mnuMakeActual.visible then
		self.mnuSep1.visible := false;
	else
		self.mnuSep1.visible := false;
	endif;
	
	if not self.mnuDelete.visible then
		self.mnuSep2.visible := false;
	else
		self.mnuSep2.visible := true;
	endif;
	
	if not self.mnuExtractNewEDIData.visible and
		not self.mnuExtractSelectedEDI.visible and 
		not self.mnuLeaveMyContainers.visible then
		self.mnuSep3.visible := false;
	else
		self.mnuSep3.visible := true;
	endif;
	// now actually  show the popup menu
	xLeft	:= x;
	yTop 	:= y;
	
	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);
	
	self.popupMenu(self.mnuTablePopup, xLeft.Integer, yTop.Integer);
	
	return false;
epilog
	delete coll;
end;</source>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTblDataDBClick" id="ec217716-b13c-44fb-bbf6-ce056c1d5f03">
        <updating/>
        <source>doTblDataDBClick(_table: CM_DataTable input) updating;
// ---------------------------------------------------------------------------
// Created:     26 April 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	ediData : CM_EDIData;	//par 27392 13 Apr 2011
begin
	if _table.row &lt;= _table.fixedRows then
		inheritMethod(_table);

		_table.colourRows (self.colorRow1,colorRow2);
		return;
	endif;
	
	self.doViewItem(ediData);	//par 27392 13 Apr 2011
epilog

end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doVerify" id="12797686-32de-4863-9e59-d4cff20c9cd2">
        <updating/>
        <source>doVerify() updating, protected;
// ---------------------------------------------------------------------------
// Created:     28 April 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 22/06/2010	cnwcs5		par 24298 - allow multi-select
// ---------------------------------------------------------------------------
vars
	ediData		: CM_EDIData;
	passport	: CM_Passport;
	allErrorEdiData : ObjectArray;
	coll		: CM_EDIDataByDateStatusDict;
	cmifMonitor	: CMIF_Monitor;
	count, countOK, countNotOK,
	size		: Integer;
	invalidObject	:Boolean;
	strCaption		:String;
begin
	self.staStatusBar.caption := null;
	passport					:= app.myPassport;
	
	// make sure we have something to verify
	coll := self.getAllSelectedEDIData();
	
	size := coll.size;
	
	if size = 0 then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Nothing selected');	
	endif;
	
	// arm exception handler
	on Exception do app.handleDeletedObject (exception, ediData, invalidObject);
	
	app.mousePointer 	:= MP_HOURGLASS;
	// clear out any old stuff
	passport.clearErrorsWarnings();
	// the monitor will handle updating the progress bar
	cmifMonitor := self.createCMIFMonitor (passport);
	// show the progress dialog
	self.progressStart (size, app.getErrorString(Cancel), null, null, app.getErrorString (XLAT_Verifying_EDIData));
	
	create allErrorEdiData transient;
	
	foreach ediData in coll do 
		count 			:= count + 1;
		invalidObject	:= false;	
		
		if ediData.isKindOf (CM_EDIDataGeneric)then
			// menu item should have been disabled - this form does not handle generic
			continue;
		endif;
		
		if ediData = null or ediData.edition &lt; 0 then	// will cause exception if ediData is deleted
			continue;
		endif;
		
		if invalidObject then
			continue;
		endif;
		// update the progress dialog	
		self.lblModalMessage.caption := (app.getErrorString2 (Verifying_X_of_Y, count.String, size.String));
		self.pbProgressBar.partsDone := count;
		self.frmModalDialog.refreshNow;
		self.btnModalDefault.doWindowEvents(null);	// did someone press the cancel button
		
		if self.modalDialogReturnValue = self.ModalDialogReturn_Default then
			// Cancel button was pressed
			break;		
		endif;
		
		// do the actual verify
		self.myEDIControllerAgent.verifyEdiData(ediData);
		
		
		// check for errors 
		if passport.allErrorWarnings.size = 0 then
			countOK := countOK + 1; 
		else
			allErrorEdiData.add(ediData);
			countNotOK := countNotOK + 1; 
			if size = 1 then
				// Direct them to old form if there was only one item being verified
				//self.showVerifyErrors (app.getErrorString (EDIData_Failed_To_Verify2), self.mnuVerify.caption);
			endif;
		endif;
		
		
	endforeach;
	
	// now display result
	strCaption := self.mnuCancel.caption;
	
	self.staStatusBar.caption := app.getErrorString3 (X_of_Y_Sucessful, strCaption, countOK.String, size.String);
	
	if allErrorEdiData.size &gt; 0 then
		if app.msgBox (app.getErrorString (EDIData_Failed_To_Verify2),  self.mnuVerify.caption, MsgBox_Yes_No) = MsgBox_Return_Yes then
			// display the edi form
			 self.myEDIAgent.showEDIFormWithColl (allErrorEdiData, self.myMasterMenuAction, false);	
		endif;
	endif;
	
	/*if size &gt; 1 and countNotOK &lt;&gt; 0 then
		
		
		self.showVerifyErrors (app.getErrorString (EDIData_Failed_To_Verify2), self.mnuVerify.caption);
		// multi-select had some errors - show message.  if there was only one item being processed we would have 
		// shown the errors already if there were any
	//	app.msgBox (app.getErrorString3 (X_of_Y_Items_ErrorsWarnings, strCaption, countNotOK.String, size.String),
	//				strCaption, MsgBox_OK_Only);
	endif;*/
epilog
	self.clearErrorWarnings();	// always clear out
	self.progressFinish;		// just to make sure
	delete cmifMonitor;			// will reset passport value
	delete coll;
	delete allErrorEdiData;
	app.mousePointer := MP_DEFAULT;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doViewInternalXML" id="7b1323be-b545-4cdc-8606-8075c877e41b">
        <updating/>
        <source>doViewInternalXML() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 December 2014	cnwkpd1	PAR #34713 - .NET EDI transform integration

*/

vars
	ediData	:CM_EDIData;

begin
	if self.tblData.row &gt; self.tblData.fixedRows then
		ediData := self.tblData.accessRow(self.tblData.row).itemObject.CM_EDIData;
	endif;
	
	self.myEDIAgent.doEDIViewInternalXML(ediData, self);
	
epilog

end;</source>
        <access>protected</access>
