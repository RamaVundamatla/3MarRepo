    <JadeMethod name="updateLoadFlagProperties" id="90f83dad-783a-4408-b369-1a990f3e65fa">
        <updating/>
        <source>updateLoadFlagProperties(_flagFrom : Boolean; _menuItem :MenuItem) updating, protected;
// ---------------------------------------------------------------------------
// Created:     16 March 2004	cnwth2
//
// Purpose:     if _flagFrom then it will update the ta.isSuitableToLoadFrom to be the opposite of the currect value
//				if NOT _flagFrom then it will update the ta.isSuitableToLoadInto to be the opposite of the currect value
// ----------   ----------  --------------------------------------------------
// 05/11/2012	cnwcs5	par 30475 - tidy up translations, added _menuItem parameter
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	ta				: CM_TerminalArea;
	jRow			: JadeTableRow;
	passport		: CM_Passport;
	result			: Integer;
begin
	jRow := self.tblData.accessRow(self.tblData.row);
	
	if jRow = null then
		return;
	endif;
	
	if (jRow = null) or (not jRow.selected) or (jRow.itemObject = null) then
		app.msgBox(app.getErrorString (Please_select_terminal_area), app.getErrorString (CMUI_Nothing_Selected), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	passport 	:= app.myPassport;
	ta 			:= jRow.itemObject.CM_TerminalArea;
	

	while true do
		if _flagFrom then
			app.myTrxUA.trxUpdateTerminalAreaFlag(ta, (not ta.isSuitableForLoadFrom), false, passport);
		else
			app.myTrxUA.trxUpdateTerminalAreaFlag(ta, false, (not ta.isSuitableForLoadInto), passport);
		endif;
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			result := app.showErrorWarningDialog(_menuItem.caption, passport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			
			if passport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				passport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(passport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;
	
	//notification spawned in the trx will update the table, and thus the display color of the updated ta
end;</source>
        <access>protected</access>
        <Parameter name="_flagFrom" type="Boolean"/>
        <Parameter name="_menuItem" type="MenuItem"/>
    </JadeMethod>
    <JadeMethod name="updateProgress" id="8f77ebdc-0194-4eb6-bba4-927b79a4e88f">
        <updating/>
        <source>updateProgress(_cmifMonitor: CMIF_Monitor input) updating;
// ---------------------------------------------------------------------------
// Created:     15 March 2004	cnwth2
//			 
// ----------   ----------  --------------------------------------------------
// 05/11/2012	cnwcs5	par 30475 - tidy up translations
vars

begin
	self.lblModalInfo.caption		:=  app.getErrorString1 (Containers_queried, _cmifMonitor.partsDone.String);
	self.lblModalMessage.caption 	:= app.getErrorString1 (Terminal_areas_found, _cmifMonitor.partsInJob.String);
	
	self.refreshNow();
	self.btnModalDefault.doWindowEvents(0);
	
	if self.modalDialogReturnValue = ModalDialogReturn_Null then
		// see if the user has pressed the Cancel button
		self.btnModalOpt1.doWindowEvents(0);
	endif;
end;</source>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="input"/>
    </JadeMethod>
