    <JadeMethod name="doBtnAudit" id="bf1a7583-e639-445b-b3b5-b4973dfef18e">
        <source>doBtnAudit();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 November 2023	navrv30 Bug 58391: EUP - Audits for Invoice Copy

*/

vars
	//theReturn : Integer;
	custDoc : CM_CustomDocumentDetail;
begin
	if  self.tblData.row &lt;=  self.tblData.fixedRows then
		return;
	endif;
	
	if self.tblData.accessRow( self.tblData.row).selected then
		custDoc := self.tblData.accessedRow.itemObject.CM_CustomDocumentDetail;
	endif;
	
	if custDoc = null then
		app.msgBox(app.getErrorString(Record_selected), app.getErrorString(Warning),MsgBox_OK_Only);
		return;
	endif;
	if custDoc &lt;&gt; null then		
		app.viewAuditFormModal(custDoc, self.myAssistant.class, self.myTerminal);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnRemove" id="f9070844-8cef-49a1-8f7a-90b4d2ffed8c">
        <updating/>
        <source>doBtnRemove() updating;
/*
Purpose:			

Date		Who		Reason
11AUG2023	NAVAB1	 CR 59614 TASK 59619
*/

vars
	theReturn : Integer;
	custDoc : CM_CustomDocumentDetail;
begin
	if  self.tblData.row &lt;=  self.tblData.fixedRows then
		return;
	endif;
	
	if self.tblData.accessRow( self.tblData.row).selected then
		custDoc := self.tblData.accessedRow.itemObject.CM_CustomDocumentDetail;
	endif;
	
	if custDoc = null then
		app.msgBox(app.getErrorString(Record_selected), app.getErrorString(Warning),MsgBox_OK_Only);
		return;
	endif;
	if custDoc &lt;&gt; null then
		while true do
			app.myTrxDA.trxDeleteCustDocDetail(custDoc, app.myPassport);
			if app.myPassport.trxCompletedOK then
				// Clear errors/warnings from form and err/warnings window
				self.clearErrorWarnings();
				global.beep;
				break;
			else
				theReturn := app.showErrorWarningDialog("Cust Doc Detail", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   theReturn = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
				return;
			endif;
			break;
		endwhile;

	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnUpdate" id="179986bf-17ee-4a67-a2a7-02796d9314b3">
        <updating/>
        <source>doBtnUpdate() updating;
/*
Purpose:			

Date		Who		Reason
11AUG2023	NAVAB1	 CR 59614 TASK 59619
*/

vars
	form : CMUI_CustomDocsDetail;
	bank :CM_Bank;
	custDoc : CM_CustomDocumentDetail;
	ti : CM_TrackedItem;
	ct : CM_CargoType;
begin

	self.allProxyDetailsForInclude.purge(); // ### TFS CR 64285 TASK 64286 24JUNE024 NAVAB1 - use this for 'include' TRX update, however if going to detail UI need to get rid of the update proxies.

	custDoc := self.tblData.accessRow(self.tblData.row).itemObject.CM_CustomDocumentDetail;
	if custDoc = null then
		app.msgBox(app.getErrorString(Record_selected), app.getErrorString(Warning),MsgBox_OK_Only);
		return;
	endif;
	
	if custDoc &lt;&gt; null then
		ti := custDoc.myTrackedItem;
		if not ti.isCargoGroupItem then
			ct := ti.myCargoType;
			if not ct.allowDuplicates then
				app.msgBox(app.getErrorString(This_cargo_item_not_split_need), app.getErrorString(Warning),MsgBox_OK_Only);
				return;
			endif;
		endif;
		form := app.loadForm(CMUI_CustomDocsDetail, CMUI_Assistant, false, false,false, self.myTerminal,null).CMUI_CustomDocsDetail;
		
		 // ### TFS CR 60052 TASK 60054 25AUG2023 NAVAB1
		if self.mode = self.Cargo_Review_Mode then
			if form &lt;&gt; null then
				form.updateMode := false;
				form.setProxyForCargoReview(custDoc);
			endif;
		
		else
			if form &lt;&gt; null then
				form.updateMode := true;
				form.setMyCustDocDetail(custDoc);
				form.setMyCustDocument(self.myCustomDocument);
			endif;
		endif;
		if form &lt;&gt; null then
			form.centreWindow();
			form.showModal;
			
			if self.mode = self.Cargo_Review_Mode then
				self.getCargoReviewProxyDocType(custDoc);
				self.resetCustDocClearedAmounts(custDoc);
				self.displayDetails();
				self.displayStatus();
			endif;
		endif;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doCheckDocTypeIsAutoId" id="3c53ec6c-dc25-4a1f-9eb6-4abfa8ac55c4">
        <source>doCheckDocTypeIsAutoId(_docType : CM_CustomDocumentType);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29/08/2023	navkc1	CR 59556  Task 59593: UI - Cust Docs Auto Id

*/

vars
	terminal		: CM_Terminal;
	autoId			: CM_AutoIdCustomDocs;
	date			: Date;
	firstTI			: CM_TrackedItem;
	firstRow		: Integer;
	custDocDtl		: CM_CustomDocumentDetail;
	tiTrans			: CM_TITransaction;
begin
	if _docType = null then
		return;
	endif;
	// If doc type is not using auto id then return;
	if _docType.hasAutoId = false then
		return;
	endif;
	
	terminal := self.myTerminal;
	
	if terminal = null then
		return;
	endif;
	
	autoId := terminal.getMyAutoIdGenerator(CM_AutoIdCustomDocs).CM_AutoIdCustomDocs;
	
	// If no auto id set up then return;
	if autoId = null then
		return;
	endif;
	
	// We have auto id now, disable the textbox, the Code will be generated by Auto ID at the end of the TRX
	self.txtCode.enabled := false;
	self.txtCode.text := "Auto ID";
	
epilog

end;</source>
        <Parameter name="_docType" type="CM_CustomDocumentType"/>
    </JadeMethod>
    <JadeMethod name="doCmbDocTypeClick" id="b46533bb-ec1d-4787-a153-898dedcd6585">
        <source>doCmbDocTypeClick();
/*
Purpose:			

Date		Who		Reason
13 September 2023	navab1	CR 59942 TASK 59943 
*/
vars
	custDocType : CM_CustomDocumentType;
	license : CM_CustomLicense;
begin
	custDocType := self.cmbDocType.listObject.CM_CustomDocumentType;
	if custDocType &lt;&gt; null then
		self.buildCmbDirection(custDocType);
		
		self.buildCmbLicense(custDocType);
		self.txtCode.enabled := true;
		self.doCheckDocTypeIsAutoId(custDocType); //29/08/2023	navkc1	CR 59556  Task 59593
		
	endif;
	self.enableForCargoReview(); // ### TFS CR 60052 TASK 60054 25AUG2023 NAVAB1
epilog

end;</source>
    </JadeMethod>
