    <JadeMethod name="addToolbarControls" id="2f570387-583f-4bf1-bafb-a4b8ec5a6ae4">
        <updating/>
        <source>addToolbarControls() updating, protected;
/* Changes

Date		Name	TFS#		Description
============================================================================
11 Mar 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
29 Mar 2022	jlika1	TFS 53181	GPHA - Voyage Code Translation for Multiple Terminals and Co-Loaders
============================================================================*/
vars
	frm			: CMUI_Toolbar;
	user		: CM_User;
	canUpdate	: Boolean;
begin	
	frm 	:= self.frmToolbar;
	user	:= app.getMyUser;
	
	canUpdate := user.canDo (null, PmAdmEdixlationMaint);
	
	frm.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnExportCSVQE, CMUI_Toolbar.Control_Alignment_Left);
	//jlier1 TFS 56291 26/1/22
	if canUpdate then
		frm.addButton(self.btnImportCSV, CMUI_Toolbar.Control_Alignment_Left);
	endif;
	
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	
	
	if canUpdate then
		frm.addButton(self.btnNew, CMUI_Toolbar.Control_Alignment_Left);
	endif;
	
	frm.addButton(self.btnEditItem, CMUI_Toolbar.Control_Alignment_Left);
	
	if canUpdate then
		frm.addButton(self.btnDelete, CMUI_Toolbar.Control_Alignment_Left);
	endif;
	
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	frm.addButton(self.btnQuery, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnResetSearch, CMUI_Toolbar.Control_Alignment_Left);
//	frm.addButton(self.btnRefresh, CMUI_Toolbar.Control_Alignment_Left);
	
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	frm.addButton(self.btnSelectAll, CMUI_Toolbar.Control_Alignment_Left);
		
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);	
	
	if canUpdate then
		frm.addButton(self.btnCopy, CMUI_Toolbar.Control_Alignment_Left);
	endif;
	
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);	
	frm.addButton(self.btnVoyageBulkTranslation, CMUI_Toolbar.Control_Alignment_Left);	
	
	inheritMethod();
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
