    <JadeMethod name="utlUpdateUserStatus" id="49a4880a-d40f-4de1-8c7b-34a8d3efdd90">
        <source>utlUpdateUserStatus(user : CM_User input; expectedEdition : Integer; newStatus : Integer; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 22/06/2020	jlgmd1		TFS 49615 Prevent 'important' users from being diabled
//
// ---------------------------------------------------------------------------
vars

begin

	self.initialiseActivity();

	if expectedEdition &lt; 1 then
		app.setContinueCMExceptions(false);
		app.raiseCMException2(ExpectedEditionInvalid, expectedEdition.String, method.name ,null, null);
		return;
	endif;

	if user = null then
		app.setContinueCMExceptions(false);
	//	app.raiseCMException1(REQUIRED_FIELD, "user", null, null);
		app.raiseCMException(Input_required_field_Usr, null, null); // cnwdb2	PAR 35364
		return;
	endif;
	
	// Prevent changing 'special' users statuses
	if user.isInternalSystemUser() then
		return;
	endif;
	
	app.myValUA.valUserStatus(newStatus);
	
	// Do some extra validation if we're disabling this user
	if newStatus = DisabledBySysAdminUser then
		user.validateNotInUse(user, true);
	endif;
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	// Lock will be released at commit/abort transaction	
	exclusiveLock(user);
	
	if _passport.noErrors then
		if user.edition &lt;&gt; expectedEdition then
			app.setContinueCMExceptions(false);
			app.raiseCMException1(ObjectUpdatedByAnotherUserSave, "user", null, null);
			return;
		endif;
	endif;

	user.updateStatus(newStatus);
	
end;</source>
        <Parameter name="user" type="CM_User" usage="input"/>
        <Parameter name="expectedEdition" type="Integer"/>
        <Parameter name="newStatus" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateUserTempPW" id="ea13fbb7-7ab8-4591-9e0e-b77b6649826e">
        <updating/>
        <source>utlUpdateUserTempPW( _realUser : CM_User io; _tempPassword : String; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2018	jlgndl1	Initial creation	TFS 38768

*/

vars

	userPwDefEmail : CM_UserPasswordDefaultEmail;

begin

	self.initialiseActivity();
	
	exclusiveLock( _realUser );
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(_realUser, true);
	endif;
	
	//chg the password.
	if _passport.noErrors then
		_realUser.setPassword( _tempPassword, false );
		_realUser.updateStatus( NewUser ); //to force password change at first logon
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(_realUser, false);
	endif;
	
	//send the email
	if _passport.noErrors then
		userPwDefEmail := app.myRoot.getConfig( UserEmailTemplate ).CM_UserPasswordDefaultEmail;
		_realUser.sendPasswordResetEmail( userPwDefEmail, _tempPassword );
	endif;

epilog

end;</source>
        <Parameter name="_realUser" type="CM_User" usage="io"/>
        <Parameter name="_tempPassword" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateUserToolbarMenu" id="d9e52c92-34cc-45b4-96bc-8e7020bb794e">
        <source>utlUpdateUserToolbarMenu(_user : CM_User input; _toolbarRoot : CM_MenuUserToolbarRoot input);
// ---------------------------------------------------------------------------
// Created:     22 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	menuEntity 				: CM_MenuEntity;
	userToolbar				: CM_MenuUserToolbar;
begin
	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	
	if _user = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'User', null, null);
		app.raiseCMException(Input_required_field_Usr, null, null); // cnwdb2	PAR 35364
		return;
	endif;
	
	if _toolbarRoot = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Toolbar Entity Array', null, null);
		app.raiseCMException(Input_required_field_TolEntAry, null, null); // cnwdb2	PAR 35364
		return;
	endif;


	app.setContinueCMExceptions(false);

	exclusiveLock(_user);
	
	_user.myMenuUserToolbarRoot.allMenuUserToolbarItems.purge;
	_user.myMenuUserToolbarRoot.setShowCaption(_toolbarRoot.showCaption);
	
	foreach menuEntity in _toolbarRoot.allChildren do
		if not CM_MenuToolbar.hasInstance(menuEntity) then
			continue;
		endif;
		
		if not global.isValidObject(menuEntity.CM_MenuToolbar.myMenuDtlSystem) and
			(menuEntity.CM_MenuToolbar.myMenuDtlSystem &lt;&gt; null) then
			app.writeLog(menuEntity.CM_MenuToolbar.heading &amp; ' had an invalid system item reference', LogINFO);
			continue;
		endif;
		
		create userToolbar persistent;
		userToolbar.setFromSystemToolbar(menuEntity.CM_MenuToolbar);
		_user.myMenuUserToolbarRoot.allMenuUserToolbarItems.add(userToolbar);
		
	endforeach;

	
end;</source>
        <Parameter name="_user" type="CM_User" usage="input"/>
        <Parameter name="_toolbarRoot" type="CM_MenuUserToolbarRoot" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateUserWindow" id="7d6f55a1-dc54-4213-8b94-670516314bd1">
        <source>utlUpdateUserWindow(pUser : CM_User; pUserWindow : CM_UserWindow);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	self.initialiseActivity();
