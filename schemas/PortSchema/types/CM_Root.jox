    <JadeMethod name="getNextStopID" id="81a72844-9cdb-4376-afdc-478e42821de3">
        <source>getNextStopID(): Integer;
//----------------------------------------------------------------
//	Created:	18 May 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//Finds the next ID to allocate to a new stop
vars
	dict	: CM_StopsTableByIdDict;
	nextNum	: Integer;	
begin

	nextNum := 1;
	dict := self.allStopsTable;
	
	while true do
		if dict[nextNum] &lt;&gt; null then
			//Found one! Carry on until we can't
			nextNum := nextNum +1;
		else
			return nextNum;
		endif;
	endwhile;
	
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getNextToDoTaskCode" id="6ac37d58-dd8e-4d96-89be-4a8aea8c4ad1">
        <source>getNextToDoTaskCode(nextNum	:	Integer io);
//Finds the next number to allocate to a new to-do task.
vars
	dict	:	CM_ToDoTaskDescByCode;	
begin
	nextNum := 1;
	dict := self.allToDoTaskDescriptions;
	while true do
		if dict[nextNum] &lt;&gt; null then
			//Found one! Carry on until we can't
			nextNum := nextNum +1;
		else
			return;
		endif;
	endwhile;
end;</source>
        <Parameter name="nextNum" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getNextVoyageCode" id="0d9860e9-0a17-4911-93a8-3b4ea6ab99a2">
        <source>getNextVoyageCode(_vesselCode : String io):String;
//--------------------------------------------------
// Created:	28 March 2006 By: cnwgd1
//--------------------------------------------------

// MOVED TO ROOT FROM TERMINAL - LORCAN 18/9/2006

// vesselCode 25 + 4 digit number = 29 characters, but voyage code only 20 characters long
// changed to use 4 digit prefix (terminal code or config setting) + key series sequence number
vars
	vesselCode,
 	sysVoyCode			: String;	
 	count,
 	uniqueCode			: Integer;
 	existingPermVoyage 	: CM_Voyage;
	terminal			: CM_Terminal;
	
begin
	// TEMPORARY WAY OF CREATING SYSTEM VOYAGE CODE AS PER ORIGINAL HMS SYSTEM 1998
	
	// This method automatically creates a unique system (only) voyage code
	// The basic structure of the code is: VesselCode XX000 &amp; a 4 digit number
	// eg. SysVoyCode = XX0009999
	// The code is updated if the vessel is changed.
	
	// Get ship code
	vesselCode	:=	_vesselCode[1:5].cnEcRemoveSubstring(" ");
	
	// Get next lowest available four digit code with this vessel code combination
	count		:=	1;
	uniqueCode	:=	HMSUniqueCodeNotSet;
    
    while count &lt;= 9999 do
   		uniqueCode	:=	count;
   		count		:=	HMS_UniqueVoyCode;
		
    	if count = HMS_UniqueVoyCode then
	   		sysVoyCode	:=	vesselCode &amp; uniqueCode.String.padLeadingZeros(4);
			
			foreach terminal in self.allTerminals do
				// Check active terminal
				existingPermVoyage	:=	terminal.lookupVoyage (sysVoyCode, null, true);
				
//				if existingPermVoyage = null then
//				// check archived terminal
//		     		existingPermVoyage := self.allVoyagesArchived.getAtKey(sysVoyCode);
//		   		endif;
				
				if existingPermVoyage = null then
					// check inward code
					existingPermVoyage := terminal.allVoyagesByInwardCode.getAtKey(sysVoyCode);
				endif;
				
				if existingPermVoyage &lt;&gt; null then
					// The proposed code is being used by another perm voyage
					// ie. not the currently selected voyage.
					// Increase the count to select the next unique code
					count	:=	uniqueCode;
					count	:=	count + 1;
					uniqueCode := HMSUniqueCodeNotSet;
					break;
				else
					// Code is not used by any other existing perm voyage - use this code
				endif;
				
			endforeach;
		endif;
	endwhile;
    
  	// Test to see if a unique code has been found
   	if count = HMS_UniqueVoyCode then
   		// Return unique code
   		return sysVoyCode;
   	else
   		// Code has not been found - raise error msg - all available codes have been used.
		//errorMsg := "All avaliable voyage codes have been used for this 'Ship'. Please contact the System Administrator.";
    	//msgTitle := "ERROR: All codes used!";
    	app.raiseCMException(Avali_voyag_codes_have_been_us, null, null);
    	return null;
    endif;
end;</source>
        <Parameter name="_vesselCode" type="String" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
