    <JadeMethod name="getPicture" id="d2731a83-54bc-4aa2-822e-6f53a672cadc">
        <source>getPicture(form: INV_TransactionMap): Picture;

vars

begin
	if self.hidePictures then
		return null;
	endif;
	return form.picRoot;

end;</source>
        <Parameter name="form" type="INV_TransactionMap"/>
        <ReturnType type="Picture"/>
    </JadeMethod>
    <JadeMethod name="initialPopulate" id="677554fa-2215-4d76-a48c-73cc73c76943">
        <source>initialPopulate(listbox: ListBox; level : Integer);
// 35386
vars
	pic : Picture;
	tmc : CMIF_TranMapController;

begin
	if level &gt; 3 then
		return;
	endif;
	listbox.addItem(itemName);
	listbox.itemLevel[listbox.newIndex] := level;
	listbox.itemObject[listbox.newIndex] := self;
	listbox.itemData[listbox.newIndex] := self.getType(); //epr TFS 3051 29/11/2016
	pic := getPicture(listbox.form.INV_TransactionMap);
	if pic &lt;&gt; null then
		listbox.itemPicture[listbox.newIndex] := pic.picture;
	endif;
	listbox.itemPictureType[listbox.newIndex] := ListBox.ItemPictureType_Closed;
	foreach tmc in self.allGroupMembers do
		tmc.initialPopulate(listbox, level + 1);
	endforeach;

end;
</source>
        <Parameter name="listbox" type="ListBox"/>
        <Parameter name="level" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initialise" id="ff923d17-2e20-4c9a-a78e-7f9e53b40c44">
        <updating/>
        <source>initialise(_groupCount : Integer io) updating;

vars
	tmType : CMIF_TMCType;
	tmcController : CMIF_TMCController;
begin
	create tmcController;
	self.myTMCController := tmcController;	// 23659 keep a reference so can delete it
	self.myTMCController.hidePictures := self.hidePictures;
	// 35872 
	self.myTMCController.myBank := self.myBank;

	if self.showCargo then // PAR 25833
		
		create tmType;
		tmType.itemName := "Cargo";
		tmType.extractName := tmType.itemName;	// 23659
		tmType.hidePictures := self.hidePictures;
		tmType.myGroup := self;
		tmType.type := CMIF_TMCType.TYPE_TRACKEDITEM;
		tmType.myTMCController := tmcController;	// April 2010, cnwjre1, par 23659, invoice transaction map extract enhancements for Tranship IMEX status
		tmType.initialiseXCargo();
		self.groupCount := self.groupCount + 1;
	endif;
	
	if app.myPassport.myUser &lt;&gt; null and app.myPassport.myUser.canDo(app.myPassport.myTerminal, Mod_Harbour) then
		if self.showVoyage then // PAR 25833
			create tmType;
			tmType.itemName := "Voyage";
			tmType.extractName := tmType.itemName;	// 23659
			tmType.hidePictures := self.hidePictures;
			tmType.type := CMIF_TMCType.TYPE_VOYAGE;
			tmType.myGroup := self;
			tmType.myTMCController := tmcController;	// 23659
			tmType.initialseXVoyage();
			self.groupCount := self.groupCount + 1;
		endif;
	endif;

	if self.showEvent then // PAR 25833
		create tmType;
		tmType.itemName := "Event";
		tmType.extractName := tmType.itemName;	// 23659
		tmType.hidePictures := self.hidePictures;
		tmType.type := CMIF_TMCType.TYPE_EVENT;
		tmType.myGroup := self;
		tmType.myTMCController := tmcController;	// 23659
		tmType.initialiseEvent();
		self.groupCount := self.groupCount + 1;
	endif;
	
	if self.showSnapShot then // PAR 25833
		create tmType;
		tmType.itemName := "Snapshot Summary";
		tmType.extractName := tmType.itemName;
		tmType.hidePictures := self.hidePictures;
		tmType.type := CMIF_TMCType.TYPE_SSSUMMARY;
		tmType.myGroup := self;
		tmType.myTMCController := tmcController;
		tmType.initialiseSnapShot();
		self.groupCount := self.groupCount + 1;
	endif;
	if self.showCargoAlloc then // PAR 25833
		create tmType;
		tmType.itemName := "Cargo Allocations";
		tmType.extractName := tmType.itemName;
		tmType.hidePictures := self.hidePictures;
		tmType.type := CMIF_TMCType.TYPE_CARGOALLOC;
		tmType.myGroup := self;
		tmType.myTMCController := tmcController;
		tmType.initialiseCargoAlloc();
		self.groupCount := self.groupCount + 1;
	endif;

	if self.showWO then // TFS 39236
		create tmType;
		tmType.itemName := "Work Order";
		tmType.extractName := tmType.itemName;	
		tmType.hidePictures := self.hidePictures;
		tmType.type := CMIF_TMCType.TYPE_WO;
		tmType.myGroup := self;
		tmType.myTMCController := tmcController;	
		tmType.initialiseWO();
		self.groupCount := self.groupCount + 1;
	endif;
	
	if self.showBOL then //31 Oct 2019	NDL	TFS 47100
		create tmType;
		tmType.itemName := "Bill Of Lading";
		tmType.extractName := tmType.itemName;	
		tmType.hidePictures := self.hidePictures;
		tmType.type := CMIF_TMCType.TYPE_BOL;
		tmType.myGroup := self;
		tmType.myTMCController := tmcController;	
		tmType.initialiseBOL();
		self.groupCount := self.groupCount + 1;
	endif;
	
	if self.showInventory then // TFS 51219 25MAY2021 NAVAB1
		create tmType;
		tmType.itemName := "Inventory";
		tmType.extractName := tmType.itemName;	
		tmType.hidePictures := self.hidePictures;
		tmType.type := CMIF_TMCType.TYPE_INVENTORY;
		tmType.myGroup := self;
		tmType.myTMCController := tmcController;	
		tmType.initialiseInventory();
		self.groupCount := self.groupCount + 1;
	endif;
	
	//epr TFS 3051 2/12/16 
	self.groupCount := self.groupCount + 1;
end;</source>
        <Parameter name="_groupCount" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="loadList" id="bf82654b-4fac-48b9-a3f6-0a9f33e33889">
        <source>loadList(listbox: ListBox; level: Integer);
// 35386
vars
	oa	: ObjectArray;
	size	: Integer;
begin
	/*create oa transient;
	CMIF_TranMapController.allProcessTransientInstances(oa, 0, true);
	size := oa.size;*/
	//epr TFS 3051 2/12/16  problem with above was if you had the screen open more than once it was incorrectly doing this
	if self.groupCount &lt; 30000 then		// actual limit 30000, for 35386 (Jade limit is 32000, this is being cautious)
		inheritMethod(listbox, level);
	else
		self.initialPopulate(listbox, 1);
	endif;
epilog
	delete oa;
end;
</source>
        <Parameter name="listbox" type="ListBox"/>
        <Parameter name="level" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="populate" id="653c23e2-fa47-4cdc-b226-ba9ee3cd6cc8">
        <source>populate(listbox: ListBox; level: Integer; at: Integer);
// 35386
vars
	pic : Picture;
begin
	listbox.addItem(itemName);
	listbox.itemLevel[listbox.newIndex] := level;
	listbox.itemObject[listbox.newIndex] := self;
	pic := getPicture(listbox.form.INV_TransactionMap);
	if pic &lt;&gt; null then
		listbox.itemPicture[listbox.newIndex] := pic.picture;
	endif;
	listbox.itemPictureType[listbox.newIndex] := ListBox.ItemPictureType_Closed;

end;
</source>
        <Parameter name="listbox" type="ListBox"/>
        <Parameter name="level" type="Integer"/>
        <Parameter name="at" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setEnableObjects" id="810f179f-d5e1-4815-8c3b-241fdea3b86e">
        <source>setEnableObjects(form: INV_TransactionMap io);

vars

begin

	inheritMethod(form);

	form.modePropertyNew := INV_TransactionMap.ModeProperty_Null; //ModeProperty_TransMap;
	form.modePropertyUpdate := INV_TransactionMap.ModeProperty_Null;
	form.modePropertyDelete := INV_TransactionMap.ModeProperty_Null;
	form.menuSItemNew.enabled := false;
	form.menuMappingNewTMap.enabled := false;
	form.btnNew.enabled := false;


end;</source>
        <Parameter name="form" type="INV_TransactionMap" usage="io"/>
    </JadeMethod>
</Class>
