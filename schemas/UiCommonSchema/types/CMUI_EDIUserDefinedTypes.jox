    <JadeMethod name="cmbFieldType_click" id="33c6b064-b850-4bb5-a70b-383099654b2d">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbFieldType_click(combobox: ComboBox input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	02 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
180608	adm Par 17023 only update User desc when blank	
13/10/2009	cnwcs5		par 20966 - pre-fill user description field
23/04/2014	cnwdap1		PAR #33005 CCMS SFW 1381 Imperial measurements for EDI user defined layouts
----------   ----------  --------------------------------------------------
*/
vars
	entRow		: EntTableRow;
	table		: CM_DataTable;
	col			: Integer;
	heading		: String;
	
begin
	entRow 	:= combobox.listObject.EntTableRow;
	table	:= self.tblFieldMap.getControl(combobox.index);
	
	if entRow = null then
		return;
	endif;
	
	heading := entRow.getHeading(null, self.myTerminal, app.myCurrentLocale);	// par 20966
	if entRow.measurementType &lt;&gt; null then										// PAR #33005
		heading := combobox.text;												// PAR #33005
	endif;																		// PAR #33005
	
	// set field type
	col := table.getColumnByRowName(ETRow_FieldType);  	// par 20966
	table.accessCell (table.row, col).text	:= heading;		// par 20966
	
	// set property name
	col := table.getColumnByRowName(ETRow_PropName);		// par 20966
	table.setCellText(table.row, col, entRow.name);			// par 20966
	
	// set user description
	col := table.getColumnByRowName(ETRow_FieldDescription);	// par 20966

	if table.accessCell(table.row, col).text = null then	// par 20966
		table.accessedCell.text := heading;					// par 20966
	endif;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
