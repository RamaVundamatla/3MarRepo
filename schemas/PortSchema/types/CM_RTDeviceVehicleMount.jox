// -------------------------------------------
vars

begin
	return self.myMachine;


end;</source>
        <ReturnType type="CM_Machine"/>
    </JadeMethod>
    <JadeMethod name="getProcessForMachine" id="4dcfa63d-7601-4aa3-a1f2-d3bde8d5072a">
        <source>getProcessForMachine() : Process;
/*

Purpose:	Only used for Jade Mobile apps not teklogix		

Parameters:			

Return Value:		


Date		Who		Reason
07 Dec 2009	cnwer1	Initial creation
08 Oct 2010 cnwer1 	PAR 25979 - use machine code because same user can be logged into multiple machines
07/03/2011 	cnwmh5	Change write to app.writeStatement
*/

vars
	userName : String;
	aProcess : Process;
	invalidProcess ,found: Boolean;
	allUserInfo 	: StringArray;
begin
	if self.myMachine &lt;&gt; null and self.myMachine.user &lt;&gt; null then
		userName := self.myMachine.user.code;
	else
		return null;
	endif;
	
	on Exception do app.handleDeletedObject(exception, aProcess, invalidProcess);		// PAR #16421
	
	//epr par 17508 10/7/08 jade 6.2 process.userInfo changed from schema name to app name
	create allUserInfo transient;
	allUserInfo.add('JMTVehicleMountedLogon');
	allUserInfo.add('JMTVehicleMountedWithDevice');
	allUserInfo.add('JMTRadioTelemetryThinClient'); //16 sep 2008 cnwdz2 par17935
	allUserInfo.add('VehicleMountedApp'); //epr par 24898 6/7/10
	allUserInfo.add('VehicleMountedWithDevice');
	

	foreach aProcess in Process.instances do
		// we have to have set the process userInfo when we log on to the device id
		//epr par 25979 8/10/10
		if allUserInfo.includes(aProcess.userInfo) and aProcess.userCode = self.myMachine.code then //userName then 
			found:=true;
			break;
		endif;
		
	endforeach;

	//app.writeStatement(found.String ) ;
	if found then
		return aProcess;
	endif;
epilog
	delete allUserInfo;
end;</source>
        <ReturnType type="Process"/>
    </JadeMethod>
