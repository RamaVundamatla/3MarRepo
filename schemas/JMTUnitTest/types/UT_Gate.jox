	assertNotNullMsg(nextTI, "TEST0000003");
	self.move(nextTI ,taSource.allGridControllersByRowColumn[1, 3]);
	self.assertEqualMsg(nextTI.myPrimaryActualLocation, taSource.allGridControllersByRowColumn[1, 3], "Did not move TEST0000003 to correct location");
	
	// Remove all automatic stops
	self.opts.purge;
	self.opts.addAssoc("CENum", "123");
	self.deleteStops(ti);
	self.deleteStops(osTI);
	self.deleteStops(nextTI);

	// Create the Release, looking for the least-overstowed full 2200
	self.opts.purge;
	self.opts.addAssoc("ISOType", "2200");
	self.opts.addAssoc("FullRelease", true);
	releaseRequest := addReleaseByTypeRequestOpts("UTRRRoad", BR_TYPE_ROAD, TI_CargoType_Container);
	assertNotNull(releaseRequest);
	
	// Gate Out
	self.opts.purge;
	self.opts.addAssoc("release", releaseRequest);
	self.opts.addAssoc("BestPick", true);
	vvr := self.gateOutContainer("UTTRUCK", "", "UTDRIVER", null, true, singleGate , taSource.id);
	
	truck := self.getVehicle("UTTRUCK");
	assertEqual(truck.allRoadJobs.size, 1);
	assertEqual(truck.allRoadJobs.first.workListEntries.size, 1);
	assertEqual(truck.allRoadJobs.first.workListEntries.first.getRTLetter(), "Q".String);
	// check that the least-overstowed tracked item has been chosen 
	assertEqual(truck.allRoadJobs.first.workListEntries.first.allRTQueueEntries.first.allTasks.first.ti.id, nextTI.id);

	self.workVehicle(vvr);
	
	self.roadExit(vvr);

epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tReleaseByTypeMTStrat_ISOGroup" id="66a3ab1d-4757-4845-af35-8576105c5ebc">
        <source>tReleaseByTypeMTStrat_ISOGroup();
// cnwdap1
// cnwdw1	
// Test that gate out of a MT "by type" using the MT Release Strategy PAR 23677
vars
	releaseRequest: CM_BulkRelease;
	truck: CM_Vehicle;
	ti: CM_TrackedItem;
	ya: CM_YardAllocation;
	locations : CM_LCArray;
	source: CM_LocationsController;
	yaName: String;
	vvr: CM_VehicleVisitRecord;
	bs2, bs1: CM_BlockStack;
begin
	self.disableAllYA(true);
	deleteReleaseRequest("UTRRRoad");
	deleteVehicle("UTTRUCK");
	self.deleteContainer("TEST0000001");
	self.deleteTerminalArea(self.getProfileSetting(UT_Profile.P_BLOCKSTACK).asString&amp;"1");
	bs1 := addBlockStack(self.getProfileSetting(UT_Profile.P_BLOCKSTACK).asString&amp;"1", 100, null);
	
	ti := self.addContainer("TEST0000001", self.operator, "UT20", "MT", TI_IMEX_STATUS_STORAGE);
	self.move(ti, bs1);
	
	// Create MT Release
	self.opts.purge;
	self.opts.addAssoc("ISOGroup", "UT20");
	releaseRequest := addReleaseByTypeRequestOpts("UTRRRoad", BR_TYPE_ROAD, TI_CargoType_Container);
	assertNotNull(releaseRequest);
	
	// Default strategy is to use YA This should fail cos all YA are disabled
	beginTransaction;
	self.getTerminal().setAutoPlanMTReleaseStrategy(AutoPlanMTRelStrategyYA);  
	commitTransaction;
	
	// Gate Out
	self.opts.purge;
	self.opts.addAssoc("release", releaseRequest);
	vvr := self.gateOutContainer("UTTRUCK", "", "UTDRIVER", null, true, singleGate , null);

	truck := self.getVehicle("UTTRUCK");
	assertEqual(truck.allRoadJobs.size, 1);
	assertEqual(truck.allRoadJobs.first.workListEntries.size, 1);
	assertNotEqual(truck.allRoadJobs.first.workListEntries.first.getRTLetter(), "RT");

	// Check that if there is a YA with a valid container, it is found
	deleteVehicle("UTTRUCK");

	yaName := self.getProfileSetting(UT_Profile.P_YA).asString;
	self.deleteYA(yaName);
	ya := self.addYA1(yaName, YACriteriaType_OperatorItem, self.operator.code, bs1.getLocationsController);

	self.opts.purge;
	self.opts.addAssoc("release", releaseRequest);
	vvr := self.gateOutContainer("UTTRUCK", "", "UTDRIVER", null, true, singleGate , null);

	truck := self.getVehicle("UTTRUCK");
	assertEqual(truck.allRoadJobs.size, 1);
	assertEqual(truck.allRoadJobs.first.workListEntries.size, 1);
	assertEqual(truck.allRoadJobs.first.workListEntries.first.getRTLetter(), "RT");
	assertEqual(truck.allRoadJobs.first.workListEntries.first.allRTQueueEntries.first.allTasks.first.sourceLocationId, bs1.id);
	
	// Set strategy to Terminal, and move the container out of the YA. Should still find it
	beginTransaction;
	self.getTerminal().setAutoPlanMTReleaseStrategy(AutoPlanMTRelStrategyTerminal);  
	commitTransaction;

	self.deleteTerminalArea(self.getProfileSetting(UT_Profile.P_BLOCKSTACK).asString&amp;"2");
	bs2 := addBlockStack(self.getProfileSetting(UT_Profile.P_BLOCKSTACK).asString&amp;"2", 100, null);
	self.move(ti, bs2);
	assertEqual(ti.myPrimaryActualLocation, bs2.getLocationsController);
	
	self.opts.purge;
	self.opts.addAssoc("release", releaseRequest);
	deleteVehicle("UTTRUCK");
	vvr := self.gateOutContainer("UTTRUCK", "", "UTDRIVER", null, true, singleGate , null);

	truck := self.getVehicle("UTTRUCK");
	assertEqual(truck.allRoadJobs.size, 1);
	assertEqual(truck.allRoadJobs.first.workListEntries.size, 1);
	assertEqual(truck.allRoadJobs.first.workListEntries.first.getRTLetter(), "RT"); 

	// Set strategy to Both, and move the container to the YA. Should still find it
	beginTransaction;
	self.getTerminal().setAutoPlanMTReleaseStrategy(AutoPlanMTRelStrategyBoth);  
	commitTransaction;

	self.move(ti, bs1);
	assertEqual(ti.myPrimaryActualLocation, bs1.getLocationsController);
	
	self.opts.purge;
	self.opts.addAssoc("release", releaseRequest);
	deleteVehicle("UTTRUCK");
	vvr := self.gateOutContainer("UTTRUCK", "", "UTDRIVER", null, true, singleGate , null);

	truck := self.getVehicle("UTTRUCK");
	assertEqual(truck.allRoadJobs.size, 1);
	assertEqual(truck.allRoadJobs.first.workListEntries.size, 1);
	assertEqual(truck.allRoadJobs.first.workListEntries.first.getRTLetter(), "RT");
	assertEqual(truck.allRoadJobs.first.workListEntries.first.allRTQueueEntries.first.allTasks.first.sourceLocationId, bs1.id);

	// Set strategy to Both, and move the container out of the YA. Should still find it
	beginTransaction;
	self.getTerminal().setAutoPlanMTReleaseStrategy(AutoPlanMTRelStrategyBoth);  
	commitTransaction;

	self.move(ti, bs2);
	assertEqual(ti.myPrimaryActualLocation, bs2.getLocationsController);
	
	self.opts.purge;
	self.opts.addAssoc("release", releaseRequest);
	deleteVehicle("UTTRUCK");
	vvr := self.gateOutContainer("UTTRUCK", "", "UTDRIVER", null, true, singleGate , null);

	truck := self.getVehicle("UTTRUCK");
	assertEqual(truck.allRoadJobs.size, 1);
	assertEqual(truck.allRoadJobs.first.workListEntries.size, 1);
	assertEqual(truck.allRoadJobs.first.workListEntries.first.getRTLetter(), "RT");
	
epilog
	delete locations;
	self.disableAllYA(false);
end;</source>
    </JadeMethod>
    <JadeMethod name="tReleaseByTypeMTStrat_ISOType" id="110fc0c7-d313-4397-84b7-edc8263348f0">
        <source>tReleaseByTypeMTStrat_ISOType();
// cnwdap1
// cnwdw1	
// Test that gate out of a MT "by type" using the MT Release Strategy PAR 23677
vars
	releaseRequest: CM_BulkRelease;
	truck: CM_Vehicle;
	ti: CM_TrackedItem;
	ya: CM_YardAllocation;
	locations : CM_LCArray;
	source: CM_LocationsController;
	yaName: String;
	vvr: CM_VehicleVisitRecord;
	bs2, bs1: CM_BlockStack;
begin
	self.disableAllYA(true);
	deleteReleaseRequest("UTRRRoad");
	deleteVehicle("UTTRUCK");
	self.deleteContainer("TEST0000001");
	self.deleteTerminalArea(self.getProfileSetting(UT_Profile.P_BLOCKSTACK).asString&amp;"1");
	bs1 := addBlockStack(self.getProfileSetting(UT_Profile.P_BLOCKSTACK).asString&amp;"1", 100, null);

	
	ti := self.addContainer("TEST0000001", self.operator, "UT20", "MT", TI_IMEX_STATUS_STORAGE);
	self.move(ti, bs1);
	
	// Create MT Release
	self.opts.purge;
	self.opts.addAssoc("ISOType", "UT20");
	releaseRequest := addReleaseByTypeRequestOpts("UTRRRoad", BR_TYPE_ROAD, TI_CargoType_Container);
	assertNotNull(releaseRequest);
	
	// Default strategy is to use YA This should fail cos all YA are disabled
	beginTransaction;
	self.getTerminal().setAutoPlanMTReleaseStrategy(AutoPlanMTRelStrategyYA);  
	commitTransaction;
	
	// Gate Out
	self.opts.purge;
	self.opts.addAssoc("release", releaseRequest);
	vvr := self.gateOutContainer("UTTRUCK", "", "UTDRIVER", null, true, singleGate , null);

	truck := self.getVehicle("UTTRUCK");
	assertEqual(truck.allRoadJobs.size, 1);
	assertEqual(truck.allRoadJobs.first.workListEntries.size, 1);
	assertNotEqual(truck.allRoadJobs.first.workListEntries.first.getRTLetter(), "RT");
	
	// Check that if there is a YA with a valid container, it is found
	deleteVehicle("UTTRUCK");
	yaName := self.getProfileSetting(UT_Profile.P_YA).asString;
	self.deleteYA(yaName);
	ya := self.addYA1(yaName, YACriteriaType_OperatorItem, self.operator.code, bs1.getLocationsController);

	self.opts.purge;
	self.opts.addAssoc("release", releaseRequest);
	vvr := self.gateOutContainer("UTTRUCK", "", "UTDRIVER", null, true, singleGate , null);

	truck := self.getVehicle("UTTRUCK");
	assertEqual(truck.allRoadJobs.size, 1);
	assertEqual(truck.allRoadJobs.first.workListEntries.size, 1);
	assertEqual(truck.allRoadJobs.first.workListEntries.first.getRTLetter(), "RT");
	assertEqual(truck.allRoadJobs.first.workListEntries.first.allRTQueueEntries.first.allTasks.first.sourceLocationId, bs1.id);
	
	// Set strategy to Terminal, and move the container out of the YA. Should still find it
	beginTransaction;
	self.getTerminal().setAutoPlanMTReleaseStrategy(AutoPlanMTRelStrategyTerminal);  
	commitTransaction;

	self.deleteTerminalArea(self.getProfileSetting(UT_Profile.P_BLOCKSTACK).asString&amp;"2");
	bs2 := addBlockStack(self.getProfileSetting(UT_Profile.P_BLOCKSTACK).asString&amp;"2", 100, null);
	self.move(ti, bs2);
	assertEqual(ti.myPrimaryActualLocation, bs2.getLocationsController);
	
	self.opts.purge;
	self.opts.addAssoc("release", releaseRequest);
	deleteVehicle("UTTRUCK");
	vvr := self.gateOutContainer("UTTRUCK", "", "UTDRIVER", null, true, singleGate , null);

	truck := self.getVehicle("UTTRUCK");
	assertEqual(truck.allRoadJobs.size, 1);
	assertEqual(truck.allRoadJobs.first.workListEntries.size, 1);
	assertEqual(truck.allRoadJobs.first.workListEntries.first.getRTLetter(), "RT");

	// Set strategy to Both, and move the container to the YA. Should still find it
	beginTransaction;
	self.getTerminal().setAutoPlanMTReleaseStrategy(AutoPlanMTRelStrategyBoth);  
	commitTransaction;

	self.move(ti, bs1);
	assertEqual(ti.myPrimaryActualLocation, bs1.getLocationsController);
	
	self.opts.purge;
	self.opts.addAssoc("release", releaseRequest);
	deleteVehicle("UTTRUCK");
	vvr := self.gateOutContainer("UTTRUCK", "", "UTDRIVER", null, true, singleGate , null);

	truck := self.getVehicle("UTTRUCK");
	assertEqual(truck.allRoadJobs.size, 1);
	assertEqual(truck.allRoadJobs.first.workListEntries.size, 1);
	assertEqual(truck.allRoadJobs.first.workListEntries.first.getRTLetter(), "RT");
	assertEqual(truck.allRoadJobs.first.workListEntries.first.allRTQueueEntries.first.allTasks.first.sourceLocationId, bs1.id);

	// Set strategy to Both, and move the container out of the YA. Should still find it
	beginTransaction;
	self.getTerminal().setAutoPlanMTReleaseStrategy(AutoPlanMTRelStrategyBoth);  
	commitTransaction;

	self.move(ti, bs2);
	assertEqual(ti.myPrimaryActualLocation, bs2.getLocationsController);
	
	self.opts.purge;
	self.opts.addAssoc("release", releaseRequest);
	deleteVehicle("UTTRUCK");
	vvr := self.gateOutContainer("UTTRUCK", "", "UTDRIVER", null, true, singleGate , null);

	truck := self.getVehicle("UTTRUCK");
	assertEqual(truck.allRoadJobs.size, 1);
	assertEqual(truck.allRoadJobs.first.workListEntries.size, 1);
	assertEqual(truck.allRoadJobs.first.workListEntries.first.getRTLetter(), "RT");
	
epilog
	delete locations;
	self.disableAllYA(false);
end;</source>
    </JadeMethod>
    <JadeMethod name="tReleaseByTypeROpsBackToYard" id="9e4273a0-25de-4f40-b50b-8dd515077688">
        <source>tReleaseByTypeROpsBackToYard();

/*

Purpose:			Release and empty using a release request to a vehicle and 
					then drag and drop back to the yard

Parameters:			

Return Value:		


Date				Who		Reason
29 September 2011	cnwmh5	Initial creation

*/
constants
	
	RoadReleaseRequestId			: String = "UTPAR28197ROAD";
	Container1Id					: String = "UTMDHQQ0009";
	Container2Id					: String = "UTMDHQQ0010";
	BlockStackId					: String = "UTMHBS1";
	TruckId							: String = "UTMDHTRUCK";
	DriverId						: String = "UTMDHDRIVER";
	
vars

	releaseRequest					: CM_BulkRelease;
	operator						: CM_Operator;
	container1, 
	container2						: CM_Container;
	blockStack						: CM_BlockStack;
	vvr								: CM_VehicleVisitRecord;
	truck							: CM_Vehicle;
	wle								: CM_YardWLE;
	deliveryRequest					: CM_DeliveryRequest;

begin

	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	self.deleteDriverDetails(DriverId);
	
	// create the road release request
	self.deleteReleaseRequest(RoadReleaseRequestId);
	self.opts.purge();
	self.opts.addAssoc("Number", 5);
	self.opts.addAssoc("FullRelease", false);
	self.opts.addAssoc("CreateDeliveryRequest", true);
	releaseRequest := self.addReleaseByTypeRequest(RoadReleaseRequestId, BR_TYPE_ROAD, TI_CargoType_Container, "UT20");
	self.assertNotNull(releaseRequest);
	
	// create the block stack for the containers
	self.deleteTerminalArea(BlockStackId);
	blockStack := self.addBlockStack(BlockStackId, 10, null);
	self.assertNotNull(blockStack);
	
	// create the containers
	self.deleteContainer(Container1Id);
	container1 := self.addContainerAtLocation(Container1Id, operator, "UT20", "MT", TI_IMEX_STATUS_STORAGE, blockStack);
	self.assertNotNull(container1);
	self.deleteContainer(Container2Id);
	container2 := self.addContainerAtLocation(Container2Id, operator, "UT20", "MT", TI_IMEX_STATUS_STORAGE, blockStack);
	self.assertNotNull(container2);
	
	// gate out container1
	self.deleteVehicle(TruckId);
	self.opts.purge();
	self.opts.addAssoc('release', releaseRequest);
	vvr := self.gateOutContainer(TruckId, "", DriverId, null, true, singleGate, null);
	self.assertNotNull(vvr);
	self.assertEqual(vvr.myRoadJob.workListEntries.size, 1);
	
	// get the truck
	truck := vvr.vehicle;
	self.assertNotNull(truck);
	
	// unqueue the wle
	wle := vvr.myRoadJob.workListEntries.first.CM_YardWLE;
	beginTransaction;
	wle.unQueueWLE(app.myPassport);
	wle.setMyTrackedItem(container1);
	commitTransaction;
	self.assertNoTrxErrorsOrWarnings();
	
	// move container1 to the truck
	self.opts.purge();
	self.opts.addAssoc("SetWorkListEntry", wle);
	self.move(container1, truck);
	
	// move container1 from the truck back to the yard
	self.opts.purge();
	self.opts.addAssoc("SetWorkListEntry", wle);
	self.move(container1, blockStack);
	
	beginTransaction;
	wle.unassignTI();
	commitTransaction;
	
	self.assertEqual(wle.myTrackedItem, null);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tReleaseByTypeWithArea1" id="537b75ce-6b13-40da-9e70-50c92b5d5788">
        <source>tReleaseByTypeWithArea1();
// cnwmp6
/* cnwjre1
	release by type from nominated area, several candidates, no overstow, should choose the first found (last entered)
*/

vars
	taSource: CM_ForkLiftStack;
	ti, nextTI, osTI: CM_TrackedItem;
	releaseRequest: CM_BulkRelease;
	truck: CM_Vehicle;
	vvr: CM_VehicleVisitRecord;

begin
	deleteVehicle("UTTRUCK");
	deleteTerminalArea("UTFORK");
	taSource:= self.addForkLiftStack("UTFORK", 6, 5, 2);
	assertNotNullMsg(taSource, "UTFORK");
	
	self.deleteContainer("TEST0000011");
	self.deleteContainer("TEST0000002");
	self.deleteContainer("TEST0000003");

	// add as STORAGE so the best pick will find them
	self.opts.addAssoc("IMEX", TI_IMEX_STATUS_STORAGE);
	ti := self.addContainerOpts("TEST0000011", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(ti, "TEST0000011");
	self.move(ti ,taSource.allGridControllersByRowColumn[1, 1]);
	self.assertEqualMsg(ti.myPrimaryActualLocation, taSource.allGridControllersByRowColumn[1, 1], "Did not move TEST0000011 to correct location");
	
	osTI:= self.addContainerOpts("TEST0000002", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(osTI, "TEST0000002");
	self.move(osTI ,taSource.allGridControllersByRowColumn[2, 2]);
	self.assertEqualMsg(osTI.myPrimaryActualLocation, taSource.allGridControllersByRowColumn[2, 2], "Did not move TEST0000002 to correct location");
	
	nextTI:= self.addContainerOpts("TEST0000003", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(nextTI, "TEST0000003");
	self.move(nextTI ,taSource.allGridControllersByRowColumn[3, 3]);
	self.assertEqualMsg(nextTI.myPrimaryActualLocation, taSource.allGridControllersByRowColumn[3, 3], "Did not move TEST0000003 to correct location");
	
	// Remove all automatic stops
	self.opts.purge;
	self.opts.addAssoc("CENum", "123");
	self.deleteStops(ti);
	self.deleteStops(osTI);
	self.deleteStops(nextTI);

	// Create the Release
	self.opts.purge;
	self.opts.addAssoc("ISOType", "2200");
	self.opts.addAssoc("FullRelease", true);
	releaseRequest := addReleaseByTypeRequestOpts("UTRRRoad", BR_TYPE_ROAD, TI_CargoType_Container);
	assertNotNull(releaseRequest);
	
	
	//should release the oldest which is the first one created - JLIER1 19/9/25 35637
	nextTI:=ti;
	
	// Gate Out
	self.opts.purge;
	self.opts.addAssoc("release", releaseRequest);
	self.opts.addAssoc("BestPick", true);
	vvr := self.gateOutContainer("UTTRUCK", "", "UTDRIVER", null, true, singleGate , taSource.id);
	
	truck := self.getVehicle("UTTRUCK");
	assertEqual(truck.allRoadJobs.size, 1);
	assertEqual(truck.allRoadJobs.first.workListEntries.size, 1);
	assertEqual(truck.allRoadJobs.first.workListEntries.first.getRTLetter(), "Q".String);
	// check that the first found tracked item has been chosen
	assertEqual(truck.allRoadJobs.first.workListEntries.first.allRTQueueEntries.first.allTasks.first.ti.id, nextTI.id);
	
	self.workVehicle(vvr);
	
	//30 Jun 2021	NDL	TFS 51421 - Now plan it back to the yard
	self.movePlanned( nextTI, taSource.allGridControllersByRowColumn[3, 3] );
	self.assertTrueMsg( nextTI.myPrimaryPlannedLocation = taSource.allGridControllersByRowColumn[3, 3], "Cargo should be planned back to the yard" );
	
	self.roadExit(vvr);
	
	//30 Jun 2021	NDL	TFS 51421 - Planned locations should be cleared on vehicle visit depart.
	self.assertTrueMsg( nextTI.myPrimaryPlannedLocation = null, "Cargo should NO longer be planned back to the yard after departing vehicle visit" );

epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tReleaseByTypeWithArea2" id="2969dc34-d336-442f-8df3-60a3f60eab4f">
        <source>tReleaseByTypeWithArea2();
// cnwmp6
/* cnwjre1
	release by type from nominated area, only one candidate, filtering by commodity
*/

vars
	taSource: CM_ForkLiftStack;
	ti, nextTI, osTI: CM_TrackedItem;
	releaseRequest: CM_BulkRelease;
	truck: CM_Vehicle;
	vvr: CM_VehicleVisitRecord;

begin
	deleteVehicle("UTTRUCK");
	deleteTerminalArea("UTFORK");
	taSource:= self.addForkLiftStack("UTFORK", 6, 5, 2);
	assertNotNullMsg(taSource, "UTFORK");
	
	self.deleteContainer("TEST0000001");
	self.deleteContainer("TEST0000002");
	self.deleteContainer("TEST0000003");

	// add as STORAGE so the best pick will find them
	self.opts.addAssoc("IMEX", TI_IMEX_STATUS_STORAGE);
	ti := self.addContainerOpts("TEST0000001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(ti, "TEST0000001");
	self.move(ti ,taSource.allGridControllersByRowColumn[1, 1]);
	self.assertEqualMsg(ti.myPrimaryActualLocation, taSource.allGridControllersByRowColumn[1, 1], "Did not move TEST0000001 to correct location");
	
	osTI:= self.addContainerOpts("TEST0000002", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(osTI, "TEST0000002");
	self.move(osTI ,taSource.allGridControllersByRowColumn[2, 2]);
	self.assertEqualMsg(osTI.myPrimaryActualLocation, taSource.allGridControllersByRowColumn[2, 2], "Did not move TEST0000002 to correct location");
	
	nextTI:= self.addContainerOpts("TEST0000003", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(nextTI, "TEST0000003");
	self.move(nextTI ,taSource.allGridControllersByRowColumn[3, 3]);
	self.assertEqualMsg(nextTI.myPrimaryActualLocation, taSource.allGridControllersByRowColumn[3, 3], "Did not move TEST0000003 to correct location");
	
	// Remove all automatic stops
	self.opts.purge;
	self.opts.addAssoc("CENum", "123");
	self.deleteStops(ti);
	self.deleteStops(osTI);
	self.deleteStops(nextTI);

	// Create the Release, 
	self.opts.purge;
	self.opts.addAssoc("ISOType", "2200");
	self.opts.addAssoc("FullRelease", true);
	releaseRequest := addReleaseByTypeRequestOpts("UTRRRoad", BR_TYPE_ROAD, TI_CargoType_Container);
	assertNotNull(releaseRequest);
	
	//should release the oldest which is the first one created - JLIER1 19/9/25 35637
	nextTI:=ti;
	
	// Gate Out
	self.opts.purge;
	self.opts.addAssoc("release", releaseRequest);
	self.opts.addAssoc("FullRelease", true);
	self.opts.addAssoc("BestPick", true);
	vvr := self.gateOutContainer("UTTRUCK", "", "UTDRIVER", null, true, singleGate , taSource.id);
	
	truck := self.getVehicle("UTTRUCK");
	assertEqual(truck.allRoadJobs.size, 1);
	assertEqual(truck.allRoadJobs.first.workListEntries.size, 1);
	//assertEqual(truck.allRoadJobs.first.workListEntries.first.getRTLetter(), "Q");	// is Q??
	// check that the first found tracked item has been chosen
	assertEqual(truck.allRoadJobs.first.workListEntries.first.allRTQueueEntries.first.allTasks.first.ti.id, nextTI.id);
	
	self.workVehicle(vvr);
	self.roadExit(vvr);

epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tReleaseByTypeWithTruckUnload" id="cccda7a9-0d6d-44f1-8894-170c7ccfed87">
        <source>tReleaseByTypeWithTruckUnload();
// cnwdap1
/*  cnwdw1
Purpose:	Gate in a Truck for two containers by type, but only pick up one before departing the terminal.
This replicates the problem found in PAR 35282

*/
constants
	
	RoadReleaseRequestId			: String = "UTROAD";
	Container1Id					: String = "UTMDHQQ0009";
	Container2Id					: String = "UTMDHQQ0010";
	BlockStackId					: String = "UTMHBS1";
	TruckId							: String = "UTMDHTRUCK";
	DriverId						: String = "UTMDHDRIVER";
	
vars

	releaseRequest					: CM_BulkRelease;
	operator						: CM_Operator;
	container1, 
	container2						: CM_Container;
	blockStack						: CM_BlockStack;
	vvr								: CM_VehicleVisitRecord;
	truck							: CM_Vehicle;
	wle								: CM_YardWLE;
	deliveryRequest					: CM_DeliveryRequest;

begin

	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	self.deleteDriverDetails(DriverId);
	
	// create the road release request
	self.deleteReleaseRequest(RoadReleaseRequestId);
	self.opts.purge();
	self.opts.addAssoc("Number", 2);
	self.opts.addAssoc("ISOType", "UT20");
	releaseRequest := self.addReleaseByTypeRequestOpts(RoadReleaseRequestId, BR_TYPE_ROAD, TI_CargoType_Container);
	self.assertNotNull(releaseRequest);
	
	// create the block stack for the containers
	self.deleteTerminalArea(BlockStackId);
	blockStack := self.addBlockStack(BlockStackId, 10, null);
	self.assertNotNull(blockStack);
	
	// create the containers
	self.deleteContainer(Container1Id);
	container1 := self.addContainerAtLocation(Container1Id, operator, "UT20", "MT", TI_IMEX_STATUS_STORAGE, blockStack);
	self.assertNotNull(container1);
	self.deleteContainer(Container2Id);
	container2 := self.addContainerAtLocation(Container2Id, operator, "UT20", "MT", TI_IMEX_STATUS_STORAGE, blockStack);
	self.assertNotNull(container2);

	// gate out two containers
	self.deleteVehicle(TruckId);
	self.opts.purge();
	self.opts.addAssoc('release', releaseRequest);
	vvr := addVehicleVisitRecord(TruckId, "", DriverId, singleGate.name);
	self.assertNotNull(vvr);
	
	vvr := self.addVehicleVisitItem(vvr, null, true, null);
	vvr := self.addVehicleVisitItem(vvr, null, true, null);
	vvr := self.completeGateOutContainer(vvr);
	self.assertNotNull(vvr);
	self.assertEqual(vvr.myRoadJob.workListEntries.size, 2);

	// Move first container to truck
	wle := vvr.myRoadJob.workListEntries.first.CM_YardWLE;
	self.assignTiToRoadWLE(container1, wle);

	// unqueue the second container task
	wle := vvr.myRoadJob.workListEntries.last.CM_YardWLE;
	self.unqueueWLE(wle);
	self.moveWLE(wle);
	self.deleteJobEntry(wle);
	
	self.roadExit(vvr);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tReleaseByType_ClientRefUpd" id="1c862df1-8cf9-46c6-9ca0-2d155814f88a">
        <source>tReleaseByType_ClientRefUpd();
// cnwdap1
// cnwdw1	
// Test that gate out of a "by type" release updates Client Ref field on released Container
vars
	releaseRequest: CM_BulkRelease;
	truck: CM_Vehicle;
	ti: CM_TrackedItem;
	ya: CM_YardAllocation;
	locations : CM_LCArray;
	source: CM_LocationsController;
	yaName: String;
	vvr: CM_VehicleVisitRecord;
begin
	self.disableAllYA(true);
	deleteReleaseRequest("UTRRRoad");
	deleteVehicle("UTTRUCK");
	self.deleteContainer("TEST0000001");
	
	// Setup a YA over a block stack that has a cvontainer that could be released
	ti := self.addContainer("TEST0000001", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"UT20", "MT", TI_IMEX_STATUS_STORAGE);
	assertEqual(ti.clientRef, "");
	
	create locations transient;
	locations.add(bs.allLocationsControllers.first.CM_YardController);
	yaName := self.getProfileSetting(UT_Profile.P_YA).asString;
	self.deleteYA(yaName);
	ya := self.addYA1(yaName, YACriteriaType_OperatorItem, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, locations);
	assertFalse(ya.isDisabled);
	self.move(ti, locations.first);
	assertEqual(ti.myPrimaryActualLocation, locations.first);
	
	// Create the Release
	self.opts.purge;
	self.opts.addAssoc("ISOType", "UT20");
	self.opts.addAssoc("FullRelease", false);
	self.opts.addAssoc("CreateDeliveryRequest", true);
	releaseRequest := addReleaseByTypeRequestOpts("UTRRRoad", BR_TYPE_ROAD, TI_CargoType_Container);
	assertNotNull(releaseRequest);
	
	// Make sure that the expected source is found by autoplan
	source := app.sourceTisForRequestYA(self.getTerminal(), releaseRequest.requests.first);
	assertNotNullMsg(source, getYAAutoPlanMessages);
	assertEqual(source.getName(), locations.first.getName());
	
	// Gate Out
	self.opts.purge;
	self.opts.addAssoc("release", releaseRequest);
	self.opts.addAssoc("clientRef", "XXXXX");
	self.opts.addAssoc("GTERemarks", "Bob did it");	//01 Sep 2015	NDL	Par 36839
	vvr := self.gateOutContainer("UTTRUCK", "", "UTDRIVER", null, true, singleGate , null);
	
	truck := self.getVehicle("UTTRUCK");
	assertEqual(truck.allRoadJobs.size, 1);
	assertEqual(truck.allRoadJobs.first.workListEntries.size, 1);
	assertEqual(truck.allRoadJobs.first.workListEntries.first.getRTLetter(), "RT");
	assertEqual(truck.allRoadJobs.first.workListEntries.first.allRTQueueEntries.first.allTasks.first.sourceLocationId, bs.id);
	
	self.assignTiToRoadWLE(ti, truck.allRoadJobs.first.workListEntries.first);
	assertEqual(ti.clientRef, "");
	
	self.roadExit(vvr);
	assertEqual(ti.clientRef, "XXXXX");
	assertEqual(ti.remarks, "Bob did it");		//01 Sep 2015	NDL	Par 36839
	
epilog
	delete locations;
	self.disableAllYA(false);
end;</source>
    </JadeMethod>
    <JadeMethod name="tReleaseByType_ISO" id="af4b897b-9107-4861-9225-20996fb07041">
