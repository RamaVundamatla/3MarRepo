    <JadeMethod name="getNumberOfRows" id="7683f85f-f49e-4898-9ec2-35a63ed3a1dd">
        <source>getNumberOfRows(): Integer;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 August 2009	cnwer1	Initial creation

*/

vars

begin
	if self.myRTGLane.isKindOf(CM_GridArea) then
		return self.myRTGLane.CM_GridArea.numberOfRows;
	elseif self.myRTGLane.isKindOf(CM_RTGLane) then
		return self.myRTGLane.CM_RTGLane.allTAsByTypeId.first.CM_GridArea.numberOfRows;
	endif;
	
	
	
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setMyEndColumn" id="e32ebe7d-0017-47f4-a70a-404a46bd416b">
        <updating/>
        <source>setMyEndColumn(_gridColumn : CM_RTGColumn; _needsNote : Boolean output) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 October 2009	cnwer1	Initial creation

*/

vars

begin
	if (not self.rotated90 and self.flippedHorizontal) or 
		(self.rotated90 and self.flippedVertical) then
		self.myStartColumn:=_gridColumn;
		if  self.myMachine.isBeforePhysicalLimitStart(_gridColumn) then
			self.myStartColumn:= self.myMachine.myPhysicalStartBay;
			_needsNote:=true;
		endif;
	else
		self.myEndColumn:=_gridColumn;
		if  self.myMachine.isAfterPhysicalLimitEnd(_gridColumn) then
			self.myEndColumn:= self.myMachine.myPhysicalEndBay;
			_needsNote:=true;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_gridColumn" type="CM_RTGColumn"/>
        <Parameter name="_needsNote" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="setMyStartColumn" id="c5dbe02f-21d2-41cf-9777-d9a4611d1bd8">
        <updating/>
        <source>setMyStartColumn(_gridColumn : CM_RTGColumn; _needsNote : Boolean output) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 October 2009	cnwer1	Initial creation

*/

vars

begin
	
	
	if (not self.rotated90 and self.flippedHorizontal) or 
		(self.rotated90 and self.flippedVertical) then
		self.myEndColumn:=_gridColumn;
		if  self.myMachine.isAfterPhysicalLimitEnd(_gridColumn) then
			self.myEndColumn:= self.myMachine.myPhysicalEndBay;
			_needsNote:=true;
		endif;
	
	else
		self.myStartColumn:=_gridColumn;
		if  self.myMachine.isBeforePhysicalLimitStart(_gridColumn) then
			self.myStartColumn:= self.myMachine.myPhysicalStartBay;
			_needsNote:=true;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_gridColumn" type="CM_RTGColumn"/>
        <Parameter name="_needsNote" type="Boolean" usage="output"/>
    </JadeMethod>
</Class>
