    <JadeMethod name="getCargoGroupItem" id="10628103-d152-4a7f-ac01-a4e7312a2e95">
        <source>getCargoGroupItem( _id : String ):CM_CargoGroup;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Jul 2015	cnwndl1	Initial creation	Par 36608
05 Jun 2025 navma1  MTN-34114  MTN - Performance Improvements - Remove Class::FirstInstance usage  
*/

vars
	cargoGroup : CM_CargoGroup;
	idUpper	   : String;
begin

	idUpper    := _id.toUpper;																	//05.06.2025 navma1 #MTN-34114
	cargoGroup := self.allCargoGroupsByIdCargoType.getAtKeyGeq( idUpper, null ).CM_CargoGroup;	//05.06.2025 navma1 #MTN-34114
	
	if cargoGroup = null or cargoGroup.id.toUpper &lt;&gt; idUpper then
		return null;
	endif;
	
	return cargoGroup;

epilog

end;</source>
        <Parameter name="_id" type="String"/>
        <ReturnType type="CM_CargoGroup"/>
    </JadeMethod>
    <JadeMethod name="getCargoGroupItemForOperator" id="db57232b-70de-4586-bfc9-bd6a407a1670">
        <source>getCargoGroupItemForOperator(_id : String; _operator : String; _cargoType : Integer):CM_CargoGroup;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 September 2023	navsp1	Initial creation TFS 60518

*/

vars
	cargoGroup, 
	cargoGroupItem, 
	startObject 		: CM_CargoGroup;
	iter				: Iterator;
begin
	iter := self.allCargoGroupsByIdCargoType.createIterator;
	startObject := self.allCargoGroupsByIdCargoType.getAtKeyGeq(_id, _cargoType).CM_CargoGroup;
	if startObject &lt;&gt; null then
		iter.startAtObject( startObject );
		while iter.next( cargoGroupItem ) do
			if cargoGroupItem.id &lt;&gt; _id then
				break;
			endif;
			if _operator &lt;&gt; null then
				if cargoGroupItem.operatorCode = _operator then
					cargoGroup := cargoGroupItem;
					break;
				endif;	
			else
				cargoGroup := cargoGroupItem;
				break;
			endif;
		endwhile;
	endif;
	return cargoGroup;
epilog
	delete iter;
end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_operator" type="String"/>
        <Parameter name="_cargoType" type="Integer"/>
        <ReturnType type="CM_CargoGroup"/>
    </JadeMethod>
