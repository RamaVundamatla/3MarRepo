<PrimType name="Any">
    <JadeMethod name="atcgDisplayWithType" id="6d3ae36f-4c5b-41a9-9a07-eb1daaa8fe3b">
        <source>atcgDisplayWithType():String;

vars
	s:String;
	type:Type;
begin
	type:=self.cnGetType;
	if type = null then
		return "null";
	endif;
	if type.name = "Object" then
		return self.String;
	else
		s:=s&amp;type.name&amp;"=";
		if type = String or type = TimeStamp then
			s:=s&amp;'"'&amp;self.asString&amp;'"';
		else
			s:=s&amp;self.getName;
		endif;
		return s;
	endif;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
</PrimType>
