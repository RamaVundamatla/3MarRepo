    <JadeMethod name="lstHazardList_lostFocus" id="84f146b4-0045-4c39-9657-8386da21f3cc">
        <controlMethod name="CMUI_HazardsListTable::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstHazardList_lostFocus(hazListTable: CMUI_HazardsListTable input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	07 June 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
