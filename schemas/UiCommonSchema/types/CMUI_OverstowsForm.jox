    <JadeMethod name="translateForm" id="6d914fc8-37a0-4b5f-98b0-f3aab0c58b9e">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0018786, locale);
	btnMove.translateCaption(Xlat_0018787, locale);
	btnRefresh1.translateCaption(Xlat_0018788, locale);
	btnRun.translateCaption(Xlat_0018789, locale);
	chkIncludeQ.translateCaption(Xlat_0018790, locale);
	lblOverstowed.translateCaption(Xlat_0018791, locale);
	lblOverstowing.translateCaption(Xlat_0018792, locale);
	lblQuery.translateCaption(Xlat_0018793, locale);
	lblResult.translateCaption(Xlat_0018794, locale);
	mnuColumnOrg.translateCaption(Xlat_0018795, locale);
	mnuContext.translateCaption(Xlat_0018796, locale);
	mnuEditQuery.translateCaption(Xlat_0018797, locale);
	mnuEnquiry.translateCaption(Xlat_0018798, locale);
	mnuInspect.translateCaption(Xlat_0018799, locale);
	mnuMove.translateCaption(Xlat_0018800, locale);
	mnuSendToForm.translateCaption(Xlat_0018801, locale);
	mnuSendToReport.translateCaption(Xlat_0018802, locale);
end;</source>
    </JadeMethod>
