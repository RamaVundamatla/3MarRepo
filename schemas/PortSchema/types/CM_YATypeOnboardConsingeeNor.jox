    </JadeMethod>
    <JadeMethod name="getObjects" id="ed83e1df-fb81-49aa-92ed-86bbef19bffc">
        <source>getObjects(objects: ObjectLongNameDict input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 May 2024	jlier1	Initial creation 63834

*/

vars
	cons: CM_ConsigneeConsignor;
begin
	foreach cons in app.myRoot.allConsigneeConsignors do
		if cons.isConsignee or cons.isConsignor then
			objects[cons.getYAIdentifier] := cons;
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="objects" type="ObjectLongNameDict" usage="input"/>
    </JadeMethod>
