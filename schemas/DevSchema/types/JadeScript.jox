    <JadeMethod name="maTA" id="c431ff7d-7592-4858-a1f6-5b0815736181">
        <source>maTA();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 August 2024		navma1	Initial creation

*/

vars
	ta			 : CM_TerminalArea;
	terminal	 : CM_Terminal;
	bs		 	 : CM_LocationsController;
	lFile      	 : File;
	str			 : String;
begin

	terminal := app.myRoot.allTerminals['WO'];
	
	if terminal = null then
		return;
	endif;
	
	create lFile transient;
	lFile.fileName := "C:\temp\MA\QNS.csv";
	lFile.open;
	
	lFile.writeLine('Terminal Area' &amp; Comma  &amp; 'Yard Allocation' &amp; Comma  &amp; 'Location' &amp; Comma  &amp; 'No Items');
	foreach ta in terminal.allTerminalAreas do
		str := null;
		if ta.allYardAllocations.isNotEmpty then
			str := ta.allYardAllocations.listString("'",CM_YardAllocation::code.name).removeCommas();
		else
			str := null;
		endif;
		foreach bs in ta.allLocationsControllers do
			lFile.writeLine( ta.id 		&amp; Comma  &amp; 
							str    		&amp; Comma  &amp; 
							bs.getID    &amp; Comma &amp; 
							bs.allTrackedItems.size.String);
			
		endforeach;
	
	endforeach;
	lFile.close;
epilog
	delete lFile;
end;</source>
    </JadeMethod>
    <JadeMethod name="maTest" id="902251e5-4ad5-4f49-8e1c-1696de60b9f9">
        <source>maTest();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 January 2020	jlgma1	Initial creation

*/


constants

	TaskDescription = "MATEST";
	
vars
	task : CM_AutoTask;
	tmpClass : Class;
	request	: BGP_Request;
	terminal : CM_Terminal;
	bgpController : BGP_TimerController;
	toDay : TimeStamp;
	found : Boolean;
begin
	app.initialize();
	terminal := CM_Root.firstInstance.allTerminals['MA'];
	app.myPassport.setMyTerminal(terminal);
	app.myPassport.setMyUserFromCode(SUPERUSER_Str);
	foreach task in app.myRoot.allAutoTasks do
		if task.description = TaskDescription then
			found := true;
			break;
		endif;
	endforeach;
	if not found then
		write 'Task (' &amp; TaskDescription &amp; ') not found.';
		return;
	endif;
	app.setIsBackGroundApp(true);
	tmpClass := self.getClass(task.requestClassName);
	if tmpClass = null then
		// Class has not been correctly setup.
		write 'Request class ('&amp;task.requestClassName&amp;') not found.';
		return;
	endif;
	bgpController := BGP_AutoTimerController.firstInstance;

	app.myTrxCA.trxCreateBGPRequestFromTask(tmpClass, request, task, null, app.myPassport);
	app.myTrxUA.trxUpdateBGPControllerPre(bgpController, app.actualTimeServer, request, app.myPassport);
	process.profiler.methodCount := 50;
	process.profiler.start();
	request.action();
	process.profiler.stop();
	process.profiler.report();
	app.myTrxUA.trxUpdateBGPControllerPost(bgpController, app.myPassport);
epilog	
	self.unlock(task);
	app.setIsBackGroundApp(false);
	if task &lt;&gt; null then
		self.unlock(task);
	endif;
	beginTransaction;
	delete request;
	commitTransaction;
end;</source>
    </JadeMethod>
    <JadeMethod name="maTestCancelEstimate" id="8f637beb-c2a0-4dc4-ba59-57a1e7fb9963">
        <source>maTestCancelEstimate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 June 2018	jlgma1	Initial creation

*/

vars
	ca 				: CM_SAPWSConsumerAgent;
	req				: CMIF_SAPAutoCancelReq;
	resp 			: CMIF_SAPWSResponse;
	
begin
	app.initialize();
	
	create ca transient;
	ca.usercode := "IGMT_USER";
	ca.password := "igateway01";
	
	write ca.getDefaultBaseEndpoint;
	
	create req transient;
	req.estimationID := "20180101";
		
	write req.returnAsXMLString() &amp; CrLf;
		
	write "Calling Web Service getExchangeRateRequest_SI";
		
	resp := ca.autocollCancellationRequest_SI(req);
		
	if resp &lt;&gt; null then
		write resp.returnAsXMLString();
	else
		write "&gt;&gt;&gt;&gt; Error, null response";
	endif;
	
epilog
	delete ca;
	delete req;
	delete resp;
	app.finalize();
	
end;
</source>
    </JadeMethod>
