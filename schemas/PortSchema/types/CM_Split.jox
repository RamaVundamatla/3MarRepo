    <JadeMethod name="setFromCMIF_TITransactionCntrl" id="4e3ceb6d-5b66-4f9e-93b2-5488782f49e2">
        <updating/>
        <source>setFromCMIF_TITransactionCntrl(_tiTransCntrl: CMIF_SplitTransController; _passport: CM_Passport input) updating;
// -------------------------------------------
// Created 03 April 2006 by cnwdvb1
// -------------------------------------------
vars

begin
	inheritMethod(_tiTransCntrl, _passport);
	
	self.mode	:= _tiTransCntrl.mode;
	self.action := _tiTransCntrl.action;
	self.unplan	:= _tiTransCntrl.unPlan;
	
	self.myOtherTrackedItem	:= _tiTransCntrl.myOtherTrackedItem;
	
	self.oldQuantity	:= _tiTransCntrl.oldQuantity;
	self.quantity		:= _tiTransCntrl.quantity;
	
	self.oldVolume		:= _tiTransCntrl.oldVolume;
	self.volume			:= _tiTransCntrl.volume;
	
	self.oldWeight		:= _tiTransCntrl.oldWeight;
	self.weight			:= _tiTransCntrl.weight;
	
	//17 Jan 2018	NDL	TFS 36697
	self.oldCargoWeight		:= _tiTransCntrl.oldCargoWeight;
	self.cargoWeight		:= _tiTransCntrl.cargoWeight;
	self.oldTareWeight		:= _tiTransCntrl.oldTareWeight;
	self.tareWeight			:= _tiTransCntrl.tareWeight;
	
	self.locationId 	:=_tiTransCntrl.locationId;
	self.myParentSplit :=_tiTransCntrl.myParentTITransaction.CM_Split;
	


end;</source>
        <Parameter name="_tiTransCntrl" type="CMIF_SplitTransController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setOtherTrackedItem" id="70f28af8-6de0-4d66-9be2-1debcce99ea8">
