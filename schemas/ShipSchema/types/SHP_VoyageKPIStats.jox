    <JadeMethod name="loadDataForFirstTime" id="7565792a-2b5c-428f-88f0-20e7388ab4d4">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
/*

Purpose:			


Return Value:		


Date		Who		Reason
17 August 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

	tmpH : Integer;
begin

	self.splMain.stretchHeight := true;
	
	self.splMain.parent := self.shtVoyageKPI;
	self.fldMain.move(0,self.frmToolbar.clientHeight,self.clientWidth,self.clientHeight);
	self.splMain.top := 0;
	self.splMain.height := self.shtVoyageKPI.clientHeight;
	tmpH := self.clientHeight -  self.frmToolbar.clientHeight - 10;
	self.fldMain.move(0,self.frmToolbar.clientHeight + 2,self.clientWidth,tmpH);
	self.fldMain.cnEcResizeContents();
	self.fldMain.useSheetBackColors := true;
	self.fldMain.useSheetBackColors := true;
	self.fldMain.setDefaultSheetBackColors();
	self.fldMain.initSheetBackColors();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="4df313e3-8971-43f7-b9dd-17ac8c843c55">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
17 August 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	self.useTableInfo := false;
	self.usesQueryFrame:=true;
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.showToolbar := true;
	inheritMethod();

	//self.addToolbarControls;
	self.initTable;
	


epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="3fadba5f-91a1-4ea8-a1b0-8b8fea394e46">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
//	self.translateCaption(Xlat_0017678, locale);
	btnTodayArrivals.translateBubbleHelp(Xlat_0006830, locale);
	btnTodayArrivals.translateCaption(Xlat_0006831, locale);
	btnTodayDepart.translateBubbleHelp(Xlat_0006832, locale);
	btnTodayDepart.translateCaption(Xlat_0006833, locale);
	btnTodayInPort.translateBubbleHelp(Xlat_0006834, locale);
	btnTodayInPort.translateCaption(Xlat_0006835, locale);
	grpDateRange.translateCaption(Xlat_0006836, locale);
	lblArrivalsFrom.translateCaption(Xlat_0006837, locale);
	lblArrivalsTo.translateCaption(Xlat_0006838, locale);
	lblDepartFrom.translateCaption(Xlat_0006839, locale);
	lblDepartTo.translateCaption(Xlat_0006840, locale);
	lblInPortFrom.translateCaption(Xlat_0006841, locale);
	lblInPortTo.translateCaption(Xlat_0006842, locale);
	lblVessel.translateCaption(Xlat_0006843, locale);
	shtDelays.translateCaption(Xlat_0006844, locale);
	shtVoyageKPI.translateCaption(Xlat_0006845, locale);
end;</source>
    </JadeMethod>
