    <JadeMethod name="getEmailAddresses" id="15af358e-0e5f-4310-94aa-e75535e5a072">
        <source>getEmailAddresses() protected;

/*
Date		Who		Reason
07 May 2010	cnwar2	#22273

*/
vars
	strArr 	: HugeStringArray;
	str		: String;
	email	: CM_EmailEntity;
	user	: CM_User;
	
begin
	create strArr transient;
	self.myEmailController.clear();
	// 33797 users who have 'system email access' sees all in CMUI_RecipientSelector so don't filter by user here so that the addresses get passed across to CMUI_RecipientSelector
	// 	otherwise restricted to just the email addresses they can explicitly see
	if not app.myPassport.myUser.canDo(self.myTerminal, PmAdmEmailSystem) then
		user := app.getMyUser();
	endif;
	
	self.txtToAddress.text.getTokensForDelimiterHuge(';', strArr);
	foreach str in strArr do
		email := app.myRoot.getEmailAddressForUser(str, user);
		if email &lt;&gt; null then
			self.myEmailController.addEmailAddress(email, CMIF_EmailTemplateController.Mode_To);
		endif;
	endforeach;
	
	strArr.clear;
	self.txtCcAddress.text.getTokensForDelimiterHuge(';', strArr);
	foreach str in strArr do
		email := app.myRoot.getEmailAddressForUser(str, user);
		if email &lt;&gt; null then
			self.myEmailController.addEmailAddress(email, CMIF_EmailTemplateController.Mode_CC);
		endif;
	endforeach;
	
	strArr.clear;
	self.txtBccAddress.text.getTokensForDelimiterHuge(';', strArr);
	foreach str in strArr do
		email := app.myRoot.getEmailAddressForUser(str, user);
		if email &lt;&gt; null then
			self.myEmailController.addEmailAddress(email, CMIF_EmailTemplateController.Mode_BCC);
		endif;
	endforeach;
	
epilog
	delete strArr;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="load" id="542756ea-ab19-4be8-a6f1-2e7baa4e8fc1">
