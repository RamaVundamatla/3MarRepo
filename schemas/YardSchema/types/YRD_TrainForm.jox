    <JadeMethod name="btnExportSave_click" id="2b53b9b3-e54a-46e5-a341-23a8351ab519">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnExportSave_click(btn: Button input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 August 2009	cnwndl1	Initial creation

*/

vars

	exportCaption : String;
	
begin

	if optWagons.value then
		if optDirInTB.value then
			exportCaption := app.getErrorString(Wagons) &amp; "_" &amp; app.getErrorString(Inward);
		else
			exportCaption := app.getErrorString(Wagons) &amp; "_" &amp; app.getErrorString(Outward);
		endif;
		self.tblWagons.outputAsCSV(exportCaption &amp; ".csv");
	elseif optTrans.value then
		exportCaption := app.getErrorString(Transactions);
		self.tblTrans.outputAsCSV(exportCaption &amp; ".csv");
	elseif optCargoStat.value then
		exportCaption := app.getErrorString(Cargo) &amp; "_" &amp; app.getErrorString(Statistics);
		self.tblCargoStat.outputAsCSV(exportCaption &amp; ".csv");
	elseif optWagonStat.value then
		exportCaption := app.getErrorString(Wagon) &amp; "_" &amp; app.getErrorString(Statistics);
		self.tblWagonStat.outputAsCSV(exportCaption &amp; ".csv");
	endif;

	self.frmExport.visible := false;

epilog

end;</source>
