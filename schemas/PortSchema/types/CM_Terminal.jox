    <JadeMethod name="removeVoyageFromDict" id="bb5ca332-054f-49bd-871c-3a83c2152bdc">
        <source>removeVoyageFromDict(pVoyage : CM_Voyage; pGiveError : Boolean);
// ---------------------------------------------------------------------------
// Created:     26 September 2001 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.removeVoyageFromNewDict(pVoyage, pGiveError);
end;</source>
        <Parameter name="pVoyage" type="CM_Voyage"/>
        <Parameter name="pGiveError" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="removeVoyageFromNewDict" id="a644b4b0-ea2c-4df3-87f4-1cd975706618">
        <source>removeVoyageFromNewDict(pVoyage : CM_Voyage; pGiveError : Boolean);
// ---------------------------------------------------------------------------
// Created:     26 September 2001 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
12 Aug 2008	cnwkpd1	PAR #17719 - Change removeKey to removeKeyEntry to handle duplicate keys

*/

vars
	voyCol	: CM_VoyageByCodeArrivalDTDict;
	tmpVoy	: CM_Voyage;

begin
	
	if pVoyage.isTransient then
		// Transient voyages should not be in this dict!
		return;
	endif;
	
	voyCol := self.allVoyagesNew;
	exclusiveLock(pVoyage);
	exclusiveLock(voyCol);

	if pVoyage.code.trimRight &lt;&gt; null then
		// Update rather than an add so need to remove the old code from the dict
		tmpVoy := voyCol[pVoyage.code.trimRight, pVoyage.arrivedDT];
	
		if tmpVoy &lt;&gt; null and tmpVoy &lt;&gt; pVoyage then
			// The voyage in the dict with the current key is NOT self 
			if pGiveError then
				app.writeLog("Voyage not removed due to potential corruption.", LogDEBUG);
				app.raiseUnexpectedProgramError(class.name, method.name, 
												'Potential corruption in voyages dict for voyage (' &amp; pVoyage.code &amp; 
												') on terminal (' &amp; self.name &amp; ')');
				return;
			endif;
		elseif tmpVoy &lt;&gt; null then
			voyCol.removeKeyEntry(pVoyage.code.trimRight, pVoyage.arrivedDT, tmpVoy);		// PAR #17719
		else
			voyCol.removeObject(pVoyage);
		endif;
	endif;

	if pVoyage.inwardCode.trimRight &lt;&gt; null then
		// Update rather than an add so need to remove the old code from the dict
		tmpVoy := voyCol[pVoyage.inwardCode.trimRight, pVoyage.arrivedDT];
	
		if tmpVoy &lt;&gt; null and tmpVoy &lt;&gt; pVoyage then
			// The voyage in the dict with the current key is NOT self 
			if pGiveError then
				app.writeLog("Voyage not removed due to potential corruption.", LogDEBUG);
				app.raiseUnexpectedProgramError(class.name, method.name, 
												'Potential corruption in voyages dict for voyage (' &amp; pVoyage.inwardCode &amp; 
												') on terminal (' &amp; self.name &amp; ')');
				return;
			endif;
		elseif tmpVoy &lt;&gt; null then
			//15705 - when archiving a voyage, both instances should be removed from the allVoyagesNew collection
			voyCol.removeKeyEntry(pVoyage.inwardCode.trimRight, pVoyage.arrivedDT, tmpVoy);			// PAR #17719
			app.writeLog("Voyage removed.", LogDEBUG);
		else
			voyCol.removeObject(pVoyage);
		endif;
	endif;
end;</source>
        <Parameter name="pVoyage" type="CM_Voyage"/>
        <Parameter name="pGiveError" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="request1StopVBS" id="a9446f25-846f-4a16-aad0-933409e1c0e7">
        <source>request1StopVBS(_bookingRequest : CMIF_1StopBookingRequest input; _response : CMIF_1StopBookingResponse output) : Boolean;
/*

Purpose:			Requests a vehicle bookign from one stop. By sending a HTTP REST POST web request

Parameters:			

Return Value:		

Date		Who		Reason
22 December 2021	navpw1	Initial creation TFS: 52268

*/

vars
	agent : CM_1StopVBSConsumerAgent;
	url : String;
	verb : String;
	requestData : String;
	resultCode : Integer;
	resultString : String;
	response : CMIF_Object;
	pxyActivity, requestActivity : CM_EWSActivity1Stop;
	
begin
	if not app.myPassport.myUser.canDo(self, PmGateReleaseRequestByPin) then
		app.raiseCMException1(NoPermission, "access 1-Stop VBS", null, null);
		return false;
	endif;
	
	url := self.myActive1StopVBSWebServiceDef.baseEndPointBookingSlots;
	verb := "POST";
	
	create agent transient;
	agent.my1StopWebService := self.myActive1StopVBSWebServiceDef;
	requestData := agent.buildVBSlotRequestMessage(self.myActive1StopVBSWebServiceDef, _bookingRequest);
	
	// log the request
	app.writeLog(method.qualifiedName &amp; Tab &amp; "Sending request to 1-Stop: '" &amp; requestData &amp; "'", LogDEBUG);
	create pxyActivity transient;
	pxyActivity.initialiseActivity(	_bookingRequest.getActivityDescription &amp; CrLf &amp; requestData, 
									self.myActive1StopVBSWebServiceDef.name, 
									self, 
									null,
									"A".Character,
									CM_1StopVBSWebServiceDef.Type_SlotRequest,
									false,
									null	);
	requestActivity := app.myTrxCA.trxCreateEWSActivityHistory(pxyActivity, app.myPassport).CM_EWSActivity1Stop;
	delete pxyActivity;
	
	// now send the request
	agent.context := agent.Context_SlotRequest;
	resultString := agent.doSendHTTPRequest(url, verb, agent.getAdditionalHeadersForHTTP(), requestData, resultCode);
	
	if resultCode = HttpResponseNoContent then
		create response as CMIF_1StopBookingResponse transient;
		response.CMIF_1StopBookingResponse.success := false;
		response.CMIF_1StopBookingResponse.description := HttpResponseNoContent.String;
		_response := response.CMIF_1StopBookingResponse;
		if requestActivity &lt;&gt; null then
			app.myTrxUA.trxUpdateEWSActivityStatus(requestActivity, BGP_OpsViewWSRequest.EWS_STATUS_BGP_NODATA, app.myPassport);
		endif;
		app.writeLog(method.qualifiedName &amp; Tab &amp; "NODATA: Response from 1-Stop was" &amp; resultCode.String &amp; ":" &amp; resultString, LogERROR);
		return true;
	elseif resultCode &lt;&gt; HttpResponseOK or resultString = null then
		_response := null;
		if requestActivity &lt;&gt; null then
			app.myTrxUA.trxUpdateEWSActivityStatus(requestActivity, BGP_OpsViewWSRequest.EWS_STATUS_BGP_SENT_FAILURE, app.myPassport);
		endif;
		app.writeLog(method.qualifiedName &amp; Tab &amp; "FAILED: Response from 1-Stop was" &amp; resultCode.String &amp; ":" &amp; resultString, LogERROR);
		return false;
	endif;
	
	// Log the response
	app.writeLog(method.qualifiedName &amp; Tab &amp; "Response from 1-Stop was " &amp; resultCode.String &amp; ":" &amp; resultString, LogDEBUG);
	create pxyActivity transient;
	pxyActivity.initialiseActivity(	_bookingRequest.getActivityDescription &amp; CrLf &amp; resultString, 
									self.myActive1StopVBSWebServiceDef.name, 
									self, 
									null,
									"A".Character,
									CM_1StopVBSWebServiceDef.Type_SlotRequestResponse,
									false,
									null	);
	requestActivity := app.myTrxCA.trxCreateEWSActivityHistory(pxyActivity, app.myPassport).CM_EWSActivity1Stop;
	delete pxyActivity;
	
	// Convert the result string to a JSON object then to a CMIF_1StopBookingResponse
	if not agent.parseJSONResponse(resultString, agent.Context_SlotRequest, response) then
		app.writeLog(method.qualifiedName &amp; " JSON Exception - unable to parse 1-Stop VBS response. Check Activty History for request/response.", LogERROR);
		app.raiseCMException(MACS3_JSON_PARSE_ERR, null, null);
		return false;
	endif;
	
	_response := response.CMIF_1StopBookingResponse;
	return true;
	
epilog
	delete agent;
	delete pxyActivity;
end;</source>
        <Parameter name="_bookingRequest" type="CMIF_1StopBookingRequest" usage="input"/>
        <Parameter name="_response" type="CMIF_1StopBookingResponse" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="requiresToDoTask" id="2e90c0dc-1916-4676-93a4-c7438b6c00cf">
        <source>requiresToDoTask(_trans: CM_TITransaction; _array: CM_ToDoTaskDescArray input; _creation, _completion: IntegerArray input): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 August 2016	cnwmp6	Initial creation	TFS 2443

*/

vars
	type: Integer;
	ti: CM_TrackedItem;
	iter: Iterator;
	taskCriteria: CM_TaskCriteria;
begin
	type := _trans.type;
	ti := _trans.myTrackedItem;
	if type &lt; 1 or ti = null or _array = null then
		return false;
	endif;
	_array.clear();
	
	iter := self.allTaskCriteria.createIterator;
	while iter.next(taskCriteria) do
		if not taskCriteria.allAutoApplyActions.includes(type) then
			continue;
		endif;
		if not taskCriteria.matches(ti) then
			continue;
		endif;
		_array.add(taskCriteria.myToDoTaskDesc);
		_creation.add(taskCriteria.moveOnCreation);
		_completion.add(taskCriteria.moveOnCompletion);
	endwhile;
epilog
	delete iter;
end;</source>
        <Parameter name="_trans" type="CM_TITransaction"/>
        <Parameter name="_array" type="CM_ToDoTaskDescArray" usage="input"/>
        <Parameter name="_creation" type="IntegerArray" usage="input"/>
        <Parameter name="_completion" type="IntegerArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="resetGateTransactionNumber" id="06a3e6bc-adaf-441e-bfbc-068fcd7ed9c5">
        <source>resetGateTransactionNumber();
// ---------------------------------------------------------------------------
// Created:     December 2008 ANDREW BISHOP
//
// Purpose:      // PAR 17703 AKB2008AUG
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

constants
	KeyDesc = 'Gate Transaction Number';
vars
	theKeySeries 	: CM_KeySeries;
	seriesKey		: CM_SeriesKey;
	len, strt, root 			: Integer;	
	tmp, tmp2 : String;
	localTrans : Boolean;
begin
	
	if not process.isInTransactionState then
		beginTransaction;
		localTrans := true;
	endif;
	theKeySeries := self.allKeySeriesByCode[SN_RoadJobTransactionNumber];
	
	if theKeySeries = null then
		create theKeySeries persistent;
		theKeySeries.set(SN_RoadJobTransactionNumber, KeyDesc, self);
		create seriesKey persistent;
		
		strt := self.getConfig(GateTransactionNumStart).Integer;
		if strt.String.length &gt; len then
			strt := 1;
		endif;
		seriesKey.set(null, strt);
		theKeySeries.nextKey := seriesKey;
	else
		seriesKey := theKeySeries.nextKey;
		
		// RESET
		strt := self.getConfig(GateTransactionNumStart).Integer;
		if strt.String.length &gt; len then
			strt := 1;
		endif;
		seriesKey.set(null, strt);
	endif;

	lock(theKeySeries, Reserve_Lock, Transaction_Duration, 5000);

	theKeySeries.reserve(app.computerName, process.signOnUserCode, tmp, root, tmp2);
	theKeySeries.issue(app.computerName, process.signOnUserCode);


epilog
	if localTrans then
		commitTransaction;
	endif;
	unlock(theKeySeries);		
end;</source>
    </JadeMethod>
    <JadeMethod name="roadExit1StopVBS" id="6e2b7f4b-ccd0-4b5d-a7e7-c54853fda662">
        <source>roadExit1StopVBS(_roadExitRequest : CMIF_1StopRoadExitRequest; _response : CMIF_Object output) : Boolean;
/*

Purpose:			Sends road exit / vehicle visit information to 1-Stop's VBS

Parameters:			

Return Value:		

Date		Who		Reason
16 December 2021	navpw1	Initial creation TFS: 52268

*/

vars
	agent : CM_1StopVBSConsumerAgent;
	url : String;
	verb : String;
	requestData : String;
	resultCode : Integer;
	resultString : String;
	response : CMIF_Object;
	pxyActivity, requestActivity : CM_EWSActivity1Stop;
	
begin
	url := self.myActive1StopVBSWebServiceDef.baseEndPointGateEvent;
	verb := "POST";
	
	create agent transient;
	requestData := agent.buildRoadExitRequestMessage(self.myActive1StopVBSWebServiceDef, _roadExitRequest);
	
	// log the request
	app.writeLog(method.qualifiedName &amp; Tab &amp; "Sending request to 1-Stop: '" &amp; requestData &amp; "'", LogDEBUG);
	create pxyActivity transient;
	pxyActivity.initialiseActivity(	_roadExitRequest.getActivityDescription &amp; CrLf &amp; requestData, 
									self.myActive1StopVBSWebServiceDef.name, 
									self, 
									null,
									"A".Character,
									CM_1StopVBSWebServiceDef.Type_GateEvent,
									false,
									null	);
	requestActivity := app.myUtilityCA.utlCreateEWSActivityHistory(pxyActivity, app.myPassport).CM_EWSActivity1Stop;
	delete pxyActivity;
	
	// now send the request
	agent.context := agent.Context_RoadExit;
	resultString := agent.doSendHTTPRequest(url, verb, agent.getAdditionalHeadersForHTTP(), requestData, resultCode);
	
	if resultCode &lt;&gt; HttpResponseOK or resultString = null then
		_response := null;
		if requestActivity &lt;&gt; null then
			app.myUtilityUA.utlUpdateEWSActivityStatus(requestActivity, BGP_OpsViewWSRequest.EWS_STATUS_BGP_SENT_FAILURE, app.myPassport);
		endif;
		app.writeLog(method.qualifiedName &amp; Tab &amp; "FAILED: Response from 1-Stop was " &amp; resultCode.String &amp; ":" &amp; resultString, LogERROR);
		return false;
	endif;
	
	// Log the response
	app.writeLog(method.qualifiedName &amp; Tab &amp; "Response from 1-Stop was " &amp; resultCode.String &amp; ":" &amp; resultString, LogDEBUG);
	create pxyActivity transient;
	pxyActivity.initialiseActivity(	_roadExitRequest.getActivityDescription &amp; CrLf &amp; resultString, 
									self.myActive1StopVBSWebServiceDef.name, 
									self, 
									null,
									"A".Character,
									CM_1StopVBSWebServiceDef.Type_GateEventResponse,
									false,
									null	);
	requestActivity := app.myUtilityCA.utlCreateEWSActivityHistory(pxyActivity, app.myPassport).CM_EWSActivity1Stop;
	delete pxyActivity;
	
	// Convert the result string to a JSON object then to a CMIF_1StopRoadExitResponse
	if not agent.parseJSONResponse(resultString, agent.Context_RoadExit, response) then
		app.writeLog(method.qualifiedName &amp; " JSON Exception - unable to parse 1-Stop VBS Road Exit response. Check Activty History for request/response.", LogERROR);
		app.raiseCMException(MACS3_JSON_PARSE_ERR, null, null);
		return false;
	endif;
	
	_response := response.CMIF_1StopRoadExitResponse;
	return true;
	
epilog
	delete agent;
	delete pxyActivity;
end;</source>
        <Parameter name="_roadExitRequest" type="CMIF_1StopRoadExitRequest"/>
        <Parameter name="_response" type="CMIF_Object" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="roadProcessIs1StopVBS" id="4cdb24d6-3b10-4fcd-ae1d-6954c9618795">
