    <JadeMethod name="appendToOriginalFile" id="e6dfc836-2aca-4f02-8784-377a3f3ed081">
        <source>appendToOriginalFile(_originalFile, _temporarySecondaryFile : String) protected;
// ---------------------------------------------------------------------------
// Created:     07 December 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

	orginalFile, 
	tempFile	: File;
	blob		: Binary;
begin

	// For Northport and there network.
	//process.sleep(5000); //09/03/2010 cnwdz2 22817
	create orginalFile transient;
	orginalFile.mode		:=	File.Mode_Append;
	orginalFile.shareMode	:=	File.Share_Exclusive;
	orginalFile.kind		:=	File.Kind_Binary;
	orginalFile.fileName	:= 	_originalFile;
	// Create file.
	if not orginalFile.tryOpen() then
		app.writeLog(class.name &amp; '::' &amp; method.name &amp; " - " &amp; 'Could not open file : ' &amp; _originalFile, LogINFO);
		if not app.isWebApp then
			app.msgBox('Cannot open file ' &amp; _originalFile, 'Open', 0);
		endif;
		return;		
	endif;
	
	create tempFile transient;
	tempFile.mode		:=	File.Mode_Input;
	tempFile.shareMode	:=	File.Share_Exclusive;
	tempFile.kind		:=	File.Kind_Binary;
	tempFile.fileName	:= 	_temporarySecondaryFile;
	if not tempFile.tryOpen() then
		app.writeLog(class.name &amp; '::' &amp; method.name &amp; " - " &amp; 'Could not open file : ' &amp; _temporarySecondaryFile, LogINFO);
		if not app.isWebApp then
			app.msgBox('Cannot open file ' &amp; _temporarySecondaryFile, 'Open', 0);
		endif;
		return;
	endif;
	
	blob := tempFile.readBinary(tempFile.fileLength);
	orginalFile.writeBinary(blob);
	
	tempFile.close;
	orginalFile.close;
	tempFile.purge;
epilog
	delete tempFile;
	delete orginalFile;
end;</source>
        <access>protected</access>
        <Parameter name="_originalFile" type="String"/>
        <Parameter name="_temporarySecondaryFile" type="String"/>
    </JadeMethod>
    <JadeMethod name="create" id="23296a02-aea1-4912-b47f-fcd3a4e3cae3">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     10 September 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.myJadeReportWriterManager := app.createReportWriterManager();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="createNoOutputReportIfRequired" id="188be811-61c1-4695-a016-073a2e27ee1e">
        <source>createNoOutputReportIfRequired(	jadeReport : JadeReportWriterReport io;
								_formatOption : Integer;
								pxyJadeReport : JadeReport input;
								tmpJadeReport : JadeReport io;
								_clientStartTime : TimeStamp
								);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Sep 2015	cnwndl1	Initial creation	Par 36205
17 Nov 2015	cnwkpd1	PAR #37177 - XML parser error parsing HTML files

*/

vars
	replacingName : String;
	repName : String;
	jrwTransient : CM_JRWTransient;
	replacementFileTS : TimeStamp;
	
	file : File;
	s:String;
	foundBody:Boolean;
	noData:Boolean;
	
begin
	if not app.isWebApp then
		return;
	endif;

	if not pxyJadeReport.printArray.isEmpty then
		return;
	endif;
	
	if self.fileName = null then
		// If there is no output file, then there's no issue
		return;
	
	else
		//cnwmc5 - 22 Jan 2016 - PAR 37207
		if self.fileName.toUpper.pos(".HTML",1) &lt;= 0 then
			// If the file is NOT HTML, stop looking..
			return;
		endif;
		
		replacementFileTS.setDate(null);
		replacementFileTS.setTime(null);

		// If there should be an output file, then need to check it exists and that the creation time
		// is after the start of this initiation, otherwise it could be an old file being returned
		create file transient;
		file.fileName					:= self.fileName;
		file.mode						:=	File.Mode_Input;
		file.shareMode					:=	File.Share_Read;
		//file.kind						:= 	File.Kind_Binary;
		file.kind						:=	File.Kind_Unknown_Text;	// 1/3/16 cnwmp6 PAR 36286 unicode version
		if file.isAvailable() then
			if file.tryOpen then
				// file exists.  
				replacementFileTS.setDate( file.lastModifiedTime.Date );
				replacementFileTS.setTime( file.lastModifiedTime.Time );
				
				//cnwmc5 - 22 Jan 2016 - PAR 37207
				while not file.endOfFile do
					s := file.readLine;
					
					if foundBody then
						if s.cnContains("&lt;/body&gt;") then
							noData := true;
						endif;
						break;
					endif;
					
					if s.cnContains("&lt;body&gt;") then
						foundBody := true;
					endif;
				endwhile;
				
				file.close;
				
				if replacementFileTS &gt;= _clientStartTime then
					if not noData then
						return;
					endif;
				endif;
			endif;
		endif;
	endif;
	
	// If the file doesn't exist, or it is an old one, then need to create the special
	// "No Data Report" output
	replacingName := self.myQryReport.reportName;
	if  app.myQAFilter &lt;&gt; null and not app.myQAFilter.allJRWTransients.isEmpty then
		jrwTransient := app.myQAFilter.allJRWTransients.first;
		if jrwTransient &lt;&gt; null then
			jrwTransient.reportName := replacingName;
		endif;
	endif;

	delete jadeReport;
	jadeReport := null;
	
	delete tmpJadeReport;
	tmpJadeReport := null;

	repName := 'CM_NoDataRpt';

	app.printer.abort();

	jadeReport := self.myJadeReportWriterManager.getReport(repName);

	if jadeReport = null then
		app.writeLog('JRW Report (' &amp; repName &amp; ') not found', LogINFO);
		app.raiseCMException2(ERR_INVALID_VALUE, "the report name: " &amp; repName, "Contact Developer", null,null);
		return;
	endif;
	
	if self.outputtingToFile then
		jadeReport.setOutputFileTitle(self.fileName);
	else
		jadeReport.setPreviewOptions(false, false, false, false, null);	
	endif;
	
	jadeReport.setOutputDestination(_formatOption);
	// Set print preview to false to force to object rather than printer output.
	app.printer.printPreview := false;
	app.printer.setReport(pxyJadeReport);

	self.setParameters(jadeReport);

	app.printer.suppressDialog := true;
	
	jadeReport.run;

	tmpJadeReport := pxyJadeReport.cloneSelf(true);
	tmpJadeReport.description := self.myQryReport.heading;
	
epilog

	delete file;
	
end;</source>
        <Parameter name="jadeReport" type="JadeReportWriterReport" usage="io"/>
        <Parameter name="_formatOption" type="Integer"/>
        <Parameter name="pxyJadeReport" type="JadeReport" usage="input"/>
        <Parameter name="tmpJadeReport" type="JadeReport" usage="io"/>
        <Parameter name="_clientStartTime" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="delete" id="e512fbe2-e607-4502-9777-2ebc221f355c">
        <updating/>
        <source>delete() updating;
// ---------------------------------------------------------------------------
// Created:     09 September 2004 by cnwrs2
//
// Purpose:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 18 Mar 2010	consw1		PAR #22886 - Leaking report transients
// ---------------------------------------------------------------------------
vars

begin

	delete self.myJadeReportWriterManager;
	delete self.myJRWReport;

	self.allTransientsToPurge.purge();
	self.allCriteriaLineHolders.purge();
	self.allAllowedTransactionTypes.purge();

end;</source>
    </JadeMethod>
