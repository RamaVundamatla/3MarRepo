    <JadeMethod name="initTableData" id="28ccb16c-763b-45f8-b768-ca9ffb6b18b5">
        <source>initTableData(_theEntDef : String);
// ---------------------------------------------------------------------------
// Created:		09 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

	tbl		: CM_DataTable;
	entTableDef	: EntTableDef;
	
begin

	tbl := self.tblData;
		
	entTableDef := app.myController.getEntTableDef(ETDef_SpaceUtilise);
	if entTableDef = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Def (' &amp; ETDef_SpaceUtilise &amp; ') not found');
		return;
	endif;
	self.tblData.setTblDataEntRowsArray(entTableDef, null, null);
	self.tblData.accessRow(1).height := 32;
	self.tblData.accessRow(1).wordWrap := true; 
	self.tblData.sortColumn[1] := null;
	return;
		
end;</source>
        <Parameter name="_theEntDef" type="String"/>
