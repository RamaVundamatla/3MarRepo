    <JadeMethod name="setPictures" id="33c426a1-06c5-47e2-97ad-c79061b4f2a1">
        <updating/>
        <source>setPictures(_openPic, _closedPic : Binary) updating;
// ---------------------------------------------------------------------------
// Created:     02 April 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.binPicOpen := _openPic;
	self.binPicClosed := _closedPic;

