    <JadeMethod name="btnStart_click" id="3bc17ab6-aaeb-4101-8256-52e3a83efa68">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnStart_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		18 March 2009 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	
	if self.startGenertate() then
		app.msgBox(	"The form/control translation scan and schema generation has completed.",
					"Translation",
					MsgBox_OK_Only + MsgBox_Information_Icon);
	else
		app.msgBox(	DevSchema.name &amp; "::" &amp; FormCaptionsAgent.name &amp; "::" &amp; FormCaptionsAgent::loadDefinedFormConstants.name &amp; " has failed.",
					app.getString(Error),
					MsgBox_OK_Only + MsgBox_Information_Icon);
	endif;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="dobrowseForFolder" id="33c9b829-7333-4797-a7d7-d4221a03333c">
        <source>dobrowseForFolder() protected;
// --------------------------------------------------------------------------------
// Created:		18 March 2009 by cnwdad1
//
// Purpose:		Browses for a local file directory name.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 17/03/2015	cnwmh5		Transient Leak
// --------------------------------------------------------------------------------
vars
	folderName		: String;
	fileFolderObj	: FileFolder;
	
begin
	create fileFolderObj transient;
	folderName	:=	fileFolderObj.browseForFolder("Select a directory to write the schema files to:", null);
	
	if folderName &lt;&gt; null then
		txtFolder.cnEcSet(folderName);
	endif;
	
epilog
	delete fileFolderObj;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="af49d372-6f4f-4f2b-86f4-9096bd03c7f7">
        <updating/>
        <source>setupForm() updating;
// --------------------------------------------------------------------------------
// Created:		18 March 2009 by cnwdad1
//
// Purpose:		Standard form setup method.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod();
	
	self.centreWindow();
	self.handleMenusForModalDisplay();
end;</source>
    </JadeMethod>
    <JadeMethod name="startGenertate" id="9de96d0d-abdf-4df5-af64-c68f07606aea">
        <source>startGenertate():Boolean protected;
// --------------------------------------------------------------------------------
// Created:		18 March 2009 by cnwdad1
//
// Purpose:		Using the FormCaptionAgent class, process all forms in all subschemas
//				of PortSchema to analyse translation Global Constants, and generate
//				partial schema extract files for each schema, which contains generated
//				code to load any new Global Constants, and appended translateForm
//				methods.
//
//				After this processing, the log file (formcaptionsagent_yyyymmddhhmmss.log)
//				should be checked for any problems that need to be sorted out.  Any
//				problems should be corrected, then this process should be run again.
//
//				Once all is satisfactory, the partial schema files should be loaded
//				back into the development environment, then the translation Global
//				Constants should be reloaded into the database using the "Reload"
//				button on the Text Translation form in JMT (in superuser mode).
//
// Parameters:	None
//
// Returns:		True if the processsing completed successfully, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 30/01/2012	cnwmh5		Comment out call to loadDefinedFormConstants
// --------------------------------------------------------------------------------
vars
	folderName	: String;
	agentObj	: FormCaptionsAgent;
	startTime	: Integer;
	fileFolder1 		: FileFolder;
	
	diffFound			: Boolean;
	diffFound2			: Boolean;
	
begin
	folderName	:=	txtFolder.cnEcString();
	
	if folderName = null then
		app.msgBox("Please enter or browse for the schema destination directory.", app.getString(Error), MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		return false;
	endif;
	
	startTime	:=	app.clock();
	create agentObj transient;
	agentObj.fillSchemas();
	agentObj.initAllForms();
	
	///if (not agentObj.loadDefinedFormConstants()) then
	///	return false;
	///endif;
	
	agentObj.processAllForms();
	
	agentObj.createFileFolder(folderName);
	agentObj.writeSchemaFile(folderName);
	
	// get the details for the unl to extract
	agentObj.writeUNLForTranslateFormMethod();
	

	// extract out the translateForm methods
	if agentObj.writeCurrentTranslateFormMeths(agentObj.fileFolder.fileName) then
		app.msgBox("Failed to extract translateForm methods", "Extract Failed", MsgBox_OK_Only + MsgBox_Information_Icon);
		return false;
	endif;
	
	// extract form captions
	agentObj.extractOutXLAT_FormCaptions();
	
	// convert the files so can actually programatically compare them
	if not agentObj.convertFilesSoCanProgCompare() then
		app.msgBox("Failed to create converted files", "Convert Failed", MsgBox_OK_Only + MsgBox_Information_Icon);
		return false;
	endif;
	
	// programmatically check the constants to see that id's haven't changed
	diffFound := agentObj.compareOldNewConstantsIDs();
	
	// programmatically check to see if there are any difference
	diffFound2 := agentObj.compareOldNewCodeForDiffs();
	
	// were any diffs found?
	if diffFound or diffFound2 then
		app.msgBox("Please check in the directory (" &amp; agentObj.fileFolder.fileName &amp; ") for any files with '-DIFFS' in the name.", "Differences Found", MsgBox_OK_Only + MsgBox_Information_Icon);
		//return;
	endif;
	
	return true;
epilog
	delete fileFolder1;
	delete agentObj.fileFolder;
	delete agentObj;
	write "Form/Control/Menu captions processed in " &amp; startTime.cnEcClockDifference().numberFormat() &amp; " seconds.";
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
