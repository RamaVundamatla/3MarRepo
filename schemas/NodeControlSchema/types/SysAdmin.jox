    <JadeMethod name="backup" id="9e2b4d20-ba30-4f7e-a87c-8e2fc174fb7f">
        <updating/>
        <source>backup(envNames:StringArray) updating;
//	back up and restart a list of environments
//	each env is first checked for files in use (except help files)
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
begin
	write "";
	foreach envName in envNames do
		envInfo;
//		write envName&amp;Tab&amp;env&amp;Tab&amp;port&amp;Tab&amp;appSchema;
		write app.actualTimeServer.time.format("HH:mm:ss")&amp;" checking "&amp;env;// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		if not backupCheckInuse(env) then
			terminate;
		endif;
	endforeach;

	foreach envName in envNames do
		envInfo;
		if envName="SkiHis" then
			backupMixed;
		else
			backupEnv;
		endif;
//		startupEnv(envName);
	endforeach;
end;</source>
        <Parameter name="envNames" type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="backupCheckInuse" id="3c239752-6758-4e7c-9b0b-aabc783a5fc7">
        <source>backupCheckInuse(dir:String):Boolean;
// checks for any files in use, allows abort, retry and ignore
vars
	folder:FileFolder;
	file:FileNode;
	i,j,k:Integer;
	s,t:String;
begin
	if dir.toLower.cnContains("u:\hmlppr") and dir.cnContains("\ro") then
		return true;  // jhp 20060301 skip huge ro folders for hmlpprint
	endif;
	create folder;
	folder.fileName:=dir;
	folder.usePresentationFileSystem:=false;
	if folder.isAvailable then
		foreach file in folder.files do
			if file.isKindOf(File) then
				s:=file.name.toLower;
				j:=s.length;
				if j&gt;=5 then
					if s[j-3:end]=".hlp"  // ignore help files in use
					or s[j-3:end]=".gid"
					or s[1:3]="hdk" and s[j-3:end]=".dll"
					or s[1:3]="hyp" and s[j-3:end]=".dll"
					then
						continue;
					endif;
				endif;
				file.File.kind := File.Kind_Unknown_Text; // 3/3/16  cnwns1 PAR 36286 unicode version
				file.File.mode:=File.Mode_Input;
				file.usePresentationFileSystem:=false;
				file.File.shareMode:=File.Share_Exclusive;
				i:=MsgBox_Return_Retry;
				while i=MsgBox_Return_Retry do
					if file.File.tryOpen then
//						write "file ok "&amp;file.fileName;
						file.File.close;
						break;
					else
						if app.name="EnvBackup" then  // jhp 20050314
							app.logMessage("File in use: "&amp;file.fileName);
							k:=k+1;
							break;  // don't abort the automated backup
						else
							i:=app.msgBox("File in use:"&amp;Lf&amp;file.fileName,"Backup Error"
										  ,MsgBox_Abort_Retry_Ignore+MsgBox_Default_Second+MsgBox_Exclamation_Mark_Icon);
							if i=MsgBox_Return_Abort then
								global.beep;
	//							write "Terminating at user request";
								return false;
							endif;
						endif;
					endif;
				endwhile;
			else
				if not backupCheckInuse(file.fileName) then  // recursion!
					return false;
				endif;
			endif;
		endforeach;
	endif;
	if k&gt;0 then  // jhp 20050314
		app.logMessage("some files in "&amp;dir&amp;" are in use during backup");
		return false;
	else
		return true;
	endif;
epilog
	delete folder;
end;</source>
        <Parameter name="dir" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="backupEnv" id="7491a9b6-de64-4c72-913d-5a2c19750b44">
        <source>backupEnv();
//	backs up the given environment (eg "d:\actax") using WinZip to the other drive
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	i,result,retCode:Integer;
	path,exe,backupLoc,zipFile,zipFile2,zipFile3:String;
	f:File;
	ts,te:Decimal[19];
begin
	write app.actualTimeServer.time.format("HH:mm:ss ")&amp;env&amp;" backup starting... ";// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support

	// set up zip file name
/*	if env[1]="e" then
		backupLoc:="d:\zip\";
	else
		backupLoc:="e:\zip\";
	endif;
*/	//	s73 server
	if  env[1]="t" then
		backupLoc:="r:\zip\";
	elseif
		env[1]="r" then
		backupLoc:="s:\zip\";
	else
		backupLoc:="t:\zip\";
	endif;	
	
	zipFile :=backupLoc&amp;app.actualTimeServer.date.format("yyyMMdd")&amp;"_"&amp;env[4:end]&amp;".zip";									// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	zipFile2:=backupLoc&amp;app.actualTimeServer.date.format("yyyMMdd")&amp;"_"&amp;env[4:end]&amp;"_Lobj_1.zip";  // must split up SkiSbs	// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	zipFile3:=backupLoc&amp;app.actualTimeServer.date.format("yyyMMdd")&amp;"_"&amp;env[4:end]&amp;"_Lobj_2.zip";  // must split up SkiSbs	// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support

	// delete old zip file if any
	create f;
	f.usePresentationFileSystem:=false;
	f.fileName:=zipFile;
	if f.isAvailable then f.purge; endif;
	f.fileName:=zipFile2;
	if f.isAvailable then f.purge; endif;
	f.fileName:=zipFile3;
	if f.isAvailable then f.purge; endif;

	// do the zip
	path:="c:\winnt";
	exe:="wzzip";

	sa.clear;
	sa[1]:="-ef -r -P -^^ -yb -b"&amp;backupLoc[1:backupLoc.length-1];  // for explanation of options, see c:\program files\winzip\wzcline.hlp
//	sa[2]:="-x*_His96.dat*";  // these exclusions are not case sensitive
//	sa[3]:="-x*_His97.dat*";
	if env="t:\SkiHis" then
		sa[4]:="-x*_Inv96.dat*";
		sa[5]:="-x*_Mor97.dat*";
	elseif env="t:\SkiSbs2" then
		sa[4]:="-x*\Lobj*.dat";  // exclude Lobj for first bit		
	elseif env="t:\SkiSbs" then
		sa[4]:="-x*\Lobj*.dat";  // exclude Lobj for first bit
	endif;
	sa[6]:="-x*\c_system_old\*";
	sa[12]:=zipFile;
	sa[13]:=env&amp;"\*.*";
	ts:=app.relativeMachineTime;
	retCode:=node.createExternalProcess(path,path&amp;"\"&amp;exe&amp;".exe",sa,null,false,true,result);
	if result&lt;&gt;0 then
		global.beep;
		write exe&amp;" error (result "&amp;result.String&amp;")"&amp;CrLf&amp;sa.display;
		terminate;
	endif;
	if retCode&lt;&gt;0 and retCode&lt;&gt;4 then
		global.beep;
		write exe&amp;" error (retCode "&amp;retCode.String&amp;")"&amp;CrLf&amp;sa.display;
		terminate;
	endif;

	if env="t:\SkiSbs2"
	or env="t:\SkiSbs" then  // do second part, Lobj_xxx9n structures only
		te:=app.relativeMachineTime;
		write app.actualTimeServer.time.format("HH:mm:ss ")&amp;env&amp;" backup part 1 finished in "&amp;(te-ts).Time.String;	// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		ts:=te;
		sa[4]:="";
		sa[12]:=zipFile2;
		sa[13]:=env&amp;"\server\c_system\Lobj_???9?.dat";
		sa[14]:=env&amp;"\server\c_system\_control.dat";  // include a known file in case there aren't any Lobjs
		retCode:=node.createExternalProcess(path,path&amp;"\"&amp;exe&amp;".exe",sa,null,false,true,result);
		if result&lt;&gt;0 then
			global.beep;
			write exe&amp;" error (result "&amp;result.String&amp;")"&amp;CrLf&amp;sa.display;
			terminate;
		endif;
		if retCode&lt;&gt;0 and retCode&lt;&gt;4 then
			global.beep;
			write exe&amp;" error (retCode "&amp;retCode.String&amp;")"&amp;CrLf&amp;sa.display;
			terminate;
		endif;
		te:=app.relativeMachineTime;
		write app.actualTimeServer.time.format("HH:mm:ss ")&amp;env&amp;" backup part 2 finished in "&amp;(te-ts).Time.String;	// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		
		// do third part - remaining Lobj structures
		ts:=te;
		sa[4]:="-xLobj_???9?.dat";
		sa[12]:=zipFile3;
		sa[13]:=env&amp;"\server\c_system\Lobj*.dat";
		sa[14]:=env&amp;"\server\c_system\_control.dat";  // include a known file in case there aren't any Lobjs
		retCode:=node.createExternalProcess(path,path&amp;"\"&amp;exe&amp;".exe",sa,null,false,true,result);
		if result&lt;&gt;0 then
			global.beep;
			write exe&amp;" error (result "&amp;result.String&amp;")"&amp;CrLf&amp;sa.display;
			terminate;
		endif;
		if retCode&lt;&gt;0 and retCode&lt;&gt;4 then
			global.beep;
			write exe&amp;" error (retCode "&amp;retCode.String&amp;")"&amp;CrLf&amp;sa.display;
			terminate;
		endif;
	endif;
	te:=app.relativeMachineTime;
	write app.actualTimeServer.time.format("HH:mm:ss ")&amp;env&amp;" backup finished in "&amp;(te-ts).Time.String;	// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
epilog
	delete f;
end;</source>
    </JadeMethod>
    <JadeMethod name="backupJdbutilb" id="d421e19f-6473-4dde-bd2f-360b168deec1">
        <source>backupJdbutilb(env:String);
//	backs up an environment using jdbutilb
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	i,result,retCode:Integer;
	path,backupLoc,backupDir,zipFile:String;
	hugeFiles:StringArray;
	f:File;
begin
	create hugeFiles transient;
//	env:="e:\skisbs";      // sample input
	// set up zip file name
/*	if env[1]="e" then
		backupLoc:="d:\zip\";
	else
		backupLoc:="e:\zip\";
	endif;
*/	//	s73 server
	if  env[1]="t" then
		backupLoc:="r:\zip\";
	elseif
		env[1]="r" then
		backupLoc:="s:\zip\";
	else
		backupLoc:="t:\zip\";
	endif;
	
	if env="t:\SkiHis" then
		hugeFiles[1]:="Lobj_His96";
		hugeFiles[2]:="Lobj_His97";
		hugeFiles[3]:="Global_His96";
		hugeFiles[4]:="Global_His97";
	endif;

	// set up backup directory
	backupDir:=backupLoc&amp;app.actualTimeServer.date.format("yyyMMdd")&amp;"_"&amp;env[4:end];	// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	zipFile:=backupDir&amp;"\"&amp;env[4:end]&amp;".zip";
	app.makePathIfPossible(zipFile,false);

	// use jdbutilb for any huge files (&gt;4gb)
	sa.clear;
	path:=env&amp;"\server\c_bin";
	sa.clear;
	sa[1]:="path="&amp;env&amp;"\server\c_system";
	sa[2]:="backup";
	foreach i in 1 to hugeFiles.size do
		sa[2]:=sa[2]&amp;" "&amp;hugeFiles[i];
	endforeach;
	sa[3]:="backupDir="&amp;backupDir;
	sa[4]:="compress overwrite";
//	write sa.display; return;
	retCode:=node.createExternalProcess(path,path&amp;"\jdbutilb.exe",sa,null,false,true,result);
	if result&lt;&gt;0 and result&lt;&gt;4 then write "jdbutilb result "&amp;result.String&amp;" "&amp;sa.display; endif;
	if retCode&lt;&gt;0 then write "jdbutilb retCode "&amp;retCode.String&amp;" "&amp;sa.display; endif;
epilog
	delete hugeFiles;
end;</source>
        <Parameter name="env" type="String"/>
    </JadeMethod>
    <JadeMethod name="backupMixed" id="60606a94-b0ec-45fe-a177-79ec0a51dc3c">
        <source>backupMixed();
//	back up an environment, some files (listed below) with jdbutilb, the rest with wzzip
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	i,result,retCode:Integer;
	exe,path,backupLoc,backupDir,zipFile:String;
	hugeFiles:StringArray;
	ts,te:Decimal[19];
	f:File;
begin
	write app.actualTimeServer.time.format("HH:mm:ss ")&amp;env&amp;" zip backup starting... ";	// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	create hugeFiles transient;
//	env:="e:\SkiHis";      // sample input

	// set up zip file name
/*	if env[1]="e" then
		backupLoc:="d:\zip\";
	else
		backupLoc:="e:\zip\";
	endif;
*/	//	s73 server
	if  env[1]="t" then
		backupLoc:="r:\zip\";
	elseif
		env[1]="r" then
		backupLoc:="s:\zip\";
	else
		backupLoc:="t:\zip\";
	endif;

	// exclusion list
	if env="t:\SkiHis" then
		hugeFiles[1]:="Global_Inv96";
		hugeFiles[2]:="Global_Mor97";
		hugeFiles[3]:="Lobj_Inv96";
		hugeFiles[4]:="Lobj_Mor97";
	endif;

	// set up backup directory
	backupDir:=backupLoc&amp;app.actualTimeServer.date.format("yyyMMdd")&amp;"_"&amp;env[4:end];	// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	zipFile:=backupDir&amp;"\"&amp;env[4:end]&amp;".zip";
	app.makePathIfPossible(zipFile,false);

	// delete old zip file if any
	create f;
	f.fileName:=zipFile;
	f.usePresentationFileSystem:=false;
	if f.isAvailable then f.purge; endif;
	delete f;

	// do the zip portion; exclude any huge files
	path:="c:\winnt";
	exe:="wzzip";
	sa.clear;
	sa[1]:="-ef -r -P -^^ -yb -b"&amp;backupLoc[1:backupLoc.length-1];
	foreach i in 1 to hugeFiles.size do
		sa[i+1]:="-x"&amp;env&amp;"\server\c_system\"&amp;hugeFiles[i]&amp;".dat";
	endforeach;
	sa[14]:=zipFile;
	sa[15]:=env&amp;"\*.*";
	ts:=app.relativeMachineTime;
	retCode:=node.createExternalProcess(path,path&amp;"\"&amp;exe&amp;".exe",sa,null,false,true,result);
	if result&lt;&gt;0 then
		global.beep;
		write exe&amp;" error (result "&amp;result.String&amp;")"&amp;CrLf&amp;sa.display;
		terminate;
	endif;
	if retCode&lt;&gt;0 and retCode&lt;&gt;4 then
		global.beep;
		write exe&amp;" error (retCode "&amp;retCode.String&amp;")"&amp;CrLf&amp;sa.display;
		terminate;
	endif;
	te:=app.relativeMachineTime;
	write app.actualTimeServer.time.format("HH:mm:ss ")&amp;env&amp;" zip backup finished in "&amp;(te-ts).Time.String;	// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support

	if hugeFiles.size&gt;0 then
		// use jdbutilb for any huge files (&gt;4gb)
		write app.actualTimeServer.time.format("HH:mm:ss ")&amp;env&amp;" jdbutil backup starting... ";	// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		ts:=te;
		path:=env&amp;"\server\c_bin";
		exe:="jdbutilb";
		sa.clear;
		sa[1]:="path="&amp;env&amp;"\server\c_system";
		sa[2]:="backup";
		foreach i in 1 to hugeFiles.size do
			sa[2]:=sa[2]&amp;" "&amp;hugeFiles[i];
		endforeach;
		sa[3]:="backupDir="&amp;backupDir;
		sa[4]:="compress overwrite";
		retCode:=node.createExternalProcess(path,path&amp;"\"&amp;exe&amp;".exe",sa,null,false,true,result);
		if result&lt;&gt;0 then
			global.beep;
			write exe&amp;" error (result "&amp;result.String&amp;")"&amp;CrLf&amp;sa.display;
			terminate;
		endif;
		if retCode&lt;&gt;0 and retCode&lt;&gt;4 then
			global.beep;
			write exe&amp;" error (retCode "&amp;retCode.String&amp;")"&amp;CrLf&amp;sa.display;
			terminate;
		endif;
		te:=app.relativeMachineTime;
		write app.actualTimeServer.time.format("HH:mm:ss ")&amp;env&amp;" jdbutil backup finished in "&amp;(te-ts).Time.String;	// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	endif;
epilog
	delete hugeFiles;
end;</source>
    </JadeMethod>
    <JadeMethod name="create" id="969c3f51-b085-4dc1-b646-7cb98feb980b">
