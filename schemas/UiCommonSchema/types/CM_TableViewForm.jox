    <JadeMethod name="getXMLSettingsForSave" id="8053c575-1e67-4c46-8e3a-3856f9af2ad6">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;

vars
	str, mainRatio, rtnStr	: String;
	index 					: Integer;
begin
	rtnStr := inheritMethod();
	
	if self.isDataTableVisible then
		self.widthUsingTblData := self.width.Integer;
		
		str := self.setTblDataXML();
	else
		self.widthNotUsingTblData := self.width.Integer;
	endif;
	
	if self.isDataTableVisible and self.isThumbnailVisible then
		mainRatio := self.sptMain.leftToRightRatio.String;
	else
		mainRatio := self.sptMainRatioSaved.String;
	endif;
	
	// not strictly correct xml syntax here (name should not have to be in the
	// closing tag but this is required by cnEcGetNextTagValueForName - rjs
	str := str &amp; 
		   global.formatAsXMLPrefix(XMLTag_Splitter &amp; ' name="sptMain"') &amp;
		   global.formatAsXML(XMLTag_Ratio, mainRatio) &amp;
		   global.formatAsXMLSuffix(XMLTag_Splitter &amp; ' name="sptMain"') &amp;
		   global.formatAsXMLPrefix(XMLTag_Splitter &amp; ' name="sptDataFilter"') &amp;
		   global.formatAsXML(XMLTag_Ratio, self.sptDataFilter.leftToRightRatio.String) &amp;
		   global.formatAsXMLSuffix(XMLTag_Splitter &amp; ' name="sptThumbEdit"') &amp;
		   global.formatAsXMLPrefix(XMLTag_Splitter &amp; ' name="sptThumbEdit"') &amp;
		   global.formatAsXML(XMLTag_Ratio, self.sptThumbEdit.leftToRightRatio.String) &amp;
		   global.formatAsXMLSuffix(XMLTag_Splitter &amp; ' name="sptDataFilter"') &amp;		   
		   global.formatAsXML(XMLTag_TblThumbVisible, self.isThumbnailVisible.String) &amp;
		    global.formatAsXML(XMLTag_ThumbnailShowEmptyRow, self.isHideThumbnailEmtpy.String) &amp;
		   global.formatAsXML(XMLTag_FormWidth1, self.widthUsingTblData.String) &amp;
		   global.formatAsXML(XMLTag_FormWidth2, self.widthNotUsingTblData.String) &amp;
		   global.formatAsXML(XMLTag_ShowFilter, self.tblSearch.visible.String) &amp;
		   global.formatAsXML(XMLTag_DockSearcher, self.isSearcherFloating.String) &amp;
		   self.xmlStrTblData;		//21 Feb 2019	NDL	TFS 43332

	return rtnStr &amp; str;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
