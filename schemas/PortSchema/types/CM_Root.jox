    <JadeMethod name="setupInvProcessEmailDefault" id="a1d73795-0deb-458e-9e0e-689ad16e9d55">
        <source>setupInvProcessEmailDefault( _emailType : Integer; _emailName : String; _objectType : String; _sa : StringArray);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 14 June 2023 navmv20 CR 58215 Task 58216: Jade - Invoice Process Email
//
vars
	invDef : CM_InvStatusDefaultEmail;

begin
	invDef := self.allInvStatusDefaultEmails[_emailType];
	if invDef = null then
		create invDef as CM_InvProcessDefaultEmail persistent;
		invDef.setForCreate(ETDef_InvoiceProcessEmail,
							_sa,
							null,
							_emailName,
							_emailName,
							_objectType,
							_emailType,
							null,
							null,
							false,
							false );
		invDef.setPropertyValue(CM_InvStatusDefaultEmail::enabled.name, true);
	else
		// update those that can NOT be changed by the users.
		invDef.setPropertyValue( CM_InvStatusDefaultEmail::name.name, _emailName );
		invDef.setPropertyValue( CM_InvStatusDefaultEmail::objectType.name, _objectType);
	endif;

epilog

end;</source>
        <Parameter name="_emailType" type="Integer"/>
        <Parameter name="_emailName" type="String"/>
        <Parameter name="_objectType" type="String"/>
        <Parameter name="_sa" type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="setupInvProcessEmailDefaults" id="d8a0b0b2-c9b4-45fe-af47-bc64b3d3c75a">
        <updating/>
        <source>setupInvProcessEmailDefaults() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 14 June 2023 navmv20 CR 58215 Task 58216: Jade - Invoice Process Email
//
vars
	entTableDef		: EntTableDef;
	entTableRow 	: EntTableRow;
	invDef			: CM_InvStatusDefaultEmail;
	sa				: StringArray;
	emailType		: Integer;
	emailName		: String;
	objectType		: String;

begin
	create sa transient;
	entTableDef := self.myEntTableDataRoot.allEntTableDefs[ETDef_InvoiceProcessEmail];
	foreach entTableRow in entTableDef.allEntTableRows do
		if entTableRow.name.isOneOf(ETRow_OwnershipChangeNo,ETRow_OwnershipChangeNo, ETRow_OriginalOperatorDesc, ETRow_PreviousOperatorDesc) then
			sa.add(entTableRow.getHeading(null, null, app.myCurrentLocale));
		endif;
	endforeach;
	
	self.setupInvProcessEmailDefault(PINEmail_InvProcDefOffset + 800, app.getErrorString(Linux_process), 
									'Ownership Change Invoice Issue', sa);
												
	self.setupInvProcessEmailDefault(PINEmail_InvProcLinxOffset + 800, app.getErrorString(Master_terminal_default), 
									'Ownership Change Invoice Issue', sa);
									
 	self.setupInvProcessEmailDefault(PINEmail_InvProcPel1Offset + 800, app.getErrorString(Work_orders), 
									'Ownership Change Invoice Issue', sa);
									
epilog
	delete sa;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupInvStatusEmailDefault" id="484cb981-a431-498e-90bd-1161c258ac7f">
        <source>setupInvStatusEmailDefault( _emailType : Integer; _emailName : String; _objectType : String; _sa : StringArray);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 5/01/2019	jlgsl4		TFS 39618
//
vars
	invDef : CM_InvStatusDefaultEmail;

begin
	invDef := self.allInvStatusDefaultEmails[_emailType];
	if invDef = null then
		create invDef persistent;
		invDef.setForCreate(ETDef_InvoiceStatusEmail,
							_sa,
							null,
							_emailName,
							_emailName,
							_objectType,
							_emailType,
							null,
							null,
							false,
							false );
		invDef.setPropertyValue(CM_InvStatusDefaultEmail::enabled.name, true);
	else
		// update those that can NOT be changed by the users.
		invDef.setPropertyValue( CM_InvStatusDefaultEmail::name.name, _emailName );
		invDef.setPropertyValue( CM_InvStatusDefaultEmail::objectType.name, _objectType);
	endif;

epilog

end;</source>
