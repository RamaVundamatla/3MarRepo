    <JadeMethod name="setControlsForAddEdit" id="0304e25a-e497-40ce-b931-fcbaf4c90bf8">
        <updating/>
        <source>setControlsForAddEdit() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
30 August 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	
	allEmailTo,
	allEmailCC,
	allEmailBCC: HugeStringArray;
	pxyFaultType : CM_FaultType;
	emailAddy : String;
	emailEntity : CM_EmailEntity;
begin
	self.myForm.tblInput1.userInputEnabled := true;
	self.myEmailController.clear;
	
	if self.myForm.mode = SOP_TableMaintForm.Mode_Add then
		self.myForm.tblInput1.clearValues;
		self.myForm.tblInput1.setFocus;
		self.myForm.tblInput1.moveFirst();
	else
		pxyFaultType:=self.myForm.myProxyObject.CM_FaultType;
		self.showThumbnail(pxyFaultType);
		
		if pxyFaultType.emailRecipient &lt;&gt; null then
			create allEmailTo transient;
			pxyFaultType.emailRecipient.getTokensForDelimiterHuge(';',allEmailTo);
			foreach emailAddy in allEmailTo do
				emailEntity:=app.myRoot.allEmailAddressesByAddress[emailAddy];
				if emailEntity &lt;&gt; null then
					self.myEmailController.allToAddresses.add(emailEntity);
				endif;
			endforeach;
		endif;
		if pxyFaultType.emailRecipientCC &lt;&gt; null then
			create allEmailCC transient;
			pxyFaultType.emailRecipientCC.getTokensForDelimiterHuge(';',allEmailCC);
			foreach emailAddy in  allEmailCC do
				emailEntity:=app.myRoot.allEmailAddressesByAddress[emailAddy];
				if emailEntity &lt;&gt; null then
					self.myEmailController.allCcAddresses.add(emailEntity);
				endif;
			endforeach;
		endif;
		if pxyFaultType.emailRecipientBCC &lt;&gt; null then
			create allEmailBCC transient;
			pxyFaultType.emailRecipientBCC.getTokensForDelimiterHuge(';',allEmailBCC);
			foreach emailAddy in  allEmailBCC do
				emailEntity:=app.myRoot.allEmailAddressesByAddress[emailAddy];
				if emailEntity &lt;&gt; null then
					self.myEmailController.allBccAddresses.add(emailEntity);
				endif;
			endforeach;
		endif;
	endif;


epilog
	if allEmailTo &lt;&gt; null then
		delete allEmailTo;
	endif;
	if allEmailCC &lt;&gt; null then
		delete allEmailCC;
	endif;
	if allEmailBCC &lt;&gt; null then
		delete allEmailBCC;
	endif;
end;</source>
    </JadeMethod>
