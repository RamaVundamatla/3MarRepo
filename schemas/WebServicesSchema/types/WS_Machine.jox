<Class name="WS_Machine" id="06caaa53-9ef2-4322-a0ce-2f5cdd5736f3">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text> Used to get all cranes working for a specific voyage.</text>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="currentUserId" id="3c0efeec-f500-44e1-9fc2-1d1a7b557fe9">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="description" id="0354f1e5-42b5-4831-b91d-026eda46de5c">
        <length>26</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
        <text>Crane Description ,Maximum length is 25 characters</text>
    </PrimAttribute>
    <PrimAttribute name="id" id="e56df469-4032-49e6-ab28-303b13f62ddc">
        <length>5</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
        <text>Crane Id</text>
    </PrimAttribute>
    <JadeMethod name="setProxyFromObject" id="c9604cb4-f2b2-424b-8061-681d1449bcf6">
        <updating/>
        <source>setProxyFromObject(_object: CM_Machine) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 September 2008	cnwkao1	Initial creation

*/

vars

begin
	inheritMethod(_object);
	
	self.id				:= _object.id;
	self.description	:= _object.description;
	//epr TFS 51626 30/7/21
	if _object.user &lt;&gt; null then
		self.currentUserId  := _object.user.code;
	endif;
epilog

end;</source>
        <Parameter name="_object" type="CM_Machine"/>
    </JadeMethod>
</Class>
