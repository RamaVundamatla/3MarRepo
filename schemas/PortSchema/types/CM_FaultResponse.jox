    <JadeMethod name="getDisplayStringForAttribute" id="a3c61621-5084-4ccf-9079-75650111f919">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			


Return Value:		


Date		Who		Reason
21 Sep 2007	cnwer1	Initial creation - PAR#xxxx
04 May 2016	cnwns1	TFS 488 - Multi Timezone Support
07 Jul 2020 cnwma1  Bug 49710: SNO -- Error 1090 when searching under the Fault Enquiry screen
*/
vars

begin
	if _attrName = ETRow_WhenReported then
		return self.systemToLocalTime(self.reportedTS).asStringJMT;
	elseif _attrName = ETRow_Machine then
		if self.myMachine  &lt;&gt; null then
			return self.myMachine.getDisplayDetails(false);
		endif;
		return null;
	elseif _attrName = ETRow_ReportedBy then
		if self.myReportedByUser &lt;&gt; null then
			return self.myReportedByUser.code;
		endif;
		return null;
	elseif _attrName = ETRow_Status then
		if self.myFault &lt;&gt; null and self.myFault.myFaultStatus &lt;&gt; null then
			return self.myFault.myFaultStatus.description;
		endif;
		return null;
	elseif _attrName = ETRow_FaultQuestion then
		return self.question.removeTabCrLfs;
	elseif _attrName = ETRow_FaultResponse then
		return self.response;
	elseif _attrName  = ETRow_FaultType then
		if self.myFault &lt;&gt; null and self.myFault.myFaultType &lt;&gt; null  then
			return self.myFault.myFaultType.description;
		endif;
		return null;
	elseif _attrName = ETRow_FaultResponse then
		return null;
	elseif _attrName = ETRow_MachineType then
		if self.myMachine &lt;&gt; null then
			return self.myMachine.machineTypeString;
		endif;
		return null;
	elseif _attrName = ETRow_FaultStatusCode then
		if self.myFault &lt;&gt; null and self.myFault.myFaultStatus &lt;&gt; null  then
			return self.myFault.myFaultStatus.code;
		endif;
		return null;
	else	

		return inheritMethod(_attrName, _short);
	endif;
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
