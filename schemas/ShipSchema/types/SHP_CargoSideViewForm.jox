    <JadeMethod name="changeScale" id="04424bc0-8335-44c8-9257-b1e165d4cd6a">
        <updating/>
        <source>changeScale(_increase : Boolean) updating;
/*
Date		    	Who			Reason
14 September 2011	cnwas3		Initial creation: CCMS 1035 CargoSideView form
30 July 2012		cnwcs5		par 29124
*/

constants
	MaxZoom = 1.5;
	MinZoom = 1;
vars
	newScale, pc : Decimal[12,2];
begin
	
	newScale := self.scaleFactor;
	
	if _increase then
		newScale := newScale + .1;
		
		if newScale &gt; MaxZoom then
			newScale := MaxZoom;
		endif;
	else
		newScale := newScale - .1;
		
		if newScale &lt; MinZoom then
			newScale := MinZoom;
		endif;
	endif;
	
	self.setScale(newScale);
	self.myROROLocnDrawingController.setScale(newScale, true, true);
	self.myROROLocnDrawingController.drawSelf(true);
	self.doResize();	
	
	if self.btnDrawRemarks.value then
		self.doRepositionRemarks;	// par 29124
	endif;	
epilog

end;</source>
        <Parameter name="_increase" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="changeViewMode" id="edadd0e6-49ae-440c-a92d-b457e19d4896">
        <updating/>
        <source>changeViewMode(_newMode : Integer) updating;
/*
Purpose:			
Date			Who		Reason
10 June 2011	cnwab1	Initial creation
26 Jul 2012		cnwcs5	par 29124
*/

vars
	deckItemLayoutArray 		: CM_RORODeckItemLayoutArray;
	deckItem 					: CM_DeckItem;
	locnDefn, otherDefn 		: CM_ROROLocnDefn;
	newView, oldView  			: Integer;
	isCloneView1, isCloneView2 	: Boolean;
	form						: SHP_ROROPlanningForm;	// par 29124 July 2012
begin
	form	:= self.myROROPlanningForm;					// par 29124 July 2012
	oldView := self.myROROLocnDrawingController.modeView;
	newView := _newMode;
	
	self.myROROLocnDrawingController.modeView := newView;
	
	self.setCaption( form.setCaptionForModesGetView(newView));
	self.btnViewExport.visible := false; // PAR 31073
	
	// PAR 28990
	isCloneView1 := (oldView = ShpDisplayMode_ColCodeLoad  or oldView = ShpDisplayMode_Proposed);
	isCloneView2 := (newView = ShpDisplayMode_ColCodeLoad  or newView = ShpDisplayMode_Proposed);
	
	if ( isCloneView1 and not isCloneView2) or ( not isCloneView1 and  isCloneView2) then
		create deckItemLayoutArray transient;

		foreach deckItem in self.allOrderedROROLocns  discreteLock do
			locnDefn 	:= deckItem.CM_ROROLocnDefn;
			otherDefn 	:= locnDefn.getRotatedLinked();
			
			if otherDefn &lt;&gt; null then
				deckItemLayoutArray.add(otherDefn.myLayout);
			else
				deckItemLayoutArray.add(locnDefn.myLayout);
			endif;
		endforeach;
		
		self.doOrderROROLocns(deckItemLayoutArray);
	else
		self.myROROLocnDrawingController.drawSelf(false);
	endif;
	
	if newView = ShpDisplayMode_Actual then
		self.btnViewActual.value 	:= true;
		self.btnDrawRemarks.value	:= false;	// par 29124 July 2012
		self.btnDrawRemarks.enabled	:= false;	// par 29124 July 2012
		
		self.doHideRemarks;						// par 29124 July 2012
	endif;

	if newView = ShpDisplayMode_ColCodeDisch then
		self.btnViewDischarge.value := true;
		self.btnDrawRemarks.value	:= false;	// par 29124 July 2012
		self.btnDrawRemarks.enabled	:= false;	// par 29124 July 2012
		self.btnViewExport.visible := true; // PAR 31073
		self.btnViewExport.value := showExports; // PAR 31073
		
		form.displayModeColour(false);  		// PAR 29098
		self.doHideRemarks;						// par 29124 July 2012
	endif;
	
	if newView = ShpDisplayMode_ColCodeLoad then
		self.btnViewLoad.value 		:= true;
		self.btnDrawRemarks.enabled	:= true;	// par 29124 July 2012
		
		form.displayModeColour(true);  			// PAR 29098
	endif;
	
	if newView = ShpDisplayMode_Proposed then	// cnwas3 par28401
		self.btnViewProposed.value 	:= true;
		self.btnDrawRemarks.value	:= false;	// par 29124 July 2012
		self.btnDrawRemarks.enabled	:= false;	// par 29124 July 2012
		
		self.doHideRemarks;						// par 29124 July 2012
	endif;
	self.doResize(); // PAR 31073
epilog
	delete deckItemLayoutArray;
end;</source>
        <Parameter name="_newMode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="contextMenu" id="1c0e564c-f18d-45b6-a16c-62153c6c09a7">
        <controlMethod name="Form::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>contextMenu(conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
/*
Purpose:			
Date		Who		Reason
02 August 2011	cnwab1	Initial creation
*/

vars

begin
	self.mnuInspectLC.visible := app.isAllowedToInspect();
	self.mnuInspectLocnDefn.visible := app.isAllowedToInspect();
	self.mnuInspectSlotDefn.visible := app.isAllowedToInspect();
	
	self.doCargoContextMenuBuild(conwin,mouse,x,y);
	
	return self.showContextMenu(self.mnuContextMain, null, conwin, mouse, x, y);
epilog

end;</source>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
