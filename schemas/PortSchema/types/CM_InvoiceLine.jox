    <JadeMethod name="getTaxRatesAsString" id="e1ed78a7-aafe-4e36-8d6a-f33147ea0b1e">
        <source>getTaxRatesAsString(_useQuotes : Boolean) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 Nov 2018	jlgsl4	TFS 41230 - ADP - Invoice export
03 May 2023 navmv20 Bug 57664: EUP - Copy function does not include overridden rates
*/

vars
	taxRates : DecimalArray;
	rt : Decimal[23,2];	// 03/05/2023 navmv20 Bug 57664
	list : String;		// 03/05/2023 navmv20 Bug 57664
begin
	create taxRates transient;
	self.getTaxRatesForCharges(taxRates);
	// 03/05/2023 navmv20 Bug 57664 - START
	//return self.convertDecimalArrayToCSV(taxRates, _useQuotes);

	foreach rt in taxRates do
		/*
		if list.pos(rt.String,1) = 0 then
			if list = null then
				list := rt.String;
			else
				list := list &amp; ", " &amp; rt.String;
			endif;
		endif;
		*/
		
		list.addStringToList(rt.String, ", "); //04/04/2025	navkc1 JIRA Story MTN-33940
	endforeach;
	return list;
	// 03/05/2023 navmv20 Bug 57664 - END
epilog
	delete taxRates;
end;</source>
        <Parameter name="_useQuotes" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTaxRatesForCharges" id="924b58e8-938e-4790-94d5-e1e20318962b">
        <source>getTaxRatesForCharges(_taxRates : DecimalArray io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Nov 2018	jlgsl4	TFS 41230 - ADP - Invoice export

*/

vars
	charge : CM_Charge;
begin
	_taxRates.clear();
	foreach charge in self.charges do
		_taxRates.add(charge.getTaxRateForCharge());
	endforeach;
epilog

end;</source>
        <Parameter name="_taxRates" type="DecimalArray" usage="io"/>
    </JadeMethod>
