    <JadeMethod name="getExRateForCurrencyCode" id="4338d667-5099-453d-9d07-fdaacfd1ddae">
        <source>getExRateForCurrencyCode(_typeCode : String ):Decimal;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 October 2018		cnwma1	Bug 41658: PEL1 - Domestic Rates for International Tariff - Estimation

*/

vars

	currencyType : CM_CurrencyType;
	rate : CM_CurrencyRate;

begin

	if _typeCode.trimBlanks = null then
		return 0.0;
	endif;
	
	currencyType := app.myRoot.allCurrencyTypes.getAtKey(_typeCode).CM_CurrencyType;
	
	if currencyType = null then
		return 0.0;
	endif;
	
	rate := currencyType.getRate( self.createdTime );
	if rate = null then
		return 0.0;
	endif;
	
	return rate.rate ;

epilog

end;</source>
