    <JadeMethod name="utlCreateResourceTypeUsage" id="61051611-7ee7-4d85-8300-5a2a810a74b8">
        <source>utlCreateResourceTypeUsage(pProxyResourceTypeUsage			: CM_ResourceTypeUsage; 
						   pProxyAutoApplyResourceTypeUsage : CM_ResourceTypeUsage;
                           pNewResourceTypeUsage 			: CM_ResourceTypeUsage output;
                          _passport 						: CM_Passport input);

/*
Date		Who		Reason
18 December 2009	conkc1	Initial creation
01 Dec 2023 navlc30 ChangeRequest 60748: EUP | VAS Mobile App - [53813.070] [BackEnd] Automatic VAS Resources
*/
vars
	pNewAutoApplyResourceTypeUsage : CM_ResourceTypeUsage;
begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valResourceTypeUsage(pProxyResourceTypeUsage, pProxyAutoApplyResourceTypeUsage);	//15.12.2023 navlc30 #60748

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	create pNewResourceTypeUsage persistent;
	pNewResourceTypeUsage.setForCreate(pProxyResourceTypeUsage);
	
	if _passport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(pNewResourceTypeUsage);
	endif;
	
	if pProxyAutoApplyResourceTypeUsage &lt;&gt; null then
		create pNewAutoApplyResourceTypeUsage persistent;											//13.12.2023 navlc30 #60748
		pNewAutoApplyResourceTypeUsage.setForCreate(pProxyAutoApplyResourceTypeUsage);				//13.12.2023 navlc30 #60748
		
		if _passport.noErrors then																	//13.12.2023 navlc30 #60748
			self.myCreateAuditAgent.audCreateGeneric(pNewAutoApplyResourceTypeUsage);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="pProxyResourceTypeUsage" type="CM_ResourceTypeUsage"/>
        <Parameter name="pProxyAutoApplyResourceTypeUsage" type="CM_ResourceTypeUsage"/>
        <Parameter name="pNewResourceTypeUsage" type="CM_ResourceTypeUsage" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
