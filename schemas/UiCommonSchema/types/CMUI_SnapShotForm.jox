    <JadeMethod name="translateForm" id="74ad2e72-90c1-40c3-891d-3ea7df7683fd">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 18 September 2018 08:28:24.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
//	self.translateCaption(Xlat_0017474, locale);
	btnAddSnapShot.translateCaption(Xlat_0000926, locale);
	btnCancelAdd.translateCaption(Xlat_0000928, locale);
	btnCloseSSForm.translateCaption(Xlat_0000927, locale);
	btnEditSelected.translateCaption(Xlat_0000925, locale);
	btnOK.translateCaption(Xlat_0000929, locale);
	lblSelectOp.translateCaption(Xlat_0000930, locale);
	mnuAddCargo.translateCaption(Xlat_0008154, locale);
	mnuColLegend.translateCaption(Xlat_0008155, locale);
	mnuColOrganise.translateCaption(Xlat_0008156, locale);
	mnuEditSelected.translateCaption(Xlat_0008157, locale);
	mnuHideCargo.translateCaption(Xlat_0008158, locale);
	mnuHideInfo.translateCaption(Xlat_0008159, locale);
	mnuInspectSnapShot.translateCaption(Xlat_0008160, locale);
	mnuResetSnapShot.translateCaption(Xlat_0023003, locale);
	mnuSnapShotContext.translateCaption(Xlat_0008161, locale);
	mnuUpdareFromCargo.translateCaption(Xlat_0023004, locale);
	mnuViewAudits.translateCaption(Xlat_0008162, locale);
end;</source>
    </JadeMethod>
