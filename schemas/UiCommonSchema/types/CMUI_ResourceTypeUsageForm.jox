    </JadeMethod>
    <JadeMethod name="clearGrpResource" id="3ffe3464-59f9-4bc9-a13e-5995ff2fbb73">
        <updating/>
        <source>clearGrpResource() protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 December 2009	cnwndl1	Initial creation	CCMS MES 1006

*/

vars

begin

	self.txtUnits.text := null;

	if self.cmbResourceType.listCount = 1 then
		self.cmbResourceType.listIndex := 1;
		self.cmbResourceType_click(cmbResourceType);
	else
		self.cmbResourceType.listIndex := -1;
		self.setLblUnitsCaption(0);
	endif;

	self.txtRemarks.text := null;
	self.chkNoCharge.value := false;
	self.chkVoid.value := false;
	self.chkVoid.enabled := false;
	
	self.grpResource.enabled := false;
	self.myCurrentProxyUsage := null;
	
	self.btnDelete.enabled := true;
	
	//cnwmc5 - 22 Sep 2015 - PAR 36920
	self.txtFromDate.setDate(null);
	self.txtFromTime.setTime(null);
	self.txtToDate.setDate(null);
	self.txtToTime.setTime(null);
	
	//13 Apr 2017	NDL	TFS 3414
	self.chkHeatTreated.value := false;
	self.chkStoreOnP.value := false;
	self.cmbPalletType.listIndex := -1;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="clickStoreOnPallet" id="afae69a0-eef5-45dc-b26d-d710c4a59a88">
        <source>clickStoreOnPallet();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 January 2020	jlgndl1	Initial creation	TFS 48248

*/

vars

	value : Boolean;

begin

	value := self.chkStoreOnP.value;

	self.chkHeatTreated.enabled := value;
	self.cmbPalletType.enabled := value;
	self.lblPallet.enabled := value;
	
	if not value then
		self.cmbPalletType.listIndex := -1;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="cmbPalletType_displayEntry" id="b14ff595-350e-48ec-83bb-372ef522c33d">
        <controlMethod name="CMUI_ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbPalletType_displayEntry(combobox: ComboBox input; obj: Any; lstIndex: Integer):String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 April 2017	cnwndl1	Initial creation	TFS 3414

*/

vars

begin

	if obj = null or not obj.isKindOf( CM_PalletType ) then
		return null;
	endif;
	
	return obj.CM_PalletType.description;

epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="obj" type="Any"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cmbResourceType_change" id="bb32c777-baf7-4374-8436-a252b6cfccde">
        <controlMethod name="ComboBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbResourceType_change(combobox: ComboBox input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 December 2009	cnwndl1	Initial creation	CCMS MES 1006

*/

vars

	type : CM_ResourceType;
	decPlaces : Integer;
	
begin

	if self.cmbResourceType.listIndex &gt; 0 then
		type := self.cmbResourceType.itemObject[cmbResourceType.listIndex].CM_ResourceType;
	endif;
	
	if type &lt;&gt; null then
		decPlaces := type.decimalPlaces;
		
		//cnwmc5 - 22 Sep 2015 - PAR 36920
		if type.isFromToDateTimeRequired then
			self.frmFromToDate.visible := true;
		else 
			self.frmFromToDate.visible := false;
		endif;
	endif;
	
	self.txtUnits.text := null;
	setLblUnitsCaption(decPlaces);
	
	self.makePalletStuffVisible( type );	//13 Apr 2017 NDL TFS 3414

epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
