    <JadeMethod name="kpdTestActivityCaptureNotes" id="cf77c5d4-5068-43da-b6c6-8a63ba0fc1ad">
        <source>kpdTestActivityCaptureNotes();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Nov 2016	cnwkpd1	TFS 2900 - CICE performance issues

*/

constants
	MaxCount		= 100000;
	
vars
	i				: Integer;
	start,
	diff			: Decimal[20];
	s				: String;
	
begin
	app.initialize();
	
	foreach i in 1 to MaxCount do
		start := app.relativeMachineMicros();
		app.createPassport();
		diff := app.relativeMachineMicros() - start;
		app.writeLog( app.myPassport.String &amp; ' count=' &amp; i.String &amp; ', elapsed = ' &amp; diff.String, LogINFO);	//25 Nov 2019	NDL	TFS 47053
		if i mod 1000 = 0 then
			write 'Iteration ' &amp; i.String &amp; ', elapsed = ' &amp; diff.String;
		endif;
	endforeach;
	
//	read s;	
		
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="kpdTestCreatePrintForm" id="f3d5aeb7-d915-4e9f-a5d7-e371d8719750">
        <source>kpdTestCreatePrintForm();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 February 2014	cnwkpd1	PAR #33353 - tidy up creation of RootSchema classes


*/

vars
	f : CMUI_AjmanCashRec;
	
begin
	create f transient;
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="kpdTestEDITransform" id="9934d14e-c71f-49d2-9574-94675934749c">
        <source>kpdTestEDITransform();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 August 2014	cnwkpd1	PAR #34713 - .NET EDI transform integration

*/

vars
	t				: CMIF_EdiTransformWrap;
	result			: String;
	success			: Boolean;
	i				: Integer;
	
begin
	app.initialize();
	
	process.profiler.methodCount := 50;
	process.profiler.start();
	
	app.writeLog( method.qualifiedName &amp; " about to create wrapper", LogDEBUG);	//26 Nov 2019	NDL	TFS 47053
	create t transient;
	
	foreach i in 1 to 10 do
		t.addHeaderData("Key" &amp; i.String, "Value" &amp; i.String);
	endforeach;
	
	app.writeLog(method.qualifiedName &amp; " about to transform message", LogDEBUG);	//26 Nov 2019	NDL	TFS 47053
	success := t.transformMessage("Kevin", "JMT", "Test", "a message to translate", result);
	
	app.writeLog(method.qualifiedName &amp; " success = " &amp; success.String, LogDEBUG);	//26 Nov 2019	NDL	TFS 47053
	write "success = " &amp; success.String;
	
	app.writeLog(method.qualifiedName &amp; " result = |" &amp; result &amp; "|", LogDEBUG);	//26 Nov 2019	NDL	TFS 47053
	write "result = |" &amp; result &amp; "|";

	process.profiler.report();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="kpdTestEDITransformMulti" id="d5606303-ea2b-401b-8903-b3da948d65c6">
        <source>kpdTestEDITransformMulti();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 August 2014	cnwkpd1	PAR #34713 - .NET EDI transform integration

*/

constants
	MaxCount		= 2000000;

vars
	t				: CMIF_EdiTransformWrap;
	result			: String;
	success			: Boolean;
	i				: Integer;
	start, 
	elapsed			: Decimal[20];
	
begin
	app.initialize();
	
	process.profiler.methodCount := 50;
	process.profiler.start();
	
	foreach i in 1 to MaxCount do
		
		start := app.relativeMachineMicros();
		
		create t transient;
		success := t.transformMessage("Kevin", "JMT", "Test", "a message to translate", result);
		delete t;
		
		elapsed := app.relativeMachineMicros() - start;
		
		app.writeLog(method.qualifiedName &amp; " count=" &amp; i.String &amp; ", success=" &amp; success.String &amp; ", elapsed=" &amp; elapsed.String, LogDEBUG);	//26 Nov 2019	NDL	TFS 47053
		
		if i mod 100 = 0 then
			write i.String &amp; Tab &amp; elapsed.String;
		endif;

	endforeach;
	
	process.profiler.report();
	
	result := "Check memory usage before hitting OK";
	
	read result;
	
epilog
	delete t;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="kpdTestHook" id="42a8c848-2384-4b7f-8845-12ca5617a42b">
        <source>kpdTestHook(_interfaceDef:CM_InterfaceDefinition; 
		    _locationParams:CMIF_LocationTransParams):String;

vars
				_translatedTADesc:String;
				_defaultDescription:String; 
				_location:CM_LocationsController; 
				_isSource:Boolean;

	wagon :	CM_Wagon;
	returnString, tempString :	String;
	index :	Integer;
	label :	String;
	slotRequest :	CM_SlotRequest;
	job :	CM_Job;
	wle :	CM_WorkListEntry;
	rowLabel :	String;
	
begin
	_translatedTADesc := _locationParams.translatedTADesc;
	_defaultDescription := _locationParams.defaultDescription;
	_location := _locationParams.myLocation;
	_isSource := _locationParams.isSource;
	
	if _location.isKindOf(CM_BlockController) then // Block stack - the translationj is done within JMT
		
		return _translatedTADesc;
		
	elseif _location.isKindOf(CM_GridController) then // Straddle Stack - e.g. "A B 51 bar 2"
	
		returnString := _translatedTADesc &amp; ' ';
		
		if _location.CM_GridController.myTerminalArea.CM_GridArea.numberOfColumns &lt;= 2 then
			rowLabel := _location.CM_GridController.getRowLabel;
			if rowLabel.isInteger then
				// Strip leading zeros from these pads.
				tempString := rowLabel.Integer.String;
			else
				tempString := rowLabel;
			endif;
			returnString := returnString &amp; tempString;
		else
			returnString := returnString &amp; _location.getID;
		endif;
		
		if not _isSource then
			
			// Read out the height for areas that are more than one high.
			if _location.myTerminalArea.CM_GridArea.heightOfStack &gt; 1 then
				// There must be an cleaner way of getting the height.
				returnString := returnString &amp; " bar " &amp; (_location.getNumTIs(REAL_MODE) + 1).String;
			endif;
		endif;
	
		return returnString;
		
	elseif _location.isKindOf(CM_VehicleController) then // Road - "lane 1, truck front, doors aft"
	
		return "lane" &amp; _location.CM_VehicleController.vehicle.batNumber;
		
		// To get door direction it may be necessary to go CM_Container.allQueuedFutureMoves -&gt; CM_FutureMoveQueued.allRTQueueEntries
		//	-&gt; CM_RTQueueEntry.myWorkListEntry -&gt; CM_WorkListEntry.myRequest::getDoorDirectionDescription
		
	elseif _location.isKindOf(CM_WagonController) then // Rail e.g. "rail north, line 1, position 5, south end"
	
		returnString := _translatedTADesc;
		
		wagon := _location.CM_WagonController.myWagon;
		if wagon &lt;&gt; null then
			
			if wagon.myRailLine &lt;&gt; null then
				returnString := returnString &amp; ", line " &amp; wagon.myRailLine.id.Integer.String;
			else
				returnString := returnString &amp; ", unknown line";
			endif;
			
			index := wagon.myRailLine.allWagons.indexOf(wagon);
			
			if index &gt; 0 then
				returnString := returnString &amp; ", position " &amp; index.String;
			else
				returnString := returnString &amp; ", unknown position";
			endif;
		else
			returnString := returnString &amp; ", unknown wagon";
		endif;
			
		label := _location.CM_WagonController.getLabel;
		if label.Integer &lt; 3 then
			returnString := returnString &amp; ", north end";
		else
			returnString := returnString &amp; ", south end";
		endif;
		
		return returnString;

	elseif _location.isKindOf(CM_SlotController) and not _isSource then // load to ship
		// for single 20' - "B crane, lane 3, bay 60"
		// for twin crane lift, single 20' - "B crane, lane 3, north"
		// for 40' or twin 20' straddle - "B crane, lane 3"
	
		// SPNTEMP - shouldn't need to give the bay id for 40s or twin straddle lift
		// Change this when a container is passed in. Can then use  _location.CM_SlotController.getBayId
		// rather than looking at the CM_BayVoyage
		slotRequest := _location.CM_SlotController.mySlotRequestLoad;
		if slotRequest &lt;&gt; null then
			if slotRequest.myJob &lt;&gt; null and slotRequest.myJob.isKindOf(CM_VoyageJob) then
				returnString := slotRequest.myJob.CM_VoyageJob.craneId &amp; " crane";
			endif;
			if slotRequest.allWorkListEntries.size = 1 then
				wle := slotRequest.allWorkListEntries.first;
				if wle.isKindOf(CM_VoyageWLE) then
					returnString := returnString &amp; ", lane " 
						&amp; slotRequest.allWorkListEntries.first.CM_VoyageWLE.defaultCraneLoadLane.String;
						
					tempString := app.extrapolateBayDirection(wle.CM_VoyageWLE, 
						app.myPassport.myTerminal.getConfig(CraneLaneDescription).Integer);
					if tempString &lt;&gt; null then
						returnString := returnString &amp; ", " &amp; tempString;
					endif;
				endif;				
			endif;
			
			// Don't give the door direction for the aft - 90% of containers go on this way.
			if slotRequest.getDoorsDirection = TI_DOORSDIRN_FWD or slotRequest.getDoorsDirection = TI_DOORSDIRN_DEF_FWD then
				returnString := returnString &amp; ", doors forward";
			endif;
		endif;
		
		if _location.CM_SlotController.myBayVoyage &lt;&gt; null then
			if _location.CM_SlotController.myBayVoyage.id.isInteger then
				// Convert to an integer and back again to trim off leading zeros.
				returnString := returnString &amp; ", bay " &amp; _location.CM_SlotController.myBayVoyage.id.Integer.String;
			else
				returnString := returnString &amp; ", bay " &amp; _location.CM_SlotController.myBayVoyage.id;
			endif;
		endif;
			
		return returnString;
	
	else
	
		return _defaultDescription;
	endif;
	
end;
	</source>
        <Parameter name="_interfaceDef" type="CM_InterfaceDefinition"/>
        <Parameter name="_locationParams" type="CMIF_LocationTransParams"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="kpdTestIsEmpty" id="6b23b038-860e-4c3e-bff5-490278ad7f5b">
        <source>kpdTestIsEmpty();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 January 2013	cnwkpd1	PAR #30400 - SFW 1290 - Transaction EDI file type

*/

constants
	MaxCount		= 50000;
	
vars
	i				: Integer;
	start			: Decimal[20];
	ya				: CM_YADataObjects;
	val				: Boolean;
	
begin
	beginTransaction;
	create ya;
	commitTransaction;
	
	write "Testing with " &amp; MaxCount.String &amp; " iterations";
	
	start := app.relativeMachineTime();
	
	foreach i in 1 to MaxCount do
		val := ya.isEmpty();
	endforeach;
	
	write "Elasped time for non-instantiated collection = " &amp; (app.relativeMachineTime() - start).String;
	
	beginTransaction;
	ya.allObjects.add(CM_Root.firstInstance());
	commitTransaction;
	beginTransaction;
	ya.allObjects.clear();
	commitTransaction;
	
	start := app.relativeMachineTime();
	
	foreach i in 1 to MaxCount do
		val := ya.isEmpty();
	endforeach;
	
	write "Elasped time for instantiated collection = " &amp; (app.relativeMachineTime() - start).String;
	
epilog
	if ya &lt;&gt; null then
		beginTransaction;
		delete ya;
		commitTransaction;
	endif;
	
end;</source>
    </JadeMethod>
