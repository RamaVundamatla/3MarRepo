    <JadeMethod name="addToolbarControls" id="f858f114-c7ac-4fbc-90b1-8cbe90676171">
        <updating/>
        <source>addToolbarControls() updating, protected;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	frm				: CMUI_Toolbar;
begin	
	frm := self.frmToolbar;

	inheritMethod();
	frm.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnShowSearcher, CMUI_Toolbar.Control_Alignment_Left);
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnEditItem, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnCopy, CMUI_Toolbar.Control_Alignment_Left);
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnDeleteMapping, CMUI_Toolbar.Control_Alignment_Left);
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnRefresh, CMUI_Toolbar.Control_Alignment_Left);
	
	frm := self.frmToolbarCopy;
	frm.addButton(self.btnCopySave, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnCopyCancel, CMUI_Toolbar.Control_Alignment_Right);
	frm.positionToolbarControls();
	frm.visible := true;
	
	frm := self.frmToolbarDelete;
	frm.addButton(self.btnDeleteSave, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnDeleteCancel, CMUI_Toolbar.Control_Alignment_Right);
	frm.positionToolbarControls();
	frm.visible := true;
	
	frm := self.frmPropToolbar;
	frm.addButton(self.btnPropSave, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnPropDelete, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnPropCancel, CMUI_Toolbar.Control_Alignment_Right);
	frm.positionToolbarControls();
	frm.visible := true;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="addToolbarControlsQuery" id="628c091f-4d99-41d6-bd09-18ab36d5c053">
