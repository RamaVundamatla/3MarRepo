    <JadeMethod name="validateMe" id="859b042a-b38f-4255-8b5d-6a2dfdefb684">
        <source>validateMe();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 April 2013	cnwndl1	Initial creation	Par 31393

*/

vars

	existingTemplate : CM_VehicleBookingTimeTemplate;
	realTemplate : CM_VehicleBookingTimeTemplate;

begin

	
	if self.myVehicleBookingDayTemplate = null then
		app.raiseCMException(No_Vehicle_visit_Day_template, null, null);
		return;
	endif;
	
	if self.duration &lt; 1 then
		app.raiseCMException(Duratio_must_minute_more, null, null);
	endif;
	
	if self.numberOfSlots &lt; 1 then
		app.raiseCMException(Number_bookin_slots_must_great, null, null);
	endif;
	
	
	//27 Nov 2014	NDL	- found during testing.
	if self.isTransient then
		realTemplate := self.pxyGetRealObject();
	else
		realTemplate := self;
	endif;
	
	existingTemplate := self.myVehicleBookingDayTemplate.allTimeTemplates.getAtKey( self.startTime, self.endTime, self.myVBTimeslotType );
	if existingTemplate &lt;&gt; null and existingTemplate &lt;&gt; realTemplate then
		app.raiseCMException(Templ_with_this_start_time_dur, null, null);
	endif;
	
epilog

end;</source>
    </JadeMethod>
</Class>
