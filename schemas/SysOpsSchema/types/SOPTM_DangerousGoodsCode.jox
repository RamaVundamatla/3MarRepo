    <JadeMethod name="doSave" id="6e63320f-1143-436b-808b-202f319abb5d">
        <updating/>
        <source>doSave(): Boolean updating;
//
// Changed On	By			Reason
// ----------	--------	---------------------------------------------------
// 12/06/2015	cnwdap1		PAR #36421 Hazardous Materials Recording
// 07/11/2016	cnwdap1		TFS 2841 STWR Hazardous Details Enhancements
//
vars
	proxyCode			: CM_UNDangerousGoods;
	lCode,
	lNameDesc,
	symbols,
	emergency,
	marinePollutant,
	additional: String;
	theForm				: SOP_TableMaintForm;
	hazClasses,pkgGrps	: StringArray;
	dontUse				: Boolean;
	hazClass 	: CM_HazardClass;
	selectedClasses : ObjectArray;								// PAR #36421
	secondaryClasses : CM_StringArray;							// PAR #36421
	obj : Object;												// PAR #36421
	isMarinePoll : Integer;				// TFS 2841
	isMarinePollMand : Boolean;			// TFS 2841
begin

	theForm := self.myForm; 
	create pkgGrps transient;
	create selectedClasses transient;							// PAR #36421
	create secondaryClasses transient;							// PAR #36421
	
	lCode := theForm.tblInput1.getValueByName(ETRow_Code).asStringJMT;
	lNameDesc := theForm.tblInput1.getValueByName(ETRow_NameDesc).asStringJMT;
	self.getPkgGroups(theForm.tblInput1.getValueByName(ETRow_AllPackingGroups).String, pkgGrps);
	dontUse := theForm.tblInput1.getValueByName(ETRow_NoLongerUsed).Boolean;
	symbols := 	theForm.tblInput1.getValueByName(ETRow_Symbols).asStringJMT;
	additional := theForm.tblInput1.getValueByName(ETRow_Additional).asStringJMT;
	marinePollutant := theForm.tblInput1.getValueByName(ETRow_MarinePollutant).asStringJMT;
	emergency := theForm.tblInput1.getValueByName(ETRow_Emergency).asStringJMT;
	hazClass := theForm.comboBox1.getCurrentItemObject.CM_HazardClass;
	
	isMarinePoll := app.isMarinePollutantStringToEnum(theForm.tblInput1.getValueByName(ETRow_IsMarinePollutant).String);	// TFS 2841
	isMarinePollMand := theForm.tblInput1.getValueByName(ETRow_IsMarinePollutantMand).Boolean;								// TFS 2841
	
	foreach obj in theForm.lstSecClasses.allSelectedObjects do					// PAR #36421
		if not secondaryClasses.includes(obj.CM_HazardClass.code) then			// PAR #36421
			secondaryClasses.add(obj.CM_HazardClass.code);						// PAR #36421
		endif;																	// PAR #36421
	endforeach;																	// PAR #36421
	
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_UNDangerousGoods transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	proxyCode := theForm.myProxyObject.CM_UNDangerousGoods;
	//proxyCode.setForProxy(lCode,lNameDesc, false, hazClass,  pkgGrps,symbols,emergency, marinePollutant, additional, dontUse);					// PAR #36421
	//proxyCode.setForProxy(lCode,lNameDesc, false, hazClass,  pkgGrps,symbols,emergency, marinePollutant, additional, secondaryClasses, dontUse);	// PAR #36421					// TFS 2841
	proxyCode.setForProxy(lCode,lNameDesc, false, hazClass,  pkgGrps, symbols, emergency, marinePollutant, isMarinePoll, isMarinePollMand, additional, secondaryClasses, dontUse);	// TFS 2841

	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateUNDGCode(proxyCode, theForm.myCurrentObject,app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateUNDGCode(proxyCode,app.myPassport);
	else
	
		return false;
	endif;
	
	return app.myPassport.trxCompletedOK;
epilog
	delete pkgGrps;
	delete secondaryClasses;									// PAR #36421`
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
