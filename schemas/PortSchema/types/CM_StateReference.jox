<Class name="CM_StateReference" id="15fea4dd-30ee-4347-819d-8e5476eacad0">
    <superclass name="CM_StateData"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmstate"/>
    <ImplicitInverseRef name="myValue" id="f55c06ba-bee7-4a78-946c-33fe6be9628a">
        <embedded/>
        <type name="CM_Object"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="getValue" id="640aca55-f787-4493-b688-0447b721dde1">
        <source>getValue(): Any;
// ---------------------------------------------------------------------------
// Created:     09 July 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 09 Apr 2010	cnwkpd1		PAR #20728 - Replace isValidObject with exception handler
// 07/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
// ---------------------------------------------------------------------------

vars
	invalid		: Boolean;
	ed			: Integer;
	value		: CM_Object;
begin
	value := self.myValue;
	if value &lt;&gt; null then
		// Check if the object is valid.  This is done primarily because
		// we cannot put an inverse to here (and would not want to in most cases).
		on Exception do app.handleDeletedObject(exception, value, invalid);
		ed := value.edition();		// De-reference to check validity
		if not invalid then
			return value;
		endif;
	endif;
	
	return null;

end;</source>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="d0c1c343-b093-4594-a3c0-e04940383cb5">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     09 July 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// ---------------------------------------------------------------------------
vars
	proxyStateRef	: CM_StateReference;
	completedOK		: Boolean;
	
begin

	proxyStateRef := inheritMethod();
	
	proxyStateRef.setValue(self.myValue);
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyStateRef;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyStateRef;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setValue" id="970bfeda-5ec5-4e1d-a87e-b106365d0810">
        <updating/>
        <source>setValue(pValue: Any) updating;
// ---------------------------------------------------------------------------
// Created:     09 July 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.myValue := pValue.CM_Object;
	
end;</source>
        <Parameter name="pValue" type="Any"/>
    </JadeMethod>
</Class>
