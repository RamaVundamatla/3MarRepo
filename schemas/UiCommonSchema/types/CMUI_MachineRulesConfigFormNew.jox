    <JadeMethod name="createNewProxy" id="09b39c94-8cc5-4e18-a3fa-a1e444ec519e">
        <updating/>
        <source>createNewProxy() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 February 2010	cnwer1	Initial creation

*/

vars
	ruleType : Integer;
begin
	ruleType:=self.cmbRuleType.listIndex;
	
	
	if ruleType = RuleTypeTAMaster then
		if self.myProxyMultiRule &lt;&gt; null  then
			if  self.myProxyMultiRule.isKindOf(CM_RTQueueMultiRuleTAMaster) then
				return;
			else
				delete self.myProxyMultiRule;
				self.tblMoveRules.rows:=1;
			
			endif;
		endif;
		create self.myProxyMultiRule as CM_RTQueueMultiRuleTAMaster transient;
	elseif ruleType = RuleTypeTAType then
		if self.myProxyMultiRule &lt;&gt; null then
			if self.myProxyMultiRule.isKindOf(CM_RTQueueMultiRuleTAType) then
				return;
			else
				delete self.myProxyMultiRule;
				self.tblMoveRules.rows:=1;
			endif;
		endif;
		create self.myProxyMultiRule as CM_RTQueueMultiRuleTAType transient;
		
	endif;
	if self.myProxyMultiRule &lt;&gt; null then
		self.myProxyMultiRule.setForProxy(self.myTerminal);
	endif;
	self.cmbMoveMethod.initialise(true);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="9b60232b-a08e-4047-8921-4b1b57e7ad0f">
