    <JadeMethod name="createWorkOrderStatus" id="8ed605cf-10b9-4848-af02-8426ba49c1ec">
        <source>createWorkOrderStatus(_controller: CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Oct 2022 navds20 Task ChangeRequest 54253: EUP - VAS Work Orders
22 Dec 2022 navhl20	Defect 56003(54253): EUP - Duplicate Work order status on security role screen
*/

vars
	index : CM_SecurityRoleTerminal;
begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Initializing Work Order Status for Terminal Securityroles ", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Initializing Work Order Status for Terminal Securityroles ") ;	
	endif;
	
	beginTransaction;
	foreach index in CM_SecurityRoleTerminal.instances do
		index.allWorkOrderStatusMaint.purge();		//22.12.2022 navhl20 TFS 56003(54253)
		index.setWOStatus();
	endforeach;
	
	foreach index in CM_SecurityRoleTerminalRoot.instances do
		index.allWorkOrderStatusMaint.purge();		//22.12.2022 navhl20 TFS 56003(54253)
		index.setWOStatus();
	endforeach;
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Initializing Work Order Status for Terminal Securityroles ", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Initializing Work Order Status for Terminal Securityroles ") ;	
	endif;	
	
	self.addScriptRun(method.name);
epilog

end;</source>
