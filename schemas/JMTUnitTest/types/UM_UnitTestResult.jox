    <JadeMethod name="stripNONASCIICharacters" id="604d4bb4-3439-433a-89b3-889f6de143b6">
        <source>stripNONASCIICharacters(_details : String) : String;
/*

Purpose:		Strip Non ASCII Characters from details string

Parameters:			

Return Value:		

Date		Who		Reason
20/08/2019	jlgmh5	Initial creation

*/

vars

	tempStr					: String;
	linePtr					: Integer;

begin

	linePtr := 0;
	
	while linePtr &lt; _details.length do
		linePtr := linePtr + 1;
		if _details[linePtr].Character.Integer &gt; 127 or _details[linePtr].Character.Integer = null then
			continue;
		endif;
		tempStr := tempStr &amp; _details[linePtr];
	endwhile;
	
	return tempStr;
		
epilog

end;</source>
        <Parameter name="_details" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="updateDetails" id="77f47af7-ddd6-4ef1-af88-7ac32529c7ab">
        <updating/>
        <source>updateDetails(_className, _methodName, _elaspsedTime, _emailedTo, _ownerName, _result, _details : String; _runTS : TimeStamp; _testRun : UM_UnitTestRun; _jiraItem : String) updating;

/*

Purpose:		Update the result details

Date			Who		Reason
02/09/2013		cnwmh5	Initial creation
20/08/2019		jlgmh5	Strip Non ASCII Characters out of details
16 Oct 2025		navbs1	Story MTN-34979: MTN - Unit Test Results App - Add Jira Item Column - Phase2

*/

vars

begin

	self.elapsedTime := _elaspsedTime;
	self.emailedTo := _emailedTo;
	self.ownerName := _ownerName;
	///self.details := self.stripNONASCIICharacters(_details).compressToBinary(Binary.Compression_ZLib);
	self.details := _details.compressToBinary(Binary.Compression_ZLib);
	self.methodRunStartTS := _runTS;
	
	// sort result out
	self.result := self.getResultDetails(_result).Integer;
	
	// set test run
	self.myTestRun := _testRun;
	
	// set class / method details
	self.myClassMethod := self.getClassMethodDetails(_className, _methodName);
	
	self.jiraItem := _jiraItem;			//17.10.2025 navbs1  #34979

epilog

end;</source>
        <Parameter name="_className" type="String"/>
        <Parameter name="_methodName" type="String"/>
        <Parameter name="_elaspsedTime" type="String"/>
        <Parameter name="_emailedTo" type="String"/>
        <Parameter name="_ownerName" type="String"/>
        <Parameter name="_result" type="String"/>
        <Parameter name="_details" type="String"/>
        <Parameter name="_runTS" type="TimeStamp"/>
        <Parameter name="_testRun" type="UM_UnitTestRun"/>
        <Parameter name="_jiraItem" type="String"/>
    </JadeMethod>
