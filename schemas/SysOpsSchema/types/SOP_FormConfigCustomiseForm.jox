end;</source>
    </JadeMethod>
    <JadeMethod name="doAddControl" id="edcceabf-71b2-440a-9abd-3b126f686029">
        <updating/>
        <source>doAddControl(_control:Control input)updating;
/*
	Purpose:			
	Parameters:			
	Return Value:		

Date		Who		Reason
30 July 2008	concms1	Initial creation
*/

vars
	begin

	self.addControl (_control);
	
	if _control.isKindOf (Label) then
		_control.setEventMapping  ('click', 'doLabelClick');
	
		_control.setEventMapping ('mouseDown', 'doMouseDown_Label');
		_control.setEventMapping ('dragDrop', 'doDragDrop_Label');
	elseif _control.isKindOf(TextBox) then
		_control.setEventMapping  ('click', 'doTextBoxClick');
		_control.setEventMapping ('mouseDown', 'doMouseDown_TextBox');
		_control.setEventMapping ('dragDrop', 'doDragDrop_TextBox');
		_control.TextBox.readOnly := true;
	elseif _control.isKindOf (ComboBox) then
		_control.enabled := false;
	elseif _control.isKindOf (GroupBox) then
		_control.setEventMapping ('dragDrop', 'doDragDrop_GroupBox');
		elseif _control.isKindOf (Frame) then
		_control.setEventMapping ('dragDrop', 'doDragDrop_Frame');
	endif;
epilog

end;</source>
        <Parameter name="_control" type="Control" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doBaseFormCancel" id="2f6cdff7-7b6d-4968-9d33-9bfe2bfbbe9d">
