    <PrimAttribute name="lastAuditFileComplete" id="530d0a06-dbad-46f2-b82c-0a777a859dfb">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="lastAuditFileNumber" id="19036753-eed6-4680-a4ca-1b20b73df0b5">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="lastAuditFileSequence" id="1c7a481b-adaf-4b88-9ad2-4cc0b13783fc">
        <precision>20</precision>
        <embedded/>
