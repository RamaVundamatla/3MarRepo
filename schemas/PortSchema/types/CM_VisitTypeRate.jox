    <JadeMethod name="getTimeRate" id="56ab83b9-d0a4-4263-8d93-f31bf253ee48">
        <source>getTimeRate(bank: CM_Bank; t: TimeStamp): CM_RateEntry;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Jun 2018 cnwma1	ChangeRequest 38953: PEL1 - Berth Rates, Vessel Type Rates, Visit Types

*/

vars
	iter : Iterator;
	found : Boolean;
	retVal : CM_RateEntry;

begin
	iter := self.rateEntries.createIterator;
	self.rateEntries.startKeyLeq(t, iter);
	found := false;
	while iter.back(retVal) do
		if retVal.ignoreThisEntry then
			continue;
		endif;
		if retVal.expiryTimestamp &lt;&gt; null and
		   retVal.expiryTimestamp &lt;= t then
			continue;
		endif;
		found := true;
		break;
	endwhile;
	if not found then
		retVal := null;
	endif;
	return retVal;
epilog
	delete iter;
end;</source>
        <Parameter name="bank" type="CM_Bank"/>
        <Parameter name="t" type="TimeStamp"/>
        <ReturnType type="CM_RateEntry"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="86c4c6d7-54f1-4c67-8774-8b76e1c7c0fc">
