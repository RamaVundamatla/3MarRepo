    <JadeMethod name="translateForm" id="9737c59d-6452-4458-9e09-c27bba5e2b1c">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 18 July 2024 01:51:41.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0015108, locale);
	btnClose.translateCaption(Xlat_0015109, locale);
	btnFilter.translateCaption(Xlat_0021056, locale);
	btnInstruction.translateCaption(Xlat_0025205, locale);
	btnSave.translateCaption(Xlat_0015110, locale);
	btnSaveAndClose.translateCaption(Xlat_0015111, locale);
	grpBottom.translateCaption(Xlat_0015112, locale);
	mnuColOrganizer.translateCaption(Xlat_0026921, locale);
	mnuTaskForm.translateCaption(Xlat_0026922, locale);
end;</source>
    </JadeMethod>
