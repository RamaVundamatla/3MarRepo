    <JadeMethod name="closeAllOpenForms" id="6ef429e1-2d68-4df2-b2fb-e9aef0577d97">
        <source>closeAllOpenForms();
/*
Purpose:			
Date		Who		Reason
05 November 2015	cnwab1	Initial creation
*/

vars
	numForms,
	idx	, nullforms	: Integer;
	tmpForm	: Form;
	baseForm : CM_BaseForm;
	ask : Boolean;
  begin
	
	ask := true;
	if process.isJLGAB1() then
		ask := false;
	endif;
	
	if ask then
		//epr TFS 2444 28/7/16
		if  app.msgBox(app.getErrorString(Close_all_warning),app.getErrorString(Warning),MsgBox_Yes_No) = MsgBox_Return_No then
				return;
		endif;
	endif; 
	  
	while true do
		numForms	:= app.formsCount;
		nullforms := 0;
		foreach idx in 1 to numForms do
			tmpForm := app.forms(idx);
			
			// some open forms are nulls, next time round they are not nulls
			if  tmpForm = null then
				nullforms := nullforms + 1;
				continue;
			endif;
			
			//write tmpForm.name;
			if tmpForm.isKindOf(CMUI_Navigator) 
			or tmpForm.isKindOf(CMS_UserMessageForm) 
			or tmpForm.isKindOf(CMUI_SuperAppForm2) 
			or tmpForm = null then
				continue;
			endif;
			
			tmpForm.unloadForm();
		endforeach;
		
		if nullforms = 0 then
			break;
		endif;
	endwhile;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="cmbTblColFilter_click" id="095ffdf3-b5c0-4feb-92bd-1a027cc7592a">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbTblColFilter_click( combobox : ComboBox input ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 September 2014	cnwndl1	Initial creation

*/

vars

	parent : Window;
	str : String;
	row : Integer;
	column : Integer;
	colIndex : Integer;
	filterCombo : CMUI_ComboBox;
	cell : JadeTableCell;
	tbl : CM_DataTable;

begin

	process.isNDLref;

	parent := combobox.parent;
	if parent &lt;&gt; null and parent.isKindOf( CM_DataTable ) then
		tbl := parent.CM_DataTable;

		row := tbl.row;
		column := tbl.column;
		str := combobox.text;
		if str = Table.ClearFilters then
			foreach colIndex in 1 to tbl.columns do
				cell := tbl.accessCell(2,colIndex);
				filterCombo := combobox.CMUI_ComboBox.getControl(colIndex);
				if filterCombo &lt;&gt; null then
					filterCombo.listIndex := 1;
				endif;
				cell.text := filterCombo.text;
			endforeach;
			tbl.row2FilterShowAllRows();
		else
			tbl.row2FilterApplyFilters( combobox.CMUI_ComboBox );
			tbl.accessCell( row, column ).text := str;
			if str = Table.AllValues then
				tbl.accessCell( row, column ).foreColor := Black;
				tbl.accessCell( row, column ).backColor := tbl.accessCell( 1, 1 ).backColor;
			else
				tbl.accessCell( row, column ).foreColor := Red;
				tbl.accessCell( row, column ).backColor := White;
			endif;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
