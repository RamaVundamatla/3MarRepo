    <JadeMethod name="getDisplayStringForAttribute" id="09be6749-f1ee-43ad-ad38-cf1d58e831c0">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 May 2018	jlgndl1	Initial creation	TFS 38535

*/

vars

begin

	if _attrName = ETRow_BusUnit then
		return self.myBusinessUnit.code;
	elseif _attrName = ETRow_EffectiveDT then
		return self.effectiveDT.asStringJMT;
	elseif _attrName = ETRow_UserName then
		if self.myUser = null then
			return self.userName;
		else
			return self.myUser.userName;
		endif;
	elseif _attrName = ETRow_UserId then
		if self.myUser = null then
			return self.userID;
		else
			return self.myUser.code;
		endif;
	else
		return inheritMethod(_attrName, _short);
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="33657771-9a5b-4e71-9ff7-9e5eb16264f0">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2018	jlgndl1	Initial creation	TFS 38535

*/

vars

	proxy : CM_InvoiceSignoffUser;
	completedOK : Boolean;

begin

	proxy := inheritMethod();
	
	proxy.myBusinessUnit := self.myBusinessUnit;
	proxy.myUser := self.myUser;
	
	completedOK := true;
	return proxy;

epilog

	if not completedOK then	
		delete proxy;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
