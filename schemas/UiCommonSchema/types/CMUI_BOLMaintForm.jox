    <JadeMethod name="loadOperatorCombo" id="0bef47be-ba63-49bd-8b7b-f33db3b4f664">
        <source>loadOperatorCombo();
//12 March 2010	cnwml2
//03 Aug 2022 	navds20 Bug 54202: EUP - Combo Boxes not adhereing to configuration (operator and Stevedore)

vars
	voy : CM_Voyage;
	op : CM_Operator;
	selectedOp : CM_Operator;
	byName : Boolean;			// navds20 TFS 54202
begin
	voy := self.cmbVoyage.listObject.CM_Voyage;
	
	selectedOp := self.cmbOperator.listObject.CM_Operator;
	
	byName := app.myRoot.getConfig(ComboByNameOperator).Boolean;	// navds20 TFS 54202
	self.cmbOperator.clear();
	if voy &lt;&gt; null then
		foreach op in voy.allOperators do
			//start 04/08/2022 navds20 TFS 54202
			if not byName then
				self.cmbOperator.addItemObject(op.code &amp; Tab &amp; op.description, op);
			else
				self.cmbOperator.addItemObject(op.description, op);
			endif;
			//end 04/08/2022 navds20 TFS 54202
		endforeach;
		
		if voy.allOperators.includes(selectedOp) then
			self.cmbOperator.listObject := selectedOp;
		else
			self.cmbOperator.listObject := null;
		endif;
	else
		foreach op in app.myRoot.allOperators do
			//start 03/08/2022 navds20 TFS 54202
			if not byName then
				self.cmbOperator.addItemObject(op.code &amp; Tab &amp; op.description, op);
			else
				self.cmbOperator.addItemObject(op.description, op);
			endif;
			//end 03/08/2022 navds20 TFS 54202
		endforeach;
		
		if app.myRoot.allOperators.includes(selectedOp) then
			self.cmbOperator.listObject := selectedOp;
		else
			self.cmbOperator.listObject := null;
		endif;
	endif;
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadVoyageCombo" id="9ca3d37e-8340-4555-97f9-d398f5a695b1">
        <source>loadVoyageCombo(_firstTime : Boolean);
//27 January 2010	cnwml2
// Purpose:
// Date				Who		Reason
// 8 February 2023	navmk20	Bug 56397: EUP Testing | Voyage removed from BOL if not current
// ---------------------------------------------------------------------------

vars
	operator : CM_Operator;
	voy : CM_Voyage;
	iter : Iterator;
	idx : Integer;
	passport : CM_Passport;
	failedDAC  :CM_DataAccessController;
	tmpStr	: String;
	gracePeriod : Integer;
	checkDT : TimeStamp;
begin
	
	
	if _firstTime then
		if self.myCurrentBOL &lt;&gt; null then
			operator := self.myCurrentBOL.myOperator;
		endif;
	else
		operator := self.cmbOperator.listObject.CM_Operator;
	endif;
	if operator &lt;&gt; null and
	   not self.fromOnshipForm then
		iter := operator.allVoyages.createIterator;
		
		self.cmbVoyage.clear;
		
		passport := app.myPassport;
		
		while iter.next(voy) do
		
			if not voy.canUserAccessSelf(null, failedDAC, passport) then
				continue;
			endif;
			
			if voy.myTerminal &lt;&gt; self.myTerminal then									//+cnwml2  PAR20835
				continue;																//+cnwml2  PAR20835
			endif;																		//+cnwml2  PAR20835
			
			gracePeriod := self.myTerminal.getConfig(VoyDepartedGracePeriod).Integer;
			if gracePeriod = null then
				gracePeriod := 24;
			endif;
			
			checkDT := app.actualTimeServer();
			checkDT := checkDT.changeByXXHours(-gracePeriod);	
					
			if not voy.isActiveDisplay(checkDT) then		
				continue;
			endif;	
			
			tmpStr := voy.code &amp; Tab &amp; voy.description;
			idx := cmbVoyage.addItem(tmpStr);
			self.cmbVoyage.itemObject[idx] := voy;
	
		endwhile;
	else
		//epr par 34857 17/11/14
		self.myAssistant.comboBoxVoyageCurrent(self.cmbVoyage, app.getMyCurrentVoyage(),true,false,false,true,false,false,false,false,false);
	endif;
	//start 8.2.2023 navmk20 TFS 56397
	voy := self.myVoyage;
	if voy &lt;&gt; null then
		if self.cmbVoyage.findObject(voy) &lt; 1 then
			tmpStr := voy.code &amp; Tab &amp; voy.description;
			idx := cmbVoyage.addItem(tmpStr);
			self.cmbVoyage.itemObject[idx] := voy;
		endif;
	endif;
	//end 8.2.2023 navmk20 TFS 56397
epilog
	delete iter;

end;</source>
        <Parameter name="_firstTime" type="Boolean"/>
    </JadeMethod>
