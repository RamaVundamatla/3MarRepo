    <JadeMethod name="tInvoiceMerge05" id="477761e6-ab8e-4a8c-adb3-6cc35bdbebfd">
        <source>tInvoiceMerge05();
/*
Purpose - 	Create 3 invoices, two are TAS. Merge one TAS into the non TAS invoice.  Try to merge 2nd TAS into same non TAS and shoudl get an error
Who - NAVAB1
Date - 09JAN2024
ADO -  CR 58085 TASK 61344
*/
constants
	LineTypeName = "UT_InvMerge";
	LineTypeTASName = "UT_InvTypeApi";
vars
	calcType1	: CM_CalculationType;
	service		: CM_Service;
	ild			: CM_InvoiceLineDesc;
	invType, invTypeTAS		: CM_InvoiceDesc;
	services	: CM_ServiceByNameDict;
	operator	: CM_Operator;
	bu : CM_Bank;
	invoice001, invoice002, invoice003, targetInvoice : CM_Invoice;
	agent : CMIF_InvoiceLineMerge ;
	
	opdebtor, seconddebtor : CM_Debtor;
	bank : CM_Bank;
begin
	bank := self.getTerminal().getDefaultCompanyBank();

	
	self.deleteInvoiceService(LineTypeName, FORCED_ERASE);
	self.deleteInvoiceLineType(LineTypeName, FORCED_ERASE);
	self.deleteInvoiceType(LineTypeName);
	
	self.deleteInvoiceType(LineTypeTASName);
	
	self.assertNoTrxErrorsOrWarnings();
	
	calcType1 := app.myRoot.allCalculationTypesByCode['CCT00'];	// INV_CALC_TYPE_UNITY;
	self.assertNotNullMsg(calcType1, "Calculation type INV_CALC_TYPE_UNITY not found");

	// create new instances
	create services transient;
	invType := self.createInvoiceType(LineTypeName, InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type " &amp; LineTypeName &amp; " not created");
	
	// APIINV
	self.opts.purge();
	self.opts.addAssoc("APIINV", true);
	invTypeTAS := self.createInvoiceType(LineTypeTASName, InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type " &amp; LineTypeTASName &amp; " not created");
	self.assertTrueMsg(invTypeTAS.useForApiInv = true, "invTypeTAS.useForApiInv is false");
	
	self.opts.purge();

	service := self.createInvoiceService(LineTypeName, LineTypeName, calcType1, null);
	self.assertNotNullMsg(service, "Service " &amp; LineTypeName &amp; " not created");
	
	services.add(service);
	ild := self.createInvoiceLineType(LineTypeName, calcType1, invType, services, "SDT1");
	self.assertNotNullMsg(ild, "Invoice Line Type " &amp; LineTypeName &amp; " not created");
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);	
	opdebtor := operator.debtor;
	bu := self.getTerminal().getDefaultCompanyBank();
	
	
	// ### MANUAL INVOICE ONE
	invoice001 := self.createManualInvoice(bu,opdebtor,null,invTypeTAS,null);
	
	// ### MANUAL INVOICE TWO
	invoice002 := self.createManualInvoice(bu,opdebtor,null,invTypeTAS,null);
	
	// ### MANUAL INVOICE THREE
	invoice003 := self.createManualInvoice(bu,opdebtor,null,invType,null);
	
	//22/01/2023	navkc1 CR 62038 Task 62039
	beginTransaction;
	invoice001.setContext(CM_Invoice.TAS);
	invoice002.setContext(CM_Invoice.TAS);
	commitTransaction;
	
	// ### MANUAL INVOICE LINES
	self.createManualInvoiceLineRate(invoice001, ild, 231.81056,null);
	self.createManualInvoiceLineRate(invoice001, ild, 231.16032,null);
	self.createManualInvoiceLineRate(invoice001, ild, 231.16032,null);
	self.assertTrueMsg(invoice001.invoiceLines.size = 3, "Invoice 01 should have 3 lines");
	
	self.createManualInvoiceLineRate(invoice002, ild, 347.71584,null);
	self.createManualInvoiceLineRate(invoice002, ild, 346.74048,null);
	self.createManualInvoiceLineRate(invoice002, ild, 353.65944,null);
	self.createManualInvoiceLineRate(invoice002, ild, 231.16032,null);
	self.assertTrueMsg(invoice002.invoiceLines.size = 4, "Invoice 01 should have 4 lines");

	self.createManualInvoiceLineRate(invoice003, ild, 310.2976,null);
	self.createManualInvoiceLineRate(invoice003, ild, 309.4272,null);
	self.createManualInvoiceLineRate(invoice003, ild, 315.6016,null);
	self.assertTrueMsg(invoice003.invoiceLines.size = 3, "Invoice 03 should have 3 lines");

	
	// ### MANUAL INVOICE TARGET - NON TAS
	targetInvoice := self.createManualInvoice(bu,opdebtor,null,invType,null);
	self.createManualInvoiceLineRate(targetInvoice, ild, 231.81056,null);
	self.createManualInvoiceLineRate(targetInvoice, ild, 231.16032,null);
	self.createManualInvoiceLineRate(targetInvoice, ild, 231.16032,null);
	self.assertTrueMsg(targetInvoice.invoiceLines.size = 3, "Target invoice should have 3 lines");
	
	create agent transient;
	agent.myTargetInvoice := targetInvoice;
	agent.allInvoices.add(invoice001); // 1st TAS
	agent.allInvoices.add(invoice003); // NON TAS
	
	// merge should be OK
	app.myTrxUA.trxUpdateInvoiceMerge(agent, app.myPassport);
	
	self.assertTrueTrxOKShowPassport("trxUpdateInvoiceMerge");

	self.assertTrueMsg(invoice001.invoiceLines.size = 0, "Invoice 01 still has invoice lines");
	self.assertTrueMsg(invoice003.invoiceLines.size = 0, "Invoice 03 still has invoice lines");
	
	self.assertTrueMsg(invoice001.isVoided, "Invoice 01 should be VOIDED");
	self.assertTrueMsg(invoice003.isVoided, "Invoice 03 should be VOIDED");
	self.assertTrueMsg(targetInvoice.invoiceLines.size = 9, "Target invoice should have 9 lines");
	
	
	// ### Merge 2nd TAS into same invoice should ERROR
	agent.allInvoices.clear();
	agent.allInvoices.add(invoice002); // 2nd TAS
	
	
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(Invoic_alread_invoic_cannot_an); 

	app.myTrxUA.trxUpdateInvoiceMerge(agent, app.myPassport);

	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Unexpected DOUBLE TAS ISSUE");
	
	
epilog
	delete services;
	delete agent;
end;</source>
    </JadeMethod>
    <JadeMethod name="tInvoiceMerge06" id="fe83c631-221c-4135-8344-b1190b50e18c">
        <source>tInvoiceMerge06();
/*
Purpose - 	Create 3 credit notes, two are TAS. Merge one TAS into the non TAS credit note.  Try to merge 2nd TAS into same non TAS and should get an error
Who - NAVAB1
Date - 09JAN2024
ADO -  CR 58085 TASK 61344
*/
constants
	LineTypeName = "UT_InvMerge";
	LineTypeTASName = "UT_CNTypeApi";
vars
	calcType1	: CM_CalculationType;
	service		: CM_Service;
	ild			: CM_InvoiceLineDesc;
	invType, invTypeTAS		: CM_InvoiceDesc;
	services	: CM_ServiceByNameDict;
	operator	: CM_Operator;
	bu : CM_Bank;
	invoice001, invoice002, invoice003, targetInvoice : CM_Invoice;
	agent : CMIF_InvoiceLineMerge ;
	
	opdebtor, seconddebtor : CM_Debtor;
	bank : CM_Bank;
begin
	bank := self.getTerminal().getDefaultCompanyBank();

	
	self.deleteInvoiceService(LineTypeName, FORCED_ERASE);
	self.deleteInvoiceLineType(LineTypeName, FORCED_ERASE);
	self.deleteInvoiceType(LineTypeName);
	
	self.deleteInvoiceType(LineTypeTASName);
	
	self.assertNoTrxErrorsOrWarnings();
	
	calcType1 := app.myRoot.allCalculationTypesByCode['CCT00'];	// INV_CALC_TYPE_UNITY;
	self.assertNotNullMsg(calcType1, "Calculation type INV_CALC_TYPE_UNITY not found");

	// create new instances
	create services transient;
	invType := self.createInvoiceType(LineTypeName, InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type " &amp; LineTypeName &amp; " not created");
	
	// APIINV
	self.opts.purge();
	self.opts.addAssoc("APICN", true);
	invTypeTAS := self.createInvoiceType(LineTypeTASName, InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type " &amp; LineTypeTASName &amp; " not created");
	self.assertTrueMsg(invTypeTAS.useForApiCn = true, "invTypeTAS.useForApiCn is false");
	
	self.opts.purge();

	service := self.createInvoiceService(LineTypeName, LineTypeName, calcType1, null);
	self.assertNotNullMsg(service, "Service " &amp; LineTypeName &amp; " not created");
	
	services.add(service);
	ild := self.createInvoiceLineType(LineTypeName, calcType1, invType, services, "SDT1");
	self.assertNotNullMsg(ild, "Invoice Line Type " &amp; LineTypeName &amp; " not created");
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);	
	opdebtor := operator.debtor;
	bu := self.getTerminal().getDefaultCompanyBank();
	
	
	self.opts.purge();
	self.opts.addAssoc("Category", InvoiceCategory_CreditNote);
	
	// ### MANUAL CREDIT NOTE ONE
	invoice001 := self.createManualInvoice(bu,opdebtor,null,invTypeTAS,null);
	
	// ### MANUAL CREDIT NOTE TWO
	invoice002 := self.createManualInvoice(bu,opdebtor,null,invTypeTAS,null);
	
	// ### MANUAL CREDIT NOTE THREE
	invoice003 := self.createManualInvoice(bu,opdebtor,null,invType,null);
	
	//22/01/2023	navkc1 CR 62038 Task 62039
	beginTransaction;
	invoice001.setContext(CM_Invoice.TAS);
	invoice002.setContext(CM_Invoice.TAS);
	commitTransaction;
	
	// ### MANUAL INVOICE LINES
	self.createManualInvoiceLineRate(invoice001, ild, 231.81056,null);
	self.createManualInvoiceLineRate(invoice001, ild, 231.16032,null);
	self.createManualInvoiceLineRate(invoice001, ild, 231.16032,null);
	self.assertTrueMsg(invoice001.invoiceLines.size = 3, "Invoice 01 should have 3 lines");
	
	self.createManualInvoiceLineRate(invoice002, ild, 347.71584,null);
	self.createManualInvoiceLineRate(invoice002, ild, 346.74048,null);
	self.createManualInvoiceLineRate(invoice002, ild, 353.65944,null);
	self.createManualInvoiceLineRate(invoice002, ild, 231.16032,null);
	self.assertTrueMsg(invoice002.invoiceLines.size = 4, "Invoice 01 should have 4 lines");

	self.createManualInvoiceLineRate(invoice003, ild, 310.2976,null);
	self.createManualInvoiceLineRate(invoice003, ild, 309.4272,null);
	self.createManualInvoiceLineRate(invoice003, ild, 315.6016,null);
	self.assertTrueMsg(invoice003.invoiceLines.size = 3, "Invoice 03 should have 3 lines");

	
	// ### MANUAL CREDIT NOTE TARGET - NON TAS
	targetInvoice := self.createManualInvoice(bu,opdebtor,null,invType,null);
	self.createManualInvoiceLineRate(targetInvoice, ild, 231.81056,null);
	self.createManualInvoiceLineRate(targetInvoice, ild, 231.16032,null);
	self.createManualInvoiceLineRate(targetInvoice, ild, 231.16032,null);
	self.assertTrueMsg(targetInvoice.invoiceLines.size = 3, "Target invoice should have 3 lines");
	
	create agent transient;
	agent.myTargetInvoice := targetInvoice;
	agent.allInvoices.add(invoice001); // 1st TAS
	agent.allInvoices.add(invoice003); // NON TAS
	
	// merge should be OK
	app.myTrxUA.trxUpdateInvoiceMerge(agent, app.myPassport);
	
	self.assertTrueTrxOKShowPassport("trxUpdateInvoiceMerge");

	self.assertTrueMsg(invoice001.invoiceLines.size = 0, "Invoice 01 still has invoice lines");
	self.assertTrueMsg(invoice003.invoiceLines.size = 0, "Invoice 03 still has invoice lines");
	
	self.assertTrueMsg(invoice001.isVoided, "Invoice 01 should be VOIDED");
	self.assertTrueMsg(invoice003.isVoided, "Invoice 03 should be VOIDED");
	self.assertTrueMsg(targetInvoice.invoiceLines.size = 9, "Target invoice should have 9 lines");
	
	
	// ### Merge 2nd TAS into same invoice should ERROR
	agent.allInvoices.clear();
	agent.allInvoices.add(invoice002); // 2nd TAS
	
	
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(Invoi_alrea_credi_note_canno_a); 

	app.myTrxUA.trxUpdateInvoiceMerge(agent, app.myPassport);

	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Unexpected DOUBLE TAS ISSUE");
	
	
epilog
	delete services;
	delete agent;
end;</source>
    </JadeMethod>
    <JadeMethod name="tInvoiceMerge07" id="5723b632-ec7d-4a3e-8041-19cd0c8bffa5">
        <source>tInvoiceMerge07();
/*
Purpose - 	Create 2 credit notes, both are TAS. Merge one TAS into the other TAS credit note and should get an error
Who - NAVAB1
Date - 09JAN2024
ADO -  CR 58085 TASK 61344
*/
constants
	LineTypeName = "UT_InvMerge";
	LineTypeTASName = "UT_CNTypeApi";
vars
	calcType1	: CM_CalculationType;
	service		: CM_Service;
	ild			: CM_InvoiceLineDesc;
	invTypeTAS		: CM_InvoiceDesc;
	services	: CM_ServiceByNameDict;
	operator	: CM_Operator;
	bu : CM_Bank;
	invoice001, invoice002, targetInvoice : CM_Invoice;
	agent : CMIF_InvoiceLineMerge ;
	
	opdebtor, seconddebtor : CM_Debtor;
	bank : CM_Bank;
begin
	bank := self.getTerminal().getDefaultCompanyBank();

	
	self.deleteInvoiceService(LineTypeName, FORCED_ERASE);
	self.deleteInvoiceLineType(LineTypeName, FORCED_ERASE);
	self.deleteInvoiceType(LineTypeName);
	
	self.deleteInvoiceType(LineTypeTASName);
	
	self.assertNoTrxErrorsOrWarnings();
	
	calcType1 := app.myRoot.allCalculationTypesByCode['CCT00'];	// INV_CALC_TYPE_UNITY;
	self.assertNotNullMsg(calcType1, "Calculation type INV_CALC_TYPE_UNITY not found");

	// create new instances
	create services transient;
	
	// APIINV
	self.opts.purge();
	self.opts.addAssoc("APICN", true);
	invTypeTAS := self.createInvoiceType(LineTypeTASName, InvoiceTypeGeneral);
	self.assertNotNullMsg(invTypeTAS, "Invoice type " &amp; LineTypeTASName &amp; " not created");
	self.assertTrueMsg(invTypeTAS.useForApiCn = true, "invTypeTAS.useForApiCn is false");
	
	self.opts.purge();

	service := self.createInvoiceService(LineTypeName, LineTypeName, calcType1, null);
	self.assertNotNullMsg(service, "Service " &amp; LineTypeName &amp; " not created");
	
	services.add(service);
	ild := self.createInvoiceLineType(LineTypeName, calcType1, invTypeTAS, services, "SDT1");
	self.assertNotNullMsg(ild, "Invoice Line Type " &amp; LineTypeName &amp; " not created");
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);	
	opdebtor := operator.debtor;
	bu := self.getTerminal().getDefaultCompanyBank();
	
	
	self.opts.purge();
	self.opts.addAssoc("Category", InvoiceCategory_CreditNote);
	
	// ### MANUAL CREDIT NOTE ONE
	invoice001 := self.createManualInvoice(bu,opdebtor,null,invTypeTAS,null);
	
	// ### MANUAL CREDIT NOTE TWO
	invoice002 := self.createManualInvoice(bu,opdebtor,null,invTypeTAS,null);
	
	//22/01/2023	navkc1 CR 62038 Task 62039
	beginTransaction;
	invoice001.setContext(CM_Invoice.TAS);
	invoice002.setContext(CM_Invoice.TAS);
	commitTransaction;
	
	// ### MANUAL INVOICE LINES
	self.createManualInvoiceLineRate(invoice001, ild, 231.81056,null);
	self.createManualInvoiceLineRate(invoice001, ild, 231.16032,null);
	self.createManualInvoiceLineRate(invoice001, ild, 231.16032,null);
	self.assertTrueMsg(invoice001.invoiceLines.size = 3, "Invoice 01 should have 3 lines");
	
	self.createManualInvoiceLineRate(invoice002, ild, 347.71584,null);
	self.createManualInvoiceLineRate(invoice002, ild, 346.74048,null);
	self.createManualInvoiceLineRate(invoice002, ild, 353.65944,null);
	self.createManualInvoiceLineRate(invoice002, ild, 231.16032,null);
	self.assertTrueMsg(invoice002.invoiceLines.size = 4, "Invoice 01 should have 4 lines");

	// ### MANUAL CREDIT NOTE TARGET - IS TAS
	targetInvoice := self.createManualInvoice(bu,opdebtor,null,invTypeTAS,null);
	self.createManualInvoiceLineRate(targetInvoice, ild, 231.81056,null);
	self.createManualInvoiceLineRate(targetInvoice, ild, 231.16032,null);
	self.createManualInvoiceLineRate(targetInvoice, ild, 231.16032,null);
	self.assertTrueMsg(targetInvoice.invoiceLines.size = 3, "Target invoice should have 3 lines");
	
	create agent transient;
	agent.myTargetInvoice := targetInvoice;
	agent.allInvoices.add(invoice001); // 1st TAS
	agent.allInvoices.add(invoice002); // 2nd TAS
	
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(Canno_merge_more_than_credi_no); 

	app.myTrxUA.trxUpdateInvoiceMerge(agent, app.myPassport);

	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Unexpected DOUBLE TAS ISSUE");
	
	
epilog
	delete services;
	delete agent;
end;</source>
    </JadeMethod>
    <JadeMethod name="tInvoiceNoteChkAudit" id="9f20bc54-7fd8-47f8-8916-d15ddcd65a56">
        <source>tInvoiceNoteChkAudit();
/*

Purpose:			Tests the audits on an Invoice Note for creation, update and deletion

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
03 February 2022	navpw1		Initial creation TFS: 52752
26 April 2023 		navnmk20	Bug 57663: EUP - Incorrect Statuses Available when copying an invoice
23 May 2023 navtnr20 	Bug 58089: FR | EUP 54086 - Invoicing - Maintenance Enhancements - 070.b
*/

//Total of 3 Tests to run Audit Create, Audit Update and Audit Delete. Each test has their own assert section

constants
	INVOICENOTE 		= "Test Note";
	INVOICENOTEUPD 		= "Test Note" &amp; CrLf &amp; "Test Note Line 2";
	INTERNALUSEONLY 	= true;
	INTERNALUSEONLYUPD 	= false;
	INVOICETYPE 		= "UT_InvoiceNote";
	
vars
	invType					: CM_InvoiceDesc;
	operator				: CM_Operator;
	bu 						: CM_Bank;
	pxyInvoice, 
	realInvoice 			: CM_Invoice;
	pxyInvoiceNote, 
	realInvoiceNote 		: CM_InvoiceNote;
	auditObj 				: CM_AuditObject;
	createAuditExists,
	updateAuditExists,
	deleteAuditExists		: Boolean;
	realInvoiceSequenceNum	: Integer;
	
begin
	/*
	** Clean Up After Last test
	*/
	self.deleteInvoiceType(INVOICETYPE); //Also deletes all invoices using invoice type
	
	/*
	**	Setup Test
	*/
	bu := self.getTerminal().getDefaultCompanyBank();
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	invType := self.createInvoiceType(INVOICETYPE, InvoiceTypeGeneral);
	
	// ### MANUAL INVOICE
	create pxyInvoice transient;
	pxyInvoice.setProxyForCreate(bu,
								operator.debtor, 
								null,
								null,
								invType,
								//false,	// 26.4.2023 navmk20 TFS 57663
								CM_Invoice.INVOICE_PENDING, // 26.4.2023 navmk20 TFS 57663	
								true,	//isManual
								null,
								null,	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
								null,	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
								null,	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
								null,	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
								0,
								null,  // ### BUG 56925 07MAR2023 NAVAB1
								bu.myInvoiceProcess, //26.4.2023 navmk20 TFS 2023
								null,		//navtnr20 23-05-2023 BUG 58089
								null, //14/08/2023	navkc1	Bug 59803
								null, //14/08/2023	navkc1	Bug 59803
								null, //14/08/2023	navkc1	Bug 59803
								null, //14/08/2023	navkc1	Bug 59803
								null, //14/08/2023	navkc1	Bug 59803
								null //14/08/2023	navkc1	Bug 59803
								);
	app.myTrxCA.trxCreateInvoiceManual(pxyInvoice ,realInvoice, app.myPassport);
	
	beginTransaction;
		realInvoice.setPropertyValue("status",0); // OPEN
	commitTransaction;
	
	/*
	**	Run Test Audit Create
	*/
	create pxyInvoiceNote transient;
	pxyInvoiceNote.setProxyForCreate(INVOICENOTE, INTERNALUSEONLY, realInvoice); //Should the invoice be real or proxy one
	app.myTrxCA.trxCreateInvoiceNote(pxyInvoiceNote, realInvoiceNote, realInvoice, app.myPassport);
	
	//Update invoice with new invoice note
	delete pxyInvoice;
	
	/*
	**	Assert Test Audit Create
	*/
	//Check Trx has no errors
	self.assertNoTrxErrorsOrWarnings();
	
	foreach auditObj in realInvoiceNote.allAuditObjectsForClass do
		if auditObj.type = AuditCreated then
			createAuditExists := true;
			break;
		endif;
	endforeach;
	
	//Check the new reference are not null
	self.assertTrueMsg(createAuditExists, "Invoice Note: Could not find an audit of type Created");
	
	/*
	**	Run Test Audit Update
	*/
	app.myProxyManager.createProxyLink(realInvoiceNote, pxyInvoiceNote);
	pxyInvoiceNote.setProxyForUpdate(INVOICENOTEUPD, INTERNALUSEONLYUPD);
	app.myTrxUA.trxUpdateInvoiceNote(pxyInvoiceNote, app.myPassport);
	
	/*
	**	Assert Test Audit Update
	*/
	//Check Trx has no errors
	self.assertNoTrxErrorsOrWarnings();
	
	foreach auditObj in realInvoiceNote.allAuditObjectsForClass do
		if auditObj.type = AuditUpdated then
			updateAuditExists := true;
			break;
		endif;
	endforeach;
	
	//Check the new reference are not null
	self.assertTrueMsg(updateAuditExists, "Invoice Note: Could not find an audit of type Updated");
	
	app.myProxyManager.deleteProxyLink(pxyInvoiceNote);
	delete pxyInvoiceNote;
	
	/*
	**	Run Test Audit Clear
	*/
	beginLoad;
		pxyInvoiceNote := realInvoiceNote.pxyCreateUpdateProxy();
	endLoad;
	app.myTrxUA.trxClearInvoiceNote(pxyInvoiceNote, app.myPassport);
	
	/*
	**	Assert Test Audit Clear
	*/
	//Check Trx has no errors
	self.assertNoTrxErrorsOrWarnings();
	
	foreach auditObj in realInvoiceNote.allAuditObjectsForClass do
		if auditObj.type = AuditUpdated and auditObj.mySubject.CM_InvoiceNote.note = "" and not auditObj.mySubject.CM_InvoiceNote.internalOnly then
			updateAuditExists := true;
			break;
		endif;
	endforeach;
	
	//Check the new reference are not null
	self.assertTrueMsg(updateAuditExists, "Invoice Note: Could not find an audit of type Updated for the Clear Trx");
	
epilog
	delete pxyInvoice;
	delete pxyInvoiceNote;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tInvoiceNoteClear" id="d70d02d9-695a-4c68-8bf2-12299ffdefef">
        <source>tInvoiceNoteClear();
/*

Purpose:			Tests the Clearing of an Invoice Note

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
03 February 2022	navpw1		Initial creation TFS: 52752
26 April 2023 		navnmk20	Bug 57663: EUP - Incorrect Statuses Available when copying an invoice
23 May 2023 navtnr20 	Bug 58089: FR | EUP 54086 - Invoicing - Maintenance Enhancements - 070.b
*/

constants
	INVOICENOTE 	= "Test Note";
	INTERNALUSEONLY = true;
	INVOICETYPE 	= "UT_InvoiceNote";
	
vars
	invType			: CM_InvoiceDesc;
	services		: CM_ServiceByNameDict;
	operator		: CM_Operator;
	bu 				: CM_Bank;
	pxyInvoice, 
	realInvoice 	: CM_Invoice;
	pxyInvoiceNote, 
	realInvoiceNote : CM_InvoiceNote;
	
begin
	/*
	** Clean Up After Last test
	*/
	self.deleteInvoiceType(INVOICETYPE); //Also deletes all invoices using invoice type
	
	/*
	**	Setup Test
	*/
	bu := self.getTerminal().getDefaultCompanyBank();
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	invType := self.createInvoiceType(INVOICETYPE, InvoiceTypeGeneral);
	
	// ### MANUAL INVOICE
	create pxyInvoice transient;
	pxyInvoice.setProxyForCreate(bu,
								operator.debtor, 
								null,
								null,
								invType,
								//false,	// 26.4.2023 navmk20 TFS 57663
								CM_Invoice.INVOICE_PENDING, // 26.4.2023 navmk20 TFS 57663		
								true,	//isManual
								null,
								null,	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
								null,	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
								null,	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
								null,	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
								0,
								null,  // ### BUG 56925 07MAR2023 NAVAB1
								bu.myInvoiceProcess, // 26.4.2023 navmk20 TFS 57663
								null, //navtnr20 23-05-2023 BUG 58089
								null, //14/08/2023	navkc1	Bug 59803
								null, //14/08/2023	navkc1	Bug 59803
								null, //14/08/2023	navkc1	Bug 59803
								null, //14/08/2023	navkc1	Bug 59803
								null, //14/08/2023	navkc1	Bug 59803
								null //14/08/2023	navkc1	Bug 59803
								);
	app.myTrxCA.trxCreateInvoiceManual(pxyInvoice ,realInvoice, app.myPassport);
	
	beginTransaction;
		realInvoice.setPropertyValue("status",0); // OPEN
	commitTransaction;
	
	create pxyInvoiceNote transient;
	pxyInvoiceNote.setProxyForCreate(INVOICENOTE, INTERNALUSEONLY, realInvoice);
	app.myTrxCA.trxCreateInvoiceNote(pxyInvoiceNote, realInvoiceNote, realInvoice, app.myPassport);
	
	//Update invoice with new invoice note
	delete pxyInvoice;

	/*
	**	Run Test
	*/
	app.myProxyManager.createProxyLink(realInvoiceNote, pxyInvoiceNote);
	app.myTrxUA.trxClearInvoiceNote(pxyInvoiceNote, app.myPassport);
	
	/*
	**	Assert Test
	*/
	//Check Trx has no errors
	self.assertNoTrxErrorsOrWarnings();
	
	//Check the new reference is null
	self.assertTrueMsg(realInvoiceNote.note = "", "Invoice Note: Notes should be empty");
	self.assertTrueMsg(realInvoiceNote.internalOnly = false, "Invoice Note: Internal Use Only should be false");
	
epilog
	delete pxyInvoice;
	delete pxyInvoiceNote;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tInvoiceNoteCreate" id="da98e0eb-f30a-4f8e-a883-7aa364645af2">
        <source>tInvoiceNoteCreate();
/*

Purpose:			Tests that an Invoice Note can be created for an invoice

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
03 February 2022	navpw1		Initial creation TFS: 52752
26 April 2023 		navnmk20	Bug 57663: EUP - Incorrect Statuses Available when copying an invoice
23 May 2023 		navtnr20 	Bug 58089: FR | EUP 54086 - Invoicing - Maintenance Enhancements - 070.b
*/

constants
	INVOICENOTE 	= "Test Note";
	INTERNALUSEONLY = true;
	INVOICETYPE 	= "UT_InvoiceNote";
	
vars
	invType			: CM_InvoiceDesc;
	services		: CM_ServiceByNameDict;
	operator		: CM_Operator;
	bu 				: CM_Bank;
	pxyInvoice, 
	realInvoice 	: CM_Invoice;
	pxyInvoiceNote, 
	realInvoiceNote : CM_InvoiceNote;
	
begin
	/*
	** Clean Up After Last test
	*/
	self.deleteInvoiceType(INVOICETYPE); //Also deletes all invoices using invoice type
	
	/*
	**	Setup Test
	*/
	bu := self.getTerminal().getDefaultCompanyBank();
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	invType := self.createInvoiceType(INVOICETYPE, InvoiceTypeGeneral);
	
	// ### MANUAL INVOICE
	create pxyInvoice transient;
	pxyInvoice.setProxyForCreate(bu,
								operator.debtor, 
								null,
								null,
								invType,
								//false,	// 26.4.2023 navmk20 TFS 57663
								CM_Invoice.INVOICE_PENDING, // 26.4.2023 navmk20 TFS 57663		
								true,	//isManual
								null,
								null,	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
								null,	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
								null,	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
								null,	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
								0,
								null,  // ### BUG 56925 07MAR2023 NAVAB1
								bu.myInvoiceProcess,  // 26.4.2023 navmk20 TFS 57663
								null,	//navtnr20 23-05-2023 BUG 58089
								null, //14/08/2023	navkc1	Bug 59803
								null, //14/08/2023	navkc1	Bug 59803
								null, //14/08/2023	navkc1	Bug 59803
								null, //14/08/2023	navkc1	Bug 59803
								null, //14/08/2023	navkc1	Bug 59803
								null //14/08/2023	navkc1	Bug 59803
								);
	app.myTrxCA.trxCreateInvoiceManual(pxyInvoice ,realInvoice, app.myPassport);
	
	beginTransaction;
		realInvoice.setPropertyValue("status",0); // OPEN
	commitTransaction;
	
	/*
	**	Run Test
	*/
	create pxyInvoiceNote transient;
	pxyInvoiceNote.setProxyForCreate(INVOICENOTE, INTERNALUSEONLY, realInvoice); //Should the invoice be real or proxy one
	app.myTrxCA.trxCreateInvoiceNote(pxyInvoiceNote, realInvoiceNote, realInvoice, app.myPassport);
	
	//Update invoice with new invoice note
	delete pxyInvoice;
	
	/*
	**	Assert Test
	*/
	//Check Trx has no errors
	self.assertNoTrxErrorsOrWarnings();
	
	//Check the new reference are not null
	self.assertTrueMsg(realInvoiceNote.myInvoice &lt;&gt; null, "Invoice Note: Invoice is null");
	self.assertTrueMsg(realInvoice.myInvoiceNote &lt;&gt; null, "Invoice: Invoice Note is null");
	
	//Check the new reference is set to the correct objects
	self.assertTrueMsg(realInvoiceNote.myInvoice = realInvoice, "Invoice Note: Invoice has not been set to our non proxy object");
	self.assertTrueMsg(realInvoice.myInvoiceNote = realInvoiceNote, "Invoice: Invoice Note has not been set to our non proxy object");
	
	//Check that new fields match their expected value/are set
	self.assertTrueMsg(realInvoiceNote.note = INVOICENOTE, "The note on Invoice Note does not match expected value: " &amp; INVOICENOTE);
	self.assertTrueMsg(realInvoiceNote.internalOnly = INTERNALUSEONLY, "The internal use only on Invoice Note does not match expected value: " &amp; INTERNALUSEONLY.asStringJMT());
	
epilog
	delete pxyInvoice;
	delete pxyInvoiceNote;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tInvoiceNoteInvUpdate" id="7d96e70c-5375-4a35-a117-12b8f477b424">
        <source>tInvoiceNoteInvUpdate();
/*

Purpose:			Tests that an Invoice can be updated and the Invoice Note is not removed

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
17 February 2022	navpw1		Initial creation TFS: 52752
26 April 2023 		navnmk20	Bug 57663: EUP - Incorrect Statuses Available when copying an invoice
23 May 2023 navtnr20 	Bug 58089: FR | EUP 54086 - Invoicing - Maintenance Enhancements - 070.b
*/

constants
	INVOICENOTE 		= "Test Note";
	INVOICENOTEUPD 		= "Test Note" &amp; CrLf &amp; "Test Note Line 2";
	INTERNALUSEONLY 	= true;
	INTERNALUSEONLYUPD 	= false;
	INVOICETYPE 		= "UT_InvoiceNote";
	
vars
	invType			: CM_InvoiceDesc;
	services		: CM_ServiceByNameDict;
	operator		: CM_Operator;
	bu 				: CM_Bank;
	pxyInvoice, 
	realInvoice 	: CM_Invoice;
	pxyInvoiceNote, 
	realInvoiceNote : CM_InvoiceNote;
	
begin
	/*
	** Clean Up After Last test
	*/
	self.deleteInvoiceType(INVOICETYPE); //Also deletes all invoices using invoice type
	
	/*
	**	Setup Test
	*/
	bu := self.getTerminal().getDefaultCompanyBank();
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	invType := self.createInvoiceType(INVOICETYPE, InvoiceTypeGeneral);
	
	// ### MANUAL INVOICE
	create pxyInvoice transient;
	pxyInvoice.setProxyForCreate(bu,
								operator.debtor, 
								null,
								null,
								invType,
								//false,	// 26.4.2023 navmk20 TFS 57663
								CM_Invoice.INVOICE_PENDING, // 26.4.2023 navmk20 TFS 57663		
								true,	//isManual
								null,
								null,	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
								null,	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
								null,	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
								null,	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
								0,
								null, // ### BUG 56925 07MAR2023 NAVAB1
								bu.myInvoiceProcess, // 26.4.2023 navmk20 TFS 57663	
								null, //navtnr20 23-05-2023 BUG 58089
								null, //14/08/2023	navkc1	Bug 59803
								null, //14/08/2023	navkc1	Bug 59803
								null, //14/08/2023	navkc1	Bug 59803
								null, //14/08/2023	navkc1	Bug 59803
								null, //14/08/2023	navkc1	Bug 59803
								null //14/08/2023	navkc1	Bug 59803
								);
	app.myTrxCA.trxCreateInvoiceManual(pxyInvoice ,realInvoice, app.myPassport);
	
	beginTransaction;
		realInvoice.setPropertyValue("status", 0); // OPEN
	commitTransaction;
	
	create pxyInvoiceNote transient;
	pxyInvoiceNote.setProxyForCreate(INVOICENOTE, INTERNALUSEONLY, realInvoice); //Should the invoice be real or proxy one
	app.myTrxCA.trxCreateInvoiceNote(pxyInvoiceNote, realInvoiceNote, realInvoice, app.myPassport);
	
	//Update invoice with new invoice note
	delete pxyInvoice;
	
	/*
	**	Run Test
	*/
	beginLoad;
		pxyInvoice := realInvoice.pxyCreateUpdateProxy();
	endLoad;
	pxyInvoice.setProxyForUpdate("Test Narration 2", pxyInvoice.isZeroRatedTax, pxyInvoice.toDT.Date, pxyInvoice.purchaseOrderNumber, 
									pxyInvoice.debtorReference, pxyInvoice.myBillingAddress,null, null, null, null);
	app.myTrxUA.trxUpdateInvoice(pxyInvoice, app.myPassport);
	
	/*
	**	Assert Test
	*/
	//Check Trx has no errors
	self.assertNoTrxErrorsOrWarnings();
	
	//Check the new reference are not null
	self.assertTrueMsg(realInvoice.myInvoiceNote &lt;&gt; null, "Invoice: Invoice Note is null. Should not be null when invoice is updated");
	self.assertTrueMsg(realInvoiceNote.myInvoice &lt;&gt; null, "Invoice Note: Invoice is null");
	
	//Check the new reference is set to the correct objects
	self.assertTrueMsg(realInvoiceNote.myInvoice = realInvoice, "Invoice Note: Invoice has not been set to our non proxy object");
	self.assertTrueMsg(realInvoice.myInvoiceNote = realInvoiceNote, "Invoice: Invoice Note has not been set to our non proxy object");
	
epilog
	delete pxyInvoice;
	delete pxyInvoiceNote;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tInvoiceNoteUpdate" id="e05d1028-5826-4362-932d-5cf5f48acb0e">
        <source>tInvoiceNoteUpdate();
/*

Purpose:			Tests that an Invoice Note can be updated

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
03 February 2022	navpw1		Initial creation TFS: 52752
26 April 2023 		navnmk20	Bug 57663: EUP - Incorrect Statuses Available when copying an invoice
23 May 2023 navtnr20 	Bug 58089: FR | EUP 54086 - Invoicing - Maintenance Enhancements - 070.b
*/

constants
	INVOICENOTE 		= "Test Note";
	INVOICENOTEUPD 		= "Test Note" &amp; CrLf &amp; "Test Note Line 2";
	INTERNALUSEONLY 	= true;
	INTERNALUSEONLYUPD 	= false;
	INVOICETYPE 		= "UT_InvoiceNote";
	
vars
	invType			: CM_InvoiceDesc;
	services		: CM_ServiceByNameDict;
	operator		: CM_Operator;
	bu 				: CM_Bank;
	pxyInvoice, 
	realInvoice 	: CM_Invoice;
	pxyInvoiceNote, 
	realInvoiceNote : CM_InvoiceNote;
	
begin
	/*
	** Clean Up After Last test
	*/
	self.deleteInvoiceType(INVOICETYPE); //Also deletes all invoices using invoice type
	
	/*
	**	Setup Test
	*/
	bu := self.getTerminal().getDefaultCompanyBank();
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	invType := self.createInvoiceType(INVOICETYPE, InvoiceTypeGeneral);
	
	// ### MANUAL INVOICE
	create pxyInvoice transient;
	pxyInvoice.setProxyForCreate(bu,
								operator.debtor, 
								null,
								null,
								invType,
								//false,	// 26.4.2023 navmk20 TFS 57663
								CM_Invoice.INVOICE_PENDING, // 26.4.2023 navmk20 TFS 57663	
								true,	//isManual
								null,
								null,	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
								null,	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
								null,	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
								null,	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
								0,
								null,  // ### BUG 56925 07MAR2023 NAVAB1
								bu.myInvoiceProcess, // 26.4.2023 navmk20 TFS 57663
								null, //navtnr20 23-05-2023 BUG 58089
								null, //14/08/2023	navkc1	Bug 59803
								null, //14/08/2023	navkc1	Bug 59803
								null, //14/08/2023	navkc1	Bug 59803
								null, //14/08/2023	navkc1	Bug 59803
								null, //14/08/2023	navkc1	Bug 59803
								null //14/08/2023	navkc1	Bug 59803
								);
	app.myTrxCA.trxCreateInvoiceManual(pxyInvoice ,realInvoice, app.myPassport);
	
	beginTransaction;
		realInvoice.setPropertyValue("status",0); // OPEN
	commitTransaction;
	
	create pxyInvoiceNote transient;
	pxyInvoiceNote.setProxyForCreate(INVOICENOTE, INTERNALUSEONLY, realInvoice); //Should the invoice be real or proxy one
	app.myTrxCA.trxCreateInvoiceNote(pxyInvoiceNote, realInvoiceNote, realInvoice, app.myPassport);
	
	//Update invoice with new invoice note
	delete pxyInvoice;
	
	/*
	**	Run Test
	*/
	app.myProxyManager.createProxyLink(realInvoiceNote, pxyInvoiceNote);
	pxyInvoiceNote.setProxyForUpdate(INVOICENOTEUPD, INTERNALUSEONLYUPD);
	app.myTrxUA.trxUpdateInvoiceNote(pxyInvoiceNote, app.myPassport);
	
	/*
	**	Assert Test
	*/
	//Check Trx has no errors
	self.assertNoTrxErrorsOrWarnings();
	
	//Check the new reference are not null
	self.assertTrueMsg(realInvoiceNote.myInvoice &lt;&gt; null, "Invoice Note: Invoice is null");
	self.assertTrueMsg(realInvoice.myInvoiceNote &lt;&gt; null, "Invoice: Invoice Note is null");
	
	//Check the new reference is set to the correct objects
	self.assertTrueMsg(realInvoiceNote.myInvoice = realInvoice, "Invoice Note: Invoice has not been set to our non proxy object");
	self.assertTrueMsg(realInvoice.myInvoiceNote = realInvoiceNote, "Invoice: Invoice Note has not been set to our non proxy object");
	
	//Check that new fields match their expected value/are set
	self.assertTrueMsg(realInvoiceNote.note = INVOICENOTEUPD, "The note on Invoice Note does not match expected value: " &amp; INVOICENOTEUPD);
	self.assertTrueMsg(realInvoiceNote.internalOnly = INTERNALUSEONLYUPD, "The internal use only on Invoice Note does not match expected value: " &amp; INTERNALUSEONLYUPD.asStringJMT());
	
epilog
	delete pxyInvoice;
	delete pxyInvoiceNote;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tInvoiceRoundingTo2" id="cf0281cd-3c33-4c87-b43b-0febe62b8110">
        <source>tInvoiceRoundingTo2();
/*
Purpose:	TFS 42431		
Date				Who			Reason
DECEMBER 2018		NAVAB1		Initial creation
26 April 2023 		navnmk20	Bug 57663: EUP - Incorrect Statuses Available when copying an invoice
23 May 2023 navtnr20 	Bug 58089: FR | EUP 54086 - Invoicing - Maintenance Enhancements - 070.b
*/

vars
	calcType1	: CM_CalculationType;
	service		: CM_Service;
	ild			: CM_InvoiceLineDesc;
	invType		: CM_InvoiceDesc;
	services	: CM_ServiceByNameDict;
	operator	: CM_Operator;
	bu : CM_Bank;
	pxyInvoice, realInvoice : CM_Invoice;
	roundDecimalOpt : Integer;
begin
	roundDecimalOpt := self.getTerminalConfig(InvoiceRoundLineTotal).Integer;
	self.setTerminalConfig(InvoiceRoundLineTotal,CMIF_ConfigTerminal.InvLineRound_Value_NoRound);


	self.deleteInvoiceService("UT_InvRounding", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_InvRounding", FORCED_ERASE);
	self.deleteInvoiceType("UT_InvRounding");
	
	self.assertNoTrxErrorsOrWarnings();
	
	calcType1 := app.myRoot.allCalculationTypesByCode['CCT00'];	// INV_CALC_TYPE_UNITY;
	self.assertNotNullMsg(calcType1, "Calculation type INV_CALC_TYPE_UNITY not found");

	// create new instances
	create services transient;
	invType := self.createInvoiceType("UT_InvRounding", InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type UT_InvRounding not created");

	service := self.createInvoiceService("UT_InvRounding", "UT_InvRounding", calcType1, null);
	self.assertNoTrxErrorsOrWarnings();
	
	services.add(service);
	ild := self.createInvoiceLineType("UT_InvRounding", calcType1, invType, services, "SDT1");
	self.assertNoTrxErrorsOrWarnings();
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);	

	bu := self.getTerminal().getDefaultCompanyBank();
	
	// ### MANUAL INVOICE
	create pxyInvoice transient;
	pxyInvoice.setProxyForCreate(bu,
								operator.debtor, 
								null, //22.07.2019 cnwma1 TFS #45577
								null,
								invType,
								//false,	// 26.4.2023 navmk20 TFS 57663
								CM_Invoice.INVOICE_PENDING, // 26.4.2023 navmk20 TFS 57663	
								true,	//isManual
								null,
								null,	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
								null,	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
								null,	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
								null,	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
								0,
								null,  // ### BUG 56925 07MAR2023 NAVAB1
								bu.myInvoiceProcess,		 // 26.4.2023 navmk20 TFS 57663
								null,		//navtnr20 23-05-2023 BUG 58089
								null, //14/08/2023	navkc1	Bug 59803
								null, //14/08/2023	navkc1	Bug 59803
								null, //14/08/2023	navkc1	Bug 59803
								null, //14/08/2023	navkc1	Bug 59803
								null, //14/08/2023	navkc1	Bug 59803
								null //14/08/2023	navkc1	Bug 59803
								);
	app.myTrxCA.trxCreateInvoiceManual(pxyInvoice,realInvoice, app.myPassport);
	
	beginTransaction;
	realInvoice.setPropertyValue("status",0); // OPEN
	commitTransaction;
	
	// ### MANUAL INVOICE LINE3
	
	self.createManualInvoiceLineRate(realInvoice, ild, 231.81056,null);
	self.createManualInvoiceLineRate(realInvoice, ild, 231.16032,null);
	self.createManualInvoiceLineRate(realInvoice, ild, 231.16032,null);
	self.createManualInvoiceLineRate(realInvoice, ild, 347.71584,null);
	self.createManualInvoiceLineRate(realInvoice, ild, 346.74048,null);
	self.createManualInvoiceLineRate(realInvoice, ild, 353.65944,null);
	self.createManualInvoiceLineRate(realInvoice, ild, 231.16032,null);
	self.createManualInvoiceLineRate(realInvoice, ild, 310.2976,null);
	self.createManualInvoiceLineRate(realInvoice, ild, 309.4272,null);
	self.createManualInvoiceLineRate(realInvoice, ild, 315.6016,null);

	// TFS 43253 self.assertEqualMsg(realInvoice.getTotalAmount(), 2908.74.Decimal, "Rounding is incorrect - TFS 42431");
	self.assertEqualMsg(realInvoice.getTotalAmount(), 2908.733680.Decimal, "Rounding is incorrect - TFS 42431");
	

	/* Testing the changes in these methods:
	PortSchema::CM_Invoice::getTotalAmount (3)
	PortSchema::CM_Invoice::getTotalAmountConverted (2)
	PortSchema::CM_InvoiceLine::getLineTotalConverted (2)
	PortSchema::CM_InvoiceLine::lineTotal (2)
	*/
	
epilog
	self.setTerminalConfig(InvoiceRoundLineTotal,roundDecimalOpt);
	self.resetDefaultTranMap();
	delete pxyInvoice;
	delete services;
end;</source>
    </JadeMethod>
    <JadeMethod name="tInvoiceServiceTypeCreate" id="1b5992f6-a8b9-4f9e-88d9-3d9fca1fa598">
        <updating/>
        <source>tInvoiceServiceTypeCreate() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 August 2022	navkc1	Initial creation - ChangeRequest 54571: EUP - Inv Config - Service Type

To test the creation of Service Type

*/
constants
	ServiceTypeCode = "UTSVCTYPE";
	ServiceTypeDesc = "UTSerivceTypeDesc";
	
vars
	bank				: CM_Bank;
	glcode				: CM_GLCode;
	service				: CM_Service;
	pxyServiceType, 
	realServiceType		: CM_ServiceType;
	services			: CM_ServiceByNameDict;
	
begin
	// Create transient
	create services transient;
	// Get default bank
	bank		:= self.getTerminal().getDefaultCompanyBank();
	// Get first GL code
	glcode		:= bank.glCodes.first();
	// Get first service from GL code
	service		:= glcode.services.first().CM_Service;
	// Add service to Set
	services.add(service);
	// Delete any existing object
	self.deleteServiceType(ServiceTypeCode, bank);
	// Create proxy transient
	create pxyServiceType transient;
	// Set proxy
	pxyServiceType.setProxy(ServiceTypeCode, ServiceTypeDesc, services, bank);
	// Create
	app.myTrxCA.trxCreateServiceType(pxyServiceType, realServiceType, app.myPassport);
	// Test
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(realServiceType);
	
	self.assertTrueMsg(realServiceType.code = ServiceTypeCode, "Service Type code does not match expected value: " &amp; ServiceTypeCode);
	self.assertTrueMsg(realServiceType.description = ServiceTypeDesc, "Service Type description does not match expected value: " &amp; ServiceTypeDesc);
	
	self.assertNotNull(realServiceType.myBank);
	self.assertTrueMsg(realServiceType.myBank = bank, "Service Type Bank does not match with expected Bank: " &amp; bank.code);
	
	self.assertTrueMsg(realServiceType.allServices.size() &gt; 0, "Service Type does not have Services defined");
	
	// Delete created object
	self.deleteServiceType(realServiceType.code, realServiceType.myBank);
epilog
	delete pxyServiceType;
	delete services;
end;</source>
    </JadeMethod>
    <JadeMethod name="tInvoiceServiceTypeUpdate" id="5bab3387-311e-4890-8733-9cdac6c27dc5">
        <updating/>
        <source>tInvoiceServiceTypeUpdate() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 August 2022	navkc1	Initial creation - ChangeRequest 54571: EUP - Inv Config - Service Type

To test the update of Service Type

*/
constants
	ServiceTypeCode 		= "UTSVCTYPE";
	ServiceTypeDesc 		= "UTSerivceTypeDesc";
	ServiceTypeCodeUpdate 	= "UTUPDATE";
	ServiceTypeDescUpdate 	= "UTSerivceTypeDescUpdate";
	
vars
	bank				: CM_Bank;
	glcode				: CM_GLCode;
	service				: CM_Service;
	pxyServiceType, 
	realServiceType		: CM_ServiceType;
	services			: CM_ServiceByNameDict;
	
begin
	// Create transient
	create services transient;
	// Get default bank
	bank		:= self.getTerminal().getDefaultCompanyBank();
	// Get first GL code
	glcode		:= bank.glCodes.first();
	// Get first service from GL code
	service		:= glcode.services.first().CM_Service;
	// Add service to Set
	services.add(service);
	// Delete any existing object
	self.deleteServiceType(ServiceTypeCode, bank);
	// Create proxy transient
	create pxyServiceType transient;
	// Set proxy
	pxyServiceType.setProxy(ServiceTypeCode, ServiceTypeDesc, services, bank);
	// Create
	app.myTrxCA.trxCreateServiceType(pxyServiceType, realServiceType, app.myPassport);
	// Delete
	delete pxyServiceType;
	// Get proxy
	beginLoad;
	pxyServiceType := realServiceType.pxyCreateUpdateProxy();
	endLoad;
	glcode := bank.glCodes.last().CM_GLCode;
	services.clear();
	service	:= glcode.services.last().CM_Service;
	services.add(service);
	// Set update details
	pxyServiceType.setProxy(ServiceTypeCodeUpdate,
							ServiceTypeDescUpdate,
							services,
							bank);
	// Update
	app.myTrxUA.trxUpdateServiceType(pxyServiceType, app.myPassport);
	// Test
	self.assertNotNull(realServiceType);
	self.assertTrueMsg(realServiceType.code = ServiceTypeCodeUpdate,  "Service Type code does not match expected value: " &amp; ServiceTypeCodeUpdate);
	self.assertTrueMsg(realServiceType.description = ServiceTypeDescUpdate, "Service Type description does not match expected value: " &amp; ServiceTypeDescUpdate);
	
	self.assertNotNull(realServiceType.myBank);
	self.assertTrueMsg(realServiceType.myBank = bank, "Service Type Bank does not match with expected Bank: " &amp; bank.code);
	
	self.assertTrueMsg(realServiceType.allServices.size() &gt; 0, "Service Type does not have Services defined");
	
	// Delete created object
	self.deleteServiceType(realServiceType.code, realServiceType.myBank);
epilog
	delete pxyServiceType;
	delete services;
end;</source>
    </JadeMethod>
    <JadeMethod name="tInvoiceStatusProcessAudit" id="bf509eb7-4065-492e-886b-e488e75b2163">
        <source>tInvoiceStatusProcessAudit();
/*

Purpose:	Test if changing the status of an Invoice via BGP (Invoice Status Process) will create 
			an audit. The change of status is trigger by a Future Timer Runner worker in BGP screen.

Parameters:			

Return Value:		

Date		Who		TFS		Reason
24 Oct 2019	jlgdi1		46964	
26 Apr 2023 navnmk20	Bug 57663: EUP - Incorrect Statuses Available when copying an invoice
23 May 2023 navtnr20 	Bug 58089: FR | EUP 54086 - Invoicing - Maintenance Enhancements - 070.b
*/
	
vars
	bussinessUnit : CM_Bank;
	operator : CM_Operator;
	invType	: CM_InvoiceDesc;
	pxyInvoice : CM_Invoice;
	realInvoice : CM_Invoice;
	offlineFutureActor : CM_OfflineFutureActor;
	invoiceStatusProcess : CM_InvoiceStatusAdvanceProcess;
	auditObject : CM_AuditObject;
	
begin
	// Arrange
	self.deleteInvoiceType("UT_WO_Containter_Srvc");
	bussinessUnit := self.getTerminal().getDefaultCompanyBank();
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	invType := self.createInvoiceType("UT_WO_Containter_Srvc", InvoiceTypeGeneral);

	create pxyInvoice transient;
	pxyInvoice.setProxyForCreate(bussinessUnit,
								operator.debtor, 
								null,
								null,
								invType,
								//false,	// 26.4.2023 navmk20 TFS 57663
								CM_Invoice.INVOICE_PENDING, // 26.4.2023 navmk20 TFS 57663		
								true,
								null,
								null,	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
								null,	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
								null,	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
								null,	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
								0,
								null,  // ### BUG 56925 07MAR2023 NAVAB1
								bussinessUnit.myInvoiceProcess, // 26.4.2023 navmk20 TFS 57663
								null,		//navtnr20 23-05-2023 BUG 58089
								null, //14/08/2023	navkc1	Bug 59803
								null, //14/08/2023	navkc1	Bug 59803
								null, //14/08/2023	navkc1	Bug 59803
								null, //14/08/2023	navkc1	Bug 59803
								null, //14/08/2023	navkc1	Bug 59803
								null //14/08/2023	navkc1	Bug 59803
								);
	app.myTrxCA.trxCreateInvoiceManual(pxyInvoice, realInvoice, app.myPassport);
	
	beginTransaction;
	// Set Invoice Status to Open
	realInvoice.setPropertyValue("status", 0);

	auditObject := realInvoice.allAuditObjectsForClass.last();
	
	// Assert
	// Expectations
	// - invoice must have 1 Audit Object
	// - the audit object must be of type 'Created'
	assertEqualMsg(realInvoice.allAuditObjectsForClass.size, 1, "Expected number of Audit does not match");
	assertEqualMsg(auditObject.typeCode, "Created", "Initial Audit type must be Created");
	
	// Act
	realInvoice.createFutureActor(realInvoice);
	foreach offlineFutureActor in app.myRoot.allOfflineFutureActors do 
		if  offlineFutureActor.isKindOf(CM_InvoiceStatusAdvanceProcess) then 
			invoiceStatusProcess := offlineFutureActor.CM_InvoiceStatusAdvanceProcess;
			if invoiceStatusProcess.myInvoice = realInvoice then 
				// Act
				invoiceStatusProcess.doAction();
				break;
			endif;
		endif;
	endforeach;
	
	app.myRoot.deleteFutureActor(realInvoice, CM_InvoiceStatusAdvanceProcess);
	auditObject := realInvoice.allAuditObjectsForClass.last();
	
	// Assert 
	// Expectations
	// - invoice must have 2 Audit Objects
	// - the last audit object must be of type 'Updated', the status is changed from 'OPEN' to 'PENDING'
	assertEqualMsg(realInvoice.allAuditObjectsForClass.size, 2, "Expected number of Audit does not match.");
	assertEqualMsg(auditObject.typeCode, "Updated", "Audit type code must be 'Updated'");
	assertNotEqualMsg(auditObject.auditText.pos("Open", 1), 0, "Previous Invoice status = 'Open' not found.");
	assertNotEqualMsg(auditObject.postAuditText.pos("Pending", 1), 0, "Recent Invoice status = 'Pending' not found.");
	
epilog
	abortTransaction;
	delete pxyInvoice;
end;</source>
    </JadeMethod>
    <JadeMethod name="tInvoicingTranshipCargo" id="a3ee61f6-6d90-4602-9630-84eaa44023f0">
        <updating/>
        <source>tInvoicingTranshipCargo() updating;
// cnwma1
// NAVAB1 TFS 3285 AAT  Invoicing Tranship Cargo Based on the Operators of both the Inbound and Outbound Voyage
/* This test is based on the Appendix A J Vessel Rules from the Business Requirements for TFS 3103 but with simplified charging
	in that only one cargo type is used with charging per unit and without the different rates by volume of the cargo.
   The essence of the test is to confirm that a different invoice line type is used for the different voyages, based on the tranship voyage operators,
     and this invoice line type has a different service with the required rate to get the different charging, in the actual user case.
   The charging by revenue tonnes and for different RoRo volumes is assumed to work independently of this feature, and having invoice lines of the correct type
     from the invoice cargo allocation is taken to be enough to check that the overall processing is correct. 
*/
vars
	count	: Integer;
	pxyTM,realTM : CM_TranMapCargoAllocation;
	aCode, aDesc : String;

	pxyYAConfig, realYAConfig : CM_InvoiceAllocationConfig;
	opCriteriaColl : CM_YACriteriaTypeArray;
	proxyYAObj, realAlloc : CM_InvoiceCargoAllocation;
	controller: CMIF_TranshipTIController;
	allTransientCriteriaObj	: CMIF_Array;
	bs: CM_BlockStack;
	location : CM_LocationsController;
	nonJVoyage,
	voyageJ1,
	voyageJ2	: CM_Voyage;
	cargo1,
	cargo2	: CM_TrackedItem;
	aPort : CM_Port;
	operator	: CM_Operator;
	vesselCode,
	voyCode	 :String;
	id,
	isoType,
	commod	: String;
	vessel	: CM_Vessel; 
	berth	: HMS_Berth;
	bank	: CM_Bank;
	proxyDebtor		: CM_Debtor;
	debtorNodeController	: CMIF_DebtorNode;
	debtorNode	: CM_DebtorNode;
	dischDebtor,
	loadDebtor	: CM_Debtor;
	dischDebtorType,
	loadDebtorType	: CM_DebtorType;
	chargeCode1,
	chargeCode2,
	chargeCode3,
	chargeCode4,
	chargeCode5,
	chargeCode6		: String;
	loadDTCode,
	dischDTCode		: String;

	calType1		: CM_CalculationType;
	invType1		: CM_InvoiceDesc;
	invLineType1,
	invLineType2,
	invLineType3,
	invLineType4,
  	invLineType5,
	invLineType6	: CM_InvoiceLineDesc;
	service1,
	service2,
	service3,
	service4,
	service5,
	service6	: CM_Service;
	invoiceLine	: CM_InvoiceLine;
	services : CM_ServiceByNameDict;

begin
	// use invoice cargo allocations
	self.setTerminalConfig(InvUseInvoiceCargoAlloc, true);

	// debtor types, one for the discharge stevedore and one for the load one
	dischDTCode := "UT_DischSt";
	loadDTCode := "UT_LoadSt";
	// NOTE the addDebtorType includes a deleteDebtorType at the start
	dischDebtorType := self.addDebtorType(dischDTCode, "Unit test discharge stevedore");
	self.assertNotNull(dischDebtorType);
	// debtors, one for the discharge stevedore and one for the load one

	create debtorNodeController transient;
	create proxyDebtor transient;
	self.deleteDebtor("UT_DischSteve");
	self.setDebtorNodeController("UT_DischSteve", "999111", "", "", debtorNodeController, proxyDebtor);
	debtorNodeController.allDebtorTypes.add(dischDebtorType);
	app.myTrxCA.trxCreateDebtorNode(debtorNodeController, debtorNode, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	dischDebtor := debtorNode.CM_Debtor;

	loadDebtorType := self.addDebtorType(loadDTCode, "Unit test load stevedore");
	self.assertNotNull(loadDebtorType);
	delete debtorNodeController;
	delete proxyDebtor;
	create debtorNodeController transient;
	create proxyDebtor transient;
	self.deleteDebtor("UT_LoadSteve");
	self.setDebtorNodeController("UT_LoadSteve", "999112", "", "", debtorNodeController, proxyDebtor);
	debtorNodeController.allDebtorTypes.add(loadDebtorType);
	app.myTrxCA.trxCreateDebtorNode(debtorNodeController, debtorNode, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	loadDebtor := debtorNode.CM_Debtor;
	
	// invoice type, services and invoice line types
	// FAC in and out, SAC in and out for each voyage type (J and non-J)
	self.deleteInvoiceType("UT_TSCharges");
	chargeCode1 := "UT_FACJIn";
	chargeCode2 := "UT_FACJOut";
	chargeCode3 := "UT_FACNonJOut";
	chargeCode4 := "UT_SACJIn";
	chargeCode5 := "UT_SACJOut";
	chargeCode6 := "UT_SACNonJOut";

	self.deleteInvoiceService(chargeCode1, FORCED_ERASE);
	self.deleteInvoiceService(chargeCode2, FORCED_ERASE);
	self.deleteInvoiceService(chargeCode3, FORCED_ERASE);
	self.deleteInvoiceService(chargeCode4, FORCED_ERASE);
	self.deleteInvoiceService(chargeCode5, FORCED_ERASE);
	self.deleteInvoiceService(chargeCode6, FORCED_ERASE);

	self.deleteInvoiceLineType(chargeCode1, FORCED_ERASE);
	self.deleteInvoiceLineType(chargeCode2, FORCED_ERASE);
	self.deleteInvoiceLineType(chargeCode3, FORCED_ERASE);
	self.deleteInvoiceLineType(chargeCode4, FORCED_ERASE);
	self.deleteInvoiceLineType(chargeCode5, FORCED_ERASE);
	self.deleteInvoiceLineType(chargeCode6, FORCED_ERASE);

	invType1 := self.createInvoiceType("UT_TSCharges", InvoiceTypeGeneral);
	self.assertNotNullMsg(invType1, "Invoice type UT_TSCharges not created");

	calType1 := app.myRoot.allCalculationTypesByCode['CCT02'];	// INV_CALC_TYPE_TRANSQUANTITY
	self.assertNotNullMsg(calType1, "Calculation type INV_CALC_TYPE_TRANSQUANTITY not found");
	
	create services transient;
	service1 := self.createInvoiceService(chargeCode1, chargeCode1, calType1, null);
	self.assertNotNullMsg(service1, "Service " &amp; chargeCode1 &amp; " not created");
 	services.add(service1);
	invLineType1 := self.createInvoiceLineType(chargeCode1, calType1, invType1, services, loadDTCode);
	self.assertNotNullMsg(invLineType1, "Invoice line type " &amp; chargeCode1 &amp; " not created");

	service2 := self.createInvoiceService(chargeCode2, chargeCode2, calType1, null);
	self.assertNotNullMsg(service2, "Service " &amp; chargeCode2 &amp; " not created");
	services.clear();
 	services.add(service2);
	invLineType2 := self.createInvoiceLineType(chargeCode2, calType1, invType1, services, dischDTCode);
	self.assertNotNullMsg(invLineType2, "Invoice line type " &amp; chargeCode2 &amp; " not created");

	service3 := self.createInvoiceService(chargeCode3, chargeCode3, calType1, null);
	self.assertNotNullMsg(service3, "Service " &amp; chargeCode3 &amp; " not created");
	services.clear();
	services.add(service3);
	invLineType3 := self.createInvoiceLineType(chargeCode3, calType1, invType1, services, dischDTCode);
	self.assertNotNullMsg(invLineType3, "Invoice line type " &amp; chargeCode3 &amp; " not created");

	service4 := self.createInvoiceService(chargeCode4, chargeCode4, calType1, null);
	self.assertNotNullMsg(service4, "Service " &amp; chargeCode4 &amp; " not created");
	services.clear();
	services.add(service4);
	invLineType4 := self.createInvoiceLineType(chargeCode4, calType1, invType1, services, loadDTCode);
	self.assertNotNullMsg(invLineType4, "Invoice line type " &amp; chargeCode4 &amp; " not created");

	service5 := self.createInvoiceService(chargeCode5, chargeCode5, calType1, null);
	self.assertNotNullMsg(service5, "Service " &amp; chargeCode5 &amp; " not created");
	services.clear();
	services.add(service5);
	invLineType5 := self.createInvoiceLineType(chargeCode5, calType1, invType1, services, dischDTCode);
	self.assertNotNullMsg(invLineType5, "Invoice line type " &amp; chargeCode5 &amp; " not created");

	service6 := self.createInvoiceService(chargeCode6, chargeCode6, calType1, null);
	self.assertNotNullMsg(service6, "Service " &amp; chargeCode6 &amp; " not created");
	services.clear();
	services.add(service6);
	invLineType6 := self.createInvoiceLineType(chargeCode6, calType1, invType1, services, dischDTCode);
	self.assertNotNullMsg(invLineType6, "Invoice line type " &amp; chargeCode6 &amp; " not created");
	
	// operator, vessel and voyage, first J Vessel
	vesselCode := "UTJVSL1";
	voyCode := "UTJVOY1";

	deleteVoyage(voyCode);
	deleteVessel(vesselCode);
	
	self.deleteOperator("UTJ1");
	operator := self.addOperatorSimple("UTJ1", "UT Japanese Operator 1");
	vessel	:=	self.addVesselGeneralCargo(	vesselCode,
											operator,
											10);
	self.assertNotNullMsg(vessel, "Add vessel " &amp; vesselCode &amp; " failed");
	berth := self.getTerminal().myHarbour.allBerths.last;
	
	voyageJ1 :=	self.addVoyageWithGeneralCargoStruc(voyCode,
													vesselCode,
													vessel.myOperator.code,
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(),
													10);
	self.assertNotNullMsg(voyageJ1, "Add voyage " &amp; voyCode &amp; " failed");

	// vessel and voyage, second J Vessel
	vesselCode := "UTJVSL2";
	voyCode := "UTJVOY2";

	deleteVoyage(voyCode);
	deleteVessel(vesselCode);
	
	self.deleteOperator("UTJ2");
	operator := self.addOperatorSimple("UTJ2", "UT Japanese Operator 2");
	vessel	:=	self.addVesselGeneralCargo(	vesselCode,
											operator,
											10);
	self.assertNotNullMsg(vessel, "Add vessel " &amp; vesselCode &amp; " failed");
	berth := self.getTerminal().myHarbour.allBerths.last;
	
	voyageJ2 :=	self.addVoyageWithGeneralCargoStruc(voyCode,
													vesselCode,
													vessel.myOperator.code,
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(),
													10);
	self.assertNotNullMsg(voyageJ2, "Add voyage " &amp; voyCode &amp; " failed");

	// vessel and voyage, non-J Vessel
	vesselCode := "UTNJVSL1";
	voyCode := "UTNJVOY1";

	deleteVoyage(voyCode);
	deleteVessel(vesselCode);
	
	self.deleteOperator("UTNJ");
	operator := self.addOperatorSimple("UTNJ", "UT Non-Japanese Operator");
	vessel	:=	self.addVesselGeneralCargo(	vesselCode,
											operator,
											10);
	self.assertNotNullMsg(vessel, "Add vessel " &amp; vesselCode &amp; " failed");
	berth := self.getTerminal().myHarbour.allBerths.last;
	
	nonJVoyage :=	self.addVoyageWithGeneralCargoStruc(voyCode,
													vesselCode,
													vessel.myOperator.code,
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(),
													10);
	self.assertNotNullMsg(nonJVoyage, "Add voyage " &amp; voyCode &amp; " failed");

	create opCriteriaColl transient;
	
	bank := self.getTerminal().getDefaultCompanyBank();
	aCode := "UTALLOC";
	aDesc := "UT Invoice Allocation";
	
	// ### TRANSACTION MAP
	realTM := bank.allCargoAllocTranMaps[aCode];
	app.myTrxUA.trxUpdateBankTMCAActive(null); 
	
	if realTM &lt;&gt; null then
		app.myTrxDA.trxDeleteInvoiceTranMapCA(realTM);
	endif;
	
	create pxyTM transient;
	pxyTM.setProxy(bank, aCode, aDesc);
		
	app.myTrxCA.trxCreateInvoiceTranMapCAlloc(pxyTM,realTM);
	self.assertTrueTrxOKShowPassport("Create TM");
	
	app.myTrxUA.trxUpdateBankTMCAActive(realTM); 
	
	// ### TRAN MAP ALLOC CONFIG
	realYAConfig := realTM.myInvoiceAllocationConfig;
	self.assertTrueMsg(realYAConfig &lt;&gt; null, "Invoice Allocation Config is NUll");
	
	pxyYAConfig := app.createUpdateProxy(realYAConfig).CM_InvoiceAllocationConfig;
	
	// cargo type, inbound and outbound ship operators
	opCriteriaColl.add(app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType]);
	opCriteriaColl.add(app.myRoot.allYACriteriaTypes[YACriteriaType_InShipOper]);
	opCriteriaColl.add(app.myRoot.allYACriteriaTypes[YACriteriaType_OutShipOper]);
	
	pxyYAConfig.setProxyInvoiceAllocation(opCriteriaColl, null, realTM, null);
	
	app.myTrxUA.trxUpdateYAIMEXConfig(pxyYAConfig, app.myPassport);	
	
	// J-vessel to non J_vessel
	realAlloc := self.addInvoiceCargoAllocation(realTM, TI_CargoType_Container, null, TRANS_TYPE_REC_SHIP, "UTJ1", "UTNJ", "UTICA1", "NONJ DISCHARGE", null, null);
	self.addInvoiceCargoAllocationLines(realAlloc,"CCT01",chargeCode1,chargeCode4,0,CM_QuantityRangeMap.MAX_RANGE.Integer, false);
	
	realAlloc := self.addInvoiceCargoAllocation(realTM,TI_CargoType_Container,null,TRANS_TYPE_REL_SHIP, "UTJ1", "UTNJ", "UTICA11", "NONJ LOAD", null, null); // NAVAB1 03AUG2023 Fixing UTs. duplicate code 
	self.addInvoiceCargoAllocationLines(realAlloc,"CCT01",chargeCode3,chargeCode6,0,CM_QuantityRangeMap.MAX_RANGE.Integer, false);

	// J-vessel to J-vessel
	realAlloc := self.addInvoiceCargoAllocation(realTM, TI_CargoType_Container, null, TRANS_TYPE_REC_SHIP, "UTJ1", "UTJ2", "UTICA2", "J DISCHARGE", null, null);
	self.addInvoiceCargoAllocationLines(realAlloc,"CCT01",chargeCode1,chargeCode4,0,CM_QuantityRangeMap.MAX_RANGE.Integer, false);

	realAlloc := self.addInvoiceCargoAllocation(realTM,TI_CargoType_Container,null,TRANS_TYPE_REL_SHIP, "UTJ1", "UTJ2", "UTICA21", "J LOAD", null, null); // NAVAB1 03AUG2023 Fixing UTs. duplicate code 
	self.addInvoiceCargoAllocationLines(realAlloc,"CCT01",chargeCode2,chargeCode5,0,CM_QuantityRangeMap.MAX_RANGE.Integer, false);
	
	// create the cargo onship for voyageJ1, one as tranship to voyageJ2 and the other as tranship to nonJVoyage
	aPort := app.myRoot.allPorts["NZAKL"];
	location := voyageJ1.myShipBlockStack;
	isoType := "22G1";
	commod := "GENL";
	id := "GENU1503271";
	self.deleteContainer(id);
	cargo1 := self.addContainerAtLocnDisch(id, isoType, commod, TI_IMEX_STATUS_IMPORT, location, aPort, voyageJ1);
	// set the debtor type for the stevedores
	beginTransaction;
	cargo1.allDebtorsByType[dischDTCode] := dischDebtor;
	cargo1.allDebtorsByType[loadDTCode] := loadDebtor;
	commitTransaction;
	// now make it a tranship to J voyage 2
	create controller transient;
	controller.allTrackedItems.add(cargo1);
	controller.myExportDestPort 	:= app.myRoot.allPorts['NZAKA'];
	controller.myExportDisPort 		:= app.myRoot.allPorts['NZAKL'];
	controller.myExportVoyage 		:= voyageJ2;
	controller.remarks 				:= "UT Tranship";
	//controller.removeStops 			:= true; // TFS 47222 jlgzm1 20/11/2019
	self.makeTrackedItemTranship(controller);
	
	id := "GENU1503272";
	self.deleteContainer(id);
	cargo2 := self.addContainerAtLocnDisch(id, isoType, commod, TI_IMEX_STATUS_IMPORT, location, aPort, voyageJ1);
	// set the debtor type for the stevedores
	beginTransaction;
	cargo2.allDebtorsByType[dischDTCode] := dischDebtor;
	cargo2.allDebtorsByType[loadDTCode] := loadDebtor;
	commitTransaction;

	// now make it a tranship to non-J voyage
	delete controller;
	create controller transient;
	controller.allTrackedItems.add(cargo2);
	controller.myExportDestPort 	:= app.myRoot.allPorts['NZAKA'];
	controller.myExportDisPort 		:= app.myRoot.allPorts['NZAKL'];
	controller.myExportVoyage 		:= nonJVoyage;
	controller.remarks 				:= "UT Tranship";
	//controller.removeStops 			:= true; // TFS 47222 jlgzm1 20/11/2019
	self.makeTrackedItemTranship(controller);

	// discharge all voyageJ1 cargo onsite
	bs:= self.getTerminalArea("UTINVBS").CM_BlockStack;
	if bs &lt;&gt; null then
		self.deleteInvoiceLines(bs.myLocationsController);
	endif;
	deleteTerminalArea("UTINVBS");
	bs:= addBlockStack("UTINVBS", 100, null);
	location := bs.allLocationsControllers.first;
	self.deleteStops(cargo1);
	self.instantMove(cargo1, location);
	
	self.deleteStops(cargo2);
	self.instantMove(cargo2, location);

	// load nonJVoyage cargo
	location := nonJVoyage.myShipBlockStack;
	beginTransaction;
	cargo1.setVoyageCode(nonJVoyage.code, app.myPassport);
	commitTransaction;
	self.deleteStops(cargo1);
	self.instantMove(cargo1, location);
	
	// load voyageJ2 cargo
	location := voyageJ2.myShipBlockStack;
	beginTransaction;
	cargo2.setVoyageCode(voyageJ2.code, app.myPassport);
	commitTransaction;
	self.deleteStops(cargo2);
	self.instantMove(cargo2, location);
	
	// check the invoice lines, from load and discharge, ILD, quantity and value
	count := 0;
	// J to non-J
	foreach invoiceLine in cargo1.invoiceLines do
		count := count + 1;
		if count = 1 then
			self.assertEqualMsg(invoiceLine.invoiceLineDesc.narration, chargeCode1, "Cargo 1 first line ILD");
			self.assertEqualMsg(invoiceLine.debtor.name, loadDebtor.name, "Cargo 1 first line debtor");
		elseif count = 2 then
			self.assertEqualMsg(invoiceLine.invoiceLineDesc.narration, chargeCode4, "Cargo 1 second line ILD");
			self.assertEqualMsg(invoiceLine.debtor.name, loadDebtor.name, "Cargo 1 second line debtor");
		elseif count = 3 then
			self.assertEqualMsg(invoiceLine.invoiceLineDesc.narration, chargeCode3, "Cargo 1 third line ILD");
			self.assertEqualMsg(invoiceLine.debtor.name, dischDebtor.name, "Cargo 1 third line debtor");
		elseif count = 4 then
			self.assertEqualMsg(invoiceLine.invoiceLineDesc.narration, chargeCode6, "Cargo 1 fourth line ILD");
			self.assertEqualMsg(invoiceLine.debtor.name, dischDebtor.name, "Cargo 1 fourth line debtor");
		endif;
	endforeach;
	self.assertEqualMsg(count, 4, "First cargo item invoice line count");
	
	count := 0;
	// J  to J
	foreach invoiceLine in cargo2.invoiceLines do
		count := count + 1;
		if count = 1 then
			self.assertEqualMsg(invoiceLine.invoiceLineDesc.narration, chargeCode1, "Cargo 2 first line ILD");
			self.assertEqualMsg(invoiceLine.debtor.name, loadDebtor.name, "Cargo 2 first line debtor");
		elseif count = 2 then
			self.assertEqualMsg(invoiceLine.invoiceLineDesc.narration, chargeCode4, "Cargo 2 second line ILD");
			self.assertEqualMsg(invoiceLine.debtor.name, loadDebtor.name, "Cargo 2 second line debtor");
		elseif count = 3 then
			self.assertEqualMsg(invoiceLine.invoiceLineDesc.narration, chargeCode2, "Cargo 2 third line ILD");
			self.assertEqualMsg(invoiceLine.debtor.name, dischDebtor.name, "Cargo 2 third line debtor");
		elseif count = 4 then
			self.assertEqualMsg(invoiceLine.invoiceLineDesc.narration, chargeCode5, "Cargo 2 fourth line ILD");
			self.assertEqualMsg(invoiceLine.debtor.name, dischDebtor.name, "Cargo 2 fourth line debtor");
		endif;
	endforeach;
	self.assertEqualMsg(count, 4, "Second cargo item invoice line count");

epilog
	self.setTerminalConfig(InvUseInvoiceCargoAlloc, false);

	delete pxyTM;
	delete pxyYAConfig;
	delete proxyYAObj;
	delete opCriteriaColl;
	delete allTransientCriteriaObj;
	delete debtorNodeController;
	delete proxyDebtor;
	delete services;
	delete controller;
end;</source>
    </JadeMethod>
    <JadeMethod name="tLINXDraftPost01" id="08f12180-3be3-49d2-9972-177b34a0275a">
        <source>tLINXDraftPost01(); 
/*
Purpose - 	
Who - NAVAB1
Date - 28JUL2025
ADO - JIRA 35470
*/

vars
	start,
	expiry : TimeStamp;
	costs : DecimalArray;
	date		: Date;
	debtorName	: String;
	bank 		: CM_Bank;
	service 	: CM_Service;
	debtorRate  : CM_DebtorRate;
	rateEntry 	: CM_RateEntry;
	debtorNode	: CM_DebtorNode;
	proxyDebtor,
	debtor		: CM_Debtor;
	invType		: CM_InvoiceDesc;
	invLineType	: CM_InvoiceLineDesc;
	debtorNodeController	: CMIF_DebtorNode;
	invoice		: CM_Invoice;
	invoiceLine	: CM_InvoiceLine;
	invoiceMultiTaxRates : Boolean;
	term : CM_Terminal;
	pxyAddress, realAddress : CM_Address;
	invProcess : CM_InvoiceProcess;
begin
	bank := self.myBank;
	invProcess := app.myRoot.allInvoiceProcesses["LINX"];
	beginTransaction;
	bank.setPropertyValue("myInvoiceProcess", invProcess);
	commitTransaction;
	// ### 3/11/2014 NAVAB1 InvoiceMultiTaxRates must be TRUE
	self.setTerminalConfig(InvoiceMultiTaxRates,true);
	
	debtorName := "UT_DebtorX";
	// delete debtor first
	debtorNode := app.myRoot.myRootCompany.debtors[debtorName];
	if debtorNode &lt;&gt; null then
		self.deleteDebtor(debtorNode);
	endif;
	
	// new debtor
	create debtorNodeController transient;
	create proxyDebtor transient;
	self.setDebtorNodeController1(debtorName, debtorNodeController, proxyDebtor);
	self.setInvLineTypes2(proxyDebtor);
	
	app.myTrxCA.trxCreateDebtorNode(debtorNodeController, debtorNode, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqualMsg(debtorNode.CM_Debtor.decfinName, "Test 123456", "Debtor decfinName 1");	
	self.assertEqualMsg(debtorNode.CM_Debtor.purchaseOrderCode, "P/O 321", "Debtor purchaseOrderCode 1");
	
	// change debtor
	delete proxyDebtor;
	delete debtorNodeController;
	create debtorNodeController transient;
	proxyDebtor := app.createUpdateProxy(debtorNode).CM_Debtor;
	self.setDebtorNodeController2(debtorName, debtorNodeController, proxyDebtor);
	
	app.myTrxUA.trxUpdateDebtorNode(debtorNodeController, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	debtor := debtorNode.CM_Debtor;
	self.assertEqualMsg(debtor.decfinName, "Test 654321", "Debtor decfinName 2");	
	self.assertEqualMsg(debtor.purchaseOrderCode, "P/O 123", "Debtor purchaseOrderCode 2");
	
	 // ### JIRA 35465 28JUL2025 NAVAB1
	realAddress := debtor.allAddressesByCode.first;
	if realAddress &lt;&gt; null then
		pxyAddress  := app.createUpdateProxy(realAddress).CM_Address;
	else
		create pxyAddress transient;
	endif;
	pxyAddress.setProxy("DFT",
							"DEFAULT ADDREESS",
							"188 Fall Over",
							"",
							"",
							"",
							"",
							"",
							"",	
							"'invPackage01@kaleris.com; invPackage02@kaleris.com;invPackage03@kaleris.com",
							//"4bishops@xtra.co.nz; four4bishops@gmail.com", 
							null,
							true,
							false,		
							debtor);
	if realAddress = null then
		app.myTrxCA.trxCreateDebtorAddress(pxyAddress,realAddress, app.myPassport);
	else
		app.myTrxUA.trxUpdateDebtorAddress(pxyAddress,realAddress, app.myPassport);
	endif;
	
	self.assertTrueMsg(realAddress &lt;&gt; null, "Debtor Address is NULL");
	
	
	
	// set up a rate for this debtor and UT_Service99 (used by each invoice line type in this test)
	create costs transient;
	service := self.getTerminal().getDefaultCompanyBank().services['UT_Service99'];
	create debtorRate transient;
	debtorRate.setProxy(service, debtor);
	costs.add(12.00);
	start.setDate("01/01/2010".Date);
	start.setTime("00:00".Time);
	expiry := null;
	rateEntry := self.addInvoiceRateEntry(debtorRate, start, expiry, false, costs, 0, 0, null, null);
	
	// create invoice
	invType := self.getInvoiceType("UT_InvType");
	invoice := self.createManualInvoice(self.myBank, debtor, null, invType, null);
	invLineType := self.getInvoiceLineType("UT_ILD01");
	invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 10, "Line 1", date);
	invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 5, "Line 2", date);
	invLineType := self.getInvoiceLineType("UT_ILD02");
	invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 10, "Line 3", date);
	invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 5, "Line 4", date);
	invLineType := self.getInvoiceLineType("UT_ILD03");
	invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 10, "Line 5", date);
	invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 5, "Line 6", date);

	// post invoice, run invoice package
	self.postDraftInvoice(invoice, false, false); 
epilog

	invProcess := app.myRoot.allInvoiceProcesses["MTN"];
	beginTransaction;
	bank.setPropertyValue("myInvoiceProcess", invProcess);
	commitTransaction;
	delete pxyAddress;
	delete proxyDebtor;
	delete debtorNodeController;
	delete costs;
	delete debtorRate;
end;</source>
    </JadeMethod>
    <JadeMethod name="tLinkCreditToInvoice" id="35ceb01c-0134-44ae-97d7-7ac12311b5d6">
        <source>tLinkCreditToInvoice();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 January 2023	navkc1	Initial creation TFS CR 55305 Task 55534

*/
constants
	DebtorName	= "UT_Debtor1";
	InvoiceType = "UT_INV";
	VoyageId	= "UT_VOY1";
vars
	allInvoices		: CM_InvoiceSet;
	invoice1,
	pxyInvoice1,
	invoice2,
	pxyInvoice2,
	invoice3,
	pxyInvoice3,
	pxyCreditNote,
	creditNote		: CM_Invoice;
	bank			: CM_Bank;
	terminal		: CM_Terminal;
	debtor			: CM_Debtor;
	invType			: CM_InvoiceDesc;
	voyage			: CM_Voyage;
	
begin

	terminal := self.getTerminal();
	self.assertNotNull(terminal);
	
	bank := terminal.getDefaultCompanyBank();
	self.assertNotNull(bank);
	
	debtor := self.getDebtor(DebtorName);
	self.assertNotNull(debtor);
	
	invType := self.getInvoiceType(InvoiceType);
	self.assertNotNull(invType);
	
	voyage := self.getVoyage(VoyageId);
	self.assertNotNull(voyage);
	
	creditNote := self.createManualInvoice(bank, debtor, voyage, invType, null);
	beginTransaction;
	creditNote.setCategory(InvoiceCategory_CreditNote);
	commitTransaction;
	
	invoice1 := self.createManualInvoice(bank, debtor, voyage, invType, null);
	invoice2 := self.createManualInvoice(bank, debtor, voyage, invType, null);
	invoice3 := self.createManualInvoice(bank, debtor, voyage, invType, null);
	
	beginTransaction;
	invoice1.setStatus(CM_Invoice.INVOICE_POSTED);
	invoice2.setStatus(CM_Invoice.INVOICE_POSTED);
	commitTransaction;
	
	create allInvoices transient;

	beginLoad;
	pxyCreditNote := creditNote.pxyCreateUpdateProxy();
	pxyInvoice1 := invoice1.pxyCreateUpdateProxy();
	pxyInvoice2 := invoice2.pxyCreateUpdateProxy();
	pxyInvoice3 := invoice3.pxyCreateUpdateProxy();
	endLoad;
	
	allInvoices.add(pxyInvoice1);
	allInvoices.add(pxyInvoice2);
	allInvoices.add(pxyInvoice3);
	
	app.myTrxUA.trxUpdateLinkCreditToInvoice(pxyCreditNote, allInvoices, app.myPassport);
	self.assertTrxWarningMsg(Invoice_status_not_posted, "Link Credit to Invoice status check failed");
	
	allInvoices.remove(pxyInvoice3);
	
	app.myTrxUA.trxUpdateLinkCreditToInvoice(pxyCreditNote, allInvoices, app.myPassport);
	self.assertNoTrxErrors();
	self.assertEqualMsg(invoice1.allCreditCredits.includes(creditNote), true, "Invoice 1 link to Credit Note failed");
	self.assertEqualMsg(invoice2.allCreditCredits.includes(creditNote), true, "Invoice 2 link to Credit Note failed");
	
	self.deleteInvoice(creditNote);
	self.deleteInvoice(invoice1);
	self.deleteInvoice(invoice2);
	self.deleteInvoice(invoice3);
	
epilog
	delete pxyInvoice1;
	delete pxyInvoice2;
	delete pxyInvoice3;
	delete allInvoices;
	delete pxyCreditNote;
end;</source>
    </JadeMethod>
    <JadeMethod name="tLoadUnloadCargoAllocationMap" id="ddf05222-d514-4954-9115-8dfea1c1790b">
        <source>tLoadUnloadCargoAllocationMap();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 November 2017	jlgmd1	Initial creation

*/

constants
	ExportMap : String = 'UTALLOC';
	ImportMap : String = 'UTAllocCopy';
	FileName : String = 'UT_InvCargoAllocMap.xml';
	FileLog : String = 'UT_InvCargoAllocMap.log'; // This should match FileName, but end in .log
vars
	agent		: CM_ExtractLoadAgent;
	file		: File;
	term		: CM_Terminal;
	count		: Integer;
	mapName		: String;
	mapOrig,
	mapNew		: CM_TranMapCargoAllocation;
begin
	create agent transient;
	create file transient;
	
	self.assertNotNull(self.myBank);
	
	mapName := ExportMap;
	
	// Extract
	self.logMessage("Extracting " &amp; mapName &amp; " to " &amp; FileName);
	file.mode := File.Mode_Output;
	file.openOutput(FileName);
	agent.extractInvAllocTranMap(file,self.myBank,mapName,count);
	mapOrig := self.myBank.allCargoAllocTranMaps[ExportMap];
	if file.isOpen then
		file.close();
	endif;	
	
	// Import
	self.logMessage("Importing " &amp; FileName &amp; " to " &amp; ImportMap);

	// Make sure we don't import over the top of an existing map (strange things currently happen)
	mapNew := self.myBank.allCargoAllocTranMaps[ImportMap];
	if mapNew &lt;&gt; null then
		app.myTrxDA.trxDeleteInvoiceTranMapCA(mapNew);	
	endif;
	
	file.openInput(FileName);
	agent.loadInvAllocTranMap(file,self.myBank,ImportMap);

	self.assertNoTrxErrorsPassport(app.myPassport.getAllErrorsAndWarningsAsStr); // NAVAB1 03AUG2023 Fixing UTs

	mapNew := self.myBank.allCargoAllocTranMaps[ImportMap];
	self.assertNotNull(mapNew);
	
	// Compare
	self.compareCargoAllocTransMaps(mapOrig, mapNew);
	
		
	// Delete the file from disk
	file.purge();
	// Delete the import log from disk
	file.openInput(FileLog);
	file.purge();
	
	self.logMessage("Done!");
	
epilog
	delete agent;
	if file &lt;&gt; null then
		if file.isOpen then
			file.close();
		endif;
		delete file;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="tMoveTransMapDeferred" id="18857289-9845-4849-804a-ebf303ecd3b7">
        <source>tMoveTransMapDeferred();
/*

Purpose:			

Parameters:			variant of "tMoveTransactionMap" that uses the deferred charging BGP

Return Value:		

Date		Who		Reason
08 July 2021	navndl1	Initial creation	TFS 

*/

constants		

	CannonBallId				: String = "UTCB0000001";
	InvoiceServiceId			: String = "UT_MDHService1";
	InvoiceLineTypeId			: String = "UT_MDHInvLineType1";
	InvoiceTypeId				: String = "UT_MDHInvType";
	TransactionMapId			: String = "UT_MoveMDH";
	TruckId						: String = "UTMHMV";
			
vars

	ti							: CM_TrackedItem;
	invType						: CM_InvoiceDesc;
	calcType					: CM_CalculationType;
	service						: CM_Service;
	ild1						: CM_InvoiceLineDesc;
	mesType 					: CM_MeasurementType;
	glCode 						: CM_GLCode;
	vvr							: CM_VehicleVisitRecord;
	trans						: CM_TITransaction;
	moveTrans					: CM_Move;	
	services					: CM_ServiceByNameDict;
	allServices					: CM_ServiceByNameDict;
	iter						: Iterator;
	trxFound					: Boolean;
	
	bgpCont : BGP_DeferredChargingController;
	initiated : Boolean;

begin

	self.setTerminalConfig( DeferredCharging, true );

	bgpCont := BGP_DeferredChargingController.firstInstance;
	if bgpCont = null then
		self.assertTrueMsg( bgpCont &lt;&gt; null, "No BGP_DeferredChargingController found!" );
	endif;
	
	if not bgpCont.isRunning() then
		app.startApplicationWithParameter(bgpCont.schemaName, bgpCont.appName, bgpCont);
		initiated := true;
	endif;

	self.deleteInvoiceTransactionMap(1, TransactionMapId);

	ti := self.getTrackedItem(CannonBallId);
	if ti &lt;&gt; null then
		self.deleteTrackedItem(ti, false);
	endif;
	
	self.deleteInvoiceService(InvoiceServiceId, FORCED_ERASE);
	self.deleteInvoiceLineType(InvoiceLineTypeId, FORCED_ERASE);
	self.deleteInvoiceGLCode("5321-45665");
	self.deleteCalculationType("UT_MDHCONVW", NORMAL_ERASE);
	self.deleteMeasurementType("UTMWeight");
	
	self.deleteVehicle(TruckId);
	
	create services transient;
	create allServices transient;
	
	invType := self.getInvoiceType("UT_DPHINVTYPE");
	self.assertNotNullMsg(invType, "Terminal - " &amp; self.myBank.terminal.code &amp;  ", BU - " &amp; self.myBank.code &amp; " Invoice type UT_DPHINVTYPE not created. ");
	
	// #### TEST WEIGHTS
	mesType := self.createMeasurementType(0.5, 6.3, false, false, false, false, "UTMWeight", Type_Weight, "UT MDH Weight Units");
	self.assertNotNullMsg(mesType, "Measurement type UTMWeight not created");
	calcType := self.createInvoiceCalcType(null, INV_CALC_TYPE_CARGOWEIGHTCONVT, "UT_MDHCONVW", "UT_MDHCONVW", 0, 0,0,0,null, false, null, null, 0, 0, INV_CALC_TYPE_UNITY,
		null, null, null, "SUPERUSER", true, false, false, null, null, null, mesType);
	
	self.assertNotNullMsg(calcType, "Calculation type UT_MDHCONVW not created");

	glCode := self.createInvoiceGLCode("5321-45665", "UnitTest MDH 1");
	service := self.createInvoiceService(InvoiceServiceId, "MDH Qty", calcType, glCode);
	self.assertNoTrxErrorsOrWarnings();
	allServices.add(service);
	
	services.add(service);
	ild1 := self.createInvoiceLineType(InvoiceLineTypeId, calcType, invType, services, "SDT1");
	self.assertNoTrxErrorsOrWarnings();
	
	self.tranMapLoadMove();

	self.opts.purge();
	self.opts.addAssoc("SubType", "12POUNDER-12");
	self.opts.addAssoc("IMEX", TI_IMEX_STATUS_IMPORT);
	vvr := self.gateInGC(TruckId, null, TruckId, CannonBallId, "CANNONBALL", self.getProfileSetting(UT_Profile.P_OPERATOR).asString, null, 
		self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString), 100);
	self.assertNotNull(vvr);
	
	ti := self.getTrackedItem(CannonBallId);
	self.assertNotNull(ti);
	
	self.deleteStops(ti);
	
	self.moveVehicleToYard(vvr.vehicle);
	self.assertTrue(vvr.vehicle.myPrimaryActualLocation.isInterchangeAreaLocation);
	
	self.workVehicle(vvr);
	self.assertNotNull(ti.getPrimaryLocation(REAL_MODE));
	self.assertTrue(ti.getPrimaryLocation(REAL_MODE).isKindOf(CM_YardController));
	self.assertTrue(vvr.vehicle.myPrimaryActualLocation.isInterchangeAreaLocation);
				
	self.roadExit(vvr);
	self.assertNull(vvr.myRoadJob);
	self.assertEqual(vvr.status, CM_VehicleVisitRecord.Status_Complete);
	self.assertNull(vvr.vehicle.myPrimaryActualLocation);
	
	process.sleep(1000);	//allow time for the charging to occur in the bgp app
	
	// check to see that we have been charged for the move (UT_MDHInvLineType1)
	trxFound := false;
	iter := ti.allTransactions.createIterator;
	while iter.next(trans) do
		if not trans.isKindOf(CM_Move) then
			continue;
		endif;
		moveTrans := trans.CM_Move;
		if not moveTrans.isCharged() or moveTrans.allInvoiceLines.isEmpty() then
			continue;
		endif;
		if moveTrans.allInvoiceLines.first.invoiceLineDesc = ild1 then
			trxFound := true;
			break;
		endif;
	endwhile;
	
	self.assertTrueMsg(trxFound, "Charged Move transasction not found");
	
epilog

	if initiated then
		bgpCont.terminateProcessing( app.myPassport.getUserCode );
	endif;

	delete services;
	delete allServices;
	delete iter;
	
	self.resetDefaultTranMap();
	
	// delete this tran map so following tests can delete the invoice line descs etc
	self.deleteInvoiceTransactionMap(1, TransactionMapId);
	

end;</source>
    </JadeMethod>
    <JadeMethod name="tMoveTransactionMap" id="cd25c4b1-d08b-4772-ba28-4d97c7c5e91c">
        <source>tMoveTransactionMap();

/*

Purpose:		

Date			Who		Reason
25/03/2015		cnwmh5	Initial creation

*/

constants		

	CannonBallId				: String = "UTCB0000001";
	InvoiceServiceId			: String = "UT_MDHService1";
	InvoiceLineTypeId			: String = "UT_MDHInvLineType1";
	InvoiceTypeId				: String = "UT_MDHInvType";
	TransactionMapId			: String = "UT_MoveMDH";
	TruckId						: String = "UTMHMV";
			
vars

