    <JadeMethod name="createStockMovementForErase" id="aa8bac14-25ee-4d37-baf7-0661df79b724">
        <updating/>
        <source>createStockMovementForErase() updating, protected;
//--------------------------------------------------------------
//Created: 03 June 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
// No Number logs have swap or offload transactions created which does the adjustment.
// Therefore we do not want to create another one as this would cause errors in the stock levels.	
//	inheritMethod();

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="createStockMovementForOffload" id="c861e98a-7744-40c6-a83f-e78689829557">
        <updating/>
        <source>createStockMovementForOffload(_tiUpdCntrl : CMIF_TIUpdateController input; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     24 September 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpLocation		: CM_LocationsController;
	transaction		: CM_LogNoNumberOffload;
	txnParams		: CMIF_TITransactionController;
	logVoyCntrl		: CM_LogVoyageController;
begin

	if self.isTransient then
		return;
	endif;

	if (not self.isStockControlled) then
		return;
	endif;

	tmpLocation := self.getPrimaryLocation(REAL_MODE);
	if tmpLocation = null then
		return;
	endif;
	if (not tmpLocation.isStockControlled) then
		return;
	endif;
	if (not tmpLocation.isKindOf(CM_LogVoyageController)) then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Attempt to offload No-Number Log which is not on a voyage');
		return;
	else
		logVoyCntrl := tmpLocation.CM_LogVoyageController;
	endif;

	self.beginUpdate(_tiUpdCntrl, _passport);

	create txnParams transient;
	txnParams.dateTime 	:= app.serverTimestampAtTrxStart;
	txnParams.userId 	:= _tiUpdCntrl.userCode;
	txnParams.noCharge := false;
	txnParams.type 		:= TRANS_TYPE_LogNoNumberOffload;
	transaction 		:= self.createTransaction(txnParams, _passport).CM_LogNoNumberOffload;
	transaction.setAdditionalFields(logVoyCntrl.myVoyage);

	tmpLocation.adjustStock(self.myProduct, app.serverTimestampAtTrxStart.date,
							StkMove_LogNoNumberOffLoad, true, self, _tiUpdCntrl, transaction);

	// self.endUpdate not required here as the next thing that happens should be self.erase(..)

end;</source>
        <Parameter name="_tiUpdCntrl" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createStockMovementForSwap" id="be3246b9-7aa0-4803-bdc5-15649449acdc">
        <updating/>
        <source>createStockMovementForSwap(_residualLog : CM_Log input; _tiUpdCntrl : CMIF_TIUpdateController;
						_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     24 September 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpLocation		: CM_LocationsController;
	transaction		: CM_TITransaction;
	txnParams		: CMIF_TITransactionController;
	
begin

	if self.isTransient then
		return;
	endif;

	if (not self.isStockControlled) then
		return;
	endif;

	tmpLocation := self.getPrimaryLocation(REAL_MODE);
	if tmpLocation = null then
		return;
	endif;
	if (not tmpLocation.isStockControlled) then
		return;
	endif;
	if (not tmpLocation.isKindOf(CM_LogVoyageController)) then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Attempt to offload No-Number Log which is not on a voyage');
		return;
	endif;

	create txnParams transient;
	txnParams.dateTime 	:= app.serverTimestampAtTrxStart;
	txnParams.userId 	:= _tiUpdCntrl.userCode;
	txnParams.noCharge	:= false;
	txnParams.type 		:= TRANS_TYPE_LogNoNumberSwap;
	//txnParams.myTrackedItem := self;
	transaction 		:= self.createTransaction(txnParams, _passport);
	transaction.CM_LogVoyageTransaction.setAdditionalFields(tmpLocation.CM_LogVoyageController.myVoyage);
	transaction.CM_LogNoNumberSwap.setResidualLogDetails(_residualLog);

	tmpLocation.adjustStock(self.myProduct, app.serverTimestampAtTrxStart.date,
							StkMove_LogNoNumberOffLoad, true, self, _tiUpdCntrl, transaction);
	
end;</source>
        <Parameter name="_residualLog" type="CM_Log" usage="input"/>
        <Parameter name="_tiUpdCntrl" type="CMIF_TIUpdateController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="displayNoNumberDetail" id="3ddfc903-74eb-4004-b720-71740e64c71d">
        <source>displayNoNumberDetail() : String;

vars

	display,
	theOperator,
	species,
	grade,
	type,
	treatment,
	theLength			: String;

begin

	if self.myOperator &lt;&gt; null then
		theOperator := self.myOperator.code;
	endif;
																//19/02/2009 cnwdz2 par 18586 change the delimiter '/' to ':'
	display := false.Integer.String &amp; Tab &amp; theOperator &amp; Tab &amp;  self.speciesCode &amp; ':' &amp; self.gradeCode &amp; ':' &amp; self.typeCode &amp; ':' &amp;
				self.treatmentCode &amp; Tab  &amp;  self.lengthCode &amp; Tab &amp;  self.sedMean.String &amp; Tab &amp;  self.getMyTotalVolume.jasVolumeString;
	return display;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="erase" id="b85af970-fd1c-412f-8c1e-e65c13ee1e7e">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
//--------------------------------------------------------------
//Created: 25 September 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	if self.myBOLExtLogOutForNN &lt;&gt; null then
		self.myBOLExtLogOutForNN.detachTI(self);
	endif;

	inheritMethod(_eraseLevel);

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="5f1974f8-b8b8-41e3-b378-1c1962d076bc">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// -------------------------------------------
// Created 15 March 2005 by cnwdvb1
// -------------------------------------------
vars

	theOperator : String;
begin

	

	if _attrName = ETRow_Filler then
		return false.Integer.String;		
	elseif _attrName = ETRow_Specs then
		//19/02/2009 cnwdz2 par 18586 change the delimiter '/' to ':'
		return self.speciesCode &amp; ':' &amp; self.gradeCode &amp; ':' &amp; self.typeCode &amp; ':' &amp;
			self.treatmentCode;
	elseif _attrName = ETRow_Length then
		return self.lengthCode;
	elseif _attrName = ETRow_Sed then
		return self.sedMean.String;
	elseif _attrName = ETRow_Volume then
		return self.getMyTotalVolume.jasVolumeString;
	else
		return inheritMethod(_attrName, _short);
	endif;


end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
