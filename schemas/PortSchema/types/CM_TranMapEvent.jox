    <JadeMethod name="shouldAuditProperty" id="e47c7a8b-0bd4-4e2d-9861-bd43ef958d3c">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 January 2017	cnwma1	Initial creation

*/

vars
		propName	: String;
begin
	if _property = null then
		return false;
	endif;
	
	propName := _property.name;
	
	if	propName = CM_TranMapEvent::myChildQuantityMap.name or
		propName = CM_TranMapEvent::myBank.name
		then
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;
epilog
end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="e969fce9-272a-41cf-bf74-f0cf410164ff">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:		October 2007 By Andrew Bishop cnwab1
//
// Purpose:		
// 09/12/2014 cnwdb2 PAR 35364
// ---------------------------------------------------------------------------

vars

begin
	// cnwjre1 May 2010 duplicate test added from general transaction map development, to avoid 1310 exception
	if self.myBank &lt;&gt; null then
		if self.myBank.allEventTranMaps[self.name] &lt;&gt; null then
		//	app.raiseCMException3(ERR_DUPLICATE_KEY,"Transaction map",self.name,null,null,null);
			app.raiseCMException1(TransactionMap_already_exists,self.name,null,null); // cnwdb2 PAR 35364
		endif;
	endif;
end;</source>
    </JadeMethod>
