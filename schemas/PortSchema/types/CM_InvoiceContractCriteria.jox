    <JadeMethod name="cloneForCopy" id="def78084-0dc0-4da1-8590-8c6d2ab583dd">
        <source>cloneForCopy(_transient : Boolean) : SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31/01/2023	navkc1 Bug 61578: EUP | FR 54089 - Invoice Contracts - Copy function extended

*/

vars
	cloned : SelfType;
	criteria,
	clonedCriteria	: CM_YACriteria;
begin
	cloned := self.cloneSelf(_transient);
	
	cloned.description := self.description;
	cloned.name := self.name;
	
	foreach criteria in self.allCriteria do
		clonedCriteria := criteria.cloneForCopy(_transient);
		cloned.allCriteria.add(clonedCriteria);
	endforeach;
	
	return cloned;
	
epilog

end;</source>
        <Parameter name="_transient" type="Boolean"/>
        <ReturnType type="SelfType"/>
    </JadeMethod>
