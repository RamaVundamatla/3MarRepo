    <JadeMethod name="showPreferences" id="63edad48-0dd6-40dc-a1df-5ba72d7cfa6f">
        <updating/>
        <source>showPreferences() updating;
// ---------------------------------------------------------------------------
// Created:     19 May 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theFrame : Frame;
	theTable : CM_EntryTable;
	tblHeight, theTop : Integer;
begin
	theFrame := self.frmPreferences;
	theTable := self.tblPreferences;
	
	theFrame.centreWindow();
	theTable.resetHeight();
	tblHeight := theTable.clientHeight;
	if tblHeight &lt; 20 then
		tblHeight := 20;
	elseif tblHeight &gt; (self.clientHeight - 100)  then
		tblHeight := (self.clientHeight - 100);
	endif;
	theTable.height := tblHeight ;
	
	theTop := (theTable.top + tblHeight + 5).Integer;
	self.btnPreferSave.top := theTop;
	self.btnPreferCancel.top := theTop;
	theFrame.height := theTop + self.btnPreferSave.clientHeight + 15;
	
	theFrame.zOrder(1);
	theFrame.visible := true;
end;</source>
    </JadeMethod>
    <JadeMethod name="showRestrictionsForm" id="149e3df1-466f-4eab-b400-c6a08e545164">
        <source>showRestrictionsForm(_theTerminalArea : CM_TerminalArea;_areaMode : Integer; _initObject : CM_Object);
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

	theTerminalArea : CM_TerminalArea;
	aForm 	: Form;
	menuAction 		: CMUI_MenuAction;
begin
	if _theTerminalArea = null then
		return;
	endif;
	
	theTerminalArea := _theTerminalArea;
	menuAction := app.myController.createMenuAction(PmAdmPadeditView, null, self.myMasterMenuAction, self.myTerminal);
	if menuAction = null then
		return;
	endif;
	
	aForm := menuAction.goToObject(null, null, false, null); 
	if aForm = null then
		return;
	endif;
	
	aForm.sendMsgWithParams("setInitializeWithObject",theTerminalArea,_areaMode,_initObject,self.xmlFlipH,self.xmlFlipV);
	aForm.show;	


end;</source>
        <Parameter name="_theTerminalArea" type="CM_TerminalArea"/>
        <Parameter name="_areaMode" type="Integer"/>
        <Parameter name="_initObject" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="showSelectorForm" id="cc27cf0b-be88-46fd-9116-8a331f3f928d">
        <updating/>
        <source>showSelectorForm(_show : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

	theSelector				: CMUI_Selector;
	cargoType				: CM_CargoType;
	
begin
	
	theSelector := app.getSelectorForm(self, self.myMasterMenuAction);
	if theSelector = null then
		return;
	endif;
	
//	self.setSelector(theSelector);//this will set the default mode
	
	if _show then
		theSelector.show;
	else
		theSelector.btnFind.click(theSelector.btnFind);

	endif;
end;</source>
        <Parameter name="_show" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="233b6c9f-6f5a-406d-b121-82d812030787">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;
// ---------------------------------------------------------------------------
// Created:		March 2005 By Andrew Bishop cnwab1
//
// Purpose:		
