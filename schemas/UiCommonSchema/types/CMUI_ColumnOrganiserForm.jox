    <JadeMethod name="doDragDropFromMSGListBox" id="19c992c9-2126-457a-98a4-cee0d42d403b">
        <updating/>
        <source>doDragDropFromMSGListBox(_listBox: ListBox input; win: Window input; x: Real; y: Real) updating;
/*

Date		Who		Reason
27 March 2014	cnwer1	Initial creation PAR

*/

vars
	sourceIsAvailable,
	sourceIsSelected,
	targetIsSelected,
	targetIsAvailable : Boolean;
	totRows,idx : Integer;
begin
	
	/*if _listBox = self.mulColumns.myAvailableListBox then
		targetIsAvailable:=true;
	elseif _listBox = self.mulColumns.mySelectedListBox then
		targetIsSelected:=true;
	endif;
		
	if win = self.mulColumns.myAvailableListBox then
		sourceIsAvailable:=true;
	elseif win = self.mulColumns.mySelectedListBox then
		sourceIsSelected:=true;
	endif;
		
	if 	targetIsAvailable and sourceIsAvailable then
		return;
	endif;
	
	if targetIsSelected and sourceIsSelected then
		return;
	endif;
	
	if not targetIsAvailable and not targetIsSelected and not sourceIsSelected and not sourceIsAvailable then
		return;
	endif;
	
	
	if sourceIsSelected and targetIsAvailable then
		self.mulColumns.handleBtnClick(self.mulColumns.myRemoveSelectedBtn);
	endif;*/
	
	inheritMethod(_listBox, win, x, y);

epilog

end;</source>
        <Parameter name="_listBox" type="ListBox" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doExportCSV" id="79975efd-2ee1-486a-9157-8e455414cd9a">
        <updating/>
        <source>doExportCSV() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 January 2012	cnwndl1	Initial creation	Par 28889

*/

vars

begin

	app.mousePointer := MousePointer_HourGlass;
	
	if self.myDataTable = null then
		return;
	endif;

	if self.myDataTable.rows &lt;= self.myDataTable.fixedRows then
		app.raiseCMException(ERR_NoDataToExtract, 'Table Data', self.myDataTable);
		return;
	endif;
	
	self.myDataTable.outputAsCSV(null);
	
	self.doCancel();

epilog

	app.mousePointer := MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="doFilterBtnSelection" id="2f9e53f1-f1e6-4e0b-923b-5b8368bbeec6">
        <updating/>
        <source>doFilterBtnSelection( _clear : Boolean ) protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 December 2011	cnwndl1	Initial creation	Par 28889

*/

vars

	index : Integer;
	startRow : Integer;
	endRow : Integer;

begin

	startRow := self.tblFilterValues.fixedRows + 1;
	endRow := self.tblFilterValues.rows;

	if endRow &gt;= startRow then
		foreach index in startRow to endRow do
			if _clear then
				self.tblFilterValues.setCellText(index, 1, "0");
			else
				self.tblFilterValues.setCellText(index, 1, "1");
			endif;
		endforeach;
	endif;
	
	self.selectFilterUpdated := true;
	self.enabledFilterButtons();

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_clear" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doLocalFilterSave" id="86ea4da2-19c5-48cd-a240-54099b53745a">
        <updating/>
        <source>doLocalFilterSave():Boolean protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 December 2011	cnwndl1	Initial creation
11/03/2015			cnwmh5	Transient Leak
24/10/2018			jlgrh7 TFS #41067  STWO - Issue - Shorehandling demurrage (RR-3.01-10MT IMP(Slab 4+)
*/

vars

	column : Integer;
	entableRowHeading : String;
	
	filterStrings : StringArray;
	allSelected : Boolean;
	startRow : Integer;
	endRow : Integer;
	
	index : Integer;
	valuesStartRow : Integer;
	valuesEndRow : Integer;
	
	noneSelected : Boolean;
	str : String;
	msg : String;

begin

	if self.cmbColumnFilter.text.trimBlanks = null then
		return true;
	endif;

	entableRowHeading := self.cmbColumnFilter.text;
	column := self.myDataTable.getColumnByHeading( self.cmbColumnFilter.text );
	if column = 0 and self.cmbColumnFilter.listIndex &gt; 0 then
		// mybe its using teh short description...
		column := self.myDataTable.allTblDataEntRows.indexOf( self.cmbColumnFilter.itemObject[ self.cmbColumnFilter.listIndex ].EntTableRow );
	endif;
	
	if column = 0 then
		app.mousePointer :=	Idle;
		app.msgBox("Unknown column, filter not saved!","Error",MsgBox_OK_Only);
		return true;
	endif;

	valuesStartRow := self.tblFilterValues.fixedRows + 1;
	valuesEndRow := self.tblFilterValues.rows;
	
	create filterStrings transient;
	allSelected := true;
	noneSelected := true;
	startRow := self.myDataTable.fixedRows + 1;
	endRow := self.myDataTable.rows;

	if self.optTableData.value then
		if endRow &gt;= startRow then
			foreach index in valuesStartRow to valuesEndRow do
				if self.tblFilterValues.getCellText(index, 1) = "1" then
					//selected item
					noneSelected := false;
					str := self.tblFilterValues.getCellText(index, 2);
					str :=str.removeEndingDotDotDot(50);			//+TFS41067
					filterStrings.add(str);
				else
					//unselected item
					allSelected := false;
				endif;
			endforeach;
		endif;
		
		if noneSelected then
			app.mousePointer :=	Idle;
			msg := "You must select at least one item to include!";
			app.msgBox( msg, "Warning", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return false;
		endif;
		
	elseif self.optUserData.value then
		allSelected := false;
		str := self.txtFilter.text.trimBlanks;
		str := str.removeEndingDotDotDot(50);						//+TFS41067
		if str = null then
			filterStrings.add('"null"');
		else
			filterStrings.add(str);
		endif;
	
	endif;
	
	if allSelected then
		filterStrings.clear();
	endif;

	self.allFilterColumns.updateColumnFilter( self.myDataTable, column, entableRowHeading, filterStrings, self.optUserData.value);
	self.columnFiltersUpdated := true;
	self.refreshCmbFilterColour();
	
	self.selectFilterUpdated := false;
	
	return true;

epilog

	app.mousePointer :=	Idle;
	
	delete filterStrings;

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doOK" id="d9933a61-1eb9-4704-ae8b-1c2733b59435">
        <updating/>
        <source>doOK() updating;
//--------------------------------------------------
// Created:	08 September 2005 By: cnwgd1
// 09 Jul 2024	navnk30	ChangeRequest 64536: MTN - Adding Filter to column organizer screen - Selected Columns. Task 64537.
//--------------------------------------------------
vars

begin

	self.mulColumns.clearRightFilter();			//09.07.2024 navnk30 #64536 Task 64537
	if not self.validateFilterSelections() then	//04 Jan 2012 NDL	Par 28889
		return;
	endif;
	
	// 09 Aug 2016	NDL	TFS 2518 - Stop idiots from saving with no columns selected and then
	// reporting a fault saying no data is visible....
	if not self.validateSelected() then
		return;
	endif;
	
	if self.doSave then
		// visible columns have changed
		// return IDOK so the form handles re-display
		self.modalResult := IDOK;
	else
		// No change to visible columns
		// return IDCANCEL so the data is not re-displayed
		self.modalResult := IDCANCEL;	
	endif;

	self.unloadForm;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doPrint" id="ede1d861-cef3-4f1f-ae5b-ed05a352343d">
