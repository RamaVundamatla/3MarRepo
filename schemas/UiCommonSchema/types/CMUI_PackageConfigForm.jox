    <JadeMethod name="doFillPackageTypeCombo" id="5374c339-1692-4199-a819-b5a61204ff07">
        <source>doFillPackageTypeCombo(_cmb: ComboBox input) protected;
// ---------------------------------------------------------------------------
// Created:		24 June 2003  by Jason Chapman  (cnwjc2)
// 09 Mar 2020 cnwma1 ChangeRequest 48524: CPL - Credit Invoice Details for Print//09/03/2020 cnwma1 TFS #48524
// ---------------------------------------------------------------------------

vars

	idx : Integer;

begin
	_cmb.clear();
	
	idx := _cmb.addItem( app.getErrorString(Sailing_package)); // (Sailing_Package);
