    <JadeMethod name="unload" id="7bf9359a-fb6d-4950-8413-ccdfe7c37922">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 December 2010	cnwndl1	Initial creation

*/

vars

begin

	if self.timerSet then
		self.endTimer(self.Timer_Set);
	endif;

	self.endClassNotification(CM_CalendarDate, false, Object_Create_Event);
	self.endClassNotification(CM_CalendarDate, false, Object_Update_Event);
	self.endClassNotification(CM_CalendarDate, false, Object_Delete_Event);
	
	self.endClassNotification(CM_Calendar, false, Object_Create_Event);
	self.endClassNotification(CM_Calendar, false, Object_Update_Event);
	self.endClassNotification(CM_Calendar, false, Object_Delete_Event);
	
	self.endClassNotification(CM_DayType, false, Object_Create_Event);
	self.endClassNotification(CM_DayType, false, Object_Update_Event);
	self.endClassNotification(CM_DayType, false, Object_Delete_Event);
	
	inheritMethod();

epilog

end;</source>
