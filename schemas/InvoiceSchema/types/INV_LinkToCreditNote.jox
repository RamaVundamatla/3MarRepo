	if entTableDef &lt;&gt; null then
		tblCreditNotes.selectionType := CM_EntryTable.SelectionType_Row;
		tblCreditNotes.rows := tblCreditNotes.fixedRows;
		tblCreditNotes.setTblDataEntRowsFromDef(entTableDef);
		tblCreditNotes.userInputEnabled := false;
	endif;
epilog

end;</source>
