    <JadeMethod name="updateBookRefField" id="d12b644b-f90d-4a16-af3c-261f1a3f23ec">
        <source>updateBookRefField();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 November 2022	navhl20	ChangeRequest 55087: PNL - Booking Discrepancies - Can 'CA Curtains and Curtains' be renamed?

*/

vars
	bookRefField	: CM_BookingRefDiscrepFieldValue;
	desc : String;
	isAvail : Boolean;
begin
	beginTransaction;
	foreach bookRefField in CM_BookingRefDiscrepFieldValue.instances do
		if bookRefField.fieldName = "Controlled Atmosphere and Curtains In" then
			bookRefField.setFieldName("Curtains In");
		endif;
	endforeach;
	commitTransaction;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="updateEventCamTimeStamp" id="409bc431-a3ca-4b07-9ab7-7e872a8bfb14">
        <source>updateEventCamTimeStamp();
//
//16 Dec 2013	cnwrs1	Par 33035 - add CamsDateTime to CM_EventTransaction
//
vars
	obj : Object;
	objArray : ObjectArray;
	count : Integer;
	now : TimeStamp;
	trxStart : TimeStamp;
	ts : TimeStamp;
	mins : Integer;
	secs : Integer;
begin
	app.initialize;
	ts := app.actualTimeServer;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	create objArray transient;
	CM_EventTransaction.allInstances(objArray, 0, true);
	beginTransaction;
	trxStart := app.actualTimeServer;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	foreach obj in objArray do
		if obj.CM_EventTransaction.camsTimeStamp = null then
			if now.milliSecondsDiff(trxStart).Integer &gt;= 20000 then
				commitTransaction;
				beginTransaction;
				trxStart := app.actualTimeServer;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
			endif;
			obj.CM_EventTransaction.setCAMSTimeStamp(obj.CM_EventTransaction.createdTime);
			now := app.actualTimeServer;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
			count := count + 1;
		endif;
	endforeach;
	commitTransaction;
	now := app.actualTimeServer;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	secs := now.getSecondsInInterval(ts);
	mins := secs div 60;
	secs := secs mod 60;
	app.createActivityHistory(ActivityHistoryGeneral, null, null, 
								"CAMS Event timestamp conversion for terminal "&amp;count.String&amp;' in '&amp;(now.milliSecondsDiff(ts).Integer/1000).String&amp;" millisecs, is complete", 
								false, false);
	write count.String&amp;' in '&amp;mins.asDHMString&amp;' '&amp;secs.String&amp;'s';
epilog
	delete objArray;
end;

</source>
    </JadeMethod>
    <JadeMethod name="updateOperator" id="d3249136-3189-4c66-a661-8c2b049c69be">
        <source>updateOperator();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 November 2022	navhl20	ChangeRequest 55087: PNL - Booking Discrepancies - Can 'CA Curtains and Curtains' be renamed?

*/

vars
	operator	: CM_Operator;
	desc : String;
	isAvail : Boolean;
begin
	beginTransaction;
	foreach operator in CM_Operator.instances do
		foreach desc in operator.allAttribForBookingRefDiscrep do
			if desc = "Controlled Atmosphere and Curtains In" then
				isAvail := true;
			endif;
		endforeach;
		if isAvail then
			write operator.code;
			operator.allAttribForBookingRefDiscrep.remove("Controlled Atmosphere and Curtains In");
			operator.allAttribForBookingRefDiscrep.add("Curtains In");
			operator.allAttribForBookingRefDiscrep.add("CO2");
			operator.allAttribForBookingRefDiscrep.add("O2");
			isAvail := false;
		endif;
	endforeach;
	commitTransaction;
epilog

end;</source>
    </JadeMethod>
