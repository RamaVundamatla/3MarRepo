    <JadeMethod name="tblFields_mouseMove" id="0fc572b8-fb51-4633-8f29-47e581a1f2d0">
        <controlMethod name="Table::mouseMove"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblFields_mouseMove(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:     15 December 2009 by cnwcs5
// Purpose:     CCMS 1023 - snapshot summaries
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if button = MouseButton_Left then
		table.dragMode	:= Table.DragMode_Drag;
	endif;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
