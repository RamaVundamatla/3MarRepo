end;</source>
        <Parameter name="_theEntDef" type="String"/>
    </JadeMethod>
    <JadeMethod name="initTblData" id="c2855bf1-6a13-47e1-9424-4354c33a158d">
        <source>initTblData();
/*
Purpose:			

Date		Who		Reason
13 December 2022	navab1	TFS CR 55645 TASK 55662
*/

vars
	entDef	: EntTableDef;
	index	: Integer;
	xmlStr	: String;
begin

	entDef	:= app.myController.getEntTableDef(ETDef_InvContractEnq);
	xmlStr := self.xmlColumns;
	
	if xmlStr &lt;&gt; null then
		self.tblData.setTblDataEntRowsFromXML(entDef, xmlStr);	
	else	
		self.tblData.setTblDataEntRowsFromDef(entDef);
	endif;
	
	self.tblData.userInputEnabled := false;
	self.tblData.selectMode := Table.SelectMode_CurrentRow;
	self.tblData.selectionType := CM_DataTable.SelectionType_Row;
	self.tblData.multiSelect := self.tblData.MultiSelect_Simple;
	self.tblData.stretchWidth := true;
	self.tblData.stretchHeight := false;
	
	self.setLblTablDetail();


end;</source>
    </JadeMethod>
