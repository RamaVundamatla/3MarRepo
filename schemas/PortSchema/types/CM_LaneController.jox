    <JadeMethod name="getLaneId" id="e3d0258b-4308-4222-8470-d04154ec716b">
        <source>getLaneId():String;
// ---------------------------------------------------------------------------
// Created:     14 September 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if self.myGridArea.CM_AreaWithLanes.laneCount = 0 then
		if self.laneDirection = self.Is_In_Lane then
			return app.getErrorString (GATE_LANE_DEFAULT_IN);
		elseif self.laneDirection = self.Is_Out_Lane then
			return app.getErrorString (GATE_LANE_DEFAULT_OUT);
		endif;
	else
		return self.getLaneNumber.String;
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
