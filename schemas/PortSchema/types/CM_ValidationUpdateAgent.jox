    <JadeMethod name="valSubTerminalOptions" id="e3d95033-9267-4dab-bd70-51b30d8be739">
        <source>valSubTerminalOptions(	_terminalObj:CM_Terminal;
						_isTurnedOn:Boolean;
						_isAreaDefined:Boolean;	//26 Nov 2014	NDL	Par 35295
						_stForExportFullObj:CM_SubTerminal;
						_stForExportMTYObj:CM_SubTerminal;
						_stForImportFullObj:CM_SubTerminal;
						_stForImportMTYObj:CM_SubTerminal;
						_stForStorageFullObj:CM_SubTerminal;
						_stForStorageMTYObj:CM_SubTerminal;
						_stForImportGenObj:CM_SubTerminal;
						_stForExportGenObj:CM_SubTerminal;
						_stForStorageGenObj:CM_SubTerminal;
						_stForCargoOtherObj:CM_SubTerminal;
						_stForSourceBulkRdObj:CM_SubTerminal;		// cnwdad1 PAR 22205.
						_stForSourceBulkRlObj:CM_SubTerminal;		// cnwdad1 PAR 22205.
						_stForSourceBulkShObj:CM_SubTerminal;		// cnwdad1 PAR 22205.
						_stForSourceBulkPkObj:CM_SubTerminal;		// cnwdad1 PAR 22205.
						_stForTargetBulkObj:CM_SubTerminal;
						_stForBOLInwardsObj:CM_SubTerminal;
						_passportObj:CM_Passport input);
// --------------------------------------------------------------------------------
// Created:		07 April 2009 by cnwdad1
//
// Purpose:		Validation method to check the specified Terminal's Sub-Terminal settings.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 27/01/2010	cnwdad1		PAR 22205 (CCMS POL 1904).  Added extra Bulk Release
//							Sub-Terminal parameters.
// --------------------------------------------------------------------------------
begin
	self.raiseExceptionIfNull(_terminalObj, "Terminal");
	
	//if not _isTurnedOn then
	if not _isTurnedOn or _isAreaDefined then	//27 Nov 2014	NDL	Par 35295
		return;
	endif;
	
	if _stForExportFullObj = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "Default Sub-Terminal for 'Export Full' items", null, null);
		app.raiseCMException(Input_required_field_dftSubExp, null, null); // cnwdb2	PAR 35364
	endif;
	
	if _stForExportMTYObj = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "Default Sub-Terminal for 'Export MTY' items", null, null);
		app.raiseCMException(Input_required_field_SubExpMTY, null, null);
	endif;
	
	if _stForImportFullObj = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "Default Sub-Terminal for 'Import Full' items", null, null);
		app.raiseCMException(Input_required_field_SubImpFul, null, null); // cnwdb2	PAR 35364
	endif;
	
	if _stForImportMTYObj = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "Default Sub-Terminal for 'Import MTY' items", null, null);
		app.raiseCMException(Input_required_field_subImpMTY, null, null); // cnwdb2	PAR 35364
	endif;
	
	if _stForStorageFullObj = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "Default Sub-Terminal for 'Storage Full' items", null, null);
		app.raiseCMException(Input_required_field_dfltSub, null, null); // cnwdb2	PAR 35364
	endif;
	
	if _stForStorageMTYObj = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "Default Sub-Terminal for 'Storage MTY' items", null, null);
		app.raiseCMException(Input_required_field_DSTStor, null, null); // cnwdb2	PAR 35364
	endif;
	
	if _stForImportGenObj = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "Default Sub-Terminal for 'Non-Container Import' items", null, null);
		app.raiseCMException(Input_required_field_DSTNCI, null, null); // cnwdb2	PAR 35364
	endif;
	
	if _stForExportGenObj = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "Default Sub-Terminal for 'Non-Container Export' items", null, null);
		app.raiseCMException(Input_required_field_DSTNCE, null, null); // cnwdb2	PAR 35364
	endif;
	
	if _stForStorageGenObj = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "Default Sub-Terminal for 'Non-Container Storage' items", null, null);
		app.raiseCMException(Input_required_field_DSTNCS, null, null); // cnwdb2	PAR 35364
	endif;
	
	if _stForCargoOtherObj = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "Default Sub-Terminal for 'General Other' items", null, null);
		app.raiseCMException(Input_required_field_DSTGO, null, null); // cnwdb2	PAR 35364
	endif;
	
	if _stForSourceBulkRdObj = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "Default Sub-Terminal for 'Bulk Source (Road)' items", null, null);
		app.raiseCMException(Input_required_field_DSTBSR, null, null); // cnwdb2	PAR 35364
	endif;
	
	if _stForSourceBulkRlObj = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "Default Sub-Terminal for 'Bulk Source (Rail)' items", null, null);
		app.raiseCMException(Input_required_field_DSTBSRa, null, null); // cnwdb2	PAR 35364
	endif;
	
	if _stForSourceBulkShObj = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "Default Sub-Terminal for 'Bulk Source (Ship)' items", null, null);
		app.raiseCMException(Input_required_field_DSTBSS, null, null); // cnwdb2	PAR 35364
	endif;
	
	if _stForSourceBulkPkObj = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "Default Sub-Terminal for 'Bulk Source (Packing)' items", null, null);
		app.raiseCMException(Input_required_field_DSTBSP, null, null); // cnwdb2	PAR 35364
	endif;
	
	if _stForTargetBulkObj = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "Default Sub-Terminal for 'Bulk Target' items", null, null);
		app.raiseCMException(Input_required_field_DSTBT, null, null); // cnwdb2	PAR 35364
	endif;
	
	if _stForBOLInwardsObj = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "Default Sub-Terminal for 'Bill of Lading (Inwards)' items", null, null);
		app.raiseCMException(Input_required_field_DSTBLI, null, null); // cnwdb2	PAR 35364
	endif;
end;</source>
        <Parameter name="_terminalObj" type="CM_Terminal"/>
        <Parameter name="_isTurnedOn" type="Boolean"/>
        <Parameter name="_isAreaDefined" type="Boolean"/>
        <Parameter name="_stForExportFullObj" type="CM_SubTerminal"/>
        <Parameter name="_stForExportMTYObj" type="CM_SubTerminal"/>
        <Parameter name="_stForImportFullObj" type="CM_SubTerminal"/>
        <Parameter name="_stForImportMTYObj" type="CM_SubTerminal"/>
        <Parameter name="_stForStorageFullObj" type="CM_SubTerminal"/>
        <Parameter name="_stForStorageMTYObj" type="CM_SubTerminal"/>
        <Parameter name="_stForImportGenObj" type="CM_SubTerminal"/>
        <Parameter name="_stForExportGenObj" type="CM_SubTerminal"/>
        <Parameter name="_stForStorageGenObj" type="CM_SubTerminal"/>
        <Parameter name="_stForCargoOtherObj" type="CM_SubTerminal"/>
        <Parameter name="_stForSourceBulkRdObj" type="CM_SubTerminal"/>
        <Parameter name="_stForSourceBulkRlObj" type="CM_SubTerminal"/>
        <Parameter name="_stForSourceBulkShObj" type="CM_SubTerminal"/>
        <Parameter name="_stForSourceBulkPkObj" type="CM_SubTerminal"/>
        <Parameter name="_stForTargetBulkObj" type="CM_SubTerminal"/>
        <Parameter name="_stForBOLInwardsObj" type="CM_SubTerminal"/>
        <Parameter name="_passportObj" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="valSwapTruckTasks" id="373dfa42-8812-4277-b9be-d32807ed54e7">
        <source>valSwapTruckTasks(_wle1 , _wle2 : CM_WorkListEntry ; _passport : CM_Passport input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 November 2013	cnwrd1	Initial creation

*/

vars

begin


	if _wle1.isReceipt then
		app.raiseCMException(Cargo_items_tryin_swap_recei_b, 'Truck Swap', null);	
	endif;
	
	if _wle2.isReceipt then
		app.raiseCMException(Cargo_items_tryin_swap_recei_b, 'Truck Swap', null);	
	endif;
	
	if _wle1.job.CM_RoadJob.myVehicleVisit = _wle2.job.CM_RoadJob.myVehicleVisit then		
		app.raiseCMException(Cannot_swap_cargo_same_truck, 'Truck Swap', null);	
	endif;
	
	
	if _wle1.isCompleteForJob then
		app.raiseCMException1(Task_cargo_compl_canno_swap_th, _wle1.myTrackedItem.id,'Truck Swap', null);			
	endif;
	
	if _wle2.isCompleteForJob then
		app.raiseCMException1(Task_cargo_compl_canno_swap_th, _wle2.myTrackedItem.id,'Truck Swap', null);			
	endif;

	// not sure we want this as a restriction but check if they are on the same bulk release.
	/*if wle1.myRequest.getBulkRelease &lt;&gt; wle2.myRequest.getBulkRelease then
		return false;
	endif;*/
epilog

end;</source>
        <Parameter name="_wle1" type="CM_WorkListEntry"/>
        <Parameter name="_wle2" type="CM_WorkListEntry"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="valSwapWLEJobCargo" id="e707f806-da8f-4016-ae8c-ec5511149dec">
        <source>valSwapWLEJobCargo(_wle1, _wle2 : CM_WorkListEntry; _targetLocation, _twinTargetLocation : String; _passport : CM_Passport input);
/*

Purpose:			This method test the cargo against the release request during a swap.
					For Example
					Test Cargo 1 with Release Request 2
					Test Cargo 2 with Release Request 1

Parameters:			

Return Value:		

Date		Who		Reason
29/10/2025	navkc1 JIRA 36186 PNL | Vehicle App Swap behaviour with Release Requests - DB Changes / Jade / Form

*/

vars
	cargo1,
	cargo2				: CM_TrackedItem;
	request1,
	request2			: CM_Request;
	
	reserveSelection1,
	reserveSelection2	: CM_ReserveDetail;
	
	reason1,
	reason2				: String;
begin
	cargo1 := _wle1.myTrackedItem;
	cargo2 := _wle2.myTrackedItem;

	request1 := _wle1.myRequest;
	request2 := _wle2.myRequest;
	
	if request1 &lt;&gt; null then
		reserveSelection1 := request1.myReserveDetail;
	endif;
	
	if request2 &lt;&gt; null then
		reserveSelection2 := request2.myReserveDetail;
	endif;
	
	// Test Cargo 1 against Release Request 2
	if cargo1 &lt;&gt; null and reserveSelection2 &lt;&gt; null then
		if not cargo1.testAgainstReserveSelection(reserveSelection2.CM_ReserveSelection, reason1, false, null) then
			app.raiseCMException2(Warn_Request_Line_Match, reason1, cargo1.id,null,null);
		endif;
	endif;
	
	// Test Cargo 2 against Release Request 1
	if cargo2 &lt;&gt; null and reserveSelection1 &lt;&gt; null then
		if not cargo2.testAgainstReserveSelection(reserveSelection1.CM_ReserveSelection, reason2, false, null) then
			app.raiseCMException2(Warn_Request_Line_Match, reason2, cargo2.id,null,null);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_wle1" type="CM_WorkListEntry"/>
        <Parameter name="_wle2" type="CM_WorkListEntry"/>
        <Parameter name="_targetLocation" type="String"/>
        <Parameter name="_twinTargetLocation" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="valSysAlertType" id="0e32fa34-723a-47d8-9c01-4ad8c2493f6b">
