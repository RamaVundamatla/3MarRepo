    <DbClassMap file="Coy"/>
    <ImplicitInverseRef name="allTranStats1" id="b50e3080-bffa-46f3-856f-74f51c94c539">
        <memberTypeInverse/>
        <type name="DynaDictionary"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="allTranStats2" id="32704d38-1166-45dc-be79-81775bdf2729">
        <memberTypeInverse/>
        <type name="DynaDictionary"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="allTransactions" id="a08d1a60-308e-48df-8d18-8d769ec507f9">
        <memberTypeInverse/>
