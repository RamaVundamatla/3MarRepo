    <JadeMethod name="getRemarksFor" id="7e59ccab-901c-4fe9-8fdd-5e990db55146">
        <source>getRemarksFor( _taskDesc : CM_ToDoTaskDesc ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 October 2016	cnwndl1	Initial creation	TFS 2001 / 2792

*/

vars

	index : Integer;
	remarksStr : String;

begin

	if _taskDesc &lt;&gt; null then
		index := self.allTaskDescsToAdd.indexOf( _taskDesc );
	endif;
	
	if index &gt; 0 then
		if allTaskRemarkToAdd &lt;&gt; null and allTaskRemarkToAdd.size &gt;= index then
			remarksStr := allTaskRemarkToAdd[index];
		endif;
	endif;

	return remarksStr;

epilog

end;</source>
        <Parameter name="_taskDesc" type="CM_ToDoTaskDesc"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getStopsList" id="d105dea2-b737-4052-aece-cb3f2677b216">
        <source>getStopsList( _delim : String; _includeCount : Boolean ): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 September 2016	cnwndl1	Initial creation	TFS 2644 / 2001

*/

vars

	retString : String;
	invalidObj : Boolean;
	stop : CM_StopsTable;
	attrStr : String;
	completed : Real;
	applied : Real;

begin

	on Exception do app.handleDeletedObject(exception, stop, invalidObj);
	
	foreach stop in self.allStopTablesToAdd do
		attrStr := null;
		attrStr := stop.code;
		if _includeCount then
			self.getTotalsForStop( stop, completed, applied );
			attrStr := attrStr &amp; " (" &amp; completed.String &amp;"/" &amp; applied.String &amp; ")";
		endif;
		if attrStr &lt;&gt; null then
			if retString &lt;&gt; null then
				retString := retString &amp; _delim;
			endif;
			retString := retString &amp; attrStr;
		endif;
	endforeach;
	
	return retString;

epilog

end;</source>
        <Parameter name="_delim" type="String"/>
        <Parameter name="_includeCount" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTIsToBeCompleted" id="513ab2b0-c5d3-48ac-9a68-a66a39df4334">
        <source>getTIsToBeCompleted(	_tiArray : CM_TIArray input;
						_stop : CM_StopsTable;
						_task : CM_ToDoTaskDesc;
						_lc : CM_LocationsController
						);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 September 2016	cnwndl1	Initial creation	TFS 2647

*/

vars

	iter : Iterator;
	docStop : CM_DocumentStops;
	docTask : CM_DocumentToDoTask;
	ti : CM_TrackedItem;
	invalidObj : Boolean;

begin

	_tiArray.clear();
	
	on Exception do app.handleDeletedObject(exception, ti, invalidObj);

	if _stop &lt;&gt; null then
		iter := self.allDocumentStopsApplied.createIterator;
		while iter.next(docStop) do
			if _stop &lt;&gt; docStop.myStopsTable then
				continue;
			endif;
			invalidObj := false;
			ti := docStop.myTrackedItem;
			if ti = null then
				continue;
			endif;
			if _lc &lt;&gt; null then
				if _lc &lt;&gt; ti.myPrimaryActualLocation then
					continue;
				endif;
			endif;
			if invalidObj then
				continue;
			endif;
			_tiArray.add( ti );
		endwhile;
	
	elseif _task &lt;&gt; null then
		iter := self.allDocumentTasksApplied.createIterator;
		while iter.next(docTask) do
			if _task &lt;&gt; docTask.toDoTaskDesc then
				continue;
			endif;
			invalidObj := false;
			ti := docTask.myTrackedItem;
			if ti = null then
				continue;
			endif;
			if _lc &lt;&gt; null then
				if _lc &lt;&gt; ti.myPrimaryActualLocation then
					continue;
				endif;
			endif;
			if invalidObj then
				continue;
			endif;
			_tiArray.add( ti );
		endwhile;
	
	endif;

epilog

	delete iter;

end;</source>
        <Parameter name="_tiArray" type="CM_TIArray" usage="input"/>
        <Parameter name="_stop" type="CM_StopsTable"/>
        <Parameter name="_task" type="CM_ToDoTaskDesc"/>
        <Parameter name="_lc" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="getTaskAndStopStrForTi" id="cf37d40a-0bb4-407a-8452-7775bb647788">
        <source>getTaskAndStopStrForTi( _ti : CM_TrackedItem; _short : Boolean ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 September 2016	cnwndl1	Initial creation	TFS 2647 / 2001

*/

vars

	stop : CM_StopsTable;
	task : CM_ToDoTaskDesc;
	
	totalApplied : Real;
	totCompleted : Real;
	remaining : Real;
	
	hasIncompleteTasks : Boolean;
	hasIncompleteStops : Boolean;
	
	returnStr : String;
	reason : String;

begin

// TFS 4052	if self.areAllActionsCompleteFor( _ti, reason ) then
	if self.areAllActionsCompletedFor( _ti, reason ) then // TFS 4052
		return null;
	endif;

	foreach stop in self.allStopTablesToAdd do
		self.getTotalsForTi( 	stop,	//_stop : CM_StopsTable;
								null,	//_task : CM_ToDoTaskDesc;
								_ti,	//_ti : CM_TrackedItem;
								totalApplied,	//_totalApplied : Real output;
								totCompleted,	//_totCompleted : Real output;
								remaining	//_remaining : Real output
								);
		if remaining &gt; 0 then
			hasIncompleteStops := true;
			break;
		endif;
	endforeach;
	
	foreach task in self.allTaskDescsToAdd do
		self.getTotalsForTi( 	null,	//_stop : CM_StopsTable;
								task,	//_task : CM_ToDoTaskDesc;
								_ti,	//_ti : CM_TrackedItem;
								totalApplied,	//_totalApplied : Real output;
								totCompleted,	//_totCompleted : Real output;
								remaining	//_remaining : Real output
								);
		if remaining &gt; 0 then
			hasIncompleteTasks := true;
			break;
		endif;
	endforeach;
	
	if hasIncompleteStops and hasIncompleteTasks then
		returnStr := " " &amp; "(" &amp; app.getErrorString(ActionStop) &amp; "," &amp;  app.getErrorString(ActionTask) &amp; ")";
	elseif hasIncompleteStops then
		returnStr := " " &amp; "(" &amp; app.getErrorString(ActionStop) &amp; ")";
	elseif hasIncompleteTasks then
		returnStr := " " &amp; "(" &amp; app.getErrorString(ActionTask) &amp; ")";
	else
		returnStr := null;
	endif;

	return returnStr;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTaskList" id="75589ef8-fda3-4ed8-85fe-4f515697a841">
        <source>getTaskList( _delim : String; _includeCount : Boolean ): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 September 2016	cnwndl1	Initial creation	TFS 2644 / 2001

*/

vars

	retString : String;
	invalidObj : Boolean;
	task : CM_ToDoTaskDesc;
	attrStr : String;
	completed : Real;
	applied : Real;

begin

	on Exception do app.handleDeletedObject(exception, task, invalidObj);
	
	foreach task in self.allTaskDescsToAdd do
		attrStr := null;
		attrStr := task.shortDescription;
		if _includeCount then
			self.getTotalsForTask( task, completed, applied );
			attrStr := attrStr &amp; " (" &amp; completed.String &amp;"/" &amp; applied.String &amp; ")";
		endif;
		if attrStr &lt;&gt; null then
			if retString &lt;&gt; null then
				retString := retString &amp; _delim;
			endif;
			retString := retString &amp; attrStr;
		endif;
	endforeach;
	
	return retString;

epilog

end;</source>
        <Parameter name="_delim" type="String"/>
        <Parameter name="_includeCount" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getThumbNailDisp" id="e2abcccf-aebf-4f6c-b37f-632e2b8b237e">
        <source>getThumbNailDisp():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 September 2016	cnwndl1	Initial creation	TFS 2649 / 2001

*/

vars

	str : String;
	tiArray : CM_TIArray;
	ti : CM_TrackedItem;
	edition : Integer;
	invalidObj : Boolean;
	selectedTis : CM_TIArray;	// those on a 'selected' tab in HH (i.e. on a machine)
	tiIdArray : StringArray;
	tisToSummarise : CM_TIArray;
	selectedCount : Integer;

begin

	str := self.getDocumentId();
	
	if not self.allStopTablesToAdd.isEmpty then
		str := str &amp; ", Stops=" &amp; self.getStopsList(" ",true);
	endif;
	if not self.allTaskDescsToAdd.isEmpty then
		str := str &amp; ", Tasks=" &amp; self.getTaskList(" ",true);
	endif;
	
	create tiArray transient;
	self.getAllTis(	tiArray );
	
	create selectedTis transient;
	create tiIdArray transient;
	create tisToSummarise transient;
	
	on Exception do app.handleDeletedObject( exception, ti, invalidObj );
	
	foreach ti in tiArray do
		invalidObj := false;
		edition := ti.edition;
		if invalidObj then
			continue;
		endif;
		if ti.hasBeenMerged then
			continue;
		endif;
		if ti.myPrimaryActualLocation &lt;&gt; null and ti.myPrimaryActualLocation.isMachineController then
			selectedTis.addExclusive(ti);
			selectedCount := selectedCount + ti.totalQuantity.max(1);
		endif;
		if tiIdArray.includes(ti.id) then
			continue;
		endif;
		tiIdArray.add(ti.id);
		tisToSummarise.add(ti);
	endforeach;
	
	if not selectedTis.isEmpty then
		str := str &amp; ", Selected cargo count (on machine) =" &amp; selectedCount.String;
	endif;
	
	foreach ti in tisToSummarise do
		str := str &amp; ", " &amp; ti.id &amp; self.getTaskAndStopStrForTi( ti, true );
	endforeach;

	return str;

epilog

	delete tiArray;
	delete selectedTis;
	delete tiIdArray;
	delete tisToSummarise;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTotalsForStop" id="35e1908c-502f-422e-aa6e-7285a4ce2d57">
        <source>getTotalsForStop( _stop : CM_StopsTable; _completed : Real output; _applied : Real output );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 October 2016	cnwndl1	Initial creation

*/

vars

	iter : Iterator;
	tiTrx : CM_TITransaction;
	stopTrx : CM_StopClearedDocAction;
	
	stopApply : CM_DocumentStops;

	invalidObject	: Boolean;


begin
	on Exception do app.handleDeletedObject(exception, tiTrx, invalidObject); // ### TFS 53851 14JUN2022 NAVAB1


	iter := self.allCompletedStopTrx.createIterator;
	while iter.next( tiTrx ) do
		if not tiTrx.isStopClearedDocAction then
			continue;
		endif;
		stopTrx := tiTrx.CM_StopClearedDocAction;
		if stopTrx.stopID &lt;&gt; _stop.id then
			continue;
		endif;
		_completed := _completed + stopTrx.amount;
	endwhile;
	delete iter;
	
	iter := self.allDocumentStopsApplied.createIterator;
	while iter.next( stopApply ) do
		if stopApply.myStopsTable &lt;&gt; _stop then
			continue;
		endif;
		_applied := _applied + stopApply.amount;
	endwhile;

epilog

	delete iter;

end;</source>
        <Parameter name="_stop" type="CM_StopsTable"/>
        <Parameter name="_completed" type="Real" usage="output"/>
        <Parameter name="_applied" type="Real" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getTotalsForTask" id="c7db92aa-6ced-483f-9f47-14126c05b234">
        <source>getTotalsForTask( _task : CM_ToDoTaskDesc;  _completed : Real output; _applied : Real output );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 October 2016	cnwndl1	Initial creation

*/

vars

	iter : Iterator;
	tiTrx : CM_TITransaction;
	taskTrx : CM_TaskCompleteDocAction;
	
	taskApply : CM_DocumentToDoTask;

	invalidObject	: Boolean;


begin
	on Exception do app.handleDeletedObject(exception, tiTrx, invalidObject); // ### TFS 53851 14JUN2022 NAVAB1


	iter := self.allCompletedTaskTrx.createIterator;
	while iter.next( tiTrx ) do
		if not tiTrx.isTaskCompleteDocAction then
			continue;
		endif;
		taskTrx := tiTrx.CM_TaskCompleteDocAction;
		if taskTrx.todoTaskCode &lt;&gt; _task.code then
			continue;
		endif;
		_completed := _completed + taskTrx.amount;
	endwhile;
	delete iter;
	
	iter := self.allDocumentTasksApplied.createIterator;
	while iter.next( taskApply ) do
		if taskApply.toDoTaskDesc &lt;&gt; _task then
			continue;
		endif;
		_applied := _applied + taskApply.amount;
	endwhile;

epilog

	delete iter;

end;</source>
        <Parameter name="_task" type="CM_ToDoTaskDesc"/>
        <Parameter name="_completed" type="Real" usage="output"/>
        <Parameter name="_applied" type="Real" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getTotalsForTi" id="d45bc8f6-c669-4587-a844-86c5c037f337">
        <source>getTotalsForTi( 	_stop : CM_StopsTable;
					_task : CM_ToDoTaskDesc;
					_ti : CM_TrackedItem;
					_totalApplied : Real output;
					_totCompleted : Real output;
					_remaining : Real output
					);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 September 2016	cnwndl1	Initial creation	TFS 2647 / 2001

*/

vars

	docStop : CM_DocumentStops;
	docTask : CM_DocumentToDoTask;

begin

	if _ti = null then
		return;
	endif;
	
	if _stop &lt;&gt; null then
		_totalApplied := self.allDocumentStopsApplied.getTotalAmountForId( _ti.id, _stop );
		if _totalApplied &lt;= 0 then
			return;
		endif;
		
	elseif _task &lt;&gt; null then
		_totalApplied := self.allDocumentTasksApplied.getTotalAmountForId( _ti.id, _task );
		if _totalApplied &lt;= 0 then
			return;
		endif;
		
	else
		return;
	endif;
	
	_totCompleted := self.getCompletedAmount( _ti.id, _stop, _task );
	_remaining := _totalApplied - _totCompleted;

epilog

end;</source>
        <Parameter name="_stop" type="CM_StopsTable"/>
        <Parameter name="_task" type="CM_ToDoTaskDesc"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_totalApplied" type="Real" usage="output"/>
        <Parameter name="_totCompleted" type="Real" usage="output"/>
        <Parameter name="_remaining" type="Real" usage="output"/>
    </JadeMethod>
    <JadeMethod name="hasActions" id="27b537ce-2c7a-4321-818b-c7336aa9eadf">
        <source>hasActions():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 September 2016	cnwndl1	Initial creation	TFS 2647

*/

vars

begin

	if not allStopTablesToAdd.isEmpty then
		return true;
	elseif not allTaskDescsToAdd.isEmpty then
		return true;
	else
		return false;
	endif;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includesStopTable" id="cafd4d4a-78e5-4a25-adac-93d1f2f0630c">
        <source>includesStopTable( _stopTable : CM_StopsTable ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 March 2017	cnwndl1	Initial creation	TFS 3667

*/

vars

	iter : Iterator;
	docStop : CM_DocumentStops;
	tiTrx : CM_TITransaction;
	tiStop : CM_Stops;
	invalid : Boolean;

begin
	on Exception do app.handleDeletedObject(exception, tiTrx, invalid);

	if _stopTable = null then
		return false;
	endif;

	if self.allStopTablesToAdd.includes( _stopTable ) then
		return true;
	endif;
	
	iter := self.allDocumentStopsApplied.createIterator;
	while iter.next( docStop ) do
		if docStop.myStopsTable = _stopTable then
			return true;
		endif;
	endwhile;
	delete iter;
	
	iter := self.allCompletedStopTrx.createIterator;
	while iter.next( tiTrx ) do
		if tiTrx.isKindOf(CM_StopCleared) then
			tiStop := tiTrx.CM_StopCleared.myStop;
			if tiStop &lt;&gt; null and tiStop.myStopsTable = _stopTable then
				return true;
			endif;
		endif;
	endwhile;
	delete iter;
	
	return false;

epilog

	delete iter;

end;</source>
        <Parameter name="_stopTable" type="CM_StopsTable"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includesTi" id="b4f26127-0596-4e65-8316-544334d30114">
        <source>includesTi( _ti : CM_TrackedItem ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 October 2016	cnwndl1	Initial creation

*/

vars

	iter : Iterator;
	docStop : CM_DocumentStops;
	docTask : CM_DocumentToDoTask;
	ti : CM_TrackedItem;

begin

	if _ti &lt;&gt; null then
	
		iter := self.allDocumentStopsApplied.createIterator;
		while iter.next(docStop) do
			ti := docStop.myTrackedItem;
			if ti = _ti then
				return true;
			endif;
		endwhile;
		delete iter;
		
		iter := self.allDocumentTasksApplied.createIterator;
		while iter.next(docTask) do
			ti := docTask.myTrackedItem;
			if ti = _ti then
				return true;
			endif;
		endwhile;
		
	endif;
	
	return false;

epilog

	delete iter;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includesToDoTask" id="63cd9d67-2c17-479f-93f7-4c0a6ac06dc0">
        <source>includesToDoTask( _toDoTaskDesc : CM_ToDoTaskDesc ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 March 2017	cnwndl1	Initial creation	TFS 3667

*/

vars

	iter : Iterator;
	docTask : CM_DocumentToDoTask;
	tiTrx : CM_TITransaction;
	invalid : Boolean;

begin
	on Exception do app.handleDeletedObject(exception, tiTrx, invalid);

	if _toDoTaskDesc = null then
		return false;
	endif;

	if self.allTaskDescsToAdd.includes( _toDoTaskDesc ) then
		return true;
	endif;
	
	iter := self.allDocumentTasksApplied.createIterator;
	while iter.next( docTask ) do
		if docTask.toDoTaskDesc = _toDoTaskDesc then
			return true;
		endif;
	endwhile;
	delete iter;
	
	iter := self.allCompletedTaskTrx.createIterator;
	while iter.next( tiTrx ) do
		if tiTrx.isKindOf(CM_TaskComplete) then
			if tiTrx.CM_TaskComplete.todoTaskCode = _toDoTaskDesc.code then
				return true;
			endif;
		endif;
	endwhile;
	delete iter;
	
	return false;

epilog

	delete iter;

end;</source>
        <Parameter name="_toDoTaskDesc" type="CM_ToDoTaskDesc"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isBookingItemAction" id="300e1c9e-d8d7-490d-9108-3d0d721fb664">
