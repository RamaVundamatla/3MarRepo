    <JadeMethod name="voyageStatGroupENumToString" id="3e5abcb6-c9d1-4dd5-a6ee-1e4b738b8f8e">
        <source>voyageStatGroupENumToString(_group : Integer) : String;
//--------------------------------------------------
// Created:	30 November 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	
	// 1, 2, 3, 4
	if _group = VoyageStat_CargoLoaded then
		return VoyageStat_CargoLoaded_Str;
	elseif _group = VoyageStat_CargoOffloaded then
		return VoyageStat_CargoOffloaded_Str;		
	elseif _group = VoyageStat_CargoUnits then
		return VoyageStat_CargoUnits_Str;
	elseif _group = VoyageStat_CargoTons then
		return VoyageStat_CargoTons_Str;		
	
	// 5, 6
	elseif _group = VoyageStat_Charges then
		return VoyageStat_Charges_Str;
	elseif _group = VoyageStat_ChargesTotal then
		return VoyageStat_ChargesTotal_Str;		
	
	// 7, 8
	elseif _group = VoyageStat_Resources then
		return VoyageStat_Resources_Str;			
	elseif _group = VoyageStat_ResourcesTotal then
		return VoyageStat_ResourcesTotal_Str;

	// 9, 10
	elseif _group = VoyageStat_Passengers then
		return VoyageStat_Passengers_Str;	
	elseif _group = VoyageStat_PassengersTotal then
		return VoyageStat_PassengersTotal_Str;			

	// 11, 12
	elseif _group = VoyageStat_PassengerVesselCall then
		return VoyageStat_PasseVesselCall_Str;	
	elseif _group = VoyageStat_PassVesselCallTot then
		return VoyageStat_PassVesCallTot_Str;

	// 13, 14					
	elseif _group = VoyageStat_CargoVesselCall then
		return VoyageStat_CargoVesselCall_Str;	
	elseif _group = VoyageStat_CargoVesCallTot then
		return VoyageStat_CargoVesCallTot_Str;			
	
	// 15
	elseif _group = VoyageStat_VesselCallTotal then
		return VoyageStat_VesselCallTotal_Str;					
									
	else
		return VoyageStat_Unknown_Str;
	endif;
end;</source>
        <Parameter name="_group" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="voyageStatGroupStringToENum" id="1f1fbbc2-7f9f-4079-9b59-01640e704136">
        <source>voyageStatGroupStringToENum(_groupDesc : String) : Integer;
//--------------------------------------------------
// Created:	30 November 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	if _groupDesc = VoyageStat_CargoUnits_Str then
		return VoyageStat_CargoUnits;
	elseif _groupDesc = VoyageStat_CargoLoaded_Str then
		return VoyageStat_CargoLoaded;
	elseif _groupDesc = VoyageStat_CargoOffloaded_Str then
		return VoyageStat_CargoOffloaded;		
	elseif _groupDesc = VoyageStat_CargoVesselCall_Str then
		return VoyageStat_CargoVesselCall;	
	elseif _groupDesc = VoyageStat_PasseVesselCall_Str then
		return VoyageStat_PassengerVesselCall;	
	elseif _groupDesc = VoyageStat_Passengers_Str then
		return VoyageStat_Passengers;	
	elseif _groupDesc = VoyageStat_Charges_Str then
		return VoyageStat_Charges;									
	elseif _groupDesc = VoyageStat_Resources_Str then
		return VoyageStat_Resources;			
	else
		return VoyageStat_Unknown;
	endif;
end;</source>
        <Parameter name="_groupDesc" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="voyageStatusEnumToString" id="7c349bbe-3519-45da-89f6-0cc0f7294fa4">
        <source>voyageStatusEnumToString(_statusStr : Integer; _isLogVoyage : Boolean) : String;
// ---------------------------------------------------------------------------
// Created:     04 June 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
// 24/02/2017 	cnwrh7      TFS3464       #- Voyage definition / voyage status
// 09/03/2018	jlgdap1		TFS 37427 PEL1 Voyage Status Enhancements
vars
	voyStatus : CM_VoyageStatus;

begin
	// TFS 37427 Use new Voyage Status objects to get status description
	voyStatus := self.myRoot.allVoyageStatuses[_statusStr];
	if voyStatus &lt;&gt; null then
		return voyStatus.description;
	endif;
	// TFS 37427 end
	
	/*if _statusStr = Voyage_Status_Archived then													//+TFS3464
		return app.getErrorString(VoyageCmb_Status_Archived_Str);
	elseif _statusStr = Voyage_Status_Closed then
		return app.getErrorString(VoyageCmb_Status_Closed_Str);
	elseif _statusStr = Voyage_Status_Arrived then
		return app.getErrorString(VoyageCmb_Status_Arrived_Str);
	elseif _statusStr = Voyage_Status_Departed then
		return app.getErrorString(VoyageCmb_Status_Departed_Str);
	elseif _statusStr = Voyage_Status_LoadComplete then
		if _isLogVoyage then //PAR 11322
			return app.getErrorString(VoyageCmb_Status_LdComplte_Str);
		else
			return app.getErrorString(VoyageCmb_Status_XchanComp_Str);
		endif;
	elseif _statusStr = Voyage_Status_Loading then
		return app.getErrorString(VoyageCmb_Status_Loading_Str);
	elseif _statusStr = Voyage_Status_Pending then
		return app.getErrorString(VoyageCmb_Status_Pending_Str);
	elseif _statusStr = Voyage_Status_Cancelled then //cnwrd1 par 23993 24.5.2010 CCMS 1928
		return app.getErrorString(VoyageCmb_Status_Cancelled_Str);
	endif;	*/
end;</source>
        <Parameter name="_statusStr" type="Integer"/>
        <Parameter name="_isLogVoyage" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
