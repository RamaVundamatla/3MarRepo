<GUIClass name="CMUI_FilterTableFrame" id="2ec91f41-898e-492f-90bf-240533f1c0bb">
    <superclass name="Frame"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="_usergui"/>
    <ImplicitInverseRef name="myFilterTable" id="b752eb91-c9a3-49a4-9306-2c3f496fe4f1">
        <embedded/>
        <type name="CM_FilterTable"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="makePositionAndSizeRelative" id="67ba6bf4-3ff2-4342-8aa2-69fa9c2de3e5">
        <updating/>
        <source>makePositionAndSizeRelative( _colIndex : Integer; _visibleRowCount : Integer ):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 January 2015	cnwndl1	Initial creation

*/

vars

	allSet : Boolean;
	applyBtn : CMUI_Button;
	cancelBtn : CMUI_Button;
	selectBtn : CMUI_Button;
	valuesListTable : CM_FilterTableList;
	msg : String;
	columnLeftPos : Real;
	col : Integer;
	colWidth : Real;
	scrollBarWidth : Real;
	rowIndex : Integer;
	filterText : String;
	captionHeight : Integer;
	maxHeightRequired : Real;

begin

	applyBtn := self.myFilterTable.btnApplyFilterChg;
	cancelBtn := self.myFilterTable.btnCancelFilterChg;
	selectBtn := self.myFilterTable.btnSelectAll;
	valuesListTable := self.myFilterTable.lstFilterProxy;
	scrollBarWidth := 23;
	captionHeight := 30;

	self.caption := self.myFilterTable.accessCell(1,_colIndex).text &amp; CrLf &amp; app.getErrorString(Filtering);
	self.fontBold := true;
	self.alignment := Frame.Alignment_Center_Top;
	self.left := 1; //default left
	self.width := 250; //default width

	//set the relative height and top position based on teh parent table size
	if self.myFilterTable.height &lt; 100 then
		msg := app.getErrorString1(Table_needs_made_bigge_order_h, app.getErrorString(Mode_Height));
		app.msgBox( msg, app.getErrorString(Warning), MsgBox_OK_Only );
		return false;
		
	elseif self.myFilterTable.height &lt;= 200 then
		self.top := 1;
		self.height := self.myFilterTable.height - scrollBarWidth;
	
	elseif self.myFilterTable.height &gt; 200 then
		self.top := self.myFilterTable.tblFilterHeaders.height + 1;
		self.height := self.myFilterTable.height - self.top - scrollBarWidth;
		
	endif;
	
	//if the list of values is shorter than the available height, shrink the frame to suit
	if _visibleRowCount &gt; 0 then
		maxHeightRequired := ( _visibleRowCount * ( valuesListTable.accessRow(1).height + 1 ) ) + captionHeight + applyBtn.height + 3;
		if self.height &gt; maxHeightRequired then
			self.height := maxHeightRequired;
		endif;
	endif;
	
	//set the relative width and left position based on the parent table size (minimum 250 to fit the buttons)
	if self.myFilterTable.width &lt; 270 then
		//too narrow
		msg := app.getErrorString1(Table_needs_made_bigge_order_h, app.getErrorString(Width));
		app.msgBox( msg, app.getErrorString(Warning), MsgBox_OK_Only );
		return false;
		
	else
		// see if we have room to move the filter centrally over the column...
		foreach col in self.myFilterTable.leftColumn to self.myFilterTable.columns do
			if _colIndex = col then
				colWidth := self.myFilterTable.accessColumn(col).width / 2;
			else
				colWidth := self.myFilterTable.accessColumn(col).width;
			endif;
			columnLeftPos := columnLeftPos + colWidth;
			if _colIndex = col then
				break;
			endif;
		endforeach;
		columnLeftPos := columnLeftPos - ( self.width / 2 );
		if columnLeftPos &gt; self.left then
			if ( columnLeftPos + self.width + scrollBarWidth ) &lt; self.myFilterTable.width then
				self.left := columnLeftPos;
			else
				self.left := self.myFilterTable.width - scrollBarWidth - self.width;
			endif;
		endif;
		if self.left &lt; 1 then
			self.left := 1;
		endif;
		
	endif;
	
	//position the button just above the bottom.
	applyBtn.left := 1;
	applyBtn.top := self.height - applyBtn.height - 3;
	
	cancelBtn.left := self.width - cancelBtn.width - 3;
	cancelBtn.top := applyBtn.top;
	
	selectBtn.left := (cancelBtn.left / 2) + 1;
	selectBtn.top := applyBtn.top;
	
	foreach rowIndex in 1 to valuesListTable.rows do
		filterText := valuesListTable.accessCell( rowIndex, 2 ).text;
		if filterText = self.myFilterTable.AllValues then 
			allSet := valuesListTable.accessCell(rowIndex,1).text = TableCheckBox_Selected;
			break;
		endif;
	endforeach;
		
	if allSet then
		selectBtn.caption := app.getErrorString(Deselect_All);
	else
		selectBtn.caption := app.getErrorString(SelectAll);
	endif;
	
	//position the values list table, just below the caption and just above teh buttons.
	valuesListTable.top := captionHeight; // leaving room for the caption displaying the column I'm filtering
	valuesListTable.left := 1;
	valuesListTable.width := self.width - 4;
	valuesListTable.height := applyBtn.top - valuesListTable.top - 1;
	
	return true;

epilog

end;</source>
        <Parameter name="_colIndex" type="Integer"/>
        <Parameter name="_visibleRowCount" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMyFilterTable" id="e773ffcd-87b6-4595-803b-508712a399e8">
        <updating/>
        <source>setMyFilterTable( _ft : CM_FilterTable ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 January 2015	cnwndl1	Initial creation

*/

vars

begin

	self.myFilterTable := _ft;

epilog

end;</source>
        <Parameter name="_ft" type="CM_FilterTable"/>
    </JadeMethod>
