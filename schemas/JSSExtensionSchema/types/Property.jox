<Class name="Property">
    <JadeMethod name="jssIsAttribute" id="5d6df050-cea2-4159-aea5-102875cbcdf9">
        <source>jssIsAttribute():Boolean;
// --------------------------------------------------------------------------------
// Created:		01 November 2001 by cnwdad1
//
// Purpose:		Returns a flag to indicate whether the receiver is an Attribute.
//
// Parameters:	None
//
// Returns:		True if the receiver is an Attribute, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jssIsCollection" id="eb328859-d4f5-4bff-9a1f-df94f4d0a0af">
        <source>jssIsCollection():Boolean;
// --------------------------------------------------------------------------------
// Created:		01 November 2001 by cnwdad1
//
// Purpose:		Returns a flag to indicate whether the receiver is a Collection Type.
//
// Parameters:	None
//
// Returns:		True if the receiver is a Collection Type, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.type.jssIsCollection();
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
