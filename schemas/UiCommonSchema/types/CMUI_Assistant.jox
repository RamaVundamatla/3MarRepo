    <JadeMethod name="comboIntendedReleaseMode" id="a3c5c248-acb0-497d-89cd-8d2c7e248cd2">
        <source>comboIntendedReleaseMode(_cmb : ComboBox input; _intendedRelease : Integer);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 May 2009	cnwmd1	Initial creation

*/

vars
	idx : Integer;
begin
	if _cmb = null then
		return;
	endif;
	_cmb.clear;
	
	idx := _cmb.addItem(app.getErrorString(TI_Intended_Unknown));
	_cmb.itemData[idx] := TI_IntendedReleaseMode_NULL;
	
	idx := _cmb.addItem(app.getErrorString(TI_Intended_Ship));
	_cmb.itemData[idx] := TI_IntendedReleaseMode_SHIP;
	
	idx := _cmb.addItem(app.getErrorString(TI_Intended_Road));
	_cmb.itemData[idx] := TI_IntendedReleaseMode_ROAD;
	
	idx := _cmb.addItem(app.getErrorString(TI_Intended_Rail));
	_cmb.itemData[idx] := TI_IntendedReleaseMode_RAIL;
	
	_cmb.text := app.intendedReleaseModeEnum2String(_intendedRelease);
epilog

end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_intendedRelease" type="Integer"/>
