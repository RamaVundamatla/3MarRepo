    <JadeMethod name="validateMe" id="3cd03962-8496-438c-8f7e-5bfd3b9f038e">
        <source>validateMe();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 02/12/2016	cnwdap1		Initial creation TFS 3039 SNO MT Container Pool Management
//
vars
	partner : CM_MTPoolingPartner;
	percentage : Decimal [5,2];

begin
	// if I have any pooling partnes, theeir percentage of charges must add up to 100
	if self.allPoolingPartners.size &gt; 0 then
		foreach partner in self.allPoolingPartners do
			partner.validateMe();
			percentage := percentage + partner.percentageOfCharges;
		endforeach;
		
		if percentage &lt;&gt; 100.00 then
			app.raiseCMException1(Percent_Charges_Pool_Party, self.code, null, null);
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
</Class>
