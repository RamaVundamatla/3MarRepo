    <JadeMethod name="copyCollectionToDynaDict" id="5e56ce50-b46f-4506-88fd-139c661dc376">
        <updating/>
        <source>copyCollectionToDynaDict() updating; 
//--------------------------------------------------------------
//Created: June 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	
begin

	if self.optNoNumber.value then
		self.getLocationsForNNData();
	elseif self.optLoadOutLocn.value then
		if self.optLocnDockets.value then
			self.getBOLsForDict();
		elseif self.optLocnDtlsLocn.value then 
			self.getTIsForArray(); // Par9691 // new one to sort by specs. 
		else
			self.getTIsForDict();
		endif;
	else
		//Must be by Item - leave for now.		
	endif;

end;</source>
