    <JadeWebServicesMethod name="getTerminalAreaAudits" id="c0b26a62-ab6c-46f9-8a28-6d1a07fe7a3a">
        <source>getTerminalAreaAudits(_auditRequest : WS_TAAuditRequest) : WS_TAAuditResponse webService;
/*
Purpose:			
Date		Who		Reason
29 December 2015	cnwab1	Initial creation
*/

vars
	response			: WS_TAAuditResponse;	
	terminal : CM_Terminal;
	cmTAType			: CM_TerminalAreaType;
	tAType				: WS_TerminalAreaType;
	completedOK		: Boolean;
	termArea : CM_TerminalArea;
	iter2 : Iterator;
	audit				: CM_AuditObject;
	wsAudit : WS_TAAudit;
	
	st, ed : TimeStamp;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	terminal := app.myPassport.myTerminal;
	
	
	termArea := terminal.allTerminalAreas[_auditRequest.terminaAreaId];
	
	if termArea = null then
		completedOK := true;
		return response;
	
	endif;
	
	
	st := _auditRequest.startString.asTimeStampFromWebInterface();
	ed := _auditRequest.endString.asTimeStampFromWebInterface();
	
	
	
	iter2 := termArea.allAuditObjectsForClass.createIterator;	//21 Jan 2021	NDL	TFS 50152
	termArea.allAuditObjectsForClass.startKeyGeq (st, iter2);	//21 Jan 2021	NDL	TFS 50152

	
	
	while iter2.next (audit) do
		if ed.isValid and audit.timestamp &gt; ed then
			break;
		endif;
		
		if not audit.isKindOf (CM_AuditTALocations) then
			continue;
		endif;
		
		create wsAudit;
		wsAudit.setProxyFromObject(audit.CM_AuditTALocations);
		response.allAudits.add (wsAudit);
	endwhile;

	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	
	delete iter2;

	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;end;</source>
        <Parameter name="_auditRequest" type="WS_TAAuditRequest"/>
        <ReturnType type="WS_TAAuditResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getTerminalAreaTypes" id="03407508-2fb3-4d64-ae50-53692c1bbb2d">
        <usesRPC>default</usesRPC>
        <source>getTerminalAreaTypes() : WS_TATypeResponse webService;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 September 2008	cnwkao1	Initial creation

*/
vars
	response			: WS_TATypeResponse;	
	cmTAType			: CM_TerminalAreaType;
	tAType				: WS_TerminalAreaType;
	completedOK		: Boolean;
	terminal			: CM_Terminal;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	terminal := app.myPassport.myTerminal;
	
	foreach cmTAType in app.myRoot.allTerminalAreaTypes discreteLock do	
		
		if cmTAType.getIsNotAvailableForEntry then
			continue;
		endif;
		
		if cmTAType.isGantryLaneAreaType then
			continue;
		endif;
		
		if  cmTAType.type = TA_TYPE_BUILDING then
			continue;
		endif;
		
		create tAType transient;
		tAType.setProxyFromObject(cmTAType);
		response.allTATypes.add(tAType);	
	endforeach;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <wsdlName>getTerminalAreaTypes</wsdlName>
        <ReturnType type="WS_TATypeResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getTerminalAreasForTAType" id="a8ce34bc-f666-463c-9747-af3b443012cf">
        <usesRPC>default</usesRPC>
        <source>getTerminalAreasForTAType(taTypeId : String) : WS_TerminalAreaMasterResponse webService;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 September 2008	cnwkao1	Initial creation

*/

vars
	response			: WS_TerminalAreaMasterResponse;	
	cmTAType			: CM_TerminalAreaType;
	cmTAMaster			: CM_TerminalAreaMaster;
	tAType				: WS_TerminalAreaType;
	taMaster			: WS_TerminalAreaMaster;
	iter				: Iterator;
	terminal			: CM_Terminal;
	obj					: Object;
	completedOK			: Boolean;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
		
	// Create the response
	create response transient;
	
	terminal := app.myPassport.myTerminal;
	//epr TFS 5535 10/8/17 
	cmTAType := app.myPassport.getObjectOfTypeFromOid(taTypeId,CM_TerminalAreaType).CM_TerminalAreaType;
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;
	if cmTAType = null and taTypeId  &lt;&gt; null then		// CNWAB12015NOV
		cmTAType :=  app.myRoot.allTerminalAreaTypes.getAtKey(taTypeId.Integer);	// CNWAB12015NOV
	endif;
	
	if cmTAType &lt;&gt; null then		//cnwmc5 - 18 Oct 2013 - PAR 32818
		
		iter := cmTAType.allTerminalAreasByTerminal.createIterator();
		cmTAType.allTerminalAreasByTerminal.startKeyGeq(terminal, null, iter); //second key is a string ascending
		while iter.next(cmTAMaster) do : terminalAreaLoop
			if cmTAMaster.myTerminal &lt;&gt; terminal then
				break terminalAreaLoop;
			endif;
			
			create taMaster transient;
			taMaster.setProxyFromObject(cmTAMaster);
			response.allTAMasters.add(taMaster);		
		endwhile;
	else

		//cnwmc5 - 18 Oct 2013 - PAR 32818
		foreach cmTAMaster in terminal.allTerminalAreasByTypeId do
			if not cmTAMaster.isKindOf(CM_TerminalArea) then
				continue;
			endif;
			if cmTAMaster.CM_TerminalArea.isSwapStack then
				continue;
			endif;
			if cmTAMaster.CM_TerminalArea.isInterchangeArea then
				continue;
			endif;
			if cmTAMaster.CM_TerminalArea.type = TA_TYPE_LOGAREA or
				cmTAMaster.CM_TerminalArea.type = TA_TYPE_DELETE then
				continue;
			endif;
			create taMaster transient;
			taMaster.setProxyFromObject(cmTAMaster);
			response.allTAMasters.add(taMaster);	
		endforeach;
	endif;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	// Tidy up any local transients
	delete iter;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <wsdlName>getTerminalAreasForTAType</wsdlName>
        <Parameter name="taTypeId" type="String"/>
        <ReturnType type="WS_TerminalAreaMasterResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getTerminalAreasForTATypeOID" id="20196369-0680-4fa7-9e59-f28fda6687e1">
        <source>getTerminalAreasForTATypeOID(taTypeOID : String) : WS_TerminalAreaMasterResponse webService;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 May 2016	cnwmc5	Initial creation	TFS 2005 - need a web service method that returns all TAs if input null (or 0...)

*/

vars
	response			: WS_TerminalAreaMasterResponse;	
	cmTAType			: CM_TerminalAreaType;
	cmTAMaster			: CM_TerminalAreaMaster;
	tAType				: WS_TerminalAreaType;
	taMaster			: WS_TerminalAreaMaster;
	iter				: Iterator;
	terminal			: CM_Terminal;
	obj					: Object;
	completedOK			: Boolean;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
		
	// Create the response
	create response transient;
	
	terminal := app.myPassport.myTerminal;
	//epr TFS 5535 4/8/17 
	cmTAType := app.myPassport.getObjectOfTypeFromOid(taTypeOID,CM_TerminalAreaType).CM_TerminalAreaType;
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;
	
	if cmTAType &lt;&gt; null  then	
		iter := cmTAType.allTerminalAreasByTerminal.createIterator();
		cmTAType.allTerminalAreasByTerminal.startKeyGeq(terminal, null, iter); //second key is a string ascending
		while iter.next(cmTAMaster) do : terminalAreaLoop
			if cmTAMaster.myTerminal &lt;&gt; terminal then
				break terminalAreaLoop;
			endif;
			
			create taMaster transient;
			taMaster.setProxyFromObject(cmTAMaster);
			response.allTAMasters.add(taMaster);		
		endwhile;
	else
		foreach cmTAMaster in terminal.allTerminalAreasByTypeId do
			create taMaster transient;
			taMaster.setProxyFromObject(cmTAMaster);
			response.allTAMasters.add(taMaster);	
		endforeach;
	endif;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	
epilog
	// Tidy up any local transients
	delete iter;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="taTypeOID" type="String"/>
        <ReturnType type="WS_TerminalAreaMasterResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getTerminalConfig" id="7c17fd8a-3bba-4a4a-97af-3119c16307ce">
        <source>getTerminalConfig() : WS_TerminalConfigResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 September 2016	cnwrh7	Initial creation
17 August 2017 cnwhl1 updating response to include all authorities &amp; names

*/

vars
	response					: WS_TerminalConfigResponse;
	terminalConfigProxy		 	: WS_TerminalConfig;
	completedOK					: Boolean;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Check security access to this message, if required
	//app.checkCurrentUserHasAccess(99999);		// Replace with appropriate permission
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	if app.myPassport.myTerminal &lt;&gt; null then
		//create response.terminalConfig transient;
		create terminalConfigProxy transient;
		terminalConfigProxy.setProxyFromObject(app.myPassport.myTerminal);
		response.terminalConfig := terminalConfigProxy;
	endif;

	completedOK := true;
	return response;
	

epilog
	// Tidy up any local transients
	// ...
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
