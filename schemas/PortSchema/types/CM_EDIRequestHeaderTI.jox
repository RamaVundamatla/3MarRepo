    <JadeMethod name="assignValueSpecial" id="a5b1a368-240d-499b-aad3-ec8dff6358c2">
        <updating/>
        <source>assignValueSpecial(_propName: String; _processedValue: String; _xlationOperator: CM_Operator): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 February 2017	cnwndl1	Initial creation	TFS 3386
// 12 Dec 2017	jlgrs1	TFS 8195 - SNO - EDI Release Comparison add support for ReleaseRequestMulti
29 Jan 2024	jlirs1	TFS 59172 User Defined CallOff
*/

vars

begin

	if _propName = ETRow_ExpiryDate then
		if  _processedValue.Date.isValid then
			self.expiryTimeStamp.setDate( _processedValue.Date );
		endif;
		return true;
	elseif _propName = ETRow_ExpiryTime then
		if  _processedValue.Time.isValid then
			self.expiryTimeStamp.setTime( _processedValue.Time );
		endif;
		return true;
	elseif _propName = ETRow_CanBeHiLoCube then
		if _processedValue &lt;&gt; null then
			setCanBeHiLoCubeSet(true);
		endif;
	elseif _propName = ETRow_ReleaseRequestNumber then	//29 Jan 2024	jlirs1	TFS 59172 User Defined CallOff
		if self.myEDIData.isKindOf(CM_EDIDataRequestMultiLine) and
		   self.myEDIData.CM_EDIDataRequestMultiLine.myEDIDataCallOff &lt;&gt; null then
			self.releaseRequestNumber := self.myEDIData.CM_EDIDataRequestMultiLine.myEDIDataCallOff.manifestNumber;
			return true;
		endif;
	endif;

	return inheritMethod(_propName, _processedValue, _xlationOperator);

epilog

end;</source>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_processedValue" type="String"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canUserSet" id="3f896680-b10e-473e-afb1-51ee254da83f">
        <source>canUserSet(_propName: String): Boolean;
//
// 15 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
//
vars

begin
	if _propName = CM_EDITrackedItem::subTerminalCode.name then	// Booking Item/Release Request is allowed to use this field
		return true;
	else
		return inheritMethod(_propName);
	endif;
end;
</source>
        <Parameter name="_propName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCanBeHiLoCubeSet" id="4a50b3ff-bca0-4cd0-9b91-d36d5f48a8fd">
        <source>getCanBeHiLoCubeSet() : Boolean;
//
// 12 Dec 2017	jlgrs1	TFS 8195 - SNO - EDI Release Comparison add support for ReleaseRequestMulti
//
vars
	value : String;
begin
	global.getExtraData(self.allExtraData, "canBeHiLoCubeSet", value);
	return value.Boolean;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="c347ed36-cb1b-4a0a-abdc-010bf8461092">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 February 2017	cnwndl1	Initial creation

*/

vars

begin

	if _attrName = ETRow_ExpiryDate then
		if self.expiryTimeStamp.isValid then
			return self.expiryTimeStamp.date.asStringJMT;
		endif;
		return null;
		
	elseif _attrName = ETRow_ExpiryTime then
		if self.expiryTimeStamp.isValid then
			return self.expiryTimeStamp.time.asStringJMT;
		endif;
		return null;
		
	else
		return inheritMethod(_attrName, _short);
		
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
