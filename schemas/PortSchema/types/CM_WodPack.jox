    <JadeMethod name="getExtraInfo" id="b9fe0569-24a7-49a3-8a68-1c624e9acf2d">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Sep 2021 navma1  ChangeRequest 51002: MTN - Web Portal Cargo Work Orders
29 Aug 2022 navma1	Bug 54682: MTN - Work Orders - Consignee/Consignor dropdown shows the list that are marked as Is Fright Forwarder
30 Aug 2022 namva1	Bug 54696: MTN - Work Orders - Double clicking on the Packing Cargo on the Extra Info table is taking to Parent cargo
15 Mar 2023 navma1	ChangeRequest 55442:[54989] EUP - Pack Cargo Work Order - Enhancement
*/

vars
	addStr   	: String;	
	ti 		 	: CM_TrackedItem;
	block    	: CM_DataContainerBlock;
	invalid  	: Boolean;
	consignee,
	consignor	: CM_ConsigneeConsignor;
	bulkRelease : CM_BulkRelease;
begin
	on Exception do app.handleDeletedObject(exception, ti, invalid);
	
	inheritMethod(_dataContainer);
	
	foreach ti in self.allPackingTIs do
		
		ti.edition();
		if invalid then
			invalid := false;
			continue;
		endif;
			
		if addStr= "" then
			addStr := ti.id;
		else
			addStr := addStr &amp; ", " &amp; ti.id;
		endif;
	endforeach;
	
	if addStr &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(PackingCargo), DC_Label, 1, self);     //30.08.2022 navma1 #54696
		block.addNewItem(addStr, DC_Data, 1, self);                                //30.08.2022 navma1 #54696
	endif;	
	
	//29.08.2022 navma1 #54682
	consignee := self.myConsignee;
	if consignee &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Consignee), DC_Label, 1, consignee);
		block.addNewItem(consignee.code &amp; " - "&amp; consignee.description, DC_Data, 1, consignee);
	endif;
	
	//29.08.2022 navma1 #54682
	consignor := self.myConsignor;
	if consignor &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem("Consignor", DC_Label, 1, consignor);
		block.addNewItem(consignor.code &amp; " - "&amp; consignor.description, DC_Data, 1, consignor);
	endif;
	
	bulkRelease := self.getBulkReleaseFromTask();							//15.03.2023 navma1 #55442:[54989]
	if bulkRelease &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem("Release Request", DC_Label, 1, bulkRelease);
		block.addNewItem(bulkRelease.code, DC_Data, 1, bulkRelease);
	endif;
epilog

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getInstructionsForContext" id="44ba443c-293b-4c7e-a3e0-aace704d3c74">
        <source>getInstructionsForContext(_instructions: CM_InstructionsIssuedSet io; _passingObject: Object; _context: String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Sep 2023	navma1 ChangeRequest 60066: FR 53127 | EUP - Additional Operational Instructions on the Order (Web)
11 Oct 2023	navnk30	ChangeRequest 59946: EUP - Additional Operational Instructions on the Order - Enhancement 2
06 Mar 2025	navah1	Bug 34283: EUP | Additional Operational Instructions - further issues
*/

vars
	
begin
	inheritMethod(_instructions, _passingObject, _context);
	
	if self.myBookingRef &lt;&gt; null then
		self.myBookingRef.getInstructionsForContext(_instructions,_passingObject,_context);			//11.10.2023 navnk30 #59946
	endif;

	if self.myReleaseRequest &lt;&gt; null then
		if _context = null then																		  //06.03.2025 navah1 #34283
			self.myReleaseRequest.getInstructionsForContext(_instructions,_passingObject,Pack_Cargo); //06.03.2025 navah1 #34283
		else
			self.myReleaseRequest.getInstructionsForContext(_instructions,_passingObject,_context);   //11.10.2023 navnk30 #59946 
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_instructions" type="CM_InstructionsIssuedSet" usage="io"/>
        <Parameter name="_passingObject" type="Object"/>
        <Parameter name="_context" type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyReleaseRequest" id="7802964c-cef9-4383-8388-0d1457149c58">
        <source>getMyReleaseRequest(): CM_BulkRelease;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/11/2024	navkc1 JIRA Story MTN-19092: EUP | 54014 - Work Orders Enhancements - Improved Search and usability

*/

vars

	invalid : Boolean;
	edition : Integer;
	relReq : CM_BulkRelease;

begin

	on Exception do app.handleDeletedObject( exception, relReq, invalid );

	relReq := self.myReleaseRequest;	
	if relReq &lt;&gt; null then
		edition := relReq.edition;
		if not invalid then
			return relReq;
		endif;
	endif;
		
	return null;

epilog

end;</source>
        <ReturnType type="CM_BulkRelease"/>
    </JadeMethod>
    <JadeMethod name="getMyReserveDetail" id="cc979c66-41f1-4430-ac85-5bd2a3687d1a">
