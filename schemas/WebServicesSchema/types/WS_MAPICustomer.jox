    <JadeMethod name="setDetailsOnCMIF" id="6fc363d6-a438-4881-b27b-0edf532d51a1">
        <source>setDetailsOnCMIF(_cmifDebtor : CMIF_DebtorNode input);
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
02 August 2022	navlw1	Initial creation TFS 53854 Task 54249
04 August 2022	jlizm1	TFS 54039 EUP Extra Fields For Customer Data Interface
08 Sept 2022	navdap1	TFS 54654 MTN Field data not being added to MTN
27 April 2023	navra1	TFS 57086 EUP - Customer Update - New Fields incl Debtor Details incl Financial ID
20 June 2023	navmd1	TFS 57447 API Reivew fixes and refactor
28 August 2023	navmd1	TFS 60060 Remove redundent 'if' check for addresses and terminalSpecificConfiguration collections
*/

vars
	tt : CM_InvoiceTermsOfTrade;	// TFS 54654
	cmifAddress : CMIF_Address;																							//navra1 - TFS 57086 - 28th Apr 2023
	wsAddress : WS_RestAddressObject;																					//navra1 - TFS 57086 - 28th Apr 2023
	cmifDebtorTermDetail : CMIF_DebtorTerminalDetail;																	//navra1 - TFS 57086 - 28th Apr 2023	
	wsTerminalSpecConf : WS_RestTermSpecConfObject;																		//navra1 - TFS 57086 - 28th Apr 2023	
	terminalDict : CM_TerminalByCodeDict;																				//navra1 - TFS 57086 - 28th Apr 2023
	currencyTypeDict  : CM_CurrencyTypesByCodeDict;																		//navra1 - TFS 57086 - 28th Apr 2023
	localeDict : CM_LocalesByLocaleNameDict;																			//navra1 - TFS 57086 - 28th Apr 2023
	term : CM_Terminal;																									//navra1 - TFS 57086 - 28th Apr 2023
	nextAddressID : Integer;																							//navra1 - TFS 57086 - 28th Apr 2023	
	country : CM_Country;
	countryStr : String;
	root : CM_Root;
	currencyType : CM_CurrencyType;
	locale : CM_Locale;
begin
	root := app.myRoot;
	
	_cmifDebtor.longName := self.description;
	_cmifDebtor.code := self.id;
	_cmifDebtor.name := self.name;
	_cmifDebtor.additionalInformation1 := self.additionalInfo1;
	_cmifDebtor.additionalInformation2 := self.additionalInfo2;		// TFS 54654
	_cmifDebtor.decfinName := self.accountCode;						// TFS 54654
	_cmifDebtor.badDebtor := self.badCredit;	// TFS 54039
	_cmifDebtor.isSuspended := self.suspended;	// TFS 54039
	
	// TFS 54654 - Terms of Trade
	_cmifDebtor.myTermsOfTrade := null;
	if self.termsOfTradeId &lt;&gt; null then
		tt := _cmifDebtor.myBank.allInvoiceTermsOfTrade[self.termsOfTradeId];
		if tt &lt;&gt; null then
			_cmifDebtor.myTermsOfTrade := tt;
		endif;		
	endif;
	// TFS 54654 end
	
	//clear out any addresses that already exist, the update message should have what needs to be updated
	_cmifDebtor.addresses.clear();	// MPD - addresses aren't populated on the CMIF ... so why are we doing this ?
	_cmifDebtor.billingAddress := null;
	nextAddressID := 1;
	
	// If we have a Default address, handle it first, as we need it to be the first auto-generated id (eg, 1) if an id is not specified
	foreach wsAddress in self.addresses where wsAddress.type = WS_RestAddressObject.DEFAULT do
		break; //nothing
	endforeach;
	if wsAddress &lt;&gt; null then
		self.addresses.remove(wsAddress);
		self.addresses.insert(1, wsAddress);
	endif;

	foreach wsAddress in self.addresses do
		
		countryStr := null;
		country := CM_Country@lookupCountryByCode(wsAddress.isoCountryCode);
		if country &lt;&gt; null then
			countryStr := country.description;
		endif;
		
		if wsAddress.type = WS_RestAddressObject.BILLING then
			_cmifDebtor.setBillingAddress(wsAddress.line1, wsAddress.line2, wsAddress.line3, wsAddress.city,
											wsAddress.region, wsAddress.postCode, countryStr, wsAddress.email);
			continue;
			
		elseif wsAddress.type = WS_RestAddressObject.DEFAULT then						
			create cmifAddress transient;
			cmifAddress.isDefault := true;
			
		elseif wsAddress.type = WS_RestAddressObject.ALTERNATE then
			create cmifAddress transient;
			cmifAddress.isAlternative := true;
			
		elseif wsAddress.type = WS_RestAddressObject.OTHER then
			create cmifAddress transient;
			
		else	//ignore anything else
			continue;
		endif;		
		
		// Code is optional. If its not specified then we use the first number from 1 thats not already used
		if wsAddress.id = null then
			cmifAddress.code := nextAddressID.String;
			nextAddressID += 1;
		else
			cmifAddress.code := wsAddress.id;
			if wsAddress.id = nextAddressID.String then
				nextAddressID += 1;
			endif;
		endif;
		
		cmifAddress.addr1 := wsAddress.line1;
		cmifAddress.addr2 := wsAddress.line2;
		cmifAddress.addr3 := wsAddress.line3;			
		cmifAddress.city := wsAddress.city;
		cmifAddress.region := wsAddress.region;
		cmifAddress.postCode := wsAddress.postCode;
		cmifAddress.isoCountryCode := wsAddress.isoCountryCode;
		cmifAddress.email := wsAddress.email;		
		cmifAddress.description:= wsAddress.description;	
		
		_cmifDebtor.addresses.add(cmifAddress);
		cmifAddress := null;
	endforeach;
	
	// Due to CM_Address::setForUpdate (via setForCreate) forcing the first address to be the Default one, lets re-arrange the array
	if _cmifDebtor.addresses.size &gt; 0 and not _cmifDebtor.addresses.first.isDefault then
		// Find the Default one
		foreach cmifAddress in _cmifDebtor.addresses where cmifAddress.isDefault do
			break;	// do nothing
		endforeach;
		if cmifAddress &lt;&gt; null then
			_cmifDebtor.addresses.remove(cmifAddress);
			_cmifDebtor.addresses.insert(1, cmifAddress);
		endif;
		cmifAddress := null;
	endif;

	//navra1 - TFS 57086 - 28th Apr 2023 - start
	_cmifDebtor.taxCountry := null;
	_cmifDebtor.taxNumber := null;
	
	if self.tax &lt;&gt; null then
		if self.tax.countryId &lt;&gt; null then
			country := CM_Country@lookupCountryByCode(self.tax.countryId);
			_cmifDebtor.taxCountry := country;
		endif;
		_cmifDebtor.taxNumber := self.tax.number;
	endif;
	
	foreach cmifDebtorTermDetail in _cmifDebtor.allDebtorTerminalDetails do
		cmifDebtorTermDetail.reset();
	endforeach;
	
	terminalDict := root.allTerminals;
	currencyTypeDict := root.allCurrencyTypes;
	localeDict := root.allLocales;

	foreach wsTerminalSpecConf in self.terminalSpecificConfiguration do			
		if wsTerminalSpecConf.id = WS_RestTermSpecConfObject.USE_CURRENT_TERMINAL then
			// Use the Terminal specified on the Bearer token / during POST /Login
			term := app.myPassport.myTerminal;
		else
			term := terminalDict[wsTerminalSpecConf.id];
		endif;
		
		if term = null then
			app.raiseCMException1(Err_InvalidTerminal, wsTerminalSpecConf.id, null, null);
			continue;
		endif;
		
		cmifDebtorTermDetail := _cmifDebtor.allDebtorTerminalDetails[term];
		if cmifDebtorTermDetail = null then
			create cmifDebtorTermDetail transient;
			cmifDebtorTermDetail.setMyTerminal(term);
			_cmifDebtor.allDebtorTerminalDetails.add(cmifDebtorTermDetail);
		endif;
		
		cmifDebtorTermDetail.setOrgCode(wsTerminalSpecConf.organisationCode);
		cmifDebtorTermDetail.setInterTerminalCode(wsTerminalSpecConf.intercompanyCode);			
		cmifDebtorTermDetail.setCashOnly(wsTerminalSpecConf.cashOnly);
		
		if wsTerminalSpecConf.currencyId &lt;&gt; null then
			currencyType := currencyTypeDict[wsTerminalSpecConf.currencyId];
			if currencyType = null then
				app.writeLog(method.qualifiedName &amp; " Currency Type '"&amp;wsTerminalSpecConf.currencyId&amp;"' not found", LogWARN);
				app.raiseCMWarning1(Currenc_type_not_found, wsTerminalSpecConf.currencyId, null, null, null);
			else
				cmifDebtorTermDetail.setMyCurrencyType(currencyType);
			endif;
		endif;
		
		if wsTerminalSpecConf.localeId &lt;&gt; null then
			locale := localeDict[wsTerminalSpecConf.localeId];
			if locale = null then
				app.writeLog(method.qualifiedName &amp; " Locale '"&amp;wsTerminalSpecConf.localeId&amp;"' not found", LogWARN);
				app.raiseCMWarning(Unknown_locale, null, null, null);
			else
				cmifDebtorTermDetail.setMyLocale(locale);
			endif;
		endif;
		
		cmifDebtorTermDetail.setPaymentTypeFromDescription(wsTerminalSpecConf.paymentType);	
		cmifDebtorTermDetail.setDefaultInvoiceJRW(wsTerminalSpecConf.invoiceReportName);
	endforeach;
	//navra1 - TFS 57086 - 28th Apr 2023 - end	
	
epilog
	// If anything goes wrong, clean up any transients that might not be added to the CMIF yet
	delete cmifAddress;
end;</source>
        <Parameter name="_cmifDebtor" type="CMIF_DebtorNode" usage="input"/>
    </JadeMethod>
</Class>
