    <JadeMethod name="isCMIFDataMatch" id="b98ea226-8961-48b1-a519-5e29a08425bf">
        <source>isCMIFDataMatch(_cmifAutoPlan: CMIF_YAAutoPlan; _yaData: CM_YADataString): Boolean;
//09 December 2009	cnwml2


vars

begin
	return _yaData.value = null or _cmifAutoPlan.isTotWeight_Match(_yaData);

epilog

end;</source>
