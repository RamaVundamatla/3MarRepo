    <JadeMethod name="doBtnLocateClick" id="aca3d5b9-668e-47f1-9c5b-dcb6c146480e">
        <updating/>
        <source>doBtnLocateClick(_theTable : CM_DataTable) updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	
/*	theTerminalArea 		: CM_GridArea;
	theArea 				: CM_TerminalArea;
	menuAction 				: CMUI_MenuAction;
	theObject 				: Object;
	theTI 					: CM_TrackedItem;
	theLC 					: CM_LocationsController;
	aForm 					: Form;
	theTA 					: CM_TerminalArea;
*/	
begin
//	self.mousePointer := Window.MousePointer_HourGlass;
	
	inheritMethod(self.tblData);
	
	/*
	if self.tblData.row &lt;= self.tblData.fixedRows then
		return;
	endif;
	
	theObject := self.tblData.accessRow(self.tblData.row).itemObject;
	
	if theObject &lt;&gt; null then
		if theObject.isKindOf(CM_TrackedItem) then
			theTI := theObject.CM_TrackedItem;
		elseif theObject.isKindOf(CM_WorkListEntry) then
			theTI := theObject.CM_WorkListEntry.myTrackedItem;
		else
			return;
		endif;

		if theTI = null then
			return;
		endif;

		theLC := theTI.getPrimaryLocation(REAL_MODE);
		if theLC = null then
			return;
		endif;
		
		theTA := theLC.myTerminalArea;
		
		if theTA = null then
			return;
		endif;
		if theTA.isKindOf(CM_GridArea) then
			theTerminalArea := theTA.CM_GridArea;
			menuAction := app.myController.createMenuAction(PmYardAreaView, null, self.myMasterMenuAction, self.myTerminal);
			if menuAction = null then
				return;
			endif;
			aForm := menuAction.goToObject(null, null, false, null); 
			if aForm = null then
				return;
			endif;
			aForm.sendMsgWithParams("doInitializeWithTI",theTerminalArea, theLC, theTI);
			aForm.show;	
		elseif theTA.isKindOf(CM_Rail) then
		elseif theTA.isKindOf(CM_Pack) then
		
			menuAction := app.myController.createMenuAction(PmAdmLclpackView, null, self.myMasterMenuAction, self.myTerminal);
			if menuAction = null then
				return;
			endif;
			aForm := menuAction.goToObject(null, null, false, null); 
			if aForm = null then
				return;
			endif;
			aForm.show;	
		elseif theTA.isKindOf(CM_Building) then
		else			
			theArea := theTA;
			menuAction := app.myController.createMenuAction(PmYardLocationEnqView, null, self.myMasterMenuAction, self.myTerminal);
			if menuAction = null then
				return;
			endif;
			aForm := menuAction.goToObject(null, null, false, null); 
			if aForm = null then
				return;
			endif;
			aForm.sendMsgWithParams("doInitializeWithObject",theArea);
			aForm.show;	


		endif;
	endif;
*/
epilog
	//self.mousePointer := Window.MousePointer_Default;
	
end;</source>
        <Parameter name="_theTable" type="CM_DataTable"/>
    </JadeMethod>
    <JadeMethod name="doBtnMoveDownClick" id="72a1f2e1-ab04-4596-98a0-a7c2860b4d33">
        <updating/>
        <source>doBtnMoveDownClick() updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	voyageWLE1, voyageWLE2 : CM_VoyageWLE;
	obj1, obj2 : Object;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin
	self.mousePointer := Window.MousePointer_HourGlass;

	if self.tblData.row = self.tblData.rows then
		return;
	endif;
	
	obj1 := self.tblData.accessRow(self.tblData.row).itemObject;
	obj2 := self.tblData.accessRow(self.tblData.row + 1).itemObject;

	if CM_VoyageWLE.hasInstance(obj1) then
		voyageWLE1 := obj1.CM_VoyageWLE;
	endif;

	if CM_VoyageWLE.hasInstance(obj2) then
		voyageWLE2 := obj2.CM_VoyageWLE;
	endif;	
	
	if voyageWLE1 = null or voyageWLE2 = null then
		return;
	endif;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateVoyageWLESwapSequence(voyageWLE1, voyageWLE2, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Sequence Sheet', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return;
		
	endwhile;

epilog
	self.mousePointer := Window.MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnMoveUpClick" id="7e21c20d-999f-4b69-be23-e7d2cb0162c7">
        <updating/>
        <source>doBtnMoveUpClick() updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	voyageWLE1, voyageWLE2 : CM_VoyageWLE;
	obj1, obj2 : Object;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin
	self.mousePointer := Window.MousePointer_HourGlass;

	if self.tblData.row &lt;= self.tblData.fixedRows + 1 then
		return;
	endif;
	
	obj1 := self.tblData.accessRow(self.tblData.row).itemObject;
	obj2 := self.tblData.accessRow(self.tblData.row - 1).itemObject;

	if CM_VoyageWLE.hasInstance(obj1) then
		voyageWLE1 := obj1.CM_VoyageWLE;
	endif;

	if CM_VoyageWLE.hasInstance(obj2) then
		voyageWLE2 := obj2.CM_VoyageWLE;
	endif;	
	
	if voyageWLE1 = null or voyageWLE2 = null then
		return;
	endif;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateVoyageWLESwapSequence(voyageWLE1, voyageWLE2, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Sequence Sheet', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return;
		
	endwhile;

epilog
	self.mousePointer := Window.MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildBaysFast" id="086508e1-b4fd-424a-8602-07200c7c8421">
        <updating/>
        <source>doBuildBaysFast(_voyageJob : CM_VoyageJob; _displayMode : Integer; _seqReporter : CMIF_JobSequenceReporter input) updating, protected;
// ---------------------------------------------------------------------------
// Created:		June 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	displayModeOne, displayModeTwo : Integer;
	bayOne,	bayTwo: CM_Bay;
	tmpBayController : SHP_BayDrawingController;
	theHolds : CM_HoldByOrdinalDict;
	onDeck : Boolean;
	frWidth, frHeight, ordinalDeck : Integer;
	isSidePort	: Boolean;
	tmpVoyage	: CM_Voyage;
	
begin

	_voyageJob.getBays(bayOne, bayTwo);
	if bayOne = null then
		return;
	endif;
	
	tmpVoyage := _voyageJob.myVoyage;

	_seqReporter.baysDescription := bayOne.id;

	if _voyageJob.isSOBOnly() then
		// this is SOB so if only displaying 1 bay show the planned locations, i.e. the load colour coding.
		//			else if showing 2 bays show from and to
		if bayTwo &lt;&gt; null then // PAR 7634 added
			displayModeOne := ShpDisplayMode_ColCodeDisch;
			displayModeTwo := ShpDisplayMode_ColCodeLoad;
		else
			displayModeOne := ShpDisplayMode_ColCodeLoad; // PAR 7634 added
			displayModeTwo := ShpDisplayMode_ColCodeLoad; // PAR 7634 added
		endif;
	else
		displayModeOne := _displayMode;
		displayModeTwo := _displayMode;
	endif;

	if bayTwo &lt;&gt; null then
		_seqReporter.baysDescription := _seqReporter.baysDescription &amp; '/' &amp; bayTwo.id &amp; ' (' &amp; bayOne.idBay40 &amp; ')';
	endif;
	
	if _voyageJob.ordinalDeck = DeckOnDeck then
		_seqReporter.baysDescription := _seqReporter.baysDescription &amp; ' On Deck';
	else
		_seqReporter.baysDescription := _seqReporter.baysDescription &amp; ' Under Deck';
	endif;

	create theHolds transient;
	theHolds.add(bayOne.myHold);
	if bayTwo &lt;&gt; null then
		if bayOne.myHold &lt;&gt; bayTwo.myHold then
			theHolds.add(bayTwo.myHold);
		endif;
	endif;
	
	tmpBayController := self.myBayDrawingController;
	
	tmpBayController.init(tmpVoyage, theHolds, self.myTerminal);
	tmpBayController.setDisplayMode(displayModeOne);
	tmpBayController.setJobSeqSheet(_voyageJob);
	tmpBayController.setFromVoyage(_voyageJob.myVoyage); //### &lt;&lt;&lt;&lt;&lt;&lt; added SATURDAY 14th AUGUST 4:43 PM 2004 by AKB
	self.frmBayFast1.myJobSeqSheet := _voyageJob;
	self.frmBayFast2.myJobSeqSheet := _voyageJob;
	tmpBayController.showNoColours := true;
	tmpBayController.setAmPrinting(true, CMUI_GridDrawingController.PrintOutput_Medium, false);
	tmpBayController.setScale(CMUI_GridDrawingController.PrintOutput_Medium, true, true);

	// PAR-8919
	isSidePort := self.cmbSide.itemData[self.cmbSide.listIndex].Integer.Boolean;
	tmpBayController.setIsStarboardBerthed(not isSidePort);
	tmpBayController.isTwinLiftSequenceView := _voyageJob.isTwinLift;

	onDeck := _voyageJob.ordinalDeck = DeckOnDeck;

	tmpBayController.drawSelfSeqSheet(true,self.frmBayFast1,bayOne,onDeck); 
	if bayTwo &lt;&gt; null then
		tmpBayController.setDisplayMode(displayModeTwo);
		
		ordinalDeck := _voyageJob.getBaysSecondOrdinalDeck(bayTwo.CM_BayVoyage); // PAR 8729
		if ordinalDeck &lt;&gt; -1 then // if its -1 then use teh same ordinal deck as bay 1
			onDeck := ordinalDeck = DeckOnDeck;
		endif;
		
		tmpBayController.drawSelfSeqSheet(true,self.frmBayFast2,bayTwo,onDeck); 
		frWidth := (self.frmBayFast1.width + self.frmBayFast2.width).Integer;
		frHeight := self.frmBayFast1.height.Integer;
		frHeight := frHeight.max(self.frmBayFast2.height.Integer);
		self.frmBayFast2.visible := true;
	else
		frWidth := self.frmBayFast1.width.Integer ;
		frHeight := self.frmBayFast1.height.Integer;
	endif;
	self.frmBayFast1.visible := true;
	self.frmBayFast1.left := 1;
	self.frmBayFast1.top := 1;
	self.frmBayFast2.left := self.frmBayFast1.width + 5;
	self.frmBayFast2.top := 1;
	self.frmBayFastPic.ignoreSkin := true;//added by cnwyl for par 12465
	self.frmBayFastPic.move(0,0,frWidth,frHeight);
	
	//epr CCMS 1033 moved setting bayPicture to this method
	_seqReporter.bayPicture := self.frmBayFastPic.createPictureIndirect(false, true);
epilog
	//epr 27470 more leaking transients
	delete theHolds;
end;</source>
        <access>protected</access>
        <Parameter name="_voyageJob" type="CM_VoyageJob"/>
        <Parameter name="_displayMode" type="Integer"/>
        <Parameter name="_seqReporter" type="CMIF_JobSequenceReporter" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doBuildDeckPic" id="8b6ce14a-54d5-4788-a933-0fad64de9c84">
        <updating/>
        <source>doBuildDeckPic(_voyageJob : CM_VoyageJob; _displayMode : Integer; _seqReporter : CMIF_JobSequenceReporter input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 August 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars	
	voyageDeckJob : CM_VoyageDeckJob;
	deck 		: CM_Deck;
	x1, y1, x2, y2   :Integer;
	scale	: Decimal[12,2];
	deckImage	: Binary;
	imageHeight	: Integer;
	roroPrintForm : SHP_ROROPrint;
begin
	// not a voyage deck job then return
	if not _voyageJob.isKindOf(CM_VoyageDeckJob) then
		return;
	endif;
	
	voyageDeckJob:=_voyageJob.CM_VoyageDeckJob;
	deck:=voyageDeckJob.myDeck;
	_seqReporter.baysDescription :=deck.code;
	
	if deck.myDeckLayout &lt;&gt; null then
		x2:=0;
		y2:=0;
		x1 := 9999999;
		y1 := 9999999;
		deck.myDeckLayout.getExtremePoints(x1, y1, x2, y2 );
		//scaled to the height of the pic
		scale:=(app.printer.pageWidth)/(x2-x1);
		create roroPrintForm transient;
		
		deckImage:=roroPrintForm.getROROJobImagePosition(voyageDeckJob);
		
		
		self.picture12.visible:=false;
		/*
		self.picture12.parent:=self;
		self.picture12.zOrder(1);
		picture12.clipControls:=false;
	picture12.stretch:=Picture.Stretch_ControlTo;
		self.picture12.autoRedraw:=true;
		self.picture12.transparent:=false;
		self.picture12.backColor:=White;
		self.picture12.picture:=deckImage;*/
		
		_seqReporter.bayPicture := deckImage;
		
		
	endif;
	
epilog
	delete roroPrintForm;
end;</source>
        <access>protected</access>
        <Parameter name="_voyageJob" type="CM_VoyageJob"/>
        <Parameter name="_displayMode" type="Integer"/>
        <Parameter name="_seqReporter" type="CMIF_JobSequenceReporter" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doCmbCraneBuildSC" id="a5b7e064-b217-40b8-bec4-a3b0f345576d">
        <source>doCmbCraneBuildSC();
// ---------------------------------------------------------------------------
// Created:		July 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	saveIdx,
	idx : Integer;
	theVoyageJS : CM_VoyageJobSheet;
	workPointObj	: CM_Object;
begin
	
	saveIdx := self.cmbCrane.listIndex;
	self.cmbCrane.clear;
	self.cmbCrane.sorted := false;
	if self.myCurrentVoyage = null then
		return;
	endif;

	idx := self.cmbCrane.addItem("Unallocated Jobs");
	self.cmbCrane.itemObject[idx] := null;
	self.cmbCrane.itemData[idx] := self.JobType_UnallocatedSC;
	idx := self.cmbCrane.addItem("All Jobs");
	self.cmbCrane.itemObject[idx] := null;
	self.cmbCrane.itemData[idx] := self.JobType_AllSC;
	
	foreach theVoyageJS in self.myCurrentVoyage.allJobSheets do
		workPointObj:=theVoyageJS.getMyWorkPointObject;
	
	//epr CCMS 1033 15/8/2011
		if workPointObj &lt;&gt; null then
			idx := self.cmbCrane.addItem(workPointObj.IF_VoyageWorkPoint.getID &amp; " - " &amp; workPointObj.IF_VoyageWorkPoint.getDescription);
			self.cmbCrane.itemObject[idx] := workPointObj;
			self.cmbCrane.itemData[idx] := self.JobType_CraneSC;
		endif;
	endforeach;

	if saveIdx &gt; 0 and saveIdx &lt;= self.cmbCrane.listCount then
		self.cmbCrane.listIndex := saveIdx;
	else
		self.cmbCrane.listIndex := 2;
	endif;

	

end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbLoadLaneBuild" id="734094d7-933d-4756-ae82-60126122f550">
        <source>doCmbLoadLaneBuild();
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	workPointObj : CM_Object;
	aCrane : CM_Crane;
	aController : CM_LocationsController;
	idx : Integer;
begin	
	self.cmbLoadLane.clear;
	
	if self.cmbCrane.listIndex &lt; 1 then
		return;
	endif;
	self.cmbLoadLane.addItem(Any_String);
	
	workPointObj := self.cmbCrane.itemObject[self.cmbCrane.listIndex].CM_Object;
	 
	if workPointObj = null then
		return;
	endif;
	
	aCrane:=workPointObj.IF_VoyageWorkPoint.getCrane;
	if aCrane = null then
		return;
	endif;
	if aCrane.transferArea = null then
		return;
	endif;
	
	if aCrane.transferArea.loadLanes.size = 0 then
		return;
	endif;
	
	foreach aController in aCrane.transferArea.loadLanes do
		if global.isValidObject(aController) then
			idx := self.cmbLoadLane.addItem(aCrane.id &amp; " - " &amp; aController.getID);
			self.cmbLoadLane.itemObject[idx] := aController;
		endif;
	endforeach;
	
	self.cmbLoadLane.listIndex := 1;
end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbSequenceBuild" id="dde5288c-8811-4725-b6f7-c24d185c07a8">
        <source>doCmbSequenceBuild();
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	idx : Integer;
begin
	self.cmbSequence.clear;
	self.cmbSequence.sorted := false;
	
	idx := self.cmbSequence.addItem("Standard");
	self.cmbSequence.itemData[idx] := self.Seq_Standard;
	idx := self.cmbSequence.addItem("Custom");
	self.cmbSequence.itemData[idx] := self.Seq_Custom;
	idx := self.cmbSequence.addItem("Planned");
	self.cmbSequence.itemData[idx] := self.Seq_Planned;


	self.cmbSequence.listIndex := 2;
//	self.tblQuery.setValueByControlName(self.cmbSequence.name,self.cmbSequence.text);

end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbSideBuild" id="e24dd397-5a52-46b4-b75a-bc627064916e">
        <updating/>
        <source>doCmbSideBuild() updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	idx 		: Integer;
	aVoyage 	: CM_Voyage;
	theVoyageJS : CM_VoyageJobSheet;
	aCrane 		: CM_Machine;
	theJob 		: CM_Job;
	theJobs 	: CM_JobArray;
begin

	self.cmbSide.clear;
	self.cmbSide.sorted := false;
	
	idx := self.cmbSide.addItem("Port");
	self.cmbSide.itemData[idx] := 1;
	idx := self.cmbSide.addItem("Starboard");
	self.cmbSide.itemData[idx] := 0;
	
	self.cmbSide.listIndex := 1;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbVoyageBuild" id="8b3ce145-4988-4c2d-ab38-23014332c94b">
        <updating/>
        <source>doCmbVoyageBuild() updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	aVoyage : CM_Voyage;
	idx : Integer;
	theVoyages : CM_VoyageSet;
begin
	
	self.cmbVoyage.clear;
	self.cmbVoyage.sorted := true;
	
	create theVoyages transient;
	self.myTerminal.getAllCurrentCellularVoyages(theVoyages, false, false);

	foreach aVoyage in theVoyages do
		idx := self.cmbVoyage.addItem(aVoyage.code &amp; " - " &amp; aVoyage.description);
		self.cmbVoyage.itemObject[idx] := aVoyage;
	endforeach;
	
	//cnwjo3 par 23105
	aVoyage := app.getMyCurrentVoyage();
	
	if aVoyage &lt;&gt; null then
		self.setCaption(aVoyage.description.trimBlanks &amp; " " &amp; app.getErrorString(SequenceSheet));
		self.setNavigatorHeading(self.caption);
		idx := self.cmbVoyage.findObject(aVoyage);
		if idx &gt; 0 then
			self.cmbVoyage.listIndex := idx;
//			self.tblQuery.setValueByControlName(self.cmbVoyage.name,self.cmbVoyage.text);
		endif;
		self.cmbVoyage.click(self.cmbVoyage);
	endif;

epilog
	delete theVoyages;
end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbVoyageClick" id="ad05cb81-5868-48de-9b59-9c8151cf219a">
        <updating/>
        <source>doCmbVoyageClick() protected, updating;
// ---------------------------------------------------------------------------
// Created:     13 October 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	theVoyage : CM_Voyage;
	cmb			: CMUI_ComboBox;
begin
	cmb := self.cmbVoyage;

	if self.myCurrentVoyage &lt;&gt; null then
		self.endNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(EVENT_VOYAGE_BERTHING_CHANGED));	
		self.endNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(VoyageJob_Create_Event));
		self.endNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(VoyageJob_Update_Event));
		self.endNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(VoyageJob_Delete_Event));
	endif;

	self.myCurrentVoyage := cmb.listObject.CM_Voyage;
	if self.myCurrentVoyage &lt;&gt; null then
		//app.myCurrentVoyage := self.myCurrentVoyage;
		//cnwjo3 par 23105
		app.setMyCurrentVoyage(self.myCurrentVoyage);
		
		self.beginNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(EVENT_VOYAGE_BERTHING_CHANGED), Response_Continuous, null);		
		self.beginNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(VoyageJob_Create_Event), Response_Continuous, null);
		self.beginNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(VoyageJob_Update_Event), Response_Continuous, null);
		self.beginNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(VoyageJob_Delete_Event), Response_Continuous, null);
	endif;
	
	self.tblData.rows := self.tblData.fixedRows;
	self.lstJobs.rows := 0;
	self.lstJobs.clearAllSelected();
	self.lstJobs.allSelectedObjects.clear();

	self.doCmbCraneBuildSC();
	self.doJobBuild();
	self.doCmbLoadLaneBuild();
	
	if self.myCurrentVoyage &lt;&gt; null then
		if self.myCurrentVoyage.starboardBerthed then
			self.cmbSide.listIndex := 2;
			self.dynaKey := ETRow_SeqNumCustomStarboard;
		else
			self.cmbSide.listIndex := 1;
			self.dynaKey := ETRow_SeqNumCustomPort;
		endif;
		self.setNavigatorHeading(self.myCurrentVoyage.getDisplayDetails(true));
		self.setCaption("Sequence Sheet - " &amp; self.myCurrentVoyage.getDisplayDetails(true));
	else
		self.setNavigatorHeading(self.caption);		
	endif;	
	self.cmbSequence.text := "Custom";	
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doJobBuild" id="6db80885-9474-4630-a90e-fe1f04c464b3">
        <updating/>
        <source>doJobBuild() updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	idx 			: Integer;
	aVoyage 		: CM_Voyage;
	theVoyageJS 	: CM_VoyageJobSheet;
	workPointObj	: CM_Object;
	theJob 			: CM_Job;
	theJobs 		: CM_JobArray;
	jobsTable		: CMUI_ListTable;
	craneID,
	jobNum			: String;
	jobType			: Integer;
	
begin
	self.mousePointer := Window.MousePointer_HourGlass;
	jobsTable := self.lstJobs;
	jobsTable.allSelectedObjects.clear();
	jobsTable.rows := 0;

	if self.cmbCrane.listIndex &gt; -1 then
		jobType := self.cmbCrane.itemData[self.cmbCrane.listIndex];
		workPointObj :=self.cmbCrane.listObject.CM_Object;
		if workPointObj &lt;&gt; null then
			craneID:=workPointObj.IF_VoyageWorkPoint.getID;
		endif;
	else
		app.msgBox("Please select a crane." ,"Sequence Sheet Query Error",	MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);	
		return;
	endif;
	
	if self.myCurrentVoyage = null then
		app.msgBox(app.getErrorString(SHP_Please_Select_A_Voyage),app.getErrorString(Error),	MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	create theJobs transient;
	self.myCurrentVoyage.getOOWJobs(jobType,craneID,false,theJobs);
	

	foreach theJob in theJobs do
		if theJob.jobType = JOB_TYPE_USER then // &lt;&lt;&lt; PAR 5487 - NO Hatch Lid Jobs!!!
			continue;
		endif;
		if theJob.CM_VoyageJob.isLoadedToOperations then // &lt;&lt;&lt; PAR 5487
			jobNum := theJob.CM_VoyageJob.jobNum;
			jobsTable.accessRow(jobsTable.addItem('0' &amp; Tab &amp; jobNum)).itemObject := theJob;
		endif;
	endforeach;
	
epilog
	delete theJobs;
	self.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuContextBuild" id="6dfdabc9-573d-4e7f-99dd-ff7c9077b3d1">
        <updating/>
        <source>doMnuContextBuild(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
// ---------------------------------------------------------------------------
// Created:		July 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

	anObject : Object;
	aTI : CM_TrackedItem;
begin
	anObject :=  cntrl.accessRow(cntrl.row).itemObject;
	if CM_TrackedItem.hasInstance(anObject) then
		aTI := anObject.CM_TrackedItem;
	elseif CM_VoyageWLE.hasInstance(anObject) then
		aTI := anObject.CM_VoyageWLE.myTrackedItem;
	//else
	//	return false;
	endif;
	
	if aTI &lt;&gt; null then
		self.mnuContextTIEnquire.visible := true;
		self.mnuContextTIEnquire.userObject := aTI;
		self.mnuContextTIEnquire.caption := "Enquire " &amp; aTI.id &amp; "...";
	else
		self.mnuContextTIEnquire.visible := false;
		self.mnuContextTIEnquire.userObject := null;	
	endif;
	
	return self.showContextMenu(self.mnuContextTable,cntrl,conwin,mouse,x, y);
end;</source>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doMnuInspectObject" id="df5dcc34-fe38-4b05-8426-542e09c449ac">
        <source>doMnuInspectObject();
//--------------------------------------------------
// Created:	12 December 2003 By: cnwgd1
//--------------------------------------------------
vars

begin
	if self.myCurrentVoyage &lt;&gt; null then
		self.myCurrentVoyage.inspectModal;
	else
		inheritMethod();
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doNotableClear" id="c3ef5908-bedc-4963-ac7c-061c348e0e0d">
        <source>doNotableClear();
// ---------------------------------------------------------------------------
// Created:     09 December 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// // PAR 21909
// ---------------------------------------------------------------------------

vars
	removedNotification : Integer;
	anObject : Object;
begin

	foreach anObject in self.allNotableObjects do
		if anObject.isKindOf(CM_TrackedItem) then
			endNotification(anObject, Object_Update_Event);
			endNotification(anObject, Object_Delete_Event); // PAR 21909
			removedNotification := removedNotification + 1;
		elseif CM_VoyageWLE.hasInstance(anObject) then // PAR 21909
			endNotification(anObject, Object_Update_Event); // PAR 21909
			endNotification(anObject, Object_Delete_Event); // PAR 21909
			removedNotification := removedNotification + 1;
		endif;
	endforeach;

	//cnwjo3 par 21915
	validateNotificationRemoval(removedNotification,self.allNotableObjects.size);
	
	self.allNotableObjects.clear;

end;</source>
    </JadeMethod>
    <JadeMethod name="doPrint" id="8dee4f7e-3263-4938-95b0-82659dcf6b8d">
        <updating/>
        <source>doPrint() updating;
// ---------------------------------------------------------------------------
// Created:     06 October 2003	cnwth2
//
// Purpose:     
//			 
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 17 Mar 2010	consw1		PAR #22886 - Leaking report transients
// 24 Aug 2011	cnwer1		CCMS 1033 - changed so will print decks if it is a voyage deck job being printed
// ---------------------------------------------------------------------------
vars
	obj							: Object;
	voyageJob					: CM_VoyageJob;

	pageHolderReport,
	jadeReport					: JadeReport;
	jrwReport,
	jrwROROReport				: JadeReportWriterReport;
	clonedPrintData,
	printData					: JadePrintData;
	printDataArray				: JadePrintDataArray;
	seqReporter					: CMIF_JobSequenceReporter;
	jrwTrans					: CM_JRWVoyageSummary;
	jobTable					: CMUI_ListTable;
	displayMode					: Integer;
	wle							: CM_WorkListEntry;
	dynaDict					: DynaDictionary;
	cmifMonitor					: CMIF_Monitor;
	partsComplete,
	partsInJob					: Integer;
	termDict					: CM_TerminalByCodeDict;
	isFirst	, getROROReport		: Boolean;
	
begin
	
	if self.lstJobs.allSelectedObjects.isEmpty then
		app.msgBox('You must select a job before continuing', 'No jobs selected', MsgBox_Exclamation_Mark_Icon);
		return;
	endif;

	app.mousePointer := Busy;
	isFirst := true;
	create dynaDict transient;
	jobTable := self.lstJobs;
	
	//if it is a RORO voyage get the 
	getROROReport:= self.myCurrentVoyage.myROROStructure &lt;&gt; null;
		
	
	if self.optNormal.value then
		jrwReport := self.getReportFromConfig(ShipSeqShtMedium); // CCMS 1494
		if getROROReport then
			jrwROROReport := self.getReportFromConfig(ShpSeqShtMediumRORO);
		endif;
	elseif self.optLargeP.value then
		jrwReport := self.getReportFromConfig(ShipSeqShtLarge); // CCMS 1494
		if getROROReport then
			jrwROROReport := self.getReportFromConfig(ShpSeqShtLargeRORO);
		endif;
	elseif self.optLargeL.value then
		jrwReport := self.getReportFromConfig(ShipSeqShtXLarge); // CCMS 1494
		if getROROReport then
			jrwROROReport := self.getReportFromConfig(ShpSeqShtXLargeRORO);
		endif;
	endif;
		
	if jrwReport = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'The report named for the sequence sheet report could not be found');
		return;
	endif;
	
	if getROROReport and  jrwROROReport = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'The report named the RORO sequence sheet report could not be found');
		return;
	endif;
	
	jrwTrans := app.myQAFilter.createJRWTransient(CM_JRWVoyageSummary).CM_JRWVoyageSummary;
	jrwTrans.doPadZeros := not self.myTerminal.getConfig(ShipRemoveLeadingZeros).Boolean;

	
	
	cmifMonitor := self.showMonitorForPrinting();
	partsInJob := jobTable.allSelectedObjects.size();
	
	if partsInJob &gt; 30 then
		if app.msgBox('Warning: You have elected to print more than 30 reports. Your transient cache limit within Jade may not be' &amp; CrLf &amp;
					'big enough to handle printing all these reports at one time. Are you sure you wish to continue?', 
					'Warning - Cache limit may be exceeded', 
					MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Cancel) &lt;&gt; MB_OK then
			return;
		endif;
	endif;
	
	self.setDynaKey;

	create termDict transient;
	termDict.add(self.myTerminal);
	jrwTrans.setAllTerminals(termDict);

	
	jrwTrans.orderedByOption := self.dynaKey;
	jrwTrans.printWeights := self.cbPrintPreview.value;
			
	jrwReport.setOutputDestination(JadeReportWriterReport.PRINTER);
	if jrwROROReport &lt;&gt; null then
		jrwROROReport.setOutputDestination(JadeReportWriterReport.PRINTER);
	endif;
	
	app.printer.printPreview := false;
	create printDataArray transient;
	
	foreach obj in jobTable.allSelectedObjects do
		voyageJob := obj.CM_VoyageJob;

			// ______________________ ccms1052 cnwvu1 01/02/2007 __________________________
		if self.xmlPrintLidComments then
			jrwTrans.hatchLidJobRemarks := voyageJob.getSeqSheetNextLidJobRemarks( voyageJob );
		else
			jrwTrans.hatchLidJobRemarks := null;
		endif;
		
		jrwTrans.allJobSequenceReporters.purge();
		create seqReporter transient;
		jrwTrans.allJobSequenceReporters.add(seqReporter);
		seqReporter.myVoyageJob := voyageJob;
		
		if cmifMonitor &lt;&gt; null then
			cmifMonitor.message := 'Building bay and sequence info for job ' &amp; voyageJob.jobNum;
			cmifMonitor.updateProgress(null, partsInJob, partsComplete);
			if cmifMonitor.monitorReturnValue = cmifMonitor.MonitorReturnValue_Cancel then
				return;
			elseif cmifMonitor.monitorReturnValue = cmifMonitor.MonitorReturnValue_Return then
				break;
			endif;
		endif;
		
		if not isFirst then	
			dynaDict.clear();
			dynaDict.clearKeys();
		endif;
		isFirst := false;
		dynaDict.setMembership(CM_VoyageWLE);
		dynaDict.addMemberKey(self.getConvertedDyna(voyageJob.isTwinLift, self.dynaKey), false, true);
		dynaDict.addMemberKey(CM_VoyageWLE::seqNumWorkOrder.name, false, true);
		dynaDict.endKeys(true);
		foreach wle in voyageJob.workListEntries do
			if voyageJob.isSOB and wle.myRequest.CM_SlotRequest.isLoad then
				continue;
			endif;
			dynaDict.add(wle);	
		endforeach;
		
		dynaDict.copy(seqReporter.allWLEs);
		
		if voyageJob.isSOB then
			displayMode := ShpDisplayMode_ColCodeDisch;
			seqReporter.jobTitle := 'Shift On Board Sequence Sheet';
		elseif voyageJob.isRelease then
			displayMode := ShpDisplayMode_ColCodeLoad;
			seqReporter.jobTitle := 'Load Sequence Sheet';
		else 
			displayMode := ShpDisplayMode_ColCodeDisch;
			seqReporter.jobTitle := 'Discharge Sequence Sheet';
		endif;

		self.doBuildBaysFast(voyageJob, displayMode, seqReporter);
		
		//epr CCMS 1033 24/8/11
		self.doBuildDeckPic(voyageJob, displayMode, seqReporter);

		if cmifMonitor &lt;&gt; null then
			cmifMonitor.message := 'JRW processing output for Job ' &amp; voyageJob.jobNum;
			cmifMonitor.updateProgress(null, partsInJob, partsComplete);
			if cmifMonitor.monitorReturnValue = cmifMonitor.MonitorReturnValue_Cancel then
				return;
			elseif cmifMonitor.monitorReturnValue = cmifMonitor.MonitorReturnValue_Return then
				break;
			endif;
		endif;
	
		// Reset printer
		app.printer.abort();
		create jadeReport transient;
		app.printer.setReport(jadeReport);
		
		if voyageJob.isKindOf(CM_VoyageDeckJob) then
			jrwROROReport.setPreviewOptions(false, false, false, true, null);
			jrwROROReport.run();
		else
			jrwReport.setPreviewOptions(false, false, false, true, null);
			jrwReport.run();
		endif;
		partsComplete := partsComplete + 1;
		
		foreach printData in jadeReport.printArray do
			clonedPrintData := printData.cloneSelf(true);
			printDataArray.add(clonedPrintData);
		endforeach;
	
		seqReporter.bayPicture := null;
		delete jadeReport;
		delete seqReporter;
	endforeach;
	
	//pile all the pages into the first report object
	create pageHolderReport transient;
	pageHolderReport.description := 'Sequence Sheet Report';
	printDataArray.copy(pageHolderReport.printArray);
	if self.cbPrintPreview.value then
		app.printPreview(pageHolderReport, true);
	else
		app.printer.printPreview := false;
		app.printerFixPAR34782(pageHolderReport);
		app.printer.printReport(pageHolderReport);
	endif;
	
	dynaDict.clear();
	dynaDict.clearKeys();
	
epilog
	endLoad;
	delete cmifMonitor;
	app.myPassport.setMyCMIFMonitor(null);
	self.frmModalDialog.visible := false;
	self.modalDialogReturnValue := null;

	
	delete jadeReport;
	delete dynaDict;
	delete jrwReport;
	delete jrwROROReport;
	delete jrwTrans;
	delete termDict;
	delete seqReporter; //epr par 27470 23/5/2011
	app.mousePointer := MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doQuery" id="eb506c5d-c591-49b3-a311-e9c0f8271aaf">
        <updating/>
        <source>doQuery() updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	obj						: Object;
	tbl						: CM_DataTable;
	jobTable				: CMUI_ListTable;
	dynaDict				: DynaDictionary;
	firstVisibleColumn,
	sequenceOption			: Integer;
	isSOB,
	isFirst,
	sidePort				: Boolean;
	filtLoadLane			: String;
	selectedObj				: CM_Object;	
	theVoyageWLE 			: CM_VoyageWLE;
	theJob 					: CM_VoyageJob;			
	fixedRows,
	row,
	rows,
	tmpColour,
	colour1,
	colour2					: Integer;	
	lastVoyageWLE			: CM_VoyageWLE;
	isItalic				: Boolean;
	tmpStr                  : String;
	processStackArray       : ProcessStackArray;
	methodCallDesc          : MethodCallDesc;
begin
	self.mousePointer := Window.MousePointer_HourGlass;

	
	isFirst := true;
	tbl := self.tblData;
	tbl.rows := tbl.fixedRows;
	self.doNotableClear();	
	
	jobTable := self.lstJobs;
	if jobTable.allSelectedObjects.isEmpty then
		app.msgBox("No jobs have been selected." ,"No jobs selected", MsgBox_Exclamation_Mark_Icon);
		return;
	endif;

	if self.cmbSequence.listIndex &lt; 1 then
		app.msgBox("Please Select A Sequence." ,"Sequence Sheet Query Error",	MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;

	// Hold off until passed message boxes
	// As this is called from several places we will show the caller
	//
	// PAR 21787
	create processStackArray transient;
	process.currentStack(processStackArray);

	if processStackArray.size &gt; 2 then
		methodCallDesc := processStackArray[3];
		tmpStr := methodCallDesc.method.qualifiedName;
	else
		tmpStr := method.qualifiedName;
	endif;
	
	self.cnStartTransaction(tmpStr[1:50]);

	create dynaDict transient;	
	sequenceOption := self.cmbSequence.itemData[self.cmbSequence.listIndex];
	sidePort := self.cmbSide.itemData[self.cmbSide.listIndex].Integer.Boolean;
	
	tbl.hideColumnByColName(ETRow_SeqNumCustomPort);
	tbl.hideColumnByColName(ETRow_SeqNumCustomStarboard);
	tbl.hideColumnByColName(ETRow_SeqNumPort);
	tbl.hideColumnByColName(ETRow_SeqNumStarboard);
	tbl.hideColumnByColName(ETRow_SeqNumWorkOrder);
	
	firstVisibleColumn := self.setDynaKey();
	//par 19269 if neither ETRow_SeqNumCustomPort,ETRow_SeqNumCustomStarboard,ETRow_SeqNumPort
	//or ETRow_SeqNumStarboard, or ETRow_SeqNumWorkOrder is visible, don't change width
	if firstVisibleColumn &gt; 0 then
		tbl.accessColumn(firstVisibleColumn).width := 75;
	endif;
	
	filtLoadLane := self.cmbLoadLane.text;
	
	foreach obj in jobTable.allSelectedObjects do	
		theJob := obj.CM_VoyageJob;
		if not isFirst then	
			dynaDict.clear();
			dynaDict.clearKeys();
		endif;
		isFirst := false;
		dynaDict.setMembership(CM_VoyageWLE);

		dynaDict.addMemberKey(self.getConvertedDyna(theJob.isTwinLift, self.dynaKey), false, true);

		// added this incase there are more than 1 WLE on the request AKBNOV2003
		dynaDict.addMemberKey(CM_VoyageWLE::seqNumWorkOrder.name, false, true);
		dynaDict.endKeys(true);
		isSOB := theJob.isSOB();
		self.addJobToTable(theJob, firstVisibleColumn, null);

		dynaDict.clear();
		theJob.workListEntries.copy(dynaDict);
		
		foreach obj in dynaDict do
			theVoyageWLE := obj.CM_VoyageWLE;
			if isSOB and theVoyageWLE.myRequest.CM_SlotRequest.isLoad then
				continue;
			endif;
			
			if (filtLoadLane &lt;&gt; null 
			and filtLoadLane &lt;&gt; Any_String) 
			and (theVoyageWLE.defaultCraneLoadLane &lt;&gt; 0) 
			and (filtLoadLane &lt;&gt; theVoyageWLE.defaultCraneLoadLane.String) then
				continue;
			endif;
			
			self.addWLEToTable(theVoyageWLE, null);
		endforeach;
	endforeach;

	dynaDict.clear();
	dynaDict.clearKeys();
	
	self.tblData.leftColumn := 1;
	
	self.setSelectedObject();
	
	colour1 := self.colorRow1;
	colour2 := self.colorRow2;
	rows := self.tblData.rows;
	fixedRows := self.tblData.fixedRows;
	
	foreach row in fixedRows to rows do
		obj :=  self.tblData.accessRow(row).itemObject;
		if obj &lt;&gt; null and obj.isKindOf(CM_VoyageWLE) then
			theVoyageWLE := obj.CM_VoyageWLE;
			if not theVoyageWLE.job.CM_VoyageJob.isTwinLift or theVoyageWLE.status = WLE_COMPLETED then
				continue;
			endif;
			if not theVoyageWLE.useBoldOrDifferentColour.Boolean then	
				tmpColour := colour1;		
			else
				tmpColour := colour2;
			endif;
			
			self.tblData.accessedRow.backColor := tmpColour;	
			
			self.tblData.accessedRow.foreColor := tmpColour.getInverseColour();	// PAR 21774
		endif;
	endforeach;
	
epilog
	delete dynaDict;
	//
	// If we started instrumentation - finish it
	//
	// PAR 21787
	if processStackArray &lt;&gt; null then
		processStackArray.purge;
		delete processStackArray;
	endif;

	if tmpStr &lt;&gt; null then
		self.cnEndTransaction();
	endif;
	self.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="75e07cc4-6fc2-4bdf-92fa-dc8436fd3f8d">
        <updating/>
        <source>doRefresh() updating, protected;
//--------------------------------------------------
// Created:	05 November 2003 By: cnwgd1
//--------------------------------------------------
// 09 Decemember 2009	conkc1	Remove inheritMethod to stop double doQuery PAR 21812 21904
vars

begin

//	inheritMethod();
	self.doQuery();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSelectAll" id="61bea27b-e961-4908-b730-33e3d615cdd5">
        <source>doSelectAll();
// ---------------------------------------------------------------------------
// Created:     13 October 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin

	if self.btnSelectAll.caption = app.getErrorString(SelectAll) then
		self.lstJobs.setAllToTrue;
	else
		self.lstJobs.setAllToFalse;
	endif;

	inheritMethod();
end;</source>
    </JadeMethod>
    <JadeMethod name="doSystemNotification" id="ce2c37c7-6e3e-4ff4-b248-bb816894637d">
        <updating/>
        <source>doSystemNotification(eventType: Integer; theObject: Object; eventTag: Integer) updating;
//--------------------------------------------------
// Created:	28 January 2004 By: cnwgd1
//--------------------------------------------------
vars
	rowIdx : Integer;
	wle : CM_WorkListEntry;
begin
	inheritMethod(eventType, theObject, eventTag);
	if eventType = Object_Update_Event then
		if CM_TrackedItem.hasInstance(theObject) then
			self.updateTIWle(theObject.CM_TrackedItem);
			
		// PAR 21789 from here 
		elseif self.tblData.findObjectInRow(theObject, rowIdx) then
			if CM_WorkListEntry.hasInstance(theObject) then
				wle := theObject.CM_WorkListEntry;
				
				if self.tblData.findObjectInRow(wle, rowIdx) then
					self.doNotableRemove(wle.myTrackedItem);				
					self.tblData.removeItem(rowIdx);
					self.addWLEToTable(wle, rowIdx);
				else
					self.doQuery();
				endif;	
			else
		// PAR 21789 to here 
				self.doQuery();
			endif;
		endif;
	elseif eventType = Object_Delete_Event then
		if self.tblData.findObjectInRow(theObject, rowIdx) then
			self.doQuery();
		endif;
	endif;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doTblDataDBClick" id="03269d77-f2bb-4106-8914-787cc35eba5e">
        <updating/>
        <source>doTblDataDBClick(table: CM_DataTable input) updating;
// ---------------------------------------------------------------------------
// Created:		July 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	anObject : Object;
	theTI : CM_TrackedItem;
begin
	if table.row &lt;= table.fixedRows then
		return;
	endif;
	
	anObject := table.accessRow(table.row).itemObject;
	
	//epr par 18253 22/10/08
	if anObject &lt;&gt; null and anObject.isKindOf(CM_WorkListEntry) then
	
		theTI := anObject.CM_WorkListEntry.myTrackedItem;
		if theTI &lt;&gt; null then
			self.myAssistant.showCargoEnquiryForm(theTI, self.myMasterMenuAction, true, false);	
		endif;
	endif;
end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTblDataRowColChange" id="98a5276f-64bb-44a7-9d22-8febeebd1df4">
        <updating/>
        <source>doTblDataRowColChange(table: Table input) updating;
//--------------------------------------------------
// Created:	12 July 2005 By: cnwgd1
//--------------------------------------------------
vars

begin

	self.myCurrentObject :=  table.accessRow(table.row).itemObject.CM_Object;

	inheritMethod(table);

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getConvertedDyna" id="591003d9-0522-4889-b6c6-e4f2b8e3ee57">
        <source>getConvertedDyna(_isTwin : Boolean; _dyna : String) : String protected;
// -------------------------------------------
// Created 02 September 2005 by cnwdvb1
// -------------------------------------------
vars

begin


	if not _isTwin then
		return _dyna;
	endif;
	
	if _dyna = ETRow_SeqNumWorkOrder then
		return ETRow_SeqNumWorkOrder;
	elseif _dyna = ETRow_SeqNumPort then
		return CM_VoyageWLE::numSeqPortTwin.name;
	elseif _dyna = ETRow_SeqNumStarboard then
		return CM_VoyageWLE::numSeqStarboardTwin.name;
	elseif _dyna = ETRow_SeqNumCustomPort then
		return CM_VoyageWLE::numSeqPortTwinCustom.name;
	elseif _dyna = ETRow_SeqNumCustomStarboard then
		return CM_VoyageWLE::numSeqStarboardTwinCustom.name;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_isTwin" type="Boolean"/>
        <Parameter name="_dyna" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getReportFromConfig" id="dcf53d95-5c7c-43cf-af12-a6e067b53a38">
        <source>getReportFromConfig(_config : String) : JadeReportWriterReport;
// ---------------------------------------------------------------------------
// Created:		13 December 2006 By Andrew Bishop cnwab1
//
// Purpose:		CCMS 1494
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 17 Mar 2010	consw1		PAR #22886 - Leaking report transients
// ---------------------------------------------------------------------------
vars
	jrwReport	: JadeReportWriterReport;
	reportString : String;
	jrwManager					: JadeReportWriterManager;
begin
	jrwManager := app.createReportWriterManager();
	reportString := self.myTerminal.getConfig(_config).String;
	if reportString = null then
		reportString:=app.getDefaultSeqSheetReportName(_config);
		beginTransaction;
		self.myTerminal.setConfig(_config,reportString);
		commitTransaction;
	endif;

	jrwReport := jrwManager.getReport(reportString);
	if jrwReport = null then
		reportString:=app.getDefaultSeqSheetReportName(_config);
		beginTransaction;
		self.myTerminal.setConfig(_config,reportString);
		commitTransaction;
		jrwReport := jrwManager.getReport(reportString);
	endif;

	return jrwReport;
	
epilog
	delete jrwManager;
end;</source>
        <Parameter name="_config" type="String"/>
        <ReturnType type="JadeReportWriterReport"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="740dafb6-8d77-400d-ba14-985f9bba780e">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
// ---------------------------------------------------------------------------
// Created:     29 March 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	str			: String;
begin
	str := inheritMethod();

	str := str &amp; self.XML_TAG_PRINT_PREVIEW.asXmlPrefix &amp; self.cbPrintPreview.value.String &amp; self.XML_TAG_PRINT_PREVIEW.asXmlSuffix;
	str := str &amp; global.formatAsXML( self.XML_PrintLidComments, self.xmlPrintLidComments.Integer.String );

	return str;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleBerthChangeNotification" id="79dffa5f-bc05-4092-8fed-d1fd7eba69db">
        <updating/>
        <source>handleBerthChangeNotification(event: Integer; theObject: Object) updating, protected;
// ---------------------------------------------------------------------------
// Created:     15 October 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars

begin

	if self.myCurrentVoyage &lt;&gt; theObject then
		return;
	endif;
	
	if event = EVENT_VOYAGE_BERTHING_CHANGED then

		app.msgBox('The berthing of the currently selected voyage has been changed.' &amp; CrLf &amp;
				'The job sequences you have currently selected will now be re-displayed' &amp; CrLf &amp;
				'in the appropriate order.', 'Sequence sheet - Berthing change detected', MsgBox_Exclamation_Mark_Icon);

		if self.myCurrentVoyage.starboardBerthed then
			self.cmbSide.listIndex := 2;
		else
			self.cmbSide.listIndex := 1;
		endif;
		self.doQuery;		
	endif;


end;</source>
        <access>protected</access>
        <Parameter name="event" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="handleInvalidWLEAdd" id="c6b00c57-e8fe-41f8-8174-c40608893b67">
        <source>handleInvalidWLEAdd(_exc : Exception; _excOccurred : Boolean io) : Integer protected;

/*

Purpose:			Swallow up any error 4 exceptions when adding a WLE to the table - 
					timing issues identified by JBL performance testing

Parameters:			

Return Value:		


Date		Who		Reason
02 Jun 2010	cnwkpd1	PAR #24334 - System performance testing found error 4

*/

vars

begin
	if _exc.errorCode = 4 then
		app.writeLog("&gt;&gt;&gt;&gt; " &amp; method.qualifiedName &amp; " errorObject=" &amp; _exc.errorObject().String, LogINFO);
		app.writeLogProcessStack();
		_excOccurred := true;
		
		return Ex_Resume_Next;
	endif;
	
	return Ex_Pass_Back;
	

epilog

end;</source>
        <access>protected</access>
