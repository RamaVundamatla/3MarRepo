<CollClass name="CM_VoyageJobByJobNumDict" id="0afa8178-448f-4f01-a828-00c9bfd5d5c9">
    <memberType name="CM_VoyageJob"/>
    <superclass name="CM_MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="voyages"/>
    <MemberKey>
        <property name="CM_VoyageJob::jobNum"/>
    </MemberKey>
    <JadeMethod name="getNextJobID" id="7e7da796-f77b-4e91-857e-78dbcb2e216d">
        <source>getNextJobID() : String;
// --------------------------------------------------------------------------------
// Created:		01 September 2010 by cnwjo3
//
// Purpose:		ccms 1178 par 23366.  Get the next Job Id.
//
vars
	voyageJob : CM_VoyageJob;
	newId : String;
	highestID : Integer;
	id : Integer;
	voyage : CM_Voyage;
begin
	foreach voyageJob in self discreteLock do
		voyage:= voyageJob.myVoyage;
		id := voyageJob.id.Integer;
		if id &gt; highestID then
			highestID := id;
		endif;
	endforeach;
	
	highestID:=highestID + 1;
	newId := highestID.String;
	
	//epr TFS 830 22/3/17 to avoid an annoying error
	while true do
		if voyage.isUniqueJobNum(newId) then
			break;
		endif;
		highestID:=highestID + 1;
		newId:=highestID.String;
	endwhile;
	
	
	return newId;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNextJobSuffix" id="7f666460-1dc9-4013-b4c0-b1d0c3675602">
        <source>getNextJobSuffix(_jobNum : String) : String;
// --------------------------------------------------------------------------------
// Created:		02 September 2010 by cnwjo3
//
// Purpose:		get the next suffix for a job id.  Ie, Job ID 201 could return 201A, 201B, or 201C... etc
//				CCMS 1178 PAR 23366
//
vars
	voyageJob : CM_VoyageJob;
	newJobWithSuffix : String;
	allJobNumIds : StringArray;
	suffix : String;
begin
	create allJobNumIds transient;
	suffix := "A";
	
	foreach voyageJob in self discreteLock do
		allJobNumIds.add(voyageJob.id);
	endforeach;
	
	newJobWithSuffix := _jobNum &amp; suffix;
	while allJobNumIds.includes(newJobWithSuffix) do
		if suffix.length = 1 then
			if suffix[1] = "Z" then
				suffix := "ZA";
			else
				suffix[1] := (suffix[1].Integer + 1).Character;
			endif;
		elseif suffix.length = 2 then
			//we are assuming a job will be split less than 676 times
			suffix[2] := (suffix[2].Integer + 1).Character;
		else
			write "suffix is size zero?????";
		endif;
		
		newJobWithSuffix := _jobNum &amp; suffix;
	endwhile;
	
	return newJobWithSuffix;
epilog
	delete allJobNumIds;
end;</source>
        <Parameter name="_jobNum" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
</CollClass>
