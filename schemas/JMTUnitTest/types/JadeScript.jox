    <JadeMethod name="pwTestEmails" id="46621b1c-1a15-44fc-a585-072a8eb485ae">
        <source>pwTestEmails();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 April 2025	navpw1	Initial creation
08/05/2025		navhn30 MTN: 34403: MTN - Sending Unit Tests Failing Summary Report by Team to Users that are Interested in it - Part 4 - Phase1

*/

vars
	testRoot					: UM_Root;
	previousRun					: UM_UnitTestRun;
	testRunner 					: JMTTestController;
	previousTestResults			: UT_TestResultsByName;
	allPreviousUMResults		: UM_UnitTestResultByMRunTS;
	umResult					: UM_UnitTestResult;
	utResult					: UT_TestResult;
	userSummaryDict				: CM_AssociationDict;
	userIgnoreDict				: CM_AssociationDict;
	association					: CM_Association;
	summary						: String;
	user						: String;
	
	iter						: Iterator;
	retVal						: Integer;
	isOk						: Boolean;
	
begin
	app.initialize();
	testRoot := UM_Root.firstInstance;
	iter := testRoot.allUnitTestRuns.createIterator();
	iter.back(previousRun);
	
	if previousRun &lt;&gt; null and not previousRun.endTS.isValid() then
		retVal := app.msgBox("Are you sure you want to continue ?" &amp; CrLf &amp; "Script will likely break." &amp; CrLf &amp; CrLf &amp; "Retry to get the run before this one", "Previous run did not finish", MsgBox_Abort_Retry_Ignore);
		if retVal = MsgBox_Return_Abort then
			return;
		elseif retVal = MsgBox_Return_Retry then
			iter.back(previousRun);
		endif;
	endif;
	
	if previousRun = null then
		app.msgBox("No Unit Test run found", "Error", MsgBox_OK_Only + MsgBox_Stop_Icon);
		return;
	endif;
	
	create testRunner transient;
	testRunner.setTotalRunableTests(previousRun.totalRunnable);
	testRunner.setPropertyValue(JMTTestController::startTime.name, previousRun.startTS);
	testRunner.setPropertyValue(JMTTestController::finishTime.name, previousRun.endTS);
	testRunner.checkLeaks := previousRun.checkLeaks;
	testRunner.logResult := previousRun.logResult;
	testRunner.setScheduleName(previousRun.scheduleName);
	
	previousTestResults := testRunner.getTestResults();
	
	create allPreviousUMResults transient;
	previousRun.allFailed.copy(allPreviousUMResults);
	previousRun.allIgnored.copy(allPreviousUMResults);
	previousRun.allPassed.copy(allPreviousUMResults);
	
	// ... the hard way it is then (surely there is a better way to get the previous results)
	foreach umResult in allPreviousUMResults do
		create utResult transient;
		utResult.setFromUmResult(umResult);
		previousTestResults.add(utResult);
	endforeach;
	
	create userSummaryDict transient;
	create userIgnoreDict transient;
	
	testRunner.setSendEmail(true);
	
	summary := testRunner.getResultsSummary(userSummaryDict, userIgnoreDict);
	
	app.emailReports(summary, "Summary", 1, testRunner,null,false);			//cnwmc5 - 12/10/2012
	
	process.sleep(50000);
	
	testRunner.getResultsSumFailOnly(userSummaryDict, userIgnoreDict, true, false);	//Need to re-run as results from above are by team
	
	iter := userSummaryDict.createIterator();
	summary := "";
	while iter.next(association) do
		userSummaryDict.getIteratorKeys(user, iter);
		summary := summary &amp; CrLf &amp; user &amp; app.masterAddress &amp; CrLf &amp; association.asStringWithoutFailures() &amp; CrLf; //association.asString;	// 24/03/2011 cnwmh5
		app.emailReports(app.formatFailureDetails(association.asString), user, 0, testRunner,null,false);		// 27/06/2017 cnwmh5
		//self.emailReports(association.asString, user, 0, testRunner);			//cnwmc5 - 12/10/2012
		//self.emailReports(summary, user, 0, testRunner);
	endwhile;
	
	app.emailReports(summary, "User Summary", 2, testRunner,null,false);			//cnwmc5 - 12/10/2012
	
	userSummaryDict.clear();
	userIgnoreDict.clear();
	delete iter;
	
	process.sleep(50000);
	
	summary := "";
	summary := testRunner.getResultsSumFailOnly(userSummaryDict, userIgnoreDict, false, true);
	if not summary.cnContains("Failed: 0 ") then
		app.emailReports(summary, "Failure Summary", 1, testRunner,null,false);
	endif;
	
	write summary;
	
	/*userSummaryDict.clear();
	userIgnoreDict.clear();
	delete iter;
	
	summary := testRunner.getResultsSummary(userSummaryDict, userIgnoreDict);
	
	testRunner.getResultsSumFailOnly(userSummaryDict, userIgnoreDict, true, false);	//Need to re-run as results from above are by team
	
	iter := userSummaryDict.createIterator();
	summary := "";
	while iter.next(association) do
		userSummaryDict.getIteratorKeys(user, iter);
		summary := summary &amp; CrLf &amp; user &amp; app.masterAddress &amp; CrLf &amp; association.asStringWithoutFailures() &amp; CrLf; //association.asString;	// 24/03/2011 cnwmh5
		//self.emailReports(app.formatFailureDetails(association.asString), user, 0, testRunner);		// 27/06/2017 cnwmh5
		//self.emailReports(association.asString, user, 0, testRunner);			//cnwmc5 - 12/10/2012
		//self.emailReports(summary, user, 0, testRunner);
	endwhile;
	
	app.emailReports(summary, "User Summary", 2, testRunner);			//cnwmc5 - 12/10/2012
	*/
	
	isOk := true;
	
epilog
	if not isOk then
		delete utResult;
	endif;
	
	delete testRunner;
	delete allPreviousUMResults;
	delete userSummaryDict;
	delete userIgnoreDict;
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="pwTestStuff" id="a0f7bd70-e190-48e8-adb0-80aa4138a002">
        <source>pwTestStuff();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 November 2021	navpw1	Initial creation

*/

vars
	jtr : JadeTestRunner;
	tests : ObjectArray;
	
begin
	create tests transient;
    tests.add(UT_SourceCompareJade);
    create jtr transient;
	jtr.setLogCallStack(true);
    jtr.runTests(tests);
	
epilog
    delete tests;
    delete jtr;

end;</source>
    </JadeMethod>
    <JadeMethod name="removeCommentsFromSource" id="7f74079b-e10a-4c6f-ae3f-cb8b64ed70b7">
        <source>removeCommentsFromSource(pSource: String): String;

/*
Purpose:			To remove the fluff from a method source. Fluff is comment text and the contents of string literals.
					This is for use when checking for leaking transients.
					The purpose of this is two-fold: to reduce the number of (1) tokens to be processed, and (2) false positives
					which occur when the 'never delete a line of code' brigade comment out foreach statements and replace them
					with while statements.

Return Value:		The defluffed source.

Date				Who			Reason
14 Jun 2005			cnwjub1		Creation
02 Sep 2008	cnwkpd1	"Borrowed" code from JSMS

*/

vars
	dq, sq, sa, ss, p, p1, sz, first, eol: Integer;
	src, str: String;

begin
	src:= pSource;
	p:= 1;
	sz:= src.length;
	dq:= src.pos('"', 1);
	sq:= src.pos("'", 1);
	sa:= src.pos("/*", 1);
	ss:= src.pos("//", 1);
	while true do
		if dq &gt; 0 and dq &lt; p then
			dq:= src.pos('"', p);
		endif;
		if sq &gt; 0 and sq &lt; p then
			sq:= src.pos("'", p);
		endif;
		if sa &gt; 0 and sa &lt; p then
			sa:= src.pos("/*", p);
		endif;
		if ss &gt; 0 and ss &lt; p then
			ss:= src.pos("//", p);
		endif;
		first:= 0;
		p1:= sz + 1;
		if dq &gt; 0 then
			first:= 1;
			p1:= dq;
		endif;
		if sq &gt; 0 and sq &lt; p1 then
			first:= 2;
			p1:= sq;
		endif;
		if sa &gt; 0 and sa &lt; p1 then
			first:= 3;
			p1:= sa;
		endif;
		if ss &gt; 0 and ss &lt; p1 then
			first:= 4;
			p1:= ss;
		endif;
		if first = 1 then
			// Double quote: copy up to and including, then discard up to but not including match
			str:= str &amp; src[p:(p1-p+1)];
			p:= p1 + 1;
			if p &gt; sz then
				break;
			endif;
			dq:= src.pos('"', p);
			if dq &lt;= 0 then // No match
				break;
			endif;
			p:= dq + 1;
			str:= str &amp; '"';
		elseif first = 2 then
			// Single quote: copy up to and including, then discard up to but not including match
			str:= str &amp; src[p:(p1-p+1)];
			p:= p1 + 1;
			if p &gt; sz then
				break;
			endif;
			sq:= src.pos("'", p);
			if sq &lt;= 0 then // No match
				break;
			endif;
			p:= sq + 1;
			str:= str &amp; "'";
		elseif first = 3 then
			// Slash asterisk: copy up to but not including, then discard up to and including mate
			str:= str &amp; src[p:(p1-p)];
			p:= p1 + 2;
			if p &gt; sz then
				break;
			endif;
			sa:= src.pos("*/", p);
			if sa &lt;= 0 then // No match
				break;
			endif;
			p:= sa + 2;
		elseif first = 4 then
			// Slash slash: copy up to but not including, then discard up to but not including end of line
			str:= str &amp; src[p:(p1-p)];
			p:= p1 + 2;
			if p &gt; sz then
				break;
			endif;
			eol:= src.pos(Cr, p);
			if eol &lt;= 0 then // No end of line
				break;
			endif;
			p:= eol;
		else
			// No more: copy to end and exit
			str:= str &amp; src[p:end];
			break;
		endif;
		if p &gt; sz then
			break;
		endif;
	endwhile;
	return str;
end;</source>
        <Parameter name="pSource" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="rs" id="808bf7f9-b3ed-46c2-8c99-bcba28cad704">
