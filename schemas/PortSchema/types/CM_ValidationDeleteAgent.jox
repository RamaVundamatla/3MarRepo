    <JadeMethod name="valTrain" id="b8d28437-dfca-46ca-a151-7b1506921023">
        <source>valTrain(_train : CM_Train io; _isTrainConsist : Boolean; _allWagonsToDelete : CM_WagonSet);
/*
----------  ----------  --------------------------------------------------
Created:	07 November 2006 By cnwth2

Purpose:	

Changed On  Changed By  Reason
	
----------  ----------  --------------------------------------------------
19/02/2010	cnwdad1		PAR #21330 - Added _isTrainConsist and _allWagonsToDelete parameters.
*/
vars

begin
	self.raiseExceptionIfNull(_train, 'Train');
	
	if _isTrainConsist then
		_train.validateForTrainConsistDelete(_allWagonsToDelete);
	else
		_train.validateForDelete();
	endif;
end;</source>
        <Parameter name="_train" type="CM_Train" usage="io"/>
        <Parameter name="_isTrainConsist" type="Boolean"/>
        <Parameter name="_allWagonsToDelete" type="CM_WagonSet"/>
    </JadeMethod>
