    <JadeMethod name="setupDrawingAttributes" id="47ad5c94-76d9-462e-8cf6-dc2097f60cec">
        <source>setupDrawingAttributes();
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	anAttribute, 
	aProxyAttribute : CM_DrawingAttribute;

begin
	if self.allDrawingAttributes.isEmpty then
		foreach anAttribute in app.myRoot.allDrawingAttributes do
			aProxyAttribute := anAttribute.cloneSelf(true);
			self.allDrawingAttributes.add(aProxyAttribute);
		endforeach;
	endif;


end;</source>
    </JadeMethod>
    <JadeMethod name="setupFrame" id="bcbb9d60-78a0-4efc-92ba-8da807a0575b">
        <updating/>
        <source>setupFrame() updating;
// ---------------------------------------------------------------------------
// Created:		November 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	anObject : Object;
begin
	self.beginClassNotification(Global, false, self.myTerminal.getTerminalEvent(EVENT_ROWCONTROLLER_DELETE), Response_Continuous , null);
	self.setupDrawingAttributes();

end;</source>
    </JadeMethod>
    <JadeMethod name="showControl" id="b597b8d3-5384-49a9-a523-e07b3fe5fa8b">
        <source>showControl(pControl : Control input);
// ---------------------------------------------------------------------------
// Created:     29 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if pControl = null then
		return;
	endif;
	
	pControl.visible := true;
	
end;</source>
        <Parameter name="pControl" type="Control" usage="input"/>
    </JadeMethod>
    <JadeMethod name="userNotify" id="e4c8a0a4-4510-4a5b-aa27-22dc393129d5">
        <updating/>
        <source>userNotify(frame: Frame input; eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 26 May 2008	cnwkpd1		PAR #16814 - Replace global.commonResumInvalidObjHandler
// ---------------------------------------------------------------------------

vars
	lController : CM_LocationsController;
	lRow, lCol : Integer;
	lGridArea : CMUI_GridArea;
	lGridPoint : CMUI_GridPoint;
	event		: Integer;
	gotException : Boolean;
	
begin
	event := self.myTerminal.getEventFromTerminalEvent(eventType);

	if event = EVENT_TI_MOVE then
		on Exception do app.handleDeletedObject(exception, lController, gotException);		// PAR #16814
		if self.allNotableObjects.includes(theObject) then
			if not userInfo.isKindOf(CM_LocationsController) then // PAR 23435
				return;
			else
				lController := userInfo.CM_LocationsController;
			endif;
		else
			return;
		endif;
		if lController &lt;&gt; null then
			// ###########################
			// Check to see if this location controller is on our form
			self.findLCAndRedrawGridPoint(lController);
			if gotException then
				// Exception handler resumes here if lController was invalid.
				return;
			endif;
		endif;
	elseif event = EVENT_UPDATE_VOYAGE_AREA then
		on Exception do app.handleDeletedObject(exception, lController, gotException);		// PAR #16814
		if self.allNotableObjects.includes(theObject) then
			if not userInfo.isKindOf(CM_LocationsController) then // PAR 23435
				return;
			else
				lController := userInfo.CM_LocationsController;
			endif;
		else
			return;
		endif;
	
		if lController &lt;&gt; null then
			// ###########################
			// Check to see if this location controller is on our form
			self.findLCAndRedrawGridPoint(lController);
			if gotException then
				// Exception handler resumes here if lController was invalid.
				return;
			endif;
		endif;
	elseif event =  EVENT_REFRESH_VOYAGE_AREA then
		self.doEventRefreshVoyageArea();
	elseif event = EVENT_REFRESH_GRID_AREA then
		if self.allNotableObjects.includes(theObject) then
			if self.myParentForm.isKindOf(CM_BaseForm) then
				self.myParentForm.sendMsg(CM_BaseForm::doCompleteRedraw.name);
			endif;
		else
			return;
		endif;
	elseif event = EVENT_ROWCONTROLLER_DELETE then	// PAR4239 AKB2002NOV
		self.drawSelf();
	endif;
epilog

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="validateCompareSelectedPoints" id="4e13473e-0b2d-4d26-9a3f-ce4230d97fe0">
        <source>validateCompareSelectedPoints(_messageStr : String; _pointName : String) : Boolean;
// ---------------------------------------------------------------------------
// Created:		March 2003 By Andrew Bishop cnwab1
//
// Purpose:		Has the user selected the same amount of selected points and ALT selected points?
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	gridArea	: CMUI_GridArea;
	aPoint : CMUI_GridPoint;
	selPoints, altPoints : Integer;
	sameAmount : Boolean;
	aMessage, selPointLabels, altPointLabels  : String;
begin

	foreach gridArea in self.allGridAreasByRowColumn do
		selPoints := selPoints +  gridArea.allSelectedPoints.size;
		foreach aPoint in gridArea.allSelectedPoints do
	
			if selPointLabels = null then
				selPointLabels := aPoint.getName;
			else
				selPointLabels := selPointLabels &amp; ", " &amp; aPoint.getName;
			endif;
		endforeach;
	endforeach;

	foreach gridArea in self.allGridAreasByRowColumn do
		altPoints := altPoints +  gridArea.allSelectedPointsAlt.size;
		foreach aPoint in gridArea.allSelectedPointsAlt do
	
			if altPointLabels = null then
				altPointLabels := aPoint.getName;
			else
				altPointLabels := altPointLabels &amp; ", " &amp; aPoint.getName;
			endif;
		endforeach;
	endforeach;

	if altPoints = 0 then
		return true;
	endif;


	sameAmount := (selPoints = altPoints);
	if not sameAmount then
		aMessage :="Please selected the same amount of " &amp; _pointName &amp; " and ALT " &amp; _pointName &amp; "." &amp; Cr;
		aMessage := aMessage &amp; "You have " &amp; selPoints.String &amp; " selected " &amp; _pointName &amp; " (" &amp; selPointLabels &amp; ")" &amp; ", " &amp; Cr;
		aMessage := aMessage &amp; "and " &amp; altPoints.String &amp; " ALT " &amp; _pointName&amp; " (" &amp; altPointLabels &amp; ")";
		app.msgBox(aMessage,_messageStr &amp; " Draw Error", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
	endif;
	return sameAmount;

end;</source>
        <Parameter name="_messageStr" type="String"/>
        <Parameter name="_pointName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="bfadc896-c813-41c0-96fa-1a95a63e6362">
        <updating/>
        <source>windowCreated(cntrl: CMUI_ScrollableDrawingFrame input; persistCntrl: CMUI_ScrollableDrawingFrame) updating;
// ---------------------------------------------------------------------------
// Created:     29 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(cntrl, persistCntrl);
	
	if self.isInPainter then
		return;
	endif;
	
	self.autoRedraw := true;

	// Note that the order of creation is important here
	// as this sets the zOrder for the controls
	self.createLabelFrames();
	self.createHScroll();
	self.createVScroll();
	self.createFillerFrames();
	self.createDrawingFrame();
	create self.myViewModeAttribute transient;
	create self.myDrawingAttrController transient;

end;</source>
        <Parameter name="cntrl" type="CMUI_ScrollableDrawingFrame" usage="input"/>
        <Parameter name="persistCntrl" type="CMUI_ScrollableDrawingFrame"/>
    </JadeMethod>
