    <JadeMethod name="getDisplayStringForAttribute" id="96fe4edf-8d69-420c-be2b-9408eefb59ed">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 August 2014	cnwndl1	Initial creation

*/

vars
	
begin

	if _attrName = ETRow_AppliesToTerm then
		if self.appliesToTerm then
			return "per Terminal";
		else
			return "System wide";
		endif;
	elseif _attrName = ETRow_CompareValue then
		return null;
	elseif _attrName = ETRow_UpdateValue then
		return null;
	elseif _attrName = ETRow_Differs then
		return null;
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTextToSearch" id="a06d4e2e-3241-4caa-8252-bd5a850cf421">
        <source>getTextToSearch( _includeConstant : Boolean ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 August 2014	cnwndl1	Initial creation

*/

vars

	str : String;

begin

	str := self.optionName.toUpper.trimBlanks;
	str := str &amp; " " &amp; self.maintFormName.toUpper.trimBlanks;
	str := str &amp; " " &amp; self.sheetName.toUpper.trimBlanks;
	
	if self.position.pos("row",1) &lt; 1 then
		str := str &amp; " " &amp; self.position.toUpper.trimBlanks;
	endif;
	
	if _includeConstant then
		str := str &amp; " " &amp; self.constantName.toUpper.trimBlanks;
	endif;
	
	return str;

epilog

end;</source>
        <Parameter name="_includeConstant" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setNewCurrentValue" id="10384c9c-2bdc-4569-bc8a-a183490d3029">
        <updating/>
        <source>setNewCurrentValue( _term : CM_Terminal; _newValue : String ):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 August 2014	cnwndl1	Initial creation

*/

vars

	oldValue : Any;

begin

	if self.constantName &lt;&gt; null then
	
		app.myTrxUA.trxUpdateConfigFromString(	_term,	//_term : CM_Terminal;
												self,	//_cmif : CMIF_ConfigOptionsDisplay input;
												_newValue,	//_newValue : String;
												app.myPassport	//_passport : CM_Passport input
												);
		return app.myPassport.noErrors;
	endif;
	
	return false;

epilog

end;</source>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_newValue" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setValues" id="0880d2d0-6f49-49fc-abbd-19f03daa9c7c">
        <updating/>
        <source>setValues(	_appliesToTerm : Boolean;
			_constantName : String;
			_currentValue : String;
			_maintFormName : String;
			_optionName : String;
			_position : String;
			_sheetName : String
			) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 August 2014	cnwndl1	Initial creation

*/

vars

begin

	self.appliesToTerm := _appliesToTerm;
	self.constantName := _constantName;
	self.currentValue := _currentValue;
	self.maintFormName := _maintFormName;
	self.optionName := _optionName;
	self.position := _position;
	self.sheetName := _sheetName;

epilog

end;</source>
        <Parameter name="_appliesToTerm" type="Boolean"/>
        <Parameter name="_constantName" type="String"/>
        <Parameter name="_currentValue" type="String"/>
        <Parameter name="_maintFormName" type="String"/>
        <Parameter name="_optionName" type="String"/>
        <Parameter name="_position" type="String"/>
        <Parameter name="_sheetName" type="String"/>
    </JadeMethod>
</Class>
