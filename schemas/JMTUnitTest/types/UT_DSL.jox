	voyagePlanningCode : CM_VoyagePlanningCode;
	logDocketData : CM_LogDocketData;
	moveMap : CM_MoveMap;
	mTThreshold : CM_MTThreshold;
	fromUnitTestMethod : Boolean;
	hookCode : CM_HookCode;
	cmqfFilterRpts : CMQF_FilterReports;							// 23/05/2016
	rtQueueTask : CM_RTQueueTask;
	size : Integer;
	index : Integer;
	xlation : CM_Xlation;
	weighAuthTerminal : CM_WeighAuthTerminal;
	taStorageGroup : CM_TerminalAreaStorageGroup;
	taskCriteria : CM_TaskCriteria;
