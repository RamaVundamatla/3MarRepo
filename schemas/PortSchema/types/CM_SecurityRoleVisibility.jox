    <JadeMethod name="setForUpdate" id="821c8597-2c1c-4a4d-9bcf-29925485a570">
        <updating/>
        <source>setForUpdate(_availToShipCo : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:			27 March 2001 by cnwdwq1
// Purpose:			!     
// Parameters:	None
// Returns:			Nothing
// Changed On	Changed By		Reason
// ----------			----------			--------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	if self.availableToShippingCompany &lt;&gt; _availToShipCo then
		app.myAA.auditUpdate(self, "availableToShippingCompany", self.availableToShippingCompany);
		self.availableToShippingCompany := _availToShipCo;
	endif;
end;</source>
        <Parameter name="_availToShipCo" type="Boolean"/>
    </JadeMethod>
