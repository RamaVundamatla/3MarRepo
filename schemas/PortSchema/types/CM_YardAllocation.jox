    <JadeMethod name="persistCriteria" id="6461c332-e9ab-463c-8e9d-32d542eac3bd">
        <updating/>
        <source>persistCriteria(pAllTransientCriteriaObj:CMIF_Array; pPassportObj:CM_Passport input) updating;
// --------------------------------------------------------------------------------
// Created:		27 April 2005 by cnwdad1
//
// Purpose:		Persists the receiver's YA Criteria from transient representations
//				of criteria.
//
// Parameters:	pAllTransientCriteriaObj - A collection transient objects containing
//					the YA Criteria information.
//				pPassportObj - A reference to the user's "passport".
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 18/08/2008	Simon Ward	SFW1030 - Add criteria validation
// 10/03/2021	navdap1		TFS 50889 PRP Yard Allocation Performance Improvement
// --------------------------------------------------------------------------------
vars
	criteriaObj			: CM_YACriteria;
	cmifObject			: CMIF_Object;
	transientObj		: CMIF_YACriteriaPriority;
	proxyObj			: CM_YACriteriaPriority;
	realCPObj			: CM_YACriteriaPriority;
	isCreateDone		: Boolean;
	isDeleteDone		: Boolean;
	isUpdateDone		: Boolean;
	
begin
	// Now update the Yard Allocation Criteria.
	
	foreach criteriaObj in self.allCriteria reversed do
		criteriaObj.setPriorityValue(criteriaObj.priorityValue * -1);
	endforeach;
	
	// Persist, update or delete the Criteria.
	
	isCreateDone	:=	false;
	isUpdateDone	:=	false;
	isDeleteDone	:=	false;
	
	foreach cmifObject in pAllTransientCriteriaObj do
		transientObj	:=	cmifObject.CMIF_YACriteriaPriority;
		proxyObj		:=	transientObj.myProxy;
		realCPObj		:=	transientObj.myCriteriaPriority;
		proxyObj.CM_YACriteria.setYardAllocation(self);
		
		// Do "New" first, because the "changed" flag can be set if a new Criteria/Priority
		// is changed after it is added, but before it is saved to the database.
		
		if transientObj.isNew then
			app.myUtilityCA.utlCreateYACriteriaPriority(proxyObj, realCPObj, pPassportObj);
			isCreateDone	:=	true;
			
		elseif transientObj.isChanged then
			app.myUtilityUA.utlUpdateYACriteriaPriority(realCPObj, proxyObj, pPassportObj);
			isUpdateDone	:=	true;
			
		elseif transientObj.isDeleted then
			if realCPObj &lt;&gt; null then
				app.myUtilityDA.utlDeleteYACriteriaPriority(realCPObj, pPassportObj);
			endif;
			isDeleteDone	:=	true;
		else
			// The Criteria/Priority has not been touched, however, we still need to update
			// it because all priority values have been made negative, because they all need
			// to be resequenced for new or deleted Criteris/Priorities.
			app.myUtilityUA.utlUpdateYACriteriaPriority(realCPObj, proxyObj, pPassportObj);
			
		endif;
	endforeach;

	self.recalculateCriteriaPriorities();

	self.validateCriteria();		// SFW1030 18/08/2008
	
	if isCreateDone or isDeleteDone or isUpdateDone then
		self.causeEvent(app.getMyTerminalDO_NOT_USE().getTerminalEvent(EVENT_YA_CP_UPDATE), false, process);
	endif;
	
	// TFS 50889 add into the manually maintained Mark dictionary on terminal
	self.terminalMarkDictAdd();			// TFS 50889
end;</source>
        <Parameter name="pAllTransientCriteriaObj" type="CMIF_Array"/>
        <Parameter name="pPassportObj" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="03e2676b-b64e-4337-9de2-e4ee4be77f6c">
        <source>pxyCreateUpdateProxy(): SelfType;
// --------------------------------------------------------------------------------
// Created:		16 March 2005 by cnwdad1
//
// Purpose:		Deep clone the receiver.  Note that proxies of the receiver's Criteria
//				will not be created, since that will be done using special transient
//				objects.
//
// Parameters:	None
//
// Returns:		A reference to a transient clone of the receiver.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 11/05/2006	cnwdad1		CCMS #1010, now using Block Groups, instead of just Blocks.
// 12/08/2008	Simon Ward	SFW1030 - Allow for YA template properties
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// --------------------------------------------------------------------------------
vars
	proxyYAObj			: SelfType;
	groupObj			: CM_YABlockGroup;
	proxyGroupObj		: CM_YABlockGroup;
	outGroupObj			: CM_YABlockGroup;
	blockObj			: CM_YABlock;
	proxyBlockObj,
	proxyBlockObjIn,
	proxyBlockObjOut	: CM_YABlock;
	groupName			: String;
	completedOK		: Boolean;
	
begin
	if self.isTransient() then
		completedOK := true;			// 20/04/2011 cnwmh5 #27401
		return null;
	endif;
	
	proxyYAObj					:=	inheritMethod();
	proxyYAObj.myTerminal		:=	self.myTerminal;
	proxyYAObj.myYAOverstowRule	:=	self.myYAOverstowRule;
	
	proxyYAObj.myYATemplate		:=	self.myYATemplate;
	
	// First, get the proxy Group objects.
	
	foreach groupObj in self.allYABlockGroupsIn do
		proxyGroupObj	:=	groupObj.pxyCreateUpdateProxy();
		
		// Add the proxy Block Group to the In and Out collections of the proxy YA.
		proxyYAObj.allYABlockGroupsIn.add(proxyGroupObj);
		proxyYAObj.allYABlockGroupsOut.atPut(self.allYABlockGroupsOut.indexOf(groupObj), proxyGroupObj);
	endforeach;
	
	// Now that we have the proxy Groups, get the proxy Block objects, and put them
	// in their respective "IN" and "OUT" Groups.
	
	foreach groupObj in self.allYABlockGroupsIn do
		foreach blockObj in groupObj.allYABlocksIn do
			proxyBlockObj	:=	blockObj.pxyCreateUpdateProxy();
			
			// Add the proxy Block to the "IN" list Group.
			
			groupName		:=	blockObj.myYABlockGroupIn.description;
			proxyGroupObj	:=	proxyYAObj.allYABlockGroupsIn.getGroupByName(groupName);
			proxyGroupObj.allYABlocksIn.atPut(groupObj.allYABlocksIn.indexOf(blockObj), proxyBlockObj);
			
			// Add the proxy Block to the "OUT" list Group.
			
			outGroupObj		:=	blockObj.myYABlockGroupOut;
			groupName		:=	outGroupObj.description;
			proxyGroupObj	:=	proxyYAObj.allYABlockGroupsOut.getGroupByName(groupName);
			proxyGroupObj.allYABlocksOut.atPut(outGroupObj.allYABlocksOut.indexOf(blockObj), proxyBlockObj);
			
			// Finally, add the proxy Block to the ungrouped "IN" and "OUT" lists.
			
			proxyYAObj.allYABlocksIn.add(proxyBlockObj);
			proxyYAObj.allYABlocksOut.add(proxyBlockObj);
		endforeach;
	endforeach;
	
	foreach groupObj in self.allYABlockGroupsIn do
	
		proxyGroupObj := groupObj.pxyGetProxyObject();
		
		if proxyGroupObj = null then
			continue;
		endif;
		
		blockObj := groupObj.myLastYABlockIn;
		
		if blockObj &lt;&gt; null then
			proxyBlockObjIn := blockObj.pxyGetProxyObject();
			proxyGroupObj.setLastYABlock(proxyBlockObjIn, true);
		endif;
		
		blockObj := groupObj.myLastYABlockOut;
		
		if blockObj &lt;&gt; null then
			proxyBlockObjOut := blockObj.pxyGetProxyObject();
		endif;
		
		proxyGroupObj.setLastYABlock(proxyBlockObjOut, false);
		
	endforeach;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyYAObj;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyYAObj;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="recalculateCriteriaPriorities" id="7d31161c-f3f3-46df-b0c0-14e820ffef0d">
        <updating/>
        <source>recalculateCriteriaPriorities() updating;
// --------------------------------------------------------------------------------
// Created:		09 May 2005 by cnwdad1
//
// Purpose:		Recalculates the priority value for all of the receiver's Criteria,
//				and updates the total on the receiver.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	criteriaObj			: CM_YACriteria;
	allCriteriaSetObj	: CM_YACriteriaSet;
	priorityTotal		: Real;
	
begin
	create allCriteriaSetObj transient;
	self.allCriteria.copy(allCriteriaSetObj);
	priorityTotal	:=	0;
	
	foreach criteriaObj in allCriteriaSetObj do
		priorityTotal	:=	priorityTotal + criteriaObj.calculatePriority();
	endforeach;
	
	// Adjusts priority by adjustment if necessary.
	self.setPriorityValue(priorityTotal);
epilog
	delete allCriteriaSetObj;
end;</source>
    </JadeMethod>
    <JadeMethod name="resetAllCriteria" id="be815568-e8ee-4835-baba-c3621ea91174">
        <updating/>
        <source>resetAllCriteria() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 December 2009	cnwas3	Initial creation

*/

vars
	returnValue	: String;
	yacObj		: CM_YACriteria;
	
begin
	on Exception do self.xInvalidObjectDisplayHandler(exception);
	
	foreach yacObj in self.allCriteria do
		yacObj.myYAData.setValue(null);
	endforeach;
	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="searchAlternating" id="cc6b9b6f-8e04-4fbe-a131-49660b945296">
        <source>searchAlternating(_yaAgent : CM_YAAutoplanAgent input; 
					_isIn : Boolean;
					_terminalArea : CM_TerminalArea) : Boolean protected;
// -------------------------------------------
// Created 05 April 2005 by cnwdvb1
// -------------------------------------------
vars

	isFound,
	doUpdate			: Boolean;
	block				: CM_YABlock;
	yardAllocation		: CM_YardAllocation;
	toBeSearchedArray	: CM_YABlockArray;
	yaBlockGroup		: CM_YABlockGroup;
	

begin

	yardAllocation := self;
	
	doUpdate := _yaAgent.agentUsage = CM_YAAutoplanAgent.Normal_Usage;

	create toBeSearchedArray transient;	
	
	if _isIn then
		yaBlockGroup := self.allYABlockGroupsIn.first;
		if yaBlockGroup &lt;&gt; null then
			return yaBlockGroup.searchAlternating(_yaAgent, _isIn,_terminalArea);
		endif;
	else
		foreach block in self.allYABlocksOut discreteLock do
			//epr par 35377 22/12/14 
			if _terminalArea &lt;&gt; null and block.myTerminalArea &lt;&gt; _terminalArea then
				continue;
			endif;
			
			if 	self.myLastYABlockOut = null then
				_yaAgent.addLogEntry(AP_Log_YA_Default,'No information about last move', false);
				if block.searchForLocationOut(_yaAgent) then
					if doUpdate then
						self.updateLastYABlock(yardAllocation, block, false);
					endif;
					return true;
				endif;
			elseif not isFound and self.myLastYABlockOut = block then
				toBeSearchedArray.add(block);
				isFound := true;
				continue;
			elseif isFound then
				_yaAgent.addLogEntry(AP_Log_YA_Default,'Last block used was ' &amp; self.myLastYABlockOut.getListDisplay(), false);
				if block.searchForLocationOut(_yaAgent) then
					if doUpdate then
						self.updateLastYABlock(yardAllocation, block, false);
					endif;
					return true;
				endif;
			else
				toBeSearchedArray.add(block);
			endif;	
		endforeach;
		
		// If we get here then we need to search passed over ones.
		foreach block in toBeSearchedArray do
			if block.searchForLocationOut(_yaAgent) then
				if doUpdate then
					self.updateLastYABlock(yardAllocation, block, false);
				endif;
				return true;
			endif;
		endforeach;
	endif;

	return false;

epilog
	delete toBeSearchedArray;
end;</source>
        <access>protected</access>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <Parameter name="_isIn" type="Boolean"/>
        <Parameter name="_terminalArea" type="CM_TerminalArea"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="searchBestPickOut" id="98bd1c4d-003a-418c-a925-04f9384ea4cf">
        <source>searchBestPickOut(	_yaAgent : CM_YAAutoplanAgent input;
					_terminalArea : CM_TerminalArea) : Boolean protected;
// 25/02/2010	cnwjre1	CCMS 1101 add best-pick to yard allocations
vars
	block			: CM_YABlock;
begin
	// Clear working sets outside the loop here
	_yaAgent.myCurrentCMIFYAAutoPlan.allPassedLocations.clear();
	_yaAgent.myCurrentCMIFYAAutoPlan.allFailedLocations.clear();
	_yaAgent.myCurrentCMIFYAAutoPlan.allPassedLocationsRestricted.clear(); //cnwrd1 par 29269 14.3.2012
	_yaAgent.allLCsToIgnore.copy(_yaAgent.myCurrentCMIFYAAutoPlan.allFailedLocations);
	_yaAgent.fillOptionOut := self.fillOptionOut;

	foreach block in allYABlocksOut discreteLock do
		//epr par 35377 22/12/14 
			if _terminalArea &lt;&gt; null and block.myTerminalArea &lt;&gt; _terminalArea then
				continue;
			endif;
		if block.searchForLocationsBestPick(_yaAgent) then
			return true;
		endif;
	endforeach;
	// no non-overstowed matches have been found, then if a least-overstowed item is on the agent, use that instead
	if _yaAgent.bestPickOverstowedTI &lt;&gt; null then
		_yaAgent.addLocationToAgent(_yaAgent.bestPickOverstowedTI.allLocations.first, CM_YAAutoplanAgent.Locations_Found);
		_yaAgent.myCurrentCMIFYAAutoPlan.allFoundTis.add(_yaAgent.bestPickOverstowedTI);
		_yaAgent.myCurrentCMIFYAAutoPlan.allKeepTrackedTis.add(_yaAgent.bestPickOverstowedTI);
		_yaAgent.addLogEntry(AP_Log_YA_Default,'Located least-overstowed item (' &amp; _yaAgent.bestPickOverstowedTI.id &amp; ') overstow=' &amp;
					_yaAgent.lastOverstowLevel.String, true);
		return true;
	endif;
	
	return false;
epilog
	_yaAgent.fillOptionOut := 0;
end;</source>
        <access>protected</access>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <Parameter name="_terminalArea" type="CM_TerminalArea"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="searchClosestOverstowLCIn" id="13825224-d6cf-4910-b34c-1d08a250ed8a">
        <source>searchClosestOverstowLCIn(_yaAgent : CM_YAAutoplanAgent input) : Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 January 2010	cnwer1	Initial creation

*/

vars
	ti 			: CM_TrackedItem;
	theLC 			: CM_LocationsController;
	yaBlock		: CM_YABlock;
	otherYABlocks : CM_YABlockArray;
begin
	// need to get the YA_Blocks that the grid Controllers are in first and test those ones
	create otherYABlocks transient;
	ti:=_yaAgent.myCurrentCMIFYAAutoPlan.getMyTrackedItem;
	theLC:=ti.myPrimaryActualLocation;
	foreach yaBlock in self.allYABlocksIn  discreteLock do
		//search yard allocations the overstowed ti is in first
		if not yaBlock.allYardControllers.includes(theLC.CM_YardController) then
			otherYABlocks.add(yaBlock);
			continue;
		endif;
		if yaBlock.searchClosestOverstowLCIn(_yaAgent,null,REAL_MODE) then
			return true;
		endif;
	endforeach;
	
	//test all other YA blocks
	foreach yaBlock in otherYABlocks discreteLock do
		if yaBlock.searchClosestOverstowLCIn(_yaAgent,null,REAL_MODE) then
			return true;
		endif;
	endforeach;
	

	return false;
epilog
	delete otherYABlocks;
end;</source>
        <access>protected</access>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="searchFIFOIn" id="cc33791c-7492-4a60-b2bf-6dc4108b404f">
        <source>searchFIFOIn(_yaAgent : CM_YAAutoplanAgent input;
			_terminalArea : CM_TerminalArea	) : Boolean protected;
// -------------------------------------------
// Created 29 March 2005 by cnwdvb1
// -------------------------------------------
//21 Jun 25	jlier1 JIRA-13860 
vars

	terminalArea	: CM_TerminalArea;
	sorterIn		: CM_YABlockSorterIn;
	block			: CM_YABlock;
	fifoDate		: Date;
	noFIFODate 		: CM_YABlockArray;
	iter : Iterator;
begin

	create sorterIn transient;
	create noFIFODate transient;
	

	foreach block in self.allYABlocksIn discreteLock do
		fifoDate := block.getFifo(true);
		_yaAgent.addLogEntry(AP_Log_YA_Default,'FIFO area ' &amp; block.getYAMDisplay(false) &amp;  ' FIFO date ' &amp; fifoDate.asStringJMT, false);
		if fifoDate &lt;&gt; null then
			sorterIn.putAtKey(fifoDate, block);
		else
			noFIFODate.add(block);
		endif;
	endforeach;
	
	if sorterIn.isEmpty then
		//no cargo in any locations 
		iter:=self.allYABlocksIn.createIterator;
		noFIFODate.clear; //will be the same don't need to do again
	else
		iter:=sorterIn.createIterator;
	endif;
	
	while iter.next(block) do
		//epr par 35377 22/12/14 
		if _terminalArea &lt;&gt; null and block.myTerminalArea &lt;&gt; _terminalArea then
			continue;
		endif;
		if block.searchForLocationIn(_yaAgent) then
			return true;
		endif;
	endwhile;
	
	//blocks with no cargo just do in array order 
	foreach block in noFIFODate discreteLock do
		if _terminalArea &lt;&gt; null and block.myTerminalArea &lt;&gt; _terminalArea then
			continue;
		endif;
		if block.searchForLocationIn(_yaAgent) then
			return true;
		endif;
	
	endforeach;
	
	return false;				
	
epilog
	delete sorterIn;
	delete iter;
	delete noFIFODate;
	if terminalArea &lt;&gt; null then
		self.unlock(terminalArea);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <Parameter name="_terminalArea" type="CM_TerminalArea"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="searchFIFOOut" id="057d6e7b-8aaf-41c7-b1e7-3ed5a466376f">
        <source>searchFIFOOut(	_yaAgent : CM_YAAutoplanAgent input;
				_terminalArea : CM_TerminalArea) : Boolean protected;
// -------------------------------------------
// Created 29 March 2005 by cnwdvb1
// -------------------------------------------
//21 Jun 25	jlier1 JIRA-13860 
vars

	terminalArea	: CM_TerminalArea;
	sorterOut		: CM_YABlockSorterOut;
	block			: CM_YABlock;
	fifoDate		: Date;
	iter : Iterator;
begin

	create sorterOut transient;
		
	foreach block in self.allYABlocksOut discreteLock do
		fifoDate := block.getFifo(false);
		_yaAgent.addLogEntry(AP_Log_YA_Default,'FIFO area ' &amp; block.getYAMDisplay(false) &amp;  ' FIFO date ' &amp; fifoDate.asStringJMT, false);
		if fifoDate &lt;&gt; null then
			sorterOut.putAtKey(fifoDate, block);
		endif;
	endforeach;
	
	if sorterOut.isEmpty then
		//no cargo in any locations hence no fifo date
		return false;
	else
		iter:=sorterOut.createIterator;
	endif;
	
	while iter.next(block) do
		//epr par 35377 22/12/14 
		if _terminalArea &lt;&gt; null and block.myTerminalArea &lt;&gt; _terminalArea then
			continue;
		endif;
		if block.searchForLocationOut(_yaAgent)  then
			return true;
		endif;
	endwhile;
	
	return false;				
	
epilog
	delete sorterOut;
	delete iter;
	if terminalArea &lt;&gt; null then
		self.unlock(terminalArea);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <Parameter name="_terminalArea" type="CM_TerminalArea"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="searchFillInOrder" id="934e4619-ea7a-41d6-841b-434c1f19beaa">
        <source>searchFillInOrder(_yaAgent : CM_YAAutoplanAgent input; 
					_isIn : Boolean;
					_terminalArea : CM_TerminalArea	) : Boolean protected;
// -------------------------------------------
// Created 05 April 2005 by cnwdvb1
// -------------------------------------------
vars

	block			: CM_YABlock;

begin

	if _isIn then
		foreach block in allYABlocksIn discreteLock do
			//epr par 35377 22/12/14 
			if _terminalArea &lt;&gt; null and block.myTerminalArea &lt;&gt; _terminalArea then
				continue;
			endif;
			if block.searchForLocationIn(_yaAgent) then
				return true;
			endif;
		endforeach;
	else
		foreach block in allYABlocksOut discreteLock do
			//epr par 35377 22/12/14 
			if _terminalArea &lt;&gt; null and block.myTerminalArea &lt;&gt; _terminalArea then
				continue;
			endif;
			if block.searchForLocationOut(_yaAgent)  then
				return true;
			endif;
		endforeach;
	endif;

	return false;

end;</source>
        <access>protected</access>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <Parameter name="_isIn" type="Boolean"/>
        <Parameter name="_terminalArea" type="CM_TerminalArea"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="searchLocationsIn" id="454b36bb-5ff8-499e-9db0-7319e9ddf5c1">
        <source>searchLocationsIn(_yaAgent : CM_YAAutoplanAgent input;
					_terminalArea : CM_TerminalArea) : Boolean;
// -------------------------------------------
// Created 18 March 2005 by cnwdvb1
// -------------------------------------------
vars

begin
	//epr CCMS 1025 20/1/10
	if _yaAgent.isFindOverstowLocation then
		return self.searchClosestOverstowLCIn(_yaAgent) ;
	endif;

	if self.fillOptionIn  = YAFillOption_InOrder then 
		_yaAgent.addLogEntry(AP_Log_YA_Default,'Fill option (In order)', false);
		return self.searchFillInOrder(_yaAgent, true,_terminalArea);
	endif;
	
	if self.fillOptionIn = YAFillOption_FIFO then
		_yaAgent.addLogEntry(AP_Log_YA_Default,'Fill option (FIFO)', false);
		return self.searchFIFOIn(_yaAgent,_terminalArea);
	endif;
	
	if self.fillOptionIn = YAFillOption_Alternating then
		_yaAgent.addLogEntry(AP_Log_YA_Default,'Fill option (Alternating)', false);
		return self.searchAlternating(_yaAgent, true,_terminalArea);
	endif;

	return false;


end;</source>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <Parameter name="_terminalArea" type="CM_TerminalArea"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="searchLocationsOut" id="d8904ada-d7de-45d7-9f80-f5c5d4137944">
        <source>searchLocationsOut(_yaAgent : CM_YAAutoplanAgent input;
					_terminalArea : CM_TerminalArea) : Boolean;
// -------------------------------------------
// Created 18 March 2005 by cnwdvb1
// -------------------------------------------
// 22/12/14 cnwer1 PAR 35377 
vars


begin
	// CCMS 1101 - should be using out fill option
	 if self.fillOptionOut  = YAFillOption_InOrder  or 
	 _yaAgent.agentUsage = CM_YAAutoplanAgent.Scenario or
	 _yaAgent.agentUsage = CM_YAAutoplanAgent.Scenario_Verbose then
	 	_yaAgent.addLogEntry(AP_Log_YA_Default,'Fill option (Out order)', false);
		return self.searchFillInOrder(_yaAgent, false,_terminalArea);
	endif;

	if self.fillOptionOut  = YAFillOption_FIFO then
		_yaAgent.addLogEntry(AP_Log_YA_Default,'Fill option (FIFO)', false);
		return self.searchFIFOOut(_yaAgent,_terminalArea);
	endif;
	
	if self.fillOptionOut  = YAFillOption_Alternating then
		_yaAgent.addLogEntry(AP_Log_YA_Default,'Fill option (Alternating)', false);
		return self.searchAlternating(_yaAgent, false,_terminalArea);
	endif;
	
	// 25/02/2010	cnwjre1	CCMS 1101 add best-pick to yard allocations
	if self.fillOptionOut = YAFillOption_BestPick then
		_yaAgent.addLogEntry(AP_Log_YA_Default,'Fill option (Best Pick)', false);
		return self.searchBestPickOut(_yaAgent,_terminalArea);
	endif;

	return false;

end;</source>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <Parameter name="_terminalArea" type="CM_TerminalArea"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setAllowMultiRangeSplit" id="a72ea0fc-80e7-455c-9733-7cdf02a232f7">
        <updating/>
        <source>setAllowMultiRangeSplit( _allowMultiRangeSplit : Integer ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 June 2016	cnwndl1	Initial creation	TFS 2172

*/

vars

begin

	self.allowMultiRangeSplit := _allowMultiRangeSplit;

epilog

end;</source>
        <Parameter name="_allowMultiRangeSplit" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setCargoMinMaxFromProjectedGC" id="4c7a4a3d-dea0-4e69-9c81-c6e02d88e8c0">
        <source>setCargoMinMaxFromProjectedGC();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 March 2021	navndl1	Initial creation	TFS 49912

*/

vars

	cargoType : CM_CargoType;
	product : CM_Product;
	gcAllocRowArea : CM_GeneralCargoAllocRowArea;
	rowController : CM_RowController;
	groupRowController : CM_GeneralCargoAllocGroup;

begin

	cargoType := self.getCargotype;
	product := self.getCargoSubtype;
	
	if cargoType = null then
		return;
	endif;
	
	if not self.isForGenCargoAllocationRow then
		return;
	else
		gcAllocRowArea := self.allTerminalAreas.first.CM_GeneralCargoAllocRowArea;
	endif;
	
	//find the 'Group Row Controllers' that the allocation covers. 
	foreach rowController in gcAllocRowArea.allRowControllersById do
		groupRowController := rowController.CM_GeneralCargoAllocGroup;
		if groupRowController.isCoveredBy( self ) then
			groupRowController.updateCargoProdMinMax( cargoType, product, self.projectedGC );
		endif;
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setCargoSubtypeForSummary" id="815afbee-b3a5-4e6b-a65c-7a18880a5858">
        <updating/>
        <source>setCargoSubtypeForSummary(_code : String) updating;
// ---------------------------------------------------------------------------
// Created:     18 February 2010 by cnwab1
//
//		In the XML we are not sure of the order of the property types and values. IF the XML includes cargo sub type we must have the cargo type.
//		So if the cargo subtype is in the XML before the cargo sub type then after we have created everything see if we can get the cargo type from the YA.
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	parser	:JadeXMLDocumentParser;
	xmlDoc	:JadeXMLDocument;
	element, nameElement, valueElement, jadePropertyElement	:JadeXMLElement;
	xmlNode	:JadeXMLNode;
	strProperty, strValue, prodCode	:String;
	includesCargoSubtype : Boolean;
	cargoTy : CM_CargoType;
	criteria : CM_YACriteria;
	prod : CM_Product;
	objSet : ObjectSet;
begin
	if _code = null then
		return;
	endif;
	// should have a PRODUCT YA criteria setup, have we?
	criteria := self.getCriteriaOfType(app.myRoot.allYACriteriaTypes[YACriteriaType_Product]);
	if criteria = null then
		// No we do not, did we create a cargo type YA criteria?
		criteria := self.getCriteriaOfType(app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType]);
		if criteria = null then
			return;
		endif;
		// So we haev a cargo type, and need to set the cargo subtype
		if not criteria.myYAData.isKindOf(CM_YADataObjects) then
			return;
		endif;
		cargoTy := criteria.myYAData.CM_YADataObjects.allObjects.first.CM_CargoType;
		if cargoTy = null then
			return;
		endif;
		// Got the cargo type setup the sub cargo type
		prod := cargoTy.getProductFromCode(prodCode);
		if prod &lt;&gt; null then
			create objSet transient;
			objSet.add(prod );
			criteria := self.createCriteria(objSet, YACriteriaType_Product);
			if criteria &lt;&gt; null then
				criteria.setYardAllocation(self);
			endif;
		endif;
	endif;
		
epilog
	delete objSet;
end;</source>
        <Parameter name="_code" type="String"/>
    </JadeMethod>
    <JadeMethod name="setCode" id="d1680edf-0bee-42dd-914a-d46bc78b6476">
