<Class name="SMobileServerSchema" id="a70b82a9-5421-4394-9035-492c623df702">
    <superclass name="CMSWebSession"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="_environ"/>
    <PrimAttribute name="clientMachineName" id="2d92090a-9d22-4b85-9cd8-3252cb5d87d9">
        <length>129</length>
        <embedded/>
        <type name="String"/>
        <access>protected</access>
    </PrimAttribute>
    <PrimAttribute name="clientPortNumber" id="2cbd1ebf-fd8d-4356-aaa3-ec927a59ca0b">
        <embedded/>
        <type name="Integer"/>
        <access>protected</access>
    </PrimAttribute>
    <ImplicitInverseRef name="myUser" id="13c5df76-2eac-49b8-a42f-442797d1819c">
        <embedded/>
        <type name="CM_User"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ExplicitInverseRef name="myWebServerAgent" id="122ec939-dfed-453c-b9b8-4efbae887df3">
        <kind>parent</kind>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="RadioTelemetryWebServerAgent"/>
        <access>readonly</access>
        <Inverse name="RadioTelemetryWebServerAgent::myCurrentSession"/>
    </ExplicitInverseRef>
    <JadeMethod name="reply" id="63fa79ca-0d4c-4e8c-ae2f-0f9329d6485b">
        <updating/>
        <source>reply(html: String) updating;
// -------------------------------------------
// Created 09 March 2006 by cnwdvb1
// -------------------------------------------
vars

begin

app.msgBox(html, 'Returning', 0);
	inheritMethod(html);


end;</source>
        <Parameter name="html" type="String"/>
    </JadeMethod>
    <JadeMethod name="setClientConnectionDetails" id="2f23d810-30d2-45fc-b652-e94c63d10f2a">
        <updating/>
        <source>setClientConnectionDetails(_clientMachine, _portNumber : String; _webServerAgent : RadioTelemetryWebServerAgent) updating;
// --------------------------------------------------------------------------------
// Created:		10 October 2005 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	
begin
		
	self.clientMachineName	:= _clientMachine;
	self.clientPortNumber	:= _portNumber.Integer;
	self.myWebServerAgent	:= _webServerAgent;
	
end;</source>
        <Parameter name="_clientMachine" type="String"/>
        <Parameter name="_portNumber" type="String"/>
        <Parameter name="_webServerAgent" type="RadioTelemetryWebServerAgent"/>
    </JadeMethod>
    <JadeMethod name="setUser" id="eb73fc09-8332-44a8-9ca4-281fae26073d">
        <updating/>
        <source>setUser(_user : CM_User) updating;
// --------------------------------------------------------------------------------
// Created:		10 October 2005 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	beginTransaction;
	self.myUser	:= _user;
	commitTransaction;
end;</source>
        <Parameter name="_user" type="CM_User"/>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="69cbdd7e-5718-4ea2-9c44-00316bcd1c20">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;
// --------------------------------------------------------------------------------
// Created:		10 October 2005 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if eventTag = 1001 then

		app.sendHeyYouMessage(self.clientMachineName, self.clientPortNumber, 'Hey You');
		return;
	endif;
	
	inheritMethod(eventTag);
end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
</Class>
