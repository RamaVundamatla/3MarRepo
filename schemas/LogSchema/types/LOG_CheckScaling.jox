    <JadeMethod name="translateForm" id="599a2de0-cdd8-40a5-bc9a-b59a45e18296">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0006307, locale);
	btnCancelDtl.translateCaption(Xlat_0002333, locale);
	btnCreateData.translateCaption(Xlat_0002334, locale);
	btnDeleteDetail.translateCaption(Xlat_0002331, locale);
	btnDeleteHeader.translateCaption(Xlat_0002332, locale);
	btnEditDetail.translateCaption(Xlat_0002335, locale);
	btnPrint.translateCaption(Xlat_0002336, locale);
	btnPrintScaler.translateCaption(Xlat_0002337, locale);
	btnSaveDtl.translateCaption(Xlat_0002338, locale);
	btnSetCheckScale.translateCaption(Xlat_0002330, locale);
	lblEntDetail.translateCaption(Xlat_0002339, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="zShowThumbnailData" id="35bc3399-2a7c-4c9c-a37e-512335f8ec6c">
        <lockReceiver/>
        <updating/>
        <source>zShowThumbnailData(obj: Object) updating, protected, lockReceiver;
// ---------------------------------------------------------------------------
// Created:     14 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	if obj = null then
		self.myCurrentObject := null;
		self.clearThumbnailData();
	else
		on Exception do zShowThumbnailDataExHandler(exception);
		if obj &lt;&gt; self.myProxyObject then
			self.myCurrentObject := obj;
		endif;
		self.showThumbnailData(obj);
	endif;

	self.myCurrentScaleDtl := null;

end;</source>
        <access>protected</access>
        <Parameter name="obj" type="Object"/>
    </JadeMethod>
</GUIClass>
