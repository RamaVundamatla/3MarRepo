    <JadeMethod name="getAuditText" id="aec01f44-8755-4363-ba6f-886ce7430612">
        <source>getAuditText(): String;
// ---------------------------------------------------------------------------
// Created:     19 April 2007 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	txt		: String;
	tmpStr	: String;
	cargoTyp	: CM_CargoType;
	terminalType :CM_TerminalAreaType;
begin
	txt[10000] := '*';
	txt := null;
	txt := inheritMethod();

	foreach cargoTyp in self.allAllowedCargoTypes do
		if tmpStr = null then
			tmpStr := cargoTyp.abbreviation;
		else
			tmpStr := tmpStr &amp; ', ' &amp; cargoTyp.abbreviation;
		endif;
	endforeach;
	txt := txt &amp; 'Cargo Types selected ' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;	
	tmpStr:=null;
	foreach terminalType in self.allAllowedTATypes do
		if tmpStr = null then
			tmpStr := terminalType.description;
		else
			tmpStr := tmpStr &amp; ', ' &amp; terminalType.description;
		endif;
	endforeach;
	
	txt := txt &amp; 'Terminal Area Types selected' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	
	return txt;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="6edd0f56-a2cc-4c96-9dd5-435e69b943b9">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//-----------------------------------------------------------------------
//
//  Created by: cnwsh3
//
//	Date: 23 September 2003
//
//-----------------------------------------------------------------------

vars

begin
	if _attrName = ETRow_Code then
		return self.type.String;
	endif;
	return inheritMethod(_attrName, _short);
	
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="hasMachineLiftType" id="6d16665f-d6de-4ef4-929d-14787c04bbdc">
        <source>hasMachineLiftType() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 August 2009	cnwer1	Initial creation

*/

vars

begin
	// PAR #25854 - add in all machine types
	
	if self.type = MACHINETYPE_FORK_LIFT or
		self.type = MACHINETYPE_PORTAINER_CRANE or
		self.type = MACHINETYPE_RMG or
		self.type = MACHINETYPE_RTG or
		self.type = MACHINETYPE_SIDE_LOADER or
		self.type = MACHINETYPE_STRADDLE or
		self.type = MACHINETYPE_TOP_LIFT or
		self.type = MACHINETYPE_RMG 
		then
		return true;
	else
		return false;
	endif;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isForkLift" id="743512ff-4624-42a1-83c4-20c4ebe1cbaf">
