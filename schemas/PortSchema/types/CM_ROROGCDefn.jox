    <JadeMethod name="getEDITypeCode" id="54e5a56f-6780-4907-b2ec-8ad67ed9b63a">
        <source>getEDITypeCode(): Character;
//
// 16 Jan 2012	cnwrs1 MSL CCMS 1009 Par29024
// 31/08/2012	cnwmh5 #30287 - Change from "G" to "S"
//
vars

begin
	return 'S';
end;
