        <source>resetTblInput1(_isOperator : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     16 August 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
vars

