    <JadeMethod name="drawTI" id="74f89d70-bf0f-45c4-90d1-8880b6aed706">
        <updating/>
        <source>drawTI(_theTI : CM_TrackedItem; _theGridAttributes : CMUI_GridAttributes input;
	  	_x1, _y1, _x2, _y2 : Real;
	  	_frame : CMUI_GridAreaDrawingFrame input; _lc : CM_LocationsController) updating, protected;
// ---------------------------------------------------------------------------
// Created:		September  2002 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
// ---- WHO --- WHEN ----- WHY---------------------------------------------
// ---------------------------------------------------------------------------
//  AKB    		19MAY2008   PAR 16415 CCMS 1029 30,45,53s
//  consw1		03Dec2008   SFW1030 - Yard Allocation enhancements (include extra info with zoom)
//	AKB			16MAR2009	PAR 18982 -  771 testing flipp @ zoom 3 drew ISO in wrong place.
// 	jlgdap1		11NOV2019	TFS 46405 AAT Flat Rack and OOG in LOLO Planning Screen
// ---------------------------------------------------------------------------
vars
	lOuterColourUpper, 
	lOuterColourLower,
	lTIColour,
	lWeight,
	theCharacterWidth : Integer;
	tm_x2, tm_x1, tm_y1, tm_y2	: Real;
	lDisplayMode,
	lViewMode, 
	selOffSet, 
	halfOffset, 
	theFontSize : Integer;
	numLCs,
	lFactor : Real;
	theFrame: CMUI_GridAreaDrawingFrame;
	endX, startX : Real;
	tmpInverseColour,
	tmpHeight	: Integer;
	theISOCode : String;
	theTempString : String;
	theJN : String;
	autoMasked : Boolean;
	isDragging : Boolean; // PAR 19505 NEW
	tmpFM : CM_FutureMove;
	highlightcolour, highlightcolouredge  : Integer;
begin
	
	if self.displayMode = DISPLAY_MODE_PLAN then // PAR 19600
		tmpFM := _theTI.getFMforLC(self.myLocationsController, PLANNING_MODE);
	elseif self.displayMode = DISPLAY_MODE_QUEUE then // PAR 19600
		tmpFM := _theTI.getFMforLC(self.myLocationsController, QUEUE_MODE);
	endif;

	theFrame 	:= _frame;
	isDragging := app.isDragging; // PAR 19505 NEW

	lFactor 	:= self.scaleFactor;
	lDisplayMode := self.displayMode;
	lViewMode 	:= self.viewMode;
	theFrame.drawFontName := "Arial";
	theFontSize := (self.FontSize * lFactor).Integer;

	lWeight := (_theTI.totalWeight  / 1000).rounded();

	// ###################
	// ### HOW Big is the TI ?
	// ###################
	tm_y1 := _y1  + 1;
	tm_x1 := _x1;
	tm_y2 := _y2;
	tm_x2 := _x2;

	autoMasked := self.getAutoMasked(); // PAR 19505
	
	if self.flipHorizontal then // PAR 18982
		if (isDragging and autoMasked) then // PAR 19505 do not re adjust for autoMask as the Xs are correct  // PAR 19505 NEW
			startX := _x1; // PAR 18982
			endX := _x2; // PAR 18982
		else // PAR 19505 NEW
			startX := _x2; // PAR 18982
			endX := _x1; // PAR 18982
		endif;
	else
		startX := _x1; // PAR 18982
		endX := _x2; // PAR 18982
	endif;
	
	endX := endX - 5;  // Leave room for the selection rectangle;
//	numLCs := self.adjustCargoX2(_theTI,tm_x1,tm_x2); // PAR 16415 CCMS 1029
	numLCs := 1;

	// ###################
	// ### WHat is the TIs colour?	
	// ###################

	if _theTI.isKindOf(CM_Tower) then
		lTIColour := 33023; // ORANGE
	else
		lTIColour := self.getFillColourForTI(_theTI);
	endif;

	if lTIColour = NullColour then
		lTIColour := White;
	endif;
	// if they have used the selector this will not be empty. If this TI is not in the selector collection then show in White
	if self.useSelectorObjects then
		if (not self.allSelectorTIs.includes(_theTI)) then	
			lTIColour := White;
		endif;
	endif;

	if ( self.allSelectedObjects.includes(_theTI) 
		or (tmpFM &lt;&gt; null and self.allSelectedObjects.includes(tmpFM)) ) // PAR 19600
	and self.myHighlighter = null then
			highlightcolouredge := White;
			
			if process.isJLGAB1() then  // ### TFS 50421 05NOV2021 NAVAB1
				tm_x2 := tm_x2 - 1;
				tm_y2 := tm_y2 - 1;
				highlightcolouredge := lTIColour;
			endif;
			theFrame.drawFillColor := White;
			
			theFrame.drawFilledRectangle(tm_x1, tm_y1, tm_x2, tm_y2,highlightcolouredge  ); 
			if lFactor = ScaleFactor_1 then
				selOffSet := 2;
			elseif lFactor = ScaleFactor_4 then
				selOffSet := 4;
			else
				selOffSet := 3;
			endif;
			
			if self.flipHorizontal  then// PAR 19505 NEW
				if (isDragging and autoMasked) then // PAR 19505 // PAR 19505 NEW
					tm_x1 := tm_x1 + selOffSet;
					tm_y1 := tm_y1 + selOffSet;
					tm_x2 := tm_x2 - selOffSet;
					tm_y2 := tm_y2 - selOffSet;
				else// PAR 19505 NEW
					tm_x1 := tm_x1 - selOffSet + 1;
					tm_y1 := tm_y1 + selOffSet;
					tm_x2 := tm_x2 + selOffSet;
					tm_y2 := tm_y2 - selOffSet;
				endif;
			else
				tm_x1 := tm_x1 + selOffSet;
				tm_y1 := tm_y1 + selOffSet;
				tm_x2 := tm_x2 - selOffSet;
				tm_y2 := tm_y2 - selOffSet;
			endif;
			
			lOuterColourUpper := DarkGray;
			lOuterColourLower := White;
			theFrame.drawWidth := 1;
			theFrame.drawStyle := Frame.DrawStyle_Solid; //DrawStyle_Dash;
	
			theFrame.drawFillColor := lTIColour;
			theFrame.drawFillStyle := Frame.DrawFillStyle_Solid;
			theFrame.drawFilledRectangle(tm_x1, tm_y1, tm_x2, tm_y2,  lTIColour); 
	else
		if process.isJLGAB1() then  // ### TFS 50421 05NOV2021 NAVAB1
			lOuterColourUpper := lTIColour;
			lOuterColourLower := lTIColour;
			tm_x1 := tm_x1 + 2;
			tm_x2:= tm_x2 - 2;
			tm_y2:= tm_y2 - 2;
		else
			lOuterColourUpper := White;
			lOuterColourLower := DarkGray;
		endif;
		theFrame.drawWidth := 1;
		theFrame.drawStyle := Frame.DrawStyle_Solid;
		theFrame.drawFillColor := lTIColour;
		theFrame.drawFillStyle := Frame.DrawFillStyle_Solid;
		theFrame.drawFilledRectangle(tm_x1, tm_y1, tm_x2, tm_y2,  lTIColour); 
		
		self.drawTIBox(theFrame,lOuterColourUpper,lOuterColourLower,tm_x1.Integer, tm_y1.Integer, tm_x2.Integer, tm_y2.Integer);
	endif;

	tmpInverseColour := lTIColour.getInverseColour();

	theFrame.drawWidth := 1;
	
	
	// work out the width of the rectangle and split up, to get 
	// the even width for the attribute characters
	theCharacterWidth := (((tm_x2 - tm_x1) / (3 * numLCs)).Integer);

	tm_x1 := tm_x1 + (theCharacterWidth / 2).Integer;
	tmpHeight := _theTI.getHeightOfTI();

	if tmpHeight = Ti_Half_Height then
		if lFactor = ScaleFactor_2 then
			theFontSize := theFontSize - 2;
			halfOffset := 2;
		elseif lFactor = ScaleFactor_3 then
			theFontSize := theFontSize - 5;
			halfOffset := 0;
		elseif lFactor = ScaleFactor_4 then
			theFontSize := theFontSize - 5;
			halfOffset := 5;
		elseif lFactor = ScaleFactor_1_5 then
			halfOffset := 5;
		elseif lFactor = ScaleFactor_1 then
			halfOffset := 1;
		endif;

		tm_y1 := _y2 + halfOffset;
	else
		tm_y1 := _y2;

		if lFactor &gt; ScaleFactor_2 then
			theFrame.drawFontSize := 8;
			if lFactor = ScaleFactor_6 then
				theFrame.drawFontSize := 10;
			elseif lFactor = ScaleFactor_9 then
				theFrame.drawFontSize := 14;
			endif;
		
			theFrame.drawTextAlign := Frame.DrawTextAlign_Left;
			theJN := self.getTILoadJobNumber(_theTI); // PAR 33336
			if _theTI.getPrimaryLocation(QUEUE_MODE) = null and theJN &lt;&gt; null then
				theFrame.drawTextAt(theJN &amp; "/" &amp; _theTI.loadSeqNumber, startX + 4, _y1 + 3, tmpInverseColour);
			else
				if self.viewMode = VIEW_ISOGROUP then
					theISOCode := _theTI.isoTypeGroup;
				else
					theISOCode := _theTI.getISOType();
				endif;
				theFrame.drawTextAt(theISOCode &amp; "   " &amp; _theTI.operatorCode, startX + 4, _y1 + 3, tmpInverseColour); // PAR 18982
			endif;
			if _theTI.getLengthInUnits() = 4 then
				if CM_Container.hasInstance(_theTI) and _theTI.CM_Container.getTemperature &lt;&gt; NULL_TEMPERATURE then
					if _theTI.myOperator.displayTempFahrenheit then
						theTempString := _theTI.getDisplayTemperature(false, false);
					else
						theTempString := _theTI.getDisplayTemperature(false, true); 
					endif;
				endif;
				theFrame.drawTextAlign := Frame.DrawTextAlign_Right;
				if theTempString = null then
					theFrame.drawTextAt(_theTI.commodityGroup, endX, _y1 + 3, tmpInverseColour);
				else
					theFrame.drawTextAt(_theTI.commodity &amp; "   " &amp; theTempString, endX, _y1 + 3, tmpInverseColour);
				endif;
				theFrame.drawTextAlign := Frame.DrawTextAlign_Left;
			endif;
		endif;

		if lFactor &gt; ScaleFactor_3 then
			theFrame.drawTextAt(_theTI.id, startX + 4, _y1 + 18, tmpInverseColour);
		endif;
		if  lFactor = ScaleFactor_4 then //lFactor = ScaleFactor_3 or //epr par 37115 20/11/15 at scale 3 it draws under the weight so removed
			if _theTI.getLengthInUnits = 4 then
				theFrame.drawTextAlign := Frame.DrawTextAlign_Right;
				theFrame.drawTextAt(_theTI.dischargePort.trimPortCode, endX, _y1 + 18, tmpInverseColour);
				theFrame.drawTextAlign := Frame.DrawTextAlign_Left;
			endif;
		endif;
		if lFactor = ScaleFactor_6 then
//			theFrame.drawTextAt(_theTI.id, _x1 + 4, _y1 + 15, tmpInverseColour);
			theFrame.drawTextAlign := Frame.DrawTextAlign_Right;
			theFrame.drawTextAt(_theTI.dischargePort.trimPortCode, endX, _y1 + 18, tmpInverseColour);
			theFrame.drawTextAlign := Frame.DrawTextAlign_Left;
		endif;
		if lFactor = ScaleFactor_9 then
			theFrame.drawTextAlign := Frame.DrawTextAlign_Right;
			theFrame.drawTextAt(_theTI.dischargePort.trimPortCode &amp; " X " &amp;_theTI.loadPort.trimPortCode, endX, _y1 + 33, tmpInverseColour);
			theFrame.drawTextAlign := Frame.DrawTextAlign_Left;
		endif;
	endif;

	
	if lFactor &gt;= ScaleFactor_1 then
		self.defaultFontSizeForAttributes := 8;
		if lFactor = ScaleFactor_1 then
			self.defaultFontSizeForAttributes := 8;
		elseif lFactor = ScaleFactor_1_5 then
			self.defaultFontSizeForAttributes := 10;
		elseif lFactor = ScaleFactor_2 then
			self.defaultFontSizeForAttributes := 10;
		elseif lFactor = ScaleFactor_3 then
			self.defaultFontSizeForAttributes := 12;
		elseif lFactor = ScaleFactor_4 then
			self.defaultFontSizeForAttributes := 12;
		elseif lFactor &gt;= ScaleFactor_6 then
			self.defaultFontSizeForAttributes := 20;
		endif;
	
		if self.flipHorizontal then
			if (isDragging and autoMasked) then // PAR 19505 do not re adjust for autoMask as the Xs are correct // PAR 19505 NEW
				//self.drawIcons(_theTI, theFrame,_x1, y1, tmpInverseColour);			// TFS 46405
				self.drawIcons(_theTI, theFrame,_x1, y1, tmpInverseColour, false);		// TFS 46405
			else // PAR 19505 NEW
				//self.drawIcons(_theTI, theFrame,_x2,y1, tmpInverseColour);			// TFS 46405
				self.drawIcons(_theTI, theFrame,_x2,y1, tmpInverseColour, false);		// TFS 46405
			endif;
		else
			//epr par 37063 20/11/15 removed the y1 + 5 was not drawing correctly on lower zoom levels
			//self.drawIcons(_theTI, theFrame,_x1,y1 , tmpInverseColour);				// TFS 46405
			self.drawIcons(_theTI, theFrame,_x1,y1 , tmpInverseColour, false);			// TFS 46405
		endif;
	endif;
	// always draw the weight
	if tmpHeight = Ti_Half_Height then
		tm_y1 := _y1;
	else
		tm_y1 := self.y1 + self.attrY1 ;
	endif;
	theFrame.drawTextAlign := Frame.DrawTextAlign_Right;
	theFrame.drawFontName := "Arial"; // PAR 20182 was Ariel
	if self.defaultFontSizeForAttributes &gt; 0 then // PAR 20182
		theFrame.drawFontSize := defaultFontSizeForAttributes;
	elseif self.defaultFontSize &gt; 0 then
		theFrame.drawFontSize := self.defaultFontSize; // PAR 20182
	else
		theFrame.drawFontSize := 8; // PAR 20182
	endif;
	theFrame.drawTextAt(lWeight.String, endX + 4 , tm_y1, tmpInverseColour);
epilog
	theFrame.drawFontSize := self.defaultFontSize;
end;</source>
        <access>protected</access>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_theGridAttributes" type="CMUI_GridAttributes" usage="input"/>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_y2" type="Real"/>
        <Parameter name="_frame" type="CMUI_GridAreaDrawingFrame" usage="input"/>
        <Parameter name="_lc" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="drawTIBox" id="970cd681-7f56-48f7-81ae-f2e7d8a95a4b">
        <source>drawTIBox(_frame : Frame; _colour1 : Integer; _colour2 : Integer; _x1,_y1,_x2,_y2 : Integer);
// ---------------------------------------------------------------------------
// Created:		31 July 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	lFactor : Integer;
begin
	lFactor := self.scaleFactor.Integer;

	_frame.drawLine(_x1, _y1, _x2 + 1, _y1 ,  _colour1);
	_frame.drawLine(_x1, _y1, _x1, _y2,  _colour1);
	_frame.drawLine(_x2, _y1 , _x2, _y2 + 1,  _colour2);
	_frame.drawLine(_x1, _y2, _x2, _y2,  _colour2);

	if lFactor &gt; ScaleFactor_1_5 then

		_frame.drawLine(_x1, _y1 + 1, _x2, _y1 + 1 ,  _colour1);
		_frame.drawLine(_x1 + 1, _y1, _x1 + 1, _y2,  _colour1);
		_frame.drawLine(_x2 - 1, _y1 + 1, _x2 - 1, _y2 + 1,  _colour2);
		_frame.drawLine(_x1 + 1, _y2 - 1, _x2, _y2 - 1,  _colour2);
	endif;

	if lFactor &gt; ScaleFactor_2 then

		_frame.drawLine(_x1, _y1 + 2, _x2 - 1, _y1 + 2 ,  _colour1);
		_frame.drawLine(_x1 + 2, _y1, _x1 + 2, _y2 - 2,  _colour1);
		_frame.drawLine(_x2 - 2, _y1 + 2, _x2 - 2, _y2 + 1,  _colour2);
		_frame.drawLine(_x1 + 2, _y2 - 2, _x2, _y2 - 2,  _colour2);
	endif;

end;</source>
        <Parameter name="_frame" type="Frame"/>
        <Parameter name="_colour1" type="Integer"/>
        <Parameter name="_colour2" type="Integer"/>
        <Parameter name="_x1" type="Integer"/>
        <Parameter name="_y1" type="Integer"/>
        <Parameter name="_x2" type="Integer"/>
        <Parameter name="_y2" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawTITextLeft" id="e24f62c9-35ca-41bf-a9e2-792fa1971251">
        <source>drawTITextLeft(_theFrame : CMUI_Frame input; _theFontName : String; _theFontSize : Integer; _theCharacter : String;
						_theColour : Integer; _leftX, _topY, _bottomY : Integer) : Integer;
// ---------------------------------------------------------------------------
// Created:		September  2002 By Andrew Bishop cnwab1
//
// Purpose:		Return the width
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	textTopY : Integer;
	theTextWidth, theTextHeight : Integer;

begin
	_theFrame.drawFontName := _theFontName;
	_theFrame.drawFontSize := _theFontSize;
	_theFrame.drawTextAlign := Frame.DrawTextAlign_Center;
	
	// must set the fontSize as it is used to calculate the text height and width
	_theFrame.fontSize := _theFontSize;
	
	theTextWidth := _theFrame.getTextExtent(_theCharacter);
	theTextHeight := _theFrame.getTextHeight(_theCharacter);
	
	textTopY := (((_bottomY - _topY) - theTextHeight) div 2) + _topY;

	_theFrame.drawTextAt(_theCharacter, _leftX, textTopY, _theFrame.drawFillColor.getInverseColour);

	return theTextWidth;
end;</source>
        <Parameter name="_theFrame" type="CMUI_Frame" usage="input"/>
        <Parameter name="_theFontName" type="String"/>
        <Parameter name="_theFontSize" type="Integer"/>
        <Parameter name="_theCharacter" type="String"/>
        <Parameter name="_theColour" type="Integer"/>
        <Parameter name="_leftX" type="Integer"/>
        <Parameter name="_topY" type="Integer"/>
        <Parameter name="_bottomY" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawTITextLeftNew" id="602a363e-d2e8-453a-89b5-bd9ed7dd014c">
        <source>drawTITextLeftNew(_theFrame : CMUI_GridAreaFrame input; _theFontName : String; _theFontSize : Integer; _theCharacter : String;
						_theColour : Integer; _theX, _theY1, _theY2 : Integer) : Integer;
// ---------------------------------------------------------------------------
// Created:		September  2002 By Andrew Bishop cnwab1
//
// Purpose:		Return the width
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theTextWidth, theX, theY,theTextHeight : Integer;
	zoomScale : Real;
begin

	_theFrame.drawFontName := _theFontName;
	_theFrame.drawFontSize := _theFontSize;
	_theFrame.fontSize := _theFontSize;
	_theFrame.drawTextAlign := Frame.DrawTextAlign_Center;
	
	
//	zoomScale := _theFontSize / self.FontSize; // self.myGridArea.scaleXFactor; 
//	theTextWidth := (_theFrame.getTextExtent(_theCharacter) * zoomScale).Integer;
	theTextHeight := _theFrame.getTextHeight(_theCharacter);
	theX := _theX; // - theTextWidth - 2;

/*	if self.myGridArea.scaleXFactor = 1 then
		theTextHeight := theTextHeight - 5;
	elseif self.myGridArea.scaleXFactor = 1.5 then
		theTextHeight := theTextHeight - 4;
	elseif self.myGridArea.scaleXFactor = 2 then
		theTextHeight := theTextHeight - 6;
	else
		theTextHeight := theTextHeight - 10;
	endif;
*/
//	theY := _theY - theTextHeight;
//	theY := (((_theY - topY) - theTextHeight) div 2) + topY;
	theY := (((_theY2 - _theY1) - theTextHeight) / 2).Integer + _theY1;
/*
	if self.myGridArea.scaleXFactor &gt; 1 then
		_theFrame.drawTextAt(_theCharacter, theX + 1,theY - 1,White); // RIGHT &amp; UP
		_theFrame.drawTextAt(_theCharacter, theX - 1,theY + 1,White); // LEFT &amp; DOWN
		_theFrame.drawTextAt(_theCharacter, theX + 1,theY + 1,White); // RIGHT &amp; DOWN
		_theFrame.drawTextAt(_theCharacter, theX - 1,theY - 1,White); // LEFT &amp; UP
	endif;
*/
//	_theFrame.drawTextAt(_theCharacter, theX,theY,_theColour);
	_theFrame.drawTextAt(_theCharacter, theX,theY,_theFrame.drawFillColor.getInverseColour);

	return theTextWidth;
end;</source>
        <Parameter name="_theFrame" type="CMUI_GridAreaFrame" usage="input"/>
        <Parameter name="_theFontName" type="String"/>
        <Parameter name="_theFontSize" type="Integer"/>
        <Parameter name="_theCharacter" type="String"/>
        <Parameter name="_theColour" type="Integer"/>
        <Parameter name="_theX" type="Integer"/>
        <Parameter name="_theY1" type="Integer"/>
        <Parameter name="_theY2" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawTITextRight" id="3fb8e80a-b6b6-4e5a-84b6-954d42bd661a">
        <source>drawTITextRight(_theFrame : CMUI_GridAreaFrame input; _theFontName : String; _theFontSize : Integer; _theCharacter : String;
						_theColour : Integer; _theX, _theY : Integer) : Integer;
// ---------------------------------------------------------------------------
// Created:		September  2002 By Andrew Bishop cnwab1
//
// Purpose:		Return the width
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theTextWidth, theX, theY,theTextHeight : Integer;
	zoomScale : Real;
begin

	_theFrame.drawFontName := _theFontName;
	_theFrame.drawFontSize := _theFontSize;

	zoomScale :=  (_theFontSize / 8);
	theTextWidth := (_theFrame.getTextExtent(_theCharacter) * zoomScale).Integer;
	theTextHeight := (_theFrame.getTextHeightForWidth(_theCharacter,theTextWidth) * zoomScale).Integer;

	theX := _theX - theTextWidth - 2;
	if zoomScale = 1 then
		theY := _theY - theTextHeight + 2;
	elseif zoomScale = 1.5 then
		theY := _theY - theTextHeight + 3;
	elseif zoomScale = 2 then
		theY := _theY - theTextHeight + 3;
	else
		theY := _theY - theTextHeight + 5;
	endif;
	_theFrame.drawTextAt(_theCharacter, theX + 1,theY + 1,White);
	_theFrame.drawTextAt(_theCharacter, theX - 1,theY - 1,White);
	_theFrame.drawTextAt(_theCharacter, theX,theY,_theColour);

	return theTextWidth;
end;</source>
        <Parameter name="_theFrame" type="CMUI_GridAreaFrame" usage="input"/>
        <Parameter name="_theFontName" type="String"/>
        <Parameter name="_theFontSize" type="Integer"/>
        <Parameter name="_theCharacter" type="String"/>
        <Parameter name="_theColour" type="Integer"/>
        <Parameter name="_theX" type="Integer"/>
        <Parameter name="_theY" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="flipPointX" id="b570843f-401c-41ef-bbc3-6375aea335e5">
        <source>flipPointX(_xorigin, _width, _x: Real) : Real protected;

/*

Purpose:			
		Flip either axis (x or y) of a point
Parameters:			
		_xorigin : x of where the rectangle housing the flipped graphic starts 
		_width   : width of the rectangle housing the flipped graphic
		_x		 : x of the point to flip within the rectangle
Return Value:		
		flipped x 
		
		NOTE: flipPointY and flipPointX could be used for either axis.   I decided
		to add both to make the code more readable.

Date		Who		Reason
02 December 2009	cnwjk3	ccms 1018

*/

vars
	x : Real;
begin
	x := _xorigin + (_xorigin + _width - _x);	
	return x;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_xorigin" type="Real"/>
        <Parameter name="_width" type="Real"/>
        <Parameter name="_x" type="Real"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="flipPointY" id="372fe6f7-081b-46d1-8315-95435fa9a036">
        <source>flipPointY(_yorigin, _height, _y: Real) : Real protected;

/*

Purpose:			
		Flip either axis (x or y) of a point
Parameters:			
		_yorigin : y of where the rectangle housing the flipped graphic starts 
		_height  : height of the rectangle housing the flipped graphic
		_y		 : y of the point to flip within the rectangle
Return Value:
		flipped y 
		
		NOTE: flipPointY and flipPointX could be used for either axis.   I decided
		to add both to make the code more readable.

Date		Who		Reason
02 December 2009	cnwjk3	ccms 1018

*/

vars
	y : Real;
begin
	y := _yorigin + (_yorigin + _height - _y);	
	return y;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_yorigin" type="Real"/>
        <Parameter name="_height" type="Real"/>
        <Parameter name="_y" type="Real"/>
        <ReturnType type="Real"/>
    </JadeMethod>
