    <JadeMethod name="makeTimeStampsSectXML" id="60d59e2a-b095-45c6-8487-da1bd4fd5965">
        <source>makeTimeStampsSectXML( _trxTs : TimeStamp; _trx : CM_TITransaction; _parentElem : JadeXMLElement input; _term : CM_Terminal ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 August 2016	cnwndl1	Initial creation	TFS 2561 / 2277
9/11/2018 	JLGNS1	Bug 41923: AAT - Time Issue in EDI Message
*/

vars

	rootElem : JadeXMLElement;
	xmlElem : JadeXMLElement;
	tsUTC : TimeStamp;
	tsLocal : TimeStamp;
begin

	rootElem := _parentElem.addElement('TimeStamps');
	
	xmlElem := rootElem.addElement('Event');
	if _trx &lt;&gt; null and _trx.isKindOf(CM_Outturn) then	//07 Aug 2017	NDL	TFS 5701
	//	xmlElem.setText( _trx.myTrackedItem.dischargeDT.asXMLFormat );
		tsLocal :=  _term.systemToLocalTime(_trx.myTrackedItem.dischargeDT);
		xmlElem.setText(tsLocal.asXMLFormat);
		tsUTC := self.convertTStoUTC( _trx.myTrackedItem.dischargeDT );
	else
	//	xmlElem.setText( _trxTs.asXMLFormat );
		tsLocal := _term.systemToLocalTime( _trxTs);
		xmlElem.setText(tsLocal.asXMLFormat );
		tsUTC := self.convertTStoUTC( _trxTs );
	endif;
	
//	tsUTC := self.convertTStoUTC(_trxTs);
	xmlElem := rootElem.addElement('TransactionUTC');
	xmlElem.setText( tsUTC.asXMLFormat );
/*	
	xmlElem := rootElem.addElement('Arrival');
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('Departure');
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('Availability');
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('FirstDayOfStorage');
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('StartReceival');
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('ReeferCutOff');
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('CargoCutOff');
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('GPS_Time');
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('DateOfRelease');
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('TimeOfRelease');
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('OutturnCompletion');
	xmlElem.setText( null );
*/
epilog

end;</source>
