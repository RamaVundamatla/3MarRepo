	self.frmModalDialog.backColor 	:= self.backColor;
	self.btnModalDefault.visible 	:= false;
	self.pbProgressBar.top 			:= 38;
	self.lblModalInfo.top 			:= self.pbProgressBar.top + self.pbProgressBar.height + 2;
	self.pbProgressBar.zOrder(0);
end;</source>
        <access>protected</access>
    </JadeMethod>
