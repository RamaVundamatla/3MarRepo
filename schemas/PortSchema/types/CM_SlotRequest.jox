    <JadeMethod name="setForCreate" id="205b5360-34fb-43e5-b250-8f59eee7c3c6">
        <updating/>
        <source>setForCreate(_proxySlotRequest:CM_SlotRequest) updating;
// ---------------------------------------------------------------------------
// Created:     02 June 2002 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	needToSetDoorDir	: Boolean;
	tmpSlot		: CM_SlotController;
begin

	_proxySlotRequest.raiseExceptionIfNotTransient(method);
	
	if _proxySlotRequest.doorsDirection = TI_DOORSDIRN_NULL and
	   _proxySlotRequest.motorDirection = Motor_Null then
		// Assume that proxy has not been setup with defaults so set
		// a flag to set the defaults.  Need to do this once the
		// real is updated as the setDoorMotorDirDefault relies
		// on certain attributes being set.
		needToSetDoorDir := true;
	endif;

	self.setForUpdate(_proxySlotRequest);
	self.createWLEs();

	tmpSlot := _proxySlotRequest.mySlotController;
	self.setMySlotController(tmpSlot);

	// do this AFTER setting mySlotController as this relies
	// on the CM_SlotController.myDischargeRequest being set
	self.setForUpdateTI(NULL_MOVETYPE);
	app.writeVoyageLog(self, "Colour Code Create");  // PAR 31878 - logging
	
	self.useVoyageAllocations := self.mySlotController.myVoyage.useVoyageAllocations;
	
	if needToSetDoorDir then
		self.setDoorMotorDirDefault();
	endif;

end;</source>
        <Parameter name="_proxySlotRequest" type="CM_SlotRequest"/>
    </JadeMethod>
    <JadeMethod name="setForNullMoveType" id="db3ae7b7-2dfc-4cf8-9d31-e691b4d5a015">
        <updating/>
        <source>setForNullMoveType() protected, updating;
// ---------------------------------------------------------------------------
// Created:     15 April 2002 by cnwdwq1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

begin
  // Clear the structure if the fields are not applicable
	self.cargoType := TI_CargoType_Null;	//TI_CargoType_Container;
	self.commodity := null;
	self.dischargePort := null;
	self.empty := false;
	self.halfHeight := false;
	self.hazardous := false;
	self.overDimension := false;
	self.power := false;
// PAR7496 AKB2004FEB		self.reefer := false;
	self.unavailable := false;
	self.waterCooled := false;
	self.mySlotRequestForward := null;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="e71585ca-c3d9-4a42-ae31-27817d22cfd2">
        <updating/>
        <source>setForUpdate(_proxySlotRequest: CM_SlotRequest) updating;
// ---------------------------------------------------------------------------
// Created:     06 June 2002 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aWLE : CM_WorkListEntry;
	fwdSlotReq : CM_SlotRequest;
	theTI : CM_TrackedItem;
	setDirectionDefaults : Boolean;
	is40 : Boolean;		//cnwas3 PAR 24273
	oldSeqNum, newSeqNum 	: Integer; //epr CCMS 2323 tallyman
	voyage 	: CM_Voyage;
begin
	self.mySlotController := _proxySlotRequest.mySlotController;
	is40 := _proxySlotRequest.getAttrIs40();		//cnwas3 PAR 24273
	setDirectionDefaults := (self.getAttrIs40() &lt;&gt; is40); // PAR 8151. if the forty is changed set the door/motor direction 

	if setDirectionDefaults then // PAR 8151
		self.setDoorMotorDirDefault(); // PAR 8151
	endif;
	
	self.moveType	:= _proxySlotRequest.moveType;
	self.isLoad		:= _proxySlotRequest.isLoad;
	self.weight		:=	_proxySlotRequest.weight;		// cnwdad1 04/08/2010 - PAR #24045.
	
	self.ordinalDeck := _proxySlotRequest.ordinalDeck;
	self.ordinalCell := _proxySlotRequest.ordinalCell;
	self.ordinalTier := _proxySlotRequest.ordinalTier;
	
	self.doorsDirection := _proxySlotRequest.doorsDirection;
	self.motorDirection := _proxySlotRequest.motorDirection;
	
	self.mySlotRequestForward := _proxySlotRequest.mySlotRequestForward;
	
	if _proxySlotRequest.allAllocations.size() &gt; 0 then		
		self.allAllocations.clear(); // do not purge
		_proxySlotRequest.allAllocations.copyNoDupsToCol(self.allAllocations,false);		
		self.isBackend := _proxySlotRequest.isBackend; // PAR 25636
		app.writeVoyageLog(self, "Colour Code Update");  // PAR 31878 - logging
		return;
	endif;

	self.myDischargePort := _proxySlotRequest.getAttrDischargePort();
	self.dischargePort := _proxySlotRequest.dischargePort;
//	self.myCommodity := _proxySlotRequest.myCommodity;
	self.myCommodityGroup := _proxySlotRequest.getAttrCommodityGroup();
	self.commodity := _proxySlotRequest.commodity;
	self.cargoType := _proxySlotRequest.cargoType;
	self.myCargoType := _proxySlotRequest.getAttrCargoType();
	self.empty := _proxySlotRequest.getAttrEmpty();
	self.highCubed := _proxySlotRequest.getAttrHiCubed();
	
	//epr CCMS 2323 28/4/14
	oldSeqNum:= self.getSeqNum();
	
	
	self.numSeqPort := _proxySlotRequest.numSeqPort;
	self.numSeqStarBoard := _proxySlotRequest.numSeqStarBoard;
	self.numSeqPortCustom := _proxySlotRequest.numSeqPortCustom;
	self.numSeqStarboardCustom := _proxySlotRequest.numSeqStarboardCustom;

	newSeqNum:= self.getSeqNum();
	
	voyage:=self.getVoyage;
	if voyage &lt;&gt; null and oldSeqNum &lt;&gt; newSeqNum then
		voyage.incrementPlanningVersion();
	endif;
	
	self.is30 := _proxySlotRequest.getAttrIs30(); // PAR 16415 CCMS 1029
	self.is45 := _proxySlotRequest.getAttrIs45(); // PAR 16415 CCMS 1029
	self.is53 := _proxySlotRequest.getAttrIs53(); // PAR 16415 CCMS 1029
	self.isBackend := _proxySlotRequest.isBackend; // PAR 16415 CCMS 1029
	
	self.fixed := _proxySlotRequest.fixed;
	self.fortyBack := _proxySlotRequest.fortyBack;
	self.fortyFront := is40;
//process.debug;
	self.halfHeight := _proxySlotRequest.getAttrHalfHeight();
	self.hazardous := _proxySlotRequest.getAttrHazardous();
	self.overDimension := _proxySlotRequest.getAttrOverDimensioned();
	self.power := _proxySlotRequest.getAttrPowerRequired();
	self.crib := _proxySlotRequest.getAttrCrib();
	self.frame := _proxySlotRequest.getAttrFrame();	//05 Feb 2018	NDL	TFS 36752
	self.tank := _proxySlotRequest.getAttrTank();
	self.opentop := _proxySlotRequest.getAttrOpenTop();
	self.flat := _proxySlotRequest.getAttrFlatRack();
	self.fantainer := _proxySlotRequest.getAttrFantainer();
// PAR7496 AKB2004FEB		self.reefer := _proxySlotRequest.reefer;
	self.unavailable := _proxySlotRequest.unavailable;
	self.waterCooled := _proxySlotRequest.getAttrWaterCooled();

	if self.moveType = NULL_MOVETYPE then
		theTI := self.getTrackedItem(); 

		if self.myJob &lt;&gt; null then
			self.myJob := null;
		endif;

		// if this is a discharge and the WLE moveType = NULL_MOVETYPE  then
		// this is an indication that the colour coding has been erased
		// we may have more than 1 piece of cargo 
		// so clean up the WLEs
		foreach aWLE in self.allWorkListEntries do
			self.removeWLE(aWLE.CM_VoyageWLE,null);
		endforeach;
		self.createWLEs(); // this creates the default empty WLE
	else
		self.createWLEs();
	endif;
	if self.fortyBack then
		fwdSlotReq := self.getForwardSlotRequest();
		if (fwdSlotReq &lt;&gt; null) then
			self.set40AttribsFromFrontEnd(fwdSlotReq);
		endif;
	endif;
	
	
	// Set after the WLE has been created PAR 17327
	self.myBulkReleaseReserveDetail := _proxySlotRequest.myBulkReleaseReserveDetail;  
	app.writeVoyageLog(self, "Colour Code Update");  // PAR 31878 - logging
	
end;</source>
        <Parameter name="_proxySlotRequest" type="CM_SlotRequest"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateDirection" id="728740e8-0f12-4cb4-b33b-25dec40e1e1e">
        <updating/>
        <source>setForUpdateDirection(_proxySlotRequest: CM_SlotRequest) updating;
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	//epr TFS 7006 29/9/17
	self.doorsDirection := _proxySlotRequest.doorsDirection;
	if self.doorsDirection = TI_DOORSDIRN_FWD then	
		self.motorDirection := Motor_Aft;
	elseif self.doorsDirection =  TI_DOORSDIRN_AFT then
		self.motorDirection := Motor_Forward;
	else 
		self.motorDirection := Motor_Null;
	endif;
end;</source>
        <Parameter name="_proxySlotRequest" type="CM_SlotRequest"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateTI" id="7d295c03-c03e-48c8-b2cc-e4d52864099d">
        <source>setForUpdateTI(_oldMoveType : Integer) protected;
// ---------------------------------------------------------------------------
// Created:     05 April 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// Changed On 	By			Reason
// ----------	--------	--------------------------------------------------
// 18/05/2010	cnwdap1		CCMS 1116 Tranship changes
vars
	tmpTI		: CM_TrackedItem;
	tmpMoveType	: Integer;
	wle : CM_WorkListEntry;	
	otherTi : CM_TrackedItem;	//26 Nov 2015	NDL	Par 36772
begin

	tmpTI := self.getTrackedItem();
	if tmpTI = null then
		return;
	endif;
	
	// we have to set the TI status if this IS a DLR or SOB back to DLR or SOB
	exclusiveLock(tmpTI);
	
	tmpMoveType := self.moveType;

	if self.isRehandle then
		// if DLR do not change the IMEX - Import Export Transit etc
		tmpTI.setTransitStatus(TI_TransitStatusDLR, true, app.myPassport);
		
		//26 Nov 2015	NDL	Par 36772
		foreach wle in self.allWorkListEntries discreteLock  do  
			otherTi := wle.myTrackedItem;
			if otherTi = tmpTI then
				continue;
			endif;
			otherTi.setTransitStatus(TI_TransitStatusDLR, true, app.myPassport);
		endforeach;
		
	elseif self.isSOB then
		// if SOB do not change the IMEX - Import Export Transit etc
		tmpTI.setTransitStatus(TI_TransitStatusSOB, true, app.myPassport);
		
		//26 Nov 2015	NDL	Par 36772
		foreach wle in self.allWorkListEntries discreteLock  do  
			otherTi := wle.myTrackedItem;
			if otherTi = tmpTI then
				continue;
			endif;
			otherTi.setTransitStatus(TI_TransitStatusSOB, true, app.myPassport);
		endforeach;
		
	elseif tmpMoveType = DISCHARGE_MOVETYPE then
		// cnwrs2/cnwdad1 28/04/2010 - PAR #23996: tmpTI.statusEvent signature changed.
		//tmpTI.statusEvent(DIS_CCODE_STATUS_EV, true, app.myPassport);
		
// #####
// #####		
		// PAR 24248
		foreach wle in self.allWorkListEntries discreteLock  do  
			tmpTI := wle.myTrackedItem;
			tmpTI.statusEvent(DIS_CCODE_STATUS_EV, true, app.myPassport);
		endforeach;
	elseif tmpMoveType = LOAD_MOVETYPE then
		// cnwrs2/cnwdad1 28/04/2010 - PAR #23996: tmpTI.statusEvent signature changed.
		tmpTI.statusEvent(LOAD_CCODE_STATUS_EV, true, app.myPassport);

	elseif tmpMoveType = NULL_MOVETYPE then
		tmpTI.setTransitStatus(TI_TransitStatusNull, true, app.myPassport); // not DLR or SOB

		if _oldMoveType = DISCHARGE_MOVETYPE then
			if tmpTI.getImExStatus &lt;&gt; TI_IMEX_STATUS_TRANSHIP then		// PAR #23645 CCMS 1116
				tmpTI.setImExStatus(TI_IMEX_STATUS_IMPORT);
			endif;													// PAR #23645 CCMS 1116
		elseif _oldMoveType = LOAD_MOVETYPE then
			if tmpTI.getImExStatus &lt;&gt; TI_IMEX_STATUS_TRANSHIP then		// PAR #23645 CCMS 1116
				tmpTI.setImExStatus(TI_IMEX_STATUS_EXPORT);
			endif;													// PAR #23645 CCMS 1116
		else
			tmpTI.setImExStatus(TI_IMEX_STATUS_NULL);
		endif;
	endif;						

end;</source>
        <access>protected</access>
        <Parameter name="_oldMoveType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setFortyFoot" id="55660720-b270-4861-8eee-6a1a18a513d4">
        <updating/>
        <source>setFortyFoot(_fortyFoot : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     03 April 2002 by cnwdwq1
//
// Purpose:     Converted from C++ code.
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	sr : CM_SlotRequest;
	sc : CM_SlotController;
	is40 : Boolean;		//cnwas3 PAR 24273
begin
	if self.mySlotController = null then
		return;
	endif;
	
	exclusiveLock(self);
	sc := self.mySlotController;
	//-----------------------------------
	// Forty Foot Setting
	//-----------------------------------
	if _fortyFoot and 
	   (not sc.isFortyFront) and (not sc.isFortyBack) and 
	   self.isLoad then
		// Check it is defined as 40'
		app.raiseCMException1(ERR_NON_FORTY,self.mySlotController.getFullId, null, null);
		return;
	endif;
	//------------------------
	// Check the that it is not already the back end of a 40' colour code  
	//------------------------
	if self.fortyBack then
		app.raiseCMException(ERR_40_BACK, null, null);
		return;
	endif;
	
	if self.getAttrIs40() = _fortyFoot then
		return;
	endif;
	// if changing  also change the next bay
	if self.unavailable then
		app.raiseCMException(VB_SHIP_INV_SLOT, null, null);
		return;		
	endif;

	// AKB2003MAY - only check the aft slot if this is the forward slot of the forty footer
	if self.mySlotController.isFortyFront then
		sr := self.getAftSlotRequest();
		sc := self.mySlotController.myAftSlotInHold();
		if sc = null  then
			if _fortyFoot then // only error for no request in aft slot if this is a 40 - AKB2003MAY
				app.raiseCMException(ERR_NEXT_SLOT, null, null);
			endif;
		endif;
	endif;


	if sr = null  then
		return;
	endif;	
	exclusiveLock(sr);
	//------------
	//If NEXT slot has 40' front then complain.
	//If NEXT slot is unavailable then complain.
	//------------
	is40 := sr.getAttrIs40();		//cnwas3 PAR 24273
	if (is40 and _fortyFoot) or (sr.unavailable and _fortyFoot) then		//cnwas3 PAR 24273
		app.raiseCMException(ERR_40_FRONT, null, null);
		return;
	endif;
	//------------
	//Check not o'writing a 20' with this 40' DQ FCF1067
	//If next slot has a move type, and NO 40' front, and NO 40' back there is a 20' there
	//------------
	if (sr.moveType &lt;&gt; NULL_MOVETYPE) and 
		(is40 = false) then		//cnwas3 PAR 24273
		app.raiseCMException(ERR_20_PRESENT, null, null);
		return;
	endif;

	self.fortyFront := _fortyFoot;
	self.fortyBack := false;

	sr.set40AttribsFromFrontEnd(self);
end;</source>
        <Parameter name="_fortyFoot" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setFromLoadCC" id="053715a8-7d29-4cb7-a71f-af9a051d42b7">
        <updating/>
        <source>setFromLoadCC(_loadCC : CMIF_LoadColorCode; _frontEnd : Boolean; _moveType : Integer; _slotC : CM_SlotController input) updating;
// ---------------------------------------------------------------------------
// Created:		March 2003 By Andrew Bishop cnwab1
//
// Purpose:		Used for default discharge colour coding - can be called on
//				proxy or persistent requests
// ---------------------------------------------------------------------------
vars
	workedDT : TimeStamp;
	aComm : CM_Commodity;
	aPortCode, tmpAllocDesc : String;
	voy : CM_Voyage;
	useAllocations : Boolean;
	existingAlloc, newAlloc : CM_VoyageAllocation;
	cargoType : CM_CargoType;//cnwas3 PAR 24273
begin
	self.moveType	:=	_moveType;
	self.isLoad		:=	(_moveType = LOAD_MOVETYPE);
	self.mySlotController := _slotC;
	self.setProxyForCreate(_slotC, LOAD_MOVETYPE, true, _loadCC.myCargoType, _loadCC.myDischargePort);
	self.weight		:=	_loadCC.weight;		// cnwdad1 30/07/2010 - PAR #24045.
	
	voy := _slotC.myVoyage;
	if voy &lt;&gt; null then
		useAllocations := voy.useVoyageAllocations;
	endif;

	if useAllocations then
		create newAlloc transient;
		if self.isLoad then
			newAlloc.setFromLoadCC(_loadCC,TI_IMEX_STATUS_EXPORT, _moveType, self.getWeightRangeFromWeight(0));
		else
			newAlloc.setFromLoadCC(_loadCC,TI_IMEX_STATUS_IMPORT, _moveType, self.getWeightRangeFromWeight(0));
		endif;
		newAlloc.removeNonconfigCriteria(voy);
		
		tmpAllocDesc := newAlloc.getDefaultDescription(); // allocation.setFromTI() will build the criteria, so this will result in a meaningful description;
		newAlloc.setProxy(	tmpAllocDesc,
							tmpAllocDesc,
							null,
							YAFillOption_InOrder,
							YAFillOption_InOrder,
							YAExpiryType_Never,
							null,
							newAlloc.getDefaultColour,// allocation.setFromTI() should have set the dishargePort so this call should set a good colour
							null,  //cnwjo3 par 24145
							YAOverlap_Never,//allow others
							YANoLocation_Continue,
							null,
							0, //priority adjustment
							false,
							false,
							null,
							null,
							true,
							self.myTerminal);
		existingAlloc := voy.getAllocationWithSameCriteria(newAlloc);
		
		if existingAlloc = null then
			app.myUtilityUA.utlUpdateVoyageAlloc(false,voy, newAlloc,existingAlloc,app.myPassport);
			existingAlloc := voy.getAllocationWithSameCriteria(newAlloc);
		else
// PAR 24045 moved down 3 lines.			self.allAllocations.add(existingAlloc);
			app.myEventManager.createSingleObjInfoNoteEvt(voy,self.myTerminal.getTerminalEvent(EVENT_VOY_ALLOC_UPDATE),existingAlloc);
		endif;
		self.allAllocations.add(existingAlloc);
		self.myCargoType := null;
		self.myDischargePort := null;
		return;  // &lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt; RETURN if using voyage allocs
	endif;
	
	if _loadCC = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_loadCC', null, null);
		return;
	endif;
	
	self.myCargoType	:=	_loadCC.myCargoType;
	cargoType			:=	self.getAttrCargoType();	//cnwas3 PAR 24273
	if cargoType &lt;&gt; null then	//cnwas3 PAR 24273	
		self.cargoType := cargoType.id;	//cnwas3 PAR 24273
	endif;

	if self.moveType = DLR_MOVETYPE or 
	   self.moveType = SOB_MOVETYPE or
	   self.moveType = LOAD_MOVETYPE then
		if _loadCC.myDischargePort &lt;&gt; null then
			aPortCode := _loadCC.myDischargePort.code.trimBlanks;
		endif;
	else
		aPortCode := self.myTerminal.getConfig(PortDestCode).String.trimBlanks;
	endif;
	
	self.dischargePort := aPortCode;
	//self.myDischargePort := app.myRoot.allPorts[aPortCode];
	self.myDischargePort := app.myRoot.allPorts[aPortCode];
	
	self.myCommodityGroup := _loadCC.myCommodityGroup;
	
	/* DO NOT do this as 40 stuff is handled later on. Remember to TEST MOVINS and PLANNING SCRN
	if _loadCC.isForty then
		// do not use self.mySlotController here as for a create that
		// has not been set yet =&gt; need to pass in
		self.fortyFront := _frontEnd;
		self.fortyBack := (not self.getAttrIs40());
	else
		self.fortyBack := false;
		self.fortyFront := false;
	endif;
	*/
	
	if _loadCC.isThirty then
		self.is30 := true;
		self.isBackend := ( self.mySlotDefinition.isAftBay); // PAR 18823
	endif;
	
	if _loadCC.isFiftyThree then
		self.is53 := true;
		self.isBackend := (self.mySlotDefinition.isAftBay); // PAR 18823
	endif;
	
	// PAR 18682
	if _loadCC.isFortyFive then
		self.is45 := true;
		self.isBackend := (self.mySlotDefinition.isAftBay); // PAR 18823
	endif;
	
	if self.dischargePort = null then
		self.dischargePort := self.myTerminal.getConfig(PortDestCode).String;
		self.myDischargePort := app.myRoot.allPorts[self.dischargePort];
	endif;
epilog
	delete newAlloc; // not needed
end;</source>
        <Parameter name="_loadCC" type="CMIF_LoadColorCode"/>
        <Parameter name="_frontEnd" type="Boolean"/>
        <Parameter name="_moveType" type="Integer"/>
        <Parameter name="_slotC" type="CM_SlotController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setFromTI" id="346ec000-f3a6-4745-a963-c1727e33f9ae">
        <updating/>
        <source>setFromTI(_theTI : CM_TrackedItem) updating;
// ---------------------------------------------------------------------------
// Created:		March 2003 By Andrew Bishop cnwab1
//
// Purpose:		Used for default discharge colour coding - can be called on
//				proxy or persistent requests
// ---------------------------------------------------------------------------
vars
	workedDT 				: TimeStamp;
	aComm 					: CM_Commodity;
	aPortCode, tmpAllocDesc : String;
	voy 					: CM_Voyage;
	useAllocations 			: Boolean;
	existingAlloc, newAlloc : CM_VoyageAllocation;
	cargoType 				: CM_CargoType; //cnwas3 PAR 24273
	commodityGroup 			: CM_CommodityGroup; //cnwas3 PAR 24273
//	frontEnd  : Boolean;
begin


//	frontEnd := (_theTI.myPrimaryActualLocation = self.mySlotController);	//05 Feb 2016	NDL	Par 37424 - commented out

	voy := self.getVoyage();
	if voy &lt;&gt; null then
		useAllocations := voy.useVoyageAllocations;
	endif;

	if useAllocations then
		create newAlloc transient;
		if self.isLoad then
			newAlloc.setFromTI(_theTI,TI_IMEX_STATUS_EXPORT, (self.isRehandle or self.isSOB));
		else
			newAlloc.setFromTI(_theTI,TI_IMEX_STATUS_IMPORT, (self.isRehandle or self.isSOB));
		endif;
		newAlloc.removeNonconfigCriteria(voy);

		tmpAllocDesc := newAlloc.getDefaultDescription(); // allocation.setFromTI() will build the criteria, so this will result in a meaningful description;
		newAlloc.setProxy(tmpAllocDesc,
							tmpAllocDesc,
							null,
							YAFillOption_InOrder,
							YAFillOption_InOrder,
							YAExpiryType_Never,
							null,
							newAlloc.getDefaultColour,// allocation.setFromTI() should have set the dishargePort so this call should set a good colour
							null,  //cnwjo3 par 24145
							YAOverlap_Never,//allow others
							YANoLocation_Continue,
							null,
							0, //priority adjustment
							false,
							false,
							null,
							null,
							true,
							self.myTerminal);
		existingAlloc := voy.getAllocationWithSameCriteria(newAlloc);
		
		if existingAlloc = null then
			app.myUtilityUA.utlUpdateVoyageAlloc(false,voy, newAlloc,existingAlloc,app.myPassport);
			existingAlloc := voy.getAllocationWithSameCriteria(newAlloc);
		else
			app.myEventManager.createSingleObjInfoNoteEvt(voy,self.myTerminal.getTerminalEvent(EVENT_VOY_ALLOC_UPDATE),existingAlloc);
		endif;
		self.allAllocations.add(existingAlloc); // PAR 25858
		self.useVoyageAllocations := true; // PAR 31619
		return;  // &lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt; RETURN if using voyage allocs
	endif;
	
	if _theTI = null then
		app.raiseCMException2(MethodWithNullParam, method.name, 'theTI', null, null);
		return;
	endif;
	
	self.myCargoType := _theTI.myCargoType;
	
	cargoType := self.getAttrCargoType();	//cnwas3 PAR 24273
	if cargoType &lt;&gt; null then	//cnwas3 PAR 24273	
		self.cargoType := cargoType.id;	//cnwas3 PAR 24273
	endif;

	if self.moveType = DLR_MOVETYPE or 
	   self.moveType = SOB_MOVETYPE then
		aPortCode := _theTI.dischargePort.trimBlanks;
	else
		aPortCode := self.myTerminal.getConfig(PortDestCode).String.trimBlanks;
	endif;
	self.dischargePort := aPortCode;
	//self.myDischargePort := app.myRoot.allPorts[aPortCode];
	self.myDischargePort := app.myRoot.allPorts[aPortCode];
	
	aComm := app.myRoot.allCommodities[_theTI.commodity.trimBlanks];
	if aComm &lt;&gt; null then
		self.myCommodityGroup := aComm.myCommodityGroup;
	endif;
	commodityGroup := self.getAttrCommodityGroup();			//cnwas3 PAR 24273
	if commodityGroup = null then							//cnwas3 PAR 24273
		self.myCommodityGroup := _theTI.myCommodityGroup;
	endif;
	if commodityGroup &lt;&gt; null then							//cnwas3 PAR 24273
		self.commodity := commodityGroup.code.trimBlanks;	//cnwas3 PAR 24273
	endif;

	self.highCubed := _theTI.isAttributeTrue(TI_Attrib_IsHiCubed);
	self.overDimension := _theTI.isOverDimensions;
	self.hazardous := _theTI.isHazardous;
// PAR7496 AKB2004FEB		self.reefer := _theTI.isAttributeTrue(TI_Attrib_RequiresTemperature);
	self.empty := _theTI.isAttributeTrue(TI_Attrib_IsEmpty);
	self.halfHeight := _theTI.isAttributeTrue(TI_Attrib_IsHalfHeight);
	self.power :=  _theTI.isAttributeTrue(TI_Attrib_RequiresPower);
	self.unavailable :=  false;
	self.waterCooled :=  _theTI.isAttributeTrue(TI_Attrib_IsWaterCooled);
		
	if _theTI.isAttributeTrue(TI_Attrib_IsForty) then
		// do not use self.mySlotController here as for a create that
		// has not been set yet =&gt; need to pass in
		//self.fortyFront := frontEnd;
		if self.mySlotController &lt;&gt; null and _theTI.myPrimaryActualLocation = self.mySlotController then	//06 Mar 2019	TFS 43355
			// isAftBay, doesn't work for triple bays on the middle one if it is marked as front 40 and back 40.
			self.fortyFront := true;
			self.fortyBack := false;
		else
			self.fortyFront := not self.isAftBay;	//05 Feb 2016	NDL	Par 37424
			self.fortyBack := (not self.getAttrIs40());
		endif;	
	else
		self.fortyBack := false;
		self.fortyFront := false;
	endif;
	
	
	if _theTI.isAttributeTrue(TI_Attrib_IsThirty) then
		self.is30 := true;
		self.isBackend := ( self.mySlotDefinition.isAftBay); // PAR 18823
	endif;
	
	if _theTI.isAttributeTrue(TI_Attrib_IsFiftyThree) then
		self.is53 := true;
		self.isBackend := (self.mySlotDefinition.isAftBay); // PAR 18823
	endif;
	
	// PAR 18682
	if _theTI.isAttributeTrue(TI_Attrib_IsFortyFive) then
		self.is45 := true;
		self.isBackend := (self.mySlotDefinition.isAftBay); // PAR 18823
	endif;
	
	if self.dischargePort = null then
		self.dischargePort := self.myTerminal.getConfig(PortDestCode).String;
	endif;
epilog
	delete newAlloc; // not needed

end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setJob" id="5fc7fbfe-7c27-4f1e-9d8f-afe394f5a021">
        <updating/>
        <source>setJob(pJob: CM_Job) updating;
// ---------------------------------------------------------------------------
// Created:		July 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

	theWLE : CM_WorkListEntry;
	theVWLE :CM_VoyageWLE;
	theMoveController : CMIF_MoveController;
	theTI : CM_TrackedItem;
begin
	// if we are nulling out the job then we should unassign any TIs from the job also
	if pJob = null  then
		if not self.allWorkListEntries.isEmpty then
			
			create theMoveController transient;	
			foreach theWLE in self.allWorkListEntries do

				theTI := theWLE.myTrackedItem;
				if theTI &lt;&gt; null then
					self.myJob.updateTICollectionsUnassign(theTI);
					theMoveController.setMyWorkListEntry(theWLE);
					theMoveController.mySlotRequest := self;
					theMoveController.setMoveMode(PLANNING_MODE);
					theMoveController.isRehandleMove := self.isRehandle();
					theMoveController.isFullyUnplan := true;
					theMoveController.setMyTrackedItem(theTI);
					theTI.setFMUnplanIndex(self.isLoad,theMoveController);
					app.myUtilityUA.utlUpdateWLEUnassignTI(theMoveController, app.myPassport);
					if not self.isLoad then
						theWLE.setMyTrackedItem(theTI);
					endif;
					self.myJob.removeWLE(theWLE, null); // cnwrd1 par 22624 3.5.2010
					self.setSequenced(false);
				else
					self.myJob.removeWLE(theWLE, null); // PAR 7712 // cnwrd1 par 22624 3.5.2010
				endif;		
			endforeach;
		endif;
	else	
		// AKB2003SEP added this else for adding Load Requests into a SOB job and setting the WLE
		foreach theWLE in self.allWorkListEntries do
			if theWLE.job = null then
				theWLE.setJob(pJob);
			endif;
		endforeach;
	endif;
	inheritMethod(pJob);
epilog
	delete theMoveController;
end;</source>
        <Parameter name="pJob" type="CM_Job"/>
    </JadeMethod>
    <JadeMethod name="setLinkedRequest" id="4227a610-8f3e-44ff-80b1-db00ec561e0b">
        <updating/>
        <source>setLinkedRequest(_theSlotRequest : CM_Request) updating;
/*
Purpose:			
Date				Who			Reason
APRIL 2012		CNWAB1		Initial creation
*/

vars

begin
	if self.isDischarge then
//		self.mySlotRequestDLRSOBLoad := _theSlotRequest;
		self.myRequestLinkedLoad := _theSlotRequest; // PAR 28968
	else
	//	self.mySlotRequestDLRSOBDischarge := _theSlotRequest;
		self.myRequestLinkedDischarge := _theSlotRequest; // PAR 28968
	endif;	
end;</source>
        <Parameter name="_theSlotRequest" type="CM_Request"/>
    </JadeMethod>
    <JadeMethod name="setMoveType" id="9516f008-65ed-43d8-bb0f-319aa855646c">
        <updating/>
        <source>setMoveType(_moveType : Integer) updating;
/*
------------------------------------------------------------------------
Created:			26 February 2003 by cnwdwq1
Purpose:			Dave Q's code
Parameters:		See Method signature above. Special comment:
Returns:			See Method signature above. Special comment:
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														
------------------------------------------------------------------------
*/
vars

begin
	self.moveType := _moveType;

	// we don't update the isLoad attribute for
	// other move types (eg SOB,DLR) as they have
	// both a load and a discharge request
	if _moveType = LOAD_MOVETYPE then
		self.isLoad := true;
	elseif _moveType = DISCHARGE_MOVETYPE then
		self.isLoad := false;
	endif;
end;</source>
        <Parameter name="_moveType" type="Integer"/>
    </JadeMethod>
