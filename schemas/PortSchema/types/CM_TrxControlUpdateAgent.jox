	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	beginTransaction;

	app.myUtilityUA.utlLoadFileCustDocExtRef(_file, _terminal, _passport);
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxLocationActBalanceRecalc" id="1686b76e-8ec8-4732-b43e-721e927d3373">
        <updating/>
        <source>trxLocationActBalanceRecalc( _la : CMEVT_LocationActivity input;  _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 April 2021	navndl1	Initial creation	TFS 50906

