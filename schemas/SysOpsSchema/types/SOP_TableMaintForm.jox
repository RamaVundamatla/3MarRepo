    <JadeMethod name="cmbWBridgeType_lostFocus" id="bf36c9e5-46d0-4a91-af1f-72098861b512">
        <controlMethod name="CMUI_ComboBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbWBridgeType_lostFocus(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 March 2014	cnwndl1	Initial creation	Par 33588
//24/01/17 cnwns1 TFS3153:PKT - Bulk Process - WeighBridge Integration
*/

vars
	tbl : CM_EntryTable;
	weighBridgeType : CM_WeighBridgeObjType;
begin

	if combobox.parent.isKindOf(CM_EntryTable) then
		combobox.parent.CM_EntryTable.setValueByControlName(combobox.name, combobox.text);
		if combobox.listObject = null then
			return;
		endif;
		weighBridgeType:=combobox.listObject.CM_WeighBridgeObjType;
		self.myCurrentTableItem.SOPTM_WeighBridge.changeViews(weighBridgeType.code);
		self.resize;
	endif;
	
	
	
	
	

epilog

end;</source>
