<Class name="CM_PushEventsRoot" id="bc4afd7c-b5b5-4dc5-a08e-731b4f31ccf1">
    <superclass name="CM_Object"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>TFS 3369 - Push Events application

Singleton root object for JMT Push Events application.  

Will store configuration details for the .NET Event Stream application, and be maintained using Web Services by the .NET application.</text>
    <DbClassMap file="pushevents"/>
    <ExplicitInverseRef name="allEventStreamDefinitions" id="9d7dd21d-b9a5-4094-b813-536c4f51e295">
        <updateMode>automatic</updateMode>
        <type name="CM_EventStreamDefinitionDict"/>
        <access>readonly</access>
        <Inverse name="CM_EventStreamDefinition::myEventStreamRoot"/>
    </ExplicitInverseRef>
    <PrimAttribute name="configurationDetails" id="51b39996-694b-4e33-bf41-51052295a57c">
