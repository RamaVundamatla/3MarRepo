    <JadeMethod name="addLiteral" id="8a879236-7a16-4665-9578-2bcd6ed1afc9">
        <updating/>
        <source>addLiteral() : Boolean updating, protected;

vars
	classObj			: Class;
	formatObj			: CnEcXmlFormat;
	formatClassObj		: CnEcXmlFormatClass;
	formatLiteralObj	: CnEcXmlFormatLiteral;
	
begin
	classObj		:= app.myCnEcXmlSchema.getClass(lstFormatClasses.text);
	formatObj		:= app.cnEcGetXmlFormat(cmbOutputFormats.text);
	formatClassObj	:= formatObj.cnEcGetFormatClass(classObj.name); 

	if txtTextGeneral.text.trimBlanks = "" then
		lblGeneral.caption := "Enter the name of the new Literal and Press Update" &amp;
								CrLf &amp; "The name may NOT be blank.";
		return false;		
							
	elseif 	classObj.getProperty(txtTextGeneral.text.trimBlanks()) &lt;&gt; null
	or formatClassObj.getFormatProperty(txtTextGeneral.text.trimBlanks()) &lt;&gt; null
	then
		lblGeneral.caption := "Enter the name of the new Literal and Press Update" &amp;
								CrLf &amp; "'" &amp; txtTextGeneral.text.trimBlanks() &amp; "' already used.";
		return false;			
	else
		beginTransaction;
			create formatLiteralObj;
			formatLiteralObj.initializeMe(txtTextGeneral.text.trimBlanks, txtTextGeneral.text.trimBlanks, false, formatClassObj);
		commitTransaction;
		
		self.lstFormatAttribsPopulate();
		return true;
	endif;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="addLiteralClick" id="97f1a92a-9813-4b0b-b0c9-a668299d3d1c">
        <updating/>
        <source>addLiteralClick()updating, protected;

begin
	self.clearExtrasPanel();
	fraButtons.enabled := true;

	btnGeneralUpdate.caption	:= "Perform Add";
	lblGeneral.caption			:= "Enter the name of the new Literal and Press 'Perform Add'";
	lblClassFormat.caption		:= "Add Literal for " &amp; lstFormatClasses.text &amp; ".";
	txtTextGeneral.visible		:= true;	
	self.aUpdateType			:= 3;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="addMethod" id="f469c784-1272-4afd-b1e0-86d913aadbc8">
        <updating/>
        <source>addMethod(): Boolean updating, protected;

vars
	classObj		: Class;
	formatObj		: CnEcXmlFormat;
	formatClassObj	: CnEcXmlFormatClass;
	formatMethodObj	: CnEcXmlFormatMethod;
	
begin
	classObj		:= app.myCnEcXmlSchema.getClass(lstFormatClasses.text);
	formatObj		:= app.cnEcGetXmlFormat(cmbOutputFormats.text);
	formatClassObj	:= formatObj.cnEcGetFormatClass(classObj.name); 

	if (not chkEdition.value or not chkEdition.visible)
	and (not chkOid.value or not chkOid.visible)
	and (not chkNoid.value or not chkNoid.visible)
	then
		lblGeneral.caption := "Select one or more of the following options and Press Update" &amp;
								CrLf &amp; "No new Option selected.";
		return false;							
	else
		beginTransaction;
			if chkEdition.value then 
				create formatMethodObj;
				formatMethodObj.initializeMe("edition", "edition", false, formatClassObj);
				formatMethodObj.setMethodName("edition");
			endif;
			
			if chkOid.value then 
				create formatMethodObj;
				formatMethodObj.initializeMe("oid", "oid", false, formatClassObj);
				formatMethodObj.setMethodName("getOidString");
			endif;
			
			if chkNoid.value then 
				create formatMethodObj;
				formatMethodObj.initializeMe("noid", "NOID", false, formatClassObj);
				formatMethodObj.setMethodName("getNoidString");
			endif;
		commitTransaction;
		
		self.lstFormatAttribsPopulate();
		return true;
	endif;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="addMethodClick" id="b74d0648-0bc4-4e84-ae12-9361a56d5532">
        <updating/>
        <source>addMethodClick()updating, protected;

vars
	formatObj		: CnEcXmlFormat;
	formatClassObj	: CnEcXmlFormatClass;
	
begin
	formatObj		:= app.cnEcGetXmlFormat(cmbOutputFormats.text);
	formatClassObj	:= formatObj.cnEcGetFormatClass(lstFormatClasses.text);

	self.clearExtrasPanel();
	fraButtons.enabled := true;

	btnGeneralUpdate.caption := "Perform Add";
	chkEdition.visible := true;
	
	if formatClassObj.getFormatProperty("edition") &lt;&gt; null then
		chkEdition.visible := false;
	endif;
	
	chkOid.visible := true;
	
	if formatClassObj.getFormatProperty("oid") &lt;&gt; null then
		chkOid.visible := false;
	endif;
	
	chkNoid.visible := true;
	
	if formatClassObj.getFormatProperty("noid") &lt;&gt; null then
		chkNoid.visible := false;
	endif;
	
	lblClassFormat.caption := "Add Special property for " &amp; lstFormatClasses.text &amp; ".";
	self.aUpdateType := 2;

	if chkOid.visible = false and chkEdition.visible = false then
		lblGeneral.caption := "No new options to select";
		btnGeneralUpdate.enabled := false;
	else
	    lblGeneral.caption := "Select one or more of the following options and Press 'Perform Add'";
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="addPropertyFormat" id="8bb43b1c-a724-46de-848c-f39ab1b2dd99">
        <source>addPropertyFormat() protected;

vars
	formatObj				: CnEcXmlFormat;
	formatIncludeObj		: CnEcXmlFormat;
	formatClassObj			: CnEcXmlFormatClass;
	classObj				: Class;
	propertyObj				: Property;
	formatPropertyObj		: CnEcXmlFormatProperty;
//	formatAttributeObj		: CnEcXmlFormatAttribute;
//	formatLiteralObj		: CnEcXmlFormatLiteral;
//	formatMethodObj			: CnEcXmlFormatMethod;
//	formatReferenceObj		: CnEcXmlFormatReference;
//	formatCollectionObj		: CnEcXmlFormatCollection;
//	formatSingletonObj		: CnEcXmlFormatSingle;
	
begin
	beginTransaction;

	formatObj			:=	app.cnEcGetXmlFormat(cmbOutputFormats.text);
	formatIncludeObj	:=	app.cnEcGetXmlFormat(cmbIncludeFormat.text);
	
	if formatObj = null then
		create formatObj;
		formatObj.initializeMe(cmbOutputFormats.text,0,app.myCnEcXmlSchema);
	endif;

	formatClassObj	:=	formatObj.cnEcGetFormatClass(lstFormatClasses.text);
	
	if formatClassObj = null then
		formatClassObj := self.createFormatClass(formatObj); 
	endif;

	classObj	:=	app.myCnEcXmlSchema.getClass(lstFormatClasses.text);

	while classObj.getProperty(lstFormatAttribs.text) = null and classObj.name &lt;&gt; Object.name do	// If we get to here the property is inherited.
		classObj	:=	classObj.getSuperclass();													// so check our superclass.
	endwhile;

	if classObj.getProperty(lstFormatAttribs.text) &lt;&gt; null then
		if classObj.getProperty(lstFormatAttribs.text).isKindOf(Attribute) then	  
			// create formatAttribute here	
			create formatPropertyObj as CnEcXmlFormatAttribute;
			formatPropertyObj.initializeMe(lstFormatAttribs.text, txtTagWith.text, optIncludeYes.value, formatClassObj);
		else
			// must be a Reference then
			propertyObj	:=	classObj.getProperty(lstFormatAttribs.text); 
			
			if propertyObj.getType().isKindOf(CollClass) then
				// create formatCollection here
				create formatPropertyObj as CnEcXmlFormatCollection;
				formatPropertyObj.initializeMe(lstFormatAttribs.text, txtTagWith.text, optIncludeYes.value, formatClassObj);
				formatPropertyObj.CnEcXmlFormatReference.setMyFormat(formatIncludeObj);
			else
				// create formatSingleton here
				create formatPropertyObj as CnEcXmlFormatSingle;
				formatPropertyObj.initializeMe(lstFormatAttribs.text, txtTagWith.text, optIncludeYes.value, formatClassObj);
				formatPropertyObj.CnEcXmlFormatReference.setMyFormat(formatIncludeObj);
			endif;
		endif;
	endif;

	commitTransaction;

	lstFormatAttribs.itemObject[lstFormatAttribs.listIndex] := formatPropertyObj;
	
	if formatPropertyObj.isShowTagData = true then
		lstFormatAttribs.itemForeColor[lstFormatAttribs.listIndex] := Blue;
	else
		lstFormatAttribs.itemForeColor[lstFormatAttribs.listIndex] := Black;		
	endif;	
	
	btnAddProp.enabled := false;
end;</source>
        <access>protected</access>
    </JadeMethod>
