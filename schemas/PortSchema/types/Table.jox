    <JadeMethod name="getSelectedRowCount" id="f2df6fd9-0da3-4860-a7b0-c3c6e2ee044f">
        <source>getSelectedRowCount():Integer;
// --------------------------------------------------------------------------------
// Created:		24 November 2005 by cnwdad1
//
// Purpose:		Returns the number of the receiver's rows that are selected.
//
// Parameters:	None
//
// Returns:		The number of selected rows.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowPointer		: Integer;
	firstRow		: Integer;
	lastRow			: Integer;
	selectedRows	: Integer;
	
begin
	firstRow	:=	self.fixedRows + 1;
	lastRow		:=	self.rows;
	
	foreach rowPointer in firstRow to lastRow do
		if self.cnEcIsRowSelected(rowPointer) then
			selectedRows	:=	selectedRows + 1;
		endif;
	endforeach;
	
	return selectedRows;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="lastVisibleRow" id="f6af92a4-cbcf-487f-9004-c11853dd4773">
        <source>lastVisibleRow(): Integer;

constants
	// number of pixels that must be visible before we say the row is visible.
	Num_Pixels_Cuttoff = 6;
vars
	pageHeight:      Real;
	y:               Real;
	theRow:          Integer;
begin
	pageHeight := clientHeight;
	theRow := 1;
	while theRow &lt;= fixedRows do
		if rowVisible[theRow] then
			pageHeight := pageHeight - rowHeight[theRow];
		endif;
		theRow := theRow + 1;
	endwhile;

	theRow := topRow;

	// scan down the column to find appropriate row
	while true do
		if theRow &gt; rows then
			break;
		endif;
		if rowVisible[theRow] then
			y := y + rowHeight[theRow];
		endif;
		if pageHeight &lt;= y then
			if (y - pageHeight) &lt; Num_Pixels_Cuttoff then
				// we can see less than the top Num_Pixels_Cuttoff pixels of the row so step back one
				theRow := theRow - 1;
			endif;
			break;
		else
			// increment the row
			theRow := theRow + 1;
		endif;
	endwhile; 

	if theRow &gt; rows then
		theRow := rows;
	endif;

	return theRow;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="purgeTableObjects" id="1975c1e7-e104-4f24-a573-34e93cfd36e6">
        <updating/>
        <source>purgeTableObjects() updating;
//----------------------------------------------------------------
//	Created:	29 October 2004	by Jason Chapman  (cnwjc2)
//
//	Used for deleting transient row objects  
//
//----------------------------------------------------------------
vars
	obj				: Object;
	maxRows,
	theFirstRow,
	idx				: Integer;
	
begin
	maxRows		:=	self.rows;
	theFirstRow	:=	self.fixedRows + 1;
	//process.debugJK();
	foreach idx in theFirstRow to maxRows do
		obj	:=	self.accessRow(idx).itemObject;
		
		if obj &lt;&gt; null and obj.isTransient() then
			self.accessRow(idx).itemObject	:=	null;
			delete obj;
		endif;
	endforeach;
end;</source>
    </JadeMethod>
</GUIClass>
