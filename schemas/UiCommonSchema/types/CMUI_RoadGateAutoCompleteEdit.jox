    <JadeMethod name="setupForm" id="1d76e3fd-8d8d-4248-b173-8bf136193a19">
        <updating/>
        <source>setupForm() updating;
/*
----------   ----------  --------------------------------------------------
Created:	09 August 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason	
----------   ----------  --------------------------------------------------
24th Jan 2024 	navra1  TFS 62081 - CUX | Auto-setdown of cargo that doesn't require a machine move
*/
vars
	caption : String;
begin
	
	inheritMethod();
	self.setPreEditDetails;
	caption := self.criteriaName;
	if caption &lt;&gt; null then
		caption := "'" &amp; caption &amp; "'";
	endif;
	caption := self.Caption &amp; caption;
	self.setCaption(caption);	
	self.txtName.setFocus;
	self.setFormData;

end;


</source>
