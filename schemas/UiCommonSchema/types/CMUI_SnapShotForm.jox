	self.frmOpPicker.visible := false;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="initTable" id="290bb500-bb9a-4972-82be-fbd6be2baba8">
        <updating/>
        <source>initTable() updating;
//----------------------------------------------------------------
//	Created:	09 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	snapShot 		: CM_SnapShot;
	rowIdx			: Integer;
	tbl				: CM_DataTable;
	bckColour		: Integer;
begin
	if self.mySummaryItem &lt;&gt; null then
		self.setCaption("Snap Shots - " &amp; self.mySummaryItem.itemCode &amp; " " &amp; self.mySummaryItem.size);
	else
		self.setCaption("Snap Shots - ");
	endif;
	self.initTableData(ETDef_SnapShotView);	
	tbl := self.tblData;
	tbl.multiSelect := CM_BaseTable.MultiSelect_Simple;
	tbl.selectMode := Table.SelectMode_FixedRow;
	
	self.initTableInfo();

	

end;</source>
    </JadeMethod>
    <JadeMethod name="initTableData" id="ad9d4078-d1fa-4ef0-b625-54925320732d">
        <updating/>
        <source>initTableData(_theEntDef: String) updating;
//----------------------------------------------------------------
//	Created:	09 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	self.tblData.allSelectedObjects.clear;
	if _theEntDef &lt;&gt; null then
		inheritMethod(_theEntDef);
	else
		//reset stuff
		self.tblData.rows := 1;	
	endif;

end;</source>
        <Parameter name="_theEntDef" type="String"/>
    </JadeMethod>
    <JadeMethod name="initTableInfo" id="3d1b4746-bf65-4bbb-a222-be426bc33ef8">
        <source>initTableInfo();
//----------------------------------------------------------------
//	Created:	12 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	
	self.tblInfo.rows := 1;
	self.tblInfo.fixedRows := 1;
	self.tblInfo.columns := 4;
	self.tblInfo.text := 'Change Date' &amp; Tab &amp; 'Changed By' &amp; Tab &amp; 'Change Type' &amp; Tab &amp; 'Change Notes';
	self.tblInfo.columnWidth[1] := 150;
	self.tblInfo.columnWidth[2] := 100;
	self.tblInfo.columnWidth[3] := 100;

end;</source>
    </JadeMethod>
