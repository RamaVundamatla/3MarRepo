    <JadeMethod name="getDisplayStringForAttribute" id="58c6d1c3-ea73-491e-9817-49900baad282">
        <source>getDisplayStringForAttribute( _attrName : String; _short : Boolean ) : String;
// ---------------------------------------------------------------------------
// Created:		20 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// 22/04/2010	cnwcs5	ccms1118 - par23580 Enhanced EDI form
// 11 Aug 2016	cnwrs1	Par 38117 make deleted EDI for finable
// 27 Jan 2020	jlgdap1	TFS 48188 PNL TSW messages with multiple bills
// 20 Jun 2022	navdap1	TFS 53362 EUP Master Data interface customers between TOS and ERP
// 31 Oct 2023  navhn30 TFS Bug 61049: EUP | FR 54871 - EDI Administration Column Organiser
vars
	ediControllerAgent	: CM_EDIControllerAgent;
	ediError : CM_EDIError;
	operator : CM_Operator;
begin
	create ediControllerAgent transient;
	// This method can be used to add any additional columns in the Data Table eg left hand side of EDI Operations form
	if _attrName = ETRow_Items then
		return self.allEDITrackedItems.size.String;
	elseif _attrName = ETRow_Status then
		return ediControllerAgent.displayStatus( self.status );
	elseif _attrName = ETRow_CreatedTime then
		return self.systemToLocalTime(self.createdTime).date.asStringJMT() &amp; Space &amp; self.createdTime.time.format(app.getTimeShortFormat(false)); //ccms1906 cnwrs1 jan 2010	// 22/4/16 cnwmp6 TFS 488 - Multi timezone support
	elseif _attrName = ETRow_FileType then			
		return self.fileVersion;	
	elseif _attrName = CM_EDIData::ediFileCode.name then
		return ediControllerAgent.getEDIDisplayStrForFileType(self.ediFileCode);
	elseif _attrName = ETRow_DataType then
		return ediControllerAgent.getEDIDisplayStrForType(self.ediDataType);
	elseif _attrName = ETRow_Error then
		//epr par 37090 2/11/15
		if app.getMyUser &lt;&gt; null and
			app.myCurrentUserCan(self.getMyTerminal,PmAdmEdiopersMaint) then
			ediError:=self.getFirstEDIError();
			if ediError &lt;&gt; null then
				return ediError.text;
			endif;
		endif;
		return null;
	elseif _attrName = ETRow_VoyageCode then
		return self.getVoyageCode();
	//_attrName = ETRow_VoyageCode or
	elseif 
			_attrName = ETRow_VoyageCodeSystem or
			_attrName = ETRow_EdiFileVoyage or
			_attrName = ETRow_Bol or
			_attrName = ETRow_DestinationPort or
			_attrName = ETRow_DispositionCode or
			_attrName = ETRow_ControlNumber or
			_attrName = ETRow_PostedDateTime  or
			_attrName = ETRow_SendTime or
			_attrName = ETRow_SendDate or	// 07/05/2010 cnwcs5 par 23580
			_attrName = ETRow_VesselName or
			_attrName = ETRow_FromPort or
			_attrName = ETRow_DepartTime or
			_attrName = ETRow_ToPort or
			_attrName = ETRow_ArriveTime or
			_attrName = ETRow_ShipperDesc then
		// these properties will be handled in subclasses - if we get to here then
		// they don't apply to this edi data type
		return null;
// end 22/04/2010	cnwcs5	ccms1118 - par23580
	elseif _attrName = ETRow_CargoTypeDescr then		// TFS 48188
		return self.fileAdditionalInfo;					// TFS 48188
	elseif _attrName = ETRow_ManifestType then			// 31.10.23 	navhn30		#61049
		return self.getMessageType();
	elseif _attrName = ETRow_ManifestNumber then
		return self.getMessageNumber();
	elseif _attrName = ETRow_Guid then
		return self.getMessageID();
	elseif _attrName = ETRow_Sender then
		return self.getSender();
	elseif _attrName = ETRow_TransportStatus then
		return self.getAction();						// 31.10.23 	navhn30		#61049
		
	// TFS 53362 start
	elseif _attrName = ETRow_VoyageOperator // ### TFS CR 64617 TASK 64637 16JUL2024 NAVAB1
	or _attrName = ETRow_OperatorCode then 
		if app.myRoot.getConfig(ComboByNameOperator).Boolean then
			operator := app.myRoot.allOperators[self.operatorCode];
			if operator &lt;&gt; null then
				return operator.description;
			endif;
		endif;
			if self.operatorCode &lt;&gt; null then
				return self.operatorCode;
			endif;
	// TFS 53362 end
	
	// ### TFS CR 64617 TASK 64637 16JUL2024 NAVAB1
	elseif _attrName = ETRow_NumLines then
		return self.allEDITrackedItems.size.String;
	elseif _attrName = ETRow_NumErrors then
		return self.getNumErrors().String;
	elseif _attrName = ETRow_NumWarnings then
		return self.getNumWarnings().String;
	elseif _attrName = ETRow_Date then
		return self.processDate.asStringJMT();
	elseif _attrName = ETRow_FirstOperatorCode then
		return self.getFirstOpCode();
	else
		return inheritMethod(_attrName, _short);
	endif;
	
epilog
	delete ediControllerAgent;
end;
</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEDIAction" id="1f8a4464-df1a-4c14-875c-509bdf6fa69d">
