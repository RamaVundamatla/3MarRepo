    <JadeMethod name="connectionExceptionHandler" id="ecaf474a-a26b-4868-b014-9a9825daa42b">
        <source>connectionExceptionHandler(exObj: ConnectionException): Integer;
/*

Purpose:			


Return Value:		


Date		Who		Reason
24 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
