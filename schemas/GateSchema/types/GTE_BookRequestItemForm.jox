    <JadeMethod name="doWeightVolumeConversion" id="6ecfc71f-4401-4928-8f7e-9042325be621">
        <source>doWeightVolumeConversion(_weightToVolume : Boolean);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 08/04/2014	cnwdap1		Initial creation PAR #33606 CCMS SFW 1366 Bulk - Calculate weight from volume / density
//
vars
	cargoType 		: CM_CargoType;
	cargoSubType	: CM_Product;
	density 		: Decimal [22,10];
	weight 			: Decimal [22,10];
	volume			: Decimal [22,10];
	measure			: String;

begin
	cargoType := self.cmbCargoType.listObject.CM_CargoType;
	if cargoType = null then
		return;
	endif;
	cargoSubType := self.cmbProduct.listObject.CM_Product;
	if cargoSubType = null or not self.cmbProduct.visible then
		if cargoType.hasProductTypes then
			return;
		else
			cargoSubType := cargoType.mySystemProductType;
		endif;
	endif;
	if cargoSubType = null or cargoSubType.myDensityDec = null or not cargoSubType.myDensityDec.isViewable or cargoSubType.myDensityDec.value = null then // ### TFS 52193 22Nov2021 NAVPW1
		return;
	endif;
	
	// get density in system default measurement
	density := app.convertMeasurementForStorage(cargoSubType.myDensityDec.myMeasurementType.shortName, cargoSubType.myDensityDec.value); // ### TFS 52193 22Nov2021 NAVPW1
	
	if _weightToVolume then
		weight := self.tblWeight.getConvertedValue();
		//volume := weight / density;
		volume := PortSchema@calculateTotalWeightVolume(weight, volume, density, CM_CalculateVolume); // ### TFS 52193 22Nov2021 NAVPW1
		measure := cargoSubType.getMyVolume.myMeasurementType.shortName;
		self.tblVolume.setValues(app.convertMeasurementForDisplay(measure, volume) &amp; Space &amp; measure);
	else
		volume := self.tblVolume.getConvertedValue();
		//weight := volume * density;
		weight := PortSchema@calculateTotalWeightVolume(weight, volume, density, CM_CalculateWeight); // ### TFS 52193 22Nov2021 NAVPW1
		measure := cargoSubType.getMyWeight.myMeasurementType.shortName;
		self.tblWeight.setValues(app.convertMeasurementForDisplay(measure, weight) &amp; Space &amp; measure);
	endif;
	
epilog

end;</source>
        <Parameter name="_weightToVolume" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="enabledControlledAtmosphere" id="e95206f6-9962-42be-a63b-2c31b42086c8">
        <source>enabledControlledAtmosphere();
// --------------------------------------------------------------------------------
// Created:		27 May 2009 by cnwjo3
//
// Purpose:		When Checkbox Controleed Atmosphere checked enabled related controls
vars

begin
	self.lblCO2.enabled := self.chkControlAtmo.value;
	self.txtCO2.enabled := self.chkControlAtmo.value;
	self.lblO2.enabled := self.chkControlAtmo.value;
	self.txtO2.enabled := self.chkControlAtmo.value;
	self.chkCurtainsIn.enabled := self.chkControlAtmo.value;
end;</source>
    </JadeMethod>
    <JadeMethod name="enabledDisableReeferDetails" id="cd5d644c-be1b-4921-acb6-0ac6756107c0">
        <updating/>
        <source>enabledDisableReeferDetails()updating;
//
// Changed On	By			Reason
// ----------	--------	----------------------------------------------------------
// 25/03/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
vars
	btnTop : Real;
	cEnabled : Boolean;
	commodity : CM_Commodity;
	isoType   : CM_ISOType;
begin
	//11/12/2009 cnwdz2 par21830 
	//if isotype is invisible then we have selected a non ISO Container
	//if cmbIsoType.listObject &lt;&gt; null and cmbIsoType.listObject.CM_ISOType.isReefer and self.cmbCargoType.myObject.CM_CargoType.id = TI_CargoType_Container then
	commodity := self.cmbCommodity.listObject.CM_Commodity;
	//if commodity &lt;&gt; null and commodity.hasTemp and self.cmbCargoType.myObject.CM_CargoType.id = TI_CargoType_Container then
	//	cEnabled := true;
	//else
	//	cEnabled := false;
	//endif;
	
	isoType := self.cmbIsoType.listObject.CM_ISOType;
	
	//10/03/2010 cnwdz2 22550
	if self.myProxyBookingRefItem.isKindOf(CM_BRefItemContainer) and 
       ((isoType &lt;&gt; null and isoType.isReefer) or (commodity &lt;&gt; null and commodity.hasTemp )) then 
		cEnabled := true;
	else
		cEnabled := false;
	endif;
	self.lblTemperature.enabled := cEnabled;
	self.txtTemperature.enabled := cEnabled;
	self.optCel.enabled := cEnabled;
	self.optFahr.enabled := cEnabled;
	self.lblVentilation.enabled := cEnabled;
	//self.txtVentilation.enabled := cEnabled;				// PAR #31155
	//self.cmbVentUnits.enabled := cEnabled;				// PAR #31155
	self.tblVentilation.enabled := cEnabled;				// PAR #31155
	self.lblHumidity.enabled := cEnabled;
	self.txtHumidity.enabled := cEnabled;
	//self.lblGrade.enabled := cEnabled;
	//self.cmbGrade.enabled := cEnabled;
	self.chkControlAtmo.enabled := cEnabled;
end;</source>
    </JadeMethod>
    <JadeMethod name="filterIsoTypesForGroup" id="a75ff455-d9b3-44e6-aaa1-b7a1ed521bbd">
        <source>filterIsoTypesForGroup();
//13 October 2009	cnwml2


vars
	isoGroup : CM_ISOTypeGroup;
