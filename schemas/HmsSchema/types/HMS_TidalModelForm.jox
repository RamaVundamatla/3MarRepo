    <JadeMethod name="doCmbVesselClick" id="71884c43-4633-4c8c-b129-1cd4a802c8a1">
        <updating/>
        <source>doCmbVesselClick() updating;
//-----------------------------------------
// Created: November 2004 By: cnwgd1
//-----------------------------------------
vars
	tmpVesselData	: HMS_VesselData;
	tidalClass		: HMS_TidalClass;
	tmpData			: HMS_VesselDataHarbour;				
	
begin
	tmpVesselData := self.cmbVesselHMS.listObject.HMS_VesselData;

	//AJA 4.1.1 Draft Enhancements. If they've changed the vessel then surely they don't
	//want to carry on using the movement drafts ? Leave this code as is....
	if tmpVesselData &lt;&gt; null then
		tmpData := tmpVesselData.allVesselDataForHarbour[self.myTerminal.myHarbour];
		
		if tmpData &lt;&gt; null then
			if self.optArrival.value then
				tidalClass := tmpData.myTidalClassArrival;
			else
				tidalClass := tmpData.myTidalClassDeparture;
			endif;
		endif;	
		if tmpVesselData.dim_DraftAft &lt; tmpVesselData.dim_DraftFore then
		 	//txtDraft.text := tmpVesselData.dim_DraftAft.String;			// cnwdad1 10/07/2009 - PAR #20270.
			txtDraft.text := tmpVesselData.dim_DraftAft.asStringJMT();		// cnwdad1 10/07/2009 - PAR #20270.
		else
		 	//txtDraft.text := tmpVesselData.dim_DraftFore.String;			// cnwdad1 10/07/2009 - PAR #20270.
			txtDraft.text := tmpVesselData.dim_DraftFore.asStringJMT();		// cnwdad1 10/07/2009 - PAR #20270.
		endif;		
	endif;

	if tidalClass &lt;&gt; null then
		self.cmbTidalClass.listIndex := self.cmbTidalClass.findObject(tidalClass);
	else
		self.cmbTidalClass.listIndex := 1;	
	endif;
	
	self.myWorkingMovement := null;			
	self.drawMe();
end;</source>
    </JadeMethod>
    <JadeMethod name="doOptionClick" id="a9b67429-ce67-47e4-bd90-e229c5ce993b">
        <updating/>
        <source>doOptionClick()updating;
//--------------------------------------------------
// Created:	26 April 2005 By: cnwgd1
//--------------------------------------------------
vars
	tmpVesselData	: HMS_VesselData;
	tidalClass		: HMS_TidalClass;
	tmpData : HMS_VesselDataHarbour;
	
begin
	// Modified by Russell 29/03/99
	// -----------------------------------------------------------------
//	if self.myWorkingMovement &lt;&gt; null then  //dh par 16243 - changed for this:
	if self.myWorkingMovement &lt;&gt; null and self.myWorkingMovement.myHMSVoyageData &lt;&gt; null then
		if self.optArrival.value then
			tidalClass := self.myWorkingMovement.myHMSVoyageData.myTidalClass;
		else
			tidalClass := self.myWorkingMovement.myHMSVoyageData.myTidalClassDept;
		endif;
	endif;
	
	if tidalClass = null then
		tmpVesselData := self.cmbVesselHMS.listObject.HMS_VesselData;
		
		if tmpVesselData &lt;&gt; null then
			tmpData := tmpVesselData.allVesselDataForHarbour[self.myTerminal.myHarbour];
		endif;
		
		if tmpData &lt;&gt; null then
			if self.optArrival.value then
				tidalClass := tmpData.myTidalClassArrival;
			else
				tidalClass := tmpData.myTidalClassDeparture;
			endif;
		endif;
		
		if tidalClass &lt;&gt; null then
			self.cmbTidalClass.listIndex := self.cmbTidalClass.findObject(tidalClass);
		else
			self.cmbTidalClass.listIndex := 1;
		endif;
		// -----------------------------------------------------------------
	endif;
	
	self.drawMe();
end;</source>
    </JadeMethod>
    <JadeMethod name="doPrint" id="31a5299c-c8de-4b51-add7-681c67736da4">
        <updating/>
        <source>doPrint() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 August 2009	cnwer1	Initial creation  CCMS MES 2109 
// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
*/

vars
	tmpJadeReport  : JadeReport;
	theReport : CMUI_ReportLine;
	footerForm 	: CM_GenericTablePrint;
	theColour : Integer;
	picDepth : Binary;
	dateStr,
	timeStr: String;
	frmPrint : CMUI_Frame;
	now : TimeStamp;
begin
	
	dateStr:=self.txtDate.text.asStringJMT;
	timeStr:=self.txtTime.text.asStringJMT;

	

	create theReport transient;
	theReport.initReport;
	theReport.lblTitle01.caption := "Tidal Model";
	theReport.lblTitle03.caption := null ;
	theReport.lblTitle04.caption := null;  
	theReport.lblTitle02.caption := dateStr &amp; " " &amp; timeStr;
	theReport.lblPrintedBy.caption := null;
	theReport.lblPrintedBylbl.caption := null;
	theReport.initReportForPortrait;
	app.printer.setMargins(Print_Portrait,5,5,5,5);  
	app.printer.setHeader(theReport.frHeader);
	
	create footerForm transient;
	now:=app.actualTimeServer;	// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
	footerForm.frFooter.width := app.printer.pageWidth-20;
	footerForm.lblTheUser.caption := app.getMyUserCode;
	footerForm.lblTheDatePrinted.caption := self.systemToLocalTime(now).asStringJMT;	// 10/6/16 cnwmp6 TFS 488 - Multi timezone support
	app.printer.setFooter(footerForm.frFooter);
	
	app.printer.suppressDialog := true;

	create tmpJadeReport transient;
	tmpJadeReport.description := "Tidal Model";
	app.printer.setReport(tmpJadeReport);

	app.printer.printPreview := false;
	app.printer.documentType := Print_A4;
	
	theReport.printLine("");
	
	create frmPrint transient;
	self.addControl(frmPrint);
	
	frmPrint.borderStyle:=Frame.BorderStyle_None;
	frmPrint.bevelInner:=Frame.Bevel_None;
	frmPrint.bevelOuter:=Frame.Bevel_None;
	frmPrint.boundaryWidth:=0;
	frmPrint.transparent:=true;
	frmPrint.visible := true;
	frmPrint.autoRedraw:=true;
	
	app.printer.setPrintPosition(100);	
	theColour:=self.backColor;
	self.backColor:=White;
	picDepth:=self.frmTidalModel.createPictureIndirect(false,true);
	frmPrint.move(10,1, 1050,500 +  10 );
	frmPrint.drawPictureAt(picDepth,1,1);
	app.printer.print(frmPrint);
	self.backColor:=theColour;
	
	app.printer.close();
	app.printPreview(tmpJadeReport, true);
	
	

epilog
	delete frmPrint;

	delete theReport;
	delete footerForm;
end;</source>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="74e10405-5a24-48f8-8e3b-ff6c4bc63fd3">
        <updating/>
