    <JadeMethod name="doChangeConnectStatus" id="81607dc7-ccf3-415b-9b9d-c5b87797f09b">
        <updating/>
        <source>doChangeConnectStatus(ti : CM_TrackedItem input;  connect : Boolean) updating, protected;
/*
Date		Who		Reason
26/01/2009	cnwcp2	Initial creation
14/12/20009	cnwdap1	CCMS MES 1007 Any tracked item can now be a reefer, not just containers
					Method signature changed to reflect this
*/
vars
	power : CM_GapController;
	msg : String;
begin
	if ti = null then
		msg := app.getErrorString(No_Cargo_selected);
		self.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only, false);
		return;
	endif;
	
	// Check to see if this container has been connected/disconnected already elsewhere
	if ti.isConnected = connect then
		msg := app.getErrorString(Connect_done_refresh);
		self.msgBox(msg, app.getErrorString(Error), MsgBox_OK_Only, false);
		return;
	endif;
	
	// Power cannot be null if the terminal area is a ForkLifeStack (or Gridded Block stack as it is now called). 
	if ti.myTerminalArea.isKindOf(CM_ForkLiftStack) and not ti.myPrimaryActualLocation.hasPower then //cnwrd1 par 31313 18.4.13
		power := self.getSessionAgent.findClosestPowerPoint(ti);
		if power = null then
			msg := app.getErrorString(No_power_avail);
			app.msgBox(msg, app.getErrorString(Error),MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
	endif;
	
	self.getSessionAgent.updateTIConnection(ti,chkNoCharge.value,connect,power);
	self.populateTrackedItem();
	
end;</source>
        <access>protected</access>
        <Parameter name="ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="connect" type="Boolean"/>
    </JadeMethod>
