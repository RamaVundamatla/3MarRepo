    <JadeMethod name="doControlEvent" id="d4970b67-e29a-410d-9c7f-032adbffe964">
        <updating/>
        <source>doControlEvent(_control: Control) updating;
// this is called after list box population
vars
	bool : Boolean;
begin
	if _control.isKindOf(Button) then
		if _control = self.msgCriteria.myAddSelectedBtn or
		   _control = self.msgCriteria.myRemoveSelectedBtn then
			self.populateDebtorCombo();
		endif;
	endif;
end;
</source>
        <Parameter name="_control" type="Control"/>
    </JadeMethod>
    <JadeMethod name="doNoMaintPermDisableControls" id="2f7bc61e-3622-4ee8-88f1-148ffad39250">
        <source>doNoMaintPermDisableControls();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04/05/2023	navkc1	Bug 57484: EUP - Cargo Allocation Transaction Map Permissions

*/

vars

begin

	if app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;

	self.btnSave.enabled := false;
	self.cmbDebtorType.enabled := false;
	self.msgCriteria.readOnly := true;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="edb11cfd-a53b-45ac-88c3-30e72b6231c4">
        <updating/>
        <source>doSave() updating;
/*
Purpose:			
Date		Who		Reason
12 March 2015	cnwab1	Initial creation
*/

vars
	opCriteriaColl : CM_YACriteriaTypeArray;
	realDT : CM_DebtorType;
	realYAConfig, pxyYAConfig : CM_InvoiceAllocationConfig;
	theReturn : Integer;
	ct : CM_YACriteriaType;
	desc : String;
begin
	create opCriteriaColl transient;
	
	self.msgCriteria.getSelected(opCriteriaColl);

	 // ### TFS 51219 25MAY2021 NAVAB1
	if self.myCurrentTanMapInventory &lt;&gt; null then
		realYAConfig := self.myCurrentTanMapInventory.myInvoiceAllocationConfig;
		desc := self.myCurrentTanMapInventory.description;
	elseif self.myCurrentTransactionMap &lt;&gt; null then
		realYAConfig := self.myCurrentTransactionMap.myInvoiceAllocationConfig;
		desc := self.myCurrentTransactionMap.description;
	endif;
	
	if realYAConfig = null then
		app.raiseUnexpectedProgramError(class.name, method.name, "Transaction Map " &amp; desc &amp; " has no Invoice Allocation Config.");  // ### TFS 51219 25MAY2021 NAVAB1
		return;
	else
		pxyYAConfig := app.createUpdateProxy(realYAConfig).CM_InvoiceAllocationConfig;
	endif;
	
	pxyYAConfig.setProxyInvoiceAllocation(opCriteriaColl, realDT, self.myCurrentTransactionMap, self.myCurrentTanMapInventory); // ### TFS 51219 25MAY2021 NAVAB1
	
	while true do
		app.myTrxUA.trxUpdateYAIMEXConfig(pxyYAConfig, app.myPassport);
		if app.myPassport.trxCompletedOK then
			global.beep;
			self.unloadForm();
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Allocation),  app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;
epilog
	delete opCriteriaColl;
	delete pxyYAConfig;

end;</source>
    </JadeMethod>
