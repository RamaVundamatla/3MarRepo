    <JadeMethod name="create" id="06b23f7f-0812-4b4a-8e1f-d7c1e80ab759">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 March 2023	jlier1	Initial creation 56856

*/

vars

begin
	create self.myFinanceOneClient transient; 
	if self.myFinanceOneClient &lt;&gt; null then
		self.myFinanceOneClient.usePresentationClient := self.usePresentationClient;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="createGLFinanceOneInvoice" id="1433e896-adea-4068-9816-dcb1a2aaed9b">
        <updating/>
        <source>createGLFinanceOneInvoice(  _invoiceLines : CM_InvoiceLineSet input;  _glCode : String) : MTNFO_Invoice updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 March 2023	jlier1	Initial creation 56856

*/

vars
	foInvoice : MTNFO_Invoice;
	accNbr , costCentre : String;
	service : CM_Service;
	berth : HMS_Berth;
	tax,   
	total,
	taxRate : Decimal[23,6];
	firstInvoiceLine,
	invoiceLine : CM_InvoiceLine;
	taxCode : String;
begin	
	self.initialiseDetails(self.myInvoice, _invoiceLines);
	
	create foInvoice transient;
	foInvoice.usePresentationClient:=self.usePresentationClient;
	self.allTransients.add(foInvoice);
	foInvoice.docRef1:=self.myInvoice.sequenceNum.StringUtf8;
	if self.myInvoice.myPostedCreditInvoice &lt;&gt; null then
		foInvoice.docRef2:=self.myInvoice.myPostedCreditInvoice.sequenceNum.StringUtf8;
	endif;
	self.setConstantFields(foInvoice);
	self.setDateFields(foInvoice);
	
	foInvoice.lneLdgCode:="GL".StringUtf8;	
	 	
	
	firstInvoiceLine:=_invoiceLines.first;
	if firstInvoiceLine &lt;&gt; null then
		if firstInvoiceLine.invoiceLineDesc &lt;&gt; null then
			service := firstInvoiceLine.invoiceLineDesc.services.first;
		endif;
		taxCode:= firstInvoiceLine.taxCode; // ### TFS CR 62992 TASK 62994 21MAR2024 NAVAB1 firstInvoiceLine.getTaxCode(false);
		taxRate:= firstInvoiceLine.taxRate; // ### TFS CR 62992 TASK 62994 21MAR2024 NAVAB1 firstInvoiceLine.getTaxRateForLine().Decimal;
		if taxCode = null then
			taxCode:="F";
		else
			taxCode:="C";
		endif;
	endif;
	
	//account Number
	accNbr:="1" ;
	costCentre:=service.externalReference1;
	if costCentre &lt;&gt; "B" then
		accNbr:=accNbr &amp; costCentre;
	else
		//from the external ref 1 of the berth
		if self.myMovement &lt;&gt; null then
			if self.myMovement.voyIF_IsDeparture then
				berth:=self.myMovement.getMyBerthPrevious;
			else
				berth:=self.myMovement.getMyBerth;
			endif;
		endif;
		
		if berth &lt;&gt; null then
			accNbr:=accNbr &amp; berth.externalReference1;
		endif;
	endif;
	
	accNbr:=accNbr &amp;  _glCode;
	foInvoice.lneAccnbri:=accNbr.StringUtf8;
	
	foreach invoiceLine in _invoiceLines discreteLock do
		total:=total + invoiceLine.lineTotal;
		tax:=tax + invoiceLine.getTaxAmountForLine;
	endforeach;
	
	total:=total.roundedTo(2);
	tax:=tax.Decimal.roundedTo(2);
	taxRate:=(taxRate/100).roundedTo(3);	
	self.setAmountFields(foInvoice,tax,total,taxRate,taxCode);
	
	self.setNarrationFields(foInvoice);
	
	
	return foInvoice;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_invoiceLines" type="CM_InvoiceLineSet" usage="input"/>
        <Parameter name="_glCode" type="String"/>
        <ReturnType type="MTNFO_Invoice"/>
    </JadeMethod>
    <JadeMethod name="delete" id="2a1cf1c1-c68e-4871-998c-5e6e576f86f0">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 March 2023	jlier1	Initial creation 56856

*/

vars

begin
	delete self.myFinanceOneClient;
	self.allTransients.purge;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getLogFileName" id="555a312c-58dd-40df-ad17-f5524df92338">
        <source>getLogFileName() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 April 2023	jlier1	Initial creation 56856

*/

vars
	logFileName : String;
begin
	logFileName := "MTNFinanceOneClient_" &amp; app.actualTimeServer.date.formatAsYYYYMMDD &amp;  ".log"; //"_" &amp; self.getInstanceIdForObject(process).String &amp;
	if self.usePresentationClient then
		logFileName := app.getTempDir &amp; logFileName;
	else
		if app.myCnCntrl &lt;&gt; null then
			logFileName := app.myCnCntrl.logPath &amp; "\" &amp; logFileName;
		else
			logFileName := app.getTempDirAppServer &amp; logFileName;
		endif;
	endif;
	
	return logFileName;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleFOException" id="fcc298b8-b2ff-4e55-a844-7e5f1a72ddc4">
        <updating/>
        <source>handleFOException(_exc : Exception; _excOccurred : Boolean io) : Integer protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
27 March 2023		jlier1	Initial creation 56856
23 September 2024	navmd1	TFS 66210 Dump non .net exceptions (should really be passing back)

*/

vars
	pxyEWSActivity	: CM_ExternalWebServiceActivity;
	errStr			: String;
begin
	app.writeLog(method.qualifiedName &amp; " " &amp; _exc.class.name &amp; " Error: " &amp; _exc.errorCode.String &amp; 
			   " Text: " &amp; _exc.text() &amp;
			   " Error Item: " &amp; _exc.errorItem &amp; " Extended Text: " &amp; _exc.extendedErrorText, LogERROR);	//25 Nov 2019	NDL	TFS 47053
	
	if _exc.errorCode &lt; 14574 or _exc.errorCode &gt; 14999 then
		app.doDumpStack(_exc);
	endif;

	_excOccurred := true;
	
	if self.myInvoice &lt;&gt; null then
		errStr := _exc.errorCode.String &amp; Space &amp; _exc.extendedErrorText;
		if self.myActivityHistory = null then
			app.myTrxCA.trxCreateFinanceOneActivity(self.myInvoice,self.myFinanceOneServiceDef, null, null, errStr, null, self.myActivityHistory, app.myPassport);
		else
			pxyEWSActivity := app.createUpdateProxy(self.myActivityHistory).CM_ExternalWebServiceActivity;
			pxyEWSActivity.setProxyRequestDetails(pxyEWSActivity.request, pxyEWSActivity.response &amp; CrLf &amp; errStr, null);
			pxyEWSActivity.CM_EWSActivityFinanceOne.setStatus(false, true, false);
			app.myTrxUA.trxUpdateEWSActivity(pxyEWSActivity, app.myPassport);
		endif;
	endif;
	
	if _exc.resumable then
		app.writeLog(method.qualifiedName &amp; " returning Ex_Resume_Next", LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		return Ex_Resume_Next;
	endif;
	
	
	return Ex_Pass_Back;
epilog
	delete pxyEWSActivity;
end;</source>
        <access>protected</access>
        <Parameter name="_exc" type="Exception"/>
        <Parameter name="_excOccurred" type="Boolean" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initialiseDetails" id="40cdcb9c-5136-4e51-92a4-5227361e0cd9">
        <updating/>
        <source>initialiseDetails(	_invoice : CM_Invoice; 
					_invoiceLines : Collection	) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
07 March 2023		jlier1	Initial creation 56856
23 September 2024	navmd1	TFS 66210 Clear myActivityHistory on new Invoice

*/

vars
	invoiceLine : CM_InvoiceLine;
begin
	self.myInvoice:=_invoice;
	if _invoiceLines &lt;&gt; null then
		if _invoiceLines.first &lt;&gt; null then
			invoiceLine:=_invoiceLines.first.CM_InvoiceLine;
		endif;
		if invoiceLine &lt;&gt; null then
			self.myTrackedItem:=invoiceLine.getTrackedItem;
			if self.myTrackedItem = null then
				if invoiceLine.myTransactionTI &lt;&gt; null then
					self.myTrackedItem:=invoiceLine.myTransactionTI.myTrackedItem;
				endif;
			endif;
		endif;
	endif;
	
	if self.myTrackedItem = null then
		self.myTrackedItem:=self.myInvoice.myTrackedItem;
	endif;
	
	if self.myTrackedItem &lt;&gt; null then
		self.myVoyage:=self.myTrackedItem.releaseVoyage;
		if self.myVoyage = null then
			self.isDischarge:=true;
			self.myVoyage:= self.myTrackedItem.receiveVoyage;
		endif;
	endif;
	
	if self.myVoyage &lt;&gt; null then
		if self.isDischarge then
			self.myMovement:=self.myVoyage.getMovementForDateTime(self.myTrackedItem.receivedDT);
			if self.myMovement &lt;&gt; null then				
				if self.myMovement.moveType = HMSMovementTypeDeparture then
					self.myMovement:=self.myMovement.myPreviousMovement.HMS_VoyageMovement;
				endif;
			endif;
		else
			self.myMovement:=self.myVoyage.getMovementForDateTime(self.myTrackedItem.releasedDT);
			if self.myMovement &lt;&gt; null then				
				if self.myMovement.moveType &lt;&gt; HMSMovementTypeDeparture then
					self.myMovement:=self.myMovement.myNextMovement.HMS_VoyageMovement;
				endif;				
			endif;
		endif;				
	endif;
	
	self.myFinanceOneServiceDef:=app.myRoot.getFirstActiveExtWebService(CM_FinanceOneSeviceDef).CM_FinanceOneSeviceDef;
	self.myActivityHistory := null;
epilog

end;</source>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <Parameter name="_invoiceLines" type="Collection"/>
    </JadeMethod>
    <JadeMethod name="sendInvoice" id="e1cdcfeb-8be1-4a60-89dc-3bba3f9aa84a">
        <updating/>
        <source>sendInvoice(_invoice : CM_Invoice input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
01 March 2023		jlier1	Initial creation 56856
23 September 2024	navmd1	TFS 66210 Save a reference to activity history so it can be updated if multiple exceptions occur

*/
vars
	invoiceLine  : CM_InvoiceLine;
	invoiceLinesByGLCode : DynaDictionary;
	foInvoice : MTNFO_Invoice;
	allInvoices : MTNFO_AllInvoices;
	tax,   
	total: Decimal[23,6];
	iter : Iterator;
	glCode, prevGlCode : String;
	invoiceLines : CM_InvoiceLineSet;
	settings : MTNFO_Settings;
	requestString,
	formattedRequestString: String;
	jsonHelper : CMIF_JsonHelper;
	logFileName		: String;
	excOccurred : Boolean;
	errMsg, exMsg, succMsg : StringUtf8;
	pxyEWSActivity : CM_ExternalWebServiceActivity;
begin
	
	if _invoice = null then
		return;
	endif;
	
	logFileName:=self.getLogFileName;
	
	self.initialiseDetails(_invoice, _invoice.invoiceLines);
	
	on Exception do self.handleFOException(exception, excOccurred);
	
	//create a finance one invoice for each grouping of gl codes and one for the entire invoice
	create foInvoice transient;
	foInvoice.usePresentationClient:=self.usePresentationClient;
	allTransients.add(foInvoice);
	foInvoice.lneLdgCode:="AR".StringUtf8;
	
	//if external dll not there or something else will get an exception as soon as i tries to use it
	if excOccurred then
		return;
	endif;
	
	self.setConstantFields(foInvoice);
	foInvoice.docRef1:=_invoice.sequenceNum.StringUtf8;
	if _invoice.myPostedCreditInvoice &lt;&gt; null then
		foInvoice.docRef2:=_invoice.myPostedCreditInvoice.sequenceNum.StringUtf8;
	endif;
	self.setDateFields(foInvoice);
	if _invoice.debtor &lt;&gt; null then
		foInvoice.lneAccnbri:=_invoice.debtor.decfinName.StringUtf8;
	endif;
	total:=_invoice.getTotalAmount.roundedTo(2);
	tax:=_invoice.getTaxAmountForInvoice.Decimal.roundedTo(2);
	self.setAmountFields(foInvoice,tax,total,0,"NA");
	self.setNarrationFields(foInvoice);
	

	create allInvoices transient;
	allInvoices.usePresentationClient:=self.usePresentationClient;
	allTransients.add(allInvoices);
	allInvoices.addInvoice(foInvoice);
	requestString:='{"invoices" : [';
	requestString:=requestString &amp; foInvoice.toString.String;
	
	create invoiceLinesByGLCode transient;
	invoiceLinesByGLCode.setMembership(CM_InvoiceLine);
	invoiceLinesByGLCode.addExternalKey(String,30,false,true);
	invoiceLinesByGLCode.endKeys(true);
	
	foreach invoiceLine in _invoice.invoiceLines discreteLock do
		invoiceLinesByGLCode.putAtKey(invoiceLine.getGLCodesString,invoiceLine);
	endforeach;
	
	create invoiceLines transient;
	
	prevGlCode:=invoiceLinesByGLCode.first.CM_InvoiceLine.getGLCodesString();
	iter:=invoiceLinesByGLCode.createIterator;
	while iter.next(invoiceLine) do
		invoiceLines.add(invoiceLine);
		glCode:=iter.getCurrentKey(1).String;
		if glCode &lt;&gt; null and glCode &lt;&gt; prevGlCode then
			//create fo invoice 
			foInvoice:=self.createGLFinanceOneInvoice(invoiceLines,glCode);
			if foInvoice &lt;&gt; null then		
				allInvoices.addInvoice(foInvoice);
				requestString:=requestString &amp; "," &amp; foInvoice.toString.String;
			endif;
			prevGlCode:=glCode;
			invoiceLines.clear;	
		endif;
	endwhile;
	
	if invoiceLines.first &lt;&gt; null then
		foInvoice:=self.createGLFinanceOneInvoice(invoiceLines,glCode);
		if foInvoice &lt;&gt; null then
			allInvoices.addInvoice(foInvoice);
			requestString:=requestString &amp;  "," &amp;   foInvoice.toString.String;
		endif;
	endif;
	
	requestString:=requestString &amp; ']}';
	
	
	if self.myFinanceOneServiceDef &lt;&gt; null then
		settings:= self.myFinanceOneServiceDef.createFinanceOneSettings(self.usePresentationClient);
		if settings &lt;&gt; null then
			self.allTransients.add(settings);
		endif;
	endif;
	
	self.myFinanceOneClient.sendInvoices(settings,allInvoices,logFileName.StringUtf8, errMsg, exMsg, succMsg);
	on Exception do null;
	
	create jsonHelper transient;
	formattedRequestString:=jsonHelper.formatJsonString(requestString);
	if formattedRequestString &lt;&gt; null then
		requestString:=formattedRequestString;
	endif;

	// need trx to update the invoice externalIntefaceStatus create the activity history
	// If an exception happens, then the handler creates the activity history
	if not excOccurred then
		app.myTrxCA.trxCreateFinanceOneActivity(_invoice, self.myFinanceOneServiceDef, requestString, errMsg.String, exMsg.String, succMsg.String, self.myActivityHistory, app.myPassport);
	elseif excOccurred and self.myActivityHistory &lt;&gt; null then
		// If something goes wrong, then just update the existing activity
		pxyEWSActivity := app.createUpdateProxy(self.myActivityHistory).CM_ExternalWebServiceActivity;
		pxyEWSActivity.setProxyRequestDetails(requestString, pxyEWSActivity.response &amp; CrLf &amp; (errMsg &amp; exMsg &amp; succMsg).String, null);
		pxyEWSActivity.CM_EWSActivityFinanceOne.setStatus(errMsg &lt;&gt; null, exMsg &lt;&gt; null, succMsg &lt;&gt; null);
		app.myTrxUA.trxUpdateEWSActivity(pxyEWSActivity, app.myPassport);
	else
		// Shouldn't get here, but lets at least log *something* just in case
		app.writeLog(method.qualifiedName &amp; " UNKNOWN Error", LogERROR);
	endif;
	
epilog
	
	delete iter;
	delete invoiceLines;
	delete invoiceLinesByGLCode;
	delete jsonHelper;
	delete pxyEWSActivity;
	
end;</source>
        <Parameter name="_invoice" type="CM_Invoice" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setAmountFields" id="4606ee31-bed3-4450-bbd1-200f9e65872e">
        <source>setAmountFields(foInvoice : MTNFO_Invoice input;_tax : Decimal; _total : Decimal; taxRate : Decimal;taxCode : String) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 March 2023	jlier1	Initial creation 56856

*/

vars
	decimalValue : MTNFO_DecimalValue;
	tax,
	total,
	totalPlusTax : Decimal [23,4];
	nanoValue : Integer;
begin
	total:=_total;
	tax:=_tax;
	totalPlusTax:=total + tax;
	if taxCode &lt;&gt; "NA" then
		tax:=-tax;
		totalPlusTax:=-totalPlusTax;
		total:=-total;
	endif;
	
	create decimalValue transient;
	decimalValue.usePresentationClient:=self.usePresentationClient;
	self.allTransients.add(decimalValue);
	nanoValue:=((totalPlusTax - totalPlusTax.Integer) * 1000000000).Integer;
	if nanoValue &lt; 0 then
		nanoValue:=-nanoValue;
	endif;
	decimalValue.createDotNetObject_1(totalPlusTax.Integer64,nanoValue);
	foInvoice.lneAmt1:=decimalValue;		
	foInvoice.lneVatRateCode:=taxCode.StringUtf8;
	
	
	create decimalValue transient;
	decimalValue.usePresentationClient:=self.usePresentationClient;
	self.allTransients.add(decimalValue);
	if taxCode ="NA" then
		decimalValue.createDotNetObject_1(0.Integer64,0.Integer);
	else
		nanoValue:=((taxRate - taxRate.Integer) * 1000000000).Integer;
		if nanoValue &lt; 0 then
			nanoValue:=-nanoValue;
		endif;
		decimalValue.createDotNetObject_1(taxRate.Integer64,nanoValue);
	endif;
	foInvoice.lneVatRateAmt:=decimalValue;	
	
	create decimalValue transient;
	decimalValue.usePresentationClient:=self.usePresentationClient;
	self.allTransients.add(decimalValue);
	nanoValue:=((tax - tax.Integer) * 1000000000).Integer;
	if nanoValue &lt; 0 then
		nanoValue:=-nanoValue;
	endif;
	decimalValue.createDotNetObject_1(tax.Integer64,nanoValue);
	foInvoice.lneVatAmt:=decimalValue;		
	
	create decimalValue transient;
	decimalValue.usePresentationClient:=self.usePresentationClient;
	self.allTransients.add(decimalValue);
	nanoValue:=((total - total.Integer) * 1000000000).Integer;
	if nanoValue &lt; 0 then
		nanoValue:=-nanoValue;
	endif;
	decimalValue.createDotNetObject_1(total.Integer64,nanoValue);
	foInvoice.lneVatExcAmt:=decimalValue;		
epilog

end;</source>
        <access>protected</access>
        <Parameter name="foInvoice" type="MTNFO_Invoice" usage="input"/>
        <Parameter name="_tax" type="Decimal"/>
        <Parameter name="_total" type="Decimal"/>
        <Parameter name="taxRate" type="Decimal"/>
        <Parameter name="taxCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="setConstantFields" id="8fc9cb33-c2a6-42fa-8480-9e1b930cce42">
        <source>setConstantFields(financeOneInvoice : MTNFO_Invoice input) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 March 2023	jlier1	Initial creation 56856

*/
vars

begin
	if financeOneInvoice = null then
		return;
	endif;

	financeOneInvoice.docId:="1";
	financeOneInvoice.impName:=ARINVPI.StringUtf8;
	financeOneInvoice.batName:=F1OVER.StringUtf8;
	financeOneInvoice.batFmtName:=F1OVER.StringUtf8;
	financeOneInvoice.batDocType:=F1OVER.StringUtf8;
	financeOneInvoice.batPgrpName:=F1OVER.StringUtf8;
	financeOneInvoice.batBalLdgCode:="GL".StringUtf8;
	financeOneInvoice.batBalAccnbri:="1999999999".StringUtf8;
	financeOneInvoice.docDocType:=ARINVPI.StringUtf8;
	financeOneInvoice.docSource:="AR".StringUtf8;
	financeOneInvoice.lneVatType:="I";
	financeOneInvoice.status:="S";
epilog

end;</source>
        <access>protected</access>
        <Parameter name="financeOneInvoice" type="MTNFO_Invoice" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setDateFields" id="8f1d8ec5-de81-40d9-9da3-d4e774566e2a">
        <source>setDateFields(foInvoice : MTNFO_Invoice input) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 March 2023	jlier1	Initial creation 56856

*/

vars
	docDate2 : TimeStamp;
begin

	self.myFinanceOneClient.setDocDate1(foInvoice,app.actualTimeServer,app.systemTimeZoneID.StringUtf8); 
	if self.myMovement = null then
		return;
	endif;
	
	docDate2:=self.myMovement.occursOnDTNEW;
	//SetDocDate1 also sets DocPeriod and BatPeriod because Jade could not convert Integer types to Integer32
	self.myFinanceOneClient.setDocDate2(foInvoice,docDate2,app.systemTimeZoneID.StringUtf8);
	self.myFinanceOneClient.setLneDueDate(foInvoice,docDate2.addDays(self.myInvoice.getTermsOfTradeStr(true).Integer),app.systemTimeZoneID.StringUtf8);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="foInvoice" type="MTNFO_Invoice" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setNarrationFields" id="95951d65-ec07-4888-b23e-8ec4cee43745">
        <source>setNarrationFields(foInvoice : MTNFO_Invoice input) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 March 2023	jlier1	Initial creation 56856

*/
constants
	Export = "Export";
	Import = "Import";
vars
	narr1,
	narr2,
	narr3 : String;
begin	
	if self.myVoyage &lt;&gt; null then
		narr1:=self.myVoyage.myVessel.name;
		if self.isDischarge then
			narr1:=narr1 &amp; Space &amp; self.myVoyage.inwardCode;
		else
			narr1:=narr1 &amp; Space &amp; self.myVoyage.voyageCodeExternal;
		endif;
		narr1:=narr1.trimBlanks;
		if self.myMovement &lt;&gt; null then
			narr1:=narr1 &amp; Space &amp; self.myMovement.getMyBerth.code;
		endif;
		narr2 :=self.myVoyage.code;
		if self.myTrackedItem &lt;&gt; null then
			narr2:=narr2 &amp; Space &amp; self.myTrackedItem.manifestNumber;
		endif;
		narr2:=narr2.trimBlanks;
	endif;
	
	foInvoice.lneNarr1:=narr1.StringUtf8;
	foInvoice.lneNarr2:=narr2.StringUtf8;
	if self.isDischarge then
		foInvoice.lneNarr3:=Import;
	else
		foInvoice.lneNarr3:=Export;
	endif;
epilog	

end;</source>
        <access>protected</access>
        <Parameter name="foInvoice" type="MTNFO_Invoice" usage="input"/>
    </JadeMethod>
</Class>
