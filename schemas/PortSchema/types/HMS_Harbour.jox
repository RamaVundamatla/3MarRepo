    <JadeMethod name="getFirstRegionWithChkPts" id="19bcf01b-3395-4001-97e4-0214704bee6f">
        <updating/>
        <source>getFirstRegionWithChkPts(totalOffsetTime: Integer io; enterLeaveStatus:String io; _movement: HMS_VoyageMovement):HMS_HarbourRegion updating;

vars
	toBerth:			HMS_Berth;
	fromBerth:			HMS_Berth;
	pathToCheck:		HMS_MovementPath;
	path:				HMS_MovementPath;
	regA:				HMS_HarbourRegion;
	regB:				HMS_HarbourRegion;
	baseTimeAtRegA:		Boolean;
	directionFwd:		Boolean;
	pathSegment:		HMS_PathSegment;
	regToCheck:			HMS_HarbourRegion;
	offSetTime:			Integer;
	movePrev:			HMS_VoyageMovement;

begin
	// This method returns the first region with checkpoints that is 
 	// crossed as a ship moves from one region to another. It also calculates the 
 	// offset time (from basetime) to this region and the 'entering/leaving' the harbour status.

 	// SCRUCTURE:
 	// Check to see if a path exists for this movement
 	// If it does, find first region on path with checkpoints
 	// If it doesn't, check both to and from regions for checkpoints
	if _movement = null then
		return null;
	endif;
	movePrev := _movement.getVoyageMovementPrevious();

	// Get enterLeaveStatus and from/to regions
	enterLeaveStatus := self.getShipEnterLeaveStatus(regA,regB,movePrev);

	


	// Initialise offset time
	totalOffsetTime	:=	0;
	
	// Determine which end the basetime is relative to:
	if _movement.moveType = HMSMovementTypeArrival then
		// Arrival movement
		// Determine which end of the path the base time needs to be associated with
   		if self.baseTimeArrive = AtSea then
   			baseTimeAtRegA	:=	true;
   		endif;		
	elseif _movement.moveType = HMSMovementTypeDeparture then
		// Departure movement 
		// Determine which end of the path the base time needs to be associated with
   		if self.baseTimeDepart = AtWharf then
   			baseTimeAtRegA	:=	true;
   		endif;
	else
		// Shift movement
		// Determine which end of the path the base time needs to be associated with
   		if self.baseTimeDepart = AtBerthDepartingFrom then
   			baseTimeAtRegA	:=	true;
			
   			if movePrev &lt;&gt; null then
   				// If the shift is from a logical berth eg Roadstead, then set BT to
   				// the time at the physical berth (ie destination or regB)
   				if movePrev.isLogicalBerth() then
   					baseTimeAtRegA	:=	false;
   				endif;
   			endif;
   		endif;
	endif;


	// Check to see if a path is defined. If it is, then find the first region with checkpoints 
	// along the path

    foreach path in self.allMovementPaths do
    	if path.myRegionFrom = regA and path.myRegionTo = regB then
    		pathToCheck	:=	path;
    		// Set direction along path to fwd=true ie. The ship is travelling
    		// from regA to regB
    		directionFwd	:=	true;
    	elseif path.myRegionFrom = regB and path.myRegionTo = regA then
    		pathToCheck		:=	path;
    		// Set direction along path to fwd=false ie. The ship is travelling
    		// from regB to regA
    		directionFwd	:=	false;
    		// Swap BT ends
    		baseTimeAtRegA	:=	not (baseTimeAtRegA);  //- not sure why this is here - RH 06/08/99

    	endif;
    endforeach;


    


   	if pathToCheck &lt;&gt; null then
   		// Check this path
   		// Step through all regions along path and check their respective checkpoints
   		// at the appropriately offset times

   		if (baseTimeAtRegA = true and directionFwd = true) then
   			// Check regions along path in direction = from 'A' to 'B'
   				// Set basetime=movement time
   				//basetime:=self.occursOnDT;
   				// Check checkpoints at reg A at basetime
   				if regA.hasCheckpointsWithTidalModel() then
   					// Checkpoints to check
   					return regA;
   				endif;
				
   				foreach pathSegment in pathToCheck.allPathSegments do
   					regToCheck		:=	pathSegment.myRegionTo;
   					offSetTime		:=	pathSegment.steamingTimeAB;
   					totalOffsetTime	:=	totalOffsetTime+offSetTime;
   					//basetime		:=	basetime+offSetTime;
   					if regToCheck.hasCheckpointsWithTidalModel() then
   						return regToCheck;
   					endif;
   				endforeach;
				
   		elseif (baseTimeAtRegA = false and directionFwd = true) then
   			// Check regions along path in direction = from 'B' to 'A'
   				// Set basetime = movement time
   				//basetime	:=	self.occursOnDT;
   				// Check checkpoints at reg B at basetime
   				if regB.hasCheckpointsWithTidalModel() then
   					// Checkpoints to check
   					return regB;
   				endif;
				
   				foreach pathSegment in pathToCheck.allPathSegments reversed do
   					regToCheck		:=	pathSegment.myRegionFrom;
   					offSetTime		:=	pathSegment.steamingTimeAB;
   					totalOffsetTime	:=	totalOffsetTime-offSetTime;
   					//basetime		:=	basetime-offSetTime;
   					if regToCheck.hasCheckpointsWithTidalModel() then
   						return regToCheck;
   					endif;
   				endforeach;
				
   		elseif (baseTimeAtRegA = true and directionFwd = false) then
   			// Check regions along path in direction = from 'A' to 'B'
   				// Set basetime = movement time
   				//basetime	:=	self.occursOnDT;
   				// Check checkpoints at reg A at basetime
   				if regA.hasCheckpointsWithTidalModel() then
   					// Checkpoints to check
   					return regA;
   				endif;
				
   				foreach pathSegment in pathToCheck.allPathSegments do
   					regToCheck		:=	pathSegment.myRegionTo;
   					offSetTime		:=	pathSegment.steamingTimeBA;
   					totalOffsetTime	:=	totalOffsetTime-offSetTime;
   					//basetime		:=	basetime-offSetTime;
   					if regToCheck.hasCheckpointsWithTidalModel() then
   						return regToCheck;
   					endif;
   				endforeach;
				
   		elseif (baseTimeAtRegA = false and directionFwd = false) then
   			// Check regions along path in direction = from 'B' to 'A'
   				// Set basetime = movement time
   				//basetime	:=	self.occursOnDT;
   				// Check checkpoints at reg B at basetime
   				if regB.hasCheckpointsWithTidalModel() then
   					// Checkpoints to check
   					return regB;
   				endif;
   				foreach pathSegment in pathToCheck.allPathSegments reversed do
   					regToCheck		:=	pathSegment.myRegionFrom;
   					// 06/08
   					offSetTime		:=	pathSegment.steamingTimeBA;
   					totalOffsetTime	:=	totalOffsetTime+offSetTime;
   					//basetime		:=	basetime+offSetTime;
   					if regToCheck.hasCheckpointsWithTidalModel() then
   						return regToCheck;
   					endif;
   				endforeach;
   		endif;
   	else
   		// If path is not defined - check region A and B for checkpoints
   		if regA &lt;&gt; null and regA.hasCheckpointsWithTidalModel() then
   			return regA;
   		elseif regB &lt;&gt; null and regB.hasCheckpointsWithTidalModel() then
   			return regB;
   		else
			return null;
		endif;
   	endif;
end;</source>
        <Parameter name="totalOffsetTime" type="Integer" usage="io"/>
        <Parameter name="enterLeaveStatus" type="String" usage="io"/>
        <Parameter name="_movement" type="HMS_VoyageMovement"/>
        <ReturnType type="HMS_HarbourRegion"/>
    </JadeMethod>
    <JadeMethod name="getHMSTransForAuditEnquiry" id="464e9c6a-3578-4538-9028-9e559f08148d">
        <source>getHMSTransForAuditEnquiry(_auditEnquirySearcher : CMIF_HMS_AuditEnquiry input; _passport : CM_Passport input);
//--------------------------------------------------
// Created:	17 September 2004 By: cnwgd1
//--------------------------------------------------
vars
	terminal : CM_Terminal;
	tmpDict : CM_TerminalByCodeDict;
begin
	if _auditEnquirySearcher = null then
		app.setContinueCMExceptions(false);
		app.raiseUnexpectedProgramError(class.name, method.name, '_auditEnquirySearcher is null');
		return;
	endif;

	if _auditEnquirySearcher.allSelectedTerminals.isEmpty then
		tmpDict := self.allTerminalsByCode;
	else
		tmpDict := _auditEnquirySearcher.allSelectedTerminals;
	endif;
		
	foreach terminal in tmpDict do
		terminal.getHMSTransForAuditEnquiry(_auditEnquirySearcher, _passport);
	endforeach;
end;</source>
        <Parameter name="_auditEnquirySearcher" type="CMIF_HMS_AuditEnquiry" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getMatchingVoyagesMovements" id="04b8e151-bba5-43a6-a033-75a51db1803b">
        <source>getMatchingVoyagesMovements(_searcher : CMIF_HMSVoyageSearcher input; _passport : CM_Passport input);
// -------------------------------------------
// Created 12 May 2004 by cnwdvb1
// -------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// 23 Apr 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement

vars
	iter				: Iterator;
	movement			: HMS_VoyageMovement;
	voyageData			: HMS_VoyageData;
	vessel				: CM_Vessel;
	voyage				: CM_Voyage;
	failedDAC  :CM_DataAccessController;
	movementPilotDetails : HMS_MovementPilotDetails; // TFS 44438
	found : Boolean; // TFS 44438
begin

	iter := self.allVoyageMovements.createIterator();
	self.allVoyageMovements.startKeyGeq(_searcher.searchStartDT, iter);

	while iter.next(movement) do

		if (not movement.occursOnDTNEW &lt;= _searcher.searchFinishDT) then
			break;
		endif;
	
		if (not movement.canUserAccessSelf(null, failedDAC, _passport)) then
			continue;
		endif;

		voyageData := movement.myHMSVoyageData;
		if voyageData = null then
			continue;
		endif;

		voyage := voyageData.myVoyage;
		if voyage = null then
			continue;
		endif;

		// Build list of voyages

 		// Check 'Ship Name' Criteria
 		if _searcher.mySelectedShip &lt;&gt; null then
			vessel := movement.getMyVessel();
			if vessel = null then 
				continue;
			endif;
			if vessel &lt;&gt; _searcher.mySelectedShip then
 				continue;
 			endif;
 		endif;

 		// Check 'Ship Type' Criteria
 		if _searcher.mySelectedShipType &lt;&gt; null then
 			if voyageData.myVesselType &lt;&gt; _searcher.mySelectedShipType then
				continue;
			endif;
 		endif;

 		// Check 'Ship Line Co' Criteria
 		if _searcher.mySelectedShipLinesCo &lt;&gt; null then
 			if voyage.myShippingLine &lt;&gt; _searcher.mySelectedShipLinesCo then
 				continue;
 			endif;
 		endif;
		if _searcher.mySelectedAgent &lt;&gt; null then
			if movement.myShippingAgent &lt;&gt; _searcher.mySelectedAgent then
				continue;
			endif;
		endif;
		if _searcher.mySelectedPilot &lt;&gt; null then
			//31 Oct 2018	NDL	TFS 41662
			if movement.allMovementPilotDetails.isEmpty then //allPilots.isEmpty then // TFS 44438
				if movement.getUnConvertedMyPilotRef &lt;&gt; _searcher.mySelectedPilot then// allow for old single ref
					continue;
				endif;
			//elseif not movement.allPilots.includes( _searcher.mySelectedPilot ) then // --&gt; TFS 44438
			else
				foreach movementPilotDetails in movement.allMovementPilotDetails where movementPilotDetails.myPilot = _searcher.mySelectedPilot do
					found := true;
					break;
				endforeach;
				if not found then
					continue;
				endif; // &lt;-- TFS 44438	
			endif; 
		//	if movement.myPilot &lt;&gt; _searcher.mySelectedPilot then
		//		continue;
		//	endif;
		endif;
		if _searcher.mySelectedBerth &lt;&gt; null then
			if movement.getMyBerth &lt;&gt; _searcher.mySelectedBerth then
				continue;
			endif;
		endif; 		
 		_searcher.allMovementsFound.add(movement);
 		_searcher.exportsArray.add(movement);
 		if (not _searcher.allVoyagesFound.includes(voyage)) then
	 		_searcher.allVoyagesFound.add(voyage); 		
	 	endif;
	endwhile;

epilog	
	delete iter;
end;</source>
        <Parameter name="_searcher" type="CMIF_HMSVoyageSearcher" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getMovementsInDateRange" id="b56877a9-9a89-4d93-9eb6-b476a96aff45">
        <source>getMovementsInDateRange(_fromDT, _endDT : TimeStamp; _terminal : CM_Terminal; _movementsColl : Collection input);

vars
	iter : Iterator;
	tmpMove		: HMS_VoyageMovement;
	tmpVoyage	: CM_Voyage;
begin
	// This method builds a collection of permanent movements that could potentially require validation
	_movementsColl.clear;

	iter := self.allVoyageMovements.createIterator;
	self.allVoyageMovements.startKeyGeq(_fromDT, iter);
	while iter.next(tmpMove) do
		if _endDT.isValid and
		   tmpMove.occursOnDT &gt; _endDT then
			break;
		endif;
		
		if _terminal &lt;&gt; null then
			tmpVoyage := tmpMove.getVoyage;
			if tmpVoyage = null or tmpVoyage.myTerminal &lt;&gt; _terminal then
				continue;
			endif;
		endif;
		
		_movementsColl.add(tmpMove);
	endwhile;			

epilog
	delete iter;

end;</source>
        <Parameter name="_fromDT" type="TimeStamp"/>
        <Parameter name="_endDT" type="TimeStamp"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_movementsColl" type="Collection" usage="input"/>
    </JadeMethod>
