    <JadeMethod name="getControllerInfoFromTable" id="3d2010c8-e5e4-4396-a5f1-5a13e1200000">
        <source>getControllerInfoFromTable(_cmif : CMIF_BGPManagerChildren input) : Boolean  protected;

// cnwdvb1 12 November 2002 
//
//28 Apr 2016	cnwrs1	TFS Push Events Geneva
// 10 May 2017	cnwrs1	TFS 3518 remove Push Events
// 11 June 2018	jlgrs1	TFS 39013 (37190) Pelindo BGP Web Service
begin
	_cmif.myUser	:=	cmbUser.listObject.CM_User;
	
	if self.aMyBGPObject.isKindOf(BGP_BackupJournal) then
		return self.setBackupJournal(_cmif);
	elseif self.aMyBGPObject.isKindOf(BGP_CalendarCheckController) then
		return self.setCalendarCheck(_cmif);
	elseif self.aMyBGPObject.isKindOf(BGP_ChangeTrackerController) then
		return self.setChangeTracker(_cmif);
	elseif self.aMyBGPObject.isKindOf(BGP_ExternalWSController) then
		return self.setExtWebService(_cmif); 
	elseif self.aMyBGPObject.isKindOf(BGP_GenericController) then
		return self.setGeneric(_cmif);
	//BGP_LocationStatistics
	elseif self.aMyBGPObject.isKindOf(BGP_LockKeeperController) then
		return self.setLockKeeper(_cmif);
	elseif self.aMyBGPObject.isKindOf(BGP_RFIDListenController) then
		return self.setRFIDListener(_cmif);
	elseif self.aMyBGPObject.isKindOf(BGP_ReportController) then
		return self.setPrinter(_cmif); //PAR22336 - cnwsh3 27/07/2010 - Temp directory for managed service systems
		//_cmif.myPDFPrinter	:=	fieldPDFPrinter.getObject().CM_PrinterDef;
		//return true;
	elseif self.aMyBGPObject.isKindOf(BGP_TCPClient) then
		return self.setTcpIpClient(_cmif);
	elseif self.aMyBGPObject.isKindOf(BGP_AutoTimerController) then
		return self.setTimerRequest(_cmif);
	elseif self.aMyBGPObject.isKindOf(BGP_AutoWarningController) then
		return self.setAutoWarning(_cmif);
	elseif self.aMyBGPObject.isKindOf(BGP_DirectoryController) then
		return self.setDirectory(_cmif);
	//BGP_FutureTimerController
	elseif self.aMyBGPObject.isKindOf(BGP_VehicleBookingSlotCont) then
		return self.setVehicleBookingSlot(_cmif);
	elseif self.aMyBGPObject.isKindOf(BGP_DeferredChargingController) then	//06 Jul 2021	NDL	TFS 51443
		return self.setDeferredCharging(_cmif);
	//BGP_WorkOrderScheduler
	elseif self.aMyBGPObject.isKindOf(BGP_XMLListenController) then
		return self.setTCP(_cmif);
	else
		return true;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_cmif" type="CMIF_BGPManagerChildren" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getManagerInfoFromTable" id="11293e53-63d5-47b1-a69f-bda6ef754b71">
        <source>getManagerInfoFromTable(_cmif : CMIF_BGPManagerChildren input) protected;

// cnwdvb1 24 October 2002 
//
//28 Apr 2016	cnwrs1	TFS Push Events Geneva
// 10 May 2017	cnwrs1	TFS 3518 remove Push Events
// 11 June 2018	jlgrs1	TFS 39013 (37190) Pelindo BGP Web Service
vars

	
begin
	_cmif.isServer 				:= self.fieldIsServer.getBoolean();
	_cmif.managerName			:= self.fieldManagerName.getString();
	_cmif.numberOfRemotes		:= self.fieldNoRemotes.getInteger();
	_cmif.numberOfReports		:= self.fieldNoReports.getInteger();
	_cmif.numberOfDirectories	:= self.fieldNoDirect.getInteger();
	_cmif.numberOfTcpIpServers	:= self.fieldNoTcpServer.getInteger();
	_cmif.numberOfExtWSServices := self.fieldNoExtWSrvs.getInteger();
	_cmif.isAutoTimer			:= self.fieldIsAutoTimer.getBoolean();
	_cmif.isFutureTimer			:= self.fieldIsFutureTim.getBoolean();	// ***
	_cmif.numberOfTcpIpClients	:= self.fieldNoTcpClient.getInteger();
	_cmif.isLockKeeper			:= self.fieldIsLockKeep.getBoolean();
	_cmif.isChangeTracker		:= self.fieldIsChgTrack.getBoolean();
	_cmif.isBackupJournal 		:= self.fieldIsBackupJnl.getBoolean();
	_cmif.machineNameSpecific	:= self.fieldMachineName.getString();
	_cmif.isAutoWarning			:= self.fieldIsAutoWarn.getBoolean();
	_cmif.isRFIDListenController:= self.fieldIsRFIDList.getBoolean();
	_cmif.isFatClientOnly		:= self.fieldIsFatOnly.getBoolean();
	_cmif.isLocationStatistics  := self.fieldIsLocStats.getBoolean();
	_cmif.isWorkOrderScheduler  := self.fieldIsWOSched.getBoolean();
	_cmif.isCalendarCheck		:= self.fieldIsCalCheck.getBoolean();	// 02 Nov 2010	NDL	Par 25530
	_cmif.isVSBookGen			:= self.fieldIsVSBookGen.getBoolean();	//15 Apr 2013	NDL	Par 31393
	_cmif.isDeferred			:= self.fieldIsDeferred.getBoolean();	//06 Jul 2021	NDL	TFS 51443
end;</source>
        <access>protected</access>
        <Parameter name="_cmif" type="CMIF_BGPManagerChildren" usage="input"/>
    </JadeMethod>
    <JadeMethod name="initObjects" id="05177a60-0aff-4925-b8c2-4783807704a5">
        <updating/>
        <source>initObjects(_bgpObject : BGP_Object; _mode : Integer; _isManager : Boolean) updating;
// -------------------------------------------
// Created 09 September 2003 by cnwdvb1
// -------------------------------------------
begin
	self.aMyBGPObject	:= _bgpObject;
	self.aMode			:= _mode;
	self.aIsManager		:= _isManager;
end;</source>
        <Parameter name="_bgpObject" type="BGP_Object"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_isManager" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadCombos" id="634a34ea-2b58-435a-88e9-61cdb1d223ce">
        <source>loadCombos() protected;
//
// cnwdvb1 14 November 2002 
//
// 11 June 2018	jlgrs1	TFS 39013 (37190) Pelindo BGP Web Service
//
vars
	classObj		: Class;
	dynaDictObj		: DynaDictionary;
	sorterObj		: CMIF_SortBGPControllers;
	memberObj		: Object;
	displayValue	: String;
begin
//	self.cmbWorkerType.clear();
//	self.cmbWorkerType2.clear();
	fieldWorkerType.addItem(CMIF_BGPManagerChildren.XML);

//	if app.getMyUser.canDo(null, PmRefCon) then
	if app.getMyUser.canDo(null, Mod_BaseSystem) then //07 Oct 2019	NDL	TFS 46169
		self.fieldWorkerType2.addItem(CMIF_BGPManagerChildren.Refcon);
	endif;
	
	self.myAssistant.fieldTerminal(fieldTerminal, null);
//	self.myAssistant.comboBoxTerminal(self.cmbTerminal, null);
	self.myAssistant.comboBoxUser(self.cmbUser, null);
	
	app.myRoot.getPDFPrinters(self.aAllPDFPrinters);
	fieldPDFPrinter.listCollection(self.aAllPDFPrinters, false, Collection.CNEC_DISPLAY_ORDER_COLLECTION);
	
	self.myAssistant.comboBoxFieldExtWebServices(self.fieldExtWebSrvs, null);

	self.loadRequestClasses();
	
	create dynaDictObj transient;
	dynaDictObj.setMembership(CMIF_SortBGPControllers);
	dynaDictObj.addMemberKey(CMIF_SortBGPControllers::displayTest.name, false, true);
	dynaDictObj.endKeys(true);
	
	foreach classObj in self.aAllRequests do
		displayValue	:=	classObj.text.cnEcGetTagValueOfName('display');
		if displayValue &lt;&gt; null then
			create sorterObj transient;
			sorterObj.displayTest		:=	displayValue[1:60]; // Only problem during sorting.
			sorterObj.myRequestClass	:=	classObj;
			dynaDictObj.add(sorterObj);
		endif;
	endforeach;
	
	self.aAllRequests.clear();
	
	foreach memberObj in dynaDictObj do
		self.aAllRequests.add(memberObj.CMIF_SortBGPControllers.myRequestClass);
	endforeach;
	
	self.lstTable.clearSelected();
	self.lstTable.displayCollection(self.aAllRequests, false, 0, null);
	self.loadWarnListTable();
epilog
	dynaDictObj.purge();
	delete dynaDictObj;
end;</source>
        <access>protected</access>
    </JadeMethod>
