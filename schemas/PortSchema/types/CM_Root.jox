    <JadeMethod name="getFirstActiveEWSForEndpoint" id="6cbc9462-ae00-4ccc-8fd1-2e3dfe2b1cb7">
        <source>getFirstActiveEWSForEndpoint(_endpoint : String) : CM_ExternalWebServiceDef;
//
// Purpose:			Find the first active External Web Service Definition that has _endpoint as one of its defined endpoints
//
// Parameters:		_endpoint - the endpoint (ETRow_ global constant) the caller is asking for
//
// Return Value:	The active External Web Service that knows about the _endpoint
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 18/04/2023	navdap1		TFS 57207 EUP - Refactor Inspection App API Message
//
vars
	ews : CM_ExternalWebServiceDef;

begin
	foreach ews in self.allExternalWebServices discreteLock do
		if ews.allEndpoints[_endpoint] &lt;&gt; null and ews.active then
			return ews;
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_endpoint" type="String"/>
        <ReturnType type="CM_ExternalWebServiceDef"/>
    </JadeMethod>
    <JadeMethod name="getFirstActiveExtWebService" id="08d4e35b-07f7-4466-a732-7f9df1440789">
        <source>getFirstActiveExtWebService( _type : Class ):CM_ExternalWebServiceDef;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 August 2020	jlgndl1	Initial creation	TFS 49869

*/

vars

	iter : Iterator;
	extWebService : CM_ExternalWebServiceDef;

begin

	iter := self.allExternalWebServices.createIterator;
	while iter.next( extWebService ) do
		if not extWebService.active then
			continue;
		endif;
		if extWebService.isKindOf( _type ) then
			return extWebService;
		endif;
	endwhile;
	
	return null;

epilog

	delete iter;

end;</source>
        <Parameter name="_type" type="Class"/>
        <ReturnType type="CM_ExternalWebServiceDef"/>
    </JadeMethod>
    <JadeMethod name="getFirstCargoTypeForTerminal" id="29a1da84-3d14-48fd-a283-64ade5a5c934">
        <source>getFirstCargoTypeForTerminal(_terminal : CM_Terminal; _className : String) : CM_CargoType;
/*
Purpose:			
Date		Who		Reason
13 October 2016	cnwab1	Initial creation
*/

vars
	ct : CM_CargoType;
begin
	
	foreach ct in self.allCargoTypesById discreteLock do
		if ct.isSystemCargoBOLType then
			continue;
		endif;
		
		if _terminal = null
		or ct.allTerminals.includes(_terminal) then
			return ct;
		endif;
	
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_className" type="String"/>
        <ReturnType type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="getFutureActor" id="50fac5fa-0698-4d5f-b125-3453b4d99053">
        <source>getFutureActor(_parent : CM_Object; _class : Class) : CM_OfflineFutureActor;
/*
Purpose - 	
Who - NAVAB1
Date - 18JUNE2024
ADO -  BUG 64680
*/

vars
	actor	: CM_OfflineFutureActor;
	iter	: Iterator;
begin
	if _parent &lt;&gt; null then
		iter := self.allOfflineFutureActorParents.createIterator();
		self.allOfflineFutureActorParents.startKeyGeq(_parent, iter);
		while iter.next(actor) do
			if actor.myParentObject &lt;&gt; _parent then
				break;
			endif;
			if _class &lt;&gt; null 
			and actor.class &lt;&gt; _class then
				continue;
			endif;
			return actor;
		endwhile;
	endif;
	
	return null;
epilog
	delete iter;
end;
</source>
        <Parameter name="_parent" type="CM_Object"/>
        <Parameter name="_class" type="Class"/>
        <ReturnType type="CM_OfflineFutureActor"/>
    </JadeMethod>
    <JadeMethod name="getFutureActors" id="9e16398d-9fa1-4394-9a00-89d98ac4a24e">
        <source>getFutureActors(_parent : CM_Object; _class : Class; _coll : CM_OfflineFutureActorDict input);
/*
Purpose - 	
Who - NAVAB1
Date - 18JUNE2024
ADO -  BUG 64680
*/

vars
	actor	: CM_OfflineFutureActor;
	iter	: Iterator;
begin
	if _parent &lt;&gt; null then
		iter := self.allOfflineFutureActorParents.createIterator();
		self.allOfflineFutureActorParents.startKeyGeq(_parent, iter);
		while iter.next(actor) do
			if actor.myParentObject &lt;&gt; _parent then
				break;
			endif;
			if _class &lt;&gt; null 
			and actor.class &lt;&gt; _class then
				continue;
			endif;
			_coll.addNoDuplicates(actor, false);
		endwhile;
	endif;
	
epilog
	delete iter;
end;
</source>
        <Parameter name="_parent" type="CM_Object"/>
        <Parameter name="_class" type="Class"/>
        <Parameter name="_coll" type="CM_OfflineFutureActorDict" usage="input"/>
    </JadeMethod>
