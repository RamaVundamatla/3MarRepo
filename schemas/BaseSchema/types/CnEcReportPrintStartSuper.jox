    <JadeMethod name="setTableProperties" id="790282f9-1b87-42c2-b21d-eb93bf07b3a4">
        <updating/>
        <source>setTableProperties(pTable:Table input) updating, protected;

vars
	columnWidthArray	: IntegerArray;

begin
	pTable.rows				:=	1;
	pTable.rowHeight[1]		:=	20;
	pTable.columns			:=	5;
	pTable.columnVisible[5]	:=	false;
	
	create columnWidthArray transient;
	columnWidthArray.add(25);
	columnWidthArray.add(10);
	columnWidthArray.add(25);
	columnWidthArray.add(42);
	pTable.cnEcSetColumnWidths(columnWidthArray);

	pTable.setCellText(1, 1, "Name");
	pTable.setCellText(1, 2, "Required");
	pTable.setCellText(1, 3, "Type");
	pTable.setCellText(1, 4, "Value");
	
	pTable.sortColumn[1]	:=	5;
epilog
	delete columnWidthArray;
end;</source>
        <access>protected</access>
        <Parameter name="pTable" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="unload" id="c50039cd-e305-4100-95de-5c199bd48fca">
