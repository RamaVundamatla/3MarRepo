    <JadeMethod name="displayAttribute" id="8c177aa3-a5e2-4d5f-ae39-33bd8fe8f767">
        <updating/>
        <source>displayAttribute(_theAttribute : CM_DrawingAttribute;_theY1 : Integer io;_theFrame: Frame input;_useBlack : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
//	theLabel : String;
	theDrawingAttribute : CM_DrawingAttribute;
//	theX, theY, tmpX, tmpY,theAttribCount : Integer;
//	theFontName : String;
//	theDrawTextAlign
	theColour : Integer;
	theFontSize : Real;
	
begin
	theFontSize := _theFrame.drawFontSize;
	theDrawingAttribute := _theAttribute;
	if theDrawingAttribute = null then
		return;
	endif;

	if _useBlack then
		theColour := Black;
	else
		theColour := theDrawingAttribute.colour;
	endif;
	
	_theFrame.drawFontName := theDrawingAttribute.fontName;
	_theFrame.drawFontSize := 12;
	_theFrame.drawTextAlign := Frame.DrawTextAlign_Left; //DrawTextAlign_Center;
	_theFrame.drawTextAt(theDrawingAttribute.fontCharacter.Character, 5,_theY1,theColour);
epilog
	_theFrame.drawFontSize := theFontSize;
end;</source>
        <Parameter name="_theAttribute" type="CM_DrawingAttribute"/>
        <Parameter name="_theY1" type="Integer" usage="io"/>
        <Parameter name="_theFrame" type="Frame" usage="input"/>
        <Parameter name="_useBlack" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="displayLabel" id="fe9a1f78-9a6c-404d-ab72-0789e44f3c83">
        <updating/>
        <source>displayLabel(_theAttribute : CM_DrawingAttribute;_theY1 : Integer io;_theFrame: Frame input;_useBlack : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//17 Oct 2017	cnwma1  TFS #7431 JMT - Refactoring - Drawing Attributes Labels
// ---------------------------------------------------------------------------
vars
	theLabel : String;
	theDrawingAttribute : CM_DrawingAttribute;
//	theX, theY, tmpX, tmpY,theAttribCount : Integer;
//	theFontName : String;
//	theDrawTextAlign
	theColour : Integer;
	theFontSize : Real;
	
begin
	theFontSize := _theFrame.drawFontSize;
	theDrawingAttribute := _theAttribute;
	if _theAttribute = null then
		return;
	endif;
	_theFrame.drawFontName := "Helvetica";
	_theFrame.drawFontSize := 10;
	_theFrame.drawTextAlign := Frame.DrawTextAlign_Left; 
	
	if _useBlack then
		theColour := Black;
	else
		theColour := theDrawingAttribute.colour;
	endif;

	//theLabel := theDrawingAttribute.getLabel();  //17.10.2017	cnwma1  TFS #7431
	theLabel := theDrawingAttribute.label;    	   //17.10.2017	cnwma1  TFS #7431
	theLabel := "- " &amp; theLabel;
	_theFrame.drawTextAt(theLabel, 35,_theY1,theColour);
epilog
	_theFrame.drawFontSize := theFontSize;
end;</source>
        <Parameter name="_theAttribute" type="CM_DrawingAttribute"/>
        <Parameter name="_theY1" type="Integer" usage="io"/>
        <Parameter name="_theFrame" type="Frame" usage="input"/>
        <Parameter name="_useBlack" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doCentreOnSelectedPoint" id="d5d4162a-f2dc-483c-b34d-a480b9ed49c2">
        <source>doCentreOnSelectedPoint();
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	posH, posV : Real;
	theHValue, theVValue : Integer;	
//	endTime,startTime : TimeStamp;
	thePoints : CMUI_GridPointSet;
	aPoint : CMUI_GridPoint;
	theSDF : CMUI_ScrollableDrawingFrame;
begin
	app.mousePointer := Window.MousePointer_HourGlass;
	theSDF := self;
	
	create thePoints transient;
	theSDF.getAllSelectedPoints(thePoints);
	posH := (theSDF.myHScroll.value / theSDF.myHScroll.max).Real;
	posV := (theSDF.myVScroll.value / theSDF.myVScroll.max).Real;
	
	aPoint := thePoints.first;
	
	if aPoint &lt;&gt; null then
		aPoint.getXYOnSDF(theHValue,theVValue);
		aPoint.drawSelf(aPoint.myGridArea.myGridAreaFrame);
	else
		theHValue := (theSDF.myHScroll.max * posH).Integer;
		theVValue := (theSDF.myVScroll.max * posV).Integer;
	endif;
	
	theSDF.myHScroll.value := theHValue;
	theSDF.myVScroll.value := theVValue;
	theSDF.repositionScrollBars();
epilog 
	delete thePoints;
	app.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doDrawSDFViewModePicture" id="e398c728-acc5-464a-939f-2d762c70de79">
        <source>doDrawSDFViewModePicture(_mode : Integer);
// ---------------------------------------------------------------------------
// Created:		August 2003 By Andrew Bishop cnwab1
//
// ---------------------------------------------------------------------------
// 12/11/2012	cnwcs5	par 30519 - translations
vars
	theRoot : CM_Root;
	aPicture : Binary;
	
begin
	theRoot := app.myRoot;
	
	if _mode = VIEW_OPERATOR then
		aPicture := theRoot.getConfig(PicOperatorUp).Binary;	
	elseif _mode = VIEW_VOYAGE then
		aPicture := theRoot.getConfig(PicVoyageUp).Binary;	
	elseif _mode = VIEW_TEMPERATURE then
		aPicture := theRoot.getConfig(PicTempUp).Binary;	
	elseif _mode = VIEW_COMMODITY then
		aPicture := theRoot.getConfig(PicCommodityUp).Binary;	
	elseif _mode = VIEW_WEIGHT then
		aPicture := theRoot.getConfig(PicWeightUp).Binary;	
	elseif _mode = VIEW_CONSIGNEE then
		aPicture := theRoot.getConfig(PicConsigneeUp).Binary;	
	elseif _mode = VIEW_DISPORT then
		aPicture := theRoot.getConfig(PicDisPortUp).Binary;	
	elseif _mode = VIEW_LOADPORT then
		aPicture := theRoot.getConfig(PicLoadPortUp).Binary;	
	elseif _mode = VIEW_STATUS then
		aPicture := theRoot.getConfig(PicStatusUp).Binary;	
	elseif _mode = VIEW_ISOGROUP then
		aPicture := theRoot.getConfig(PicISOUp).Binary;	
	endif;

	self.myTopLeftFillerFrame.autoRedraw := true;
	self.myTopLeftFillerFrame.bubbleHelp := app.getErrorString1 (View_by_mode, app.getViewModeString(_mode));
	
	if aPicture &lt;&gt; null then
		self.myTopLeftFillerFrame.drawPictureAt(aPicture,4,4);
	endif;
end;</source>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doEventRefreshVoyageArea" id="77cb15b0-b97a-4240-8834-b45cbc888f13">
        <source>doEventRefreshVoyageArea();
// ---------------------------------------------------------------------------
// Created:		July 2003 By Andrew Bishop cnwab1
//
// Purpose:		Update and redraw the whole display - this is a result of a big update like EDI make actual or Auto Discharge colour coding
// ---------------------------------------------------------------------------
vars
	aGridArea : CMUI_GridArea;
	aGridPoint : CMUI_GridPoint;
	parentForm : Form;
	aDict : CMUI_GridAreasByLabelDict;
begin
	parentForm := self.myParentForm;

	if not parentForm.isKindOf(CMUI_GridAreaForm) then
		return;
	endif;
	parentForm.sendMsgWithParams(CMUI_GridAreaForm::doChangeGridGenerateFlag.name,ShpDisplayMode_ColCodeLoad);
	parentForm.sendMsgWithParams(CMUI_GridAreaForm::doChangeGridGenerateFlag.name,ShpDisplayMode_ColCodeDisch);

	parentForm.sendMsg(CMUI_GridAreaForm::doCompleteUpdateOfGrids.name);
	return;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doNotableAdd" id="c78d3a17-4b79-4715-89a2-f08c54762fa2">
        <source>doNotableAdd(_anObject : Object);
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	tmpTerm	: CM_Terminal;

begin
	if (not self.allNotableObjects.includes(_anObject)) then
		self.allNotableObjects.add(_anObject);
		
		tmpTerm := self.myTerminal;

		if CM_Voyage.hasInstance(_anObject) then
			beginNotification(_anObject, tmpTerm.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA), Response_Continuous, null);
			beginNotification(_anObject, tmpTerm.getTerminalEvent(EVENT_REFRESH_VOYAGE_AREA), Response_Continuous, null);
		else
			beginNotification(_anObject, tmpTerm.getTerminalEvent(EVENT_TI_MOVE), Response_Continuous, null);
//			beginNotification(_anObject, tmpTerm.getTerminalEvent(EVENT_UPDATE_GRID_AREA), Response_Continuous, null);
//			beginNotification(_anObject, tmpTerm.getTerminalEvent(EVENT_REFRESH_GRID_AREA), Response_Continuous, null);
		endif;

	endif;
end;</source>
        <Parameter name="_anObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="doNotableClear" id="d76e3fa7-3521-4f67-b5cd-2d49dc1862f3">
        <source>doNotableClear();
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	anObject : Object;
	updVoyageArea,
	refreshVoyageArea,
	updGridAreaFrom,updGridAreaTo,
	refreshGridArea	: Integer;
	tmpTerm			: CM_Terminal;
	
begin

	tmpTerm	:= self.myTerminal;

	updVoyageArea		:= tmpTerm.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA);
	refreshVoyageArea	:= tmpTerm.getTerminalEvent(EVENT_REFRESH_VOYAGE_AREA);
//	updGridArea			:= tmpTerm.getTerminalEvent(EVENT_UPDATE_GRID_AREA);
	updGridAreaFrom			:= tmpTerm.getTerminalEvent(EVENT_TI_MOVE);
//	refreshGridArea		:= tmpTerm.getTerminalEvent(EVENT_REFRESH_GRID_AREA);

	foreach anObject in self.allNotableObjects do
		if CM_Voyage.hasInstance(anObject) then
			self.endNotification(anObject, updVoyageArea);
			self.endNotification(anObject, refreshVoyageArea);
		else
//			self.endNotification(anObject, refreshGridArea);
			self.endNotification(anObject, updGridAreaFrom);
		endif;
	endforeach;

	self.allNotableObjects.clear;
end;</source>
    </JadeMethod>
    <JadeMethod name="doNotableRemove" id="6c691868-abb9-4333-a5ec-074fb6de1f78">
        <source>doNotableRemove(_anObject : Object);
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

begin
	if  self.allNotableObjects.includes(_anObject) then
		self.allNotableObjects.remove(_anObject);

		if CM_Voyage.hasInstance(_anObject) then
			endNotification(_anObject, self.myTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA));
			endNotification(_anObject, self.myTerminal.getTerminalEvent(EVENT_REFRESH_VOYAGE_AREA));
		else
			endNotification(_anObject, self.myTerminal.getTerminalEvent(EVENT_TI_MOVE));
		endif;

	endif;
end;</source>
        <Parameter name="_anObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="doZoom" id="01d3f127-234f-45e6-96c5-909e00063c5f">
        <updating/>
        <source>doZoom(pFactor : Real) updating;
// ---------------------------------------------------------------------------
// Created:     01 February 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	gridArea	: CMUI_GridArea;
	theFactor : Real;
begin

	theFactor := pFactor;
	
	if theFactor &lt;= 0 then
		gridArea := self.allGridAreasByRowColumn.first;
		if gridArea &lt;&gt; null then
			theFactor := gridArea.scaleXFactor;
		 endif; 
	endif;
	foreach gridArea in self.allGridAreasByRowColumn do
		gridArea.allPointLabels.clear;
		gridArea.allTerminalAreas.clear;
		gridArea.setZoomFactorTo(theFactor);
	endforeach;

	self.scaleFactor := theFactor;
	self.visible := false;
	self.drawSelf();	
	self.visible := true;

end;</source>
        <Parameter name="pFactor" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doZoomIncrement" id="a525c465-0156-4781-bb54-b169820c39c5">
        <updating/>
        <source>doZoomIncrement(pFactor : Real) updating;

vars
	gridArea	: CMUI_GridArea;

begin
	foreach gridArea in self.allGridAreasByRowColumn do
		gridArea.setZoomFactor(pFactor);
	endforeach;

	self.scaleFactor := gridArea.scaleXFactor;//self.scaleFactor + pFactor;  JC
	self.visible := false;
	self.drawSelf();	
	self.visible := true;

end;</source>
        <Parameter name="pFactor" type="Real"/>
    </JadeMethod>
    <JadeMethod name="dragOver" id="c0027d21-ff73-4e3d-a6fb-1fe357958e43">
        <updating/>
        <source>dragOver(frame: Frame input; win: Window input; x: Real; y: Real; state: Integer) updating;
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	horizontalScroll, verticalScroll, pluss : Boolean;
	smallChange : Integer;	
	
begin
	inheritMethod(frame, win, x, y, state);

	if state = Window.DragOver_Continue then // PAR 7554 removed or state = Window.DragOver_Enter then
		if x &gt;= (self.clientWidth - 25) then
			horizontalScroll := true;
			pluss := true;
		elseif x &lt;= 25 then
			horizontalScroll := true;
			pluss := false;
		elseif y &gt;= (self.clientHeight - 25) then
			verticalScroll := true;
			pluss := true;
		elseif y &lt;= 25 then
			verticalScroll := true;
			pluss := false;
		endif;
		
		if horizontalScroll and self.myHScroll.visible then
			smallChange := self.myHScroll.smallChange;
			if not pluss then
				smallChange := smallChange * -1;
			endif;
			self.myHScroll.value := self.myHScroll.value + smallChange;
			
			self.scrollControl(ScrollBar_Horizontal, self.myHScroll.value);
		elseif verticalScroll and self.myVScroll.visible then
			smallChange := self.myVScroll.smallChange;
			if not pluss then
				smallChange := smallChange * -1;
			endif;
			self.myVScroll.value := self.myVScroll.value + smallChange;
			self.scrollControl(ScrollBar_Vertical, self.myVScroll.value);
		endif;
	endif;
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="state" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawFrameLabel" id="69fd6855-3673-41f2-846c-0cfd13ca4cfb">
        <source>drawFrameLabel( _label : String );

/*

Purpose:		Draw label in top left filler frame

Parameters:			

Return Value:		


Date		Who		Reason
24 Jun 2009	consw1	Initial creation

*/

vars
	topLeftFiller : CMUI_Frame;
	len : Integer;
	
begin
	topLeftFiller := self.myTopLeftFillerFrame;

	topLeftFiller.drawTextAlign := Frame.DrawTextAlign_Center;
	topLeftFiller.autoRedraw := true;

	len := _label.length;
	
	if len &lt; 3 then
		topLeftFiller.drawFontSize := 16;
	elseif len &lt; 6 then
		topLeftFiller.drawFontSize := 8;
	else
		topLeftFiller.drawFontSize := 6; 
	endif;
	
	topLeftFiller.clearGraphics();
	topLeftFiller.drawTextIn(_label, 0, 0, topLeftFiller.width, topLeftFiller.height, Black);

epilog

end;</source>
        <Parameter name="_label" type="String"/>
    </JadeMethod>
    <JadeMethod name="drawRowAndColumnLabels" id="b72c59ff-4a87-4060-8e3b-1219ef612fb8">
        <source>drawRowAndColumnLabels();
// ---------------------------------------------------------------------------
// Created:		12 August 2003 by cnwsgp1
// ---------------------------------------------------------------------------
vars
	firstRow : Integer;
	firstColumn : Integer;
	gridArea : CMUI_GridArea;
	row : Integer;
	col : Integer;
	x1,	y1 : Real;
		
begin
	foreach gridArea in self.allGridAreasByColumnRow do
		row := gridArea.row;
		col := gridArea.column;
		if firstColumn = 0 then
			firstColumn := col;
		else
			if col &lt;&gt; firstColumn then
				break;
			endif;
		endif;

		// draw row labels
		gridArea.drawRowLabel(y1);
		y1 := self.allRowEndPositions[row];
	endforeach;

	foreach gridArea in self.allGridAreasByRowColumn do
		row := gridArea.row;
		col := gridArea.column;
		if firstRow = 0 then
			firstRow := row;
		else
			if row &lt;&gt; firstRow then
				break;
			endif;
		endif;

		// draw column labels
		gridArea.drawColumnLabel(col.stringWithLeadingZeros(2), x1);
		x1 := self.allColumnEndPositions[col];
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="drawSelf" id="ac61bc5e-2cf0-487d-87e6-9b726a11ee58">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>drawSelf() updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:     31 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	loadStateSet	: Boolean;
	gridAreaObj		: CMUI_GridArea;
	lastGridArea	: CMUI_GridArea;
	oldGridArea		: CMUI_GridArea;
	oldRow			: Integer;
	row				: Integer;
	col				: Integer;
	lastRowEndPos	: Real;
	maxHeight		: Real;
	tmpColWidths	: RealArray;
	
begin
	self.mousePointer := Window.MousePointer_HourGlass;

	self.visible := false;
	app.cmsBeginLoad(loadStateSet);
	create tmpColWidths transient;
	
	// self.myViewModeAttribute stores the colours and codes used during the drawing of the TIs to build a legend
	if self.myViewModeAttribute = null then
		create self.myViewModeAttribute transient;
	else
		self.myViewModeAttribute.nullMe();
	endif;
	lastRowEndPos := 0;
	self.backColor := White;
	self.myVLabels.clearGraphics;

	if self.allGridAreasByRowColumn.isEmpty then
		return;
	endif;	
	
	oldGridArea := self.allGridAreasByRowColumn.first();
	oldRow := oldGridArea.row;
	lastGridArea := self.allGridAreasByRowColumn.last();

	// ####################################
	// This tries to work out the height of the largest frame in each row, so that they are all the same height
	foreach gridAreaObj in self.allGridAreasByRowColumn do
		gridAreaObj.drawSelf();

		// need to set row/col start/end pos here
		row := gridAreaObj.row;
		col := gridAreaObj.column;
		
		if oldRow &lt;&gt; row then
			// We have moved to a new row
			lastRowEndPos := lastRowEndPos + maxHeight;
			self.allRowEndPositions[oldRow] := lastRowEndPos;
	
			// do not reset if it is the last of the grid areas
			if gridAreaObj &lt;&gt; lastGridArea then
				maxHeight := 0;
			endif;
	
			oldRow := row;
			oldGridArea := gridAreaObj;
		endif;
	
		maxHeight := maxHeight.max(gridAreaObj.totalPointHeight);

		if col &lt; 1 then
			tmpColWidths.atPut(1, gridAreaObj.totalPointWidth);
		elseif col &gt; tmpColWidths.size then
			tmpColWidths.atPut(col, gridAreaObj.totalPointWidth);
		else
			tmpColWidths[col] := tmpColWidths[col].max(gridAreaObj.totalPointWidth);
		endif;
	endforeach;
	
	lastRowEndPos := lastRowEndPos + maxHeight;
	self.allRowEndPositions[row] := lastRowEndPos;
	
	foreach col in 1 to tmpColWidths.size do
		if col = 1 then
			self.allColumnEndPositions[col] := tmpColWidths[col];
		else
			self.allColumnEndPositions[col] := self.allColumnEndPositions[col-1] + (tmpColWidths[col]).Integer;
		endif;
	endforeach;
	
	self.resizeAndRepositionChildFrames();

	// the call above resizes the frames AFTER it has been through all the grid areas setting their sizes.
	// this means that the frames are the same within each row and column.
	// this means that some grid areas will be smaller than the frame.
	// this next call allows you to do something about it.
	foreach gridAreaObj in self.allGridAreasByRowColumn do
		gridAreaObj.setGridRowColPosAfter();
	endforeach;
	
	self.drawRowAndColumnLabels();
	
	self.visible := true;
epilog
	delete tmpColWidths;
	app.cmsEndLoad(loadStateSet);	
	self.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="findLCAndRedrawGridPoint" id="6047f703-e886-4ad9-952c-8b1c6a9f17c1">
        <updating/>
        <source>findLCAndRedrawGridPoint(_controller : CM_LocationsController) updating;
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lSource, lTarget : CM_LocationsController;
	lRow, lCol : Integer;
	lGridArea : CMUI_GridArea;
	lGridPoint : CMUI_GridPoint;
	theSlotController : CM_SlotController;
	lMoveController : CMIF_MoveController;
	flipH, flipV : Boolean;
	numGridTI : Integer;
	droppedTI : CM_TrackedItem;
	aGridArea : CM_GridArea;
	aGridController : CM_GridController;
begin
	if (not (CM_GridController.hasInstance(_controller) or CM_SlotController.hasInstance(_controller))) then
		return;
	endif;
	if _controller.isKindOf(CM_GridController) then
		foreach lGridArea in self.allGridAreasByRowColumn do
			flipH := lGridArea.flipHorizontal;
			flipV := lGridArea.flipVertical;
			break;
		endforeach;
		aGridController := _controller.CM_GridController;
		aGridArea := aGridController.myTerminalArea.CM_GridArea;
		if flipH then
			lCol := aGridArea.allGridColumns.indexOf(aGridController.myGridColumn);
		else
			lCol :=aGridController.myGridColumn.column;
		
		endif;
		if flipV then
			lRow := aGridArea.allGridRows.indexOf(aGridController.myGridRow);
		else
			lRow :=aGridController.myGridRow.row;
		
		endif;
		
	elseif _controller.isKindOf(CM_SlotController) then
		theSlotController := _controller.CM_SlotController;
		lCol := theSlotController.ordinalCell;
		// the ordinals for tiers are upside down, as far as the GUI grid controll is concerned, so this flips the ordinal
		if theSlotController.ordinalDeck = DeckOnDeck then
			lRow := theSlotController.myBayVoyage.allTiersOnDeck.size - (theSlotController.ordinalTier - 1);
		else
			lRow := theSlotController.myBayVoyage.allTiersUnderDeck.size - (theSlotController.ordinalTier - 1);
		endif;
	else
		return;
	endif;

	foreach lGridArea in self.allGridAreasByRowColumn where (not lGridArea.allGridPoints.isEmpty)  do
		if lGridArea.allGridPoints.isEmpty then
			continue;
		endif;
		lGridArea.updateFromNote(lRow,lCol,_controller);
	endforeach;				



end;</source>
        <Parameter name="_controller" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="getAllSelectedPoints" id="4348872f-d427-477b-83ac-51bcc601a4e2">
