    <JadeMethod name="getMyRoot" id="3f736e3f-adf1-4b78-8f1e-6d08931069c2">
        <source>getMyRoot(): CM_Root;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 March 2016	cnwndl1	Initial creation	TFS 1627

*/

vars

begin
	return self.myHarbour.getMyRoot;

epilog

end;</source>
        <ReturnType type="CM_Root"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="d163d2f0-1114-45c3-9a64-0e456cbf8fad">
        <source>pxyCreateUpdateProxy(): SelfType;
//-----------------------------------------------------------------------
//	Created:	02 October 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	proxy 			: HMS_PlanningNote;
	completedOK		: Boolean;
begin
	proxy := inheritMethod();
	proxy.myHarbour := self.myHarbour;
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="7012643e-b9e3-4279-b014-24b50e624a60">
        <updating/>
        <source>setForUpdate(_pxyPlanningNote: HMS_PlanningNote; _passport: CM_Passport input) updating;
//-----------------------------------------------------------------------
//	Created:	02 October 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars

begin
	inheritMethod(_pxyPlanningNote, _passport);
	
	self.dateOfNote					:= _pxyPlanningNote.dateOfNote;
	self.myUser						:= _pxyPlanningNote.myUser;
	self.text						:= _pxyPlanningNote.text;
	self.myHarbour					:= _pxyPlanningNote.myHarbour;

epilog

end;</source>
        <Parameter name="_pxyPlanningNote" type="HMS_PlanningNote"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="12461673-01e9-4319-a59a-390e9148c3b8">
        <updating/>
        <source>setProxy(_harbour: HMS_Harbour; _user : CM_User; _dateOfNote : Date; _text : String ) updating ;
//-----------------------------------------------------------------------
//	Created:	02 October 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------

vars

begin
	self.raiseExceptionIfNotTransient(method);
	self.myHarbour 	:= _harbour;
	self.myUser 	:= _user;
	self.dateOfNote := _dateOfNote;
	self.text 		:= _text;
end;</source>
        <Parameter name="_harbour" type="HMS_Harbour"/>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_dateOfNote" type="Date"/>
        <Parameter name="_text" type="String"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="a0d28016-23fe-4d16-9845-fd8f8d79fb06">
        <source>validateMe(_passport: CM_Passport input);
//-----------------------------------------------------------------------
//	Created:	02 October 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars

begin

	inheritMethod(_passport);
	
	if self.dateOfNote = null then
	//	app.raiseCMException1( REQUIRED_FIELD, 'Date', ETRow_Code, null );
		app.raiseCMException( Input_required_field_date, ETRow_Code, null ); // cnwdb2	PAR 35364


	endif;
	
	if self.myHarbour = null then
	//	app.raiseCMException1( REQUIRED_FIELD, 'Harbour', ETRow_Description, null );
		app.raiseCMException(Input_required_field_harbour, ETRow_Description, null ); // cnwdb2	PAR 35364
		
	endif;
	
	if self.myUser = null then
	//	app.raiseCMException1( REQUIRED_FIELD , 'User', null, null );
		app.raiseCMException(Input_required_field_Usr, null, null ); // cnwdb2	PAR 35364
	endif;
	
	if _passport.hasErrors then
		return;
	endif;


epilog


end;
</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
