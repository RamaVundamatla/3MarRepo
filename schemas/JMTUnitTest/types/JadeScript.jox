    <JadeMethod name="mdhTest1a" id="e9384b04-d80d-4595-8159-56dad54b4935">
        <source>mdhTest1a();

/*

Purpose:		

Date			Who		Reason
24 August 2016	cnwmh5	Initial creation

*/

vars

	terminal				: CM_Terminal;
	ti						: CM_TrackedItem;
	schema					: Schema;
	klass					: Class;
	file					: File;
	attachement				: CM_Attachment;
	bol						: CM_BOL;
	bolDtl					: CM_BOLDtl;
	
	classes					: ClassColl;
	tiSet					: CM_TISet;
	
	iter					: Iterator;
	iterTI					: Iterator;
	
	transactionSize			: Integer;
	overriddenSize			: Integer;
	chargedSize				: Integer;
	eventSize				: Integer;
	photoSize				: Integer;
	type					: String;
	output					: String;
	terminalCode			: String;
	actualCount				: Integer;
	expectedCount			: Integer;
	unreconciledCount		: Integer;
	
begin

	app.initialize();
	
	create file transient;
	file.fileName := "c:\temp\ti_bol.csv";
	if file.isAvailable() then
		file.purge();
	endif;
	file.writeLine("Oid,Id,Terminal,Trans,Over,Charged,Event,Photo");	
	
	create tiSet transient;
	
	foreach bol in CM_BOL.instances discreteLock do
	
		if output.length &gt; 0 then
			output := output &amp; CrLf;
		endif;
		
		terminalCode := null;
		if bol.myTerminal &lt;&gt; null then
			terminalCode := bol.myTerminal.code;
		endif;
		
		
		output := output &amp; bol.number.String &amp; Tab &amp; terminalCode &amp; CrLf;
	
		foreach bolDtl in bol.allBOLDtls discreteLock do
		
			// Acutal
			foreach ti in bolDtl.allTrackedItems do
				if ti.isNotified then
					continue;
				endif;
				terminalCode := null;
				if ti.myTerminal &lt;&gt; null then
					terminalCode := ti.myTerminal.code;
				endif;
				output := output &amp; Tab &amp; ti.String &amp; Tab &amp; ti.id &amp; Tab &amp; terminalCode &amp; Tab &amp; "ACTUAL" &amp; CrLf;
			endforeach;
			
			// Expected
			output := output &amp; Tab &amp; bolDtl.myBOL.number &amp; Tab &amp; 'EXPECTED' &amp; CrLf;
			
		endforeach;
	
		// Unreconciled
		delete tiSet;
		create tiSet transient;
		if bol.isKindOf(CM_BOLIn) then
			if bol.CM_BOLIn.myVoyage &lt;&gt; null then
				bol.CM_BOLIn.myVoyage.getAllTrackedItems(tiSet);
			endif;		
			bol.allTrackedItems.copyNoDups(tiSet);
		endif;
		
		foreach ti in tiSet do
			if ti.myBOLDtl = null and ti.isImport then
				terminalCode := null;
				if ti.myTerminal &lt;&gt; null then
					terminalCode := ti.myTerminal.code;
				endif;
				output := output &amp; Tab &amp; ti.id &amp; Tab &amp; terminalCode &amp; Tab &amp; "UNRECONCILED" &amp; CrLf;
			endif;
		endforeach;
	
	
	endforeach;
	
	write output;
	file.close();

epilog

	delete file;
	delete classes;
	delete tiSet;
	delete iter;
	delete iterTI;

end;</source>
    </JadeMethod>
