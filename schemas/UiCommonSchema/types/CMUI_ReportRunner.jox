    <JadeMethod name="lstTblWOType_lostFocus" id="13b6b2f7-bbe0-48e7-b17c-b5e41893bc23">
        <controlMethod name="Table::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstTblWOType_lostFocus(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Aug 2023 navhl20 ChangeRequest 58568: EUP - Delivery Dispatch – Reporting

*/
vars
	tbl 	:	CM_EntryTable;
begin
	//display a list of workOrder status
	tbl := tblParameter;
	self.myAssistant.listTableLostFocus(tbl, self.saveRowHeight, self.lstTblWOType, 'description', false);
	self.setTblParameterHeight();
	if tbl.getValueByName(ETRow_WorkOrderType).String = Any_String then
		tbl.setValueByName(ETRow_WorkOrderType, None_Selected_String);
	endif;
epilog

end;</source>
