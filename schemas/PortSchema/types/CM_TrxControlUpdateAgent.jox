        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateEDIParty" id="ff712804-f6bc-407d-a511-7cdfde8eb372">
        <updating/>
        <source>trxUpdateEDIParty(_proxy :CM_EDIParty; _passport :CM_Passport input)updating;
/*
Date		Who		Reason
16 Nov 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
*/
vars

begin		
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	beginTransaction;

	app.myUtilityUA.utlUpdateEDIParty(_proxy, _passport);

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_proxy" type="CM_EDIParty"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateEDIPrenoteBooking" id="a08cd4cf-af96-47de-b554-5f54a04d9e69">
        <updating/>
        <source>trxUpdateEDIPrenoteBooking(	_ediData : CM_EDIData input;
							_passport : CM_Passport input) updating;
/*

Purpose:	THe voyage process has a user defined prenote that is loaded this needs to create/update booking details where needed

Parameters:			

Return Value:		

Date				Who		Reason
22 May 2018			jlger1	Initial creation 38518
01 October 2019		jlgzm1 	TFS 46575 GUI, Web, EDI createing Booking ref items differently
27 April   2023     navsp1  TFS Bug 56592: EUP Testing | Automatic Bookings not created with Prenotes via EDI
*/

vars
	ediTI : CM_EDITrackedItem;
	ediTIsByBooking : DynaDictionary;
	iter : Iterator;
	pxyBookingRef,
	bookingRef : CM_BookingRef;
	pxyBookingRefItem : CM_BookingRefItem;
	newBookingRefItem : CM_BRefItemContainer; // TFS 46575
	allProxyBookings :CM_BookingRefSet;
	bookingRefQuantity : Integer;
	proxyColl 		: CM_ObjectArrayActual;
	proxy			: CM_Object;
	voyage : CM_Voyage;
	terminal : CM_Terminal;
	isoGroup : String;
	product : CM_Product;
	reason : String;//05/04/2024	navkc1 Bug 63509
begin

	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	if _ediData = null  then
		return;
	endif;
	
	beginTransaction;

	create ediTIsByBooking transient;
	ediTIsByBooking.setMembership(CM_EDIPrenoteTI);
	ediTIsByBooking.addMemberKey(CM_EDIPrenoteTI::bookingRef.name,true,false);
	ediTIsByBooking.addMemberKey(CM_EDIPrenoteTI::cargoType.name,true,false);
	ediTIsByBooking.addMemberKey(CM_EDIPrenoteTI::isoType.name,true,false);
	ediTIsByBooking.addMemberKey(CM_EDIPrenoteTI::commodity.name,true,false);
	ediTIsByBooking.addMemberKey(CM_EDIPrenoteTI::product.name,true,false); //27.April.2023 navsp1 TFS 56592
	ediTIsByBooking.endKeys(true);
	//set all the edi tracked items voyage code 
	//has been translated 

	_ediData.allEDITrackedItems.copy(ediTIsByBooking);

	create allProxyBookings transient;
	iter:=ediTIsByBooking.createIterator;
	while iter.next(ediTI) do
		voyage := ediTI.CM_EDIPrenoteTI.getVoyage;
		if voyage = null then
			continue;
		endif;
		if pxyBookingRef &lt;&gt; null and pxyBookingRef.bookingReference &lt;&gt; ediTI.CM_EDIPrenoteTI.bookingRef then
			pxyBookingRef:=null;
			bookingRef :=app.myPassport.myTerminal.getBookingReference(ediTI.CM_EDIPrenoteTI.operatorCode, ediTI.CM_EDIPrenoteTI.bookingRef, voyage);
		endif;
		
		if pxyBookingRef = null  then
			bookingRefQuantity:=0;
			if bookingRef = null then 
				create pxyBookingRef transient;
				pxyBookingRef.setProxyBasic(ediTI.CM_EDIPrenoteTI.bookingRef,app.myPassport.myTerminal,  voyage,ediTI.CM_EDIPrenoteTI.operatorCode);
			else
				pxyBookingRef :=bookingRef.pxyCreateUpdateProxy;
			endif;
			allProxyBookings.add(pxyBookingRef);
		endif;
		
		pxyBookingRefItem := pxyBookingRef.getMatchingItem( ediTI.myCargoType,ediTI.CM_EDIPrenoteTI.commodity,app.myRoot.allISOTypes[ediTI.CM_EDIPrenoteTI.isoType],null, ediTI.CM_EDIPrenoteTI.mark, ediTI.CM_EDIPrenoteTI.markNumber, ediTI.CM_EDIPrenoteTI.colour, null, ediTI.CM_EDIPrenoteTI.serviceOrder, reason); // ### TFS 56707 (56712) 05Apr2023 NAVPW1
		if pxyBookingRefItem = null then
			//create pxyBookingRefItem as pxyBookingRef.getBookingRefItemClass(ediTI.myCargoType) transient;
			//pxyBookingRefItem.setProxyBasic(ediTI.cargoType,ediTI.CM_EDIPrenoteTI.commodity,ediTI.CM_EDIPrenoteTI.isoType,ediTI.CM_EDIPrenoteTI.isoTypeGroup);
			
			//27.April.2023 navsp1 TFS 56592
			if ediTI.CM_EDIPrenoteTI.operatorCode &lt;&gt; null and ediTI.CM_EDIPrenoteTI.product &lt;&gt; null then
				product := ediTI.getProduct(ediTI.CM_EDIPrenoteTI.operatorCode, ediTI.CM_EDIPrenoteTI.product).CM_Product;
			endif;
			
			create newBookingRefItem transient;							// TFS 46575
			newBookingRefItem.setProxyBasic(ediTI.cargoType,ediTI.CM_EDIPrenoteTI.commodity,ediTI.CM_EDIPrenoteTI.isoType,ediTI.CM_EDIPrenoteTI.isoTypeGroup, product);	// TFS 46575
			pxyBookingRef.allBookingRefItems.add(newBookingRefItem);	// TFS 46575
		else
			pxyBookingRefItem.increaseItemQuantity(1);
		endif;
		//write ediTI.CM_EDIPrenoteTI.bookingRef &amp; " "  &amp; ediTI.CM_EDIPrenoteTI.isoType &amp; " " &amp; ediTI.CM_EDIPrenoteTI.commodity;
	endwhile;
	
	foreach pxyBookingRef in allProxyBookings do
		if proxyColl &lt;&gt; null then
			foreach proxy in proxyColl do
				app.myProxyManager.deleteProxyLink(proxy);
			endforeach;
		endif;
		create proxyColl transient;
		if pxyBookingRef.pxyGetRealObject = null then
			app.myUtilityCA.utlCreateBookingRef(pxyBookingRef,_passport, null, bookingRef,proxyColl);
		else
			app.myUtilityUA.utlUpdateBookingRef(pxyBookingRef,_passport,proxyColl);
		endif;
	endforeach;

epilog
	self.finaliseActivityWithPassport(_passport);
	if proxyColl &lt;&gt; null then
		//these proxies have not been committed yet so if there was an exception then need to remove proxy link
		foreach proxy in proxyColl do
			app.myProxyManager.deleteProxyLink(proxy);
		endforeach;
		
		delete proxyColl;
	endif;
	if allProxyBookings &lt;&gt; null then
		allProxyBookings.purge;
	endif;
	delete allProxyBookings;
	delete iter;
	delete ediTIsByBooking;
	
end;</source>
        <Parameter name="_ediData" type="CM_EDIData" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateEDIPrenoteWithVoyage" id="82dc6f02-3437-41f7-b6e9-579b85e8a2ac">
        <updating/>
        <source>trxUpdateEDIPrenoteWithVoyage(	_voyage : CM_Voyage input;
								_ediData : CM_EDIData input;
								_passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 May 2018	jlger1	Initial creation 38518

*/

vars
	ediTI : CM_EDITrackedItem;
begin
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	if _ediData = null or _voyage = null then
		return;
	endif;
	
	beginTransaction;
	
	foreach ediTI in _ediData.allEDITrackedItems  discreteLock do		
		ediTI.CM_EDIPrenoteTI.setVoyageCode(_voyage.code);
		if ediTI.cargoType = null and ediTI.CM_EDIPrenoteTI.isoType &lt;&gt; null then
			ediTI.setCargoType(TI_CargoType_Container);
		endif;
	endforeach;
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
        <Parameter name="_ediData" type="CM_EDIData" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateEDIProcessFile" id="288a7a63-127b-46cd-93fe-302413402ec1">
        <updating/>
        <source>trxUpdateEDIProcessFile( _ediFile : CM_EDIFile io; _passport : CM_Passport input) updating;
//
//10 Sep 2015	cnwrs1	Par 32883 - EDI File Type sequence number
//
// 16 Aug 2016	cnwrs1	TFS 2534 Par 38135 - dead locking between edidata process and edidata deletion
// 18 Jan 2019	jlgrs1	TFS 41659 42276 STWR Make EDI MultiThreaded Stage 8
// 29 Jan 2019	jlgrs1	TFS 43144 CusCar not working after changes for TFS 41659 42276
// 08 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
// 27 Jan 2020	jlgdap1	TFS 48188 PNL TSW messages with multiple bols
//
vars
	ediData 			  : CM_EDIData;
	ediConfig 			  : CM_EDIConfig;
	ediFileType			  : CM_EDIFileType;
	status 				  : Integer;
	ediUserDefinedAssist  : CMIF_EDIUserDefinedAssist;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	self.raiseExceptionIfNull(_ediFile,"Null EDI File");
	
	ediData := _ediFile.ediData;	
	self.raiseExceptionIfNull(ediData,"Null EDI Data");
	
	ediFileType := _ediFile.myEDIFileType;
	self.raiseExceptionIfNull(ediFileType,"Null EDI File Type");
	
	ediConfig := ediData.ediConfig;
	app.setContinueCMExceptions(true);
	create ediUserDefinedAssist transient;
	
	beginTransaction;
	ediFileType.processFileData(_ediFile, _passport);
	ediData := _ediFile.ediData;
	if ediData.allEDITrackedItems.size &gt; 0 then
		if not tryLock(ediData.ediConfig, Exclusive_Lock, Transaction_Duration, LockTimeout_Server_Defined) then
			self.exclusiveLock(ediData.ediConfig);
		endif;
		if not tryLock(ediData.ediConfig.allEDITrackedItemsByIdStatus, Exclusive_Lock, Transaction_Duration, LockTimeout_Server_Defined) then
			self.exclusiveLock(ediData.ediConfig.allEDITrackedItemsByIdStatus);
		endif;

		ediData.addEDIConfigToEDITis(ediUserDefinedAssist);
		ediData.updateFileAdditionalInfo();												// TFS 48188
	endif;
	if _ediFile.ediData.status &lt;&gt; CM_EDIFile.EDI_STATUS_OUTOFSEQUENCE then
		if _passport.allErrors.size = 0 then
			status := CM_EDIFile.EDI_STATUS_LOADED;
		else
			status := CM_EDIFile.EDI_STATUS_LOADED_ERRORS;
		endif;
		if not process.isInTransactionState then	 //if there has been an exception
			status := CM_EDIFile.EDI_STATUS_LOADED_ERRORS;
			beginTransaction;
		endif;
		app.myUtilityUA.utlUpdateEDIFileStatus(_ediFile, status, _passport);
	endif;
epilog	
	delete ediUserDefinedAssist;
	self.finaliseActivityWithPassport(_passport);
end;
</source>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateEDIReprocessFile" id="c022aebd-79ba-4716-a402-74c81d1d9f58">
        <updating/>
        <source>trxUpdateEDIReprocessFile( _ediFile : CM_EDIFile io;
							_ediData		: CM_EDIData input;	
							_clearFirst : Boolean;
							_passport : CM_Passport input) updating;
/*

Date		Who		Reason
26 May 2014	cnwer1	Initial creation PAR
10 Sep 2015	cnwrs1	Par 32883 - EDI File Type sequence number
29 Jan 2019	jlgrs1	TFS 43144 CusCar not working after changes for TFS 41659 42276
11 Mar 2024	navdap1	TFS 62649 EUP | FR 53824 - UDF Transport Manifest Commodity Code Not Loaded From File
*/
vars
	ediFileType			 : CM_EDIFileType;	
	status 				 : Integer;
	jsonTypeEDITIs		 : CM_ObjectArray;		// TFS 62649

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	self.raiseExceptionIfNull(_ediData,"Null EDI Data");
	self.raiseExceptionIfNull(_ediFile,"Null EDI File");
	ediFileType := _ediFile.myEDIFileType;
	self.raiseExceptionIfNull(ediFileType,"Null EDI File Type");
	
	app.setContinueCMExceptions(true);
	
	beginTransaction;
	if _clearFirst then
		// remove all trackeditem first
		_ediData.allEDITrackedItems.purge();
		// TFS 62649 Transport Mainfest and CallOff are special - their EDI tracked items hang off secondary objects
		if _ediData.isTransportManifest or _ediData.isCallOff then
			create jsonTypeEDITIs transient;
			_ediData.getAllEDITrackedItems(jsonTypeEDITIs);
			jsonTypeEDITIs.purge;
		endif;
		// TFS 62649 end
		
		if _ediData.myEDIFile &lt;&gt; null then									//09.Feb.24 navsp1 TFS 61071
			_ediData.myEDIFile.allHeaderReferences.purge();
		endif;
		
		_ediData.allErrorWarnings.purge();									// 09/08/2011 cnwmh5 #27912
	endif;
	//REPROCESS FILE
	ediFileType.reprocessFile(_ediFile, _ediData);
	//jlier1 TFS 56234 24/1/22 removed out code done in reprocessFile

	if _ediFile.ediData.status &lt;&gt; CM_EDIFile.EDI_STATUS_OUTOFSEQUENCE and _ediFile.ediData.status &lt;&gt; CM_EDIFile.EDI_STATUS_CANCELLED then //07.Jul.2023 navsp1 TFS 58055
		//epr TFS 5842 29/8/17
		if _passport.allErrors.size = 0 then
			status := CM_EDIFile.EDI_STATUS_LOADED;
		else
			if _passport.allErrors.size = 1 and _passport.allErrors.includesErrorCode(Exist_file_not_db_loaded) then					  //11.Mar.2024 navsp1 TFS 60793
				status := _ediFile.ediData.status;
				_passport.allErrors.purge();
			else
				status := CM_EDIFile.EDI_STATUS_LOADED_ERRORS;
			endif;
		endif;
		if not process.isInTransactionState then	 //if there has been an exception
			status := CM_EDIFile.EDI_STATUS_LOADED_ERRORS;
			beginTransaction;
		endif;
		app.myUtilityUA.utlUpdateEDIFileStatus(_ediFile,  status, _passport);
	endif;
epilog	
	self.finaliseActivityWithPassport(_passport);
	delete jsonTypeEDITIs;			// TFS 62649
end;</source>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="io"/>
        <Parameter name="_ediData" type="CM_EDIData" usage="input"/>
        <Parameter name="_clearFirst" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateEDISendRecipFileType" id="3ba75aeb-8f70-4d38-9bd0-a044b7b0d0f5">
        <updating/>
        <source>trxUpdateEDISendRecipFileType(_proxy : CM_EDISenderRecipFileType; _ediData : CM_EDIData; _passport : CM_Passport input)updating;
//
//10 Sep 2015	cnwrs1	Par 32883 - EDI File Type sequence number
//
// 04 Aug 2016	cnwrs1	Par 38117 make deleted EDI for finable
//
vars

begin
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	beginTransaction;

	app.myUtilityUA.utlUpdateEDISendRecipFileType(_proxy, _ediData, _passport);

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_proxy" type="CM_EDISenderRecipFileType"/>
        <Parameter name="_ediData" type="CM_EDIData"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateEDITIMode" id="78cda725-fea3-45f7-97ca-6bc59a52d5ab">
        <updating/>
        <source>trxUpdateEDITIMode(_ediTI : CM_EDITrackedItem input; _mode : String; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 October 2019	jlgndl1	Initial creation TFS 47101

*/

vars

begin

	//	do not initialize activity for this action
	app.setContinueCMExceptions(true);
	if _ediTI = null or _mode= null then 
		return;
	endif;
	beginTransaction;
	
	_ediTI.messageMode := _mode;

	app.cmsCommitTransaction(null);
	
epilog
	//should have committed by now - must be a problem
	if process.isInTransactionState then
		app.cmsAbortTransaction;
	endif;
	
end;</source>
        <Parameter name="_ediTI" type="CM_EDITrackedItem" usage="input"/>
        <Parameter name="_mode" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateEDITIPackComplete" id="9c6e8c5c-1278-46f8-8f34-64c62b75bbe7">
        <updating/>
        <source>trxUpdateEDITIPackComplete(_ediData : CM_EDIDataPack input; _verifyOnly : Boolean;  _passport: CM_Passport input) updating;
//----------------------------------------------------------------
//	Created:	08 Dec 2010 cnwrs1 ccms 1976
//----------------------------------------------------------------
/* Changes

Date		Name	TFS#		Description
============================================================================
14 Feb 2013	cnwrs1	Par 31143 	EDI TRX not handling dbLoadErrors after no verify errors take 2
18 sep 2013	cnwrs1	Par 31150	EDI Pack not restarting after lock error//
04 Aug 2014	cnwrs1	Par 34668	EDI Status can be wrong if doDeferredUpdate fails
11 Dec 2018	jlgzm1	TFS 41747 	Better handle when failed to create TI proxy
03 Sep 2019 jlgka1 	TFS 45332 	STWR - Better Forms and Interfaces for EDI Module
20 Oct 2020	jlgmd1	TFS 50204	Refactor progress updates to superclass method
12 Dec 2022 jlika1	TFS 55586  	HS Code User Defined EDI
============================================================================*/
vars
	pxyCargoItem	: CM_TrackedItem;
	realCargoItem 	: CM_TrackedItem;
	proxyTI 		: CM_TrackedItem;
	realTI 			: CM_TrackedItem;
	ediTI 			: CM_EDITrackedItem;
	ediPackTI 		: CM_EDIPackTI;
	updCntrl 		: CMIF_TIUpdateController;
	pxySet 			: CM_TISet;
	terminal 		: CM_Terminal;
	done, todo 		: Integer;
	skipCount		: Integer;
	errorSet 		: CM_ErrorSet;
	status 			: Integer;
	progressTS 		: TimeStamp;
	consign 		: CM_ConsigneeConsignor;
	hsCode			: CM_HSCodeCode;
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	progressTS := app.actualTimeServer();// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	app.setContinueCMExceptions(true);
	
	create pxySet transient;
	terminal := _ediData.getMyTerminal();
	if terminal = null then
		app.raiseCMException1(Err_InvalidTerminal, 'null', null, null);
		return;
	endif;
	create errorSet transient;
	
	
	todo := _ediData.allEDITrackedItems.size;
	_ediData.updateProgress(progressTS, "Loading into JMT...", todo, done, true, _passport);
	
	beginLoad;
	
	foreach ediTI in _ediData.allEDITrackedItems do
		ediPackTI := ediTI.CM_EDIPackTI;
		pxyCargoItem := null;
		
		done := done + 1;
		_ediData.updateProgress(progressTS, "Loading into JMT...", todo, done, false, _passport);
		
		// 34574 check the status which may have been set in Fonterra hook code
		if ediPackTI.status = CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING then
			skipCount := skipCount + 1;
			continue;
		endif;
		if ediPackTI.messageMode = CM_EDITrackedItem.EDI_ACTION_ADD or ediPackTI.messageMode = CM_EDITrackedItem.EDI_ACTION_UPDATE then		//cnwmc5 - 4 Sep 2015 - PAR 36764
			if ediPackTI.id.trimBlanks = null then
				app.raiseCMException2(ERR_FIELD_ID, ediPackTI.id, 'ID', ETRow_Id, ediPackTI);
				continue;
			endif;
			realCargoItem := terminal.allOnsiteTIsByCargoTypeId[ediPackTI.cargoType, ediPackTI.id];
			if realCargoItem = null then
				app.raiseCMException2(ERR_FIELD_ID, ediPackTI.id, 'ID', ETRow_Id, ediPackTI);
				continue;
			endif;
			if not realCargoItem.isEmpty then
				app.raiseCMException5(ERR_NotEmpty, ediPackTI.id, null, ediPackTI.id, realCargoItem.commodity, null, ETRow_Commodity, ediPackTI);
			endif;
			//14 Apr 2014	NDL	Par 33978
			if  ediPackTI.operatorCode &lt;&gt; realCargoItem.operatorCode then
				app.raiseCMException2(Conta_opera_does_not_match_ope, realCargoItem.operatorCode, ediPackTI.operatorCode, ETRow_Operator, ediPackTI);
				continue;
			endif;
			
			//07 Sep 2021	NDL	TFS 51928
			if ediPackTI.consignee &lt;&gt; null then
				consign := app.myRoot.allConsigneeConsignors.getAtKey( ediPackTI.consignee );
				if consign &lt;&gt; null then
					ediPackTI.verifyObjectAvailableForEntry( consign );
				endif;
			endif;
			
			//jlier1 TFS 54846 11/10/22 
			if ediPackTI.countryOfOriginCode &lt;&gt; null then
				if app.myRoot.allCountries[ediPackTI.countryOfOriginCode] = null then
					app.raiseCMException1(Invalid_Country_Origin, ediPackTI.countryOfOriginCode, "countryOfOriginCode", null);
					continue;
				endif;			
			endif;
			
			//07 Sep 2021	NDL	TFS 51928
			if ediPackTI.consignor &lt;&gt; null then
				consign := app.myRoot.allConsigneeConsignors.getAtKey( ediPackTI.consignor );
				if consign &lt;&gt; null then
					ediPackTI.verifyObjectAvailableForEntry( consign );
				endif;
			endif;
			
			//jlika1 TFS 55586
			if ediPackTI.hsCode &lt;&gt; null then
				hsCode := app.myRoot.allHSCodes.getAtKey( ediPackTI.hsCode );
				if hsCode = null then
					app.raiseCMException1(Invalid_hsCode_specified, ediPackTI.hsCode,ETRow_HsCode, null);
					continue;
				endif;
			endif;
			
			pxyCargoItem := realCargoItem.pxyCreateUpdateProxy();
			//if proxy failed to be created then skip
			if pxyCargoItem &lt;&gt; null then
				pxySet.add(pxyCargoItem);
				pxyCargoItem.setPxyFromEDIPackTI(ediPackTI, updCntrl, _passport);
				pxyCargoItem.setSubTerminal(null,null);
			endif;
		else
			app.raiseCMException1(EDI_Action_Is_Invalid, ediPackTI.messageMode, ETRow_MessageMode, null);			//cnwmc5 - 4 Sep 2015 - PAR 36764
		endif;
	endforeach;
	
	endLoad;
	
	_ediData.updateProgress(progressTS, "Loading into JMT...", todo, done, true, _passport);
	
	if pxySet.isEmpty then
		// 34574 if all skipped, log this and continue into the update code to set the processed status
		if skipCount &gt; 0 and todo &gt; 0 and skipCount = todo then
			app.writeLog(class.name &amp; " " &amp; method.name &amp;  " all TIs marked to be skipped", LogINFO);
		else
			app.writeLog(class.name &amp; " " &amp; method.name &amp;  " no TIs found to load", LogINFO);
			return;
		endif;
	endif;
	
	updCntrl := app.createTIUpdateControl(TI_UPDMODE_NORMAL, null, null);
	updCntrl.setMyUserObject(_ediData);
	updCntrl.setMyTransientTIs(pxySet);
	_passport.warningsAcknowledged := true;
	
	beginTransaction;
	_passport.useTIDictDeferUpdate 			:= true;
	_passport.useTITransactionDeferUpdate 	:= true;

	foreach proxyTI in updCntrl.allTransientTIs do
		realTI := proxyTI.pxyGetRealObject();
		//complete the update of the real ti
		app.myUtilityUA.utlUpdateEDITIPackComplete(proxyTI, realTI, _passport);
		if _passport.hasErrors() then
			break;
		endif;
	endforeach;
	if _verifyOnly and _passport.noErrors then
		// sucessful validate - abort then update status in new transaction
		// we need to abort here as it won't get done for us in self.finaliseActivityWithPassport
		app.cmsAbortTransaction();
		return;
	else
		if _passport.noErrors() then
			// sucessful DB Load so update status in same transaction
			_passport.doDeferredUpdates();
			if _passport.noErrors() then
				// use passport to get new status for EDI Data
				status := _ediData.getStatusAfterVerifyOrDBLoad (_verifyOnly, _passport);
				app.myUtilityUA.utlSetEDIDataStatusAfterVerify(_ediData, status);
			endif;
		endif;
	endif;
epilog
	endLoad;
	delete updCntrl;
	if _verifyOnly then
		pxySet.purge;	//clear out the unused proxies
	endif;
	delete pxySet;
	delete errorSet;
	self.finaliseActivityWithPassport(_passport);

	if _verifyOnly or _passport.hasErrors then
		// use passport to get new status for EDI Data
		status := _ediData.getStatusAfterVerifyOrDBLoad (_verifyOnly, _passport);
		app.myTrxUA.trxSetEDIDataStatusAfterVerify(_ediData, status);	// par 27392 cnwrs1 14 Apr 2011
	endif;
end;</source>
        <Parameter name="_ediData" type="CM_EDIDataPack" usage="input"/>
        <Parameter name="_verifyOnly" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateEDITIParent" id="b5617b66-17ce-4be5-93ef-e845773db801">
        <updating/>
        <source>trxUpdateEDITIParent(_childEdiTI: CM_EDITrackedItem input; _parentEdiTI: CM_EDITrackedItem input; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 November 2016	cnwndl1	Initial creation	TFS 2843 / 2604

*/

vars

begin
	//	do not initialize activity for this action
	app.setContinueCMExceptions(true);
	if _childEdiTI.myParent = _parentEdiTI then 
		return;
	endif;
	beginTransaction;
	
	app.myUtilityUA.utlUpdateEDITIParent(_childEdiTI, _parentEdiTI, _passport);

	app.cmsCommitTransaction(null);
	
epilog
	//should have committed by now - must be a problem
	if process.isInTransactionState then
		app.cmsAbortTransaction;
	endif;
	
end;</source>
