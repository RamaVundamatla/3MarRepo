<Class name="CM_ReceivalCutoffCriteria" id="7c1b7838-a249-4dcf-867b-b85297b24bfc">
    <superclass name="CM_YACriteriaPriority"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="voyages"/>
    <ExplicitInverseRef name="myReceivalCutoffTermDef" id="7e30b449-5476-4516-aa36-293d6b83bd11">
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_ReceivalCutoffTermDef"/>
        <access>readonly</access>
        <Inverse name="CM_ReceivalCutoffTermDef::allCriteria"/>
    </ExplicitInverseRef>
    <JadeMethod name="isDataMatch" id="f4517ea3-c055-4bff-846d-e1abfa0c0aee">
        <source>isDataMatch(_cmif : CMIF_YAAutoPlan): Boolean;

/*
Date		Who		Reason
28 May 2009	cnwar2	Initial creation

*/
vars

begin
	return self.myYACriteriaType.isCMIFDataMatch(_cmif, self.myYAData);
end;</source>
        <Parameter name="_cmif" type="CMIF_YAAutoPlan"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="ecaa044f-dfc5-432d-9118-941cbe30e254">
        <updating/>
        <source>setForCreate(pProxyObj: SelfType) updating;

/*
Date		Who		Reason
22 May 2009	cnwar2	Initial creation

*/
vars

begin
	self.setForUpdate(pProxyObj);
	
	self.myReceivalCutoffTermDef	:=	pProxyObj.myReceivalCutoffTermDef;
end;</source>
        <Parameter name="pProxyObj" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setReceivalCutoffDef" id="64a51467-021c-4de6-8820-4cd47cc8e6ed">
        <updating/>
        <source>setReceivalCutoffDef(_receivalCutoffDef : CM_ReceivalCutoffTermDef) updating;

/*
Date		Who		Reason
22 May 2009	cnwar2	Initial creation

*/
vars

begin
	self.myReceivalCutoffTermDef := _receivalCutoffDef;
end;</source>
        <Parameter name="_receivalCutoffDef" type="CM_ReceivalCutoffTermDef"/>
    </JadeMethod>
</Class>
