<Class name="CMQF_PlanReefer" id="07b61187-6f4f-4116-b86b-a737ef6326d5">
    <superclass name="CMQF_Container"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="filterObjects" id="c5fcc76b-4f63-4cb3-bc8e-0c77a42989dc">
        <updating/>
        <source>filterObjects(_collection  : Collection input; _passport : CM_Passport) updating;
// ---------------------------------------------------------------------------
// Created:		07 February 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
vars
	ti 					: CM_TrackedItem;
	terminal			: CM_Terminal;
	breakOut			: Boolean;
begin

	//search onship ti's for selected voyage
	//TI_STATE_ONSHIP
	if self.getMyVoyage &lt;&gt; null then
	
		foreach ti in self.getMyVoyage.allOnsiteTIsByIdCargoType discreteLock do
			if self.checkStatusIncludesObject(ti, _passport, breakOut) then
//			if self.includesObject(ti, _passport, breakOut) then
				if not _collection.includes(ti) then
					_collection.add(ti);
					self.doStats(ti);
				endif;
			endif;
			
//			if breakOut then
//				return;
//			endif;
		endforeach;
		
			
		foreach ti in self.getMyVoyage.allOnshipTIsByIdCargoType discreteLock do
			if self.checkStatusIncludesObject(ti, _passport, breakOut) then
//			if self.includesObject(ti, _passport, breakOut) then
				if not _collection.includes(ti) then
					_collection.add(ti);
					self.doStats(ti.CM_Container);
				endif;
			endif;
//			if breakOut then
//				return;
//			endif;

		endforeach;
	endif;
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="7e973a31-ad85-4ea6-aec4-b55f4d8c7b30">
        <updating/>
        <source>includesObject(_ti: CM_TrackedItem; _passport : CM_Passport; _breakOut : Boolean output): Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:		07 February 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars

begin
	if CM_Container.hasInstance(_ti) and
	(_ti.site = TI_SITE_ONSHIP or _ti.plannedSite = TI_SITE_ONSHIP) and
	_ti.CM_Container.monitorConnection and
	inheritMethod(_ti, _passport, _breakOut) then
		return true;
	endif;

	return false;

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
