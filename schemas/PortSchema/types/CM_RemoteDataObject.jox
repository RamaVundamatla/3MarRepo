    <JadeMethod name="xmlDefaultResponse" id="38facec0-4034-41a9-afa7-bb35fdc7ef27">
        <updating/>
        <source>xmlDefaultResponse(_header : CM_RemoteDataHdr io; _err : Integer; _errText : String) : String updating;

vars

	response,
	type,
	id,
	version,
	time		: String;
	theDate		: Date;
	theTime		: Time;
	device,
	errorText	: String;

begin

	errorText :=	_errText;
	id		:= '9999';
	time	:= theDate.formatAsYYYYMMDD() &amp; theTime.format('HHmmss');
	type 	:= CM_RemoteDataManager.DEFAULTEXCEPTION;
	if _header &lt;&gt; null then			
		if _header.myRadioTelemetryDevice &lt;&gt; null then
			device := _header.myRadioTelemetryDevice.id;
		else
			device := 'Invalid(' &amp; _header.deviceId &amp; ')';
		endif;	
		version := _header.theVersion.String;
		type := _header.getMessageResponseType();
		if _header.messageId &lt;&gt; null then
			id := _header.messageId;
		endif;
		_header.setError(_err, _errText[1:30]);
	endif;
	response := self.formatAsXMLPrefix(XML_HDR) &amp;
				self.formatAsXML(XML_MSGTYPE, type ) &amp;
				self.formatAsXML(XML_MSGID, id) &amp;
				self.formatAsXML(XML_DEVICEID, device);

	response := response &amp; 
				self.formatAsXML(XML_ERRNO, _err.String);
		
	if _err &lt;&gt; 0 then
		response := response &amp;	self.formatAsXML(XML_ERRTXT, errorText);
	endif;

	response := response &amp;
				self.formatAsXML(XML_TIME, time) &amp; 
				self.formatAsXML(XML_VERSION, version) &amp;
				self.formatAsXMLSuffix(XML_HDR);				
			
	return response;

end;</source>
        <Parameter name="_header" type="CM_RemoteDataHdr" usage="io"/>
        <Parameter name="_err" type="Integer"/>
        <Parameter name="_errText" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
