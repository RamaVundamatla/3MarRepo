<Class name="GTEIF_ShipBOLIn" id="9a5735b5-70a1-4775-822b-0aac4bb38efb">
    <superclass name="CMIF_BOLIn"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <JadeMethod name="actionForCreate" id="9853327d-7bd0-4586-b24a-24f30e0f681a">
        <updating/>
        <source>actionForCreate(pProxy: CM_Object io; _passport: CM_Passport input): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     04 January 2006	cnwhjg1
//
// Purpose:     Created so a General Docket could be created on a Voyage. 
//				To do this the inherit method has been moved as we want no 
//				reference to a Road Job. 
// ----------   ----------  --------------------------------------------------
vars
	job				: CM_RoadJob;
	tmpStr			: String;
	inOutAttach		: CMIF_TIObject;
	cancelSave		: Boolean;
	request : CM_Request;	
	theTIS : CM_TISet;
begin
	// WAS PAR 16180 self.myPersistentBOL  := self.doesBOLAlreadyExist();
	// NOW
	self.myPersistentBOL := self.myVoyage.doesBOLAlreadyExist(self.myProxyBOL.number); // PAR  16180
	
	if self.myPersistentBOL  = null then
		self.myPersistentBOL := self.myTerminal.createBillOfLading(self.myProxyBOL, _passport);
	else // already exists // PAR 15206
		create theTIS transient; // PAR 15206
		self.myProxyBOL.allTrackedItems.copyNoDuplicates(theTIS,false); // PAR 15206
		self.myPersistentBOL.allTrackedItems.copyNoDuplicates(theTIS,false); // PAR 15206
		self.myPersistentBOL.setTIsForCreate(theTIS, _passport);// PAR 15206
		self.moveToShip(_passport);// PAR 15206
		return _passport.noErrors;// PAR 15206
	endif;

	if _passport.noErrors and (not self.myPersistentBOL.allTrackedItems.isEmpty) then
		//Receive the TI onto Ship
		if self.myUserObject = null or not self.myUserObject.isKindOf(CMIF_PreNote) then 
			app.raiseUnexpectedProgramError(class.name, method.name,
					"The self.myUserObject has not been set. This should be set as a CMIF_PreNote to provide the location details. ");
				
			return false;
		else 	
			self.moveToShip(_passport);
		endif;
	endif;
	
	if not _passport.noErrors then
		return false;
	endif;
	
	if _passport.noErrors then
		// create the request
		create self.myProxyBOLRequest transient;
		self.myProxyBOLRequest.setProxy(self.consignorCode, null /* _consignorVoyageCode */,
									    null /* _deliveryNumber */,
									    null /* _eirNumber */,
										null /* _freightForwarderCode */,
									    null /* _freightPayerCode */,
									    true /* _isReceipt */,
									    null /* _reasonCode */,
									    null /* _reasonCodeDescr */,
									    null /* _remarks */,
									    true /* _removeStops */,
									    app.getMyUserCode,
									    null /* _voyageCode */,
									    job, self.myPersistentBOL);
	endif;
	
	if _passport.noErrors then	
		//Validate the request (TI is already validated)
		self.myProxyBOLRequest.validate(self.myUserObject);
	endif;
	
	if (not _passport.noErrors()) then
		return false;
	endif;

	// Par 8635
	if _passport.noErrors then
		app.myAA.auditCreateTrx(self.myPersistentBOL, self.myPersistentBOL.getAuditText(), null);
		
		self.myPersistentBOL.handleOpsView(BGP_OpsViewWSRequest.OPS_ACTION_CREATE); // ### TFS 53105 30MAY2022 NAVAB1
		
	endif;
	
epilog
	delete theTIS;
	return _passport.noErrors();
end;</source>
        <Parameter name="pProxy" type="CM_Object" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doesBOLAlreadyExist" id="512bb816-d4da-41eb-8d89-bd942257e39c">
        <source>doesBOLAlreadyExist() : CM_BOLIn;
// ---------------------------------------------------------------------------
// Created:		29 November 2007 By Andrew Bishop cnwab1
//
// Purpose:		// PAR 15206
//
// ---------------------------------------------------------------------------
vars
	bolNumber : String;
	bolIn : CM_BOLIn;
	intFaceBOLIn : CMIF_BOLIn;
begin


	//PAR 16180 NOT USED, moved to CM_Voyage::doesBOLAlreadyExist
	return null;
	
	
	
	
	if app.myRoot.client &lt;&gt; Client_CentrePort then
		return null;
	endif;
	
	bolNumber := self.myProxyBOL.number;
	if bolNumber = null then
		return null;
	endif;
	
	bolIn := self.myVoyage.allBOLInByTypeStatusNumDT.getAtKeyGeq(BOLType_GeneralBillOfLading, BOL_STATUS_NORMAL, bolNumber, null);
	if bolIn = null then 
		bolIn := self.myVoyage.allBOLInByTypeStatusNumDT.getAtKeyGeq(BOLType_GeneralDocket, BOL_STATUS_NORMAL, bolNumber, null);
	else
		if bolIn.number &lt;&gt; bolNumber then 
			bolIn := self.myVoyage.allBOLInByTypeStatusNumDT.getAtKeyGeq(BOLType_GeneralDocket, BOL_STATUS_NORMAL, bolNumber, null);
		endif;
	endif;
	return bolIn;
end;</source>
        <ReturnType type="CM_BOLIn"/>
    </JadeMethod>
    <JadeMethod name="setDataFromTable" id="0351c2e3-4cdc-4160-a7cf-4e85bc95d99b">
        <updating/>
        <source>setDataFromTable(pTblMain: CM_EntryTable input; pTblExtra: CM_EntryTable input; pIntFaceCommon: CMIF_InOutCommon; pAssistant: CMUI_Assistant) updating;
// ---------------------------------------------------------------------------
// Created:     25 June 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

//	self.setUserDetails(app.getMyUser);
//	self.setMyInOutCommon(pIntFaceCommon);
	
	pTblMain.setObjectFromTable(self, null, false);
	pTblExtra.setObjectFromTable(self, 'saveEntTblSpecial', false);
	
	self.operatorCode := pTblMain.getValueByName(ETRow_Supplier).String;
	self.myOperator := app.myRoot.allOperators[self.operatorCode];
end;</source>
        <Parameter name="pTblMain" type="CM_EntryTable" usage="input"/>
        <Parameter name="pTblExtra" type="CM_EntryTable" usage="input"/>
        <Parameter name="pIntFaceCommon" type="CMIF_InOutCommon"/>
        <Parameter name="pAssistant" type="CMUI_Assistant"/>
    </JadeMethod>
</Class>
