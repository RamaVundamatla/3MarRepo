    <JadeMethod name="setCurrentParam" id="a70e3ab9-e14a-4d8e-8b88-e03e0f7debe1">
        <updating/>
        <source>setCurrentParam( _param : CMIF_EDIFACTParams) updating;
/*

Date		Who		Reason
17 February 2017	cnwer1	Initial creation TFS 2744

*/

vars

begin
	if _param = null then
		return;
	endif;
	
	if not self.allParams.includes(_param) then
		return;
	endif;
	
	self.myCurrentParams := _param;
epilog

end;</source>
        <Parameter name="_param" type="CMIF_EDIFACTParams"/>
    </JadeMethod>
    <JadeMethod name="setCurrentTag" id="543adaeb-e323-4c32-86f0-9099dff3152f">
        <updating/>
        <source>setCurrentTag() updating;
//----------------------------------------------------------------
//	Created:	30 August 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//12 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
//27 Jul 2015	cnwrs1	Par 32883 - EDI File Type sequence number
vars
	int	: Integer;
	msg	: String;
	
begin
	msg := self.currentMessage;
	
// cnwdad1 09/11/2010 - PAR #26017 Added check for UNA tag. Refer to the text of the "UNA" class constant on CM_EDIFileTypeUNEDIFACT.
// cnwdad1 16/11/2010 - Temporarily put original code back, until we have a design to implement UNA handling.
//	if msg.length() &gt; 2 and msg[1:3] = CM_EDIFileTypeUNEDIFACT.UNA then
//		int	:=	4;
//	else
		int := msg.pos("+",1);
		
		if int &lt; 1 then
			int := 1;
		endif;
//	endif;
	
	msg := msg[1:int];
	msg := msg.replaceString("'", null);	//[1:str.length - 1];		// drop last character (')
	msg := msg.replaceString(":", null);	//[1:str.length - 1];		// drop last character (')
	msg := msg.replaceString("+", null);	//[1:str.length - 1];		// drop last character (')
	self.currentTag := msg[1:30];
end;</source>
    </JadeMethod>
    <JadeMethod name="setEDIFile" id="cc162026-8fba-4073-bfa3-a681547def3b">
        <updating/>
        <source>setEDIFile(_ediFile: CM_EDIFile) updating;
//----------------------------------------------------------------
//	Created:	30 August 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	self.myEDIFile := _ediFile;

end;</source>
        <Parameter name="_ediFile" type="CM_EDIFile"/>
    </JadeMethod>
    <JadeMethod name="setFirstField" id="4074ea95-3a01-4127-985d-e8241fc58f5e">
        <updating/>
        <source>setFirstField() updating;
/*

Date		Who		Reason
03 Jun 2010	cnwkpd1	PAR #21998 - EDI File load performance changes
09/11/2010	cnwdad1	PAR #26017 - We now recognise the UNA tag/segment.

*/

vars
	msg			: String;
	str			: String;
	pos			: Integer;
	escape		: String;
	
begin
	self.currentFieldNumber := 1;
	msg := self.currentMessage;
	
	if msg &lt;&gt; null then
// cnwdad1 09/11/2010 - PAR #26017. To handle the UNA tag line.
// cnwdad1 16/11/2010 - Temporarily put original code back, until we have a design to implement UNA handling.
//		if self.currentTag = CM_EDIFileTypeUNEDIFACT.UNA then
//			// Following the 3-character tag name, there are four explicit characters
//			// which represent how the EDIFACT file should be handled.  Refer to the
//			// text of CM_EDIFileTypeUNEDIFACT::UNA class constant.
//			
//			if msg.length() &gt; 3 then
//				str		:=	msg[4:end];
//				
//				if str.length() &gt; 3 then
//					escape	:=	str[4:1].trimBlanks();
//					
//					if escape &lt;&gt; null then
//						self.escapeChar	:=	escape.Character;
//					endif;
//				endif;
//			endif;
//		else
			pos := 1;
			str := msg.scanUntil("+", pos);
			
			if pos = null then			// no delimiter found, then return all but last character
				if str &lt;&gt; null then
					str := str[1:str.length() - 1];
				endif;
			endif;
//		endif;
	endif;
	
// cnwdad1 09/11/2010 - PAR #26017.
// cnwdad1 16/11/2010 - Temporarily put original code back, until we have a design to implement UNA handling.
//	if self.escapeChar &lt;&gt; null and self.currentTag &lt;&gt; CM_EDIFileTypeUNEDIFACT.UNA then
//		str	:=	str.handleEscapeChar(self.escapeChar, 1);
//	endif;
	
	self.currentField := str;
	self.setFirstSubItem();
end;

/* 	old code replaced

vars
	str: String;
	pos1,start,stop: Integer;
begin
	self.currentFieldNumber := 1;
	start := 1;
	pos1 := self.getCurrentMessage.pos("+",start);
	stop := pos1-start;
	if pos1 &lt; 1 then
		stop := self.getCurrentMessage.length - start;
	endif;
	if stop &lt; 1 then
		self.currentField := "";
	else
		self.currentField := self.getCurrentMessage[start:stop];
	endif;
	self.setFirstSubItem;

end;
*/</source>
    </JadeMethod>
    <JadeMethod name="setFirstSubItem" id="ff31a187-e31b-4ee4-9e9a-17f7db4da097">
        <updating/>
        <source>setFirstSubItem() updating;

/*

Date		Who		Reason
03 Jun 2010	cnwkpd1	PAR #21998 - EDI File load performance changes

*/

vars
	field		: String;
	pos			: Integer;
	
begin
	self.currentSubItemNumber := 1;
	
	field := self.currentField;
	
	if field = null then
		self.currentSubItem := null;
	else
		pos := 1;
		self.currentSubItem := field.scanUntil(":", pos);
	endif;

end;
</source>
    </JadeMethod>
    <JadeMethod name="setNextField" id="d5c7f5ec-1f11-4d53-8955-8fed5335a896">
        <updating/>
        <source>setNextField() updating;

/*

Date		Who		Reason
03 Jun 2010	cnwkpd1	PAR #21998 - EDI File load performance changes
09/11/2010	cnwdad1	PAR #26017 - We now recognise the UNA tag/segment.

*/

vars
	str,
	msg				: String;
	msgLen,
	pos,
	index,
	currentIndex	: Integer;
	
begin
// cnwdad1 09/11/2010 - PAR #26017. There IS NO next field in a UNA tag line.
// cnwdad1 16/11/2010 - Temporarily put original code back, until we have a design to implement UNA handling.
//	if self.currentTag = CM_EDIFileTypeUNEDIFACT.UNA then
//		return;
//	endif;
	
	currentIndex := self.currentFieldNumber + 1;
	self.currentFieldNumber := currentIndex;
	
	msg := self.currentMessage;
	msgLen := msg.length;
	
	pos := 1;
	index := 0;
	
	while index &lt; currentIndex do
		index := index + 1;
		
		if pos &gt; msgLen then
			str := null;
			break;
		endif;
		
		// Find field number "index"
		str := msg.scanUntil("+", pos);

		if pos = null then			// No more "+" delimiters, must be the end of the line
			if index &lt;&gt; currentIndex then	//par26701 cnwrs1 6 Jan 2011
				str := null;
				break;
			endif;
			if str &lt;&gt; null then 
				str := str[1:str.length - 1];		// drop last character (')
			endif;
			break;
		endif;
		
		pos := pos + 1;				// Step over delimiter
	endwhile;
	
// cnwdad1 09/11/2010 - PAR #26017.
// cnwdad1 16/11/2010 - Temporarily put original code back, until we have a design to implement UNA handling.
//	if self.escapeChar &lt;&gt; null then
//		str	:=	str.handleEscapeChar(self.escapeChar, 1);
//	endif;
	
	self.currentField := str;
	self.setFirstSubItem;
end;

/*	old code replaced

vars
	pos1,pos2,index,start,stop: Integer;
begin
	self.currentFieldNumber := self.currentFieldNumber + 1;
	index := 1;
	start := 1;
	while index &lt; self.currentFieldNumber do
		pos1 := self.getCurrentMessage.pos("+",start);
		if pos1 = 0 then // got all the fields
			start	:= 1;
			pos2	:= 1; // this ensures stop := 0 and currentField is set to blank
			break;
		endif;
		start :=  pos1 + 1; //skip the delimiter
		pos2 := self.getCurrentMessage.pos("+",start);
		index := index + 1;
	endwhile;
	stop := pos2-start;
	if pos2 &lt; 1 then
		stop := self.getCurrentMessage.length - start; //cnwrs1 Aug 2009 par 20500 skip the last character of the line which is a '
	endif;
	if stop &lt; 1 then
		self.currentField := "";
	else
		self.currentField := self.getCurrentMessage[start:stop];
	endif;
	self.setFirstSubItem;

end;
*/</source>
    </JadeMethod>
    <JadeMethod name="setNextMessage" id="480ad185-8736-4226-8478-67902140460b">
        <updating/>
        <source>setNextMessage(message:String) updating;

vars

begin
	self.currentMessageNumber := self.currentMessageNumber + 1;
	self.currentMessage := message;
	self.setCurrentTag;
	self.setFirstField;
end;</source>
        <Parameter name="message" type="String"/>
    </JadeMethod>
    <JadeMethod name="setNextSubItem" id="8a8f2987-ff05-4076-8483-33354dd13723">
        <updating/>
        <source>setNextSubItem() updating;

/*

Date		Who		Reason
03 Jun 2010	cnwkpd1	PAR #21998 - EDI File load performance changes

*/

vars
	field,
	str				: String;
	fieldLen,
	pos,
	index,
	currentIndex	: Integer;
	
begin
	currentIndex := self.currentSubItemNumber + 1;
	self.currentSubItemNumber := currentIndex;
	
	field := self.currentField;
	fieldLen := field.length;
	
	pos := 1;
	index := 0;
	
	while index &lt; currentIndex do
		index := index + 1;
		
		if pos &gt; fieldLen then
			str := null;
			break;
		endif;
		
		// Find subfield number "index"
		str := field.scanUntil(":", pos);
		
		if pos = null then			// No more ":" delimiters, must be the end of the field
			if index &lt; currentIndex then
				str := null;
			endif;
			break;
		endif;
		
		pos := pos + 1;				// Step over delimiter
	endwhile;
	
	self.currentSubItem := str;
	
end;
/*
///*	old code replaced 

vars
	str: String;
	pos1,pos2,pos3,i,start,stop: Integer;
begin
	self.currentSubItemNumber := self.currentSubItemNumber + 1;
	i := 1;
	start := 1;
	while i &lt; self.currentSubItemNumber do
		pos1 := self.currentField.pos(":",start);
		if pos1 = 0 then // got all the subItems
			start := 1;
			pos2 := 1; // this ensures stop := 0 and currentSubItem is set to blank
			break;
		endif;
		start :=  pos1+1; //skip the delimiter
		pos2 := self.currentField.pos(":",start);
		i := i + 1;
	endwhile;
	stop := pos2-start;
	if pos2 &lt; 1 then
		stop := self.currentField.length - start + 1;
	endif;
	if stop &lt; 1 then
		self.currentSubItem := "";
	else
		self.currentSubItem := self.currentField[start:stop];
	endif;
end;

//*/</source>
    </JadeMethod>
    <JadeMethod name="setPreviousField" id="f2c855a2-8644-46aa-8a80-a192a0c3be5f">
        <updating/>
        <source>setPreviousField() updating;

/*

Date		Who		Reason
03 Jun 2010	cnwkpd1	PAR #21998 - EDI File load performance changes

*/

vars

begin
	if self.currentFieldNumber &lt; 2 then
		return;
	endif;
	
	self.currentFieldNumber := self.currentFieldNumber - 2;
	self.setNextField();
	
end;

/*	old code replaced

vars
	str: String;
	pos1,pos2,pos3,i,start,stop: Integer;
begin
	if self.currentFieldNumber &lt; 1 then
		return;
	endif;
	self.currentFieldNumber := self.currentFieldNumber - 1;
	i := 1;
	start := 1;
	while i &lt; self.currentFieldNumber do
		pos1 := self.getCurrentMessage.pos("+",start);
		if pos1 = 0 then // got all the fields
			start := 1;
			pos2 := 1; // this ensures stop := 0 and currentField is set to blank
			break;
		endif;
		start :=  pos1+1; //skip the delimiter
		pos2 := self.getCurrentMessage.pos("+",start);
		i := i + 1;

	endwhile;
	stop := pos2-start;
	if pos2 &lt; 1 then
		stop := self.getCurrentMessage.length - start + 1;
	endif;
	if stop &lt; 1 then
		self.currentField := "";
	else
		self.currentField := self.getCurrentMessage[start:stop];
	endif;
	self.setFirstSubItem;


end;
*/</source>
    </JadeMethod>
</Class>
