    <JadeMethod name="showWorkOrder" id="fcf5575e-e036-4f09-b78a-60b8ccf100ea">
        <source>showWorkOrder(_workOrder : CM_WorkOrder;_task : CM_WorkOrderDtl);
// -----------------------------------------------------------------------------
// Created:		29 July 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
// 17/05/2018	jlgdap1		TFS 38560 PEL1 Voyage Work Orders
// 13/09/2022   navma1		ChangeRequest 54645: MTN - Work Order Refactor (Additional Changes and remove IsSpecial)
// 20 Feb 2022  navma1		Bug 56605: MTN - Cancelled voyages in voyage work orders issues and proxy deletion issues on exceptions
// -----------------------------------------------------------------------------

vars
	woForm 			: YRD_WorkOrder;
	pxyWorkOrder,
	realWorkOrder 	: CM_WorkOrder;
	voyage			: CM_Voyage;
	task 			: CM_WorkOrderDtl;
	mode			: Integer; //13/11/2024	navkc1 JIRA Story MTN-33012
begin
	
	app.mousePointer := MousePointer_HourGlass;

	if _workOrder = null then
		return;
	endif;
	
	realWorkOrder := _workOrder;										//13.09.2022 navma1 #54645
	if realWorkOrder &lt;&gt; null and realWorkOrder.isVoyageWorkOrder then	//13.09.2022 navma1 #54645			
		voyage := realWorkOrder.CM_WorkOrderVoyage.getMyVoyageObject();				
	endif;	
	
	if realWorkOrder.pxyGetProxyObject() &lt;&gt; null then					//20.02.2023 navma1 #56605
		/*In case of a failure before*/
		pxyWorkOrder :=  realWorkOrder.pxyGetProxyObject();
		delete pxyWorkOrder;
	endif;
	
	mode := YRD_WorkOrder.MODE_UPDATE; //13/11/2024	navkc1 JIRA Story MTN-33012
	
	//13/11/2024	navkc1 JIRA Story MTN-33012 - New mode for updating completed work order
	if realWorkOrder.isComplete() then
		mode := YRD_WorkOrder.MODE_UPDATECOMPLETED;
	endif;
	
	pxyWorkOrder 	 := app.createUpdateProxy(realWorkOrder).CM_WorkOrder;
	task        	 := _task;
	app.mousePointer := MousePointer_HourGlass;
	
	
	woForm 			 := app.getForm(YRD_WorkOrder.name).YRD_WorkOrder;
	
	if woForm = null then
		woForm := app.loadForm(YRD_WorkOrder, YRD_Assistant, false, false, false, self.myTerminal, self.myMasterMenuAction).YRD_WorkOrder;
	endif;
	
	if woForm = null then
		return;
	endif;
	
	woForm.centreWindow;
	woForm.setMyTerminal(self.myTerminal);
	//woForm.initialise( self, pxyWorkOrder, YRD_WorkOrder.MODE_UPDATE, pxyWorkOrder.getProxyTask(task), pxyWorkOrder.getWorkOrderMode, voyage );
	woForm.initialise( self, pxyWorkOrder, mode, pxyWorkOrder.getProxyTask(task), pxyWorkOrder.getWorkOrderMode, voyage ); //13/11/2024	navkc1 JIRA Story MTN-33012
	woForm.setDeleteProxy(true);
	woForm.show;
	
	
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="_workOrder" type="CM_WorkOrder"/>
        <Parameter name="_task" type="CM_WorkOrderDtl"/>
    </JadeMethod>
    <JadeMethod name="stub_GetOriginalCollection" id="909cbb2a-ac1c-403c-a1fc-b9566d69b91d">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_CMUI_MultiSelectGroupBox::getOriginalCollection"/>
        </interfaceImplements>
        <source>stub_GetOriginalCollection() : Collection;
// -----------------------------------------------------------------------------
// Created:		25 August 2009 by consw1
//
// Purpose:		Stub for mltTasks control interface
//
