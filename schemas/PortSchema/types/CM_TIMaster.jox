    <JadeMethod name="shouldAuditProperty" id="2795a1ee-3db1-4277-b5a5-a839e39de33a">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Feb 2018	cnwma1  ChangeRequest 36813: PEN - Gen Sets, Chassis &amp; Reefers

*/

vars
		propName	: String;
begin
	if _property = null then
		return false;
	endif;
	
	propName := _property.name;
	
	if	propName = CM_TIMaster::allTIMasterAttachees.name or
		propName = CM_TIMaster::allTIMasterAttachers.name
		then
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;
epilog

end;</source>
