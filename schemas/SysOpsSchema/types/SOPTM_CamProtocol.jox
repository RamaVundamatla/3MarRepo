	self.lblBGMRepCode.parent := theForm.picSingleSelect2;
	self.lblBGMRepCode.visible := true;
	if self.lblBGMRepCode.form = null then
		theForm.addControl(self.lblBGMRepCode);
	endif;
	
	//jlgka1 TFS 44737 --&gt;
	self.lblVGMBGMMsgCode.parent := theForm.picSingleSelect2;
	self.lblVGMBGMMsgCode.visible := true;
	if self.lblVGMBGMMsgCode.form = null then
		theForm.addControl(self.lblVGMBGMMsgCode);
