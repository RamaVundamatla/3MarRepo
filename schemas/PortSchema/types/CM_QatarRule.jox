    <JadeMethod name="validate" id="2820a759-6ab8-48a7-b0f5-784566af966a">
        <source>validate(_passport :CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 June 2015	cnwndl1	Initial creation	Par 36543

*/

vars
	ruleItem		:String;
	ruleFunction, 
	type			:Integer;
begin
	self.raiseExceptionIfNotTransient (method);
	
	ruleItem 	:= self.item;
	type 		:= self.myEDIPartyRules.getType;
	
	if ruleItem = null then
		app.raiseCMException (EDI_Party_Error6, null, null);
	elseif type = EDIFileType_XML_Milaha_Customs 
		and ruleItem = self.Item_Qatar then
			//ok
	else
		// we expect GUI to take care of this (including not passing in null values)
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Item is not supported');
	endif;
	
	ruleFunction := self.function;
	
	if ruleFunction = null then
		app.raiseCMException (EDI_Party_Error8, null, null);
	endif;
	
	if ruleItem = self.Item_Qatar then
		if ruleFunction &lt;&gt; null then
			if ruleFunction &lt;&gt; self.Function_ImportReleaseStop
			and ruleFunction &lt;&gt; self.Function_ExportReleaseStop
			and ruleFunction &lt;&gt; self.Function_ImportBayanStop
			and ruleFunction &lt;&gt; self.Function_ExportBayanStop
			then
				app.raiseUnexpectedProgramError (self.class.name, method.name, 'Function is not supported');
			endif;
		endif;
	endif;
	
	if self.value = null then
		app.raiseCMException (EDI_Party_Error7, null, null);
	endif;
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
