    <JadeMethod name="doFlipGfxLandscapePortrait" id="9ef99539-6710-4b4e-bba5-f223ee1a720b">
        <updating/>
        <source>doFlipGfxLandscapePortrait() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 May 2010	cnwjk3	Initial creation

*/

vars

begin
	if not self.frmGraphic.visible then
		return;
	endif;
	
	if self.myDrawingController.myDisplayBuilder = null then
		return;
	endif;
	
	if self.myDrawingController.isLandscape then
		if self.myDrawingController.myDisplayBuilder.canDisplayPortrait(self.myDrawingController.drawMode) and not self.isForceLandscapeButtons() then
			// The flip will succeed so we need to shift the buttons to portrait and resize
			// the graphic frame accordingly before we display the graphics.  This ensures 
			// the graphic frame is the right size before the controller calculates various positions and offsets
			self.resizeForGfxButtonsPortrait();
		endif;
	else
		if self.myDrawingController.myDisplayBuilder.canDisplayLandscape(self.myDrawingController.drawMode) then
			// See comment above...
			self.resizeForGfxButtonsLandscape();
		endif;
	endif;
	
	self.myDrawingController.flipLandscapePortrait();
	//self.refreshScrollButtons();
	self.updateCaption();
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
