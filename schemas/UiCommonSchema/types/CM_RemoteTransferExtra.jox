<Class name="CM_RemoteTransferExtra">
    <JadeMethod name="loadRemoteArray" id="4cb246e1-c1fe-4cb5-bdeb-e77deb08af04">
        <updating/>
        <source>loadRemoteArray(_table: CM_EntryTable io) updating;

// cnwdvb1 13 June 2003 
constants

	AllNNArrayRow = 8;
	ColumnHeading = 'New Detail';
	
vars

	detail 					: String;

begin

	if _table.row = AllNNArrayRow then
		inheritMethod(_table);
		_table.setColumnHeadings(NNDetailHeading, ColumnHeading);
		foreach detail in self.allNNTis do
			self.addRemoteRow(_table, detail,detail, null);
		endforeach;
	endif;

end;</source>
        <Parameter name="_table" type="CM_EntryTable" usage="io"/>
    </JadeMethod>
    <JadeMethod name="loadRemoteTable" id="419b3e24-ecf5-4dd3-b268-a330e150d4e7">
        <updating/>
        <source>loadRemoteTable(_table: CM_EntryTable io) updating;

// cnwdvb1 13 June 2003 

vars

begin

	inheritMethod(_table);
	self.addRemoteRow(_table, 'Supplier', self.operator, null);
	self.addRemoteRow(_table, 'Species', self.species, null);
	self.addRemoteRow(_table, 'Grade', self.grade, null);
	self.addRemoteRow(_table, 'Type', self.type, null);
	self.addRemoteRow(_table, 'Treatment', treatment, null);
	self.addRemoteRow(_table, 'Length', length, null);
	self.addRemoteRow(_table, 'All No Number Extra Detail', Click, self);
end;</source>
        <Parameter name="_table" type="CM_EntryTable" usage="io"/>
    </JadeMethod>
</Class>
