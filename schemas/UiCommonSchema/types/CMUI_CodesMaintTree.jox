    <JadeMethod name="setControlsForView" id="beed0ceb-d6b4-4dd1-954b-ba355b202faf">
        <updating/>
        <source>setControlsForView() updating;
// -----------------------------------------------------------------------------
// Created:		19 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
