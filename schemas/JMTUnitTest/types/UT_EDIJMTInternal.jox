    <JadeMethod name="tBookingSeqAction" id="3f905c43-3b8f-409d-a3fa-464473fcde29">
        <source>tBookingSeqAction();
//
//28 July 2017	jlgrs1	Initial creation
//
constants
	USER_DEF_NAME : String = "JMTInternalBooking";
	VESSEL_CODE	: String = "UTXVES1";
	VOYAGE_CODE	: String = "UTXVOY1";
	CONTAINER_ID01 : String = "TEST0000001";
	CONTAINER_ID02 : String = "TEST0000002";
	CONTAINER_ID03 : String = "TEST0000003";
	BOOKING002 : String = "GB100012";
	BOOKING004 : String = "GB100014";
vars
	containerObj : CM_TrackedItem;
	vesselObj : CM_Vessel;
	voyageObj : CM_Voyage;
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	passportObj : CM_Passport;
	ediText : String;
	errorMsg : String;
	bookingRef : CM_BookingRef;
begin
	passportObj	:=	app.myPassport;
	self.deleteContainer(CONTAINER_ID01);
	containerObj := self.getTrackedItem(CONTAINER_ID01);
	self.assertIsDeleted(containerObj);
	self.deleteContainer(CONTAINER_ID02);
	containerObj := self.getTrackedItem(CONTAINER_ID02);
	self.assertIsDeleted(containerObj);
	self.deleteContainer(CONTAINER_ID03);
	containerObj := self.getTrackedItem(CONTAINER_ID03);
	self.assertIsDeleted(containerObj);
	self.deleteBooking(BOOKING002);
	bookingRef := self.getBooking(BOOKING002);
	self.assertIsDeleted(bookingRef);
	self.deleteBooking(BOOKING004);
	bookingRef := self.getBooking(BOOKING004);
	self.assertIsDeleted(bookingRef);
	// Create the Vessel and the Voyage.
	self.deleteVessel(VESSEL_CODE);
	vesselObj	:=	self.getVessel(VESSEL_CODE);
	self.assertIsDeleted(vesselObj);
	self.deleteVoyage(VOYAGE_CODE);
	voyageObj	:=	self.getVoyage(VOYAGE_CODE);
	self.assertIsDeleted(voyageObj);
	self.createVoyageVessel(VOYAGE_CODE, VESSEL_CODE, voyageObj, vesselObj);
	self.assertNotNullMsg(vesselObj, "Add vessel failed!");
	ediText :=
'
&lt;?xml version="1.0"?&gt;
&lt;JMTInternalBooking&gt;
	&lt;AllBookingHeader&gt;
		&lt;BookingHeader&gt;
			&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
			&lt;consignor&gt;UTCOE&lt;/consignor&gt;
			&lt;destinationPort&gt;SAJED&lt;/destinationPort&gt;
			&lt;dischargePort&gt;NZBLU&lt;/dischargePort&gt;
			&lt;id&gt;'&amp;BOOKING002&amp;'&lt;/id&gt;
			&lt;messageMode&gt;A&lt;/messageMode&gt;
			&lt;operatorCode&gt;MSK&lt;/operatorCode&gt;
			&lt;vesselName&gt;'&amp;VESSEL_CODE&amp;'&lt;/vesselName&gt;
			&lt;voyageCode&gt;'&amp;VOYAGE_CODE&amp;'&lt;/voyageCode&gt;
				&lt;AllBookingItem&gt;
					&lt;BookingItem&gt;
						&lt;weight&gt;18830.0000&lt;/weight&gt;
						&lt;number&gt;1&lt;/number&gt;
						&lt;temperature&gt;-20&lt;/temperature&gt;
						&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
						&lt;commodity&gt;FZVG&lt;/commodity&gt;
						&lt;commodityDescription&gt;FROZEN VEGETABLES&lt;/commodityDescription&gt;
						&lt;fullOrMT&gt;F&lt;/fullOrMT&gt;
						&lt;id&gt;'&amp;BOOKING002&amp;'&lt;/id&gt;
						&lt;isoType&gt;22R1&lt;/isoType&gt;
						&lt;messageMode&gt;D&lt;/messageMode&gt;
						&lt;sequence&gt;001&lt;/sequence&gt;
					&lt;/BookingItem&gt;
					&lt;BookingItem&gt;
						&lt;weight&gt;25840.0000&lt;/weight&gt;
						&lt;number&gt;1&lt;/number&gt;
						&lt;temperature&gt;-20&lt;/temperature&gt;
						&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
						&lt;commodity&gt;FZVG&lt;/commodity&gt;
						&lt;commodityDescription&gt;FROZEN VEGETABLES&lt;/commodityDescription&gt;
						&lt;fullOrMT&gt;F&lt;/fullOrMT&gt;
						&lt;id&gt;'&amp;BOOKING002&amp;'&lt;/id&gt;
						&lt;isoType&gt;45R1&lt;/isoType&gt;
						&lt;messageMode&gt;D&lt;/messageMode&gt;
						&lt;sequence&gt;002&lt;/sequence&gt;
					&lt;/BookingItem&gt;
				&lt;/AllBookingItem&gt;
			&lt;/BookingHeader&gt;
			&lt;BookingHeader&gt;
				&lt;AllBookingItem&gt;
					&lt;BookingItem&gt;
						&lt;weight&gt;18830.0000&lt;/weight&gt;
						&lt;number&gt;1&lt;/number&gt;
						&lt;temperature&gt;-20&lt;/temperature&gt;
						&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
						&lt;commodity&gt;FZVG&lt;/commodity&gt;
						&lt;commodityDescription&gt;FROZEN VEGETABLES&lt;/commodityDescription&gt;
						&lt;fullOrMT&gt;F&lt;/fullOrMT&gt;
						&lt;id&gt;'&amp;BOOKING004&amp;'&lt;/id&gt;
						&lt;isoType&gt;22R1&lt;/isoType&gt;
						&lt;messageMode&gt;D&lt;/messageMode&gt;
						&lt;sequence&gt;003&lt;/sequence&gt;
					&lt;/BookingItem&gt;
					&lt;BookingItem&gt;
						&lt;weight&gt;25840.0000&lt;/weight&gt;
						&lt;number&gt;1&lt;/number&gt;
						&lt;temperature&gt;-20&lt;/temperature&gt;
						&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
						&lt;commodity&gt;FZVG&lt;/commodity&gt;
						&lt;commodityDescription&gt;FROZEN VEGETABLES&lt;/commodityDescription&gt;
						&lt;fullOrMT&gt;F&lt;/fullOrMT&gt;
						&lt;id&gt;'&amp;BOOKING004&amp;'&lt;/id&gt;
						&lt;isoType&gt;45R1&lt;/isoType&gt;
						&lt;messageMode&gt;D&lt;/messageMode&gt;
						&lt;sequence&gt;004&lt;/sequence&gt;
					&lt;/BookingItem&gt;
				&lt;/AllBookingItem&gt;
			&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
			&lt;consignor&gt;UTCOE&lt;/consignor&gt;
			&lt;destinationPort&gt;SAJED&lt;/destinationPort&gt;
			&lt;dischargePort&gt;NZBLU&lt;/dischargePort&gt;
			&lt;id&gt;'&amp;BOOKING004&amp;'&lt;/id&gt;
			&lt;messageMode&gt;U&lt;/messageMode&gt;
			&lt;operatorCode&gt;MSK&lt;/operatorCode&gt;
			&lt;vesselName&gt;'&amp;VESSEL_CODE&amp;'&lt;/vesselName&gt;
			&lt;voyageCode&gt;'&amp;VOYAGE_CODE&amp;'&lt;/voyageCode&gt;
		&lt;/BookingHeader&gt;
	&lt;/AllBookingHeader&gt;
&lt;/JMTInternalBooking&gt;
';
	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						errorMsg,
//						CM_EDIFile.EDI_STATUS_VERIFIED,
//						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, errorMsg);
	ediDataObj := ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						"Load Failed",
//						CM_EDIFile.EDI_STATUS_DBLOADED,
//						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	errorMsg := "DB Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write method.name&amp;" EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 6, "incorrect number of EDI trackedItems");
	bookingRef := self.getBooking(BOOKING002);
	self.assertNotNull(bookingRef);
	self.assertEqualMsg(bookingRef.allBookingRefItems.size, 2, "");
	bookingRef := self.getBooking(BOOKING004);
	self.assertNotNull(bookingRef);
	self.assertEqualMsg(bookingRef.allBookingRefItems.size, 2, "");

	ediText :=
'
&lt;?xml version="1.0"?&gt;
&lt;JMTInternalBooking&gt;
	&lt;AllBookingHeader&gt;
		&lt;BookingHeader&gt;
			&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
			&lt;consignor&gt;UTCOE&lt;/consignor&gt;
			&lt;destinationPort&gt;SAJED&lt;/destinationPort&gt;
			&lt;dischargePort&gt;NZBLU&lt;/dischargePort&gt;
			&lt;id&gt;'&amp;BOOKING002&amp;'&lt;/id&gt;
			&lt;messageMode&gt;A&lt;/messageMode&gt;
			&lt;operatorCode&gt;MSK&lt;/operatorCode&gt;
			&lt;vesselName&gt;'&amp;VESSEL_CODE&amp;'&lt;/vesselName&gt;
			&lt;voyageCode&gt;'&amp;VOYAGE_CODE&amp;'&lt;/voyageCode&gt;
				&lt;AllBookingItem&gt;
					&lt;BookingItem&gt;
						&lt;weight&gt;18830.0000&lt;/weight&gt;
						&lt;number&gt;10&lt;/number&gt;
						&lt;temperature&gt;-20&lt;/temperature&gt;
						&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
						&lt;commodity&gt;FZVG&lt;/commodity&gt;
						&lt;commodityDescription&gt;FROZEN VEGETABLES&lt;/commodityDescription&gt;
						&lt;fullOrMT&gt;F&lt;/fullOrMT&gt;
						&lt;id&gt;'&amp;BOOKING002&amp;'&lt;/id&gt;
						&lt;isoType&gt;22R1&lt;/isoType&gt;
						&lt;messageMode&gt;D&lt;/messageMode&gt;
						&lt;sequence&gt;001&lt;/sequence&gt;
					&lt;/BookingItem&gt;
					&lt;BookingItem&gt;
						&lt;weight&gt;25840.0000&lt;/weight&gt;
						&lt;number&gt;1&lt;/number&gt;
						&lt;temperature&gt;-21&lt;/temperature&gt;
						&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
						&lt;commodity&gt;FZBF&lt;/commodity&gt;
						&lt;commodityDescription&gt;FROZEN VEGETABLES&lt;/commodityDescription&gt;
						&lt;fullOrMT&gt;F&lt;/fullOrMT&gt;
						&lt;id&gt;'&amp;BOOKING002&amp;'&lt;/id&gt;
						&lt;isoType&gt;45R1&lt;/isoType&gt;
						&lt;messageMode&gt;D&lt;/messageMode&gt;
						&lt;sequence&gt;002&lt;/sequence&gt;
					&lt;/BookingItem&gt;
				&lt;/AllBookingItem&gt;
			&lt;/BookingHeader&gt;
			&lt;BookingHeader&gt;
				&lt;AllBookingItem&gt;
					&lt;BookingItem&gt;
						&lt;weight&gt;18830.0000&lt;/weight&gt;
						&lt;number&gt;1&lt;/number&gt;
						&lt;temperature&gt;-19&lt;/temperature&gt;
						&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
						&lt;commodity&gt;FZMT&lt;/commodity&gt;
						&lt;commodityDescription&gt;FROZEN VEGETABLES&lt;/commodityDescription&gt;
						&lt;fullOrMT&gt;F&lt;/fullOrMT&gt;
						&lt;id&gt;'&amp;BOOKING004&amp;'&lt;/id&gt;
						&lt;isoType&gt;22R1&lt;/isoType&gt;
						&lt;messageMode&gt;D&lt;/messageMode&gt;
						&lt;sequence&gt;003&lt;/sequence&gt;
					&lt;/BookingItem&gt;
					&lt;BookingItem&gt;
						&lt;weight&gt;25840.0000&lt;/weight&gt;
						&lt;number&gt;1&lt;/number&gt;
						&lt;temperature&gt;-20&lt;/temperature&gt;
						&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
						&lt;commodity&gt;FZVG&lt;/commodity&gt;
						&lt;commodityDescription&gt;FROZEN VEGETABLES&lt;/commodityDescription&gt;
						&lt;fullOrMT&gt;F&lt;/fullOrMT&gt;
						&lt;id&gt;'&amp;BOOKING004&amp;'&lt;/id&gt;
						&lt;isoType&gt;45R1&lt;/isoType&gt;
						&lt;messageMode&gt;A&lt;/messageMode&gt;
						&lt;sequence&gt;005&lt;/sequence&gt;
					&lt;/BookingItem&gt;
				&lt;/AllBookingItem&gt;
			&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
			&lt;consignor&gt;UTCOE&lt;/consignor&gt;
			&lt;destinationPort&gt;SAJED&lt;/destinationPort&gt;
			&lt;dischargePort&gt;NZBLU&lt;/dischargePort&gt;
			&lt;id&gt;'&amp;BOOKING004&amp;'&lt;/id&gt;
			&lt;messageMode&gt;D&lt;/messageMode&gt;
			&lt;operatorCode&gt;MSK&lt;/operatorCode&gt;
			&lt;vesselName&gt;'&amp;VESSEL_CODE&amp;'&lt;/vesselName&gt;
			&lt;voyageCode&gt;'&amp;VOYAGE_CODE&amp;'&lt;/voyageCode&gt;
		&lt;/BookingHeader&gt;
	&lt;/AllBookingHeader&gt;
&lt;/JMTInternalBooking&gt;
';
	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						errorMsg,
//						CM_EDIFile.EDI_STATUS_VERIFIED,
//						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, errorMsg);
	ediDataObj	:=	ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						"Load Failed",
//						CM_EDIFile.EDI_STATUS_DBLOADED,
//						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	errorMsg := "Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write method.name&amp;" EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 6, "incorrect number of EDI trackedItems");
	bookingRef := self.getBooking(BOOKING002);
	self.assertNotNull(bookingRef);
	self.assertEqualMsg(bookingRef.allBookingRefItems.size, 2, "");
	bookingRef := self.getBooking(BOOKING004);
	self.assertNotNull(bookingRef);
	self.assertEqualMsg(bookingRef.allBookingRefItems.size, 1, "");
end;
</source>
    </JadeMethod>
    <JadeMethod name="tCallOffAction" id="c0c506b6-c9bc-421c-afbf-66b6b5f6058e">
        <source>tCallOffAction();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Nov 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
*/

constants
	USER_DEF_NAME : String = "JMTInternalCallOff";
	RELEASE_001 : String = "UTRequestRelease123456789012_1";
	RELEASE_002 : String = "UTRequestRelease123456789012_2";
	RELEASE_003 : String = "UTRequestRelease123456789012_3";
	ManifestNumber = "UTRequestRelease123456789012";
vars
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	relRequest : CM_BulkRelease;
	passportObj : CM_Passport;
	ediText : String;
	errorMsg : String;
begin
	self.setTerminalConfig(IsSubTerminalsOn, false);
	passportObj := app.myPassport;
	self.deleteReleaseRequest(RELEASE_001);
	relRequest := self.getReleaseRequest(RELEASE_001);
	self.assertIsDeleted(relRequest);
	self.deleteReleaseRequest(RELEASE_002);
	relRequest := self.getReleaseRequest(RELEASE_002);
	self.assertIsDeleted(relRequest);
	self.deleteReleaseRequest(RELEASE_003);
	relRequest := self.getReleaseRequest(RELEASE_003);
	self.assertIsDeleted(relRequest);
	self.deleteReleaseRequest(ManifestNumber);
	relRequest := self.getReleaseRequest(ManifestNumber);
	self.assertIsDeleted(relRequest);
	
	ediText :=
'&lt;?xml version="1.0"?&gt;
&lt;JMTInternalCallOff xmlns:xsi="http://www.jademasterterminallogistics.com/JMTInternal" xsi:noNamespaceSchemaLocation="JMTInternalCallOff.xsd"&gt;
  &lt;AllDataCallOff&gt;
  &lt;DataCallOff&gt;
		&lt;statusString&gt;Create&lt;/statusString&gt;
		&lt;guid&gt;"bd32cfne-24eb-495e-98d2-df19db66dd8&lt;/guid&gt;
		&lt;type&gt;Ship&lt;/type&gt;
		&lt;receiver&gt;EBTA&lt;/receiver&gt;
		&lt;sender&gt;Sarge&lt;/sender&gt;
      &lt;manifestNumber&gt;UTRequestRelease123456789012&lt;/manifestNumber&gt;
  &lt;AllRequestHeader&gt;
    &lt;RequestHeader&gt;
      &lt;carrierCode&gt;ABC&lt;/carrierCode&gt;
      &lt;consignee&gt;ABCNE&lt;/consignee&gt;
      &lt;consignor&gt;ABCNR&lt;/consignor&gt;
      &lt;consignorVoyage&gt;Consignor Voyage&lt;/consignorVoyage&gt;
      &lt;customsAgent&gt;DEBCA&lt;/customsAgent&gt;
      &lt;deliveryReleaseNumber&gt;Additional Required Informatio&lt;/deliveryReleaseNumber&gt;
      &lt;dischargePort&gt;NZNSN&lt;/dischargePort&gt;
      &lt;freightForwarder&gt;ABFFD&lt;/freightForwarder&gt;
      &lt;loadPort&gt;NZPOE&lt;/loadPort&gt;
      &lt;messageMode&gt;A&lt;/messageMode&gt;
      &lt;operatorCode&gt;MSL&lt;/operatorCode&gt;
      &lt;releaseRequestNumber&gt;UTRequestRelease123456789012_1&lt;/releaseRequestNumber&gt;
      &lt;releaseTypeStr&gt;Road&lt;/releaseTypeStr&gt;
      &lt;remarks&gt;Remarks 1&lt;/remarks&gt;
      &lt;statusBulkRelease&gt;Active&lt;/statusBulkRelease&gt;
      &lt;subTerminalCode&gt;UT_Depot&lt;/subTerminalCode&gt;
      &lt;estimatedRequiredDate&gt;12 July 2016, 00:00:00&lt;/estimatedRequiredDate&gt;
      &lt;requestDate&gt;21 December 2015, 00:00:00&lt;/requestDate&gt;
      &lt;AllRequestDetail&gt;
        &lt;RequestDetail&gt;
          &lt;clean&gt;true&lt;/clean&gt;
          &lt;quantity&gt;1&lt;/quantity&gt;
          &lt;availabilityGrades&gt;50 66&lt;/availabilityGrades&gt;
          &lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
          &lt;id&gt;REQUEST0013&lt;/id&gt;
          &lt;ids&gt;SUDU20 !SUDU202&lt;/ids&gt;
          &lt;messageMode&gt;A&lt;/messageMode&gt;
          &lt;releaseRequestNumber&gt;UTRequestRelease123456789012_1&lt;/releaseRequestNumber&gt;
		  &lt;requestDetailID&gt;UTRequestRelease123456789012_11&lt;/requestDetailID&gt;
          &lt;remarks&gt;FARE RIF   PER CONTO SMART LIVORNO&lt;/remarks&gt;
          &lt;requestDetailID&gt;001&lt;/requestDetailID&gt;
          &lt;AllRequestCriteria/&gt;
          &lt;AllTaskActionsToApply/&gt;
        &lt;/RequestDetail&gt;
        &lt;RequestDetail&gt;
          &lt;clean&gt;true&lt;/clean&gt;
          &lt;quantity&gt;1&lt;/quantity&gt;
          &lt;availabilityGrades&gt;50 66&lt;/availabilityGrades&gt;
          &lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
          &lt;id&gt;REQUEST0014&lt;/id&gt;
          &lt;ids&gt;SUDU20 !SUDU202&lt;/ids&gt;
          &lt;messageMode&gt;A&lt;/messageMode&gt;
          &lt;releaseRequestNumber&gt;UTRequestRelease123456789012_1&lt;/releaseRequestNumber&gt;
 		  &lt;requestDetailID&gt;UTRequestRelease123456789012_12&lt;/requestDetailID&gt;
         &lt;remarks&gt;Detail Remarks 1&lt;/remarks&gt;
          &lt;requestDetailID&gt;002&lt;/requestDetailID&gt;
        &lt;/RequestDetail&gt;
        &lt;RequestDetail&gt;
          &lt;quantity&gt;1&lt;/quantity&gt;
          &lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
          &lt;id&gt;REQUEST0029&lt;/id&gt;
          &lt;messageMode&gt;A&lt;/messageMode&gt;
          &lt;releaseRequestNumber&gt;UTRequestRelease123456789012_2&lt;/releaseRequestNumber&gt;
 		  &lt;requestDetailID&gt;UTRequestRelease123456789012_13&lt;/requestDetailID&gt;
         &lt;remarks&gt;Detail Remarks 2&lt;/remarks&gt;
          &lt;requestDetailID&gt;001&lt;/requestDetailID&gt;
        &lt;/RequestDetail&gt;
        &lt;RequestDetail&gt;
          &lt;quantity&gt;1&lt;/quantity&gt;
          &lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
          &lt;id&gt;REQUEST0034&lt;/id&gt;
          &lt;messageMode&gt;A&lt;/messageMode&gt;
          &lt;releaseRequestNumber&gt;UTRequestRelease123456789012_3&lt;/releaseRequestNumber&gt;
 		  &lt;requestDetailID&gt;UTRequestRelease123456789012_14&lt;/requestDetailID&gt;
         &lt;remarks&gt;Detail Remarks 3&lt;/remarks&gt;
          &lt;requestDetailID&gt;001&lt;/requestDetailID&gt;
        &lt;/RequestDetail&gt;
      &lt;/AllRequestDetail&gt;
    &lt;/RequestHeader&gt;
    &lt;RequestHeader&gt;
      &lt;messageMode&gt;U&lt;/messageMode&gt;
      &lt;operatorCode&gt;MSL&lt;/operatorCode&gt;
      &lt;releaseRequestNumber&gt;UTRequestRelease123456789012_2&lt;/releaseRequestNumber&gt;
      &lt;releaseTypeStr&gt;Road&lt;/releaseTypeStr&gt;
      &lt;remarks&gt;Remarks 2&lt;/remarks&gt;
      &lt;statusBulkRelease&gt;Active&lt;/statusBulkRelease&gt;
      &lt;subTerminalCode&gt;UT_Depot&lt;/subTerminalCode&gt;
    &lt;/RequestHeader&gt;
    &lt;RequestHeader&gt;
      &lt;messageMode&gt;U&lt;/messageMode&gt;
      &lt;operatorCode&gt;MSL&lt;/operatorCode&gt;
      &lt;releaseRequestNumber&gt;UTRequestRelease123456789012_3&lt;/releaseRequestNumber&gt;
      &lt;releaseTypeStr&gt;Ship&lt;/releaseTypeStr&gt;
      &lt;remarks&gt;Remarks 3&lt;/remarks&gt;
      &lt;statusBulkRelease&gt;Active&lt;/statusBulkRelease&gt;
      &lt;subTerminalCode&gt;UT_Depot&lt;/subTerminalCode&gt;
    &lt;/RequestHeader&gt;
  &lt;/AllRequestHeader&gt;
  &lt;/DataCallOff&gt;
  &lt;/AllDataCallOff&gt;
&lt;/JMTInternalCallOff&gt;
';

	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);
return;
	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						errorMsg,
//						CM_EDIFile.EDI_STATUS_VERIFIED,
//						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, errorMsg);
	ediDataObj := ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						"Load Failed",
//						CM_EDIFile.EDI_STATUS_DBLOADED,
//						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	errorMsg := "DB Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 4, "incorrect number of EDI trackedItems");
	relRequest := self.getReleaseRequest(ManifestNumber);
	self.assertNotNull(relRequest);
	self.assertEqualMsg(relRequest.consigneeCode, "ABCNE", "consigneeCode wrong");
end;
</source>
    </JadeMethod>
    <JadeMethod name="tCargoAction" id="ebaf24fe-64f8-42ca-90b4-2e091fa26e55">
        <source>tCargoAction();
//
//14 August 2017	jlgrs1	Initial creation
//
constants
	USER_DEF_NAME : String = "JMTInternalCargo";
	CONTAINERID : String = "SARG1234543";
	OPERATORCODE = 'MSK';
	BookingId1 = 'BK27418';
vars
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	operator : CM_Operator;
	container : CM_Container;
	passportObj : CM_Passport;
	ediText : String;
	errorMsg : String;
begin
	passportObj := app.myPassport;
	operator := self.getOperator(OPERATORCODE);
	self.deleteContainer(CONTAINERID);
	container := self.getTrackedItem(CONTAINERID).CM_Container;
	self.assertIsDeleted(container);
//	container := self.addContainer(CONTAINERID, operator, "4102", "MT", TI_IMEX_STATUS_STORAGE).CM_Container;
	ediText :=
'&lt;?xml version="1.0"?&gt;
&lt;JMTInternalCargo xmlns:xsi="http://www.jademasterterminallogistics.com/JMTInternal" xsi:noNamespaceSchemaLocation="JMTInternalCargo.xsd"&gt;
	&lt;AllCargo&gt;
		&lt;Cargo&gt;
			&lt;directDelivery/&gt;
			&lt;hasRadio/&gt;
			&lt;isNew/&gt;
			&lt;isWeightCertified/&gt;
			&lt;preSlung/&gt;
			&lt;selfPropelled/&gt;
			&lt;wet/&gt;
			&lt;certificate1Expiry/&gt;
			&lt;certificate2Expiry/&gt;
			&lt;docsCleared/&gt;
			&lt;docsReceived/&gt;
			&lt;docsReturned/&gt;
			&lt;docsSent/&gt;
			&lt;expiryDate/&gt;
			&lt;cargoWeight/&gt;
			&lt;height/&gt;
			&lt;length/&gt;
			&lt;overHeight/&gt;
			&lt;overLengthBack/&gt;
			&lt;overLengthFront/&gt;
			&lt;overWidthLeft/&gt;
			&lt;overWidthRight/&gt;
			&lt;tareWeight/&gt;
			&lt;vent/&gt;
			&lt;volume/&gt;
			&lt;weight/&gt;
			&lt;width/&gt;
			&lt;availabilityGrade/&gt;
			&lt;carbonDioxide/&gt;
			&lt;contentsStatus/&gt;
			&lt;doors/&gt;
			&lt;humidity/&gt;
			&lt;oxygen/&gt;
			&lt;parentCargoTypeCode/&gt;
			&lt;quantity/&gt;
			&lt;receiptTransportMode/&gt;
			&lt;site/&gt;
			&lt;totalQuantity/&gt;
			&lt;year/&gt;
			&lt;temperature/&gt;
			&lt;alternativeId/&gt;
			&lt;bol/&gt;
			&lt;bookingRef/&gt;
			&lt;breakBulkType/&gt;
			&lt;carType/&gt;
			&lt;cargoGroupId/&gt;
			&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
			&lt;carrierCode/&gt;
			&lt;certificate1/&gt;
			&lt;certificate2/&gt;
			&lt;chassisNo/&gt;
			&lt;colour&gt;12&lt;/colour&gt;
			&lt;commodity/&gt;
			&lt;commodityDescription/&gt;
			&lt;companyCode/&gt;
			&lt;consignee/&gt;
			&lt;consignor/&gt;
			&lt;customsAgent/&gt;
			&lt;customsReference/&gt;
			&lt;description&gt;Stuff&lt;/description&gt;
			&lt;destinationPort/&gt;
			&lt;dischargePort/&gt;
			&lt;engineNo/&gt;
			&lt;freightForwarder/&gt;
			&lt;fullOrMT/&gt;
			&lt;generatorID/&gt;
			&lt;generatorType/&gt;
			&lt;heatTreated/&gt;
			&lt;heightString/&gt;
			&lt;id&gt;'&amp;CONTAINERID&amp;'&lt;/id&gt;
			&lt;imexStatus/&gt;
			&lt;invoiceNumber/&gt;
			&lt;isoType&gt;4102&lt;/isoType&gt;
			&lt;isoTypeGroup/&gt;
			&lt;lengthString/&gt;
			&lt;loadPort/&gt;
			&lt;locationId/&gt;
			&lt;make/&gt;
			&lt;mark/&gt;
			&lt;markNumber/&gt;
			&lt;messageMode&gt;A&lt;/messageMode&gt;
			&lt;model/&gt;
			&lt;operatorCode&gt;MSK&lt;/operatorCode&gt;
			&lt;orderNumber/&gt;
			&lt;palletType/&gt;
			&lt;parentCargoID/&gt;
			&lt;parentCargoType/&gt;
			&lt;product/&gt;
			&lt;purchaseOrder/&gt;
			&lt;registration/&gt;
			&lt;remarks/&gt;
			&lt;sealCustoms/&gt;
			&lt;sealNum/&gt;
			&lt;sealNumberVent/&gt;
			&lt;sealShipper/&gt;
			&lt;sealTerminalOperator/&gt;
			&lt;sealUnknown/&gt;
			&lt;serviceOrder/&gt;
			&lt;storeOnPallet/&gt;
			&lt;trackingNumber1/&gt;
			&lt;trackingNumber2/&gt;
			&lt;trailerType/&gt;
			&lt;vgmAuthSignature/&gt;
			&lt;vgmCommsType/&gt;
			&lt;vgmDocumentDetails/&gt;
			&lt;vgmEDITransmission/&gt;
			&lt;vgmElectronicMail/&gt;
			&lt;vgmMail/&gt;
			&lt;vgmPhone/&gt;
			&lt;vgmTelefax/&gt;
			&lt;vgmTelephone/&gt;
			&lt;vin/&gt;
			&lt;voyageCode/&gt;
			&lt;weightCertifiedName/&gt;
			&lt;weightCertifiedReference/&gt;
			&lt;widthString/&gt;
			&lt;receiveDate/&gt;
			&lt;vgmDeterminationDT/&gt;
			&lt;vgmDocsIssuedDT/&gt;
			&lt;salesOrderNbr/&gt;
		&lt;/Cargo&gt;
	&lt;/AllCargo&gt;
&lt;/JMTInternalCargo&gt;';

	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
	self.assertIsOneOf(	ediFileObj.fileStatus,
						errorMsg,
						CM_EDIFile.EDI_STATUS_VERIFIED,
						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
//	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, errorMsg);
	ediDataObj := ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						"Load Failed",
//						CM_EDIFile.EDI_STATUS_DBLOADED,
//						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	errorMsg := "DB Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 1, "incorrect number of EDI trackedItems");
	container := self.getTrackedItem(CONTAINERID).CM_Container;
	self.assertNotNull(container);
	self.assertEqualMsg(container.description, "Stuff", "wrong remarks");
end;
</source>
    </JadeMethod>
    <JadeMethod name="tCargoFieldUpdateAction" id="55c6400b-117b-412c-afcb-937193444fb9">
        <source>tCargoFieldUpdateAction();
//
//14 August 2017	jlgrs1	Initial creation
//
constants
	USER_DEF_NAME : String = "JMTInternalCargoFieldUpdate";
	CONTAINERID : String = "SARG1234543";
	VOYAGECODE = 'VOY27418';
	VESSELNAME = 'SHIP27418';
	OPERATORCODE = 'MSK';
	BookingId1 = 'BK27418';
	BlockStackName	= 'BS26728';
vars
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	operator : CM_Operator;
	bs : CM_BlockStack;
	container : CM_Container;
	passportObj : CM_Passport;
	ediText : String;
	errorMsg : String;
begin
	passportObj := app.myPassport;
	operator := self.getOperator(OPERATORCODE);
	self.deleteVoyage(VOYAGECODE);
	voyage := self.getVoyage(VOYAGECODE);
	self.assertIsDeleted(voyage);
	self.deleteVessel(VESSELNAME);
	vessel := self.getVessel(VESSELNAME);
	self.assertIsDeleted(vessel);
	self.deleteContainer(CONTAINERID);
	container := self.getTrackedItem(CONTAINERID).CM_Container;
	self.assertIsDeleted(container);
	vessel := self.addVesselCellular(VESSELNAME,
										operator);
	self.assertNotNullMsg(vessel, 'Add vessel failed');
	
	voyage := self.addVoyageWithContainerStructur(VOYAGECODE,
													VESSELNAME,
													OPERATORCODE,
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage failed');
	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);

	// Delete and add the required bookings
	self.opts.addAssoc('Stock', true);
	self.opts.addAssocIfNotNull(ETRow_PackAs, app.getString(PackAs_LCL));
	self.deleteBooking(BookingId1);
	container := self.addContainerOnShip(CONTAINERID, operator, "4102", "GOLD", BookingId1, voyage, self.getTerminal.getConfig(PortDestCode).String, "010682").CM_Container;
	bs := addBlockStack(BlockStackName, 100, null);
	self.opts.addAssoc('IsForcedMove', true);
	self.move(container, bs);
	ediText :=
'&lt;?xml version="1.0"?&gt;
&lt;JMTInternalCargoFieldUpdate xmlns:xsi="http://www.jademasterterminallogistics.com/JMTInternal" xsi:noNamespaceSchemaLocation="JMTInternalCargoFieldUpdate.xsd"&gt;
	&lt;AllCargoFieldUpdate&gt;
		&lt;CargoFieldUpdate&gt;
		&lt;bolNumber/&gt;
			&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
		&lt;description/&gt;
		&lt;fieldName&gt;freightForwarderCode&lt;/fieldName&gt;
		&lt;fieldValue&gt;UTFF2&lt;/fieldValue&gt;
		&lt;fullOrMT/&gt;
			&lt;id&gt;'&amp;CONTAINERID&amp;'&lt;/id&gt;
		&lt;messageMode&gt;A&lt;/messageMode&gt;
		&lt;voyageCode/&gt;
		&lt;/CargoFieldUpdate&gt;
	&lt;/AllCargoFieldUpdate&gt;
&lt;/JMTInternalCargoFieldUpdate&gt;';

	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						errorMsg,
//						CM_EDIFile.EDI_STATUS_VERIFIED,
//						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, errorMsg);
	ediDataObj := ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						"Load Failed",
//						CM_EDIFile.EDI_STATUS_DBLOADED,
//						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	errorMsg := "DB Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 1, "incorrect number of EDI trackedItems");
	container := self.getTrackedItem(CONTAINERID).CM_Container;
	self.assertNotNull(container);
	self.assertEqualMsg(container.freightForwarderCode, "UTFF2", "freightForwarderCode incorrect");
	self.assertEqualMsg(container.remarks.trimBlanks, "Created by unit test UT_EDIJMTInternal::tCargoFieldUpdateAction"&amp;CrLf, "wrong remarks");
end;
</source>
    </JadeMethod>
    <JadeMethod name="tCargoGroupAction" id="56f52ed4-0100-4898-a347-6d94ec8b8243">
