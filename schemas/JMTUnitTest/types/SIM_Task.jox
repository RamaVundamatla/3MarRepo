    <JadeMethod name="isTaskReadyForAccept" id="d858b84c-43d8-49a2-b4d9-e4a5085eb5ce">
        <source>isTaskReadyForAccept(): Boolean;

vars

begin
	if self.isFirst then
		return true;
	endif;
	
	return self.getPrev.isWorking;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isWorking" id="531976db-d5da-4108-8b0a-bc780e848871">
        <source>isWorking(): Boolean;
vars

begin
	if self.isSetdown then
		return true;
	endif;
	
	if self.isMove and self.myMachine.hasCargo then
		return true;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
