    <JadeMethod name="doEnquireTblPacked" id="0e8cc635-bda9-4476-8e1a-de883051e7e0">
        <source>doEnquireTblPacked(_edit : Boolean) protected;
// ---------------------------------------------------------------------------
// Created:     19 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	ti				: CM_TrackedItem;
	tbl				: CM_DataTable;
	str				: String;
begin
	tbl :=self.tblPacked;
	ti := tbl.accessRow(tbl.row).itemObject.CM_TrackedItem;
	
	if (not tbl.accessedRow.selected) then
		if _edit then
			app.msgBox('Please select an item to edit', 'Nothing selected', MsgBox_Exclamation_Mark_Icon);
		else
			app.msgBox('Please select an item on which to enquire', 'Nothing selected', MsgBox_Exclamation_Mark_Icon);		
		endif;
		return;
	endif;
	
	//epr par 31372
	if self.tblPacked.allSelectedObjects.size &gt; 1 then
		self.myAssistant.showCargoEnquiryForTIs(ti,self.tblPacked.allSelectedObjects,self.myMasterMenuAction,_edit);
		return;
	endif;
	
	self.myAssistant.showCargoEnquiryForm(ti, self.myMasterMenuAction, true, _edit);

end;</source>
        <access>protected</access>
        <Parameter name="_edit" type="Boolean"/>
    </JadeMethod>
