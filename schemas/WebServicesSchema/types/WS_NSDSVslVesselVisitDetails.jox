    <JadeMethod name="setFromOpsViewTable" id="c4e75efd-2edf-4c02-a1b2-f72e97516d1b">
        <updating/>
        <source>setFromOpsViewTable(_detail : CMIF_VslVesselVisitDetails; _seq : Integer io) updating;
/*
Purpose:			

Date		Who		Reason
09 December 2021	navab1	TFS 51853
*/

vars
	wsMoves                 : WS_NSDSVslVesselBerthingsArray;
	pxyMove     		    : WS_NSDSVslVesselBerthings;
	berth : CMIF_VslVesselBerthings;
	seq                     : Integer;
begin
	inheritMethod(_detail, _seq);

	self.tableName := _detail.tableName;
	self.gkey := _detail.gkey;
	self.vvd_gkey := _detail.vvd_gkey;
	self.classification := _detail.classification;
	self.vessel_gkey := _detail.vessel_gkey;

	if not _detail.allVslVesselBerthings.isEmpty() then
		create wsMoves transient;
		foreach berth in _detail.allVslVesselBerthings do
			create pxyMove transient;
			pxyMove.setFromOpsViewTable(berth, seq);
			wsMoves.add(pxyMove);
		
		endforeach;
		self.allVslVesselBerthings := wsMoves;
	endif;

epilog

end;</source>
        <Parameter name="_detail" type="CMIF_VslVesselVisitDetails"/>
        <Parameter name="_seq" type="Integer" usage="io"/>
    </JadeMethod>
