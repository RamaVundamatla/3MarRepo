    <JadeMethod name="setControlsForAddEdit" id="e091593c-2b26-4819-9c60-61268de5e7d0">
        <updating/>
        <source>setControlsForAddEdit() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 March 2017	cnwndl1	Initial creation

*/

vars

	theForm : SOP_TableMaintForm;
	
begin

	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
	
	theForm.initTblInput(theForm.tblInput1, theForm.tblInput1.myEntTableDef.name);
	
	theForm.tblInput1.hideRowByName(ETRow_HandlingType, false);
	
	if theForm.mode = theForm.Mode_Add then
		theForm.tblInput1.clearValues;
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);
		theForm.tblInput1.enableRowByName(ETRow_IsDefault);
		theForm.tblInput1.enableRowByName(ETRow_IsAvailableForEntry);
		theForm.tblInput1.enableRowByName(ETRow_HeatTreated);
		
		theForm.tblInput1.setFocus;
		theForm.tblInput1.moveFirst();
		
	else
		// refresh the data from the newly created proxy
		self.showThumbnail(theForm.myProxyObject.CM_PalletType);

	endif;
	
	theForm.btnImport.enabled := false;
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="804f159f-6711-4492-87a0-fb4fc1a4d03c">
        <updating/>
        <source>setCtrlsForView() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 March 2017	cnwndl1	Initial creation	TFS 3414

*/

vars

	theForm : SOP_TableMaintForm;

begin

	inheritMethod();
	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := false;
	theForm.initTblInput(theForm.tblInput1, theForm.tblInput1.myEntTableDef.name);
	
	theForm.btnImport.enabled := false;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="3b482840-b89c-4aeb-b4a0-34d0e89938c6">
        <updating/>
        <source>showThumbnail(pObj: CM_Object) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 March 2017	cnwndl1	Initial creation	TFS 3414

*/

vars

	theForm : SOP_TableMaintForm;

begin
	
	theForm := self.myForm;
	
	theForm.tblInput1.setValueByName(ETRow_HandlingType, pObj.CM_PalletType.getDisplayStringForAttribute(ETRow_HandlingType,false));
	theForm.tblInput1.setValueByName(ETRow_Code, pObj.CM_PalletType.code);
	theForm.tblInput1.setValueByName(ETRow_Description, pObj.CM_PalletType.description);
	theForm.tblInput1.setValueByName(ETRow_IsAvailableForEntry, not pObj.CM_PalletType.isNotAvailableForEntry);
	theForm.tblInput1.setValueByName(ETRow_IsDefault, pObj.CM_PalletType.isDefault);
	theForm.tblInput1.setValueByName(ETRow_HeatTreated, pObj.CM_PalletType.heatTreated);

epilog

end;</source>
        <Parameter name="pObj" type="CM_Object"/>
    </JadeMethod>
</Class>
