<Class name="CMIF_InvoiceTMGrouping" id="3159baab-572b-426a-b596-47baa49720f3">
    <superclass name="CMIF_Object"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="invoice"/>
    <ImplicitInverseRef name="allInvoiceLineTypes" id="cba8db4f-4ee8-4ee9-a1e7-8280676f0e72">
        <memberTypeInverse/>
        <type name="CM_InvoiceLineDescSet"/>
    </ImplicitInverseRef>
    <PrimAttribute name="defaultLineGroupType" id="9334ba9d-2e7f-4de4-8bcf-522c634cf130">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <ImplicitInverseRef name="defaultLineType" id="abbb4ab2-234e-4bb2-9cd3-5a19edf4319d">
        <embedded/>
        <type name="CM_InvoiceLineDesc"/>
    </ImplicitInverseRef>
    <PrimAttribute name="invoiceLineGroupType" id="81cbfc44-868b-42f7-9c31-48264518d688">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <ImplicitInverseRef name="myBusinessUnit" id="75f11b3e-df8e-40c9-aacd-e2533e89042d">
        <embedded/>
        <type name="CM_Bank"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myQRM" id="b79e8b8d-45e6-4b05-bc68-4f947a04b40d">
        <embedded/>
        <type name="CM_QuantityRangeMap"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myTransaction" id="2f6934a5-bd0f-41e0-869b-f49022123ef3">
        <embedded/>
        <type name="CM_TITransaction"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myTransientInvoice" id="9733171f-d899-4d73-8b72-aacbefcf9945">
        <embedded/>
        <type name="CM_Invoice"/>
    </ImplicitInverseRef>
    <JadeMethod name="findGroupedInvoiceLineDesc" id="2076005a-27a5-4272-af32-6b3fc272c691">
        <source>findGroupedInvoiceLineDesc() : CM_InvoiceLineDesc;
/*
Purpose:			

Date		Who		Reason
15 February 2023	navab1	TFS CR 56446 TASK 56447
23 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/

vars
	invLineType : CM_InvoiceLineDesc;
	invLineTypes : CM_InvoiceLineDescSet;
	invLine : CM_InvoiceLine;
	invLines : CM_InvoiceLineSet;
	extremeInvLine, defaultInvLine : CM_InvoiceLine;
	idx, seqnum : Integer;
	total	: Decimal[23, 6];
	msg : String;
	canLogExtra	: Boolean;	//28.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//28.02.2025 navah1	#34141
	create invLines transient;
	create invLineTypes transient;
	
	foreach invLineType in self.allInvoiceLineTypes discreteLock do
		idx := idx + 1;
		seqnum:= (self.invoiceLineGroupType * 10) + idx;
		
		invLine := self.myBusinessUnit.createTransientInvoiceLine2(invLineType,	//_invLineDesc : CM_InvoiceLineDesc io;
													self.myTransientInvoice,
													self.myTransaction,	//_transaction : CM_TITransaction;
													null,			//_resourceTypeUsage : CM_ResourceTypeUsage;
													seqnum,			//_index : Integer;
													self.myQRM			//_qrm : CM_QuantityRangeMap
													);
									
		if invLine &lt;&gt; null then
			if invLineType = self.defaultLineType then
				invLine.setProformaPaymentType(self.defaultLineGroupType);
			else
				invLine.setProformaPaymentType(self.invoiceLineGroupType);
			endif;
			invLines.add(invLine);
			if canLogExtra then	//28.02.2025 navah1	#34141
				app.invLog("GROUPING temporary line '" &amp; invLineType.narration &amp; "' value " &amp; invLine.lineTotal.String, LogTRACE.String);
			endif;
		endif;
	endforeach;
	
	if self.invoiceLineGroupType = TranMapInvLineGroupTypeLow or
	   self.invoiceLineGroupType = TranMapInvLineGroupTypeLowDef then
		msg := "GROUPING lowest";
		total := 999999999.9999;
	else // Is highest
		msg := "GROUPING highest (" &amp; self.invoiceLineGroupType.String &amp; ")";
		total := -999999999.9999;
	endif;
	if canLogExtra then	//28.02.2025 navah1	#34141
		app.invLog(CrLf &amp; method.qualifiedName &amp; " " &amp; msg, LogTRACE.String); // ### TFS BUG 64673 15JUNE024 NAVAB1&amp; " value " &amp; total.String);
	endif;
	// ### TFS BUG 64673 15JUNE024 NAVAB1
	if canLogExtra then	//28.02.2025 navah1	#34141
		foreach invLine in invLines do
			app.invLog("GROUPING Line and Value " &amp;  " - " &amp; invLine.invoiceLineDesc.narration &amp; " VALUE = " &amp; invLine.lineTotal.String, LogTRACE.String);
		endforeach;
	endif;	
		
	foreach invLine in invLines do
		if self.invoiceLineGroupType = TranMapInvLineGroupTypeLow 
		or self.invoiceLineGroupType = TranMapInvLineGroupTypeLowDef then
			if invLine.lineTotal &lt; total then
				total := invLine.lineTotal;
				extremeInvLine := invLine;
				
				defaultInvLine := null; // ### TFS BUG 64673 15JUNE024 NAVAB1

				if invLine.paymentType = TranMapInvLineGroupTypeLowDef then
					defaultInvLine := invLine;
				endif;
			elseif invLine.lineTotal = total then
				if invLine.paymentType = self.defaultLineGroupType then
					defaultInvLine := invLine;
				endif;
			endif;
		else
			if invLine.lineTotal &gt; total then
				total := invLine.lineTotal;
				extremeInvLine := invLine;
				
				defaultInvLine := null; // ### TFS BUG 64673 15JUNE024 NAVAB1
				
				if invLine.paymentType = self.defaultLineGroupType then
					defaultInvLine := invLine;
				endif;
			elseif invLine.lineTotal = total then
				if invLine.paymentType = self.defaultLineGroupType then
					defaultInvLine := invLine;
				endif;
			endif;
		endif;
	endforeach;
	
	if defaultInvLine &lt;&gt; null then
		if canLogExtra then	//28.02.2025 navah1	#34141
			app.invLog(CrLf &amp; "GROUPING - " &amp; self.defaultLineType.narration &amp; " USED", LogTRACE.String); // ### TFS BUG 64673 15JUNE024 NAVAB1
		endif;
		return self.defaultLineType;
	elseif extremeInvLine &lt;&gt; null then
		if canLogExtra then	//28.02.2025 navah1	#34141
			app.invLog(CrLf &amp; "GROUPING - " &amp; extremeInvLine.invoiceLineDesc.narration &amp; " USED", LogTRACE.String);// ### TFS BUG 64673 15JUNE024 NAVAB1
		endif;
		return extremeInvLine.invoiceLineDesc;
	
	endif;

	return null;
epilog
	delete invLines;
	delete invLineTypes;
end;</source>
        <ReturnType type="CM_InvoiceLineDesc"/>
    </JadeMethod>
</Class>
