    <JadeMethod name="doSave" id="4c46519c-264e-4354-891c-73b95fe6f2ed">
        <updating/>
        <source>doSave() : Boolean updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
06 July 2009	cnwndl1	Initial creation
08/04/2011		cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
06/03/2014		cnwdap1	PAR #33638 Correct measurement field handling
*/

vars
	
	pxyMaster : CM_WagonMaster;
	id : String;
	wagonClass : CM_WagonClass;
	carrier : CM_Carrier;
	maxCHeight : Decimal [12,4];		// PAR #33638
	maxCWeight : Decimal [12,4];		// PAR #33638
	//tareWeight : Integer;				// PAR #33638
	tareWeight : Decimal [12,4];		// PAR #33638
	result : Integer;
	errors : String;
	askPropo, isCreate : Boolean;
	msg : String;
	changes : String;
	
begin

	isCreate := ( self.myWagonMaster = null ).Boolean;

	askPropo := (not isCreate and not self.myWagonMaster.allCurrentWagons.isEmpty());
	
	beginLoad;
	if not isCreate then
		pxyMaster := self.myWagonMaster.pxyCreateUpdateProxy;
	else
		create pxyMaster transient;
	endif;
	endLoad;
	
	id :=self.txtId.text;
	wagonClass :=  self.cmbWagonClass.listObject.CM_WagonClass;
	carrier :=  self.cmbCarrier.listObject.CM_Carrier;
	//maxCHeight := self.txtMaxCHeight.text.Decimal;										// PAR #33638
	//maxCHeight := self.txtMaxCHeight.text.asDecimalJMT();	// 01 APR 2010	NDL	Par 23556	// PAR #33638
	//maxCWeight := self.txtMaxCWeight.text.Decimal;										// PAR #33638
	//maxCWeight := self.txtMaxCWeight.text.asDecimalJMT();	// 01 APR 2010	NDL	Par 23556	// PAR #33638
	//tareWeight := self.txtTareWeight.text.Integer;										// PAR #33638
	maxCHeight := self.txtMaxCHeight.getConvertedValue();									// PAR #33638
	maxCWeight := self.txtMaxCWeight.getConvertedValue();									// PAR #33638
	tareWeight := self.txtTareWeight.getConvertedValue();									// PAR #33638
	
	pxyMaster.setProxy(	id,	//_id : String;
						wagonClass,	//_myWagonClass : CM_WagonClass;
						carrier,	//_myCarrier : CM_Carrier;
						maxCHeight,	//_maxCargoHeight	: Decimal; 
						maxCWeight,	//_maxCargoWeight	: Decimal;
						tareWeight	//_tareWeight	: Decimal
						);
	
	if pxyMaster = null then
		app.raiseUnexpectedProgramError(class.name, method.name, app.getErrorString(Proxy_Object_Null_For_Update) );
		return false;
	endif;
	
	while true do

		if pxyMaster.propogateChanges = CM_WagonMaster.AskPropogateChgs then
			if self.myWagonMaster = null then
				// creating a new one, do not propogate changes.
				pxyMaster.setPropogateChanges(false);
			elseif not pxyMaster.differsFrom(self.myWagonMaster, changes) then
				pxyMaster.setPropogateChanges(false);
			else
				msg := app.getErrorString(Want_propo_these_chang_curre) &amp; "?";
				if changes.trimBlanks &lt;&gt; null then
					msg := msg &amp; CrLf &amp; changes;
				endif;
				if askPropo then
					if app.msgBox(msg,app.getErrorString(Propogate_changes),MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_Yes then
						pxyMaster.setPropogateChanges(true);
					else
						pxyMaster.setPropogateChanges(false);
					endif;
				else	//07 Oct 2009	NDL Par 20857
					pxyMaster.setPropogateChanges(false);
				endif;
			endif;
		endif;
		if isCreate then	
			app.myTrxCA.trxCreateWagonMaster( pxyMaster, self.myWagonMaster, app.myPassport );
		else
			app.myTrxUA.trxUpdateWagonMaster(pxyMaster, app.myPassport);
		endif;
		if not app.myPassport.trxCompletedOK then
			result := app.showErrorWarningDialog(app.getErrorString(Create_wagon_master) , app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
			self.setAllErrorWarnings(app.myPassport);	
			if app.myPassport.noErrors and  result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		else
			self.clearErrorWarnings();
			self.myParentForm.CMUI_TIMasterForm.setMyCurrentTiMaster( self.myWagonMaster );
			self.btnDamage.enabled := true;	//07 Oct 2009	NDL Par 20783
			return true;
		endif;
		break;
	endwhile;
	
	return false;
	
epilog
	endLoad;				// 08/04/2011 cnwmh5 #27347
	pxyMaster.allDamageInstancesByPos.purge();
	delete pxyMaster;	

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSelectWagonClass" id="f607c339-c1a8-4a46-b5fe-1515394ac152">
        <updating/>
        <source>doSelectWagonClass() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 July 2009	cnwndl1	Initial creation

*/

vars

	wagonClass : CM_WagonClass;
	changes : String;
	msg : String;
	
begin

	wagonClass := cmbWagonClass.listObject.CM_WagonClass;

	if wagonClass &lt;&gt; null then
		if mySelectedWagonClass &lt;&gt; wagonClass and wagonClassDataDiffers( wagonClass, changes ) then
			msg := app.getErrorString(Use_wagon_class_values);
			if changes.trimBlanks &lt;&gt; null then
				msg := msg &amp; CrLf &amp; changes;
			endif;
			if app.msgBox( msg, app.getErrorString(Update_with_default_values) &amp; "?", MsgBox_Yes_No + MsgBox_Question_Mark_Icon + MsgBox_Default_Second) = MsgBox_Return_Yes then
				if wagonClass.myCarrier &lt;&gt; null then
					self.cmbCarrier.listIndex := self.cmbCarrier.findObject(wagonClass.myCarrier);
				endif;
				if wagonClass.maxCargoHeight &gt; 0 then
					self.txtMaxCHeight.text := wagonClass.maxCargoHeight.asStringMeasurementJMT();
				endif;
				if wagonClass.maxLoadWeight &gt; 0 then
					self.txtMaxCWeight.text := wagonClass.maxLoadWeight.asStringWeightJMT();
				endif;
				if wagonClass.tareWeight &gt; 0 then
					self.txtTareWeight.text := wagonClass.tareWeight.asStringWeightJMT();
				endif;
			endif;
		endif;
	endif;
	
	mySelectedWagonClass := wagonClass;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doTxtIdLostFocus" id="94c0590f-9248-43f1-9118-2fa000d52e0d">
        <updating/>
        <source>doTxtIdLostFocus() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 July 2009	cnwndl1	Initial creation

*/

vars

	uniqueId : String;
	wagonMaster : CM_WagonMaster;
	
	iter : Iterator;
	terminal : CM_Terminal;
	
	iter2 : Iterator;
	startWagon : CM_Wagon;
	wagon : CM_Wagon;
	wagons : CM_WagonByIDByDateDict;
	
begin

	if myWagonMaster &lt;&gt; null then
		//Only want to do this to new wagon masters.
		return;
	endif;
	
	uniqueId := self.txtId.text.trimBlanks;
	if uniqueId = null then
		return;
	elseif app.myRoot.allWagonMasters[uniqueId] &lt;&gt; null then
		app.msgBox(app.getErrorString(Wagon_master) &amp; " '" &amp; uniqueId &amp; "' "&amp; app.getErrorString(EDIData_AlreadyExists),app.getErrorString(EDIData_AlreadyExists),MsgBox_OK_Only);
		return;
	endif;
	
	// find the wagons.
	create wagons transient;
	iter := app.myRoot.allTerminals.createIterator;
	while iter.next( terminal ) do

		startWagon := terminal.allWagons.getAtKeyLeq(uniqueId,null);
		if startWagon = null or startWagon.id &lt;&gt; uniqueId then
			continue;
		endif;
		
		iter2 := terminal.allWagons.createIterator;
		iter2.startAtObject(startWagon);

		while iter2.next( wagon ) do
			if wagon.id &lt;&gt; uniqueId then
				break;
			endif;
			wagons.add(wagon);
		endwhile;
		delete iter2;
		
	endwhile;
	
	if wagons.isEmpty then
		// nothing to default from.
		return;
	endif;
	
	//use the latest wagon for the default values.
	wagon := wagons.first;
	if wagon = null then
		return;
	endif;
	
	if app.msgBox(app.getErrorString(Use_wagon_values), app.getErrorString(Update_with_default_values), MsgBox_Yes_No + MsgBox_Question_Mark_Icon ) &lt;&gt; MsgBox_Return_Yes then
		return;
	endif;
	
//	if self.txtTareWeight.text.Decimal = 0.0 then
	if self.txtTareWeight.text.asDecimalJMT() = 0.0 then	// 01 APR 2010	NDL	Par 23556
		self.txtTareWeight.text := wagon.getWagonTareWeight.asStringJMT();	//07 Oct 2009	NDL Par 20908
	endif;
//	if self.txtMaxCHeight.text.Decimal = 0.0 then
	if self.txtMaxCHeight.text.asDecimalJMT() = 0.0 then	// 01 APR 2010	NDL	Par 23556
		//self.txtMaxCHeight.text := wagon.maxCargoHeight.asStringJMT();
		self.txtMaxCHeight.text := wagon.getMaxCargoHeight.asStringJMT();	//Par 21924
	endif;
//	if self.txtMaxCWeight.text.Decimal = 0.0 then
	if self.txtMaxCWeight.text.asDecimalJMT() = 0.0 then	// 01 APR 2010	NDL	Par 23556
		//self.txtMaxCWeight.text := wagon.maxCargoWeight.asStringJMT();
		self.txtMaxCWeight.text := wagon.getMaxCargoWeight.asStringJMT();	//Par 21924
	endif;
	if self.cmbWagonClass.listIndex = -1 then
		self.cmbWagonClass.listIndex := self.cmbWagonClass.findObject(wagon.myWagonClass);
		mySelectedWagonClass := wagon.myWagonClass;
	endif;
	if self.cmbCarrier.listIndex = -1 then
		self.cmbCarrier.setObject(wagon.myCarrier);
	endif;

epilog

	delete wagons;
	delete iter;
	delete iter2;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="getNext" id="d4d23626-246c-42ca-88e8-84325f139cfd">
        <source>getNext():CM_WagonMaster protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 July 2009	cnwndl1	Initial creation

*/

vars
	nextWagonMaster : CM_WagonMaster;
	tiMasterForm : CMUI_TIMasterForm;
	rows : Integer;
	row : Integer;
	nextRow : Integer;
	accessRow : JadeTableRow;
begin
	if self.myParentForm &lt;&gt; null then
		if self.myParentForm.isKindOf(CMUI_TIMasterForm) then
			tiMasterForm := self.myParentForm.CMUI_TIMasterForm;
			rows := tiMasterForm.tblData.rows;
			row := tiMasterForm.tblData.row;
			if myWagonMaster = tiMasterForm.tblData.accessRow(row).itemObject.CM_WagonMaster then
				if rows &gt; row then
					nextRow := row + 1 ;
					nextWagonMaster := tiMasterForm.tblData.accessRow(nextRow).itemObject.CM_WagonMaster;
					if nextWagonMaster &lt;&gt; null then
						accessRow := tiMasterForm.tblData.accessRow(row);
						accessRow.selected := false;
						tiMasterForm.setMyCurrentTiMaster(nextWagonMaster);
						accessRow := tiMasterForm.tblData.accessRow(nextRow);
						accessRow.selected := true;
						tiMasterForm.tblData.row := nextRow;
					endif;
				endif;
			endif;
		endif;
	endif;

	return nextWagonMaster;
	
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="CM_WagonMaster"/>
    </JadeMethod>
    <JadeMethod name="loadData" id="9416e42c-ed0f-4181-8456-acbba2ac4a4a">
        <updating/>
        <source>loadData() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06/07/2009	cnwndl1	Initial creation
12/03/2013	cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements
06/03/2014	cnwdap1	PAR #33638 Correct measurement field handling
17/07/2024	jlier1  TFS 65100 - handle invalid carrier
23/05/2025  navma1	MTN-34803 1090 exception when selecting the Wagon restrictions form the Rail Operations form
*/
vars
	weightType, 
	heightType 		: CM_MeasurementType;		// PAR #31155
	carrier 		: CM_Carrier;
	invalidCarrier  : Boolean;
	wagonMaster		: CM_WagonMaster;
begin

	wagonMaster := self.myWagonMaster;
	
	if wagonMaster = null then
		self.txtId.text 			 := null;
		self.txtId.enabled 			 := true;
		self.cmbWagonClass.listIndex := -1;
		self.cmbCarrier.listIndex 	 := -1;
		self.txtMaxCHeight.text 	 := null;
		self.txtMaxCWeight.text 	 := null;
		self.txtTareWeight.text 	 := null;
		self.mySelectedWagonClass 	 := null;
		self.btnDamage.enabled 		 := false;	//07 Oct 2009	NDL Par 20783
		self.btnRestrict.enabled 	 := false;	//07 Feb 2014	NDL	Par 33439
	
	else

		self.txtId.text		 		 := wagonMaster.id;
		self.txtId.enabled   		 := false;
		self.cmbWagonClass.listIndex := self.cmbWagonClass.findObject(wagonMaster.myWagonClass);
		mySelectedWagonClass 		 := wagonMaster.myWagonClass;
		
		on Exception do app.handleDeletedObject(exception,carrier,invalidCarrier);
		carrier	:=	wagonMaster.myCarrier;
		
		if carrier &lt;&gt; null then		//23.05.2025 navma1 #MTN-34803
			carrier.edition;
		endif;
		
		if invalidCarrier then
			carrier := null;
		endif;
		if carrier &lt;&gt; null then
			self.cmbCarrier.listIndex := self.cmbCarrier.findObject(carrier);
			// 25096 if existing carrier is road-only, refresh the combo with rail and road then find the carrier again
			if self.cmbCarrier.listIndex = -1 and 
				carrier &lt;&gt; null and //cnwrd1 par 28394 10.10.2011
			   carrier.isForRoad and
			   self.cmbCarrier.transportMode &lt;&gt; 0 then
				self.cmbCarrier.setTransportMode(0);
				self.cmbCarrier.initialise(true);
				self.cmbCarrier.listIndex := self.cmbCarrier.findObject(carrier);
			endif;
		endif;

		weightType := app.getDefaultMeasurementForType(Type_Weight);																// PAR #31155
		heightType := app.getDefaultMeasurementForType(Type_Height);																// PAR #31155
		self.txtMaxCHeight.setValues(app.convertMeasurementForDisplay(heightType.shortName, wagonMaster.getMaxCargoHeight) &amp; Space &amp; heightType.shortName);	// PAR #33638
		self.txtMaxCWeight.setValues(app.convertMeasurementForDisplay(weightType.shortName, wagonMaster.getMaxCargoWeight) &amp; Space &amp; weightType.shortName);	// PAR #33638
		self.txtTareWeight.setValues(app.convertMeasurementForDisplay(weightType.shortName, wagonMaster.getTareWeight)     &amp; Space &amp; weightType.shortName);	// PAR #33638
		
		self.btnDamage.enabled   := true;	//07 Oct 2009	NDL Par 20783
		self.btnRestrict.enabled := true;	//07 Feb 2014	NDL	Par 33439
		
		//07 Feb 2014	NDL	Par 33439
		if self.btnSave.enabled = false then
			self.btnCancel.caption := "&amp;" &amp; app.getErrorString(Close);
		endif;
		
	endif;
	
	//23 Feb 2010 NDL Par 21924
	lblWagClassNote.visible   := true;
	lblWagClassNote.foreColor := Red;
	lblTareWeight.foreColor   := Grey;
	lblMaxCHeight.foreColor   := Grey;
	lblMaxCWeight.foreColor   := Grey;
	txtMaxCHeight.enabled     := false;
	txtMaxCWeight.enabled     := false;
	txtTareWeight.enabled     := false;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setAttributes" id="163a9ae5-7398-4ec3-9502-51be3d79a953">
        <updating/>
        <source>setAttributes( _wagonMaster : CM_WagonMaster io) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 July 2009	cnwndl1	Initial creation

*/

vars

begin

	self.myWagonMaster := _wagonMaster;
	
epilog

end;</source>
        <Parameter name="_wagonMaster" type="CM_WagonMaster" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="c695c472-d13d-4c41-98e3-f408fab6a720">
        <updating/>
        <source>setupForm() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06/06/009	cnwndl1	Initial creation
12/03/2013	cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements
06/03/2014	cnwdap1	PAR #33638 Correct measurement type field handling
*/
vars

begin
	inheritMethod();
	
	self.handleMenusForModalDisplay;
	
	self.toolbarStyle := self.ToolbarStyle_None;
	self.showToolbar := false;
	self.hasChanged := false;
	self.height := minimumHeight;
	self.width := 468;

	self.centreWindow();
	self.setCaption( app.getErrorString(Wagon_master) );
	
//	setButtons();
	
	self.myAssistant.comboBoxWagonClass(cmbWagonClass, null );
	self.cmbWagonClass.addItemAt(  app.getErrorString(NewWagonClass), 1 );	// 06 Apr 2010	NDL Par 22342
	// 25096 show rail carriers only
	self.cmbCarrier.setTransportMode(BR_TYPE_RAIL);
	self.cmbCarrier.initialise(true);
	
	// PAR #31155 set measurement captions to include measurement short name
	//self.lblHeightUnit.caption := app.getDefaultMeasurementForType(Type_Height).shortName;			// PAR #33638
	//self.lblWeightUnit.caption := app.getDefaultMeasurementForType(Type_Weight).shortName;			// PAR #33638
	//self.lblWeightUnit_2.caption := app.getDefaultMeasurementForType(Type_Weight).shortName;			// PAR #33638
	
	//07 Feb 2014	NDL	Par 33439
	//self.txtMaxCHeight.decimals := app.getDefaultMeasurementForType(Type_Height).getDecimalPrecision;	// PAR #33638
	//self.txtMaxCWeight.decimals := app.getDefaultMeasurementForType(Type_Weight).getDecimalPrecision;	// PAR #33638
	//self.txtTareWeight.decimals := app.getDefaultMeasurementForType(Type_Weight).getDecimalPrecision;	// PAR #33638
	
	self.txtMaxCHeight.setup(Type_Height, self.backColor);												// PAR #33638
	self.txtMaxCHeight.tabKey := J_key_Tab;																// PAR #33638
	self.txtMaxCWeight.setup(Type_Weight, self.backColor);												// PAR #33638
	self.txtMaxCWeight.tabKey := J_key_Tab;																// PAR #33638
	self.txtTareWeight.setup(Type_Weight, self.backColor);												// PAR #33638
	self.txtTareWeight.tabKey := J_key_Tab;																// PAR #33638
	
	self.beginClassNotification(CM_WagonMaster, false, Any_System_Event, Response_Continuous, null); //cnwrd1 par #18127 23.1.09
	
	self.loadData();
	
	self.btnDamage.visible := false;  // ### TFS 55313 08NOV2022 NAVAB1 - Recorded damage is not used anywhere

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="24a08663-201e-4623-b998-9b2b01f52fbb">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 06 March 2014.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0017519, locale);
	btnCancel.translateCaption(Xlat_0012229, locale);
	btnDamage.translateCaption(Xlat_0012230, locale);
	btnNext.translateCaption(Xlat_0012231, locale);
	btnRestrict.translateCaption(Xlat_0019428, locale);
	btnSave.translateCaption(Xlat_0012232, locale);
	btnWagonClass.translateCaption(Xlat_0012233, locale);
	lblCarrier.translateCaption(Xlat_0012234, locale);
	lblId.translateCaption(Xlat_0012236, locale);
	lblMaxCHeight.translateCaption(Xlat_0012237, locale);
	lblMaxCWeight.translateCaption(Xlat_0012238, locale);
	lblTareWeight.translateCaption(Xlat_0012239, locale);
	lblWagClassNote.translateCaption(Xlat_0014285, locale);
	lblWagonClass.translateCaption(Xlat_0012240, locale);
end;</source>
    </JadeMethod>
