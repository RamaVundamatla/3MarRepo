    <JadeMethod name="doFormInitialize" id="f75c5774-a89b-4c24-ba48-67951e4f007b">
        <source>doFormInitialize() protected;
// --------------------------------------------------------------------------------
// Created:		30 October 2002 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 12/03/2003	cnwdad1		Changed to default the top/bottom schemas to the current schema.
//
// 14/04/2004	cnwdad1		Commented out the default value of the "temp" directory
//							because it caused a 1008 exception if the karma.dll library
//							did not exist in the thin bin directory.
//
// 19/04/2004	cnwdad1		Reinstated the default value of the "temp" directory
//							method which now uses a new native method instead of
//							relying on the karma.dll library.
// --------------------------------------------------------------------------------
begin
	lblDateSample.cnEcSet(null);
	
	chkIsClassFile.value	:=	false;
	lblInputFile.enabled	:=	false;
	txtInputFile.enabled	:=	false;
	btnBrowseInput.enabled	:=	false;
	
	chkIsHeaderPage.value	:=	false;
	txtGroupName.enabled	:=	false;
	txtDocTitle.enabled		:=	false;
	txtDocVersion.enabled	:=	false;
	txtDocDate.enabled		:=	false;
	chkIsHeaderLogo.enabled	:=	false;
	lblLogo.enabled			:=	false;
	txtLogo.enabled			:=	false;
	btnBrowseLogo.enabled	:=	false;
	
	chkIsPrefacePage.value	:=	false;
	txtOverview.enabled		:=	false;
	btnSpellCheck.enabled	:=	false;
	
	cmbTopSchema.listIndex		:=	cmbTopSchema.findObject(currentSchema);
	cmbBottomSchema.listIndex	:=	cmbBottomSchema.findObject(currentSchema);
	txtDirectoryName.text		:=	global.cnEcGetTempDirectory();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormLoad" id="0f89dc34-82dc-46c0-922b-44f420cc6198">
        <updating/>
        <source>doFormLoad() updating, protected;
// --------------------------------------------------------------------------------
// Created:		05 July 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	allSchemasObj	: SchemaColl;
	
begin
	inheritMethod();
	centreWindow();
	
	create allSchemasObj transient;
	rootSchema.allSubschemas(allSchemasObj);
	cmbTopSchema.listCollection(allSchemasObj, false, Collection.CNEC_DISPLAY_ORDER_COLLECTION);
	cmbBottomSchema.listCollection(allSchemasObj, false, Collection.CNEC_DISPLAY_ORDER_COLLECTION);
	
	self.doFormInitialize();
epilog
	delete allSchemasObj;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormUpdate" id="5f360be3-e8aa-4e73-b4ff-84480a45b110">
        <updating/>
        <source>doFormUpdate(): Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		05 July 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	progressFormObj			: CnEcDocumentModelProgressForm;
	parameterObj			: CnEcDocParameter;
	xmlClassDocObj			: CnEcXmlStructureInstance;
	jadeLogo				: Binary;
	topSchemaObj			: Schema;
	bottomSchemaObj			: Schema;
	directoryPath			: String;
	isIncludeClassText		: Boolean;
	isIncludeSource			: Boolean;
	isIncludeJadeClasses	: Boolean;
	isClassInputFile		: Boolean;
	isIgnoreCollections		: Boolean;
	classInputFileName		: String;
	isGenerateHeader		: Boolean;
	groupName				: String;
	docTitle				: String;
	docVersion				: String;
	docDate					: Date;
	isProductLogo			: Boolean;
	productLogoPath			: String;
	productLogo				: Binary;
	isGeneratePreface		: Boolean;
	productOverview			: String;

begin
	on Exception do self.xHandler(exception);
	
	if self.doFormValidate() then
		create parameterObj transient;
		
		jadeLogo				:=	picJadeLogo.picture;
		topSchemaObj			:=	cmbTopSchema.listObject.Schema;
		bottomSchemaObj			:=	cmbBottomSchema.listObject.Schema;
		directoryPath			:=	txtDirectoryName.cnEcString();
		isIncludeClassText		:=	chkIsClassText.value;
		isIncludeSource			:=	chkIsSource.value;
		isIncludeJadeClasses	:=	chkIsRootSchema.value;
		isClassInputFile		:=	chkIsClassFile.value;
		isIgnoreCollections		:=	chkIsNoColls.value;
		classInputFileName		:=	txtInputFile.cnEcString();
		isGenerateHeader		:=	chkIsHeaderPage.value;
		groupName				:=	txtGroupName.cnEcString();
		docTitle				:=	txtDocTitle.cnEcString();
		docVersion				:=	txtDocVersion.cnEcString();
		docDate					:=	txtDocDate.cnEcDate();
		isProductLogo			:=	chkIsHeaderLogo.value;
		productLogoPath			:=	txtLogo.cnEcString();
		isGeneratePreface		:=	chkIsPrefacePage.value;
		productOverview			:=	txtOverview.cnEcString();
		
		if isProductLogo and productLogoPath &lt;&gt; null then
			productLogo				:=	global.cnEcReadBinaryFile(productLogoPath);
		endif;
		
		if isClassInputFile then
			create xmlClassDocObj as CnEcXmlGroupInstance transient;
			self.parseXmlDocument(classInputFileName, xmlClassDocObj);
		endif;
		
		parameterObj.jadeLogo				:=	jadeLogo;
		parameterObj.jadeLogoName			:=	CNEC_CLASS_DOC_JADE_LOGO_NAME;
		parameterObj.mySchemaTop			:=	topSchemaObj;
		parameterObj.mySchemaBottom			:=	bottomSchemaObj;
		parameterObj.baseDirectory			:=	directoryPath;
		parameterObj.isIncludeClassText		:=	isIncludeClassText;
		parameterObj.isIncludeSource		:=	isIncludeSource;
		parameterObj.isIncludeJadeClasses	:=	isIncludeJadeClasses;
		parameterObj.isClassInputFile		:=	isClassInputFile;
		parameterObj.isIgnoreCollections	:=	isIgnoreCollections;
		parameterObj.isGenerateHeader		:=	isGenerateHeader;
		parameterObj.groupName				:=	groupName;
		parameterObj.docTitle				:=	docTitle;
		parameterObj.docVersion				:=	docVersion;
		parameterObj.docDate				:=	docDate;
		parameterObj.isProductLogo			:=	isProductLogo;
		parameterObj.isGeneratePreface		:=	isGeneratePreface;
		parameterObj.productOverview		:=	productOverview;
		
		if isClassInputFile then
			// This option defaults to true, so reset it.
			parameterObj.isDoAllWhenNoList	:=	false;
		endif;
		
		if isProductLogo then
			parameterObj.productLogo		:=	productLogo;
			parameterObj.productLogoName	:=	self.getFileName(productLogoPath);
		endif;
		
		if isClassInputFile then
			parameterObj.myXmlClassDoc	:=	xmlClassDocObj.CnEcXmlGroupInstance;
		endif;
		
		create progressFormObj transient;
		progressFormObj.show();
		progressFormObj.refreshNow();
		self.visible	:=	false;
		self.refreshNow();
		
		global.cnEcDocumentModel(parameterObj);
	
		return inheritMethod();
	else
		return false;
	endif;
epilog
	delete parameterObj;
	delete xmlClassDocObj;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doFormValidate" id="277a4f25-2534-4904-8044-ce9b44dbb843">
        <source>doFormValidate(): Boolean protected;
// --------------------------------------------------------------------------------
// Created:		05 July 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	topSchemaObj			: Schema;
	bottomSchemaObj			: Schema;
	directoryPath			: String;
	isIncludeSource			: Boolean;
	isIncludeJadeClasses	: Boolean;

begin
	topSchemaObj			:=	cmbTopSchema.listObject.Schema;
	bottomSchemaObj			:=	cmbBottomSchema.listObject.Schema;
	directoryPath			:=	txtDirectoryName.cnEcString();
	isIncludeSource			:=	chkIsSource.value;
	isIncludeJadeClasses	:=	chkIsRootSchema.value;
	
	if topSchemaObj = null then
		app.msgBox(	"Please select the top schema.",
					"Error",
					MsgBox_Stop_Icon + MsgBox_OK_Only);
						
		return false;
	endif;

	if bottomSchemaObj = null then
		app.msgBox(	"Please select the bottom schema.",
					"Error",
					MsgBox_Stop_Icon + MsgBox_OK_Only);
						
		return false;
	endif;
	
	if topSchemaObj &lt;&gt; bottomSchemaObj then
		if topSchemaObj.getSubschema(bottomSchemaObj.name) = null then
			app.msgBox(	"The bottom schema must be the same as, or a subschema of, the top schema.",
						"Error",
						MsgBox_Stop_Icon + MsgBox_OK_Only);
						
			return false;
		endif;
	endif;
	
	if directoryPath = null then
		app.msgBox(	"Please enter (or browse for) the starting file directory name.",
					"Error",
					MsgBox_Stop_Icon + MsgBox_OK_Only);
		
		return false;
	endif;

	return inheritMethod();
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getFileName" id="e8ae3c52-8654-41da-a5d0-ddf2498733f0">
        <source>getFileName(pPathName:String):String protected;
// --------------------------------------------------------------------------------
// Created:		30 October 2002 by cnwdad1
//
// Purpose:		Extract the name of a file from a path name.
//
// Parameters:	pPathName - The full path name of the file.
//
// Returns:		The name of the file.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	position	: Integer;
	fileName	: String;
	
begin
	if pPathName = null then
		return null;
	else
		position	:=	pPathName.reversePos(global.cnEcGetFileSeparator());
		
		if position &gt; 0 then
			fileName	:=	pPathName[(position + 1):end];
			return fileName;
		else
			return null;
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pPathName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="parseXmlDocument" id="88c21d3d-f300-4ae5-af3f-1cf0379d87d4">
        <source>parseXmlDocument(pFileName:String; pXmlDocument:CnEcXmlStructureInstance io) protected;
// --------------------------------------------------------------------------------
// Created:		30 October 2002 by cnwdad1
//
// Purpose:		Read an XML document from the specified file name, then parse the
//				XML into a CnEcXmlStructureInstance tree.
//
// Parameters:	pFileName - The file containing the XML document.
//				pXmlDocument - The XML structure instance tree.
//
// Returns:		The XML structure instance tree as an output parameter.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 27/01/2003	cnwdad1		Added the openInput statement so that read-only files
//							will not cause an exception.
// --------------------------------------------------------------------------------
vars
	parserObj	: CnEcXmlParser;
	xmlMessage	: String;
	fileObj		: File;
	
begin
	create fileObj transient;
	fileObj.kind 		:=  File.Kind_Unknown_Text; // 26/2/16  cnwns1 PAR 36286 unicode version
	fileObj.fileName	:=	pFileName;
	fileObj.openInput(pFileName);
	xmlMessage			:=	fileObj.readString(fileObj.fileLength());
	fileObj.close();
	
	create parserObj transient;
	parserObj.parseToMsgStructure(xmlMessage, pXmlDocument);
epilog
	delete parserObj;
	delete fileObj;
end;</source>
        <access>protected</access>
        <Parameter name="pFileName" type="String"/>
        <Parameter name="pXmlDocument" type="CnEcXmlStructureInstance" usage="io"/>
    </JadeMethod>
    <JadeMethod name="xHandler" id="7bf428ec-c169-4621-a3af-1f7e0912eb6d">
        <updating/>
        <source>xHandler(pExceptionObj:Exception):Integer updating, protected;
// --------------------------------------------------------------------------------
// Created:		12 March 2003 by cnwdad1
//
// Purpose:		Handler to delete the Progress form and unload this form if a
//				BaseSchema exception occurs, and then pass back the handling to
//				the next handler in the stack.
//
// Parameters:	pExceptionObj - A reference to the exception object.
//
// Returns:		Ex_Pass_Back.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	progressFormObj		: Form;
	isBaseException		: Boolean;
	
begin
	isBaseException	:=	pExceptionObj.cnEcIsBaseException();
	
	if isBaseException then
		progressFormObj	:=	app.getForm(CnEcDocumentModelProgressForm.name);
		
		if progressFormObj &lt;&gt; null then
			progressFormObj.unloadForm();
			delete progressFormObj;
		endif;
	endif;
	
	return Ex_Pass_Back;
epilog
	self.visible	:=	true;
end;</source>
        <access>protected</access>
        <Parameter name="pExceptionObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</GUIClass>
