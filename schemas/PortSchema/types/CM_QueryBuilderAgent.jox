    <JadeMethod name="addCriteria" id="9b36f5dc-cf15-4163-bd9a-22a59ab2b3ef">
        <updating/>
        <source>addCriteria(_property : String; _operator : String; _value : Any)updating;
//28 August 2009	cnwml2


vars
	criteriaLine: CM_SelectorCriteriaLine;
	property, clonedProperty : CM_QueryProperty;
	operator, clonedOperator : CM_QueryOperator;
	queryValue : Any;
begin
	if self.query = null then
		create self.query transient;
	endif;
	
	create criteriaLine transient;
	
	property := queryDef.allQueryProperties[_property];
	clonedProperty := property.cloneSelf(true);
	operator := property.allAllowedOperators[_operator];
	clonedOperator := operator.cloneSelf(true);
	queryValue := property.translateToSearchValue(_value);
	clonedOperator.setSearchValue(queryValue);
	criteriaLine.set(clonedProperty, clonedOperator, false);
	
	criteriaLine.setMyCriteriaLineHolder(query);
epilog
	
end;	</source>
        <Parameter name="_property" type="String"/>
        <Parameter name="_operator" type="String"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="delete" id="c9cd80bc-8725-409f-9fbb-fb5ceef115a0">
        <updating/>
        <source>delete() updating;
//28 August 2009	cnwml2


vars

begin
	delete query;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doQuery" id="f4c62539-299a-4791-97af-fe90a0d63003">
        <updating/>
        <source>doQuery()updating;
//28 August 2009	cnwml2


vars
	queryRunner: CM_EnquiryController;
begin
	if self.queryDef.isKindOf(CM_QDefCargoTransaction) then
		create queryRunner as CM_EnqControllerCargoTrans transient;
	else
		create queryRunner as CM_EnqControllerTI  transient;
	endif;
	if self.allObjects &lt;&gt; null then
		queryRunner.allObjects := self.allObjects;

		queryRunner.myCriteriaLineHolder := query;
		queryRunner.doQuery(queryDef);
		queryRunner.allObjects := null;
	endif;
	
epilog
	delete queryRunner;
end;</source>
    </JadeMethod>
    <JadeMethod name="getWLETrackedItem" id="5860bd49-da79-49cb-8b0a-3be81c6c8e7c">
        <updating/>
        <source>getWLETrackedItem(_wle : CM_WorkListEntry; _termArea : CM_TerminalArea) : CM_TrackedItem updating;
// 10/02/2010	cnwjre1	CCMS 1101
// this method is here temporarily until a better home is found
vars
	tis : CM_TISet;
	lc		: CM_LocationsController;
	allOverstowedTIs 	: CM_TIArray;
	request	: CM_DeliveryRequest;
	saveTi,
	ti : CM_TrackedItem;
	found	: Boolean;
	thisOverstow,
	lastOverstow : Integer;
	grade,
	sideAccessDirection	: Integer;
begin
	if _wle = null or
	   _termArea = null then
		return null;
	endif;
	if not _wle.myRequest.isKindOf(CM_DeliveryRequest) then
		return null;
	endif;
	request := _wle.myRequest.CM_DeliveryRequest;
	
	create tis transient;
	create allOverstowedTIs transient;
	lastOverstow := 99999;
	
	// read and filter tracked items for this terminal area
	foreach lc in _termArea.allLocationsControllers do
		foreach ti in lc.allTrackedItems do
			if request.operatorCode &lt;&gt; null then
				if ti.operatorCode &lt;&gt; null and 
				   ti.operatorCode &lt;&gt; request.operatorCode then
					continue;
				endif;
			endif;

			if request.myCargoType &lt;&gt; null then
				if ti.cargoType &lt;&gt; request.myCargoType.id then
					continue;
				endif;
				if request.myCargoType.id = TI_CargoType_Container then
					if request.isoGroup &lt;&gt; null then
					
						//cnwrd1 par 30414 25.9.2012
						if not request.testISOGroup(ti.isoTypeGroup , null) then
							continue;
						endif;
						/*
						if ti.isoTypeGroup &lt;&gt; request.isoGroup then
							continue;
						endif;
						*/
					endif;
					if request.isoType &lt;&gt; null then
						if ti.getISOType() &lt;&gt; request.isoType then
							continue;
						endif;
					endif;
				endif;
			endif;
			if request.mySubTerminalSource &lt;&gt; null then
				if ti.mySubTerminal &lt;&gt; null and
				   ti.mySubTerminal &lt;&gt; request.mySubTerminalSource then
					continue;
				endif;
			endif;
			if 	request.ids &lt;&gt; null then
				if not request.ids.compareIDStrings(ti.id) then
					continue;
				endif;
			endif;

			if ti.isKindOf(CM_Container) then
				if ti.CM_Container.isClean &lt;&gt; request.clean then
					continue;
				endif;
				if ti.CM_Container.isHeavyDuty &lt;&gt; request.heavyRated then
					continue;
				endif;
				if request.allAvailabilityGrades.size &gt; 0 then
					if not request.allAvailabilityGrades.includes(ti.CM_Container.availabilityGrade) then
						continue;
					endif;
				endif;
			endif;

			// following not actually set on an empty ///
			if request.voyageCode &lt;&gt; null then
				if ti.voyageCode &lt;&gt; null and
				   ti.voyageCode &lt;&gt; request.voyageCode then
					continue;
				endif;
			endif;
			if request.billOfLading &lt;&gt; null then
				if ti.billOfLading &lt;&gt; null and
				   ti.billOfLading &lt;&gt; request.billOfLading then
					continue;
				endif;
			endif;
			if request.consignee &lt;&gt; null then
				if ti.consignee &lt;&gt; null and
				   ti.consignee &lt;&gt; request.consignee then
					continue;
				endif;
			endif;
			if request.commodity &lt;&gt; null then
				if ti.commodity &lt;&gt; null and
				   ti.commodity &lt;&gt; request.commodity then
					continue;
				endif;
			endif;
	
			if not tis.includes(ti) then
				tis.add(ti);
				allOverstowedTIs.clear;
				sideAccessDirection:=null;
				ti.getAllOverstowedTIs(allOverstowedTIs,true,sideAccessDirection,null);
				thisOverstow := allOverstowedTIs.size;
				if thisOverstow = 0 then
					saveTi := ti;
					found := true;
					break;
				elseif thisOverstow &lt; lastOverstow then
					saveTi := ti;
					lastOverstow := thisOverstow;
				endif;
			endif;
		endforeach;
		if found then
			break;
		endif;
	endforeach;
	
	return saveTi;
epilog
	delete allOverstowedTIs;
	delete tis;
end;
</source>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_termArea" type="CM_TerminalArea"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setQueryMode" id="68f21d0d-974e-45fe-ad39-e831e1ab4f82">
        <updating/>
        <source>setQueryMode(_cargoType: CM_CargoType) updating;
//28 August 2009	cnwml2


vars

begin
	if _cargoType &lt;&gt; null then
		if _cargoType.isSystemCargoBOLType then		//if system defined
			//queryDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.BOL_Query_Type, _cargoType.id];					//-cnwml2 PAR22188
			queryDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type, _cargoType.id];				//+cnwml2 PAR22188
		else										//if user defined
			//figure out what the id should be
			if _cargoType.productType = ProductType_Trailer then
				queryDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type, 10];
			elseif _cargoType.productType = ProductType_Vehicle then
				queryDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type, 7];				
			elseif _cargoType.isBreakBulk() then
				queryDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type, 3];
			else
				queryDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type, null];
			endif;
		endif;

	else
		queryDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type, null];
	endif;

epilog

end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="setQueryTypeAndMode" id="5a39f014-8032-4b89-bafc-d546d562c902">
        <updating/>
        <source>setQueryTypeAndMode(_type : Integer; _mode : Integer) updating;
// for transaction selector queries
vars

begin
	if _type = CM_QueryDefinition.Transaction_Query_Type then
		self.queryDef := app.myRoot.allQueryDefinitionObjects[_type, _mode];
	endif;
end;
</source>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setResultArray" id="7c6b3ea9-114d-45b7-a677-23bbdcc2706f">
        <updating/>
        <source>setResultArray(_collection : Collection)updating;
//28 August 2009	cnwml2


vars

begin
	self.allObjects := _collection;
epilog

end;</source>
        <Parameter name="_collection" type="Collection"/>
    </JadeMethod>
</Class>
