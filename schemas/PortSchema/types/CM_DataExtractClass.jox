    <JadeMethod name="setCommon" id="e5a6d049-7466-4b0a-910a-887cb5df763c">
        <updating/>
        <source>setCommon(_proxyDataExtractClass : CM_DataExtractClass) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 April 2011	#cnwdz2	 

*/

vars

begin
	_proxyDataExtractClass.raiseExceptionIfNotTransient(method);
	
	self.className := _proxyDataExtractClass.className;
	self.classNumber := self.getObjectClass().number;
	self.description := _proxyDataExtractClass.description;
	self.extractOrder.clear();
	_proxyDataExtractClass.extractOrder.copy(self.extractOrder);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_proxyDataExtractClass" type="CM_DataExtractClass"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="328c8c58-c2a6-4b0b-9042-bbc3b46d7c7a">
        <updating/>
        <source>setForCreate(_proxyDataExtractClass : CM_DataExtractClass) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 April 2011	#cnwdz2	 

*/

vars
	proxyField : CM_DataExtractField;
	newField   : CM_DataExtractField;
begin
	self.setCommon(_proxyDataExtractClass);
	
	foreach proxyField in _proxyDataExtractClass.allDataExtractFields do
		newField := proxyField.createPersistentField();
		newField.setDataExtractClass(self);
	endforeach;
	//self.myRoot := app.myRoot;
	self.myExtractRoot := CM_DataExtractRoot.firstInstance;
epilog

end;</source>
        <Parameter name="_proxyDataExtractClass" type="CM_DataExtractClass"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="2857954e-4ce7-4966-8949-5db8eaf07d60">
        <updating/>
        <source>setForUpdate(_proxyDataExtractClass : CM_DataExtractClass) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 April 2011	#cnwdz2	 

*/

vars
	newField,
	proxyField,
	realField : CM_DataExtractField;
	toDelete : CM_DataExtractFieldSet;
	expectedEdition : Integer;  
begin

	self.setCommon(_proxyDataExtractClass);
	
	create toDelete transient;
	exclusiveLock(self.allDataExtractFields);
	self.allDataExtractFields.copy(toDelete);
	
	// 1. Create new features, update existing ones
	foreach proxyField in _proxyDataExtractClass.allDataExtractFields do
		proxyField.pxyGetRealObjectAndEdition(realField, expectedEdition);
		if realField = null then
			newField := proxyField.createPersistentField();
			newField.setDataExtractClass(self);
		else
			toDelete.removeIfPresent(realField);
			exclusiveLock(realField);
			if realField.edition &lt;&gt; expectedEdition then
				app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'dataExtractField', null, null);
				return;
			endif;
			realField.setForUpdate(proxyField);
		endif;

	endforeach;
	
	// 2. Delete missing features
	foreach realField in toDelete do
		delete realField;
	endforeach;
	
epilog
	delete toDelete;
end;</source>
        <Parameter name="_proxyDataExtractClass" type="CM_DataExtractClass"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="3a113432-c7a1-4b18-9be8-8c39bb9b80d9">
