    <JadeMethod name="cnEcGetDuplicate" id="136f54f2-ab8a-4222-bdbc-55974daa8534">
        <source>cnEcGetDuplicate(pFormat: CnEcXmlFormat; pInput: CnEcXmlStructureInstance): Object;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 September 2014	cnwndl1	Initial creation	Par 34893

*/

vars

	address : String;
	email : CM_EmailEntity;

begin

	address := self.cnEcXMLGetTheAttributeValue( pFormat, pInput, self.class.name, "emailAddress" ).String; 
	
	if address &lt;&gt; null then
		email := app.myRoot.allEmailAddressesByAddress.getAtKey( address );
	endif;

epilog

	return email;

end;</source>
        <Parameter name="pFormat" type="CnEcXmlFormat"/>
        <Parameter name="pInput" type="CnEcXmlStructureInstance"/>
        <ReturnType type="Object"/>
    </JadeMethod>
