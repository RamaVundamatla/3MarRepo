<Class name="CM_QIntegerLookupMethod" id="9bb2425f-37cf-4839-ba5e-f12958a808fe">
    <superclass name="CM_QueryMethod"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="create" id="9ccb0719-7859-4640-beaa-5d3333146a60">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:	21 May 2008 By Graeme Black cnwgb1 PAR 16415
// ---------------------------------------------------------------------------
vars
	oper : CM_QueryOperator;

begin
	if self.isTransient then 
		return;
	endif;
		
	create oper as CM_QIntegerLookupEqual persistent;
	self.allAllowedOperators.add(oper);
	
	create oper as CM_QIntegerLookupNotEqual persistent;
	self.allAllowedOperators.add(oper);
	
	create oper as CM_QIntegerIsOneOf persistent;
	self.allAllowedOperators.add(oper);
end;</source>
    </JadeMethod>
    <JadeMethod name="getControlTypeForOperator" id="3533d1b9-5a74-4d87-8358-872b8aa5eb8d">
        <source>getControlTypeForOperator(_op: CM_QueryOperator): Integer;
// ---------------------------------------------------------------------------
// Created:	21 May 2008 By Graeme Black cnwgb1 PAR 16415
// ---------------------------------------------------------------------------
begin
	if _op.isKindOf(CM_QIntegerLookupEqual) or _op.isKindOf(CM_QIntegerLookupNotEqual) then
		return QueryControl_ComboBox;
	elseif _op.isKindOf(CM_QIntegerIsOneOf) then
		return QueryControl_MultiSelect;
	endif;

	return inheritMethod(_op);

end;</source>
        <Parameter name="_op" type="CM_QueryOperator"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getKeyLengthForXTABDictionary" id="8c742bad-fb18-43ad-ab0b-16379edabb76">
        <source>getKeyLengthForXTABDictionary(): Integer;
// ---------------------------------------------------------------------------
// Created:     04 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	return (Max_Integer * -1).String.length;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getQueryOperatorForYADataConv" id="62eb5a6c-75b7-4bc4-b534-ec6da5f170b6">
        <source>getQueryOperatorForYADataConv(): Class;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 June 2015	cnwndl1	Initial creation

*/

vars

begin
	return CM_QIntegerIsOneOf;

epilog

end;</source>
        <ReturnType type="Class"/>
    </JadeMethod>
</Class>
