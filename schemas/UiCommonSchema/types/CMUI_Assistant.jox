    <JadeMethod name="doFullyPlan" id="c457d05b-08db-4efe-84e5-5a8264c95329">
        <updating/>
        <source>doFullyPlan(_allJobs : CM_JobArray; _myCurrentVoyage : CM_Voyage; _cmifMonitor : CMIF_Monitor; _shipController : CMIF_ShipPlanningController io) updating;
// --------------------------------------------------------------------------------
// Created:		23 November 2010 by cnwjo3
//
// Purpose:		this method is effectively a copy of CMUI_ShipFullyPlanForm::doQueury
//
// 17/03/2015	cnwmh5	Transient Leaks
vars
	allJobs : CM_JobArray;
	currentJS : CM_VoyageJobSheet;
	
	tmpOptionsUsed : IntegerArray;
	noPlanIfStops : Boolean;
	rowEnd	: Boolean;
	rows : Integer;
	useWeights : Boolean;
	weight : Integer;
	pc : Integer;
	ignoreWarnings : Boolean;
	twinPlan : Boolean;
	crossTermOne : Boolean;
	crossTermCol : Boolean;	
	
	myCurrentVoyage : CM_Voyage;
	tmpHeight : Integer;
begin
	create allJobs transient;
	
	myCurrentVoyage := _myCurrentVoyage;
	
	_allJobs.copy(allJobs);
	
	allJobs.removeInvalidObjects();
	
	if allJobs.isEmpty then
		app.raiseCMException(ERR_JOBS_EMPTY,null,null);
		return;
	endif;	

	currentJS := allJobs.first().myJobSheet.CM_VoyageJobSheet;
	
	create tmpOptionsUsed transient;  //just using original defaults
	tmpOptionsUsed.add(2);
	tmpOptionsUsed.add(1);
	tmpOptionsUsed.add(3);
	tmpOptionsUsed.add(4);

	//using defaults
	noPlanIfStops := false;
	rowEnd := false;
	rows := 0;
	useWeights := false;
	weight := 2001;
	pc := 0;
	crossTermOne := false;
	crossTermCol := false;
	ignoreWarnings := false;
	twinPlan := false;
	
	_shipController.init(self.myTerminal, 3, allJobs, currentJS, myCurrentVoyage, noPlanIfStops, tmpOptionsUsed, tmpHeight, 
								rowEnd, rows, null,  useWeights, weight, pc, crossTermOne, crossTermCol, ignoreWarnings,twinPlan);
	
	_shipController.useLCOut := true;
	
	_shipController.initQuery();  //why do i need it here?
	
	_shipController.doQuery(_cmifMonitor);
	
epilog
	delete allJobs;
	delete tmpOptionsUsed; //epr delete transients
end;</source>
        <Parameter name="_allJobs" type="CM_JobArray"/>
        <Parameter name="_myCurrentVoyage" type="CM_Voyage"/>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor"/>
        <Parameter name="_shipController" type="CMIF_ShipPlanningController" usage="io"/>
    </JadeMethod>
