    <JadeMethod name="selectTableRowForVehicle" id="31d8d828-810d-461a-bc34-2b262e9a60ec">
        <source>selectTableRowForVehicle(_vehicle: CM_Vehicle input) : Boolean;
/*
Date		Who		Reason
21 August 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	wleArray 	: CM_WLEArray;
	wle		  	: CM_WorkListEntry;
	row 		: Integer;
	isFirst		: Boolean; //cnwmc5 - par 29716
	table		: CM_DataTable;
begin
	if not inheritMethod(_vehicle) then
		return false;
	endif;
	
	self.myDataTable.clearAllSelected;
	
	create wleArray transient;
	
	_vehicle.getAllWLEs(wleArray);
	
	isFirst := true; 				//cnwmc5 par 29716
	table	:= self.myDataTable;
	
	foreach wle in wleArray do
		if table.findObjectInRowReversed(wle, row) then	 
			
			table.selectRow(row, false);
			
			if isFirst = true then
				table.topRow:= row;
			endif;
			
			isFirst := false;
		endif;
	endforeach;
epilog
	if wleArray &lt;&gt; null then
		delete wleArray;
	endif;

end;</source>
        <Parameter name="_vehicle" type="CM_Vehicle" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
