    <JadeMethod name="isTiValidForLocation" id="575fa69a-b37c-4ce6-ba7a-49ae16f382a4">
        <source>isTiValidForLocation(_ti: CM_TrackedItem): Boolean;

vars
	auto			: CMIF_AutoMovePlan;
	restriction		: CM_LocationRestriction;

begin 
	create auto transient;
	auto.generateLog := false;
	restriction := self.myLocationRestriction;
	if restriction &lt;&gt; null then
		if (not _ti.isCompatibleWithRestriction(restriction, auto)) then
			app.raiseCMException3(TiIncompatibleWithRestriction, _ti.cargoTypeDescr, _ti.id, self.ident, null, null);
			return false;
		endif;
	endif;
	return true;

epilog
	delete auto;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
