    <JadeMethod name="updateTable" id="0183e048-d2f4-4e5f-81e6-8d1989810ec5">
        <source>updateTable(_theVVR:CM_VehicleVisitRecord;_addRecord:Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 November 2016	cnwns1	Initial creation

*/

vars
	failedDAC	: CM_DataAccessController;
	detailString: String;
	isInTable 	: Boolean;
	idx 		: Integer;
	backColour	: Integer;
	startAt 	: Integer;

begin

	isInTable := self.tblItems.findObjectInRow(_theVVR,startAt);
	if _addRecord then
		if not _theVVR.canUserAccessSelf(app.getMyUser, failedDAC, app.myPassport) then
			return;
		endif;
		
		if isInTable then
			self.tblItems.updateItemObject(_theVVR,self.colorRow1,self.colorRow2,app.myPassport);	//TFS 5560 jlgns1 28/7/17
		else	
			detailString := _theVVR.getAttributeStringForDefArray(self.tblItems.allTblDataEntRows);
			idx := self.tblItems.addItemObject(_theVVR, detailString);
			if idx mod 2 = 0 then
				backColour := self.colorRow1;
			else
				backColour := self.colorRow2;
			endif;			
			self.tblItems.accessRow(idx).backColor := backColour;			
		endif;
	else
		if isInTable then
			self.tblItems.removeItemObject(_theVVR);	
			self.tblItems.cnEcAlternateRowColors(self.colorRow1,self.colorRow2);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_theVVR" type="CM_VehicleVisitRecord"/>
        <Parameter name="_addRecord" type="Boolean"/>
    </JadeMethod>
</GUIClass>
