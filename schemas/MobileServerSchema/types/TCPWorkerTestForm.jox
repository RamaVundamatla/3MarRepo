<GUIClass name="TCPWorkerTestForm" id="a77e21bd-7acb-4b9a-8f5c-e4d9bdde510b">
    <superclass name="Form"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="btnStart" id="5e50e156-402b-4a6f-a0ed-386190370b13">
        <embedded/>
        <type name="Button"/>
    </ImplicitInverseRef>
