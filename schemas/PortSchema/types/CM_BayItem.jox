<Class name="CM_BayItem" id="79886cc5-d1df-4801-9e86-3c44cf303472">
    <superclass name="CM_Object"/>
    <transient/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <ExplicitInverseRef name="allBayItemLayouts" id="b54a264d-ceda-4dc2-9d5e-0365b977f2cd">
        <kind>parent</kind>
        <transientToPersistentAllowed/>
        <updateMode>automatic</updateMode>
        <type name="CM_BayItemLayoutByTypeDict"/>
        <access>readonly</access>
        <Inverse name="CM_BayItemLayout::myBayItem"/>
    </ExplicitInverseRef>
    <JadeMethod name="exportAsXMLInverseRef" id="b2fc64f0-5974-4d8c-80a1-b7924ecac5d8">
        <source>exportAsXMLInverseRef(_property: Reference): Integer protected;
// ---------------------------------------------------------------------------
// Created:     24 January 2014 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if _property = CM_BayItem::allBayItemLayouts then
		return ExportAsParent;
	endif;
	
	return inheritMethod(_property);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_property" type="Reference"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="hasBayItemLayouts" id="1c840a29-0c5c-4cd2-80a8-69e57e06b1ff">
        <source>hasBayItemLayouts() : Boolean;
/*
Purpose:			
Date		Who		Reason
21 January 2014	cnwab1	Initial creation
*/

vars

begin
	return not self.allBayItemLayouts.isEmpty();
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="importFromXMLDocReference" id="1737d861-3fbd-4024-af40-e97fac07d963">
        <updating/>
        <source>importFromXMLDocReference(_property: Property; _xmlElement: JadeXMLElement input) updating, protected;
// ---------------------------------------------------------------------------
// Created:     24 January 2014 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	childElement		: JadeXMLElement;
	allChildElements 	: JadeXMLElementArray;
	pxyItemLayout	: CM_BayItemLayout;
begin
	if _property = CM_BayItem::allBayItemLayouts then
		create allChildElements transient;
		_xmlElement.getAllElementsByTagName(CM_BayItemLayout.name,allChildElements);
		
		foreach childElement in  allChildElements do
			create pxyItemLayout transient;
			pxyItemLayout.setMyBayItem(self);
			pxyItemLayout.importFromXMLDoc(childElement);
			pxyItemLayout.setMyBayItem(self);
		endforeach;
	endif;

	inheritMethod(_property, _xmlElement);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_property" type="Property"/>
        <Parameter name="_xmlElement" type="JadeXMLElement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateLayouts" id="9c3e57f1-ed02-47fd-a1a5-fa990ace884d">
        <updating/>
        <source>setForUpdateLayouts(_proxyBayItem : CM_BayItem;  _passport : CM_Passport input) updating;
/*

Date		Who		Reason
19 August 2013	cnwer1	Initial creation PAR

*/

vars
	pxyLayout , newLayout: CM_BayItemLayout;
	layoutsToDelete : ObjectArray;
begin
		
	if _proxyBayItem = null or _proxyBayItem.allBayItemLayouts.size = 0 then
		return;
	endif;
	
	//always re-create the bay layouts
	self.allBayItemLayouts.purge;
	
	foreach pxyLayout in _proxyBayItem.allBayItemLayouts discreteLock do
		app.myUtilityCA.utlCreateBayItemLayout(	pxyLayout,newLayout,self,_passport);
		if _passport.hasErrors then
			return;
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_proxyBayItem" type="CM_BayItem"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
