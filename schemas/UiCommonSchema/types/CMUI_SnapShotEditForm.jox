    <JadeMethod name="cmbToCargoType_click" id="9628f861-27df-435f-885b-90cb42ece8be">
        <controlMethod name="CMUI_ComboBoxObject::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbToCargoType_click(combobox: ComboBox input) updating;
/*

Purpose:			TFS 40336

Parameters:			

Return Value:		

Date		Who		Reason
12 September 2018	jlgab1	Initial creation

*/

vars
	ct : CM_CargoType;
begin
	if combobox.listObject.isKindOf(CM_CargoType) then
		ct := combobox.listObject.CM_CargoType;
	endif;

	self.doBuildCargoSubTypeCombo(ct);
	
	if ct &lt;&gt; null then
//	if self.txtCargoTypeDesc.text = "" then
		self.txtCargoTypeDesc.text := ct.description;
//	endif;
	endif;
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
