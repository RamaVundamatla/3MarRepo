    <JadeMethod name="setComboCargoType" id="a83c7df5-c90e-4a7c-8f58-e09dd0d713ac">
        <source>setComboCargoType(_cargoType : Integer);
//********************************************************************
//
// Created by: cnwsh3
//
// Date: 19 January 2004
//
//********************************************************************
vars
	theCargoType : CM_CargoType;
begin
	
	if _cargoType = null then
		self.cmbQryCargoType.text := Any_String;
		self.tblQuery.setValueByName(ETRow_CargoType, Any_String);
		return;
	endif;
	
	self.cmbQryCargoType.listObject := app.myRoot.allCargoTypesById[_cargoType];
	self.cmbQryCargoType.lostFocus(self.cmbQryCargoType);

end;</source>
        <Parameter name="_cargoType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setContentsImExStatus" id="bdee7700-8230-4b3e-a5e9-335f216a7eca">
        <updating/>
        <source>setContentsImExStatus(_contentsStatus, _imexStatus : Integer) updating, protected;
// ---------------------------------------------------------------------------
// Created:		September  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	contentsStatus 	: CM_ContentsStatus;
	imexStatus		: CM_IMEXStatus;
	idx 			: Integer;
begin
	contentsStatus := app.myRoot.allContentsStatuses[_contentsStatus];
	imexStatus := app.myRoot.allImexStatuses[_imexStatus];
	
	if self.myTI.isKindOf(CM_Container) then			//+cnwml2 PAR23045
		if contentsStatus &lt;&gt; null then
			self.tblContainer.setValueByName(ETRow_ContentsStatus,contentsStatus.description);
			self.cmbContentsStat.listObject := contentsStatus;	
		endif;
	endif;

	if imexStatus &lt;&gt; null then
		self.tblContainer.setValueByName(ETRow_ImexStatus, imexStatus.description);
		self.cmbImEx.listObject := imexStatus;	
	endif;
		
end;</source>
        <access>protected</access>
        <Parameter name="_contentsStatus" type="Integer"/>
        <Parameter name="_imexStatus" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setContentsStatus" id="f23fe2e8-aee9-4c38-8ddc-640003cf22aa">
        <updating/>
        <source>setContentsStatus(_contentsStatus : Integer) updating, protected;
// ---------------------------------------------------------------------------
// Created:		March  2009 By Adam Richards cnwar2
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	contentsStatus 	: CM_ContentsStatus;
	idx 			: Integer;
begin
	if self.myTI.isKindOf(CM_Container) then
		contentsStatus := app.myRoot.allContentsStatuses[_contentsStatus];
		
		if contentsStatus &lt;&gt; null then
			self.tblContainer.setValueByName(ETRow_ContentsStatus, contentsStatus.description);
			self.cmbContentsStat.listObject := contentsStatus;	
		endif;
	endif;
end;</source>
