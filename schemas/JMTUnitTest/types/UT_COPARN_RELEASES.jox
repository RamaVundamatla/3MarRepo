    <JadeMethod name="ediDBLoad" id="9772198b-d8ff-45d8-86f1-502fa1381e51">
        <source>ediDBLoad(_ediFile: CM_EDIFile);
/*
Date		Who		Reason
06/04/2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
*/
vars
	ediAgent: CM_EDIControllerAgent;
	ediData	: CM_EDIData;
begin
	create ediAgent transient;
	
	ediAgent.setTerminal(self.getTerminal());
	
	ediData := _ediFile.ediData;
	
	ediAgent.verifyEdiData(ediData);
	ediAgent.loadEdiDb(null, ediData, false);
	
	// self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, 'EDI Data DB Load failed' &amp; CrLf &amp; app.myPassport.getErrorsAndWarningsAsString());			
	
	
	foreach ediData in _ediFile.allEDIData do
		ediAgent.verifyEdiData(ediData);
		ediAgent.loadEdiDb(null, ediData, false);
		
		// self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, 'EDI Data DB Load failed' &amp; CrLf &amp; app.myPassport.getErrorsAndWarningsAsString());		
	endforeach;
//	self.assertNoTrxErrorsOrWarnings();		// let the calling method decide what is allowed - eg verify warnings might be OK
epilog
	delete ediAgent;
end;</source>
        <Parameter name="_ediFile" type="CM_EDIFile"/>
    </JadeMethod>
    <JadeMethod name="ediVerify" id="f6bb9992-087d-4ea0-9e00-d4ea419d1da7">
        <source>ediVerify(_ediFile: CM_EDIFile);
/*
Purpose:	verify for edi files with &gt; 1 edi data

Date		Who		Reason
01 December 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
07/05/2012			cnwcs5	par 29402 - let calling method decide whether to do asserts
*/
vars
	ediAgent	: CM_EDIControllerAgent;
	ediData		: CM_EDIData;
	result 		: Boolean;
begin
	create ediAgent transient;
	
	ediAgent.setTerminal(self.getTerminal());
	
	ediData := _ediFile.ediData;
	result 	:= ediAgent.verifyEdiData(ediData);

	//self.assertTrueMsg(ediData.status = CM_EDIFile.EDI_STATUS_VERIFIED or ediData.status = CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS, 'EDI Data Verify failed' &amp; CrLf &amp; app.myPassport.getErrorsAndWarningsAsString());			
	
	foreach ediData in _ediFile.allEDIData do
		result := ediAgent.verifyEdiData(ediData);
			
		//self.assertTrueMsg(ediData.status = CM_EDIFile.EDI_STATUS_VERIFIED or ediData.status = CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS, 'EDI Data Verify failed' &amp; CrLf &amp; app.myPassport.getErrorsAndWarningsAsString());			
	endforeach;
epilog
	if process.isInTransactionState then
		abortTransaction;
	endif;
	delete ediAgent;
end;</source>
        <Parameter name="_ediFile" type="CM_EDIFile"/>
    </JadeMethod>
    <JadeMethod name="getMatchingEDIItemTI" id="e0ff86c8-c5e6-4e36-8df5-f65da154f4fb">
        <source>getMatchingEDIItemTI(_ediHeaderTI : CM_EDIRequestHeaderTI) : CM_EDIRequestDetailTI;
//
// 17 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
//
vars
	ediTI : CM_EDITrackedItem;
	ediItemTI : CM_EDIRequestDetailTI;
begin
	foreach ediTI in _ediHeaderTI.myEDIData.allEDITrackedItems do
		if ediTI.isKindOf(CM_EDIRequestDetailTI) and
		   ediTI.getReleaseRequestNumber =_ediHeaderTI.getReleaseRequestNumber and
		   ediTI.myParent = _ediHeaderTI and ediTI.cargoType = _ediHeaderTI.cargoType then
			ediItemTI := ediTI.CM_EDIRequestDetailTI;
			break;
		endif;
	endforeach;
	return ediItemTI;
epilog

end;</source>
        <Parameter name="_ediHeaderTI" type="CM_EDIRequestHeaderTI"/>
        <ReturnType type="CM_EDIRequestDetailTI"/>
    </JadeMethod>
