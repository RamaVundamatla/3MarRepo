/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 April 2010	cnwjk3	Initial creation

*/

vars

begin	
	self.myDrawingController.flipLandscapePortrait();
	if self.myDrawingController.isLandscape then
		self.btnLandscape.caption := "Portrait";
	else
		self.btnLandscape.caption := "Landscape";
	endif;
	
	self.updateCaption();
epilog

end;</source>
