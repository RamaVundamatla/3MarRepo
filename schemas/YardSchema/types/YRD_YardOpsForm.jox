    <JadeMethod name="displayTask" id="aaee5720-3911-42b7-8a23-ad8978a8ff36">
        <source>displayTask( _obj : Object ) : String;
// -----------------------------------------------------------------------------
// Created:		25 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
// 09/05/2018	jlgdap1		TFS 38501 PEL1 Work Order Changes
// 29/09/2021   navma1 		ChangeRequest 51925: SAL - Web Portal Cargo Work Orders
// 08 Feb 2023	navcs2		ChangeRequest 56318:[56319] EUP - Enable ToDo Work Order job on Yard Operation Screen
// -----------------------------------------------------------------------------

vars
	taskId 		: Integer;
	woTaskType	: CM_WorkOrderDetailType;
	root		: CM_Root;
begin
	root := app.myRoot;
	
	if _obj.isKindOf(CM_ToDoTaskDesc) then
		woTaskType	:= root.allWorkOrderTaskTypes[WorkOrderMode_Cargo,WO_TASK_TODO];
	else
		taskId 	:= root.getWorkOrderTaskTypeByObject(_obj);
		woTaskType	:= root.allWorkOrderTaskTypes[WorkOrderMode_Cargo,taskId];
		if woTaskType = null then															// 08 Feb 2023	navcs2	#56318:[56319]
			woTaskType	:= root.allWorkOrderTaskTypes[WorkOrderMode_ToDo,taskId];			// 08 Feb 2023	navcs2	#56318:[56319]
		endif;																				// 08 Feb 2023	navcs2	#56318:[56319]
	endif;
	
	if woTaskType &lt;&gt; null then
		if _obj.isKindOf(CM_ToDoTaskDesc) then
			return woTaskType.description &amp; ' - ' &amp; _obj.CM_ToDoTaskDesc.description;
		else
			return woTaskType.description;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="displayWLEs" id="8b85fd07-c741-4d06-a46f-02fb98581897">
