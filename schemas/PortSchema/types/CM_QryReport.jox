    <JadeMethod name="addToRootSecurityRoles" id="ead211c6-f768-4a36-bece-4b400a95388a">
        <source>addToRootSecurityRoles() protected;
// ---------------------------------------------------------------------------
// Created:     24 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if (not self.allSecurityRoles.includes(app.myRoot.mySecurityRoleSystem)) then
		self.allSecurityRoles.add(app.myRoot.mySecurityRoleSystem);
	endif;


	if (not self.allSecurityRoles.includes(app.myRoot.mySecurityRoleTerminal)) then
		self.allSecurityRoles.add(app.myRoot.mySecurityRoleTerminal);
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
