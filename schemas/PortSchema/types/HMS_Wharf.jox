    <JadeMethod name="getDisplayStringForAttribute" id="9e29a3ad-c924-41f9-8faf-7e3cd5b3eae8">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     18 February 2005	cnwhjg1
//
// Purpose:  
// 26.08.24		navhn30		ChangeRequest 65521: NSW | OnePort Integration - Setting voyage process by wharf   
// ----------   ----------  --------------------------------------------------
vars
	resourceWharf : HMS_ResourceForWharf;
begin		
	if _attrName = ETRow_MyHarbour then
		if self.getHarbourReal &lt;&gt; null then
			return self.getHarbourReal.description;
		else
			return null;
		endif;
	elseif _attrName = ETRow_MyArrivalResource then
	resourceWharf := self.allResourcesForWharf[self.myHarbour, self, self.First_Resource];
		if resourceWharf &lt;&gt; null and resourceWharf.myArrivalResource &lt;&gt; null then 
			return (resourceWharf.myArrivalResource.description);
		else 
			return null;
		endif;
		
	elseif _attrName = ETRow_MyDepartResource then
	resourceWharf := self.allResourcesForWharf[self.myHarbour, self, self.First_Resource];
		if resourceWharf &lt;&gt; null and resourceWharf.myDepartResource &lt;&gt; null then 
			return (resourceWharf.myDepartResource.description);
		else 
			return null;
		endif;
	elseif _attrName = ETRow_MyShiftResource then
	resourceWharf := self.allResourcesForWharf[self.myHarbour, self, self.First_Resource];
		if resourceWharf &lt;&gt; null and resourceWharf.myShiftResource &lt;&gt; null then 
			return (resourceWharf.myShiftResource.description);
		else 
			return null;
		endif;
		
	elseif	_attrName = ETRow_WaterOnLeft then
		if self.waterOnLeft = true then
			return	"Water on Left" ; 
		endif ; 
	return	"Water on Right"	 ; 
	
	elseif _attrName = ETRow_IsLogicalWharf then
		if self.isLogicalWharf	= false	then
			return	"Physical Wharf" ; 
		endif ; 
	return	"Logical Wharf" ; 
	
	elseif _attrName = ETRow_MyDefaultVoyageProcess then		//	26.08.24	 navhn30	TFS 65526
		if self.myDefaultVoyageProcess &lt;&gt; null then
			return self.myDefaultVoyageProcess.description;
		else
			return null;
		endif;
	elseif _attrName = ETRow_Colour then
		return	self.colour.String;
	else
		return inheritMethod(_attrName, _short);
	endif;
	


end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getHarbour" id="348a6762-c53e-4740-83d1-26577dda6388">
