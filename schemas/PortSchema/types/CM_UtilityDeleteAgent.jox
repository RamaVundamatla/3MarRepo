    <JadeMethod name="utlDeleteEDITrackedItems" id="285aec25-b443-44b1-a18c-c06bd8e1e549">
        <source>utlDeleteEDITrackedItems(_ediTIDict : CM_EDITIById; _passport : CM_Passport input);
//--------------------------------------------------------------
//Created: December 2002 By: cnwgd1
//--------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	------------------------------------
// 13/03/2012	cnwdap1		PAR #29226 Use Oid of EDI tracked item instead of id
//							EDI tracked items are not all CM_TrackedItems, and some of them don't have ids
// 28/08/2012	cnwcs5		par 30134 - Fix problem where the String passed back is truncated. If we don't have enough
//							room in _userInfo parameter then pass back DELETE_LIMIT_EXCEEDED
//08 Oct 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
constants
	ProgressBarRefresh	: Integer = 2000;	
	DELETE_LIMIT_EXCEEDED 	= 'LIMIT EXCEEDED';
	MAX_USERINFO_LENGTH		= 48000;			// approximately
vars
	ediTI 				: CM_EDITrackedItem;
	monitor 			: CMIF_Monitor;
	total, updateCount,
	count 				: Integer;
	ediData				: CM_EDIData;
	userInfo, temp		: String;
	progressInt	: TimeStampInterval;
	progressTS : TimeStamp;
begin
	self.raiseExceptionIfNull(_ediTIDict, 'EDI Dict');

	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	progressTS := app.actualTimeServer();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	monitor := _passport.myCMIFMonitor;			
	
	if not global.isValidObject(monitor) then				// transient so no trip to server
		monitor := null;						
	endif;											
		
	if monitor &lt;&gt; null then
		total 	:= _ediTIDict.size;
		
		monitor.updateProgress(monitor.message, total, 0);
		
		updateCount := (total / 20).roundedUp; // update after every 5%
	endif;
	
	ediTI := _ediTIDict.first;					
	
	if ediTI &lt;&gt; null then						
		ediData := ediTI.myEDIData;				
	endif;										
	
	foreach ediTI in _ediTIDict do
		count := count + 1;
		
		progressInt := app.actualTimeServer() - progressTS;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		if monitor &lt;&gt; null and progressInt.getMilliseconds &gt;= ProgressBarRefresh then
			monitor.updateProgress(monitor.message, monitor.partsInJob, count);
			progressTS := app.actualTimeServer();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		endif;
		
		userInfo := userInfo &amp; "^" &amp; ediTI.getOidString;	
		
		exclusiveLock(ediTI);
		ediTI.erase(NORMAL_ERASE);
		
		if _passport.hasErrors then
			return;
		endif;
	endforeach;

	if ediData &lt;&gt; null and userInfo.length &gt; 1 then
		if userInfo.length &gt; MAX_USERINFO_LENGTH then
			// we can't actually pass back all the oids we have deleted
			userInfo := DELETE_LIMIT_EXCEEDED;
		endif;
		
		ediData.causeEvent(_passport.myTerminal.getTerminalEvent(Event_EDITI_Delete), false, userInfo[2:end]);	
	endif;
	
end;</source>
        <Parameter name="_ediTIDict" type="CM_EDITIById"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
