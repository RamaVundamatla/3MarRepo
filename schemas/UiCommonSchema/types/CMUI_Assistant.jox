    <JadeMethod name="showBlendForm" id="add27ab3-c5b5-4679-9335-06502ec5e29f">
        <source>showBlendForm( _callerForm : CM_BaseForm; _ti : CM_TrackedItem; _cargoType : CM_CargoType );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	form : CMUI_BlendCargoForm;
	msg : String;

begin


	form := app.loadForm(CMUI_BlendCargoForm, CMUI_Assistant, false, false, true, self.myTerminal, null).CMUI_BlendCargoForm;
	if form = null then
		return;
	endif;	
	
	if _ti = null and _cargoType = null then
		//nothing to set up
	elseif _ti &lt;&gt; null and not _ti.hasBeenMerged and _ti.isOnSite and ( _ti.myCargoType.isBulk or _ti.myCargoType.isBreakBulk ) then
		form.setMyCargoType( _ti, _ti.myCargoType );
	elseif _cargoType &lt;&gt; null and ( _cargoType.isBulk or _cargoType.isBreakBulk ) then
		form.setMyCargoType( null, _cargoType );
	endif;
	form.setParentForm( _callerForm );
	form.centreOverParent(1);
//	form.showModal();
	form.show();

epilog

end;</source>
        <Parameter name="_callerForm" type="CM_BaseForm"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="showBookingForm" id="a1c9eba5-e62d-402c-a31d-da0174d94271">
        <source>showBookingForm( _booking: CM_BookingRef; _masterMenuAction: CMUI_MenuAction;_terminal :CM_Terminal);
// Show the dialog based Booking Fomr 
vars
	subSys : CMUI_SubSystem;
	formCls,
	assistCls: Class;
	bookingRefForm : CM_BaseForm;
begin
	subSys := app.myController.allSubSystems['GateSchema'];
	
	if subSys &lt;&gt; null then
		subSys.getFormDetails('GTE_BookingRequestForm', formCls, assistCls);
	endif;
	if formCls = null then
		return;
	endif;
//	if _booking = null then
	//	app.msgBox(app.getErrorString1(NothingSelected,"Booking"),"Booking" ,MsgBox_OK_Only);
//		return;
//	endif;
	bookingRefForm := app.loadForm(formCls, 
							assistCls, 
							false, 
							false,
							false, 
							_terminal,
							_masterMenuAction).CM_BaseForm;	

	if bookingRefForm = null then
		return;
	endif;
	bookingRefForm.setFormObject(_booking);
	bookingRefForm.show;		
end;</source>
        <Parameter name="_booking" type="CM_BookingRef"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="showBookingFormForVoyage" id="ce07d2e5-0218-4995-80e1-21ded40c0b5f">
        <updating/>
        <source>showBookingFormForVoyage(_voyage : CM_Voyage; _masterMenuAction : CMUI_MenuAction) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 29/12/2014	cnwdap1		Initial creation PAR #35397 CCMS SFW 1394 Voyage Rationalisation
//
vars
	theForm: Form;
	theClass : Class;
	assistClass : Class;
	jrw : Schema;
	
begin
	jrw := rootSchema.getSchema("GateSchema");
	theClass := jrw.getClass("GTE_BookingRefMultiForm");
	assistClass := jrw.getClass("GTE_Assistant");
	
	theForm := app.loadForm(theClass, assistClass, false, false, true, self.myTerminal, _masterMenuAction);
	if theForm = null then
		return;
	endif;
	
	theForm.show;
	theForm.setPropertyValue("isFirstActivateComplete", true);
	theForm.sendMsgWithParams("openBRwithVoyage", _voyage);
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
    </JadeMethod>
    <JadeMethod name="showBookingRefDiscrep" id="62a90fef-38e7-4e85-ba4b-109b40ce51bc">
        <source>showBookingRefDiscrep( _bookingRefDiscrep : CMEVT_BookingRefDiscrep; _trackedItems : CM_TISet; _bookingRef : CM_BookingRef; _masterMenuAction: CMUI_MenuAction; _terminal : CM_Terminal );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 September 2009	cnwndl1	Initial creation	CCMS 1609 Par 20521

*/

vars
	form : CMUI_BookingRefDiscrepForm;
	terminal : CM_Terminal;
begin

	terminal := _terminal;
	if terminal = null then
		if _bookingRefDiscrep &lt;&gt; null then
			terminal := _bookingRefDiscrep.myTerminal;
		endif;
		if terminal = null and _bookingRef &lt;&gt; null then
			terminal := _bookingRef.myTerminal;
		endif;
		if terminal = null then
			terminal := self.myTerminal;
		endif;
	endif;
	form := app.loadForm(CMUI_BookingRefDiscrepForm, CMUI_Assistant, false, false, true, terminal, _masterMenuAction).CMUI_BookingRefDiscrepForm;

	if form = null then
		return;
	endif;	
	
	form.setBaseData( terminal, _bookingRefDiscrep, _trackedItems, _bookingRef);
	
	form.show();
	
epilog

end;</source>
        <Parameter name="_bookingRefDiscrep" type="CMEVT_BookingRefDiscrep"/>
        <Parameter name="_trackedItems" type="CM_TISet"/>
        <Parameter name="_bookingRef" type="CM_BookingRef"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="showBookingReferenceForm" id="dde5b7ee-227a-459a-8f3d-3039233c8b8a">
        <source>showBookingReferenceForm( _voyage: CM_Voyage; _masterMenuAction: CMUI_MenuAction;_terminal :CM_Terminal);
// ---------------------------------------------------------------------------
// Created:     05/08/08 by cnwaer1
//
// Purpose:     Voyage booking change - for CCMS SFW 1037
// ---------------------------------------------------------------------------
vars
	subSys : CMUI_SubSystem;
	formCls,
	assistCls: Class;
	bookingRefForm : CM_BaseForm;
begin
	subSys := app.myController.allSubSystems['GateSchema'];
	
	if subSys &lt;&gt; null then
		subSys.getFormDetails('GTE_BookingRefMultiForm', formCls, assistCls);
	endif;
	
	if formCls = null then
		return;
	endif;
	if _voyage = null then
		app.msgBox(app.getErrorString1(NothingSelected,"Voyage"),"Voyage" ,MsgBox_OK_Only);
		return;
	endif;
	bookingRefForm := app.loadForm(formCls, 
							null, 
							false, 
							false,
							false, 
							_terminal,
							_masterMenuAction).CM_BaseForm;	

	if bookingRefForm = null then
		return;
	endif;
	
	//show voyage form with searched bookings for the selected voyage
	bookingRefForm.show;		
	bookingRefForm.openBRwithVoyage(_voyage);
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="showBreakBulkoverageForm" id="82c99e15-de05-4098-a459-62041a6a6f02">
        <source>showBreakBulkoverageForm( _ti : CM_TrackedItem);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 May 2013	cnwrd1	Initial creation

*/


vars

	form : CMUI_BreakBulkDiscrepancyForm;
