    <JadeMethod name="translateForm" id="a0fa6b60-7e48-4654-9ccb-39cc9b34c4a3">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 08 February 2019 08:18:37.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0023200, locale);
	btnClose.translateCaption(Xlat_0023201, locale);
	btnConfig.translateCaption(Xlat_0023202, locale);
	btnDelete.translateCaption(Xlat_0023203, locale);
	btnMappings.translateCaption(Xlat_0023204, locale);
	btnNew.translateCaption(Xlat_0023205, locale);
	btnUpdate.translateCaption(Xlat_0023206, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="updateFromNote" id="b123e639-cb82-4588-a74d-d68652c321ba">
        <source>updateFromNote(_alloc : CM_InvoiceAllocation);
/*

Purpose:			// TFS 7496

Parameters:			

Return Value:		

Date		Who		Reason
15 November 2017	jlgab1	Initial creation

*/

vars
	idx : Integer;
begin
	if self.tblData.findObjectInRow(_alloc, idx) then
		self.tblData.setCellText( idx, 1,	_alloc.description  &amp; Tab &amp; 
										  _alloc.getInvoiceLineTypesString &amp; Tab &amp; 
										  _alloc.priorityValue.asStringJMT()&amp; Tab &amp; 
										  _alloc.myQuantityMap.allQuantityRanges.size.asStringJMT() 
										  ); 
		self.tblData.resort();
	endif;
epilog

end;</source>
        <Parameter name="_alloc" type="CM_InvoiceAllocation"/>
    </JadeMethod>
