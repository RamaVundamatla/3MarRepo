vars
	cancelSave : Boolean;
	
begin
	self.initialiseActivity;
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valDataDumpClass(_proxyDataDumpClass);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	app.setContinueCMExceptions(false);

	_newDataDumpClass := app.myRoot.createDataDumpClass(_proxyDataDumpClass);
end;</source>
