    <JadeMethod name="translateForm" id="639a9710-b4de-4356-bdd8-652fc635d56a">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0007948, locale);
	btnDeSelect.translateCaption(Xlat_0000654, locale);
	btnLoad.translateBubbleHelp(Xlat_0000653, locale);
	btnLoad.translateCaption(Xlat_0000656, locale);
	btnLoadCountries.translateBubbleHelp(Xlat_0000647, locale);
	btnLoadCountries.translateCaption(Xlat_0000648, locale);
	btnLoadUNFile.translateBubbleHelp(Xlat_0000650, locale);
	btnLoadUNFile.translateCaption(Xlat_0000651, locale);
	btnSearch.translateCaption(Xlat_0000657, locale);
	btnSelect.translateCaption(Xlat_0000658, locale);
	lblActive.translateCaption(Xlat_0000659, locale);
	lblActiveColor.translateCaption(Xlat_0000649, locale);
	lblCountry.translateCaption(Xlat_0000660, locale);
	lblDesc.translateCaption(Xlat_0000661, locale);
	lblPortCode.translateCaption(Xlat_0000662, locale);
	lblPortDesc.translateCaption(Xlat_0000663, locale);
	lblPortsOnly.translateCaption(Xlat_0000664, locale);
	lblResults.translateCaption(Xlat_0000665, locale);
	mnuLocationEdit.translateCaption(Xlat_0007949, locale);
	mnuLocations.translateCaption(Xlat_0007950, locale);
end;</source>
    </JadeMethod>
