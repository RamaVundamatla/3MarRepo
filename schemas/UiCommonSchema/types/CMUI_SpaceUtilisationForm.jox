    <JadeMethod name="createMonitor" id="715e7fe5-e727-47f5-8d51-6c187cb02e75">
        <updating/>
        <source>createMonitor() updating;
// ---------------------------------------------------------------------------
// Created:		14 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

	cmifMonitor		: CMIF_Monitor;
	tmpHeight, idx : Integer;
	tmpOptionsUsed : IntegerArray;
	now : TimeStamp;
begin

	cmifMonitor := app.myPassport.myCMIFMonitor;
	if cmifMonitor = null then
		create cmifMonitor transient;
		cmifMonitor.myParent := self;
		app.myPassport.setMyCMIFMonitor(cmifMonitor);
	endif;

	self.modalDialogReturnValue := self.ModalDialogReturn_Null;	
	self.modalDialogShow(null,'Cancel' , null, null, 'Terminal Utilisation',  'Please Wait....');
	self.pbProgressBar.visible := true;


end;</source>
    </JadeMethod>
    <JadeMethod name="deleteMonitor" id="dda7bebe-d06c-40f8-a64c-8d59ec811275">
        <source>deleteMonitor();
// ---------------------------------------------------------------------------
// Created:		14 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	delete app.myPassport.myCMIFMonitor;	
	app.myPassport.setMyCMIFMonitor(null);
	self.frmModalDialog.visible := false;

end;</source>
    </JadeMethod>
    <JadeMethod name="displayHazTable" id="8c0dfbf1-6da6-4d11-8de1-fe2ea971135b">
        <source>displayHazTable();
// ---------------------------------------------------------------------------
// Created:     20 April 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	aTI : CM_TrackedItem;

begin
	self.tblHaz.rows := self.tblHaz.fixedRows;
	self.tblHazInfo.rows := 0;
	foreach aTI in self.myQueryAgent.allNonMatchTIsHAZ discreteLock do
		self.displayTiTable(aTI, self.tblHaz);
	endforeach;
	self.tblHaz.colourRows(self.colorRow1, self.colorRow2);
end;</source>
    </JadeMethod>
    <JadeMethod name="displaySpaceTable" id="dd7f8b97-b82d-4d2d-9db2-e7176aad54db">
        <source>displaySpaceTable();
// ---------------------------------------------------------------------------
// Created:		13 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//26 Feb 2015  cnwma1 PAR # 33352 Space Utilisation functionality for Block Stacks
// ---------------------------------------------------------------------------
vars
	table : CM_DataTable;
	tmpKPITA : CM_KPITerminalArea;
	tmpKPI : CM_KPI;
	line : String;
	row, col, idx : Integer;
	clr : Boolean;
	
	rowNameArray : StringArray;
begin
	table := self.tblData;
	
	table.rows := table.fixedRows;
	self.tblInfo.rows := 0;

	if not self.chkSpace.value then
		return;
	endif;

	if self.myQueryAgent.allQryTerminalAreas.isEmpty then
		app.msgBox("Must Select a terminal area!", "Query Error", MsgBox_Exclamation_Mark_Icon);
		self.fldQuery.topSheet := self.shtQuery1;
		return;
	endif;
	
	if self.myQueryAgent = null then
		return;
	endif;
	table.columns := 20;
	clr := true;
	
	self.mySummaryLine.clearSummaryData( app.getErrorString(Summary) );	//24 Oct 2013	NDL	Par 32079
	self.initTableData(null);				// //26/02/2015  cnwma1 PAR #33352
	
	
	foreach tmpKPI in self.myQueryAgent.allKPITerminalAreas discreteLock do
		tmpKPITA := tmpKPI.CM_KPITerminalArea;
		
		self.displaySpaceTableDetail(tmpKPITA, Black, clr);
		clr := false;
		
	/*	if tmpKPITA.code &lt;&gt; null then											//26/02/2015  cnwma1 PAR #33352
			if tmpKPITA.getTA.CM_TerminalArea.isBlockStack then
				if tmpKPITA.getTA.CM_BlockStack.getMaxCapacity &lt;&gt; 0 then
					tmpKPITA.setTotEmpty(tmpKPITA.getTA.CM_BlockStack.getMaxCapacity - tmpKPITA.totalTIs);
				endif;
			else
				tmpKPITA.setTotEmpty(tmpKPITA.totalLocnEmpty);
			endif;
		endif;
	
		if tmpKPITA.code  &lt;&gt; null then											//26/02/2015  cnwma1 PAR #33352
			if tmpKPITA.getTA.CM_TerminalArea.isBlockStack then
				if tmpKPITA.getTA.CM_BlockStack.getMaxCapacity &lt;&gt; 0 then
					tmpKPITA.setTotOccupied(tmpKPITA.totalTIs);
				endif;
			else
				tmpKPITA.setTotOccupied(tmpKPITA.totalLocnOccupied);
			endif;
		endif; */
		

		line := tmpKPITA.getDisplayLine();
		idx := table.addItemObject(tmpKPITA, line.trimBlanks);

	//	self.mySummaryLine.addToSummaryLine( tmpKPITA, false );	//24 Oct 2013	NDL	Par 32079
		self.mySummaryLine.addToSummaryLine( tmpKPITA, true );	//20 Jul 2021	NDL	TFS 51518
	endforeach;
	
	if self.hasRoRoOnly() then
		line := self.mySummaryLine.getDisplayLineSummaryRORO();//08/09/2025	navkc1 JIRA 35623
	else
		line := self.mySummaryLine.getDisplayLine();	//24 Oct 2013	NDL	Par 32079
	endif;
	
	idx := table.addItemObject(self.mySummaryLine, line.trimBlanks);	//24 Oct 2013	NDL	Par 32079
	table.accessRow(idx).fontBold := true;	//24 Oct 2013	NDL	Par 32079
	
	table.colourRows(self.colorRow1, self.colorRow2);
	self.tblSpaceDtl.colourRows(self.colorRow1, self.colorRow2);

	idx := table.fixedRows + 1;
	foreach col in 13 to 20 reversed do :outerLoop
		foreach row in idx to table.rows do
			if table.accessCell(row,col).text &lt;&gt; null then
				break outerLoop;
			endif;
		endforeach;
	endforeach;
	table.columns := col;
	
epilog

	delete rowNameArray;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="displaySpaceTableDetail" id="e7d3d312-39e8-4bca-ad4a-441435e69d5c">
        <source>displaySpaceTableDetail(_tmpKPITA : CM_KPITerminalArea; _color : Integer; _clear : Boolean);
// ---------------------------------------------------------------------------
// Created:		14 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	tmpKPILocn : CM_KPILocation;
	line, taCode : String;
	idx : Integer;
	table : CM_DataTable;
begin
	table := self.tblSpaceDtl;
	
	if _clear then
		table.rows := table.fixedRows;
	endif;
	
	//08/09/2025	navkc1 JIRA 35623
	if _tmpKPITA.isRoRoLane() then
		taCode := _tmpKPITA.code;
	else
		taCode := _tmpKPITA.terminalAreaCode;
	endif;
	
	foreach tmpKPILocn in _tmpKPITA.allKIPLocations discreteLock do
		line := taCode &amp; Tab &amp; tmpKPILocn.getDisplayLine();
		idx := table.addItem(line.trimBlanks);
		
		// keep the TA code so can resort
		//taCode := null;
	endforeach;

	/*
	line := "Total " &amp; _tmpKPITA.terminalAreaCode &amp; Tab &amp; _tmpKPITA.getDisplayLine();
	idx := table.addItem(line.trimBlanks);
	table.accessRow(idx).fontBold := true;
	table.accessRow(idx).foreColor := _color;
	*/

end;</source>
        <Parameter name="_tmpKPITA" type="CM_KPITerminalArea"/>
        <Parameter name="_color" type="Integer"/>
        <Parameter name="_clear" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="displaySpaceTableForDate" id="d1971784-a007-4752-a1d4-75cc93f371e8">
        <source>displaySpaceTableForDate(_dateTime : TimeStamp);
// ---------------------------------------------------------------------------
// Created:		13 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/

vars
	table : CM_DataTable;
	tmpKPILocn : CM_KPILocation;
	tmpKPITA : CM_KPITerminalArea;
	tmpKPI : CM_KPI;
	line : String;
	idx : Integer;
	iter	: Iterator;
	clr : Boolean;
begin
	table := self.tblData;
	
	table.rows := table.fixedRows;
	self.tblInfo.rows := 0;

	if not self.chkSpace.value then
		return;
	endif;

	if self.myQueryAgent.allQryTerminalAreas.isEmpty then
		app.msgBox("Must Select a terminal area!", "Query Error", MsgBox_Exclamation_Mark_Icon);
		self.fldQuery.topSheet := self.shtQuery1;
		return;
	endif;
	
	if self.myQueryAgent = null then
		return;
	endif;

	iter := self.myTerminal.allKPIbyTypeTSCode.createIterator();
	self.myTerminal.allKPIbyTypeTSCode.startKeyGeq(1, _dateTime, null, iter);
	clr := true;
	foreach tmpKPI in self.myQueryAgent.allKPITerminalAreas discreteLock do
		tmpKPITA := tmpKPI.CM_KPITerminalArea;
		
		self.displaySpaceTableDetail(tmpKPITA, Black,clr);
		clr := false;
		
		line := tmpKPITA.getDisplayLine();
		idx := table.addItem(line.trimBlanks);

	endforeach;

epilog
	delete iter;		// PAR #26678

end;</source>
        <Parameter name="_dateTime" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="displayTiTable" id="04303c90-6a39-4ff4-b0e7-41132cb5f5fe">
        <source>displayTiTable(_theTI : CM_TrackedItem; _table : CM_DataTable input);
// ---------------------------------------------------------------------------
// Created:		10 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theDataLine : String;
	idx : Integer;
begin
		
	
	theDataLine := _theTI.getAttributeStringForDefArray(_table.allTblDataEntRows);

	idx := _table.addItem(theDataLine.trimBlanks);
	_table.accessRow(idx).itemObject := _theTI;
	
	self.doNotableAdd(_theTI);	
end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="displayYATable" id="d7f0c5b9-0f08-4ca9-9ac2-02f3699d9b40">
        <source>displayYATable();
// ---------------------------------------------------------------------------
// Created:     20 April 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	aTI : CM_TrackedItem;

begin
	self.tblYA.rows := self.tblYA.fixedRows;
	self.tblYAInfo.rows := 0;
	foreach aTI in self.myQueryAgent.allNonMatchTIsYA discreteLock do
		self.displayTiTable(aTI, self.tblYA);
	endforeach;
	self.tblYA.colourRows(self.colorRow1, self.colorRow2);

end;</source>
    </JadeMethod>
    <JadeMethod name="doAutoPlan" id="b036195d-f860-4982-8e84-1b886c3f0626">
        <updating/>
        <source>doAutoPlan() updating, protected;
/* ---------------------------------------------------------------------------
Created:	27 October 2010	by cnwvu1

Purpose:	#25719
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	obj		: Object;
	ti		: CM_TrackedItem;
	str		: String;
	result	: Integer;
	params	: CMIF_AutoplanParams;
	tbl		: CM_DataTable;
	tiArray	: ObjectArray;
	
begin

	if self.fldMain.topSheet = self.shtHaz then
		tiArray := self.tblHaz.allSelectedObjects.ObjectArray;
	elseif self.fldMain.topSheet = self.shtYA then
		tiArray := self.tblYA.allSelectedObjects.ObjectArray;
	else
		return;	
	endif;
	
	if tiArray = null or tiArray.size &lt; 1 then
		return;
	endif;

	create params transient;
	tiArray.copy(params.allTrackedItems);
	params.moveMode := QUEUE_MODE;
	params.myTerminalArea := null;
	params.myJob := null;
	params.showWarningWhenNoPlan := true;

	
	while true do
		str := app.myTrxUA.trxUpdateAutoplanTrackedItems(params, app.myPassport);
		if app.myPassport.trxCompletedOK then

			global.beep;
			break;
		else
			result := app.showErrorWarningDialog('Move', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
				result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;	

epilog
	delete params;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doAutoPlanTest" id="fbf5aaca-163a-40b7-a577-eec879e4a265">
        <source>doAutoPlanTest() protected;
