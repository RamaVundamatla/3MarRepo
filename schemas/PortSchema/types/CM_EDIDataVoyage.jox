    <JadeMethod name="getTIProperties" id="e6dfc7f5-d739-4d2a-beee-eaa96ada88a0">
        <source>getTIProperties(_propArray: ObjectArray io);
//
// cnwrs1 sept 2009 CCMS Messina 1008
//
vars
	popColl: PropertyNDict;
	property: Property;
begin
	inheritMethod(_propArray);
	popColl := CM_EDIVoyageTI.getProperties;
