end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRemainingAmountForJob" id="f3b6afd7-107b-4ecb-8588-03bd280f4d68">
        <source>getRemainingAmountForJob(_job : CM_Job) : String;
/*

Date		Who		Reason
15 Sep 2015	cnwer1	Initial creation PAR 36908
25 Mar 2024 navma1	ChangeRequest 63141: MTN - Code Refactor to improve finding matching cargo items using reserve details
*/

vars
	amount 			: String;
	wle 			: CM_WorkListEntry;
	invalid 		: Boolean;
	amountWeight 	: Decimal[14,4];
	amountQuantity  : Integer;
	req 			: CM_Request;
	cargoType		: CM_CargoType;
begin
	
	on Exception do app.handleDeletedObject( exception, wle, invalid );
	
	cargoType := self.myCargoType;															//25.03.2024 navma1 #63141
	
	foreach req in self.allDeliveryRequests do
		if req.myJob &lt;&gt; _job then
			continue;
		endif;
		foreach wle in req.allWorkListEntries do
			invalid := false;
			if wle.status = WLE_COMPLETED then
				continue;
			endif;
			if invalid then
				continue;
			endif;
			if cargoType &lt;&gt; null and cargoType.isBulkMulti then								//25.03.2024 navma1 #63141
				amountWeight 	:= amountWeight + wle.weight;
			else
				amountQuantity	:= amountQuantity + wle.quantity.max(1);
			endif;
		endforeach;
	endforeach;
	
	if amountWeight &gt; 0 then
		if cargoType &lt;&gt; null then
			return cargoType.getBulkTrackByDisplayForWeight(amountWeight,self.getDensity,true);	//25.03.2024 navma1 #63141
		endif;
	else
		return amountQuantity.asStringJMT;
	endif;
	
	
epilog
	
end;</source>
        <Parameter name="_job" type="CM_Job"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getReserveHeader" id="5fb04bd6-2370-4aa6-afd6-1c4d43b57ee5">
