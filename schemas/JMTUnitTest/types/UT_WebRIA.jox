// cnwmc5
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 January 2015	cnwdb2	Initial creation

*/
constants
	ReleaseCode = "WebRel" ; 

vars
	realBulkRelease : CM_BulkRelease ;
begin
	self.webServiceCall( CM_UnitTestAgent::wsBulkReleaseById.name );
epilog
	// get the real object and delete it 
	realBulkRelease :=	self.getTerminal().getBulkReleaseFromCode(ReleaseCode) ; 

	if realBulkRelease &lt;&gt; null then
		app.myTrxDA.trxDeleteBulkRelease(realBulkRelease,app.myPassport) ; 
	endif ; 
	
end;</source>
