<Class name="CMQF_ContainersPacked" id="19fa72b4-b415-435d-932c-6498bc165981">
    <superclass name="CMQF_Container"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="filterObjects" id="33c73010-55ce-4015-9898-2cfbad0d5aa9">
        <updating/>
        <source>filterObjects(_collection  : Collection input; _passport : CM_Passport) updating;
// ---------------------------------------------------------------------------
// Created:		07 February 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	ti			:	CM_TrackedItem;
	tran		:	CM_TITransaction;
	col			:	CM_TITransactionByDateTypeDict;
	endDateTime	:	TimeStamp;
	time		:	Integer;
	terminal	: CM_Terminal;
	breakOut	: Boolean;
begin
	endDateTime.setTime("23:59:59".Time);
	endDateTime.setDate(self.endDate);

	time := app.clock();
	create col transient;
	//search for pack trans
	foreach terminal in self.allTerminals do
		terminal.getTITxnsForTypeAll(TRANS_TYPE_PACK,  self.startDate.TimeStamp, endDateTime, null, self, col);
	endforeach;


	foreach tran in col do
		//if self.includeTransaction(tran) then
		if not tran.deleted then					// 13/10/2010 cnwmh5 #25859
			ti := tran.myTrackedItem;
			if ti &lt;&gt; null and self.checkStatusIncludesObject(ti, _passport, breakOut) then
				if not _collection.includes(ti) then
					_collection.add(ti);
				endif;
			endif;
		endif;
	endforeach;

epilog
	delete col;
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
</Class>
