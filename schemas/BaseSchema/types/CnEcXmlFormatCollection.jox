    <PrimAttribute name="isReportSize" id="01638939-9d84-4b0d-b3c8-eb517e1318e3">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="cnEcXmlFormatOutput" id="593a5813-79d5-4b5a-8064-2200a8dccc10">
        <source>cnEcXmlFormatOutput(pObject:Object;
					pIsDebug:Boolean;
					pMaxObjectCount:Integer io;
					pCurrentObjectCount:Integer io;
					pMaxResponseSize:Integer io): String;

vars
	xmlString		: String;
	errorStr		: String;
    referenceObject	: Object;
    theCollection	: Collection;
 	iter			: Iterator;
 	keyValue		: Any;  

begin
	on CnEcBaseXmlException do self.handleXMLException(exception, errorStr);

	if not self.isShowTagData then
		return null;
	endif;

	theCollection := pObject.getPropertyValue(self.propertyName).Collection;
	if theCollection = null then
		return null;
	endif;
    iter := theCollection.createIterator();
    
	if pObject.getPropertyValue(self.propertyName).isKindOf(ExtKeyDictionary) then 	// temporary hack for ExtKeyDictionaries NDL 14/09/00
																		// also see CnEcXmlStructureInstance::tagTagAttribute
																		// and Object::cnEcImport
		while iter.next(referenceObject) do
			if app.isValidObject(self.myFormat) and app.isValidObject(referenceObject) then
				pObject.getPropertyValue(self.propertyName).ExtKeyDictionary.getIteratorKeys(keyValue, iter);
				xmlString := xmlString &amp; '&lt;OID key="' &amp; keyValue.String &amp; '"&gt;' &amp; referenceObject.getOidString() &amp; "&lt;/OID&gt;";
			endif;
		endwhile;	
	else	
		while iter.next(referenceObject) do
			if app.isValidObject(self.myFormat) and app.isValidObject(referenceObject) then
				xmlString := xmlString &amp; getFormatXmlString(self.myFormat.formatName, referenceObject, pIsDebug, pMaxObjectCount, pCurrentObjectCount, pMaxResponseSize);
				//xmlString := xmlString &amp; referenceObject.cnEcXmlFormat(self.myFormat.formatName, pIsDebug, pMaxObjectCount, pCurrentObjectCount, pMaxResponseSize);
			endif;
		endwhile;
	endif;		

    if self.isReportSize then	
    	xmlString := "&lt;" &amp; self.tagName &amp; ' size="' &amp; theCollection.size().String &amp; '"&gt;' &amp; xmlString &amp; "&lt;/" &amp; self.tagName &amp; "&gt;";
		// KBA - 15 Sep 2000 must have double quotes around the size.
    else
	    xmlString := cnEcXmlTagIt(self.tagName, xmlString, pIsDebug);
	endif;
    if errorStr &lt;&gt; "" then
    	xmlString := xmlString &amp; cnEcXmlTagIt("ERROR", errorStr, pIsDebug);
    endif;

	return xmlString;		
epilog
	delete iter;
end;</source>
        <Parameter name="pObject" type="Object"/>
        <Parameter name="pIsDebug" type="Boolean"/>
        <Parameter name="pMaxObjectCount" type="Integer" usage="io"/>
        <Parameter name="pCurrentObjectCount" type="Integer" usage="io"/>
        <Parameter name="pMaxResponseSize" type="Integer" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcXmlOutput" id="ddacc7b7-d997-4d79-96e7-70812bf7846a">
        <source>cnEcXmlOutput(	pObject:Object;
				pIsDebug:Boolean;
				pMaxObjectCount:Integer io;
				pCurrentObjectCount:Integer io;
				pMaxResponseSize:Integer io): String;

vars
	xmlString		: String;
	errorStr		: String;
    referenceObject	: Object;
    theCollection	: Collection;
 	iter			: Iterator;
 	keyValue		: Any;  

begin
	on CnEcBaseXmlException do self.handleXMLException(exception, errorStr);

	if not self.isShowTagData then
		return null;
	endif;

	theCollection := pObject.getPropertyValue(self.propertyName).Collection;
	if theCollection = null then
		return null;
	endif;
    iter := theCollection.createIterator();
    
	if pObject.getPropertyValue(self.propertyName).isKindOf(ExtKeyDictionary) then 	// temporary hack for ExtKeyDictionaries NDL 14/09/00
																		// also see CnEcXmlStructureInstance::tagTagAttribute
																		// and Object::cnEcImport
		while iter.next(referenceObject) do
			if app.isValidObject(self.myFormat) and app.isValidObject(referenceObject) then
				pObject.getPropertyValue(self.propertyName).ExtKeyDictionary.getIteratorKeys(keyValue, iter);
				xmlString := xmlString &amp; '&lt;OID key="' &amp; keyValue.String &amp; '"&gt;' &amp; referenceObject.getOidString() &amp; "&lt;/OID&gt;";
			endif;
		endwhile;	
	else	
		while iter.next(referenceObject) do
			if app.isValidObject(self.myFormat) and app.isValidObject(referenceObject) then
				xmlString := xmlString &amp; getXmlString(self.myFormat.formatName, referenceObject, pIsDebug, pMaxObjectCount, pCurrentObjectCount, pMaxResponseSize);
				//xmlString := xmlString &amp; referenceObject.cnEcXmlFormat(self.myFormat.formatName, pIsDebug, pMaxObjectCount, pCurrentObjectCount, pMaxResponseSize);
			endif;
		endwhile;
	endif;		

    if self.isReportSize then	
    	xmlString := "&lt;" &amp; self.tagName &amp; ' size="' &amp; theCollection.size().String &amp; '"&gt;' &amp; xmlString &amp; "&lt;/" &amp; self.tagName &amp; "&gt;";
		// KBA - 15 Sep 2000 must have double quotes around the size.
    else
	    xmlString := cnEcXmlTagIt(self.tagName, xmlString, pIsDebug);
	endif;
    if errorStr &lt;&gt; "" then
    	xmlString := xmlString &amp; cnEcXmlTagIt("ERROR", errorStr, pIsDebug);
    endif;

	return xmlString;		
epilog
	delete iter;
end;</source>
