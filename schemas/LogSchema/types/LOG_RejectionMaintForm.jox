    <JadeMethod name="getDescription" id="e5da6034-032a-4d2e-b1bf-a554785943a9">
        <source>getDescription() : String protected;

// cnwdvb1 28 November 2002 

vars

begin
	
	if self.selection = LOGID then
		if self.myLog &lt;&gt; null then
			return 'Log(' &amp; self.myLog.id &amp; ')';
		endif;
	elseif self.selection = LOGDOCKET then
		if self.mySelectedDocketDef &lt;&gt; null then
			return 'Docket(' &amp; self.mySelectedDocketDef.myBol.number &amp;')';
		endif;
	elseif self.selection = LOGLOCATION then
		if self.mySelectedDocketDef &lt;&gt; null then
			return 'Old location(' &amp; self.mySelectedDocketDef.myLocationsController.getID() &amp; ')';
		endif;
	endif;
	return null;

end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="loadCombos" id="8d244083-c762-46fe-9700-401e1ecdd4fa">
        <source>loadCombos() protected;

vars
	lc			: CM_LocationsController;
begin
	
	lc := self.cmbLocation.listObject.CM_LocationsController;
	
	inheritMethod();
	
	if self.cmbLocation.findObject(lc) &gt; - 1 then 
		self.cmbLocation.listObject := lc;
	endif;

	// Setup combo boxes for reason codes and recovery codes.
//	self.myAssistant.comboBoxGeneral(self.cmbReason, app.myRoot.allLogRejectCodes);
//	self.myAssistant.comboBoxGeneral(self.cmbRecovery, app.myRoot.allLogRejectRecoveryCodes);

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="saveTrackedItems" id="f8c0a213-1712-4f47-ab0a-4173d8837d93">
        <updating/>
        <source>saveTrackedItems(): Boolean protected, updating;

vars

	rtnValue	: Boolean;
	reason		: String;
	recovery	: String;
	comment		: String;
	theReason	: CM_LogRejectCode;
	theRecovery	: CM_LogRejectRecoveryCode;
	cmif		: CMIF_Remote;
	manager		: CM_RemoteDataManagerInternal;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
		
begin

	if not self.validateForSave() then	//PAR 21688 Dec 2009
		return false;
	endif;
	
	reason := self.tblActionData.getValueByName(ETRow_ReasonCode).String;
	recovery := self.tblActionData.getValueByName(ETRow_RecoveryCode).String;
	comment := self.tblActionData.getValueByName(ETRow_Comment).String;
	if self.btnBackground.value then
		create manager transient;
		create cmif transient;
		cmif.transactionType	:= manager.REJECTRQ;
		cmif.reason				:= reason;
		cmif.recovery			:= recovery;
		cmif.terminal			:= self.myTerminal.code;
		self.getTrackedItems(cmif.allTis);				
		rtnValue := manager.processInternal(cmif, app.myPassport);
	else
		self.myCMIFMonitor.partsInJob := self.allTrackedItems.size;
	   	self.myCMIFMonitor.partsDone := 0;
	   	self.pbProgressBar.visible := true;   	
	   	self.updateProgress(self.myCMIFMonitor);	
		
			//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			app.myTrxUA.trxRejectTrackedItems(self.allTrackedItems, reason, recovery, comment, self.getDescription, app.myPassport);
		
			if app.myPassport.trxCompletedOK then
				rtnValue := true;
				break;
			else
				theResult := app.showErrorWarningDialog('Reject Tracked Item', app.myPassport, ErrWarnMode_Update);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			rtnValue := false;
			break;
			
		endwhile;
	
		return rtnValue;
		
	endif;

	if (not app.myPassport.trxCompletedOK) then
		app.showErrorWarningDialog('Reject Tracked Item', app.myPassport, ErrWarnMode_Update);
		self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
	else
		self.clearErrorWarnings();
		rtnValue := true;
	endif;
	
epilog
	delete manager;
	delete cmif;
	return rtnValue;

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setActionTableView" id="8f4a7c33-456b-49ae-8d0c-614c96f85dd3">
