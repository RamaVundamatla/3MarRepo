    <JadeMethod name="userNotify" id="b3bc7cf0-6dfb-4acb-8da2-af835cd3bbe1">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
04 December 2009	cnwndl1	Initial creation
Dec 2010 			cnwjre1 par 26608 snap shot definition form issues, add the selector notification
*/

vars

begin

	// if this event is not one of the required events just return.
	if eventType = EVENT_SummaryTable_Update or eventType = EVENT_SummaryTable_Delete or
	   eventType = Event_Selector_Create or eventType = Event_Selector_Update or eventType = Event_Selector_Delete then
		self.handleNotification(eventType, theObject, eventTag, userInfo);
	endif;
	
epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</GUIClass>
