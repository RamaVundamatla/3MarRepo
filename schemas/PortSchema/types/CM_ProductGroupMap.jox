	endforeach;

end;</source>
        <Parameter name="_child" type="CM_FinancialObject"/>
        <Parameter name="_paths" type="HugeStringArray" usage="input"/>
        <Parameter name="_items" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getBank" id="d3f523f1-286f-4c1f-915b-da56538a798f">
        <source>getBank() : CM_Bank;
// ---------------------------------------------------------------------------
// Created:		02 October 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if self.myCargoTypeMap &lt;&gt; null then
		return self.myCargoTypeMap.getBank();
	endif;
	
	return null;
end;</source>
        <ReturnType type="CM_Bank"/>
    </JadeMethod>
    <JadeMethod name="getItemCode" id="e2a583e7-3bc0-4505-8172-9e73d4a46fda">
        <source>getItemCode() : String;
// 23659 Apr 2010 invoice transaction map extract to use codes instead of descriptions
vars
	code : String;
begin
	if self.myProductGroup = null then
		code := CM_FinancialObject.Extract_Default;
	else
		code := self.myProductGroup.code &amp; "| " &amp; self.myProductGroup.description;	// 33095 use | as delimiter, to allow for spaces in the code
	endif;
	return code;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPath" id="fbf1c230-ecd8-4892-87d3-aba6b07c0cc7">
        <source>getPath() : String;

vars
	path	: String;
begin
	path := self.itemName;
	return self.myCargoTypeMap.getPath() &amp; "/" &amp; path;
	
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPath2" id="81a5f72b-69ca-4ce7-b450-61fcfe0deaef">
        <source>getPath2() : String;

vars
	path	: String;
begin
	if self.myProductGroup = null then
		path := "Default";
	else
		path := self.itemName;
	endif;
	return self.myCargoTypeMap.getPath2() &amp; Tab &amp; path;
	
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getProductMap" id="48ad5535-d536-4b95-9c88-ca0efa7c64ae">
        <source>getProductMap(_ti : CM_TrackedItem) : CM_ProductMap;
// ---------------------------------------------------------------------------
// Created:		09 February 2006  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
//Date			Who		Reason
//22 March 2018	jlgndl1	Initial creation
//06 March 2023	navmk20	Task 56140: EUP Inv Config - Surcharge Logging
//23 Oct 2024	navlw1  JIRA-33107: Invoice Logging Use Levels
//

vars
	product : CM_Product;
	productMap : CM_ProductMap;
begin
	product := _ti.myProduct;
	if product = null then
		app.invLog("Sub Cargo Type map for DEFAULT, cargo has no product", LogINFO.String); // TFS 37994
		return self.allProductMaps[null]; // DEFAULT
	endif;
	
	productMap := self.allProductMaps[product.code];
	if productMap &lt;&gt; null then
		app.invLog("Sub Cargo Type map found for product " &amp; product.code, LogINFO.String); // TFS 37994
	endif;
	if productMap = null then
		app.invLog("Sub Cargo Type map for DEFAULT, no map entry for product " &amp; product.code, LogINFO.String); // TFS 37994
		return self.allProductMaps[null]; // DEFAULT
	endif;
	return productMap;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_ProductMap"/>
    </JadeMethod>
    <JadeMethod name="getTranMapBreadCrumb" id="bb6ccf74-c020-40f6-946d-313c37240b21">
        <source>getTranMapBreadCrumb(): String;
/*
Purpose:			
Date		Who		Reason
19 October 2016	cnwab1	Initial creation
*/

vars

begin
	return self.myCargoTypeMap.getTranMapBreadCrumb() &amp; "/" &amp; itemName;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initialise" id="475b8014-9def-4353-8aa4-5c0c4e240ae0">
        <source>initialise(_bank : CM_Bank);

vars
	prodMap : CM_ProductMap;
begin
	prodMap := self.allProductMaps[null]; // default;
	if prodMap = null then
		create prodMap;
		prodMap.setMyProduct(null); //default
		prodMap.setMyProductGroupMap(self);
	endif;
	prodMap.initialise(_bank);

end;</source>
        <Parameter name="_bank" type="CM_Bank"/>
    </JadeMethod>
    <JadeMethod name="itemName" id="f2fca82c-42b2-4947-a9a1-b2015a4878da">
        <methodInvocation>mapping</methodInvocation>
        <source>itemName(set: Boolean; _value: String io) mapping;
// ---------------------------------------------------------------------------
// Created:		09 February 2006  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if set then
		return;
	else
		if self.myProductGroup = null then
			//_value := "Default (Product Group)"; // - " &amp; self.myCargoTypeMap.getTIClassName();
			_value := app.getErrorString(CM_Default) &amp; " (" &amp; app.getErrorString(Cargo_subtype_group) &amp;")";	//PAR 20568 SEp 2009
		else
			_value := self.myProductGroup.description;
		endif;
	endif;


end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="replaceInvoiceLineTypes" id="c730bc3f-24e2-40a3-bd18-b1fb85a49e59">
        <source>replaceInvoiceLineTypes(_oldILD : CM_InvoiceLineDesc; _newILD : CM_InvoiceLineDesc) : Integer;
// 32311
vars
	count	: Integer;
	productMap		: CM_ProductMap;
begin
	foreach productMap in self.allProductMaps do
		count := count + productMap.replaceInvoiceLineTypes(_oldILD, _newILD);
	endforeach;
	return count;
end;
</source>
        <Parameter name="_oldILD" type="CM_InvoiceLineDesc"/>
        <Parameter name="_newILD" type="CM_InvoiceLineDesc"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="2e2430a2-f8f5-40f4-b7e9-348a447b9102">
        <updating/>
        <source>setForCreate(_pxyProductGroupMap : CM_ProductGroupMap) updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	_pxyProductGroupMap.raiseExceptionIfNotTransient(method);
	self.raiseExceptionIfTransient(method);
	
	self.myProductGroup := _pxyProductGroupMap.myProductGroup;
	self.myCargoTypeMap := _pxyProductGroupMap.myCargoTypeMap;
	
	self.initialise(_pxyProductGroupMap.myCargoTypeMap.transactionMap.bank);

end;</source>
        <Parameter name="_pxyProductGroupMap" type="CM_ProductGroupMap"/>
    </JadeMethod>
