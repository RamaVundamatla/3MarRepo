    <JadeMethod name="buildBOLInCargoMenu" id="bb4a38ff-494b-4c7c-9f6c-534073ad7888">
        <updating/>
        <source>buildBOLInCargoMenu(_bolIn: CM_BOLIn input)updating;
//----------------------------------------------------------------
//	Created:	06 August 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 14/06/2010	cnwcs5		par 24342 - Changes to the way stops are maintained
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	cargoMenu,
	tmpMenu	: MenuItem;

begin
	if (not app.getMyUser.canDo(self.myTerminal, PmAdmCargoEnquiryMaint)) then	
		return;
	endif;
	
	self.mnuDeleteInterTerminal.visible := false;
	cargoMenu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuDeleteInterTerminal, false); 

	self.mnuCargoConnect.visible := false;
	self.mnuCargoAttach.visible := false;
	self.mnuCargoUnplan.visible := false;
	self.mnuCargoMoveIt.visible := false;
	self.mnuCargoAP.visible 	:= false;
	self.mnuCargoTestAp.visible	:= false;
	self.mnuCargoTestAPChild.visible	:= false;	//15 July 2014	NDL	Par 34559 
	self.mnuDeleteInterTerminal.visible := false;
	self.mnuCargoUnplan.visible := false;
	self.mnuBookingRefDiscrep.visible := false;	//09 Sep 2009 NDL CCMS 1609 / Par 20521
	self.mnuBookingRefDiscrep.caption := app.getErrorString(Show_booking_referen_discrep) &amp; "...";
	
	// AKB2004FEB build unplan/unqueue menu correctly to show multiple planned moves - DLRs from here
	cargoMenu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuCargo, false); 

	tmpMenu := self.zCloneMenu(cargoMenu, self.mnuCargoConnect, true); 
	tmpMenu := self.zCloneMenu(cargoMenu, self.mnuCargoAttach, true); 
//	tmpMenu := self.zCloneMenu(cargoMenu, self.mnuCargoUnplan, true);  AKB2004FEB removed
	tmpMenu := self.zCloneMenu(cargoMenu, self.mnuCargoPack, true);
	
	self.mnuCargoUnassign.visible := false;
	tmpMenu := self.zCloneMenu(cargoMenu, self.mnuCargoUnassign, true);
	
	self.mnuCargoMoveIt.userObject := _bolIn;	
		
	self.mnuCargoAP.visible := false;
	
	tmpMenu := self.buildCargoMenuXtra(cargoMenu);

	tmpMenu := self.zCloneMenu(cargoMenu, self.mnuCargoMoveIt, true); 	
	tmpMenu := self.zCloneMenu(cargoMenu, self.mnuCargoTestAp, true); 	
	tmpMenu := self.zCloneMenu(cargoMenu, self.mnuCargoAP, true); 	

	tmpMenu := self.zCloneMenu(cargoMenu, self.mnuCargoStops, true); 
	//self.doBuildMnuBOLInStops(tmpMenu, _bolIn);	par 24342
epilog

end;</source>
        <Parameter name="_bolIn" type="CM_BOLIn" usage="input"/>
    </JadeMethod>
    <JadeMethod name="buildCargoGroupMenu" id="ca2e07ea-84da-4f8a-a3f2-2b976595ef34">
        <updating/>
        <source>buildCargoGroupMenu(	_cargoGroup : CM_CargoGroup input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03/06/2015	cnwndl1	Initial creation	Par 36338
30/03/2016	cnwrs1	TFS 1546 POL - Unpacking Process Options
17/01/2018	jlgdap1	TFS 36658 STWR Cargo Scanning Enhancements
28 Oct 2022 navtnr20 ChangeRequest 54967: EUP - INB/OUT - Operational Instructions
*/

vars

	cargoMenu,
	tmpMenu,
	tmpMenu2	: MenuItem;
//	notifiedCG : CM_NotifiedCargoGroup;				// TFS 36658

begin

	if (not self.canAccessCargoMenu) then
		self.mnuCargo.visible := false;
		return;
	endif;

	self.mnuShowAlphabetised.visible := false;
	self.mnuCargoCreateItem.visible := false;
	self.mnuCargoCreateItem.caption := app.getErrorString(ADD_Cargo_group_item);
	self.mnuCargo.caption := app.getErrorString(Cargo_group);
	self.mnuCargoLabelPrint.visible := false;
	self.mnuWeighCargo.visible := false;
	self.mnuAdditionalStorage.visible := false;
	self.mnuCargoMoveIt.visible := false;
	self.mnuCargoTestAp.visible := false;
	self.mnuCargoAP.visible := false;
	self.mnuRequestTask.visible := false;
	self.mnuCreateWorkOrder.visible := false;
	self.mnuCargoTaskAdd.visible := false;
	self.mnuCargoTaskComplete.visible := false;
	self.mnuCargoTaskRemove.visible := false;
	self.mnuTaskRemarks.visible := false;
	self.mnuTaskInstruction.visible := false;	//28.10.2022 navtnr20 TFS 54967
	self.mnuShowInTerminalArea.visible := false;
	self.mnuCargoBulkTrans.visible := false;
	self.mnuCargoStops.visible := false;
	self.mnuCargoSetGrade.visible := false;
	self.mnuPackCargo.visible := false;
	self.mnuUnpackCargo.visible := false;
	self.mnuCargoAttachGenSet.visible := false;
	self.mnuCargoDetachGenSet.visible := false;
	self.mnuCargoConnect.visible := false;
	self.mnuSplitBB.visible := false;
	self.mnuMultiSplitCargo.visible := false;	//04 Jun 2020	NDL	TFS 49401
	self.mnuWeighCargo.visible := false;
	self.mnuPackageBulk.visible := false;
	self.mnuAggregateBB.visible := false;
	self.mnuBlend.visible := false;	//24 May 2021	NDL	TFS 51243
	self.mnuMergeBB.visible := false;
	self.mnuDiscrepancyBB.visible := false;
	self.mnuEraseChildCargo.visible := false;
	self.mnuNonTrans.visible := false;
	self.mnuBookingRefDiscrep.visible := false;
	self.mnuCargoAttach.visible := false;
	self.mnuDABooking.visible := false;	//07 Nov 2016	NDL	TFS 2419
	self.mnuDAReserve.visible := false;	//07 Nov 2016	NDL	TFS 2419
	self.mnuDeleteCargoGroup.visible := false;		//13 Aug 2018	NDL	TFS 40120
	
	self.mnuCargoMoveIt.caption := app.getErrorString(Move_It_Menu_Caption);				// TFS 36658
		
	if self.canUpdate then
	
		self.mnuCargoCreateItem.visible := true;
		
		if _cargoGroup &lt;&gt; null then
			self.mnuCargoStops.visible := true;
			self.mnuComplete.visible := not _cargoGroup.isComplete;	//21 Aug 2015	NDL Par 36608
			self.mnuComplete.userObject := _cargoGroup;
			
	//		notifiedCG := self.myTerminal.getNotifiedGroupForCargoGroup(_cargoGroup);		// TFS 36658
	//		if notifiedCG &lt;&gt; null and self.moveModeForm = PLANNING_MODE then				// TFS 36658
			if _cargoGroup &lt;&gt; null and self.moveModeForm = PLANNING_MODE then	//01 Oct 2018	NDL	TFS 39186
				self.mnuCargoMoveIt.visible := true;										// TFS 36658
			//	self.mnuCargoMoveIt.userObject := notifiedCG;								// TFS 36658
				self.mnuCargoMoveIt.userObject := _cargoGroup;
				self.mnuCargoMoveIt.caption := app.getErrorString(Update_Default_Location);	// TFS 36658
			endif;																			// TFS 36658
		endif;
		
		cargoMenu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuCargo, false);
	
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuCargoLabelPrint, true);
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuCargoCreateItem, true);
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuWeighCargo, true);
		
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuCargoPack, true);
		tmpMenu.caption := "Re-evaluate Free Storage Days";
		tmpMenu.visible := false;
		
		tmpMenu := self.zCloneMenu(cargoMenu,self.mnuAdditionalStorage,true);
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuCargoMoveIt, true); 
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuCargoTestAp, true); 
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuCargoAP, true);
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuRequestTask, true);
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuCreateWorkOrder, true);
		if self.canAccessTodoTasksAddRemove and _cargoGroup &lt;&gt; null then
			self.mnuCargoTaskAdd.visible := true;	//06 Oct 2015	NDL	Par 37011
			tmpMenu := self.zCloneMenu(cargoMenu, self.mnuCargoTaskAdd, true);
			self.mnuCargoTaskAdd.helpKeyword := CMUI_TasksForm.name &amp; ":" &amp; TASK_MODE_ADD.String;	//06 Oct 2015	NDL	Par 37011	
		endif;
		if self.canAccessTodoTasksComplete and _cargoGroup &lt;&gt; null then
			self.mnuCargoTaskComplete.visible := true;//06 Oct 2015	NDL	Par 37011
			tmpMenu := self.zCloneMenu(cargoMenu, self.mnuCargoTaskComplete, true);
			self.mnuCargoTaskComplete.helpKeyword := CMUI_TasksForm.name &amp; ":" &amp; TASK_MODE_COMPLETE.String;//06 Oct 2015	NDL	Par 37011
			self.mnuTaskInstruction.visible := true;//28.10.2022 navtnr20 TFS 54967
			tmpMenu := self.zCloneMenu(cargoMenu, self.mnuTaskInstruction, true);//28.10.2022 navtnr20 TFS 54967
			self.mnuTaskInstruction.helpKeyword := CMUI_TasksForm.name &amp; ":" &amp; self.TASK_MODE_INSTRUCTION.String;//28.10.2022 navtnr20 TFS 54967
		endif;
		if self.canAccessTodoTasksAddRemove and _cargoGroup &lt;&gt; null then
			self.mnuCargoTaskRemove.visible := true;//06 Oct 2015	NDL	Par 37011
			tmpMenu := self.zCloneMenu(cargoMenu, self.mnuCargoTaskRemove, true);
			self.mnuCargoTaskRemove.helpKeyword := CMUI_TasksForm.name &amp; ":" &amp; TASK_MODE_REMOVE.String;	//06 Oct 2015	NDL	Par 37011
			self.mnuTaskRemarks.visible := true;//06 Oct 2015	NDL	Par 37011
			tmpMenu := self.zCloneMenu(cargoMenu, self.mnuTaskRemarks, true);//06 Oct 2015	NDL	Par 37011
			self.mnuTaskRemarks.helpKeyword := CMUI_TasksForm.name &amp; ":" &amp; TASK_MODE_REMARKS.String;//06 Oct 2015	NDL	Par 37011
		endif;
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuShowInTerminalArea, true);
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuCargoBulkTrans, true);
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuCargoStops, true);
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuCargoSetGrade, true);
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuPackCargo, true);
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuUnpackCargo, true);
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuMergeBB, true);
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuAggregateBB, true);
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuBlend, true);	//24 May 2021	NDL	TFS 51243
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuPackageBulk, true);
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuSplitBB, true);
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuMultiSplitCargo, true);//04 Jun 2020	NDL	TFS 49401
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuDiscrepancyBB, true);
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuCargoConnect, true); 
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuCargoAttach, true); 
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuCargoAttachGenSet, true); 
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuCargoDetachGenSet, true); 
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuWeighCargo, true);
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuEraseChildCargo, true);
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuNonTrans, true);
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuBookingRefDiscrep, true);	
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuComplete, true);
		if _cargoGroup &lt;&gt; null then	//13 Aug 2018	NDL	TFS 40120
			self.mnuDeleteCargoGroup.visible := true;
			self.mnuDeleteCargoGroup.userObject := _cargoGroup;
			tmpMenu := self.zCloneMenu(cargoMenu, self.mnuDeleteCargoGroup, true);	
		endif;
		
	endif;

epilog

end;</source>
        <Parameter name="_cargoGroup" type="CM_CargoGroup" usage="input"/>
    </JadeMethod>
    <JadeMethod name="buildCargoMenu" id="8681a354-3230-46e1-b9b2-7c1f8e826253">
        <updating/>
        <source>buildCargoMenu(_ti: CM_TrackedItem input)updating;
//----------------------------------------------------------------
//	Created:	06 August 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 08/09/2008	concms1	par17884/ccms 1742 - job requests interim solution
//						show job request menu item if user has permission
//						hide totdo task menus if user is view only and has permission to hide set
// 30/10/2008	consw1	SFW1030 - Remove unused auto plan flags
// 20/05/2010	cnwdap1	CCMS 1116 Tranship changes - remove "Show Export/Import tranship...." menu items
// 14/06/2010	cnwcs5	par 24342 - changes to the way stops are maintained
// 22/05/2013 	cnwer1 	CCMS 2274 - breakbulk changes if cargo was merged cargo menus are disabled
//30 Mar 2016	cnwrs1	TFS 1546 POL - Unpacking Process Options
//14 Aug 2017	cnwma1	TFS #5695:STWO - Re-Calculate Volumes on Forms and EDI
// 13/03/2018	jlgsl4	TFS 37573 no pack/unpack for cargo on transport

	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
// 02/05/2022	jlizm1	TFS 53084 GPHA revceival/release of tranship cargo
// 28 Oct 2022 navtnr20 ChangeRequest 54967: EUP - INB/OUT - Operational Instructions
// 14/04/2023	navkc1	CR 57036 Task 57590: UI - Cargo Enquiry Create New Cargo
// 21 June 2023 navmv20 CR 58373 Task 58381: Jade - Future Storage Additional Days
vars
	cargoMenu,
	tmpMenu,
	tmpMenu2	: MenuItem;
	theAction 	: Integer;
	container 			: CM_Container;
	canTestAutoPlan		: Boolean;
	tmpBR 				: CM_BulkRelease;
	obj 				: Object;
	useInterimConfig, 
	useInterimForm, 
	useOldMenus			: Boolean;	// par 17884
	locale 				: CM_Locale;
	queueEntry			: CM_RTQueueEntry;
	useTaskForm			: Boolean;
	resDetailSet : CM_ReserveDetailSet;
	bookingItemSet : CM_BookingRefItemSet;
	errMsg : String;	//08 Jan 2018	NDL	TFS 36437
	preNoteAllowed : Boolean;	//02 Nov 2018	NDL	TFS 41736
	ti : CM_TrackedItem;
begin

	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	self.hideToDoTaskMenus();

	if (not self.canAccessCargoMenu) then
		self.mnuCargo.visible := false;
		return;
	endif;
	
	//epr CCMS 2274 22/5/13 if has been merged do not allow users to do any more transactions

	if _ti.hasBeenMerged then
		self.mnuCargo.visible := false;
		cargoMenu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuCargo, false); 
		return;
	endif;
	
	if self.canUpdate and
	   (_ti.myInTransitTerminalFrom &lt;&gt; null or
	   _ti.myInTransitTerminalTo &lt;&gt; null) then
		self.mnuDeleteInterTerminal.visible := true;
		self.mnuDeleteInterTerminal.userObject := _ti;
		self.mnuCargo.visible := false;
		cargoMenu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuCargo, false); 
		cargoMenu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuDeleteInterTerminal, false); 
		return;
	else
		self.mnuDeleteInterTerminal.visible := false;
		cargoMenu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuDeleteInterTerminal, false); 
	endif;

	self.mnuCargoConnect.visible := false;
	self.mnuCargoAttach.visible := false;
	self.mnuCargoAttachGenSet.visible := false;	// Par17775. ccms1405. APM Yard Ops, new generator types
	self.mnuCargoDetachGenSet.visible := false;	// Par17775. ccms1405. APM Yard Ops, new generator types
	self.mnuCargoUnplan.visible := false;
	self.mnuCargoMoveIt.visible := false;
	self.mnuCargoAP.visible 	:= false;
	self.mnuCargoTestAp.visible	:= false;
	self.mnuCargoTestAPChild.visible	:= false;	//15 July 2014	NDL	Par 34559 
	self.mnuCargoShowOverstow.visible 	:= false;	// PAR 21532 CCMS SFW 1025
	self.mnuCargoMoveOverstow.visible 	:= false;	// PAR 21532 CCMS SFW 1025
	self.mnuDeleteInterTerminal.visible	:= false;
	self.mnuCargoCreateItem.visible		:= false; //ccms 1093 cnwrs1 feb 2008
//	self.mnuAdditionalStorage.visible:=false;
	self.mnuBookingRefDiscrep.visible := false;	//09 Sep 2009 NDL CCMS 1609 / Par 20521
	self.mnuSplitBB.visible := false;
	self.mnuMultiSplitCargo.visible := false;	//04 Jun 2020	NDL	TFS 49401
	self.mnuMergeBB.visible := false;
	self.mnuAggregateBB.visible := false;
	self.mnuBlend.visible := false;	//24 May 2021	NDL	TFS 51243
	self.mnuPackageBulk.visible := false;
	self.mnuDiscrepancyBB.visible := false;
	self.mnuUnQueueSel.visible := false;
	self.mnuWeighCargo.visible := false;	//13 Mar 2014	NDL	Par 33268
	self.mnuUnpackCargo.visible:=false; //epr par 34472 4/7/14
	self.mnuPackCargo.visible:=false;  //epr par 34472 4/7/14
	self.mnuEraseChildCargo.visible := false;		//cnwmc5 - 8 July 2014 - PAR 34086
	self.mnuComplete.visible := false;	//21 Aug 2015	NDL Par 36608
	self.mnuDABooking.visible := false;	//07 Nov 2016	NDL	TFS 2419
	self.mnuDAReserve.visible := false;	//07 Nov 2016	NDL	TFS 2419
	self.mnuAutoVolumeCalculate.visible := false; // 14.8.2017 cnwma1 TFS #5695
	self.mnuDeleteCargoGroup.visible := false;		//13 Aug 2018	NDL	TFS 40120
	self.mnuCreateOnboardCargo.visible:= false;		// 14/04/2023	navkc1	CR 57036 Task 57590
	self.mnuFutureStAnn.visible := false; //21/06/2023 navmv20 CR 58373 Task 58381
	
	self.mnuBookingRefDiscrep.caption := app.getErrorString(Show_booking_referen_discrep) &amp; "...";
	if self.tblData.allSelectedObjects.size &gt; 0 then
		foreach obj in self.tblData.allSelectedObjects do
			if obj.isKindOf(CM_TrackedItem) and not obj.CM_TrackedItem.allBookingRefDiscreps.isEmpty then
				self.mnuBookingRefDiscrep.visible := true;
				break;
			endif;
		endforeach;
	elseif not _ti.CM_TrackedItem.allBookingRefDiscreps.isEmpty then
		self.mnuBookingRefDiscrep.visible := true;
		self.mnuBookingRefDiscrep.userObject := _ti;
	endif;	

	//CCMS 1086 Anca Rosca 20/11/2007
	
	self.mnuNonTrans.visible := false;
	self.mnuNonTrans.caption := null;
	self.mnuInterModal.visible := false;	// TFS 53084
	if self.tblData.allSelectedObjects.size &gt; 0 then
		foreach obj in self.tblData.allSelectedObjects do
			if obj.isKindOf(CM_TrackedItem) and obj.CM_TrackedItem.isTranshipItem then
				self.mnuNonTrans.visible := true;
				self.mnuNonTrans.translateCaption_Unconditional( Xlat_0014640, app.myCurrentLocale );
				if app.myRoot.allowTranshipInterModal then	// TFS 53084
					self.mnuInterModal.visible := true;		// TFS 53084
				endif;
				break;
			endif;
		endforeach;
	elseif _ti.CM_TrackedItem.isTranshipItem then
		self.mnuNonTrans.visible := true;
		self.mnuNonTrans.translateCaption_Unconditional( Xlat_0014640, app.myCurrentLocale );
		if app.myRoot.allowTranshipInterModal then	// TFS 53084
			self.mnuInterModal.visible := true;		// TFS 53084
		endif;
	endif;
	
	//cnwmc5 - 8 August 2014 - PAR 34086
	if self.tblData.allSelectedObjects.size &gt; 0 then
		foreach obj in self.tblData.allSelectedObjects do
			if obj.isKindOf(CM_TrackedItem) 
			and obj.CM_TrackedItem.isChild 
			and (obj.CM_TrackedItem.isPreNote or obj.CM_TrackedItem.isOnShip) then
				self.mnuEraseChildCargo.visible := true;
				break;
			endif;
		endforeach;
	endif;
	//21/06/2023 navmv20 CR 58373 Task 58381 - start
	if self.tblData.allSelectedObjects.size &gt; 0 then // ### TFS BUG 58953 29JUN2023 NAVAB1
		foreach ti in self.tblData.allSelectedObjects as CM_TrackedItem do // ### TFS BUG 58953 29JUN2023 NAVAB1
//			if obj.isKindOf(CM_TrackedItem) then
//				if ti.getTransactionOfType(TRANS_TYPE_FUTURE_STORAGE) &lt;&gt; null then
				if ti.hasStartedFutureStorageProcess()  then // ### TFS BUG 58953 29JUN2023 NAVAB1
					self.mnuFutureStAnn.visible := true;
					break;
				endif;
			//endif;
		endforeach;
	  // ### TFS BUG 58953 29JUN2023 NAVAB1
	else // if on 'double click' view the selectedObjects is empty and the _ti is what is being edited
		if _ti.getTransactionOfType(TRANS_TYPE_FUTURE_STORAGE) &lt;&gt; null 
		or _ti.getBGPFutureActor(CM_FutureStorageProcess) &lt;&gt; null then 
			self.mnuFutureStAnn.visible := true;
		endif;
	
	endif;
	//21/06/2023 navmv20 CR 58373 Task 58381 - end
	// 20 Jan 2010 NDL CCMS MES 1004
	self.mnuCargoLabelPrint.visible := true;
	self.mnuCargoLabelPrint.userObject := _ti;
	
	if self.canUpdate then
		//24 Jun 2013 EPR par 31727
		if _ti.isNotified then
			preNoteAllowed := self.myTerminal.getConfig( AllowPrenoteDiscrep ).Boolean;
		endif;
		self.mnuDiscrepancyBB.visible := _ti.canMergeBreakBulk and (_ti.isOnSite or _ti.isOnShip or preNoteAllowed); //epr par 32332 2/9/13
		self.mnuDiscrepancyBB.userObject := _ti;
		
		//24 Jun 2013	NDL	Par 31884
		self.mnuMergeBB.visible := _ti.canMergeBreakBulk and _ti.isOnSite;
		self.mnuMergeBB.userObject := _ti;
		
		self.mnuAggregateBB.visible := _ti.canMergeBreakBulk and _ti.isBulkByQuantity and _ti.isOnSite;
		self.mnuAggregateBB.userObject := _ti;
		
		//24 May 2021	NDL	TFS 51243
		self.mnuBlend.visible := ( _ti.myCargoType.isBreakBulk or _ti.myCargoType.isBulk ) and _ti.isOnSite and not _ti.isChild and not _ti.hasBeenMerged;
		self.mnuBlend.userObject := _ti;
		
		self.mnuPackageBulk.visible := ( _ti.isBulkByVolume or _ti.isBulkByWeight ) and _ti.isOnSite;
		self.mnuPackageBulk.userObject := _ti;
		
		self.mnuWeighCargo.visible := _ti.isWeighBridgeWeighable(null,errMsg);	//13 Mar 2014	NDL	Par 33268
		self.mnuWeighCargo.userObject := _ti;	//13 Mar 2014	NDL	Par 33268
	
	//	if _ti.canSplitTotalQuantity and _ti.isOnSite then	//14 Jun 2013	NDL	Par 31826
		if _ti.canSplitTotalQuantity and (_ti.isOnSite  or _ti.isOnShip ) then	//14 Jul 2015	NDL	Par 36550
			self.mnuSplitBB.visible := true;
			self.mnuSplitBB.userObject := _ti;
			//04 Jun 2020	NDL	TFS 49401
			if _ti.isOnSite then
				self.mnuMultiSplitCargo.visible := true;
				self.mnuMultiSplitCargo.userObject := _ti;
			endif;
			
		elseif _ti.isKindOf(CM_Container) then
		
			container := _ti.CM_Container;
			self.mnuCargoConnect.caption := self.doBuildConnectCaption(_ti,theAction);
			if container.isPortHole then
				self.mnuCargoConnect.visible := true;
				self.mnuCargoConnect.userObject := _ti;
			endif;
			if container.requiresPower then
				self.mnuCargoConnect.visible := true;
				self.mnuCargoConnect.userObject := _ti;
			endif;
			if container.hasCOU then
				self.mnuCargoAttach.visible := true;
				self.mnuCargoAttach.userObject := _ti;
			endif;
			if container.isPortHole then
				self.mnuCargoAttach.visible := true;
				self.mnuCargoAttach.userObject := _ti;
			endif;
			if container.isReefer then	// Par17775. ccms1405. APM Yard Ops, new generator types
				if container.getGenerator = null then
					self.mnuCargoAttachGenSet.visible := true;
					self.mnuCargoAttachGenSet.userObject := _ti;
				else
					self.mnuCargoDetachGenSet.visible := true;
					self.mnuCargoDetachGenSet.userObject := _ti;
				endif;
			endif;
			if self.mnuCargoConnect.caption = null then // AKB2004AUG added
				self.mnuCargoConnect.visible := false; // AKB2004AUG added
				self.mnuCargoConnect.userObject := null; // AKB2004AUG added
			endif;
			if not container.isEmpty() then
				self.mnuCargoCreateItem.visible := true;
				self.mnuCargoCreateItem.userObject := _ti;
			endif;
			
		elseif _ti.isKindOf(CM_TILC) then	// Par17775. ccms1405. APM Yard Ops, new generator types
			if _ti.CM_TILC.myGenerator = null then
				self.mnuCargoAttachGenSet.visible := true;
				self.mnuCargoAttachGenSet.userObject := _ti;
			else
				self.mnuCargoDetachGenSet.visible := true;
				self.mnuCargoDetachGenSet.userObject := _ti;
			endif;
			
			// 14/04/2023	navkc1	CR 57036 Task 57590
			if _ti.isMAFI() then
				self.mnuCreateOnboardCargo.visible := true;
				self.mnuCreateOnboardCargo.userObject := _ti;
			endif;
		endif;
		
		//epr par 34472 4/7/14
		if _ti.myParent &lt;&gt; null then
			self.mnuUnpackCargo.visible:=app.getMyUser.canDo(self.myTerminal, PmAdmLclpackMaint) // TFS 37573
				and not _ti.isOnTransport; // TFS 37573
			self.mnuUnpackCargo.userObject:=_ti;
		else
			if _ti.isKindOf(CM_Cargo) then
				self.mnuPackCargo.visible:=app.getMyUser.canDo(self.myTerminal, PmAdmLclpackMaint) // TFS 37573
					and not _ti.isOnTransport; // TFS 37573
				self.mnuPackCargo.userObject:=_ti;
			endif;
		endif;	
		
	endif;
	
	// AKB2004FEB build unplan/unqueue menu correctly to show multiple planned moves - DLRs from here
	cargoMenu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuCargo, false); 

	if self.canUpdate then
	
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuCargoLabelPrint, true);
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuMergeBB, true);
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuAggregateBB, true);
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuBlend, true);	//24 May 2021	NDL	TFS 51243
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuPackageBulk, true);
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuSplitBB, true);
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuMultiSplitCargo, true);//04 Jun 2020	NDL	TFS 49401
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuDiscrepancyBB, true);
			//epr par 34472
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuUnpackCargo, true);
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuPackCargo, true);
		
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuNonTrans, true); // AER CCMS 1086
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuInterModal, true);	// TFS 53084
		
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuCargoCreateItem, true);
		
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuEraseChildCargo, true);	//cnwmc5 - 8 August 2014 - PAR 34086
		
		self.mnuCargoUnplan.visible := false;
	
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuCargoUnplan, true); 
		tmpMenu2:= self.zCloneMenu(cargoMenu, self.mnuCargoUnplanSingle, true); 
		
		self.doBuildUnplanMenu(tmpMenu, tmpMenu2, _ti);
		//23 Dec 2013	NDL	Par 32900
		self.mnuUnQueueSel.visible := self.hasMultiSelectedQueuedItems();
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuUnQueueSel, true);
		
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuCargoConnect, true); 
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuCargoAttach, true); 
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuCargoAttachGenSet, true); 
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuCargoDetachGenSet, true); 
		
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuWeighCargo, true);	//13 Mar 2014	NDL	Par 33268
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuFutureStAnn, true); //21/06/2023 navmv20 CR 58373 Task 58381

		// CCMS 1295 free storage days
		mnuCargoPack.userObject := _ti;
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuCargoPack, true);
		// CCMS 1295 free storage days
		tmpMenu.caption := "Re-evaluate Free Storage Days";
		tmpMenu.visible := true;
		
		
		//self.mnuAdditionalStorage.visible:=true;
		self.mnuAdditionalStorage.userObject:=_ti;
		tmpMenu := self.zCloneMenu(cargoMenu,self.mnuAdditionalStorage,true);
		tmpMenu.visible := true;
		
		// 14.8.2017 cnwma1 TFS #5695
		if checkForAutoVolumeCalc(self.tblData.allSelectedObjects,_ti )then
			self.mnuAutoVolumeCalculate.userObject :=_ti;
			tmpMenu := self.zCloneMenu(cargoMenu,self.mnuAutoVolumeCalculate,true);
			tmpMenu.visible := true;
		else
			self.mnuCargoMoveOverstow.visible := false;
			self.mnuCargoMoveOverstow.userObject := null;
			if not _ti.isContainer() then
				tmpMenu := self.zCloneMenu(cargoMenu, self.mnuAutoVolumeCalculate, true);		// 30/5/19 MAP TFS41707
				tmpMenu.visible := true;
			endif;
		endif;
		
		// 14/04/2023	navkc1	CR 57036 Task 57590
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuCreateOnboardCargo, true);
	endif;
	
	// ### CCMS 1282 AKB2004NOV
	tmpBR := _ti.allBulkReleasesAssigned.getAtKeyGeq(null, BR_ACTIVE, null, null);
	if self.canUpdate and tmpBR &lt;&gt; null then
		self.mnuCargoUnassign.visible := true;
		self.mnuCargoUnassign.caption := app.getErrorString(Unassign_from)   &amp; ' '  &amp; tmpBR.code;	
		self.mnuCargoUnassign.userObject := _ti;
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuCargoUnassign, true);
	else
		self.mnuCargoUnassign.visible := false;
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuCargoUnassign, true);
	endif;
	
	if self.canUpdate then
		self.mnuCargoTestAp.caption := app.getErrorString(Test_autoplan)  &amp; ' ' &amp; _ti.id &amp; '...';
		self.mnuCargoTestAp.userObject := _ti;
		canTestAutoPlan := true;
		self.mnuCargoTestAPChild.caption := 'Test Auto Plan Children of'  &amp; ' ' &amp; _ti.id &amp; '...';	//15 July 2014	NDL	Par 34559 
		self.mnuCargoTestAPChild.userObject := _ti;	//15 July 2014	NDL	Par 34559 
	endif;
	
	if self.canAccessMoveIt then
		self.mnuCargoMoveIt.userObject := _ti;	
		
		if _ti.state = TI_STATE_NORMAL or _ti.state = TI_STATE_NOTIFIED	or _ti.state = TI_STATE_ONSHIP //ccms jmtcp01 - 1059  //cnwrd1 par 26963 21.2.2011
		then
			self.mnuCargoMoveIt.visible := true;
			if canTestAutoPlan then
				self.mnuCargoTestAp.visible := true;
				self.mnuCargoTestAPChild.visible := true;	//15 July 2014	NDL	Par 34559 
			endif;
		endif;
	
		//cnwjo3, par 21337.  Do allow autoplanning for notified or deleted TIs
		self.mnuCargoAP.visible := (_ti.state &lt;&gt; TI_STATE_NOTIFIED and _ti.state &lt;&gt; TI_STATE_DELETED and _ti.myPrimaryQueuedLocation =null);
		self.mnuCargoTestAPChild.visible:= _ti.allChildren.size &gt; 0;
		//epr 36069 6/5/15
		if self.tblData.allSelectedObjects.size &gt; 1 then		
			self.mnuCargoAP.caption := app.getErrorString(Auto_queue_selected_item);
		else
			self.mnuCargoAP.caption := app.getErrorString1(Auto_queue, _ti.id);	
		endif;
		
		tmpMenu := self.buildCargoMenuXtra(cargoMenu);
	
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuCargoMoveIt, true); 
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuCargoTestAPChild, true);	//15 July 2014	NDL	Par 34559 
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuCargoTestAp, true); 
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuCargoAP, true); 	
	endif;
	
	//07 Nov 2016	NDL	TFS 2917
	if _ti &lt;&gt; null then
		create resDetailSet transient;
		create bookingItemSet transient;
		_ti.hasDocumentActions( resDetailSet, bookingItemSet );
		if not resDetailSet.isEmpty then
			self.mnuDAReserve.visible := true;
			self.mnuDAReserve.userObject := _ti;
		endif;
		if not bookingItemSet.isEmpty then
			self.mnuDABooking.visible := true;
			self.mnuDABooking.userObject := _ti;
		endif;
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuDABooking, true); 
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuDAReserve, true); 
	endif;
	
	useInterimConfig 	:= app.myRoot.getConfig(UseInterimJobRequestForm).Boolean;		// par 17884
	useInterimForm		:= app.getMyUser.canDo (self.myTerminal, PmJobRequestView);		// par 17884
	useOldMenus			:= app.getMyUser.canDo (self.myTerminal, PmShowToDoMenuInViewMode);	// par 17884

	// if the system config (use interim job request form) is set and
	// the user has view job request form permission then
	// show then interim job request menu item	
	if useInterimConfig and  useInterimForm then										// par 17884
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuRequestTask, true); 				// par 17884
		tmpMenu.visible	:= true;
		self.mnuRequestTask.userObject	:= _ti;											// par 17884
	endif;
	
	//cnwrd1 ccms 1075 work order 26.11.09
	tmpMenu := self.zCloneMenu(cargoMenu, self.mnuCreateWorkOrder, true); 			
	tmpMenu.visible	:= true;
	self.mnuCreateWorkOrder.userObject	:= _ti;	
		
	// PAR 21532 CCMS SFW 1025
	if  _ti.isOverStowedRTQueue(null) then
		self.mnuCargoShowOverstow.visible := true;
		self.mnuCargoShowOverstow.userObject := _ti;
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuCargoShowOverstow, true);
		self.mnuCargoMoveOverstow.visible := true;
		self.mnuCargoMoveOverstow.userObject := _ti;
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuCargoMoveOverstow, true);
	else
		self.mnuCargoShowOverstow.visible := false;
		self.mnuCargoShowOverstow.userObject := null;
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuCargoShowOverstow, true);
		self.mnuCargoMoveOverstow.visible := false;
		self.mnuCargoMoveOverstow.userObject := null;
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuCargoMoveOverstow, true);
	endif;
	
	useTaskForm := self.myTerminal.getConfig(UseTaskFormCount).Boolean;	//05 Oct 2015	NDL	Par 37011
	if self.canAccessTodoTasksAddRemove then
		// if the system is using the interim solution the add tasks menu is
		// not show unless they are in update mode or have the permission set
		
		if not useInterimConfig or self.canUpdate or useOldMenus then					// par 17884
			if useTaskForm then
				tmpMenu := self.zCloneMenu(cargoMenu, self.mnuCargoTaskAdd, true);
				self.mnuCargoTaskAdd.helpKeyword := CMUI_TasksForm.name &amp; ":" &amp; TASK_MODE_ADD.String ;
				tmpMenu.caption := tmpMenu.caption &amp; "...";			// from 36868 to indicate that a sub-form will be shown
			else
				self.mnuCargoTaskAdd.helpKeyword := null;	//06 Oct 2015	NDL	Par 37011
				tmpMenu := self.zCloneMenu(cargoMenu, self.mnuCargoTaskAdd, true); 
				self.doBuildMnuTasksAdd(tmpMenu, _ti);	
			endif;
			
		endif;																			// par 17884
		
	endif;																				// par 17884
	
	if self.canAccessTodoTasksComplete then
		// if the user does not have update access then we don't show the todo task
		// sub menu if the 'hide job request menu' permission is set.
		// if they have update access or the permission is not set then the submenu 
		// will be shown (assuming they have totdo task permissions)
		if not useInterimConfig or self.canUpdate or useOldMenus then					// par 17884
			if useTaskForm then	//06 Oct 2015	NDL	Par 37011
				tmpMenu := self.zCloneMenu(cargoMenu, self.mnuCargoTaskComplete, true);
				self.mnuCargoTaskComplete.helpKeyword := CMUI_TasksForm.name &amp; ":" &amp; TASK_MODE_COMPLETE.String;
				tmpMenu.caption := tmpMenu.caption &amp; "...";			// from 36868 to indicate that a sub-form will be shown
			else
				self.mnuCargoTaskComplete.helpKeyword := null;	//06 Oct 2015	NDL	Par 37011
				tmpMenu := self.zCloneMenu(cargoMenu, self.mnuCargoTaskComplete, true); 
				self.doBuildMnuTasksComplete(tmpMenu, _ti);	
			endif;
		endif;																			// par 17784
		// Start 28.10.2022 navtnr20 TFS 54967
		if useTaskForm then	
			tmpMenu := self.zCloneMenu(cargoMenu, self.mnuTaskInstruction, true);
			self.mnuTaskInstruction.helpKeyword := CMUI_TasksForm.name &amp; ":" &amp; self.TASK_MODE_INSTRUCTION.String;
		else
			self.mnuTaskInstruction.helpKeyword := null;
		endif;
		//End  28.10.2022 navtnr20 TFS 54967
	endif;
	
	if self.canAccessTodoTasksAddRemove then
		// if the user does not have update access then we don't show the todo task
		// sub menu if the 'hide job request menu' permission is set.
		// if they have update access or the permission is not set then the submenu 
		// will be shown (assuming they have totdo task permissions)
		if not useInterimConfig or self.canUpdate or useOldMenus then					// par 17884
			if useTaskForm then	//06 Oct 2015	NDL	Par 37011
				tmpMenu := self.zCloneMenu(cargoMenu, self.mnuCargoTaskRemove, true);
				self.mnuCargoTaskRemove.helpKeyword := CMUI_TasksForm.name &amp; ":" &amp; TASK_MODE_REMOVE.String;
				tmpMenu.caption := tmpMenu.caption &amp; "...";			// from 36868 to indicate that a sub-form will be shown
			else
				self.mnuCargoTaskRemove.helpKeyword := null;	//06 Oct 2015	NDL	Par 37011
				tmpMenu := self.zCloneMenu(cargoMenu, self.mnuCargoTaskRemove, true); 
				self.doBuildMnuTasksRemove(tmpMenu, _ti);	
			endif;
		endif;																			// par 17884
		
		//06 Oct 2015	NDL	Par 37011
		if useTaskForm then	
			tmpMenu := self.zCloneMenu(cargoMenu, self.mnuTaskRemarks, true);
			self.mnuTaskRemarks.helpKeyword := CMUI_TasksForm.name &amp; ":" &amp; TASK_MODE_REMARKS.String;
		else
			self.mnuTaskRemarks.helpKeyword := null;
		endif;
		
	endif;
	
	executeWhen JMTDevelopmentEnvironment;
		self.mnuShowInTerminalArea.visible := true;
		self.mnuShowInTerminalArea.enabled := true;
	endExecuteWhen;
	
	tmpMenu := self.zCloneMenu(cargoMenu, self.mnuShowInTerminalArea, true);	

	//09 Sep 2009 NDL CCMS 1609 / Par 20521
	if self.mnuBookingRefDiscrep.visible then
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuBookingRefDiscrep, true);	
	endif;

	tmpMenu := self.zCloneMenu(cargoMenu, self.mnuCargoBulkTrans, true); 
	tmpMenu := self.zCloneMenu(cargoMenu, self.mnuCargoStops, true); 

	//epr par 32261 19/8/13
	if self.canUpdate and _ti &lt;&gt; null and _ti.canSetAvailabilityGrade then
		tmpMenu := self.zCloneMenu(cargoMenu, self.mnuCargoSetGrade, true); 
		//epr par 32261 19/8/13
		self.myAssistant.menuSetGradeBuild(tmpMenu,self.mnuSetGradeSub,_ti);		
		//self.clonedMenuCount:=self.menuItemCount; //epr par 34179 30/7/14
	endif;
	
epilog

	delete resDetailSet;
	delete bookingItemSet;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="buildCargoMenuXtra" id="50af6c70-e087-4d94-8328-3d8a591991e3">
        <updating/>
        <source>buildCargoMenuXtra(_cargoMenu : MenuItem input) : MenuItem updating;
//----------------------------------------------------------------
//	Created:	August 2005	by Russell Sargent  (cnwrs1)
