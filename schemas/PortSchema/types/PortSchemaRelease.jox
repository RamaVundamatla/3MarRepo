15 September 2021	navndl1	Initial creation	TFS 51142

*/

vars

	root : CM_Root;
	term : CM_Terminal;

begin

	root := app.myRoot;

	beginTransaction;
	
	root.addUpdateRootMutexes();
	
	foreach term in root.allTerminals do
