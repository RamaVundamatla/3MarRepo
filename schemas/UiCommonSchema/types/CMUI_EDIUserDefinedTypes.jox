        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbEDIDataType_click(combobox: ComboBox input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	01 March 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
23/09/2009	cnwcs5		par 20320 - multiple record types
21/11/2015  cnwma1		PAR #36842	Unable to define control column value when defining a User-Defined EDI Format
*/
vars

