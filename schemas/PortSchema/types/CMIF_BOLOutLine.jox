    <JadeMethod name="getDisplayStringForAttribute" id="cd6359fc-8674-4139-8abc-fdd95fdacdf2">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     10 May 2004	cnwth2
//
// Purpose:     
// 10/11/2014 	cnwma1		PAR #35110 Cargo Loadout - 1011 error occurring when trying to create BOL			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if _attrName = ETRow_MyCargoType or
	   _attrName = ETRow_CargoType then
		if self.myCargoType &lt;&gt;  null then
			return self.myCargoType.description;
		else
			return null;
		endif;
		
	elseif _attrName = ETRow_MyProduct or
	   _attrName = ETRow_Product then
		if self.myProduct &lt;&gt;  null then
			return self.myProduct.code;
		else
			return null;
		endif;
	
	elseif _attrName = ETRow_Id or
	   _attrName = ETRow_Location or 
	   _attrName = ETRow_Volume or
	   //_attrName = ETRow_Weight then						//-cnwml2 MSL CCMS 1017
	   _attrName = ETRow_WeightTotal  or							//+ cnwma1 PAR #35110
	   _attrName = ETRow_TotalWeight then					//+cnwml2 MSL CCMS 1017
		if self.myTrackedItem &lt;&gt;  null then
			return self.myTrackedItem.getDisplayStringForAttribute(_attrName, _short);
		else
			return null;
		endif;
	
	elseif _attrName = ETRow_LineNo then
		return null;
	endif;
	
	return inheritMethod(_attrName, _short);


end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setFromStockOrderLine" id="e9287f3c-f25c-459f-bb83-9897895a2fb9">
        <updating/>
        <source>setFromStockOrderLine(_stockOrderLine : CM_StockOrderLine) updating;
// ---------------------------------------------------------------------------
// Created:     14 June 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	product			: CM_Product;
	ti				: CM_TrackedItem;
begin
	self.myStockOrderLine := _stockOrderLine;
	if CM_StockOrderProductLine.hasInstance(_stockOrderLine) then
		self.lineType := StockOrderLine_Product;
		product := _stockOrderLine.CM_StockOrderProductLine.myProduct;
		self.myProduct := product;
		self.myCargoType := product.myCargoType;
	elseif CM_StockOrderTILine.hasInstance(_stockOrderLine) then
		self.lineType := StockOrderLine_TI;
		ti := _stockOrderLine.CM_StockOrderTILine.myTrackedItem;
		self.myTrackedItem := ti;
		self.myProduct := ti.myProduct;
		self.myCargoType := ti.myCargoType;
	else
		return;
	endif;
	
end;</source>
        <Parameter name="_stockOrderLine" type="CM_StockOrderLine"/>
    </JadeMethod>
    <JadeMethod name="setFromTrackedItem" id="1abdb69d-f747-42b1-a9f0-17e9fbc45d6a">
        <updating/>
        <source>setFromTrackedItem(_ti : CM_TrackedItem) updating;
// ---------------------------------------------------------------------------
// Created:     10 May 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	
	if _ti = null then
		// if null passed in then update to null
		self.myTrackedItem := null;
		return;
	endif;
	
	self.myCargoType := _ti.myCargoType;
	self.myProduct := _ti.myProduct;
	self.myTrackedItem := _ti;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
</Class>
