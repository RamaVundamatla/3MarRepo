    <JadeMethod name="stub_SaveSelectedTrackedItems" id="ad61c5f3-719a-4041-8719-19a8f3514261">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_CMUI_TrackedItems::saveSelectedTrackedItems"/>
        </interfaceImplements>
        <source>stub_SaveSelectedTrackedItems(_allTIs : CM_TIArray) : Boolean;

	/*
		this method stub has been automatically generated by Jade to satisfy interface implementation requirements for the IF_CMUI_TrackedItems interface 
	*/
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
20/09/2025		navcs2	MTN-35847
*/
vars
	trackedItem : CM_TrackedItem;
	moveControl	: CMIF_MoveController;
	location		: CM_LocationsController;
	terminalArea	: CM_TerminalArea;
	subTermArea		: CM_LocationsController;
	tbl			: CM_DataTable;
	theDataLine	: String;
	tiCMIF		: CMIF_MoveQuantityTI;
begin

	tbl := self.tblReleasedTrackedItems;
		
	foreach trackedItem in _allTIs do
		if trackedItem &lt;&gt; null then
			create tiCMIF transient;
			tiCMIF.myTI := trackedItem;
			tiCMIF.moveQuantity := trackedItem.totalQuantity;
			tiCMIF.moveWeight := trackedItem.weight;
			theDataLine := tiCMIF.getAttributeStringForDefArray(tbl.allTblDataEntRows);
			tbl.accessRow(tbl.addItem(theDataLine)).itemObject := tiCMIF;
		endif;
	endforeach;
		
	return true;
	
epilog

end;</source>
        <Parameter name="_allTIs" type="CM_TIArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
