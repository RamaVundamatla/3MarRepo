    <JadeMethod name="btnCancelP_click" id="82aa796b-2a62-49de-8fc2-34d5091c297c">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCancelP_click(btn: Button input) updating;

begin
	app.mousePointer	:=	Busy;
	self.doCancelReportQueueEntry(tblQueueP);
	self.doCheckErrorStatus(btnStatusP, tblQueueP);
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnNewReport_click" id="17cddc55-f64d-4f7b-9578-8c63d9c767f0">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnNewReport_click(btn: Button input) updating;

vars
	reportDetailsForm	: CnEcReportEditSuper;

begin
	app.mousePointer	:=	Busy;
	create reportDetailsForm as global.cnEcGetReportModuleForm(CnEcReportEditSuper);
	reportDetailsForm.setIsNewEntry(true);
	reportDetailsForm.setParamsReadOnly(false);
	reportDetailsForm.showModal();
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
