    <JadeMethod name="doCancel" id="b499d9c0-f195-438f-9fe7-2a8e27a0ba6b">
        <updating/>
        <source>doCancel() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Oct 2022 navsj20	ChangeRequest 55084: EUP - EDI Administration Usability Requirements
26 Oct 2022 navvt20	ChangeRequest 55084: EUP - EDI Administration Usability Requirements
*/

vars
	ediData		: CM_EDIData;
	passport	: CM_Passport;
	allErrorEdiData : ObjectArray;
	coll		: CM_EDIDataByDateStatusDict;
	cmifMonitor	: CMIF_Monitor;
	count, countOK, countNotOK,
	size		: Integer;
	invalidObject	:Boolean;
	strCaption		:String;
begin
	self.staStatusBar.caption := null;
	passport					:= app.myPassport;
	
	coll := self.getAllSelectedEDIData();
	
	size := coll.size;
	
	if size = 0 then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Nothing selected');	
	endif;
	
	// arm exception handler
	on Exception do app.handleDeletedObject (exception, ediData, invalidObject);
	
	app.mousePointer 	:= MP_HOURGLASS;
	// clear out any old stuff
	passport.clearErrorsWarnings();
	// the monitor will handle updating the progress bar
	cmifMonitor := self.createCMIFMonitor (passport);
	// show the progress dialog
	self.progressStart (size, app.getErrorString(Cancel), null, null, app.getErrorString (XLAT_Cancelling_EDIData));
	
	create allErrorEdiData transient;
	
	foreach ediData in coll do 
		count 			:= count + 1;
		invalidObject	:= false;	
		
		if ediData.isKindOf (CM_EDIDataGeneric)then
			// menu item should have been disabled - this form does not handle generic
			continue;
		endif;
		
		if ediData = null or ediData.edition &lt; 0 then	// will cause exception if ediData is deleted
			continue;
		endif;

		if invalidObject then
			continue;
		endif;
		
		if not ediData.canBeCancelled() then // 26 Oct 2022 navvt20 TFS 55084
			continue;
		endif;
		// update the progress dialog	
		self.lblModalMessage.caption := (app.getErrorString2 (Cancelling_X_of_Y, count.String, size.String));
		self.pbProgressBar.partsDone := count;
		self.frmModalDialog.refreshNow;
		self.btnModalDefault.doWindowEvents(null);	// did someone press the cancel button
		
		if self.modalDialogReturnValue = self.ModalDialogReturn_Default then
			// Cancel button was pressed
			break;		
		endif;
		
		app.myTrxUA.trxSetEDIDataStatus(ediData, CM_EDIFile.EDI_STATUS_CANCELLED);

		// check for errors 
		if passport.allErrorWarnings.size = 0 then
			countOK := countOK + 1; 
		else
			allErrorEdiData.add(ediData);
			countNotOK := countNotOK + 1; 
			if size = 1 then
				// Direct them to old form if there was only one item being verified
			//	self.showVerifyErrors (app.getErrorString (EDIData_Failed_To_Verify2), self.mnuCancel.caption);
			endif;
		endif;
		
		
	endforeach;
	
	// now display result
	strCaption := self.mnuCancel.caption;
	
	self.staStatusBar.caption := app.getErrorString3 (X_of_Y_Sucessful, strCaption, countOK.String, size.String);
	
	
	
epilog
	self.clearErrorWarnings();	// always clear out
	self.progressFinish;		// just to make sure
	delete cmifMonitor;			// will reset passport value
	delete coll;
	delete allErrorEdiData;
	app.mousePointer := MP_DEFAULT;
end;</source>
    </JadeMethod>
    <JadeMethod name="doDEVCreateCargo" id="d3d4e658-be40-4581-b308-b5d93f4db6c4">
        <source>doDEVCreateCargo() protected;
// ---------------------------------------------------------------------------
// Created:     02 May 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	ediData			: CM_EDIData;
	taID			: String;
	area			: CM_TerminalArea;
	terminal		: CM_Terminal;
	gotException	: Boolean;
begin
	on Exception do app.handleDeletedObject (exception, ediData, gotException);
	
	// development only - not bothering with translations
	ediData := self.getSelectedEDIData;
	
	if ediData = null or not app.isSpecial() or ediData.edition &lt; 0 then
		return;
	endif;
	
	if gotException then
		return;
	endif;
	// can only load cargo for certain statuses
	if ediData.status &lt;&gt; CM_EDIFile.EDI_STATUS_VERIFIED and 
		ediData.status &lt;&gt; CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS and 
		ediData.status &lt;&gt; CM_EDIFile.EDI_STATUS_DBLOADED then
		app.msgBox("The EDI Data you select must be VERIFIED or DBLOADED.", "Invalid EDI Data Status", null);
		return;
	endif;
	
	terminal := self.myTerminal;
	
	app.msgBox("Enter the ID of a suitable Third Party Receipt Area in the following input box.", "Click OK to Enter ID", null);
	
	taID := "EDIREC";
	read taID;
	
	area := terminal.allTerminalAreas[taID];
	
	if area = null then
		app.msgBox("Cannot find area with ID " &amp; taID &amp; ".", 'Invalid Area ID', null);
		return;
	endif;
	
	if area.type &lt;&gt; TA_TYPE_RECTRANS then
		app.msgBox("Area " &amp; taID &amp; " is not a 3rd party receive area.", 'Invalid Area', null);
		return;
	endif;
	
	ediData.createCargoTesting(terminal, area);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doDEVResetStatus" id="175e562e-ab7c-4c8b-a0e2-73807ff9eb73">
        <source>doDEVResetStatus()protected;
// ---------------------------------------------------------------------------
// Created:     02 May 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	ediData 		: CM_EDIData;
	gotException	: Boolean;
begin
	on Exception do app.handleDeletedObject (exception, ediData, gotException);
	
	ediData := self.getSelectedEDIData;
	
	if ediData = null or not app.isSpecial() or ediData.edition &lt; 0 then
		return;
	endif;
	
	if gotException then
		return;
	endif;
	
	beginTransaction;
	ediData.setStatus(CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS);
	commitTransaction;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doDelete" id="4bcfcd85-fc62-44eb-b068-b5d4f78cb6b2">
        <updating/>
        <source>doDelete() updating;
// ---------------------------------------------------------------------------
// Created:     26 April 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 22/06/2010	cnwcs5		par 24298 - tidy up multi-select
// ---------------------------------------------------------------------------
vars
	passport		: CM_Passport;
	coll			: CM_EDIDataByDateStatusDict;
	ediData			: CM_EDIData;
	count, size, countNotOK,
	countOK			: Integer;
	invalidObject	: Boolean;
	strCaption		: String;
	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815
begin
	self.staStatusBar.caption 	:= null;	// just in case
	passport 					:= app.myPassport;
	
	self.staStatusBar.caption 	:= null;	// just in case

	coll := self.getAllSelectedEDIData();	// par 22/06/2010

	size := coll.size;
	
	if size = 0 then
		return;	// nothing selected
	endif;
	
	// arm exception handler
	on Exception do app.handleDeletedObject (exception, ediData, invalidObject);
	
	// display confrmation message
	if size &gt; 1 then
		if app.msgBox(app.getErrorString (Delete_EDI_Data_Confirm), app.getErrorString (Delete_EDI_Data), 
						MsgBox_Information_Icon + MsgBox_OK_Cancel) = MsgBox_Return_Cancel then
			return;	// they cliocked cancel
		endif;	
	else
		ediData := coll.first.CM_EDIData;
		if app.msgBox(app.getErrorString2 (Delete_EDI_Data_Confirm1, self.myAssistant.getEDIDisplayStrForType(ediData.ediDataType), ediData.createdTime.shortCurrentLocaleFormat ), 
							app.getErrorString (Delete_EDI_Data), 
							MsgBox_Information_Icon + MsgBox_OK_Cancel) = MsgBox_Return_Cancel then
			return;	// they clicked cancel
		endif;
		if invalidObject then
			return;
		endif;
	endif;	

	// display a progress bar
	self.progressStart(size, app.getErrorString(Cancel), null, null, app.getErrorString (Delete_EDI_Data));
	
	foreach ediData in coll do
		count			:= count + 1;
		invalidObject	:= false;	
		
		if ediData = null or ediData.edition &lt; 0 then	// will cause exception if ediData is deleted
			continue;
		endif;
		
		if invalidObject then
			continue;
		endif;
		
		app.mousePointer := Window.MousePointer_HourGlass; 

		// update the progress bar and check to see if they have clicked cancel
		self.modalDialogUpdateInfo(app.getErrorString2 (Deleting_X_Of_Y, count.String, size.String));
		self.pbProgressBar.partsDone := count;
		self.frmModalDialog.refreshNow;
		self.btnModalDefault.doWindowEvents(null);	// did someone press the cancel button
		
		if self.modalDialogReturnValue = self.ModalDialogReturn_Default then
			// Cancel button was pressed
			break;		
		endif;
		
		//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			app.myTrxDA.trxDeleteEDIData(ediData, passport);
		
			if app.myPassport.trxCompletedOK then
				countOK := countOK + 1;
				break;
			elseif size = 1 then
				// only display errors if there is just one item being deleted
				theResult := app.showErrorWarningDialog(app.getErrorString (Delete_EDI_Data), passport, ErrWarnMode_Delete);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			countNotOK := countNotOK + 1;
			break;
			
		endwhile;
		
	endforeach;
	// now display result	
	strCaption := self.mnuDelete.caption;
	
	self.staStatusBar.caption := app.getErrorString3 (X_of_Y_Sucessful, strCaption, countOK.String, size.String);
	
	if size &gt; 1 and countNotOK &lt;&gt; 0 then
		// multi-select had some errors - show message.  if there was only one item being processed we would have 
		// shown the errors already if there were any
		app.msgBox (app.getErrorString3 (X_of_Y_Items_ErrorsWarnings, strCaption, countNotOK.String, size.String),
					strCaption, MsgBox_OK_Only);
	endif;
epilog
	self.progressFinish;
	
	delete coll;	
	
	app.mousePointer := Window.MousePointer_Default; 
end;</source>
    </JadeMethod>
    <JadeMethod name="doEditItem" id="352054a2-e0ca-41e0-b560-2fdd51f11c18">
        <updating/>
        <source>doEditItem() updating;
// ---------------------------------------------------------------------------
// Created:     26 April 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 13/09/2010 	cnwcs5 		par 25665
// ---------------------------------------------------------------------------
vars
	
	coll	:ObjectArray;	// 13/09/2010 cnwcs5 par 25665
begin
	
	coll 	:= self.tblData.allSelectedObjects;		// 13/09/2010 cnwcs5 par 25665
	if coll.isEmpty then
		return;
	endif;
	//epr CPL 957 EDI Administration improvements 19/10/15
	self.myEDIAgent.showEDIFormWithColl (coll, self.myMasterMenuAction, true);	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doExtractSelected" id="4700cb45-b110-40a5-bf92-367add15bb7a">
        <source>doExtractSelected() protected;
// ---------------------------------------------------------------------------
// Created:     27 April 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	ediData			: CM_EDIData;
	gotException	:Boolean;
begin
	ediData := self.getSelectedEDIData;
	
	on Exception do app.handleDeletedObject (exception, ediData, gotException );
	
	if ediData &lt;&gt; null and ediData.edition &gt;=0 then	// will cause exception if invalid otherwise always true
		self.myEDIAgent.doEDIExtract(CMUI_EDIDBExtract.FinishMode, ediData, self.myAssistant, self.myTerminal, self.myEDIControllerAgent);
		return;
	endif;
	// either no object selected or we got an exception. If we got exception a delete notification should fix up the table
	app.msgBox(app.getErrorString(Nothing_Selected), app.getErrorString(No_Current_Item), MsgBox_OK_Only + MsgBox_Information_Icon);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doIncludeObject" id="241db74f-997c-4a52-884a-0d04b5c30a70">
        <source>doIncludeObject(_ediData :CM_EDIData; _voyage :CM_Voyage; _statusColl :IntegerArray; _ediFileTypeColl :CM_ObjectSet;
				_dateStart, _dateEnd :Date):Boolean protected;
// ---------------------------------------------------------------------------
// Created:     21 April 2010 by cnwcs5
// Purpose:     Do query when at least one status has been selected
// Parameters:  _ediData			- candidate object
//				_voyage				- voyage to filter by (may be null)
//				_statusColl 		- one or more statii to filter by (if null it does not get checked)
//				_ediFileTypeColl	- one or more ediFileTypes to filter by (if null it does not get checked)
//				_dateStart 			- 
//				_dateEnd 			-
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 28/07/2010	cnwrl1		PAR 24415 - EDI Admin form does not handle deleted of EDI File Types.
// 14 Oct 2022  navsj20		ChangeRequest 55084: EUP - EDI Administration Usability Requirements
// 26 Oct 2022  navvt20		ChangeRequest 55084: EUP - EDI Administration Usability Requirements
// 15 Mar 2023 	navra1		Bug TFS 57122 - US .010 'a' - EDI Advanced Search is only working on 
//							data from the first line of an EDI file - it doesn't search for other lines.
// 15 Mar 2023 	navra1		Bug TFS 57123 - US .010 'a' - EDI Advanced Search is case-sensitive while 
//							the EDI uploads accept case-insensitive values - this leads to some EDI 
//							files being missed if you put "Road" instead of "ROAD" for example.
// 27 Mar 2023	navra1		TFS 57263 EDI Advanced Search is only working on data from the first line 
//							of an EDI file
// 04 Oct 2023	jlika1	TFS 60232 - EUP | FR 54871 - EDI Management for New EDI Types
// 06 May 2024	navlw1 	TFS 63312 - EUP | FR 54871 - EDI Administration Usability Operator Search Filter Returns Incorrect Results
// 17 May 2024	naviv1	TFS 63310 - EUP | FR 54871 Search EDI Message on Vessel Behaviour Not Clear
// 23 Sep 2024  navma1	Bug 66196: PEN - Searching using Booking IDs in EDI Message Administration screen
//16/1/25 navsaa30 EUP | FR 54871 - EDI Message Administration Advanced Filters not working
//22/1/25 navsaa30 EUP | FR 54871 - EDI Message Administration Advanced Filters not working
//11/2/25 navsaa30 EUP | FR 54871 - EDI Message Administration Advanced Filters not working
//25 Feb 2025 navsaa30 EUP | FR 54871 - EDI Message Administration Advanced Filters not working
// ---------------------------------------------------------------------------
vars
	ediFileType	: CM_EDIFileType;
	voyage : CM_Voyage;	
begin
	if _voyage &lt;&gt; null and 
		not _ediData.isForVoyage(_voyage) then 
		return false;	// not for voyage we are interested in
	endif;
	
	if _statusColl &lt;&gt; null and 
		not _statusColl.isEmpty and
		not _statusColl.includes(_ediData.status) then // not great but need to check
		return false;	// filtering by status and not one of the selected statii
	endif;
	
	if _ediFileTypeColl &lt;&gt; null and not _ediFileTypeColl.isEmpty then
		ediFileType := _ediData.getEDIFileType;
		
		// cnwrl1 28/07/2010 PAR 24415 - start of replacement coding
		if ediFileType = null then
			// this can happen if the EDI User File Definition is deleted!
			return false;
		endif;
		// Check the ediFileType is contained in the selected list
		if not _ediFileTypeColl.includes( ediFileType ) then 
			return false;
		endif;
		// cnwrl1 28/07/2010 PAR 24415 - end of coding
	endif;
	
	if self.chkExcludeDepart.value then
		voyage:=self.myTerminal.lookupVoyage(_ediData.getVoyageCode,null,false);
		if voyage &lt;&gt; null and voyage.hasDeparted then
			return false;
		endif;
	endif;
	
	if _dateStart &lt;&gt; null and
	   _ediData.processDate &lt; _dateStart then 
		return false;
	endif;
	
	if _dateEnd &lt;&gt; null and
	   _ediData.processDate &gt; _dateEnd then
		return false;
	endif;
	//START 14.10.2022	navsj20	TFS 55084
	/*if self.filterCargoETA.isValid  and self.filterCargoETA &lt;&gt; _ediData.getCargoETA() then // 26 Oct 2022 navvt20 TFS 55084
		return false;
	endif;*/
	if self.filterCargoETA.isValid  and not _ediData.doesCargoForExptDateExist(self.filterCargoETA) then 								//navra1 - TFS 57263 - 27th Mar 2022
		return false;																												//navra1 - TFS 57263 - 27th Mar 2022
	endif;																															//navra1 - TFS 57263 - 27th Mar 2022
	if self.filterVoyageETA.isValid  and self.filterVoyageETA &lt;&gt; _ediData.getVoyageETA() then // 26 Oct 2022 navvt20 TFS 55084
		return false;
	endif;
	if self.filterCargoGroupId &lt;&gt; null and not _ediData.doesCargoGroupExist(self.filterCargoGroupId) then							//navra1 - TFS 57123 - 15th Mar 2023 //navra1 - TFS 57263 - 27th Mar 2023
		return false;
	endif;	
	if self.filterEDIAction &lt;&gt; null and not _ediData.doesEDIActionExist(self.filterEDIAction.toUpper()) then			//navsaa30 16/1/25  #MTN-33489						//navra1 - TFS 57123 - 15th Mar 2023  //navra1 - TFS 57263 - 27th Mar 2023
		return false;
	endif;
	if self.filterMessageID &lt;&gt; null and self.filterMessageID.toUpper() &lt;&gt; _ediData.getMessageID().toUpper() then					//navra1 - TFS 57123 - 15th Mar 2023
		return false;
	endif;
	if self.filterMessageNumber &lt;&gt; null and self.filterMessageNumber.toUpper() &lt;&gt; _ediData.getMessageNumber().toUpper() then		//navra1 - TFS 57123 - 15th Mar 2023
		return false;
	endif;
	if self.filterOperatorCode &lt;&gt; null and not _ediData.doesCargoOperatorExist(self.filterOperatorCode) then						//navra1 - TFS 57122 - 15th Mar 2023	//navra1 - TFS 57263 - 27th Mar 2023
		return false;																												//navra1 - TFS 57122 - 15th Mar 2023
	endif;																															//navra1 - TFS 57122 - 15th Mar 2023	
	if self.filterReceiptMode &lt;&gt; null and not _ediData.doesReceiptTransportModeExist(self.filterReceiptMode.toUpper()) then 					//navra1 - TFS 57123 - 6th	Apr 2023	//navsaa30 28/1/25 #33489
		return false;
	endif;
	if self.filterVBSNumber &lt;&gt; null and self.filterVBSNumber.toUpper() &lt;&gt; _ediData.getVBSExternalReference().toUpper() then			//navra1 - TFS 57123 - 15th Mar 2023
		return false;
	endif;
	/*if self.filterVesselName &lt;&gt; null and self.filterVesselName.toUpper() &lt;&gt; _ediData.getVesselName().toUpper() then				//navra1 - TFS 57123 - 15th Mar 2023
		return false;
	endif;*/
	if self.filterVesselName &lt;&gt; null then																									//navra1 - TFS 57263 - 27th Mar 2023
		if _ediData.isKindOf(CM_EDIDataVoyage) or _ediData.isKindOf(CM_EDIDataVoyageEvent) or _ediData.isKindOf(CM_EDIDataBooking) 
			or _ediData.isKindOf(CM_EDIDataCallOff) or _ediData.isKindOf(CM_EDIDataTransManifest) then		//navra1 - TFS 57263 - 27th Mar 2023	//navra1 - TFS 57263 - 12th Apr 2023 //17 May 2024 naviv1 #63310
			if not _ediData.doesVesselNameExist(self.filterVesselName) then																	//navra1 - TFS 57263 - 27th Mar 2023
				return false;																												//navra1 - TFS 57263 - 27th Mar 2023
			endif;																															//navra1 - TFS 57263 - 27th Mar 2023
		else																																//navra1 - TFS 57263 - 27th Mar 2023
			if self.filterVesselName.toUpper() &lt;&gt; _ediData.getVesselName().toUpper() then													//navra1 - TFS 57123 - 15th Mar 2023
				return false;
			endif;
		endif;		
	endif;
	//END 14.10.2022  navsj20  TFS 55084
	
	//jlika1 TFS 60232 --&gt;
	if self.filterMessageType &lt;&gt; null and not _ediData.getMessageType().toUpper().cnContains(self.filterMessageType.toUpper()) then			//navsaa30   22/1/25 #33489
		return false;
	endif;
	if self.filterSender &lt;&gt; null and self.filterSender.toUpper() &lt;&gt; _ediData.getSender().toUpper() then
		return false;
	endif;
	if self.filterVoyageCode &lt;&gt; null and self.filterVoyageCode.toUpper() &lt;&gt; _ediData.getVoyageCode().toUpper() then
		return false;
	endif;
	if self.filterVehicle &lt;&gt; null then			//navsaa30 11/2/25 #33489		//navra1 - TFS 57263 - 27th Mar 2023  //navsaa30 25/2/25 #33489
		if _ediData.isTransportManifest then
			return _ediData.doesVehicleNumberExist(self.filterVehicle);
		else
			return self.filterVehicle.toUpper() = _ediData.getVehicleNumber().toUpper();
		endif;
	endif;										//navsaa30 11/2/25 #33489 //navsaa30 25/2/25 #33489
	//jlika1 TFS 60232 &lt;--
	
	// navlw1 #63312
	if _ediData.isKindOf(CM_EDIDataRequestMultiLine) and _ediData.isCallOffRelated then
		return false;
	endif;
	if _ediData.isKindOf(CM_EDIDataGateDoc) and _ediData.isTransportManifestRelated then			//23.09.2024 navma1 #23.09.2024
		return false;
	endif;
	if _ediData.isKindOf(CM_EDIDataTrainConsist) and _ediData.isTransportManifestRelated then
		return false;
	endif;
	if _ediData.isKindOf(CM_EDIDataShipManifest) and _ediData.isTransportManifestRelated then
		return false;
	endif;
	// navlw1 #63312
	
	return true;
	
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_ediData" type="CM_EDIData"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_statusColl" type="IntegerArray"/>
        <Parameter name="_ediFileTypeColl" type="CM_ObjectSet"/>
        <Parameter name="_dateStart" type="Date"/>
        <Parameter name="_dateEnd" type="Date"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doLeaveMyContainers" id="ee3c583f-9539-4cb9-b1a2-c46b6b4977ce">
        <updating/>
        <source>doLeaveMyContainers() updating, protected;
// ---------------------------------------------------------------------------
// Created:     29 April 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	ediData	: CM_EDIData;
	heading	: String;
	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815
begin
	self.staStatusBar.caption 	:= null;	// just in case

	// make sure we have something selected - only handle one selection
	ediData := self.getSelectedEDIData;

	if ediData = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'No current ediData object');	
	endif;
	
	if not ediData.isKindOf (CM_EDIDataBayPlan) then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Current ediData object isnot a bay plan');	
	endif;
	// use same heading on all messages
	heading := self.mnuLeaveMyContainers.caption;
	// get confimation of delete
	if app.msgBox(app.getErrorString(ConfirmDelete_NonDischarge), heading, 
			MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
		return;
	endif;
	// set mouse pointer once we know we are actually doing something
	app.mousePointer := MP_HOURGLASS;
	
	self.progressStart (null, null, null, null, app.getErrorString (Deleting_NonDischarge_Cargo));
	
	//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxEDILeaveMyContainers(ediData.CM_EDIDataBayPlan, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog(heading, app.myPassport, ErrWarnMode_Delete);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
	
epilog
	// notifications should take care of displaying updated information
	self.progressFinish;
	app.mousePointer := MP_DEFAULT;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doLoadNew" id="9bdfa303-5fe2-4ae4-9eda-3793d4b45755">
        <updating/>
        <source>doLoadNew(_copyToServer :Boolean) updating, protected;
// ---------------------------------------------------------------------------
// Created:     27 April 2010 by cnwcs5
// Purpose:     Warpper method so we can trap file exceptions
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	errorMsg	: String;
	
begin
	self.staStatusBar.caption 	:= null;	// just in case

	on FileException do self.handleFileException (exception, errorMsg);
	
	errorMsg :=	null;
	
	self.doLoadNewFile(_copyToServer);
	
	if errorMsg &lt;&gt; null then
		app.msgBox(errorMsg, app.getString(Load_failed), MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		self.staStatusBar.caption	:=	app.getString(Load_failed);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_copyToServer" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doLoadNewFile" id="0bed3e8e-e161-4043-abc3-5957995de347">
        <updating/>
        <source>doLoadNewFile(_copyToServer :Boolean) updating, protected;
// ---------------------------------------------------------------------------
// Created:     28 April 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//12 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
// 16/03/2015	cnwmh5	Transient Leak
// ---------------------------------------------------------------------------vars
vars
	loadFile		: File;
	ediFile			: CM_EDIFile;
	cmifMonitor		: CMIF_Monitor;
	passport		: CM_Passport;
	ext				: String;
	dotPos			: Integer;
	fileName		: String;
	fileArray		: FileNodeArray;
	fileNode		: FileNode;
	aMsg			: String;
	selectedType	: CM_EDIFileType;
	serverFileName	: String;	// par 17254
	ediData			: CM_EDIData;
begin
	passport := app.myPassport;
	
	if self.txtFileName.text.trimBlanks = null then
		self.myEDIAgent.getNewEDIFile(self.txtFileName);
	endif;
	
	create loadFile transient;
	loadFile.fileName := self.txtFileName.text.trimBlanks();
	
	if loadFile.fileName = null then
		return;
	endif;
	
	self.createCMIFMonitor (passport);

	if self.optSpecifyType.value then
		selectedType := self.cmbLoadAsType.listObject.CM_EDIFileType;
		
		if selectedType = null then
			app.msgBox(app.getErrorString(Select_EDI_File_Type),app.getErrorString (Error),MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
	endif;
	
	self.progressStart (100, null, null, null, app.getErrorString (Loading_EDI_File));
	
	dotPos := loadFile.fileName.reversePos('.'); //cnwgb1 13.2.09
	
	if dotPos &gt; 0 and dotPos &lt; loadFile.fileName.length then
		ext := loadFile.fileName[dotPos+1:end];
		fileName := loadFile.fileName.getFileName();
	endif;
	
	create fileArray transient;
	
	if ext.toUpper = "XLS" then
		self.myEDIAgent.convertXLSToCSV(loadFile, fileName, fileArray);
		delete loadFile;
		
		if not self.optSpecifyType.value then //Dont need to do this for user defined type
			if fileArray.isEmpty then
				aMsg := app.getErrorString (Excel_File_Convert_Error);
			else
				foreach fileNode in fileArray do
					aMsg := aMsg &amp; CrLf &amp; fileNode.File.fileName;
				endforeach;
				
				aMsg := app.getErrorString1 (Excel_Convert_Message, aMsg);
			endif;
			app.msgBox(aMsg, self.caption, MsgBox_Information_Icon);
		endif;
	else
		fileArray.add(loadFile);
	endif;
	
	app.doWindowEvents(0);
	
	self.myEDIControllerAgent.setCurrentFileFormat(null, null); //must reset these
	
	foreach fileNode in fileArray do
	// par 17254 - start
		if _copyToServer then
			app.writeLog('  Copying file to AppServer', LogINFO);
			serverFileName := app.copyFileToAppServer(fileNode.fileName);
			app.writeLog('  Copied file to AppServer as (' &amp; serverFileName &amp; ')', LogINFO);
			
			fileNode.File.close;
			
			fileNode.usePresentationFileSystem 	:= false;
			fileNode.fileName					:= serverFileName;
		endif;
	// par 17254 - end
		ediFile := self.myEDIControllerAgent.loadAndProcessFileForTerminal(fileNode.File, selectedType, passport);
		
		if passport.allErrorWarnings.size &gt; 0 then
			break;
		endif;
	endforeach;
	
	if ediFile &lt;&gt; null then
		ediData := ediFile.ediData;
	endif;
	
	if passport.allErrorWarnings.size &gt; 0 then 
		app.showErrorWarningDialog(self.mnuLoadNew.caption, passport, ErrWarnMode_AddUpdate);
		self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		self.clearErrorWarnings();
	else
		// add new item to the list if it meets criteria
		if ediData &lt;&gt; null and self.includeObject (ediData) then
			self.doQueryAddItem (ediData);
		endif;
		
		self.clearErrorWarnings();
		self.staStatusBar.caption := app.getErrorString (File_load_sucessful);
	endif;
	
	self.showHideLoadNewFile(false);
epilog
	self.progressFinish;
	
	delete fileArray;
	delete loadFile;
	delete cmifMonitor;
	passport.setMyCMIFMonitor(null);
end;</source>
        <access>protected</access>
        <Parameter name="_copyToServer" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doLoadToDB" id="283ae02c-9a55-4124-b6db-f07139ace8c3">
        <updating/>
        <source>doLoadToDB()updating, protected;
// ---------------------------------------------------------------------------
// Created:     28 April 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 24/06/2010	cnwcs5		par 24298 - multi-select for db/load
// 02 Aug 2012	cnwcs5		par 30136 - change usage of loadEDIDb _ediData parameter
// 02 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded
// ---------------------------------------------------------------------------
vars
	coll					: CM_EDIDataByDateStatusDict;
	size, count, countNotOK,
	countOK					: Integer;
	valid, gotException		: Boolean;
	ediData					: CM_EDIData;
	passport				: CM_Passport;
	strTemp					: String;
	flags, intCancel		: Integer;
	cmifMonitor				: CMIF_Monitor;
	hasCargo, 
	isSingleSelect 			: Boolean;
	voyage 					: CM_Voyage;
	strCaption				: String;
	
	completed, unactioned, partCompleted, exportCargo : Integer;
	mergeRetainAllCargo, mergeRetainEDICargo,mergeRetainManCargo,
	mergeRetainNoCargo, mergeCargo, planning, clearDetails : Boolean;
begin
	passport 					:= app.myPassport;
	self.staStatusBar.caption 	:= null;	// just in case

	coll := self.getAllSelectedEDIData;
	
	size 			:= coll.size;
	isSingleSelect	:= size = 1;
	
	if size = 0 then
		app.raiseUnexpectedProgramError(class.name, method.name, 'no current ediData object');	
	endif;
		
	// check the items selected can be reloaded as part of multi-select	
	if not self.isSelectionOKForLoadToDB (coll) then
		return;
	endif;
	
	on Exception do app.handleDeletedObject (exception, ediData, gotException);
	
	foreach ediData in coll do	
		// some edi data types have special warning messages that get displayed
		ediData.warnOnDBLoad(strTemp, flags, intCancel);
		
		if gotException then
			gotException := false;
			continue;
		endif;
	
		if strTemp &lt;&gt; null then
			if app.msgBox(strTemp, app.getErrorString(Warning), flags) = intCancel then
				return;
			endif;
		endif;
	endforeach;
	
	// create a monitor object that gets used to updated the progress dialod
	self.createCMIFMonitor (passport);
	passport.clearErrorsWarnings();
		
	// let them know we are doing something
	self.progressStart (size, null, null, null, app.getErrorString (Loading_EDI_Data_DB));
	self.pbProgressBar.partsDone := 0;

	app.mousePointer := MP_HOURGLASS;

	foreach ediData in coll do
		valid := true;
		count := count + 1;
		
		if ediData.isKindOf (CM_EDIDataGeneric)then
			// menu item should have been disabled - this form does not handle generic
			continue;
		endif;
		
		// update the progress dialog	
		self.lblModalMessage.caption := (app.getErrorString2 (Loading_X_of_Y, count.String, size.String));
		self.pbProgressBar.partsDone := count;
		self.frmModalDialog.refreshNow;
		self.btnModalDefault.doWindowEvents(null);	// did someone press the cancel button
		
		if self.modalDialogReturnValue = self.ModalDialogReturn_Default then
			// Cancel button was pressed
			break;		
		endif;		
		
		// lock the edi data object and then do verify and load
		if not self.tryLock(ediData, Share_Lock, Session_Duration, LockTimeout_Immediate) then
			// did not get lock - try the next one
// 02 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded
			app.raiseCMException(Objects_locked, null, ediData);
			continue;
		endif;
		
		if gotException then
			// must have got exception doing tryLock
			gotException := false;	// for next time
			continue;
		endif;
				
		// we have the lock
		if ediData.status = CM_EDIFile.EDI_STATUS_VERIFIED or 
			ediData.status = CM_EDIFile.EDI_STATUS_VERIFYING or 			// so you can still continue
			ediData.status = CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS or
			ediData.status = CM_EDIFile.EDI_STATUS_DBLOADED_ERRORS or
			ediData.status = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then 	//so you can still continue
			valid := true;	
			
		elseif ediData.CM_EDIData.status = CM_EDIFile.EDI_STATUS_DBLOADED and ediData.canReDBLoad()	then
			if isSingleSelect then
				// message will have already been displayed if muylti-select
				if app.msgBox(app.getErrorString(File_Loaded), self.mnuLoadToDB.caption, 
						MsgBox_Yes_No + MsgBox_Question_Mark_Icon) &lt;&gt; MsgBox_Return_Yes then
					self.unlock(ediData);
					return;	// they did not confirm re-load
				endif;
			endif;
			//restart from verify
			app.myTrxUA.trxSetEDIDataStatus(ediData, CM_EDIFile.EDI_STATUS_LOADED);
			valid := self.myEDIControllerAgent.verifyEdiData(ediData);
		else
			// if status is DBLOADED or MADEACTUAL then verifyEdiData will return false
			// so we won't actually do the DBLoad.  That is WAI !!!
			valid := self.myEDIControllerAgent.verifyEdiData(ediData);
		endif;
		
		if not valid then				
			// the code to do the verify skips files which certain statuses (e.g. Made Actual) so we could 
			// get to here if no verify was actually done but the method returned false anyway.  
			// We will know that if there are no errors
			if passport.allErrorWarnings.size = 0 then
				self.unlock(ediData);
				continue;	// going to ignore this one
			endif;
		endif;
		
		if valid then
			if ediData.isKindOf(CM_EDIDataBayPlan) then
				// will always be single select
				voyage := ediData.CM_EDIDataBayPlan.getVoyageFromCode(ediData.CM_EDIDataBayPlan.voyageCode);
				
				if voyage &lt;&gt; null then
				// ccms 1022 cnwrs1 june 2006
					voyage.getJobTotals(completed, unactioned, partCompleted, exportCargo);
					
					if completed &gt; 0 or partCompleted &gt; 0 and exportCargo &gt; 0 then				
						app.msgBox(app.getErrorString (BayPlan_Cannot_MakeActual), app.getErrorString (EDI_Update), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
						self.unlock(ediData);
						return;
					endif;
					//ccms 1022 cnwrs1 july 2006
// PAR 33644					if voyage.isNonPlannedVoyage then
					if voyage.isHOLDSorSHIP() then
					
					
						hasCargo := not voyage.allOnshipTIsByCargoTypeId.isEmpty;
						
						if hasCargo then
							if not self.myEDIAgent.doEDIBayPlanMergeOptions(hasCargo, false, clearDetails, mergeRetainAllCargo, 
											mergeRetainEDICargo, mergeRetainManCargo, mergeRetainNoCargo, planning) then
								self.unlock(ediData);
								return;
							endif;
							// now get input options				
							if not clearDetails then
								mergeCargo := mergeRetainAllCargo or mergeRetainEDICargo or mergeRetainManCargo;  //July 2008 cnwrs1 Par 17595 
							endif;
						endif;
					endif;
				endif;
			endif;
			// do the load - we want to ignore any warnings		
			passport.warningsAcknowledged := true;
			self.myEDIControllerAgent.loadEdiDb(null, ediData, mergeCargo);
		endif;
		
		if passport.allErrorWarnings.size &gt; 0 and passport.hasErrors then
			// could be from 1st validate or from load
			countNotOK := countNotOK + 1;
			
			if isSingleSelect then 
				// display detailed errrors of NOT multi-select

				self.showVerifyErrors (app.getErrorString (EDIData_Failed_To_Verify2), self.mnuLoadToDB.caption);
			endif;
		else
			countOK := countOK + 1;
			
			self.clearErrorWarnings();
			
			if isSingleSelect then
				self.staStatusBar.caption := app.getErrorString(DBLoadSuccessful);
			endif;
		endif;
		
		// probably don't need to do this as all locks should have been released at commitTransaction
		self.unlock(ediData);
	endforeach;
		
	strCaption := self.mnuLoadToDB.caption;
	
	self.staStatusBar.caption := app.getErrorString3 (X_of_Y_Sucessful, strCaption, countOK.String, size.String);
	
	if size &gt; 1 and countNotOK &lt;&gt; 0 then
		// multi-select had some errors - show message.  if there was only one item being processed we would have 
		// shown the errors already if there were any
		app.msgBox (app.getErrorString3 (X_of_Y_Items_ErrorsWarnings, strCaption, countNotOK.String, size.String),
					strCaption, MsgBox_OK_Only);
	endif;
epilog
	delete coll;
	self.progressFinish;	// just in case
	delete cmifMonitor;		// will reset inverse
	app.mousePointer := MP_DEFAULT;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doMakeActual" id="68fdda63-fca5-44ad-866a-a31c5187debb">
        <updating/>
        <source>doMakeActual() updating, protected;
// ---------------------------------------------------------------------------
// Created:     27 April 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	passport	: CM_Passport;
	ediData		: CM_EDIData;
	voyage		: CM_Voyage;
	controller	: CM_VoyageEDIBayPlanController;
	result		: Integer;
	completed, unactioned, partCompleted, exportCargo : Integer;
	hasPlanning, hasCargo : Boolean;

	clearDetails, mergeRetainAllCargo, mergeRetainEDICargo, mergeRetainManCargo, mergeRetainNoCargo , mergePlanning : Boolean; 
begin
	passport 					:= app.myPassport;
	ediData						:= self.getSelectedEDIData;
	self.staStatusBar.caption 	:= null;	// just in case
	
	if ediData = null or (not ediData.isKindOf(CM_EDIDataBayPlan)) then
		return;
	endif;

	voyage 	:= self.myTerminal.lookupVoyage(ediData.CM_EDIDataBayPlan.voyageCode, null, false);
		
	if voyage = null then
		return;
	endif;
	
	controller := ediData.CM_EDIDataBayPlan.myBayPlanController;

	if controller = null or not voyage.allEDIBayPlans.includes(controller) then
		return;
	endif;

// ccms 1022 cnwrs1 june 2006	
	voyage.getJobTotals(completed, unactioned, partCompleted, exportCargo);
	// can't make actual if voyage has jobs that have been worked
	if completed &gt; 0 or partCompleted &gt; 0 and exportCargo &gt; 0 then
		app.msgBox(app.getErrorString (BayPlan_Cannot_MakeActual), 
					app.getErrorString (EDI_Update), 
					MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;	
	endif;
	
	hasCargo 	:= not voyage.allOnshipTIsByCargoTypeId.isEmpty;
	hasPlanning := voyage.hasVoyageStartedPlanning();
	
	if not hasCargo and not hasPlanning then
		if app.msgBox(app.getErrorString1(EDI_Confirm_MakeActual, controller.description), 
						app.getErrorString (EDI_Update), 
						MsgBox_Yes_No) &lt;&gt; MsgBox_Return_Yes then
			return;	// they clicked cancel
		endif;
	else
		if not self.myEDIAgent.doEDIBayPlanMergeOptions (hasCargo, hasPlanning, clearDetails, mergeRetainAllCargo, 
												mergeRetainEDICargo, mergeRetainManCargo, mergeRetainNoCargo, mergePlanning) then
			return; // they clicked cancel
		endif;
	endif;

	app.mousePointer := MP_HOURGLASS;

	while true do
		app.myTrxUA.trxSetEDIAsActualBayPlan(voyage, controller, clearDetails, mergeRetainAllCargo, mergeRetainEDICargo, mergeRetainManCargo, mergeRetainNoCargo, mergePlanning, passport);
		
		if passport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			app.myTrxUA.trxSetEDIDataStatus(ediData, CM_EDIFile.EDI_STATUS_MADE_ACTUAL);
			global.beep;
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString (EDI_Set_To_Actual), passport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if passport.noErrors and result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				passport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(passport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;
epilog
	app.mousePointer := MP_DEFAULT;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doNotableAdd" id="ae058e2e-2080-4055-8040-bbae023e166e">
        <source>doNotableAdd(_object: CM_EDIData);
// ---------------------------------------------------------------------------
// Created:     26 April 2010 by cnwcs5
// Purpose:     
// Parameters:  _object
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.allNotableObjects.add(_object);
	
	beginNotification(_object, Object_Update_Event, Response_Continuous, null);
	beginNotification(_object, Object_Delete_Event, Response_Continuous, null);
epilog

end;</source>
        <Parameter name="_object" type="CM_EDIData"/>
    </JadeMethod>
    <JadeMethod name="doNotableClear" id="763c7af0-1a29-4e4d-87e9-7fc9e5f566bc">
        <source>doNotableClear();
// ---------------------------------------------------------------------------
// Created:     26 April 2010 by cnwcs5
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 28/07/2010	cnwrl1		PAR 24415 - EDI Admin form does not handle deleted of EDI File Types.
// ---------------------------------------------------------------------------

vars

begin
	// we don't want to call inheritMethod
	self.endNotificationForSubscriber (self);
	self.allNotableObjects.clear;
	
	// cnwrl1 28/07/2010 PAR 24415 - start of coding
	// Re-register the persistent CM_EDIFileTypeUser class for notification of a deletion.
	self.beginClassNotification( CM_EDIFileTypeUser, false, Object_Delete_Event, Response_Continuous, null );
	// cnwrl1 28/07/2010 PAR 24415 - end of coding
	
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doNotableRemove" id="0a44fc6a-6465-47ae-a84d-579fd24c62c8">
        <source>doNotableRemove(_object: CM_EDIData);
// ---------------------------------------------------------------------------
// Created:     26 April 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin
	// no need for inheritMethod
	
	if  self.allNotableObjects.includes(_object) then
		self.allNotableObjects.remove(_object);				// no exception even if invalid object
		self.endNotification(_object, Object_Update_Event);	// no exception even if invalid object
		self.endNotification(_object, Object_Delete_Event);	// no exception even if invalid object
	endif;
epilog

end;</source>
        <Parameter name="_object" type="CM_EDIData"/>
    </JadeMethod>
    <JadeMethod name="doPreQuery" id="0d7526a3-2d57-4133-a740-0664a42ef986">
