    <JadeMethod name="initCmbSchema" id="b5e688b8-ca82-487b-a6de-8e2e37547df3">
        <source>initCmbSchema() protected;
// ---------------------------------------------------------------------------
// Created:     15 March 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpSchema	: Schema;
	tmpAllSchemas	: SchemaColl;
begin

	create tmpAllSchemas transient;
	rootSchema.allSubschemas(tmpAllSchemas);
	
	foreach tmpSchema in tmpAllSchemas do
		self.cmbSchema.addItem(tmpSchema.name);
	endforeach;

	self.cmbSchema.text := currentSchema.name;

epilog
	delete tmpAllSchemas;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initiateRequest" id="5bf3d77a-eef1-48a9-8023-48fe39ad7e42">
        <updating/>
        <source>initiateRequest(_getIniFile, _listFiles, _getFiles, _getVerInfo : Boolean; 
			_filesToGet, _foldersToList : HugeStringArray; 
			_useCardLogDir, _useJadeLogDir, _useJadeCrashLogDir, 
			_useTempDir, _useDbaseDir, _useTransientDir : Boolean;
			_timeStampFrom, _timeStampTo : TimeStamp) updating, protected;
// ---------------------------------------------------------------------------
// Created:     07 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars

begin

	if _getFiles and txtSaveDir.text = null then
		app.msgBox('You must specify a directory to save files to if you are getting files.', 'Error', MsgBox_OK_Only);
		txtSaveDir.setFocus;
		return;
	endif;

	if self.myNodeFileRequest &lt;&gt; null then
		if self.myNodeFileRequest.isBeingActioned then
			app.msgBox('A request is already being actioned.  You must wait until this is complete.', 'Error', MsgBox_OK_Only);
			return;
		endif;
	endif;
	
	beginTransaction;

	if self.myNodeFileRequest = null then
		create self.myNodeFileRequest persistent;
	else
		exclusiveLock(self.myNodeFileRequest);
	endif;
	
	self.myNodeFileRequest.sendRequest(_getIniFile,
									   _listFiles,
									   _getFiles,
									   _getVerInfo,
									   _filesToGet, _foldersToList,
									   _useCardLogDir,
									   _useJadeLogDir,
									   _useJadeCrashLogDir,
									   _useTempDir,
									   _useDbaseDir,
									   _useTransientDir,
									   _timeStampFrom, _timeStampTo);

	commitTransaction;
	
	self.beginNotification(self.myNodeFileRequest, self.myNodeFileRequest.NR_NodeRequestLogEntryEvent, Response_Continuous, 0);
	self.beginNotification(self.myNodeFileRequest, self.myNodeFileRequest.NR_NodeRequestCompleteEvent, Response_Cancel, 0);

	self.tblLogEntries.rows := self.tblLogEntries.fixedRows;
	
	if global.isValidObject(self.myProcess) then
		self.myProcess.causeEvent(self.myNodeFileRequest.NR_NodeRequestActionEvent, true, self.myNodeFileRequest);
		staMain.caption := 'Request sent to process ' &amp; self.myProcess.String;
	else
		app.msgBox('Process has been deleted.', 'Error', MsgBox_OK_Only);
	endif;
	
	btnCancelRequest.visible := true;
	btnSend.visible := false;

epilog
	if process.isInTransactionState then
		abortTransaction;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_getIniFile" type="Boolean"/>
        <Parameter name="_listFiles" type="Boolean"/>
        <Parameter name="_getFiles" type="Boolean"/>
        <Parameter name="_getVerInfo" type="Boolean"/>
        <Parameter name="_filesToGet" type="HugeStringArray"/>
        <Parameter name="_foldersToList" type="HugeStringArray"/>
        <Parameter name="_useCardLogDir" type="Boolean"/>
        <Parameter name="_useJadeLogDir" type="Boolean"/>
        <Parameter name="_useJadeCrashLogDir" type="Boolean"/>
        <Parameter name="_useTempDir" type="Boolean"/>
        <Parameter name="_useDbaseDir" type="Boolean"/>
        <Parameter name="_useTransientDir" type="Boolean"/>
        <Parameter name="_timeStampFrom" type="TimeStamp"/>
        <Parameter name="_timeStampTo" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="keyDown" id="2db26486-2a90-43a1-b01f-bbc488554a11">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
09 December 2019	jlgmd1	Initial creation

*/
vars

begin
	if keyCode = CNEC_KEY_F12 then
		if (app.isSpecial() or app.isDevelopmentSystem()) and shift.cnEcIsCtrlKey() then
			if shift.cnEcIsShiftKey() then
				self.cnEcShowContents();
			else
				self.cnEcShowGuiInfo();
			endif;
		endif;
	endif;
	
	if fldMain.topSheet = shtParser then
		if keyCode = J_key_Enter then
			btnSearch.click(btnSearch);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="load" id="fcfc5134-d322-4291-bd83-43088c53dad6">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
// ---------------------------------------------------------------------------
// Created:     04 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	now		: TimeStamp;
begin

	btnCancelRequest.visible := false;

	tblFilesList.accessCell(1,1).text := 'Results';
	tblFilesList.accessCell(1,1).mergeCells := Table.MergeCells_Merge;
	tblFilesList.accessCell(2,1).text := 'Name' &amp; Tab &amp;
										'Last Modified' &amp; Tab &amp;
										'Size' &amp; Tab &amp; 
										'Folder';

	tblFilesList.selectMode := Table.SelectMode_CurrentRow;

	tblFilesToGet.accessCell(1,1).text := 'Files to Return';
	tblFilesToGet.accessCell(1,1).mergeCells := Table.MergeCells_Merge;
	tblFilesToGet.accessCell(2,1).text := 'Name' &amp; Tab &amp; 
										'Last Modified' &amp; Tab &amp;
										'Size' &amp; Tab &amp; 
										'Folder';

	tblFilesToGet.selectMode := Table.SelectMode_CurrentRow;
	
	self.initCmbSchema();
	txtMaxNum.text := '1000';
	
	//activity capture
	self.lastMessageTime := now;
	self.myActivityCapture := app.myPassport.myActivityCapture;
	self.loadActivityTypes();
	self.beginSysActivityNotification();
	self.beginTimer(1500, Timer_Continuous, TIMER_SYS_ACTIVITY_REFRESH);
	
	self.saveActivityCapture();
	self.refreshJRWINIButtons();
	self.resize;
	
	// Log parser
	create self.myParserAgent transient;
	self.initCmbProcTypeList();		// TFS 48181 jlgmd1 09/01/2020
	
end;</source>
    </JadeMethod>
    <JadeMethod name="loadActivityTypes" id="07c42fca-882f-4669-904d-34de81ee5ffe">
        <source>loadActivityTypes() protected;
/*
----------   ----------  --------------------------------------------------
Created:	09 June 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	cmb			: ComboBox;
begin
	cmb := self.cmbActivityType;
	cmb.clear();
	cmb.sorted := false;
	
	cmb.itemData[cmb.addItem('Capture Transactions')] := CM_ActivityCapture.CaptureMode_Transaction;
	cmb.itemData[cmb.addItem('Capture Form Loads')] := CM_ActivityCapture.CaptureMode_FormLoad;
	cmb.itemData[cmb.addItem('Capture Form Refresh')] := CM_ActivityCapture.CaptureMode_FormRefresh;
	//cmb.itemData[cmb.addItem('Capture Form User Notifications')] := CM_ActivityCapture.CaptureMode_FormUserNote;
	//cmb.itemData[cmb.addItem('Capture Form System Notifications')] := CM_ActivityCapture.CaptureMode_FormSystemNote;
	cmb.itemData[cmb.addItem('Capture Searches')] := CM_ActivityCapture.CaptureMode_Search;
	cmb.itemData[cmb.addItem('Capture Reports')] := CM_ActivityCapture.CaptureMode_Report;
	
	cmb.itemData[cmb.addItem('Capture Misc Debug')] := CM_ActivityCapture.CaptureMode_DebugMisc;
	
	cmb.listIndex := 1;
end;</source>
        <access>protected</access>
    </JadeMethod>
