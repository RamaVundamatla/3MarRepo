    <JadeMethod name="setupForm" id="2f9b0fc5-b96f-4ac4-a90b-dc6ec857fecd">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Feb 2023 navtnr20	TFS CR 55646 TTask 55665: UI - Contract Details
16 October 2023	navmv20	Bug 60893: FR - 54089 - Invoice Contract screens - Modal mode
25 October 2023 navmv20 CR 60503 Task 60505: UI - Contract Rate Entry UI Changes
03 Sep 2024	navnk30		Bug 65602: FR - 54089 - Invoice Contract - permissions
*/

vars
	
begin
	inheritMethod();
	
	
	self.splMain.setRightControl(self.tblInfo);
	self.splMain.setLeftControl(self.tblData);
	self.splMain.setLeftToRightRatioAndResize(30);
	self.splMain.top := self.topMargin;
	
	
	self.handleMenusForModalDisplay();
	self.doPermissions();	//03.09.2024 navnk30 #65602
	self.doCmbShippingterm();
	self.doCmbInvoiceLinesBuild();
	self.initTblContractRateMaint(ETDef_ContractRate);
	//if self.updateMode then
	if self.mode = self.MODE_UPDATE or self.mode = self.MODE_COPY then //31/01/2023	navkc1 Bug 61578
		// ### TFS BUG 59913 31AUG2023 NAVAB1
		if self.myContractDetails&lt;&gt; null then
			self.myInvLineDescription := self.myContractDetails.myInvoiceLineType;
		endif;
		self.doCmbCalculationTypes(self.myInvLineDescription); 
		
		self.chkVolume.enabled := false;	 //15-03-2023 navtnr20 CR 55647 TASK 55696
		
		self.populateContractDtl();
		self.tblDisplayRow();
		
		//31/01/2023	navkc1 Bug 61578 - Disable these buttons, user need to save the contract details before they can make changes to the rates
		if self.mode = self.MODE_COPY then
			self.btnAdd.enabled := false;
			self.btnAdd.setBubbleHelpForTranslation(app.getErrorString(Contr_disab_pleas_save_chang_e));
			self.btnRemoveRtEnt.enabled := false;
			self.btnRemoveRtEnt.setBubbleHelpForTranslation(app.getErrorString(Contr_disab_pleas_save_chang_e));
			self.btnUpdate.enabled := false;
			self.btnUpdate.setBubbleHelpForTranslation(app.getErrorString(Contr_disab_pleas_save_chang_e));
			self.btnRemoveRate.enabled := false;
			self.btnRemoveRate.setBubbleHelpForTranslation(app.getErrorString(Contr_disab_pleas_save_chang_e));
			self.btnNew.enabled := false;
			self.btnNew.setBubbleHelpForTranslation(app.getErrorString(Contr_disab_pleas_save_chang_e));
		endif;
	else
		self.clearFields();
	endif;
	self.setCaption(self.caption &amp;" - " &amp; self.myCurrentBank.code);	 // ### TFS BUG 58106 23MAY2023 NAVAB1
	self.setCriteriaLabel(self.myContractDetails);
	//Start //15-03-2023 navtnr20 CR 55647 TASK 55696 
	if self.chkVolume.value = true then	
		self.grpAmountFrom.visible := true;
		self.grpAccumulateFor.visible := true;
		self.tblGrp.height	:=self.tblGrp.height-60;
		self.tblGrp.top	:= 350;
		self.grpAmountFrom.top := 260;
		self.grpAccumulateFor.top := 300;
	else
		self.grpAmountFrom.visible := false;
		self.grpAccumulateFor.visible := false;
		self.tblGrp.height	:= 307;
		self.tblGrp.top	:= 265;
	endif;
	self.tblGrp.height := self.btnSave.top - self.tblGrp.top - 10;
	//End //15-03-2023 navtnr20 CR 55647 TASK 55696
	
	self.zOrder(2); //16/10/2023	navmv20	Bug 60893
epilog

end;</source>
    </JadeMethod>
