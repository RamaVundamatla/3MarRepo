    <JadeMethod name="doChangeToInterchangeArea" id="5f8e1397-e6c6-4ba3-91e1-2ed6d7820b41">
        <source>doChangeToInterchangeArea() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 May 2010	cnwer1	Initial creation
06 Oct 2010 cnwer1	PAR 25923
17/08/2016 	cnwrh7	TFS	2501
*/
constants 	
	Margin = 5;
vars
	theRow: Integer;
	makeICVisible : Boolean;
	bottomCell,
	bCell	: JadeTableCell;
	bottomEntRow : String;	
begin
	makeICVisible:=not self.myMoveTableDetails.isEntRowNameVisible(ETRow_IcArea);
	
	self.myMoveTableDetails.setEntRowVisible(ETRow_TargetID,not makeICVisible);
	self.myMoveTableDetails.setEntRowVisible(ETRow_IcArea,makeICVisible);
	
	self.grpICFrom.visible:=makeICVisible;
	self.myMoveTableDetails.setRowVisibleAfterEntRow(ETRow_TargetID,makeICVisible);
	
	if makeICVisible then
		self.btnTargetSearch.visible:=false;
		if self.getWorkingTwinDTOEntry &lt;&gt; null then
			self.myMoveTableDetails.setRowVisibleAfterEntRow(ETRow_TargetID, false);
			if self.myMachine.isTwinLift then
				bottomEntRow:=ETRow_TwinID;
				if not self.myVMAgent.getMyRTVehicleConfig.canRemoveSplitScreen then
					self.myMoveTableDetails.setEntRowVisible(ETRow_TwinTargetID,false);
				else
					bottomEntRow:=ETRow_TargetID;
				endif;
			elseif self.myMachine.isTandemLift then
				bottomEntRow:=ETRow_TandemID;
				self.myMoveTableDetails.setEntRowVisible(ETRow_TandemTargetID,false);
			endif;
		else
			bottomEntRow:=ETRow_CargoID;
			//if self.myWeightInterfaceController &lt;&gt; null then							//-TFS2501
			if self.myWeightInterfaceController &lt;&gt; null or self.myTCPWeightInterfaceController &lt;&gt; null then		//+TFS2501
				bottomEntRow:=ETRow_TotalWeight;	
			endif;
		endif;
		self.tblMoveEntry.fitTableHeight;
		self.btnSwap.visible:=false;
		self.btnIC.caption:=app.getErrorString(Back);
		bCell:=self.tblMoveEntry.accessCell(self.myMoveTableDetails.findRowWithEntRowName(bottomEntRow)+2,self.DataColumn);
	
		self.grpICFrom.top:=  self.tblMoveEntry.top + bCell.positionTop;
		self.grpICFrom.left:=bCell.positionLeft;
		self.setupICFields();
		bottomCell:=self.tblMoveEntry.accessCell(self.myMoveTableDetails.findRowWithEntRowName(ETRow_IcArea)+2,self.DataColumn);
		
	else
		if self.getWorkingTwinDTOEntry &lt;&gt; null then
			if self.myMachine.isTwinLift then
				bottomEntRow :=ETRow_TwinTargetID;
				if not self.myVMAgent.getMyRTVehicleConfig.canRemoveSplitScreen then
					self.myMoveTableDetails.setEntRowVisible(ETRow_TwinTargetID,true);
				else
					bottomEntRow:=ETRow_TargetID;
				endif;
			elseif self.myMachine.isTandemLift then
				bottomEntRow :=ETRow_TandemTargetID;
				self.myMoveTableDetails.setEntRowVisible(ETRow_TandemTargetID,true);
			endif;	
			self.setBtnSwapVisible(bottomEntRow);
		else
			bottomEntRow:=ETRow_TargetID;
		endif;
		
		bottomCell:=self.tblMoveEntry.accessCell(self.myMoveTableDetails.findRowWithEntRowName(bottomEntRow) + 2,self.DataColumn);
	
		self.btnIC.caption:=app.getErrorString(Pick_interchange);
		self.btnTargetSearch.visible:=self.btnGraphic.visible;
	endif;
	
	if self.btnSwap.visible then
		self.btnIC.top:=self.btnSwap.top + self.btnSwap.clientHeight  + 5;
	else
		self.btnIC.top:=self.tblMoveEntry.top + bottomCell.positionTop + Margin;
	endif;
	
	self.btnIC.left:=bottomCell.positionLeft;
	self.btnIC.visible:=true;
	self.tblMoveEntry.fitTableHeight();
	self.setFrmMoveEntryScollRange();
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doChangeToVoyageDischarge" id="b104b7e6-3d10-4511-8374-847dd431861b">
        <updating/>
        <source>doChangeToVoyageDischarge() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 June 2010	cnwer1	Initial creation

*/

vars

begin
	self.tblTasks.clear;
	if self.btnVoyDischarge.value then
		//epr par 33423 CCMS 2330 show voyage discharge button when in get next mode
		if not app.myVMAgent.showingTaskList then
			self.doShowTaskList(true);
			app.myVMAgent.setShowingTaskList(true); //epr par 33495 13/2/14
		endif;
		
		self.myVMAgent.resetNotesForVoyageDischarge();
		app.myVMAgent.setupTableHeadings(self.tblTasks);	
		self.btnAccept.caption:=app.getErrorString(Pickup);
		self.btnSearchTwin.visible:=self.myMachine.machineLiftType = TWIN_LIFT;
		self.btnSearchTwin.value:=false;
		self.btnTaskMode.enabled:=false;
	else
		//epr par 33495 13/2/14
		if  app.myVMAgent.getMyRTVehicleConfig.taskViewMode = CM_RTVehicleConfig.TASKVIEW_GETNEXT then
			self.doShowTaskList(false);
		endif;
		
		self.myVMAgent.startNotes;
		self.setupTasksTable();
		self.clearTableData(self.tblTasks);
		app.myVMAgent.initTable(self.tblTasks);
		self.btnAccept.caption:=app.myVMAgent.getMoveTaskStr;
		self.btnSearchTwin.visible:=false;
		self.btnTaskMode.enabled:=true;
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doControlChangedQueue" id="fcd71665-e0c8-47e3-9355-739fa809fdd9">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_VehicleMountedDetails::doControlChangedQueue"/>
        </interfaceImplements>
        <updating/>
        <source>doControlChangedQueue() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13/04/2010	cnwer1	Initial creation
27/01/2016	cnwdap1	PAR #37374 Set columns on tblMoveEntry to avoid invalid column errors
*/

vars
	queueId : String;
begin
	//epr par 36796 16/11/15
	if app.myVMAgent.getMyRTVehicleConfig.canRemoveTargetSource then
		//epr par 37374
		self.myMoveTableDetails.clearData(3);
		if self.myMoveTableDetails.myTable.columns &gt;= 5 then
			self.myMoveTableDetails.clearData(5);
		endif;
	
	else
		self.loadTable(self.tblTasks);
	endif;
	
	// epr 1/3/2011 was using machine::queueId however this returns the next Primary queue first if there is one
	if self.myMachine.myPrimaryQueue &lt;&gt; null then
		queueId:=self.myMachine.myPrimaryQueue.id.asStringJMT;
	endif;
	
	self.addInfoDisplay(app.getErrorString1(Control_transferred_queue, queueId));
	self.updateCaption;
	global.beep;
	
	self.showVoyageDischargeButton();
	if not self.btnVoyDischarge.visible then
		self.btnSearchTwin.visible:=false;
		//epr par 33141 33495 13/2/14
		if self.btnVoyDischarge.value then
			self.btnVoyDischarge.value:=false;
			self.doChangeToVoyageDischarge();
		endif;
		
	endif;
	
	
	
	self.repositionButtons();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doControlChangedTarget" id="900ccf29-ce3e-4936-872d-feeedb90eb97">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_VehicleMountedDetails::doControlChangedTarget"/>
        </interfaceImplements>
        <updating/>
        <source>doControlChangedTarget(_rtQueueEntry : CM_RTQueueEntry) protected, updating;
/*

Date		Who		Reason
11 February 2014	cnwer1	Initial creation PAR 33401

*/

vars
	dataColumn ,targetRow: Integer;
	twinTask : CM_RTQueueTask;
	targetRowEnt : String;
	targetCell : JadeTableCell;
	screenMode : CM_RTScreenConfig;
	targetLC : CM_LocationsController;
begin
	
	if self.myMachine.allCurrentQueueTasks.size = 0 then
		return;
	endif;
	
	targetLC:=_rtQueueEntry.getTargetLocation;
	//epr par 33401
	if self.frmTop.height &gt; 1 and targetLC &lt;&gt; null then
		self.lblInfo.caption:=app.getErrorString1(Target_location_changed,targetLC.getFullId());
	endif;
	
	screenMode:=self.myVMAgent.getMyScreenMode;
	dataColumn:=DataColumn;

	twinTask:= self.myMachine.getCurrentTwinTask;
	if twinTask &lt;&gt; null and twinTask.myEntry = _rtQueueEntry then
		self.hasControlChangedTwinTarget:=true;
	else
		self.hasControlChangedTarget:=true;
	endif;
	
	if self.hasWorkingTask() then
		//epr par 34591 21/7/14
		targetRowEnt:=ETRow_TargetID;
		targetRow:=self.myMoveTableDetails.findRowWithEntRowName(targetRowEnt);
		if targetRow &gt; 0 then
			targetCell:=self.tblMoveEntry.accessCell(targetRow,DataColumn );
			targetCell.foreColor:=screenMode.tableSelectColour;
		endif;	
		//epr par 34591 21/7/14
		if self.hasControlChangedTwinTarget then
			if self.myVMAgent.getMyRTVehicleConfig.canRemoveSplitScreen then
			//	dataColumn:=DataColumn;	
				targetRowEnt:=ETRow_TargetID;
				dataColumn:=5;
			else
				targetRowEnt:=ETRow_TwinTargetID;
			endif;
				
			targetRow:=self.myMoveTableDetails.findRowWithEntRowName(targetRowEnt);
			if targetRow &gt; 0 then
				targetCell:=self.tblMoveEntry.accessCell(targetRow,dataColumn );
				targetCell.foreColor:=screenMode.tableSelectColour;
			endif;		
		endif;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rtQueueEntry" type="CM_RTQueueEntry"/>
    </JadeMethod>
    <JadeMethod name="doControlResetSession" id="e251b751-6001-40b8-9861-446869dce45f">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_VehicleMountedDetails::doControlResetSession"/>
        </interfaceImplements>
        <updating/>
        <source>doControlResetSession() updating;
/*

Purpose:			

Parameters:			

Return Value:		


