    <JadeMethod name="utlUpdateSecurityRole" id="90b4a2a7-d936-4d60-b963-2df1b809b9fb">
        <source>utlUpdateSecurityRole(_pxyRole : CM_SecurityRole; _permAgent : CM_PermissionAgent; _passport : CM_Passport input);
						
// ---------------------------------------------------------------------------
// Created:     27 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	realRole	: CM_SecurityRole;

begin

	self.initialiseActivity();

	app.myValUA.valSecurityRole(_pxyRole, _permAgent);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	realRole := self.getRealObjectAndEditionCheck(_pxyRole, 'Security Role', _passport).CM_SecurityRole;

	exclusiveLock(realRole);
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realRole, true);
	endif;

	if _passport.noErrors then
		// Perform the operation
		realRole.setForUpdate(_pxyRole);
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realRole, false);
	endif;

end;</source>
        <Parameter name="_pxyRole" type="CM_SecurityRole"/>
        <Parameter name="_permAgent" type="CM_PermissionAgent"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateSegMatrix" id="50100fc7-ca1a-4605-9343-535545750da3">
        <source>utlUpdateSegMatrix(_segMatrixAgent : CMIF_SegregationMatrixAgent; _passport : CM_Passport input);
/*
----------   ----------  --------------------------------------------------
Created:	24 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	matrixTrans			: CM_SegregationMatrixTrans;
	newRule,
	updatedRule,
	deletedRule			: CM_SegregationRule;
	allDeletedRules		: CM_ObjectSet;
	
begin

	self.initialiseActivity();

	app.myValUA.valSegregationMatrix(_segMatrixAgent, _passport);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	create allDeletedRules transient;
	
	foreach matrixTrans in _segMatrixAgent.allSegMatrixTransByRowCol do
		if matrixTrans.mySegregationRule = null and matrixTrans.myPxySegregationRule = null then
			//has not been edited, and there is no existing rule at this juncture
			continue;
		endif;
		
		if matrixTrans.mySegregationRule = null and matrixTrans.myPxySegregationRule &lt;&gt; null then
			//user has added a rule at this juncture
			create newRule persistent;
			newRule.setForUpdate(matrixTrans.myPxySegregationRule);
		
		elseif matrixTrans.mySegregationRule &lt;&gt; null and matrixTrans.myPxySegregationRule &lt;&gt; null then
			//user has update the rule at this juncture
			matrixTrans.mySegregationRule.setForUpdate(matrixTrans.myPxySegregationRule);
		
		elseif matrixTrans.mySegregationRule &lt;&gt; null and matrixTrans.myPxySegregationRule = null then
			//user has deleted the rule at this juncture
			//th2 - validate for delete here??
			allDeletedRules.add(matrixTrans.mySegregationRule);
		endif;
		
		if not self.checkValidationWithPassport(_passport) then
			return;
		endif;
	endforeach;
	
	allDeletedRules.purge();
	
	_passport.myTerminal.refreshHazardMoveDetails(_segMatrixAgent.ruleType);
	
	
epilog
	delete allDeletedRules;
end;
</source>
        <Parameter name="_segMatrixAgent" type="CMIF_SegregationMatrixAgent"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateSegregationCond" id="27c98993-4719-46f5-b53b-15f16b41ae9c">
        <source>utlUpdateSegregationCond(_pxySegCond : CM_SegregationCondition; _passport : CM_Passport input);
/*
----------   ----------  --------------------------------------------------
Created:	24 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	realSegCond				: CM_SegregationCondition;

begin

	self.initialiseActivity();

	app.myValUA.valSegregationCond(_pxySegCond);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	realSegCond := self.getRealObjectAndEditionCheck(_pxySegCond, 'Segregation Condition', _passport).CM_SegregationCondition;

	exclusiveLock(realSegCond);
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realSegCond, true);
	endif;

	if _passport.noErrors then
		// Perform the operation
		realSegCond.setForUpdate(_pxySegCond);
	endif;
	realSegCond.myTerminal.refreshHazardMoveDetails(realSegCond.type);
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realSegCond, false);
	endif;

end;</source>
        <Parameter name="_pxySegCond" type="CM_SegregationCondition"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateSelectorQuery" id="79fdda2d-69a2-42e0-8371-cc5ba09a36d7">
        <source>utlUpdateSelectorQuery(_pxyQuery : CM_MenuUserQuery input; 
					_parent : CM_MenuEntity input;
					_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     15 April 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	cancelSave 			: Boolean;
	realQuery			: CM_MenuUserQuery;
begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValUA.valSelectorQuery(_pxyQuery);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	realQuery := _pxyQuery.pxyGetRealObject;
	if realQuery = null then
		app.raiseCMException1(ProxyMgrCannotLocateReal, _pxyQuery.String, null, null);
	endif;
	
	realQuery.setForUpdate(_pxyQuery);
	realQuery.setForUpdateUserQuery(_pxyQuery);
	
	if _passport.noErrors and
	   app.myRoot.myQueryMenuRoot &lt;&gt; null then
		app.myRoot.myQueryMenuRoot.causeEvent(Event_Selector_Update, false, realQuery);	// 26608 Dec 2010 snap shot definition form issues
	endif;
end;</source>
        <Parameter name="_pxyQuery" type="CM_MenuUserQuery" usage="input"/>
        <Parameter name="_parent" type="CM_MenuEntity" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
