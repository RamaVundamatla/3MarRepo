    <JadeMethod name="getCargoLabelFormat" id="dcb57fe7-d821-413b-ae0f-cf8c0b69a1ef">
        <source>getCargoLabelFormat():String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 January 2010	cnwndl1	Initial creation	CCMS MES 1004

*/

vars

begin

	if self.cargoLabelFormat = null then
		return self.DefaultFormat;
	else
		return self.cargoLabelFormat;
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNextCargoId" id="347bfe91-ca96-4f9b-abed-fd9740ee7d2a">
        <updating/>
        <source>getNextCargoId():String updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 January 2010	cnwndl1	Initial creation	CCMS MES 1004
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

	prefix : String;
	year : String;
	seqNum : Real;
	newCargoId : String;
	existingTi : CM_TrackedItem;
	nextSeqNum : Real;
	
	failSafeCount : Integer;
	
begin

	// get the value set up last time thru, or by the last user edit.
	seqNum := self.nextSequenceNum;
	year := app.actualTimeServer.Date.format("yy");		// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support

	if self.cargoIdStyle = AutoIdStyle_P_YY_SSS or self.cargoIdStyle = AutoIdStyle_P_SSS then
		prefix := self.cargoIdPrefix;
	endif;
	if self.cargoIdStyle = AutoIdStyle_P_YY_SSS or self.cargoIdStyle = AutoIdStyle_YY_SSS then
		prefix := prefix &amp; year;
		if year &lt;&gt; lastIdGeneratedYear then
			// new year, time to reset the counter.
			seqNum := 1;
		endif;
	endif;
	
	while true do
		if seqNum.String.length &gt; self.cargoIdSeqNumLength then
			// just in case the user has made the seq num length shorter since last time thru,
			// or we have naturally reached the end of the series and need to reset.
			seqNum := 1;
		endif;
		newCargoId := prefix &amp; seqNum.String.padLeadingZeros(self.cargoIdSeqNumLength);
		existingTi := self.myTerminal.allOnsiteTIsByIdCargoType.getAtKeyGeq(newCargoId,null);
		if existingTi = null or existingTi.id &lt;&gt; newCargoId then
			// no existing onsite cargo with the same id.
			break;
		endif;
		seqNum := seqNum + 1;
		
		failSafeCount := failSafeCount + 1;
		if failSafeCount &gt; 9 then
			return null;
		endif;
		
	endwhile;
	
	nextSeqNum := seqNum + 1;
	if nextSeqNum.String.length &gt; self.cargoIdSeqNumLength then
		nextSeqNum := 1;
	endif;
	
	beginTransaction;
	self.setLastAndNextValues(	newCargoId, year, nextSeqNum);
	commitTransaction;
	
	return newCargoId;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="3605013a-12b7-4b3b-b301-25874c6440fe">
        <updating/>
        <source>setForCreate( _proxy : CM_AutoCargoIdController ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 January 2010	cnwndl1	Initial creation	CCMS MES 1004
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

begin

	_proxy.raiseExceptionIfNotTransient(method);
	
	self.lastIdGeneratedYear := app.actualTimeServer.Date.format("yy");	// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.setForUpdate(_proxy);
	
	self.validateMe;
	
epilog

end;</source>
        <Parameter name="_proxy" type="CM_AutoCargoIdController"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="b482439f-909d-4043-9072-b891576a16d1">
        <updating/>
        <source>setForUpdate( _proxy : CM_AutoCargoIdController  ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 January 2010	cnwndl1	Initial creation	CCMS MES 1004

*/

vars

begin

	self.nextSequenceNum := _proxy.nextSequenceNum;
	self.cargoIdPrefix := _proxy.cargoIdPrefix;
	self.cargoIdSeqNumLength := _proxy.cargoIdSeqNumLength;
	self.cargoIdStyle := _proxy.cargoIdStyle;
	self.cargoLabelFormat := _proxy.cargoLabelFormat;

	self.myTerminal := _proxy.myTerminal;
	
epilog

end;</source>
        <Parameter name="_proxy" type="CM_AutoCargoIdController"/>
    </JadeMethod>
    <JadeMethod name="setLastAndNextValues" id="511cc6fd-3a0b-4d12-bef5-6627e85a77f8">
        <updating/>
        <source>setLastAndNextValues(	_lastIdGenerated : String;
						_lastIdGeneratedYear : String;
						_nextSeqNum : Real
						) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 January 2010	cnwndl1	Initial creation	CCMS MES 1004

*/

vars

begin

	self.lastIdGenerated := _lastIdGenerated;
	self.lastIdGeneratedYear := _lastIdGeneratedYear;
	self.nextSequenceNum := _nextSeqNum;
	
epilog

end;</source>
        <Parameter name="_lastIdGenerated" type="String"/>
        <Parameter name="_lastIdGeneratedYear" type="String"/>
        <Parameter name="_nextSeqNum" type="Real"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="1ca3ae82-0f94-4e55-8633-37aba3a9b582">
        <updating/>
        <source>setProxy(	_cargoIdPrefix : String ;
			_cargoIdSeqNumLength : Integer;
			_cargoIdStyle : Integer;
			_cargoLabelFormat : String; 
			_myTerminal : CM_Terminal; 
			_nextSequenceNum : Real
			) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 January 2010	cnwndl1	Initial creation	CCMS MES 1004

*/

vars

begin

	self.raiseExceptionIfNotTransient(method);

	self.nextSequenceNum := _nextSequenceNum;
	self.cargoIdPrefix := _cargoIdPrefix;
	self.cargoIdSeqNumLength := _cargoIdSeqNumLength;
	self.cargoIdStyle := _cargoIdStyle;
	self.cargoLabelFormat := _cargoLabelFormat;
	self.myTerminal := _myTerminal;
	
epilog

end;</source>
        <Parameter name="_cargoIdPrefix" type="String"/>
        <Parameter name="_cargoIdSeqNumLength" type="Integer"/>
        <Parameter name="_cargoIdStyle" type="Integer"/>
