    <JadeMethod name="addToolbarControls" id="9d28efaf-834b-4c92-894b-79afb01a06e8">
        <updating/>
        <source>addToolbarControls() updating, protected;
//--------------------------------------------------
// Created:	13 April 2005 By: cnwgd1
// 03.03.2021 cnwma1 Bug 50882: STWO - Hide Resync Storage Transactions on voyage enquiry
//--------------------------------------------------
// Changed On By Reason
// ---------- ---------- --------------------------------------------------
// 04 Mar 2022  navgm20     TFS #53051 MTN - Add Filter to Vessel Enquiry, Voyage Enquiry
// 20 Apr 2022  navtnr20	TFS 53142 Cargo Forecast on Voyage &amp; Train
// 04 Jul 2024	navnk30		ChangeRequest 64613: NSW - Auto Voyage Configuration. Task 64639.
vars
	toolbar       : CMUI_Toolbar;
	storageConfig : CM_StorageConfig;
begin
	inheritMethod();

	toolbar := self.frmToolbar;
	toolbar.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnReportOptions, CMUI_Toolbar.Control_Alignment_Left);		
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton(self.btnShowSearch, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnVoyageDefin, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCopyVoyage, CMUI_Toolbar.Control_Alignment_Left);						
	toolbar.addButton(self.btnNew, CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addButton(self.btnEdit, CMUI_Toolbar.Control_Alignment_Left);
	//For Comalco only at this stage
	//epr 11/3/14 removing voyage commodity planning as part of bulk CCMS 1366
	toolbar.addButton(self.btnDelete, CMUI_Toolbar.Control_Alignment_Left);
	
	/*//23/04/2024	navkc1 CR63736 Task 63770 - Use new filter control
		// ### TFS 53051 --START
		toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
		toolbar.addFrame(self.frmFilter, CMUI_Toolbar.Control_Alignment_Left);
		self.txtFilterBox.parent 	:= self.frmFilter;
		self.txtFilterBox.visible 	:= true;
		self.txtFilterBox.left 		:= 0;
		self.txtFilterBox.top 		:= 2;
		toolbar.addButton(self.btnClearFilter, CMUI_Toolbar.Control_Alignment_Left);
		toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
		// ### TFS 53051 --END
	*///23/04/2024	navkc1 CR63736 Task 63770 end
	
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addFrame(self.frmTableFilter, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton(self.btnCargoForecast,CMUI_Toolbar.Control_Alignment_Left);		//20-Apr-2022 TFS 53142
	
	toolbar.addButton(self.btnSelectAll, CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);				
	
//	if app.myCurrentUserCan(self.myTerminal, PmShipPlanning) then
	// ### JIRA 33505 30DEC2024 NAVAB1 (Mod_CargoShip in part of base now)
	//if app.myCurrentUserCan(self.myTerminal, Mod_CargoShip) then//07 Oct 2019	NDL	TFS 46169
		toolbar.addButton(self.btnBayDefinition, CMUI_Toolbar.Control_Alignment_Left);		
		toolbar.addButton(self.btnROROEnquiry, CMUI_Toolbar.Control_Alignment_Left);
		toolbar.addButton(self.btnHoldDef, CMUI_Toolbar.Control_Alignment_Left); //15 Jul 2013	NDL	Par 31965
		//if app.myCurrentUserCan(self.myTerminal, Mod_CargoShip) then	//12 Dec 2018	NDL	TFS 42267
			toolbar.addButton(self.btnExchangeSum, CMUI_Toolbar.Control_Alignment_Left);
		//endif;
		toolbar.addButton(self.btnJobPriority, CMUI_Toolbar.Control_Alignment_Left);							
		toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);					
	//else
	//	self.mnuBayDefinition.visible := false;
	//	self.mnuExchangeSummary.visible := false;
	//endif;

	// ### JIRA 33505 30DEC2024 NAVAB1 (Mod_CargoShip in part of base now) if app.myCurrentUserCan(self.myTerminal, Mod_CargoShip) then
		toolbar.addButton(self.btnTranslations, CMUI_Toolbar.Control_Alignment_Left);
	//endif;	

	toolbar.addButton(self.btnOpenSchedule, CMUI_Toolbar.Control_Alignment_Left);				
	toolbar.addButton(self.btnArchive, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCheckList, CMUI_Toolbar.Control_Alignment_Left);					// TFS 4793
	toolbar.addButton(self.btnEventTrans, CMUI_Toolbar.Control_Alignment_Left); // PAR 35478
	toolbar.addButton(self.btnCustomsEDI, CMUI_Toolbar.Control_Alignment_Left);
//	if app.myPassport.myUser.canDo(self.myTerminal, PmKPIModule) then
	if app.myPassport.myUser.canDo(self.myTerminal, Mod_BaseSystem) then//07 Oct 2019	NDL	TFS 46169
		toolbar.addButton(self.btnKPIUpdate, CMUI_Toolbar.Control_Alignment_Left);
		toolbar.addButton(self.btnKPIView, CMUI_Toolbar.Control_Alignment_Left);
		
	endif;
	toolbar.addButton(self.btnShipDelaysEnq, CMUI_Toolbar.Control_Alignment_Left); // TFS 8166
	
	if (app.myRoot.canDo(Mod_Harbour)) // VTMIS License
	and app.myRoot.canDo(Mod_Invoicing) // Invoice License
	and self.myTerminal.getConfig(FinancialsEnabled).Boolean
	then // Invoicing Turned On
		toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);	
		toolbar.addButton(self.btnResourcesUsed, CMUI_Toolbar.Control_Alignment_Left);
		self.mnuResources.visible := true;
		self.mnuHarbourInvoices.visible := true;		
//		self.mnuReeval.visible := true;			// Nov 2010 CCMS 2020 par 26107 [now moved down]
		if app.myCurrentUserCan(self.myTerminal, PmHMSInvoiceStatus) then
			toolbar.addButton(self.btnHMSInvoice, CMUI_Toolbar.Control_Alignment_Left);
		endif;
	endif;
	// 26895 Feb 2011 cnwjre1 set up CCMS 2020 menu option if invoicing enabled, but don't need VTMIS or commodity planning
	if app.myRoot.canDo(Mod_Invoicing) // Invoice License
	and self.myTerminal.getConfig(FinancialsEnabled).Boolean then
		
		//self.mnuReeval.visible := true;			// CCMS 2020 par 26107
		self.mnuReeval.visible   := false;          // 03.03.2021 cnwma1 #50882
		// 03.03.2021 cnwma1 #50882
		if self.myTerminal &lt;&gt; null and self.myTerminal.myStorageConfig &lt;&gt; null then
			storageConfig :=  self.myTerminal.myStorageConfig;
			if storageConfig.shipReceivalType = Voyage_Rec_Ship_Exch_End or 
			   storageConfig.shipReleaseType  = Voyage_Ship_Exchange_End  then
				self.mnuReeval.visible := true;	
			endif;
		endif;
	endif;

	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);			
	toolbar.addButton(self.btnVesselDef, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnBookingRef, CMUI_Toolbar.Control_Alignment_Left); //AER 05/08/08 CCMS 1037
	
	if app.isSpecial() then				
		toolbar.addButton(self.btnShipGraphics, CMUI_Toolbar.Control_Alignment_Left);					
	endif;
	
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnNewCargo, CMUI_Toolbar.Control_Alignment_Left); //cnwas3 temporarily for the new cargo form ccms 1035 
	toolbar.addButton(self.btnOOWConfirm,CMUI_Toolbar.Control_Alignment_Left); //16 Mar 2018	NDL	TFS 37447
	
	if app.myRoot.canDo(Mod_VoyageAutoClosure) then // ### JIRA 33001 03OCT2024 NAVAB1
		toolbar.addButton(self.btnAutoVoyageConfig, CMUI_Toolbar.Control_Alignment_Left);		//04.07.2024 navnk30 CR #64613 Task #64639
		
		// ### TFS CR 64612 TASK 64659 18JUL2024 NAVAB1
		toolbar.addButton(self.btnAutoVoyageProgress, CMUI_Toolbar.Control_Alignment_Left);	
		self.btnAutoVoyageConfig.enabled := true;
		self.btnAutoVoyageProgress.enabled := true;
	endif;
	
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
	
	//=======================================
	// now setup searchToolbar
	//=======================================
	toolbar := self.frmSearchToolbar;

	toolbar.addButton(self.btnSearch, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnResetSearch, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnClearSearch, CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addButton(self.btnCloseSearch, CMUI_Toolbar.Control_Alignment_Left);
	
	
	toolbar.positionToolbarControls();
	toolbar.visible := true;
	
	self.setSearchToolbar();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="btnArchive_click" id="7a9f1ba3-c5a4-4234-a7b3-e889a3ab351f">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnArchive_click(btn: Button input) updating;
//--------------------------------------------------
// Created:	02 August 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.doArchive();
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnAutoVoyageConfig_click" id="235dc8f3-7154-4ce9-a98f-8c4242558330">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnAutoVoyageConfig_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Jul 2024	navnk30	ChangeRequest 64613: NSW - Auto Voyage Configuration. Task 64639.

*/

vars
	form			: SHP_AutoVoyageConfig;
	autoVoy : Boolean;
begin
	// ### TFS CR 64612 TASK 64659 18JUL2024 NAVAB1
	if self.myCurrentVoyage= null then
		return;
	endif;
	
	autoVoy := self.myCurrentVoyage.myVoyageProcess.isAutomaticProcess(); 

	if not autoVoy then
		global.beep;
		return;
	endif;
	
	form := app.loadForm(SHP_AutoVoyageConfig, CMUI_Assistant, false, false, true , self.myTerminal, null).SHP_AutoVoyageConfig; 
	form.showWithObjectMode(self.myCurrentVoyage, false);
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnAutoVoyageProgress_click" id="8161356c-aff2-4cc7-af61-799fd0ca3866">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnAutoVoyageProgress_click(btn: Button input) updating;
/*
Purpose:	

Date		Who		Reason
18 July 2024	navab1	CR 64612 TASK 64659
*/

vars

	form			: SHP_AutoVoyageMonitor  ;
	autoVoy : Boolean;
begin
	// ### TFS CR 64612 TASK 64659 18JUL2024 NAVAB1
	if self.myCurrentVoyage= null then
		return;
	endif;
	
	autoVoy := self.myCurrentVoyage.myVoyageProcess.isAutomaticProcess(); 

	if not autoVoy then
		global.beep;
		return;
	endif;

	form := app.loadForm(SHP_AutoVoyageMonitor  , CMUI_Assistant, false, false, true , self.myTerminal, null).SHP_AutoVoyageMonitor  ; 
	form.showWithObjectMode(self.myCurrentVoyage, false);

epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnBayDefinition_click" id="c1a84de5-f0af-4260-a509-64d5124f1c08">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnBayDefinition_click(btn: Button input) updating;
//--------------------------------------------------
// Created:	29 July 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	if self.myCurrentVoyage &lt;&gt; null
	and self.myCurrentVoyage.myCellularVoyageStructure &lt;&gt; null then
		self.myAssistant.showBayDefinitionForm(self.myCurrentVoyage, self.myMasterMenuAction, false);
	else
		self.myAssistant.showBayDefinitionForm(null, self.myMasterMenuAction, false);
	endif;					
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnBookingRef_click" id="f1cbb067-0697-40a7-b23f-b7eb56d5077a">
