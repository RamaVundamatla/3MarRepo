<Class name="CM_EDIFileTypeCSVMSCLoad" id="7f44bedb-bc3c-4c94-9d9e-6f632473f22f">
    <superclass name="CM_EDIFileTypeCSV"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
