    <JadeMethod name="createProductsForOperator" id="668e9d77-278d-49f1-8b46-fbf0d1906618">
        <source>createProductsForOperator(_operator : CM_Operator; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     14 January 2005 by cnwrs2
//
// Purpose:     Goes through all the combination of species/grade/type/treatment/length
//				that are valid for the code group and creates products for the passed
//				in operator.
// ---------------------------------------------------------------------------
vars
	tmpLength	: CM_LogLength;
	tmpTreat	: CM_LogTreatment;
	tmpType		: CM_LogType;
	tmpSpecies		: CM_LogSpecies;
	tmpGrade	: CM_LogGrade;
	tmpCode		: CM_Code;
	prodCode	: String;
	pxyLogProduct,
	realLogProduct	: CM_ProductLog;
begin

	if _operator = null then
		return;
	endif;
	
	foreach tmpCode in self.allCodes do
		tmpSpecies := tmpCode.CM_LogSpecies;
		foreach tmpCode in tmpSpecies.allLogGrades do
			tmpGrade := tmpCode.CM_LogGrade;
			foreach tmpType in tmpGrade.allLogTypes	do
				foreach tmpTreat in tmpGrade.allLogTreatments do
					foreach tmpLength in tmpGrade.allLogLengths do

						create pxyLogProduct transient;
						
						prodCode := app.buildLogProductCode(tmpSpecies.code, tmpGrade.code, tmpType.code, tmpTreat.code, tmpLength.code);

						
						// This will also raise an exception if the codes are not valid
						pxyLogProduct.setProxyLogProductFromCodes(prodCode, _operator, 
										tmpSpecies.code, tmpGrade.code, tmpType.code, 
										tmpTreat.code, tmpLength.code, _passport, null);
						if _passport.hasErrors then
							return;
						endif;
						
						realLogProduct := _operator.allProducts[TI_CargoType_Log, prodCode].CM_ProductLog;
						if realLogProduct = null and _passport.noErrors then
							// need to create the real product
							//beginTransaction;
							create realLogProduct persistent;
							realLogProduct.setForCreate(pxyLogProduct);
							
							if _passport.hasErrors then
								return;
							endif;
							//commitTransaction;
						endif;
					endforeach;
				endforeach;
			endforeach;
		endforeach;
	endforeach;

end;</source>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getDetailForRemoteQuery" id="cbef4ff7-eb72-43fa-9f94-e28b68669335">
        <source>getDetailForRemoteQuery(_version : Integer) : String;

// cnwdvb1 10 June 2003 
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls

vars

	iter	: Iterator;
	species	: CM_LogSpecies;
	detail	: String;

begin

	iter := self.allCodes.createIterator;
	while iter.next(species) do  
		
		detail := detail &amp; species.getDetailForRemoteQuery(_version);
	endwhile;
	return self.formatAsXMLPrefix(XML_CODEGRP) &amp; self.formatAsXML(XML_CODEID, self.name) &amp; 
	self.formatAsXMLPrefix(XML_CODES) &amp; detail &amp; self.formatAsXMLSuffix(XML_CODES) &amp; self.formatAsXMLSuffix(XML_CODEGRP);
	
epilog
	delete iter;

end;</source>
        <Parameter name="_version" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="0a261674-e3c0-4e2b-961a-b5c22e69b4f4">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:     12 October 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod();

	if not self.allLogLengths.isEmpty then
		app.raiseCMException2(ObjectStillHasEntries, 'Code Group ' &amp; self.name, 
							  self.allLogLengths.size.String &amp; ' Log Length Code', null, null);
	endif;

	if not self.allLogTreatments.isEmpty then
		app.raiseCMException2(ObjectStillHasEntries, 'Code Group ' &amp; self.name, 
							  self.allLogTreatments.size.String &amp; ' Log Treatment Code', null, null);
	endif;

	if not self.allLogTypes.isEmpty then
		app.raiseCMException2(ObjectStillHasEntries, 'Code Group ' &amp; self.name, 
							  self.allLogTypes.size.String &amp; ' Log Type Code', null, null);
	endif;

end;</source>
    </JadeMethod>
</Class>
