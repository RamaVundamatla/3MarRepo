    <JadeMethod name="listFlags" id="3f283421-94a0-4d12-88e3-8129a67e1e28">
        <source>listFlags(): String;
// ---------------------------------------------------------------------------
// Created:     Oct 2004 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	str: String;
begin
	str := str&amp;inheritMethod();
	if self.secondary then
		str := str&amp;"/Secondary ";
	endif; 
	return str;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="saveVersionCopyRefs" id="9f15b68c-d2c4-4bfa-b4f9-e90ac9b57ae4">
        <source>saveVersionCopyRefs(toClone: CM_Connect input) protected;
/*
 ------------------------------------------------------------------------
Created:			13 September 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars

begin
	inheritMethod(toClone);
	toClone.otherTrackedItem := self.otherTrackedItem;
end;</source>
        <access>protected</access>
        <Parameter name="toClone" type="CM_Connect" usage="input"/>
    </JadeMethod>
    <JadeMethod name="secondary" id="92016fb0-9903-4d6a-b9c6-337d613170d5">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>secondary(set: Boolean; _value: Boolean io) mapping, updating;
/*
 ------------------------------------------------------------------------
Created:			05 April 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
begin
	if set then
		if _value then
			flags := flags.bitOr(SecondaryFlag);
		else
			flags := flags.getValueWithBitUnset(SecondaryFlag);
		endif;
	else
		_value := (flags.bitAnd(SecondaryFlag) &lt;&gt; 0);
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setOtherTrackedItem" id="ea5db449-17b2-4a7c-adf5-041e13d206b8">
        <updating/>
        <source>setOtherTrackedItem(pTI : CM_TrackedItem) updating;
// ---------------------------------------------------------------------------
// Created:     13 September 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.otherTrackedItem		:= pTI;
	self.otherTrackedItemId		:= pTI.id;
	self.otherTrackedItemCargoType	:= pTI.cargoType;
	
	self.location := pTI.locationId;
	
end;</source>
        <Parameter name="pTI" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="updateTI" id="a32d9122-57ca-4139-8743-f3a12193c605">
        <updating/>
        <source>updateTI(_passport : CM_Passport input) updating;
//
// 10/12/2009	cnwdap1		CCMS MES 1007 Any TI can now be a reefer
// 11/03/2010	cnwdap1		PAR #22938 Correct reefer checking
//
vars

begin
	inheritMethod(_passport);
	if self.myTrackedItem = null then
		return;
	endif;
	
	//if not self.myTrackedItem.isKindOf(CM_Container) then		// CCMS 1007
	if self.myTrackedItem.isKindOf(CM_Container) or (self.myTrackedItem.isReefer) then	// PAR #22938
	else
		return;
	endif;
	
	//self.myTrackedItem.CM_Container.updateConnection;		// CCMS 1007
	self.myTrackedItem.updateConnection(self);					// CCMS 1007 //cnwrs1 10 May 2010 par 23815
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="a3969c0a-8993-415c-9185-e4f2d49a44d6">
        <source>validateForUpdate(pProxyTransaction: CM_Connect);
// ---------------------------------------------------------------------------
// Created:     24 September 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.connectType &lt;&gt; pProxyTransaction.connectType or
	   self.location &lt;&gt; pProxyTransaction.location or
	   self.otherTrackedItem &lt;&gt; pProxyTransaction.otherTrackedItem then
	   	// These fields cannot be updated ??????
	   	app.raiseCMException(ERR_INVALID_TRANS_EDIT, null, null);
	endif;

	inheritMethod(pProxyTransaction);

end;</source>
        <Parameter name="pProxyTransaction" type="CM_Connect"/>
    </JadeMethod>
</Class>
