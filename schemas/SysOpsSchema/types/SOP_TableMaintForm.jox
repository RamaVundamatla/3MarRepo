    <JadeMethod name="showHideMsgSearch" id="4e3a2a0f-bef0-4a01-95fb-091651f85ede">
        <source>showHideMsgSearch() protected;
/*
----------   ----------  --------------------------------------------------
Created:	06 August 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	
begin
	if self.frmSearchMsg.visible then
		self.frmSearchMsg.visible := false;
		self.btnSearchMsg.default := false;
	else
		
		self.frmSearchMsg.parent := self;
		self.frmSearchMsg.top := self.height /2;
		self.frmSearchMsg.left := self.mulSelect1.mySelectedListBox.left;
		self.frmSearchMsg.visible := true;
		self.frmSearchMsg.zOrder(1);
		self.txtSearchMsg.setFocus();
		self.btnSearchMsg.default := true;
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showHookCodeMaintForm" id="b4fd855f-e475-4eb7-b47a-7cf280e1ad86">
        <source>showHookCodeMaintForm();
// ---------------------------------------------------------------------------
// Created:     15 January 2008 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpHookType	: CM_HookType;
begin

	tmpHookType := self.myCurrentTableItem.getHookType();
	
	if tmpHookType = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Hook Type is null for ' &amp; self.myCurrentTableItem.name);
		return;
	endif;

	app.showHookCodeMaintForm(tmpHookType,
			self.myCurrentTableItem.jadeCode,
			(self.mode = self.Mode_View));
	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="showIOClass" id="0fdd9d1e-97d4-4fa1-a5f2-d975c2dbf2e7">
        <source>showIOClass(_ioObject : CM_ExtFinanceIO); 
/*
Purpose:			
Date				Who			Reason
FEBRUARY 2015		CNWAB1		Initial creation
*/

vars
	idx, lc : Integer;
	ioObject : CM_ExtFinanceIO;
	c : Class;
begin
	if _ioObject &lt;&gt; null then
		ioObject := _ioObject; 
	endif;
	if ioObject &lt;&gt; null then
		if self.cmbFinancialIO.findObject(_ioObject) &gt; 0 then
			self.cmbFinancialIO.listObject := _ioObject;
		endif;

		self.tblInput2.setValueByName(ETRow_FirstMonthFinancialYear,ioObject.firstMonthOfFinYear); // PAR 33572
		self.tblInput2.setValueByName(ETRow_ExternalExportPath,ioObject.exportPath); // PAR 33572
		self.tblInput2.setValueByName(ETRow_CurrentGLPeriod,ioObject.glPeriod); // PAR 33572
		self.tblInput2.setValueByName(ETRow_CurrentGLYear,ioObject.glYear); // PAR 33572
		self.tblInput2.setValueByName(ETRow_ExternalFinancialName,ioObject.name);  // PAR 33572
		self.tblInput2.setValueByName(ETRow_ExternalFinSysRemarks,ioObject.remarks); // PAR 33572

	else
		self.tblInput2.setValueByName(ETRow_FirstMonthFinancialYear,null); // PAR 33572
		self.tblInput2.setValueByName(ETRow_ExternalExportPath,null); // PAR 33572
		self.tblInput2.setValueByName(ETRow_CurrentGLPeriod,null); // PAR 33572
		self.tblInput2.setValueByName(ETRow_CurrentGLYear,null); // PAR 33572
		self.tblInput2.setValueByName(ETRow_ExternalFinancialName,null); // PAR 33572
		self.tblInput2.setValueByName(ETRow_ExternalFinancialName,null); // PAR 33572
		self.tblInput2.setValueByName(ETRow_ExternalFinSysRemarks,null); // PAR 33572
		
	endif;

end;</source>
        <Parameter name="_ioObject" type="CM_ExtFinanceIO"/>
    </JadeMethod>
    <JadeMethod name="showSearcher" id="375472ad-1520-49ae-b3eb-ece2654fddb1">
        <updating/>
        <source>showSearcher() updating;

// Created by cnwdvb1 on 24 November 2006

vars
	tbl			: CM_EntryTable;

begin

	self.zShowSearcher();

	tbl := self.tblSearch;
	

	if tbl.getValueByName(ETRow_FilterId) &lt;&gt; null then
		tbl.goToRowByName(ETRow_FilterId);
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="showSheetEmailReaderServer" id="f8345f01-43d3-474d-a833-be2b0553d50a">
        <updating/>
        <source>showSheetEmailReaderServer() updating;
//
// 28 May 2013	cnwrs1	ccms 1336 Par 31389 separate BGP EmailRequest to seperate read and send
// 12 Aug 2013	cnwrs1	Par 32224 setup timeout value for this connection
// 03 Feb 2017	cnwrs1	TFS 3247 not deleting emails at NXL
// 03 Aug 2020	jlgdap1	TSF 49764 MTN Retire Basic Authentication to Oxchange Online
// 19 Oct 2020  cnwma1  Bug 50128: MTN Error 1090 System Adm. - Terminal
// 21/05/2021	navdap1	TFS 51244 PNL OAUTH set up
// 10 june 2022 navvt20 TFS53234 --&gt; 1090 when selecting VGM tab when creating a terminal
vars
	row : Integer;				// TFS 49764
	terminal : CM_Terminal;		// TFS 49764

begin
	if self.myCurrentObject &lt;&gt; null and self.myCurrentObject.isKindOf(CM_Terminal) then // ### TFS 51526 23Feb2022 NAVPW1
		terminal   := self.myCurrentObject.CM_Terminal;									// ### TFS 51526 23Feb2022 NAVPW1
	endif;																				// ### TFS 51526 23Feb2022 NAVPW1
	
	//"EMAILARCHITECT");
	if self.cmbSoftware.listIndex = BGP_EmailSendRequest.EMAIL_EMAILARCHITECT then
		self.tblInput2.enableRowByName(ETRow_AutoPop3Account);
		self.tblInput2.enableRowByName(ETRow_AutoPop3Password);
		self.tblInput2.enableRowByName(ETRow_AutoPop3Server);
		self.tblInput2.disableRowByName(ETRow_AutoMailSystem );
		self.tblInput2.enableRowByName(ETRow_AutoUseImap);
		self.tblInput2.enableRowByName(ETRow_AutoUseImap);
		self.tblInput2.enableRowByName(ETRow_AutoImapPort);
		self.tblInput2.enableRowByName(ETRow_AutoImapFlags);
		self.tblInput2.enableRowByName(ETRow_AutoInwardSecurePassword);
		self.tblInput2.enableRowByName(ETRow_AutoInwardSSLUsage);
		self.tblInput2.enableRowByName(ETRow_AutoEmailTimeout);
		self.tblInput2.enableRowByName(ETRow_EmailLicenseType);
		self.tblInput2.hideRowByName(ETRow_TenantId, false);				// TFS 51244
		
		self.tblInput2.showRowByName(ETRow_AutoPop3Password, false);			// TFS 49764
		self.tblInput2.showRowByName(ETRow_AutoPop3Server, false);				// TFS 49764
		//if terminal.getConfig(EmailLicenseType).Integer = EmailLicenseType_3 then
		if terminal &lt;&gt; null and terminal.getConfig(EmailLicenseType).Integer = EmailLicenseType_3 then	// navvt20 10 june 2022 TFS53234 
			self.tblInput2.hideRowByName(ETRow_AutoMailSystem, false);				// ### TFS 51526 23Feb2022 NAVPW1
		else																		// ### TFS 51526 23Feb2022 NAVPW1
			self.tblInput2.showRowByName(ETRow_AutoMailSystem, false);				// ### TFS 51526 23Feb2022 NAVPW1
		endif;																		// ### TFS 51526 23Feb2022 NAVPW1
		//self.tblInput2.showRowByName(ETRow_AutoMailSystem, false);				// ### TFS 51526 23Feb2022 NAVPW1 // TFS 49764
		self.tblInput2.showRowByName(ETRow_AutoUseImap, false);					// TFS 49764
		self.tblInput2.showRowByName(ETRow_AutoImapPort, false);				// TFS 49764
		self.tblInput2.showRowByName(ETRow_AutoImapFlags, false);				// TFS 49764
		self.tblInput2.showRowByName(ETRow_AutoInwardSecurePassword, false);	// TFS 49764
		self.tblInput2.showRowByName(ETRow_AutoInwardSSLUsage, false);			// TFS 49764
	//"IDSMAIL");
	elseif self.cmbSoftware.listIndex = BGP_EmailSendRequest.EMAIL_IDSMAIL then
		self.tblInput2.enableRowByName(ETRow_AutoPop3Account);
		self.tblInput2.enableRowByName(ETRow_AutoPop3Password);
		self.tblInput2.enableRowByName(ETRow_AutoPop3Server);
		self.tblInput2.enableRowByName(ETRow_AutoMailSystem );
		self.tblInput2.enableRowByName(ETRow_AutoUseImap);
		self.tblInput2.enableRowByName(ETRow_AutoUseImap);
		self.tblInput2.disableRowByName(ETRow_AutoImapPort);
		self.tblInput2.disableRowByName(ETRow_AutoImapFlags);
		self.tblInput2.disableRowByName(ETRow_AutoInwardSecurePassword);
		self.tblInput2.disableRowByName(ETRow_AutoInwardSSLUsage);
		self.tblInput2.enableRowByName(ETRow_AutoEmailTimeout);
		self.tblInput2.disableRowByName(ETRow_EmailLicenseType);
		self.tblInput2.hideRowByName(ETRow_TenantId, false);				// TFS 51244
		
		self.tblInput2.showRowByName(ETRow_AutoPop3Password, false);			// TFS 49764
		self.tblInput2.showRowByName(ETRow_AutoPop3Server, false);				// TFS 49764
		self.tblInput2.showRowByName(ETRow_AutoMailSystem, false);				// TFS 49764
		self.tblInput2.showRowByName(ETRow_AutoUseImap, false);					// TFS 49764
		self.tblInput2.showRowByName(ETRow_AutoImapPort, false);				// TFS 49764
		self.tblInput2.showRowByName(ETRow_AutoImapFlags, false);				// TFS 49764
		self.tblInput2.showRowByName(ETRow_AutoInwardSecurePassword, false);	// TFS 49764
		self.tblInput2.showRowByName(ETRow_AutoInwardSSLUsage, false);			// TFS 49764
	// TFS 49764 "EMAILARCHITECT OAUTH"
	elseif self.cmbSoftware.listIndex = BGP_EmailSendRequest.EMAIL_EMAILARCHITECTOAUTH then
		self.tblInput2.showRowByName(ETRow_AutoPop3Account, false);
		self.tblInput2.showRowByName(ETRow_AutoPop3Server, false);
		self.tblInput2.showRowByName(ETRow_AutoEmailTimeout, false);
		self.tblInput2.showRowByName(ETRow_AutoCharset, false);
		self.tblInput2.showRowByName(ETRow_EmailLicenseType, false);
		self.tblInput2.showRowByName(ETRow_TenantId, false);					// TFS 51244
		self.tblInput2.enableRowByName(ETRow_AutoPop3Server);
		
		// also default to correct license type and disable the license row
		row := self.tblInput2.getRowByName(ETRow_EmailLicenseType);
		if row &lt;&gt; null and self.tblInput2.accessCell(row, self.tblInput2.ColumnValue).comboList &lt;&gt; null then
			self.tblInput2.setValueByName(ETRow_EmailLicenseType, EmailLicenseDescr_2);
		endif;
		self.tblInput2.disableRowByName(ETRow_EmailLicenseType);
		
		self.tblInput2.hideRowByName(ETRow_AutoMailSystem, false);
		self.tblInput2.hideRowByName(ETRow_AutoPop3Password, false);
		self.tblInput2.hideRowByName(ETRow_AutoUseImap, false);
		self.tblInput2.hideRowByName(ETRow_AutoImapPort, false);
		self.tblInput2.hideRowByName(ETRow_AutoImapFlags, false);
		self.tblInput2.hideRowByName(ETRow_AutoInwardSecurePassword, false);
		self.tblInput2.hideRowByName(ETRow_AutoInwardSSLUsage, false);
		self.tblInput2.disableRowByName(ETRow_AutoUseImap);
		self.tblInput2.disableRowByName(ETRow_AutoImapPort);
		self.tblInput2.disableRowByName(ETRow_AutoImapFlags);
		self.tblInput2.disableRowByName(ETRow_AutoInwardSecurePassword);
		self.tblInput2.disableRowByName(ETRow_AutoInwardSSLUsage);
	// TFS 49764 end
	endif;
	
	// TFS 49764 double-check on license type and software type combinations
	if self.cmbSoftware.listIndex &lt;&gt; BGP_EmailSendRequest.EMAIL_EMAILARCHITECTOAUTH and self.cmbSoftware.listIndex &gt; 0 then
		self.myCurrentTableItem.SOPTM_Terminal.initEmailLicenseTypeCombo(false);
		
		//terminal := self.myTerminal;                                                      //19.10.2020 cnwma1 # 50128
		//Moved to top of the method // ### TFS 51526 23Feb2022 NAVPW1
		//if self.myCurrentObject &lt;&gt; null and self.myCurrentObject.isKindOf(CM_Terminal) then  //19.10.2020 cnwma1 # 50128
		//	terminal   := self.myCurrentObject.CM_Terminal;
		//endif;

		if terminal &lt;&gt; null and terminal.getConfig(EmailLicenseType).Integer = EmailLicenseType_0 then
			self.tblInput2.setValueByName(ETRow_EmailLicenseType, EmailLicenseDescr_0);
		elseif terminal &lt;&gt; null and terminal.getConfig(EmailLicenseType).Integer = EmailLicenseType_1 then
			self.tblInput2.setValueByName(ETRow_EmailLicenseType, EmailLicenseDescr_1);
		elseif terminal &lt;&gt; null and terminal.getConfig(EmailLicenseType).Integer = EmailLicenseType_3 then 	// ### TFS 51526 23Feb2022 NAVPW1
			self.tblInput2.setValueByName(ETRow_EmailLicenseType, EmailLicenseDescr_3); 					// ### TFS 51526 23Feb2022 NAVPW1
		else
			self.tblInput2.setValueByName(ETRow_EmailLicenseType, null);
		endif;
	endif;
	self.tblInput2.cnEcResizeContents();
	// TFS 49764
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnailData" id="aff2ca3e-215f-4dcb-b0de-b373b7dbac09">
        <updating/>
        <source>showThumbnailData(obj: CM_Object) updating;
// ---------------------------------------------------------------------------
// Created:     30 March 2001 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 04/03/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
// 29/06/2016   cnwma1      PAR #37988 TFS #2233 CPL - 1090 error - System Admin
// ---------------------------------------------------------------------------
vars
	ls	: Boolean;
begin

	app.cmsBeginLoad(ls);
	self.chkIncludeNotSet.visible := false;
	self.resetMeasurementRows(self.tblInput1);
	
	if self.tblInput1.myEntTableDef &lt;&gt; null then                                        	//cnwma1 29/06/2016   PAR #37988 TFS #2233 
		self.loadMeasurementTypes(	self.tblInput1,											// PAR #31155
									self.tblInput1.myEntTableDef.name,						// PAR #31155
									self.tblInput1.myEntTableDef.allEntTableRows,			// PAR #31155
									self.mode.isOneOf(self.Mode_Add, self.Mode_Update)	);	// PAR #31155
	endif;
	self.myCurrentTableItem.showThumbnail(obj);
	self.tblInput1.cnEcResizeContents();												// PAR #31155

epilog
	app.cmsEndLoad(ls);
end;</source>
        <Parameter name="obj" type="CM_Object"/>
    </JadeMethod>
