<Class name="BGP_RestrictionExpiryRequest" id="040125b9-f5da-4aad-b95a-5fbca1e0aa37">
    <superclass name="BGP_Request"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;Restriction Expiry&lt;/display&gt;</text>
    <DbClassMap file="backgroundprocess"/>
    <JadeMethod name="action" id="4ec4867e-2971-49ba-bde1-a4feafb64ba6">
        <updating/>
        <source>action(): Boolean updating;
// -------------------------------------------
// Created 07 June 2005 by cnwdvb1
// -------------------------------------------
vars
	errCode	: Integer;
	errTxt	: String;
begin

	on Exception do app.alertExceptionHandler(exception, null, self.getErrorDesc(), errCode, errTxt, true, true);
	on LockException do app.alertLockExceptionHandler(exception);
	
	self.setUser();
	self.processRestrictionExpiry();

epilog
	if errCode &lt;&gt; null then
		app.myTrxUA.trxUpdateBGPRequest(self, true, errCode, errTxt, app.myPassport);
	else
		// Do nothing.
	endif;
	inheritMethod();
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDisplay" id="ef0b799f-29e5-4b11-9f75-fa1b42fd564c">
        <source>getDisplay(): String;
// -------------------------------------------
// Created 07 June 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	return inheritMethod &amp; Tab &amp; 'Restriction Expiry Request';



end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="processRestrictionExpiry" id="28ac6011-3fd4-404f-b945-69e967225dc0">
        <source>processRestrictionExpiry() protected;
// -------------------------------------------
// Created 07 June 2005 by cnwdvb1
// -------------------------------------------
vars
	labourRestriction : CM_LabourRestriction;
	lRArray : ObjectArray;
	currentTime : TimeStamp;
	lr : Object;
	heading,
	sender,
	body,
	strId,
	email : String;
	emailEntity : CM_EmailEntity;
	invalidObj : Boolean;	//08 Jul 2015	NDL	Par 36588
begin
	create lRArray transient; 

	currentTime := app.actualTimeServer;
	
	foreach labourRestriction in CM_LabourRestriction.instances discreteLock do
	 	if labourRestriction.expiryDateTime &lt;&gt; null then
	 		if labourRestriction.expiryDateTime &lt; currentTime then 
	 			lRArray.add(labourRestriction);
	 		endif;				
	 	endif;
	 endforeach;

	sender := app.myRoot.getConfig(AutoSendersEmailAddress).String;	
	
	on Exception do app.handleDeletedObject(exception, emailEntity, invalidObj);
	
	 foreach lr in lRArray do 
	 	labourRestriction := lr.CM_LabourRestriction; 
			
		heading := app.getErrorString(CM_Labour_Restriction) &amp; ' ' &amp; app.getErrorString(Expiry) &amp; ': ' &amp; labourRestriction.id;

		//08 Jul 2015	NDL	Par 36588 - allow for multiple addresses.
	//	emailEntity := labourRestriction.allNotifyEmailEntities.first;
		
	//	if emailEntity &lt;&gt; null then 
	//		email := emailEntity.getEmailAddress();
	//	endif;
	
		foreach emailEntity in labourRestriction.allNotifyEmailEntities do
		
			invalidObj := false;
			email := emailEntity.getEmailAddress();
				
			if email &lt;&gt; null and not invalidObj then 
		
				body := app.getErrorString2(BGP_Labour_Restrict_Email_Msg, labourRestriction.id ,labourRestriction.myTerminalArea.id);
					
				app.myTrxCA.trxCreateEmailSendRequest(heading, email, sender, null , null, heading, body,
														null, null, null, null, EmailSource_System, null, app.myPassport);
				if not app.myPassport.trxCompletedOK then
					app.remoteErrorWarningToAlert('Could not send Labour Restriction email', 
												null,  app.myPassport.allErrors, null, false, true);
				endif;
			endif;
		
		endforeach;
		
		
		endforeach;
epilog
delete lRArray;
end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
