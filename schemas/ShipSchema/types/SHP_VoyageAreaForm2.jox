        <Parameter name="_theSelector" type="CMUI_Selector" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setTblPreferFromObjSpecial" id="3dc0f76b-6071-4345-8990-baae7fc47413">
        <updating/>
        <source>setTblPreferFromObjSpecial(_tbl: CM_EntryTable input; _attrName: String; _row: Integer; _obj: Object): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     20 May 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	showOtherStr	: String;
	
begin

	if _attrName = ETRow_ShipDischCCShowOthers or
	   _attrName = ETRow_ShipLoadCCShowOthers or
	   _attrName = ETRow_ShipLoadJobShowOthers or
	   _attrName = ETRow_ShipLoadPlanShowOthers or
	   _attrName = ETRow_ShipLoadSeqShowOthers then
	     
	   
		showOtherStr := app.getErrorString(ShipShowOtherColors_Hatched) &amp; Tab &amp; 
						app.getErrorString(None) &amp; Tab &amp;
						app.getErrorString(ShipShowOtherColors_Other);
		_tbl.setComboValues(_row, showOtherStr);
		_tbl.setValue(_row, app.shipShowOtherColorNumToStr(_obj.getPropertyValue(_attrName).Integer));
		return true;
	endif;
	
	return false;
end;</source>
        <Parameter name="_tbl" type="CM_EntryTable" usage="input"/>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setToolbarCombosWidth" id="4ca5ff12-94cd-46e5-b628-c656ef99d680">
        <source>setToolbarCombosWidth() protected;
// ---------------------------------------------------------------------------
// Created:     14 May 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
constants
	ComboSpace	: Integer = 2;
	JobModeDischargeWidth	: Integer = ComboSpace + ComboWidth_Max + ComboSpace + CmbJob_Width + ComboSpace + TxtJobLinkLoad_Width + ComboSpace;
	JobModeLoadWidth		: Integer = ComboSpace + ComboWidth_Max + ComboSpace + CmbJob_Width + ComboSpace;
	JobModeMinWidthDischarge	: Integer = ComboSpace + ComboWidth_Min + ComboSpace + CmbJob_Width + ComboSpace + TxtJobLinkLoad_Width + ComboSpace;
	JobModeMinWidthLoad		: Integer = ComboSpace + ComboWidth_Min + ComboSpace + CmbJob_Width;

vars
	comboWidth,
	theWidth,
	maxWidth,
	minWidth	: Integer;
begin
	if self.displayMode = ShpDisplayMode_ColCodeLoad and
	   self.workingMode &lt;&gt; self.WorkMode_CustomSeq and
	   self.workingMode &lt;&gt; self.WorkMode_Job then
		theWidth := self.frmToolbar2.clientWidth - self.frmToolbarCombos.left.Integer;
		
		comboWidth := (theWidth / 3).Integer - 8;
		if comboWidth &gt; ComboWidth_Max then
			comboWidth := ComboWidth_Max;
		endif;
		
		self.cmbPortDis.width := comboWidth;
		self.cmbCommodity.width := comboWidth;
		self.cmbCommodity.left := comboWidth + (ComboSpace * 2);
		self.cmbCargoType.width := comboWidth;
		self.cmbCargoType.left := (comboWidth * 2) + (ComboSpace * 3);
		
// cnwdad1 30/07/2010 - PAR #24045, had to make frame wider for new weight control.
		self.frmToolbarCombos.width := (comboWidth * 3) + (ComboSpace * 4) + (ComboSpace * 2 + self.txtWeight.width);
		
	elseif self.workingMode = self.WorkMode_CustomSeq then
		theWidth := self.frmToolbar2.clientWidth - self.frmToolSeqApply.left.Integer;
		if theWidth &gt; 155 then
			theWidth := 155;
		endif;
		if theWidth &gt; 100 then
			// need to adjust frame / combo width
		//	self.frmToolSeqApply.width := theWidth - 2;
		//	self.cmbSeqAppliesTo.width := theWidth - 2 - self.cmbSeqAppliesTo.left - 2;
		endif;

	elseif self.workingMode = WorkMode_Job then
		theWidth := self.frmToolbar2.clientWidth - self.frmToolbarCombos.left.Integer - 18;

		if self.displayMode = ShpDisplayMode_ColCodeDisch then
			//	txtJobLinkLoad.visible is only visible for Discharge
			theWidth := theWidth.min(JobModeDischargeWidth);
			maxWidth := JobModeDischargeWidth;
			minWidth := JobModeMinWidthDischarge;
		else
			theWidth := theWidth.min(JobModeLoadWidth);
			maxWidth := JobModeLoadWidth;
			minWidth := JobModeMinWidthLoad;
		endif;

		if theWidth &gt; minWidth and theWidth &lt; maxWidth then
			// need to adjust frame / combo width
			self.frmToolbarCombos.width := theWidth;

			if self.displayMode = ShpDisplayMode_ColCodeDisch then
				self.cmbCrane.width := theWidth - CmbJob_Width - TxtJobLinkLoad_Width - (ComboSpace * 4);
				self.cmbJob.width := CmbJob_Width;
				self.txtJobLinkLoad.width := TxtJobLinkLoad_Width;

				self.cmbCrane.left := ComboSpace;
				self.cmbJob.left := (ComboSpace * 2) + self.cmbCrane.width;
				self.txtJobLinkLoad.left := (ComboSpace * 3) + self.cmbCrane.width + TxtJobLinkLoad_Width;
			else
				self.cmbCrane.width := theWidth - CmbJob_Width - (ComboSpace * 3);
				self.cmbJob.width := CmbJob_Width;

				self.cmbJob.left := (ComboSpace * 2) + self.cmbCrane.width;
			endif;
		else
			self.frmToolbarCombos.width := maxWidth;

			self.cmbCrane.width := ComboWidth_Max;
			self.cmbJob.width := CmbJob_Width;
			self.txtJobLinkLoad.width := TxtJobLinkLoad_Width;

			self.cmbJob.left := (ComboSpace * 2) + ComboWidth_Max;
			self.txtJobLinkLoad.left := (ComboSpace * 3) + ComboWidth_Max + CmbJob_Width;
		endif;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setWorkingModeBubble" id="94a817fc-10cf-4c67-988a-deec75815697">
        <source>setWorkingModeBubble();
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	dispString : String;
begin
	if self.displayMode = ShpDisplayMode_ColCodeDisch then
		self.btnColorCodeDish.value := true;
		self.btnColorCodeDish.myToolbarButton.drawButtonDown();
		dispString := $SHP_DISCHARGE;

	elseif self.displayMode = ShpDisplayMode_ColCodeLoad then
		self.btnColorCodeLoad.value := true;
		self.btnColorCodeLoad.myToolbarButton.drawButtonDown();
		dispString := $SHP_LOAD;
	endif;
	
	if self.workingMode = self.WorkMode_None then
		self.doResetWorkingButtons(true,true,true);
		self.btnJobsMode.bubbleHelp := $SHP_Enter_Into &amp; dispString &amp; $SHP_JOB &amp; $SHP_Mode;
		self.btnPlanningMode.bubbleHelp := $SHP_Enter_Into &amp; dispString &amp; $SHP_PLANNING &amp; $SHP_Mode;
		self.btnSequenceMode.bubbleHelp := $SHP_Enter_Into &amp; dispString &amp; $SHP_CUSTOM_SEQUENCING &amp; $SHP_Mode;

	elseif self.workingMode = self.WorkMode_Job then
		self.doResetWorkingButtons(false,true,true);
		self.btnJobsMode.bubbleHelp := $SHP_You_Are_In &amp; dispString &amp; $SHP_JOB &amp; $SHP_Mode;
		self.btnPlanningMode.bubbleHelp := $SHP_Enter_Into &amp; dispString &amp; $SHP_PLANNING &amp; $SHP_Mode;
		self.btnSequenceMode.bubbleHelp := $SHP_Enter_Into &amp; dispString &amp; $SHP_CUSTOM_SEQUENCING &amp; $SHP_Mode;

	elseif self.workingMode = self.WorkMode_Plan then
		self.doResetWorkingButtons(true,false,true);
		self.btnJobsMode.bubbleHelp := $SHP_Enter_Into &amp; dispString &amp; $SHP_JOB &amp; $SHP_Mode;
		self.btnPlanningMode.bubbleHelp := $SHP_You_Are_In &amp; dispString &amp; $SHP_PLANNING &amp; $SHP_Mode;
		self.btnSequenceMode.bubbleHelp := $SHP_Enter_Into &amp; dispString &amp; $SHP_CUSTOM_SEQUENCING &amp; $SHP_Mode;

	elseif self.workingMode = self.WorkMode_CustomSeq then
		self.doResetWorkingButtons(true,true,false);
		self.btnJobsMode.bubbleHelp := $SHP_Enter_Into &amp; dispString &amp; $SHP_JOB &amp; $SHP_Mode;
		self.btnPlanningMode.bubbleHelp := $SHP_Enter_Into &amp; dispString &amp; $SHP_PLANNING &amp; $SHP_Mode;
		self.btnSequenceMode.bubbleHelp := $SHP_You_Are_In &amp; dispString &amp; $SHP_CUSTOM_SEQUENCING &amp; $SHP_Mode;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupBtnPens" id="c11910e2-691f-4c51-b772-1fe8940e2e0d">
        <source>setupBtnPens() protected;
// ---------------------------------------------------------------------------
// Created:     12 September 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	atttDict	: CM_DrawingAttributesByCodeDict;
	drawAttr	: CM_DrawingAttribute;
	ls			: Boolean;
	
begin

	atttDict := app.myRoot.allDrawingAttributes;

	app.cmsBeginLoad(ls);	
	
	drawAttr := atttDict[PicTI40Footer];
	if drawAttr &lt;&gt; null then
		self.btnPen40.setFontFromDrawingAttr(drawAttr);
	endif;
	
	// PAR 16415 CCMS 1029
	drawAttr := atttDict[PicTI30Footer];
	if drawAttr &lt;&gt; null then
		self.btnPen30.setFontFromDrawingAttr(drawAttr);
	endif;
	
	// PAR 16415 CCMS 1029
	drawAttr := atttDict[PicTI53Footer];
	if drawAttr &lt;&gt; null then
		self.btnPen53.setFontFromDrawingAttr(drawAttr);
	endif;
	
	// PAR 18682 CCMS 1055
