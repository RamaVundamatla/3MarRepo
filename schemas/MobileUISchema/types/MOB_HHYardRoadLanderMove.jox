    <JadeMethod name="txtLocation_lostFocus" id="fd62df74-e087-48cb-a5df-ad59b4d5e487">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtLocation_lostFocus(textbox: TextBox input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 February 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

begin

	if self.txtLocation.text.trimBlanks = null then
