					'remarksupdate',//_remarks,
					null,//_stand,
					null,//_subSupplier,
					'2.000',//_tareWeight,
					null,//_trailerNumber,
					VehicleId,//_truckNumber,
					null,//_unloadPoint,
					VehicleId,//_vehicle,
					'WBR'//_weighBridge
						);

	self.assertNotNull(bolIn);
	
	
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="logBolWeightUpdateCompare" id="c5dc5c53-497f-49e2-8202-033e74b7f0e5">
        <source>logBolWeightUpdateCompare();
// 16 September 2010	by cnwvu1
//Purpose:	Compare weight on a BOLIn and from stock (logs). They should match.

vars
	bolIn		: CM_BOLIn;
	locn		: CM_LogController;
	totQty		: Integer;
	totVol,
	totWeight	: Decimal[16,4];
	
begin

	bolIn	:= self.getBOLIn( self.BOLInNumber_WeightUpdate, self.OperatorCode );
	locn	:= self.getLogRow( self.LogAreaCode, self.LocationWeightUpdCode );
	
	locn.getSOHLevelsForDate(app.actualTimeServer.date, true, totQty, totVol, totWeight);

	self.assertEqual(bolIn.weightNet, totWeight);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="logBolWeightUpdateTest" id="1aaabf55-e04e-42ac-a89d-de8c2921f480">
        <source>logBolWeightUpdateTest();
//16 September 2010	by cnwvu1

/* creates Docket and logs
	updates Docket's weight (weight for logs are updated accordingly)
	then checks docket's weight = log weight, i.e. weight from SOHLocations, from a particular location.
*/
vars

begin

	self.createLocationForLogModuleTest(self.LocationWeightUpdCode);
	self.createBOLInLogsForLogModuleTst(self.LocationWeightUpdCode, self.BOLInNumber_WeightUpdate,  self.BOLInNumber_WeightUpdate[1:6] &amp; "LOG", 10);
	self.logBolWeightUpdateCompare();	// compare before weight update
	self.logBolWeigthChange();
	self.logBolWeightUpdateCompare();	// compare after weight update
	
end;</source>
    </JadeMethod>
    <JadeMethod name="logBolWeigthChange" id="86003249-e9cc-4235-bdb8-562df5ac010c">
        <source>logBolWeigthChange();
// 16 September 2010	by cnwvu1
/* Ppurpose		Change Weight for a docket, then eight for all lolgs are recalulated.
				Later, we will compare BOL weight and logs total weight.*/
vars
	pxyBolIn,
	bolIn		: 	CM_BOLIn;
	loadStateSet: Boolean;
	
begin

	bolIn	:= self.getBOLIn( self.BOLInNumber_WeightUpdate, self.OperatorCode );
	
	app.cmsBeginLoad(loadStateSet);
	pxyBolIn:= bolIn.pxyCreateUpdateProxy();
	app.cmsEndLoad(loadStateSet);
	
	pxyBolIn.weightNetTonnes := pxyBolIn.weightNetTonnes * 2;	// weight change
	app.myTrxUA.trxUpdateBOL(pxyBolIn, false, null, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	
epilog
	app.cmsEndLoad(loadStateSet);
	delete pxyBolIn;

end;</source>
    </JadeMethod>
    <JadeMethod name="logConsignorChangeForDocket" id="a55116e2-baf5-45e9-ba8a-cad869a64929">
