    <JadeMethod name="btnReload_click" id="d01ed786-8a61-4d25-960f-ec4cf3994421">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnReload_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		18 March 2009 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	MESSAGE			: String = "This action will reload all translation Global Constants into the database.  It should not be run during normal development hours." &amp; CrLf &amp; CrLf &amp; "Do you wish to continue ?";
	
vars
	transAgentObj	: CM_TranslationAgent;
	userResponse	: Integer;
	
begin
	app.mousePointer	:=	Busy;
	
	userResponse	:=	app.msgBox(MESSAGE, "Reload Constants", MsgBox_Question_Mark_Icon + MsgBox_Yes_No);
	
	if userResponse = MsgBox_Return_Yes then
		create transAgentObj transient;
		transAgentObj.trxLoadXLATsFromGlbConstants(null);
	endif;
epilog
	delete transAgentObj;
	app.mousePointer	:=	Idle;
end;</source>
