    <JadeMethod name="btnMenuTemplate_click" id="7d005bc6-cf51-4481-bf96-8519156282fd">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnMenuTemplate_click(btn: Button input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 January 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

begin

	self.clickTrackedItemButton( btn.userObject );
	
epilog

