    <JadeMethod name="addCodeRow" id="3e9aa27f-bf5e-47f7-8f02-71a06ee00642">
        <source>addCodeRow(_prodCode : CM_ProductAttributeCode );
// ---------------------------------------------------------------------------
// Created:     23 August 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	prodCode : CM_ProductAttributeCode;
	idx		: Integer;
	tmpTable : CM_DataTable;
	cell	: JadeTableCell;
begin
		
	prodCode := _prodCode;	
	tmpTable := self.tblCodeData;
		
	idx := tmpTable.addItem(prodCode.code &amp; Tab &amp; prodCode.description);
	tmpTable.accessRow(idx).itemObject := prodCode;

	cell := tmpTable.accessCell(idx,tmpTable.getColumnByRowName(ETRow_EntCode));//.inputType := CM_DataTable.InputType_TextBox;
	cell.inputType := CM_DataTable.InputType_TextBox;
	cell.cellControl.TextBox.case := TextBox.Case_Upper;		
	
	cell := tmpTable.accessCell(idx,tmpTable.getColumnByRowName(ETRow_EntDescription));//.inputType := CM_DataTable.InputType_TextBox;
	cell.inputType := CM_DataTable.InputType_TextBox;
	cell.cellControl.TextBox.case := TextBox.Case_None;	
end;</source>
        <Parameter name="_prodCode" type="CM_ProductAttributeCode"/>
    </JadeMethod>
    <JadeMethod name="addNewRowTblCodeData" id="f243f385-9e75-43e3-80ad-85b2b280df6d">
        <source>addNewRowTblCodeData(_currentRow : Integer);
// ---------------------------------------------------------------------------
// Created:     24 August 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	tmpTable : CM_DataTable;
	idx : Integer;
	cell : JadeTableCell;
begin

	tmpTable := self.tblCodeData;
	
	idx := tmpTable.rows + 1;
	tmpTable.addItemAt("", idx);


	cell := tmpTable.accessCell(idx,tmpTable.getColumnByRowName(ETRow_EntCode));//.inputType := CM_DataTable.InputType_TextBox;
	cell.inputType := CM_DataTable.InputType_TextBox;
	cell.cellControl.TextBox.case := TextBox.Case_Upper;	


	cell := tmpTable.accessCell(idx,tmpTable.getColumnByRowName(ETRow_EntDescription));//.inputType := CM_DataTable.InputType_TextBox;
	cell.inputType := CM_DataTable.InputType_TextBox;
	cell.cellControl.TextBox.case := TextBox.Case_None;	
	
	tmpTable.row := idx;
	tmpTable.column := 1;
	self.doRowChangeForNewRow(_currentRow, tmpTable);

end;</source>
        <Parameter name="_currentRow" type="Integer"/>
    </JadeMethod>
