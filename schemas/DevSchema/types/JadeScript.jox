    <JadeMethod name="mdhGetHighestConstantNo" id="d5f7c815-62cf-4a02-8a0d-69de10e383c7">
        <source>mdhGetHighestConstantNo();

/*

Purpose:		Get the highest constant number for the specified XLAT class

Date			Who		Reason
16/09/2014		cnwmh5	Initial creation

*/

vars

	constant 				: Constant;

	number 					: Integer;
	category				: String;
	
begin

	app.initialize();
	
	// category e.g. XLAT_FormCaptions; XLAT_Exceptions
	category := "XLAT_Exceptions";	
	
	foreach constant in rootSchema.getSchema(PortSchemaName).getCategory(category).getConstants discreteLock do
		number := number.max(constant.getPropertyValue("source").Integer);
	endforeach;
	
	write "Highest contstant number for " &amp; category &amp; " is " &amp; number.String;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="mdhHubbleExtract" id="56de9860-30ad-4e61-be41-9a71cc3760ed">
        <source>mdhHubbleExtract();

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 September 2014	cnwndl1	Initial creation
// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

	allSelectedObjects : ObjectArray;
	formatName : String;
	errorFileName : String;
	inputFileName : String;
	noidFileName : String;
	logFileName : String;
	outputFileName : String;
	
	oidTableRootObj : CnEcOidTable;
	hubbleObj : CnEcHubble;

begin

	app.cnEcInitializeBaseSchema();
	app.cnEcSetXmlSchema("PortSchema");
	app.cnEcSetBaseRoot(false);


	create allSelectedObjects transient;
	//self.getAllSelectedObjects( allSelectedObjects );
	CM_Carrier.instances.copy(allSelectedObjects);
	
	
	if allSelectedObjects.isEmpty then
		app.msgBox( "No objects selected to extract", "Warning", MsgBox_OK_Only );
		return;
	endif;
	
	formatName := CNEC_DEFAULT_FULL;
	if formatName = null then
		app.msgBox( "No extract format selected", "Warning", MsgBox_OK_Only );
		return;
	endif;
	
	inputFileName := null;
	errorFileName := "c:\temp\All2805TerminalAreaLog.txt";
	noidFileName := "c:\temp\All2805TerminalAreaNoid.txt";
	outputFileName := "c:\temp\All2805TerminalAreaMain.txt";
	logFileName := errorFileName;
	
	if logFileName = null then
		app.msgBox( "Log file name required", "Warning", MsgBox_OK_Only );
		return;
	endif;
	if noidFileName = null then
		app.msgBox( "Noid file name required", "Warning", MsgBox_OK_Only );
		return;
	endif;
	if outputFileName = null then
		app.msgBox( "Main Output file name required", "Warning", MsgBox_OK_Only );
		return;
	endif;
	
	write allSelectedObjects.size().String &amp; " objects being extracted.";
	//lblMessage.caption := allSelectedObjects.size().String &amp; " objects being extracted.";
	//self.btnExtractCode.enabled := false;
	//self.doWindowEvents(1);
	
	create oidTableRootObj transient;
	create hubbleObj transient;
	
	hubbleObj.initializeMe(	errorFileName,
							inputFileName,
							noidFileName,
							logFileName,
							outputFileName,
							formatName,
							oidTableRootObj,
							allSelectedObjects
							);
	
	//lblMessage.caption := "Exporting...." &amp; " - " &amp; app.actualTime().Time.String;
	//self.doWindowEvents(1);
	write "Exporting...." &amp; " - " &amp; app.actualTimeServer().Time.String;// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	
    if allSelectedObjects.size() &lt; 1000 then
    	hubbleObj.export(0,false);
 	else
 		hubbleObj.export((allSelectedObjects.size() div 10),false);
 	endif;   	   	
    
   // lblMessage.caption :=  "Deleting transients...." &amp; " - " &amp; app.actualTime().Time.String;
	//self.doWindowEvents(1);
	write "Deleting transients...." &amp; " - " &amp; app.actualTimeServer().Time.String;// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	
epilog

	delete allSelectedObjects;
	delete oidTableRootObj;
	delete hubbleObj;
	
	write  "Exporting complete" &amp; " - " &amp; app.actualTimeServer().Time.String;// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	//self.btnExtractCode.enabled := true;

end;</source>
    </JadeMethod>
    <JadeMethod name="mdhLockTerminalAllTxns" id="8b312253-4a6f-4a15-8e0a-e2b3cf574977">
        <source>mdhLockTerminalAllTxns();

/*

Purpose:			

Parameters:			

