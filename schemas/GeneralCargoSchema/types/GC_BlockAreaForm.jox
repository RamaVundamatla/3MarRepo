    <JadeMethod name="doMnuContext" id="8b500311-7726-4c09-8222-d5a37c5afba0">
        <updating/>
        <source>doMnuContext(_cntrl: Frame input; _conwin: Window input; _mouse: Boolean; _x: Integer; _y: Integer) : Boolean updating;

/*

Purpose:			


Return Value:		


Date		Who		Reason
16 May 2008	cnwkpd1	PAR #16753 - CCMS SFW 1003 - General Cargo Graphical Screens

*/

vars
	showAll : Boolean;
	
begin
	if self.myDrawingController = null then // PAR 17125 cnwgb1
		return false;
	endif;
	self.doTurnOffContextMenus();

	showAll := true;
	self.mnuGridSeperator02.visible := showAll;
	self.mnuZoomSub.visible := showAll;
	self.mnuGridBigFont.visible := true;
	self.mnuGridSeperator01.visible := false;

	
	return self.showContextMenu(mnuGridAreaContext, _cntrl, _conwin, _mouse, _x, _y);

end;</source>
        <Parameter name="_cntrl" type="Frame" usage="input"/>
        <Parameter name="_conwin" type="Window" usage="input"/>
        <Parameter name="_mouse" type="Boolean"/>
        <Parameter name="_x" type="Integer"/>
        <Parameter name="_y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doMnuGridHideLegendClick" id="10c76f43-e852-4536-a6cc-a9a3404f42dc">
        <updating/>
        <source>doMnuGridHideLegendClick() updating, protected;

/*

Purpose:			


Return Value:		


Date		Who		Reason
16 May 2008	cnwkpd1	PAR #16753 - CCMS SFW 1003 - General Cargo Graphical Screens

*/
// adm 250509 Par 19575
begin
	if self.mnuGridHideLegend.caption = self.MNU_LEGEND_SHOW then
		if self.xmlSplitMain = 0 then
			self.splMain.showLeftControlAndSize(50);
		else
			self.splMain.showLeftControl(self.xmlSplitMain, true);
		endif;	
		self.mnuGridHideLegend.caption		:=	self.MNU_LEGEND_HIDE;
	else	
		self.xmlSplitMain	:= splMain.leftToRightRatio;
		self.splMain.hideLeftControl(true);
		self.mnuGridHideLegend.caption		:=	self.MNU_LEGEND_SHOW;
	endif;
	
	self.splMain.cnEcResizeContents();
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doMnuGridHideMacroClick" id="df1ac654-394a-402d-8e67-4250332970a1">
        <updating/>
        <source>doMnuGridHideMacroClick() updating, protected;

/*

Purpose:			


Return Value:		


Date		Who		Reason
16 May 2008	cnwkpd1	PAR #16753 - CCMS SFW 1003 - General Cargo Graphical Screens

*/
// adm 250509 Par 19575
begin
	if self.mnuGridHideMacro.caption = self.MNU_MACRO_SHOW then
		self.sptGridArea01.showRightControl(100 - self.xmlSplitGridArea01, true);
		self.mnuGridHideMacro.caption := self.MNU_MACRO_HIDE;
	else
		self.xmlSplitGridArea01 := self.sptGridArea01.leftToRightRatio;
		self.sptGridArea01.hideRightControl(true);
		self.mnuGridHideMacro.caption := self.MNU_MACRO_SHOW;
	endif;
	
	self.sptGridArea01.cnEcResizeContents();
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doMnuGridHideToolbarClick" id="b5eaac06-b59c-4546-964d-2b11dc530960">
