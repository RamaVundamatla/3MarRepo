    <JadeMethod name="clearForm" id="ac16b24b-baae-4f42-a890-a6341c476855">
        <updating/>
        <source>clearForm() updating, protected;
// ---------------------------------------------------------------------------
// Created:     20 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	idx			: Integer;
	numCntrls	: Integer;
	tblRow		: Integer;
	cntrl		: Control;
	navObj		: CMUI_NavigatorObject;
	menAct		: CMUI_MenuAction;
	gateDefaultEntry: CM_Gate;

begin

	// Notify the GateControllor and Navigator window of sheets being deleted

	numCntrls := self.controlCount;	
	
	self.clearLayout();
	
	// do in reverse order so that child sheets are deleted before parents.
	foreach idx in numCntrls to 1 step -1 do
		cntrl := self.controls(idx);

		if cntrl.isKindOf(CMUI_ListTable) then
			cntrl.CMUI_ListTable.setSelected(null);

		elseif cntrl.isKindOf(ComboBox) then
			cntrl.ComboBox.text := null;
			cntrl.ComboBox.listObject := null;

		elseif cntrl.isKindOf(GTE_Sheet) then
			menAct := cntrl.GTE_Sheet.myMenuAction;
			if menAct &lt;&gt; null /*and menAct.getLevel = 2*/ then
				self.notifySheetDelete(cntrl.GTE_Sheet);
			endif;
			
			if cntrl.visible then
				delete cntrl;
			endif;

		elseif cntrl.isKindOf(TextBox) then
			cntrl.TextBox.text := null;
			
		endif;
	endforeach;
	
	tblCommon.clearValues();
	self.myGTESheetRequiresRefresh := null;	//PAR 23408 22/04/2010
	
	
	btnDeleteCurrent.enabled := false;
	//Removed to allow for just entering a chassis in the carrier/vehicle details field
	//btnSaveBase.enabled := false;
	
	//epr we need to do this always - because when saved this gets cleared and if it is not visible is never set. Results in a validation error "Gate Area - required field"
	
	if not self.myTerminal.getConfig(GateInOutHideArea).Boolean then
		gateDefaultEntry := self.myTerminal.getConfig(GateDefaultEntry).CM_Gate;
		if gateDefaultEntry &lt;&gt; null and gateDefaultEntry.myDefaultInterchangeArea &lt;&gt; null then
			tblCommon.setValueByName(ETRow_RoadTransAreaId, gateDefaultEntry.myDefaultInterchangeArea.id);  // 21313
		endif;
	endif;

	if tblCommon.accessRow(tblCommon.getRow(ETRow_IsReceiptRequired)).visible then
		tblCommon.setValueByName(ETRow_IsReceiptRequired, self.myTerminal.getConfig(GateReceiptRequired).String.trimRight);
	endif;

	self.setAutoComplete();
	self.clearTblJobs();
	self.fillTblTransfers();
	self.resetChassisControls();

	if self.myTerminal.defaultCargoType = TI_CargoType_Log then
		self.tblCommon.goToRowByName(ETRow_RegNumber);
		self.tblCommon.setFocus;	
	else
		// doWindowEvents is a fudge as sometimes the setFocus does
		// not cause the app.activeControl to be set correctly which
		// then causes problems when the user tabs into tblCommon
		// (after Save tab key does not go to first row in tblCommon) - rjs Jun2303
		txtNewItem.doWindowEvents(0);
		txtNewItem.setFocus;	
	endif;	

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="clearLayout" id="322ffba5-711a-445c-838a-9bc10ecd6770">
