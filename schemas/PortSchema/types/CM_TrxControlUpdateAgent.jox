    <JadeMethod name="trxUpdateRepairedDimensions" id="208b5cad-f70a-4804-9f3c-07a85402b9b6">
        <updating/>
        <source>trxUpdateRepairedDimensions( _ti : CM_TrackedItem input;
							_quantity : Integer;
							_tareWeight : Decimal;
							_cargoWeight : Decimal;	
							_totaWeight : Decimal;
							_reason : String; 
							_diameter : Decimal input;
							_height : Decimal input;
							_volume : Decimal input;
							_rollingLength : Decimal input;
							_length : Decimal input;
							_grammage : Decimal input;
							_width : Decimal input;
							_passport : CM_Passport input
							) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 July 2022	navak20	TFS 53862 EUP - WMS - Damage Recording Extra Details
17 May 2023		jlika1	TFS 56398 EUP - OUT - Overlanded Cargo Handling - Web
20/10/2023	navcs2	ChangeRequest 59995: EUP | Damage Recording - Updating Cargo Details
*/

vars
	realTI	: CM_TrackedItem;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);

	beginTransaction;

	app.myUtilityUA.utlUpdateRepairedDimensions( _ti, _diameter, _height, _volume, _rollingLength, _length, _grammage, _width, _passport);
	
	// 20/10/2023	navcs2	ChangeRequest 59995 Start
	if _totaWeight = 0 then
		app.raiseCMWarning1(Total_weight_should_not_zero, "Total Weight", null, null, null);
	endif;
	
	if _ti.myCargoType.useTareCargoWeight then
		if _cargoWeight = 0 then
			app.raiseCMWarning1(Cargo_weight_should_not_zero, "Cargo Weight", null, null, null);
		endif;
		if _tareWeight = 0 then
			app.raiseCMWarning1(Tare_weight_should_not_zero, "Cargo Weight", null, null, null);
		endif;
	endif;
	// 20/10/2023	navcs2	ChangeRequest 59995 End
	
	if not _passport.noErrors then
		return;
	endif;
	
	//this is to check if qauntity or weight is getting changed or not to avoid blank row in transaction
	if  (_quantity &lt;&gt; null and _ti.totalQuantity &lt;&gt; _quantity) 
		or _ti.totalWeight &lt;&gt; _totaWeight 
		or _ti.weightCargo &lt;&gt; _cargoWeight 
		or _ti.weightTare &lt;&gt; _tareWeight then
		
		realTI := app.myProxyManager.getRealObject(_ti).CM_TrackedItem;
		
		app.myUtilityUA.utlBreakBulkOverage( realTI, _quantity, _totaWeight, _cargoWeight, _tareWeight, _reason, false, false, false, _passport);
		
	endif;
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_tareWeight" type="Decimal"/>
        <Parameter name="_cargoWeight" type="Decimal"/>
        <Parameter name="_totaWeight" type="Decimal"/>
        <Parameter name="_reason" type="String"/>
        <Parameter name="_diameter" type="Decimal" usage="input"/>
        <Parameter name="_height" type="Decimal" usage="input"/>
        <Parameter name="_volume" type="Decimal" usage="input"/>
        <Parameter name="_rollingLength" type="Decimal" usage="input"/>
        <Parameter name="_length" type="Decimal" usage="input"/>
        <Parameter name="_grammage" type="Decimal" usage="input"/>
        <Parameter name="_width" type="Decimal" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateReparentMenuUserItem" id="2fde322d-0c75-4709-898f-79d011aac467">
        <updating/>
        <source>trxUpdateReparentMenuUserItem(_parent : CM_MenuEntity; _child : CM_MenuUserItem input;
						_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     07 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on LockException do agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(false);

	beginTransaction;

	app.myUtilityUA.utlUpdateReparentMenuUserItem(_parent, _child, _passport);

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
