    <JadeMethod name="isTransferType_Match" id="b34151da-2639-47e0-aee6-a6b107d7f93d">
        <source>isTransferType_Match(_yaData: CM_YADataObjects): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 October 2018	jlgndl1	Initial creation	TFS 41187

*/

vars

	yaDataObjs : CM_YADataObjects;
	obj : Object;
	
	transferType : CM_VoyageJobTransferType;
	transferTypeId : Integer;

begin

	if self.myTransaction = null then
		return false;
	endif;
	if self.myTransaction.isKindOf( CM_ReceiveShip ) then
		transferTypeId := self.myTransaction.CM_ReceiveShip.transferType;
	elseif self.myTransaction.isKindOf( CM_ReleaseShip ) then
		transferTypeId := self.myTransaction.CM_ReleaseShip.transferType;
	elseif self.myTransaction.isKindOf( CM_WorkOrderExtraTI ) then // TFS 42221
		transferTypeId := self.myTransaction.CM_WorkOrderExtraTI.getTransferType(); // TFS 42221
	else
		transferTypeId := self.myTransaction.myTrackedItem.getTransferType;
	endif;
	
	if _yaData &lt;&gt; null and _yaData.isKindOf(CM_YADataObjects) then
		yaDataObjs := _yaData.CM_YADataObjects;
		if not yaDataObjs.isEmpty then
			obj := yaDataObjs.getFirstObject;
		endif;
		if obj &lt;&gt; null and obj.isKindOf( CM_VoyageJobTransferType ) then
			transferType := obj.CM_VoyageJobTransferType;
			return transferType.id = transferTypeId;
		endif;
	endif;
	
	return false;
	
epilog

end;</source>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isTransitStatus_Match" id="ebcc9577-0e45-420b-81e0-33133db127ee">
        <source>isTransitStatus_Match(_yaData: CM_YADataInteger): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Apr 2017	cnwma1 TFS #3890:STWO - Add 'in transit' to Cargo allocations

*/

vars
	transitStatus : Integer;
	yaData : CM_YAData;
	yaDataInteger : CM_YADataInteger;
begin
	transitStatus := self.myTransaction.myTrackedItem.getTransitStatus;
	
	if _yaData &lt;&gt; null and _yaData.isKindOf(CM_YADataInteger) then
		yaDataInteger := _yaData.CM_YADataInteger;
		if yaDataInteger &lt;&gt; null then
			if not yaDataInteger.allValues.isEmpty then
				return _yaData.allValues.includes(transitStatus);
			endif;
		endif;
	endif;
		
	return true;
	

epilog

end;</source>
        <Parameter name="_yaData" type="CM_YADataInteger"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isTrxToDoResource_Match" id="64170429-4a6a-4e7b-9b11-52ed34551504">
        <source>isTrxToDoResource_Match(_yaData: CM_YADataObjects): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 May 2024	jlier1	Initial creation 63834
25 Jun 2024 jlier1  TFS 64775
*/

vars

begin

	if _yaData.isEmpty() then
		return true;
	endif;

	if self.myResourceTypeUsage = null then
		return false;
	endif;
	

	if _yaData.matches(self.myResourceTypeUsage.myResourceType) then
		return true;
	endif;
	
	return false;
epilog

end;</source>
