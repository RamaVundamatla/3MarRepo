Date		Who		Reason
28 June 2022	jlier1	Initial creation  TFS 53679

*/

vars
	auditText : String;
begin
	auditText:= inheritMethod();

	return app.getErrorString(Address) &amp; " "  &amp; self.code &amp; AuditStringSeparator &amp; auditText.length.String &amp; AuditStringSeparator &amp; auditText &amp; AuditStringSeparator;

