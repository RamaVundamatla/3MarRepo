<PrimType name="String">
    <JadeMethod name="cnEcDisplayNonPrintable" id="e50b2d6c-71c4-4fc4-b427-4edcc78756e7">
        <source>cnEcDisplayNonPrintable():String;
// Convert non-printable characters in the receiver to 
// ASCII code equivalents and display in angle brackets.
vars
	charIndex		: Integer;
	returnString	: String;
	theCharacter	: Character;
	receiverLength	: Integer;

begin
	receiverLength	:=	self.length;
	
	while charIndex &lt; receiverLength do
		charIndex		:=	charIndex + 1;
		theCharacter	:=	self[charIndex].Character;

		if theCharacter.isPrintable then
			returnString	:=	returnString &amp; theCharacter;
		else 
			returnString	:=	returnString &amp; "&lt;/" &amp; theCharacter.Integer.String.padLeadingZeros(3) &amp; "&gt;";
		endif;
	endwhile;

	return returnString;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isTrue" id="b670f129-d370-42ed-8174-a5ec12e26546">
        <source>isTrue(_trueValue : String) : Boolean;
/*

Purpose:			


Return Value:		


Date		Who		Reason
07 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin

	if self  = _trueValue then
		return true;
	else
		return false;
	endif;
epilog

end;</source>
        <Parameter name="_trueValue" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isTrueFalse" id="ef915582-4293-40a8-ad4d-bc677caf981e">
        <source>isTrueFalse(_trueValue, _falseValue : String) : Boolean;
/*

Purpose:			


Return Value:		


Date		Who		Reason
15 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin

	if self = _trueValue then
		return true;
	elseif self = _falseValue then
		return false;
	endif;
	return null;
epilog

end;</source>
        <Parameter name="_trueValue" type="String"/>
        <Parameter name="_falseValue" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="mbEncrypt" id="1e25b033-53fc-4dd1-9648-300146a9a3c1">
        <source>mbEncrypt():String;
// --------------------------------------------------------------------------------
// Created:		31 May 2000 by cnwdad1
//
// Purpose:		Provides a one-way encryption of the string.
//
//  To ensure portability (ie. that we get the same result) across architectures
//  that may have different byte ordering, we use a mod 256 to get the logical LSB
//  and build the result into a character string.  This algorithm will work with
//  ANSI or UNICODE strings.  The encryption is one-way.
//
// Parameters:	None
//
// Returns:		The encrypted receiver.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	// We are hard coding the key so we don't have to generate/derive it for each use.
	CRYPT_KEY	: Integer =	37463 * 1324;

vars
	encryptedResult	: String;
	sourceLength	: Integer;
	charIndex		: Integer;
	encryptChar 	: Character;
 	temp			: Integer;

begin
	encryptedResult		:=	"";

	if self = null then				// Handle special case of empty string.
		encryptedResult[1] := (CRYPT_KEY mod 256).Character;
	else
		sourceLength	:=	self.length;
		charIndex		:=	1;
		encryptChar		:=	self[sourceLength];

		foreach charIndex in 1 to sourceLength do
			temp	:=	(self[charIndex].Integer*CRYPT_KEY + encryptChar.Integer) mod 256;

			if (temp = 0) then
				temp	:=	1;
			endif;

			encryptedResult[charIndex]	:=	temp.Character;
			encryptChar					:=	self[charIndex];
		endforeach;
	endif;

	return encryptedResult;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="mbHandleAmpersands" id="ddeb7306-b610-4409-bf8d-58c479e3035e">
        <source>mbHandleAmpersands():String;
// --------------------------------------------------------------------------------
// Created:		25 January 2006 by cnwdad1
//
// Purpose:		To handle ampersands in the receiver (which is to be displayed in
//				the caption of a label or button) where the default action of
//				underlining the following character is not required.
//
//				Any ampersand followed by a space, or at the end of the string, is
//				replaced by "&amp;&amp;".  Other ampersands are removed.
//
// Parameters:	None
//
// Returns:		The receiver string, with ampersands transformed as described above.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	AMPERSAND		: String = '&amp;';
	SPACE			: String = ' ';
	
vars
	selfLen			: Integer;
	tempString		: String;
	returnString	: String;
	charPos			: Integer;
	
begin
	// Handle exception cases first
	if self = null or self.pos('&amp;', 1) &lt; 1 then
		return self;
	endif;

	selfLen	:=	self.length;
	charPos	:=	1;
	
	while charPos &lt;= selfLen do
		tempString := self.scanUntil(AMPERSAND, charPos);
		
		// Performance enhancement for long strings
		if tempString &lt;&gt; null then
			returnString := returnString &amp; tempString;
		endif;
		
		// No more ampersands
		if charPos = 0 then
			break;
		endif;
		
		// If the ampersand is at the end of the string, or there's a space following 
		//  it, then replace it with "&amp;&amp;"
		if charPos = selfLen or self[charPos + 1:1] = SPACE then
			returnString := returnString &amp; AMPERSAND &amp; AMPERSAND;
		endif;
		
		// Otherwise skip it
		charPos	:=	charPos + 1;
	endwhile;

	return returnString;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="substituteParams" id="5f044753-a339-46a2-9de8-25579ac54d31">
        <source>substituteParams(_paramArrayObj : HugeStringArray) : String;
// --------------------------------------------------------------------------------
// Created:		13 October 2005 by cnwdad1 - Copied from the PortSchema.
//
// Purpose:		Returns a new string which is self with all %n parameters
//				substituted from the values in the supplied string array
//
// Parameters:	_paramArrayObj - An array if (huge) string parameter values.
//
// Returns:		The receiver with the parameter values inserted.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	paramIndex		: Integer;
	originalMsgLen	: Integer;
	charPos			: Integer;
	copyFromPos		: Integer;
	originalMsg		: String;
	substitutedMsg	: String;
	currentChar		: Character;
	nextChar		: Character;
	
begin
	copyFromPos		:=	1;
	originalMsg		:=	self;
	originalMsgLen	:=	originalMsg.length();
	substitutedMsg	:=	null;
	
	foreach charPos in 1 to originalMsgLen do
		currentChar	:=	originalMsg[charPos];
		
		if charPos + 1 &lt;= originalMsgLen then
			nextChar	:=	originalMsg[charPos + 1];
		else
			nextChar	:=	null;
		endif;
		
		if currentChar = '%' and nextChar &gt;= '1' and nextChar &lt;= '9' then
			paramIndex		:=	nextChar.Integer - '0'.Integer;
			substitutedMsg	:=	substitutedMsg &amp; originalMsg[copyFromPos : charPos - copyFromPos];
			
			if paramIndex &lt;= _paramArrayObj.size then
				substitutedMsg	:=	substitutedMsg &amp; _paramArrayObj[paramIndex].trimBlanks;
			endif;
			
			charPos		:=	charPos + 2;
			copyFromPos	:=	charPos;
		endif;
	endforeach;
	
	if copyFromPos &lt;= originalMsgLen then
		substitutedMsg	:=	substitutedMsg &amp; originalMsg[copyFromPos : charPos - copyFromPos];
	endif;

	return substitutedMsg;
end;</source>
        <Parameter name="_paramArrayObj" type="HugeStringArray"/>
        <ReturnType type="String"/>
    </JadeMethod>
</PrimType>
