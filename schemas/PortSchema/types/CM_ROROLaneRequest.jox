    <JadeMethod name="setForCreate" id="835bb4b9-9f0b-416c-bd34-4367b0025772">
        <updating/>
        <source>setForCreate(_proxySlotRequest:CM_RORORequest) updating;
// ---------------------------------------------------------------------------
// Created:     June 2008 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
 // PAR 29807 the setForCreateLayout call has to be before this new request is added to the LC
// ---------------------------------------------------------------------------

vars
	needToSetDoorDir	: Boolean;
	tmpSlot		: CM_VoyageROROController;
begin

	_proxySlotRequest.raiseExceptionIfNotTransient(method);
	
	if _proxySlotRequest.doorsDirection = TI_DOORSDIRN_NULL and
	   _proxySlotRequest.motorDirection = Motor_Null then
		// Assume that proxy has not been setup with defaults so set
		// a flag to set the defaults.  Need to do this once the
		// real is updated as the setDoorMotorDirDefault relies
		// on certain attributes being set.
		needToSetDoorDir := true;
	endif;

	self.myROROController := _proxySlotRequest.myROROController;

	self.setForUpdate(_proxySlotRequest);
	self.createWLEs();
	
	
	self.setForCreateLayout();
	self.myROROController.addSlotRequest(self.isLoad, self);


	
	// do this AFTER setting mySlotController as this relies
	// on the CM_SlotController.myDischargeRequest being set
	self.setForUpdateTI(NULL_MOVETYPE);
	

end;</source>
        <Parameter name="_proxySlotRequest" type="CM_RORORequest"/>
    </JadeMethod>
</Class>
