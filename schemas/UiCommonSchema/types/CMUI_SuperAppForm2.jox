    <JadeMethod name="doToolbarTopContextMenu" id="23754610-3552-4d68-8f82-5ba7b2ad81fe">
        <updating/>
        <source>doToolbarTopContextMenu(cntrl: Frame input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     20 January 2003		cnwth2	
//
// Purpose:     //conwin: Window input;
//			 
// ----------   ----------  --------------------------------------------------
vars
	
	x1, 
	y1					: Real;
	menuEntity			: CM_MenuEntity;
	user				: CM_User;
	terminal			: CM_Terminal;
	
begin

	user := app.getMyUser();
	x1 := x;
	y1 := y;
	if cntrl &lt;&gt; null then
		if not mouse then  // if keyboard, use current listIndex value
		    x1 := 20;
		    if cntrl.top &lt; 0 then
		        y1 := 5;
		    else
		        y1 := cntrl.top;
		    endif;
		endif;
		conwin.windowToScreen(x1, y1);
	endif;
	
	self.mnuResetAll.visible := false;
	self.mnuResetFromJMT.visible := true;
	self.mnuResetFromSys.visible := true;
	self.mnuSaveAsJMT.visible := app.isSpecial();
	self.mnuSaveAsSys.visible := false;
	self.mnuCustomise.visible := false;
	self.mnuSeperator2.visible := false;
	self.mnuShowCaptions.visible := false;
	
	if user.canDo(terminal, PmAdmAdminMenuAccess) then
		self.mnuSeperator2.visible := true;
		self.mnuSaveAsSys.visible := true;
		self.mnuResetAll.visible := true;
	endif;
		
	if app.getMyUser.canDo(terminal, PmAdmOrganizeMenus) then
		self.mnuCustomise.visible := true;
	endif;
	
	self.screenToWindow(x1, y1);
	self.popupMenu(self.mnuToolbarContext, x1.Integer, y1.Integer);
	
	return false;
end;</source>
        <access>protected</access>
        <Parameter name="cntrl" type="Frame" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
