    <JadeMethod name="embargoPin" id="7140463e-8b07-4367-ae7b-4d5842510938">
        <source>embargoPin(_isDelete : Boolean);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 16/05/2018	jlgdap1		Initial creation TFS 38501 PEL1 Work Order Changes
//
vars

begin
	if self.myPinNo = null then
		return;
	endif;
	
	self.myPinNo.isEmbargoed := true;
	self.myPinNo.embargoedTS := app.serverTimestampAtTrxStart;
