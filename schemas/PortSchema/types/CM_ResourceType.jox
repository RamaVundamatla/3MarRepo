    <JadeMethod name="cnEcGetDuplicate" id="f1c5919b-1b5f-4976-a4dc-db8ff257f9f8">
        <source>cnEcGetDuplicate(pFormat: CnEcXmlFormat; pInput: CnEcXmlStructureInstance): Object;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 September 2014	cnwndl1	Initial creation	Par 34893

*/

vars

	code : String;
	resource : CM_ResourceType;

begin

	code := self.cnEcXMLGetTheAttributeValue( pFormat, pInput, self.class.name, "code" ).String; 
	
	if code &lt;&gt; null then
		resource := app.myRoot.allTaskResourceTypes.getAtKey( code );
	endif;

epilog

	return resource;

end;</source>
        <Parameter name="pFormat" type="CnEcXmlFormat"/>
        <Parameter name="pInput" type="CnEcXmlStructureInstance"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="58413932-5406-4624-80fd-1daa2c5ff0d8">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 December 2009	cnwndl1	Initial creation	CCMS MES 1006
31 October  2022    ChangeRequest 56635:[54261] EUP - Todo Task Resources Maintenance
23 December 2022    ChangeRequest 54349[54262]: EUP - Enable Is Mandatory for ToDo Task Resources
*/

vars

begin

	if _attrName = ETRow_Code then
		return self.code;
	elseif _attrName = ETRow_Description then
		return self.description;
	elseif _attrName = ETRow_NumDecimals then
		return self.decimalPlaces.String;
	elseif _attrName = ETRow_UnitDescription then
		return self.unitDescription;
	elseif _attrName = ETRow_IsAvailable then
		return self.isAvailable.asStringJMT;
	elseif _attrName = ETRow_HasBeenUsed then
		return self.hasBeenUsed.asStringJMT;
	elseif _attrName = ETRow_IsAvailableYesNo then
		return self.isAvailable.getYesNo;
	elseif _attrName = ETRow_HasBeenUsedYesNo then
		return self.hasBeenUsed.getYesNo;
	//cnwmc5 - 22 Sep 2015 - PAR 36920
	elseif _attrName = ETRow_IsFromToDateTimeRequired then
		return self.isFromToDateTimeRequired.asStringJMT;
	elseif _attrName = ETRow_IsFromToDateTimeReqYesNo then
		return self.isFromToDateTimeRequired.getYesNo;
	elseif _attrName = ETRow_HookCode then
		return app.getErrorString(Doubleclick_view);
	elseif _attrName = ETRow_AdditionalInfo then				  //13 Apr 2017	NDL	TFS 3414
		return self.additionalInfo;
	elseif _attrName = ETRow_IsMandatory then    				 //23.12.2022 navds21 TFS #54349[54262]
		return self.mandatory.asStringJMT;		 				 //23.12.2022 navds21 TFS #54349[54262]
	elseif _attrName = ETRow_Type then       					 //31/10/2022 navds20 TFS #56635[54261]
		return app.getToDoTaskIntToString(self.type); 			 //31/10/2022 navds20 TFS #56635[54261]
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getJadeCode" id="e7708775-31b0-4bd4-a881-d6a87587b25c">
        <source>getJadeCode() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 September 2015	cnwmc5	Initial creation

*/

vars

begin
	if self.myHookCode = null then
		return null;
	endif;
	return self.myHookCode.getCurrentJadeCode();
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
