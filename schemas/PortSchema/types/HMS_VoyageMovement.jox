    <JadeMethod name="movement_CheckDateIsValid" id="c9d94b56-41b7-4e9e-a171-fe27abed6b55">
        <updating/>
        <source>movement_CheckDateIsValid(movementType:String; moveDate: Date; moveTime: Time; selectedVoyage: CMIF_HMS_WorkingVoyage):Boolean updating;


vars
   	moveToCheck:	CMIF_HMS_WorkingMovement;
   	arrvMove:		CMIF_HMS_WorkingMovement;
   	deptMove:		CMIF_HMS_WorkingMovement;
   	msgBoxType:		Integer;
   	moveDT:			TimeStamp;
begin
	moveDT:=(moveDate.String &amp; "," &amp; moveTime.String).TimeStamp;
 	// This method checks that the movement date is valid

 	if movementType=HMSMovementTypeArrival then
 		// Arrival Movement - must occur before all other movements
 		arrvMove:=selectedVoyage.allWorkingMovements.first.CMIF_HMS_WorkingMovement;
 		// Get first movement in voyage.allWorkingMovements collection directly after the arrival movement
 		moveToCheck:=selectedVoyage.allWorkingMovements.getAtKeyGtr(arrvMove.occursOnDT).CMIF_HMS_WorkingMovement;
        if moveToCheck.occursOnDT&lt;moveDT then
        	// Error - arrival movement must occur before all other movements
        	msgBoxType:=MsgBox_OK_Only+MsgBox_Exclamation_Mark_Icon+MsgBox_Default_First;
			app.msgBox(app.getErrorString(MSGBOX_ArrvDTError), app.getErrorString(MSGBOX_MoveDTInvalidTitle), msgBoxType);
			return false;
        endif;
        return true;
	elseif movementType=HMSMovementTypeShift then
 		// Shift Movement - must occur after arrival and before departure movements
 		if moveDT&lt;selectedVoyage.arrivedDT then
 			// Error - The shift movement cannot occur before the arrival movement
 			msgBoxType:=MsgBox_OK_Only+MsgBox_Exclamation_Mark_Icon+MsgBox_Default_First;
			app.msgBox(app.getErrorString(MSGBOX_ShiftADTError), app.getErrorString(MSGBOX_MoveDTInvalidTitle), msgBoxType);
			return false;
 		elseif moveDT&gt;selectedVoyage.departedDT then
 			// Error - The shift movement cannot occur after the departure movement
 			msgBoxType:=MsgBox_OK_Only+MsgBox_Exclamation_Mark_Icon+MsgBox_Default_First;
			app.msgBox(app.getErrorString(MSGBOX_ShiftDDTError), app.getErrorString(MSGBOX_MoveDTInvalidTitle), msgBoxType);
			return false;
 		endif;
 		return true;
	elseif movementType=HMSMovementTypeDeparture then
		// Departure Movement - must occur after all other movements
		deptMove:=selectedVoyage.allWorkingMovements.last.CMIF_HMS_WorkingMovement;
 		// Get first movement in voyage.allWorkingMovements collection directly before the departure movement
 		moveToCheck:=selectedVoyage.allWorkingMovements.getAtKeyLss(deptMove.occursOnDT).CMIF_HMS_WorkingMovement;
        if moveToCheck.occursOnDT&gt;moveDT then
        	// Error - departure movement must occur after all other movements
        	msgBoxType:=MsgBox_OK_Only+MsgBox_Exclamation_Mark_Icon+MsgBox_Default_First;
			app.msgBox(app.getErrorString(MSGBOX_DeptDTError), app.getErrorString(MSGBOX_MoveDTInvalidTitle), msgBoxType);
			return false;
        endif;
        return true;
 	endif;

end;</source>
        <Parameter name="movementType" type="String"/>
        <Parameter name="moveDate" type="Date"/>
        <Parameter name="moveTime" type="Time"/>
        <Parameter name="selectedVoyage" type="CMIF_HMS_WorkingVoyage"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="myHMSVoyageData" id="4397a1b0-a3ca-4768-9404-425107126bd5">
        <methodInvocation>mapping</methodInvocation>
        <source>myHMSVoyageData(set : Boolean; _value : HMS_VoyageData io) mapping;
/*

Purpose:			Cancelled Movements don't have an HMS_VoyageData, but its mandatory on all the others.	

Parameters:			

Return Value:		

Date		Who		Reason
19 November 2018	jlgndl1	Initial creation	TFS 42043

*/

vars

	voyage : CM_Voyage;

begin

	if self.isCancelled then
		if set then
			_value := null;
		else
			if self.myReplacementMovement &lt;&gt; null then
				_value := self.myReplacementMovement.HMS_VoyageMovement.myHMSVoyageData;
			else
				// one that is not linked yet...
				_value := self.getMyHMSVoyageData();
			endif;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="HMS_VoyageData" usage="io"/>
    </JadeMethod>
    <JadeMethod name="myPilot" id="d312c51c-d474-42f1-8627-630247a93954">
        <methodInvocation>mapping</methodInvocation>
        <source>myPilot(set : Boolean; _value : HMS_Pilot io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 October 2018	jlgndl1	Initial creation	TFS 41662 - This method is provided for the use of existing Report Writer Reports only
23 Apr 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement
*/

vars

begin

	if set then
		
		_value := null;	// No longer used.
	
	else
	
		if _value = null then
			//if not self.allPilots.isEmpty then // TFS 44438
			//	_value := self.allPilots.first; // TFS 44438
			if not self.allMovementPilotDetails.isEmpty then // TFS 44438
				_value := self.allMovementPilotDetails.first.myPilot; // TFS 44438			
			endif;
		else
			//returning value for as yet unconverted data
		endif;
	
	endif;

epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="HMS_Pilot" usage="io"/>
    </JadeMethod>
    <JadeMethod name="myPilotLaunch" id="ea472cf1-f7e3-4a7a-be70-e8b5bb2b101a">
        <methodInvocation>mapping</methodInvocation>
        <source>myPilotLaunch(set : Boolean; _value : HMS_PilotLaunch io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Apr 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement

*/

vars

begin
	if set then // never set
		_value := null;	
	else	
		if _value = null then
			if self.getFirstPilotLaunch() &lt;&gt; null then
				_value := self.getFirstPilotLaunch();		
			endif;
		else
			_value := self.myPilotLaunch;
		endif;	
	endif;
epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="HMS_PilotLaunch" usage="io"/>
    </JadeMethod>
