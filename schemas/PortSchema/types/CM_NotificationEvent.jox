<Class name="CM_NotificationEvent" id="c6033210-3ab2-473b-85d7-b46b5e8bf90d">
    <superclass name="CM_ModelEvent"/>
    <transient/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <DbClassMap file="cmtrans"/>
    <JadeMethod name="dispatch" id="d39e1fe2-bce9-4bb8-a68a-f299be9cf385">
        <updating/>
        <source>dispatch() updating;
// ---------------------------------------------------------------------------
// Created:     19 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin

	if self.mySubject = null then
		return;
	endif;
	
	self.doCauseEvent;
end;</source>
    </JadeMethod>
    <JadeMethod name="doCauseEvent" id="b473d997-a3c5-4bae-8dd8-a57395a71437">
        <source>doCauseEvent() protected, abstract;</source>
        <abstract/>
        <access>protected</access>
    </JadeMethod>
</Class>
