    <JadeMethod name="getTIDisplayValueForAttribute" id="13bb0dd3-3825-4368-9618-71dbfb8c9f68">
        <source>getTIDisplayValueForAttribute(_bb : CM_BreakBulkGeneric; _attrName : String) : String;
// ---------------------------------------------------------------------------
// Created:     12 May 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

	i	: Integer;
	d	: Decimal[12,4];

begin
	if _bb = null then
		return null;
	endif;
	
	if ((_attrName = ETRow_Width or _attrName = ETRow_MyWidth) and
	   (self.myWidth &lt;&gt; null)) then
		return self.myWidth.multiplyValue(_bb.width).String;
		
	elseif ((_attrName = ETRow_Height or _attrName = ETRow_MyHeight) and
	   (self.myHeight &lt;&gt; null)) then
		return self.myHeight.multiplyValue(_bb.height).String;
		
	elseif ((_attrName = ETRow_Length or _attrName = ETRow_MyLength) and
	   (self.myLength &lt;&gt; null)) then
		return self.myLength.multiplyValue(_bb.length).String;
	
	elseif ((_attrName = ETRow_Quantity or _attrName = ETRow_MyQuantity) and
	   (self.myQuantity &lt;&gt; null)) then
		return self.myQuantity.multiplyValue(_bb.quantity).String;
	
	elseif ((_attrName = ETRow_Volume or _attrName = ETRow_MyVolume) and
	   (self.myVolume &lt;&gt; null)) then
		return self.myVolume.multiplyValue(_bb.getMyTotalVolume).asStringJMTWithPrecision(3, false);	// #26490 2/12/2010. Fixed for ITA locale and 3 decimals precision for volume **
	
	elseif ((_attrName = ETRow_Density or _attrName = ETRow_MyDensity) and
	   (self.myDensityDec &lt;&gt; null)) then										// ### TFS 52193 22Nov2021 NAVPW1
		return self.myDensityDec.multiplyValue(_bb.density).String;				// ### TFS 52193 22Nov2021 NAVPW1
	
	//elseif ((_attrName = ETRow_Weight or _attrName = ETRow_MyWeight) and		//-cnwml2 MSL CCMS 1017
	elseif _attrName = ETRow_MyWeight and self.myWeight &lt;&gt; null then
		//return self.myWeight.multiplyValue(_bb.weight).String;				//-cnwml2 MSL CCMS 1017
		return self.myWeight.multiplyValue(_bb.totalWeight).String;				//+cnwml2 MSL CCMS 1017
	
	elseif ((_attrName = ETRow_Colour) and
	   (self.colour &lt;&gt; null)) then
		return self.colour.String;
	elseif ((_attrName = ETRow_UnsplitVolume) and 
		(self.myVolume &lt;&gt; null)) then
		d := self.myVolume.multiplyValue(_bb.unsplitVolume);
		if d &gt; 0 then
			return d.roundedTo(2).String;
		endif;
	elseif ((_attrName = ETRow_UnsplitWeight) and 
		(self.myWeight &lt;&gt; null )) then
	//	d := self.myWeight.multiplyValue(_bb.unsplitWeight);
		d := self.	getMyWeightDisplayValue(_bb.unsplitWeight);
		if d &gt; 0 then
			return d.roundedTo(2).String;
		endif;
	endif;
	   
	return null;
end;</source>
        <Parameter name="_bb" type="CM_BreakBulkGeneric"/>
        <Parameter name="_attrName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTotalQuantity" id="f8937af6-c770-4062-8c67-a416c7e4218c">
        <source>getTotalQuantity() : Integer;
// ---------------------------------------------------------------------------
// Created:     28 August 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	soh			: CM_SOHLocation;
	totQty		: Integer;
begin
	foreach soh in self.allSOHLocations do
		// RJS - 3/6/2010 - only interested in on-site details. PAR18081/15591
		if (not soh.myLocationsController.isKindOf(CM_YardController)) then
			continue;
		endif;
		totQty := totQty + soh.allTrackedItems.size.Integer;
	endforeach;
	
	return totQty;
	
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTotalVolume" id="b654d6a8-d81c-4a80-a1e6-eb633f8ce983">
        <source>getTotalVolume() : Real;
// ---------------------------------------------------------------------------
// Created:     28 August 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	soh			: CM_SOHLocation;
	totVol		: Real;
begin
	foreach soh in self.allSOHLocations do
		if (not soh.myLocationsController.isKindOf(CM_YardController)) then //PAR15591/18081 - cnwsh3 Only check on-site locations. 3/6/2010
			continue;
		endif;
		
		totVol := totVol + soh.getTotalVolume;
		
	endforeach;
	
	return totVol;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getTotalWeight" id="3266d4cb-9747-48d0-bcca-7434b68d14a3">
        <source>getTotalWeight() : Real;
// ---------------------------------------------------------------------------
// Created:     28 August 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	soh			: CM_SOHLocation;
	totWeight		: Real;
begin
	foreach soh in self.allSOHLocations do
		if (not soh.myLocationsController.isKindOf(CM_YardController)) then //PAR15591/18081 - cnwsh3 3/6/2010 Only check on-site locations.
			continue;
		endif;
		
		totWeight := totWeight + soh.getTotalWeight;
		
	endforeach;
	
	return totWeight; //already in tonnes from SOH Location summary methods
end;</source>
        <ReturnType type="Real"/>
