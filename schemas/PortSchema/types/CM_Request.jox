    <JadeMethod name="getNumTIsOfMode" id="7b8291f6-b005-4e75-ad4f-de887bd7b813">
        <source>getNumTIsOfMode(_theMode : Integer; _checkWLE : Boolean) : Integer;
/*
Purpose:			
Date			Who			Reason
AUGUST 2011		CNWAB1		Initial creation 
14 May 2013		cnwer1		CCMS 2274 changed to use quantity on wle
23 July 2019	jlgzm1		TFS 42863 Direct Release Between RORO Voyages and Rail
*/

vars
	num : Integer;
	aWLE : CM_WorkListEntry;
begin
	
	foreach aWLE in self.allWorkListEntries do
		
		if not _checkWLE // PAR 28409
		and aWLE.myTrackedItem &lt;&gt; null then
			if _theMode = PLANNING_MODE then
				if aWLE.myTrackedItem.myPrimaryPlannedLocation &lt;&gt; null then
					num := num + aWLE.quantity.max(1);
				endif;
			elseif _theMode = REAL_MODE then
				if aWLE.myTrackedItem.myPrimaryActualLocation = self.getLC() then
					num := num + aWLE.quantity.max(1);
				endif;
			elseif _theMode = QUEUE_MODE then
				if aWLE.myTrackedItem.myPrimaryQueuedLocation &lt;&gt; null then
					num := num + aWLE.quantity.max(1);
				endif;
			endif;
		else
			if _theMode = QUEUE_MODE then
				if (aWLE.myFutureMove &lt;&gt; null and aWLE.myFutureMove.isFutureMoveQueued()) or
				   (aWLE.myFutureMoveDR &lt;&gt; null and aWLE.myFutureMoveDR.isFutureMoveQueued()) then	// TFS 42863
					num := num + aWLE.quantity.max(1);
				endif;
			elseif _theMode = PLANNING_MODE then
				if aWLE.myFutureMove &lt;&gt; null then
					if aWLE.myFutureMove.isFutureMovePlanned() then
						num := num + aWLE.quantity.max(1);
					elseif aWLE.myFutureMove.isFutureMoveQueued() and aWLE.myFutureMove.CM_FutureMoveQueued.myFutureMovePlanned &lt;&gt; null then
					//can still be planned if we have a queued move epr par 29898 26/6/12
						num := num + aWLE.quantity.max(1);
					endif;
				elseif aWLE.myFutureMoveDR &lt;&gt; null then												// TFS 42863
					if aWLE.myFutureMoveDR.isFutureMovePlanned() or									// TFS 42863
					   (aWLE.myFutureMoveDR.isFutureMoveQueued() and 								// TFS 42863
					   aWLE.myFutureMoveDR.CM_FutureMoveQueued.myFutureMovePlanned &lt;&gt; null) then	// TFS 42863	
						num := num + aWLE.quantity.max(1);											// TFS 42863
					endif;
				endif;
			elseif _theMode = REAL_MODE then
				// PAR 28409
				if aWLE.myTrackedItem &lt;&gt; null and  aWLE.myTrackedItem.myPrimaryActualLocation = self.getLC() then
					num := num + aWLE.quantity.max(1);
				endif;
			endif;
		endif;
	endforeach;
	
	return num;
end;</source>
        <Parameter name="_theMode" type="Integer"/>
        <Parameter name="_checkWLE" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
