12 February 2009	cnwer1	Initial creation

*/

vars

begin

	if self.tblInput1.getValueByName(ETRow_MachineType).String =  app.myRoot.allMachineTypes[MACHINETYPE_PORTAINER_CRANE].description and 	combobox.text = "Twin Lift" then
		tblInput1.showRowByName(ETRow_MaxLiftWeightTL, false);
