    <JadeMethod name="vesselNameVerify" id="398b58bc-6099-43c1-ae52-5f0608b479ac">
        <source>vesselNameVerify(_terminal : CM_Terminal):String;

vars
	voyageOid: CM_Voyage;
	message: String;
	value: Integer;
	ti	: CM_TrackedItem;
	terminal	: CM_Terminal;
	ediCargoType : Integer;
begin
	value := VALID;
	
//	voyageOid := _terminal.lookupVoyage(voyageCode, null, false);	// cnwrl1 09/06/2010 PAR 24299 - what it was
	if(_terminal.getConfig(EDIEnforceVoyageMatch).Boolean) then //TFS 52994, AjitM, navam1
		
		//21.Mar.2023 navsp1 TFS 56275
		if self.cargoType &lt; 1 then
			ediCargoType := TI_CargoType_Container;
		else
			ediCargoType := self.cargoType;
		endif;
		terminal := self.getMyTerminal;
		ti := terminal.allOnsiteTIsByIdCargoType[self.id,cargoType];
		if (not _terminal.getConfig(EDIEnforceVeslMatchExprt).Boolean) or (_terminal.getConfig(EDIEnforceVeslMatchExprt).Boolean and ti &lt;&gt; null and ti.isExport) then //06.Mar.2023 navsp1 TFS 56275

			voyageOid := _terminal.lookupVoyage(getVoyageCode(), null, false);
			
			if voyageOid = null or
			   voyageOid.vesselName = null or
			   voyageOid.vesselName.trimBlanks &lt;&gt; vesselName.trimBlanks then
				value := WARNING;
				message := "Vessel name does not match.";
			endif;
		endif;
	endif;
	return value.String &amp; message;
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="voyageCodeVerify" id="33a31d87-e6e5-4e32-96d9-f718381f2353">
        <source>voyageCodeVerify(_terminal : CM_Terminal) :String;
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------
// 29 Nov 2023	navpw1		TFS: 61364 (61375) - Modified to find bol on terminal by number and pack count. If the config setting is set 'Enforce Vessel Name Match for Customs EDI'
//30/6/2025 navsaa30 MTN-35121 CPL | TSW 819 Clearance - Clarify Error Message
vars
	value: Integer;
	message: String;
	bolIn	: CM_BOLIn;	// ### TFS 61364 (61375) 28Nov2023 NAVPW1
	valid	: Integer;
begin
	value := WARNING;
	
	//	if _terminal.lookupVoyage(voyageCode.trimBlanks, null, false) &lt;&gt; null then	// cnwrl1 09/06/2010 PAR 24299 - what it was
	if _terminal.lookupVoyage(self.getVoyageCode().trimBlanks, null, false) &lt;&gt; null then
		value := VALID;
	else
		// ### TFS 61364 (61375) 28Nov2023 NAVPW1
		if _terminal.getConfig(EDIEnforceVeslMatchExprt).Boolean and self.billOfLading &lt;&gt; null and self.billOfLading = self.id then
			bolIn := _terminal.getBOLInByNumberPackCount(self.billOfLading, self.packCount,valid);		//navsaa30 #35121
			if bolIn &lt;&gt; null then
				value := VALID;
			else
				message := "Voyage Code is not valid.";
			endif;
		else
			message := "Voyage Code is not valid.";
		endif;
		// ### TFS 61364 (61375) 28Nov2023 NAVPW1
		
	endif;
	
	return value.String &amp; message;
	
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
