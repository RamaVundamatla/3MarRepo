    <JadeMethod name="doSave" id="e4de6427-b1aa-46d8-b1d0-f313aadd5c7e">
        <updating/>
        <source>doSave(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 17/09/2015	cnwdap1		PAR #36909 CCMS ADP 2537 Minimum Charge changes
// 04/10/2017	jlgdap1		TFS 7204 STWR Fix real handling for non-standard locales
// 28/10/2021   navma1 		ChangeRequest 52163: SAL - Unicode Arabic Support Business Requirements
// 22/03/2022 	jlier1		TFS 53286
// 17/06/2022	jlizm1		TFS 52495 Disable editing of void service and invoice lines
// 31/01/2023	navvt20		TFS CR 56132 Task 56134: UI - Invoice Line Type - UOM

vars
	pxyInvoiceLineDesc	: CM_InvoiceLineDesc;
	realInvoiceLineDesc : CM_InvoiceLineDesc;
	table				: CM_EntryTable;
	theReturn 			: Integer;
	theServices 		: CM_ServiceByNameDict;
	chgNum 				: Integer;
	updatingVoidLine	: Boolean;
begin

	table := self.tblEntDetail;

	if self.mode = Mode_Add then
		create pxyInvoiceLineDesc transient;
		pxyInvoiceLineDesc.bank := self.myCurrentBank;
	elseif self.mode = Mode_Update then
		pxyInvoiceLineDesc := self.myProxyObject.CM_InvoiceLineDesc;
		if pxyInvoiceLineDesc.isVoid then	// TFS 52495
			updatingVoidLine := true;		// TFS 52495
		endif;
	else
		return false;
	endif;
	
	if updatingVoidLine then	// TFS 52495
		pxyInvoiceLineDesc.setNarration(table.getValueByName(ETRow_Narration200).String);	// TFS 52495
		
		realInvoiceLineDesc := self.myCurrentObject.CM_InvoiceLineDesc;						// TFS 52495
		if realInvoiceLineDesc &lt;&gt; null then													// TFS 52495
			pxyInvoiceLineDesc.setServices(realInvoiceLineDesc.services);					// TFS 52495
		endif;
		
	else
		create theServices transient;
		self.msgServices.getSelected(theServices);
		if self.cmbCharges.listIndex &gt; 0 then
			chgNum := self.cmbCharges.itemData[self.cmbCharges.listIndex];
		endif;
		
		pxyInvoiceLineDesc.setProxy(table.getValueByName(ETRow_OneLinePerFP).Boolean,
									table.getValueByName(ETRow_PrintTIs).Boolean,
									chgNum,
									self.cmbCharges.listObject.CM_DebtorType, 								//CCMS CP1047 16 April 2008 cnwgb1
									self.cmbUnits.itemObject[self.cmbUnits.listIndex].CM_CalculationType,	// 24024
									self.cmbInvTypeInv.listObject.CM_InvoiceDesc,
									table.getValueByName(ETRow_Narration200).String,						//28.10.2021 navma1 #52163
									table.getValueByName(ETRow_PrintOrder).Integer,
									table.getValueByName(ETRow_Remarks).String,
									table.getValueByName(ETRow_UnitNarration).String,
									theServices,
									table.getValueByName(ETRow_IsNotAvailableForEntryCk).Boolean,
									table.getValueByName(ETRow_MinimumChargeAmount).String.asRealJMT,		// TFS 7204
									table.getValueByName(ETRow_MinimumChargeGroupBy).String,				// PAR #36909
									table.getValueByName(ETRow_MinimumChargeLineType).String,				// PAR #36909
									table.getValueByName(ETRow_CurrConvNotReq).Boolean, 					// TFS 41484
									table.getValueByName(ETRow_TaxAlwaysCharged).Boolean,					//07 May 2019	NDL	TFS 44651
									table.getValueByName(ETRow_ExternalReference1).String,					//13/4/22 jlier1 TFS 53286
									self.cmbUOM.listObject.CM_InvoiceUnitOfMeasure	 			//31/01/2023 navvt20 TFS 56134
									);
									
	endif;

	while true do
 
	 	if self.mode = Mode_Add then
			app.myTrxCA.trxCreateInvoiceLineDesc(pxyInvoiceLineDesc,  self.myCurrentObject, app.myPassport);
		elseif self.mode = Mode_Update then
			app.myTrxUA.trxUpdateInvoiceLineDesc(pxyInvoiceLineDesc, app.myPassport);
		endif;
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			//global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog("Invoice Type", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return false;
		endif;
		break;
	endwhile;
	
	return true;

epilog
	if self.mode = Mode_Add then
		delete pxyInvoiceLineDesc;
	endif;
	delete theServices;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTblEntDetailDClick" id="ebeb0105-e03c-4fef-9447-b996ef0e4529">
        <updating/>
        <source>doTblEntDetailDClick(_table: CM_EntryTable input) updating;
// 24024 CCMS 1151 Aug 2010 cnwjre1 edit user hook code for invoice 
// 31451 no edit now, just view
vars
	rowInTable	: Integer;
begin
	rowInTable := _table.getRowByName(ETRow_QuantityHookCode);
	if _table.row = rowInTable and rowInTable &gt; 0 then
		self.showHookCodeMaintForm();
		return;
	endif;

end;</source>
        <Parameter name="_table" type="CM_EntryTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doThumbnailDClick" id="32601172-0c22-41fb-858f-49aa849b1907">
        <updating/>
        <source>doThumbnailDClick() updating;
// 24024 CCMS 1151 Aug 2010 cnwjre1 view user hook code for invoice quantity and rate
vars
	rowInTable	: Integer;
	obj	: Object;
begin
	// view hook code
	rowInTable := self.tblThumb.getRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_QuantityHookCode));
	if self.tblThumb.row = rowInTable and rowInTable &gt; 0 then
		self.showHookCodeMaintForm();
		return;
	endif;
	// edit calculation type
	rowInTable := self.tblThumb.getRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_Unity));
	if self.tblThumb.row = rowInTable and rowInTable &gt; 0 then
		obj := self.myCurrentObject.CM_InvoiceLineDesc.myCalculationType;
		if obj &lt;&gt; null then
			self.myAssistant.showTableViewForm(obj.CM_Object, PmAdmInvCalcTypesView, self.myMasterMenuAction, true, false);
		endif;
		return;
	endif;

end;
</source>
    </JadeMethod>
