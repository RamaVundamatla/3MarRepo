    <JadeMethod name="addErrorFull" id="6700a8e6-e8fd-43bf-995d-f013a3661eb0">
        <updating/>
        <source>addErrorFull(_errorCode : Integer; _text, _field : String; _object : CM_Object) updating;
// ---------------------------------------------------------------------------
// Created:     14 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	err	: CM_Error;

begin
	beginTransaction;
	create err;
	err.set(_errorCode, _text, false, _field, _object, _object);
//	err.setMyErrorApp();
//	err.myUserObject := pObject.CM_EDITrackedItem;
//	err.message := pText;
//	err.property := pField;
//	err.propertyValue := pText;
//	err.value := pErrorCode;
	commitTransaction;
end;</source>
        <Parameter name="_errorCode" type="Integer"/>
        <Parameter name="_text" type="String"/>
        <Parameter name="_field" type="String"/>
        <Parameter name="_object" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="canBeDBLoaded" id="be021628-8c42-4107-bbe0-fc5b15617969">
        <source>canBeDBLoaded(): Boolean;
//
// 22 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
//
vars
	result 	:Boolean;
begin
	result := inheritMethod();
	
	if not result then
		result := (self.status = CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS or self.status = CM_EDIFile.EDI_STATUS_VERIFY_ERRORS_X) and 
					self.getMyTerminal.getConfig (EdiBookingAllowPartial).Boolean;
	endif;

	return result;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canBePartiallyLoaded" id="e765738a-2310-4dec-b03e-75dd73bcb1f3">
        <source>canBePartiallyLoaded(): Boolean protected;
//
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
//
vars

begin
	return self.getMyTerminal.getConfig(EdiBookingAllowPartial).Boolean;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
