    <JadeMethod name="getAllBerthsForMovement" id="7771a191-1bbd-449f-acd5-b85ace17ca79">
        <source>getAllBerthsForMovement(_movement : HMS_VoyageMovement; _berthDict : HMS_BerthByCodeDict input);
//--------------------------------------------------
// Created:	19 August 2004 By: cnwgd1
//--------------------------------------------------
vars
	berthEndPos,
	startPos,
	endPos		: Decimal[12,2];
	tmpBerth 	: HMS_Berth;
	iter	 	: Iterator;
begin
	if _berthDict = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null _berthDict passed to method');
		return;
	endif;

	if _movement = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null _movement passed to method');
		return;
	endif;	
	
	_berthDict.clear();
	
	_movement.berthing_StartEndFromOrient(startPos, endPos, _movement.bowMarkTo, _movement.sternMarkTo);

	iter := self.allBerthsByStartPosnAndName.createIterator();
	self.allBerthsByStartPosnAndName.startKeyLeq(startPos.Integer, null, iter);
	
	// find berths spanning range
	while iter.next(tmpBerth) do
		berthEndPos := (tmpBerth.startPosition + tmpBerth.length);

		if startPos &gt;= tmpBerth.startPosition and endPos &gt;= berthEndPos
		or startPos &lt;= tmpBerth.startPosition and endPos &gt;= tmpBerth.startPosition
		or startPos &gt;= tmpBerth.startPosition and endPos &lt;= berthEndPos then
			_berthDict.add(tmpBerth);
		endif;
		
	endwhile;

epilog
	delete iter;
end;</source>
        <Parameter name="_movement" type="HMS_VoyageMovement"/>
        <Parameter name="_berthDict" type="HMS_BerthByCodeDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="ca0fe831-6948-4a04-acc0-0207e327d9c6">
        <source>getAuditText(): String;
// ---------------------------------------------------------------------------
// Created:     May 2007 by cnwvu1
//
// Purpose:     
// ---------------------------------------------------------------------------

vars
	txt		: String;
	tmpStr	: String;
	terminal: CM_Terminal;
begin

	txt[10000] := '*';
	txt := null;
	txt := inheritMethod();
	
	foreach terminal in self.allTerminals do
		if tmpStr = null then
			tmpStr := terminal.code;
		else
			tmpStr := tmpStr &amp; ', ' &amp; terminal.code;
		endif;
	endforeach;
	txt := txt &amp; 'Terminals Assigned' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	tmpStr:=null;
	
	return txt;
	
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getBerthForMarks" id="b098f7ef-9dde-46ec-a0ea-630583fff0b3">
        <source>getBerthForMarks(_bowMark, _sternMark: Decimal): HMS_Berth;
//--------------------------------------------------
// Created:	19 August 2004 By: cnwgd1
//--------------------------------------------------
vars
	centreBerth,
	berth,
	previousBerth	: HMS_Berth;
	int,
	centreMark,
	previousMeter,
	currentMeter	: Decimal[12,2];
begin
	// Calculate centre of ship
	if _bowMark &gt; _sternMark then
		centreMark := _sternMark + ((_bowMark - _sternMark)/2);
	else
		centreMark := _bowMark + ((_sternMark - _bowMark)/2);
	endif;

	previousMeter := 0;

	// find centre berth
	foreach berth in self.allBerths do
		currentMeter := berth.startPosition;
		if centreMark&gt;=berth.startPosition and centreMark&lt;=(berth.startPosition + berth.length) then
			centreBerth:=berth;
			break;
		endif;
		// check if the vessel has been dropped into a dead zone (zone that is not considered a normal part of the berth)
		if centreMark &gt;= previousMeter and centreMark &lt;= currentMeter then
			if previousMeter = 0 then
				centreBerth := berth;
			else	
				int := ((currentMeter - previousMeter)/2);
				if centreMark &lt;= (previousMeter + int) then
					if previousBerth &lt;&gt; null then
						centreBerth := previousBerth;
					else
						centreBerth := berth;
					endif;	
				else
					centreBerth := berth;
				endif;
			endif;
		endif;
		previousBerth := berth;
		previousMeter := berth.startPosition + berth.length;
	endforeach;
	
	if centreBerth = null then
		if _bowMark &lt;= 0 then
			centreBerth := self.allBerthsByStartPosnAndName.first;
		else
			centreBerth := previousBerth;
		endif;
	endif;

	return centreBerth;

end;</source>
        <Parameter name="_bowMark" type="Decimal"/>
        <Parameter name="_sternMark" type="Decimal"/>
        <ReturnType type="HMS_Berth"/>
    </JadeMethod>
    <JadeMethod name="getBollardForMark" id="85a8f1a7-620a-46ed-b389-ded7504b8349">
        <source>getBollardForMark(_metre : Decimal; _bollardMark : Decimal output; _bollard : HMS_Resource output);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 05/09/2023	navdap1		Initial creation TFS 59472 EUP | FR 56588 Berth planning by bollards Remedial
// 30/10/2024	navdap1		MTN-12358 EUP* | FR 54107 - Berth planning by bollards - part II
//
vars
	resource, bollard : HMS_Resource;
	distance, closest : Decimal [12,2];
	firstTime : Boolean;		// MTN-12358
	
begin
	_bollardMark := null;
	_bollard := null;
	firstTime := true;			// MTN-12358
	
	foreach resource in self.allResources where resource.myResourceType.isBollard do
		if resource.startPosnAlongWharf &lt;= _metre then
			distance := _metre - resource.startPosnAlongWharf;
			if distance &lt; closest or firstTime then				// MTN-12358
				closest := distance;
				bollard := resource;
				firstTime := false;								// MTN-12358
			endif;
		endif;
	endforeach;
	
	if bollard &lt;&gt; null then
		_bollardMark := closest;
	endif;
	_bollard := bollard;
epilog

end;</source>
        <Parameter name="_metre" type="Decimal"/>
        <Parameter name="_bollardMark" type="Decimal" usage="output"/>
        <Parameter name="_bollard" type="HMS_Resource" usage="output"/>
    </JadeMethod>
