    <JadeMethod name="translateForm" id="7f87b933-7686-4ba3-86b3-de870b9fba66">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 23 September 2021 10:42:03.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0008197, locale);
	//btnClearFilter.translateBubbleHelp(Xlat_0024454, locale);
	//btnClearFilter.translateCaption(Xlat_0024455, locale);
	btnCloseSearcher.translateBubbleHelp(Xlat_0001028, locale);
	btnCloseSearcher.translateCaption(Xlat_0001030, locale);
	btnDelete.translateBubbleHelp(Xlat_0001033, locale);
	btnDelete.translateCaption(Xlat_0001039, locale);
	btnDoSearch.translateBubbleHelp(Xlat_0001034, locale);
	btnDoSearch.translateCaption(Xlat_0001040, locale);
	btnEdit.translateBubbleHelp(Xlat_0005361, locale);
	btnEdit.translateCaption(Xlat_0005362, locale);
	btnNew.translateBubbleHelp(Xlat_0014623, locale);
	btnNew.translateCaption(Xlat_0001041, locale);
	btnPrint.translateCaption(Xlat_0001042, locale);
	btnReportOptions.translateBubbleHelp(Xlat_0001029, locale);
	btnReportOptions.translateCaption(Xlat_0001031, locale);
	btnSearcher.translateBubbleHelp(Xlat_0001036, locale);
	btnSearcher.translateCaption(Xlat_0001043, locale);
	btnSelectAll.translateBubbleHelp(Xlat_0001037, locale);
	btnSelectAll.translateCaption(Xlat_0001044, locale);
	btnView.translateBubbleHelp(Xlat_0001038, locale);
	btnView.translateCaption(Xlat_0001045, locale);
	lblSearcherCap.translateCaption(Xlat_0001032, locale);
	mnuAdd.translateCaption(Xlat_0010045, locale);
	mnuAddTask.translateCaption(Xlat_0010046, locale);
	mnuAddTaskSub.translateCaption(Xlat_0010047, locale);
	mnuColumnOrganiser.translateCaption(Xlat_0008198, locale);
	mnuContextTbl.translateCaption(Xlat_0008199, locale);
	mnuEdit.translateCaption(Xlat_0010048, locale);
	mnuInspectObj.translateCaption(Xlat_0008200, locale);
	mnuRemoveTasks.translateCaption(Xlat_0010049, locale);
	mnuRemoveTasksSub.translateCaption(Xlat_0010050, locale);
	mnuShowAll.translateCaption(Xlat_0010051, locale);
	mnuShowOnSite.translateCaption(Xlat_0010052, locale);
	mnuShowReal.translateCaption(Xlat_0010053, locale);
	mnuStops.translateCaption(Xlat_0010054, locale);
//  par 24342	mnuStopsSub.translateCaption(Xlat_0010055, locale);
	mnuTIMaster.translateCaption(Xlat_0010056, locale);
	mnuTblVCloneDataTbl.translateCaption(Xlat_0010057, locale);
	mnuTblVViewAudits.translateCaption(Xlat_0010058, locale);
	//txtFilterBox.translateBubbleHelp(Xlat_0024456, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="zTblDataResort" id="45608b5d-1936-4361-bc4e-1cc870718d5b">
        <updating/>
        <source>zTblDataResort() updating;

vars
	idx,
	startRow,
	endRow,
	sortColNo	: Integer;
	sortColName	: String;
	descending	: Boolean;
	obj			: Object;
begin

	
	sortColNo := tblData.column;
	
	if sortColNo &lt;= 0
	or sortColNo &gt; tblData.columns then
		return;
	endif;
	
	if self.tblData.allTblDataColPropertyNames.size &gt;= sortColNo then	

		sortColName := tblData.allTblDataColPropertyNames[sortColNo];
	endif;

	if sortColName = null then
		app.msgBox(app.getErrorString(Not_Able_To_Sort_By_Column), app.getErrorString(Info), MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	endif;
	
	self.tblData.resortTableByColumn(sortColNo);

	startRow := self.tblData.fixedRows + 1;
	endRow	:= self.tblData.rows;
	foreach idx in startRow to endRow do
		if (idx mod 2 = 0) then
			self.tblData.accessRow(idx).backColor := self.colorRow1;
		else
			self.tblData.accessRow(idx).backColor := self.colorRow2;
		endif;
	endforeach;

end;
</source>
    </JadeMethod>
</GUIClass>
