    <JadeMethod name="addCriteriaLine" id="57dc0671-145a-46ce-8a0b-f045d8627cbd">
        <updating/>
        <source>addCriteriaLine() : Boolean protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Dec 2022 navtnr20	TFS CR 55301 Task 55553: UI - New Selector Dialog
*/
vars
	idx 						: Integer;
	criteriaLine				: CM_SelectorCriteriaLine;
	tblSheet					: JadeTableSheet;
begin

	self.queryLineChanged := false;
	criteriaLine := self.setPropertyValueAndOperator(null);
	
	if criteriaLine = null then//creation was not sucessful
		return false;
	endif;
	
	criteriaLine.setMyCriteriaLineHolder(self.myCriteriaLineHolder);
	
	idx := self.tblCriteria.addItemObject(criteriaLine, criteriaLine.getDescriptionString);
	self.tblCriteria.accessRow(idx).backColor := criteriaLine.getPerformanceColour;
	
	return true;
	
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="addResultsRow" id="7e2cb831-48fa-4d34-ac63-941f8c2991b3">
        <source>addResultsRow(_obj : Object) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Dec 2022 navtnr20	TFS CR 55301 Task 55553: UI - New Selector Dialog
*/
vars
	propDict		: CM_QueryPropertyDict;
	queryProp		: CM_QueryProperty;
	attrName,
	propValStr,
	rowStr			: String;
	propArray		: StringArray;
	propVal			: Any;
	idx				: Integer;
	oper 			: CM_QueryOperator;
	propName		: String;							
	pos, revPos		: Integer;							
	measureStr		: String;							
	measure,											
	default			: CM_MeasurementType;				



	
begin
	if self.myQDef = null then
		return;
	endif;
	
	propDict := self.myQDef.allQueryProperties;
	propArray := self.allVisibleColumns;
	if propArray.size = 0 then	//Par 16731. When choosing a Query Definition (cmbSelectorMode), a set of columns can be null fro some definitions (Log Docket etc.)
		app.raiseCMException( ERR_NoColumnsInColumnOrganizer, null, self );
		return;
	endif;
	
	//foreach attrName in propArray do
	foreach attrName in propArray discreteLock do
		measureStr := null;										
		measure := null;										
		if attrName.isMeasurementType then						
			pos := attrName.pos("_", 1);						
			revPos := attrName.reversePos("_");					
			measureStr := attrName[revPos+1:end];				
			measure := app.myRoot.allMeasurementTypesByShortName[measureStr];	
			propName := attrName[pos+1:revPos-pos-1];			
		else													
			propName := attrName;								
		endif;										
		queryProp := propDict[propName];						
		if queryProp = null then
			continue;   //PAR23233 - 26/03/2010 cnwsh3 This needs to be the same as the code in self.displayResultColumn otherwise the results get out of sync with the labels.
			//propValStr := 'Could not retreive ' &amp; attrName;
		elseif (CM_QStringLookupProperty.hasInstance(queryProp)) then//no need to translate
			propValStr := _obj.getPropertyValue(queryProp.propertyName).String;
		else 		
			propVal := queryProp.getValueForObject(_obj,null);
			if propVal = null 
			and (not queryProp.displayNull) then
				propValStr := null;
			else
				if queryProp.propertyName = CM_Invoice::getInvoiceNote.name then 	
					propValStr := propVal.String.formatWithEllipsis(1, 100, true);			
				else
					if propVal.isKindOf(TimeStamp) then										
						propVal := propVal.TimeStamp.systemToLocalTimeUsingObject(_obj);	
					endif;																	
					propValStr := queryProp.translateToDisplayValue(propVal);
				endif;
				// For measurement types, propValStr is now in whatever unit the system default is.	
				// We now need to convert that to whatever unit we're displaying here				
				if measure &lt;&gt; null then																
					if CM_Object.hasInstance(_obj) then														
						propValStr := _obj.CM_Object.getRawMeasurementValue(propName).String;				
						propValStr := app.convertMeasurementForDisplay(measureStr, propValStr.Decimal);		
					else																				
						propValStr := propVal.String;	
						default := app.getDefaultMeasurementForType(measure.measurementType);	
						propValStr := app.convertMeasurementFromTo(default.shortName, measureStr, propValStr.Decimal).String;	
						propValStr := measure.removeDecimalZeros(propValStr);					
					endif;																										
				endif;																				
			endif;
		endif;
		
		rowStr := rowStr &amp; propValStr &amp; Tab;
	endforeach;
	
	self.tblResults.accessRow(self.tblResults.addItem(rowStr)).itemObject := _obj;
	self.beginNotification(_obj, Object_Delete_Event, Response_Continuous, null);
	
end;
</source>
        <access>protected</access>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="btnAdd_click" id="9cf48487-9f76-4e27-a898-54eca3c7937d">
        <controlMethod name="CMUI_Button::click"/>
