    <JadeMethod name="getRoRoAreaMidPoint" id="8ba0590d-6b8d-4812-ac07-ac851e64f5aa">
        <source>getRoRoAreaMidPoint(_ta : CM_RoRoLaneArea; _x1, _y1 : Real; _cx, _cy : Real output) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 December 2009	cnwjk3	ccms 1018

*/

vars
	x2, y2			: Real;
	borderWidth		: Integer;
begin
	borderWidth 	:= CM_RoRoLaneArea.SAT_RORO_BORDER_WIDTH;
	x2 := _x1 + _ta.getSatDrawWidthInPixels(self.scaleFactor) ;//+ (borderWidth/2);
	y2 := _y1 + _ta.getSatDrawHeightInPixels(self.scaleFactor);// + (borderWidth/2);
	_cx := _x1 + (x2 - _x1)/2 ;
	_cy := _y1 + (y2 - _y1)/2 ;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ta" type="CM_RoRoLaneArea"/>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_cx" type="Real" usage="output"/>
        <Parameter name="_cy" type="Real" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getRoRoAreaRawMidPoint" id="06a60101-7f9a-41ce-81b8-d97cdbea5234">
        <source>getRoRoAreaRawMidPoint(_ta : CM_RoRoLaneArea; _x1, _y1 : Real; _cx, _cy : Real output) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 December 2009	cnwjk3	ccms 1018

*/

vars
	x2, y2			: Real;
	borderWidth		: Integer;
begin
	borderWidth 	:= CM_RoRoLaneArea.SAT_RORO_BORDER_WIDTH;
	x2 := _x1 + _ta.getSatRawDrawWidthInPixels(self.scaleFactor) + (borderWidth/2);
	y2 := _y1 + _ta.getSatRawDrawHeightInPixels(self.scaleFactor) + (borderWidth/2);
	_cx := _x1 + (x2 - _x1)/2 ;
	_cy := _y1 + (y2 - _y1)/2 ;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ta" type="CM_RoRoLaneArea"/>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_cx" type="Real" usage="output"/>
        <Parameter name="_cy" type="Real" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getRowColumnPointsALL" id="12b20fdf-1f51-4d5d-a0c3-0bdb3b769ac8">
        <source>getRowColumnPointsALL(_rows, _cols : PointArray input);
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	rowIdx,
	colIdx,rowNum,colNum	: Integer;
	theRowHeight,
	theColWidth,
	yPos1, yPos2,
	xPos1, xPos2	: Integer;	
	tmpGA	: CM_GridArea;
	tmpTA : CM_TerminalArea;
	tmpPoint : Point;
	ydc : YRD_ContainerDrawingController;
	aGCol : CM_GridColumn;
begin
	_rows.clear;
	_cols.clear;
	// these point appear to only be used for drag drop - this does not happen on satellite view 
	// returning because of the overhead of iterating through all lc again
	if self.isForSatelliteView then
		return;
	endif;
	ydc := self;

	if ydc.allTerminalAreas.isEmpty() then
		return;
	endif;
	xPos2 := 27;//self.LABELGAP;
	if self.isForSatelliteView then

		xPos2 := self.Margin;
	endif;
	theColWidth	 := self.getColumnWidthForScale().Integer;
	theRowHeight := self.getRowHeightForScale().Integer;
	
	foreach tmpTA in ydc.allTerminalAreas do
		if tmpTA.isKindOf(CM_BlockStack) or tmpTA.isKindOf(CM_IrregularBlockArea) then
		else
			tmpGA := tmpTA.CM_GridArea;
			colNum := tmpGA.allGridColumns.size;
			rowNum := tmpGA.allGridRows.size;
		
			// ##### COLUMNS
			foreach aGCol in tmpGA.allGridColumns do
				xPos1 :=  xPos2;
				if aGCol.hasGap then
					xPos2 := xPos1 + (self.getGapDrawWidth(aGCol) + self.columnSpacing).Integer;
				else
					xPos2 := xPos1 + theColWidth + self.columnSpacing;
				endif;
				
				if xPos1 &lt;= 0 then
					xPos1 := 1;
				endif;
				
				tmpPoint.set(xPos1,xPos2);
				_cols.add(tmpPoint);
			endforeach;
			// allow for the gap, on screen between multiple areas.
			
			xPos1 :=  xPos2;
			xPos2 := xPos1 + 28;
			tmpPoint.set(xPos1,xPos2);
			_cols.add(tmpPoint);
		
			yPos2 := self.LABELGAP;
			foreach rowIdx in 1 to rowNum do
				yPos1 :=  yPos2;
				yPos2 := yPos1 + theRowHeight + 3; //RowSpacing;
		
				if yPos1 &lt;= 0 then
					yPos1 := 1;
				endif;
		
				tmpPoint.set(yPos1,yPos2);
				_rows.add(tmpPoint);
			endforeach;
		endif;
	endforeach;
end;</source>
        <Parameter name="_rows" type="PointArray" usage="input"/>
        <Parameter name="_cols" type="PointArray" usage="input"/>
    </JadeMethod>
