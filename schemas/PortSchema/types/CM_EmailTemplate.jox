    <JadeMethod name="validate" id="a060829b-c85d-434d-a46c-7cf2cb601e35">
        <source>validate();
// -------------------------------------------
// Created 25 March 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	if self.allToAddresses.isEmpty and self.toAddresses = null then
		app.raiseCMException(Invalid_email_address_destina, null, null);
	endif;
	
	app.validateEmailAddress(self.toAddresses);
	app.validateEmailAddress(self.ccAddresses);
	app.validateEmailAddress(self.bccAddresses);
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForInvoicePackage" id="1e24136b-bd2f-4995-a173-3cf665d47d8a">
        <source>validateForInvoicePackage(_package : CM_PackageInvoice);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 February 2024	navra1	Initial creation for CR 61910/Task 62303 - EUP | API Create default package to run on invoice

*/

vars

begin
	if self.allToAddresses.isEmpty and self.toAddresses = null and not _package.sendToDebtorEmail then
		app.raiseCMException(Invalid_email_address_destina, null, null);
	endif;
	
	app.validateEmailAddress(self.toAddresses);
	app.validateEmailAddress(self.ccAddresses);
	app.validateEmailAddress(self.bccAddresses);
epilog

end;</source>
        <Parameter name="_package" type="CM_PackageInvoice"/>
    </JadeMethod>
</Class>
