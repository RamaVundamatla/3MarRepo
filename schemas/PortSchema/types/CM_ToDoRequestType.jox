<Class name="CM_ToDoRequestType" id="411043dd-d109-4ac7-8cd2-d2fa64610cf9">
    <superclass name="CM_Code"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="terminal"/>
    <ExplicitInverseRef name="allToDoRequests" id="3fe114dd-7f11-44a1-9d27-4be7e12435b0">
        <kind>parent</kind>
        <transientToPersistentAllowed/>
        <updateMode>automatic</updateMode>
        <type name="CM_ToDoRequestSet"/>
        <access>readonly</access>
        <text>
This is here to maintain an inverse to any todo requests currently
awaiting processing.</text>
        <Inverse name="CM_ToDoRequest::myToDoRequestType"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="allToDoTaskDescs" id="b81786e8-7dcc-4590-ba40-702000eae2c9">
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <type name="CM_ToDoTaskDescArray"/>
        <access>readonly</access>
        <Inverse name="CM_ToDoTaskDesc::allToDoRequestTypes"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="allWOToDoRequests" id="bafdc14a-2560-4e90-98ba-a07cb976e114">
        <kind>parent</kind>
        <transientToPersistentAllowed/>
        <updateMode>automatic</updateMode>
        <type name="CM_RequestSet"/>
        <access>readonly</access>
        <Inverse name="CM_WOToDoRequest::myToDoRequestType"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="myRoot" id="ae089453-4006-4077-a89b-0b4c207e2bff">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_Root"/>
        <access>readonly</access>
        <Inverse name="CM_Root::allToDoRequestTypes"/>
    </ExplicitInverseRef>
    <JadeMethod name="create" id="fbae7f4d-c8b6-4881-8889-669f9b12c263">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     08 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.isCodeGroupNOTRequired := true;

end;</source>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="c965fdf2-01dc-4efc-8eeb-40011e8e2374">
        <updating/>
        <source>setForCreate(pProxy: CM_ToDoRequestType) updating;
// ---------------------------------------------------------------------------
// Created:     08 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(pProxy);
	
	self.myRoot	:= pProxy.myRoot;

end;</source>
        <Parameter name="pProxy" type="CM_ToDoRequestType"/>
    </JadeMethod>
    <JadeMethod name="setForProxy" id="441d79f3-d646-4b8e-a30e-1f6f7aa14a7e">
        <updating/>
        <source>setForProxy(pCode, pDescription : String; _notAvailableForEntry:Boolean; _allToDoTaskDescs : CM_ToDoTaskDescArray; _root : CM_Root) updating;
// ---------------------------------------------------------------------------
// Created:     08 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.setSuperClassDetailsForProxy(pCode, pDescription, _notAvailableForEntry, null);
	
	_allToDoTaskDescs.copy(self.allToDoTaskDescs);
	
	self.myRoot := _root;

end;</source>
        <Parameter name="pCode" type="String"/>
        <Parameter name="pDescription" type="String"/>
        <Parameter name="_notAvailableForEntry" type="Boolean"/>
        <Parameter name="_allToDoTaskDescs" type="CM_ToDoTaskDescArray"/>
        <Parameter name="_root" type="CM_Root"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="bbf54edd-9e8b-4c09-bee2-e9d58e587b39">
        <updating/>
        <source>setForUpdate(pProxy: CM_ToDoRequestType) updating;
// ---------------------------------------------------------------------------
// Created:     08 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(pProxy);
	
	pProxy.allToDoTaskDescs.copy(self.allToDoTaskDescs);
	
end;</source>
        <Parameter name="pProxy" type="CM_ToDoRequestType"/>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="01b8d46a-2d71-4ea3-8d3a-ace37f81bcab">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:     08 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if (not self.allToDoRequests.isEmpty()) then
		app.raiseCMException2(ObjectStillHasEntries, 'Request type (' &amp; self.code &amp; ')', 'ToDo Requests', null, null);
	endif;
	
end;</source>
    </JadeMethod>
</Class>
