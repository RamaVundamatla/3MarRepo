    <JadeMethod name="setTblDataEntRows" id="024c2ac9-db98-4a23-a0bb-3cd06d088026">
        <updating/>
        <source>setTblDataEntRows(_defName : String)updating;
//--------------------------------------------------------------
//Created: 13 May 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	entTableDef : EntTableDef;
	entRow 		: EntTableRow;
begin
	entTableDef := app.myController.getEntTableDef(_defName);
	
	if entTableDef = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Def (' &amp; _defName &amp; ') not found');
		return;
	endif;

	
	self.allTblDataEntRows.clear();
	entTableDef.allEntTableRows.copy(self.allTblDataEntRows);
	

	if _defName = ETDef_NoNumberData then
		self.setupTable(self.tblNNData);
	elseif _defName = ETDef_LocationDataDocket then
//		self.setupTable(self.tblLocationDtls);
		self.tblLocationDock.setTblDataEntRowsFromDef(entTableDef);	
	elseif _defName = ETDef_LocationDataLogs then 
		self.tblLocationDtls.setTblDataEntRowsFromDef(entTableDef);
	endif;
		
end;</source>
        <Parameter name="_defName" type="String"/>
    </JadeMethod>
    <JadeMethod name="setTblHdrValues" id="4f55e7ec-07fc-49dc-838b-445463544487">
        <updating/>
        <source>setTblHdrValues(_header : CM_BOLOutHeader) updating;
//--------------------------------------------------------------
//Created: 04 November 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	str 		: String;
	tmpOperator : CM_Operator;
	tmpUser		: CM_User;
begin

	if _header = null then
		tblHeaderDtls.clearValues();
		self.mode := null;
		return;
	endif;

	tblHeaderDtls.setValueByName(ETRow_DocketNumber, _header.bolNumber);
	tblHeaderDtls.setValueByName(ETRow_Quantity, _header.allTrackedItemIDs.size);	
	tblHeaderDtls.setValueByName(ETRow_Operator, _header.operatorCode);
	tblHeaderDtls.setValueByName(ETRow_ScalerCode, _header.userCode);
		
	tmpOperator := app.myRoot.allOperators[_header.operatorCode];
//	self.myAssistant.comboBoxSupplier(cmbOperator, tmpOperator);
	self.cmbOperator.setObject(tmpOperator);
	tmpUser := app.myRoot.allUsers[_header.userCode];
//	self.myAssistant.comboBoxUser(cmbUser, tmpUser);	
	self.cmbUser.setObject(tmpUser);
	
	self.cmbOperator.lostFocus(self.cmbOperator);
	self.cmbUser.lostFocus(self.cmbUser);
					
end;</source>
        <Parameter name="_header" type="CM_BOLOutHeader"/>
    </JadeMethod>
    <JadeMethod name="setTblItemValues" id="de333d6b-8b83-44cc-99c1-19733ce7945e">
        <updating/>
        <source>setTblItemValues(_header : CM_BOLOutHeader) updating;
//--------------------------------------------------------------
//Created: 04 November 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	row,
	cnt		: Integer;
	str 	: String;
	table	: LOG_BulkTable;
	theSheet : JadeTableSheet;	
begin

	if _header = null then
		self.clearTblItems();
		self.mode := null;
		return;
	endif;
	table := self.tblItems01;

	foreach str in _header.allTrackedItemIDs do
		if cnt = 0 then
			table := self.tblItems01;
			theSheet := table.accessSheet(table.topSheet);
			row := 1;				
		elseif cnt = 12 then
			table := self.tblItems02;
			theSheet := table.accessSheet(table.topSheet);			
			row := 1;			
		elseif cnt = 24 then
			table := self.tblItems03;
			theSheet := table.accessSheet(table.topSheet);			
			row := 1;			
		elseif cnt = 36 then
			table := self.tblItems04;
			theSheet := table.accessSheet(table.topSheet);			
			row := 1;			
		elseif cnt = 48 then
			table := self.tblItems05;
			theSheet := table.accessSheet(table.topSheet);			
			row := 1;			
		elseif cnt = 60 then
			table := self.tblItems06;
			theSheet := table.accessSheet(table.topSheet);			
			row := 1;			
		elseif cnt = 72 then
			self.doNextPrevSheetTblItems(true);
			table := self.tblItems01;
			theSheet := table.accessSheet(table.topSheet);			
			row := 1;
			cnt := 0;																		
		endif;
		theSheet.accessCell(row, 1).text := str;
		row := row + 1;
		cnt := cnt + 1;
	endforeach;
	self.calculateItems();		
end;</source>
        <Parameter name="_header" type="CM_BOLOutHeader"/>
    </JadeMethod>
    <JadeMethod name="setXMLStrForTblColumns" id="3aeee264-fe81-4f59-ba2e-7b01c3d7f4b1">
        <updating/>
        <source>setXMLStrForTblColumns(_theTable: CM_DataTable input) updating, protected;
// ---------------------------------------------------------------------------
// Created:     14 April 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	tagPrefix,
	tagSuffix,
	tmpStr,	
	defName,
	replaceStr,
	tmpDefStr,
	tmpXMLStr 	: String;
	startPos	: Integer;
begin

	tmpXMLStr := _theTable.getXmlStrForColumns(true);
	
	if self.xmlStrTblLocationDtls = null then
		self.xmlStrTblLocationDtls := tmpXMLStr;

		return;
	endif;
	
	defName := _theTable.myEntTableDef.name;
	tagPrefix := J_key_LessThan.Character &amp; _theTable.XMLTag_EntTblDef &amp; defName &amp; J_key_GreaterThan.Character;
	tagSuffix := global.formatAsXMLSuffix(_theTable.XMLTag_EntTblDef &amp; defName).trimBlanks;

	startPos := 1;
	tmpDefStr := self.xmlStrTblLocationDtls.cnEcGetNextTagValueOfName(_theTable.XMLTag_EntTblDef &amp; defName, startPos).trimBlanks;	

	if tmpDefStr &lt;&gt; null then
		startPos := 1;
		tmpStr := tmpXMLStr.cnEcGetNextTagValueOfName(_theTable.XMLTag_EntTblDef &amp; defName, startPos).trimBlanks;
		replaceStr := tagPrefix &amp; tmpStr &amp; tagSuffix;
		startPos := 1;
		tmpDefStr := tagPrefix &amp; self.xmlStrTblLocationDtls.cnEcGetNextTagValueOfName(_theTable.XMLTag_EntTblDef &amp; defName, startPos).trimBlanks &amp; tagSuffix;
		self.xmlStrTblLocationDtls := self.xmlStrTblLocationDtls.replaceString(tmpDefStr, replaceStr);
	else
		startPos := 1;
		tmpDefStr := tagPrefix &amp; tmpXMLStr.cnEcGetNextTagValueOfName(_theTable.XMLTag_EntTblDef &amp; defName, startPos).trimBlanks &amp; tagSuffix;
		startPos := 1;
		self.xmlStrTblLocationDtls.scanWhile('&lt;'&amp; _theTable.XMLTag_Table &amp; _theTable.name &amp; '&gt;', startPos);
		self.xmlStrTblLocationDtls := self.xmlStrTblLocationDtls.cnEcInsertInto(tmpDefStr, startPos, startPos);
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_theTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupDynaDict" id="caaa24ee-e623-4ae2-9859-54ea3765b7c9">
        <updating/>
        <source>setupDynaDict(_clearFirst : Boolean)updating;
//--------------------------------------------------------------
//Created: 12 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if _clearFirst then
		self.myDynaDict.clear();
		self.myDynaDict.clearKeys();
		self.allTIArray.clear();
	endif;

	self.myDynaDict.setMembership(self.myDataClass);

	if self.myDataClass = CM_TrackedItem then
		self.myDynaDict.addMemberKey(CM_TrackedItem::id.name, false, true);
	elseif self.myDataClass = CM_BOL then
		self.myDynaDict.addMemberKey(CM_BOL::number.name, false, true);
	elseif self.myDataClass = CM_SOHLocation then
		self.myDynaDict.addMemberKey(CM_SOHLocation::myProduct.name, false, true);
	else
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, 
							  'Data class unknown.', null, null);
		return;			
	endif;
		
	self.myDynaDict.endKeys(true);
	
	if self.filterLogLocation &lt;&gt; null or self.filterVoyage &lt;&gt; null then
		self.copyCollectionToDynaDict();	
	endif;

end;</source>
        <Parameter name="_clearFirst" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="ea689fa7-68a1-4340-ba01-cb8a106f3579">
        <updating/>
        <source>setupForm() updating;
//--------------------------------------------------------------
//Created: 10 June 2002 By: cnwgd1
// 
//--------------------------------------------------------------
vars


begin

	inheritMethod();
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.showToolbar := true;
	
	self.beginClassNotification(CM_Voyage, false, self.myTerminal.getTerminalEvent(Voyage_Create_Event), Response_Continuous, null);
	self.beginClassNotification(CM_Voyage, false, self.myTerminal.getTerminalEvent(Voyage_Update_Event), Response_Continuous, null);
	self.beginClassNotification(CM_Voyage, false, self.myTerminal.getTerminalEvent(Voyage_Delete_Event), Response_Continuous, null);
	self.beginClassNotification(Global, false, self.myTerminal.getTerminalEvent(VoyageOperator_Create_Event), Response_Continuous, null);
	self.beginClassNotification(Global, false, self.myTerminal.getTerminalEvent(VoyageOperator_Update_Event), Response_Continuous, null);
	self.beginClassNotification(Global, false, self.myTerminal.getTerminalEvent(VoyageOperator_Delete_Event), Response_Continuous, null);
	self.beginClassNotification(Global, false, self.myTerminal.getTerminalEvent(LogLot_Create_Event), Response_Continuous, null);
	//self.beginClassNotification(Global, false, self.myTerminal.getTerminalEvent(LogLot_Update_Event), Response_Continuous, null);
	self.beginClassNotification(Global, false, self.myTerminal.getTerminalEvent(LogLot_Delete_Event), Response_Continuous, null);
	self.beginClassNotification(Global, false, self.myTerminal.getTerminalEvent(StockOrderAlloc_Create_Event), Response_Continuous, null);
	self.beginClassNotification(Global, false, self.myTerminal.getTerminalEvent(StockOrderAlloc_Update_Event), Response_Continuous, null);
	self.beginClassNotification(Global, false, self.myTerminal.getTerminalEvent(StockOrderAlloc_Delete_Event), Response_Continuous, null);			

	self.initTableHeader();
	self.initTablesItems();
	self.initTblNNData();
	self.initTblOnBoard();
	self.initTblsLocation();
			
	self.optLoadOutItem.value := true;
	self.optLocnDtlsLocn.value := true;	
	
	self.lblPage.caption := 'Page 1 of 1';
	
	self.lblIdFilter.visible := false;
	self.txtIdFilter.visible := false;
	self.lblRequired.visible := false;
	self.txtRequired.visible := false;
	self.lblSelected.visible := false;
	self.txtSelected.visible := false;
	self.tblLocationDtls.visible := false;
	self.tblLocationDock.visible := false;
	
	self.fldMain.useSheetBackColors := true;
	self.fldMain.setDefaultSheetBackColors();
	self.fldMain.initSheetBackColors();

	self.transportMode := TI_TRANSMODE_SHIP;	//Defaults to ship
	
	self.myDataClass := CM_SOHLocation;
	self.setupDynaDict(false);
//	self.doResize();
	self.mnuContextMenu.visible := false; //par14926 cnwrs1 Mar 2008
	

	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnSaveBase.enabled:= false;
		self.btnNextItem.enabled:= false;
		self.btnNextT.enabled:= false;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="setupShtItemDetails" id="4f7ec62c-09a6-495a-98bc-90ecf4e9c547">
        <source>setupShtItemDetails();
//--------------------------------------------------------------
//Created: 11 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	required : Integer;
begin
	required := self.tblHeaderDtls.getValueByName(ETRow_Quantity).Integer;
	self.tbRequired.text := required.String;
	self.tbRemaining.text := self.calculateRemaining().String;
