    <JadeMethod name="doInspectCellObject" id="e30c1e46-a103-418a-a160-3751e52f7da3">
        <updating/>
        <source>doInspectCellObject() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 January 2010	cnwas3	Initial creation

*/

vars
	selectedCellsColl	: ObjectSet;	
begin
	app.mousePointer := Window.MousePointer_HourGlass;
	
	create selectedCellsColl transient;
	self.tblMain.getSelectedCellObjects(selectedCellsColl);
	
	if selectedCellsColl = null or selectedCellsColl.isEmpty() then
		return ;
	endif;

	selectedCellsColl.first.inspect;

epilog
	
	delete selectedCellsColl;
	app.mousePointer := Window.MousePointer_Default;	
end;</source>
