    <JadeMethod name="validate" id="eb04b075-a2e5-4b3e-9a06-afdb21fad3dd">
        <source>validate(_webPatch: Boolean) : Boolean;
// ----------------------------------------------------------------------------
//	Created by cnwvu1	09 April 2008
// ----------------------------------------------------------------------------

vars
	scm : SchemaInPatch;
	web: WebInPatch;
	
	//cnwmc5 - 14 Jan 2014 - PAR 32864
	rpt		: ReportInPatch;
	rptView	: ReportViewInPatch;
begin

	if _webPatch then
		if self.allWebsInPatch.size = 0 then
			app.msgBox('There are no web files in the patch ' &amp; self.parNo, self.class.name &amp;'.'&amp; method.name, MsgBox_OK_Only + MsgBox_Information_Icon);
			return false;
		endif;
	
		app.writeLogMessage(' ');
		app.writeLogMessage(' Validation:');
		
		foreach web in self.allWebsInPatch do
			if not web.validate() then
				return false;
			endif;
		endforeach;
	else
		//cnwmc5 - 15 Jan 2014 - PAR 32864		
		if self.allSchemasInPatch.size = 0 and self.allReportsInPatch.size = 0 and self.allReportViewsInPatch.size = 0 then
			app.msgBox('There are no schemas, reports, or report views in the patch ' &amp; self.parNo, self.class.name &amp;'.'&amp; method.name, MsgBox_OK_Only + MsgBox_Information_Icon);
			return false;
		endif;
	
		app.writeLogMessage(' ');
		app.writeLogMessage(' Validation:');
		
		foreach scm in self.allSchemasInPatch do
			if not scm.validate() then
				return false;
			endif;
		endforeach;
		
		//cnwmc5 - 14 Jan 2014 - PAR 32864
		foreach rpt in self.allReportsInPatch do
			if not rpt.validate() then
				return false;
			endif;
		endforeach;
		
		//cnwmc5 - 14 Jan 2014 - PAR 32864
		foreach rptView in self.allReportViewsInPatch do
			if not rptView.validate() then
				return false;
			endif;
		endforeach;
	endif;
	
	return true;
	
end;
</source>
        <Parameter name="_webPatch" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="writeToFileLiveAppUpgrade" id="6fbb0182-4276-4157-8f39-833b60bdf423">
        <source>writeToFileLiveAppUpgrade()protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 July 2017	jlgma1	 TFS#4847:JMT - Change to HotFixesCommonSchema PatchCreateApp

*/

vars
		file	: File;
begin
	create file transient;	
	file.mode := File.Mode_Output; 
	file.fileName:= self.getFileLiveAppUpgrade();
	file.open;
	
	app.writeLogMessage(' Creating live_app_upgrade.bat file:');
	
	file.writeLine('%env_binpath%\jade.exe path=%env_systempath% ini=%env_inifile% server=singleuser schema=PortSchema app=JMTRelease');
	// TFS 46543 jlgzm1 25/09/2019
	file.writeLine("if ERRORLEVEL 0 ( echo CompletedOK &gt; %env_logpath%\app_upgrade.log ) else ( echo UpgradeError &gt; %env_logpath%\app_upgrade.log )");

	file.commit;
	file.close;
	app.writeLogMessage(' Created ' &amp; file.fileName);
	
epilog
	delete file;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="writeToFileReadme" id="da89bd38-5c4a-4830-bf41-35d512c39fd7">
        <source>writeToFileReadme( _readmeParTopic, _readmeParDescription, _readmeCloseDetail, _readmeAreasAffected : String ) protected;
// created by cnwvu1 on 11/03/2007
vars
	file	: File;
//	s	: String;
	
begin

	create file transient;	
	file.mode := File.Mode_Output; // 3/3/16  cnwns1 PAR 36286 unicode version
	file.fileName:= self.getFileReadmeName();
	file.open;
	
	app.writeLogMessage(' Creating readme file:');
	file.writeLine('');
	if self.singleUser and not self.isWebPatch then
		file.writeLine( RootHotFixes.TXT_SINGLEUSER_NOTE1 );
		file.writeLine('');
	endif;
	file.writeLine( RootHotFixes.README_STR_BEGIN );
	file.writeLine('');
	//f.writeString( Readme_PAR &amp;'-'&amp; self.parNo &amp;' : ' &amp; _readmeParTopic &amp; CrLf);
	file.writeString( _readmeParTopic &amp; CrLf);
	file.writeString( /*'          ' &amp;*/ Readme_PAR_DESCRIPTION &amp; _readmeParDescription &amp; CrLf);	
	file.writeString( /*'          ' &amp;*/ Readme_CLOSE_DETAIL &amp; _readmeCloseDetail &amp; CrLf);	
	file.writeString( /*'          ' &amp;*/ Readme_AREAS_AFFECTED &amp; _readmeAreasAffected &amp; CrLf);	

	file.commit;
	file.close;
	app.writeLogMessage(' Created ' &amp; file.fileName);
	
epilog
	delete file;
	
end;
</source>
        <access>protected</access>
        <Parameter name="_readmeParTopic" type="String"/>
        <Parameter name="_readmeParDescription" type="String"/>
        <Parameter name="_readmeCloseDetail" type="String"/>
        <Parameter name="_readmeAreasAffected" type="String"/>
    </JadeMethod>
</Class>
