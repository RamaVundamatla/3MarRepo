    <JadeMethod name="getCargoOperationsTimesString" id="6bc6c7cc-f8f1-408f-a25f-17f09042c38f">
        <source>getCargoOperationsTimesString():String;
/*

Date		Who		Reason
22 September 2011	cnwcs5	Initial creation - CCMS RIO 2041 / par 28220 Start/Stop Times
*/
vars
	interval	:CM_TimeStampInterval;
	str			:String;
begin
	foreach interval in self.allCargoOperationsIntervals do
		if str = null then
			str := interval.getName;
		else
			str := str &amp; ', ' &amp; interval.getName;
		endif;
	endforeach;
	
	return str;
epilog

end;</source>
