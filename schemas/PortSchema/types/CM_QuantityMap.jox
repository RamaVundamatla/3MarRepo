        <source>copyFromTrans(_map : CM_QuantityMap; _parent : CM_FinancialObject) updating;
// 32311 set up self from the parameter plus the new transaction type, copy all of the parameter map children under self.
// 16/02/2017 cnwma1  TFS #2901:ADP - Variable storage charges based on weight and time

vars
	qrm			: CM_QuantityRangeMap;
	newChild	: CM_QuantityRangeMap;
	subQrm      : CM_QuantityRangeMap;
	newSubChild : CM_QuantityRangeMap;
	newQuantitySubMap : CM_QuantityMap;
begin
	if _parent &lt;&gt; null then
		self.myParentFinancialObject := _parent;
	else
		self.myParentFinancialObject := _map.myParentFinancialObject;
	endif;
	self.chargeZero := _map.chargeZero;
	self.mappingType := _map.mappingType;
	self.myCalculationType := _map.myCalculationType;

	foreach qrm in _map.allQuantityRanges do
		create newChild transient;
		newChild.copyFrom(qrm, self);
	
		if qrm.myChildQuantityMap &lt;&gt; null then   //16/02/2017 cnwma1 TFS #2901
			 create newQuantitySubMap transient;
			 newQuantitySubMap.copyFrom(qrm.myChildQuantityMap, newChild);
		endif;
	endforeach;

end;
</source>
        <Parameter name="_map" type="CM_QuantityMap"/>
        <Parameter name="_parent" type="CM_FinancialObject"/>
    </JadeMethod>
