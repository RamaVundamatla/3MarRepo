    <JadeMethod name="doDisplayBGPDetails" id="cdfdceef-da5f-4514-adc9-94c62c40ac19">
        <source>doDisplayBGPDetails();
//----------------------------------------------------------------
//	Created:	13 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	infoArray	: StringArray;
	str			: String;
begin
	create infoArray transient;
	
	self.getBGPDetails(infoArray);
	
	foreach str in infoArray reversed do
		self.writeTxt(str);
		//txtMonitorLog.text := str &amp; CrLf &amp; txtMonitorLog.text[1:16384];
	endforeach;

epilog
	delete infoArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="b830656f-2ef0-47f5-813a-4434548503a8">
        <updating/>
        <source>doResize() updating;
//----------------------------------------------------------------
//	Created:	13 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	inheritMethod();
	self.txtMonitorLog.move(0,self.frmToolbar.height, self.width-8, self.height - self.frmToolbar.height-27);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doStopStartClick" id="f518f33e-6168-4627-9b9b-5cef6c43fdde">
        <updating/>
        <source>doStopStartClick() updating;
//----------------------------------------------------------------
//	Created:	16 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	if self.monitoringPaused then
		//resume monitoring
		//beginClassNotification(CM_TempReading, false, self.myTerminal.getTerminalEvent(EVENT_TEMP_CREATE_REFCON), Response_Continuous	, 0);
		beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(EVENT_TEMP_CREATE_REFCON), Response_Continuous	, 0);
		self.btnStopStartMon.caption := "Pause Log";
		self.btnStopStartMon.bubbleHelp := "Pause Log";
		self.monitoringPaused := false;
		self.writeTxt("Monitoring Resumed");
	else
		//end monitoring
		//self.endClassNotification(CM_TempReading, false, self.myTerminal.getTerminalEvent(EVENT_TEMP_CREATE_REFCON));
		self.endNotification(self.myTerminal, self.myTerminal.getTerminalEvent(EVENT_TEMP_CREATE_REFCON));
		self.btnStopStartMon.caption := "Resume Log";
		self.btnStopStartMon.bubbleHelp := "Resume Log";
		self.monitoringPaused := true;
		self.writeTxt("Monitoring Paused");
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getBGPDetails" id="989b40e3-03b6-4eca-9589-c68898e66a88">
        <source>getBGPDetails(_infoArray: StringArray input);
//----------------------------------------------------------------
//	Created:	13 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	controller	: Object;
	objectArray	: ObjectArray;
	answer		: Integer;
begin

	create objectArray transient;
	BGP_Controller.allInstances(objectArray, 100, true);
	foreach controller in objectArray do
		if controller.isKindOf(BGP_TCPClient) and controller.BGP_TCPClient.workerClass.toUpper = "REFCON" then
				_infoArray.add("Manager Name        :" &amp; Tab &amp; controller.BGP_TCPClient.myBGPManager.name);
				_infoArray.add("Background App Type :" &amp; Tab &amp; controller.BGP_TCPClient.name &amp; "(" &amp; controller.BGP_TCPClient.workerClass &amp; ")");
			
			if controller.BGP_TCPClient.isRunning() then
				_infoArray.add("Status              :" &amp; Tab &amp; "Started.");
				_infoArray.add("Start Date          :" &amp; Tab &amp; controller.BGP_TCPClient.dateTimeLastStarted.String);
				_infoArray.add("Connection Details  :" &amp; Tab &amp; controller.BGP_TCPClient.serverName&amp;":"&amp;controller.BGP_TCPClient.tcpIpPort.String);
				_infoArray.add("Running on          :" &amp; Tab &amp; controller.BGP_TCPClient.machineName);
			else
				_infoArray.add("Status              :" &amp; Tab &amp; "Stopped.");
				_infoArray.add("                    :" &amp; Tab &amp; "(Start from Background Processing)");
				_infoArray.add("Connection Details  :" &amp; Tab &amp; controller.BGP_TCPClient.serverName&amp;":"&amp;controller.BGP_TCPClient.tcpIpPort.String);
			endif;
				_infoArray.add("============================================");		//separator				  	
		endif;
		
	endforeach;
	
	if _infoArray.size = 0 then
				_infoArray.add("Background App Info   :" &amp; Tab &amp; "");
				_infoArray.add("Background App Status :" &amp; Tab &amp; "No Refcon background apps found");
	endif;
		
epilog
	delete objectArray;
end;</source>
        <Parameter name="_infoArray" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="handleNotification" id="df3c9772-8bfe-40f1-a990-1974aedb406f">
        <updating/>
        <source>handleNotification(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
//----------------------------------------------------------------
//	Created:	13 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------

vars
	now			: TimeStamp;
	reefer		: CM_Container;
	tempRead	: CM_TempReading;
	event		: Integer;
begin
//global.writeForUser('CNWJC2', false, class.name &amp; " " &amp; method.name &amp; "");
	if self.monitoringPaused then
		return;
	endif;
	event := self.myTerminal.getEventFromTerminalEvent(eventType);
	
	if event = EVENT_TEMP_CREATE_REFCON then
	
		tempRead := userInfo.CM_TempReading;
		if tempRead.myRefConRawData &lt;&gt; null then
	//		self.txtMonitorLog.text := tempRead.getLogDisplay &amp; CrLf &amp; self.txtMonitorLog.text[1:2048];
			self.writeTxt(tempRead.getLogDisplay);
			//if self.frmActivity.backColor = LightGreen then
//				self.frmActivity.backColor := LightRed;
//			else
//				self.frmActivity.backColor := LightGreen;
//			endif;
		endif;		
	endif;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="load" id="7353633d-1633-49c3-b468-ffe8f02899be">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
//----------------------------------------------------------------
//	Created:	16 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	inheritMethod();
	self.doDisplayBGPDetails();
	
	beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(EVENT_TEMP_CREATE_REFCON), Response_Continuous	, 0);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="3992341d-fa60-44ed-a369-93364e7bc029">
        <updating/>
        <source>setupForm() updating;
//----------------------------------------------------------------
//	Created:	13 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	inheritMethod();

	self.setNavigatorHeading(self.caption); 

	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.showToolbar := true;
	self.frmToolbar.priorityRight := true;

	self.monitoringPaused := false;
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnStopStartMon.enabled:= false;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="e3401a9b-0645-4884-88ae-b91c573ce575">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;
//----------------------------------------------------------------
//	Created:	13 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
//global.writeForUser('CNWJC2', false, class.name &amp; " " &amp; method.name &amp; "");
	self.handleNotification(eventType, theObject, eventTag, null);

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="d600c57f-99e9-4978-8b26-33556f9788c9">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0008029, locale);
	btnStopStartMon.translateCaption(Xlat_0000740, locale);
end;</source>
    </JadeMethod>
