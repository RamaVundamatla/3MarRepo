    <JadeMethod name="copyToRealWSObject" id="075fe558-3ff7-4d42-bbac-8cc169805bb8">
        <source>copyToRealWSObject(_realRequest: KRF_CheckInIMEX input;
				   _createdObjects : ObjectSet input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Feb 2019	jlgsl4	TFS 40360 - KiwiRail EDI message

*/

vars

begin
	inheritMethod(_realRequest, _createdObjects);
	
	_realRequest.customsClearanceNumber := self.customsClearanceNumber;
	_realRequest.cutoffTimestamp := self.cutoffTimestamp;
	_realRequest.exportEntryNumber := self.exportEntryNumber;
	_realRequest.overseasDestination := self.overseasDestination;
	_realRequest.shipName := self.shipName;
	_realRequest.shipper := self.shipper;
	_realRequest.shipperReference := self.shipperReference;
	_realRequest.voyageNumber := self.voyageNumber;

epilog

end;</source>
        <Parameter name="_realRequest" type="KRF_CheckInIMEX" usage="input"/>
        <Parameter name="_createdObjects" type="ObjectSet" usage="input"/>
