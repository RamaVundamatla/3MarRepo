    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="46ba1806-4363-440c-8866-34ce386204a8">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Jul 2022	navhl20	ChangeRequest 53697: EUP - VBS MTN - [1] - VBS Slot Types

*/

vars

	pxyRelByTypeCrit : CM_VBSSlotTypeCriteria;
	completedOK 	 : Boolean;

begin

	pxyRelByTypeCrit := inheritMethod();
	
	completedOK := true;
	
	return pxyRelByTypeCrit;

epilog

	if not completedOK then
		delete pxyRelByTypeCrit;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
