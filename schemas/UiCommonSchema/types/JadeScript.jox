    <JadeMethod name="testTranshipSummaryVoyage" id="8dbc1b0b-d25a-4a62-bec2-e4a30d3979c3">
        <source>testTranshipSummaryVoyage();


vars
	form : CMUI_EDITranshipSummary;
	voyage,myVoyage : CM_Voyage;
	ti : CM_TrackedItem;
begin
	app.initialize;
	app.myPassport.setMyUserFromCode("SUPERUSER");
	app.createMyController(CMUI_Controller);
	app.myPassport.setMyTerminal(CM_Terminal.firstInstance);
	foreach voyage in  app.getMyTerminalDO_NOT_USE().allVoyagesSet do :outerloop
		foreach ti in voyage.allOnshipTIsByCargoTypeId where ti.isTranshipOnInboundVoyage do
			app.writeStatement( voyage.String&amp;' '&amp;voyage.code);
//			break;
//			break outerloop;
		endforeach;
	endforeach outerloop;
	voyage := "2416.30".asOid.CM_Voyage;
	create form transient;
	form.myCurrentVoyage := voyage;
	form.show;
	form := form;
epilog
//	delete form;
end;

</source>
    </JadeMethod>
