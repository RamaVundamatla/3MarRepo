    <JadeMethod name="doBuildMenuDisplay" id="6a7c7b3a-8f9c-4102-90a3-4fc1003fa1bf">
        <updating/>
        <source>doBuildMenuDisplay() updating;
// ---------------------------------------------------------------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	if self.myParent.name = "SHP_VoyageAreaForm" or
	   self.myParent.name = "SHP_VoyageAreaForm2" then
		self.doBuildMenuDisplaySub(DISPLAY_MODE_ACTUAL, PicDisplayModeI, "Display Actual");
		self.doBuildMenuDisplaySub(DISPLAY_MODE_PLAN, PicDisplayModeP, "Display Proposed");
	
	//elseif self.myParent.name = "YRD_RailOpsForm" then//no planning
	//	self.doBuildMenuDisplaySub(DISPLAY_MODE_ACTUAL, PicDisplayModeI, "Display Actual");
	//	self.doBuildMenuDisplaySub(DISPLAY_MODE_QUEUE, PicDisplayModeQ, "Display Queued");
	else
		self.doBuildMenuDisplaySub(DISPLAY_MODE_ACTUAL, PicDisplayModeI, "Display Actual");
		self.doBuildMenuDisplaySub(DISPLAY_MODE_QUEUE, PicDisplayModeQ, "Display Queued");
		self.doBuildMenuDisplaySub(DISPLAY_MODE_PLAN, PicDisplayModeP, "Display Planned");
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildMenuDisplaySub" id="f4670e14-ad02-48e4-8329-6f6d59d1b082">
        <updating/>
        <source>doBuildMenuDisplaySub(_index : Integer; _picture : String; _caption : String) updating, protected;
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 16 Dec 2008	cnwkpd1		PAR #18664 - remove unnecessary Picture create
// ---------------------------------------------------------------------------

vars

	idx	: Decimal[3,1];
	lFactor : Real;
	lIndex, lParentDisplayMode : Integer;
	lCaption	: String;
	mnuChild,mnuMaster	: MenuItem;
	mnuIndex 	: Integer;
//	lPicture : Picture;
	aPicture	: Binary;
	root : CM_Root;
	
begin
	lParentDisplayMode := self.myParent.sendMsg(CMUI_GridAreaForm2::getDisplayMode.name).Integer;
	if lParentDisplayMode = 100 then
		if _index = DISPLAY_MODE_QUEUE then
			return;
		endif;
	endif;
	
	mnuMaster := self.myParent.sendMsgWithParams(CM_BaseForm::getMenu.name, CMUI_GridAreaStatusLine.MenuType_DISPLAY).MenuItem;
	mnuMaster.visible := true;
	mnuMaster.enabled := true;
	root := app.myRoot;
//	create lPicture transient;

	mnuChild := mnuMaster.getMenuItem(_index); // check if the menu is already cloned
	if mnuChild = null then
		mnuChild := mnuMaster.loadSubMenu(_index); // Clone menu
		mnuChild.caption := _caption;
		mnuChild.visible := true;
		mnuChild.enabled := true;
		if root &lt;&gt; null then
			aPicture := root.getConfig(_picture).Binary;
			mnuChild.picture := aPicture;
		endif;
	endif;
	if lParentDisplayMode = _index then
		mnuChild.checked := true;
	else
		mnuChild.checked := false;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_index" type="Integer"/>
        <Parameter name="_picture" type="String"/>
        <Parameter name="_caption" type="String"/>
    </JadeMethod>
    <JadeMethod name="doBuildMenuMove" id="c7b04746-fcdf-45f6-a2b4-baf672151f21">
        <source>doBuildMenuMove();
// ---------------------------------------------------------------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 16 Dec 2008	cnwkpd1		PAR #18664 - remove unnecessary Picture create
// ---------------------------------------------------------------------------

vars
	idx	: Decimal[3,1];
	lFactor : Real;
	lIndex,lMoveMode : Integer;
	lCaption	: String;
	mnuChild,mnuMaster	: MenuItem;
	mnuIndex 	: Integer;
//	lPicture : Picture;
	aPicture	: Binary;
	root : CM_Root;
	myForm: Form;		//24 Aug 2022	navsj20	TFS 54281
	myFormName: String;	//24 Aug 2022	navsj20	TFS 54281
	
begin
	lMoveMode := self.myParent.sendMsg(CM_BaseForm::getMoveMode.name).Integer;
	mnuMaster := self.myParent.sendMsgWithParams(CM_BaseForm::getMenu.name, CMUI_GridAreaStatusLine.MenuType_MOVE).MenuItem;
	mnuMaster.visible := true;
	mnuMaster.enabled := true;

	root := app.myRoot;
//	create lPicture transient;

	if self.form &lt;&gt; null then
		myForm:=self.form;											//24 Aug 2022	navsj20	TFS 54281
		myFormName := myForm.String[1:myForm.String.pos("/",1)-1];	//24 Aug 2022	navsj20	TFS 54281
	endif;
	mnuChild := mnuMaster.getMenuItem(MENU_MOVE_INSTANT); // check if the menu is already cloned
	
	if mnuChild = null then
		mnuChild := mnuMaster.loadSubMenu(MENU_MOVE_INSTANT); // Clone menu
		mnuChild.caption := "Instant Mode";
		mnuChild.visible := true;
		mnuChild.enabled := true;
		mnuChild.helpKeyword := "Instant Mode";
		
		if root &lt;&gt; null then
			aPicture := root.getConfig(PicMoveModeI).Binary;
			mnuChild.picture := aPicture;
		endif;
	endif;
	
	if lMoveMode = REAL_MODE or lMoveMode = self.MENU_MOVE_INSTANT_ONLY then
		mnuChild.visible := true;
		mnuChild.checked := true;
	else
		mnuChild.checked := false;
	endif;
	
	// turn off the actual menu
	if lMoveMode = self.MENU_MOVE_PLAN_ONLY then
		mnuChild.visible := false;
	endif;
	
	// Only Allow to Queue if it is turned on
	if app.myPassport.myTerminal &lt;&gt; null  then //epr par 36229 17/7/15
		mnuChild := mnuMaster.getMenuItem(MENU_MOVE_QUEUED); // check if the menu is already cloned
		
		if mnuChild = null then
			mnuChild := mnuMaster.loadSubMenu(MENU_MOVE_QUEUED); // Clone menu
			mnuChild.caption := "Queued Mode";
			mnuChild.visible := true;
			mnuChild.enabled := true;
			
			if root &lt;&gt; null then
				aPicture := root.getConfig(PicMoveModeQ).Binary;
				mnuChild.picture := aPicture;
			endif;
		endif;

		//if lMoveMode = self.MENU_MOVE_INSTANT_ONLY or lMoveMode = self.MENU_MOVE_PLAN_ONLY then	//24 Aug 2022	navsj20	TFS 54281
		if lMoveMode = self.MENU_MOVE_INSTANT_ONLY or lMoveMode = self.MENU_MOVE_PLAN_ONLY or myFormName = "YRD_TrainWagonEnquiry" or myFormName = "YRD_TrainForm" then	//24 Aug 2022	navsj20	TFS 54281
			mnuChild.visible := false;
		else
			mnuChild.visible := true;
		endif;
		
		if lMoveMode = QUEUE_MODE then
			mnuChild.checked := true;
		else
			mnuChild.checked := false;
		endif;
	endif;
	
	
	mnuChild := mnuMaster.getMenuItem(MENU_MOVE_PLAN); // check if the menu is already cloned
	
	if mnuChild = null then
		mnuChild := mnuMaster.loadSubMenu(MENU_MOVE_PLAN); // Clone menu
		mnuChild.caption := "Planned Mode";
		mnuChild.visible := true;
		mnuChild.enabled := true;
		
		if root &lt;&gt; null then
			aPicture := root.getConfig(PicMoveModeP).Binary;
			mnuChild.picture := aPicture;
		endif;
	endif;
	
	if lMoveMode = self.MENU_MOVE_INSTANT_ONLY then
		mnuChild.visible := false;
	else
		mnuChild.visible := true;
	endif;
	
	if lMoveMode = PLANNING_MODE then
		mnuChild.checked := true;
	else
		mnuChild.checked := false;
	endif;
	
	if app.isSpecial() then
		mnuChild := mnuMaster.getMenuItem(8); // check if the menu is already cloned
		if mnuChild = null then
			mnuChild := mnuMaster.loadSubMenu(8); // Clone menu
			mnuChild.caption := "Play OX";
			mnuChild.visible := true;
			mnuChild.enabled := true;
			
			if root &lt;&gt; null then
				aPicture := root.getConfig(PicMoveModeQ).Binary;
				mnuChild.picture := aPicture;
			endif;
		endif;
		mnuChild := mnuMaster.getMenuItem(9); // check if the menu is already cloned
		if mnuChild = null then
			mnuChild := mnuMaster.loadSubMenu(9); // Clone menu
			mnuChild.caption := "Play Dice!";
			mnuChild.visible := true;
			mnuChild.enabled := true;
			
			if root &lt;&gt; null then
				aPicture := root.getConfig(PicMoveModeQ).Binary;
				mnuChild.picture := aPicture;
			endif;
		endif;
	endif;
	
	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildMenuOther" id="b75c4925-2234-4cd1-9205-bf0beae0787a">
        <updating/>
        <source>doBuildMenuOther(_mode : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 16 Dec 2008	cnwkpd1		PAR #18664 - remove unnecessary Picture create
// ---------------------------------------------------------------------------

vars
	idx	: Decimal[3,1];
	lFactor : Real;
	lIndex : Integer;
	lCaption	: String;
	mnuChild,mnuMaster	: MenuItem;
	mnuIndex 	: Integer;
//	lPicture : Picture;
	aPicture	: Binary;
	root : CM_Root;
	lPic : String;
	apOnOff, logOnOff, chgOnOff : Boolean;
	
begin
	// 20/02/2013 cnwar2 #31176 - these options should no longer be shown.
/*	

	apOnOff := app.isTerminalAutoPlanningEnabled();   //SFW1030 04/08/2008
	logOnOff := app.verboseLogging;
	chgOnOff := app.chargeForMove;
	
	mnuMaster := self.myParent.sendMsgWithParams(CM_BaseForm::getMenu.name, CMUI_GridAreaStatusLine.MenuType_OTHER).MenuItem;
	mnuChild := mnuMaster.getMenuItem(3); // check if the menu is already cloned
	if mnuChild &lt;&gt; null then
		mnuChild.visible := false;
	endif;
	
	mnuMaster.visible := true;
	mnuMaster.enabled := true;
	root := app.myRoot;
//	create lPicture transient;

	mnuChild := mnuMaster.getMenuItem(MENU_OTHER_ON); // check if the menu is already cloned
	if mnuChild = null then
		mnuChild := mnuMaster.loadSubMenu(MENU_OTHER_ON); // Clone menu
	endif;
	mnuChild.visible := true;
	mnuChild.enabled := true;

	self.frameOtherIndex := _mode;
	if _mode = PIC_OTHER_AUTO then // AUTOPLAN
			mnuChild.caption := "Autoplanning On";
			mnuChild.checked := apOnOff;
			lPic := PicAutoPlanOn;
	endif;
	if _mode = PIC_OTHER_LOG then // VERBOSE LOGGING
		mnuChild.caption := "Verbose Logging On";
		mnuChild.checked := logOnOff;
		lPic := PicLogOn;
	endif;
	if _mode = PIC_OTHER_CHARGE then // CHARGE FOR MOVE
		mnuChild.caption := "Charge For Move On";
		mnuChild.checked := chgOnOff;
		lPic := PicChgMoveOn;
	endif;
	
	if root &lt;&gt; null then
		aPicture := root.getConfig(lPic).Binary;
		mnuChild.picture := aPicture;
	endif;
	mnuChild := mnuMaster.getMenuItem(MENU_OTHER_OFF); // check if the menu is already cloned
	if mnuChild = null then
		mnuChild := mnuMaster.loadSubMenu(MENU_OTHER_OFF); // Clone menu
	endif;
	mnuChild.visible := true;
	mnuChild.enabled := true;

	if _mode = PIC_OTHER_AUTO then // AUTOPLAN
		if apOnOff then
			mnuChild.caption := "Autoplanning Off";
		else
			mnuChild.caption := "Autoplanning Not Enabled";
		endif;
		mnuChild.checked := not apOnOff;
		lPic := PicAutoPlanOff;
	endif;
	if _mode = PIC_OTHER_LOG then // VERBOSE LOGGING
		mnuChild.caption := "Verbose Logging Off";
		mnuChild.checked := not logOnOff;
		lPic := PicLogOff;
	endif;
	if _mode = PIC_OTHER_CHARGE then // CHARGE FOR MOVE
		mnuChild.caption := "Charge For Move Off";
		mnuChild.checked := not chgOnOff;
		lPic := PicChgMoveOff;
		
		if app.isSpecial() then
			mnuChild := mnuMaster.getMenuItem(3); // check if the menu is already cloned
			if mnuChild = null then
				mnuChild := mnuMaster.loadSubMenu(3); // Clone menu
			endif;
			mnuChild.visible := true;
			mnuChild.enabled := true;
			mnuChild.caption := "Dice!";
		
		endif;
	endif;
	
	if root &lt;&gt; null then
		aPicture := root.getConfig(lPic).Binary;
		mnuChild.picture := aPicture;
	endif;
*/
end;</source>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doContextMenu" id="b65ca99c-d055-497e-8a20-c84e320582ac">
        <updating/>
        <source>doContextMenu(_frame: Frame input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------

// ---------------------------------------------------------------------------

vars

	lLeft : Real;
	tTop : Real;
	lInOut	: CM_RailJSInOutRake;
	lOBJ : Object;
	lOtherMode : Integer;
	lMenuItem	: MenuItem;
begin
	lLeft := x;
	tTop := y;

	if not mouse then  // if keyboard, use current cell position
	endif;
	
	// ########################
	// MOVE MODE MENU
	if _frame = self.myFrameMoveMode then
	//	if form.isKindOf(YRD_SatelliteViewForm)
		self.myFrameMoveMode.windowToScreen(lLeft, tTop);
		self.screenToWindow(lLeft, tTop);   // convert x, y relative to form
		lMenuItem := self.myParent.sendMsgWithParams(CM_BaseForm::getMenu.name, CMUI_GridAreaStatusLine.MenuType_MOVE).MenuItem;		
		
		if lMenuItem &lt;&gt; null then
			self.doBuildMenuMove();	
			if self.top = 0 then	// 25 Aug 2011	NDL	Par 28035
				// I'm cloned onto the std status bar of a CM_ContainerEnqForm.
				tTop := self.parent.top + 5;
			else
				tTop := self.top + 5;
			endif;
			self.form.popupMenu(lMenuItem, lLeft.Integer, tTop.Integer);
		endif;
	endif;
	// ########################
	// DISPLAY MODE MENU
	if _frame = self.myFrameDisplayMode then
		self.myFrameDisplayMode.windowToScreen(lLeft, tTop);
		self.screenToWindow(lLeft, tTop);   // convert x, y relative to form

		lMenuItem := self.myParent.sendMsgWithParams(CM_BaseForm::getMenu.name, CMUI_GridAreaStatusLine.MenuType_DISPLAY).MenuItem;
		if lMenuItem &lt;&gt; null then
			self.doBuildMenuDisplay();
			tTop := self.top + 5;	
			self.form.popupMenu(lMenuItem, lLeft.Integer, tTop.Integer);
		endif;
	endif;
	// ########################
	// 20/02/2013 cnwar2 #31176 - these options should no longer be shown.
	/*
	if _frame = self.myFrameOther then
	
		if lLeft &gt;= 1 and lLeft &lt;= 9 then
			return false; // AKB2004OCT not doing this anymore
			
		endif;
		if lLeft &gt;= 10 and lLeft &lt;= 27 then
			lOtherMode := PIC_OTHER_LOG;
		endif;
		if lLeft &gt;= 33 and lLeft &lt;= 50 then
			lOtherMode := PIC_OTHER_CHARGE;
		endif;
		self.myFrameOther.windowToScreen(lLeft, tTop);
		self.screenToWindow(lLeft, tTop);   // convert x, y relative to form
		
		lMenuItem := self.myParent.sendMsgWithParams(CM_BaseForm::getMenu.name, CMUI_GridAreaStatusLine.MenuType_OTHER).MenuItem;
		if lMenuItem &lt;&gt; null then
			self.doBuildMenuOther(lOtherMode);
			tTop := self.top + 5;
			self.form.popupMenu(lMenuItem, lLeft.Integer, tTop.Integer);
		endif;
	endif;
	*/
	return false;

end;</source>
        <Parameter name="_frame" type="Frame" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doMenuDisplayClick" id="92c2a2d7-a7e4-4777-899b-bbc1d12f98a3">
        <updating/>
        <source>doMenuDisplayClick(_index : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

begin
	if _index = 0 then
		return;
	endif;
	self.setDisplayMode(_index);
	self.myParent.sendMsgWithParams("setDisplayMode", _index);

end;</source>
        <Parameter name="_index" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doMenuMoveClick" id="a5ce0cc1-19f5-4c0a-8146-442148af8ce2">
        <updating/>
        <source>doMenuMoveClick(_index : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 16 Dec 2008	cnwkpd1		PAR #18664 - remove unnecessary Picture create
// ---------------------------------------------------------------------------

vars
	moveMode	: Integer;
	lPic, lCaption : String;
//	lPicture : Picture;
	aPicture	: Binary;
		form : Form;

begin
	if self.myParent = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null parentForm. Contact Developer.');
		return;
	endif;
//app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' 1. IDX: ' &amp; _index.String);
	if _index = null then // PAR7153 this was initing the move mode to REAL on the drop down. Only reset if they clicked on the move mode menu item.
//write class.name &amp; '::' &amp; method.name &amp; ' returning as index null';
		return;
	endif;
	if _index = 8 then
		create form as CMUI_Out3;
		form.centreWindow();
		form.show();
	endif;
	if _index = 9 then
		create form as CMUI_Out1;
		form.centreWindow();
		form.show();
	endif;
	
//	create lPicture transient;

	if _index = MENU_MOVE_INSTANT or _index = MENU_MOVE_INSTANT_ONLY then
		lPic := PicMoveModeI;
		lCaption := "Instant Mode";
		moveMode := REAL_MODE;
	elseif _index = MENU_MOVE_QUEUED then
		lPic := PicMoveModeQ;
		lCaption := "Queued Mode";
		moveMode := QUEUE_MODE;
		//app.moveMode := QUEUE_MODE;
	elseif _index = MENU_MOVE_PLAN or _index = MENU_MOVE_PLAN_ONLY then
		lPic := PicMoveModeP;
		lCaption := "Planned Mode";
		moveMode := PLANNING_MODE;
		//app.moveMode := PLANNING_MODE;
	endif;
	
	self.myParent.sendMsgWithParams("setMoveMode", moveMode);

	if lPic &lt;&gt; null then
		aPicture := app.myRoot.getConfig(lPic).Binary;
		self.myFrameMoveMode.clearGraphics();
		if not self.isInPainter then
			if app.isUsingSkin then
				if self.parent.isKindOf(CMUI_StatusLine) then
					self.myFrameMoveMode.drawTextAt(lCaption,18,1, Black);
					self.myFrameMoveMode.drawPictureAt(aPicture,1,1);
				else
					self.myFrameMoveMode.drawTextAt(lCaption,18,5, Black);
					self.myFrameMoveMode.drawPictureAt(aPicture,1,4);
				endif;
			else
				self.myFrameMoveMode.drawTextAt(lCaption,18,2, Black);
				self.myFrameMoveMode.drawPictureAt(aPicture,1,1);
			endif;
		endif;
		self.myFrameMoveMode.refreshNow();
	endif;
	
	//self.myParent.sendMsgWithParams("setMoveMode", _index);		// cnwdad1 12/04/2007.
	//self.myParent.sendMsgWithParams("setMoveMode", moveMode);		// cnwdad1 12/04/2007.
end;</source>
        <Parameter name="_index" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doMenuOtherClick" id="e6583dd7-d934-4ac8-9b96-5ce91b7b00ed">
        <updating/>
        <source>doMenuOtherClick(_index : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 16 Dec 2008	cnwkpd1		PAR #18664 - remove unnecessary Picture create
// ---------------------------------------------------------------------------

vars
	apStr, logStr,chgStr : String;
	lPic, lCaption : String;
//	lPicture : Picture;
	lX : Integer;
	form : Form;

begin
	// 20/02/2013 cnwar2 #31176 - these options should no longer be shown.
/*

//	create lPicture transient;
	if _index = MENU_OTHER_ON then
		if frameOtherIndex = PIC_OTHER_AUTO then
			// DVB I DON'T THINK THIS IS SUPPOSED TO DO THE WHOLE SYSTEM IS IT.
			// IT WAS SETTING AUTO PLAN TO TRUE EVERY TIME YOU OPENED THE GRIDAREA FORM
			// BECAUSE IT WAS BEING CALLED BY INITFRAME
			beginTransaction;
			app.myPassport.myTerminal.setAutoPlanningEnabled(true);   //SFW1030 04/08/2008
			commitTransaction;
			lPic := PicAutoPlanOn;
			lX := 1;
		endif;
		if frameOtherIndex = PIC_OTHER_LOG then
			lPic := PicLogOn;
			lX := 19;
			app.verboseLogging := true;
		endif;
		if frameOtherIndex = PIC_OTHER_CHARGE then
			lPic := PicChgMoveOn;
			lX := 37;
			app.chargeForMove := true;
		endif;
	endif;
	if _index = MENU_OTHER_OFF then
		if frameOtherIndex = PIC_OTHER_AUTO then
			beginTransaction;
			app.myPassport.myTerminal.setAutoPlanningEnabled(false);   //SFW1030 04/08/2008
			commitTransaction;
			lPic := PicAutoPlanOff;
			lX := 1;
		endif;
		if frameOtherIndex = PIC_OTHER_LOG then
			lPic := PicLogOff;
			lX := 19;
			app.verboseLogging := false;
		endif;
		if frameOtherIndex = PIC_OTHER_CHARGE then
			lPic := PicChgMoveOff;
			lX := 37;
			app.chargeForMove := false;
		endif;
	endif;
	if _index = 3 then
		create form as CMUI_Out1;
		form.show();
	endif;
	self.displayOtherGraphics();

*/	
end;</source>
        <Parameter name="_index" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doResize" id="8ff57e41-c24e-4fb0-bb76-d3aab1d9c40c">
        <source>doResize();
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 02/02/2016	cnwdap1		PAR #36766 Bulk Graphical Representation
// ---------------------------------------------------------------------------

vars
	slf : CMUI_StatusLineFrame;
	slg : Frame;
	txtWidth, frmWidth : Integer;
begin
	//cnwmc5 - PAR 31051
	if not self.isInPainter then
		if not app.isUsingSkin then
			// 20/02/2013 cnwar2 #31176 - these options should no longer be shown.
			/*slf := self.myFrameOther;
			slf.autoRedraw := true;
			slf.top := 1;
			slf.height := self.height - 2;
			slf.width := 60;
			slf.left := self.width - self.myFrameOther.width;*/
		
			slf := self.myFrameMoveMode;
			slf.autoRedraw := true;
			slf.top := 1;
			slf.height := self.height - 2;
			slf.width := 105;	//must fit 'Planned Mode'
			slf.left := self.width - slf.width;
			
			slf := self.myFrameDisplayMode;
			slf.autoRedraw := true;
			slf.top := 1;
			slf.height := self.height - 2;
			slf.width := 125; // please leave this as 125 as in ship we have to display the words 'Display Proposed' which is bigger than 'Display Planned'
			slf.left := self.myFrameMoveMode.left - slf.width;
		
			slg := self.myFrameCaption;
			slg.top := 1;
			slg.height := self.height - 2;
			slg.width := slf.left;
			slg.left := 1;
		else
			// 20/02/2013 cnwar2 #31176 - these options should no longer be shown.
			/*slf := self.myFrameOther;
			slf.autoRedraw := true;
			slf.height := self.height;
			slf.width := 60;
			slf.left := self.width - self.myFrameOther.width;*/
		
			slf := self.myFrameMoveMode;
			slf.autoRedraw := true;
			slf.height := self.height;
			slf.width := 105;	//must fit 'Planned Mode'
			slf.left := self.width - slf.width;
			
			slf := self.myFrameDisplayMode;
			slf.autoRedraw := true;
			slf.height := self.height;
			slf.width := 125; // please leave this as 125 as in ship we have to display the words 'Display Proposed' which is bigger than 'Display Planned'
			slf.left := self.myFrameMoveMode.left - slf.width;
			if not self.myFrameMoveMode.visible then						// PAR #36766
				slf.left := self.width - slf.width;							// PAR #36766
			endif;															// PAR #36766
		
			slg := self.myFrameCaption;
			slg.height := self.height;
			slg.width := slf.left;
			// PAR #36766 adjust caption width in case modes are not visible// PAR #36766
			if not self.myFrameDisplayMode.visible then						// PAR #36766
				slg.width := self.myFrameMoveMode.left;						// PAR #36766
				if not self.myFrameMoveMode.visible then					// PAR #36766
					slg.width := self.clientWidth;							// PAR #36766
				endif;														// PAR #36766
			endif;															// PAR #36766
		endif;
		
		txtWidth := self.myFrameCaption.getTextExtent(self.myFrameCaption.caption);
		frmWidth := self.myFrameCaption.width.Integer;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="getMoveModeForDisplayMode" id="4e46810c-edbf-492d-a672-8216cc5fe2c1">
        <source>getMoveModeForDisplayMode() : Integer;
//--------------------------------------------------------------
//Created: 25 February 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if self.displayMode = DISPLAY_MODE_ACTUAL then
		return REAL_MODE;
	elseif self.displayMode = DISPLAY_MODE_PLAN then
		return PLANNING_MODE;
	elseif self.displayMode = DISPLAY_MODE_QUEUE then
		return QUEUE_MODE;
	else
		return null;
	endif;		
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="hideDisplayModeFrame" id="53fa6462-587d-4e70-a486-f08bf1597f43">
        <source>hideDisplayModeFrame(_hide : Boolean);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 02/01/2016	cnwdap1		Initial creation PAR #36766 Graphical Bulk Representation
//
vars

begin
	self.myFrameDisplayMode.visible := _hide;
epilog

end;</source>
        <Parameter name="_hide" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hideMoveModeFrame" id="731f4da9-b7a4-4103-952a-80799e89e532">
        <source>hideMoveModeFrame( _hide : Boolean);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 September 2009	cnwrd1	Initial creation

*/

vars

begin
	self.myFrameMoveMode.visible := _hide;
epilog

end;</source>
        <Parameter name="_hide" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initFrame" id="eadfe59e-96d9-40f1-b4a8-6e2f38c7c52c">
        <updating/>
        <source>initFrame()updating;
//--------------------------------------------------------------
//Created: 04 April 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	idx,
	moveMode : Integer;
begin

	moveMode := app.getMyTerminalConfigDO_NOT_USE(StartupMoveMode).Integer;
	
	if moveMode = REAL_MODE then
		idx := self.MENU_MOVE_INSTANT;
	elseif moveMode = QUEUE_MODE then
		idx := self.MENU_MOVE_QUEUED;
	elseif moveMode = PLANNING_MODE then
		idx := self.MENU_MOVE_PLAN;
	else
		idx := self.MENU_MOVE_INSTANT;				
	endif;
	
	self.doBuildMenuDisplay();
	self.doMenuDisplayClick(DISPLAY_MODE_ACTUAL);
	self.doBuildMenuMove();	
	self.doMenuMoveClick(idx);
	//self.doBuildMenuOther(self.PIC_OTHER_AUTO);	// 20/02/2013 cnwar2 #31176 - these options should no longer be shown.

	
end;</source>
    </JadeMethod>
    <JadeMethod name="setDisplayMode" id="6770b680-a4ea-43af-ab6a-e9c9adf29734">
        <updating/>
        <source>setDisplayMode(_index : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	pic		: String;
	picBin	: Binary;
begin
	if _index = DISPLAY_MODE_ACTUAL then
		pic := PicDisplayModeI;
		self.myFrameDisplayMode.clearGraphics;
		//cnwmc5 - PAR 31051
		if not self.isInPainter then
			if app.isUsingSkin then
				self.myFrameDisplayMode.drawTextAt(DISPLAY_MODE_ACTUAL_CAPTION,18,5, Black);
			else
				self.myFrameDisplayMode.drawTextAt(DISPLAY_MODE_ACTUAL_CAPTION,18,2, Black);
			endif;
		endif;
	elseif _index = DISPLAY_MODE_PLAN then
		pic := PicDisplayModeP;
		self.myFrameDisplayMode.clearGraphics;
		if self.myParent.class.name = "SHP_VoyageAreaForm" or
			self.myParent.class.name = "SHP_VoyageAreaForm2" then
			//cnwmc5 - PAR 31051
			if not self.isInPainter then
				if app.isUsingSkin then
					self.myFrameDisplayMode.drawTextAt("Display Proposed",18,5, Black);
				else
					self.myFrameDisplayMode.drawTextAt("Display Proposed",18,2, Black);
				endif;
			endif;
		else
			//cnwmc5 - PAR 31051
			if not self.isInPainter then
				if app.isUsingSkin then
					self.myFrameDisplayMode.drawTextAt(DISPLAY_MODE_PLAN_CAPTION,18,5, Black);
				else
					self.myFrameDisplayMode.drawTextAt(DISPLAY_MODE_PLAN_CAPTION,18,2, Black);
				endif;
			endif;
		endif;

	elseif _index = DISPLAY_MODE_QUEUE then
		pic := PicDisplayModeQ;
		self.myFrameDisplayMode.clearGraphics;
		
		//cnwmc5 - PAR 31051
		if not self.isInPainter then
			if app.isUsingSkin then
				self.myFrameDisplayMode.drawTextAt(DISPLAY_MODE_QUEUE_CAPTION,18,5, Black);
			else
				self.myFrameDisplayMode.drawTextAt(DISPLAY_MODE_QUEUE_CAPTION,18,2, Black);
			endif;
		endif;

	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid display mode (' &amp; _index.String &amp; ')');
	endif;
	
	if pic &lt;&gt; null then
		picBin := app.myRoot.getConfig(pic).Binary;
		//cnwmc5 - PAR 31051
		if not self.isInPainter then
			if app.isUsingSkin then
				self.myFrameDisplayMode.drawPictureAt(picBin,1,4);
			else
				self.myFrameDisplayMode.drawPictureAt(picBin,1,1);
			endif;
		endif;
	endif;

end;</source>
        <Parameter name="_index" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="c7095faf-de78-46a1-a877-8dcee819119b">
        <updating/>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating;
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod(cntrl, persistCntrl);
	//cnwmc5 - PAR 31051
	if not self.isInPainter then
		if not app.isUsingSkin then
			self.bevelInner := Frame.Bevel_Inset;
			self.bevelInnerWidth := 0;
			self.bevelOuter := Frame.Bevel_None;
			self.bevelOuterWidth := 0;
			self.borderStyle := Table.BorderStyle_None;
			self.boundaryWidth := 0;
			self.backColor := White; //Frame.Color_3DFace;
			self.height := 25;
		else
			self.height := 20;
		endif;
	endif;
	
	self.caption := null;
	self.enabled := true;
	self.alignContainer := Frame.AlignContainer_Bottom;
	self.width := 500;
	self.left := 0;
	self.autoRedraw := true;

	//self.createFrameOther();	// 20/02/2013 cnwar2 #31176 - these options should no longer be shown.
	
	self.createFrameMoveMode();

	self.createFrameDisplayMode();

	self.createFrameCaption();
	
	if not self.isInPainter then
		self.createGraphics();
	endif;
	self.myParent := form;
	
	self.doResize();
end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
