    <JadeMethod name="verifyEDIDataTIs" id="95f32ccd-bf99-4af6-9b9d-79579e43aa2f">
        <updating/>
        <source>verifyEDIDataTIs(_passport: CM_Passport input): Integer updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
27 June 2023		jlizm1	Initial creation TFS 53901 EUP VBS EDI

*/

vars
	ediTI			: CM_EDITrackedItem;
	
begin	
	// Arm our base exception handlers
	on Exception do validationExceptionHandler(exception, _passport);
	app.setContinueCMExceptions(true);

	foreach ediTI in self.allEDITrackedItems do
		ediTI.verifySelf();
	endforeach;
	
	return app.myPassport.allErrorWarnings.size;
	
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
