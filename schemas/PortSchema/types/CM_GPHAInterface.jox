    <JadeMethod name="createInvoiceRecord" id="4f1535c9-8bd1-4ecf-8f8e-8e8b5e62fc59">
        <source>createInvoiceRecord(file : File io; inv : CM_Invoice);
/*
Purpose:	GPHA financial export to CSV		
Date				Who			Reason
AUGUST 2015		CNWAB1		Initial creation
 // PAR 36631
// 37040 Oct 2015 output changed from CSV to XML
//  some other changes as per the spec, including using date.format instead of shortFormat to get both day and month without leading zeros
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
24/03/2020		jlgdap1			TFS 48959 GPHA MS Dynamics Interface Enhancement
23/04/2020		jlgdap1			TFS 49178 GPHA MS Dynamics Interface Enhancement (XML Update) - no business unit in header
*/
vars
	narration : String;
	termsCode,
	termsDescription	: String;
	now : TimeStamp;
	term : CM_Terminal;
	custcode, debtorname	: String;
	invline : CM_InvoiceLine;
	voyage : CM_Voyage;					// TFS 48959
	busUnit : CM_Bank;					// TFS 48959
	header : String;					// TFS 48959
	berthCode, stevedore, vesselType,	// TFS 48959
	loa, grt, visitType : String;		// TFS 48959
	arrivedDT, departedDT : String;		// TFS 48959

begin

	custcode := inv.debtor.decfinName;
	debtorname := inv.debtor.longName;
	if debtorname = null then
		debtorname := inv.debtor.name;
	endif;
	narration := inv.narration;
	if  inv.invoiceType.myInvTermsOfTrade &lt;&gt; null then
		termsDescription := inv.invoiceType.myInvTermsOfTrade.description;
		termsCode := inv.invoiceType.myInvTermsOfTrade.code;
	endif;
	// TFS 48959 start
	voyage := inv.myVoyage;
	if voyage &lt;&gt; null then
		arrivedDT := voyage.arrivedDT.date.format("d/M/yyy");
		departedDT := voyage.departedDT.date.format("d/M/yyy");
		berthCode := voyage.getBerthCode;
		if voyage.myHMSVoyageData &lt;&gt; null then 
			if voyage.myHMSVoyageData.myVesselType &lt;&gt; null then
				vesselType := voyage.myHMSVoyageData.myVesselType.description;
			endif;
			if not voyage.myHMSVoyageData.allStevedoresDischarge.isEmpty then
				stevedore := voyage.myHMSVoyageData.allStevedoresDischarge.first.code;
			endif;
			visitType := voyage.getVisitTypeDescription();
			loa := voyage.myHMSVoyageData.dim_LengthOverall.String;
			grt := voyage.myHMSVoyageData.dim_GrossRegTonnes.String;
		endif;
	endif;
	busUnit := inv.bank;
	//if busUnit &lt;&gt; null then				// TFS 49178
	//	header := "JMT_" &amp; busUnit.code;	// TFS 49178
	//else									// TFS 49178
	header := "JMT";
	//endif;								// TFS 49178
	// TFS 48959 end of this bit

	// XML header
	file.writeLine('&lt;?xml version="1.0"?&gt;' &amp; CrLf &amp; //'&lt;ns0:Invoice xmlns:ns0="http://JMT_INTEGRATION_PROD.InvoiceXML"&gt;');	// TFS 48959
					'&lt;' &amp; header &amp; '&gt;');																					// TFS 48959

	now := app.actualTimeServer;// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	term  := inv.myTerminal;
	
	file.writeLine('&lt;InvoiceHeader&gt;');
	file.writeLine(self.formatAsXML('CustomerCode', custcode));
	file.writeLine(self.formatAsXML('DebtorName', debtorname));
	file.writeLine(self.formatAsXML('SequenceNo', inv.sequenceNum.String));
	file.writeLine(self.formatAsXML('Description', narration));
	file.writeLine(self.formatAsXML('InvoiceFrom', inv.fromDT.date.format("d/M/yyy")));
	file.writeLine(self.formatAsXML('InvoiceTo',  inv.toDT.date.format("d/M/yyy")));
	file.writeLine(self.formatAsXML('UserCode', app.getMyUserCode()));
	file.writeLine(self.formatAsXML('DateRun', inv.postedDT.date.format("d/M/yyy"))); // RUN DATE
	file.writeLine(self.formatAsXML('PurchaseOrder', inv.purchaseOrderNumber));
	file.writeLine(self.formatAsXML('GLYear', self.glYear.String));
	file.writeLine(self.formatAsXML('GLPeriod', self.glPeriod.String));
	file.writeLine(self.formatAsXML('BatchDate', now.date.format("d/M/yyy"))); // BATCH DATE
	file.writeLine(self.formatAsXML('BusinessUnit', inv.bank.code));
	file.writeLine(self.formatAsXML('Terminal', inv.myTerminal.code));
	file.writeLine(self.formatAsXML('TermsOfTrade', termsDescription));
	file.writeLine(self.formatAsXML('TermsOfTradeCode', termsCode));
	file.writeLine(self.formatAsXML('VesselName', inv.vesselName));
	file.writeLine(self.formatAsXML('VoyageCode', inv.voyageCode));
	file.writeLine(self.formatAsXML('ArrivalDate', arrivedDT));											// TFS 48959
	file.writeLine(self.formatAsXML('DepartureDate', departedDT));										// TFS 48959
	file.writeLine(self.formatAsXML('BerthCode', berthCode));											// TFS 48959
	file.writeLine(self.formatAsXML('VesselType', vesselType));											// TFS 48959
	file.writeLine(self.formatAsXML('StevedoreCode', stevedore));										// TFS 48959
	file.writeLine(self.formatAsXML('LOA', loa));														// TFS 48959
	file.writeLine(self.formatAsXML('GRT', grt));														// TFS 48959
	file.writeLine(self.formatAsXML('InvoiceType', inv.getInvoiceTypeDescription));						// TFS 48959
	file.writeLine(self.formatAsXML('VisitType', visitType));											// TFS 48959
	file.writeLine('&lt;/InvoiceHeader&gt;');
	
	file.writeLine('&lt;InvoiceLines&gt;');
	// XML details
	foreach 	invline in inv.invoiceLines discreteLock do
		file.writeLine('&lt;Line&gt;');
		file.writeLine(self.formatAsXML('CustomerCode', custcode));
		file.writeLine(self.formatAsXML('DebtorName', debtorname));
		file.writeLine(self.formatAsXML('SequenceNo', invline.sequenceNum.String));
		//file.writeLine(self.formatAsXML('Quantity', invline.quantity.Integer.String));				// TFS 48959
	///	file.writeLine(self.formatAsXML('Quantity', invline.quantity.String.padDecimalsWithZeros(4)));	// TFS 48959
		//file.writeLine(self.formatAsXML('Quantity', invline.quantity.roundedTo(4).String.padDecimalsWithZeros(4)));	// 09 Nov 2020	NDL	TFS 50228
		file.writeLine(self.formatAsXML('Quantity', invline.getLineQuantityTen())); //16/05/2025	navkc1 JIRA EPIC-34131 STORY-34817
		file.writeLine(self.formatAsXML('UnitNarration', invline.invoiceLineDesc.unitNarration));		// TFS 48959
		file.writeLine(self.formatAsXML('Rate', invline.getRate().String));
		file.writeLine(self.formatAsXML('TotalExclTax', invline.getLineTotalTen().String)); //16/05/2025	navkc1 JIRA EPIC-34131 STORY-34817
		file.writeLine(self.formatAsXML('GLCode', invline.getGLCodesString));
		file.writeLine(self.formatAsXML('ServiceName', invline.invoiceLineDesc.narration));
		file.writeLine(self.formatAsXML('ExternalReference1', invline.getFirstServiceRef1())); //16/05/2025	navkc1 JIRA EPIC-34131 STORY-34817
		file.writeLine(self.formatAsXML('ExternalReference2', invline.getFirstServiceRef2())); //16/05/2025	navkc1 JIRA EPIC-34131 STORY-34817
		file.writeLine(self.formatAsXML('TaxCode', invline.getTaxCode(false)));		// Feb 2016 cnwjre1 37586
		file.writeLine(self.formatAsXML('TaxValue', invline.getTotalTaxAmountForLineTen().String)); //16/05/2025	navkc1 JIRA EPIC-34131 STORY-34817
		file.writeLine(self.formatAsXML('TotalInclTax', invline.getLineTotalWithTaxTen().String)); //16/05/2025	navkc1 JIRA EPIC-34131 STORY-34817
		///file.writeLine(self.formatAsXML('TaxCode', inv.bank.parentCompany.taxNarration));
		file.writeLine('&lt;/Line&gt;');
	endforeach;

	file.writeLine('&lt;/InvoiceLines&gt;');
	//file.writeLine('&lt;/ns0:Invoice&gt;');																	// TFS 48959
	file.writeLine('&lt;/' &amp; header &amp; '&gt;');																// TFS 48959

epilog
	file.close();
end;</source>
        <Parameter name="file" type="File" usage="io"/>
        <Parameter name="inv" type="CM_Invoice"/>
    </JadeMethod>
    <JadeMethod name="createInvoiceRecordCSV" id="b42b419a-c6b9-48ec-9120-23210715f399">
        <source>createInvoiceRecordCSV(file : File io; inv : CM_Invoice);
/*
Purpose:	GPHA financial export to CSV		
Date				Who			Reason
AUGUST 2015		CNWAB1		Initial creation
 // PAR 36631
// 37040 Oct 2015 output changed from CSV to XML, this original code retained but no longer used
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/
constants
	DELIMITER = ",";
vars
	str, narration : String;
	idx, pos 	: Integer;
	now : TimeStamp;
	term : CM_Terminal;
	voyage	: CM_Voyage;
	yearStr : String;
	isZeroRatedTax : Boolean;
	taxRate : Real;
	custcode, debtorname, taxCode : String;
	invline : CM_InvoiceLine;
	ch : CM_Charge;
	service : CM_Service;
begin

	custcode := inv.debtor.decfinName;
	debtorname := inv.debtor.name;
	narration := inv.invoiceType.generateNarration(inv);

	str := "Customer Code,Debtor Name,Sequence No.,Description,Invoice From,Invoice To,User Code,Date Run,Purchase Order,General Ledger Year,General Ledger Period,Batch Date,Business Unit,Terminal,Terms Of Trade,Terms Of Trade Code,Vessel Name,Voyage Code"; 
	file.writeLine(str);

	now := app.actualTimeServer;// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	term  := inv.myTerminal;
	
	str := custcode;
	str := str &amp; DELIMITER &amp; debtorname;
	str := str &amp; DELIMITER &amp; inv.sequenceNum.String;
	str := str &amp; DELIMITER &amp; narration;
	str := str &amp; DELIMITER &amp; inv.fromDT.date.shortFormat();
	str := str &amp; DELIMITER &amp; inv.toDT.date.shortFormat();
	str := str &amp; DELIMITER &amp; app.getMyUserCode();
	str := str &amp; DELIMITER &amp; inv.postedDT.date.shortFormat(); // RUN DATE
	str := str &amp; DELIMITER &amp; inv.purchaseOrderNumber;
	
	isZeroRatedTax := inv.isZeroRatedTax ; 
	if isZeroRatedTax then
		taxRate := 0;
		taxCode := "";
	else
		taxRate := inv.bank.parentCompany.taxPercentageRate / 100;
		taxCode :=  inv.bank.parentCompany.taxNumber;
	endif;
	
	str := str &amp; DELIMITER &amp; self.glYear.String;
	str := str &amp; DELIMITER &amp; self.glPeriod.String;
	str := str &amp; DELIMITER &amp; now.date.shortFormat(); // BATCH DATE
	str := str &amp; DELIMITER &amp; inv.bank.code;
	str := str &amp; DELIMITER &amp; inv.myTerminal.code;
	
	if  inv.invoiceType.myInvTermsOfTrade &lt;&gt; null then
		str := str &amp; DELIMITER &amp; inv.invoiceType.myInvTermsOfTrade.description;
		str := str &amp; DELIMITER &amp; inv.invoiceType.myInvTermsOfTrade.code;
	else
		str := str &amp; DELIMITER &amp; DELIMITER;
	endif;
	
	str := str &amp; DELIMITER &amp; inv.vesselName;
	str := str  &amp; DELIMITER &amp; inv.voyageCode;
	
	file.writeLine(str);
	
	str := "Customer Code,Debtor Name,Sequence No.,Quantity,Rate,GL Code,Service Name, Tax Code";
	file.writeLine(str);
	
	foreach 	invline in inv.invoiceLines discreteLock do
		str := custcode;
		str := str &amp; DELIMITER &amp; debtorname;
		str := str &amp; DELIMITER &amp; invline.sequenceNum.String;
	//	str := str &amp; DELIMITER &amp; invline.quantity.Integer.String;
		str := str &amp; DELIMITER &amp; invline.quantity.roundedTo(4).String.padDecimalsWithZeros(4);	//09 Nov 2020	NDL	TFS 50228
		str := str &amp; DELIMITER &amp; invline.getRate().String;
		str := str &amp; DELIMITER &amp; invline.getGLCodesString;
		
		ch := invline.charges.first;
		if ch &lt;&gt; null then
			service := ch.service;
			if service &lt;&gt; null then
				str := str &amp; DELIMITER &amp; service.name;
			else
				str := str &amp; DELIMITER &amp; DELIMITER;
			endif;
		else
			str := str &amp; DELIMITER &amp; DELIMITER;
		endif;
		
		str := str &amp; DELIMITER &amp; invline.getTaxCode(false);
		
		file.writeLine(str);
	endforeach;
epilog
	file.close();
end;</source>
        <Parameter name="file" type="File" usage="io"/>
        <Parameter name="inv" type="CM_Invoice"/>
    </JadeMethod>
    <JadeMethod name="export" id="6e47f20c-e595-44c5-8838-fd8e9b1e4d36">
        <updating/>
        <source>export(_invoice: CM_Invoice input) updating;
/*
Purpose:		 // PAR 36631	
Date				Who			Reason
AUGUST 2015		CNWAB1		Initial creation
// 27 Oct 2016	cnwrs1	TFS allow this directory to be assigned %MiscDir% insrtead of D:\qnsPjmt\server\c_misc
*/

vars
	file 	: File;
	path 	: String;
	fFolder : FileFolder;
	message : String;
begin
	path := self.exportPath.normaliseDirectory().substituteDirectory();
	
	create fFolder;
	fFolder.fileName := path;
	if not fFolder.isAvailable then
	/* WAS TFS 6949
		app.msgBox("The export path of '" &amp; path &amp; "' does not exist. Cannot export invoice " &amp; _invoice.sequenceNum.String &amp; "." &amp; Cr
					&amp; "See export path settings in Invoice System Defaults.","Export Error",
			MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			NOW */
			message := app.getErrorString2(Expor_path_does_not_exist_cann,path,_invoice.sequenceNum.String);
			app.msgBox(message,app.getErrorString(Export_error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);

		return;
	endif;

	create file;
	file.fileName := path &amp; _invoice.sequenceNum.String &amp; ".xml"; 	// 37040 output format XML
	file.mode := File.Mode_Output;
	file.allowReplace := true;
	
	self.createInvoiceRecord(file,_invoice);

epilog
	delete fFolder;
	delete file;
end;
</source>
        <Parameter name="_invoice" type="CM_Invoice" usage="input"/>
    </JadeMethod>
    <JadeMethod name="exportCSV" id="37a5938b-6918-41a8-b096-fd4cd1829e61">
        <updating/>
        <source>exportCSV(_invoice: CM_Invoice input) updating;
/*
Purpose:		 // PAR 36631	
Date				Who			Reason
AUGUST 2015		CNWAB1		Initial creation
// 37040 Oct 2015 output changed from CSV to XML, this original code retained but no longer used
// 27 Oct 2016	cnwrs1	TFS allow this directory to be assigned %MiscDir% insrtead of D:\qnsPjmt\server\c_misc
*/

vars
	file 	: File;
	path 	: String;
	fFolder : FileFolder;
	message : String;
begin
	path := self.exportPath.normaliseDirectory().substituteDirectory();
	
	create fFolder;
	fFolder.fileName := path;
	if not fFolder.isAvailable then
	/* WAS TFS 6949
		app.msgBox("The export path of '" &amp; path &amp; "' does not exist. Cannot export invoice " &amp; _invoice.sequenceNum.String &amp; "." &amp; Cr
					&amp; "See export path settings in Invoice System Defaults.","Export Error",
			MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			NOW */
			message := app.getErrorString2(Expor_path_does_not_exist_cann,path,_invoice.sequenceNum.String);
			app.msgBox(message,app.getErrorString(Export_error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			
			
		return;
	endif;

	create file;
	file.fileName := path &amp; _invoice.sequenceNum.String &amp; ".txt"; 
	file.mode := File.Mode_Output;
	file.allowReplace := true;
	
	self.createInvoiceRecord(file,_invoice);

epilog
	delete fFolder;
	delete file;
end;
</source>
        <Parameter name="_invoice" type="CM_Invoice" usage="input"/>
    </JadeMethod>
    <JadeMethod name="exportToFile" id="e35b1d46-6ff6-41a7-808d-41b41bffc0b9">
        <source>exportToFile(invoice: CM_Invoice input; fileNameBase: String) ;
 // PAR 36631
vars
	file : File;
begin

	create file;
	file.allowReplace := true;
	file.fileName := fileNameBase; 
	file.mode := File.Mode_Output;

	
	self.createInvoiceRecord(file,invoice);
	
epilog
	delete file;
end;
</source>
        <Parameter name="invoice" type="CM_Invoice" usage="input"/>
        <Parameter name="fileNameBase" type="String"/>
    </JadeMethod>
