    <JadeMethod name="btnGroupMaint_click" id="a826d7ab-28ac-4467-acac-3262630f6f67">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnGroupMaint_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 July 2018	jlgndl1	Initial creation	TFS 39186

*/

vars	

	form : CMUI_CargoGroupNotifiedMaint;
	rowIndex : Integer;
	cga : CM_CargoGroupAssignment;

begin

	form := app.loadForm(CMUI_CargoGroupNotifiedMaint, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_CargoGroupNotifiedMaint;	
	if form = null then
		return;
	endif;
	
	rowIndex := self.tblData.row;
	if rowIndex &gt; self.tblData.fixedRows then
		cga := self.tblData.accessRow( rowIndex ).itemObject.CM_CargoGroupAssignment;
	endif;
	form.setMyCargoGroupAssignment( cga );
		
	form.show();

epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
