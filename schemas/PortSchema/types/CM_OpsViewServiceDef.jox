    <JadeMethod name="createBGPRequestsForRUNNING" id="cceb7935-ec83-4b14-8a37-e4d9153f920b">
        <updating/>
        <source>createBGPRequestsForRUNNING() updating;
/*
Purpose:			

Date		Who		Reason
03 August 2021	navab1	TFS 50669
*/

vars
	ewsAct : CM_EWSActivityOpsview;
begin

	// process any that have been 'created' during starting that were missed
	// status will be RUNNING after this which means newly created EWS activity will auto create the BGP request.

	foreach ewsAct in app.myRoot.allEWSOpsviewActivities  discreteLock where ewsAct.status = BGP_OpsViewWSRequest.EWS_STATUS_BGP_CREATED do
		ewsAct.createBGPRequest();
	endforeach;
	
	self.status := EWS_STATUS_RUNNING; // this will make the activity 'live' i.e. instantly raise BGP request

epilog


end;</source>
    </JadeMethod>
    <JadeMethod name="createBGPRequestsForSEQUENCE" id="c6602d91-f82d-49fc-a01d-1abcccf3ed1a">
        <updating/>
        <source>createBGPRequestsForSEQUENCE() updating;
/*
Purpose:			

Date		Who		Reason
03 August 2021	navab1	TFS 50669
*/

vars
	ewsAct : CM_EWSActivityOpsview;
	bgp : BGP_Manager;
begin

	bgp := null; // Keep this null as it is only used for raising an activity history for the deleted request which we do not want for OpsView

	foreach ewsAct in app.myRoot.allEWSOpsviewActivities  discreteLock where ewsAct.sequence &gt; self.lastSuccessfullSequence do
		if ewsAct.isSnapshot then
			continue;
		endif;
		if ewsAct.status = BGP_OpsViewWSRequest.EWS_STATUS_DELETED then
			continue;
		endif;
		
		ewsAct.initialiseStatus(BGP_OpsViewWSRequest.EWS_STATUS_BGP_CREATED, bgp);
	endforeach;
	
	foreach ewsAct in app.myRoot.allEWSOpsviewActivities  discreteLock where ewsAct.sequence &gt; self.lastSuccessfullSequence do	
		if ewsAct.isSnapshot then
			continue;
		endif;
		if ewsAct.status = BGP_OpsViewWSRequest.EWS_STATUS_DELETED then
			continue;
		endif;
		ewsAct.createBGPRequest();
	endforeach;
	
	// The call from the producer to the MTN API with SATRTING will respond successful to the producer, the producer will immediately send a RUNNING
	// At this point this method may finish before the producer sends a RUNNING, 
	//				if this methods finishes before the RUNNING arrives we set the status to READYTORUN
	//				if this method is still running when the RUNNING arrives it will set the status to READYTORUN
	//				SO either this method or the API will set ready to run based on who is first
	// This method has to finish before setting status to 'running', so the 'running' sent by the producer will set our status to 'ready to run' so we know it is OK to set status to running whne we finish
	if self.status = EWS_STATUS_READYTORUN then
		system.causeEvent(BGP_Object.BGP_NavisSmartProducerRunning, true, null);
	else // if we have finished first set the status to ready to run so the API call with running can change status to RUNNING
		self.status := EWS_STATUS_READYTORUN; // when the producer calls the API with a RUNNING this will tell it that the starting has finsihed.
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="createBGPRequestsForSTARTING" id="d23f58ef-fded-48a8-805c-9345bd383439">
        <updating/>
        <source>createBGPRequestsForSTARTING() updating;
/*
Purpose:			

Date		Who		Reason
03 August 2021	navab1	TFS 50669
*/

vars
	ewsAct : CM_EWSActivityOpsview;

begin
	
	foreach ewsAct in app.myRoot.allEWSOpsviewActivities  discreteLock where ewsAct.status = BGP_OpsViewWSRequest.EWS_STATUS_BGP_CREATED do
		ewsAct.createBGPRequest();
	
	endforeach;
	
	
	// The call from the producer to the MTN API with STARTING will respond successful to the producer, the producer will immediately send a RUNNING
	// At this point this method may finish before the producer sends a RUNNING, 
	//				if this methods finishes before the RUNNING arrives we set the status to READYTORUN
	//				if this method is still running when the RUNNING arrives it will set the status to READYTORUN
	//				SO either this method or the API will set ready to run based on who is first
	// This method has to finish before setting status to 'running', so the 'running' sent by the producer will set our status to 'ready to run' so we know it is OK to set status to running when we finish
	
	/* possible solution to producer at running status and MTN says ready to run still and does nto change.
	if self.status = EWS_STATUS_STARTING then
		self.status := EWS_STATUS_READYTORUN; // when the producer calls the API with a RUNNING this will tell it that the starting has finsihed.
	else
		system.causeEvent(BGP_Object.BGP_NavisSmartProducerRunning, true, null);
	endif;
	*/
	
	if self.status = EWS_STATUS_READYTORUN then
		system.causeEvent(BGP_Object.BGP_NavisSmartProducerRunning, true, null);
	else // if we have finished first set the status to ready to run so the API call with running can change status to RUNNING
		self.status := EWS_STATUS_READYTORUN; // when the producer calls the API with a RUNNING this will tell it that the starting has finsihed.
	endif;
				
epilog

end;</source>
    </JadeMethod>
