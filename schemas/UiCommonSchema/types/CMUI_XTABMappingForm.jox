// ---------------------------------------------------------------------------
vars
	op	:CM_QueryOperator;
begin
	foreach op in self.myQueryProperty.allAllowedOperators do
		cmbOperator.addItemObject (op.description, op);
	endforeach;
epilog

end;</source>
