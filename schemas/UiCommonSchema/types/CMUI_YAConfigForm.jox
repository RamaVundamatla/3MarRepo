    <JadeMethod name="createYAConfig" id="33643156-6aa5-4884-99f2-48726f018cf6">
        <updating/>
        <source>createYAConfig() updating;

/*

Purpose:		Create YAConfig for current terminal.
				Really just for development mode as YAConfig will be created when terminal created.

Parameters:		

Return Value:		


Date			Who		Reason
31 July 2008	consw1	Initial creation
25 Aug 2025		navdap1	MTN-35615 ENT | Bulk Creation of Yard Allocations
*/

vars
	configOpts : CMIF_YAConfig;
	proxyYAConfig : CM_YAConfig;
	realYAConfig : CM_YAConfig;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin
	create proxyYAConfig transient;
	proxyYAConfig.setProxy(self.myTerminal, null, null, null, null);	// MTN-35615
	
	create configOpts transient;
	configOpts.setFromTerminal(self.myTerminal);
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxCA.trxCreateYAConfig(proxyYAConfig, realYAConfig, configOpts, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		self.unloadForm;
		break;
		
	endwhile;
	
epilog
	delete proxyYAConfig;
	delete configOpts;
end;</source>
    </JadeMethod>
    <JadeMethod name="displayCriteria" id="911f8899-4947-4171-9358-f5baa4347f91">
