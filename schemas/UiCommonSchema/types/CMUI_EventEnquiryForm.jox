    <JadeMethod name="setupContextMenuItems" id="0ac780c8-1174-4ce6-8b06-c083be99e225">
        <updating/>
        <source>setupContextMenuItems(conwin: Window input) updating;
/* ---------------------------------------------------------------------------
Created:	07 November 2008	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	tmpMenu	: MenuItem;

begin

	self.mnuPrintDetails.visible := false;
	self.mnuEditDiscrepancy.visible := false;

	if conwin = tblData then
		
		if self.myCurrentObject &lt;&gt; null then
			if self.myCurrentObject.isKindOf(CMEVT_InvoiceGeneration) then
				self.mnuPrintDetails.visible := true;	//ccms jmt 1772. Printing Invoice Generation details. Nov 2008
				self.mnuPrintDetails.caption := "Print Invoice Generation Details...";
			elseif self.myCurrentObject.isKindOf(CMEVT_BookingRefDiscrep) then
				//25 Aug 2009	NDL	CCMS1609 Par 20521
				self.mnuEditDiscrepancy.visible := true;
				self.mnuEditDiscrepancy.userObject := self.myCurrentObject;
			endif;
		endif;
	
	endif;

	tmpMenu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuPrintDetails, false); 
	tmpMenu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuEditDiscrepancy, false); 
	
end;</source>
        <Parameter name="conwin" type="Window" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="84062396-9523-4a7c-bf67-e4117ab28f24">
        <updating/>
        <source>setupForm() updating;
/*
----------   ----------  --------------------------------------------------
Created:	10 July 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
----------   ----------  --------------------------------------------------
*/
vars
	userWindow	: CM_UserWindow;
begin
	
	self.searcherDockUndock(false);
	
	
	inheritMethod();
	
	userWindow := self.myUserWindow;
	if userWindow = null then
		userWindow := app.getUserWindow(self.name, false);
	endif;
	self.xmlSetSearchCriteria(userWindow);
	
	self.setCaption(app.getErrorString(System_event_enquiry));
	self.doResize();//sigh...framework problem with tableViewForm - methods called in wrong order
	self.sptMain.hideRightControl(true);
	self.sptMain.setLeftToRightRatio(100);
	
	self.txtDateFrom.setFocus();
	
	// TFS 2101 CNWAB1
	if not app.myCurrentUserCan(null, self.permissionMaint) then
		self.btnEditTV.visible := false;			
		self.btnSaveBase.visible := false;
		self.btnDeleteTV.visible := false;
	endif;
end;

</source>
    </JadeMethod>
    <JadeMethod name="showForQuickSearch" id="8b83ca05-f519-4d4e-99b0-0b360531ab05">
        <updating/>
        <source>showForQuickSearch(_minutesAgo : Integer) updating;
/*
----------   ----------  --------------------------------------------------
Created:	18 July 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	user			: CM_User;
	eventType		: CM_EventType;
	time			: Time;
	recentTime		: TimeStamp;
	minutesAgo			: Integer;
begin
	
	self.show;
	//setup filter criteria so as to show all event transactions of types the user has subscribed
	//to over the last short period of time.
	user := app.myPassport.myUser;
	
	self.filtAllEventTypes.clear();
	foreach eventType in user.allEventTypes do
		self.filtAllEventTypes.add(eventType.type);
	endforeach;
	self.filtIncludesUserEventType := true;
	self.filtNeedFilterEventTypes := true;
	
	recentTime := app.actualTimeServer;
	minutesAgo := _minutesAgo;
	if minutesAgo &gt; 0 then//make negative
		minutesAgo := -minutesAgo;
	endif;
	
	recentTime.setTime(recentTime.time.cnEcAddMinutes(minutesAgo));
	self.filtFromDT := recentTime;
	//app.writeStatement(class.name &amp; '::' &amp; method.name &amp; '-filtFromDT=' &amp; filtFromDT.String);
	self.filtToDT := null;
	self.filtAllTerminals.clear();
	app.myRoot.allTerminals.copy(self.filtAllTerminals);
	self.filtIncludeNoTerm := true;
	self.filtAllUsers.clear();
	app.myRoot.allUsers.copy(self.filtAllUsers);
	self.filtIncludeNoUser := true;
	
	//self.zDoSearch();
	self.zHideSearcher();
	self.zTblDataSortAndShow(true);
	self.postSearchProcessing();
	
epilog
	self.frmModalDialog.visible := false;
	self.mode := Mode_View;
	app.mousePointer := MousePointer_Default;
	app.myPassport.myActivityCapture.stopCaptureSearch();
end;

</source>
        <Parameter name="_minutesAgo" type="Integer"/>
    </JadeMethod>
