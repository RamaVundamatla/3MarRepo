    <JadeMethod name="setForUpdate" id="6d626ca6-7342-480f-9db5-1e470b2eb85b">
        <updating/>
        <source>setForUpdate(_pxyEventGroup : CM_EventTypeGroup) updating;
// ---------------------------------------------------------------------------
// Created:     cnwyl1  Yi Liu
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.name					:= _pxyEventGroup.name;
	self.description			:= _pxyEventGroup.description;
	
	self.allEventTypes.clear();
	_pxyEventGroup.allEventTypes.copy(self.allEventTypes);
	self.myRoot 				:= _pxyEventGroup.myRoot;
epilog

end;</source>
        <Parameter name="_pxyEventGroup" type="CM_EventTypeGroup"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="1f5805f0-4e83-4e98-8643-872be0fb035f">
        <updating/>
        <source>setProxy(pName : String; pDesc : String; pAllEventTypes : Collection; pRoot : CM_Root) updating;
// ---------------------------------------------------------------------------
// Created:     cnwyl1  Yi Liu
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.name 			:= pName;
	self.description 	:= pDesc;
	
	self.allEventTypes.clear();
	pAllEventTypes.copy(self.allEventTypes);
	self.myRoot 		:= pRoot;
end;</source>
        <Parameter name="pName" type="String"/>
        <Parameter name="pDesc" type="String"/>
        <Parameter name="pAllEventTypes" type="Collection"/>
        <Parameter name="pRoot" type="CM_Root"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="94666e86-bb1f-4198-9065-bc0a538aa474">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;

vars

begin
	if _property.name = CM_EventType::allEventTransactions.name then
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;
end;
</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="6a911273-018e-414b-ab49-6a495488d247">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:     cnwyl1  Yi Liu
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
//13/06/2022 navds20 TFS 53760 DuplicateItem not Translatable
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
	iter			: Iterator;
	eventGroup		: CM_EventTypeGroup;
	
begin

	if self.myRoot = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'reference to root', null, null);
		app.raiseCMException(Input_required_field_refrToRoo, null, null); // cnwdb2	PAR 35364
		return;
	endif;

	//check no duplicate names or abbreviations
	iter := self.myRoot.allEventTypeGroups.createIterator();
	while iter.next(eventGroup) do
		if (eventGroup.name = self.name) or
			(eventGroup.description = self.description) then
			//app.raiseCMException2(DuplicateItem, 'Name or Description', 'another Item', null, null);  //13.06.2022 navds20 53760
			// Name or Description already exists for another Item : Name_descr_alrea_exist_anoth_i
			app.raiseCMException(Name_descr_alrea_exist_anoth_i, null, null); //13.06.2022 navds20 53760
			return;
		endif;
	endwhile;
	
	if self.myRoot.allEventTypeGroups[self.name] &lt;&gt; null then
		app.raiseCMException2(VB_DUPLICATED_ITEM, self.name.String, 'Name', null, null);
	endif;

	self.validateForUpdate();
epilog
	delete iter;
	
end;</source>
    </JadeMethod>
