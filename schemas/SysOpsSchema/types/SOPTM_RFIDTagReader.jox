    <JadeMethod name="doCmbAreasClick" id="a70dd712-b87f-4357-87d1-9894e0240f89">
        <source>doCmbAreasClick();
/*
----------   ----------  --------------------------------------------------
Created:	01 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	ta				: CM_TerminalArea;
	rfidTagReader	: CM_RFIDTagReader;
	row				: CM_GridRow;
	lane			: CM_LaneController;
	allLanes		: CM_ObjectArray;
	context			: Integer;
	assistant		: CMUI_Assistant;
begin
	assistant	:= self.myForm.myAssistant;
	context 	:= assistant.getSelectedContext (self.myForm.cmbReaderContext);
		
	if context = TagReaderContext_LaneDevice then
		ta := self.myForm.cmbGateArea.listObject.CM_TerminalArea;
		
		if ta = null then 
			self.myForm.cmbGateLane.clear;
			self.myForm.tblInput1.setValueByName (ETRow_RfidReadAssign, null);
			return;
		endif;
		
		if ta.isYardInterchangeArea then
			self.myForm.tblInput1.setValueByName (ETRow_RfidReadAssign, app.getErrorString (XLAT_RFID_Read));	// 24/02/2010 - changed default to read not assign
		endif;
		
		create allLanes transient;
		
		ta.CM_AreaWithLanes.getAllLaneControllers (allLanes); 
			
		assistant.comboBoxLocationControllers(self.myForm.cmbGateLane, allLanes, false);
	endif;
	
epilog
	delete allLanes;
end;


</source>
    </JadeMethod>
