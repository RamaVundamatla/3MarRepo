    </JadeMethod>
    <JadeMethod name="trxCreateProformaInvoiceLines" id="42c839c0-db5c-42f0-92be-d42df9b06268">
        <updating/>
        <source>trxCreateProformaInvoiceLines(	_transactionTypes : IntegerArray;
								_cargoItem : CM_TrackedItem input;
								_children : CM_TISet;
								_endDate : Date;
								_releaseDate : Date;
								_lineTrxTypes : IntegerArray io;
								_passport : CM_Passport input
								) : CM_InvoiceLineBySeqNumDict updating;
// CCMS 1280 - proforma invoicing for cash processing
vars
	lines : CM_InvoiceLineBySeqNumDict;
	childLines	: CM_InvoiceLineBySeqNumDict;
	child	: CM_TrackedItem;
	tiUpdateCntrlr 	: CMIF_TIUpdateController;
	realTI : CM_TrackedItem;
	line : CM_InvoiceLine;
begin
	// we are going to abort this, so do a limited pre-transaction setup
	app.setServerTimestampAtTrxStart(null); // ### TFS 52639 21Mar2022 NAVPW1
	
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(true);
	_passport.initialiseTransaction();	
	
	
	if _transactionTypes = null or
	   _cargoItem = null then
		return null;
	endif;
	
	beginTransaction;
	
	//if pxy item passed in update ti from pxy - done when pxy ti is updated from a Gate Receival Entity
	if _cargoItem.isTransient then
		// get real ti
		tiUpdateCntrlr := app.createTIUpdateControl( TI_UPDMODE_RECEIPT, _passport.userCode, null );
		_cargoItem.validateTrackedItem(tiUpdateCntrlr,_passport );
		realTI:=_cargoItem.myTerminal.createTrackedItem(_cargoItem, _passport);
		if _passport.hasErrors or realTI = null then	//25 Sep 2013	NDL	Par 32557
			return null;
		endif;
	else
		realTI :=_cargoItem;
	endif;
	
	app.setIsInProformaMode( true );

	//20 Dec 2012	NDL	Par 30901
	if _lineTrxTypes &lt;&gt; null then
		_lineTrxTypes.clear();
	endif;
	lines := app.myUtilityCA.utlCreateProformaInvoiceLines(_transactionTypes, realTI, _endDate, _releaseDate, _lineTrxTypes, _passport);
	// 34917 include children directly if needed
	if _children &lt;&gt; null then
		foreach child in _children do
			childLines := app.myUtilityCA.utlCreateProformaInvoiceLines(_transactionTypes, child, _endDate, _releaseDate, _lineTrxTypes, _passport);
			childLines.copy(lines);
			delete childLines;
		endforeach;
	endif;
	
	return lines;
	
epilog
	delete tiUpdateCntrlr;
	delete childLines;
	app.setIsInProformaMode( false );
	abortTransaction;
	
end;
</source>
        <Parameter name="_transactionTypes" type="IntegerArray"/>
        <Parameter name="_cargoItem" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_children" type="CM_TISet"/>
        <Parameter name="_endDate" type="Date"/>
        <Parameter name="_releaseDate" type="Date"/>
        <Parameter name="_lineTrxTypes" type="IntegerArray" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_InvoiceLineBySeqNumDict"/>
    </JadeMethod>
    <JadeMethod name="trxCreateProformaPaymentWO" id="2df1e227-88bc-4d3a-935a-e6bff353f652">
        <updating/>
        <source>trxCreateProformaPaymentWO(_controller : CMIF_ProformaWOController input; _comments : String; _passport : CM_Passport input) updating;
/*
Purpose:			 // TFS 38524 - PELINDO ONLY, BESPOKE TO RUN FROM WEB SERVICE
Date			Who			Reason
MAY 2018		JLGAB1		Initial creation
06/08/2019		jlgdap1		TFS 45853 PEL1 Additional Fees Cash Receipt doesn't show correct invoice type
16 Oct 2019 	cnwma1		Bug 46974: JMT - Auditing Transients while creating Proforma
15 Jan 2024		jlirs1		TFS 60575 - Jade 2022 upgrade fixing unitTests
23 Oct 2024		navlw1		JIRA-33107: Invoice Logging Use Levels
25 Feb 2025		navah1		Story 34141: MTN - Performance Improvements - Review for invLog() Methods
20/06/2025		navcs2		MTN-34987
*/
vars
	lines, 
	tmpLines 		       : CM_InvoiceLineBySeqNumDict;
	line 			       : CM_InvoiceLine;
	existingCashReceipt    : CM_CashReceipt;
	voyage 				   : CM_Voyage;
	workOrder 			   : CM_WorkOrder;
	proformaLinesDebtor    : CMIF_ProformaInvLinesForDebtor;
	paymentType 		   : Integer;
	additionalLineDebtor   : CMIF_ProformaInvLinesForDebtor;	//07 May 2019	NDL	TFS 44651
	additionalInvoiceLinez : CM_InvoiceLineBySeqNumDict; 
	proformaAgentWO 	   : CM_CashProformaWorkOrderAgent;
	transientArray 		   : ObjectArray;
	
	addInvoiceLinesNorm : CM_InvoiceLineBySeqNumDict;	    //10 Jun 2019	NDL	TFS 45017 
	addInvoiceLinesSeparated : CM_InvoiceLineBySeqNumDict;	//10 Jun 2019	NDL	TFS 45017 
	canLogExtra			   : Boolean;						//28.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//28.02.2025 navah1	#34141
	// we are going to abort this, so do a limited pre-transaction setup
	app.setServerTimestampAtTrxStart(null); // ### TFS 52639 21Mar2022 NAVPW1
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	app.setContinueCMExceptions(true);
	_passport.initialiseTransaction();	
	
	if _controller = null then
		return;
	endif;
	
	
	
	// TFS 39803
	if app.myAA &lt;&gt; null then
		app.myAA.initialiseAudit();
	endif;
	
	workOrder := _controller.myWorkOrder;
	
	if workOrder = null then
		return;
	endif;
	
	
	// ### Check the status on certain work order types 
	 if not workOrder.canCreateCashReceipt() then
		return;
	endif;
	
	
	// ### // TFS 39507 If not Pelindo then we do not re do the estimate
	existingCashReceipt := workOrder.allCashReceipts.first();
	if existingCashReceipt &lt;&gt; null then
		if workOrder.myTerminal.isUsingDefaultProcessJMT() then
			return;
		endif;
	endif;
	
	/*  // ### TFS 51924 08SEP2021 NAVAB1 - Cash is not configured for the work order estimates. SO do not need to check if have cash module in license.
	// TFS 39507 only for cash
	if not workOrder.myTerminal.getConfig(CashProcessingEnabled).Boolean then
		app.invLog("Cash is not enabled in your terminal");
		return;
	endif;
	*/
	
	// ### GET THE PROFORMA INVOICE LINES
	beginTransaction;
	
	app.setIsInProformaMode( true );
	
	create tmpLines transient;		// 15 Jan 2024	jlirs1	TFS 60575 - Jade 2022 upgrade fixing unitTests

	app.myUtilityCA.utlCreateProformaPaymentWO(_controller, _passport, tmpLines);

	app.setIsInProformaMode( false );
	
	
	if tmpLines &lt;&gt; null then // TFS 42221
	
		// TFS 41281 set payment type on the line whilst we still have the supporting transactions.
		//						we are about to abort and lose the transactions on the invoice line.
		foreach line in tmpLines do
				paymentType := line.getProformaPaymentType(); 
	//			line.setPropertyValue(CM_InvoiceLine::overriddenChargeCount.name, paymentType);
				line.setProformaPaymentType(paymentType);
	
		endforeach;
	endif;

	abortTransaction; 
	app.setIsInProformaMode( false );     //16.10.2019 cnwma1 #46974
	
	if tmpLines = null or tmpLines.isEmpty then
		if canLogExtra then	//28.02.2025 navah1	#34141
			app.invLog("No Proforma Lines Were created", LogINFO.String);
		endif;
		return;
	endif;
	
	create lines transient;
	foreach line in tmpLines discreteLock do : outerloop
		lines.add(line);
	endforeach;
	if lines = null or lines.isEmpty then
		return;
	endif;
	if canLogExtra then	//28.02.2025 navah1	#34141
		app.invLog(method.qualifiedName &amp; " Proforma Lines Found - " &amp; lines.size.String, LogTRACE.String); // LOG CASH
	endif;
		
	// sort the invoice lines by debtor and invoice type
	_controller.sortProformaLines(lines);
	
	voyage := workOrder.getMyVoyageObject();

	beginTransaction;
	// ### // TFS 39507 If  Pelindo then we re do the estimate by deleting the estimate
	// TFS 39349 Each time a work order is saved we need to re do the cash
	foreach existingCashReceipt in workOrder.allCashReceipts do
		if canLogExtra then	//28.02.2025 navah1	#34141
			app.invLog(method.qualifiedName &amp; " Deleting Existing Cash Receipts - " &amp; existingCashReceipt.sequenceNum.String, LogTRACE.String); // LOG CASH
		endif;
		app.myUtilityDA.utlDeleteCashReceipt(existingCashReceipt);
	endforeach;

	if app.myPassport.hasErrors then
		if canLogExtra then	//28.02.2025 navah1	#34141
			app.invLog(method.qualifiedName &amp; " Errors/Warnings ", LogTRACE.String); // LOG CASH
		endif;
		return;
	endif;
	
	create additionalInvoiceLinez transient;
	create addInvoiceLinesNorm transient;	//10 Jun 2019	NDL	TFS 45017 	
	create addInvoiceLinesSeparated transient;	//10 Jun 2019	NDL	TFS 45017 
	
	// TFS 39349 #### for each debtor and invoice type we create a cash receipt
	foreach proformaLinesDebtor in _controller.allProformaInvLineDebtor	discreteLock do
		proformaLinesDebtor.myWorkOrder := workOrder;
		proformaLinesDebtor.myVoyage := voyage;
	
	//	proformaLinesDebtor.myInvoiceType.getSurcharges(proformaLinesDebtor.allInvoiceLines, proformaLinesDebtor.myDebtor,voyage);
	
		additionalInvoiceLinez.clear();
		proformaLinesDebtor.myInvoiceType.getSurcharges( proformaLinesDebtor, proformaLinesDebtor.allInvoiceLines, additionalInvoiceLinez ); //17 Dec 2018	NDL	TFS 42577 &amp; 18 Dec
		
		proformaLinesDebtor.addSurcharges(); // TFS 41684
		
		//07 May 2019	NDL	TFS 44651
		if additionalInvoiceLinez.size &gt; 0 then
		
			//10 Jun 2019	NDL	TFS 45017 - split the surcharge lines based on the 'taxAlwaysCharged' field to decide whether they are on the 
			// original Cash Receipt or split off to a new one.
			addInvoiceLinesNorm.clear();	
			addInvoiceLinesSeparated.clear();
			if workOrder.isTaxExempt and proformaLinesDebtor.myInvoiceType.mySurchargeAndExemptions.myInvoiceDescForSeperateTax &lt;&gt; null then
				foreach line in additionalInvoiceLinez do
					if line.invoiceLineDesc.taxAlwaysCharged then
						addInvoiceLinesSeparated.add( line );
					else
						addInvoiceLinesNorm.add( line );
					endif;
				endforeach;
			else
				additionalInvoiceLinez.copy( addInvoiceLinesNorm );
			endif;
		
			if not addInvoiceLinesSeparated.isEmpty then
				//create new proforma for separated always taxed surcharge lines
				if transientArray = null then
					create transientArray transient;
					if canLogExtra then	//28.02.2025 navah1	#34141
						app.invLog("Work Order is Tax Exempt, so creating separate Receipt for 'Additional Fee lines' that are always taxed", LogINFO.String);
					endif;
				endif;
				
				create additionalLineDebtor transient;
				transientArray.add( additionalLineDebtor );
				
				additionalLineDebtor.myWorkOrder := workOrder;
				additionalLineDebtor.myVoyage := voyage;	//21 May 2019	NDL	tFS 44651
				additionalLineDebtor.myInvoiceType:=proformaLinesDebtor.myInvoiceType.mySurchargeAndExemptions.myInvoiceDescForSeperateTax;
				additionalLineDebtor.myDebtor:=proformaLinesDebtor.myDebtor;
				additionalLineDebtor.paymentType:=proformaLinesDebtor.paymentType;
				additionalLineDebtor.isAdditionalTax := true;								// TFS 45853
				
				create proformaAgentWO transient;
				transientArray.add( proformaAgentWO );
				
				additionalLineDebtor.allProformaAgents.add(proformaAgentWO);
				additionalLineDebtor.addAdditionalCharges(addInvoiceLinesSeparated);
				app.myUtilityCA.utlCreateProformaReceiptWO(additionalLineDebtor);
			endif;
			
			if not addInvoiceLinesNorm.isEmpty then
				proformaLinesDebtor.addAdditionalCharges(addInvoiceLinesNorm);
			endif;
			
		endif;
		
		app.myUtilityCA.utlCreateProformaReceiptWO(proformaLinesDebtor);
	endforeach;
	
	//epr TFS 43260 5/2/19
	//if _controller.createSAPRequest then			20/06/2025		navcs2		MTN-34987
		//workOrder.processSAPRequest(false);		20/06/2025		navcs2		MTN-34987
	//endif;										20/06/2025		navcs2		MTN-34987
	
epilog

	app.setIsInProformaMode( false ); //to be sure could get exception in app.myUtilityCA.utlCreateProformaPaymentWO and would be stuck in proforma mode
	if lines &lt;&gt; null then
		lines.purge();
	endif;
	delete lines;
	if tmpLines &lt;&gt; null then
		tmpLines.purge();
	endif;
	delete tmpLines;
	delete additionalInvoiceLinez;
	if transientArray &lt;&gt; null then
		transientArray.purge;
		delete transientArray;
	endif;
	
	delete addInvoiceLinesNorm;	
	delete addInvoiceLinesSeparated;
	
	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_controller" type="CMIF_ProformaWOController" usage="input"/>
        <Parameter name="_comments" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCreateProformaWithResync" id="00daa205-5ba0-4f18-9dd0-d0009b13b2c2">
        <updating/>
        <source>trxCreateProformaWithResync(	_transactionTypes : IntegerArray;
								_cargoItem : CM_TrackedItem input;
								_endDate : Date;
								_releaseDate : Date; // TFS 44275
								_debtor : CM_Debtor;
								_agent : CM_Object;			// consignee, consignor, customs agent
								_allCurrentLines : CM_InvoiceLineSet input;
								_allProformaLines : CM_InvoiceLineSet input;
								_passport : CM_Passport input
								) updating;
								
// CCMS 2368 - proforma invoicing for regular non-cash invoicing
vars
	lineTrxTypes : IntegerArray;
	lines : CM_InvoiceLineBySeqNumDict;
	realTI : CM_TrackedItem;
	line : CM_InvoiceLine;
begin
	// we are going to abort this, so do a limited pre-transaction setup
	app.setServerTimestampAtTrxStart(null); // ### TFS 52639 21Mar2022 NAVPW1
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	app.setContinueCMExceptions(true);
	_passport.initialiseTransaction();	
	
	if _transactionTypes = null or
	   _cargoItem = null then
		return;
	endif;
	
	beginTransaction;
	
	realTI :=_cargoItem;
	
	app.setIsInProformaMode( true );

	app.myUtilityCA.utlCreateProformaWithResync(_transactionTypes, realTI, _endDate, _releaseDate, _debtor, _agent, _allCurrentLines, 
																			_allProformaLines, _passport);
	
epilog

	app.setIsInProformaMode( false );
	abortTransaction;
	
end;
</source>
        <Parameter name="_transactionTypes" type="IntegerArray"/>
        <Parameter name="_cargoItem" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_endDate" type="Date"/>
        <Parameter name="_releaseDate" type="Date"/>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <Parameter name="_agent" type="CM_Object"/>
        <Parameter name="_allCurrentLines" type="CM_InvoiceLineSet" usage="input"/>
        <Parameter name="_allProformaLines" type="CM_InvoiceLineSet" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
