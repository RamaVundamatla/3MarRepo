    <JadeMethod name="tCoparnANL" id="eff240f6-bb3e-4612-bc9d-236f5357716c">
        <updating/>
        <source>tCoparnANL() updating;
//
// cnwrs1 TFS 3116
// 09 Mar 2017	cnwrs1	TFS3116 only match on a release item once
//
constants
	ShipName = "CCMS1913";//Was MAERSK DUNFARE
	VoyageName = "CCMS1913VOY";
	RELEASE1 = 'ACD0278846';
	RELEASE2 = 'ACD0281728';
	RELEASE3 = 'ACD0282044';
	OPERATOR = 'ANL';
	SENDER1	= 'ANLCOPARN';
	SENDER2 = 'ANL';
	PARTY1 = 'Anl Coparn Unit Tests';
	PARTY2 = 'Anl Coparn Unit Tests2';
	PARTY3 = 'Anl Coparn Unit Tests3';
vars
	vessel: CM_Vessel;
	voyage: CM_Voyage;
	ediFile : CM_EDIFile;
	releaseReq : CM_BulkRelease;
	releaseItem : CM_ReserveDetail;
	text : String;
	releaseItems : Integer;
	tempStr : String;
	operator : CM_Operator;
	code : String;
	ediParty : CM_EDIParty;
	rules : CM_EDIPartyCoparnRules;
	ts1	: TimeStamp;
	ts2	: TimeStamp;
begin
	// disable cutoffs - they can stop a loadDB 
	self.disableAllEDIVoyageCutoffs;
	code := self.getTerminal.code;
	self.deleteReleaseRequest(RELEASE1); 
	self.deleteReleaseRequest(RELEASE2); 
	self.deleteReleaseRequest(RELEASE3); 
	self.deleteVoyage(VoyageName);
	self.deleteVessel(ShipName);
	operator := self.getOperator (OPERATOR);
	self.assertNotNullMsg (operator, 'Operator '&amp;OPERATOR&amp;' does not exist');
	self.deleteEDIInwardXlation ('GP', XLATION_TYPE_MTGRADE_BYOP, operator, null);
	self.deleteEDIOutwardXlation (0.String, XLATION_TYPE_MTGRADE_BYOP, operator, null);

//	self.createEDIXlation ('GP', 0.String, XLATION_TYPE_MTGRADE_BYOP, true, operator, null);
//	self.createEDIXlation ('DAIRY', 1.String, XLATION_TYPE_MTGRADE_BYOP, true, operator, null);
//	if not self.createEDIXlation ('5049000221', CONSIGNEE, XLATION_TYPE_CONSIGNEE_BYOP, true, operator, null) then
//		self.assertEqualMsg (1, 2, 'Consignor xlation could not be created');
//	endif;	
	 
//	if not self.createEDIXlation ('5046240346', CONSIGNEE, XLATION_TYPE_CONSIGNEE_BYOP, true, operator, null) then
//		self.assertEqualMsg (1, 2, 'Consignor xlation could not be created');
//	endif;	
	// makes sure the operator can use ALL availability grades
	beginTransaction;
	self.clearOperatorCodeGroups (operator, CodeGroup_AvailabilityGrade);
	commitTransaction;
	// this voyage will be used in most files
	self.createVesselVoyage(VoyageName, ShipName, operator);
	self.deleteEDIParty(PARTY2);
	self.deleteEDIParty(PARTY3);
	ediParty := self.createEDIPartyAndRules('UT_HOLD' &amp; code, 'UT_HOLD' &amp; code, PARTY1, PARTY1, SENDER1, SENDER2, operator, false);
	rules := ediParty.getRulesForFileType(EDIFileType_Coparn).CM_EDIPartyCoparnRules;
	// change voyafge arrival/departure dates so we don't get cutoff errors
	voyage := self.getVoyage(VoyageName);
	if voyage &lt;&gt; null then
		ts1.setDate (ts1.date+7);
		beginTransaction;
		voyage.setArrivalDT (ts1);
		voyage.setDepartureDT (null);
		commitTransaction;
	endif;
	ts1 := app.actualTimeServer;// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
	ts2 := app.actualTimeServer;// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
	ts1.setDate(ts1.date-2);
	ts1.setTime('09:00'.Time);
	ts2.setDate(ts1.date+1);
	ts2.setTime('15:00'.Time);
	self.setTerminalConfig(EdiReleaseAllowPartial, false);
	self.setTerminalConfig(EdiBookingAllowPartial, false);

		text :=
"UNB+UNOA:2+ANL+NZOTAGO+161123:1947+RLO1969992++COPARN'
UNH+1+COPARN:D:03A:UN'
BGM+12+ACD0278846+9'
DTM+137:201611231947:203'
RFF+BN:ACD0278846'
TDT+20+CCMS1913VOY+1++ANL+++9445526:::CCMS1913'
LOC+9+NZPOE:139:6'
LOC+11+NZTRG'
NAD+MS+ANL'
NAD+MR+:160:87'
EQD+CN++2230+++4'
EQN+1'
MEA+AAE+EGW+KGM:46020'
TMP+5+12.0:CEL'
FTX+AAA+++CHOC'
FTX+QQD++1'
EQD+CN++45R1+++4'
EQN+6'
MEA+AAE+EGW+KGM:24700'
TMP+5+12.0:CEL'
FTX+AAA+++CHOC'
FTX+QQD++1'
EQD+CN++2230+++4'
EQN+1'
MEA+AAE+EGW+KGM:46020'
TMP+5+12.0:CEL'
FTX+AAA+++CHOC'
FTX+QQD++1'
UNT+28+1'
UNH+2+COPARN:D:03A:UN'
BGM+12+ACD0281728+9'
DTM+137:201611231947:203'
RFF+BN:ACD0281728'
TDT+20+CCMS1913VOY+1++ANL+++9445526:::CCMS1913'
LOC+9+NZPOE:139:6'
LOC+11+NZTRG'
NAD+MS+ANL'
NAD+MR+:160:87'
EQD+CN++22G0+++4'
EQN+3'
MEA+AAE+EGW+KGM:17230'
FTX+AAA+++CHOC'
FTX+QQD++1'
UNT+15+2'
UNH+3+COPARN:D:03A:UN'
BGM+12+ACD0282044+9'
DTM+137:201611231947:203'
RFF+BN:ACD0282044'
TDT+20+CCMS1913VOY+1++ANL+++9445526:::CCMS1913'
LOC+9+NZPOE:139:6'
LOC+11+NZTRG'
NAD+MS+ANL'
NAD+MR+:160:87'
EQD+CN++22G0+++4'
EQN+3'
MEA+AAE+EGW+KGM:17230'
FTX+AAA+++CHOC'
FTX+QQD++1'
UNT+15+3'
UNZ+3+RLO1969992'
EOF";

	ediFile := self.ediLoadFileName(text, EDIFileType_Unknown, "COPARN", "COPARN"&amp;method.name);
	self.assertNotNull(ediFile);
	self.ediVerify(ediFile);
	tempStr	:= 'Verify failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, tempStr);
	self.ediDBLoad(ediFile);
	tempStr	:= 'DB Load failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	releaseReq := self.getReleaseRequest(RELEASE1);
	self.assertNotNull(releaseReq);
	releaseItems := releaseReq.allReserveDetails.size;
	self.assertEqual(releaseItems, 3);
	self.assertEqual(releaseReq.totalRequested, 8);
	releaseReq := self.getReleaseRequest(RELEASE2);
	self.assertNotNull(releaseReq);
	releaseItems := releaseReq.allReserveDetails.size;
	self.assertEqual(releaseItems, 1);
	self.assertEqual(releaseReq.totalRequested, 3);
	releaseReq := self.getReleaseRequest(RELEASE3);
	self.assertNotNull(releaseReq);
	releaseItems := releaseReq.allReserveDetails.size;
	self.assertEqual(releaseItems, 1);
	self.assertEqual(releaseReq.totalRequested, 3);
end;
</source>
        <text>MTN-36111</text>
    </JadeMethod>
    <JadeMethod name="tCoparnANL2" id="13fe3e05-a9ce-4666-bc3b-f1b39a3afca4">
        <updating/>
        <source>tCoparnANL2() updating;
//
// cnwrs1 TFS 3116
// 09 Mar 2017	cnwrs1	TFS3116 only match on a release item once
//
constants
	ShipName = "CCMS1913";//Was MAERSK DUNFARE
	VoyageName = "CCMS1913VOY";
	RELEASE1 = 'ACD0278846';
	RELEASE2 = 'ACD0281728';
	RELEASE3 = 'ACD0282044';
	OPERATOR = 'ANL';
	SENDER1	= 'ANLCOPARN';
	SENDER2 = 'ANL';
	PARTY1 = 'Anl Coparn Unit Tests';
	PARTY2 = 'Anl Coparn Unit Tests2';
	PARTY3 = 'Anl Coparn Unit Tests3';
vars
	vessel: CM_Vessel;
	voyage: CM_Voyage;
	ediFile : CM_EDIFile;
	releaseReq : CM_BulkRelease;
	releaseItem : CM_ReserveDetail;
	text : String;
	releaseItems : Integer;
	tempStr : String;
	operator : CM_Operator;
	code : String;
	ediParty : CM_EDIParty;
	rules : CM_EDIPartyCoparnRules;
	ts1	: TimeStamp;
	ts2	: TimeStamp;
	previousLogLevel : Integer;
begin
	previousLogLevel := app.logLevel;
//	app.changeLogLevel(LogTRACE);

	// disable cutoffs - they can stop a loadDB 
	self.disableAllEDIVoyageCutoffs;
	code := self.getTerminal.code;
	self.deleteReleaseRequest(RELEASE1); 
	self.deleteReleaseRequest(RELEASE2); 
	self.deleteReleaseRequest(RELEASE3); 
	self.deleteVoyage(VoyageName);
	self.deleteVessel(ShipName);
	operator := self.getOperator(OPERATOR);
	self.assertNotNullMsg(operator, 'Operator '&amp;OPERATOR&amp;' does not exist');
	self.deleteEDIInwardXlation('DAIRY', XLATION_TYPE_MTGRADE_BYOP, operator, null);
	self.deleteEDIOutwardXlation(1.String, XLATION_TYPE_MTGRADE_BYOP, operator, null);

//	self.createEDIXlation ('GP', 0.String, XLATION_TYPE_MTGRADE_BYOP, true, operator, null);
	self.createEDIXlation('DAIRY', 1.String, XLATION_TYPE_MTGRADE_BYOP, true, operator, null);
//	if not self.createEDIXlation ('5049000221', CONSIGNEE, XLATION_TYPE_CONSIGNEE_BYOP, true, operator, null) then
//		self.assertEqualMsg (1, 2, 'Consignor xlation could not be created');
//	endif;	
	 
//	if not self.createEDIXlation ('5046240346', CONSIGNEE, XLATION_TYPE_CONSIGNEE_BYOP, true, operator, null) then
//		self.assertEqualMsg (1, 2, 'Consignor xlation could not be created');
//	endif;	
	// makes sure the operator can use ALL availability grades
	beginTransaction;
	self.clearOperatorCodeGroups(operator, CodeGroup_AvailabilityGrade);
	commitTransaction;
	// this voyage will be used in most files
	self.createVesselVoyage(VoyageName,ShipName,  operator);
	self.deleteEDIParty(PARTY1);
	self.deleteEDIParty(PARTY3);
	ediParty := self.createEDIPartyAndRules('UT_HOLD' &amp; code, 'UT_HOLD' &amp; code, PARTY2, PARTY2, SENDER1, SENDER2, operator, false);
	rules := ediParty.getRulesForFileType(EDIFileType_Coparn).CM_EDIPartyCoparnRules;
	// change voyafge arrival/departure dates so we don't get cutoff errors
	voyage := self.getVoyage(VoyageName);
	if voyage &lt;&gt; null then
		ts1.setDate (ts1.date+7);
		beginTransaction;
		voyage.setArrivalDT (ts1);
		voyage.setDepartureDT (null);
		commitTransaction;
	endif;
	ts1 := app.actualTimeServer;// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
	ts2 := app.actualTimeServer;// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
	ts1.setDate(ts1.date-2);
	ts1.setTime('09:00'.Time);
	ts2.setDate(ts1.date+1);
	ts2.setTime('15:00'.Time);
	self.setTerminalConfig(EdiReleaseAllowPartial, false);
	self.setTerminalConfig(EdiBookingAllowPartial, false);

		text :=
"UNB+UNOA:2+ANL+NZOTAGO+161123:1947+RLO1969992++COPARN'
UNH+1+COPARN:D:03A:UN'
BGM+12+ACD0278846+9'
DTM+137:201611231947:203'
RFF+BN:ACD0278846'
TDT+20+CCMS1913VOY+1++ANL+++9445526:::CCMS1913'
LOC+9+NZPOE:139:6'
LOC+11+NZTRG'
NAD+MS+ANL'
NAD+MR+:160:87'
EQD+CN++2230+++4'
EQN+1'
MEA+AAE+EGW+KGM:46020'
TMP+5+12.0:CEL'
FTX+AAA+++CHOC'
FTX+ZZZ+++DAIRY'
EQD+CN++45R1+++4'
EQN+6'
MEA+AAE+EGW+KGM:24700'
TMP+5+12.0:CEL'
FTX+AAA+++CHOC'
FTX+ZZZ+++1'
EQD+CN++2230+++4'
EQN+1'
MEA+AAE+EGW+KGM:46020'
TMP+5+12.0:CEL'
FTX+AAA+++CHOC'
FTX+ZZZ+++DAIRY'
UNT+28+1'
UNH+2+COPARN:D:03A:UN'
BGM+12+ACD0281728+9'
DTM+137:201611231947:203'
RFF+BN:ACD0281728'
TDT+20+CCMS1913VOY+1++ANL+++9445526:::CCMS1913'
LOC+9+NZPOE:139:6'
LOC+11+NZTRG'
NAD+MS+ANL'
NAD+MR+:160:87'
EQD+CN++22G0+++4'
EQN+3'
MEA+AAE+EGW+KGM:17230'
FTX+AAA+++CHOC'
FTX+ZZZ+++DAIRY'
UNT+15+2'
UNH+3+COPARN:D:03A:UN'
BGM+12+ACD0282044+9'
DTM+137:201611231947:203'
RFF+BN:ACD0282044'
TDT+20+CCMS1913VOY+1++ANL+++9445526:::CCMS1913'
LOC+9+NZPOE:139:6'
LOC+11+NZTRG'
NAD+MS+ANL'
NAD+MR+:160:87'
EQD+CN++22G0+++4'
EQN+3'
MEA+AAE+EGW+KGM:17230'
FTX+AAA+++CHOC'
FTX+ZZZ+++DAIRY'
UNT+15+3'
UNZ+3+RLO1969992'
EOF";

	ediFile := self.ediLoadFileName(text, EDIFileType_Unknown, "COPARN", "COPARN"&amp;method.name);
	self.assertNotNull(ediFile);
	self.ediVerify(ediFile);
	tempStr	:= 'Verify failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, tempStr);
	self.ediDBLoad(ediFile);
	tempStr	:= 'DB Load failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	releaseReq := self.getReleaseRequest(RELEASE1);
	self.assertNotNull(releaseReq);
	releaseItems := releaseReq.allReserveDetails.size;
	self.assertEqual(releaseItems, 3);
	self.assertEqual(releaseReq.totalRequested, 8);
	self.assertEqual(releaseReq.allReserveDetails.first.getAvailabilityGradesIntegers.String, '1'.String);
	releaseReq := self.getReleaseRequest(RELEASE2);
	self.assertNotNull(releaseReq);
	releaseItems := releaseReq.allReserveDetails.size;
	self.assertEqual(releaseItems, 1);
	self.assertEqual(releaseReq.totalRequested, 3);
	releaseReq := self.getReleaseRequest(RELEASE3);
	self.assertNotNull(releaseReq);
	releaseItems := releaseReq.allReserveDetails.size;
	self.assertEqual(releaseItems, 1);
	self.assertEqual(releaseReq.totalRequested, 3);
epilog
	app.changeLogLevel(previousLogLevel);
end;
</source>
