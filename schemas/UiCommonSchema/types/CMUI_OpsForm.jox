    <JadeMethod name="resortTblWorkEntries" id="9b01c5f4-b2fd-4584-ac10-819d1d930a13">
        <source>resortTblWorkEntries();
//--------------------------------------------------------------
//Created: 01 May 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	obj : Object;
	wle : CM_WorkListEntry;
	idx,
	rtCol,
	rows : Integer;
begin

	if self.tblWorkEntries.row &lt;&gt; 1 then
		return;
	endif;

	self.tblWorkEntries.resortTableByColumn(self.tblWorkEntries.column);
	rows := self.tblWorkEntries.rows;
	rtCol := self.tblWorkEntries.getColumnByRowName(ETRow_RadioTelemetry);	
	
	foreach idx in 2 to rows do
		obj := self.tblWorkEntries.accessRow(idx).itemObject;
		if obj &lt;&gt; null and obj.isKindOf(CM_WorkListEntry) then
			wle := obj.CM_WorkListEntry;
		endif;
		self.tblWLESetRowColour(wle, idx, rtCol);
		wle := null;
	endforeach;	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="returnWorkEntry" id="79fd712d-1f6e-4870-9189-10c6488c103d">
        <updating/>
        <source>returnWorkEntry()updating;
//--------------------------------------------------------------
//Created: 11 April 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	result : Integer;
begin

	app.mousePointer := MousePointer_HourGlass;
		
	if self.myCurrentWLE = null then
		return;
	endif;
	
	while true do
		app.myTrxUA.trxUpdateWLEReturnWorkEntry(self.myCurrentWLE, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog('Return Work Entry', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;
				
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="selectISOSource" id="b0fe0f7d-7114-4bda-8e19-597b329562d5">
        <source>selectISOSource();
// ---------------------------------------------------------------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	sourceForm	: CMUI_SelectISOSource;
begin

	if self.myCurrentWLE = null or 
	   (not self.myCurrentWLE.myRequest.isKindOf(CM_DeliveryRequest)) then
		return;
	endif;
	
	sourceForm := app.loadForm(CMUI_SelectISOSource, CMUI_Assistant, false, false, true, self.myTerminal, self.myMasterMenuAction).CMUI_SelectISOSource;
	// Update the navigator
	//self.myMasterMenuAction.setHeading(self.myCurrentWLE.id.trimBlanks &amp; " Select ISO Source"); 

	sourceForm.centreWindow;
	// cnwsb1 14 May 2003 - CM_BaseForm::showModal() now sets isModal:
	// sourceForm.isModal := true;
	sourceForm.setMyTerminal(self.myTerminal);
	sourceForm.myCurrentWLE := self.myCurrentWLE;
	sourceForm.myDeliveryRequest := self.myCurrentWLE.myRequest.CM_DeliveryRequest;

	sourceForm.showModal;


end;</source>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="2868bf31-1bf7-48ad-bdec-ca89a6450631">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
// ---------------------------------------------------------------------------
// Created:     30 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpBackColor	: Integer;

begin
	inheritMethod(_colorControl);

	tmpBackColor := self.backColor;
	
	self.fldInfo.backColor			:= tmpBackColor;
	
	self.frmGridArea.backColor		:= tmpBackColor;
	self.frmLeftSplitter.backColor	:= tmpBackColor;
	self.frmLegend.backColor		:= tmpBackColor;
	self.frmModeStatusBar.backColor	:= tmpBackColor;
	self.frmReport.backColor		:= tmpBackColor;
	self.frmWLE.backColor			:= tmpBackColor;
	
	self.lstJobs.backColor			:= self.colorControlBack;
	
	self.shtInfo.backColor			:= tmpBackColor;
	self.shtTransportView.backColor	:= tmpBackColor;
	
	self.splExtraInfo.backColor		:= tmpBackColor;
	self.splFolder.backColor		:= tmpBackColor;
	self.splGridArea.backColor		:= tmpBackColor;
	self.splMain.backColor			:= tmpBackColor;
	self.splOperations.backColor	:= tmpBackColor;
	
	self.setColorsForTable(self.tblInfo);
	self.setColorsForTable(self.tblInfoSmall);
	self.setColorsForTable(self.tblWorkEntries);

	self.mySDF.backColor			:= Gray;
	
end;</source>
        <Parameter name="_colorControl" type="CM_ColorController"/>
    </JadeMethod>
    <JadeMethod name="setCurrentWLEFromXY" id="12f3df11-a0e4-4345-ba40-6fb89f4cc21f">
        <updating/>
        <source>setCurrentWLEFromXY(y : Real) updating;
// ---------------------------------------------------------------------------
// Created:     02 June 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theRow : Integer;
begin
	theRow := self.tblWorkEntries.getRowFromY(y);
	if theRow &gt; self.tblWorkEntries.fixedRows then
		self.myCurrentWLE := self.tblWorkEntries.accessRow(theRow).itemObject.CM_WorkListEntry;
	endif;
epilog

end;</source>
        <Parameter name="y" type="Real"/>
