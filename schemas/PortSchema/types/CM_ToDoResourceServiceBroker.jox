    <JadeMethod name="setForCreate" id="b6e18192-b812-4107-b805-9f5b263e12f8">
        <updating/>
        <source>setForCreate(_pxySB: SelfType) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15/05/2023	navkc1	CR 57927 Task 54268 - Transaction Map

*/

vars

begin
	inheritMethod(_pxySB);
	
	self.myResourceType 	:= _pxySB.myResourceType;
	self.myServiceBroker 	:= _pxySB.myServiceBroker;
	self.initialise(self.myServiceBroker.getBank());
epilog

end;</source>
        <Parameter name="_pxySB" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setResourceTypeAndBroker" id="0ce80378-f852-42a9-818f-3cc4c9dd4c2a">
