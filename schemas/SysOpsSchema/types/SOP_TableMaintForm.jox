    <JadeMethod name="doTableHandlePassword" id="387e385e-b6a6-49d4-8f35-95bc37aca245">
        <updating/>
        <source>doTableHandlePassword( _table : CM_EntryTable input; _newRow: Integer; _newCol: Integer ):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
25 August 2021		navndl1	Initial creation	TFS 51632
02 November 2023	navmd1	TFS 61072 Ignore EventStream as this generates its own (Basic) Auth Token instead
22 October 2024		navdap1	MTN-14005 NSW | OnePort Integration - Requested Changes
*/

vars

	rowIndex : Integer;
	proxy : CM_Object;
	encryptedPassword : String;
	isPasswordField : Boolean;
	updated : Boolean;
	config : CMIF_Config;
	configField : String;
	maxPwLength : Integer;  // The max length of the actual password, not the encrypted version

begin

	if self.mode = self.Mode_View then
		return false;
	endif;
	
	if self.myCurrentTableItem = null then
		return false;
	endif;

	rowIndex := _table.row;
	if _newRow &gt; 0 then
		rowIndex := _newRow;
	endif;

	if self.myCurrentTableItem.isKindOf(SOPTM_Boom)
	or self.myCurrentTableItem.isKindOf(SOPTM_SFTPEntity)
	or self.myCurrentTableItem.isKindOf(SOPTM_FTPEntity)
	or self.myCurrentTableItem.isKindOf(SOPTM_ExtWebService)
	//or self.myCurrentTableItem.isKindOf(SOPTM_EventStreamDefinition)
	then
		proxy := self.myProxyObject.CM_Object;
		if rowIndex = _table.getRowByName( ETRow_Password ) then
			isPasswordField := true;
			if self.myCurrentTableItem.isKindOf(SOPTM_SFTPEntity)
			or self.myCurrentTableItem.isKindOf(SOPTM_FTPEntity)
			or self.myCurrentTableItem.isKindOf(SOPTM_ExtWebService)
			then 
				maxPwLength := 30;
				// MTN-14005 API passwords are longer than 30 characters
				if self.tblInput1.myEntTableDef &lt;&gt; null and self.tblInput1.getRowByName(ETRow_BaseAuthEndpoint) &lt;&gt; null then
					maxPwLength := 64;
				endif;
			else
				// Boom and Event stream are max length in db, but the SOP_TableMaintForm restricted
				// these to 64 so we will leave it like this in case there is an external reason.
				maxPwLength := 64;
			endif;
			configField := ETRow_Password;
		elseif rowIndex = _table.getRowByName( ETRow_PassPhrase ) then		//06 Sep 2021	NDL	TFS 51165
			if self.myCurrentTableItem.isKindOf(SOPTM_SFTPEntity) then
				isPasswordField := true;
				configField := CM_SFTPEntity::passPhrase.name;
			endif;
		elseif rowIndex = _table.getRowByName( ETRow_MessagePassword ) then
			isPasswordField := true;
			configField := CM_KiwiRailCheckInWSDef::messagePassword.name;
		endif;
	elseif self.myCurrentTableItem.isKindOf(SOPTM_Terminal) then
		config := self.myCurrentTableItem.SOPTM_Terminal.myIntFaceConfig;
		if config &lt;&gt; null then
			if rowIndex = _table.getRowByName( ETRow_AutoPop3Password ) then
				maxPwLength := 64;  // same form restriction as above
				configField := ETRow_AutoPop3Password;
				isPasswordField := true;
			endif;
		endif;
	endif;
	
	if isPasswordField then
		encryptedPassword := self.myAssistant.showSetPassword( self.mode, proxy, config, configField, updated, maxPwLength );
		if updated then
			if configField = CM_SFTPEntity::passPhrase.name then	//06 Sep 2021	NDL	TFS 51165
				self.setEnteredPassword2(encryptedPassword);
				if encryptedPassword &lt;&gt; null then
					_table.setValueByName(ETRow_PassPhrase, '******');
				else
					_table.setValueByName(ETRow_PassPhrase, ' ');
				endif;
			elseif configField = CM_KiwiRailCheckInWSDef::messagePassword.name then
				self.setEnteredPassword2(encryptedPassword);
				if encryptedPassword &lt;&gt; null then
					_table.setValueByName(ETRow_MessagePassword, '******');
				else
					_table.setValueByName(ETRow_MessagePassword, ' ');
				endif;
			else
				self.setEnteredPassword(encryptedPassword);
				if encryptedPassword &lt;&gt; null then
					_table.setValueByName(ETRow_Password, '******');
				else
					_table.setValueByName(ETRow_Password, ' ');
				endif;
			endif;
		endif;
		return true;
	else
		return false;
	endif;
	


epilog

end;</source>
        <Parameter name="_table" type="CM_EntryTable" usage="input"/>
        <Parameter name="_newRow" type="Integer"/>
        <Parameter name="_newCol" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTblAddrDetails" id="bfdaa388-d4b0-49e1-b006-90c7b1ae27c8">
        <source>doTblAddrDetails();
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 15 June 2022
TFS#		: 53679
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

begin
	if self.myCurrentTableItem.isKindOf(SOPTM_DeliveryParty) then		
		self.myCurrentTableItem.SOPTM_DeliveryParty.tblAddrDetailsClick();
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doTblInput1Change" id="f10f8742-1d6d-467c-a9b2-cf6c2a2fbc19">
        <updating/>
        <source>doTblInput1Change(_table: CM_EntryTable input) updating;
//-----------------------------------------
// Created: Janurary 2008 By: cnwjo3
//-----------------------------------------
// 08/03/2012	cnwcs5	par 29158 - EDI cutoffs
// 14/11/2012	cnwdap1	PAR #30741 CCMS 2232 Display Resource Codes on Harbour View
// 06/12/2016	cnwdap1	TFS 3039 SNO Empty Container Pool Management
// 24/01/17 	cnwns1	TFS3153:PKT - Bulk Process - WeighBridge Integration
// 02/11/2023	navmd1	TFS 61072 - Handle manually entered Auth Token strings for Event Stream
vars
	
begin
	if _table.row &lt;= _table.fixedRows then
		return;
	endif;
	
    if self.mode = self.Mode_View then
    	return;
    endif;  
	
	if self.myDataClass = CM_Port then
		if _table.row = _table.getRowByName(ETRow_IsPort) then
			self.tblInput1_click(_table);
		endif;
		
	elseif self.myDataClass = CM_StopsTable then
		if _table.row = _table.getRowByName(ETRow_RequiresInfo) then
			self.tblInput1_click(_table);
		endif;
		
	elseif self.myDataClass = CM_ReceivalCutoffTermDef then
		if _table.row = _table.getRowByName(ETRow_CriteriaType) then
			// reload Default relative to combo
			self.myCurrentTableItem.SOPTM_ReceivalRestriction.doCriteriaChange (_table, 
										_table.getValueByName (ETRow_DefaultRelativeTo).String,
										_table.getValueByName (ETRow_CriteriaType).String);
		
		elseif _table.row = _table.getRowByName(ETRow_DefaultRelativeTo) then
			self.myCurrentTableItem.SOPTM_ReceivalRestriction.doDefaultRelativeToChange (_table, 
										app.defRelativeToStringToEnum (_table.getValueByName (ETRow_DefaultRelativeTo).String));
		endif;
		
	// PAR #30741 start
	elseif self.myDataClass = HMS_ResourceType then
		if _table.row = _table.getRowByName(ETRow_IconVisibleOnView) then
			self.tblInput1_click(_table);
		endif;
	// PAR #30741 end
	
	elseif self.myDataClass = CM_MTPoolingParty then										// TFS 3039
		self.myCurrentTableItem.SOPTM_MTPoolParty.doInputTableChange(self.tblInput1);		// TFS 3039
		
	elseif 	self.myDataClass = CM_WeighBridgeObj then
		if _table.row = _table.getRowByName(ETRow_WeighBridgeType) then
			self.myCurrentTableItem.SOPTM_WeighBridge.changeViews(_table.getValueByName (ETRow_WeighBridgeType).String);
		endif;
		
	elseif self.myDataClass = CM_DelayType then	//24 Aug 2018	NDL	TFS 40309
		if _table.row = _table.getRowByName(ETRow_RequiresVoyage) then
			self.myCurrentTableItem.SOPTM_DelayTypes.changeRequiresVoyage( _table.getValueByName (ETRow_RequiresVoyage).Boolean );
		endif;
	elseif self.myCurrentTableItem .isKindOf(SOPTM_HSCodes) then  //jlier1 TFS 55583 20/12/22
		if _table.row = _table.getRowByName(ETRow_HsCode) then
			self.myCurrentTableItem.SOPTM_HSCodes.changeHSCode( _table.getValueByName (ETRow_HsCode).String);
		endif;
	elseif self.myCurrentTableItem.isKindOf(SOPTM_ConsigneeConsignor) then
		//jlier1 TFS 57087 27/6/23
		if _table.row = _table.getRowByName(ETRow_IsFreightFwdr) then
			if _table.getValueByName(ETRow_IsFreightFwdr).Boolean then
				self.tblInput1.showRowByName(ETRow_IsInternal,false);
			else
				self.tblInput1.hideRowByName(ETRow_IsInternal,false);
			endif;
			self.shtTblInput1.cnEcResizeContents;
		endif;
	elseif self.myCurrentTableItem.isKindOf(SOPTM_Kiosk) then
		//jlier1 TFS 59547 4/8/23
		if _table.row = _table.getRowByName(ETRow_NoPassengersEnabled) then
			if _table.getValueByName(ETRow_NoPassengersEnabled).Boolean then
				self.tblInput1.showRowByName(ETRow_MaxPassengersAllowed,false);
				self.tblInput1.showRowByName(ETRow_SecurityEmailAddresses,false);
			else
				self.tblInput1.hideRowByName(ETRow_MaxPassengersAllowed,false);
				self.tblInput1.hideRowByName(ETRow_SecurityEmailAddresses,false);
			endif;
			self.shtTblInput1.cnEcResizeContents;		
		endif;
	elseif self.myCurrentTableItem.isKindOf(SOPTM_EventStreamDefinition) then
		if _table.row = _table.getRowByName(ETRow_Password) then
			self.setEnteredPassword(_table.getValueByName(ETRow_Password).String);
		endif;
	endif;
end;</source>
        <Parameter name="_table" type="CM_EntryTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTblInput1Click" id="8a3d40e8-7c2b-40f5-8657-9ebec2f64c68">
        <updating/>
        <source>doTblInput1Click(table: Table input) updating;
//-----------------------------------------
// Created: February 2005 By: cnwgd1
// 17/08/2016 cnwrh7	TFS	2501
//-----------------------------------------
vars
	tbl				: CM_EntryTable;
	rowInTable		: Integer;
	filePath		: String;
begin
	if table.row &lt;= table.fixedRows then
		return;
	endif;
    if self.mode = self.Mode_View then
    	return;
    endif;  
	
	rowInTable := table.CM_EntryTable.getRow(ETRow_EmailFileImbedded);
	if table.row = rowInTable and rowInTable &gt; 0 then
		if (tblInput1.getValueByName(ETRow_EmailFileImbedded).Boolean = true) then
			tblInput1.disableRowByName(ETRow_EmailMessage);
		else
			tblInput1.enableRowByName(ETRow_EmailMessage);
		endif;
		return;
	endif;
	
	//cnwrd1 par #18271 12.5.09
	rowInTable := table.CM_EntryTable.getRow(ETRow_RequiresInfo);
	if table.row = rowInTable and rowInTable &gt; 0 then
		if (self.tblInput1.getValueByName(ETRow_RequiresInfo).Boolean = true) then
			self.tblInput1.showRowByName(ETRow_CustomsInfoEntry, false);
		else
			self.tblInput1.hideRowByName(ETRow_CustomsInfoEntry, false);
		endif;
		
		self.tblInput1.resetSize();
		return;
	endif;
	
	// TFS 54165 jlizm1 29/07/2022
	rowInTable := table.CM_EntryTable.getRow(ETRow_ShowWeight);
	if table.row = rowInTable and rowInTable &gt; 0 then
		if (self.tblInput1.getValueByName(ETRow_ShowWeight).Boolean = true) then
			self.tblInput1.showRowByName(ETRow_WeightMeasureType, false);
		else
			self.tblInput1.hideRowByName(ETRow_WeightMeasureType, false);
		endif;
		
		self.tblInput1.resetSize();
		return;
	endif;
	
	//cnwrd1 par 32655
	rowInTable := table.CM_EntryTable.getRow(ETRow_Default);
	if table.row = rowInTable and rowInTable &gt; 0 then
		if (self.tblInput1.getValueByName(ETRow_Default).Boolean = true) then
			rowInTable := table.CM_EntryTable.getRow(ETRow_Available);
			if rowInTable &gt; 0 then
				self.tblInput1.setValueByName(ETRow_Available, true);
				self.tblInput1.disableRowByName(ETRow_Available);
			endif;
			rowInTable := table.CM_EntryTable.getRow(ETRow_Display);
			if rowInTable &gt; 0 then
				self.tblInput1.setValueByName(ETRow_Display, true);
				self.tblInput1.disableRowByName(ETRow_Display);
			endif;
		else
			rowInTable := table.CM_EntryTable.getRow(ETRow_Available);
			if rowInTable &gt; 0 then
				//self.tblInput1.setValueByName(ETRow_Available, true);
				self.tblInput1.enableRowByName(ETRow_Available);
			endif;
			rowInTable := table.CM_EntryTable.getRow(ETRow_Display);
			if rowInTable &gt; 0 then
				//self.tblInput1.setValueByName(ETRow_Display, true);
				self.tblInput1.enableRowByName(ETRow_Display);
			endif;
		endif;	
		return;
	endif;	
	
	if self.myDataClass = CM_ISOType then
		tbl := table.CM_EntryTable;
		self.doTblInput1ISOTypeClick(tbl);
	endif;
	// 33404 restrict Pos/Cheque setting
	if self.myDataClass = CM_PaymentMethod then
		tbl := table.CM_EntryTable;
		self.doTblInput1PaymentMethodClick(tbl);
	endif;
	
	if self.myDataClass = CM_CamProtocol then // ccms 1011
		rowInTable := table.CM_EntryTable.getRow(ETRow_DestinationFilePath);
		if table.row = rowInTable and rowInTable &gt; 0 then
			filePath	:= self.getServerFilePath;
			if filePath &lt;&gt; null then
				self.tblInput1.setValueByName(ETRow_DestinationFilePath, filePath);
			endif;
		endif;
	endif;
	// 17/08/2016 cnwrh7	TFS	2501
	rowInTable := table.CM_EntryTable.getRow( ETRow_UseSerialConnection );
	if table.row = rowInTable and rowInTable &gt; 0 then
		if (tblInput1.getValueByName(ETRow_UseSerialConnection).Boolean = true) then
			tblInput1.disableRowByName(ETRow_UseTCPConnection);
		else
			tblInput1.enableRowByName(ETRow_UseTCPConnection);
		endif;
		return;
	endif;
	
	rowInTable := table.CM_EntryTable.getRow( ETRow_UseTCPConnection );
	if table.row = rowInTable and rowInTable &gt; 0 then
		if (tblInput1.getValueByName(ETRow_UseTCPConnection).Boolean = true) then
			tblInput1.disableRowByName(ETRow_UseSerialConnection);
		else
			tblInput1.enableRowByName(ETRow_UseSerialConnection);
		endif;
		return;
	endif;
	
	//10 Apr 2018	NDL	TFS 7556
	rowInTable := table.CM_EntryTable.getRow( ETRow_IsSingleTransPerFile );
	if table.row = rowInTable and rowInTable &gt; 0 then
		if (tblInput1.getValueByName(ETRow_IsSingleTransPerFile).Boolean = false) then
			tblInput1.hideRowByName(ETRow_SingleContainerPerUNB, false);	
			tblInput1.setValueByName(ETRow_SingleContainerPerUNB, false);
		else
			tblInput1.showRowByName(ETRow_SingleContainerPerUNB,false);
		endif;
		return;
	endif;
	
	//15 Feb 2019	NDL	TFS 43403
//	if self.myCurrentTableItem.isKindOf(SOPTM_Boom) then
//		self.myCurrentTableItem.SOPTM_Boom.doTblInput1Click();
//	endif;
	
	//25 Aug 2021	NDL	TFS 51632
	self.doTableHandlePassword( table.CM_EntryTable, 0, 0 );
	
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTblInput1ISOTypeClick" id="52ea7a38-4982-4d03-aeef-6494d8af5274">
        <source>doTblInput1ISOTypeClick(_table : CM_EntryTable);
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	onOff : Boolean;
	tbl : CM_EntryTable;
begin
    if self.mode = self.Mode_View then
	    	return;
    endif;  
	
	
	if self.myDataClass = CM_ISOType then
		tbl := _table;
		if tbl.row = tbl.getRowByName(ETRow_Frame) then	//05 Feb 2018	NDL	TFS 36752
			onOff := tbl.getValueByName(ETRow_Frame).Boolean;
			if onOff then
				tbl.setValueByName(ETRow_Porthole,false);
				tbl.setValueByName(ETRow_Flat,false);
				tbl.setValueByName(ETRow_Crib,false);
				tbl.setValueByName(ETRow_Fan,false);
				tbl.setValueByName(ETRow_OpenTop,false);
				tbl.setValueByName(ETRow_Tank,false);
				tbl.setValueByName(ETRow_Integral,false);
				tbl.setValueByName(ETRow_Reefer,false);
				tbl.setValueByName(ETRow_Powered,false);
			endif;
		elseif tbl.row = tbl.getRowByName(ETRow_Crib) then	//05 Feb 2018	NDL	TFS 36752
			onOff := tbl.getValueByName(ETRow_Crib).Boolean;
			if onOff then
				tbl.setValueByName(ETRow_Frame,false);
			endif;
		elseif tbl.row = tbl.getRowByName(ETRow_Fan) then	//05 Feb 2018	NDL	TFS 36752
			onOff := tbl.getValueByName(ETRow_Fan).Boolean;
			if onOff then
				tbl.setValueByName(ETRow_Frame,false);
			endif;
		elseif tbl.row = tbl.getRowByName(ETRow_OpenTop) then	//05 Feb 2018	NDL	TFS 36752
			onOff := tbl.getValueByName(ETRow_OpenTop).Boolean;
			if onOff then
				tbl.setValueByName(ETRow_Frame,false);
			endif;
		elseif tbl.row = tbl.getRowByName(ETRow_Reefer) then	//05 Feb 2018	NDL	TFS 36752
			onOff := tbl.getValueByName(ETRow_Reefer).Boolean;
			if onOff then
				tbl.setValueByName(ETRow_Frame,false);
			endif;
		elseif tbl.row = tbl.getRowByName(ETRow_Powered) then	//05 Feb 2018	NDL	TFS 36752
			onOff := tbl.getValueByName(ETRow_Powered).Boolean;
			if onOff then
				tbl.setValueByName(ETRow_Frame,false);
			endif;
		elseif tbl.row = tbl.getRowByName(ETRow_Tank) then
			onOff := tbl.getValueByName(ETRow_Tank).Boolean;
			if onOff then
				tbl.setValueByName(ETRow_Porthole,false);
				tbl.setValueByName(ETRow_Flat,false);
				tbl.setValueByName(ETRow_Fan,false);
				tbl.setValueByName(ETRow_OpenTop,false);
				tbl.setValueByName(ETRow_Frame,false);	//05 Feb 2018	NDL	TFS 36752
			endif;
		elseif tbl.row = tbl.getRowByName(ETRow_Porthole) then
			onOff := tbl.getValueByName(ETRow_Porthole).Boolean;
			if onOff then
				tbl.setValueByName(ETRow_Integral,false);
				tbl.setValueByName(ETRow_Flat,false);
				tbl.setValueByName(ETRow_Fan,false);
				tbl.setValueByName(ETRow_OpenTop,false);
				tbl.setValueByName(ETRow_Frame,false);	//05 Feb 2018	NDL	TFS 36752
			endif;
		elseif tbl.row = tbl.getRowByName(ETRow_Integral) then
			onOff := tbl.getValueByName(ETRow_Integral).Boolean;
			if onOff then
				tbl.setValueByName(ETRow_Porthole,false);
				tbl.setValueByName(ETRow_Flat,false);
				tbl.setValueByName(ETRow_Frame,false);	//05 Feb 2018	NDL	TFS 36752
			endif;
		elseif tbl.row = tbl.getRowByName(ETRow_Flat) then
			onOff := tbl.getValueByName(ETRow_Flat).Boolean;
			if onOff then
				tbl.setValueByName(ETRow_Porthole,false);
				tbl.setValueByName(ETRow_Integral,false);
				tbl.setValueByName(ETRow_Reefer,false);
				tbl.setValueByName(ETRow_Fan,false);
				tbl.setValueByName(ETRow_OpenTop,false);
				tbl.setValueByName(ETRow_Frame,false);	//05 Feb 2018	NDL	TFS 36752
			endif;
		elseif tbl.row = tbl.getRowByName(ETRow_Twenty) then
			onOff := tbl.getValueByName(ETRow_Twenty).Boolean;
			if onOff then
				tbl.setValueByName(ETRow_Forty,false);
				tbl.setValueByName(ETRow_FortyFive,false);
				tbl.setValueByName(ETRow_Thirty,false);
				tbl.setValueByName(ETRow_FiftyThree,false);
			endif;
		elseif tbl.row = tbl.getRowByName(ETRow_Thirty) then
			onOff := tbl.getValueByName(ETRow_Thirty).Boolean;
			if onOff then
				tbl.setValueByName(ETRow_Forty,false);
				tbl.setValueByName(ETRow_FortyFive,false);
				tbl.setValueByName(ETRow_Twenty,false);
				tbl.setValueByName(ETRow_FiftyThree,false);
			endif;
		elseif tbl.row = tbl.getRowByName(ETRow_Forty) then
			onOff := tbl.getValueByName(ETRow_Forty).Boolean;
			if onOff then
				tbl.setValueByName(ETRow_Twenty,false);
				tbl.setValueByName(ETRow_FortyFive,false);
				tbl.setValueByName(ETRow_Thirty,false);
				tbl.setValueByName(ETRow_FiftyThree,false);
			endif;
		elseif tbl.row = tbl.getRowByName(ETRow_FortyFive) then
			onOff := tbl.getValueByName(ETRow_FortyFive).Boolean;
			if onOff then
				tbl.setValueByName(ETRow_Twenty,false);
				tbl.setValueByName(ETRow_Forty,false);
				tbl.setValueByName(ETRow_Thirty,false);
				tbl.setValueByName(ETRow_FiftyThree,false);
			endif;
		elseif tbl.row = tbl.getRowByName(ETRow_FiftyThree) then
			onOff := tbl.getValueByName(ETRow_FiftyThree).Boolean;
			if onOff then
				tbl.setValueByName(ETRow_Twenty,false);
				tbl.setValueByName(ETRow_Forty,false);
				tbl.setValueByName(ETRow_Thirty,false);
				tbl.setValueByName(ETRow_FortyFive,false);
			endif;
		elseif tbl.row = tbl.getRowByName(ETRow_Height8) then
			onOff := tbl.getValueByName(ETRow_Height8).Boolean;
			if onOff then
				tbl.setValueByName(ETRow_Height86,false);
				tbl.setValueByName(ETRow_Height96,false);
				tbl.setValueByName(ETRow_Height4,false);
				tbl.setValueByName(ETRow_Height43,false);
			endif;
		elseif tbl.row = tbl.getRowByName(ETRow_Height86) then
			onOff := tbl.getValueByName(ETRow_Height86).Boolean;
			if onOff then
				tbl.setValueByName(ETRow_Height8,false);
				tbl.setValueByName(ETRow_Height96,false);
				tbl.setValueByName(ETRow_Height4,false);
				tbl.setValueByName(ETRow_Height43,false);
			endif;
		elseif tbl.row = tbl.getRowByName(ETRow_Height96) then
			onOff := tbl.getValueByName(ETRow_Height96).Boolean;
			if onOff then
				tbl.setValueByName(ETRow_Height8,false);
				tbl.setValueByName(ETRow_Height86,false);
				tbl.setValueByName(ETRow_Height4,false);
				tbl.setValueByName(ETRow_Height43,false);
			endif;
		elseif tbl.row = tbl.getRowByName(ETRow_Height4) then
			onOff := tbl.getValueByName(ETRow_Height4).Boolean;
			if onOff then
				tbl.setValueByName(ETRow_Height8,false);
				tbl.setValueByName(ETRow_Height86,false);
				tbl.setValueByName(ETRow_Height96,false);
				tbl.setValueByName(ETRow_Height43,false);
			endif;
		elseif tbl.row = tbl.getRowByName(ETRow_Height43) then
			onOff := tbl.getValueByName(ETRow_Height43).Boolean;
			if onOff then
				tbl.setValueByName(ETRow_Height8,false);
				tbl.setValueByName(ETRow_Height86,false);
				tbl.setValueByName(ETRow_Height96,false);
				tbl.setValueByName(ETRow_Height4,false);
			endif;
		endif;
	endif;

end;</source>
        <Parameter name="_table" type="CM_EntryTable"/>
    </JadeMethod>
    <JadeMethod name="doTblInput1PaymentMethodClick" id="ce9d9015-8788-4d8c-8bdf-0f011db521f7">
        <source>doTblInput1PaymentMethodClick(_table : CM_EntryTable);
// ---------------------------------------------------------------------------
// Created:		27/08/2014 
//
// Purpose:		33404 limit isCheque and isPOS to only one being selected
//
// ---------------------------------------------------------------------------

vars

	onOff : Boolean;
	tbl : CM_EntryTable;
begin
    if self.mode = self.Mode_View then
	    return;
    endif;  
	
	if self.myDataClass = CM_PaymentMethod then
		tbl := _table;
		if tbl.row = tbl.getRowByName(ETRow_IsCheque) then
			onOff := tbl.getValueByName(ETRow_IsCheque).Boolean;
			if onOff then
				tbl.setValueByName(ETRow_IsPOS,false);
			endif;
		elseif tbl.row = tbl.getRowByName(ETRow_IsPOS) then
			onOff := tbl.getValueByName(ETRow_IsPOS).Boolean;
			if onOff then
				tbl.setValueByName(ETRow_IsCheque,false);
			endif;
		endif;
	endif;

end;</source>
