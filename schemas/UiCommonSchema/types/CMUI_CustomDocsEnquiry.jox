    <JadeMethod name="setCargoSubType" id="b22d0e21-1acc-4f2c-ae48-ff2c79a0ff5a">
        <updating/>
        <source>setCargoSubType()updating;
/*
Purpose:			

Date		Who		Reason
08AUG2023	NAVAB1	 CR 56094 TASK 59618
*/

vars
	criteria : CM_YACriteriaPriority;
	criteriaFrame : CMUI_YACriteriaCntl;
	i : Integer;
	propCount : Integer;
	critType : CM_YACriteriaType;
	event : CM_Product;
	allCriteriaStr : String;
	cargotype : CM_CargoType;
begin
	criteriaFrame := self.frmCargoSubType;
	criteriaFrame.transparent := true;
	criteriaFrame.setMasterControl(null);
	critType := CM_YATypeProduct.firstInstance();
	
	if critType &lt;&gt; null then
		criteriaFrame.setCriteriaType( critType );
		criteriaFrame.setLabelVisible(true);
		
		criteriaFrame.setWidth(560);			
		criteriaFrame.move(704, 30, 560, 40);
		criteriaFrame.visible := true;
		
	endif;

epilog

end;</source>
