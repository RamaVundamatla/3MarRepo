    <JadeMethod name="loadCargoList" id="8560241c-5e43-4c70-b383-6d2f3206a400">
        <source>loadCargoList() :Integer protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 August 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars
	workListEntry : CM_WorkListEntry;
	back,fore : Integer;
	str   : String;
	totalSelected : Integer;
	 idx : Integer;
	 tbl : CM_DataTable;
begin

	tbl := self.tblCargoList;
	//populate rows
	foreach workListEntry in self.myVoyageJob.workListEntries discreteLock do
		
		str := workListEntry.getAttributeStringForDefArray(tbl.allTblDataEntRows);
		idx :=tbl.addItemObject(workListEntry, str);
		
		workListEntry.getRowColour(fore,back);
		tbl.accessRow(idx).backColor := back;
		tbl.accessRow(idx).foreColor := fore;
		
		if self.allSelectedWLEs.includes(workListEntry) then
			tbl.accessRow(idx).selected := true;
			totalSelected := totalSelected + 1;
		endif;

	endforeach;		

	self.doSort();
	
	return totalSelected;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Integer"/>
    </JadeMethod>
