    <JadeMethod name="getDefaultInterchangeLocation" id="8b40b823-f731-4018-9cdb-24703ced5b85">
        <source>getDefaultInterchangeLocation() : CM_LaneController;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 May 2010	cnwer1	Initial creation

*/

vars
	termArea : CM_TerminalArea;
begin
	
	termArea := self.myTerminalArea;
	
	if termArea = null then
		return null;
	endif;
	
	if termArea.myDefaultInterchangeArea &lt;&gt; null then
		return termArea.myDefaultInterchangeArea.getDefaultLane;
	endif;
	
	
	//else use the first
	if termArea.allAssociatedInterchangeAreas.size &gt; 0 then
		return termArea.allAssociatedInterchangeAreas.first.getDefaultLane;
	endif;
	
epilog

end;</source>
