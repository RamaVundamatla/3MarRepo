begin
	on Exception do self.handleInvalidMethodCall(exception);

	if self.mySDF &lt;&gt; null then
		if self.mySDF.myParentForm &lt;&gt; null then
			self.mySDF.myParentForm.sendMsgWithParams("doFrameDrawScroll",_direction, _value);
		endif;
	endif;
	
	if _direction = ScrollBar_Horizontal then
	// SET LEFT
	else
	// SET TOP
	endif;
end;</source>
        <Parameter name="_direction" type="Integer"/>
        <Parameter name="_value" type="Integer"/>
