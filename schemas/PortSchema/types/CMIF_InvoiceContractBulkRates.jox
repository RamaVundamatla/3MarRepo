<Class name="CMIF_InvoiceContractBulkRates" id="e95569c6-30a8-4d05-b8d2-04de98b57368">
    <superclass name="CMIF_Object"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="invoice"/>
    <ImplicitInverseRef name="allPxyRateEntries" id="454d5c37-a781-47b7-8676-424681f4c193">
        <memberTypeInverse/>
        <type name="ObjectSet"/>
    </ImplicitInverseRef>
    <JadeMethod name="createProxyRateEntriesForDates" id="3b66c719-50ce-4627-8cf1-41826682cf5c">
        <source>createProxyRateEntriesForDates();
/*
Purpose:	CM_InvoiceContractRateEntry are logically grouped on CM_InvoiceContractRate by a date range. 
			If we are changing the dates on one of the CM_InvoiceContractRateEntryin the 'group' we must change all of them.	
			Assume passed in proxies have already had their date updated
			passed in proxies can be across many contracts and contract details
			

Date		Who		Reason
// ### TFS CR 55651 TASK 55656 23MAR2023 NAVMV20

*/

vars
	proxyRateEntry, pxyRateEntryGrouped : CM_InvoiceContractRateEntry;
	aRateEntry, realRateEntry: CM_InvoiceContractRateEntry;
	realRate : CM_InvoiceContractRate;
	fromDate, toDate : TimeStamp;
	realRateEntries, newProxies : ObjectSet;
begin

	if self.allPxyRateEntries = null then
		return;
	endif;

	create newProxies transient;
	create realRateEntries transient;
	
	// Get all the real rate entries so we know what has already been changed
	foreach proxyRateEntry in self.allPxyRateEntries as CM_InvoiceContractRateEntry do
		realRateEntry := proxyRateEntry.pxyGetRealObject().CM_InvoiceContractRateEntry;
		realRateEntries.add(realRateEntry);
	endforeach;

	// go through all the matching rate etnries for the 'group' and if not already a proxy create one and update the dates.
	foreach proxyRateEntry in self.allPxyRateEntries as CM_InvoiceContractRateEntry do //re1, re2, re4 - rate1
		realRateEntry := proxyRateEntry.pxyGetRealObject().CM_InvoiceContractRateEntry;
		realRate:= realRateEntry.myInvoiceContractRate;
		
		if realRateEntry.fromTS = proxyRateEntry.fromTS
		and realRateEntry.toTS = proxyRateEntry.toTS then
			continue; // no dates changed on proxy so do not need to get others in logical grouping
		endif;
		
		
		foreach aRateEntry in realRate.allInvoiceContractRateEntries discreteLock do
			if aRateEntry = realRateEntry then // already in the proxies
				continue;
			endif;
			
			// get all the other logically grouped rate entries
			if realRateEntry.fromTS = aRateEntry.fromTS 
			and realRateEntry.toTS =  aRateEntry.toTS then
				if realRateEntries.includes(aRateEntry) then // already selected and proxied
					continue;
				endif;
				

				pxyRateEntryGrouped := app.createUpdateProxy(aRateEntry).CM_InvoiceContractRateEntry;
				pxyRateEntryGrouped.setProxy(null,aRateEntry.costPerUnit, aRateEntry.fromAmount, aRateEntry.toAmount, proxyRateEntry.fromTS, proxyRateEntry.toTS, realRate, aRateEntry.myBusinessUnit);
				newProxies.add(pxyRateEntryGrouped);
				realRateEntries.add(aRateEntry);
			endif;
	
		endforeach;
	endforeach;

	newProxies.copy(self.allPxyRateEntries);
	
epilog
	delete newProxies;
	delete realRateEntries;
end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="fb39f766-403d-45a3-b86a-4cb49cac9bac">
        <updating/>
        <source>delete() updating;
/*
Purpose:			

Date		Who		Reason
23 March 2023	navab1	TFS CR 56806 TASK 56807
*/

vars

begin
	self.allPxyRateEntries.purge;
epilog

end;</source>
    </JadeMethod>
</Class>
