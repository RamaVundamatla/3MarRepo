    <JadeMethod name="create" id="d18fb2a5-1d00-4e5a-8271-9f5af6c2ed34">
        <updating/>
        <source>create() updating;
// --------------------------------------------------------------------------------
// Created:		15 July 2002 by cnwdad1
//
// Purpose:		Constructor to set default values etc..
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.isInLocalSchema	:=	(currentSchema.name = JSSFileManagerSchema.name);
end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="f658053c-ac77-4534-b1e2-42bde27fa8c7">
        <updating/>
        <source>delete() updating;
// --------------------------------------------------------------------------------
// Created:		22 September 2002 by cnwdad1
//
// Purpose:		If the File Browser of Background Copy Monitor forms exist, then
//				unlaod them.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	// Remove the File Browser form.
	
	if self.myFileBrowserForm &lt;&gt; null then
		self.myFileBrowserForm.unloadForm();
	endif;
	
	// Remove the monitor form.
	
	if self.myMonitorForm &lt;&gt; null then
		self.myMonitorForm.unloadForm();
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="getManager" id="b533b818-ae2d-4903-a45d-247ce4038935">
        <source>getManager(): JSSFMServiceManager;
// --------------------------------------------------------------------------------
// Created:		30 June 2002 by cnwdad1
//
// Purpose:		The standard JSS CoreSchema service object method.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self;
end;</source>
        <ReturnType type="JSSFMServiceManager"/>
    </JadeMethod>
    <JadeMethod name="getTA" id="844b0c51-d4e5-4c59-a6b6-c2d2dc9bf09b">
        <source>getTA(): JSSFMTransactionAgent;
// --------------------------------------------------------------------------------
// Created:		13 July 2002 by cnwdad2
//
// Purpose:		The standard JSS CoreSchema service object method.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.myTA.JSSFMTransactionAgent;
end;</source>
        <ReturnType type="JSSFMTransactionAgent"/>
    </JadeMethod>
    <JadeMethod name="getTAClass" id="8f1ab6bc-1ee6-4121-8f7c-cae058e5118e">
        <source>getTAClass(): Class protected;
// --------------------------------------------------------------------------------
// Created:		13 July 2002 by cnwdad2
//
// Purpose:		The standard JSS CoreSchema service object method.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return JSSFMTransactionAgent;
end;</source>
        <access>protected</access>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="setFileBrowserForm" id="add6098c-597b-45b6-8cea-6992dad77b99">
        <updating/>
        <source>setFileBrowserForm(pTheFileBrowserForm:JSSFMFileBrowserForm) updating;
// --------------------------------------------------------------------------------
// Created:		22 September 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.myFileBrowserForm	:=	pTheFileBrowserForm;
end;</source>
        <Parameter name="pTheFileBrowserForm" type="JSSFMFileBrowserForm"/>
    </JadeMethod>
    <JadeMethod name="setMonitorForm" id="7bb83c97-8dc9-49a9-847c-24869c9e3cc3">
        <updating/>
        <source>setMonitorForm(pTheMonitorForm:JSSFMBackgroundCopyMonitorForm) updating;
// --------------------------------------------------------------------------------
// Created:		22 September 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.myMonitorForm	:=	pTheMonitorForm;
end;</source>
        <Parameter name="pTheMonitorForm" type="JSSFMBackgroundCopyMonitorForm"/>
    </JadeMethod>
</Class>
