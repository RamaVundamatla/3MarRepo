    <JadeMethod name="removeVehicleFromDataTable" id="48d05aeb-b993-4488-b169-596c46bea3d3">
        <source>removeVehicleFromDataTable(_vehicle : CM_Vehicle input; _wleDeleted : Boolean);
/*

Purpose:			


Return Value:		


Date		Who		Reason
22 August 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	
	if self.dataTableDisplayWLEs then
		self.removeWLEsFromDataTable(_vehicle, _wleDeleted);
	else
		removeTIFromDataTable(_vehicle);	
	endif;

	if self.allVehicles.includes(_vehicle) then
		self.allVehicles.remove(_vehicle);
	endif;
	


epilog

end;</source>
        <Parameter name="_vehicle" type="CM_Vehicle" usage="input"/>
        <Parameter name="_wleDeleted" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="removeWLEsFromDataTable" id="3919a870-6874-4860-90de-5b472414f6c2">
        <source>removeWLEsFromDataTable(_vehicle:CM_Vehicle input;_wleDeleted : Boolean)protected;
/*

Purpose:			


Return Value:		


Date		Who		Reason
20 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	wleArray : CM_WLEArray;
	wle : CM_WorkListEntry;
	iter  : Iterator;
	vehicle  : CM_Vehicle;
	i , j : Integer;
	invalid : Boolean;
begin
	on Exception do handleObjectNotInCollection(exception); // adm 150708 Par 17547
//if the vehicles road job and wles have not been deleted we can remove them the simple way
	if not _wleDeleted then
		create wleArray transient;
		_vehicle.getAllWLEs(wleArray);
		foreach wle in wleArray do
			self.removeDataTableObject(wle);
			self.allWLEs.remove(wle);
		endforeach;
	else
	//start looking for invalid objects from the previous vehicles last wle 
		on Exception do app.handleDeletedObject( exception, vehicle, invalid );	//18 July 2019	NDL	TFS 42876
		create wleArray transient;
		iter:=self.allVehicles.createIterator;
		self.allVehicles.startKeyLss(_vehicle.code,iter);
		while iter.back(vehicle) do
			if vehicle &lt;&gt; _vehicle then
				vehicle.getAllWLEs(wleArray);
				if invalid then
					invalid:= false;
					continue;
				endif;
				if wleArray.size &gt; 0 then
					break;
				else
					continue;
				endif;
			endif;
		endwhile;
		delete iter;
		
		i:= self.allWLEs.indexOf(wleArray.last);
		if i = 0 then
			i:=1;
		endif;
		
		//epr par 12747 12/10/06
		while i &lt;= self.allWLEs.size do
			wle:=self.allWLEs[i];
			if not global.isValidObject(wle) then
				self.removeDataTableObject(wle);
				self.allWLEs.remove(wle);
			else
				i:=i+1;
			endif;
		endwhile;
	endif;
	
epilog
	if wleArray &lt;&gt; null then
		delete wleArray;
	endif;
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_vehicle" type="CM_Vehicle" usage="input"/>
        <Parameter name="_wleDeleted" type="Boolean"/>
    </JadeMethod>
