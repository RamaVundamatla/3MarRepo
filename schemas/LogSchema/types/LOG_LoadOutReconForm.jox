    <JadeMethod name="setStatusCaption" id="7fc7fab0-a17a-4369-bd42-14e38bc935f4">
        <source>setStatusCaption();
// ---------------------------------------------------------------------------
// Created:     29 April 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	logErrStr	: String;

begin

	if self.myCurrentBOLExt &lt;&gt; null then
		logErrStr := (tblLogError.rows - 1).String &amp; ' errors found for docket ' &amp; self.myCurrentBOLExt.myBOL.number &amp; '.';
	endif;

	staMain.caption := (tblBOLExt.rows - 1).String &amp; ' dockets found. ' &amp; logErrStr;

end;</source>
