	self.setDestinationPort(_proxyEDITI.destinationPort);
	self.setCommodity(_proxyEDITI.commodity);
	self.setWeight(_proxyEDITI.weight);
	self.setTemperature(_proxyEDITI.temperature);
	self.setExportVesselName(_proxyEDITI.exportVesselName);
//	self.setExportVoyageCode(_proxyEDITI.exportVoyageCode);	// cnwrl1 11/06/2010 PAR 24299 - what it was
	self.setExportVoyageCode( _proxyEDITI.getExportVoyageCode() );
	self.setInterModal(_proxyEDITI.interModal); // TFS 53083 jlizm1 22/04/2022
	
end;
</source>
