    <JadeMethod name="utlUpdateInvLinesExtReferences" id="d815b7c8-8973-4c5f-8dbf-10071df1ca68">
        <updating/>
        <source>utlUpdateInvLinesExtReferences(_cmif : CMIF_InvoiceExtRefSummaries; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//08/12/2025	navkc1 JIRA 36262 ROS - 1 - External Reference updates in MTN 

*/

vars
	cmifSummary : CMIF_InvoiceExternalRefSummary;
	invLine		: CM_InvoiceLine;
begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);
	
	app.myValUA.valUpdateInvLinesExtReferences(_cmif, _passport);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;	
	endif;

	app.setContinueCMExceptions(false);
	
	foreach cmifSummary in _cmif do
		foreach invLine in cmifSummary.allInvoiceLines do
			
			exclusiveLock(invLine);
			
			if _passport.noErrors then
				self.myUpdateAuditAgent.audUpdateGeneric(invLine, true);
			endif;
			
			if _passport.noErrors then
				if cmifSummary.externalRef1Update then
					invLine.externalRef1 := cmifSummary.externalRef1;
				endif;
				
				if cmifSummary.externalRef2Update then
					invLine.externalRef2 := cmifSummary.externalRef2;
				endif;
				
				if cmifSummary.externalRef3Update then
					invLine.externalRef3 := cmifSummary.externalRef3;
				endif;
				
				if cmifSummary.externalRef4Update then
					invLine.externalRef4 := cmifSummary.externalRef4;
				endif;
			endif;
			
			if _passport.noErrors then
				self.myUpdateAuditAgent.audUpdateGeneric(invLine, false);
				app.myEventManager.createSingleObjInfoNoteEvt(invLine, _passport.myTerminal.getTerminalEvent(Event_InvoiceLineUpdate), invLine);
			endif; 
		endforeach;
	endforeach;
	
epilog

end;</source>
        <Parameter name="_cmif" type="CMIF_InvoiceExtRefSummaries"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateInvSignoff" id="5164edae-c675-4cd7-9a22-dc1b60237e54">
        <source>utlUpdateInvSignoff( _proxy : CM_InvoiceSignoffUser io; 
					_passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2018	jlgndl1	Initial creation	TFS 38535

*/

vars
	real : CM_InvoiceSignoffUser;
	expectedEdition : Integer;
begin
	self.initialiseActivity();

	_proxy.raiseExceptionIfNotProxy(method);
	
	_proxy.pxyGetRealObjectAndEdition( real, expectedEdition);
	
	if real = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_InvoiceSignoffUser.name, null, null);
		return;
	endif;

	app.myValUA.valInvSignoff( _proxy );

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	exclusiveLock( real );
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric( real, true);
	endif;

	if _passport.noErrors then
		real.setForUpdate( _proxy );
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(real, false);
	endif;		
	
	
epilog
	


end;</source>
        <Parameter name="_proxy" type="CM_InvoiceSignoffUser" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateInvStatusDetailed" id="cffb5e34-49db-4dae-b4c3-eb7f3a568618">
        <updating/>
        <source>utlUpdateInvStatusDetailed(_status : CMIF_InvoiceStatus;_passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 August 2024	navra1	Initial creation for //navra1 - TFS 65380 - 7th Aug 2024

*/

vars
	pxyInvoiceLine : CM_InvoiceLine;
	pxyPayment : CM_CashPayment;
	newCashPaymentStatus : Integer;
	
	invoices : CM_InvoiceSet;
	inv : CM_Invoice;
	invLine : CM_InvoiceLine;

begin

	create invoices transient; // ### TFS CR 63369 TASK 63687 23APR2024 NAVAB1
	
	if _status.allInvoiceLines.isEmpty and
	   _status.allCashPayments.isEmpty then
		app.myUtilityUA.utlUpdateInvoiceStatus( _status, _passport);
	else
		foreach pxyInvoiceLine in _status.allInvoiceLines do
			app.myUtilityUA.utlUpdateInvoiceLineStatus( pxyInvoiceLine, _status, _passport);
			if _passport.hasErrors() then
				return;
			endif;
			
			invLine := pxyInvoiceLine.pxyGetRealObject().CM_InvoiceLine;
			if invLine &lt;&gt; null then
				if invoices.tryAddIfNotNull(invLine.invoice) then  // ### TFS CR 63369 TASK 63687 23APR2024 NAVAB1
					reserveLock(invLine.invoice);                  //22.06.2024 navrv30 Task 64598
				endif;
			endif;
		endforeach;
		
		foreach pxyPayment in _status.allCashPayments do
			newCashPaymentStatus := pxyPayment.getStatusFromInvoiceStatus(_status.newStatus);	// TFS 45301
			app.myUtilityUA.utlUpdateCashPaymentStatus(pxyPayment, newCashPaymentStatus, _passport);
			if _passport.hasErrors() then
				return;
			endif;
		endforeach;
	endif;
	
	// ### TFS CR 63369 TASK 63687 23APR2024 NAVAB1
	if not _passport.hasErrorsOrWarnings() then
		foreach inv in invoices do
			inv.setTaxDetailsFromLines();
			inv.setTotalAmountFromLines();
		endforeach;
	endif;

epilog
	delete invoices;
end;</source>
        <Parameter name="_status" type="CMIF_InvoiceStatus"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateInvTermsOfTrade" id="828f96a6-6ca2-46ad-a71b-55599c3dd7af">
        <source>utlUpdateInvTermsOfTrade(_theTerminal : CM_Terminal;pProxyInvTermsOfTrade : CM_InvoiceTermsOfTrade io; 
					_passport : CM_Passport input);
//----------------------------------------------
//Created: 16 October 2001 By: cnwgd1
//----------------------------------------------
vars
	pRealInvTermsOfTrade : CM_InvoiceTermsOfTrade;
	expectedEdition : Integer;
begin
	self.initialiseActivity();

	pProxyInvTermsOfTrade.raiseExceptionIfNotProxy(method); //add this in when UI in JADE 
	
	pProxyInvTermsOfTrade.pxyGetRealObjectAndEdition(pRealInvTermsOfTrade, expectedEdition);
	
	if pRealInvTermsOfTrade = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_InvoiceTermsOfTrade.name, null, null);
		return;
	endif;

	app.myValUA.valInvTermsOfTrade(pProxyInvTermsOfTrade, pRealInvTermsOfTrade);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	exclusiveLock(pRealInvTermsOfTrade);
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(pRealInvTermsOfTrade, true);
	endif;

	if _passport.noErrors then
		pRealInvTermsOfTrade.CM_InvoiceTermsOfTrade.setForUpdate(pProxyInvTermsOfTrade);
	endif;
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(pRealInvTermsOfTrade, false);
	endif;		
	if _passport.noErrors then
	endif;
	
epilog
	


end;</source>
        <Parameter name="_theTerminal" type="CM_Terminal"/>
