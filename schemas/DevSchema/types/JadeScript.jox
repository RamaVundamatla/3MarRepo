    <JadeMethod name="eprTestMachineHistory" id="c93a06d1-13b8-44fc-9934-71f508e1df1a">
        <source>eprTestMachineHistory();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 October 2017	jlger1	Initial creation

*/

vars
	oldHist,
	hist : CM_MachineLogOnOffHistory;
	machine : CM_Machine;
	i, j : Integer;
begin
	//oldHist := "2472.7646".asOid.CM_MachineLogOnOffHistory;
	
	machine := "2296.467".asOid.CM_Machine;
	app.initialize;
	app.myPassport.setMyUserFromCode("CNWER1");
	beginTransaction;
	while i &lt;= 10000 do
		
			machine.addLogOnToHistory();
		
		if  j = 2000 then
			commitTransaction;
			beginTransaction;
			j:=0;
		endif;
		i:=i + 1;
	endwhile;
	
	
	if process.isInTransactionState then
		commitTransaction;
	endif;
	
epilog

end;</source>
    </JadeMethod>
