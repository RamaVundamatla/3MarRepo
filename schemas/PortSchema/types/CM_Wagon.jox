epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasTrackedItems" id="33c17686-049f-4b4e-b519-7ff32a76f20c">
        <methodInvocation>mapping</methodInvocation>
        <source>hasTrackedItems(set: Boolean; _value: Boolean io) mapping;
/*
 ------------------------------------------------------------------------
Created:			18 July 2002 by cnwdwq1
Purpose:			Return TRUE if a controller here has a tracked item on it.
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	controller : CM_LocationsController;
begin
	_value := false;
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;

	//foreach controller in self.allLocationsControllers do
	foreach controller in self.allLocationsControllersArray do	//04 Dec 2014	NDL	Par 35345
		if controller.allTrackedItems.isEmpty = false then
			_value := true;
			return;
		endif;
	endforeach;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="initializeForActivity" id="4e5a41d1-527f-47f1-a594-c96fd7d89ab4">
        <updating/>
        <source>initializeForActivity(_ewsOpsView: CM_EWSActivityOpsview; _opsViewTable : CMIF_OpsViewTables) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 May 2022	navsp1	Initial creation TFS#53569

*/

vars
	n4CarVisit			: CMIF_RailCarVisits;
	trainin, trainout 	: CM_Train;
	n4Car				: CMIF_RailCars;
	wclass 				: CM_WagonClass;
	carrier 			: CM_Carrier;
begin
	if _opsViewTable.isKindOf(CMIF_RailCarVisits) then 
		trainin 					:= self.myTrainInwards;
		trainout 					:= self.myTrainOutwards;
		
		n4CarVisit 					:= _opsViewTable.CMIF_RailCarVisits;
		n4CarVisit.gkey				:= n4CarVisit.generateFullGKey(self, "");
		n4CarVisit.active		 		:= true;
		if self.myDestinationPort &lt;&gt; null then
			n4CarVisit.destination 	:= self.myDestinationPort.description;
		else	
			n4CarVisit.destination 	:= "";
		endif;
		n4CarVisit.fcy_gkey 		:= n4CarVisit.generateFullGKey(self.myTerminal, "");
		n4CarVisit.id 				:= self.id;
		if trainin &lt;&gt; null then
			n4CarVisit.in_seq 		:= trainin.allWagonsByOrderInward.indexOf(self);
		else
			n4CarVisit.in_seq 		:= 0;
		endif;
		if self.myOriginPort &lt;&gt; null then
			n4CarVisit.origin 		:= self.myOriginPort.description;
		else
			n4CarVisit.origin 		:= "";	
		endif;		
		if trainout &lt;&gt; null then
			n4CarVisit.out_seq		:= trainout.allWagonsByOrderOutward.indexOf(self);
		else 
			n4CarVisit.out_seq		:= 0;
		endif;			
		n4CarVisit.rcar_gkey 		:= n4CarVisit.generateFullGKey(self,"");		 // ### TFS 54025 29JUN2022 NAVAB1 n4CarVisit.generateFullGKey(self.myWagonClass,"");		
		n4CarVisit.rv_inbound_gkey 	:= n4CarVisit.generateFullGKey(trainin,CMIF_OpsViewTables.Prefix_Inbound);
		n4CarVisit.rv_outbound_gkey := n4CarVisit.generateFullGKey(trainout,CMIF_OpsViewTables.Prefix_Outbound);
	elseif _opsViewTable.isKindOf(CMIF_RailCars) then
		n4Car		:= _opsViewTable.CMIF_RailCars;
		wclass 						:= self.myWagonClass;
		if wclass &lt;&gt; null then
			carrier 						:= wclass.myCarrier;
			n4Car.gkey 						:= n4Car.generateFullGKey(self,"");	
			n4Car.flat_car_type 			:= wclass.getWagonTypeString();
			n4Car.floor_height_cm 			:= wclass.deckHeight;
			n4Car.id 						:= self.id;
			if wclass.isFlatcar then
				n4Car.length_cm				:= wclass.getLenInCMs();
			else
				n4Car.length_cm				:= wclass.overallLength;
			endif;
			n4Car.max_20s_per_platform 		:= wclass.maxNumInStack;
			n4Car.max_tiers_per_platform 	:= wclass.maxNumInStack;
			n4Car.rr_gkey 					:= n4Car.generateFullGKey(carrier,"");
			n4Car.safe_weight_kg 			:= wclass.maxLoadWeight;
			n4Car.tare_weight_kg 			:= wclass.tareWeight;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_ewsOpsView" type="CM_EWSActivityOpsview"/>
        <Parameter name="_opsViewTable" type="CMIF_OpsViewTables"/>
    </JadeMethod>
