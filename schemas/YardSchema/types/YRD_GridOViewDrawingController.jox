    <JadeMethod name="recordRTGSelectBounds" id="e7390930-0667-48c7-8d4e-5396686afb97">
        <source>recordRTGSelectBounds( _ta : CM_RTGArea; _startX, _startY : Real );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 January 2009	cnwjk3	SFW1030

*/

vars

	theColWidth, 
	theRowHeight	: Real;
	blockX1, blockX2, 
	blockY1, blockY2  : Real;
	tmpRow			: CM_GridRow;
	tmpCol			: CM_GridColumn;
	drawGap 		: Boolean;
	firstONE		: Boolean;
	index           : Integer;
begin
	theColWidth	 := self.getColumnWidthForScale();
	theRowHeight := self.getRowHeightForScale();

	blockX1 := _startX;
	blockX2 := _startX;
	blockY1 := _startY;
	blockY2 := _startY;
	drawGap := true;
	firstONE := true;

	// Calculate the column total width of a row
	foreach tmpCol in _ta.allGridColumns do
			blockX2 := blockX2 + self.columnSpacing;
			if tmpCol.hasGap then
				blockX2 := blockX2 + self.getGapDrawWidth(tmpCol); 
			else
			    blockX2 := blockX2 + theColWidth;
			endif;
	endforeach;
	blockX2 := blockX2 - 1;
	
	foreach tmpRow in _ta.allGridRows  do			
		if tmpRow.hasGap then
			drawGap := true;
			continue;
		endif;
		if drawGap and not firstONE then
			//self.myDrawingFrame.drawRectangle(blockX1-10, blockY1, blockX2+10, blockY2, Red);			
			self.selectionBoundsObjectsPutAtKey( blockX1.Integer, blockY1.Integer, blockX2.Integer, blockY2.Integer, tmpRow );			
			index := index + 1;
			blockY1 := blockY2 + theRowHeight;
			blockY2 := blockY1;
		endif;
		
		blockY2 := blockY2 + theRowHeight - 1;
		drawGap := false;
		firstONE := false;
	endforeach;
	if _ta.allGridRows.size() &gt;= 1 then
		//self.myDrawingFrame.drawRectangle(blockX1-10, blockY1, blockX2+10, blockY2, Red);			
		self.selectionBoundsObjectsPutAtKey( blockX1.Integer, blockY1.Integer, blockX2.Integer, blockY2.Integer, tmpRow );
	endif;
epilog

end;</source>
        <Parameter name="_ta" type="CM_RTGArea"/>
        <Parameter name="_startX" type="Real"/>
        <Parameter name="_startY" type="Real"/>
    </JadeMethod>
