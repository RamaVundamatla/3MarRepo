    <JadeMethod name="pxyUpdateLaneCount" id="33439c57-d118-4b5e-8bd0-e550a4e7d58f">
        <updating/>
        <source>pxyUpdateLaneCount(_numLanes : Integer; maxLaneLen : Real) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 November 2009	cnwjk3	ccms 1018

*/

vars
	int		: Integer;
	size 	: Integer;
	lane	: CM_RoRoController;
begin

	self.raiseExceptionIfNotTransient (method);
	
	if _numLanes = self.laneCount then
		return;	
	endif;
	
	if _numLanes &gt; self.laneCount then
		size := self.allLanesByLaneNumber.size;
		
		// create new lane proxies
		foreach int in (size + 1) to _numLanes do
			//self.pxyCreateNewLane();			
			self.pxyCreateNewLane(maxLaneLen);	// cnwjk3 PAR 23760 19/04/2010			
		endforeach;
	elseif _numLanes &lt; self.laneCount then
		// delete extra lanes we don't need		
		// we will also delete any real lanes
		int := self.allLanesByLaneNumber.size;
		
		while int &gt; _numLanes do
			lane := self.allLanesByLaneNumber[int];
			
			lane.erase (NORMAL_ERASE);	// make sure we delete lane devices
			
			int := int - 1;
		endwhile;		
	endif;
	
	self.laneCount := _numLanes;
epilog

end;</source>
        <Parameter name="_numLanes" type="Integer"/>
        <Parameter name="maxLaneLen" type="Real"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="bd9714d6-aa17-4cc6-b6dd-d9c930d26bcf">
        <updating/>
        <source>setForCreate(_proxy: CM_RoRoLaneArea input; _passport: CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 November 2009	cnwjk3	CCMS 1018

*/

vars
	realLane,
	pxyLane 	: CM_RoRoController;
begin
	inheritMethod(_proxy, _passport);

	self.setForUpdateCreateCommon(_proxy, _passport);
	
	foreach pxyLane in  _proxy.allLanesByLaneNumber do
		create realLane as pxyLane.class persistent;
		realLane.setForCreate(pxyLane, self);
	endforeach;
epilog

end;</source>
        <Parameter name="_proxy" type="CM_RoRoLaneArea" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="1fc8f6ee-42e4-4d8f-84b1-ea5909b7ef41">
        <updating/>
        <source>setForUpdate(_proxy: CM_RoRoLaneArea) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 November 2009	cnwjk3	Initial creation

*/

vars
	deleteSet	: CM_ObjectSet;
	realLane,
	pxyLane		: CM_RoRoController;
begin
	inheritMethod(_proxy);
	
	create deleteSet transient;
	
	self.setForUpdateCreateCommon(_proxy, null);
	
	// re hash real lanes on different sort keys to avoid clashes
	foreach realLane in self.allLanesById do
		realLane.setLaneId("/" &amp; realLane.id);
		realLane.setLaneNumber(-realLane.laneNumber);
	endforeach;
	
	// go through lanes and see which ones need updating, creating or deleting
	self.allLanesByLaneNumber.copy(deleteSet);
	foreach pxyLane in _proxy.allLanesByLaneNumber do
		realLane := pxyLane.pxyGetRealObject().CM_RoRoController;
		if realLane &lt;&gt; null then
			if deleteSet.includes(realLane) then
				deleteSet.remove(realLane);
			endif;	
			realLane.setForUpdate(pxyLane, self);
		else
			create realLane as pxyLane.class persistent;
			realLane.setForCreate(pxyLane, self);
		endif;
	endforeach;
	
	// Delete any real lanes that no longer exist
	if (not deleteSet.isEmpty()) then
		deleteSet.purge();
	endif;
	
epilog
	delete deleteSet;
end;</source>
        <Parameter name="_proxy" type="CM_RoRoLaneArea"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateCreateCommon" id="57e29341-47f1-40f5-99e1-c994bb944558">
        <updating/>
