    <JadeMethod name="create" id="cb77d02a-cef3-4811-a71c-7dc9b1fa449e">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     10 September 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.name	:= "IFTMBC PONL98B - Booking Reference";
	self.type	:= EDIFileType_IFTMBCPonl98B;
end;</source>
    </JadeMethod>
    <JadeMethod name="getEDIBundle" id="f6260597-4411-433b-ba28-b00ed9742b6b">
        <source>getEDIBundle(): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 January 2025	navkc1	JIRA Story MTN-33491: MTN | License - EDI Bundles Methods

*/

vars

begin
	
	return self.EDI_Bundle_CUSTOM;

epilog

end;</source>
        <ReturnType type="Integer"/>
