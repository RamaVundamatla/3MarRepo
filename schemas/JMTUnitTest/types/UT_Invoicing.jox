    <JadeMethod name="createReefer" id="83ac02a0-034d-40f7-acc6-302ee1262cd5">
        <updating/>
        <source>createReefer(_id : String; _loc : CM_GridController input) : CM_Container updating;
// code copied from HandHeld test
constants
	POWERED_REEFER = "2231";
vars
	ti : CM_Container;
	moveCont : CMIF_MoveController;
	
begin
		
	ti := self.addContainer(_id,self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), "2200","MT",TI_IMEX_STATUS_IMPORT).CM_Container;

	beginTransaction;
	// change to a powered reefer and a commodity that requires power and isn't empty
	ti.changeISOType(POWERED_REEFER,null,null);
	ti.setCommodity("AMFC");
	
	ti.updateContentsStatus();
	
	_loc.setPower(true);
	
	create moveCont transient;
	moveCont.setMyToPrimaryLocation(_loc);
	moveCont.setMyTrackedItem(ti);
	moveCont.setMoveMode(REAL_MODE);
	
	ti.setMyLocationsPublic(moveCont);
	
	commitTransaction;

	return ti;
epilog
	delete moveCont;
end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_loc" type="CM_GridController" usage="input"/>
        <ReturnType type="CM_Container"/>
    </JadeMethod>
    <JadeMethod name="createReeferTransactions" id="75da90c3-0593-45d9-b172-973aff6fdc99">
        <source>createReeferTransactions(realTI : CM_TrackedItem input);
// ---------------------------------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	transParams: CMIF_TITransactionController;
	tran : CM_TITransaction;
	tranTS : TimeStamp;
	baseDate : Date;
	connectDate,
	disconnectDate	: Date;
begin
		
	// Connect the container
	assertTrueMsg(app.myMobileAgent.updateTIConnection(realTI, true, true, null), realTI.id &amp; " power connection fail");

	// Disconnect the container
	assertTrueMsg(app.myMobileAgent.updateTIConnection(realTI, true, false, null), realTI.id &amp; " power disconnection fail");

	// back-date the transactions
	baseDate.setDate(24,1,2011);
	connectDate.setDate(24,1,2011);
	disconnectDate.setDate(24,3,2011);
	
	tranTS.setDate(baseDate);
	foreach tran in realTI.allTransactions do
		tranTS.setDate(baseDate);
		if tran.isKindOf(CM_ConnectPower) then
			tranTS.setDate(connectDate);
		elseif tran.isKindOf(CM_DisconnectPower) then
			tranTS.setDate(disconnectDate);
		endif;
		tranTS.setTime(tran.dateTime.time);
		
		beginTransaction;
		tran.setPropertyValue("dateTime", tranTS);
		commitTransaction;
	endforeach;
	
	// fiddle the TI connection dates as well to get the Reefer Daily quantity correct
	beginTransaction;
	tranTS := realTI.getFirstConnectDT();
	tranTS.setDate(connectDate);
	realTI.setFirstConnectDT(tranTS);
	tranTS := realTI.getLastDisconnectDT();
	tranTS.setDate(disconnectDate);
	realTI.setLastDisconnectDT(tranTS);
	commitTransaction;
	
	create transParams transient;
	transParams.type := TRANS_TYPE_ReeferDaily;
	transParams.noCharge := false;
	transParams.userId := "NAVAB1";
	
	beginTransaction;
	tranTS.setDate(disconnectDate);
	transParams.dateTime := tranTS;
	realTI.createTransaction(transParams, app.myPassport);
	commitTransaction;
epilog
	delete transParams;
end;</source>
        <Parameter name="realTI" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createStorageTransactions" id="d85d3120-cd20-447a-b197-f3813de15a2d">
