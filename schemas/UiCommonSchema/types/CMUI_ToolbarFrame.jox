    <DbClassMap file="_usergui"/>
    <JadeMethod name="getWidth" id="b760e305-4dc2-439b-a455-95d01e2d94ec">
        <source>getWidth(_showCaptions : Boolean): Integer;
// ---------------------------------------------------------------------------
// Created:     20 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	return self.width.Integer;

end;</source>
        <Parameter name="_showCaptions" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="init" id="6d3c0247-ae4a-4615-8f1c-1d7f08e72318">
        <updating/>
        <source>init(_showCaptions : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     04 September 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	self.setShowCaptions(_showCaptions); // TFS 50421 this does not do anything

end;</source>
        <Parameter name="_showCaptions" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setShowCaptions" id="6819c774-3c18-4360-9bd3-31cfcce8a386">
        <updating/>
        <source>setShowCaptions(_showCaptions: Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     04 September 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpHeight	: Real;

begin
	inheritMethod(_showCaptions);

	/* TFS 50421 waste of time doing this
	if _showCaptions then
		tmpHeight := CMUI_Toolbar.ControlHeightWithCaptions;
	else
		tmpHeight := CMUI_Toolbar.ControlHeightWithoutCaptions;
	endif;
	
	self.height := tmpHeight;
	*/
end;</source>
        <Parameter name="_showCaptions" type="Boolean"/>
    </JadeMethod>
