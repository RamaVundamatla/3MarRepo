                    "oxygen": ' &amp; UTOxygen11.String &amp; ',
                    "vent": ' &amp; UTVentilation11.String &amp; ',
                    "ventUnits": ' &amp; UTVentUnits11.String &amp; ',
					"temperature": ' &amp; UTTemperature11.String &amp; '
                },
                "hazards": [
                    {
                        "id": "2.3",
                        "undgNumber": "0326, 0333",
                        "limitedQuantity": true,
                        "packingGroupId": "I",
                        "marinePollutant": 1,
                        "acidBase": "ACID",
