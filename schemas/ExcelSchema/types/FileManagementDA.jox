        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="copyBlobToFile" id="481e05f0-ae65-45e8-a74f-bbd5801cd1d2">
        <updating/>
        <source>copyBlobToFile(	blob		: Binary;
				folder		: String;
				fileNameIn	: String) : String updating;

/*****************************************************
	Written by	:	cnwpra1		04 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars
	file				: File;
	strFileName			: String;
	strFolder			: String;
	length				: Integer;

begin
	if folder &lt;&gt; null then	// if no folder parameter then the filename contains the full path
		create myFileFolder;
		myFileFolder.usePresentationFileSystem := useLocalDirectory;
		myFileFolder.fileName := folder;
		if not myFileFolder.isAvailable then
			directoryCreated := true;
			directoryName := folder;
			myFileFolder.make;
		endif;
		
		length := folder.length;
		if folder[length - 1: 1] &lt;&gt; '\'  and folder[length - 1: 1] &lt;&gt; '/' then
			strFolder := folder &amp; '\';
		else
			strFolder := folder;
		endif;
		
		strFileName := strFolder &amp; fileNameIn;
		fileName := strFileName;
	else
		fileName := fileNameIn;
	endif;
	
	create file;
	file.usePresentationFileSystem := true;
	file.fileName := fileName;
	file.mode := File.Mode_Output;
	file.kind := File.Kind_Binary;
	file.allowReplace := true;
	
	if not file.tryOpen then
		return 'Unable to open ' &amp; fileName &amp; ' for output in ' &amp; folder;
	endif;
	
	file.writeBinary(blob);
	
	return null;					// successful

epilog
	delete file;
end;</source>
        <Parameter name="blob" type="Binary"/>
        <Parameter name="folder" type="String"/>
        <Parameter name="fileNameIn" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="copyFileToBlob" id="850d810d-1430-4393-9132-19d6f1c7de31">
        <source>copyFileToBlob(	blob		: Binary output;
				fileNameIn	: String)	: String;

/*****************************************************
	Written by	:	cnwpra1		04 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars
	file		: File;

begin
	create file;
	file.usePresentationFileSystem := useLocalDirectory;
	file.fileName := fileNameIn;
	file.mode := File.Mode_Input;
	file.kind := File.Kind_Binary;
	if not file.isAvailable then
		return 'File ' &amp; fileNameIn &amp; ' is not available';
	endif;
	if not file.tryOpen then
		return 'File ' &amp; fileNameIn &amp; ' can not be opened';
	endif;
	
	blob := file.readBinary(file.fileLength);
	
	return null;					// successful

epilog
	if file &lt;&gt; null then
		delete file;
	endif;
end;</source>
        <Parameter name="blob" type="Binary" usage="output"/>
        <Parameter name="fileNameIn" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="createFolder" id="8bfdf994-c574-4da8-b6f9-411731ab6f4f">
        <updating/>
        <source>createFolder(folder : String) updating;

/*****************************************************
	Written by	:	cnwpra1		02 June 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars

begin
	create myFileFolder;
	myFileFolder.usePresentationFileSystem := useLocalDirectory;
	myFileFolder.fileName := folder;
	if not myFileFolder.isAvailable then
		directoryCreated := true;
		directoryName := folder;
		myFileFolder.readOnly := false;
		myFileFolder.make;
	endif;
	
epilog

end;</source>
        <Parameter name="folder" type="String"/>
    </JadeMethod>
    <JadeMethod name="removeBadCharsFromFileName" id="045f56f9-b0b9-4ab0-afe3-158974e5d4a2">
        <source>removeBadCharsFromFileName(fileNameIn : String) : String;

/*****************************************************
	Written by	:	cnwpra1		08 December 2004
	Description	:	PAR 8880 - ignore chars which can't be part of a filename

	Change history
	--------------
	Date		By		Reason
******************************************************/

constants
	BadChars = ':/\*?"&lt;&gt;|';

vars
	nameOut		: String;
	pos			: Integer;
	
begin
	pos := 1;
	while pos &gt; 0 do
		nameOut := nameOut &amp; fileNameIn.scanUntil(BadChars, pos);
		if pos &lt;&gt; 0 then
			pos := pos + 1;
		endif;
	endwhile;
	
	return nameOut;
epilog

end;</source>
        <Parameter name="fileNameIn" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="removeFile" id="48e0c045-8786-4ecd-8b36-ab724c040dcf">
        <updating/>
        <source>removeFile() updating;

/*****************************************************
	Written by	:	cnwpra1		24 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars
	file				: File;
	strFileName			: String;
	strFolder			: String;
	length				: Integer;

begin
	if myFileFolder &lt;&gt; null then
		if not myFileFolder.isAvailable then
			return;				// the file filder has gone so the file must be gone too
		endif;
	endif;
	
	create file;
	file.mode := File.Mode_Output;
	file.fileName := fileName;
	
	if not file.isAvailable then
		return;
	endif;
	
	if not file.tryOpen then
		return;
	endif;
	
	file.close;
	
	file.purge;	

epilog
	if file &lt;&gt; null then
		delete file;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="removeFolder" id="c4bd969a-b83c-4ab2-944e-9a144c614bf9">
        <updating/>
        <source>removeFolder() updating;

/*****************************************************
	Written by	:	cnwpra1		03 June 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars
	fileNodeArray	: FileNodeArray;
	fileNode		: FileNode;

begin
	if myFileFolder &lt;&gt; null then
		myFileFolder.readOnly := false;
		fileNodeArray := myFileFolder.files;
		foreach fileNode in fileNodeArray do
			fileNode.purge;
		endforeach;
		myFileFolder.purge;
	endif;
	
epilog
	if myFileFolder &lt;&gt; null then
		delete myFileFolder;
	endif;
end;</source>
    </JadeMethod>
