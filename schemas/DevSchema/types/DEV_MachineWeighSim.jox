/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 Jul 2016	cnwkpd1	TFS 2357 - Capture VGM info using Loadrite

*/

vars

begin
	self.loadProcessCombo();
	
	self.beginClassNotification(Process, false, Any_System_Event, Response_Continuous, 0);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadProcessCombo" id="3db81869-bbb6-4b63-9d7b-6ba417f9263d">
        <source>loadProcessCombo();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 Jul 2016	cnwkpd1	TFS 2357 - Capture VGM info using Loadrite
18 April 2018	jlgns1	Bug 38134: PKT - Weight Discrepancy
*/

vars
	savedProc,
	proc			: Process;
	invalid			: Boolean;
	index			: Integer;
	
begin
	on Exception do app.handleDeletedObject(exception, proc, invalid);

	savedProc := cmbProcess.listObject.Process;
	cmbProcess.clear();
	
	foreach proc in Process.instances do
		if proc.persistentApp.name.startsWith("VehicleMounted") or
			(proc.persistentApp.name = JMTerminal and self.cbIncludeJMT.value)  then	//Bug 38134
			cmbProcess.itemObject[cmbProcess.addItem(self.getProcessDisplay(proc))] := proc;
		endif;
	endforeach;
	
	if savedProc &lt;&gt; null then
		index := cmbProcess.findObject(savedProc);
		if index &gt; 0 then
			cmbProcess.listIndex := index;
		endif;
	endif;
		
	
epilog

end;
</source>
    </JadeMethod>
