    <JadeMethod name="showThumbnailData" id="1bc39565-4af9-43e4-8d19-76e1246a71b7">
        <updating/>
        <source>showThumbnailData(obj: Object) updating;

vars
	tidalDef	 : HMS_TidalModelDefinition;

begin
	if not global.isValidObject(obj) then
		self.clearThumbnailData();
		return;
	endif;

	tidalDef := obj.HMS_TidalModelDefinition;
	
	self.tblThumb.rows := 0;
	self.showThumbnailForDef(ETDef_HMSTidalModelData, tidalDef);
end;</source>
        <Parameter name="obj" type="Object"/>
    </JadeMethod>
