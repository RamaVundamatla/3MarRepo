        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="assesInvalidConsignor" id="f6157e4d-dcf4-431a-9ffd-fad05ded276c">
        <updating/>
        <source>assesInvalidConsignor(_passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 July 2019	jlgdi1	Initial creation

*/

vars
	terminal : CM_Terminal;
	copyOfErrors : CM_ErrorSet;
	error : CM_Error;
	
begin
	if not (self.ediFileCode = EDIFileType_Coparn or 
			self.ediFileCode = EDIFileType_CoparnRelease) 
	then 
		return;
	endif;

	if not (self.isKindOf(CM_EDIDataGateDoc) or 
			self.isKindOf(CM_EDIDataBooking) or 
			self.isKindOf(CM_EDIDataReleaseRequest) or 
			self.isKindOf(CM_EDIDataPrenote))
	then 
		return;
	endif;
	
	terminal := self.ediConfig.myTerminal;
	if (terminal = null) or 
	   (terminal.getConfig(EdiGateDocInvConsignor).Boolean)
	then 
		return;
	endif;
	
	// convert error into warning
	foreach error in _passport.allErrorWarnings do
		if (not error.warningOnly) and 
		   (error.errorCode = ERR_INVALID_CONSIGN) 
		then
			error.removeFromPassport();
			error.set(error.errorCode, error.text, true, error.fieldName, error.myUserObject, error.mySubject);
			error.setMyWarningPassport(_passport);
		endif;	
	endforeach;

epilog
	delete copyOfErrors;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="assignValueSpecial" id="ad3252fa-fcf8-4196-82ec-4e6497d5be5c">
        <updating/>
        <source>assignValueSpecial(_propName: String; _processedValue: String; _xlationOperator: CM_Operator): Boolean updating;
/*
07 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
08 Aug 2018	jlgrs1	TFS 39619 PEN - Approved Carriers For Operator 
21 Nov 2022	navma1	ChangeRequest 55424: MTN - Improve the performance of Edi file loading
*/
vars
	xlationOperator 	: CM_Operator;
	operator 	    	: CM_Operator;
	property 			: Property;
	propertyType 		: Type;
	fileType 			: CM_EDIFileType;
	ts 			   		: TimeStamp;
	dateDelim 			: String;
	date 				: Date;
	operatorXlationCode : String;
	foundMatch 			: Boolean;
	processedValue		: String;
	opCode 				: String;
	root				: CM_Root;
begin
	xlationOperator := _xlationOperator;
	processedValue  := _processedValue;
	
	if _propName = ETRow_OperatorCode then
		
		root := app.myRoot;														//21.11.2022 navma1 #55424
			
		if processedValue = null and   xlationOperator &lt;&gt; null then 			// null string - NULL Operator
			//self.setPropertyValue(ETRow_OperatorCode, xlationOperator.code);
			self.setOperatorCode(xlationOperator.code);							//21.11.2022 navma1 #55424
		else
			if self.operatorCode = null then
				opCode := root.getXlationSystemOperatorCode(null, processedValue, foundMatch);		//21.11.2022 navma1 #55424
				self.operatorCode := opCode[1:5];
			endif;
		endif;
		
		if self.operatorCode &lt;&gt; null then
			operator := root.allOperators[self.operatorCode];										//21.11.2022 navma1 #55424
			if operatorCode &lt;&gt; null then
				self.setOperator(operator);
			endif;
		endif;
	else

		fileType := self.getEDIFileType;
		
		// ### TFS 53953 14July2022 NAVPW1														//21.11.2022 navma1 #55424 
		//if _propName = ETRow_CargoMtchClientReference then
		//	property := self.class.getPropertyInHTree("cargoMatchClientReference");
		//else
			property := self.class.getPropertyInHTree(_propName);	//ccms 1976 15 Dec 2010 cnwrs1
		//endif;
		// ### TFS 53953 14July2022 NAVPW1
		
		if property = null then
			// there is an invalid property name within the definition - display an error so they can go in and fix it up
			app.raiseCMException3 (EDI_UDFT_PROPERTY_ERROR, fileType.name, _propName, self.class.name, null, null);	// par 23326
			return false;
		endif;
		
		if property &lt;&gt; null and property.cnEcIsPrimitive then
			propertyType := property.type;
			
			if propertyType = Integer then
				self.setPropertyValue(_propName, processedValue[1:9].Integer);	
				
			elseif propertyType = Real then
				self.setPropertyValue(_propName, processedValue.Real);	
				
			elseif propertyType = Decimal then	//cnwrs1 10 Dec 2010 ccms 1976
				self.setPropertyValue(_propName, processedValue.Decimal);
				
			elseif propertyType = Boolean then
				self.setPropertyValue(_propName, processedValue.asBooleanJMT);
				
			elseif propertyType = Character then
				self.setPropertyValue(_propName, processedValue.Character);	//par 26848 cnwrs1 31 Jan 2011
				
			elseif propertyType = Time then
				if  processedValue = null then //epr TFS 2474 1/8/16
					self.setPropertyValue(_propName, NULL_TIME);
				else
					self.setPropertyValue(_propName, processedValue.Time);
				endif;
				
			elseif propertyType = TimeStamp then
				//self.setPropertyValue(_name, processedValue.TimeStamp);
				//29 Mar 2017	NDL	TFS 3886
				ts := processedValue.ediTimeStampFormat( fileType, null, null );
				self.setPropertyValue(_propName, ts);
				
			elseif propertyType = Date then
				if fileType.isKindOf(CM_EDIFileTypeUser) then //ccms 1976 cnwrs1 31 dec 2010
					if fileType.CM_EDIFileTypeUser.dateFormat &lt;&gt; null then
						if fileType.CM_EDIFileTypeUser.dateDelimeter.Character &gt; #0.Character then
							dateDelim := fileType.CM_EDIFileTypeUser.dateDelimeter.String;
						endif;
						date := processedValue.String.ediDateFormat(fileType.CM_EDIFileTypeUser.dateFormat, dateDelim);
					else
						date := processedValue.String.asDateJMT();
					endif;
				endif;
				
				self.setPropertyValue(_propName, date);
				
			elseif propertyType = String then
				if xlationOperator = null and  _propName = ETRow_OperatorCode then
					// try and use this operator as the xlation Operator
					root := app.myRoot;																								//21.11.2022 navma1 #55424
					operatorXlationCode := root.getXlationSystemOperatorCode(xlationOperator, processedValue, foundMatch)[1:4];		//21.11.2022 navma1 #55424
					xlationOperator     := root.allOperators[operatorXlationCode];													//21.11.2022 navma1 #55424
					self.setXlationOperator(xlationOperator);
				endif;
				
				if xlationOperator &lt;&gt; null then
					self.translateValue(_propName, xlationOperator, processedValue);
				endif;
				
				//self.setStringValue(_propName, processedValue);	// ### TFS 53953 14July2022 NAVPW1 - Commented Out
			
				// ### TFS 53953 14July2022 NAVPW1													//21.11.2022 navma1 #55424 *** Temp***
				//if _propName = ETRow_CargoMtchClientReference then
				//		self.setStringValue("cargoMatchClientReference", processedValue);
				//else
					self.setStringValue(_propName, processedValue);
				//endif;
				// ### TFS 53953 14July2022 NAVPW1
			else
				//this would be an unhandled type here (not an unhandled property)!! If this happens it SHOULD raise an exception
				//and you should add code to handle the type
				app.raiseUnexpectedProgramError(class.name, method.name, 'Unhandled property type (' &amp; propertyType.String &amp; '"');
			endif;
		else
			self.setPropertyValue(_propName, processedValue);
		endif;
	endif;
	return true;
end;
</source>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_processedValue" type="String"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
