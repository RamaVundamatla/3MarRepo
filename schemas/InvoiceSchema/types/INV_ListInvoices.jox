        <source>doTblInfoDbClick(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:		March 2005 By Andrew Bishop cnwab1
//
// Purpose:		
// 11 Feb 2022 navma1	ChangeRequest 52580: SAL - Work Order and Invoicing link
// ---------------------------------------------------------------------------

vars
	obj	: Object;
begin
	if table.row &lt;= table.fixedRows or 
	   table.column &lt;= table.fixedColumns then
		inheritMethod(table);
	endif;
	
	app.mousePointer := MousePointer_HourGlass;
	
	obj := table.accessCell(table.row, table.column).itemObject.Object;
	if obj &lt;&gt; null then

		if obj.isKindOf(CM_Invoice) then
			self.myAssistant.INV_Assistant.showInvoiceLinesForInvoice(obj.CM_Invoice, self.myMasterMenuAction);
		elseif obj.isKindOf(CM_WorkOrder) then		//11.02.2022 navma1 #52580
			self.myAssistant.INV_Assistant.showWorkOrderForm(obj.CM_WorkOrder, self.myMasterMenuAction,self.myTerminal);
		else
			inheritMethod(table);
		endif;
	endif;


epilog
	app.mousePointer := MousePointer_Default;


end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
