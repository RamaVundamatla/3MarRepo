    <JadeMethod name="getEntTableDef" id="0530d6a2-7ef9-47e4-bb7e-7c731895556f">
        <source>getEntTableDef(_defName:String):EntTableDef;
// --------------------------------------------------------------------------------
// Created:		11 February 2009 by cnwdad1
//
// Purpose:		Returns a reference to the EntTableDef with the specified name.
//
// Parameters:	_defName - The name of the EntTableDef to return.
//
// Returns:		A reference to an EntTableDef object, or null.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tableDefObj	: EntTableDef;
	
begin
	return self.allEntTableDefs[_defName];
end;</source>
        <Parameter name="_defName" type="String"/>
        <ReturnType type="EntTableDef"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="03e38d5e-f370-4752-9cb0-50dfbf5e9dab">
        <updating/>
        <source>setForCreate(pName: String; pText: String; pSchema: String; pGroupCategory: String; pDefCategory: String; pRowCategory: String) updating;
// ---------------------------------------------------------------------------
// Created:     26 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	inheritMethod(pName, pText, pSchema, pGroupCategory, pDefCategory, pRowCategory);

	self.myRoot := app.myRoot;
	
end;</source>
        <Parameter name="pName" type="String"/>
        <Parameter name="pText" type="String"/>
        <Parameter name="pSchema" type="String"/>
        <Parameter name="pGroupCategory" type="String"/>
        <Parameter name="pDefCategory" type="String"/>
        <Parameter name="pRowCategory" type="String"/>
    </JadeMethod>
    <JadeMethod name="translateConstantName" id="18311b94-24e6-4714-9c0c-ae07f25495ac">
        <source>translateConstantName(pType, pName: String): String;
// ---------------------------------------------------------------------------
// Created:     28 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theType	: String;
	
begin

	theType := pType.toUpper;

	if theType = GroupType then
		return inheritMethod(pType, pName);

	elseif theType = RowType then
		if pName = 'availableToShippingCompany' then
			return 'AvailableToShippingCoy';
		elseif pName = 'hasCoolingWaterConnection' then
			return 'HasCoolingWaterConn';
		elseif pName = 'plannedReceivalTransportMode' then
			return 'PlannedReceivalTransMode';
		elseif pName = 'plannedReleaseTransportMode' then
			return 'PlannedReleaseTransMode';
		elseif pName = 'requiresConsigneeConsignor' then
			return 'RequiresConsigneeOr';
		else
			return inheritMethod(pType, pName);
		endif;

	elseif theType = DefType then
		return inheritMethod(pType, pName);

	else
		app.writeStatement( class.name &amp; '::' &amp; method.name &amp; '  Invalid type (' &amp; pType &amp; ')');
	endif;

end;</source>
        <Parameter name="pType" type="String"/>
        <Parameter name="pName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
