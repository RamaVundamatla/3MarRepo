    <JadeMethod name="tblInput2_change" id="951ce73a-1b37-423b-8307-727434e9b00e">
        <controlMethod name="CM_EntryTable::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblInput2_change(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 March 2023	navsp1	Initial creation TFS 56275

*/

vars
	tblData		: CM_EntryTable;
	row1		: Integer;
	row1Value, 
	row2Value 	: Boolean;
begin
	tblData := table.CM_EntryTable;
	row1 := tblData.getRow(ETRow_EDIEnforceVoyageMatch);	
	if table.row = row1 then
		if (self.myCurrentTableItem.isKindOf(SOPTM_Terminal)) and self.mode = self.Mode_Update then
			row1Value := tblData.getValueByName(ETRow_EDIEnforceVoyageMatch).Boolean;
			row2Value := tblData.getValueByName(ETRow_EDIEnforceVeslMatchExprt).Boolean;
			if row1Value = false then
				tblData.setValueByName(ETRow_EDIEnforceVeslMatchExprt,false);
				tblData.disableRowByName(ETRow_EDIEnforceVeslMatchExprt);
			else
				tblData.enableRowByName(ETRow_EDIEnforceVeslMatchExprt);
			endif;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblInput2_click" id="c42b37bb-1ec9-4bbb-979b-fbebcf910efb">
        <controlMethod name="CM_EntryTable::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblInput2_click(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:		24 March 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 19/06/2019	jlgdap1		TFS 43765 SNO Booking Operator Code Road Gate Defaults
// 02/11/2022	navdap1		TFS 54899 PEN Reefer Monitor App Changes
// 14/08/2025	navdap1		MTN-35604 NSW - Partial Load Voyage EDI
vars
	tbl2		: CM_EntryTable;
	rowInTable	: Integer;
	machineType : Integer;
	
begin

	tbl2 := table.CM_EntryTable;
	rowInTable := tbl2.getRow(ETRow_HasRadioTelemetry);
	if tbl2.row = rowInTable and rowInTable &gt; 0 then
		if self.myCurrentTableItem.isKindOf(SOPTM_Machine) then
			if self.cmbMachineType.listObject &lt;&gt; null then
				machineType:= self.cmbMachineType.listObject.CM_MachineType.type;
				 
			endif;
			self.myCurrentTableItem.SOPTM_Machine.showHideRowsForRT(tbl2.getValueByName(ETRow_HasRadioTelemetry).Boolean ,machineType);
		endif;
		self.resize;
	endif;
	
	// TFS 43765
	// If "Prefill Prenote Container from previous visit at Road Gate" is unticked,
	rowInTable := tbl2.getRow(ETRow_PrefillPreNoteRoadGate);
	if rowInTable = tbl2.row and tbl2.getValueByName(ETRow_PrefillPreNoteRoadGate).Boolean = false then
		// untick "Prefill Prenote Container from Booking" row as well
		tbl2.setValueByName(ETRow_PrefillRecContBookGate, false);
	endif;
	// If "Prefill Prenote Container from Booking" is ticked,
	rowInTable := tbl2.getRow(ETRow_PrefillRecContBookGate);
	if rowInTable = tbl2.row and tbl2.getValueByName(ETRow_PrefillRecContBookGate).Boolean = true then
		// tick "Prefill Prenote Container from previous visit at Road Gate" row as well
		tbl2.setValueByName(ETRow_PrefillPreNoteRoadGate, true);
	endif;
	// TFS 43765 end
	
	// TFS 54899 start
	rowInTable := tbl2.getRow(ETRow_AllReeferJobsForTerminal);
	if rowInTable = tbl2.row then 
		// if "Reefer App - Show All Terminal Reefer Jobs Oldest First" is ticked, 
		if tbl2.getValueByName(ETRow_AllReeferJobsForTerminal).Boolean = true then
			// untick and disable the Include Jobless Reefers row
			tbl2.setValueByName(ETRow_IncludeJoblessReefers, false);
			tbl2.disableRowByName(ETRow_IncludeJoblessReefers);
			// enable the Reefer App Show None option in cmbSortOrder
			self.cmbSortOrder.itemEnabled[1] := true;
		else
			// enable the Include Jobless Reefers row
			tbl2.enableRowByName(ETRow_IncludeJoblessReefers);
			// disable the Reefer App Show None option in cmbSortOrder
			self.cmbSortOrder.itemEnabled[1] := false;
			self.cmbSortOrder.listIndex := 2;
			self.tblInput2.setValueByName(ETRow_ReeferJobGrouping, self.cmbSortOrder.text);
		endif;
	endif;
	
	// MTN-35604 start
	rowInTable := tbl2.getRow(ETRow_EdiVoyagePartialWarning);
	if rowInTable = tbl2.row then
		// If "Warn if other DB Loaded / Partial OnePort files exist" is ticked,
		if tbl2.getValueByName(ETRow_EdiVoyagePartialWarning).Boolean = true then
			// enable the Number of Previous Days to Check for DB Loaded row
			tbl2.enableRowByName(ETRow_EdiVoyagePartialWarnDays);
		else
			// disable and clear the Number of Previous Days to Check for DB Loaded row
			tbl2.disableRowByName(ETRow_EdiVoyagePartialWarnDays);
			tbl2.setValueByName(ETRow_EdiVoyagePartialWarnDays, null);
		endif;
	endif;
	// MTN-35604 end
	
	//25 Aug 2021	NDL	TFS 51632
	self.doTableHandlePassword( tbl2, 0, 0 );
	self.currentRowNumber := tbl2.row; // TFS 52235 2NOV2021 NAVLW1
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblInput2_dblClick" id="93c2dab8-74b6-4605-920e-04735d848f61">
        <controlMethod name="CM_EntryTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblInput2_dblClick(table: CM_EntryTable input) updating;
/*

Date		Who		Reason
11 May 2016	cnwer1	Initial creation TFS 1882

*/

vars

begin
	if self.mode &lt;&gt; self.Mode_View and table.row = table.getRowByName(ETRow_PrenoteCertWeightValCrit) and self.myCurrentTableItem.isKindOf(SOPTM_Terminal) then
		self.myCurrentTableItem.SOPTM_Terminal.doShowCriteriaForm();
	endif;
	//22 Oct 2019	NDL	TFS 46911
	if self.mode &lt;&gt; self.Mode_View and table.row = table.getRowByName(ETRow_RoadGateCargoCheckCrit) and self.myCurrentTableItem.isKindOf(SOPTM_Terminal) then
		self.myCurrentTableItem.SOPTM_Terminal.doShowRGCriteriaForm();
	endif;
epilog

end;</source>
        <Parameter name="table" type="CM_EntryTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblInput2_mouseDown" id="0623c8dc-dca0-48c3-820a-4001da12c20d">
        <controlMethod name="CM_EntryTable::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblInput2_mouseDown(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 November 2012	cnwndl1	Initial creation	Par 30682

*/

vars

	rowInTable	: Integer;
	text : String;

begin

	if self.myCurrentTableItem.isKindOf(SOPTM_Terminal) then
		rowInTable := table.CM_EntryTable.getRow(ETRow_DotMatrixInvoiceRep);
		if table.row = rowInTable and rowInTable &gt; 0 then
			if button = 2 then
				text := table.getCellText(table.row,2).trimBlanks;
				app.printReportDotMatrixLineUp( text );
			endif;
		endif;
	endif;
	

epilog

end;</source>
