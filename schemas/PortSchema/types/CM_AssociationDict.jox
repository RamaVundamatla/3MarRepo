    </JadeMethod>
    <JadeMethod name="addAssociation" id="e05a85a9-0d18-4be5-95a6-df59b436946d">
        <source>addAssociation(_key: String; _value: Any);
//23 October 2008	cnwdw1	
//
vars
	association: CM_Association;
	upperKey : String;
	
begin
	upperKey := _key.toUpper();
	
	if self.includesKey(upperKey) then
		association := self[upperKey];
	else
		create association transient;
		self[upperKey] := association;
	endif;
	association.setValue(_value);
end;</source>
        <Parameter name="_key" type="String"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
