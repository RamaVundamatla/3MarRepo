<Class name="CM_QStopsProperty" id="23ec87c5-0a69-4d15-a86b-81ee5468938a">
    <superclass name="CM_QIntegerLookupProperty"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <JadeMethod name="create" id="84a7b8a3-b54d-407a-b7c0-700d4fd125bc">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     22 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	oper : CM_QueryOperator;

begin
	if self.isTransient then 
		return;
	endif;
		
	create oper as CM_QIntegerIsOneOf persistent;
	self.allAllowedOperators.add(oper);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setListValues" id="9ff5330c-6bfd-4443-9afd-32fad0e175a2">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QIntegerIsOneOf; _passport: CM_Passport);
// ---------------------------------------------------------------------------
// Created:     22 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

	stopTable			: CM_StopsTable;
	stopTablesDict		: CM_StopsTableByIdDict;
	selectionValue	: Integer;
	idx				: Integer;
begin
	
	_tbl.rows := _tbl.fixedRows;
	stopTablesDict := app.myRoot.allStopsTable;
	
	foreach stopTable in stopTablesDict do
		selectionValue := 0;
		if _operator &lt;&gt; null 
		and _operator.allSelectionValues.includes(stopTable.id) then
			selectionValue := 1;
		endif;
		idx := _tbl.addItem(selectionValue.String &amp; Tab &amp; stopTable.heading);	
		_tbl.accessRow(idx).itemObject := stopTable;
		_tbl.row := idx;
		_tbl.change(_tbl);
	endforeach;


end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QIntegerIsOneOf"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="7af47c0a-d304-4445-ab83-80ce3f092a43">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
// ---------------------------------------------------------------------------
// Created:     22 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	stopTable		: CM_StopsTable;
	str			: String;
	numRows,
	idx			: Integer;
	ia			: IntegerArray;

begin
	create ia transient;
	
	numRows := _tbl.rows;
	foreach idx in (_tbl.fixedRows + 1) to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			stopTable := _tbl.accessRow(idx).itemObject.CM_StopsTable;
			ia.add(stopTable.id);
		endif;
	endforeach;
	
	_op.setSearchValue(ia);

epilog
	delete ia;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateStringToSearchValue" id="a4cbd6b8-f776-4cbb-b03c-628a25175750">
        <source>translateStringToSearchValue(_value: Any; _criteriaLine : CM_SelectorCriteriaLine ): Any;
// ----------------------------------------------------------------------
// Created 12 May 2008 by cnwvu1
//
// Purpose:	Gets value as String from RT screen and returns value
//			 into criteriaLineLine for running a query
// ----------------------------------------------------------------------

vars
	stopTable		: CM_StopsTable;
	codeDict		: CM_StopsTableByIdDict;
	tmpDescription	: String;
	
begin
	
	if _value.isKindOf( CM_StopsTable ) then
		return _value;
	endif;
	
	tmpDescription	:= _value.String.toUpper();
	codeDict := app.myRoot.allStopsTable;
	
	foreach stopTable in codeDict discreteLock do
		if tmpDescription = stopTable.heading.toUpper() then
			return stopTable.id;
		endif;
	endforeach;
	
	// when not found. Par 17092	cnwvu1, June 2008
	inheritMethod( _value, _criteriaLine );

end;
</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_criteriaLine" type="CM_SelectorCriteriaLine"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="ac006a34-c7c7-4d2b-91d1-34011b8d3eda">
        <source>translateToDisplayValue(_value: Any): String;
// ---------------------------------------------------------------------------
// Created:     22 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	stop			: CM_Stops;
	dict			: CM_StopsByIdDict;
	str				: String;
begin

	if _value.isKindOf(CM_StopsByIdDict) then
		dict := _value.CM_StopsByIdDict;
		foreach stop in dict do
			str := str &amp; stop.myStopsTable.heading &amp; ', ';
		endforeach;
	else
		str := app.myRoot.allStopsTable[_value.Integer].heading;
	endif;
	
	return str;

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="06ededa6-27c3-4187-8aae-7a53a3689ab4">
        <source>translateToSearchValue(_value: Any): Any;
// ---------------------------------------------------------------------------
// Created:     16 October 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	return app.myRoot.allStopsTable[_value.Integer].id;
end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
