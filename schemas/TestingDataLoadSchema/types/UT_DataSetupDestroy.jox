	self.getJobSlotControllers(_voyage.code, "05", DeckUnderDeck, 6, 2, 1, slots);
	self.getJobSlotControllers(_voyage.code, "05", DeckUnderDeck, 5, 3, 1, slots);
	self.getJobSlotControllers(_voyage.code, "05", DeckUnderDeck, 6, 4, 1, slots);
	self.getJobSlotControllers(_voyage.code, "05", DeckUnderDeck, 5, 5, 1, slots);
