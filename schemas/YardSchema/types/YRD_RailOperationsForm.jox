    <JadeMethod name="txtEffectiveDate_lostFocus" id="8bbcef08-d7e3-42b7-aa8e-9418c92dacda">
        <controlMethod name="CMUI_DateMask::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtEffectiveDate_lostFocus(editMask: JadeEditMask input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 February 2021	navndl1	Initial creation	TFS 50837

*/

vars

	date : Date;
	msg : String;

begin

	date := self.txtEffectiveDate.getDate();

	if self.chkRetrospect.value and date.isValid then
		self.retrospectiveDate.setDate( date );
	else
		self.retrospectiveDate := null;
		self.txtEffectiveDate.setDate( null );
	endif;
	
	self.validateRetrospectiveTS( null );
	

epilog

end;</source>
        <Parameter name="editMask" type="JadeEditMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtEffectiveTime_lostFocus" id="dc64f165-38be-47d3-8269-49f3f58d1b3a">
        <controlMethod name="CMUI_TimeMask::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtEffectiveTime_lostFocus(editMask: JadeEditMask input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 February 2021	navndl1	Initial creation	TFS	TFS 50837

*/

vars

	time : Time;
	msg : String;

begin

	time := self.txtEffectiveTime.getTime();

	if self.chkRetrospect.value and time.isValid then
		self.retrospectiveDate.setTime( time );
	else
		if self.retrospectiveDate.time.isValid then
			self.txtEffectiveTime.setTime( null );
		endif;
	endif;
	
	self.validateRetrospectiveTS( null );

epilog

end;</source>
        <Parameter name="editMask" type="JadeEditMask" usage="input"/>
