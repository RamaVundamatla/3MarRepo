    <JadeMethod name="doDeleteRequest" id="c0a10672-c213-4d1e-abcf-50a2a7b111a4">
        <updating/>
        <source>doDeleteRequest( menuItem : MenuItem ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 November 2011	cnwndl1	Initial creation	Par 28366

*/

vars
	result,
	row : Integer;
	wle : CM_WorkListEntry;
	tbl : CM_DataTable;
begin
  	app.mousePointer := MousePointer_HourGlass;
  	
	if menuItem = null then
		return;
	else
		wle := menuItem.userObject.CM_WorkListEntry;
	endif;
	if wle = null then
		return;
	endif;
	
	if wle.isReceipt then
		tbl := self.tblReceivals;
	else
		tbl := self.tblReleases;
	endif;
	
	tbl.findObjectInRow(wle, row);
	
	while true do
		app.myTrxDA.trxDeleteJobEntry(wle, null, app.myPassport); // cnwrd1 par 22624 3.5.2010
		if app.myPassport.trxCompletedOK then
			break;
		else
			result := app.showErrorWarningDialog('Road Ops', app.myPassport, ErrWarnMode_Delete + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;

	if app.myPassport.trxCompletedOK then
		tbl.deleteRow(row);
		self.myCurrentWLE := null;
	endif;
	
epilog
	app.mousePointer := MousePointer_Default;  	
end;</source>
        <Parameter name="menuItem" type="MenuItem"/>
    </JadeMethod>
    <JadeMethod name="doMenuComplete" id="322b6504-eb55-4b59-9d40-9011599cbb7e">
        <updating/>
        <source>doMenuComplete() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 February 2010	cnwjk3	ccms 1071

*/

vars

begin
	if self.myCurrentWLE = null then
		return;
	endif;
	
	if not self.myCurrentWLE.myRequest.isKindOf(CM_ReceivalRequest) then
		return;
	endif;
	
	app.myTrxUA.trxUpdateWLEStatusDirectWLE(self.myCurrentWLE.CM_YardWLE, WLE_COMPLETED, app.myPassport);
	
	self.doRefresh();
	
epilog

end;</source>
