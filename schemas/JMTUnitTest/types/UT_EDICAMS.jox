	self.assertNotNull (port);

	// ### 20 MT
	cargo1 := self.addCargoAtLocationDetailed(CargoID1, cargoTypeObj, cargoSubType, bs.myLocationsController, "NZCHC", TI_IMEX_STATUS_EXPORT, voyage, operator);
