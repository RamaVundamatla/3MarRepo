    <JadeMethod name="getOIDAndDescForAttribute" id="55bd3989-4fb3-4a9b-82ce-e63133747ab3">
        <source>getOIDAndDescForAttribute(_attrName : String; _getCalculatedDate : Boolean; _oid:String output) : String;
// ---------------------------------------------------------------------------
// Created:     19/07/2010 cnwdz2	
//
// Purpose:     PAR24513 extend the current existing getDisplayStringForAttribute method to return an object's oid.		 
// ----------   ----------  --------------------------------------------------
vars
	runDate			: Date;
begin
	runDate := self.systemToLocalTime(app.actualTimeServer()).Date;	// 28/4/16 cnwmp6 TFS 488 - Multi timezone support
	
	if _attrName = ETRow_CarrierCode or
	   _attrName = ETRow_Carrier then
		return self.carrierCode;
		
	elseif _attrName = ETRow_GangNumber then
		return self.gangNumber;
	
	elseif _attrName = ETRow_DocketError then			//ccms 1110 begins
		if self.getMyDocketErrorType &lt;&gt; null then
			_oid := self.getMyDocketErrorType.getOidAsString(); //20/07/2010 cnwdz2 24513
			return self.getMyDocketErrorType.code;
		endif;
		return Any_String;
		//return self.logDocketErrorCode;		// for 781 should be this
		
	elseif _attrName = ETRow_PieceCountError then
		return self.isPieceCountError.cnEcGetTableCheckBoxValue(); // #24306	01/06/2010
		
	elseif _attrName = ETRow_HasComments then
		return self.hasComments.cnEcGetTableCheckBoxValue;
	
	elseif _attrName = ETRow_MyLogSpecies or
		_attrName = ETRow_LogSpecies then
		if self.getMyLogSpecies &lt;&gt; null then
			_oid := self.getMyLogSpecies.getOidAsString(); //20/07/2010 cnwdz2 24513
			return self.getMyLogSpecies.code;
		endif;
		return Any_String;
		
	elseif _attrName = ETRow_MyLogGrade or
		_attrName = ETRow_LogGrade then
		if self.getMyLogGrade &lt;&gt; null then
			_oid := self.getMyLogGrade.getOidAsString(); //20/07/2010 cnwdz2 24513
			return self.getMyLogGrade.code;
		endif;
		return Any_String;
		
	elseif _attrName = ETRow_MyLogType or
		_attrName = ETRow_LogType then
		if self.getMyLogType &lt;&gt; null then
			_oid := self.getMyLogType.getOidAsString(); //20/07/2010 cnwdz2 24513
			return self.getMyLogType.code;
		endif;
		return Any_String;

	elseif _attrName = ETRow_MyLogTreatment or
		_attrName = ETRow_LogTreatment then
		if self.getMyLogTreatment &lt;&gt; null then
			_oid := self.getMyLogTreatment.getOidAsString(); //20/07/2010 cnwdz2 24513
			return self.getMyLogTreatment.code;
		endif;
		return Any_String;

	elseif _attrName = ETRow_MyLogLength or
		_attrName = ETRow_LogLength then
		if self.getMyLogLength &lt;&gt; null then
			_oid := self.getMyLogLength.getOidAsString(); //20/07/2010 cnwdz2 24513
			return self.getMyLogLength.code;
		endif;
		return Any_String;
	
	elseif _attrName = ETRow_LoggingOrganisation then
		return self.loggingOrganisation;
	
	elseif _attrName = ETRow_LoggingOperation then
		return self.loggingOperation;
		
	elseif _attrName = ETRow_MatchDateStart then
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.matchStartDateTplType, self.matchStartDateTplFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.matchStartDateTplType, self.matchStartDateTplFactor);
		endif;
		
	elseif _attrName = ETRow_MatchDateEnd then
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.matchEndDateTplType, self.matchEndDateTplFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.matchEndDateTplType, self.matchEndDateTplFactor);
		endif;
		
	elseif _attrName = ETRow_MatchTimeStart then
		//return self.matchStartDate.time.String;
		return self.matchStartDate.time.asStringJMT(); //par 18944 cnwjo3
		
	elseif _attrName = ETRow_MatchTimeEnd then
		//return self.matchEndDate.time.String;
		return self.matchEndDate.time.asStringJMT();  //par 18944 cnwjo3
	
	elseif _attrName = ETRow_SrcLocation then
		return self.sourceLocation;
	
	elseif _attrName = ETRow_SrcSubLocation then
		return self.sourceSubLocation;
	
	elseif _attrName = ETRow_SrcSubSubLocation then
		return self.sourceSubSubLocation;
	endif;

	return inheritMethod(_attrName, _getCalculatedDate, _oid);


end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_getCalculatedDate" type="Boolean"/>
        <Parameter name="_oid" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="30943247-bf53-484b-9003-f1bed5562133">
        <updating/>
        <source>includesObject(_docket: CM_BOLIn; _passport : CM_Passport; _breakOut : Boolean output): Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     06 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	bolExt			: CM_BOLExtLogIn;
	queryBol		: CMQF_BOLInLog;
	failedDAC  :CM_DataAccessController;
	
begin
	queryBol := self;
	queryBol.numSearched := queryBol.numSearched + 1;
	
	//some matching criteria are off the bol extension
	if _docket.myExtension &lt;&gt; null then//and _docket.myExtension.isKindOf(CM_BOLExtLogIn) then
		bolExt := _docket.myExtension.CM_BOLExtLogIn;
	else
		return false;
	endif;
	
	if (queryBol.matchStartDate.isValid) and (not _docket.matchTime.isValid) then
		return false;
	endif;
	
	if (queryBol.hasComments = false or _docket.hasComments = queryBol.hasComments)
	and (queryBol.docketNumber = null or  _docket.number.startsWith(queryBol.docketNumber))
	and	(queryBol.myOperator = null or queryBol.myOperator = _docket.myOperator)
	and (queryBol.consignor = null or queryBol.consignor = _docket.consignor)
	and (queryBol.getMyLogSpecies = null or queryBol.getMyLogSpecies = _docket.myLogSpecies)
	and (queryBol.getMyLogGrade = null or queryBol.getMyLogGrade = _docket.myLogGrade)
	and (queryBol.getMyLogType = null or queryBol.getMyLogType = _docket.myLogType)
	and (queryBol.getMyLogTreatment = null or queryBol.getMyLogTreatment = _docket.myLogTreatment)
	and (queryBol.getMyLogLength = null or queryBol.getMyLogLength = _docket.myLogLength)
	and (queryBol.carrierCode = null or queryBol.carrierCode = _docket.carrierCode)
	and (queryBol.sourceLocation = null or queryBol.sourceLocation = _docket.sourceLocation)
	and (queryBol.sourceSubLocation = null or queryBol.sourceSubLocation = _docket.sourceSubLocation)
	and (queryBol.sourceSubSubLocation = null or queryBol.sourceSubSubLocation = _docket.sourceSubSubLocation)
	and (queryBol.loggingOperation = null or queryBol.loggingOperation = _docket.loggingOperation)
	//and (queryBol.loggingOrganisation = null or queryBol.loggingOrganisation = _docket.loggingOrganisation)//#cnwdz2	 CCMS 1108 par22177 
	and (queryBol.loggingOrganisation = null or queryBol.loggingOrganisation = _docket.getLoggingOrganisation())
	and (queryBol.getMySubTerminal = null or queryBol.getMySubTerminal = _docket.mySubTerminal) //28/04/2009 cnwdz2 ccms1735
	and (queryBol.gangNumber = null or queryBol.gangNumber = bolExt.gangNumber)	
	and (queryBol.getMyDocketErrorType = null or queryBol.getMyDocketErrorType.code = _docket.getLogDocketErrorCode() )	// #24306 01/06/2010
	and (queryBol.isPieceCountError = false or (queryBol.isPieceCountError and _docket.hasPieceCountError()))	// #23894	24/05/2010
	then
		if not _docket.canUserAccessSelf(null, failedDAC, _passport) then	//now testing all data access	PAR 10614
			return false;
		endif;

		queryBol.numFound := queryBol.numFound + 1;
		return true;
	endif;
	
	return false;
end;</source>
        <access>protected</access>
        <Parameter name="_docket" type="CM_BOLIn"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setDatesForTemplateRun" id="ec5a1105-d765-476e-a934-06479f13b69e">
        <updating/>
        <source>setDatesForTemplateRun(_runDate : Date) updating;
// ---------------------------------------------------------------------------
// Created:     10 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	inheritMethod(_runDate);
	
	self.matchEndDate.setDate(self.setDateFromTemplate(self.matchEndDateTplType, 
											self.matchEndDateTplFactor, 
											_runDate));
											
	self.matchStartDate.setDate(self.setDateFromTemplate(self.matchStartDateTplType, 
											self.matchStartDateTplFactor, 
											_runDate));
	

end;</source>
        <Parameter name="_runDate" type="Date"/>
    </JadeMethod>
    <JadeMethod name="setFromTemplate" id="40a0fbcd-0cad-4399-bdff-2b79af653601">
        <updating/>
        <source>setFromTemplate(_obj: CMQF_FilterReports; _runDate: Date; _allEventData : CM_EventDataByTypeDict) updating;
// ---------------------------------------------------------------------------
// Created:     07 March 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(_obj, _runDate, _allEventData);

	self.matchStartDate.setDate(self.setDateFromTemplate(self.matchStartDateTplType, self.matchStartDateTplFactor, _runDate));

	if self.matchEndDate.time = null then //only a consideration for data pre 715 i - as after that time automatically sets to 23:59:59:999
		self.matchEndDate.setDate(self.setDateFromTemplate(self.matchEndDateTplType, self.matchEndDateTplFactor, _runDate) + 1);
	else
		self.matchEndDate.setDate(self.setDateFromTemplate(self.matchEndDateTplType, self.matchEndDateTplFactor, _runDate));
	endif;
	
end;</source>
        <Parameter name="_obj" type="CMQF_FilterReports"/>
        <Parameter name="_runDate" type="Date"/>
        <Parameter name="_allEventData" type="CM_EventDataByTypeDict"/>
    </JadeMethod>
