    <JadeMethod name="getObjects" id="2ac90651-80aa-4af7-9067-81a36c391d63">
        <source>getObjects(objects: ObjectLongNameDict input);
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
13 July 2022	navsj20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details

*/

vars
	damageParty: CM_DamageParty;
	terminal: CM_Terminal;
begin
	terminal	:=	app.getMyTerminalDO_NOT_USE;
	foreach damageParty in terminal.allDamageParties do
		objects[damageParty.getYAIdentifier] := damageParty;
	endforeach;
epilog

end;</source>
        <Parameter name="objects" type="ObjectLongNameDict" usage="input"/>
    </JadeMethod>
