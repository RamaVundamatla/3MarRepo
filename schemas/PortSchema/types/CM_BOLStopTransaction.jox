    </JadeMethod>
    <JadeMethod name="getDisplayID" id="d44af4ef-1417-447e-86f2-8c88aa33d41b">
        <source>getDisplayID(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 November 2019	jlgndl1	Initial creation	TFS 47100

*/

vars

begin
	return inheritMethod &amp; " " &amp; self.stopDescription;

epilog

end;</source>
