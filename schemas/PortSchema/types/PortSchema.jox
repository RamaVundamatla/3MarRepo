    <JadeMethod name="getLatestObjEdition" id="e8fad607-e29d-41ab-9e87-2b1ad60152a1">
        <source>getLatestObjEdition(_obj: Object) : Integer;
// ---------------------------------------------------------------------------
// Created:     23 July 2003 by cnwsb1
//
// Purpose:		Returns the latest object edition number, and retrieves the
//				latest object version into cache (if it wasn't already there).
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
26 May 2008	cnwkpd1	PAR #16814 - Replace global.commonResumInvalidObjHandler

*/

vars
	needUnlock : Boolean;
	error : Boolean;
	objEdition : Integer;

begin
	if _obj = null then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject(exception, _obj, error);		// PAR #16814
	
	error := false;
	if isLockedByMe(_obj) then
		// Already locked by me - so have the latest edition already
	else
		// Share lock the object to guarantee the latest edition
		sharedLock(_obj);
		needUnlock := true;
	endif;
	
	objEdition := _obj.edition;
	if not error then
		return objEdition;
	endif;
	
	return 0;
	
epilog
	// Put the unlock in the epilog to make sure it gets executed. Be sure to
	// guard against null to avoid a 1090 exception on the unlock. There's no
	// problem if a method exits (and executes the epilog) before the lock has
	// been done as Jade does nothing if an unlock is requested on an object
	// that isn't locked by the calling process.
	if needUnlock and _obj &lt;&gt; null and not error then
		unlock(_obj);
	endif;
end;</source>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getLicenseName" id="098b6ec1-5bab-4c86-94e0-2ab3ad0a620c">
        <source>getLicenseName( _permissionNumber : Integer ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 October 2019	jlgndl1	Initial creation	TFS 46169

*/

constants
	StartTag : String = "&lt;Description&gt;";
	EndTag : String = "&lt;/Description&gt;";
vars

	category : ConstantCategory;
	const : Constant;
	constDict : ConstantNDict;
	constantText : String;
	startPos : Integer;
	endPos : Integer;
	length : Integer;

begin

	if _permissionNumber &gt; Mod_BaseView then
		// Its a 'license' permisssion we want the value off the constant
		// that is stored in the 'XML' on the constant.

		category := currentSchema.getCategory(XLAT_Permissions);		
		constDict := category.getConstants();
		
		foreach const in constDict do
			if const.getSource = _permissionNumber.String then
				constantText := const.text;
				startPos := constantText.pos(StartTag,1);
				if startPos &gt; 1 then
					startPos := startPos + StartTag.length;
					endPos := constantText.pos(EndTag,startPos);
					if endPos &gt; 1 then
						length := endPos - startPos;
						return constantText[ startPos : length ];
					endif;
				endif;
			endif;
		endforeach;
	
	else
		//Its actually just a std permission.
		//Return the translated version.
		return self.getPermissionName( _permissionNumber );

	endif;
	
	return null;

epilog

end;</source>
        <Parameter name="_permissionNumber" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLockDetailsForObject" id="49f525dc-459a-4f48-8a3e-5a649958ba3b">
        <source>getLockDetailsForObject(_obj : Object; _userCode : String output) : Boolean;
//--------------------------------------------------
// Created:	30 July 2004 By: cnwgd1
//--------------------------------------------------
vars
	theLock  : Lock;
	la : LockArray;
begin
	if _obj = null then
		return false;
	endif;
	create la transient;
	system.getLocks(la, 10000);
	foreach theLock in la do
		if theLock.target &lt;&gt; _obj then
			continue;
		endif;
		//Return the lock
		if theLock.lockedBy &lt;&gt; null then
			_userCode := theLock.lockedBy.userCode;
		elseif theLock.requestedBy &lt;&gt; null then
			_userCode := theLock.requestedBy.userCode;
		else
			_userCode := 'user unknown';
		endif;			
		return true;
	endforeach;
	return false;
epilog
	la.purge;
	delete la;		
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_userCode" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getLockExceptionDetails" id="3288c870-9223-4d40-b41d-5835ea7c3cf6">
        <source>getLockExceptionDetails(exObj : Exception; _lockedByProcess : Process output; 
		_lockTypeStr, _lockedUser, _lockedByUser : String output;
		_terminal : CM_Terminal output; 
		_targetOid, _targetClass : String output; 
		_logFileName : String output) protected;
// ---------------------------------------------------------------------------
// Created:     20 December 2002 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
14 Sep 2012	cnwkpd1	PAR #30027 - locking framework issues
	
*/
vars
	obtainedObj,
	targetObj		: Object;
	obtained		: String;	
begin

	if exObj.isKindOf(LockException) then
		_lockTypeStr := 'Lock';
		targetObj := exObj.LockException.lockTarget;
		_lockedByProcess := exObj.LockException.targetLockedBy;
	elseif exObj.isKindOf(DeadlockException) then
		_lockTypeStr := 'Deadlock';
		targetObj := exObj.DeadlockException.lockTarget;
		_lockedByProcess := exObj.DeadlockException.targetLockedBy;
	 	obtained	:= app.cnGetClassAndOid(exObj.DeadlockException.obtainedLock);
	else
		return;
	endif;

	if targetObj &lt;&gt; null then
		_targetOid := self.getOidStringForObject(targetObj);
		_targetClass	:= self.getClassNameForObject(targetObj);
	else
		_targetOid := '&lt;unknown&gt;';
		_targetClass := '&lt;unknown&gt;';
	endif;

	_lockedByUser := '&lt;unknown&gt;';

	if _lockedByProcess &lt;&gt; null then
		on LockException do ignoreObjectLockedExHandler(exception, _lockedByProcess);
		_lockedByUser := _lockedByProcess.userCode;
		on LockException do null;			// PAR #30027
	endif;

	if app.myPassport &lt;&gt; null then
		_terminal := app.myPassport.myTerminal;
		_lockedUser	:= app.myPassport.userCode;
	endif;
	if _lockedUser = null then
		_lockedUser	:= '&lt;unknown&gt;';
	endif;
	
	if app.myLogFile &lt;&gt; null then
		_logFileName := app.myLogFile.fileName;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="exObj" type="Exception"/>
        <Parameter name="_lockedByProcess" type="Process" usage="output"/>
        <Parameter name="_lockTypeStr" type="String" usage="output"/>
        <Parameter name="_lockedUser" type="String" usage="output"/>
        <Parameter name="_lockedByUser" type="String" usage="output"/>
        <Parameter name="_terminal" type="CM_Terminal" usage="output"/>
        <Parameter name="_targetOid" type="String" usage="output"/>
        <Parameter name="_targetClass" type="String" usage="output"/>
        <Parameter name="_logFileName" type="String" usage="output"/>
    </JadeMethod>
