    <JadeMethod name="doSave" id="785869e5-552f-4d11-b4fc-78a49f7e524e">
        <updating/>
        <source>doSave() : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     16 October 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if self.aIsForCreation then  //we are creating persistent break bulks from this screen
		if not self.saveAttachmentsAsTIs then
			return false;
		endif;
	endif;
	
	inheritMethod();

end;</source>
        <ReturnType type="Boolean"/>
