    <JadeWebServicesMethod name="machineDoPickup" id="628bd302-ddc4-412b-ae7f-3e1a3cbfc4af">
        <source>machineDoPickup(_request : WS_MachinePickupTaskRequest)  : WS_MachineStatusResponse webService;
/*

Date		Who		Reason
22 May 2017	cnwer1	Initial creation TFS 995
20 Mar 2020 cnwma1 Bug 48757: SNO - Power disconnection
*/

vars

	response		: WS_MachineStatusResponse;
	completedOK		: Boolean;
	wsMachineTasks  : WS_MachineStatus;
	weight 			: Decimal[16,4];
	terminal        : CM_Terminal;
	ti 				: CM_TrackedItem;
	connectParams	: CMIF_ConnectParams;
	doDisconnect    : Boolean;
	infoMessage 	: WS_InfoMessage;
	id              : String;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null ;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
		
	self.validateCurrentMachine(true);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	if currentSession.myCurrentMachine.currentQueueTask &lt;&gt; null then
		ti := currentSession.myCurrentMachine.currentQueueTask.ti;
		if ti &lt;&gt; null then
			if ti.isBulkByWeight then
				weight:=_request.weight;
			elseif ti.isBulkByVolume then
				weight:= ti.getDensity * _request.volume;
			endif;
		endif;
	endif;
	
	//20.03.2020 cnwma1 #48757
	terminal     := app.myPassport.myTerminal;
	
	if ti &lt;&gt; null then
		id := ti.id;
		if ti.isConnected  then
			if not  terminal.getConfig(SetConnectedTIToHeld).Boolean then
				if _request.ignoreErrorCodes.Integer = MACH_LIFT_POWER then
					app.myPassport.errorsToIgnore.add(MACH_LIFT_POWER);	
					if _request.warningsAcknowledged then
						doDisconnect := true;
					endif;
				endif;
			endif;
		endif;
		
		//20.03.2020 cnwma1 #48757
		if doDisconnect then 
			create connectParams transient;
			connectParams.allTrackedItems.add(ti);
			connectParams.dateTime      			   := app.actualTimeServer;
			connectParams.noCharge     				   := false;
			connectParams.myTerminal    			   := terminal;
			connectParams.myTrackedItem 			   := ti;
			connectParams.userId       				   := app.getMyUserCode();
			connectParams.action      				   := ACTION_DISCONNECT;
			connectParams.urNumber     				   := null;
			connectParams.radioTelemetryIgnoreWarnings := true;
			connectParams.radioTelemetryUser           := false;
			app.myTrxUA.trxUpdateDisconnect(connectParams, app.myPassport);
		endif;
	endif;
	
	// PAR 20338 18807
	app.myPassport.setupForDeadlockReplay(-100, 2000);
	
	while true do
		self.setIgnoreWarnings(true);
		app.myTrxUA.trxMachinePickupTask( currentSession.myCurrentMachine,_request.quantity,weight,app.myPassport);
		
		if app.myPassport.noTrxReplayAllowed() then	//15 Jan 2013	NDL	Par 30920
			break;
		endif;

	endwhile;
		
	if app.myPassport.noErrors then
		create wsMachineTasks transient;
		wsMachineTasks.setProxyFromObject(currentSession.myCurrentMachine);	
		response.myMachineStatus:=wsMachineTasks;
	endif;
	
	//20.03.2020 cnwma1 #48757
	if not app.myPassport.allErrors.isEmpty() and  app.myPassport.allErrors.includesErrorCode(MACH_LIFT_POWER) then 
		create infoMessage transient;
		infoMessage.text :=  app.getErrorString1(Machine_disconnect_power,id);
		response.allInfo.add(infoMessage);
	endif;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	// Tidy up any local transients
	// ...
	delete connectParams;
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

	process.setPersistentDeadlockPriority(0);
	app.myPassport.replayingDeadlocks := false;
end;</source>
        <Parameter name="_request" type="WS_MachinePickupTaskRequest"/>
        <ReturnType type="WS_MachineStatusResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="machineDoReject" id="f1a1b30d-f11c-49e4-a740-729e0f4b8edf">
        <source>machineDoReject(_request : WS_MachineRejectTasksRequest)  : WS_MachineStatusResponse webService;
/*

Date		Who		Reason
22 May 2017	cnwer1	Initial creation TFS 995
*/

vars

	response		    : WS_MachineStatusResponse;
	completedOK		    : Boolean;
	wsMachineTasks      : WS_MachineStatus;
	task,
	twinTask            : CM_RTQueueTask;
	sideAccessDirection : Integer;
	allTasks 			: CM_RTQueueTaskArray;
	addToRejectList     : Boolean;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null ;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
		
	self.validateCurrentMachine(true);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	if not _request.rejectAll then
		create allTasks transient;
		//epr TFS 5535 4/8/17 
		task :=app.myPassport.getObjectOfTypeFromOid( _request.taskOid,CM_RTQueueTask).CM_RTQueueTask;
		if app.myPassport.hasErrors then
			completedOK:=true;
			return response;
		endif;
		if task = null then
			app.raiseCMException(Input_required_field_RTQue,null,null);
			completedOK := true;
			return response;
		endif;
		allTasks.add(task);
		twinTask := app.myPassport.getObjectOfTypeFromOid(_request.twinTaskOid,CM_RTQueueTask).CM_RTQueueTask;
		if app.myPassport.hasErrors then
			completedOK:=true;
			return response;
		endif;
		if twinTask &lt;&gt; null then
			allTasks.add(twinTask);
		endif;
	endif;
	app.myPassport.setupForDeadlockReplay(-100, 2000);
	while true do
		self.setIgnoreWarnings(true);
		app.myTrxUA.trxMachineRejectTasks(currentSession.myCurrentMachine,allTasks, addToRejectList,app.myPassport);
		
		if app.myPassport.noTrxReplayAllowed() then	//15 Jan 2013	NDL	Par 30920
			break;
		endif;

	endwhile;
	
	if app.myPassport.noErrors then
		create wsMachineTasks transient;
		wsMachineTasks.setProxyFromObject(currentSession.myCurrentMachine);	
		response.myMachineStatus:=wsMachineTasks;
	endif;
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	// Tidy up any local transients
	// ...
	delete allTasks;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
	process.setPersistentDeadlockPriority(0);
	app.myPassport.replayingDeadlocks := false;

end;</source>
        <Parameter name="_request" type="WS_MachineRejectTasksRequest"/>
        <ReturnType type="WS_MachineStatusResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="machineDoSetdown" id="a06fd65e-e21a-48f7-a8ee-fbf5f7990692">
        <source>machineDoSetdown(_request : WS_MachineSetdownTaskRequest)  : WS_MachineStatusResponse webService;
/* Changes

Date		Name	TFS#		Description
============================================================================
22/05/2017	cnwer1	TFS 995		Initial creation 
09/08/2019	jlgdap1	TFS 44462 	PNL Vehicle App Warnings
09/10/2019	jlgka1 	TFS 46449	JMT - Loadrite for the Vehicle App
01/04/2020  cnwma1  Bug 48757: SNO - Power disconnection
22/06/2022 jlika1	53830	PNL - Vehicle App - Swap Button Broken when Tandem Lifting to two trucks
16 Aug 2022	jlier1	54410 	Moved updating the weights to the trx layer 
============================================================================*/

vars
	response		: WS_MachineStatusResponse;
	completedOK		: Boolean;
	wsMachineTasks 	: WS_MachineStatus;
	task,
	twinTask 		: CM_RTQueueTask;
	sideAccessDirection : Integer;
	machineConfig 	: CM_RTVehicleConfig;
	machine 		: CM_Machine;
	showList		: Boolean;
	canChange		: Boolean;
	isDriverMove	: Boolean;
	tiUpdateCntrlr	: CMIF_TIUpdateController; 	
	proxyTi			: CM_TrackedItem;	
	weighAuth		: CM_WeighAuthority;			
	authTerm 		: CM_WeighAuthTerminal;			
	authorised		: String;
	certified		: String;
	taskTi			: CM_TrackedItem;
	terminal        : CM_Terminal;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null ;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
		
	self.validateCurrentMachine(true);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	//epr TFS 5535 4/8/17 
	task := app.myPassport.getObjectOfTypeFromOid(_request.taskOid,CM_RTQueueTask).CM_RTQueueTask;	
	if task = null then
		app.raiseCMException(Input_required_field_RTQue,null,null);
		completedOK := true;
		return response;
	endif;
	//epr TFS 5535 4/8/17	
	taskTi   := task.ti; //jlgka1 TFS 46449
	twinTask := app.myPassport.getObjectOfTypeFromOid(_request.twinTaskOid,CM_RTQueueTask).CM_RTQueueTask;
	
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	terminal     := app.myPassport.myTerminal;
	machine      := currentSession.myCurrentMachine;
	isDriverMove := not task.isOverstowTask and task.myEntry.isMachineInitiatedMove;

	if taskTi &lt;&gt; null then
		if taskTi.isConnected  then
			if not  terminal.getConfig(SetConnectedTIToHeld).Boolean then
				if _request.ignoreErrorCodes.Integer = MACH_LIFT_POWER then
					app.myPassport.errorsToIgnore.add(MACH_LIFT_POWER);	
				endif;
			endif;
		endif;
	endif;
	
	app.myPassport.setupForDeadlockReplay(-100, 2000);
	while true do
		if machine.ignoresWarnings then									// TFS 44462
			self.setIgnoreWarnings(true);
		else															// TFS 44462
			self.setIgnoreWarnings(_request.warningsAcknowledged);		// TFS 44462
		endif;															// TFS 44462
		app.myTrxUA.trxMachineSetdownTask(machine, task, twinTask, _request.setdownLocation, _request.twinSetdownLocation, _request.overrideToInterchange, false, _request.weightTotal.Integer, _request.weightCertified, app.myPassport);
		
		//if app.myPassport.hasWarningsToAcknowledge and not app.myPassport.warningsAcknowledged then	// TFS 44462	// TFS 46449
		if app.myPassport.hasWarningsToAcknowledge and not app.myPassport.warningsIgnored then			// TFS 44462	// TFS 46449
			completedOK := true;																		// TFS 44462
			app.writeLog(method.qualifiedName &amp; Tab &amp; " returned with hasWarningsToAcknowledge", LogWARN);
			return response;																			// TFS 44462
		endif;																							// TFS 44462
				
		if app.myPassport.noTrxReplayAllowed() then	//15 Jan 2013	NDL	Par 30920
			break;
		endif;		
		
	endwhile;
	
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	machineConfig := machine.getMyTerminal.getRTVehicleConfigForObject(machine);	

	if  not isDriverMove and machineConfig &lt;&gt; null then
		showList:=machineConfig.isShowingList(canChange);
		if not showList and  machineConfig.automaticGetNextTask then
			app.myPassport.replayingDeadlocks := false;
			app.myPassport.setupForDeadlockReplay(-100, 2000);
			while true do
				self.setIgnoreWarnings(true);
				app.myTrxUA.trxMachineGetNext(machine,app.myPassport);
				if app.myPassport.noTrxReplayAllowed() then	//15 Jan 2013	NDL	Par 30920
					break;
				endif;
	
			endwhile;
		endif;
		//I don't care about errors after automatic get next
		app.myPassport.clearErrorsWarnings;
	endif;
	
	
	if app.myPassport.noErrors then
		create wsMachineTasks transient;
		wsMachineTasks.setProxyFromObject(currentSession.myCurrentMachine);	
		response.myMachineStatus:=wsMachineTasks;
	endif;
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	// Tidy up any local transients
	// ...
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
	process.setPersistentDeadlockPriority(0);
	app.myPassport.replayingDeadlocks := false;
end;</source>
        <Parameter name="_request" type="WS_MachineSetdownTaskRequest"/>
        <ReturnType type="WS_MachineStatusResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="machineDoSwapTandem" id="44965e90-0ded-44de-9141-ce2081ddc54b">
        <source>machineDoSwapTandem(_request : WS_MachineSwapTasksRequest)  : WS_MachineStatusResponse webService;
/*

Date		Who		Reason
06/10/2019	JLGNS1	ChangeRequest 46451: JMT - Tandem Lift moves - Order of selecting and set down items using Vehicle App

*/

vars

	response		: WS_MachineStatusResponse;
	completedOK		: Boolean;
	task,
	tandemTask : CM_RTQueueTask;
	sideAccessDirection : Integer;
	wsMachineTasks : WS_MachineStatus;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null ;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
		
	self.validateCurrentMachine(true);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	task := app.myPassport.getObjectOfTypeFromOid(_request.taskOid,CM_RTQueueTask).CM_RTQueueTask;
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;
	if task = null then
		app.raiseCMException(Input_required_field_RTQue,null,null);
		completedOK := true;
		return response;
	endif;

	
	tandemTask :=app.myPassport.getObjectOfTypeFromOid( _request.tandemTaskOid,CM_RTQueueTask).CM_RTQueueTask;
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;
	sideAccessDirection:=null;
	
	
	app.myPassport.setupForDeadlockReplay(-100, 2000);
	
	while true do
		self.setIgnoreWarnings(true);
		
		app.myTrxUA.trxSwapMachineTandemTaskState(currentSession.myCurrentMachine,task,tandemTask,app.myPassport);
	
		if app.myPassport.noTrxReplayAllowed() then	
			break;
		endif;

	endwhile;
	
	if app.myPassport.noErrors then
		create wsMachineTasks transient;
		wsMachineTasks.setProxyFromObject(currentSession.myCurrentMachine);	
		response.myMachineStatus:=wsMachineTasks;
	endif;
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	// Tidy up any local transients
	// ...
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
	process.setPersistentDeadlockPriority(0);
	app.myPassport.replayingDeadlocks := false;
end;</source>
        <Parameter name="_request" type="WS_MachineSwapTasksRequest"/>
        <ReturnType type="WS_MachineStatusResponse"/>
    </JadeWebServicesMethod>
