    <JadeMethod name="doPickup" id="654aa18a-b290-4834-858e-4f97c5734a1c">
        <source>doPickup() protected;
/*

Date		Who		Reason
11 August 2014	cnwer1	Initial creation PAR

*/

vars
	rtQueueEntry : CM_RTQueueEntry;
	task 			: CM_RTQueueTask;
begin
	rtQueueEntry:=self.getSelectedWorkingRTEntry();
	if rtQueueEntry = null then
		return;
	endif;
	task:=rtQueueEntry.getDirectorOrPickupTask();
	if task = null then
		return;
	endif;
	if task.taskType = TASK_DIRECTOR then
		self.showDirectorFrame();
		self.doLoadDirectorCargo(task);
		return;
	endif;
	
	if not task.isPickUp or task.status = TASK_COMPLETE then
		return;
	endif;
	
	app.myVMAgent.doPickupSingleTask(task,self.getMoveQuantity,self.getMoveWeight());  //still to add quantity &amp; weight
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
