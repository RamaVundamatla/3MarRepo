    <JadeMethod name="loadSelectedDelays" id="e9dbb957-5a1c-4a3e-9881-91c6c4a3d134">
        <updating/>
        <source>loadSelectedDelays() updating, protected;
// ---------------------------------------------------------------------------
// Created:		May 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	delay : CM_Delay;
begin
	if not self.initialiseWithObject then
		return;
	endif;
	
	if self.allSelectedDelays.isEmpty then
		return;
	endif;
	
	self.tblData.clearAllData();
	self.doNotableClear;
	
	foreach delay in self.allSelectedDelays do 
		// ??? self.myFilterVoyage := delay.myVoyage;
		
		self.doQueryAddItem(delay);
	endforeach;
	
	self.showNumberOfItems (self.tblData);
end;
</source>
