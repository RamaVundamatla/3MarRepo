    <JadeMethod name="utlCreateTrackClearance" id="b04a7b2f-4c50-49f9-99ba-606a9a260b85">
        <source>utlCreateTrackClearance(_proxyTrackClearance : CM_TrackClearance;
						_newTrackClearance   : CM_TrackClearance output;
						_passport 			 : CM_Passport input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 Jun 2009	cnwndl1	Initial creation
31 Mar 2025 navma1  MTN-34387 MTN - Removing Unnecessary Audits
*/

vars

begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valTrackClearance(_proxyTrackClearance);

	if not self.checkValidationWithPassport(_passport) then
		return;
