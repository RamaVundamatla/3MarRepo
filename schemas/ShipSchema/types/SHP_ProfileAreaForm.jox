    <JadeMethod name="addToolbarControls" id="a0272ff4-a77f-49b2-8bad-ef446eb888b8">
        <updating/>
        <source>addToolbarControls() updating, protected;
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	toolbar		: CMUI_Toolbar;
	showCaptions	: Boolean;
	
begin
	inheritMethod();

	toolbar := self.frmToolbar;

	showCaptions := toolbar.showCaptions;

	toolbar.addFrame(self.frmToolbarCombos, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnTBPrint, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnTBFlipH, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnTBRefresh, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);

	// There is only one view mode at the moment and don't need any button. Par 18247 Mar 2009
	//toolbar.addButton(self.btnViewDischPort, CMUI_Toolbar.Control_Alignment_Left);
	//toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton(self.btnWebCam, CMUI_Toolbar.Control_Alignment_Left);

	if app.myPassport.myUser.canDo(self.myTerminal,PmAdmVoyageDefEdit) then
		toolbar.addButton(self.btnVoyageCall, CMUI_Toolbar.Control_Alignment_Left);
		toolbar.addButton(self.btnShipDelays,CMUI_Toolbar.Control_Alignment_Left);
		toolbar.addButton(self.btnDelaysEnquiry,CMUI_Toolbar.Control_Alignment_Left);
		toolbar.addButton(self.btnOOW,CMUI_Toolbar.Control_Alignment_Left);
//		toolbar.addButton(self.btnOOWCreation,CMUI_Toolbar.Control_Alignment_Left);
	endif;
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	//if app.myPassport.myUser.canDo(self.myTerminal, PmKPIModule) then
	if app.myPassport.myUser.canDo(self.myTerminal, Mod_BaseSystem) then//07 Oct 2019	NDL	TFS 46169
		// toolbar.addButton(self.btnAddKPI, CMUI_Toolbar.Control_Alignment_Left);
		toolbar.addButton(self.btnEventTrans, CMUI_Toolbar.Control_Alignment_Left); // PAR 35478
		
		
		toolbar.addButton(self.btnTBKPIUpdate, CMUI_Toolbar.Control_Alignment_Left);
		toolbar.addButton(self.btnKPIExport, CMUI_Toolbar.Control_Alignment_Left);
		toolbar.addButton(self.btnTBPrintStats, CMUI_Toolbar.Control_Alignment_Left);
		toolbar.addButton(self.btnKPIVessel, CMUI_Toolbar.Control_Alignment_Left);
		toolbar.addButton(self.btnKPIDetail, CMUI_Toolbar.Control_Alignment_Left);
		toolbar.addButton(self.btnKPIShowHideAv, CMUI_Toolbar.Control_Alignment_Left);
		toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);

	endif;

	if app.isSpecial() then //isDevelopmentSystem() then
		toolbar.addButton(self.btnShipGraphics, CMUI_Toolbar.Control_Alignment_Left);
		toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	endif;
	toolbar.positionToolbarControls();
	toolbar.visible := true;	


	toolbar := self.frmToolbarWebCam;

	showCaptions := toolbar.showCaptions;
	toolbar.addButton(self.btnSaveWebCam, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnWebCamClose, CMUI_Toolbar.Control_Alignment_Left);


	toolbar.positionToolbarControls();
	toolbar.visible := true;	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="btnAddKPI_click" id="fe58abce-fd4c-40fd-93b4-740dbb0164c4">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnAddKPI_click(btn: Button input) updating;
/*

Date		    Who			Reason
15 June 2010	cnwas3	  Initial creation

*/

vars

begin
	//app.mousePointer := Window.MousePointer_HourGlass;
	self.myAssistant.SHP_Assistant.showKPIAdditionsForm(self.myCurrentVoyage,null,null,self.myMasterMenuAction);
	
epilog
	//app.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnDelaysEnquiry_click" id="2ac03165-6a98-458d-868a-7c6cac6ed06b">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnDelaysEnquiry_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:		04 April 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	self.openShipDelayEnquiryForm(self.myCurrentVoyage, null);

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
