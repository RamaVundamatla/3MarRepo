    </JadeMethod>
    <JadeMethod name="tblDataView3_contextMenu" id="94296fc9-708f-4dc8-a1c7-6d3f1eeeeffa">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblDataView3_contextMenu(
	_table	: Table input;
	_conwin	: Window input;
	_mouse	: Boolean;
	_x		: Integer;
	_y		: Integer ) : Boolean updating;

/*

Purpose:		
Parameters:		
Return Value:	

Date				Who		Reason
19 May 2009			cnwrl1	Initial creation as part of PAR 19668 - CCMS 1814 - Interface History

*/
	
vars
	
begin
	if self.myCurrentTableItem = null or not self.myCurrentTableItem.isKindOf( SOPTM_Machine ) then
		return true;
	endif;
	
	return self.contextMenu( _table, _mouse, _x, _y );
	
epilog
	
end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_conwin" type="Window" usage="input"/>
        <Parameter name="_mouse" type="Boolean"/>
        <Parameter name="_x" type="Integer"/>
        <Parameter name="_y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblForecastReqd_lostFocus" id="43f7e6c5-76f7-49da-bed7-3791eb093733">
        <controlMethod name="Table::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblForecastReqd_lostFocus(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Sep 2022 navtnr20 ChangeRequest 54505: MTN - Optional fields for Cargo Forecast on Voyage and Train

*/

vars
	theRow : Integer;
	str	: String;
	tbl : CM_EntryTable;
	lstTbl : CMUI_ListTable;
	row : Integer;
begin
	tbl := self.tblInput2;
	lstTbl := table.CMUI_ListTable;
	
	theRow := tbl.getRowByControlName(lstTbl.name);

	if (theRow &gt; tbl.fixedRows) and (theRow &lt;= tbl.rows) then
		tbl.accessRow(theRow).height := self.saveRowHeight.Integer;
		lstTbl.height := saveRowHeight.Integer; 
		self.saveRowHeight := 0;
		tbl.scrollBars := Table.ScrollBars_Both;
		
		foreach row in 1 to lstTbl.rows do
			if lstTbl.accessCell(row, 1).text = "1" then
				if str = null then
					str := lstTbl.accessCell(row, 3).text;
				else
					str := str &amp; Comma &amp; Space &amp; lstTbl.accessCell(row, 3).text;
				endif;
			endif;
		endforeach;
		tbl.setValue(theRow, str);
		
	endif;
	self.tblInput1.adjustHeight(200);
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblInput1_cellInputReady" id="4bac8012-5967-424e-817b-db5c736c8db6">
