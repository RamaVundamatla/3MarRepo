    <JadeMethod name="setMeterMarksTo" id="ef47af97-ee31-4c75-bf3b-b2291972dde9">
        <updating/>
        <source>setMeterMarksTo(textbox: TextBox input; _berthChange : Boolean) updating, protected;
//-----------------------------------------
// Created: May 2004 By: cnwgd1
//-----------------------------------------
// Changed On	By			Reason
// ----------------------------------------
// 22/03/2023	navdap1		TFS 56593 EUP - Show Bollards+Meters in all instances
// 10/07/2024	navcs2	Bug 64769: MSL- IMT- Unable to manage the movements in Harbor management

vars
	bridgeToBow,
	loa : Decimal[6,2];
	sideTo : Integer;
	bowMark,
	sternMark,
	bridgeMark : Decimal[12,2];
	berthForMarks,
	selectedBerth : HMS_Berth;
  	validForDT: Boolean;
  	voyageData : HMS_VoyageData;
	bowBMark, bridgeBMark, sternBMark : Integer;				// TFS 56593
	bowBollard, bridgeBollard, sternBollard : HMS_Resource;		// TFS 56593
begin

	voyageData := self.aMySelectedMovement.myWorkingVoyage.myHMSVoyageData;
	bridgeToBow := voyageData.dist_BridgeToBow;
	loa := voyageData.dim_LengthOverall;
	sideTo := self.aMySelectedMovement.sideTo;
		
	if self.aTxtBowMark_LostFocus_Not_OK = true then
		self.txtBowMarkTo.text := self.aLastValidBowMark.asStringJMT();		//#24363 18/06/2010
		self.txtSternMarkTo.text := self.aLastValidSternMark.asStringJMT();	//#24363 18/06/2010
	   	if self.aLastValidBowMark &lt; self.aLastValidSternMark then
			bridgeMark := self.aLastValidBowMark + bridgeToBow;
		else
			bridgeMark := self.aLastValidBowMark - bridgeToBow;		
		endif;					
		self.txtBridgeMarkTo.text := bridgeMark.asStringJMT();		//#24363 18/06/2010
		self.myCmbBerthTo.listIndex := self.myCmbBerthTo.findObject(self.aMyLastValidBerth);
		self.aTxtBowMark_LostFocus_Not_OK := false;		
		return;
	endif;
	
	// Set flag to say that bow mark has changed but has not been check
	self.aTxtBowMark_LostFocus_Not_OK := true;
	selectedBerth := self.myCmbBerthTo.listObject.HMS_Berth;
	
	if selectedBerth = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'To Berth', null, null);
		app.raiseCMException(Input_required_field_toBerth, null, null); // cnwdb2	PAR 35364

		self.aTxtBowMark_LostFocus_Not_OK := false;
		return;
	endif;
	
	if textbox = null then
		if selectedBerth = self.aMyLastValidBerth then
			self.aTxtBowMark_LostFocus_Not_OK := false;		
			return;
		endif;
		// use the berth preference if there are any otherwise centre on berth
		self.aMySelectedMovement.myBerth := selectedBerth;
		if self.aMySelectedMovement.setToPreferredBerthMarks() then
			bowMark := self.aMySelectedMovement.bowMarkTo;
			sternMark := self.aMySelectedMovement.sternMarkTo;
			// calculate the bridge mark
		   	if bowMark &lt; sternMark then
				bridgeMark := bowMark + bridgeToBow;
			else
				bridgeMark := bowMark - bridgeToBow;		
			endif;
			// berth may have changed so use the one on the movement
			berthForMarks := self.aMySelectedMovement.myBerth;
		else
			self.aMySelectedMovement.myBerth := self.aMyLastValidBerth;	
			selectedBerth.getBowSternBridgeMarksFromLOA(loa, bridgeToBow, sideTo, bowMark, sternMark, bridgeMark, null, berthForMarks,true);
		endif;
	elseif textbox = self.txtBowMarkTo then
		//bowMark := textbox.text.Decimal;
		bowMark := textbox.text.asDecimalJMT();// 01 APR 2010	NDL	Par 23556
		if bowMark = self.aLastValidBowMark then
			self.aTxtBowMark_LostFocus_Not_OK := false;		
			return;
		endif;			
		selectedBerth.getBowSternBridgeMarksFromLOA(loa, bridgeToBow, sideTo, bowMark, sternMark, bridgeMark, app.getErrorString(HMS_BowMark), berthForMarks,true);
	elseif textbox = self.txtSternMarkTo then
		//sternMark := textbox.text.Decimal;
		sternMark := textbox.text.asDecimalJMT();// 01 APR 2010	NDL	Par 23556
		if sternMark = self.aLastValidSternMark then
			self.aTxtBowMark_LostFocus_Not_OK := false;		
			return;
		endif;			
		selectedBerth.getBowSternBridgeMarksFromLOA(loa, bridgeToBow, sideTo, bowMark, sternMark, bridgeMark, app.getErrorString(HMS_SternMark), berthForMarks,true);
	elseif textbox = self.txtBridgeMarkTo then
		//bridgeMark := textbox.text.Decimal;
		bridgeMark := textbox.text.asDecimalJMT();// 01 APR 2010	NDL	Par 23556	
		selectedBerth.getBowSternBridgeMarksFromLOA(loa, bridgeToBow, sideTo, bowMark, sternMark, bridgeMark, app.getErrorString(HMS_BridgeMark), berthForMarks,true);
	else
		return;
	endif;
	
	self.txtBowMarkTo.text		:= bowMark.asStringJMT();		//#24363 18/06/2010
	self.txtSternMarkTo.text	:= sternMark.asStringJMT();		//#24363 18/06/2010
	self.txtBridgeMarkTo.text	:= bridgeMark.asStringJMT();	//#24363 18/06/2010
	self.myCmbBerthTo.listIndex := self.myCmbBerthTo.findObject(berthForMarks);
	self.aMySelectedMovement.myBerth := berthForMarks;
	
	// TFS 56593 start
	berthForMarks.getBollardForMark(bowMark.Integer, bowBMark, bowBollard);
	berthForMarks.getBollardForMark(sternMark.Integer, sternBMark, sternBollard);
	berthForMarks.getBollardForMark(bridgeMark.Integer, bridgeBMark, bridgeBollard);
	self.txtBowMarkMeter.text := self.stringOrNull(bowBMark);													// 10/07/2024	navcs2	Bug 64769
	if bowBollard &lt;&gt; self.cmbBowMarkBollard.listObject then
		self.cmbBowMarkBollard.listIndex := self.cmbBowMarkBollard.findObject(bowBollard);
	endif;
	self.txtBridgeMarkMeter.text := self.stringOrNull(bridgeBMark);												// 10/07/2024	navcs2	Bug 64769
	if bridgeBollard &lt;&gt; self.cmbBridgeMarkBollard.listObject then
		self.cmbBridgeMarkBollard.listIndex := self.cmbBridgeMarkBollard.findObject(bridgeBollard);
	endif;
	self.txtSternMarkMeter.text := self.stringOrNull(sternBMark);												// 10/07/2024	navcs2	Bug 64769
	if sternBollard &lt;&gt; self.cmbSternMarkBollard.listObject then
		self.cmbSternMarkBollard.listIndex := self.cmbSternMarkBollard.findObject(sternBollard);
	endif;
	self.aMySelectedMovement.bowToBollard := bowBMark;
	self.aMySelectedMovement.sternToBollard := sternBMark;
	self.aMySelectedMovement.bridgeToBollard := bridgeBMark;
	self.aMySelectedMovement.setMyBollards(bowBollard, sternBollard, bridgeBollard);
	// TFS 56593 end

	self.aMySelectedMovement.setBerthMark(bowMark, sternMark, self.aMySelectedMovement.sideTo, self.aMySelectedMovement.foreClearanceTo, self.aMySelectedMovement.aftClearanceTo); 	

	if self.checkAndUpdateMoveDT(validForDT, _berthChange, false)=false then
		// DT hasn't changed ie. clearances have not already been checked.
		// The ship position has changed, recalc marks and clearances
		self.checkAndSetClearances(_berthChange, false);
	else
		// Berth is VALID for these marks - Proceed with change of focus
		self.aTxtBowMark_LostFocus_Not_OK := false;		
	endif;

	// New marks are not correct - have rolled back to lastValidBowMark
	// Return focus to tbxBowMarkTo
epilog
	if self.aTxtBowMark_LostFocus_Not_OK = true then
		self.fldMovements.topSheet := self.shtGeneral;
		if textbox &lt;&gt; null then
			textbox.setFocus;
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="textbox" type="TextBox" usage="input"/>
        <Parameter name="_berthChange" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMoveStatus" id="21cb9284-0d3f-410d-ad8a-3d2d6e04deb5">
        <source>setMoveStatus();
/*

Purpose:			


Return Value:		


Date		Who		Reason
13 March 2008	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	// ------------------------------------------------------------------------
 	// Set movement status  -Modified by Russell 11/08/99
 	// --------------------------------------------------------------------------
	if self.aMySelectedMovement.isCancelled then	//20 Nov 2018	NDL	TFS 42043
		txtMoveStatus.text	:=	app.getErrorString(Cancelled_At_Gate);
	elseif self.aMySelectedMovement.moveStatus = MovementStatus_Planned then
 		txtMoveStatus.text	:=	app.getErrorString(Planned);
 	elseif self.aMySelectedMovement.moveStatus=MovementStatus_ConfirmedPlan then
 		txtMoveStatus.text	:=	app.getErrorString(PlanConfirmed);
 	elseif self.aMySelectedMovement.moveStatus=MovementStatus_Actual then
 		txtMoveStatus.text	:=	app.getErrorString(Actual);
 	else
 		txtMoveStatus.text:="";
 	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setMoveVoyageNum" id="3e4a1696-7d21-4c01-86ce-80959bde2f50">
        <source>setMoveVoyageNum(_harbour : HMS_Harbour);
/*

Purpose:			


Return Value:		


Date		Who		Reason
13 March 2008	cnwer1	Initial creation - PAR#xxxx

*/
vars
	currWorkVoyage		: CMIF_HMS_WorkingVoyage;
begin
	// Modified by Russell 06/04/99
 	// ------------------------------------------------------------------------
 	// Display voyage number if vessel and voyage arrival date have not
 	// changed from the values that are saved in the database
 	currWorkVoyage	:=	self.aMySelectedMovement.myClonedVoyage.ofClonedVoyage;
	
 	if currWorkVoyage &lt;&gt; null then
 		if currWorkVoyage.ofPermanentVoyage &lt;&gt; null then
 			if currWorkVoyage.ofPermanentVoyage.vesselCode = currWorkVoyage.myHMSVoyageData.vesselCode 
 			and currWorkVoyage.ofPermanentVoyage.arrivedDT = currWorkVoyage.arrivedDT
			then
 				// Arrived DT and vessel have not changed for the voyage
 				// Calc voyage number
 				self.txtMoveVoyageNum.text	:=	_harbour.getVesselVisitCountStr(currWorkVoyage.vesselCode, currWorkVoyage.arrivedDT);
 			else
 				// Arrived DT or vessel have changed for the voyage
 				// Voyage number is no longer valid
 				self.txtMoveVoyageNum.text	:=	app.getErrorString(ShipVoyageCodeInvalid);
 			endif;
 		endif;
 	else
 		self.txtMoveVoyageNum.text	:=	app.getErrorString(ShipVoyageCodeInvalid);
 	endif;


epilog

end;</source>
        <Parameter name="_harbour" type="HMS_Harbour"/>
    </JadeMethod>
    <JadeMethod name="setPLaunchReqdStatus" id="71447822-691e-42a7-9e97-0c4ccf94373d">
        <updating/>
        <source>setPLaunchReqdStatus() updating, protected;
//
// Changed On	By			Reason
// ==========	========	========================================================
// 17/08/2012	cnwdap1		PAR #30145 Pilot on shift movements is now configurable
vars
	moveCurrent:	CMIF_HMS_WorkingMovement;
	movePrevious:	CMIF_HMS_WorkingMovement;
	berthTo:		HMS_Berth;
	berthFrom:		HMS_Berth;
	launchRequired:	Boolean;
begin
 	// This method sets the required status for the pilot launch for a movement
 	// LAUNCH REQUIRED	
 	// Arrival:		(except when Pilot Exempt = true // or // when 'to' berth is logical)
 	// Departure:	(except when Pilot Exempt = true // or // when 'from' berth is logical)
 	// Shift:		(except when Pilot Exempt = true // or // 'to' or 'from' berth
 	//               is a logical berth)
	if aMySelectedMovement = null then
		return;
	endif;

 	// Set references
 	moveCurrent:=aMySelectedMovement;
 	movePrevious:=aMySelectedMovement.getMovementPrevious;
 	berthTo:=moveCurrent.myBerth;
 	if movePrevious&lt;&gt;null then
 		berthFrom:=movePrevious.myBerth;
 	endif;

 	launchRequired:=false;
 	if moveCurrent.pilotExempt=false or moveCurrent.init_IsPilotExempt = false then
 		
 		if moveCurrent.moveType=HMSMovementTypeArrival then
 			if berthTo&lt;&gt;null then
 				if berthTo.noMarineServices=false then
 					// Arrival is to a physical berth					
 					launchRequired:=true; // Pilot is required.
 				endif;
 			endif;
 		// DEPARTURE
 		elseif moveCurrent.moveType=HMSMovementTypeDeparture then
 			if berthFrom&lt;&gt;null then
 				if berthFrom.noMarineServices=false then
 					// Departure is from a physical berth					
 					launchRequired:=true; // Pilot is required.
 				endif;
 			endif;
 		// SHIFT
 		elseif moveCurrent.moveType=HMSMovementTypeShift then
 			if berthFrom&lt;&gt;null and berthTo&lt;&gt;null then
 //				if berthFrom.ofWharf.isLogicalWharf=false or berthTo.ofWharf.isLogicalWharf=false then
 				

 				if berthFrom.noMarineServices=true or berthTo.noMarineServices=true then
 					// Shift is either to or from the berth					
 					launchRequired:=true; // Pilot is required.
 				endif;
 			endif;
 		endif;
 	endif;

	if launchRequired=true then
		if self.aMode = self.Mode_Update then
			
			moveCurrent.checkAndSetInitialValues;
			shtMarineService.enabled:=true;
			//reloadMarineServicesSheet;
			self.pilotExemptEnable();	// set controll according to Pilot exempt checkbox value
		endif;
	else
		// Pilot launch is NOT required - set order time and position cbx's to disabled 
		// PAR #30145 Pilot in shift movements is now configurable
		if not self.myTerminal.getConfig(PilotOnShiftMovement).Boolean then
			cmbLaunchPosn.enabled:=false;
			cmbPilotLaunch.enabled:=false;
			txtLaunchRel.enabled:=false;
			txtLOrderActual.enabled:=false;
		endif;
	endif;					

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setPilotLaunchCellText" id="5107295c-2345-4d2b-ab57-4e8951909cd8">
        <updating/>
        <source>setPilotLaunchCellText(table : Table input; _newRow : Integer; _newCol : Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 May 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement

*/

vars
	cntrl : Control;
	temp : Integer;
begin	
	if (not table.userInputEnabled)	or table.row &lt;= table.fixedRows then
		return;
	endif;
		
	if table.accessCell(table.row, table.column).enabled then
		cntrl := table.accessedCell.cellControl;
		if TextBox.hasInstance(cntrl) then
			temp := 1;
		elseif ComboBox.hasInstance(cntrl) then
			table.accessedCell.text := cntrl.ComboBox.text;
		endif;
	endif;
	
	if table.accessCell(_newRow, _newCol).enabled then
		cntrl := table.accessedCell.cellControl;
		if TextBox.hasInstance(cntrl) then
			table.gotFocus(table);
		endif;		
	endif;
		
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="_newRow" type="Integer"/>
        <Parameter name="_newCol" type="Integer"/>
    </JadeMethod>
