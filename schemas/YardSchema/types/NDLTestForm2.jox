    <JadeMethod name="doIt" id="46335aed-86d1-45ee-8e78-0909ca6a651f">
        <updating/>
        <source>doIt() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 May 2012	cnwndl1	Initial creation

*/

vars

	iters : Integer;
	delay : Integer;
	cmifMonitor : CMIF_Monitor;
	count : Integer;

begin

	iters := self.txtIter.text.Integer;
	delay := self.txtDelay.text.Integer;
	
	app.mousePointer := MousePointer_HourGlass;
	
	create cmifMonitor transient;
   	app.myPassport.setMyCMIFMonitor(cmifMonitor);
   	cmifMonitor.myParent := self;
	cmifMonitor.message := 'Started...';
	cmifMonitor.partsInJob := iters;	
	cmifMonitor.partsDone := 0;
	 
	self.modalDialogShow(null, 'Cancel', null, null, 'Testing doWindowsEvents(0)', cmifMonitor.message);
	self.pbProgressBar.visible := true;
	updateProgress(cmifMonitor);
	
	self.modalDialogReturnValue := 0;
	
	while true do
		count := count + 1;
		cmifMonitor.partsDone := count;
		cmifMonitor.message := 'processing...';
		process.sleep( delay * 1000 );
		updateProgress(cmifMonitor);
		if count = iters then
			break;
		endif;
		if self.modalDialogReturnValue = 1 then
			break;
		endif;
	endwhile;

epilog

	self.frmModalDialog.visible := false;
	delete cmifMonitor;
   	app.myPassport.setMyCMIFMonitor(null);
	app.mousePointer := MousePointer_Default;

end;</source>
    </JadeMethod>
