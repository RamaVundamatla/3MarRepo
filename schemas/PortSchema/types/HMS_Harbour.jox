    <JadeMethod name="checkIfDaylightSaving" id="5a72ee65-96ca-4331-bcc1-7a22337895a2">
        <source>checkIfDaylightSaving(_time : TimeStamp; _clocksChangeToday : Boolean output) : Boolean;
//--------------------------------------------------
// Created:	27 April 2005 By: cnwgd1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 31/08/2010	cnwdad1		PAR #20064.
// --------------------------------------------------------------------------------
vars
	zone : String;
begin
	if (not _time.isValid) then
		return false;
	endif;
	//----------------------------------------------------------------
	//TEMPORARY - NO GOOD FOR MULTI HARBOUR IN DIFFERENT TIME ZONES
	//HARBOUR WILL NEED TO KNOW WHAT TIME ZONE TO USE
	//----------------------------------------------------------------
// cnwdad1 31/08/2010 - PAR #20064.
//	zone := app.currentLocaleInfo.englishCountryName;
//	zone := app.getMyLocaleInfoJMT.englishCountryName;
	
	zone := self.getTimezoneDescr();	//20 Mar 2012	NDL	Par 28251
	
	//THE BELOW METHOD IS NEW ZEALAND SPECIFIC
	return _time.checkIfDaylightSaving(_clocksChangeToday, zone);
end;</source>
        <Parameter name="_time" type="TimeStamp"/>
        <Parameter name="_clocksChangeToday" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkVesselHasHMSVoyage" id="bd328fa7-d280-4bb4-8de3-d0c36e577528">
        <source>checkVesselHasHMSVoyage(_vesselCode : String; _startDT : TimeStamp) : Boolean;
//--------------------------------------------------
// Created:	28 July 2004 By: cnwgd1
//--------------------------------------------------
vars
	tmpStartDT 	: TimeStamp;
	iter		: Iterator;
	tmpMove		: HMS_VoyageMovement;
	voyage		: CM_Voyage;
begin
	tmpStartDT.setDate(_startDT.date);
	
	if (not tmpStartDT.isValid) then
		tmpStartDT.setDate(app.actualTimeServer().date);
	endif;
	
	tmpStartDT.setTime(null);
	
	iter := self.allVoyageMovements.createIterator();
	self.allVoyageMovements.startKeyGeq(tmpStartDT, iter);
	
	while iter.next(tmpMove) do
		if tmpMove.myHMSVoyageData &lt;&gt; null	//11 Dec 2018	NDL	TFS 42043
		and tmpMove.myHMSVoyageData.vesselCode.trimBlanks = _vesselCode
		then
			return true;
		endif;
	endwhile;

	return false;
	
epilog
	delete iter;
end;</source>
        <Parameter name="_vesselCode" type="String"/>
        <Parameter name="_startDT" type="TimeStamp"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkWarningPeriod" id="549e57c4-4d9f-4fee-81f5-02befb5e2452">
        <source>checkWarningPeriod(_warnDT : TimeStamp io) : Boolean;
//--------------------------------------------------
// Created:	28 February 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	
	
	if self.numHoursOutForWarnings &gt; 0 then
		//Movement that occurs after warnDT will not be validated
	 	_warnDT := _warnDT.changeByXXHours(self.numHoursOutForWarnings);
	 	return true;
	endif;
	
	//No warning period set, all voyage movements will be checked
	return false;
	
end;</source>
        <Parameter name="_warnDT" type="TimeStamp" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
