	create outFile transient;
	outFile.openOutput(FileDir &amp; '/cn_tranlog_20180216_trim.csv');
	outFile.mode := File.Mode_Output;
//	outFile.writeLine(Headings);
	
	create inFile transient;
	inFile.kind := File.Kind_Unknown_Text;	// 29/2/16 cnwmp6 PAR 36286 unicode version
	
	create folder transient;
	folder.fileName := FileDir;
	folder.mask := 'cn_tranlog_20180216*.csv';
	
	foreach fn in folder.files where fn.isKindOf(File) do
//		gotDate := false;
		inFile.openInput(fn.fileName);
		while not inFile.endOfFile() do
			ignoreLine := false;
			line := inFile.readLine();
			
//			if not gotDate then
//				if line.startsWith(PeriodFrom) then
//					gotDate := true;
//					date := line[PeriodFrom.length + 1:end].trimBlanks().TimeStamp.date();
//				endif;
//			else
				foreach trxId in trxIds do
					if line.pos(trxId, 1) &gt; 0 then
//						outFile.writeLine(date.format('dd/MM/yyyy') &amp; ',' &amp; line);
						ignoreLine := true;
						break;
					endif;
				endforeach;
//			endif;
			if not ignoreLine then
				outFile.writeLine(line);
			endif;
		endwhile;
		inFile.close();
		break;
	endforeach;
	outFile.close();
epilog
	delete folder;
	delete inFile;
	delete outFile;
	delete trxIds;
end;</source>
