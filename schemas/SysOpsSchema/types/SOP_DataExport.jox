    <JadeMethod name="setColorsFromController" id="83cd8f2d-0f91-4d97-9db9-6025330462fe">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
// ---------------------------------------------------------------------------
// Created:     07 December 2004	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	tmpBackColor	: Integer;
begin
	inheritMethod(_colorControl);
	
	self.setColorsForEntryTable(self.tblExtractDef);
	self.setColorsForTable(self.tblExtractHist);
	self.setColorsForTable(self.tblExtractClass);
	
	tmpBackColor := self.backColor;
	self.mulFeatures.backColor := tmpBackColor;
	self.mulObjects.backColor := tmpBackColor;
end;</source>
