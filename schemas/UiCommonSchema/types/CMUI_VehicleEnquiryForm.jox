    <JadeMethod name="addObjectsToTable" id="fb02d03d-7de4-4583-9813-af261f590504">
        <updating/>
        <source>addObjectsToTable(_numItems: Integer io) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 October 2017	jlgndl1	Initial creation	TFS 7216

*/

vars

	iter : Iterator;
	startVehicle : CM_Vehicle;
	vehicle : CM_Vehicle;
	breakOut : Boolean;

begin

	if not self.isFirstActivateComplete then
		//We want to open without searching.
		return;
	endif;

	iter := self.myTerminal.vehicles.createIterator;
	
	if self.filterRegNo &lt;&gt; null then
		startVehicle := self.myTerminal.vehicles.getAtKeyGeq( self.filterRegNo, null );
		if startVehicle = null then
			return;
		else
			iter.startAtObject( startVehicle );
		endif;
	endif;
	
	while iter.next( vehicle ) do
		if self.filterRegNo &lt;&gt; null then
			if vehicle.regNumber[1 : self.filterRegNo.length] &lt;&gt; self.filterRegNo then
				break;
			endif;
		endif;
		if self.includeObject(vehicle, app.myPassport) then
			self.addObjectToTable(vehicle, _numItems, breakOut);
			
			if breakOut then
				break;
			endif;
		endif;
	endwhile;

epilog
	
	delete iter;
end;</source>
        <Parameter name="_numItems" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="addVehicleToTable" id="b62caaf6-74a6-4ad7-9345-3344142ebe1e">
        <updating/>
        <source>addVehicleToTable(_vehicle : CM_Vehicle)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 March 2023	navhl20	Defect 57173: MTN - 75776 exception when double clicking on the Vehicle on the Info table

*/

vars
	idx,_numItems : Integer;
	breakOut 	  : Boolean;
begin
	self.myCurrentObject := _vehicle;
	self.isFirstActivateComplete := true;
	
	if self.includeObject(_vehicle, app.myPassport) then
		self.addObjectToTable(_vehicle, _numItems, breakOut);
	endif;
	
	idx := self.tblData.fixedRows + 1;
	self.tblData.rows := idx;
	if idx &gt; self.tblData.fixedRows and idx &lt;= self.tblData.rows then
		self.tblData.row := idx;
		self.tblData.accessRow(idx).itemObject := _vehicle;
		self.tblData.selectRow(idx, true);
		self.tblData.accessRow(idx).visible := true;
	endif;

	if _vehicle &lt;&gt; self.myPlaceHolderObject then
		self.zShowThumbnailData(_vehicle);
	else
		self.zShowThumbnailData(null);
	endif;

	self.numItemsShown := 1;
	if self.useNumRowsShown then
		self.showNumRowsShown();
	endif;
epilog

end;</source>
        <Parameter name="_vehicle" type="CM_Vehicle"/>
    </JadeMethod>
