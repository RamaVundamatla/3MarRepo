    <JadeMethod name="validateRequestLinkSameToSame" id="9cc0bbac-788f-4a3e-b035-14987a87fbc0">
        <source>validateRequestLinkSameToSame(_theRequest : CM_Request; theLLocn, theLocn : String);

/*

Purpose:		Validate linking is same to same

Date			Who		Reason
15/07/2013		cnwmh5	Initial creation

*/

vars

	realRequestLeft						: CM_Request;
	realRequestRight					: CM_Request;
	tempRequest							: CM_Request;
	
//	isLoad								: Boolean;

begin
/* PAR 32120 - we already have the actual UPDATE PXY do not ask the LC for the actual request, cos we end up with 2 discharge requests
	isLoad := self.getIsDischarge();
	realRequestLeft := self.getLC().getRequest(isLoad);
	if realRequestLeft = null then
		realRequestLeft := self.getLC().getRequest(not isLoad);
	endif;
	
	realRequestRight := _theRequest.getLC().getRequest(isLoad);
	if realRequestRight = null then
		realRequestRight := _theRequest.getLC().getRequest(not isLoad);
	endif;
*/
	
	realRequestLeft := self.pxyGetRealObject();
	realRequestRight := _theRequest.pxyGetRealObject();
	if realRequestLeft = null or realRequestRight = null then
		return;
	endif;

	// PAR 32120 if not length type attribute is set then do not compare lengths
	if not realRequestLeft.getAttrHasLengthSet() then
		return;
	endif;
	if not realRequestRight.getAttrHasLengthSet() then
		return;
	endif;
	
	
	
	if realRequestRight.getAttrIs20() and not realRequestLeft.getAttrIs20() then
		app.raiseCMException2(ERR_INVALID_VALUE,app.getErrorString(TwentyFoot).toUpper &amp; " " &amp; app.getErrorString(Attrib), app.getErrorString2(Request_linked_no_matching, 
			theLocn, app.getErrorString(TwentyFoot)), null, null);
	elseif realRequestRight.getAttrIs30() and not realRequestLeft.getAttrIs30() then
		app.raiseCMException2(ERR_INVALID_VALUE,app.getErrorString(ThirtyFoot).toUpper &amp; " " &amp; app.getErrorString(Attrib), app.getErrorString2(Request_linked_no_matching, 
			theLocn, app.getErrorString(ThirtyFoot)), null, null);
	elseif realRequestRight.getAttrIs40() and not realRequestLeft.getAttrIs40() then
		app.raiseCMException2(ERR_INVALID_VALUE,app.getErrorString(FortyFoot).toUpper &amp; " " &amp; app.getErrorString(Attrib), app.getErrorString2(Request_linked_no_matching, 
			theLocn, app.getErrorString(FortyFoot)), null, null);
	elseif realRequestRight.getAttrIs45() and not realRequestLeft.getAttrIs45() then
		app.raiseCMException2(ERR_INVALID_VALUE,app.getErrorString(FortyFiveFoot).toUpper &amp; " " &amp; app.getErrorString(Attrib), app.getErrorString2(Request_linked_no_matching, 
			theLocn, app.getErrorString(FortyFiveFoot)), null, null);
	elseif realRequestRight.getAttrIs53() and not realRequestLeft.getAttrIs53() then
		app.raiseCMException2(ERR_INVALID_VALUE,app.getErrorString(FiftyThreeFoot).toUpper &amp; " " &amp; app.getErrorString(Attrib), app.getErrorString2(Request_linked_no_matching, 
			theLocn, app.getErrorString(FiftyThreeFoot)), null, null);
	elseif (self.isKindOf(CM_ROROGCRequest) and not _theRequest.isKindOf(CM_ROROGCRequest)) then
		app.raiseCMException4(Request_Cannot_Be_Linked_GC, theLocn, " not a GC Area", theLLocn, "a GC Area", null, null);
	elseif not self.isKindOf(CM_ROROGCRequest) and _theRequest.isKindOf(CM_ROROGCRequest) then
		app.raiseCMException4(Request_Cannot_Be_Linked_GC, theLocn, "a GC Area", theLLocn, "not a GC Area", null, null);
	endif;
	
epilog

end;</source>
        <Parameter name="_theRequest" type="CM_Request"/>
        <Parameter name="theLLocn" type="String"/>
        <Parameter name="theLocn" type="String"/>
    </JadeMethod>
