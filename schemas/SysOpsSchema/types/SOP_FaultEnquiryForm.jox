    <JadeMethod name="doDelete" id="f735fa7f-890f-4947-bf58-ddd564857e93">
        <updating/>
        <source>doDelete(): Boolean updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
18 September 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	fault : CM_Fault;
	theReturn : Integer;
	rtnValue : Boolean;
	obj : Object;
begin

	if self.myCurrentObject = null then
		return false;
	endif;
/* WAS PAR 15966
	fault:= self.myCurrentObject.CM_Fault;
	app.myTrxDA.trxDeleteFault(fault,app.myPassport);

	rtnValue:=app.myPassport.trxCompletedOK;
	if not rtnValue then
		app.showErrorWarningDialog('Fault Delete', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
	endif;
	NOW */
	
	
	while true do
		app.myTrxDA.trxDeleteFaults(self.tblData.allSelectedObjects,app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog("Faults", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return false;
		endif;
		break;
	endwhile;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPrint" id="d6d5836f-b8b5-4cc9-8aa8-a67895b8aed2">
        <updating/>
        <source>doPrint() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
12 October 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

	pxyJadeReport	: JadeReport;
	tblPrintParams	: CMIF_PrintTableParams;

begin

	create tblPrintParams transient;
	tblPrintParams.closePrinter := true;
	tblPrintParams.jadeReport := pxyJadeReport;
	tblPrintParams.newReport := true;
	tblPrintParams.printFrame := self.frmReport;
	tblPrintParams.printLabel := self.lblReport;
	tblPrintParams.title := self.caption[1:100];

//	self.tblAlerts.doPrintTableOLD(false,true,self.frmReport, self.lblReport,self.caption, true, pxyJadeReport);
	//self.tblAlerts.doPrintTable(tblPrintParams);
//	self.tblData.doPrintTable2(self.caption, self.caption, self.caption);
	self.doPrintOutTable(self.tblData, self.caption,  true, false, true, false); // PAR 19503

epilog
	delete tblPrintParams;


end;</source>
    </JadeMethod>
