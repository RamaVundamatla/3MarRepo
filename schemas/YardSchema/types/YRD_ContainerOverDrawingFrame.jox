        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getYABlockAndPointsForPosition" id="00659f6a-67f0-468d-8c98-083277f0eb37">
        <source>getYABlockAndPointsForPosition(x, y : Integer; xy1, xy2 : Point output) : CM_YABlock;
vars
	yaBlock : CM_YABlock;
begin
	yaBlock:= self.allYABlocks.findObjectInDict(x, y, xy1, xy2).CM_YABlock;
	return yaBlock;
end;</source>
        <Parameter name="x" type="Integer"/>
