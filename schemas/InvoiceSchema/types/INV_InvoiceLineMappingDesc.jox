    <JadeMethod name="doTblDataClick" id="05799f6d-ad32-4438-85e9-6585f9bd50c2">
        <updating/>
        <source>doTblDataClick(table: Table input) updating;
/*

Purpose:			What to do when we click into the table

Parameters:			table	Table	The table we clicked on

Return Value:		NONE

Date			Who		Reason
10 October 2022	navpw1	Initial creation TFS: 54566

*/

vars
	row, col : Integer;
	
begin
	inheritMethod(table);
	
	if table.selectedNext(row, col) then	
		self.myCurrentInvLineMapping := table.accessRow(row).itemObject.CM_InvoiceLineDescMapping;
	endif;
	
	if table.selectedCount &gt; 0 then
		self.setControlsForAddEdit();
	else
		self.setControlsForView();
	endif;
	
end;</source>
