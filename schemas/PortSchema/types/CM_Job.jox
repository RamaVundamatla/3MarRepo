    <JadeMethod name="getTotalQuantity" id="74312465-57f4-4a16-b12c-154a0ce79174">
        <source>getTotalQuantity():Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2023	navhl20	ChangeRequest 57714:[57764] EUP - Delivery Dispatch – Gate
06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars
	qty 	: Integer;
	wle		: CM_WorkListEntry;
begin
	
	foreach wle in self.workListEntries discreteLock do
		qty := qty + wle.quantity.max(1);
	endforeach;

	return qty;
epilog

end;</source>
