    <JadeMethod name="doChangeCargoSubType" id="307d5ea0-698a-4340-a752-23df0a008d4b">
        <updating/>
        <source>doChangeCargoSubType(_cargoSubType : CM_Product) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 23/05/2018	jlgdap1		Initial creation TFS 38560 PEL1 Voyage Work Orders
//
vars
	weight, volume : String;

begin
	if _cargoSubType &lt;&gt; null then
		// set measurement type on weight / volume fields
		weight := _cargoSubType.getDefaultMeasurementForType(Type_Weight).shortName;
		volume := _cargoSubType.getDefaultMeasurementForType(Type_Volume).shortName;
		self.txtCargoWeight.accessCell(1, 3).text := weight;
		self.txtTareWeight.accessCell(1, 3).text := weight;
		self.txtTotalWeight.accessCell(1, 3).text := weight;
		self.txtTotalVolume.accessCell(1, 3).text := volume;
	endif;
epilog

end;</source>
        <Parameter name="_cargoSubType" type="CM_Product"/>
    </JadeMethod>
    <JadeMethod name="doChangeCargoType" id="604ef59d-9b45-45d2-a3ef-be870f2b81d7">
        <updating/>
        <source>doChangeCargoType(_cargoType : CM_CargoType) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 23/05/2018	jlgdap1		Initial creation TFS 38560 PEL1 Voyage Work Orders
//
vars
	weight, volume : String;

begin

	if _cargoType = null then
		return;
	endif;
	
	if _cargoType.hasProductTypes then
		self.cmbCargoSubType.listCollection(_cargoType.allProducts, true, 0);
		self.cmbCargoSubType.enabled := true;
	else
		self.cmbCargoSubType.clear;
		self.cmbCargoSubType.enabled := false;
		// use cargo type default weight / volume type to set weight / volume fields
		weight := _cargoType.getDefaultMeasurementForType(Type_Weight).shortName;
		volume := _cargoType.getDefaultMeasurementForType(Type_Volume).shortName;
		self.txtCargoWeight.accessCell(1, 3).text := weight;
		self.txtTareWeight.accessCell(1, 3).text := weight;
		self.txtTotalWeight.accessCell(1, 3).text := weight;
		self.txtTotalVolume.accessCell(1, 3).text := volume;
	endif;
	self.txtTotalWeight.enabled := true;
	if _cargoType.isTrackByWeight then
		self.txtTotalVolume.enabled := false;
	elseif _cargoType.isTrackByVolume then
		self.txtTotalVolume.enabled := true;
		self.txtTotalWeight.enabled := false;
	endif;
	if _cargoType.isAllowDuplicates then
		self.txtTotalQuantity.enabled := true;
	else
		self.txtTotalQuantity.enabled := false;
	endif;
	if _cargoType.useTareCargoWeight then
		self.txtCargoWeight.enabled := true;
		self.txtTareWeight.enabled := true;
	else
		self.txtCargoWeight.enabled := false;
		self.txtTareWeight.enabled := false;
	endif;
	if _cargoType.allCommodities.isEmpty then
		self.cmbCommodity.clear;
		self.cmbCommodity.enabled := false;
	else
		self.cmbCommodity.listCollection(_cargoType.allCommodities, true, 0);
		self.cmbCommodity.enabled := true;
	endif;
	
epilog

	
end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="doClearLine" id="24d3bcb2-5cdd-4b2e-ba7a-ebace3c79a32">
        <source>doClearLine( _table : CM_DataTable input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 June 2018	jlgndl1	Initial creation

*/

vars
	
	rowIndex : Integer;
	
	uColIndex : Integer;
	fdColIndex : Integer;
	ftColIndex : Integer;
	tdColIndex : Integer;
	ttColIndex : Integer;

begin

	rowIndex := _table.row;
	
	if rowIndex &gt; _table.fixedRows then
	
		uColIndex := _table.getColumnByRowName( ETRow_UnitsUsed );
		fdColIndex := _table.getColumnByRowName( ETRow_FromDate );
		ftColIndex := _table.getColumnByRowName( ETRow_FromTime );
		tdColIndex := _table.getColumnByRowName( ETRow_ToDate );
		ttColIndex := _table.getColumnByRowName( ETRow_ToTime );
		
		_table.accessCell( rowIndex, uColIndex ).text := null;
		_table.accessCell( rowIndex, fdColIndex ).text := null;
		_table.accessCell( rowIndex, ftColIndex ).text := null;
		_table.accessCell( rowIndex, tdColIndex ).text := null;
		_table.accessCell( rowIndex, ttColIndex ).text := null;
	
	endif;
	
	

epilog

end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doDeleteTask" id="d12ecab5-731f-4563-b06f-92a16bafbe32">
        <updating/>
        <source>doDeleteTask(_task : CM_WorkOrderDtl io) protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 August 2009	cnwmd1	Initial creation

*/

vars
	currentPos, lstIndexNow, collSize : Integer;
	nextTaskToDisplay : CM_WorkOrderDtl;
begin
	if _task &lt;&gt; null then
		//validation
		_task.validateForDelete();
		
		//Calculate the next task to display in the tasks listbox
		currentPos := self.myProxyWorkOrder.allWoDtls.indexOf(_task);
		if currentPos = 1 then
			lstIndexNow := currentPos + 1;
		else
			lstIndexNow := currentPos - 1;
		endif;
		
		if self.myProxyWorkOrder.allWoDtls.size &gt; 1 then
			nextTaskToDisplay := self.myProxyWorkOrder.allWoDtls[lstIndexNow].CM_WorkOrderDtl;
		endif;
		
		//remove the task
		self.myProxyWorkOrder.allWoDtls.remove(_task);
		delete _task;
		
		//- cnwmd1, CCMS 1075, Par 20354 - Removed because this now is handled by notifications
		//redisplay tasks
		self.myCurrentProxyTask := null;  //Setting to null will prevent the new selected object to be saved
		self.displayTasks(nextTaskToDisplay);
		self.myCurrentProxyTask := nextTaskToDisplay;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_task" type="CM_WorkOrderDtl" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doEditSource" id="43c90b9c-6655-4aa7-accf-3b9d4ee933a9">
        <updating/>
        <source>doEditSource( _obj : Object ) protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 August 2009	cnwmd1	Initial creation

*/

vars
	frm : YRD_TaskJobSourceForm;
	loadStateSet : Boolean;
	pxyWOSource : CM_WorkOrderTISource;
	task : CM_WorkOrderDtl;
	cargoType : CM_CargoType;
begin
	task := self.lstTasks.listObject.CM_WorkOrderDtl;
	if task.class &lt;&gt; CM_WodPack then
		app.raiseUnexpectedProgramError(self.class.name, method.name, "This task should not contain a source.");
		return;
	endif;
	pxyWOSource := task.CM_WodPack.mySource;
	
	// we should update the pxy source from the main form here if it can/has changed.
	cargoType := self.cmbPackCargoType.listObject.CM_CargoType;
	if cargoType &lt;&gt; null and not task.CM_WodPack.mySource.hasNonIDSource  then
		pxyWOSource.setProxy( cargoType.id, self.txtPackCargo.text);
	endif;
	
	
	frm := app.loadForm(YRD_TaskJobSourceForm, YRD_Assistant, false, false, false, self.myTerminal, self.myMasterMenuAction).YRD_TaskJobSourceForm;
	
	if frm = null then
		return;
	endif;
	
	frm.set(self, pxyWOSource);
	frm.setInitSource( _obj);
	
	//frm.showModal();\
	frm.myParentForm := self;
	frm.show();
	
	/*
	//Note: No cancel functionality for Add is allowed for. This is done on purpose.
	//Having to allow for the cancel would require a copy of the proxy to be made
	if frm.modalResult = IDOK and self.mode = self.Mode_Add then //Persistent wodtls have NOT been updated
		self.displayPackSource(task.CM_WodPack);
	elseif self.mode = self.Mode_Update then 
		//Either cancel has been presssed or an update on the persistent source has occurred.  
		//Refresh from persistent source in both cases.  
		//This is so that:
		//1. In the event of updating a persistent object the latest edition of the real object is retreived 
		//2. In the event of a cancel, any changes to the proxies has been backed out of
		
		app.cmsBeginLoad(loadStateSet);
		
		delete pxyWOSource;
		
		pxyWOSource := self.setProxyWorkOrderSource(task.CM_WodPack);
		self.displayPackSource(task.CM_WodPack);
		
		app.cmsEndLoad(loadStateSet);
	endif;
	
	self.setControlsForViewMode();
	
	*/
epilog
	//delete frm;
end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="doMoveTask" id="6f0d27f4-abf9-4a96-ba4c-3a56b4435494">
        <updating/>
        <source>doMoveTask(_direction : Integer; _task : CM_WorkOrderTIDtl input) protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 August 2009	cnwmd1	Initial creation

*/

vars
	currentPos, maxPos : Integer;
	workOrder : CM_WorkOrder;
begin
	if _task = null then
		return;
	endif;
	
	workOrder := self.myProxyWorkOrder;
	maxPos := workOrder.allWoDtls.size;
	currentPos := workOrder.allWoDtls.indexOf(_task);
	
	if _direction = self.MoveDirection_Up then //decreasing the pos
		if currentPos &gt; 1 then
			workOrder.allWoDtls.remove(_task);
			workOrder.allWoDtls.insert(currentPos - 1, _task);
			_task.setParent(workOrder);
			self.doRefresh();
		endif;
	elseif _direction = MoveDirection_Down then //increasing the pos
		if currentPos &lt; maxPos then
			workOrder.allWoDtls.remove(_task);
			workOrder.allWoDtls.insert(currentPos + 1, _task);
			_task.setParent(workOrder);
			self.doRefresh();
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_direction" type="Integer"/>
        <Parameter name="_task" type="CM_WorkOrderTIDtl" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doNewTask" id="50a05b33-ea47-4b81-ad54-4b42f422bfee">
        <updating/>
        <source>doNewTask() protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19/08/2009	cnwmd1	Initial creation
22/05/2018	jlgdap1	TFS 38560 PEL1 Voyage Work Orders
*/

vars
	form : YRD_WorkOrderNewTask;
begin
	form := app.loadForm(YRD_WorkOrderNewTask, YRD_Assistant, false, false, false, self.myTerminal, self.myMasterMenuAction).YRD_WorkOrderNewTask;
	if form = null then
		return;
	endif;

	form.setProxyWorkOrder(self.myProxyWorkOrder);
	form.setWorkOrderMode(self.workOrderMode);			// TFS 38560
	form.showModal();
	
	if form.modalResult = IDOK then
		self.doRefresh();
	endif;
epilog
	delete form;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="f6912ae0-397d-493c-8ea8-98960f9a5f7a">
        <updating/>
        <source>doRefresh() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04/08/2009	cnwrd1	Initial creation
22/05/2018	jlgdap1	TFS 38560 PEL1 Voyage Work Orders
*/

vars
	//task : CM_WorkOrderTIDtl;		// TFS 38560
	task : CM_WorkOrderDtl;			// TFS 38560
begin
	//inheritMethod();
	//self.lstTasks.listIndex := self.lstTasks.listCount();
	//task := self.lstTasks.listObject.CM_WorkOrderTIDtl;
	
	//task := self.myProxyWorkOrder.allWoDtls.last.CM_WorkOrderTIDtl;		// TFS 38560
	task := self.myProxyWorkOrder.allWoDtls.last.CM_WorkOrderDtl;			// TFS 38560
	
	self.displayTasks(task);

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResourceTypeSelected" id="30d21ee4-3176-4084-aa2e-d6badadc4d5f">
        <updating/>
        <source>doResourceTypeSelected() updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 22/05/2018	jlgdap1		Initial creation TFS 38560 PEL1 Voyage Work Orders
//
vars
	resourceType : HMS_ResourceType;
	resource : HMS_Resource;
	harbour 	: HMS_Harbour;
begin
	if self.cmbResourceType.listObject = null then
		return;
	endif;
	resourceType := self.cmbResourceType.listObject.HMS_ResourceType;
	if self.myVoyage &lt;&gt; null and  self.myVoyage.myHMSVoyageData &lt;&gt;  null then
		harbour:= self.myVoyage.myHMSVoyageData.myHarbour;
	endif;
	
	// populate resources for this type
	self.cmbResource.clear;
	foreach resource in resourceType.allResources discreteLock do
		if resource.isNotAvailableForEntry then
			continue;
		endif;
		if harbour &lt;&gt; null and resource.myHarbour &lt;&gt; harbour then
			continue;
		endif;
		
		self.cmbResource.addItemObject(resource.code &amp; Tab &amp; resource.description, resource);
	endforeach;
	
	// make fields enabled/disabled depending on resource type requirements
	if resourceType.isQuantityRequired then
		self.txtUnitsUsed.enabled := true;
	else
		self.txtUnitsUsed.enabled := false;
	endif;
	if resourceType.isActionDateTimeRequired then
		self.txtFromDate.enabled := true;
		self.txtFromTime.enabled := true;
	else
		self.txtFromDate.enabled := false;
		self.txtFromTime.enabled := false;
	endif;
	if resourceType.isFromToDateTimeRequired then
		self.txtFromDate.enabled := true;
		self.txtFromTime.enabled := true;
		self.txtToDate.enabled := true;
		self.txtToTime.enabled := true;
	else
		if not resourceType.isActionDateTimeRequired then
			self.txtFromDate.enabled := false;
			self.txtFromTime.enabled := false;
		endif;
		self.txtToDate.enabled := false;
		self.txtToTime.enabled := false;
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSaveBillingAdjustment" id="56c7da6e-59bc-412a-b117-ceda8e865255">
        <source>doSaveBillingAdjustment(_wodtl : CM_WodBillingAdjustment input) : Boolean protected;
/*
Purpose:	TFS 42241		
Date				Who			Reason
NOVEMBER 2018		CNWAB1		Initial creation


The proxy is set in the following:
YardSchema::YRD_TaskJobTasks::displayBillingAdjustment
YardSchema::YRD_TaskJobTasks::doSaveBillingAdjustment

*/

vars

begin
	_wodtl.setRemarks(self.txtBillingAdjReason.text);
	return true;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_wodtl" type="CM_WodBillingAdjustment" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveCargoRequest" id="768b1e29-d8a5-48ba-ad4a-6df096e4a040">
        <source>doSaveCargoRequest(_wodtl : CM_WodCargoRequest input):Boolean protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 23/05/2018	jlgdap1		Initial creation TFS 38560 PEL1 Voyage Work Orders
//
vars
	dischargePort : String;
	imexStatus, transferType : Integer;
	volume : Decimal [14, 4];
	totalWeight, tareWeight, cargoWeight : Decimal [14, 4];
	quantity : Integer;
	cargoSubType : CM_Product;
	cargoType : CM_CargoType;
	commodity : CM_Commodity;
	consignee, consignor, freightFwdr : CM_ConsigneeConsignor;
	location : CM_LocationsController;
	operator : CM_Operator;
	workPoint : CM_WorkPoint;
	allFiles : CM_FileDataSet;
	permitType : Integer;
	bolNumber : String;	//20 Jul 2018	NDL	TFS 39837
	loadPort : String;	//20 Jul 2018	NDL	TFS 39837
	estStartTS : TimeStamp;	//20 Jul 2018	NDL	TFS 39837
	estEndTS : TimeStamp;	//20 Jul 2018	NDL	TFS 39837
	reqByTS : TimeStamp;	//31 Jul 2018	NDL	TFS 39930
	berth : HMS_Berth;	//31 Jul 2018	NDL	TFS 39930
	resourceUsedSet : HMS_ResourceUsedSet; //17 Aug 2018	NDL	TFS 40127
	specialStow : CM_SpecialStow;	//07 Sep 2018	NDL	TFS 40699

begin
	create allFiles transient;
	
	cargoType := self.cmbCargoType.listObject.CM_CargoType;
	cargoSubType := self.cmbCargoSubType.listObject.CM_Product;
	commodity := self.cmbCommodity.listObject.CM_Commodity;
	operator := self.cmbOperator.listObject.CM_Operator;
	consignee := self.cmbConsignee.listObject.CM_ConsigneeConsignor;
	consignor := self.cmbConsignor.listObject.CM_ConsigneeConsignor;
	freightFwdr := self.cmbFreightFwdr.listObject.CM_ConsigneeConsignor;
	volume := self.txtTotalVolume.getConvertedValue;
	totalWeight := self.txtTotalWeight.getConvertedValue;
	tareWeight := self.txtTareWeight.getConvertedValue;
	cargoWeight := self.txtCargoWeight.getConvertedValue;
	if self.cmbImexStatus.listIndex &gt; 0 then
		imexStatus := self.cmbImexStatus.listObject.CM_IMEXStatus.code;
	endif;
	if self.cmbDischargePort.listIndex &gt; 0 then
		dischargePort := self.cmbDischargePort.listObject.CM_Port.code;
	endif;
	if self.cmbWorkPoint.listIndex &gt; 0 then
		workPoint := self.cmbWorkPoint.listObject.CM_WorkPoint;
	endif;
	if self.cmbTransferType.listIndex &gt; 0 then
		transferType := self.cmbTransferType.listObject.CM_VoyageJobTransferType.id;
	endif;
	if self.cmbLocation.listIndex &gt; 0 then
		location := self.cmbLocation.listObject.CM_LocationsController;
	endif;
	specialStow := self.cmbSpecialStow.listObject.CM_SpecialStow;	//07 Sep 2018	NDL	TFS 40699
	if not self.txtTotalQuantity.enabled then
		quantity := 1;
	else
		quantity := self.txtTotalQuantity.text.asIntegerJMT;
	endif;
	//27 Jun 2018	NDL	TFS 39246
	if self.cmbPermitType.listIndex &gt; 0 then
		permitType := self.cmbPermitType.itemData[self.cmbPermitType.listIndex];
	else
		permitType := INV_WO_PERMIT_MANUALETMAL;
	endif;
	if _wodtl.myVoyageCargoRequest &lt;&gt; null then
		//this is NOT an additional cargo request, this is the associated with the work order representing the total "Voyage Cargo" which does NOT use permit types.
		permitType := 0;
	endif;
	
	//20 Jul 2018	NDL	TFS 39837
	if self.cmbLoadPort.listIndex &gt; 0 then
		loadPort := self.cmbLoadPort.listObject.CM_Port.code;
	endif;
	//20 Jul 2018	NDL	TFS 39837
	bolNumber := self.txtBOLNumber.text.toUpper;
	//20 Jul 2018	NDL	TFS 39837
	estStartTS.setDate(self.txtEstStartDate.getDate());	
	estStartTS.setTime(self.txtEstStartTime.getTime());	
	estStartTS  := self.localToSystemTime(estStartTS);	
	//20 Jul 2018	NDL	TFS 39837
	estEndTS.setDate(self.txtEstEndDate.getDate());	
	estEndTS.setTime(self.txtEstEndTime.getTime());
	estEndTS := self.localToSystemTime(estEndTS);	
	
	//17 Aug 2018	NDL	TFS 40127
	create resourceUsedSet transient;
	// 26 Nov 2018	NDL	TFS 41980
	// "createResourceUsedPxys" now updates the _wodtl.CM_WodCargoRequest.myVoyageCargoRequest.allMarineServiceDetails directly 
	//28 Nov 2018	 and now the _wodtl.CM_WodCargoRequest.myPermitRequest.allMarineServiceDetails as well
	if not self.createResourceUsedPxys( self.tblResourcesCR, resourceUsedSet ) then
		return false;
	endif;
	
	_wodtl.setProxyWodCargoRequest(	dischargePort,
									imexStatus,
									self.txtNumGangs.text.Integer,
									quantity,
									volume,
									totalWeight,
									transferType,
									cargoWeight,
									tareWeight,
									cargoSubType,
									cargoType,
									commodity,
									consignee,
									consignor,
									freightFwdr,
									location,
									operator,
									workPoint,
									allFiles,
									permitType,	//permitType : Integer; //27 Jun 2018	NDL	TFS 39246
									loadPort,	//_loadPort : String;	//20 Jul 2018	NDL	TFS 39837
									bolNumber,	//_bolNumber : String;	//20 Jul 2018	NDL	TFS 39837
									estStartTS,	//_estStartTS : TimeStamp;	//20 Jul 2018	NDL	TFS 39837
									estEndTS	//_estEndTS : TimeStamp	//20 Jul 2018	NDL	TFS 39837
									);
									
	_wodtl.setSpecialStow( specialStow );	//07 Sep 2018	NDL	TFS 40699
	
	//31 Jul 2018	NDL	TFS 39930
	if _wodtl.myVoyageCargoRequest &lt;&gt; null then
		//Part of total voyage cargo request
		berth := self.cmbBerthCR.listObject.HMS_Berth;
		
		reqByTS.setDate(self.dtReqBy.getDate());	
		reqByTS.setTime(self.tmReqBy.getTime());	
		reqByTS  := self.localToSystemTime(reqByTS);	
	
		_wodtl.myVoyageCargoRequest.setMyBerth( berth );
		_wodtl.myVoyageCargoRequest.setRequiredByDT( reqByTS );
	//	_wodtl.myVoyageCargoRequest.setMarineDetsFromResourceUsed( resourceUsedSet );	//17 Aug 2018	NDL	TFS 40127 - Now done directly via "createResourceUsedPxys" call above.
	
//	else
		//An individual additional cargo request
//		_wodtl.setMarineDetsFromResourceUsed( resourceUsedSet );	//17 Aug 2018	NDL	TFS 40127
	endif;
	
	return true;
	
epilog
	delete allFiles;
	//17 Aug 2018	NDL	TFS 40127
	if not resourceUsedSet.isEmpty then
		resourceUsedSet.purge();
	endif;
	delete resourceUsedSet;
end;</source>
        <access>protected</access>
        <Parameter name="_wodtl" type="CM_WodCargoRequest" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveExtension" id="a6d4b1b5-0f51-4eab-95b6-150208ad7f9d">
        <source>doSaveExtension(_wodtl : CM_WodExtension input):Boolean protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 24/05/2018	jlgdap1		Initial creation TFS 38560 PEL1 Voyage Work Orders
// 28/03/2019	jlgdap1		TFS 43694 PEL1 Chanrging for Vessels that use a Ramp
//
vars
	occursOn : TimeStamp;
	resourceUsedSet : HMS_ResourceUsedSet;

begin
	occursOn.setDate(self.txtMoveOnDateNew.getDate);
	occursOn.setTime(self.txtMoveOnTimeNew.getTime);
	
	//_wodtl.setProxyWodExtension(occursOn);								// TFS 43694
	_wodtl.setProxyWodExtension(occursOn, self.chkHasRamp.value);			// TFS 43694
	
	create resourceUsedSet transient;
	if not self.createResourceUsedPxys( self.tblResourcesEx, resourceUsedSet ) then
		return false;
	endif;
	
	_wodtl.setMarineDetsFromResourceUsed( resourceUsedSet );
	
	return true;
	
epilog

	if not resourceUsedSet.isEmpty then
		resourceUsedSet.purge();
	endif;
	delete resourceUsedSet;

end;</source>
        <access>protected</access>
        <Parameter name="_wodtl" type="CM_WodExtension" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveHMSRequestCancel" id="963cc9ea-9122-4a98-afd3-7b51027022a7">
        <source>doSaveHMSRequestCancel(_wodtl : CM_WodHMSRequestCancel input) protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 24/05/2018	jlgdap1		Initial creation TFS 38560 PEL1 Voyage Work Orders
//
vars
	workOrder : CM_WorkOrderVoyage;

begin
	workOrder := self.cmbWorkOrderC.listObject.CM_WorkOrderVoyage;
	
	_wodtl.setProxyWodHMSRequestCancel(workOrder);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_wodtl" type="CM_WodHMSRequestCancel" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doSaveMarineDepart" id="91d7d327-1659-4631-8e4c-327893fc0856">
        <source>doSaveMarineDepart( _wodtl : CM_WodMarineServicesDepart input ):Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 July 2018	jlgndl1	Initial creation	TFS 39742

*/

vars

	resourceUsedSet : HMS_ResourceUsedSet;
	reqByTS : TimeStamp;
	towingVoyage : CM_Voyage;

begin

	create resourceUsedSet transient;

	towingVoyage := self.cmbTowVoyageMD.listObject.CM_Voyage;	
	if towingVoyage &lt;&gt; null and towingVoyage = self.myVoyage then
		app.raiseCMException(Voyage_not_itself, null, null);
		return false;
	endif;
	
	if not self.createResourceUsedPxys( self.tblResourcesMD, resourceUsedSet ) then
		return false;
	endif;
	
	_wodtl.setMarineDetsFromResourceUsed( resourceUsedSet );
	
	//19 Sep 2018	NDL	TFS 40810
	_wodtl.setPxyMarineDetails( self.txtDraftAftMD.text.Decimal,	//_draftAft : Decimal;
								self.txtDraftFwdMD.text.Decimal,	//_draftFwd : Decimal;
								self.txtBowMarkToMD.text.Decimal	//_bowMarkTo : Decimal
								);
	reqByTS.setDate(self.dtReqBy.getDate());	
	reqByTS.setTime(self.tmReqBy.getTime());	
	reqByTS  := self.localToSystemTime(reqByTS);	

	_wodtl.setRequiredByDT( reqByTS );
	
	_wodtl.setTowingVoyage(towingVoyage);
	
	return true;

epilog

	if not resourceUsedSet.isEmpty then
		resourceUsedSet.purge();
	endif;
	delete resourceUsedSet;

end;</source>
        <access>protected</access>
        <Parameter name="_wodtl" type="CM_WodMarineServicesDepart" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveMarineInitial" id="13b343b9-77b8-4528-8185-7c7899d87bd3">
        <source>doSaveMarineInitial( _wodtl : CM_WodMarineServicesInitial input ):Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 July 2018	jlgndl1	Initial creation	TFS 39742

*/

vars

	berth : HMS_Berth;
	resourceUsedSet : HMS_ResourceUsedSet;
	reqByTS : TimeStamp;
	wodVoyageCargoRequest : CM_WodVoyageCargoRequest;
	towingVoyage : CM_Voyage;

begin
	
	berth := self.cmbBerthMI.listObject.HMS_Berth;
	
	create resourceUsedSet transient;
	if not self.createResourceUsedPxys( self.tblResourcesMI, resourceUsedSet ) then
		return false;
	endif;
	
	//20 Sep 2018	NDL	TFS 40810
	towingVoyage := self.cmbTowVoyageMI.listObject.CM_Voyage;	
	if towingVoyage &lt;&gt; null and towingVoyage = self.myVoyage then
		app.raiseCMException(Voyage_not_itself, null, null);
		return false;
	endif;
	
	//31 Jul 2018	NDL	TFS 39930
	if self.myVoyage &lt;&gt; null then
		wodVoyageCargoRequest := self.myVoyage.allWorkOrders.getWorkOrderDetailOfType(WO_TASK_CARGOINITIAL).CM_WodVoyageCargoRequest;
	endif;
	
	if wodVoyageCargoRequest = null then	//31 Jul 2018	NDL	TFS 39930
		// TFS 40236 _wodtl.setMyBerth( berth );
		
		
		reqByTS.setDate(self.dtReqBy.getDate());	
		reqByTS.setTime(self.tmReqBy.getTime());	
		reqByTS  := self.localToSystemTime(reqByTS);	
	
		_wodtl.setRequiredByDT( reqByTS );
		
	endif;
	
	// TFS 40236
	_wodtl.setPxyMarineDetails(berth,
		self.txtDraftAftMI.text.Decimal,
		self.txtDraftFwdMI.text.Decimal,
		self.txtBowMarkToMI.text.Decimal,
		self.chkHasRampMI.value,
		self.optStarboardMI.value);

	_wodtl.setMarineDetsFromResourceUsed( resourceUsedSet );
		
	_wodtl.setTowingVoyage(towingVoyage);	//20 Sep 2018	NDL	TFS 40810

	return true;

epilog

	if not resourceUsedSet.isEmpty then
		resourceUsedSet.purge();
	endif;
	delete resourceUsedSet;

end;</source>
        <access>protected</access>
        <Parameter name="_wodtl" type="CM_WodMarineServicesInitial" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSavePermitRequest" id="7a130adb-79f2-4aa4-9daf-59e092a2a233">
        <source>doSavePermitRequest(_wodtl : CM_WodPermitRequest input):Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 Oct 2018	jlger1	Initial creation
20 Nov 2018 jlger1	TFS 41880
02 Jul 2019 jlgsl4	TFS 45375 - PEL - Wrong Move Amount for Penalty - Continue work order update
*/

vars
	relatedWOD : CM_WorkOrderVoyageDtl;
	proxywod : CM_WodCargoRequest;
	job : CM_VoyageHoldJob;
	rowIndex, posUnit: Integer;
	cargo : CM_TrackedItem;
	ct			: CM_CargoType;
	weight : Decimal [14,4];
	quantity, trsfrTypeInt, gangs : Integer;
	trsfrTypeStr, unit: String;
	workPoint : CM_WorkPoint;
	measureType : CM_MeasurementType;
	weightStr : String;
begin
	if self.cmbRelatedWO.visible then
		relatedWOD:=self.cmbRelatedWO.listObject.CM_WorkOrderVoyageDtl;
	endif;
	
	_wodtl.setProxyPermitRequest(self.cmbPermitType.listData,self.cmbPermitFor.listData,self.cmbPermitOperator.listObject.CM_Operator,relatedWOD);
	
	_wodtl.myParent.setLengthOfTime(self.txtPermitTotalDays.text.asDecimalJMT);
	
	
	
	// TFS 42221 19DEC18 - We have to create 'basic' cargo requests that are only used for invoicing, only ht ecargo type, discharge port, quantity and weight are set.
	if _wodtl.allCargoDetails.isEmpty() then
		foreach rowIndex in 1 to self.tblOOWConfirm.rows do
			if rowIndex &lt;= self.tblOOWConfirm.fixedRows then
				continue;
			endif;
			job := self.tblOOWConfirm.accessRow( rowIndex ).itemObject.CM_VoyageHoldJob;
			
			if job = null then
				continue;
			endif;
			
			cargo:=job.workListEntries.first.myTrackedItem;
			
			if cargo = null then
				continue;
			endif;
			
			ct := cargo.myCargoType;
			
			create proxywod transient;
			if ct &lt;&gt; null and  ct.isBulkMulti then
				weightStr := self.tblOOWConfirm.accessCell( rowIndex, AmountCol ).text;
				quantity := 0;
				
				if ct.isBulkByWeight then
					measureType:=ct.myWeightMeasurementType;
				elseif ct.isBulkByVolume then
					measureType:=ct.myVolumeMeasurementType;
				endif;
				
				weight := weightStr.asDecimalJMT; // DEFAULT
				if measureType &lt;&gt; null then
					unit := measureType.shortName;
					posUnit := weightStr.pos(unit,1);
					if posUnit &gt; 0 then
						weight := weightStr[1:posUnit].trimBlanks.asDecimalJMT;
					endif;
					weight := weight * measureType.conversionRate;
				
				endif;
				
				
			else
				quantity := self.tblOOWConfirm.accessCell( rowIndex, AmountCol ).text.Integer;		
				weight := 0;
			endif;
			trsfrTypeStr := self.tblOOWConfirm.accessCell( rowIndex, TransferTypeCol ).text;
			trsfrTypeInt := app.vesselAccessTypeStrToEnum(trsfrTypeStr);
			workPoint :=  self.myTerminal.allWorkPointsByCode[self.tblOOWConfirm.accessCell( rowIndex, WPCol ).text].CM_WorkPoint; 
			gangs := self.tblOOWConfirm.accessCell( rowIndex, GangsCol ).text.Integer;

			proxywod.setProxyForPermit(weight,quantity,trsfrTypeInt,workPoint,gangs, cargo);
			_wodtl.allCargoDetails.add(proxywod);
			
		endforeach;	
	else // UPDATE EXISTING
		foreach proxywod in _wodtl.allCargoDetails	discreteLock do : outerloop
		
			foreach rowIndex in 1 to self.tblOOWConfirm.rows do
				if rowIndex &lt;= self.tblOOWConfirm.fixedRows then
					continue;
				endif;
				job := self.tblOOWConfirm.accessRow( rowIndex ).itemObject.CM_VoyageHoldJob;
				
				if job = null then
					continue;
				endif;
				
				cargo:=job.workListEntries.first.myTrackedItem;

				if cargo.id = proxywod.taskID then
					ct := cargo.myCargoType;

					if ct &lt;&gt; null and  ct.isBulkMulti then
						if ct.isBulkByWeight then // --&gt; TFS 45375
							measureType := ct.myWeightMeasurementType;
						elseif ct.isBulkByVolume then
							measureType := ct.myVolumeMeasurementType;
						endif; // &lt;-- TFS 45375
						weight := self.tblOOWConfirm.accessCell( rowIndex, AmountCol ).text.Decimal * measureType.conversionRate; // TFS 45375
						quantity := cargo.totalQuantity;
					else
						quantity := self.tblOOWConfirm.accessCell( rowIndex, AmountCol ).text.Integer;		
						weight := cargo.totalWeight;
					endif;
					
					trsfrTypeStr := self.tblOOWConfirm.accessCell( rowIndex, TransferTypeCol ).text;
					trsfrTypeInt := app.vesselAccessTypeStrToEnum(trsfrTypeStr);
					workPoint :=  self.myTerminal.allWorkPointsByCode[self.tblOOWConfirm.accessCell( rowIndex, WPCol ).text].CM_WorkPoint; 
					gangs := self.tblOOWConfirm.accessCell( rowIndex, GangsCol ).text.Integer;
		
					proxywod.setProxyForPermit(weight,quantity,trsfrTypeInt,workPoint,gangs, cargo);
					
					continue outerloop;
				endif;
				
			endforeach;
			
			
		endforeach;
	
	endif;
	
	return true;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_wodtl" type="CM_WodPermitRequest" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveProxy" id="9935efb8-3049-4afe-844d-343bdf7bcc04">
        <source>doSaveProxy():Boolean protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 August 2009	cnwmd1	Initial creation
10/03/2011	cnwmh5	PAR #27142 - Change where handleDeletedObject is armed
29/04/2016	cnwns1	TFS 488 - Multi Timezone Support
08/05/2018	jlgdap1	TFS 38501 PEL1 Work Order Changes
22/05/2018	jlgdap1	TFS 38560 PEL1 Voyage Work Orders
20/06/2018  cnwma1	ChangeRequest 38815: PEL1 - WP TI Work Order Changes
12/02/2019	jlgdap1	TFS 43062 PEl1 Container Services - Changes in Web Portal
10/09/2021  navma1  ChangeRequest 51002: MTN - Web Portal Cargo Work Orders
05/05/2022	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
24 Mar 2023 navhl20 ChangeRequest 57301:[57303] EUP - [Framework] - Improve Audits on Work orders
18 Apr 2023 navhl20 ChangeRequest 55442:[57629] EUP - Pack Cargo Work Order - Enhancement
05 Jul 2024 navhl20	ChangeRequest 61368: EUP* | Adding Pack Reserve Child to Packing Work order Release Request
*/

vars
	wodtl 			: CM_WorkOrderDtl;
	pxyWOSource		: CM_WorkOrderTISource;
	imexStatus  	: CM_IMEXStatus;
	commodity   	: CM_Commodity;
	reqdDT, 
	startDT 		: TimeStamp;
	imexStatusCode  : Integer;
	commodityCode   : String;
	invalidWodDtl 	: Boolean; 
	todoSet 		: CM_ToDoTaskDescSet;
begin 

	wodtl := self.myCurrentProxyTask;

	if wodtl = null then
		return true; //No task selected - Form just loaded
	endif;
	
	on Exception do app.handleDeletedObject(exception, wodtl, invalidWodDtl); 
	
	reqdDT.setDate(self.dtReqBy.getDate());
	reqdDT.setTime(self.tmReqBy.getTime());
	startDT.setDate(self.dtStartBy.getDate());
	startDT.setTime(self.tmStartBy.getTime());
	//29 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
	reqdDT  := self.localToSystemTime(reqdDT);
	startDT := self.localToSystemTime(startDT);
	
	//wodtl.setProxy(reqdDT, startDT, self.chkAutoQueue.value ); //Base details		//24.3.2023 navhl20	#57301[57303]
	wodtl.setProxyReqByDT(reqdDT);													//24.3.2023 navhl20	#57301[57303]
	
	if invalidWodDtl then
		return true;
	endif;

	//Set the proxy for the appropriate type
	if wodtl.isKindOf(CM_WodMove) then
		wodtl.CM_WodMove.setProxyMove(self.cmbMoveSrcArea.listObject.CM_TerminalArea, 
									  self.cmbMoveTargArea.listObject.CM_TerminalArea, 
									  self.chkMoveAutoRTQ.value,
									  null); //	05/05/2022	navcs2	TFS 52351
	elseif wodtl.isKindOf(CM_WodPack) then
		imexStatus := self.cmbPackImExStats.listObject.CM_IMEXStatus;
		if imexStatus &lt;&gt; null then
			imexStatusCode := imexStatus.code;
		endif;
		
		commodity := self.cmbPackCommodity.listObject.CM_Commodity;
		if commodity &lt;&gt; null then
			commodityCode := commodity.code;
		endif;
		
		wodtl.CM_WodPack.setProxyWodPack(wodtl.CM_WodPack.allPackingTIs,			//10.09.2021 navma1 #51002 
				self.cmbPackBookRef.listObject.CM_BookingRef,
				self.cmbPackConsignee.listObject.CM_ConsigneeConsignor,
				self.cmbPackConsignor.listObject.CM_ConsigneeConsignor,
				self.cmbPackConStatus.listObject.CM_ContentsStatus,
				self.cmbPackDishPort.listObject.CM_Port,
				self.cmbPackOperator.listObject.CM_Operator,
				self.cmbPackSubTerm.listObject.CM_SubTerminal,
				self.cmbPackVoyage.listObject.CM_Voyage,
				commodityCode,
				imexStatusCode,
				null,																//18.4.2023 navhl20 #55442[57629]
				null,																//05.07.2024 navhl20 #61368
				self.chkPackIsChild.value);
		
		if wodtl.CM_WodPack.mySource = null then
			pxyWOSource := self.setProxyWorkOrderSource(wodtl.CM_WodPack);
		endif;
		
		//29.09.2021 navma1 #51925
		create todoSet transient;
		self.mulReceiveToDo.getSelected( todoSet );	
		wodtl.CM_WodPack.setProxyAllToDoRequests( todoSet );
		//29.09.2021 navma1 #51925
		
	elseif wodtl.isKindOf(CM_WodUnpack) then
		wodtl.CM_WodUnpack.setProxyWodUnpack(self.cmbUnpkToLocal.listObject.CM_TerminalArea);
		
		//29.09.2021 navma1 #51925
		create todoSet transient;
		self.mulReceiveToDo.getSelected( todoSet );	
		wodtl.CM_WodUnpack.setProxyAllToDoRequests( todoSet );
		//29.09.2021 navma1 #51925
		
	elseif wodtl.isKindOf(CM_WodToDo) then
		wodtl.CM_WodToDo.setProxyWodToDo(self.cmbToDoDesc.listObject.CM_ToDoTaskDesc);
		
	elseif wodtl.isWorkOrderForNullVoyage then													// TFS 38501
		wodtl.CM_WodNullVoyage.setProxyWodNullVoyage(self.cmbVoyage.listObject.CM_Voyage);		// TFS 38501
	elseif wodtl.isWorkOrderForReceival then													// TFS 38501
		//wodtl.CM_WodReceive.setProxyWodReceival(self.cmbBooking.listObject.CM_BookingRef,
												//self.txtCustomExportEntryNumber.text); //20.6.2018 cnwma1 TFS #38815
		
		create todoSet transient;								//11 Jul 2018	NDL	TFS 39638
		self.mulReceiveToDo.getSelected( todoSet );				//11 Jul 2018	NDL	TFS 39638
		wodtl.CM_WodReceive.setProxyAllToDoRequests( todoSet );	//11 Jul 2018	NDL	TFS 39638
		
	elseif wodtl.isWorkOrderForRelease then														// TFS 38501
		//wodtl.CM_WodRelease.setProxyWodRelease(self.cmbRelease.listObject.CM_BulkRelease);		// TFS 38501
		
		create todoSet transient;								//29.09.2021 navma1 #51925
		self.mulReceiveToDo.getSelected( todoSet );				//29.09.2021 navma1 #51925
		wodtl.CM_WodRelease.setProxyAllToDoRequests( todoSet ); //29.09.2021 navma1 #51925
		
		wodtl.CM_WodRelease.setCustomsClearanceNumber(self.txtCustoms.text.trimBlanks);		// TFS 43062
	
	elseif wodtl.isWorkOrderForReleaseExtension then	//12 Mar 2019	NDL	TFS 43405
		wodtl.CM_WodReleaseExtension.setProxyWodReleaseExt(self.cmbRelExtWORel.listObject.CM_WodRelease);
	
		create todoSet transient;										//29.09.2021 navma1 #51925
		self.mulReceiveToDo.getSelected( todoSet );						//29.09.2021 navma1 #51925
		wodtl.CM_WodReleaseExtension.setProxyAllToDoRequests( todoSet );  //29.09.2021 navma1 #51925
		
	elseif wodtl.isKindOf(CM_WodShiftMovement) then						// TFS 38560
		return self.doSaveShiftMovement(wodtl.CM_WodShiftMovement);		// TFS 38560
	elseif wodtl.isKindOf(CM_WodCargoRequest) then						// TFS 38560
		return self.doSaveCargoRequest(wodtl.CM_WodCargoRequest);		// TFS 38560
	elseif wodtl.isKindOf(CM_WodTimeChange) then						// TFS 38560
		self.doSaveTimeChange(wodtl.CM_WodTimeChange);					// TFS 38560
	elseif wodtl.isKindOf(CM_WodExtension) then							// TFS 38560
		return self.doSaveExtension(wodtl.CM_WodExtension);				// TFS 38560
	elseif wodtl.isKindOf(CM_WodWaterRequest) then						// TFS 38560
		self.doSaveWaterRequest(wodtl.CM_WodWaterRequest);				// TFS 38560
	elseif wodtl.isKindOf(CM_WodHMSRequestCancel) then					// TFS 38560
		self.doSaveHMSRequestCancel(wodtl.CM_WodHMSRequestCancel);		// TFS 38560
		
	elseif wodtl.isKindOf(CM_WodMarineServicesInitial) then					 //17 Jul 2018	NDL	TFS 39742
		return self.doSaveMarineInitial(wodtl.CM_WodMarineServicesInitial); 
	elseif wodtl.isKindOf(CM_WodMarineServicesDepart) then					 //17 Jul 2018	NDL	TFS 39742
		return self.doSaveMarineDepart(wodtl.CM_WodMarineServicesDepart);
	elseif wodtl.isKindOf(CM_WodVoyageRequest) then							 // TFS 40029
		return self.doSaveVoyageRequest(wodtl.CM_WodVoyageRequest);			 // TFS 40029
	elseif wodtl.isKindOf(CM_WodPermitRequest) then
		return self.doSavePermitRequest(wodtl.CM_WodPermitRequest); 
	elseif wodtl.isKindOf(CM_WodBillingAdjustment) then 					 // TFS 42241
		return self.doSaveBillingAdjustment(wodtl.CM_WodBillingAdjustment);  // TFS 42241
	endif;
	
	return true;	//22 Jun 2018	NDL	TFS 39248
		
epilog

	delete todoSet;

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveShiftMovement" id="0c567727-6b72-49b3-99e2-9e305fce5f8a">
        <source>doSaveShiftMovement(_wodtl : CM_WodShiftMovement input):Boolean protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 22/05/2018	jlgdap1		Initial creation TFS 38560 PEL1 Voyage Work Orders
// 19/02/2019	jlgdap1		TFS 43433 PEL1 INAP - Payment type resetting for Shift Movement 
//
vars
	occursOn : TimeStamp;
	serverOccursOn : TimeStamp;
	cargoRequests : CM_WodCargoRequestSet;
	prevMove : HMS_VoyageMovement;
	previousBerth : HMS_Berth;
	seaHarbourRegion : HMS_HarbourRegion;
	seaHRArrivalBerth : HMS_Berth;
	towingVoyage : CM_Voyage;	//22 Jun 2018	NDL	TFS 39248
	resourceUsedSet : HMS_ResourceUsedSet;	//22 Jun 2018	NDL	TFS 39248
	berthArrival : TimeStamp;	//26 Oct 2018	NDL	TFS 41413
	serverBerthArrival : TimeStamp;	//26 Oct 2018	NDL	TFS 41413

begin
	create cargoRequests transient;
	occursOn.setDate(self.txtMoveOnDate.getDate);
	occursOn.setTime(self.txtMoveOnTime.getTime);
	serverOccursOn := occursOn.localToSystemTimeUsingObject(self.myTerminal);
	if self.myCurrentMovement &lt;&gt; null then
		prevMove := self.myCurrentMovement.getMovementPrevious.HMS_VoyageMovement;
	endif;
	if prevMove &lt;&gt; null then
		previousBerth := prevMove.getMyBerth;
	else
		// TFS 43433 Previous movement should be the movement prior to the "occursOnDT" of this	// TFS 43433
		// Shift movement. Don't default to SEA just yet unless we can't find a prior movement	// TFS 43433
		if self.myVoyage &lt;&gt; null then															// TFS 43433
			prevMove := self.myVoyage.getMovementForDateTime(serverOccursOn);					// TFS 43433
			if prevMove &lt;&gt; null then															// TFS 43433
				previousBerth := prevMove.getMyBerth;											// TFS 43433
			endif;																				// TFS 43433
		endif;																					// TFS 43433
		if previousBerth = null then															// TFS 43433
			seaHarbourRegion := app.myRoot.getSeaHarbourRegion;
			if seaHarbourRegion &lt;&gt; null then
				seaHRArrivalBerth := seaHarbourRegion.getArrivalBerth();
				if seaHRArrivalBerth &lt;&gt; null then
					previousBerth := seaHRArrivalBerth;
				endif;
			endif;
		endif;																					// TFS 43433
	endif;
	
	towingVoyage := self.cmbTowVoyage.listObject.CM_Voyage;	//22 Jun 2018	NDL	TFS 39248
	if towingVoyage &lt;&gt; null and towingVoyage = self.myVoyage then
		app.raiseCMException(Voyage_not_itself, null, null);
	endif;
	
	//22 Jun 2018	NDL	TFS 39248
	create resourceUsedSet transient;
	if not self.createResourceUsedPxys( self.tblResources, resourceUsedSet ) then
		return false;
	endif;
	
	//26 Oct 2018	NDL	TFS 41413
	berthArrival.setDate(self.txtBerthArrDate.getDate);
	berthArrival.setTime(self.txtBerthArrTime.getTime);
	serverBerthArrival := berthArrival.localToSystemTimeUsingObject(self.myTerminal);
	
	_wodtl.setProxyWodShiftMovement(	self.txtBowMarkTo.text.Decimal,
										self.txtDraftAft.text.Decimal,
										self.txtDraftFwd.text.Decimal,
										serverOccursOn,
										self.txtLineRelative.text.Integer,
										self.txtLaunchRelative.text.Integer,
										self.txtTugRelative.text.Integer,
										self.txtSternMarkTo.text.Decimal,
										previousBerth,
										self.cmbToBerth.listObject.HMS_Berth,
										cargoRequests,
										towingVoyage,	//22 Jun 2018	NDL	TFS 39248
										self.chkHasRampSM.value, // TFS 40236
										self.optStarboardSM.value, // TFS 40236
										serverBerthArrival	//_berthArrivalDT : TimeStamp	//26 Oct 2018	NDL	TFS 41413
										);
										
	_wodtl.setMarineDetsFromResourceUsed( resourceUsedSet );	//22 Jun 2018	NDL	TFS 39248
	
	//22 Jun 2018	NDL	TFS 39248
	if serverOccursOn.date.isValid and self.myParentForm.isKindOf(YRD_TaskJobMaintForm) then //epr 13/8/18 1086
		self.myParentForm.YRD_TaskJobMaintForm.dtJobRequiredBy.setDate( serverOccursOn.date );
		self.myParentForm.YRD_TaskJobMaintForm.tmJobRequiredBy.setTime( serverOccursOn.time );
	endif;
	
	return true;
	
epilog
	delete cargoRequests;
	//22 Jun 2018	NDL	TFS 39248
	if not resourceUsedSet.isEmpty then
		resourceUsedSet.purge();
	endif;
	delete resourceUsedSet;	//22 Jun 2018	NDL	TFS 39248
end;</source>
        <access>protected</access>
        <Parameter name="_wodtl" type="CM_WodShiftMovement" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveTimeChange" id="3b9bbb35-2944-46ba-ade7-e32b2c376a8b">
        <source>doSaveTimeChange(_wodtl : CM_WodTimeChange input) protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 24/05/2018	jlgdap1		Initial creation TFS 38560 PEL1 Voyage Work Orders
//
vars
	workOrder : CM_WorkOrderVoyage;
	occursOn : TimeStamp;

begin
	occursOn.setDate(self.txtMoveOnDateTC.getDate);
	occursOn.setTime(self.txtMoveOnTimeTC.getTime);
	if self.cmbWorkOrder.listIndex &gt; 0 then
		workOrder := self.cmbWorkOrder.listObject.CM_WorkOrderVoyage;
	endif;
	
	_wodtl.setProxyWodTimeChange(occursOn, null, workOrder);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_wodtl" type="CM_WodTimeChange" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doSaveVoyageRequest" id="59773532-2330-4952-b0f0-00f33648dfe6">
        <source>doSaveVoyageRequest(_wodtl : CM_WodVoyageRequest input) : Boolean protected;
/*

Purpose:		TFS 40029	

Parameters:			

Return Value:		

Date				Who		Reason
20 August 2018		jlgab1	Initial creation
06 October 2021		jlizm1	TFS 51963 SAL Voyage Request Changes
31 August 2022		jlizm1	TFS 54298 EUP - Simplified Voyage Work Order Process

*/

vars
	cargoOperatorCodeDischarge : String;
	cargoOperatorCodeLoad : String;
	commodityCode : String;
	estimatedArrivalTS : TimeStamp;
	estimatedDepartureTS : TimeStamp;
	externalCode : String;
	hasCargo : Boolean;
	portCode1 : String;
	portCode2 : String;
	portCode4 : String;
	portCode5 : String;
	remarks : String;
	vesselCategoryCode : String;
	vesselCode : String;
	visitTypeCode : String;
	voyageCode : String;
	voyageCodeIn : String;
	voyageCodeOut : String;
	voyageOperatorCode : String;
	voyageProcess : CM_VoyageProcess;
	
	tmpOp : CM_Operator;
	tmpTS : TimeStamp;
	tmpPort : CM_Port;
	tmpVC : HMS_VesselCategory;
	tmpVT : HMS_VisitType;
begin

	tmpOp := self.cmbOpCargoDischVR.listObject.CM_Operator;
	if tmpOp &lt;&gt; null then
		cargoOperatorCodeDischarge := tmpOp.code;
	endif;

	tmpOp := self.cmbOpCargoLoadVR.listObject.CM_Operator;
	if tmpOp &lt;&gt; null then
		cargoOperatorCodeLoad := tmpOp.code;
	endif;

	commodityCode := _wodtl.commodityCode;

	tmpTS.setDate(self.txtEstArrVR.getDate());	
	tmpTS.setTime(self.txtEstArrTimeVR.getTime());
	tmpTS := self.localToSystemTime(tmpTS);	
	estimatedArrivalTS := tmpTS;

	tmpTS.setDate(self.txtEstDepVR.getDate());	
	tmpTS.setTime(self.txtEstDepTimeVR.getTime());
	tmpTS := self.localToSystemTime(tmpTS);	
	estimatedDepartureTS := tmpTS;
	
	externalCode := _wodtl.externalCode;
	
	tmpPort := self.cmbPortOriginVR.listObject.CM_Port;
	if tmpPort &lt;&gt; null then
		portCode1 := tmpPort.code;
	endif;
	
	tmpPort := self.cmbPortLastCallVR.listObject.CM_Port;
	if tmpPort &lt;&gt; null then
		portCode2 := tmpPort.code;
	endif;
	
	
	tmpPort := self.cmbPortNextPortVR.listObject.CM_Port;
	if tmpPort &lt;&gt; null then
		portCode4 := tmpPort.code;
	endif;
	
	tmpPort := self.cmbPortLastVR.listObject.CM_Port;
	if tmpPort &lt;&gt; null then
		portCode5 := tmpPort.code;
	endif;

	tmpVC := self.cmbVesselCatVR.listObject.HMS_VesselCategory;
	if tmpVC &lt;&gt; null then
		vesselCategoryCode :=  tmpVC.code;
	endif;
	
	vesselCode := _wodtl.vesselCode;
	
	tmpVT := self.cmbVisitTypeVR.listObject.HMS_VisitType;
	if tmpVT &lt;&gt; null then
		visitTypeCode := tmpVT.code;
	endif;
	
	voyageCode := _wodtl.voyageCode;
	
	voyageCodeIn := self.txtCodeVoyageInVR.text.trimBlankCharacters;
	voyageCodeOut := self.txtCodeVoyageOutVR.text.trimBlankCharacters;
	
	tmpOp := self.cmbOpVoyageVR.listObject.CM_Operator;
	if tmpOp &lt;&gt; null then
		voyageOperatorCode := tmpOp.code;
	endif;
	
	remarks := self.txtGeneralRemarksVR.text; // TFS 51963
	
	voyageProcess := self.myTerminal.getDefaultVoyageProcess;			// TFS 54298
	if voyageProcess &lt;&gt; null and voyageProcess.isEUPDefaultProcess then	// TFS 54298
		hasCargo := true;												// TFS 54298
	else
		hasCargo := self.chkHasCargoVR.value;							// TFS 54298
	endif;
	
	_wodtl.setProxyVoyageRequest(	cargoOperatorCodeDischarge,
														cargoOperatorCodeLoad,
														commodityCode,
														estimatedArrivalTS,
														estimatedDepartureTS,
														externalCode,
														portCode1,
														portCode2,
														portCode4,
														portCode5,
														vesselCategoryCode,
														vesselCode,
														visitTypeCode,
														voyageCode,
														voyageCodeIn,
														voyageCodeOut,
														voyageOperatorCode,
														remarks,
														hasCargo);
														
	return true;
													
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_wodtl" type="CM_WodVoyageRequest" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveWaterRequest" id="2a7520fb-857d-446e-a043-70f2555134c7">
        <source>doSaveWaterRequest(_wodtl : CM_WodWaterRequest input) protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 24/05/2018	jlgdap1		Initial creation TFS 38560 PEL1 Voyage Work Orders
//
vars
	fromDateTime, toDateTime : TimeStamp;
	resourceType : HMS_ResourceType;
	resource : HMS_Resource;
	transferType : Integer;

begin
	resourceType := self.cmbResourceType.listObject.HMS_ResourceType;
	resource := self.cmbResource.listObject.HMS_Resource;
	fromDateTime.setDate(self.txtFromDate.getDate);
	fromDateTime.setTime(self.txtFromTime.getTime);
	toDateTime.setDate(self.txtToDate.getDate);
	toDateTime.setTime(self.txtToTime.getTime);
	if self.cmbWTransferType.listIndex &gt; 0 then
		transferType := self.cmbWTransferType.listObject.CM_VoyageJobTransferType.id;
	endif;
	
	_wodtl.setProxyWodWaterRequest(	fromDateTime,
									toDateTime,
									self.txtUnitsUsed.text.asRealJMT,
									transferType,
									resource,
									resourceType	);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_wodtl" type="CM_WodWaterRequest" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTaskListContextMenu" id="8399b2c2-331e-4647-9b6f-11054c9ee74f">
        <updating/>
        <source>doTaskListContextMenu(cntrl: ListBox input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 December 2009	cnwrd1	Initial creation

*/

vars

begin

	self.mnuAddTask.visible := self.btnNew.enabled;
	self.mnuRemoveTask.visible := self.btnDelete.enabled;
	self.mnuMoveUp.visible := self.btnTaskUp.enabled;
	self.mnuMoveDown.visible := self.btnTaskDown.enabled;

	return self.showContextMenu(self.mnuTaskOptions,cntrl,conwin,mouse,x,y);
	
epilog

end;</source>
        <Parameter name="cntrl" type="ListBox" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="enableControls" id="814eebcc-a91c-48af-9f9d-a7411f9b9e58">
        <source>enableControls() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 Aug 2009	cnwmd1	Initial creation
16 Aug 2018 cnwma1	ChangeRequest 39698: PEL1 - SAP Enable SAP interfaces
29 Sep 2021 navma1  ChangeRequest 51925: SAL - Web Portal Cargo Work Orders
16 Feb 2022 navma1	Bug 52884: MTN - Work Order - Should Allow Multiple Tasks to be Added to a Cargo Work Order
*/

vars
	task 			 : CM_WorkOrderDtl;
	currentPos 		 : Integer;
	size 			 : Integer;
	voyCargoRequest  : CM_WodVoyageCargoRequest;
	disableJobCntrls : Boolean;
begin
	
	task := self.lstTasks.listObject.CM_WorkOrderDtl;
	
	if task &lt;&gt; null then
		if task.isKindOf( CM_WodCargoRequest ) then
			voyCargoRequest := task.CM_WodCargoRequest.myVoyageCargoRequest;
		endif;
	endif;
	
	if task &lt;&gt; null then
		//16 Jul 2018	NDL	TFS 39742
		if task.myParent = null then
			if  voyCargoRequest &lt;&gt; null then
				currentPos := voyCargoRequest.allCargoDetails.indexOf(task.CM_WodCargoRequest);
				size := voyCargoRequest.allCargoDetails.size;
			endif;
		else
			currentPos := task.myParent.allWoDtls.indexOf(task);
			size 	   := task.myParent.allWoDtls.size;
		endif;
	else
		currentPos := 0;
		size       := 0;
	endif;
	
	self.btnDelete.enabled   := ( task &lt;&gt; null )     and (not self.isApproved);
	self.btnTaskUp.enabled   := ( currentPos &gt; 1)    and (not self.isApproved);
	self.btnTaskDown.enabled := (currentPos &lt; size)  and (not self.isApproved);
	
	//29.09.2021 navma1 #51925
	//16.02.2022 navma1	#52884
	if task.isKindOf(CM_WorkOrderVoyageDtl) then
		disableJobCntrls := true;
	elseif task.isKindOf(CM_WorkOrderTIDtl) then
		if self.isUseYardJobs then
			disableJobCntrls := false;
		else
			disableJobCntrls := true;
		endif;
	endif;
	
	//16.02.2022 navma1	#52884
	if  disableJobCntrls then
		self.btnDelete.enabled   := false;
		self.btnNew.enabled 	 := false;
		self.btnTaskUp.enabled   := false;
		self.btnTaskDown.enabled := false;
	endif;
	

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="filterDischargePort" id="62c34ce7-4171-41be-9eba-eaf8b434404c">
        <updating/>
        <source>filterDischargePort(_imexStatus : Integer) updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 19/06/2018	jlgdap1		Initial creation TFS 38560 PEL1 Voyage Work order fix ups
//
vars
	port : CM_Port;

begin
	if _imexStatus &lt;&gt; TI_IMEX_STATUS_IMPORT then
		self.cmbDischargePort.enabled := true;
		return;
	endif;
	port := self.myTerminal.getDefaultPort;
	self.cmbDischargePort.listIndex := self.cmbDischargePort.findObject(port);
	self.cmbDischargePort.enabled := false;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_imexStatus" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getActivePorts" id="95e2f68c-3b72-4d9e-86e0-b2623062ddc5">
        <source>getActivePorts(_wod : CM_WorkOrderVoyageDtl ; _allPorts : CM_PortByCodeDict input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Dec 21	    navma1	ChangeRequest 52511: SAL - Web Portal - Ports of Call

*/

vars
	voyage  : CM_Voyage;
	port	: CM_Port;
begin
	
	if _wod.isKindOf(CM_WodVoyageRequest) then
		voyage := _wod.CM_WodVoyageRequest.getMyVoyageObject();
		
		foreach port in voyage.allPorts discreteLock do 
			_allPorts.addNoDuplicates(port,false);
		endforeach;
	else
		app.myRoot.allActivePorts.copy(_allPorts);
	endif;
	
	
epilog

end;</source>
        <Parameter name="_wod" type="CM_WorkOrderVoyageDtl"/>
        <Parameter name="_allPorts" type="CM_PortByCodeDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTaskDescription" id="e780807a-8f20-4bfd-aba1-e9242fa42f8f">
        <source>getTaskDescription( _task : CM_ToDoTaskDesc ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 July 2018	jlgndl1	Initial creation	TFS 39638

*/

vars

begin

	return _task.description;

epilog

end;</source>
        <Parameter name="_task" type="CM_ToDoTaskDesc"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getWorkPointDaysToComplete" id="f229c5ce-b207-4c1f-a744-c2616e3f6546">
        <source>getWorkPointDaysToComplete(_workPoint : CM_WorkPoint;
							_holdJob : CM_VoyageHoldJob;
							_newTrsfrType : CM_VoyageJobTransferType;
							_gangs 	: Integer;
							_newAmount : String;
							_newRate : String output) : Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 November 2018	jlger1	Initial creation 41645

*/

vars
	cargoType  : CM_CargoType;
	ti  : CM_TrackedItem;
	wpCraneRate : CM_WorkPointCargoRates;
	totalHrs : Decimal[16,2];
	hrsPerDay : Decimal[4,2];
	elapsedDays : Decimal[6,2];
	newAmount   : Decimal[16,2];
	unit : String;
	posUnit : Integer;
	measureType : CM_MeasurementType;
begin
	if _workPoint = null  or _holdJob = null then
		return null ;
	endif;
	
	cargoType :=_holdJob.workListEntries.first.getCargoType();
	
	if cargoType = null then
		return null;
	endif;
	
	wpCraneRate:=_workPoint.getDefinedTargetRate(_holdJob,_newTrsfrType,ti);
	if wpCraneRate = null then
		return null;
	endif;
	newAmount:=_newAmount.asDecimalJMT;
	if cargoType.isBulkByWeight then
		measureType:=cargoType.myWeightMeasurementType;
		
		
	elseif cargoType.isBulkByVolume then
		measureType:=cargoType.myVolumeMeasurementType;
	endif;
	
	if measureType &lt;&gt; null then
		unit :=measureType.shortName;
		posUnit:=_newAmount.pos(unit,1);
		if posUnit &gt; 0 then
			newAmount:=_newAmount[1:posUnit].trimBlanks.asDecimalJMT;
		endif;
		newAmount:=newAmount * measureType.conversionRate;
	
	endif;
	
	if cargoType.isBulkByVolume then
		totalHrs := ( newAmount / wpCraneRate.targetRatePHVolume ).Decimal.roundedTo(2);
	elseif cargoType.isBulkByWeight then
		totalHrs := (newAmount / wpCraneRate.targetRatePHWeight ).Decimal.roundedTo(2);
	else
		totalHrs := ( _newAmount.Integer / wpCraneRate.targetRatePHQuantity ).Decimal.roundedTo(2);
	endif;
	
	_newRate:=wpCraneRate.getTargetRateStr();
	
	if totalHrs &lt;= 0 then
		return 0.0;
	endif;
	
	//03 Aug 2018	NDL	TFS 40048
	if _gangs &gt; 1 then
		totalHrs := totalHrs / _gangs;
	endif;
	//epr TFS 41310 23/10/18 
	if wpCraneRate.dailyHoursWorkable &gt; 0 and totalHrs &gt; wpCraneRate.dailyHoursWorkable then
		hrsPerDay := wpCraneRate.dailyHoursWorkable;
	else
		hrsPerDay := 24.0;
	endif;
	
	elapsedDays := ( totalHrs / hrsPerDay ).Decimal.roundedTo(2);
	
	return elapsedDays;
epilog

end;</source>
        <Parameter name="_workPoint" type="CM_WorkPoint"/>
        <Parameter name="_holdJob" type="CM_VoyageHoldJob"/>
        <Parameter name="_newTrsfrType" type="CM_VoyageJobTransferType"/>
        <Parameter name="_gangs" type="Integer"/>
        <Parameter name="_newAmount" type="String"/>
        <Parameter name="_newRate" type="String" usage="output"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="initDetailTable" id="eb28a23e-5e79-431d-a7bd-90208d273988">
