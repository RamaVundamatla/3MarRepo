    <JadeMethod name="getAlternateISOTypeGroup" id="f53098a5-0798-4ac6-83b7-4d32d2967b88">
        <source>getAlternateISOTypeGroup(): CM_ISOTypeGroup;
/*
 ------------------------------------------------------------------------
Created:			18 December 2001 by cnwdwq1
Purpose:			
							If this container is a Reefer box with a COU attached, then we treat it as if
							its an integral for planning purposes.
							This method determines if it does fall into this category, and returns an appropriate
							isoTypeGroup.
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	isoT	:	CM_ISOType;
begin
	if self.isPortHole = false then
		return null;
	endif;
	if not self.requiresTemperature then
		//No commodity that requires a temperature
		return null;
	endif;
	if self.hasCOU = false then
		//No cou..
		return null;
	endif;
	//----------------
	//By now, we are a PortHole with a COU, find and return an ISOTypeGroup for this type
	//----------------
	foreach isoT in app.myRoot.allISOTypes do
		if not isoT.isIntegral then
			continue;
		endif;
		if isoT.myISOTypeGroup &lt;&gt; null then
			return isoT.myISOTypeGroup;
		endif;
	endforeach;
end;</source>
        <ReturnType type="CM_ISOTypeGroup"/>
    </JadeMethod>
    <JadeMethod name="getAuditTextForProperty" id="ea94dd63-a63c-4113-94d3-b1147ec8a80a">
        <source>getAuditTextForProperty(_property: Property): String;
//----------------------------------------------------------------
//	Created:	17 September 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
/* Changes

Date		Name	TFS#		Description
============================================================================
29 Mar 2019 jlgka1	TFS 44020	Change StringArray to HugeStringArray.
14 Nov 2019	jlgdap1	TFS 46405 AAT Flat Rack and OOG in LOLO Planning Screen
19 Jan 2024	jlika1	TFS 62092 CUX | MAFI Contents Status on Transactions
============================================================================*/
vars
	propName : String;
	strArray : HugeStringArray;	//jlgka1 TFS 44020
	tmpStatus : CM_ContentsStatus;
begin
	propName := _property.name;
	
	//if propName = CM_Container::allCustomsSealNumbers.name then
	if propName = AllCustomsSealNumbers then	//17 Sep 2010	NDL	Par 25608
		//16 Sep 2010	NDL	Par 25608	remove ref to 'allCustomsSealNumbers'
		create strArray transient;
		self.getSealNumCustomsStringArray(strArray);
		//return self.formatAuditText(propName, self.getAuditTextForStringArray(self.allCustomsSealNumbers));
		return self.formatAuditText(propName, self.getAuditTextForHugeStringArray(strArray)); //jlgka1 TFS 44020
		
	elseif propName = CM_Container::getTemperature.name then
		if self.getTemperature = NULL_TEMPERATURE then
			return self.formatAuditText(propName, null);			// PAR #19538
		else
			return self.formatAuditText(propName, self.getTemperature.String);
		endif;
	elseif propName = CM_Container::getHumidity.name then //cnwrs1 Par19451 Aopr 2009
		if self.getHumidity = NULL_HUMIDITY then
			return self.formatAuditText(propName, null);			// PAR #19538
		else
			return self.formatAuditText(propName, self.getHumidity.String);
		endif;
	elseif propName = CM_Container::getVentilation.name then  //cnwrs1 Par19451 Aopr 2009
		if self.getVentilation = NULL_VENTILATION then
			return self.formatAuditText(propName, null);			// PAR #19538
		else
			return self.formatAuditText(propName, self.getVentilation.String);
		endif;
	elseif propName = CM_Container::getCarbonDioxide.name then  //cnwrs1 Par19451 Aopr 2009
		if self.getCarbonDioxide = NULL_CARBON_DIOXIDE then
			return self.formatAuditText(propName, null);			// PAR #19538
		else
			return self.formatAuditText(propName, self.getCarbonDioxide.String);
		endif;
	elseif propName = CM_Container::getOxygen.name then 
		if self.getOxygen = NULL_OXYGEN then //cnwrs1 Par19451 Aopr 2009
			return self.formatAuditText(propName, null);			// PAR #19538
		else
			return self.formatAuditText(propName, self.getOxygen.String);
		endif;
		
	// TFS 46405 start
	elseif propName = CM_Container::doorsDirn.name then
		return self.formatAuditText("Flat Rack", app.flatRackEndsEnumToString(self.doorsDirn));
	// TFS 46405 end
	elseif propName = CM_Container::contentsStatus.name then		
		return self.formatAuditText(_property.name,self.getContentsStatusDesc(true));		
	else
		return inheritMethod(_property);
	endif;
	
epilog
	delete strArray;
end;</source>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAutoLoadPlanCommodityCode" id="c960fa38-6782-486d-abab-d60ed48079b0">
        <source>getAutoLoadPlanCommodityCode() : String;
// ---------------------------------------------------------------------------
// Created:		29 May 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------




// ANY CHANGES HERE MUST BE MIRRORED IN THE SAME METHOD ON CM_SLOTREQUEST




vars
	aISO : CM_ISOType;
begin
	if self.isSpecialStow()  or self.requiresPower then
		if self.myCommodityGroup &lt;&gt; null then // PAR 17746
			return self.myCommodityGroup.code; // PAR 16604
		endif;
	endif;

	aISO := self.getISOTypeObject();
	if aISO &lt;&gt; null then
		return aISO.getGeneralShortCode();
	endif;
	return null;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
