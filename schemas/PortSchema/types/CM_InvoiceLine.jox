    <JadeMethod name="getPreviousLinkedAmount" id="60149b51-a0a9-4262-90d6-ecaa7c355edd">
        <source>getPreviousLinkedAmount() : Real;
// ---------------------------------------------------------------------------
// Created:     11 June 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 23 Oct 2024		navlw1			JIRA-33107: Invoice Logging Use Levels
// 25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
// ---------------------------------------------------------------------------

vars
	calcType	: Integer;
	tran, prevTran : CM_TITransaction;
	bu : CM_Bank;
	daysAlreadyCharged	: Integer;
	chargedDaysWorking	: Boolean;
	startDateTime	: TimeStamp;
	endDateTime	: TimeStamp;
	invalid : Boolean;
	chargedDaysWorkingAndComp : Boolean;	//21 Sep 2017	NDL	TFS 7032
	canLogExtra	: Boolean;	//27.02.2025 navah1	#34141
begin
	tran := self.myTransactionTI;
	canLogExtra	:= app.canLogExtraDetail();				//27.02.2025 navah1	#34141
	if tran = null then
		return 0 ;
	endif;
	
	chargedDaysWorking := tran.getChargedDaysWorking();
	chargedDaysWorkingAndComp := tran.getChargedDaysWorkingAndComp();	//21 Sep 2017	NDL	TFS 7032
	calcType := self.invoiceLineDesc.getChargeByUnits;
	bu := self.bank;
	if canLogExtra then	//27.02.2025 navah1	#34141
		app.invLog(method.qualifiedName &amp; " calcType=" &amp; calcType.String, LogINFO.String);
	endif;
	prevTran := tran;
	while true do
		prevTran := prevTran.getStartTransaction();
		if prevTran = null then
			break;
		endif;
		// Jan 2011 handle invalid reference (in the crap data in dmast at least)
		on Exception do app.handleDeletedObject(exception, prevTran, invalid);
		endDateTime := prevTran.dateTime;
		if invalid then
			break;
		endif;
		on Exception do null;
		// 27229 Apr 2011 the days since ship start calculation type needs to use the ship exchange date here
		endDateTime := prevTran.dateTime;
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog(method.qualifiedName &amp; " prevTran=" &amp; prevTran.String &amp; " endDateTime=" &amp; endDateTime.String, LogTRACE.String);
		endif;
		if tran.isKindOf(CM_Storage) and
		   prevTran.isKindOf(CM_ReceiveShip) and
		   calcType = INV_CALC_TYPE_DAYSINCE_SHIP_ST then
			endDateTime := tran.CM_Storage.getCargoStartTime(calcType, endDateTime);
			if canLogExtra then	//27.02.2025 navah1	#34141
				app.invLog(method.qualifiedName &amp; " Storage from Rec Ship, endDateTime=" &amp; endDateTime.String, LogTRACE.String);
			endif;
		endif;
		
		if prevTran.isStorageWorkOrder() then // TFS 43405 JLGAB1
			startDateTime := prevTran.getStartDateTime(calcType); // TFS 43405 JLGAB1
			if canLogExtra then	//27.02.2025 navah1	#34141
				app.invLog(method.qualifiedName &amp; " PEL1 PREPAY startDateTime=" &amp; startDateTime.String, LogTRACE.String); // TFS 43405 JLGAB1
			endif;
			daysAlreadyCharged := daysAlreadyCharged + bu.evaluateDaysCalendar(startDateTime, endDateTime, chargedDaysWorking, chargedDaysWorkingAndComp, tran).Integer; // TFS 43405 JLGAB1
			if canLogExtra then	//27.02.2025 navah1	#34141
				app.invLog(method.qualifiedName &amp; " PEL1 PREPAY daysAlreadyCharged=" &amp; daysAlreadyCharged.String, LogTRACE.String); // TFS 43405 JLGAB1
			endif;
		else
			// 33923  if the first storage transaction use the dateTime from it as it already has any additional free days included
			if prevTran.noCharge and
			   prevTran.isKindOf(CM_Storage) and not prevTran.CM_Storage.startTransaction.isKindOf(CM_Storage) then
				startDateTime := prevTran.dateTime;
				if canLogExtra then	//27.02.2025 navah1	#34141
					app.invLog(method.qualifiedName &amp; " prevTran is no-charge Storage, startDateTime=" &amp; startDateTime.String, LogTRACE.String);
				endif;
			else
				startDateTime := prevTran.getStartDateTime(calcType);
				if canLogExtra then	//27.02.2025 navah1	#34141
					app.invLog(method.qualifiedName &amp; " startDateTime=" &amp; startDateTime.String, LogTRACE.String);
				endif;
			endif;
			// TFS 3588 only count storage days actually charged, otherwise this can get an incorrect quantity
			if prevTran.noCharge then
				if canLogExtra then	//27.02.2025 navah1	#34141
					app.invLog(method.qualifiedName &amp; " prevTran noCharge so not included in daysAlreadyCharged", LogTRACE.String);
				endif;
			else
				daysAlreadyCharged := daysAlreadyCharged + bu.evaluateDaysCalendar(startDateTime, endDateTime, chargedDaysWorking, chargedDaysWorkingAndComp, tran).Integer;
				if canLogExtra then	//27.02.2025 navah1	#34141
					app.invLog(method.qualifiedName &amp; " daysAlreadyCharged=" &amp; daysAlreadyCharged.String, LogTRACE.String);
				endif;
			endif;
		endif;
	endwhile;
	if canLogExtra then	//27.02.2025 navah1	#34141
		app.invLog(method.qualifiedName &amp; " returning daysAlreadyCharged=" &amp; daysAlreadyCharged.String, LogTRACE.String);
	endif;
	return daysAlreadyCharged;
epilog

end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getProformaPaymentType" id="9da4e9cc-95a1-4c6d-940d-dba8086b24d6">
        <source>getProformaPaymentType():Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 October 2018	jlgndl1	Initial creation	TFS 41281
09 Apr 2019	NDL	TFS 44231 - more new rules

*/

vars

	paymentType : Integer;
	service : CM_Service;
	paymentTypeMapping : CM_ServicePayTypeMapping;
	voyage : CM_Voyage;
	wo : CM_WorkOrder;
	terminal : CM_Terminal;
	berth : HMS_Berth;	//31 Oct 2018	NDL	TFS 41281
begin

	if self.myTransactionHMS &lt;&gt; null then
		voyage := self.myTransactionHMS.myVoyage;
		berth := self.myTransactionHMS.getBerthFromWOForPaymentType(); //31 Oct 2018	NDL	TFS 41281
	elseif self.myTransactionWO &lt;&gt; null then
		wo := self.myTransactionWO.getMyWorkOrder();
		berth := self.myTransactionWO.getBerthFromWOForPaymentType();
		if wo &lt;&gt; null then
			if wo.isVoyageWorkOrder() then
				voyage := self.myTransactionWO.getMyVoyageObject();
				berth := wo.getBerthForPaymentType(); //31 Oct 2018	NDL	TFS 41281
			endif;
		endif;
	endif;
	
	
	if berth &lt;&gt; null then	//31 Oct 2018	NDL	TFS 41281
		paymentType := berth.paymentType;
	elseif voyage &lt;&gt; null then
		paymentType := voyage.paymentType;
	endif;
	
	if paymentType = null or paymentType = PaymentType_None then	//09 Apr 2019	NDL	TFS 44231 - Try again if equals PaymentType_None
		if self.debtor &lt;&gt; null then
			terminal:= self.bank.terminal;
			paymentType := self.debtor.getDefaultPaymentType(terminal);
			if self.invoiceLineDesc &lt;&gt; null then
				service := self.invoiceLineDesc.services.first;
				if service &lt;&gt; null then
					paymentTypeMapping := self.invoiceLineDesc.bank.getServicePayTypeMapping( service, debtor, true ); // this debtor or otherwise the default debtor.
					if paymentTypeMapping &lt;&gt; null then
						paymentType := paymentTypeMapping.paymentType;
					endif;
				endif;
			endif;
		endif;
	endif;	
	
	return paymentType;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getQty1Qty2CARGO" id="fcfd8dcf-a839-4817-94eb-7c9b30ca3eeb">
        <source>getQty1Qty2CARGO(quantity1, quantity2 : Decimal output;	uom1, uom2 : String output);
/*
Purpose - 	
Who - NAVAB1
Date - 08JAN2024
ADO -  CR 58085 TASK 61342
*/


vars
	chargedDaysWorking	: Boolean;
	terminal	: CM_Terminal;
	storageConfig	: CM_StorageConfig;
	calcType : CM_CalculationType;
	titran	:CM_TITransaction;
	chargedDaysWorkingAndComp : Boolean;
	blockUnit : Integer;
	
	chargeByUnits : Integer;
begin
	chargeByUnits := self.invoiceLineDesc.getChargeByUnits();

	if self.myTransactionTI &lt;&gt; null then // if it has a TI it is not  a manual invoice line.
		titran := self.myTransactionTI;
		chargedDaysWorking := titran.getChargedDaysWorking();
		chargedDaysWorkingAndComp := titran.getChargedDaysWorkingAndComp();	//21 Sep 2017	NDL	TFS 7032
		
		if chargeByUnits = INV_CALC_TYPE_UNITY then
			quantity1 := 1.0;
			uom1 := "UNIT";
		elseif chargeByUnits = INV_CALC_TYPE_QUANTITY then
			quantity1 := self.trackedItemQuantity;
			uom1 := "QTY";
		elseif chargeByUnits = INV_CALC_TYPE_TRANSQUANTITY then
			if self.myResourceTypeUsage &lt;&gt; null then	//13 Jan 2010	NDL	CCMS MES 1006
				quantity1 := self.myResourceTypeUsage.quantity;
			else
				quantity1 := titran.getChargeQuantity();
			endif;
			uom1 := "QTY";
		elseif chargeByUnits = INV_CALC_TYPE_WEIGHT then
			quantity1 := self.trackedItemWeight;
			uom1 := "WEIGHT";
		elseif chargeByUnits = INV_CALC_TYPE_WEIGHT_TON then
			quantity1 := self.trackedItemWeight/1000;
			uom1 := "WEIGHT";
		elseif chargeByUnits = INV_CALC_TYPE_VOLUME then
			quantity1 := self.trackedItemVolume;
				
			if quantity1 = 0 then
				quantity1 := titran.getChargeVolume();
			endif;
			uom1 := "VOLUME";
		elseif chargeByUnits = INV_CALC_TYPE_REVENUE_TONS then

			quantity1 := self.myTransactionTI.getRTvalue();
			uom1 := "WEIGHT";
		// per-day calculation types - refactored for CCMS 1295 free storage days
		elseif chargeByUnits = INV_CALC_TYPE_DAYS_SINCE_RECVL or
			   chargeByUnits = INV_CALC_TYPE_DAYSINCE_SUBTERM or 	//28 Jun 2018	NDL	TFS 39338
			   chargeByUnits = INV_CALC_TYPE_DAYSINCE_REC_TEU or
			   chargeByUnits = INV_CALC_TYPE_DAYSINCE_REC_RT or	//08 May 2018	NDL	TFS 38525
			   chargeByUnits = INV_CALC_TYPE_DAYSINCE_SHIP_ST or
			   chargeByUnits = INV_CALC_TYPE_DAYSINCE_SHIP_EN or
			   chargeByUnits = INV_CALC_TYPE_DAYSINCE_VOY_IN or
			   chargeByUnits = INV_CALC_TYPE_DAYSINCE_VOY_OUT or
			   chargeByUnits = INV_CALC_TYPE_DAYS_WEIGHT or
			   chargeByUnits = INV_CALC_TYPE_DAYS_VOLUME or 
			   chargeByUnits = INV_CALC_TYPE_BOARDFEET_DAYS
			   then
			terminal := self.getTerminal();
			if terminal &lt;&gt; null then
				storageConfig := terminal.myStorageConfig;
			endif;

			quantity2 := self.getElapsedDays(chargeByUnits,  chargedDaysWorking, storageConfig, chargedDaysWorkingAndComp);
			uom2 := "DAYS";
			// now do the calculation-type specific processing
			if chargeByUnits = INV_CALC_TYPE_DAYSINCE_REC_TEU then
				quantity1 := titran.myTrackedItem.getNumTEU();
				uom1 := "TEU";
			elseif chargeByUnits = INV_CALC_TYPE_DAYSINCE_REC_RT then	
				quantity1 := self.myTransactionTI.getRTvalue;
				uom1 := "REVTONS";
			elseif chargeByUnits = INV_CALC_TYPE_DAYS_WEIGHT then
				quantity1 := self.trackedItemWeight;
				uom1 := "WEIGHT";
			elseif chargeByUnits = INV_CALC_TYPE_DAYS_VOLUME then
				quantity1 := self.trackedItemVolume;
				uom1 := "VOLUME";
			elseif chargeByUnits = INV_CALC_TYPE_BOARDFEET_DAYS then
				if titran.myTrackedItem &lt;&gt; null then
					quantity1 := titran.myTrackedItem.getBoardFeetAmount;				
					uom1 := "BRDFEET";
				endif;
			endif;
		elseif chargeByUnits = INV_CALC_TYPE_DAYS_ONSITE_AT then
			quantity2 := self.bank.evaluateDaysOnsiteAtCalendar(titran.getStartDateTime(chargeByUnits), self.myTransactionTI.dateTime, chargedDaysWorking, chargedDaysWorkingAndComp, self.myTransactionTI );
		elseif chargeByUnits = INV_CALC_TYPE_DAYS_CONNECTED then
			quantity2 := titran.getChargeQuantity();
			uom1 := "DAYS";
			
		elseif chargeByUnits = INV_CALC_TYPE_DISCREPANCYVALUE then
			quantity1 := self.myTransactionTI.getChargeQuantity();
			uom1 := "QTY";
			
		elseif chargeByUnits = INV_CALC_TYPE_DISCREPANCYABS then
			quantity1 := self.myTransactionTI.getChargeQuantity().abs;
			uom1 := "QTY";
		elseif chargeByUnits = INV_CALC_TYPE_WO_EXTRA then
			calcType := self.invoiceLineDesc.myCalculationType;
			if calcType &lt;&gt; null then
				blockUnit := calcType.theCalcTypeUnit;
			else
				blockUnit := INV_CALC_TYPE_UNITY; // value of 1
			endif;
			
			quantity1 := titran.getInvoiceQuantityForWOExtra(blockUnit);
			uom1 := "QTY";
			
		elseif chargeByUnits = INV_CALC_TYPE_BOARDFEET then
				if titran.myTrackedItem &lt;&gt; null then
					quantity1 := titran.myTrackedItem.getBoardFeetAmount;				
					uom1 := "BRDFEET";
				endif;	
		endif;
	endif;

end;</source>
        <Parameter name="quantity1" type="Decimal" usage="output"/>
        <Parameter name="quantity2" type="Decimal" usage="output"/>
        <Parameter name="uom1" type="String" usage="output"/>
        <Parameter name="uom2" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getQty1Qty2EVENT" id="07a20595-f0ac-404e-afbb-9cce38606d5b">
        <updating/>
        <source>getQty1Qty2EVENT(quantity1, quantity2 : Decimal output;	uom1, uom2 : String output) updating;
/*
Purpose - 	
Who - NAVAB1
Date - 08JAN2024
ADO -  CR 58085 TASK 61342
*/

vars
	theVoyage 		: CM_Voyage;
	theVessel 		: CM_Vessel;
	theHMSData 		: HMS_VesselData;
	theHMSVoyageData: HMS_VoyageData;
	
	theUnits 		: Integer;
	stTS, 
	endTS 			: TimeStamp;
	 
	diffTS 			: Real;
	tran 			: CM_EventTransaction;
	cmifHook		: CMIF_CalcTypeQuantityHook;
	valueOut 		: Real;
	blockUnit		: Integer;		
	diffDays		: Integer;
	
	theCalcType : CM_CalculationType;
begin
	tran := self.myTransactionEvent;
	
	if tran &lt;&gt; null then
		theCalcType := self.invoiceLineDesc.getCalcType();

		theVoyage := tran.getVoyage();
		
		theUnits := theCalcType.calculationType;
		if self.myResourceTypeUsage &lt;&gt; null then
			stTS := self.myResourceTypeUsage.fromDateTime;
			endTS := self.myResourceTypeUsage.toDateTime;
		else
			stTS := tran.getStartTS();
			endTS := tran.getEndTS();
		endif;
		
		diffTS := stTS.differenceInHoursReal(endTS);
		
		if isEventBlockUnit(theUnits) then
			blockUnit := theCalcType.theCalcTypeUnit;		
			if theVoyage &lt;&gt; null then
				theHMSVoyageData := theVoyage.myHMSVoyageData;				
			endif;
			
			if theHMSVoyageData &lt;&gt; null then
				quantity2 := self.quantityVoyageBlockUnits(blockUnit, theHMSVoyageData, theVoyage, null);
				if quantity2 = 0 then
					quantity2 := 1;
					uom2 := "UNIT";
				else
					uom2 := "UNIT";
					if blockUnit = INV_CALC_TYPE_UNITY then
						uom2 := "UNIT";
					elseif blockUnit = INV_CALC_TYPE_WO_UNITS then // TFS 39236
						uom2 := "UNIT";
					elseif blockUnit = INV_CALC_TYPE_RESOURCE_QTY then
						uom2 := "QTY";
					elseif blockUnit = INV_CALC_TYPE_UNIT_GRT then
						uom2 := "WEIGHT";
					elseif blockUnit = INV_CALC_TYPE_UNIT_NRT then
						uom2 := "WEIGHT";
					elseif blockUnit = INV_CALC_TYPE_UNIT_LENGTH then
						uom2 := "LENGTH";
					elseif blockUnit = INV_CALC_TYPE_UNIT_BEAM then
						uom2 := "LENGTH";
					elseif blockUnit = INV_CALC_TYPE_UNIT_DEADWEIGHT then
						uom2 := "WEIGHT";
					elseif blockUnit = INV_CALC_TYPE_UNIT_DRAFT_MID then
						uom2 := "LENGTH";
					else // DEFAULT
						uom2 := "WEIGHT";
					endif;
				endif;
			else 
				quantity2 := 1;
				uom2 := "UNIT";
			endif;
		endif;
		
		if theUnits = INV_CALC_TYPE_EVENT_UNIT then
			quantity1 := tran.getAmount(); 
			if quantity1 = 0 then
				if self.myResourceTypeUsage &lt;&gt; null then 
					quantity1 := self.myResourceTypeUsage.quantity; 
				else
					quantity1 := 1;
				endif;
			endif;
			uom1 := "UNIT";
		elseif theUnits = INV_CALC_TYPE_EVENT_TIME_DAYS then
			quantity1 :=  (diffTS / 24);
			uom1 := "DAYS";
	elseif theUnits = INV_CALC_TYPE_EVENT_DAYS_FULL then
			diffDays := stTS.differenceInHoursFullDay(endTS);
			quantity1 :=  diffDays;
			uom1 := "DAYS";
	elseif theUnits = INV_CALC_TYPE_EVENT_TIME_HOURS then 
			quantity1 := diffTS;
			uom1 := "HOURS";
		elseif theUnits = INV_CALC_TYPE_EVENT_TIME_MINUT then
			quantity1 := (diffTS * 60);
			uom1 := "MINS";
		elseif (theUnits = INV_CALC_TYPE_EVENT_LENGTH or theUnits = INV_CALC_TYPE_EVENT_GRT) then
			quantity1 := 1;
			uom1 := "UNIT";
			if theVoyage &lt;&gt; null then
				theVessel := theVoyage.getMyVessel();
				if theVessel &lt;&gt; null then
					theHMSData := theVessel.myHMSVesselData;
					if theHMSData &lt;&gt; null then
						if theUnits = INV_CALC_TYPE_EVENT_LENGTH then
							quantity1 := theHMSData.dim_LengthOverall;
							uom1 := "LENGTH";
						elseif theUnits = INV_CALC_TYPE_EVENT_GRT then
							quantity1 := theHMSData.dim_GrossRegTonnes;
							uom1 := "WEIGHT";
						endif;
					endif;
				endif;
			endif;
		endif;
		
		if theCalcType &lt;&gt; null and theCalcType.myHookCodeQuantity &lt;&gt; null then
			create cmifHook transient;
			cmifHook.myTransaction := tran;
			cmifHook.origQty := quantity1;
			
			valueOut := app.myHookAgent.runHookLinkReturn(HookType_InvoiceQuantity, theCalcType, theCalcType, cmifHook).Real;
	
			quantity1 := valueOut;
			uom1 := "QTY";

		endif;
	endif;

end;</source>
        <Parameter name="quantity1" type="Decimal" usage="output"/>
        <Parameter name="quantity2" type="Decimal" usage="output"/>
        <Parameter name="uom1" type="String" usage="output"/>
        <Parameter name="uom2" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getQty1Qty2WORKORDER" id="055cedf7-01a0-4d26-b4e4-fda59eb4cfea">
        <updating/>
        <source>getQty1Qty2WORKORDER(quantity1, quantity2 : Decimal output;	uom1, uom2 : String output) : Real updating;
/*
Purpose - 	
Who - NAVAB1
Date - 08JAN2024
ADO -  CR 58085 TASK 61342
*/

vars
	theVoyage : CM_Voyage;
	theHMSData : HMS_VoyageData;
	theUnits : Integer;
	stTS, endTS : TimeStamp;
	buValue, diffTS : Real;
	tran : CM_WOTransaction;
	lengthOfStay : Decimal[12,2];
	theWorkOrder : CM_WorkOrder;
	blockUnit : Integer;
	tiSet : CM_TISet;
	cmifHook	: CMIF_CalcTypeQuantityHook;
	valueOut : Real;	
	diffDays		: Integer;
	theCalcType : CM_CalculationType;
	
begin
	tran := self.myTransactionWO;
	theCalcType := self.invoiceLineDesc.getCalcType();
	theUnits := theCalcType.calculationType;
	
	if tran &lt;&gt; null then

		theWorkOrder := tran.getMyWorkOrder();
		if theWorkOrder = null then
			return 0;
		endif;
		
		if self.myResourceTypeUsage &lt;&gt; null then 
			stTS := self.myResourceTypeUsage.fromDateTime;
			endTS := self.myResourceTypeUsage.toDateTime;
		else
			stTS := tran.getStartTS();
			endTS := tran.getEndTS();
		endif;
		
		diffTS := stTS.differenceInHoursReal(endTS);

		lengthOfStay := theWorkOrder.getInvLengthOfStay();
		
		
		if theUnits = INV_CALC_TYPE_WO_UNITS then
			quantity1 := tran.getInvUnitsUsed(); 
			if quantity1 = 0 then
				quantity1 := 1;
			endif;
			uom1 := "UNIT";
		elseif theUnits = INV_CALC_TYPE_WO_CARGOREVTONS  
		or theUnits = INV_CALC_TYPE_WO_CARGOWEIGHT   
		or theUnits = INV_CALC_TYPE_WO_CARGOQUANTITY   
		or theUnits = INV_CALC_TYPE_WO_CARGOVOLUME then 
			quantity1 := theWorkOrder.getValueForCargoCalcType(theUnits);
			uom1	:= "UNIT";
			if theUnits = INV_CALC_TYPE_UNITY then
				uom1 := "UNIT";
			elseif theUnits = INV_CALC_TYPE_WO_CARGOQUANTITY then
				uom1 := "QTY";
			elseif theUnits = INV_CALC_TYPE_WO_CARGOWEIGHT then 
				uom1 := "WEIGHT";
			elseif theUnits = INV_CALC_TYPE_WO_CARGOVOLUME  then 
				uom1 := "VOLUME";
			elseif theUnits = INV_CALC_TYPE_WO_CARGOREVTONS then
				uom1 := "WEIGHT";
			endif;
		
		elseif theUnits = INV_CALC_TYPE_WO_PERMIT then
			// this calc type was designed for the CM_WOCargoRequest transaction
			// the calc type allows 5 rates to be maintained and the quantity will be a cargo quantity via the block unit on the calc type
			
			if theCalcType &lt;&gt; null then
				blockUnit := theCalcType.theCalcTypeUnit;
			else
				blockUnit := INV_CALC_TYPE_UNITY; // value of 1
			endif;
			
			quantity1 := theWorkOrder.getValueForCargoCalcType(blockUnit);  
			uom1 := "UNIT";
			
		elseif theUnits = INV_CALC_TYPE_WO_VALUEOF1 then
			quantity1 := 1;
			uom1 := "UNIT";
		elseif theUnits = INV_CALC_TYPE_WO_ETMAL_DAYS then
			quantity1 := lengthOfStay;
			uom1 := "DAYS";
		elseif theUnits = INV_CALC_TYPE_WO_ETMAL_HOURS then
			if lengthOfStay = 0 then
				return 0;
			endif;
			quantity1 := (lengthOfStay * 24);
			uom1 := "HOURS";
		
		elseif theUnits = INV_CALC_TYPE_WO_ETMAL_MINUTES then
			if lengthOfStay = 0 then
				return 0;
			endif;
			
			quantity1 := ((lengthOfStay * 24) * 60);
			uom1 := "MINS";
		elseif theUnits = INV_CALC_TYPE_WO_RES_UNIT then
			quantity1 := tran.getInvUnitsUsed();
			if quantity1 = 0 then
				if self.myResourceTypeUsage &lt;&gt; null then 
					quantity1 := self.myResourceTypeUsage.quantity; 
				else
					quantity1 := 1;
				endif;
			endif;
			uom1 := "UNIT";
		elseif theUnits = INV_CALC_TYPE_WO_TIME_DAYS then
			quantity1 :=  (diffTS / 24) ;
			uom1 := "DAYS";
		elseif theUnits = INV_CALC_TYPE_WO_DAYS_FULL then
			diffDays := stTS.differenceInHoursFullDay(endTS);
			quantity1 :=  diffDays ;
			uom1 := "DAYS";
		elseif theUnits = INV_CALC_TYPE_WO_TIME_HOURS then 
			quantity1 := diffTS ;
			uom1 := "HOURS";
		elseif theUnits = INV_CALC_TYPE_WO_TIME_MINUT then
			quantity1 := (diffTS * 60) ;
			uom1 := "MINS";
		elseif theUnits = INV_CALC_TYPE_WO_RES_WEIGHT then
			quantity1 := tran.myWorkOrderDetail.getTotalWeight();
			uom1 := "WEIGHT";
		elseif theUnits = INV_CALC_TYPE_WO_RES_VOLUME then
			tran.myWorkOrderDetail.getTotalVolume();
			uom1 := "VOLUME";
		elseif theUnits = INV_CALC_TYPE_WO_RES_QUANTITY then
			tran.myWorkOrderDetail.getTotalQuantity();
			uom1 := "QTY";
		elseif theUnits = INV_CALC_TYPE_WO_RES_QTYWGT then
			if self.myResourceTypeUsage &lt;&gt; null then 
				quantity1 := self.myResourceTypeUsage.quantity;
				uom1 := "QTY";
				quantity2 := tran.myWorkOrderDetail.getTotalWeight();
				uom2 := "WEIGHT";
			endif;
		elseif theUnits = INV_CALC_TYPE_WO_RES_QTYQTY then
			if self.myResourceTypeUsage &lt;&gt; null then 
				quantity1 := self.myResourceTypeUsage.quantity;
				uom1 := "QTY";
				quantity2 := tran.myWorkOrderDetail.getTotalQuantity;
				uom2 := "QTY";
			endif;
		elseif theUnits = INV_CALC_TYPE_WO_RES_QTYVOL then
			if self.myResourceTypeUsage &lt;&gt; null then 
				quantity1 := self.myResourceTypeUsage.quantity;
				uom1 := "QTY";
				quantity2 := tran.myWorkOrderDetail.getTotalVolume();
				uom2 := "VOLUME";
			endif;
		endif;
		
		if theUnits &lt;&gt; INV_CALC_TYPE_WO_PERMIT then
			theVoyage := tran.getMyVoyageObject();
			if theVoyage &lt;&gt; null then
				// the block unit for all WO calc types are vessel dimensions like GRT,  except INV_CALC_TYPE_WO_PERMIT which are cargo based.
				if theCalcType &lt;&gt; null then
					blockUnit := theCalcType.theCalcTypeUnit;
				else
					blockUnit := INV_CALC_TYPE_UNITY; // value of 1
				endif;
				
				theHMSData := theVoyage.myHMSVoyageData;
				if theHMSData &lt;&gt; null then
					quantity2 := self.quantityVoyageBlockUnits(blockUnit, theHMSData, theVoyage, null);
					uom2 := "UNIT";
				endif;
			endif;
		endif;
		
		if theCalcType &lt;&gt; null and theCalcType.myHookCodeQuantity &lt;&gt; null then
			create cmifHook transient;
			cmifHook.myTransaction := tran;
			cmifHook.origQty := quantity1;
			
			valueOut := app.myHookAgent.runHookLinkReturn(HookType_InvoiceQuantity, theCalcType, theCalcType, cmifHook).Real;
	
			quantity1 := valueOut;
		endif;
		
	endif;
	
	
	
epilog

	delete tiSet;

end;</source>
        <Parameter name="quantity1" type="Decimal" usage="output"/>
        <Parameter name="quantity2" type="Decimal" usage="output"/>
        <Parameter name="uom1" type="String" usage="output"/>
        <Parameter name="uom2" type="String" usage="output"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getRate" id="e0dcfd1a-b0ed-430d-963c-6495cffb5be0">
        <source>getRate() : Decimal;
/* ---------------------------------------------------------------------------
Created:     28 April 2010 by cnwrs2

Purpose:     
        
Change Date	Who		Reason
// SFW CCMS 1115 PAR23680   cnwsh3 - Invoice JRW Interface
//07 Jun 2016	cnwrs1	TFS2107 change rate/cost per unit from 12,6 to 16,6
------------------------------------------------------------------------------*/
vars
//	tmpRate	: Decimal[16,6];
	charge	: CM_Charge;
	tmpRate	: Decimal[23,6];	//11 May 2018	NDL	TFS 38528
begin
	/*if self.quantity &lt;&gt; 0 then												//navra1 - MTN-36618 - 14th Nov 2025
		tmpRate := (self.lineTotal / self.quantity).roundedTo(6);				//navra1 - MTN-36618 - 14th Nov 2025
	else*/																		//navra1 - MTN-36618 - 14th Nov 2025
		foreach charge in self.charges do
			tmpRate := tmpRate + charge.getRate();
		endforeach;
	//endif;																	//navra1 - MTN-36618 - 14th Nov 2025							
	return tmpRate;
epilog

end;</source>
        <ReturnType type="Decimal"/>
