    <JadeMethod name="getIniSettings" id="267d9399-da7c-4ce9-8048-5a3232e5d47d">
        <updating/>
        <source>getIniSettings() updating;

vars
	pcache  : Integer;
    tcache  : Integer;
    rtcache : Integer;
	string  : String;
begin

	if app.checkForCacheCoherency = true then
		l_iniValue1.caption := "True";
	else
		l_iniValue1.caption := "False";
	endif;

	getCacheOnServer(pcache, tcache, rtcache);
	l_iniOpt2.caption   := 'Server Cache';
	l_iniOpt3.caption   := '  Persistent';
	string := pcache.userNumberFormat($IntegerFormat).String;
	l_iniValue3.caption := string;
	string := tcache.userNumberFormat($IntegerFormat);
	l_iniOpt4.caption   := '  Transient';
	l_iniValue4.caption := string;

	getCacheOnClient(pcache, tcache, rtcache);
	l_iniOpt5.caption   := 'Client Cache';
	l_iniOpt6.caption   := '  Persistent';
	string := pcache.userNumberFormat($IntegerFormat).String;
	l_iniValue6.caption := string;
	string := tcache.userNumberFormat($IntegerFormat);
	l_iniOpt7.caption   := '  Transient';
	l_iniValue7.caption := string;

	l_iniOpt8.caption   := 'Production Mode';
	if app.productionMode = true then
		l_iniValue8.caption := 'On';
	else
		l_iniValue8.caption := 'Off';
	endif;
	
	l_iniOpt9.caption   :=  'Network Address';
	if node.networkAddress &lt;&gt; null then
		l_iniValue9.caption := node.networkAddress;
	else
		l_iniValue9.caption := 'JadeLocal';
	endif;

	l_iniOpt10.caption   := '';
	l_iniValue10.caption := '';

	l_iniOpt11.caption   := '';
	l_iniValue11.caption := '';

	l_iniOpt12.caption   := '';
	l_iniValue12.caption := '';

	l_iniOpt13.caption   := '';
	l_iniValue13.caption := '';
end;</source>
    </JadeMethod>
    <JadeMethod name="getJadeVersion" id="236d5ccf-ee4f-4546-9c05-3ea04d1c0faa">
        <updating/>
        <source>getJadeVersion() updating;

vars
	st    : String;
	token : String;
	index : Integer;
	start : Integer;
begin
	st    := app.getSystemVersion;
	index := st.pos('.', 1);
	if index &gt; 0 then
		v_tcpHandler.v_jadeMajorVersion := st[ 1 : index - 1].Integer;
		index.bump;
		start := index;
		index := st.pos('.', start);
		if index &gt; 0 then 
			v_tcpHandler.v_jadeMinorVersion := st[ start : index - start].Integer;
			index.bump;
			start := index;
			index := st.length - start;
			if index &gt; 0 then 
				v_tcpHandler.v_jadePatchVersion := st[ start : index + 1].Integer;
				index.bump;
				index := st.pos('.', start);
			endif;
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getMonitorStatistics" id="dd861e9d-6ce8-4372-aa71-1de5e7a2f1f9">
        <updating/>
        <source>getMonitorStatistics() updating;

vars
	committedTransactions : Integer; 
	abortedTransactions   : Integer;
	getObjects            : Integer; 
	queuedLocks           : Integer;
	createObjects         : Integer;
	deleteObjects         : Integer;
	updateObjects         : Integer;
	lockObjects           : Integer;
	unlockObjects         : Integer;
	beginNotifications    : Integer;
	endNotifications      : Integer;
	deliveredNotifications: Integer;
	serverExecutions      : Integer;
begin
	system.getStatistics(committedTransactions, abortedTransactions,
						 getObjects, queuedLocks, createObjects, deleteObjects,
						 updateObjects, lockObjects, unlockObjects,
						 beginNotifications, endNotifications,
						 deliveredNotifications, serverExecutions);
	tbx_CacheCon.text    := 
	                        'Gets'.padBlanks(15) &amp; Tab &amp;      (getObjects            - v_getObjects).userNumberFormat($IntegerFormat).padLeading(8) &amp; CrLf &amp;
                            'Created'.padBlanks(15) &amp; Tab &amp;   (createObjects         - v_createObjects).userNumberFormat($IntegerFormat).padLeading(8) &amp; CrLf &amp;
                            'Deleted'.padBlanks(15) &amp; Tab &amp;   (deleteObjects         - v_deleteObjects).userNumberFormat($IntegerFormat).padLeading(8) &amp; CrLf &amp;
                            'Locked'.padBlanks(15) &amp; Tab &amp;    (lockObjects           - v_lockObjects).userNumberFormat($IntegerFormat).padLeading(8) &amp; CrLf &amp;
                            'Unlocked'.padBlanks(15) &amp; Tab &amp;  (unlockObjects         - v_unlockObjects).userNumberFormat($IntegerFormat).padLeading(8) &amp; CrLf &amp;
                            'Updated'.padBlanks(15) &amp; Tab &amp;   (updateObjects         - v_updateObjects).userNumberFormat($IntegerFormat).padLeading(8) &amp; CrLf &amp;
                            'Queued'.padBlanks(15) &amp; Tab &amp;    (queuedLocks           - v_queuedLocks).userNumberFormat($IntegerFormat).padLeading(8) &amp; CrLf &amp;
	                        'Committed'.padBlanks(15) &amp; Tab &amp; (committedTransactions - v_committedTransactions).userNumberFormat($IntegerFormat).padLeading(8) &amp; CrLf &amp;
	                        'Aborted'.padBlanks(15) &amp; Tab &amp;   (abortedTransactions   - v_abortedTransactions).userNumberFormat($IntegerFormat).padLeading(8) &amp; CrLf &amp;
                            'Begin Notes'.padBlanks(15) &amp; Tab &amp; (beginNotifications  - v_beginNotifications).userNumberFormat($IntegerFormat).padLeading(8) &amp; CrLf &amp;
                            'End Notes'.padBlanks(15) &amp; Tab &amp; (endNotifications      - v_endNotifications).userNumberFormat($IntegerFormat).padLeading(8) &amp; CrLf &amp;
                            'Delivered'.padBlanks(15) &amp; Tab &amp; (deliveredNotifications- v_deliveredNotifications).userNumberFormat($IntegerFormat).padLeading(8) &amp; CrLf &amp;
                            'Server Execute'.padBlanks(15) &amp; Tab &amp; (serverExecutions - v_serverExecutions).userNumberFormat($IntegerFormat).padLeading(8);

	v_committedTransactions := committedTransactions; 
	v_abortedTransactions   := abortedTransactions;
	v_getObjects            := getObjects; 
	v_queuedLocks           := queuedLocks;
	v_createObjects         := createObjects;
	v_deleteObjects         := deleteObjects;
	v_updateObjects         := updateObjects;
	v_lockObjects           := lockObjects;
	v_unlockObjects         := unlockObjects;
	v_beginNotifications    := beginNotifications;
	v_endNotifications      := endNotifications;
	v_deliveredNotifications:= deliveredNotifications;
	v_serverExecutions      := serverExecutions;
end;</source>
    </JadeMethod>
    <JadeMethod name="handleDisplayRows" id="f128b883-2398-4f41-ae38-03a6a7285321">
        <updating/>
        <source>handleDisplayRows(sampleObject : SampleObjects io) : String updating;
vars

	classname    : String;
	lockType     : String;
begin
	if sampleObject.volatility = 8 then 
		lockType := ' s';
	elseif sampleObject.volatility = 4 then
		lockType := ' f';
	endif;
	classname := v_tcpHandler.getClassDescription(v_environment, sampleObject);
	return classname &amp; lockType &amp; Tab &amp; sampleObject.count.String &amp; Tab &amp; sampleObject.countIncrement.String;

end;</source>
        <Parameter name="sampleObject" type="SampleObjects" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleIncrementColumn" id="cc1089cf-15d4-41a1-9c6a-8d400f6f058e">
        <updating/>
        <source>handleIncrementColumn(_visible : Boolean) updating;

constants
	Colwidth : Integer = 36;
vars
	column      : JadeTableColumn;
	remainder   : Integer;
	scrollWidth : Integer;
begin

	scrollWidth := getSystemMetrics(Window.SM_cxVScroll) + 2;

	column         := tbl_Stats_Get.accessColumn(3);
	column.width   := Colwidth;
	column.visible := _visible;
	column         := tbl_Stats_Lock.accessColumn(3);
	column.width   := Colwidth;
	column.visible := _visible;
	column         := tbl_Stats_Unlock.accessColumn(3);
	column.width   := Colwidth;
	column.visible := _visible;
	column         := tbl_Stats_Note.accessColumn(3);
	column.width   := Colwidth;
	column.visible := _visible;
	column         := tbl_Stats_Update.accessColumn(3);
	column.width   := Colwidth;
	column.visible := _visible;
	column         := tbl_Stats_Create.accessColumn(3);
	column.width   := Colwidth;
	column.visible := _visible;
	column         := tbl_Stats_Delete.accessColumn(3);
	column.width   := Colwidth;
	column.visible := _visible;
	column         := tbl_Stats_QLock.accessColumn(3);
	column.width   := Colwidth;
	column.visible := _visible;
	column         := tbl_Stats_GetEdn.accessColumn(3);
	column.width   := Colwidth;
	column.visible := _visible;
	
	column         := tbl_Stats_Get.accessColumn(2);
	column.width   := Colwidth;
	column         := tbl_Stats_Lock.accessColumn(2);
	column.width   := Colwidth;
	column         := tbl_Stats_Unlock.accessColumn(2);
	column.width   := Colwidth;
	column         := tbl_Stats_Note.accessColumn(2);
	column.width   := Colwidth;
	column         := tbl_Stats_Update.accessColumn(2);
	column.width   := Colwidth;
	column         := tbl_Stats_Create.accessColumn(2);
	column.width   := Colwidth;
	column         := tbl_Stats_Delete.accessColumn(2);
	column.width   := Colwidth;
	column         := tbl_Stats_QLock.accessColumn(2);
	column.width   := Colwidth;
	column         := tbl_Stats_GetEdn.accessColumn(2);
	column.width   := Colwidth;
	//
	// Work out remainder by tables on the left, then middle and then right
	// This is because in Jade 6.0.18 the align all Vertical gives different size tables
	//
	// Left hand tables
	//
	if _visible = true then
		remainder := (tbl_Stats_Get.width - (Colwidth * 2) - scrollWidth).Integer;
	else
		remainder := (tbl_Stats_Get.width - Colwidth - scrollWidth).Integer;
	endif;
	column        := tbl_Stats_Get.accessColumn(1);
	column.width  := remainder;
	column        := tbl_Stats_Note.accessColumn(1);
	column.width  := remainder;
	column        := tbl_Stats_Create.accessColumn(1);
	column.width  := remainder;
	//
	// Middle tables
	//
	if _visible = true then
		remainder := (tbl_Stats_Lock.width - (Colwidth * 2) - scrollWidth).Integer;
	else
		remainder := (tbl_Stats_Lock.width - Colwidth - scrollWidth).Integer;
	endif;
	column        := tbl_Stats_Lock.accessColumn(1);
	column.width  := remainder;
	column        := tbl_Stats_Delete.accessColumn(1);
	column.width  := remainder;
	column        := tbl_Stats_QLock.accessColumn(1);
	column.width  := remainder;
	//
	// Right hand tables
	//
	if _visible = true then
		remainder := (tbl_Stats_Update.width - (Colwidth * 2) - scrollWidth).Integer;
	else
		remainder := (tbl_Stats_Update.width - Colwidth - scrollWidth).Integer;
	endif;
	column        := tbl_Stats_Update.accessColumn(1);
	column.width  := remainder;
	column        := tbl_Stats_Unlock.accessColumn(1);
	column.width  := remainder;
	column        := tbl_Stats_GetEdn.accessColumn(1);
	column.width  := remainder;
end;</source>
        <Parameter name="_visible" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="handleNodeExceptions" id="654c5ad1-58cb-46fa-b7a6-c6e200b3a567">
        <updating/>
        <source>handleNodeExceptions(x : Exception) : Integer updating;

vars
	time : Time;
begin

	sl_Status.caption := time.String &amp; ' Handling ' &amp; x.text &amp; ' (' &amp; x.errorCode.String &amp; ')';
	return Ex_Abort_Action;
	return Ex_Resume_Next;
end;</source>
        <Parameter name="x" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
