    <JadeMethod name="setForProxy" id="d1fe8bf5-b37d-4ef7-a6c7-1896ad43b249">
        <updating/>
        <source>setForProxy(_code, _description : String; _isFSC : Boolean; _notAvailableForEntry :Boolean; _sourceSubLocn: CM_SourceSubLocation) updating;
//--------------------------------------------------------------
//Created: 07 February 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	self.raiseExceptionIfNotTransient(method);
	self.mySourceSubLocation := _sourceSubLocn;
	self.setSuperClassDetailsForProxy(_code, _description,false, null);	
	
	self.isFSC := _isFSC;	//ccms jml 1105, par 21535 Nov 2009
	
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_isFSC" type="Boolean"/>
        <Parameter name="_notAvailableForEntry" type="Boolean"/>
        <Parameter name="_sourceSubLocn" type="CM_SourceSubLocation"/>
    </JadeMethod>
