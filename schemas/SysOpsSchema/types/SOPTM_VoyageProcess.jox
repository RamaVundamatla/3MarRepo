    <JadeMethod name="showThumbnail" id="318d3e42-b059-4566-99b9-f744ec36a7a9">
        <updating/>
        <source>showThumbnail( pObj : CM_VoyageProcess ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
10 May 2018			jlgndl1	Initial creation	TFS 38517
31 August 2022		jlizm1	TFS 54298 EUP - Simplified Voyage Work Order Process

*/

vars

	form : SOP_TableMaintForm;

begin

	form := self.myForm;
	form.tblInput1.clearValues();
	
	form.tblInput1.setValueByName(ETRow_Code, pObj.code);
	form.tblInput1.setValueByName(ETRow_Description, pObj.description);
	form.tblInput1.setValueByName(ETRow_EdiPrenoteFormat, pObj.ediPrenoteFormat);
	form.tblInput1.setValueByName(ETRow_ReportInvoiceEstimate, pObj.reportInvoiceEstimate);
	form.tblInput1.setValueByName(ETRow_ReportInvoicePreinvoice, pObj.reportInvoicePreinvoice);
	form.tblInput1.setValueByName(ETRow_ReportInvoiceTaxinvoice, pObj.reportInvoiceTaxinvoice);
	form.tblInput1.setValueByName(ETRow_WorkOrderReceivalReport, pObj.workOrderReceivalReport);	//11 Jun 2018	NDL	TFS 38795
	form.tblInput1.setValueByName(ETRow_WorkOrderReleaseReport, pObj.workOrderReleaseReport);	//11 Jun 2018	NDL	TFS 38795
	form.tblInput1.setValueByName(ETRow_ProcessHarbour, app.getErrorString( Dbl_Click_Edit_View ));
	form.tblInput1.setValueByName(ETRow_ProcessTerminal, app.getErrorString( Dbl_Click_Edit_View ));//11 Jun 2018	NDL	TFS 39140
	form.tblInput1.setValueByName(ETRow_AddReportsForm, app.getErrorString( Dbl_Click_Edit_View ));//08 Feb 2019	NDL	TFS 43240
	
	//12 Feb 2019	NDL	TFS 43240 - convert to combos...
	self.populateReportCmb(	form.cmbRepInvEst, "CM_InvoiceView", pObj.reportInvoiceEstimate );

	
	form.tblInput1.disableRowByName(ETRow_Code);
	 //jlier1 TFS 51963 12/10/21
	form.allowUpdate := app.getMyUser.canDo( null, PmAdmVoyageProcessMaint );
	form.tblInput1.showRowByName(ETRow_ReportInvoiceEstimate,false);
	if pObj.isDefaultProcessJMT then	
		form.tblInput1.disableRowByName(ETRow_Description);
		form.tblInput1.hideRowByName(ETRow_EdiPrenoteFormat,false);	
		form.tblInput1.hideRowByName(ETRow_ReportInvoicePreinvoice,false);
		form.tblInput1.hideRowByName(ETRow_ReportInvoiceTaxinvoice,false);
		form.tblInput1.hideRowByName(ETRow_WorkOrderReceivalReport,false);
		form.tblInput1.hideRowByName(ETRow_WorkOrderReleaseReport,false);
		form.tblInput1.hideRowByName(ETRow_ProcessHarbour,false);
		form.tblInput1.hideRowByName(ETRow_ProcessTerminal,false);//11 Jun 2018	NDL	TFS 39140
		form.tblInput1.hideRowByName(ETRow_AddReportsForm,false);//08 Feb 2019	NDL	TFS 43240
		
	elseif pObj.isEUPDefaultProcess then	// TFS 54298
		form.tblInput1.hideRowByName(ETRow_EdiPrenoteFormat,false);	
		form.tblInput1.hideRowByName(ETRow_ReportInvoicePreinvoice,false);
		form.tblInput1.hideRowByName(ETRow_ReportInvoiceTaxinvoice,false);
		form.tblInput1.hideRowByName(ETRow_WorkOrderReceivalReport,false);
		form.tblInput1.hideRowByName(ETRow_WorkOrderReleaseReport,false);
		form.tblInput1.showRowByName(ETRow_ProcessHarbour,false);
		form.tblInput1.showRowByName(ETRow_ProcessTerminal,false);
		form.tblInput1.hideRowByName(ETRow_AddReportsForm,false);
		
	// 25/06/2024 navkc1 CR64611 Task 64623
	elseif pObj.isAutomaticProcess() then
		form.tblInput1.hideRowByName(ETRow_EdiPrenoteFormat,false);	
		form.tblInput1.hideRowByName(ETRow_ReportInvoicePreinvoice,false);
		form.tblInput1.hideRowByName(ETRow_ReportInvoiceTaxinvoice,false);
		form.tblInput1.hideRowByName(ETRow_WorkOrderReceivalReport,false);
		form.tblInput1.hideRowByName(ETRow_WorkOrderReleaseReport,false);
		form.tblInput1.hideRowByName(ETRow_ProcessHarbour,false);
		form.tblInput1.hideRowByName(ETRow_ProcessTerminal,false);
		form.tblInput1.hideRowByName(ETRow_AddReportsForm,false);
		form.tblInput1.hideRowByName(ETRow_ReportInvoiceEstimate,false);
	else
		self.populateReportCmb(	form.cmbRepInvPre, "CM_InvoiceView", pObj.reportInvoicePreinvoice );
		self.populateReportCmb(	form.cmbRepInvTax, "CM_InvoiceView", pObj.reportInvoiceTaxinvoice );
		self.populateReportCmb(	form.cmbRepWoRec, "CM_TransactionView", pObj.workOrderReceivalReport );
		self.populateReportCmb(	form.cmbRepWoRel, "CM_TransactionView", pObj.workOrderReleaseReport );
	
		form.tblInput1.showRowByName(ETRow_EdiPrenoteFormat,false);
		form.tblInput1.showRowByName(ETRow_ReportInvoicePreinvoice,false);
		form.tblInput1.showRowByName(ETRow_ReportInvoiceTaxinvoice,false);
		form.tblInput1.showRowByName(ETRow_WorkOrderReceivalReport,false);
		form.tblInput1.showRowByName(ETRow_WorkOrderReleaseReport,false);
		form.tblInput1.showRowByName(ETRow_ProcessHarbour,false);
		form.tblInput1.showRowByName(ETRow_ProcessTerminal,false);//11 Jun 2018	NDL	TFS 39140
		form.tblInput1.showRowByName(ETRow_AddReportsForm,false);//08 Feb 2019	NDL	TFS 43240
		
	endif;
	
	if form.mode = form.Mode_Update then
		//can only edit the associated 'Process Harbour' objects when in view mode.
		form.tblInput1.hideRowByName(ETRow_ProcessHarbour,false);
		form.tblInput1.hideRowByName(ETRow_ProcessTerminal,false);//11 Jun 2018	NDL	TFS 39140
		form.tblInput1.hideRowByName(ETRow_AddReportsForm,false);//08 Feb 2019	NDL	TFS 43240
	endif;
	
epilog

end;</source>
        <Parameter name="pObj" type="CM_VoyageProcess"/>
    </JadeMethod>
</Class>
