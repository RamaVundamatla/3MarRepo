    <JadeMethod name="addToolbarControls" id="80105fe2-ef70-44a9-8730-20691b8ab339">
        <updating/>
        <source>addToolbarControls() updating, protected;
// -------------------------------------------
// Created 28 August 2003 by cnwdvb1
// -------------------------------------------
vars

	toolbar	: CMUI_Toolbar;
	
begin
	inheritMethod();

	toolbar := self.frmToolbar;
	
	toolbar.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnLocate, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnEnquiry, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnRemove, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
	
	toolbar.visible := true;

end;</source>
        <access>protected</access>
    </JadeMethod>
