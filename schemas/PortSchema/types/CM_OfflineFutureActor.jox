    <JadeMethod name="create" id="b0eb9928-9f02-4cd4-ade9-382c8a41f559">
        <updating/>
        <source>create() updating;
// defer setting myRoot to a background process

vars
	oai				: CM_OfflineFutureActorInserter;
	
begin
	// In order to prevent locks when creating CM_OfflineFutureActor instances,
	// they will always be inserted into the CM_Root collection by an automatically
	// generated CM_OfflineActor
	if not self.isTransient then
		create oai;
		oai.setMyOfflineFutureActor(self);
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doAction" id="19639416-5bbb-496e-b56f-d487cd7cf871">
        <updating/>
        <source>doAction() : Boolean updating;

/*

Purpose:			Perform the relevant action(s) for the receiver class


Return Value:		True if action was successful, false otherwise



*/

vars
	
begin
	// Return false here, so if a reimplementation is incomplete, then the 
	// OfflineFutureActor will not be deleted
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
