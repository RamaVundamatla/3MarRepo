    <JadeMethod name="colorRows" id="511c7238-5673-4d1c-82ff-1254db317f03">
        <source>colorRows() protected;
// ---------------------------------------------------------------------------
// Created:     16 March 2004	cnwth2
//
// ----------   ----------  --------------------------------------------------
// 01/11/2012	cnwcs5	par 30475 - minor tweaks
// 11/09/2015   cnwma1  PAR #36436 Received an Object NO Found Code 4 Error Repair Coordinators PC Jade app's
vars
	color1, color2, int, numRows,
	fixedRows	: Integer;
	row			: JadeTableRow;
	table		: CM_DataTable;
	ta			: CM_TerminalArea;
	invalidTA 	: Boolean;
	name        : String;
begin
	on Exception do app.handleDeletedObject(exception, ta, invalidTA);
	table 		:= self.tblData;
	fixedRows 	:= (table.fixedRows + 1);
	numRows 	:= table.rows;
	color1 		:= self.colorRow1;
	color2 		:= self.colorRow2;
	
	foreach int in fixedRows to numRows do
		row := table.accessRow (int);
		ta	:= row.itemObject.CM_TerminalArea;
		
		name := ta.id;							//11/09/2015 cnwma1 PAR #36436
		if invalidTA or ta = null then
			return;
		endif;
	
		if ta.isSuitableForLoadFrom then
			row.backColor := CM_TerminalArea.FLAG_LOAD_FROM_COLOR;
			
		elseif ta.isSuitableForLoadInto then
			row.backColor := CM_TerminalArea.FLAG_LOAD_INTO_COLOR;
			
		elseif int mod 2 = 0 then
			row.backColor := color1;
		else
			row.backColor := color2;
		endif;	
		//TFS#53231 NAVSP1 04APR2022
		if ta.isKindOf(CM_BlockStack) and ta.CM_BlockStack.isOverlapped and not ta.allRestrictionsLabour.isEmpty() then
			row.backColor := LightSkyBlue;
		// ccms 1471
		elseif ta.isKindOf(CM_BlockStack)and ta.CM_BlockStack.isOverlapped then
			row.backColor	:= Yellow;
			
		elseif not ta.allRestrictionsLabour.isEmpty() then	// ccms1573 -	cnwvu1
			row.backColor	:= LightRed;
		endif;
	endforeach;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="create" id="4d053eff-8be1-4741-a2ee-698ea7f1c90e">
        <updating/>
        <source>create() updating;
//-----------------------------------------------------------------------
//  Created by: cnwsh3
//
//	Date: 15 September 2003
//-----------------------------------------------------------------------
vars

begin
	self.permissionView  	:= PmTerminalAreaEnq;
	self.permissionMaint 	:= PmTerminalAreaEnqMaint; // TFS 2198
	self.helpFileName 		:= HelpFile_Yard;
end;</source>
    </JadeMethod>
    <JadeMethod name="deleteAllLabourRestriction" id="9d738237-d426-428b-a2cd-b36194d11c7c">
        <updating/>
        <source>deleteAllLabourRestriction()updating;
// ---------------------------------------------------------------------------
// Created:     02 June 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	table				: CM_DataTable;
	row 				: Integer;
	ta 					: CM_TerminalArea;
	passport			: CM_Passport;
	labourRestriction 	: CM_LabourRestriction;
	coll				: CM_LCArray;
	theResult : Integer;	//15 Jan 2020 NDL	TFS 46815
	
begin
	table	:= self.tblData;
	row 	:= table.row;
	
	if row &lt;= table.fixedRows then
		return;
	endif;

	ta := table.accessRow(row).itemObject.CM_TerminalArea;
	
	if ta = null then
		return;
	endif;

	if ta.allRestrictionsLabour.isEmpty then 
		app.msgBox('There are no Labour Resrtictions associated with this Terminal Area', 
						'No Labour Restrictions to Delete', MsgBox_OK_Only);
		return;
	endif;
	
	if app.msgBox(app.getErrorString2(ConfirmDelete, 'ALL ' &amp; app.getErrorString(CM_Labour_Restriction).trimBlanks &amp; 's',' for Teminal Area ' &amp; ta.id), 'DELETE ALL Labour Restrictions',
						MsgBox_Yes_No + MsgBox_Exclamation_Mark_Icon) = MsgBox_Return_No then
		return;
	endif;
	
	passport := app.myPassport;
										
	foreach labourRestriction in ta.allRestrictionsLabour discreteLock do 
		
		//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			app.myTrxDA.trxDeleteRestrictionLabour(labourRestriction, passport);
		
			if app.myPassport.trxCompletedOK then
				break;
			else
				theResult := app.showErrorWarningDialog(app.getErrorString(CM_Labour_Restriction), passport, ErrWarnMode_Update);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			break;
			
		endwhile;
		
	endforeach;
	
	app.checkLabourRestrictionHook(ta, coll); // PAR 21639 cnwgb1 28.4.2010

end;</source>
    </JadeMethod>
    <JadeMethod name="deleteLabourRestriction" id="5f2f35cf-6f73-487f-a33f-ac1c4b42d495">
        <updating/>
        <source>deleteLabourRestriction(_labourRestriction : CM_LabourRestriction)updating;
// ---------------------------------------------------------------------------
// Created:     25 May 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	coll		: CM_LCArray;
	ta 			: CM_TerminalArea;	
	passport	: CM_Passport;
	theResult : Integer;	//15 Jan 2020 NDL	TFS 46815
	
begin
	ta	:= _labourRestriction.myTerminalArea;
	
	if app.msgBox(app.getErrorString2(ConfirmDelete, app.getErrorString(CM_Labour_Restriction), _labourRestriction.id), 'Confirm Delete',
						MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
		return;
	endif;

	passport := app.myPassport;
	
	//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxDA.trxDeleteRestrictionLabour(_labourRestriction, passport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog(app.getErrorString(CM_Labour_Restriction), passport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return;
		
	endwhile;	
	
	app.checkLabourRestrictionHook(ta, coll); // PAR 21639 cnwgb1 28.4.2010

end;</source>
        <Parameter name="_labourRestriction" type="CM_LabourRestriction"/>
    </JadeMethod>
    <JadeMethod name="displaySelectorResults" id="07bd236c-b8b7-43a6-af3c-8f2c0e5cd749">
        <updating/>
        <source>displaySelectorResults(_resultCollection: Collection; _mode: Integer) updating;
// -------------------------------------------
// Created 18 February 2004 by cnwdvb1
// -------------------------------------------
vars

	iter		: Iterator;
	ti			: CM_TrackedItem;
	dyna		: DynaDictionary;
	area		: CM_TerminalArea;
	

begin

	if not _resultCollection.size &gt; 0 then
		return;
	endif;
	dyna := self.tblData.myDynaDict;
	dyna.clear();
	iter := _resultCollection.createIterator();
	while iter.next(ti) do
		if ti.myPrimaryActualLocation &lt;&gt; null then
			area := ti.myPrimaryActualLocation.myTerminalArea;
			if not dyna.includes(area) then
				dyna.add(area);
			endif;
		endif;
	endwhile;
	self.displayTerminalAreas();

epilog
	delete iter;
end;</source>
        <Parameter name="_resultCollection" type="Collection"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="displayTerminalAreas" id="3dc413a1-9572-4dcc-8e8f-1f5f6dd23e29">
        <source>displayTerminalAreas() protected;
//-----------------------------------------
// Created: 17 November 2003 By: cnwgd1
//-----------------------------------------
// 01/11/2012	cnwcs5	par 30475
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars

	obj			: Object;
	ta			: CM_TerminalArea;
	dict		: DynaDictionary;
	table		: CM_DataTable;
	colLR, colLRWidth, colYA, colYAWidth,
	row			: Integer;

begin

	dict 	:= self.tblData.myDynaDict;
	table 	:= self.tblData;
	
	if table.disallowColumnSorter then
		table.clearSort();
	endif;
	
	table.rows := table.fixedRows;
	
	colLR := table.getColumnByRowName(ETRow_LabourRestrictions);
	
	if colLR &lt;&gt; 0 then
		colLRWidth := table.accessColumn(colLR).width;
	endif;
	
	colYA := table.getColumnByRowName(ETRow_YardAllocations);
	
	if colYA &lt;&gt; 0 then
		colYAWidth := table.accessColumn(colYA).width;
	endif;
	
	foreach obj in dict do
		ta := obj.CM_TerminalArea;
		
		row := table.addItemObject(ta, ta.getAttributeStringForDefArray(table.allTblDataEntRows));
		
		self.setRowHeight (table, row, colLR, colLRWidth, colYA, colYAWidth);	// par 30475 Nov 2012
	endforeach;

	self.colorRows();

	if row &gt; table.fixedRows then
		table.selectTheCurrentRow(table.fixedRows + 1);
		// DVB force the row to be 2 as well so column change method works.
		table.row := table.fixedRows + 1;
		
		table.setFocus();
		self.doRowColumnChange(table);
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
