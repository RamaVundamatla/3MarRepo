    <JadeMethod name="btnCancel_click" id="e454b80a-388a-45f7-91c6-82de6a133836">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCancel_click(btn: Button input) updating;

/*

Purpose:		

Date			Who		Reason
14 February 2014	cnwmh5	Initial creation

*/

vars

begin

	self.wasCancelled := true;
	self.unloadForm();

epilog

end;</source>
