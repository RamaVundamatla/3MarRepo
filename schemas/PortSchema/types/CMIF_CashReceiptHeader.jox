    <JadeMethod name="updateTotalsFromDetails" id="db5e17a5-cb48-4caa-b027-375214d85839">
        <updating/>
        <source>updateTotalsFromDetails() updating;
/*

Date		Who		Reason
17 August 2015	cnwer1	Initial creation PAR 36778
28/11/2019	jlgsl4	TFS 47529 - JMT - Decimal Values on CM_CashReceipt, CM_CashPayment, CM_CashInvoiceProformaAgent
*/

vars
	cmifDetailReport : CMIF_CashReceiptReporting;
	cmifDetail : CMIF_CashReceiptDetail;
	allTaxCodes 	: ObjectArray;
	taxCode		: CM_TaxCode;
	taxRate		: CM_TaxRate;
	count 		: Integer;
	obj	 		: Object;
	effectiveTS : TimeStamp;
	voyage :  CM_Voyage;
	hookExempt : Boolean;
begin
	foreach cmifDetailReport in self.allDetails do
		cmifDetail:=cmifDetailReport.CMIF_CashReceiptDetail;
		
		self.total:=self.total + cmifDetail.lineValue;
	endforeach;
	
	effectiveTS.setDate(self.effectiveDate);
	if self.myDebtor &lt;&gt; null and
	   not self.myDebtor.isZeroRatedTax then
		create allTaxCodes transient;
		self.myTerminal.getAllCashTaxCodes(allTaxCodes);
		foreach obj in allTaxCodes do
			count := count + 1;
			taxCode := obj.CM_TaxCode;
			taxRate := taxCode.getTimeRate(effectiveTS);
			if count = 1 then
				self.tax1Value :=((self.total * taxRate.rate) / 100);//.roundedTo(2); // TFS 47529
			elseif count = 2 then
				self.tax2Value :=((self.total * taxRate.rate) / 100);//.roundedTo(2); // TFS 47529
			elseif count = 3 then
				self.tax3Value :=((self.total * taxRate.rate) / 100);//.roundedTo(2); // TFS 47529
			endif;
		endforeach;	
		
		// TFS 37562 exempt by voyage
		voyage := self.myVoyage;
		if voyage &lt;&gt; null then
			hookExempt := app.myRoot.getVoyageTaxExempt( voyage.myTerminal, voyage ).Boolean;
			if hookExempt then
				self.tax1Value := 0;
				self.tax2Value := 0;
				self.tax3Value := 0;
			endif;
		endif;
	endif;

epilog
	delete allTaxCodes;
end;</source>
    </JadeMethod>
</Class>
