    <JadeMethod name="notifiedIncludesSubCargoType" id="2c29bf30-c168-465b-804a-748f28805f1b">
        <source>notifiedIncludesSubCargoType( _subCargoType : CM_Product ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 July 2018	jlgndl1	Initial creation	TFS 37882

*/

vars

