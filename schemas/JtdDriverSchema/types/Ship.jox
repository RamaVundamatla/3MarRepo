    <JadeMethod name="startup2" id="d90998aa-d533-426c-8667-403cb2aec410">
        <updating/>
        <source>startup2() updating;

begin
	assert(app.profileName = "VoyagePlanner" or app.profileName = "VoyageWorker", self);
	create myMoveController transient;
	millisecondsForPickupSetDown:=3000;
	zAllocateRTGCrane;
	zAllocateIMV;
	numberOfPortainerCranes:=2;
	numberOfLoadContainers:=200;
// vw001_doNextStep assumes there are two workers per voyage, and their app.sequenceId's are consecutive
//	voyageCode:='PTN0040';  // workers start with the voyage AFTER this one
end;
</source>
    </JadeMethod>
