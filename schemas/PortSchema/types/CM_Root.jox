	// TFS 54298 End - EUP voyage status email templates
	
	//03/07/2024	navkc1 CR 65032 Task 65033
	self.setupVoyStatusEmailDefault(	PINEmail_AutoVoyPending,				// ie 411
										app.voyageStatusEnumToString(Voyage_Status_Pending_Auto, false),
										PINEmail_Object_Voyage, sa);
										
	self.setupVoyStatusEmailDefault(	PINEmail_AutoVoyArrived ,				// ie 412
										app.voyageStatusEnumToString(Voyage_Status_Arrived_Auto, false),
										PINEmail_Object_Voyage, sa);
										
	self.setupVoyStatusEmailDefault(	PINEmail_AutoVoyLoading ,				// ie 413
										app.voyageStatusEnumToString(Voyage_Status_AutoOn_Auto, false),
										PINEmail_Object_Voyage, sa);
	
	self.setupVoyStatusEmailDefault(	PINEmail_AutoVoyLoadComplete ,				// ie 414
										app.voyageStatusEnumToString(Voyage_Status_Autoff_Auto, false),
										PINEmail_Object_Voyage, sa);
	
	self.setupVoyStatusEmailDefault(	PINEmail_AutoVoyClosed ,				// ie 415
										app.voyageStatusEnumToString(Voyage_Status_Closed_Auto, false),
										PINEmail_Object_Voyage, sa);
	
	self.setupVoyStatusEmailDefault(	PINEmail_AutoVoyDeparted ,				// ie 416
										app.voyageStatusEnumToString(Voyage_Status_Depart_Auto, false),
										PINEmail_Object_Voyage, sa);
	
	self.setupVoyStatusEmailDefault(	PINEmail_AutoVoyCancelled ,				// ie 417
										app.voyageStatusEnumToString(Voyage_Status_Cancel_Auto, false),
										PINEmail_Object_Voyage, sa);
	
	self.setupVoyStatusEmailDefault(	PINEmail_AutoVoyArchived ,				// ie 418
										app.voyageStatusEnumToString(Voyage_Status_Archive_Auto, false),
										PINEmail_Object_Voyage, sa);
										
	//03/07/2024	navkc1 CR 65032 Task 65033
epilog
	delete sa;
end;</source>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="b398321a-3347-4de6-ae63-a84bf35f4a8e">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/// ---------------------------------------------------------------------------
// Created:     05 April 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if _property.name = 'extraInfo' then
		return false;
	endif;

	return inheritMethod(_rootClass, _property);
end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="shouldPushObject" id="c96ce838-6254-4ea6-b663-74e93ce6f471">
        <source>shouldPushObject( _obj : CM_Object ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
03 July 2020	jlgndl1	Initial creation	TFS 49590
12 Oct  2022	navcs2	ChangeRequest 54621: PNL - Event Stream Sending Though Old Records
*/

vars

	keyObject : CM_Object;
	keyType : Integer;
	esEventType : CM_EventStreamEventType;
	iter : Iterator;
	nextEsEventType : CM_EventStreamEventType;
	
begin

	if _obj = null then
		return false;
	endif;

	_obj.getEventStreamEventTypeKeys( keyObject, keyType );
	
	esEventType := app.myRoot.allEventStreamEventTypes.getAtKey( keyObject, keyType );
	if esEventType = null then
		//We don't have any Event Stream Event Types that want objects of this kind,
		//so don't bother pushing it out.
		return false;
	endif;
	if esEventType.myEventStreamDefinition.isActive then
		//found a match and its active, push it.
		return _obj.shouldPushObject(_obj); // 12 Oct 2022	navcs2	ChangeRequest 54621
	else
		iter := app.myRoot.allEventStreamEventTypes.createIterator;
		iter.startAtObject( esEventType );
		while iter.next( nextEsEventType ) do
			if nextEsEventType.myObject &lt;&gt; keyObject then
				//no more with matching object, bail
				break;
			endif;
			if nextEsEventType.type &lt;&gt; keyType then
				//no more with matching key, bail
				break;
			endif;
			if nextEsEventType.myEventStreamDefinition.isActive then
				//found another match and this one is active, push it.
				return true;
			endif;
		endwhile;
	endif;
	
	//no matches that are active
	return false;

epilog

delete iter;

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="startJadeProfiler" id="8fec87a4-c8eb-42be-b63d-08ae17257e4b">
        <source>startJadeProfiler(_profiler 		: JadeProfiler io ;
				  _fileName	 		: String;
				  _methodCount  	: Integer;
				  _reportTotalTime  : Boolean;
				  _subFolder   		: String;
				  _startTime		: Decimal io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 April 2025		navma1	Initial creation
*/
vars
	folder		: String;
	
begin
	_startTime					:= null;
	folder 						:= global.getJadeInstallDirServer().replace( CN_C_BIN, CN_C_MISC );
	_profiler   		    	:= process.profiler;	
	_profiler.methodCount   	:= _methodCount;
	_profiler.reportTotalTime	:= true;
	_startTime 					:= app.relativeMachineTime;
	
	_profiler.fileName 	        := folder
								&amp; "\"
								&amp; _subFolder 
								&amp; '\'  
								&amp; " - " 
								&amp; _fileName 
								&amp; " - " 
								&amp; app.getMyUserCode;
								
	
	_profiler.clearMethodCache();
	_profiler.start;
epilog

end;</source>
        <Parameter name="_profiler" type="JadeProfiler" usage="io"/>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_methodCount" type="Integer"/>
        <Parameter name="_reportTotalTime" type="Boolean"/>
        <Parameter name="_subFolder" type="String"/>
        <Parameter name="_startTime" type="Decimal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="stopJadeProfiler" id="ba40ad91-bb50-484b-816d-13faed1f76e2">
        <source>stopJadeProfiler(_profiler 	: JadeProfiler io;
				_startTime	: Decimal );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 April 2025		navma1	Initial creation

*/

vars
	endTime 		,
	totalTime		: Decimal[19]; 
begin
	
	if _profiler &lt;&gt; null then
		_profiler.stop;
		
		endTime 	  	    := app.relativeMachineTime;
		totalTime    		:= endTime - _startTime;
		
		_profiler.fileName  :=  _profiler.fileName 		&amp; 
								' - ' 					&amp; 
								totalTime.String      &amp; 
								' - ' 					&amp;
								_startTime.String &amp;'.txt';
		
		//if totalTime &gt; 2000 then
			_profiler.report;
		//endif;
	endif;
epilog

end;</source>
        <Parameter name="_profiler" type="JadeProfiler" usage="io"/>
        <Parameter name="_startTime" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="stopQueryPropertyAdd" id="d22e6f8a-730b-4c70-9938-1e1f2919d8aa">
        <source>stopQueryPropertyAdd(_stopTable: CM_StopsTable; _passport: CM_Passport);
//----------------------------------------------------------------
//	Created:	08 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 04/03/2010 	cnwcs5	par 22768 
vars

	cargoBol	: CM_CargoBOLType;
	qDef		: CM_QueryDefinition;
	qProp		: CM_QueryProperty;
	strKey		: String;
	stopsProp	: CM_QBooleanStopsProperty;
	tmpStr		: String;
	strArray	: StringArray;
	
	includeDA : Boolean;
	stopsDAProp : CM_QBooleanDocActionStop;

begin

	includeDA := app.myRoot.getConfig(IncludeDocActions).Boolean;	//29 Nov 2016	NDL	TFS 3021 / 2419
	
	strKey := 'stop- ' &amp; _stopTable.id.String;
		
	foreach qDef in self.allQueryDefinitionObjects do
		// par 22768 03/04/2010 CNWCS5 we only want to create for tracked item and BOL
		if qDef.type &lt;&gt; CM_QueryDefinition.TrackedItem_Query_Type and
			qDef.type &lt;&gt; CM_QueryDefinition.BOL_Query_Type then
			continue;
		endif;
		// par 22768 - end
	
		//15 Dec 2009	NDL	- Don't want these for Booking refs, Booking Ref Items or Snapshot queries.
//		if qDef.type = CM_QueryDefinition.BookRef_Query_Type or qDef.type = CM_QueryDefinition.Snapshot_Query_Type then
//			continue;
//		endif;
		
		qProp := qDef.allQueryProperties[strKey];
		
		tmpStr := _stopTable.heading;
		if tmpStr.length &gt;= 24 then
			tmpStr := _stopTable.heading[1:21] &amp; '...';
		endif;
		
		if qProp = null then
			create stopsProp persistent;
			//set key before adding to collection
			stopsProp.set('Stop- ' &amp; tmpStr, 'stop- ' &amp; _stopTable.id.String, qDef.className);
			stopsProp.stopId := _stopTable.id;
			stopsProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'	
			qDef.allQueryProperties.add(stopsProp);	
		else
			//update it
			stopsProp := qProp.CM_QBooleanStopsProperty;
			stopsProp.set('Stop- ' &amp; tmpStr, 'stop- ' &amp; _stopTable.id.String, qDef.className);
			stopsProp.stopId := _stopTable.id;
			stopsProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'	
		endif;
		
		strArray := null;
		if qDef.mode = 0 then
			if self.myQueryMenuRoot &lt;&gt; null then
				strArray := self.myQueryMenuRoot.allColumns;
			endif;
		else
			cargoBol := self.allCargoTypesById[qDef.mode];
			if cargoBol &lt;&gt; null then
				strArray := cargoBol.allSelectorColumns;
			endif;
		endif;
		
		if strArray &lt;&gt; null
		and (not strArray.includes(stopsProp.propertyName)) then 		
			strArray.add(stopsProp.propertyName);
		endif;
					
	endforeach;
	
	//29 Nov 2016	NDL	TFS 3021 / 2419
	if includeDA then
		strKey := CM_QBooleanDocActionStop.PREFIX_PROPERTY_NAME &amp; _stopTable.id.String;
		foreach qDef in self.allQueryDefinitionObjects do
			if qDef.type &lt;&gt; CM_QueryDefinition.TrackedItem_Query_Type then
				continue;
			endif;
			qProp := qDef.allQueryProperties[strKey];
			if qProp &lt;&gt; null and qProp.isKindOf(CM_QBooleanDocActionStop) then
				stopsDAProp := qProp.CM_QBooleanDocActionStop;
			endif;
			if stopsDAProp = null then
				create stopsDAProp persistent;
			endif;
			stopsDAProp.setup(_stopTable, qDef.className);
			
			qDef.allQueryProperties.add(stopsDAProp);
			break;
		endforeach;
	endif;

	if self.myQueryMenuRoot &lt;&gt; null then
		self.myQueryMenuRoot.causeEvent(SelectorProperty_Create_Event, false, strKey); 
	endif;


end;</source>
        <Parameter name="_stopTable" type="CM_StopsTable"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="stopQueryPropertyRemove" id="75f98ed2-2261-405f-b78b-7b5309f6bbf5">
        <source>stopQueryPropertyRemove(_stopTable: CM_StopsTable; _passport: CM_Passport);
//----------------------------------------------------------------
//	Created:	08 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	strKey		: String;
begin

	strKey := 'stop- ' &amp; _stopTable.id.String;
	self.doRemoveQueryProperty(strKey);	
	
	//29 Nov 2016	NDL	TFS 3021 / 2419
	strKey := CM_QBooleanDocActionStop.PREFIX_PROPERTY_NAME &amp; _stopTable.id.String;
	self.doRemoveQueryProperty(strKey);	
	
end;</source>
        <Parameter name="_stopTable" type="CM_StopsTable"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="todoTaskQueryPropertyAdd" id="03ce987b-5058-41df-8357-6e39e1fe313e">
        <source>todoTaskQueryPropertyAdd(_todoTaskDesc: CM_ToDoTaskDesc; _passport: CM_Passport);
//----------------------------------------------------------------
//	Created:	08 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 03/04/2010 	cnwcs5	par 22768
// 10/11/2011	cnwcs5	par 28574 - handle new classes CM_QBooleanToDoTaskCompletedPro/CM_QDateToDoTaskCompletedProp
// 02/02/2022   navma1	Defect 56387: MTN - Selector - To Do Tasks no longer available for selection to search by
vars

	cargoBol	: CM_CargoBOLType;
	qDef		: CM_QueryDefinition;
	qProp		: CM_QueryProperty;
	strKey, 
	strKeyDone, 
	strKeyDate,
	strClassName: String;
	tasksProp	: CM_QBooleanToDoTaskProperty;
	doneProp	: CM_QBooleanToDoTaskCompletePro;
	dateProp	: CM_QDateToDoTaskCompletedProp;
	strArray	: StringArray;
	strKeyDA 	: String;					//29 Nov 2016	NDL	TFS 3021 / 2419
	includeDA 	: Boolean;					//29 Nov 2016	NDL	TFS 3021 / 2419
	daToDoProp	: CM_QBooleanDocActionToDo;	//29 Nov 2016	NDL	TFS 3021 / 2419
	
begin
	
	if _todoTaskDesc.type &lt;&gt; TODO_TYPE_GROUP_TI then				// 02.02.2022 navma1 #56387
		return;
	endif;
	
	includeDA := app.myRoot.getConfig(IncludeDocActions).Boolean;	//29 Nov 2016	NDL	TFS 3021 / 2419
	
	strKey 		:= CM_QBooleanToDoTaskProperty.PREFIX_PROPERTY_NAME 	&amp; _todoTaskDesc.code.String;
	strKeyDone	:= CM_QBooleanToDoTaskCompletePro.PREFIX_PROPERTY_NAME  &amp; _todoTaskDesc.code.String;
	strKeyDate 	:= CM_QDateToDoTaskCompletedProp.PREFIX_PROPERTY_NAME   &amp; _todoTaskDesc.code.String;
	strKeyDA 	:= CM_QBooleanDocActionToDo.PREFIX_PROPERTY_NAME 		&amp; _todoTaskDesc.code.String;
	
	foreach qDef in self.allQueryDefinitionObjects do
		// par 22768 03/04/2010 CNWCS5 we only want to create for tracked item
		if qDef.type &lt;&gt; CM_QueryDefinition.TrackedItem_Query_Type then
			continue;
		endif;

		strArray := null;
		
		if qDef.mode = 0 then
			if self.myQueryMenuRoot &lt;&gt; null then
				strArray := self.myQueryMenuRoot.allColumns;
			endif;
		else
			cargoBol := self.allCargoTypesById[qDef.mode];
			
			if cargoBol &lt;&gt; null then
				strArray := cargoBol.allSelectorColumns;
			endif;
		endif;
		
		strClassName	:= qDef.className;
		
		// first do 'has todo task' (CM_QBooleanToDoTaskProperty)
		qProp := qDef.allQueryProperties[strKey];
		
		if qProp = null then
			create tasksProp persistent;
			
			tasksProp.setup (_todoTaskDesc, strClassName);
			
			qDef.allQueryProperties.add(tasksProp);	
			
			if strArray &lt;&gt; null and not strArray.includes(tasksProp.propertyName) then 		
				strArray.add(tasksProp.propertyName);
			endif;
			
		elseif qProp.isKindOf (CM_QBooleanToDoTaskProperty) then
			// we don't expect this to happen but should at least handle it 
			qProp.CM_QBooleanToDoTaskProperty.setup (_todoTaskDesc, strClassName);
		else
			// it is not what we are looking for so ignore it.
		endif;		
		
		// now do 'todo task complete' (CM_QDateToDoTaskCompletedProp)
		qProp := qDef.allQueryProperties[strKeyDate];
		
		if qProp = null then
			create dateProp persistent;
			
			dateProp.setup (_todoTaskDesc, strClassName);
			
			qDef.allQueryProperties.add(dateProp);	
			
			if strArray &lt;&gt; null and not strArray.includes(dateProp.propertyName) then 		
				strArray.add(dateProp.propertyName);
			endif;
			
		elseif qProp.isKindOf (CM_QDateToDoTaskCompletedProp) then
			// we don't expect this to happen but should at least handle it 
			qProp.CM_QDateToDoTaskCompletedProp.setup (_todoTaskDesc, strClassName);
		else
			// it is not what we are looking for so ignore it.
		endif;	
		
		// finally  do 'todo task complete DT' (CM_QDateToDoTaskCompletedProp)
		qProp := qDef.allQueryProperties[strKeyDone];
		
		if qProp = null then
			create doneProp persistent;
			
			doneProp.setup (_todoTaskDesc, strClassName);
			
			qDef.allQueryProperties.add(doneProp);	
			
			if strArray &lt;&gt; null and not strArray.includes(doneProp.propertyName) then 		
				strArray.add(doneProp.propertyName);
			endif;
			
		elseif qProp.isKindOf (CM_QBooleanToDoTaskCompletePro) then
			// we don't expect this to happen but should at least handle it 
			qProp.CM_QBooleanToDoTaskCompletePro.setup (_todoTaskDesc, strClassName);
		else
			// it is not what we are looking for so ignore it.
			
		endif;	
		
		if includeDA then
			qProp := qDef.allQueryProperties[strKeyDA];
			
			if qProp = null then
				create daToDoProp persistent;
				
				daToDoProp.setup (_todoTaskDesc, strClassName);
				
				qDef.allQueryProperties.add(daToDoProp);	
				
				if strArray &lt;&gt; null and not strArray.includes(daToDoProp.propertyName) then 		
					strArray.add(daToDoProp.propertyName);
				endif;
				
			elseif qProp.isKindOf (CM_QBooleanDocActionToDo) then
				// we don't expect this to happen but should at least handle it 
				qProp.CM_QBooleanDocActionToDo.setup (_todoTaskDesc, strClassName);
			else
				// it is not what we are looking for so ignore it.
				
			endif;	
		endif;
		
	endforeach;

	if self.myQueryMenuRoot &lt;&gt; null then
		self.myQueryMenuRoot.causeEvent(SelectorProperty_Create_Event, false, strKey); 
	endif;
end;</source>
        <Parameter name="_todoTaskDesc" type="CM_ToDoTaskDesc"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="todoTaskQueryPropertyRemove" id="6a65a8da-685d-492c-b0a5-7461200bac97">
        <source>todoTaskQueryPropertyRemove(_todoTaskDesc: CM_ToDoTaskDesc; _passport: CM_Passport);
//----------------------------------------------------------------
//	Created:	08 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 14/11/2011	cnwcs5	par 28574 
vars
	strKey		: String;
begin
	strKey := CM_QBooleanToDoTaskProperty.PREFIX_PROPERTY_NAME &amp; _todoTaskDesc.code.String;
	
	self.doRemoveQueryProperty(strKey);	
	
	strKey := CM_QBooleanToDoTaskCompletePro.PREFIX_PROPERTY_NAME &amp; _todoTaskDesc.code.String;
	
	self.doRemoveQueryProperty(strKey);	
	
	strKey := CM_QDateToDoTaskCompletedProp.PREFIX_PROPERTY_NAME &amp; _todoTaskDesc.code.String;
	
	self.doRemoveQueryProperty(strKey);	
	
	//29 Nov 2016	NDL	TFS 3021 / 2419
	strKey 	:= CM_QBooleanDocActionToDo.PREFIX_PROPERTY_NAME &amp; _todoTaskDesc.code.String;
	self.doRemoveQueryProperty(strKey);
	
end;</source>
        <Parameter name="_todoTaskDesc" type="CM_ToDoTaskDesc"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="todoTaskQueryPropertyUpdate" id="4d216945-a799-4078-a814-d7c42a8f7f53">
        <source>todoTaskQueryPropertyUpdate(_task :CM_ToDoTaskDesc);
/*
Date		Who		Reason
14 Nov 2011	cnwcs5	Initial creation - par 28574
 2 Feb 2022 navma1	Defect 56387: MTN - Selector - To Do Tasks no longer available for selection to search by
*/

vars
	strKey		: String;
begin
	
	if _task.type &lt;&gt; TODO_TYPE_GROUP_TI then				// 02.02.2022 navma1 #56387
		return;
	endif;
	
	strKey := CM_QBooleanToDoTaskProperty.PREFIX_PROPERTY_NAME &amp; _task.code.String;
	
	self.doUpdateQueryProperty(strKey, CM_QBooleanToDoTaskProperty.PREFIX_NICE_NAME &amp; _task.shortDescription);	
	
	strKey := CM_QBooleanToDoTaskCompletePro.PREFIX_PROPERTY_NAME &amp; _task.code.String;
	
	self.doUpdateQueryProperty(strKey, CM_QBooleanToDoTaskCompletePro.PREFIX_NICE_NAME &amp; _task.shortDescription);	
	
	strKey := CM_QDateToDoTaskCompletedProp.PREFIX_PROPERTY_NAME &amp; _task.code.String;
	
	self.doUpdateQueryProperty(strKey, CM_QDateToDoTaskCompletedProp.PREFIX_NICE_NAME &amp; _task.shortDescription);
	
	//29 Nov 2016	NDL	TFS 3021 / 2419
	strKey 	:= CM_QBooleanDocActionToDo.PREFIX_PROPERTY_NAME &amp; _task.code.String;
	self.doUpdateQueryProperty(strKey, CM_QBooleanDocActionToDo.PREFIX_NICE_NAME &amp; _task.shortDescription);
	
epilog

end;</source>
        <Parameter name="_task" type="CM_ToDoTaskDesc"/>
    </JadeMethod>
    <JadeMethod name="updateRolePermissions" id="e7775ce6-74c2-48af-8ded-cefc7418c285">
        <updating/>
        <source>updateRolePermissions() updating;
// ---------------------------------------------------------------------------
// Created:			01 May 2001 by cnwdwq1
// Purpose:			!     
// Parameters:	None
// Returns:			Nothing
// Changed On	Changed By		Reason
// ----------			----------			--------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	role : CM_SecurityRole;
	perms : IntegerArray;
	appScm : Schema;
	category : ConstantCategory;
	const : Constant;
begin
	create perms transient;
	appScm := rootSchema.getSchema(PortSchemaName);
	category := appScm.getCategory(XLAT_Permissions);
	//------------------
	//Populate the array of constants
	//------------------
	foreach const in category.getConstants do
		perms.add(const.GlobalConstant.valueAsInteger);
	endforeach;
	foreach role in self.allRoles do
		exclusiveLock(role);
		role.refreshPermissions(perms);
	endforeach;
epilog
	delete perms;
end;</source>
    </JadeMethod>
    <JadeMethod name="updateVoyageDataFromVesselData" id="713df3ff-7f79-4146-913a-f9d1f6054f3b">
        <updating/>
        <source>updateVoyageDataFromVesselData(_realVessel : CM_Vessel; _origVesselCode : String; _fromDT : TimeStamp; _passport : CM_Passport input) updating;
//--------------------------------------------------
// Created:	28 July 2004 By: cnwgd1
//--------------------------------------------------
vars
	tmpTerminal : CM_Terminal;
begin
	
	if _realVessel = null then
		app.raiseUnexpectedProgramError(class.name, method.name, ' Null _realVessel passed to method');
		return;
	endif;
	
	foreach tmpTerminal in self.allTerminals discreteLock do
		tmpTerminal.updateVoyageFromVessel(_realVessel, _origVesselCode, _fromDT, _passport);
	endforeach;

end;</source>
        <Parameter name="_realVessel" type="CM_Vessel"/>
        <Parameter name="_origVesselCode" type="String"/>
        <Parameter name="_fromDT" type="TimeStamp"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateConsigneeConsignor" id="f0002b9e-ee9d-4efa-a60c-6c8532c208f0">
        <source>validateConsigneeConsignor(_code : String);
//--------------------------------------------------
// Created:	19 January 2004 By: cnwgd1
//--------------------------------------------------
vars
	tmpConsignee : CM_ConsigneeConsignor;
begin
	tmpConsignee := self.allConsigneeConsignors[_code];
	if tmpConsignee = null then
		app.raiseCMException1(ERR_INVALID_CONSIGN, _code, ETRow_Consignee, null);
	endif;
end;</source>
        <Parameter name="_code" type="String"/>
    </JadeMethod>
    <JadeMethod name="validateLicenseName" id="d9f9baa5-a200-4220-8fcc-c9e9c0d736f6">
        <source>validateLicenseName(_licenseName, _productCode : String; _licenseObject : Object);
// ---------------------------------------------------------------------------
// Created:     05 April 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// ### JIRA 33543 12DEC2024 NAVAB1 change to use constants
vars
	tmpTerm	: CM_Terminal;
	
begin

	if _licenseName = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_licenseName', null, null);
		return;
	endif; 

	if _licenseObject = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_licenseObject', null, null);
		return;
	endif;
	
	if _licenseObject &lt;&gt; self then
		if _productCode = ProductCode_JMT 
		and _licenseName = self.licenseName then
			app.raiseCMException2(LicenseNameAlreadyUsed, _licenseName, app.getErrorString(System_GC), null, null);
		elseif _productCode = ProductCode_JMT_EDI
		and _licenseName = self.licenseNameEDI then
			app.raiseCMException2(LicenseNameAlreadyUsed, _licenseName, ProductStr_JMT_EDI, null, null);		
		// ### JIRA 33543 12DEC2024 NAVAB1
		elseif _productCode = ProductCode_EWS 
		and _licenseName = self.licenseEWS then
			app.raiseCMException2(LicenseNameAlreadyUsed, _licenseName, ProductStr_EWS, null, null);		
		endif;	
	endif;
	
	foreach tmpTerm in self.allTerminals where tmpTerm.licenseName &lt;&gt; null do
		if _licenseObject &lt;&gt; tmpTerm and
		   _licenseName = tmpTerm.licenseName then
			app.raiseCMException2(LicenseNameAlreadyUsed, _licenseName, app.getErrorString(Terminal) &amp; ' ' &amp; tmpTerm.name, null, null);
		endif;
	endforeach;
	
end;</source>
        <Parameter name="_licenseName" type="String"/>
        <Parameter name="_productCode" type="String"/>
        <Parameter name="_licenseObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="validateMasterTI" id="9b842ca7-b13a-4b2a-be2c-6d2b1af163d4">
        <source>validateMasterTI(_cargoType : Integer; _subType : Integer; _id : String; _terminal : CM_Terminal; _valOnSite : Boolean; _valNotOnSite : Boolean; _userObject : Object) : CM_TIMaster;
// ---------------------------------------------------------------------------
// Created:     22 August 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theContainerMaster : CM_TIMasterContainer;
	theGenMaster : CM_TIMasterGenerator;
	theChassisMaster : CM_TIMasterTILC;
	theTIMASTER : CM_TIMaster;
	tmpLC : CM_LocationsController;
	id : String;
begin
	id := _id;
	if id = null then
		return null;
	endif;
	
	if _cargoType = TI_CargoType_Container then
		theContainerMaster := self.findTIMasterByCargoType(TI_CargoType_Container,id).CM_TIMasterContainer;
		theTIMASTER := theContainerMaster;
	elseif _subType = ProductType_Trailer then
		theChassisMaster := 	self.findTIMasterByProductType(ProductType_Trailer, id).CM_TIMasterTILC;
		theTIMASTER := theChassisMaster;
	elseif _cargoType = TI_CargoType_Generator then
		theGenMaster := self.findTIMasterGeneratorByID(id);
		theTIMASTER := theGenMaster;
	endif;

	if theTIMASTER = null  then
		app.raiseCMException2(ERROR_NOT_IN_FLEET_FILE, self.getMasterTITypeString(_cargoType, _subType, null).cnEcFirstToUpper() &amp; " '" &amp; _id &amp; "'", null, null,_userObject);
		return null;
	elseif _terminal &lt;&gt; null then
		tmpLC := theTIMASTER.isOnsite(_terminal);
		if _valOnSite then
			if tmpLC &lt;&gt; null then
				app.raiseCMException3(ERR_TI_ONSITE, self.getMasterTITypeString(_cargoType, _subType, theTIMASTER).cnEcFirstToUpper(), _id, _terminal.code &amp; ". It is positioned at '" 
									&amp; _terminal.code &amp;  " " &amp; tmpLC.getFullId()&amp; "'.", null,_userObject);
				return null;
			endif;
		elseif _valNotOnSite then
			if tmpLC = null then
				app.raiseCMException1(ERR_TI_NOT_ONSITE, _id, null,_userObject);
				return null;
			endif;
		endif;
	endif;

	return theTIMASTER;
	
epilog

end;</source>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_subType" type="Integer"/>
        <Parameter name="_id" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_valOnSite" type="Boolean"/>
        <Parameter name="_valNotOnSite" type="Boolean"/>
        <Parameter name="_userObject" type="Object"/>
        <ReturnType type="CM_TIMaster"/>
    </JadeMethod>
    <JadeMethod name="validateOnsiteTrackedItemIDs" id="6d9c1572-46b0-4650-ad85-cfa04047a78f">
        <source>validateOnsiteTrackedItemIDs(_cargoType : Integer; _ids : StringArray; _foundIds : StringArray input; 
							_raiseException, _ignoreUnscaled : Boolean) : Boolean;
// ---------------------------------------------------------------------------
// Created:     07 April 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpTerm		: CM_Terminal;
	unscaledDict,
	onsiteDict		: CM_TIByIdCargoTypeDict;
	noneFound	: Boolean;
	errArray	: StringArray;
	errStr,
	idStr,
	termStr		: String;
	pos			: Integer;
	
begin

	noneFound := true;

	endLoad;	// always free any locks before continuing

	create errArray transient;

	foreach tmpTerm in self.allTerminals do
	
		beginLoad;
		
		onsiteDict 		:= tmpTerm.allOnsiteTIsByIdCargoType;
		if _ignoreUnscaled then
			unscaledDict	:= tmpTerm.allUnscaledLogsByIdCargoType;
		endif;
		
		foreach idStr in _ids do
			if onsiteDict.includesKey(idStr, _cargoType) then
				if _ignoreUnscaled and unscaledDict.includesKey(idStr, _cargoType) then
					continue;
				endif;
				if _raiseException then
					errArray.add(idStr &amp; '::' &amp; tmpTerm.code);
				endif;
				if _foundIds &lt;&gt; null then
					_foundIds.add(idStr);
				endif;
				noneFound := false;
			endif;
		endforeach;
		
		endLoad;		// free up lock on dict
	
	endforeach;

	endLoad;

	if _raiseException then
		foreach errStr in errArray do
			pos := errStr.pos('::', 1);
			if pos &gt; 0 then
				idStr 	:= errStr[1:pos-1];
				termStr	:= errStr[pos+2:end];
			else
				idStr 	:= '&lt;unknown&gt;';
				termStr	:= '&lt;unknown&gt;';
			endif;
			app.raiseCMException3(ERR_TI_ONSITE, 'Log', idStr, termStr, ETRow_Id, null);
		endforeach;
	endif;

	return noneFound;

epilog
	endLoad;
	delete errArray;
	
end;</source>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_ids" type="StringArray"/>
        <Parameter name="_foundIds" type="StringArray" usage="input"/>
        <Parameter name="_raiseException" type="Boolean"/>
        <Parameter name="_ignoreUnscaled" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateScript" id="e93bb25c-b1ef-478c-8ca2-2c3b3d56efaf">
        <source>validateScript(int: Integer): Boolean;
vars
	now : Date;
begin
	now := app.actualTimeServer().date();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
	if now.Integer &gt; int then
		return false;
	endif;
	
	return true;

end;</source>
        <Parameter name="int" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateUserIdPassword" id="d9f44dde-a09a-4442-91d1-503fffbbb4ac">
        <updating/>
        <source>validateUserIdPassword(	userId: String; 
						password : String;
						machine,
						machineToIgnore: CM_Machine;
						passport : CM_Passport input) : Integer updating;
/*
8 Feb 2011 cnwer1  PAR 26908 - now passing in machine to app.myRoot.concurrentAppSignonCheck method signature changed to include machine						
29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls	
28/05/2020	jlgdap1		TFS 49465 PIBT User Status Malfunctioning
05 Mar		2024	jlier1 62428
05/11/2025	navlw1	JIRA-36369: Add a new status “PENDING” for users and use this status for new imported users
05 Dec 2025 navlc30 JIRA 36748 CUX - Enforce SSO Login
*/
vars
	errCode			: Integer;
	userObj			: CM_User;
	alert			: CM_SystemAlert;
	maxNumAttempts	: Integer;
	loginAttempts	: Integer;
	isSSOLoginEnforced : Boolean;
begin
	//====================
	// Does user exist?
	//===================	
	maxNumAttempts	:=	self.getConfig(MaxPasswordAttempts).Integer;

	if maxNumAttempts = 0  then
		maxNumAttempts := 3;
	endif;
	
 	userObj	:=	self.allUsers[userId.toUpper];

 	if userObj = null then

		errCode := ERR_PASSWORD;
		
		if app.isWebApp and currentSession &lt;&gt; null then //epr TFS 44759 rest services will not have a currentSession
			currentSession.numberOfLoginAttempts := currentSession.numberOfLoginAttempts + 1;			
			loginAttempts := currentSession.numberOfLoginAttempts;
		else		
			app.numberOfFailedLogons	:=	app.numberOfFailedLogons + 1;
			loginAttempts				:=	app.numberOfFailedLogons;
		endif;
		
		if loginAttempts &gt;= maxNumAttempts then
			if not app.isSDSSecondaryDB() then	//cnwrs1 par24679 July 2010 make JMTTerminal work on SDSsecondary			
				create alert transient;
				alert.details	:=	"Unknown user (last id attempted with (" &amp; userId &amp; ")) has exceeded the password retry limit.";
				alert.setSeverity(SEVERE_WARNING);
				//-----------
				//Tell alert to add itself to system
				//-----------
				alert.add();
			endif;
			errCode := ERR_RETRY_LIMIT;
		endif;
		
		return errCode;
	endif;
  	//===================
  	// Password correct?
  	//===================
	errCode := 0;
	app.setSpecial(null);

	if app.testLevel = 911 then
		// Special permission to log on.
		app.testLevel := 0;
	else
		
		//Enforce SSO login
		isSSOLoginEnforced := app.myRoot.getConfig(SsoEnforceSingleSignOn).Boolean;				//05.12.2025 navlc30 #36748
		if isSSOLoginEnforced and 																//05.12.2025 navlc30 #36748
		not (userObj.isLocalMTNLoginAllowed() or 
			 userObj.isNewUser() or 
			 userObj.isInternalSystemUser()) then
			return ERR_LOCAL_LOGIN_DISABLED;
		endif;	
		
		// TFS 49465 Moved this check to before the password checking so a user who has been suspended by administrator
		// can't get their status changed after exceeding the number of failed logon attempts
	 	//==============
	 	// Not disabled?
	 	//==============
	// 	if userObj.isSuspended() then
		if userObj.isSuspendedOrIsDisabled() then	 //23 Nov 2020	NDL TFS 50378
			return ERR_USER_SUSPENDED;
	 	endif;
		
		// navlw1 05/11/2025 JIRA-MTN-36369
		// if we are a pending user do not proceed with the password vaildation as they cannot log in with this state
		if userObj.isPendingUser() then
			return ERR_USER_PENDING;
		endif;
		
	 	if userObj.isValidPassword(password) = false then
	 		errCode	:=	ERR_PASSWORD;
	 		
			if not app.isSDSSecondaryDB() then	//cnwrs1 nov 2005 make JMTTerminal work on SDSsecondary			
				userObj.updateNumberLogonAttempts(userObj.numberOfFailedLogons+1);
		 	endif;
		 	
	 		if userObj.numberOfFailedLogons &gt;= maxNumAttempts then
				// can reset this to 0 as user has been suspended in above (userObj.updateNumberLogonAttempts) 
  			 	userObj.updateNumberLogonAttempts(0);		 	
	 			errCode	:=	ERR_RETRY_LIMIT;
	 			//---------------
	 			//Warn
	 			//---------------
				if userObj &lt;&gt; null then
					create alert transient;
					alert.details	:=	userId.toUpper() &amp; " Has exceeded the password retry limit, and has been Suspended.";
					alert.setSeverity(SEVERE_WARNING);
					//-----------
					//Tell alert to add itself to system
					//-----------
					alert.add();
				endif;
	 		endif;

	 		return errCode;
	 	endif;
	 
		// user has logged on so reset. 	 	
		if not app.isSDSSecondaryDB() then	//cnwrs1 par24679 July 2010 make JMTTerminal work on SDSsecondary			
			userObj.updateNumberLogonAttempts(0);
		endif;
	 endif;
 
	passport.setForLogon(userObj);

	//epr par 25192 - with changes to apps setting isRTApp this meant process.usercode was not changed which meant 
	// the peek at screen was not fixed.
	if not app.isWebApp  then
	   	process.changeUserCode(userObj.code);
		process.causeEvent(Event_ProcessUserCodeUpdate, false, null);
	endif;

 	if userObj.isPasswordOld() then
	   	app.writeLog('User ' &amp; app.getMyUserCode() &amp; ' logged on - requires password change ******', LogERROR);
 		return Err_Password_Expired;		
 	endif;
	
//	if not app.isWebApp and not self.concurrentAppSignonCheck(userObj, errCode,machine, passport) then //+ cnwmd1 Par 22287
	if not self.concurrentAppSignonCheck(userObj, errCode,machine, machineToIgnore,passport) then //03 Mar 2021	NDL	TFS 50833
		//write 'concurrent signon failed: ' &amp; errCode.String;
		return errCode;
	endif;
	
	if machine &lt;&gt; null and userObj.allUserTerminals[machine.getMyTerminal] = null then
		//return error user does not have access to the machines terminal
		return User_no_acces_machine_terminal;
	endif;

 	return 0;
end;</source>
        <Parameter name="userId" type="String"/>
        <Parameter name="password" type="String"/>
        <Parameter name="machine" type="CM_Machine"/>
        <Parameter name="machineToIgnore" type="CM_Machine"/>
        <Parameter name="passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validateUserUpnUid" id="52cf7d90-d069-4aa6-b25c-87c50c0bcb12">
        <updating/>
        <source>validateUserUpnUid(	_userMatchingId_UPN	: String; 
					   _idpUniqueId_UID : String;
								machine : CM_Machine;
							   passport : CM_Passport input) : Integer updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
20 July 2022 	navam1	ChangeRequest 52824: EUP - Azure Active Directory Single Sign On - MTN
30 March 2023	navmd1	TFS 57335 Refactor to make the method easier to read (might end up deleting entirely soon)
31 January 2024 navmd1	TFS 60905 Updated to handle 'special' logins

*/

vars
	errCode			: Integer;
	userObj, 
	proxyUser		: CM_User;
	alert			: CM_SystemAlert;
	maxNumAttempts	: Integer;
	loginAttempts	: Integer;
	terminal		: CM_Terminal;
	linkUid			: Boolean;
	iter			: Iterator;
	root			: CM_Root;
begin
	root			:= app.myRoot;
	linkUid			:= false;
	maxNumAttempts	:=	self.getConfig(MaxPasswordAttempts).Integer;
	if maxNumAttempts = 0  then
		maxNumAttempts := 3;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Matching ID(UPN): " &amp; _userMatchingId_UPN &amp; " Unique ID(UID): " &amp; _idpUniqueId_UID, LogTRACE);
	
	//===================
	// Does user exist?
	//===================	
	if _userMatchingId_UPN &lt;&gt; null then
		
		// 1. Try a lookup using the UID first if we have one
		if _idpUniqueId_UID &lt;&gt; null then
			// The UPN can change, so we can't do a direct lookup here :(
			iter := root.allUsersBySSOIdEmail.createIterator();
			root.allUsersBySSOIdEmail.startKeyGeq(_idpUniqueId_UID, null, iter);
			// We have to assume UIDs are unique, if we ever allow more than one provider to be active at a time, this needs reviewing
			if iter.next(userObj) and userObj.ssoUniqueId &lt;&gt; _idpUniqueId_UID then
				userObj := null;
			endif;
		endif;

		// 2. Next, try a lookup using the UPN / Matching ID. It /looks/ like an email address, but it doesn't have to be. eg, it could be mason.drew_navis.com#EXT#@jadeworld.onmicrosoft.com
		if userObj = null then
			// This can be a direct lookup as the UID hasn't been set yet
			userObj := root.allUsersBySSOIdEmail[null, _userMatchingId_UPN];
			linkUid  := true;
		endif;
	
	else
		// UPN is null, but if UID is a known value, then we must be logging in as a special user
		if _idpUniqueId_UID = SUPERUSER_Str then
			userObj := root.allUsers[SUPERUSER_Str];
		elseif _idpUniqueId_UID = JMTSUPPORT_Str then
			userObj := root.allUsers[JMTSUPPORT_Str];
		endif;
	endif;

	//===================
	// Invalid/No User
	//===================
    if userObj = null then
		errCode := ERR_PASSWORD;
		
		if app.isWebApp and currentSession &lt;&gt; null then
			currentSession.numberOfLoginAttempts := currentSession.numberOfLoginAttempts + 1;			
			loginAttempts := currentSession.numberOfLoginAttempts;
		else		
			app.numberOfFailedLogons	:=	app.numberOfFailedLogons + 1;
			loginAttempts				:=	app.numberOfFailedLogons;
		endif;
		
		if loginAttempts &gt;= maxNumAttempts then
			if not app.isSDSSecondaryDB() then		
				create alert transient;
				if _userMatchingId_UPN = null then
					alert.details	:=	"Unknown user (last id attempted single-sign-on with ( No Matching ID provided )) has exceeded the retry limit. Exiting application.";
				else
					alert.details	:=	"Unknown user (last id attempted single-sign-on with (" &amp; _userMatchingId_UPN &amp;")) has exceeded the password retry limit. Exiting application.";
				endif;
				alert.setSeverity(SEVERE_WARNING);
				//-----------
				//Tell alert to add itself to system
				//-----------
				alert.add();
			endif;
			errCode := ERR_RETRY_LIMIT;
		else
			// Its difficult to work out SSO errors, so lets also raise an alert
			if _userMatchingId_UPN &lt;&gt; null then
				create alert transient;
				alert.details	:=	"Unknown user (last id attempted single-sign-on with (" &amp; _userMatchingId_UPN &amp;")) has no matching user records.";
				alert.setSeverity(SEVERE_WARNING);
				alert.add();
			endif;		
		endif;
		
		app.writeLog(method.qualifiedName &amp; " - SSO user with upn: " &amp; _userMatchingId_UPN &amp; ' not found', LogERROR);	
		return errCode;
	endif;
  	
	//===================
  	// User exists
  	//===================
	app.setSpecial(null);

	if app.testLevel = 911 then
		app.testLevel := 0;
	else
		if userObj.isSuspendedOrIsDisabled() then	 
			return ERR_USER_SUSPENDED;
	 	endif;
	 
		// user has logged on so reset. 	 	
		if not app.isSDSSecondaryDB() then			
			userObj.updateNumberLogonAttempts(0);
		endif;
	 endif;
	
	passport.setForLogon(userObj);
	
	//===================
	// link uniqueId if required
	//===================
	if linkUid then
		proxyUser	:= app.createUpdateProxy(userObj).CM_User;
		app.myUtilityUA.utlUpdateUserSSOUniqueId(proxyUser, _idpUniqueId_UID, passport);
	endif;
	
	//===================
	// Check user has access to the machine they're logging in to
	//===================
	if machine &lt;&gt; null and userObj.allUserTerminals[machine.getMyTerminal] = null then
		//return error user does not have access to the machines terminal
		return User_no_acces_machine_terminal;
	endif;
	
	//===================
	// Single session check
	//===================
	if not app.isWebApp then
	   	process.changeUserCode(userObj.code);
		process.causeEvent(Event_ProcessUserCodeUpdate, false, null);
	endif;
	
	// Check Single Session after setting our process to this user
	if not self.concurrentAppSignonCheck(userObj, errCode,machine,null, passport) then //03 Mar 2021	NDL	TFS 50833
		return errCode;
	endif;
	
 	return 0;

epilog
	delete proxyUser;
	delete iter;
end;</source>
        <Parameter name="_userMatchingId_UPN" type="String"/>
        <Parameter name="_idpUniqueId_UID" type="String"/>
        <Parameter name="machine" type="CM_Machine"/>
        <Parameter name="passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validateVoyageConflicts" id="93042f2f-5b92-4fba-b02a-b0e60fbc1df8">
        <source>validateVoyageConflicts(_conflictManager : CMIF_HMS_ConflictsManager input);
//--------------------------------------------------
// Created:	17 October 2005 By: cnwgd1
//--------------------------------------------------
vars
	checkClearances : Boolean;
	harbour : HMS_Harbour;
begin
	
	if _conflictManager = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null _conflictManager');
		return;
	endif;
	
	if _conflictManager.allValidationTypes.includes(ValidateShipPosn)
	or _conflictManager.allValidationTypes.includes(ValidateClearances) then
		checkClearances := true;
	endif;
	foreach harbour in self.allHarbours discreteLock do
		_conflictManager.myHarbour := harbour;
		if checkClearances then
			_conflictManager.buildMoveCollToValidate();
		endif;
		_conflictManager.runConflictReport();
	endforeach;
end;</source>
        <Parameter name="_conflictManager" type="CMIF_HMS_ConflictsManager" usage="input"/>
    </JadeMethod>
    <JadeMethod name="zCreateTranslationCategory" id="d30931fd-a77b-458e-b57e-8fc5bc7910df">
        <source>zCreateTranslationCategory(	_constantCategoryName 			: String; 
							_translatableTextClass 			: Class; 
							_constantCategoryDescription	: String; 
							_usesShortText					: Boolean) protected;

vars
	category : XLAT_Category;
begin
	category := self.allXLAT_Categories[_constantCategoryName];
	if category = null then
		create category persistent;
	endif;
	category.update(self, _constantCategoryName, _constantCategoryDescription, _translatableTextClass, _usesShortText);
end;</source>
        <access>protected</access>
        <Parameter name="_constantCategoryName" type="String"/>
        <Parameter name="_translatableTextClass" type="Class"/>
        <Parameter name="_constantCategoryDescription" type="String"/>
        <Parameter name="_usesShortText" type="Boolean"/>
    </JadeMethod>
</Class>
