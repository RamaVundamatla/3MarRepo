<Class name="EntTableTextNumeric">
    <JadeMethod name="initialiseFieldFrame" id="87c885de-4bb4-4743-b23e-08f2984fe4ac">
        <updating/>
        <source>initialiseFieldFrame(_frame: Frame) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 July 2009	cnwdap1	Initial creation

*/
vars
	fieldFrame 	: CMUI_FieldTextBox;
	currentText	: String;

begin
	if not _frame.isKindOf(CMUI_FieldTextBox) then
		return;
	endif;
	
	fieldFrame 	:= _frame.CMUI_FieldTextBox;
	// In some cases the text has already been set on the textbox, while it had an input type of Alphanumeric
	// We need to store away this text value and clear the text so we can set the input type without getting
	// exceptions from a possible decimal place in the existing text
	currentText	:= fieldFrame.getString;
	fieldFrame.setValue(null);
	
	fieldFrame.setInputType(TextBox.DataType_Numeric);
	fieldFrame.setDecimals(self.decimals);
	fieldFrame.setMaxLength(self.maxLength);
	if self.decimals = null then
		fieldFrame.setInputKind(fieldFrame.KIND_INTEGER);
	else
		fieldFrame.setInputKind(fieldFrame.KIND_DECIMAL);
	endif;
	
	// now put the original text back again
	fieldFrame.setValue(currentText);	
epilog

end;</source>
        <Parameter name="_frame" type="Frame"/>
    </JadeMethod>
</Class>
