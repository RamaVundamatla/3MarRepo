    <JadeMethod name="getDisplayStringForAttribute" id="ec5fee7a-5585-4c89-a447-1dde607aab87">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*
Purpose:			

Date		Who		Reason
20MAY2022	NAVAB1	TFS 51855
*/


vars
	unitID, move_kind,doctype : String;
begin
	if _attrName = ETRow_IsSnapshot then
		return self.isSnapshot.asStringJMT();
	elseif _attrName = ETRow_DataAction then
		return self.dataAction;
	elseif _attrName = ETRow_DataType then
		return self.dataType;
	elseif _attrName = ETRow_Sequence then
		return self.sequence.padLeadingWith("0",10);
	elseif _attrName = ETRow_Description then
		move_kind := self.getMoveKind();
		if move_kind &lt;&gt; "" then
			return move_kind;
		else
			// TFS 53105
			doctype := self.getDocumentType();
			if doctype &lt;&gt; null then
				return doctype;
			else
				unitID := self.getUnitId();
				if unitID &lt;&gt; null then
					return unitID;
				endif;
				
				return self.description;
			endif;
		endif;
	endif;

	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDocumentType" id="f19a6f44-c9fe-48e8-a35e-3317d8e43ce2">
        <source>getDocumentType() : String;
/*
Purpose:			

Date		Who		Reason
03 June 2022	navab1	TFS 53105
*/

vars
	st, ed, len : Integer;
	doctype : String;
begin
	if dataType = BGP_OpsViewWSRequest.OPS_TYPE_DOCUMENT then
		st := self.request.pos("docType", 1);
		
		if st &gt; 0 then
			ed := self.request.pos(",", st);
			len := ed - st;
			
			if st &gt; 0 and len &gt; 0 then
				doctype := self.request[st:len];
			endif;
			if doctype.pos("BOOKING", 1) &gt; 0 then
				return "Booking";
			elseif doctype.pos("BOOKINGITEM", 1) &gt; 0 then
				return "Booking Item";
			elseif doctype.pos("BOLITEM", 1) &gt; 0 then
				return "Bill of Lading Item";
			elseif doctype.pos("BILLOFLADING", 1) &gt; 0 then
				return "Bill of Lading";
			endif;
		endif;
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMoveKind" id="31854c4a-7752-4456-b780-7b074190e732">
        <source>getMoveKind() : String;
/*
Purpose:			

Date		Who		Reason
07JUN2022	NAVAB1	TFS 53105
*/
 
vars
	st, ed, len : Integer;
	moveKind : String;
	opsview : CMIF_OpsViewTables;
begin

	if dataType = BGP_OpsViewWSRequest.OPS_TYPE_MOVE 
	or dataType = BGP_OpsViewWSRequest.OPS_TYPE_WLE then
		st := self.request.pos("move_kind", 1);
		
		if st &gt; 0 then
			ed := self.request.pos(",", st);
			len := ed - st;
			
			if st &gt; 0 and len &gt; 0 then
				moveKind := self.request[st:len];
			endif;
			if moveKind.pos(CMIF_OpsViewTables.Move_Kind_Delivered, 1) &gt; 0 then
				return dataType &amp; " - Truck Load";
			elseif moveKind.pos(CMIF_OpsViewTables.Move_Kind_Discharge, 1) &gt; 0 then
				return dataType &amp; " - Vessel Discharge";
			elseif moveKind.pos(CMIF_OpsViewTables.Move_Kind_DischargeRail, 1) &gt; 0 then
				return dataType &amp; " - Train Discharge";
			elseif moveKind.pos(CMIF_OpsViewTables.Move_Kind_Load, 1) &gt; 0 then
				return dataType &amp; " - Vessel Load";
			elseif moveKind.pos(CMIF_OpsViewTables.Move_Kind_LoadRail, 1) &gt; 0 then
				return dataType &amp; " - Train Load";
			elseif moveKind.pos(CMIF_OpsViewTables.Move_Kind_Received, 1) &gt; 0 then
				return dataType &amp; " - Truck Discharge";
			elseif moveKind.pos(CMIF_OpsViewTables.Move_Kind_Shift, 1) &gt; 0 then
				return dataType &amp; " - Yard Shift";
			elseif moveKind.pos(CMIF_OpsViewTables.Move_Kind_Yard, 1) &gt; 0 then
				return dataType &amp; " - Yard House Keeping";
			elseif moveKind.pos(CMIF_OpsViewTables.Move_Kind_Sob, 1) &gt; 0 then
				return dataType &amp; " - Vessel Shift on Board";
			endif;
		endif;
	endif;
	
	

	return moveKind;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
