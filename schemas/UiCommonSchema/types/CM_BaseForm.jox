    <JadeMethod name="removeRegisteredKeys" id="bf79f598-5437-4a9c-8855-14f0ff6d0105">
        <updating/>
        <source>removeRegisteredKeys(_keys : IntegerArray) updating;

// THIS METHOD SHOULD BE CALLED AFTER CREATE METHOD FROM LOAD FORM METHODS.
vars

	key	:	Integer;

begin

	foreach key in _keys do
		if self.allRegisteredKeyCodes.includes(key) then
			self.allRegisteredKeyCodes.remove(key);
		endif;
	endforeach;
	self.doRegisterFormKeys();

end;</source>
        <Parameter name="_keys" type="IntegerArray"/>
    </JadeMethod>
    <JadeMethod name="resetCaption" id="3900bfdf-e299-4b78-9dd8-ad7cad3aa11f">
        <updating/>
        <source>resetCaption(_id :Integer)updating, protected;
// ---------------------------------------------------------------------------
// Created:     25 February 2010 by cnwcs5
// Purpose:     Resets caption to translated value without terminal appended
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	xlat	:XLAT_TranslatableText;
begin
	self.caption := null;	
	
	self.translateCaption(_id, self.getLocale );
	
	if self.caption = null then	
		// translate didn't find a translated version for this locale. 
		// original was cleared so we need to re-populate with default value.
		xlat := app.myRoot.allXLAT_TranslatableText.getAtKey(XLAT_FormCaptions, _id).XLAT_FormCaption;
		
		self.caption := xlat.vDefaultMessage;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_id" type="Integer"/>
    </JadeMethod>
