/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 October 2016	cnwndl1	Initial creation

*/

vars

begin
	
	self.myMobileGenericAgent.clearAll();
	app.myMobileCargoFindAgent.clearHistory( true );
	self.doBackButtonClick();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="handleBtnTwo" id="4ef4de28-9569-43a7-babb-8f940c8937fe">
        <updating/>
        <source>handleBtnTwo() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 October 2016	cnwndl1	Initial creation		TFS 2811 / 2549

*/

vars

	size : Integer;
	rowIndex : Integer;
	obj : CM_BookingRef;
	allBookings : CM_BookingRefSet;
	selected : Boolean;
	msg : String;

begin

	create allBookings transient;
	size := self.tblBookings.rows;
	foreach rowIndex in 1 to size do
		obj := self.tblBookings.accessRow(rowIndex).itemObject.CM_BookingRef;
		if obj = null then
			continue;
		endif;
		selected := self.tblBookings.accessCell(rowIndex,1).text = "1";
		if not selected then
			continue;
		endif;
		allBookings.add(obj);
	endforeach;
	
	if allBookings.isEmpty then
		msg := app.getErrorString(Bookings_selected_process);
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
		return;
	endif;
	
	self.myMobileGenericAgent.setAllSelectedBookings( allBookings );
	self.myMobileGenericAgent.setMyLocationsController( self.cmbLocation.listObject.CM_LocationsController );
	self.myMobileGenericAgent.setDriver( self.txtBookingFilt.text );
		
	self.gotoForm( MOB_HHMultiBookingStrip, false );
	
epilog

	delete allBookings;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateCmbLocation" id="fbd31e35-a691-4280-b13d-55e2decca5c0">
        <updating/>
        <source>populateCmbLocation( _lc : CM_LocationsController )updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 October 2016	cnwndl1	Initial creation

*/

vars

	term : CM_Terminal;
	ta : CM_TerminalArea;
	firstTa : CM_TerminalArea;
	iter : Iterator;
	newIndex : Integer;
	index : Integer;
	lc : CM_LocationsController;

begin

	self.cmbLocation.clear();
	
	term := self.myMobileDataAgent.myTerminal; 
	firstTa := term.allTerminalAreasByTypeId.getAtKeyGeq( TA_TYPE_YARD_INTERCHANGE, null );
	
	if firstTa &lt;&gt; null then
		iter := term.allTerminalAreasByTypeId.createIterator;
		iter.startAtObject( firstTa );
		while iter.next( ta ) do
			if ta.type &lt;&gt; TA_TYPE_YARD_INTERCHANGE then
				break;
			endif;
			lc := null;
			if ta.isKindOf( CM_InterchangeArea ) then
				lc := ta.CM_InterchangeArea.getDefaultLane;   // 36089
			elseif ta.isKindOf( CM_BlockStack ) then
				lc := ta.CM_BlockStack.myLocationsController;
			endif;
			if lc = null then
				continue;
			endif;
			newIndex := self.cmbLocation.addItem( ta.id );
			self.cmbLocation.itemObject[newIndex] := lc;
		endwhile;
		
		if self.cmbLocation.listCount &lt; 1 then
			self.cmbLocation.addItemAt( app.getErrorString(Interchang_areas_avaialable), 1 );
		elseif self.cmbLocation.listCount = 1 then
			self.cmbLocation.listIndex := 1;
		else
			self.cmbLocation.addItemAt( app.getErrorString(Select_default_area), 1 );
			self.cmbLocation.listIndex := 1;
		endif;
		
		if _lc &lt;&gt; null then
			index := self.cmbLocation.findObject(_lc);
			if index &gt; 0 then
				self.cmbLocation.listIndex := index;
			endif;
		endif;
	endif;

epilog

	delete iter;

end;</source>
        <access>protected</access>
        <Parameter name="_lc" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="setupControls" id="f4036b5f-e0e7-4f14-8387-48997965a90b">
        <updating/>
        <source>setupControls()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 October 2016	cnwndl1	Initial creation	TFS 2811 / 2549

*/

vars

	size : Integer;
	obj : CM_BookingRef;
	rowIndex : Integer;

begin

	self.populateCmbLocation( null );

	self.doResizeControls(true);
	
	if self.myMobileGenericAgent.myLocationsController &lt;&gt; null then
		self.cmbLocation.listIndex := self.cmbLocation.findObject(self.myMobileGenericAgent.myLocationsController);
		self.myMobileGenericAgent.setMyLocationsController(null);
	endif;
	
	if self.myMobileGenericAgent.driver &lt;&gt; null then
		self.txtBookingFilt.text := self.myMobileGenericAgent.driver;
		self.myMobileGenericAgent.setDriver(null);
		
		if not self.myMobileGenericAgent.allSelectedBookings.isEmpty then
			self.doClickSearch();
			
			size := self.tblBookings.rows;
			foreach rowIndex in 1 to size do
				obj := self.tblBookings.accessRow(rowIndex).itemObject.CM_BookingRef;
				if obj = null then
					continue;
				endif;
				if  self.myMobileGenericAgent.allSelectedBookings.includes( obj ) then
					self.tblBookings.accessCell(rowIndex,1).text := "1";
				endif;
			endforeach;
			
			self.myMobileGenericAgent.setAllSelectedBookings( null );
		endif;
	else
		self.txtBookingFilt.lostFocus( self.txtBookingFilt );
	endif;
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="eb386940-f188-45d0-8892-1cc15bc18870">
        <updating/>
        <source>setupForm() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 October 2016	cnwndl1	Initial creation	TFS 2811 / 2549

*/

vars

begin

	if app.myMobileCargoFindAgent = null then
		create app.myMobileCargoFindAgent transient;
	endif;
	
	self.setupCmdButtons( 3, app.getErrorString(Store), app.getErrorString(Unpack), app.getErrorString(Back), null, null );
	
	inheritMethod();
	
	self.setupControls();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupTable" id="9d14e993-6662-4407-8262-f83280493a70">
        <source>setupTable();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 October 2016	cnwndl1	Initial creation	TFS 2811 / 2549

*/

vars

begin

	self.tblBookings.parentAspect:=Table.ParentAspect_StretchBoth;
	self.tblBookings.rows := 1;
	self.tblBookings.columns := 2;
	self.tblBookings.fixedColumns := 0;
	self.tblBookings.accessColumn(1).width := (self.tblBookings.width * 0.20).Integer;
	self.tblBookings.accessColumn(1).inputType := Table.InputType_CheckBox;
	self.tblBookings.accessColumn(1).alignment := Table.Alignment_Center_Top;
	self.tblBookings.accessCell(1,2).alignment := Table.Alignment_Center_Top;
	self.tblBookings.accessCell(1,1).text := app.getErrorString(Selected);
	self.tblBookings.accessCell(1,2).text := app.getErrorString(Booking);
	self.tblBookings.selectMode := Table.SelectMode_None;
	self.tblBookings.accessSheet(1).scrollMode := Table.ScrollMode_HorzPixel_VertCell;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="d73f33f4-50f5-4b5b-a0bb-37e8b2820e39">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 10 November 2016 08:37:30.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0021523, locale);
	lblBookingFilt.translateCaption(Xlat_0021354, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="txtBookingFilt_gotFocus" id="f3b854d1-27ee-4c34-acfe-da057b7ffd96">
        <controlMethod name="TextBox::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtBookingFilt_gotFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 October 2016	cnwndl1	Initial creation	TFS 2811 / 2549

*/

vars

begin
	if self.txtBookingFilt.text = self.lblBookingFilt.caption.toUpper then
		self.txtBookingFilt.selStart := 0;
		self.txtBookingFilt.selLength := self.lblBookingFilt.caption.length;
	endif;

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtBookingFilt_keyPress" id="c1eb6d57-706e-4ec0-868c-569cabf997f0">
        <controlMethod name="TextBox::keyPress"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtBookingFilt_keyPress(textbox: TextBox input; keyCharCode: Integer io) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 December 2016	cnwndl1	Initial creation	TFS 3000/2549

*/

vars

begin

	if keyCharCode = J_key_Enter then
		self.doClickSearch();
	endif;


epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
        <Parameter name="keyCharCode" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="txtBookingFilt_lostFocus" id="9e66b246-247c-400d-96d7-25142e45d8d1">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtBookingFilt_lostFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 October 2016	cnwndl1	Initial creation	TFS 2811 / 2549

*/

vars

begin

	if self.txtBookingFilt.text.trimBlanks = self.lblBookingFilt.caption.toUpper then
		//do nothing
	elseif self.txtBookingFilt.text.trimBlanks = null then
		self.txtBookingFilt.text := self.lblBookingFilt.caption.toUpper;
		self.txtBookingFilt.userObject := null;
	else
		//do nothing
	endif;
	
	self.txtBookingFilt.selStart := 0;
	self.txtBookingFilt.selLength := 0;

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
</GUIClass>
