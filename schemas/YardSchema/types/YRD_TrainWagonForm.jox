	self.setControlsForAddEditDelete(true);
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doWagonUnplan" id="bef0ccbc-807e-43a0-a6b6-2e43e03fee4b">
        <updating/>
        <source>doWagonUnplan() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 August 2022	navhl20	ChangeRequest 54281: EUP - Wagon Track Planning

*/

vars
	moveController  : CMIF_WagonMoveController;
	wagon			: CM_Wagon;
	result,
	int				: Integer;
	str				: String;
begin
	int := app.msgBox(app.getErrorString1(Sure_that_want_unplan_wagons,self.myCurrentWagon.id), app.getErrorString(Warning), MsgBox_OK_Cancel);
	if int &lt;&gt; MsgBox_Return_OK then
		return;
	else
		create moveController transient;
		moveController.allWagons.add(self.myCurrentWagon);
		moveController.setMoveMode(UNPLAN_MODE);
		while true do
			app.myTrxUA.trxMoveWagons(moveController, app.myPassport);
			if app.myPassport.trxCompletedOK then
				// Clear errors/warnings from form and err/warnings window
				self.clearErrorWarnings();
			else
				result := app.showErrorWarningDialog(app.getErrorString(Wagon), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   result = IDOK then
					// there must have just been warnings that the user has acknowledged so ...
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			break;
		endwhile;
	endif;
	self.lblPlanLocation.visible := false;
epilog
	delete moveController;
end;</source>
    </JadeMethod>
