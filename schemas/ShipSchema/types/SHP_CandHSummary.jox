    <JadeMethod name="positionQueryFrame" id="d65d4ace-1086-45c4-b607-767aee216495">
        <source>positionQueryFrame() protected;
// ---------------------------------------------------------------------------
// Created:     11 October 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.frmQuery.left		:=	(self.width / 2) - (self.frmQuery.width / 2);
	self.frmQuery.top		:=	100;
	self.frmQuery.height	:=	300;
	self.frmQuery.width		:=	320;
	
	self.fldQuery.top		:=	self.frmQueryToolbar.clientHeight()+2;
	self.fldQuery.left		:=	0;
	self.fldQuery.height	:=	frmQuery.clientHeight() - (self.frmQueryToolbar.height + 30);
	self.fldQuery.width		:=	self.frmQuery.clientWidth();

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setEnableObjects" id="b2054d83-e05d-423b-842f-86864ea0304d">
        <source>setEnableObjects();
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

begin

	self.btnDiscrepancies.enabled := self.myCurrentVoyage &lt;&gt; null;
	self.btnPrint.enabled := self.myCurrentVoyage &lt;&gt; null;
//app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 1. " &amp; self.myCurrentVoyage.String);
end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="e5508b95-b2a4-4d76-bc63-62a49a5ac508">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	//epr CCMS 1058 11/5/09
	if not self.myTerminal.getConfig(ShipLinePortGroupsForInv).Boolean then
		app.msgBox(app.getErrorString(Hatch_sum_report_run),app.getErrorString(MSGBOX_InvalidAction),MsgBox_OK_Only);
		self.unloadForm();
	endif;
	self.shtQuery1.visible := true;
	self.usesQueryFrame := true;
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.showToolbar := true;
	self.useTableInfo := false;
	self.useTableSorting := false;
	if self.optPlanned.value then
		self.chkHideEdits.enabled := false;
		self.chkHideColours.enabled := false;
	else
		self.chkHideEdits.enabled := true;
	endif;

	self.addRegisteredKey(J_key_O);
	
	self.setMyTerminal(app.getMyTerminalDO_NOT_USE()); //+ cnwmd1, Par 20643
	
	inheritMethod();

	self.doCmbVoyageBuild();
	self.initSumariseTo();

	self.setNavigatorHeading(self.caption);
	self.initTableData(null);
	self.loadNone(self.tblData, 3);

	self.loadServiceStrings;
	//self.loadSeviceStringsCCMS1399();	
	
	self.mode := self.Mode_Enquire;
	self.fldQuery.topSheet := self.shtQuery1;


end;</source>
    </JadeMethod>
    <JadeMethod name="showColumnDataForLGD" id="3923ae2d-962b-4a3b-95b8-9fe3da4ad31e">
        <updating/>
        <source>showColumnDataForLGD(_lgd: CM_LineGroupDebtor; _column: Integer; _colTotal: Integer io) updating;
//----------------------------------------------------------------
//	Created:	11 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	codeArray		: StringArray;
	summaryTLG		: CMIF_CandHTradeLineGeo;
	summItem		: CMIF_CandHSummaryItem;
	str				: String;
	tbl				: CM_DataTable;
begin
	
	tbl := self.tblData;
		
	create codeArray transient;
		
	_lgd.getCandHCode(codeArray);
	str := codeArray[1] &amp; CrLf &amp; codeArray[2] &amp; CrLf &amp; codeArray[3];
	summaryTLG := self.myCandHReport.getSummaryTLGfromLGD(_lgd, true);
	if summaryTLG = null then
		app.raiseUnexpectedProgramError(class.name, method.name, "summary Trade Line Geo is null");
		return;
	endif;
	
	tbl.row := 1;
	tbl.column := _column;
	tbl.accessColumn(tbl.column).itemObject := _lgd;
	
	tbl.text := str;
	_colTotal := 0;
	
	foreach summItem in summaryTLG.allSummaryItemsByPrintOrder do
		tbl.row := tbl.row + 1;
		self.addToDataTable(summItem.getCount(self.showOriginalData), summItem, tbl.row, tbl.column, _colTotal);
	endforeach;
	//crane moves
	tbl.row := tbl.row + 1;
	self.addToDataTable(summaryTLG.getTotalCraneMoves20(self.showOriginalData), null, tbl.row, tbl.column, _colTotal);
	tbl.row := tbl.row + 1;
	self.addToDataTable(summaryTLG.getTotalCraneMoves40(self.showOriginalData), null, tbl.row, tbl.column, _colTotal);
	//import OD OH
	tbl.row := tbl.row + 1;
	self.addToDataTable(summaryTLG.importODOH20, null, tbl.row, tbl.column, _colTotal);
	tbl.row := tbl.row + 1;
	self.addToDataTable(summaryTLG.importODOH40, null, tbl.row, tbl.column, _colTotal);
	//export OD OH
	tbl.row := tbl.row + 1;
	self.addToDataTable(summaryTLG.exportODOH20, null, tbl.row, tbl.column, _colTotal);
	tbl.row := tbl.row + 1;
	self.addToDataTable(summaryTLG.exportODOH40, null, tbl.row, tbl.column, _colTotal);
	//rehandle OD OH
	tbl.row := tbl.row + 1;
	self.addToDataTable(summaryTLG.rehandleODOH20, null, tbl.row, tbl.column, _colTotal);
	tbl.row := tbl.row + 1;
	self.addToDataTable(summaryTLG.rehandleODOH40, null, tbl.row, tbl.column, _colTotal);
	//SOB OD OH
	tbl.row := tbl.row + 1;
	self.addToDataTable(summaryTLG.shiftODOH20, null, tbl.row, tbl.column, _colTotal);
	tbl.row := tbl.row + 1;
	self.addToDataTable(summaryTLG.shiftODOH40, null, tbl.row, tbl.column, _colTotal);
	//lash
	tbl.row := tbl.row + 1;
	self.addToDataTable(summaryTLG.lashWithCage, null, tbl.row, tbl.column, _colTotal);
	tbl.row := tbl.row + 1;
	self.addToDataTable(summaryTLG.lashWithOutCage, null, tbl.row, tbl.column, _colTotal);
	//surcharge
	tbl.row := tbl.row + 1;
	tbl.row := tbl.row + 1;
	//hatches
	tbl.row := tbl.row + 1;
	self.addToDataTable(summaryTLG.hatchCoverMoves, null, tbl.row, tbl.column, _colTotal);
	tbl.row := tbl.row + 1;
	//timberpaks
	tbl.row := tbl.row + 1;
	self.addToDataTable(summaryTLG.timberPacksLoaded, null, tbl.row, tbl.column, _colTotal);
	//BBulk
	tbl.row := tbl.row + 1;
	self.addToDataTable(summaryTLG.bbulkLoaded, null, tbl.row, tbl.column, _colTotal);
	tbl.row := tbl.row + 1;
	self.addToDataTable(summaryTLG.bbulkDischarged, null, tbl.row, tbl.column, _colTotal);
	//shifts
	tbl.row := tbl.row + 1;
	tbl.row := tbl.row + 1;
	tbl.row := tbl.row + 1;
	tbl.row := tbl.row + 1;
	//meat rebate
	tbl.row := tbl.row + 1;
	
		
epilog
	delete codeArray;
end;</source>
        <Parameter name="_lgd" type="CM_LineGroupDebtor"/>
        <Parameter name="_column" type="Integer"/>
        <Parameter name="_colTotal" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="showColumnDataForTLG" id="d1f33675-67a5-495f-b825-155652aae8b1">
        <updating/>
        <source>showColumnDataForTLG(_tlg: CMIF_CandHTradeLineGeo; _column: Integer; _colTotal: Integer io) updating;
//----------------------------------------------------------------
//	Created:	11 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	codeArray		: StringArray;
	summItem		: CMIF_CandHSummaryItem;
	str				: String;
	tbl				: CM_DataTable;
begin
	
	tbl := self.tblData;
		
	create codeArray transient;
		
	_tlg.buildCode(codeArray);
	if codeArray[3] = null then
		//str := codeArray[1] &amp; CrLf &amp; codeArray[2] &amp; CrLf &amp; app.getMyTerminal.getConfig(CandHShipPortGrpNullHead).String; //cnwrs1 Feb 2008 par 15848 (ccms1468) //- cnwmd1, Par 20643
		str := codeArray[1] &amp; CrLf &amp; codeArray[2] &amp; CrLf &amp; self.myTerminal.getConfig(CandHShipPortGrpNullHead).String; //+ cnwmd1, Par 20643
	else
		str := codeArray[1] &amp; CrLf &amp; codeArray[2] &amp; CrLf &amp; codeArray[3];
	endif;
	
	tbl.row := 1;
	tbl.column := _column;
	tbl.accessColumn(tbl.column).itemObject := _tlg;
	
	tbl.text := str;
	_colTotal := 0;
	
	foreach summItem in _tlg.allSummaryItemsByPrintOrder do
		tbl.row := tbl.row + 1;
		self.addToDataTable(summItem.getCount(self.showOriginalData), summItem, tbl.row, tbl.column, _colTotal);
	endforeach;
	//crane moves
	tbl.row := tbl.row + 1;
	self.addToDataTable(_tlg.getTotalCraneMoves20(self.showOriginalData), null, tbl.row, tbl.column, _colTotal);
	tbl.row := tbl.row + 1;
	self.addToDataTable(_tlg.getTotalCraneMoves40(self.showOriginalData), null, tbl.row, tbl.column, _colTotal);
	//import OD OH
	tbl.row := tbl.row + 1;
	self.addToDataTable(_tlg.importODOH20, null, tbl.row, tbl.column, _colTotal);
	tbl.row := tbl.row + 1;
	self.addToDataTable(_tlg.importODOH40, null, tbl.row, tbl.column, _colTotal);
	//export OD OH
	tbl.row := tbl.row + 1;
	self.addToDataTable(_tlg.exportODOH20, null, tbl.row, tbl.column, _colTotal);
	tbl.row := tbl.row + 1;
	self.addToDataTable(_tlg.exportODOH40, null, tbl.row, tbl.column, _colTotal);
	//rehandle OD OH
	tbl.row := tbl.row + 1;
	self.addToDataTable(_tlg.rehandleODOH20, null, tbl.row, tbl.column, _colTotal);
	tbl.row := tbl.row + 1;
	self.addToDataTable(_tlg.rehandleODOH40, null, tbl.row, tbl.column, _colTotal);
	//SOB OD OH
	tbl.row := tbl.row + 1;
	self.addToDataTable(_tlg.shiftODOH20, null, tbl.row, tbl.column, _colTotal);
	tbl.row := tbl.row + 1;
	self.addToDataTable(_tlg.shiftODOH40, null, tbl.row, tbl.column, _colTotal);
	//lash
	tbl.row := tbl.row + 1;
	self.addToDataTable(_tlg.lashWithCage, null, tbl.row, tbl.column, _colTotal);
	tbl.row := tbl.row + 1;
	self.addToDataTable(_tlg.lashWithOutCage, null, tbl.row, tbl.column, _colTotal);
	//surcharge
	tbl.row := tbl.row + 1;
	tbl.row := tbl.row + 1;
	//hatches
	tbl.row := tbl.row + 1;
	self.addToDataTable(_tlg.hatchCoverMoves, null, tbl.row, tbl.column, _colTotal);
	tbl.row := tbl.row + 1;
	//timberpaks
	tbl.row := tbl.row + 1;
	self.addToDataTable(_tlg.timberPacksLoaded, null, tbl.row, tbl.column, _colTotal);
	//BBulk
	tbl.row := tbl.row + 1;
	self.addToDataTable(_tlg.bbulkLoaded, null, tbl.row, tbl.column, _colTotal);
	tbl.row := tbl.row + 1;
	self.addToDataTable(_tlg.bbulkDischarged, null, tbl.row, tbl.column, _colTotal);
	//shifts
	tbl.row := tbl.row + 1;
	tbl.row := tbl.row + 1;
	tbl.row := tbl.row + 1;
	tbl.row := tbl.row + 1;
	//meat rebate
	tbl.row := tbl.row + 1;
	
		
epilog
	delete codeArray;
end;</source>
        <Parameter name="_tlg" type="CMIF_CandHTradeLineGeo"/>
        <Parameter name="_column" type="Integer"/>
        <Parameter name="_colTotal" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="showDisFrame" id="6c765698-0318-4a75-9772-4c89baa0bc6c">
        <source>showDisFrame();
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	frm : Frame;
begin
	self.frmToolbar.enabled := false;
	frm := self.frmDis;
	self.txtDis.fontSize := 8;
	self.txtDis.text := self.discrepancies;
	
	frm.visible := true;
	frm.centreWindow();
	frm.zOrder(1);
end;</source>
    </JadeMethod>
    <JadeMethod name="showSnapShotForm" id="e3d534f9-6131-457c-ae68-7333f730ec03">
        <source>showSnapShotForm(_summaryItem: CMIF_CandHSummaryItem);
//----------------------------------------------------------------
//	Created:	09 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	form : CMUI_SnapShotForm;
begin

	form := app.loadForm(CMUI_SnapShotForm, CMUI_Assistant, false, false, true, self.myTerminal, self.myMasterMenuAction).CMUI_SnapShotForm;

	if form = null then
		return;
	endif;	
	
	form.setup(_summaryItem, self.myCurrentVoyage);
	
	form.show();

end;</source>
        <Parameter name="_summaryItem" type="CMIF_CandHSummaryItem"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="bf5f66bd-e2a6-48e7-bb79-489815b175f9">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0006392, locale);
	btnCancelDis.translateBubbleHelp(Xlat_0002789, locale);
	btnCancelDis.translateCaption(Xlat_0002790, locale);
	btnDiscrepancies.translateBubbleHelp(Xlat_0002780, locale);
	btnDiscrepancies.translateCaption(Xlat_0002782, locale);
	chkHideColours.translateCaption(Xlat_0002791, locale);
	chkHideEdits.translateCaption(Xlat_0002792, locale);
	grpCargoView.translateCaption(Xlat_0002793, locale);
	lblSumariseTo.translateCaption(Xlat_0006393, locale);
	lblVoyOperator.translateCaption(Xlat_0002795, locale);
	lblVoyage.translateCaption(Xlat_0002796, locale);
	optActual.translateCaption(Xlat_0002797, locale);
	optPlanned.translateCaption(Xlat_0002798, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="unload" id="636a1a38-9856-42ee-87a6-e6b40a6071f8">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
//----------------------------------------------------------------
