    <JadeMethod name="allowsColumnFilters" id="6164f147-8adb-41b7-8d95-609371657507">
        <source>allowsColumnFilters():Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 December 2011	cnwndl1	Initial creation	Par 28889

*/

vars

begin

	if self.form = null then
		return false;
	endif;

	return self.form.allowsTableFilters(self);

epilog

end;</source>
        <ReturnType type="Boolean"/>
