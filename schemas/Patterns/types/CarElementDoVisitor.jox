<Class name="CarElementDoVisitor" id="3d786853-a6e3-44dd-8957-003d44c0dbc6">
    <superclass name="CarElementVisitor"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="dev"/>
    <JadeMethod name="visit" id="333b0216-8278-48c3-94f5-d5f25722e8d8">
        <source>visit(element: Any);
//18 August 2009	cnwdw1	
//
vars

begin
	if element.isKindOf(Body) then
		write "Moving my Body";
	elseif element.isKindOf(Engine) then
		write "Starting my Engine";
	elseif element.isKindOf(Wheel) then
		write "Kicking my "&amp;element.Wheel.name;
	endif;
end;</source>
        <Parameter name="element" type="Any"/>
    </JadeMethod>
    <JadeMethod name="visitCar" id="0705bad1-71b2-4148-93fd-dc27d0852ac8">
        <source>visitCar(_car: Car);
//18 August 2009	cnwdw1	
//
vars
	obj: Object;
begin
	write "===============";
	write "Starting my Car";
	foreach obj in _car.elements do
		obj.CarElement.accept(self);
	endforeach;

end;</source>
        <Parameter name="_car" type="Car"/>
    </JadeMethod>
</Class>
