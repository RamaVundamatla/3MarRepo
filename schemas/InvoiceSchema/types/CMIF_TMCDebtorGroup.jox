<Class name="CMIF_TMCDebtorGroup" id="a27175a3-2df7-43d1-b473-64eb918dbc7f">
    <superclass name="CMIF_TMCGroup"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="invoice"/>
    <ImplicitInverseRef name="myDebtor" id="5a345a17-437a-45fe-82cc-7b8254e4988c">
        <embedded/>
        <type name="CM_DebtorNode"/>
