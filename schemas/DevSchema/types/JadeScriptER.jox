    <JadeMethod name="testLoadToReleaseUndo" id="0d5e9bb9-10d2-42ab-9252-f7087c32e4ae">
        <source>testLoadToReleaseUndo();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 April 2025	jlier1	Initial creation

*/

vars
	
	cargo : CM_TrackedItem;
	release : CM_BulkRelease;
	cmifLoader : CMIF_MobileGenericAgent;
	quantity 			: Integer;
	weight 			: Decimal [16,4];
	targetLocation,
 	currentLocation	: CM_LocationsController;
	moveController : CMIF_MoveController;
	tiToAdd : CM_TrackedItem;
	cmifAutoPlan	: CMIF_YAAutoPlanNormal;
	cargoCheck	  : CM_CargoCheck;
	check 			: CM_CargoCheckItem;
	cargoSplitable, cargoWillSplit : Boolean;
	context : Object;
	vehicle  : CM_Vehicle;
	wagon  : CM_Wagon;
	wle : CM_WorkListEntry;
begin

app.initialize;
	app.myPassport.setMyUserFromCode("JLIER1");

	release:="2161.150318".asOid.CM_BulkRelease;
	create cmifLoader transient;
	app.myPassport.setMyTerminal(release.myTerminal);
	cmifLoader.setMyTerminal(release.myTerminal);
	cmifLoader.setMyBulkRelease(release);
	targetLocation:="2289.775596".asOid.CM_LocationsController;
	cmifLoader.setMyLocationsController(targetLocation);
	cargo:="4949.5702449".asOid.CM_TrackedItem;
	if cargo.jobRoadRelease &lt;&gt; null then
		wle:=cargo.jobRoadRelease.getWLEForTI(cargo);
	endif;
	
	app.myPassport.setWarningsIgnored(true);
	
	
	context :=release;
		
	cmifLoader.moveTI(cargo, null, targetLocation, wle, true, 1, 0, context);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="testLocationHook35370" id="47a218dd-3e12-4e85-9f2f-c06be30c1a82">
        <source>testLocationHook35370() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 August 2025	jlier1	Initial creation

*/

vars
	_locationParams : CMIF_LocationTransParams;
	request : CM_Request;
	gateEntity, gte : CMGTE_Entity;
	vvr : CM_VehicleVisitRecord;
	jobCount, jobOrder : Integer;
begin
	if _locationParams.myQueueTask &lt;&gt; null then
		request:=_locationParams.myQueueTask.myEntry.getMyRequest;
	endif;
	if request &lt;&gt; null and request.isKindOf(CM_YardRequest) then
		gateEntity:=request.CM_YardRequest.myGateEntity;
		
		
		if gateEntity &lt;&gt; null then
			//if it is for the modified source return null if the gate entity is a release or if for target it is a receipt
			if _locationParams.isSource &lt;&gt;  gateEntity.isReceipt then
				return null;
			endif;
			
			vvr:=gateEntity.myVehicleVisitRecord;
			if vvr &lt;&gt; null then
				//go through gate entities in order - only doing gate in or gate outs
				jobCount:=0;
				foreach gte in vvr.allGateEntities do
					if gte.isReceipt &lt;&gt; gateEntity.isReceipt then
						continue;
					endif;
					jobCount:=jobCount+1;
					if jobOrder = 0 and gte = gateEntity then
						//this is the current order
						jobOrder:=jobCount;
					endif;
				endforeach;
				
				if jobOrder = 1 then
					//FRONT CONTAINER
					return  "Trailer Target = Front";
				elseif jobOrder = jobCount and jobCount &lt;&gt; 1 then
					// REAR CONTAINER
					return  "Trailer Target = Rear";
				elseif jobOrder &gt; 1 and jobCount &gt; 2 and jobOrder &lt;&gt; jobCount then
					//CENTER CONTAINER somewhere in the center
					return  "Trailer Target = Center";
				endif;
							
			endif;
		endif;	
	endif;
		
	return null;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
