    <JadeMethod name="getPreGateToOutGateTime" id="a2c5d32a-4a96-40b7-a815-10d237c0610a">
        <source>getPreGateToOutGateTime() : Integer;
// ---------------------------------------------------------------------------
// Created:     15 April 2008 by cnwrs2
//
// Purpose:     Returns the number of mins between the pre-gate being completed and
//				the truck leaving the terminal.
// ---------------------------------------------------------------------------
vars
	preGateTS,
	outGateTS	: TimeStamp;
begin

	preGateTS := self.getPreGateCompleteTime();
	outGateTS := self.getArrivalAtGateOutTime();
	
	if preGateTS.isValid and outGateTS.isValid then
		return preGateTS.truncateToMinute.getDifferenceInMinutes(outGateTS.truncateToMinute);
	endif;
	
	return 0;

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getRFIDTag" id="6fe46076-fa5d-4ba3-a60d-9af8f4f4a31c">
        <source>getRFIDTag():String;
/*
Returns:	Last RFID Tag that was assigned

Date		Who		Reason
04 Dec 2012	cnwcs5	Initial creation - par 30413
18 Dec 2013	cnwdap1	PAR #32849 CCMS PEN 2321 Security Gate
*/
vars
	result	:String;
	vvrd	:CM_VehicleVisitRecordDetail;
begin
	foreach vvrd in self.allVehicleVisitRecordDetails reversed do
		if vvrd.recordType = VisitRecord_AssignRFIDTag 
		or vvrd.recordType = VisitRecord_ArriveSecurityGate then		// PAR #32849
			result	:= vvrd.getExtraInfo_AssignRFIDTag;
			break;
		endif;
	endforeach;
	
	return result;
epilog
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
