    <JadeMethod name="trxCashPaymentsConsolidate" id="c1d0c21c-e161-4d22-9a8e-4aba4a8a7bed">
        <updating/>
        <source>trxCashPaymentsConsolidate(	_cashPaymentSet : CM_CashPaymentSet;
							_invoiceLine : CM_InvoiceLine;
							_passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 August 2019	jlgndl1	Initial creation	TFS 44261

*/

vars

	cashPayment : CM_CashPayment;
	pxyCashPayment : CM_CashPayment;
	allProxies : CM_CashPaymentSet;
	load : Boolean;
	proDetail : CM_ProformaDetails;

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);

	create allProxies transient;
	
	app.cmsBeginLoad( load );
	
	if _invoiceLine = null then
		//Unassigning
		foreach cashPayment in _cashPaymentSet do
			proDetail := cashPayment.getProDetailForUnassign();
			pxyCashPayment := cashPayment.pxyCreateUpdateProxy();
			pxyCashPayment.setProformaDetail( proDetail );
			pxyCashPayment.setInvoiceLine( null );
			pxyCashPayment.setCashReceipt( cashPayment.myCashReceipt );
			allProxies.add( pxyCashPayment );
		endforeach;
	else
		//Assigning
		foreach cashPayment in _cashPaymentSet do
			pxyCashPayment := cashPayment.pxyCreateUpdateProxy();
			pxyCashPayment.setProformaDetail( null );
			pxyCashPayment.setInvoiceLine( _invoiceLine );
			pxyCashPayment.pxySetInvoice( _invoiceLine.invoice );
			pxyCashPayment.setCashReceipt( cashPayment.myCashReceipt );
			allProxies.add( pxyCashPayment );
		endforeach;
	
	endif;
	app.cmsEndLoad( load );
	
	beginTransaction;
	
	foreach pxyCashPayment in allProxies do
	
		app.myUtilityUA.utlUpdateCashPayment( pxyCashPayment, _passport );
		
		if not _passport.noErrors then
			return;
		endif;
		
	endforeach;
	
epilog

	if allProxies &lt;&gt; null and not allProxies.isEmpty then
		allProxies.purge();
	endif;
	delete allProxies;
	
	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_cashPaymentSet" type="CM_CashPaymentSet"/>
        <Parameter name="_invoiceLine" type="CM_InvoiceLine"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCashPaymentsCreateInvLine" id="ddf6306c-a7c7-4a15-a82a-5fba1b84ee40">
        <updating/>
        <source>trxCashPaymentsCreateInvLine(	_unassignedCashPayment : CM_CashPayment;
								_pxyInvoiceLine : CM_InvoiceLine input;
								_qty : Integer;
								_amount : Decimal;
								_invoiceLine : CM_InvoiceLine output;
								_passport : CM_Passport input) updating;
	/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 August 2019	jlgndl1	Initial creation	TFS 44261

*/

vars

	cashInvoice : CM_Invoice;
	load : Boolean;
	pxyCashPayment : CM_CashPayment;

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);
	
	cashInvoice := _unassignedCashPayment.getInvoiceForManualAssign;
	
	app.cmsBeginLoad( load );
	pxyCashPayment := _unassignedCashPayment.pxyCreateUpdateProxy();
	app.cmsEndLoad( load );
	
	beginTransaction;
	
	//create a new invoice line
	_invoiceLine := cashInvoice.createManLineForNonAssigned( _pxyInvoiceLine, _qty, _amount );
	
	if not _passport.noErrors then
		return;
	endif;
	
	//link the new invoice line to the cash payment
	pxyCashPayment.setProformaDetail( null );
	pxyCashPayment.setInvoiceLine( _invoiceLine );
	pxyCashPayment.pxySetInvoice( _invoiceLine.invoice );
	pxyCashPayment.setCashReceipt( _unassignedCashPayment.myCashReceipt );
	app.myUtilityUA.utlUpdateCashPayment( pxyCashPayment, _passport );
	
	if app.myPassport.noErrors then
		app.myAA.auditCreateTrx( _invoiceLine, _invoiceLine.getAuditText(), null );
	endif;

epilog

	delete pxyCashPayment;

	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_unassignedCashPayment" type="CM_CashPayment"/>
        <Parameter name="_pxyInvoiceLine" type="CM_InvoiceLine" usage="input"/>
        <Parameter name="_qty" type="Integer"/>
        <Parameter name="_amount" type="Decimal"/>
        <Parameter name="_invoiceLine" type="CM_InvoiceLine" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
