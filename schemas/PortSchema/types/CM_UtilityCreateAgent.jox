    <JadeMethod name="utlCreateExternalOrganisation" id="1eee2759-5a7d-445c-8f34-d6f672a22ec5">
        <source>utlCreateExternalOrganisation(_name : String; _logo : Binary;  _dacs : CM_DataAccessControllerSet; 
					_newExternOrg : CM_ExternalOrganisation output; _isNotAvailableForEntry : Boolean;
					_isAvailableForLabourRestrict : Boolean; _emails : CM_EmailAddressByAddressDict; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//29/07/2016	 cnwma1 TFS #2447:Adding duplicate gives error
//14/06/2022    navds20     TFS 53760 DuplicateItem not Translatable
// ---------------------------------------------------------------------------
vars
	trimmedName	: String;
	externalOrg   : CM_Organisation;
begin

	self.initialiseActivity();

	trimmedName := _name.trimBlanks;
	if trimmedName = null then
		app.raiseCMException2(ERR_FIELD_VALUE, "null", "name", 'name', null);
		return;
	endif;
	
	foreach externalOrg in app.myRoot.allOrganisations do                  //29/07/2016 cnwma1 TFS #2447
		if externalOrg.name.toUpper =trimmedName.toUpper then
			//app.raiseCMException2(DuplicateItem, "Organisation Name", trimmedName, null, null); //14.06.2022 navds20 53760
			// Organisation Name already exists for %1 : Organis_name_already_exists
			app.raiseCMException1(Organis_name_already_exists, trimmedName, null, null);  //14.06.2022 navds20 53760
			return;
		endif;
	endforeach;
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	create _newExternOrg persistent;
	_newExternOrg.setForCreate(_name, _logo, _isNotAvailableForEntry,
					_isAvailableForLabourRestrict, _emails,  app.myRoot, _passport);
	_newExternOrg.setDataAccessControllers(true,_dacs);

	if _passport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(_newExternOrg);
	endif;	

end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_logo" type="Binary"/>
        <Parameter name="_dacs" type="CM_DataAccessControllerSet"/>
