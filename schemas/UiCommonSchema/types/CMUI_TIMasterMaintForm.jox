    <JadeMethod name="keyDown" id="d6514f0e-522a-4211-8bbc-8f9d3a5c1317">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
// -------------------------------------------
// Created 30 November 2005 by cnwdvb1
// -------------------------------------------
vars
	theActiveControl	: Control;
	
begin

	theActiveControl := app.activeControl;
	if theActiveControl.parent.isKindOf(CM_EntryTable) then
		theActiveControl := theActiveControl.parent.Control;
	endif;
	
/*	if keyCode = J_key_Tab then
		if self.frmLocations.tblMove.tabStop then
			self.frmLocations.tblMove.handleFormTab(keyCode, shift, self.cmbTerminal, self.txtId);
			if theActiveControl.isKindOf(CM_EntryTable) and theActiveControl.visible then
				theActiveControl.CM_EntryTable.handleTableTab(shift);
			endif;
		endif;

	else*/
	if keyCode = CMUI_Key_F5 then
		// F5 does a refresh of the screen.
		self.doRefresh;
	else
		inheritMethod(keyCode, shift);
	endif;


end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadData" id="e2a0f379-b9a1-49dc-8a4f-55fa7c5357cf">
        <updating/>
        <source>loadData() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
05 Apr 2007	cnwer1	Initial creation - PAR#xxxx
30 Jun 2008	cnwkpd1	PAR #17210 - Handle possible invalid myInitialLocation references
12 Mar 2013	cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements
06 Mar 2014	cnwdap1	PAR #33638 Correct Tare Weight field
27 Feb 2018	cnwma1  ChangeRequest 36813: PEN - Gen Sets, Chassis &amp; Reefers
*/

vars
	indx	: Integer;
	stopTable : CM_StopsTable;
	toDoTaskDesc : CM_ToDoTaskDesc;
	weightType : CM_MeasurementType;				// PAR #31155
	
begin
	weightType := app.getDefaultMeasurementForType(Type_Weight);	// PAR #31155

	if self.myTiMaster &lt;&gt; null then
	
		self.txtID.text			:= self.myTiMaster.id;
		self.txtDescription.text:= self.myTiMaster.description;
		
		self.txtLicenceIssuer.text	:= self.myTiMaster.licenseIssuer; 
		self.txtLicenceNo.text		:= self.myTiMaster.licenseNumber;
		
		//+cnwml2 MSL CCMS 1027
		self.dateOffHire.text := self.myTiMaster.offHireDate.asStringJMT();
		self.dateOnHire.text := self.myTiMaster.onHireDate.asStringJMT();
		self.txtRemarks.text := self.myTiMaster.remarks;
		
		indx:=self.cmbOperator.findObject(self.myTiMaster.myOperatorNew);
		if indx &gt; 0 then
			self.cmbOperator.listIndex:=indx;

		endif;
		
		indx:=self.cmbOwner.findObject(self.myTiMaster.myOwner);
		if indx &gt; 0 then
			self.cmbOwner.listIndex:=indx;
		endif;
		
		
		indx:=self.cmbTILCType.findObject(self.myTiMaster.myTILCType);
		if indx &gt; 0 then
			self.cmbTILCType.listIndex:=indx;
		endif;
		
		//27.02.2018 cnwma1 ChangeRequest #36813
		indx	:= self.cmbGenerators.findObject(self.myTiMaster.allTIMasterAttachees.first.CM_TIMaster);
		if indx &gt; 0 then
			self.cmbGenerators.listIndex	:=	indx;
		endif;
		//self.txtWeight.text := self.myTiMaster.tWeight.asStringWeightJMT();									// PAR #31155
		//self.txtWeight.decimals := weightType.getDecimalPrecision;												// PAR #31155					// PAR #33638
		//self.txtWeight.text := app.convertMeasurementForDisplay(weightType.shortName, self.myTiMaster.tWeight);	// PAR #31155					// PAR #33638
		self.txtWeight.setValues(app.convertMeasurementForDisplay(weightType.shortName, self.myTiMaster.tWeight) &amp; Space &amp; weightType.shortName);	// PAR #33638
		
		//self.lstTblStops.clearAllSelected;
		self.lstTblStops.clearSelected(); //cnwrd1 par 18399 13.3.09
		foreach stopTable in self.myTiMaster.allStopsNew do
			self.lstTblStops.addSelectedObject(stopTable);		
		endforeach;
		//self.setListAllStops;
		
		//self.lstTblToDoTasks.clearAllSelected;
		self.lstTblToDoTasks.clearSelected(); //cnwrd1 par 18399 13.3.09
		foreach toDoTaskDesc in self.myTiMaster.allToDoTaskDesc do
			self.lstTblToDoTasks.addSelectedObject(toDoTaskDesc);
		endforeach;
		//self.setListToDoTaksDescs;
		
		//self.tblDamage.setTableFromProxyTIMaster(self.myTiMaster);
		//self.myAssistant.damageTableLostFocus(self.tblData, self.saveRowHeight, self.tblDamage);
		self.btnDamage.enabled := true;	// cnwrd1 par 20799 27/10/09
	else
		self.btnDamage.enabled := false;// cnwrd1 par 20799 27/10/090
	endif;

end;</source>
    </JadeMethod>
