    <JadeMethod name="utlUpdateOwnershipChange" id="1621f653-9311-47b0-a3f8-334fc0da50f6">
        <source>utlUpdateOwnershipChange(_pxyOwnerShipChange : CM_OwnershipChange io;
							  _passport 		       : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 May 2023 navtnr20	TFS CR 58507	Task 58209: Jade - TRX CM_OwnershipChange

*/

vars
	realOwnerShipChange:CM_OwnershipChange;
	expectedEdition:Integer;
	theTerminal : CM_Terminal;
begin
	self.initialiseActivity();

	_pxyOwnerShipChange.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_pxyOwnerShipChange.pxyGetRealObjectAndEdition(realOwnerShipChange, expectedEdition);
	
	if realOwnerShipChange = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_OwnershipChange.name, null, null);
		return;
	endif;

	app.myValUA.valUpdateOwnershipChange(_pxyOwnerShipChange);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;


	app.setContinueCMExceptions(false);

	exclusiveLock(realOwnerShipChange);

	if _passport.noErrors and realOwnerShipChange.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'OWNERSHIP CHANGE', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realOwnerShipChange, true);
	endif;
	
	if _passport.noErrors then
		realOwnerShipChange.setForUpdate(_pxyOwnerShipChange);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realOwnerShipChange, false);
		//navtnr20 4-07-2023 TFS 58229
		 theTerminal := realOwnerShipChange.myTerminal;
		app.myEventManager.createSingleObjInfoNoteEvt(theTerminal,theTerminal.getTerminalEvent(Event_COOUpdate),realOwnerShipChange);	
	endif;
epilog

end;</source>
        <Parameter name="_pxyOwnerShipChange" type="CM_OwnershipChange" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateOwnershipChangeApprov" id="0defd791-b659-4235-b70d-690c850b649b">
        <source>utlUpdateOwnershipChangeApprov(_realCOO : CM_OwnershipChange input; _passport : CM_Passport input; _cmifAgent	: CMIF_COOAgent);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30/11/2023	navkc1 ChangeRequest 58254 Task 58257: Jade - TRX Ownership Change Approval

*/

vars
	cg						: CM_CargoGroup;
	terminal				: CM_Terminal;
begin
	self.initialiseActivity();

	_realCOO.raiseExceptionIfTransient(method);

	app.setContinueCMExceptions(true);
	
	_realCOO.latestEdition();
	
	app.myValUA.valUpdateOwnershipChangeApprov(_realCOO);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(_realCOO);
	
	if _passport.noErrors() then
		self.myUpdateAuditAgent.audUpdateGeneric(_realCOO, true);
	endif;
	
	_realCOO.doCOOApproval(_cmifAgent);
	
	if _passport.noErrors() then
		self.myUpdateAuditAgent.audUpdateGeneric(_realCOO, false);
		terminal := _realCOO.myTerminal;
		app.myEventManager.createSingleObjInfoNoteEvt(terminal,terminal.getTerminalEvent(Event_COOUpdate),_realCOO);	
	endif;
	
epilog
	
end;</source>
        <Parameter name="_realCOO" type="CM_OwnershipChange" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_cmifAgent" type="CMIF_COOAgent"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateOwnershipChangeDetail" id="c6458fce-123e-4365-b693-565c311968e0">
        <source>utlUpdateOwnershipChangeDetail(_pxyOwnerShipChangeDetail : CM_OwnershipChangeDetail io;
							  _passport 		       : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 June 2023 navtnr20    TFS CR 58507    Task 58210: Jade - TRX CM_OwnershipChangeDetail

*/

vars
	realOwnerShipChangeDetail:CM_OwnershipChangeDetail;
	parentCOO : CM_OwnershipChange;
	expectedEdition, actualEdition:Integer;
	theTerminal : CM_Terminal;
begin
	self.initialiseActivity();

	_pxyOwnerShipChangeDetail.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_pxyOwnerShipChangeDetail.pxyGetRealObjectAndEdition(realOwnerShipChangeDetail, expectedEdition);
	
	if realOwnerShipChangeDetail = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_OwnershipChangeDetail.name, null, null);
		return;
	endif;

	app.myValUA.valUpdateOwnershipChangeDetail(_pxyOwnerShipChangeDetail);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;


	app.setContinueCMExceptions(false);

	exclusiveLock(realOwnerShipChangeDetail);
	actualEdition := realOwnerShipChangeDetail.edition;
	if _passport.noErrors and realOwnerShipChangeDetail.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'OWNERSHIP CHANGE DETAIL', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realOwnerShipChangeDetail, true);
	endif;
	
	if _passport.noErrors then
		realOwnerShipChangeDetail.setForUpdate(_pxyOwnerShipChangeDetail);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realOwnerShipChangeDetail, false);
		// ### TFS CR 58230 TASK 58232 26JUL2023 NAVAB1
		parentCOO := realOwnerShipChangeDetail.myOwnershipChange; 
		if parentCOO = null
		and realOwnerShipChangeDetail.myParentOwnershipChangeDetail &lt;&gt; null then
			parentCOO := realOwnerShipChangeDetail.myParentOwnershipChangeDetail.myOwnershipChange;
		endif;
		if parentCOO&lt;&gt; null then
			app.myEventManager.createSingleObjInfoNoteEvt(parentCOO,app.myPassport.myTerminal.getTerminalEvent(Event_COODtlUpdate),realOwnerShipChangeDetail);	//navtnr20 12-07-2023 58238
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_pxyOwnerShipChangeDetail" type="CM_OwnershipChangeDetail" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
