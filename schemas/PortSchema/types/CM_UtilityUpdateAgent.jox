    <JadeMethod name="utlUpdateCamObjectStatus" id="7dfef2cc-47d1-4ba7-bce1-15761df7fff5">
        <updating/>
        <source>utlUpdateCamObjectStatus(_camObject: CM_Object input; _newStatus: Integer; _passport: CM_Passport) updating;
// ---------------------------------------------------------------------------
// Created:		20 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// 18 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
// 10 dec 2012	cnwcs5	CCMS SFW 1294 / par 30855 - change parameter usage
vars
	camTaskHistory 	: CM_CamTaskHistory;
	camProtocol		: CM_CamProtocol;
begin

	self.initialiseActivity();
	app.setContinueCMExceptions(true);

	exclusiveLock(_camObject);
	
	if _camObject.isKindOf(CM_CamProtocol) then
		camProtocol := _camObject.CM_CamProtocol;	
		camProtocol.setStatus(_newStatus);
		
	elseif _camObject.isKindOf(CM_CamTaskHistory) then
		camTaskHistory 	:= _camObject.CM_CamTaskHistory;		
		camTaskHistory.setStatus(_newStatus);
		
	else
		//wrong kind of object
		app.raiseCMException(ERR_INVALID_PARAMETER,'camObject',null);
	endif;

	// jade bug 63509 16/2/15 was causing 4027 but not sure why we do this anyway as we are only registered for system events and 
	// updating  the object is enough 
	//if camProtocol &lt;&gt; null then
	//	camProtocol.causeEvent(eventType, false, camProtocol);
	//endif;
end;</source>
        <Parameter name="_camObject" type="CM_Object" usage="input"/>
        <Parameter name="_newStatus" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
