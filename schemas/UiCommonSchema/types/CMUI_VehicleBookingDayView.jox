    <JadeMethod name="populateCombos" id="d624ffb1-b950-4e74-8260-b7d4c3606a40">
        <source>populateCombos();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 April 2013	cnwndl1	Initial creation
// 19 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	date : Date;
	pos : Integer;
	dayType : CM_DayType;
begin

	self.cmbPeriod.clear();
	self.cmbPeriod.width := 100;
	
	self.cmbPeriod.addItem( ByDay );
	self.cmbPeriod.addItem( ByMonth );
	
	self.cmbPeriod.listIndex := self.cmbPeriod.findStringExact( 1, ByMonth );	// default
	
	date := self.systemToLocalTime(app.actualTimeServer).date();// 19 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	self.setDayListArray( date.lastMonday );

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="reColourBookings" id="7d7604e7-57f8-4281-8076-58cd8d43ecc2">
        <source>reColourBookings();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 April 2013	cnwndl1	Initial creation	Par 31393
// 18 May 2016	cnwns1	TFS 488 - Multi Timezone Support
27 Mar 2025	navnk30	JIRA 34424: TPT | VBS - Change the information from "Arrived on schedule" to be more clear with the timestamp like "Arrived on schedule at 23:23 on 20th March 2025"
*/

vars

	index : Integer;
	rowBooking : CM_VehicleBookingTimeSlot;
	graceMins : Integer;
	now : TimeStamp;
	nowStartGrace : TimeStamp;
	nowEndGrace : TimeStamp;
	stdBackColour : Integer;
	firstCurrentLine : Integer;
	numVisibleRows : Integer;
	halfWay : Integer;
	backColour : Integer;
	statusColumn : Integer;
	withinGraceTimes : Boolean;
	graceTSInterval : TimeStampInterval;
	currentDay : Date;
	nextDay : Boolean;
currentDayLocal	: TimeStamp;
begin
	
	stdBackColour := self.tblBookings.backColor;
	graceTSInterval := self.myTerminal.getVSTimeslotGraceTimeInterval( graceMins );

	now := app.actualTimeServer;// 18 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	if graceMins = 0 then
		nowStartGrace := now;
		nowEndGrace := now;
	else
		nowStartGrace := now - graceTSInterval;
		nowEndGrace := now + graceTSInterval;
	endif;
	
	statusColumn := self.tblBookings.getColumnByRowName(ETRow_Status);
	
	currentDayLocal.cnEcSetDateAndTime(self.txtDate.getDate,TimeStartOfDay);	// 18 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	currentDay :=  currentDayLocal.localToSystemTimeUsingObject(self).date();			// 18 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		
	foreach index in self.tblBookings.fixedRows to self.tblBookings.rows do
		rowBooking := self.tblBookings.accessRow(index).itemObject.CM_VehicleBookingTimeSlot;
		if rowBooking = null then
			continue;
		endif;
		withinGraceTimes := false;
		if rowBooking.bookingTSend &lt; nowStartGrace then
			backColour := PaleYellow;
		else
			if firstCurrentLine = 0 then
				firstCurrentLine := index;
			endif;
			backColour := stdBackColour;
			if rowBooking.bookingTSend &lt; nowEndGrace then
				withinGraceTimes := true;
			endif;
		endif;
		if backColour = stdBackColour then
			nextDay := rowBooking.bookingTSend.date &lt;&gt; currentDay;
			if nextDay and rowBooking.bookingTSend.time &gt; "00:00".Time then
				backColour := xmlColourNonCurrMth;
			endif;
		endif;
		
		if self.tblBookings.accessRow( index ).backColor &lt;&gt; backColour then
			if statusColumn &gt; 0 then
				//self.tblBookings.setCellText( index, statusColumn, rowBooking.getStatusString);			//27.03.2025 navnk30 JIRA 34424
				self.tblBookings.setCellText( index, statusColumn, rowBooking.getStatusStringWithTS());		//27.03.2025 navnk30 JIRA 34424
			endif;
			self.tblBookings.accessRow( index ).backColor := backColour;
		elseif withinGraceTimes and statusColumn &gt; 0 then
			if statusColumn &gt; 0 then
				self.tblBookings.setCellText( index, statusColumn, rowBooking.getStatusString);
			endif;
		endif;
	endforeach;
	
	if firstCurrentLine &gt; self.tblBookings.fixedRows then
		numVisibleRows := ( self.tblBookings.height / self.tblBookings.accessRow(firstCurrentLine).height ).Integer;
		halfWay := ( numVisibleRows / 2 ).Integer;
		if firstCurrentLine &gt; halfWay then
			firstCurrentLine := firstCurrentLine - halfWay;
		endif;
		self.tblBookings.topRow := firstCurrentLine;
	endif;
		
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="reScaleWeekMonthHeight" id="de6676a4-1aad-4838-9b9a-4d0b89b375ee">
        <source>reScaleWeekMonthHeight() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 April 2013	cnwndl1	Initial creation

*/

vars

	baseCellHeight : Integer;
	row : Integer;
	vHeight : Real;
	vRowHeight : Integer;
	usedHeight : Real;
	
begin

	if self.tblBookings.rows = 1 then
		return;
	endif;
	
	baseCellHeight := 16;	// the heading.

	vHeight := self.tblBookings.height - baseCellHeight - self.tblBookings.rows;
	vRowHeight := ( vHeight / ( self.tblBookings.rows - 1 ) ).Integer;
	
	foreach row in 2 to self.tblBookings.rows do
		self.tblBookings.accessRow(row).height := vRowHeight;
	endforeach;
	
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="resetListBoxContents" id="de2571f6-bc01-4593-b3c1-dbb32593e91c">
        <source>resetListBoxContents( _listBox : CMUI_ListBox; _date : Date; _row : Integer; _column : Integer );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 April 2013	cnwndl1	Initial creation

*/

vars

	newIndex : Integer;
	term : CM_Terminal;
	vssTerm : CM_VehicleBookingTerminal;
	strArray : StringArray;
	str : String;
	
begin

	_listBox.clear();

	term := self.myTerminal;
	vssTerm := term.myVehicleBookingTerminal;
	
	create strArray transient;
	vssTerm.getBookingSummaryData(	_date,
									self.chkInclUnbooked.value,
									self.chkInclBooked.value,
									self.chkInclUsed.value,
									self.myFilterCarrier,
									self.myFilterDriver,
									self.myFilterVehicle,
									true,
									strArray
									);
	
	foreach str in strArray do
		newIndex := _listBox.addItem( str );
		if newIndex = 1 then
			_listBox.itemBackColor[newIndex] := xmlColourDateBack;
		endif;
	endforeach;

	self.displaycellText( _row, _column );
	
epilog

	delete strArray;
	
end;</source>
        <Parameter name="_listBox" type="CMUI_ListBox"/>
        <Parameter name="_date" type="Date"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_column" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setCellDataForWeek" id="7491a0e0-fd68-47c1-bce6-dfb78528917a">
        <source>setCellDataForWeek( date : Date );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 April 2013	cnwndl1	Initial creation
// 19 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

	rowIndex : Integer;
	colIndex : Integer;
	listBox : CMUI_ListBox;
	tableCell : JadeTableCell;
	tableRow : JadeTableRow;
	baseDayIndex : Integer;
	baseDay : Date;
	index : Integer;
	newIndex : Integer;
	today : Date;
	baseCellHeight : Integer;
	listCount : Integer;

begin

	// find the first date that will be in the row, i.e. the Monday.
	if date.dayOfWeek = 1 then
		baseDay := date;
	else
		baseDay := date.lastMonday;
	endif;
	
	baseDayIndex := baseDay.dayOfYear;
	listBox := self.lstActivity.getControl(baseDayIndex).CMUI_ListBox;
	listCount := 1;
	baseCellHeight := 16;
	tableRow := self.tblBookings.accessRow(1);
	tableRow.height := ( baseCellHeight );
	
	today := self.systemToLocalTime(app.actualTimeServer).date();// 19 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	if listBox = null then
		// we don't have a row that includes the monday, so have to build one.
		
		self.tblBookings.rows := self.tblBookings.rows + 1;
		rowIndex := self.tblBookings.rows;
		tableRow := self.tblBookings.accessRow(rowIndex);
		
		index := baseDayIndex;
		
		foreach colIndex in 1 to self.tblBookings.columns do
			tableCell := self.tblBookings.accessCell(rowIndex,colIndex);
			tableCell.alignment := Table.Alignment_Left_Top;
			if today = baseDay then
				tableCell.backColor := xmlColourCurrentDay;
				tableCell.foreColor := xmlColourCurrentDay.getInverseColour();
			elseif baseDay.month &lt;&gt; date.month then
				tableCell.backColor := xmlColourNonCurrMth;
				tableCell.foreColor := xmlColourNonCurrMth.getInverseColour();
			else
				tableCell.backColor := xmlColourDateBack;
				tableCell.foreColor := xmlColourDateBack.getInverseColour();
			endif; 
			listBox := self.lstActivity.loadControl(index).CMUI_ListBox;
			self.listBoxIndexArray.add(index);
			listBox.visible := true;
			listBox.enabled := true;
			tableCell.cellControl := listBox;
			self.resetListBoxContents( listBox, baseDay, rowIndex, colIndex );
			baseDay := baseDay + 1;
			index := baseDay.dayOfYear;
			if listBox.listCount &gt; listCount then
				listCount := listBox.listCount;
			endif;
		endforeach;
		
		if listCount &gt; 5 then
			tableRow.height := (baseCellHeight * 5);
		elseif listCount &gt; 3 then
			tableRow.height := (baseCellHeight * listCount);				
		else
			tableRow.height := baseCellHeight * 3;
		endif;
		
	else
		// we have the row with Monday in it
		// so now we find the row of the control
		listBox := self.lstActivity.getControl(date.dayOfYear).CMUI_ListBox;
		rowIndex := 0;
		colIndex := date.dayOfWeek;
		foreach index in 1 to self.tblBookings.rows do
			tableCell := self.tblBookings.accessCell(index,colIndex);
			if tableCell.cellControl = listBox then
				rowIndex := index;
				self.resetListBoxContents( listBox, date, rowIndex, colIndex );
				break;
			endif;
		endforeach;
	endif;
		
epilog

end;</source>
        <Parameter name="date" type="Date"/>
    </JadeMethod>
    <JadeMethod name="setColours" id="6d48afe5-59a9-4a13-907f-3e559ec849dd">
        <updating/>
        <source>setColours() updating;

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 April 2013	cnwndl1	Initial creation

