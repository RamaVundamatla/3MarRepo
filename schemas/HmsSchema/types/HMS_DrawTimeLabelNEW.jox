    <JadeMethod name="setMyLabelFrmHeight" id="c6558497-ebc7-4516-97d3-32c7a4604fa4">
        <updating/>
        <source>setMyLabelFrmHeight() updating, protected;
//-----------------+---------------------------------
// Created:	12 May 2004 By: cnwgd1
//--------------------------------------------------
vars
	tmpHeight,
	oldHeight,
	newHeight : Real;
	tmpScrollableFrame	: CMUI_ScrollableFrame;
	msgStr : String;
begin
	
	oldHeight := self.myLabelFrame.height;
	newHeight := (self.toTimePeriod.date - self.fromTimePeriod.date)*24*10/(self.myGraphicalView.timeZoom);

	tmpScrollableFrame := self.myLabelFrame.myScrollableFrame;

	if tmpScrollableFrame.hasHScroll then
		tmpHeight := tmpScrollableFrame.clientHeight - self.myLabelFrame.width - CMUI_ScrollableFrame.ScrollBarWidth;
	else
		tmpHeight := tmpScrollableFrame.clientHeight - self.myLabelFrame.width;
	endif;

	if newHeight &lt; tmpHeight then
		newHeight := tmpHeight;
	endif;	

//	if newHeight &lt;&gt; oldHeight then // Lorcan remove 26/7/2006 Lets always do this calculation
		self.minutesPerPixel := fromTimePeriod.minutesDiff(toTimePeriod) / newHeight;
		self.myGraphicalView.minutesPerPixel := self.minutesPerPixel;	
		self.myLabelFrame.height := newHeight;
		self.scaleHeight := newHeight;
		self.myGraphicalView.resizeScrollingFrame();
//	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
