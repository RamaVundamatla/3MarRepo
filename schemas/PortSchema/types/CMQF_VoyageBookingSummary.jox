    <JadeMethod name="filterObjects" id="92adc1e9-3206-4e96-8c76-573f523eecca">
        <updating/>
        <source>filterObjects(_bookingSummaryDict : CMIF_BookingByPortCommCodeDict input; _passport : CM_Passport) updating;
// ---------------------------------------------------------------------------
// Created:     07 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
// 15/07/2010	cnwdap1		PAR #25021 review use of isImport/isExport for tranships
// 17 Feb 2015	cnwkpd1	PAR #35704 - Changes to prevent extended locking

vars

	ti					: CM_TrackedItem;
	slotRequest			: CM_SlotRequest;
	tiDict 				: CM_TIByCargoTypeIdDict;
	iter				: Iterator;
	querySelf			: CMQF_VoyageBookingSummary;
	loadPortCode		: String;
	bay					: CM_BayVoyage;
	slot				: CM_SlotController;
	breakOut			: Boolean;
begin
	querySelf := self;
	
	if querySelf.getMyVoyage = null then
		return;
	endif;
	
	loadPortCode := self.getMyVoyage.myTerminal.getConfig(PortDestCode).String.toUpper.trimBlanks;
	
	self.createPreDefinedSummaryObj(_bookingSummaryDict);
	//go through jobs/each request/each wle to total colour codes (that which is planned)
	if self.getMyVoyage.myCellularVoyageStructure &lt;&gt; null then //added by cnwyl1 24052006
		foreach bay in self.getMyVoyage.myCellularVoyageStructure.allBayVoyagesById discreteLock do : bayLoop
			foreach slot in bay.allSlotControllersByOrdinal discreteLock do : slotLoop
				slotRequest := slot.mySlotRequestLoad;
				if slotRequest = null then
					continue slotLoop;
				endif;
		
				if ((not slotRequest.isLoad) and 
				   (not slotRequest.isRehandle)) or
				   (slotRequest.isSOB) then
					continue slotLoop;
				endif;
		
				// PAR 21746 if slotRequest.fortyBack or slotRequest.isBackend then // PAR 19945
				if slotRequest.getAttrIsBackend() then // PAR 21746 
					continue slotLoop;
				endif;
				
				querySelf.numFound := querySelf.numFound + 1;
				querySelf.numSearched := querySelf.numSearched + 1;
				
				querySelf.checkStatusIncludesObject(null, _passport, breakOut);
				
				querySelf.totalBookingColourCode(_bookingSummaryDict, slotRequest, _passport);
			endforeach;
		endforeach;
	endif;//added by cnwyl1 24052006
	//go through each TI onship, onsite and notified
	
	// ONSHIP
	tiDict := self.getMyVoyage.allOnshipTIsByCargoTypeId;
	delete iter;
	iter := tiDict.createIterator;
	tiDict.startKeyGeq(TI_CargoType_Container, null, iter);
	
	while iter.next(ti) do
		if ti.cargoType &lt;&gt; TI_CargoType_Container then
			break;
		endif;
		
		if	((not ti.isExport) and
			(not ti.isTranshipOutbound) and		// PAR #25021
		  	(not ti.isRehandle)) or
			(ti.isSOB) then
				continue;
		endif;
		
		self.totalBookingActual(_bookingSummaryDict, ti, _passport);
	endwhile;
	
	// ONSITE
	tiDict := self.getMyVoyage.allOnsiteTIsByCargoTypeId;
	delete iter;
	iter := tiDict.createIterator;
	tiDict.startKeyGeq(TI_CargoType_Container, null, iter);
	
	while iter.next(ti) do
		if ti.cargoType &lt;&gt; TI_CargoType_Container then
			break;
		endif;
		
		if (not ti.isExport) and
		   (not ti.isTranshipOutbound) and		// PAR #25021
		   (not ti.isRehandle) then
			continue;
		endif;
		
		self.totalBookingActual(_bookingSummaryDict, ti, _passport);
	endwhile;
	
	// NOTIFIED
	tiDict := self.getMyVoyage.allNotifiedTIsByCargoTypeId;
	delete iter;
	iter := tiDict.createIterator;
	tiDict.startKeyGeq(TI_CargoType_Container, null, iter);

	while iter.next(ti) do
		if ti.cargoType &lt;&gt; TI_CargoType_Container then
			break;
		endif;
		
		if (not ti.isExport) and
		   (not ti.isRehandle) then
			continue;
		endif;
		
		self.totalBookingActual(_bookingSummaryDict, ti, _passport);
	endwhile;
	
epilog
	delete iter;	
	
end;</source>
        <Parameter name="_bookingSummaryDict" type="CMIF_BookingByPortCommCodeDict" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="totalBookingActual" id="25873f74-187d-4249-bde0-8cb2683e349d">
        <source>totalBookingActual(_bookingSummaryDict : CMIF_BookingByPortCommCodeDict input; 
					_ti : CM_TrackedItem; _passport : CM_Passport);
// ---------------------------------------------------------------------------
// Created:     09 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	container			: CM_Container;
	isDLR,
	is40				: Boolean;
	lc					: CM_LocationsController;
	slotController		: CM_SlotController;
	commodityCode,
	filterLoadPort		: String;
		
begin
	self.updateBookingForActual(_bookingSummaryDict, 
									_ti, 
									CMIF_VoyageBookingSummary.TYPE_COMMODITY,
									_ti.commodityGroup);
	container := _ti.CM_Container;
	is40 := container.is40;
	isDLR := (container.isRehandle);	
  	
  	if container.isEmpty then
		self.updateBookingForActual(_bookingSummaryDict,
										_ti,
										CMIF_VoyageBookingSummary.TYPE_ISO,
										CMIF_VoyageBookingSummary.Category_TotalEmpties);	
		if is40 then
			if isDLR then
				self.updateBookingForActual(_bookingSummaryDict, 
											_ti,
											CMIF_VoyageBookingSummary.TYPE_MOVE,
											CMIF_VoyageBookingSummary.Category_40GeneralDLR);
			endif;
			self.updateBookingForActual(_bookingSummaryDict,
											_ti,
											CMIF_VoyageBookingSummary.TYPE_ISO,
											CMIF_VoyageBookingSummary.Category_40MT);
												
		else
			if isDLR then
				self.updateBookingForActual(_bookingSummaryDict, 
											_ti,
											CMIF_VoyageBookingSummary.TYPE_MOVE,
											CMIF_VoyageBookingSummary.Category_20GeneralDLR);
			endif;
			self.updateBookingForActual(_bookingSummaryDict, 
											_ti,
											CMIF_VoyageBookingSummary.TYPE_ISO,
											CMIF_VoyageBookingSummary.Category_20MT);	
		endif;
	elseif container.isAttributeTrue(TI_Attrib_RequiresPower) then
		self.updateBookingForActual(_bookingSummaryDict, 
										_ti,
										CMIF_VoyageBookingSummary.TYPE_ISO,
										CMIF_VoyageBookingSummary.Category_TotalIntegral);
		if is40 then
			if isDLR then
				self.updateBookingForActual(_bookingSummaryDict, 
											_ti,
											CMIF_VoyageBookingSummary.TYPE_MOVE,
											CMIF_VoyageBookingSummary.Category_40IntegralDLR);
			endif;
			
			self.updateBookingForActual(_bookingSummaryDict, 
											_ti,
											CMIF_VoyageBookingSummary.TYPE_ISO,
											CMIF_VoyageBookingSummary.Category_40Integral);
		else
			if isDLR then
				self.updateBookingForActual(_bookingSummaryDict, 
											_ti,
											CMIF_VoyageBookingSummary.TYPE_MOVE,
											CMIF_VoyageBookingSummary.Category_20IntegralDLR);
			endif;
			
			self.updateBookingForActual(_bookingSummaryDict, 
											_ti,
											CMIF_VoyageBookingSummary.TYPE_ISO,
											CMIF_VoyageBookingSummary.Category_20Integral);
		endif;

	else
		self.updateBookingForActual(_bookingSummaryDict, 
										_ti, 
										CMIF_VoyageBookingSummary.TYPE_ISO,
										CMIF_VoyageBookingSummary.Category_TotalGeneral);
		if is40 then
			if isDLR then
				self.updateBookingForActual(_bookingSummaryDict, 
											_ti,
											CMIF_VoyageBookingSummary.TYPE_MOVE,
											CMIF_VoyageBookingSummary.Category_40GeneralDLR);
			endif;
			self.updateBookingForActual(_bookingSummaryDict, 
											_ti, 
											CMIF_VoyageBookingSummary.TYPE_ISO,
											CMIF_VoyageBookingSummary.Category_40General);
		else
			if isDLR then
				self.updateBookingForActual(_bookingSummaryDict, 
											_ti,
											CMIF_VoyageBookingSummary.TYPE_MOVE,
											CMIF_VoyageBookingSummary.Category_20GeneralDLR);
			endif;
			self.updateBookingForActual(_bookingSummaryDict, 
											_ti, 
											CMIF_VoyageBookingSummary.TYPE_ISO,
											CMIF_VoyageBookingSummary.Category_20General);
		endif;
	endif;
	
	if isDLR then
			self.updateBookingForActual(_bookingSummaryDict, 
											_ti,
											CMIF_VoyageBookingSummary.TYPE_MOVE,
											CMIF_VoyageBookingSummary.Category_TotalDLR);
	endif;
end;</source>
        <Parameter name="_bookingSummaryDict" type="CMIF_BookingByPortCommCodeDict" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="totalBookingColourCode" id="cf2a13a6-66f0-4501-8325-94d0cbedd10e">
        <source>totalBookingColourCode(_bookingSummaryDict : CMIF_BookingByPortCommCodeDict input; 
						_slotRequest : CM_SlotRequest; _passport : CM_Passport);
// ---------------------------------------------------------------------------
// Created:     08 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	is40				: Boolean;
	lc					: CM_LocationsController;
	commodityGroup		: String;
begin	
	self.updateBookingForColourCode(_bookingSummaryDict, 
									_slotRequest, 
									CMIF_VoyageBookingSummary.TYPE_COMMODITY,
									_slotRequest.commodity);
	is40 := _slotRequest.getAttrIs40();
	
	// DLR Totals
	if _slotRequest.moveType = DLR_MOVETYPE then
		self.updateBookingForColourCode(_bookingSummaryDict, 
										_slotRequest,
										CMIF_VoyageBookingSummary.TYPE_MOVE,
										CMIF_VoyageBookingSummary.Category_TotalDLR);
		if is40 then
			if _slotRequest.getAttrPowerRequired() or _slotRequest.getAttrWaterCooled() then //integ
				self.updateBookingForColourCode(_bookingSummaryDict, 
												_slotRequest,
												CMIF_VoyageBookingSummary.TYPE_MOVE, 
												CMIF_VoyageBookingSummary.Category_40IntegralDLR);
			else
				self.updateBookingForColourCode(_bookingSummaryDict, 
												_slotRequest,
												CMIF_VoyageBookingSummary.TYPE_MOVE,
												CMIF_VoyageBookingSummary.Category_40GeneralDLR);
			endif;
		else
			if _slotRequest.getAttrPowerRequired() or 
			   _slotRequest.getAttrWaterCooled() then
				self.updateBookingForColourCode(_bookingSummaryDict, 
												_slotRequest,
												CMIF_VoyageBookingSummary.TYPE_MOVE,
												CMIF_VoyageBookingSummary.Category_20IntegralDLR);
			else
				self.updateBookingForColourCode(_bookingSummaryDict, 
												_slotRequest,
												CMIF_VoyageBookingSummary.TYPE_MOVE,
												CMIF_VoyageBookingSummary.Category_20GeneralDLR);
			endif;
		endif;
 	endif;
	
	
	if _slotRequest.getAttrEmpty() then
		self.updateBookingForColourCode(_bookingSummaryDict,
										_slotRequest,
										CMIF_VoyageBookingSummary.TYPE_ISO,
										CMIF_VoyageBookingSummary.Category_TotalEmpties);	
		if is40 then
			self.updateBookingForColourCode(_bookingSummaryDict,
											_slotRequest,
											CMIF_VoyageBookingSummary.TYPE_ISO,
											CMIF_VoyageBookingSummary.Category_40MT);	
		else
			self.updateBookingForColourCode(_bookingSummaryDict, 
											_slotRequest,
											CMIF_VoyageBookingSummary.TYPE_ISO,
											CMIF_VoyageBookingSummary.Category_20MT);	
		endif;
		// We don't want to add to general totals below so...
		return;
	endif;
	
	if _slotRequest.getAttrPowerRequired() or _slotRequest.getAttrWaterCooled() then //integ
		self.updateBookingForColourCode(_bookingSummaryDict, 
										_slotRequest,
										CMIF_VoyageBookingSummary.TYPE_ISO,
										CMIF_VoyageBookingSummary.Category_TotalIntegral);
		if is40 then
			self.updateBookingForColourCode(_bookingSummaryDict, 
											_slotRequest,
											CMIF_VoyageBookingSummary.TYPE_ISO,
											CMIF_VoyageBookingSummary.Category_40Integral);
		else
			self.updateBookingForColourCode(_bookingSummaryDict, 
											_slotRequest,
											CMIF_VoyageBookingSummary.TYPE_ISO,
											CMIF_VoyageBookingSummary.Category_20Integral);
		endif;
	else
		self.updateBookingForColourCode(_bookingSummaryDict, 
										_slotRequest, 
										CMIF_VoyageBookingSummary.TYPE_ISO,
										CMIF_VoyageBookingSummary.Category_TotalGeneral);
		if is40 then
			self.updateBookingForColourCode(_bookingSummaryDict, 
											_slotRequest, 
											CMIF_VoyageBookingSummary.TYPE_ISO,
											CMIF_VoyageBookingSummary.Category_40General);
		else
			self.updateBookingForColourCode(_bookingSummaryDict, 
											_slotRequest, 
											CMIF_VoyageBookingSummary.TYPE_ISO,
											CMIF_VoyageBookingSummary.Category_20General);
		endif;
	endif;
	
end;</source>
        <Parameter name="_bookingSummaryDict" type="CMIF_BookingByPortCommCodeDict" usage="input"/>
        <Parameter name="_slotRequest" type="CM_SlotRequest"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="updateBookingForActual" id="0e061d4d-8092-4d0f-8846-23e79e144313">
        <source>updateBookingForActual(_bookingSummaryDict : CMIF_BookingByPortCommCodeDict input;
						_ti : CM_TrackedItem;
						_categoryType : Integer;
						_categoryStr : String);
// ---------------------------------------------------------------------------
// Created:     08 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	bookingSummary		: CMIF_VoyageBookingSummary;
	disPortCode			: String;	
begin	
	if _ti.dischargePort = null then
		disPortCode := CMIF_VoyageBookingSummary.NOPORTCODE;
	else
		disPortCode := _ti.dischargePort.trimBlanks;
	endif;
	
	bookingSummary := _bookingSummaryDict[_categoryType, _categoryStr, disPortCode];
	if bookingSummary = null then
		create bookingSummary transient;
		bookingSummary.categoryType := _categoryType;
		bookingSummary.categoryCode := _categoryStr;
		bookingSummary.loadPort := disPortCode.toUpper;
		_bookingSummaryDict.add(bookingSummary);
	endif;	
	
	bookingSummary.actuallyLoadedCount := bookingSummary.actuallyLoadedCount + 1;
	/*
	bookingSummary := _bookingSummaryDict[_categoryType, _categoryStr, CMIF_VoyageBookingSummary.Port_PortTotal];
	if bookingSummary = null then
		create bookingSummary transient;
		bookingSummary.categoryType := _categoryType;
		bookingSummary.categoryCode := _categoryStr;
		bookingSummary.loadPort := CMIF_VoyageBookingSummary.Port_PortTotal;
		_bookingSummaryDict.add(bookingSummary);
	endif;

	bookingSummary.actuallyLoadedCount := bookingSummary.actuallyLoadedCount + 1;
	*/	

end;</source>
        <Parameter name="_bookingSummaryDict" type="CMIF_BookingByPortCommCodeDict" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_categoryType" type="Integer"/>
        <Parameter name="_categoryStr" type="String"/>
    </JadeMethod>
    <JadeMethod name="updateBookingForColourCode" id="985bca66-5fbb-49b5-b0ec-8a52c77b9e8e">
        <source>updateBookingForColourCode(_bookingSummaryDict : CMIF_BookingByPortCommCodeDict input;
						_slotRquest : CM_SlotRequest;
						_categoryType : Integer;
						_categoryStr : String);
// ---------------------------------------------------------------------------
// Created:     08 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	bookingSummary		: CMIF_VoyageBookingSummary;
	disPortCode		: String;
begin
	if _slotRquest.dischargePort = null then
		disPortCode := CMIF_VoyageBookingSummary.NOPORTCODE;
	else
		disPortCode := _slotRquest.dischargePort.trimBlanks;
	endif;
	
	bookingSummary := _bookingSummaryDict[_categoryType, _categoryStr, disPortCode];
	if bookingSummary = null then
		create bookingSummary transient;
		bookingSummary.categoryType := _categoryType;
		bookingSummary.categoryCode := _categoryStr;
		bookingSummary.loadPort := disPortCode;
		_bookingSummaryDict.add(bookingSummary);
	endif;	
	
	bookingSummary.colourCodeCount := bookingSummary.colourCodeCount + 1;
	/*
	bookingSummary := _bookingSummaryDict[_categoryType, _categoryStr, CMIF_VoyageBookingSummary.Port_PortTotal];
	if bookingSummary = null then
		create bookingSummary transient;
		bookingSummary.categoryType := _categoryType;
		bookingSummary.categoryCode := _categoryStr;
		bookingSummary.loadPort := CMIF_VoyageBookingSummary.Port_PortTotal;
		_bookingSummaryDict.add(bookingSummary);
	endif;
		
	bookingSummary.actuallyLoadedCount := bookingSummary.actuallyLoadedCount + 1;
	*/
end;</source>
        <Parameter name="_bookingSummaryDict" type="CMIF_BookingByPortCommCodeDict" usage="input"/>
        <Parameter name="_slotRquest" type="CM_SlotRequest"/>
        <Parameter name="_categoryType" type="Integer"/>
        <Parameter name="_categoryStr" type="String"/>
    </JadeMethod>
</Class>
