/*
Purpose:			

Date		Who		Reason
15 August 2022	navab1	TFS 53105
16 August 2022	navak20	TFS ChangeRequest 54441: EUP - Additional Field - Country of Origin
*/

vars

begin
	if set then
		global.setExtraData(self.allExtraData, self, MyCountryOfOrigin, _value);
	else
		global.getExtraData(self.allExtraData, MyCountryOfOrigin, _value);
	endif;

epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_Country" usage="io"/>
