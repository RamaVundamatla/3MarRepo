    <JadeMethod name="doDataTableDblClick" id="be816dad-dff9-4135-adad-dd10fdeb1031">
        <updating/>
        <source>doDataTableDblClick(_table : CM_DataTable) updating;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 07 August 2007
//
//----------------------------------------------------------------------

vars
	obj : Object;
	wle : CM_WorkListEntry;
	ti : CM_TrackedItem;
	tiArray : ObjectArray;
begin
	if _table = null then
		return;
	endif;


	if self.myCurrentWLE = null then
		return;
		//app.raiseUnexpectedProgramError(self.class.name, method.name, 'self.myCurrentWLE is null');
	endif;
	
	if _table.allSelectedObjects.size &gt; 1 then
		create tiArray transient;
		foreach obj in _table.allSelectedObjects do
			wle := obj.CM_WorkListEntry;
			if wle.myTrackedItem &lt;&gt; null then
				tiArray.add(wle.myTrackedItem);
			endif;
		endforeach;
		self.myAssistant.showCargoEnquiryForTIs(tiArray.first.CM_TrackedItem, tiArray, self.myMasterMenuAction, false);									//+cnwml2 PAR19782 CCMS SFW 1079
	else
		if self.myCurrentWLE.myRequest.isKindOf(CM_ReceivalRequest) then																// cnwjk3 ccms 1071 25/02/10
			self.myAssistant.showCargoEnquiryFormForRcvlReq(self.myCurrentWLE.myRequest.CM_ReceivalRequest, self.myMasterMenuAction);	// cnwjk3 ccms 1071 25/02/10	
		elseif self.myCurrentWLE.myTrackedItem &lt;&gt; null then
			self.myAssistant.showCargoEnquiry(self.myCurrentWLE.myTrackedItem);
		endif;
	endif;
epilog
	delete tiArray;
end;</source>
        <Parameter name="_table" type="CM_DataTable"/>
    </JadeMethod>
