    <JadeMethod name="setJob_Attachments" id="d731ed3e-712c-4e56-9bfa-c60b28c75f86">
        <updating/>
        <source>setJob_Attachments(_receival : CMGTE_Receival input) updating;
// ---------------------------------------------------------------------------
// Created:     13 August 2008 by cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	realAttach, pxyAttach : CMGTE_Receival;
	tmpID : String;
	idx, sizeObjs : Integer;
	pxyTI, tmpTI : CM_TrackedItem;
	theChassisMaster : CM_TIMasterTILC;
	theChassis : CM_TILC;
	theContainerMaster : CM_TIMasterContainer;
begin

	if self.allAttachmentIDs.isEmpty() then
		return;
	endif;
	sizeObjs := self.allAttachmentsReal.size;
	
	foreach tmpID in self.allAttachmentIDs do
		idx := idx + 1;
		// ### DETAIL RECEIVE FLAT RACKS or CHASSIS
		if tmpID &lt;&gt; null then
			if sizeObjs &gt;= idx then
				realAttach := self.allAttachmentsReal[idx].CMGTE_Receival;
				pxyAttach := realAttach.pxyGetProxyObject();
				if pxyAttach = null then
					pxyAttach :=  app.createUpdateProxy(realAttach).CMGTE_Receival; // UPDATE
				endif;
			else
				create pxyAttach as _receival.class transient ;
			endif;
			if _receival.isKindOf(CMGTE_Container) then
				self.id := tmpID; // LEAVE
			else
				self.chassisID := tmpID; // LEAVE
			endif;
			pxyAttach.setPXYFromController(self);
			pxyAttach.setParentObject(_receival);
		endif;
	
	endforeach;
end;</source>
        <Parameter name="_receival" type="CMGTE_Receival" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setNullReeferDetails" id="fbc7973d-6d20-40af-8695-c312d4c14f4f">
