    <JadeMethod name="valTrackedItemAttachment" id="765c206f-af61-417b-a5fc-dc5aa80aaabc">
        <updating/>
        <source>valTrackedItemAttachment(_attachment : Object input; _passport : CM_Passport input) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 September 2009	cnwdap1	Initial creation
*/
vars
	receival	: CMGTE_Receival;
	prenote		: CMIF_Receival;
	status		: Integer;

begin
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	_passport.initialiseTransaction();

	if _attachment.isKindOf(CMGTE_Receival) then
		receival := _attachment.CMGTE_Receival;
		receival.validateForAttachment(_passport);
		
	elseif _attachment.isKindOf(CMIF_Receival) then
		prenote := _attachment.CMIF_Receival;
		prenote.validateForAttachment(_passport);
	
	endif;
	
	self.checkValidationWithPassport(_passport);
	if _passport.warningsAcknowledged or not _passport.hasErrorsOrWarnings then
		status := TRXStatus_Committed;
	else
		status := TRXStatus_WarningsToBeAck;
	endif;
	
epilog
	_passport.finaliseTransaction(status);
end;</source>
        <Parameter name="_attachment" type="Object" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="valTrackedItems" id="e64eb05a-6bcd-406a-b7c3-73c3103f2e90">
        <source>valTrackedItems(_controller : CMIF_TIUpdateController input; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     14 February 2001 by cnwdwq1
// ---------------------------------------------------------------------------
//08 Oct 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// 19 Nov 2025 navhl20 Bug MTN-36492: TPA - Overall System Slowness
constants
	ProgressBarRefresh	: Integer = 2000;	
vars
	proxyTI					: CM_TrackedItem;
	updateProgress			: Boolean;
	count, total			: Integer;
	progressInt				: TimeStampInterval;
	progressTS 				: TimeStamp;
begin
	progressTS := app.actualTimeAppServer();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support	//19.11.2025 navhl20 #36492
	//-------------------
	//Validate the tracked Item
	//-------------------
	updateProgress 	:= _passport.myCMIFMonitor &lt;&gt; null;
	total 		:= _controller.allTransientTIs.size;
		
	foreach proxyTI in _controller.allTransientTIs do		
		proxyTI.validateTrackedItem(_controller, _passport);
		
		count := count + 1;
	
		progressInt := app.actualTimeAppServer() - progressTS;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support	//19.11.2025 navhl20 #36492
		if updateProgress and ((progressInt.getMilliseconds &gt;= ProgressBarRefresh) or (count = total)) then
			_passport.myCMIFMonitor.updateProgress("Validating Cargo " &amp; count.String &amp; "/" &amp; total.String, total, count);
			progressTS := app.actualTimeAppServer();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support	//19.11.2025 navhl20 #36492
		endif;
	endforeach;	
	
	if _passport.noErrors() then
		_controller.setIsValidated(true);
	endif;
end;</source>
        <Parameter name="_controller" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
