    <JadeMethod name="enableEditControls" id="6ea1942b-9bd5-4bec-9dbd-f7bf0b5d5bbf">
        <source>enableEditControls(_enable: Boolean);
//----------------------------------------------------------------
//	Created:	19 April 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	
	inheritMethod(_enable);

	self.myCmbCargoType.enabled 	:= _enable;
	self.myCmbHatch.enabled 		:= _enable;
	self.myCmbProduct.enabled 		:= _enable;
	self.myTblProductDtls.userInputEnabled	:= _enable;
	self.myTxtDescription.enabled 	:= _enable;
	self.myTxtID.enabled			:= _enable;
	self.myTxtMarks.enabled 		:= _enable;
	self.myTxtMarksNo.enabled 		:= _enable;
	self.myTxtPurchaseOrder.enabled	:= _enable;
	//self.myTxtQuantity.enabled 		:= _enable;
	self.myTxtRemarks.enabled 		:= _enable;
	//self.myTxtVolume.enabled 		:= _enable;
	//self.myTxtWeight.enabled 		:= _enable;

end;</source>
        <Parameter name="_enable" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getInputFrameCaption" id="4ce4347a-1926-453b-a5e8-7bcaf5baef12">
        <source>getInputFrameCaption(): String;
//----------------------------------------------------------------
//	Created:	19 April 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	tmpTI	: CM_TrackedItem;
begin

	if self.myCMIFAttach &lt;&gt; null then
		tmpTI := self.myCMIFAttach.myProxyTrackedItem;
	endif;
	
	if tmpTI &lt;&gt; null
	and not tmpTI.site = TI_SITE_ONSHIP then
		return self.FRAME_CAPTION_OFFSET &amp; self.INPUT_FRAME_CAPTION &amp; DESCRIPTION_SEPARATOR &amp; "*" &amp; tmpTI.getDisplaySiteForReports.toUpper &amp; "*";
	else
		return self.FRAME_CAPTION_OFFSET &amp; self.INPUT_FRAME_CAPTION;
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getShortDesc" id="bd4e8cc5-c63c-444d-b5c4-5bc651a7f5a3">
        <source>getShortDesc(): String;
//----------------------------------------------------------------
//	Created:	07 April 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	siteString		: String;
begin

	if self.myCMIFAttach &lt;&gt; null
	and self.myCMIFAttach.myProxyTrackedItem &lt;&gt; null then
		siteString := self.myCMIFAttach.myProxyTrackedItem.getDisplaySiteForReports();
	endif;

	return	self.FRAME_CAPTION_OFFSET &amp;
			self.myTxtID.text &amp; DESCRIPTION_SEPARATOR &amp;
			self.myCmbCargoType.text &amp; DESCRIPTION_SEPARATOR &amp;
			self.myCmbProduct.text &amp; DESCRIPTION_SEPARATOR &amp;
			"Qty. " &amp; self.myTblProductDtls.getValueByName(ETRow_Pieces).String &amp; 
			//self.myTxtQuantity.text &amp; DESCRIPTION_SEPARATOR &amp;
			siteString;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleComboLostFocus" id="fa55ebf7-62c0-4f9e-8b01-b037e7f412ce">
        <source>handleComboLostFocus(_cmb: CMUI_ComboBox);
//----------------------------------------------------------------
//	Created:	07 April 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	inheritMethod(_cmb);

	if _cmb = self.myCmbCargoType then
		self.setProductCombo();	
	endif;

end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox"/>
    </JadeMethod>
    <JadeMethod name="handleFormKeyDown" id="86ef3bfb-c383-484e-a292-b3b67e537b0e">
        <source>handleFormKeyDown(_activeControl : Control input; keyCode: Integer io; shift: Integer);
// ---------------------------------------------------------------------------
// Created:     17 May 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin


	self.myTblProductDtls.handleFormTab(keyCode, shift, self.myTxtDescription, self.myCmbHatch);

end;</source>
        <Parameter name="_activeControl" type="Control" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="isDisabled" id="a15dd5f1-fe55-4f68-a2e5-33190682581c">
        <source>isDisabled(): Boolean;
//----------------------------------------------------------------
//	Created:	19 April 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	if self.myTxtID.enabled then
		return false;
	else
		return true;
	endif;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="saveToCMIF" id="17abf5fd-2db8-4546-be94-acab43ab573d">
        <source>saveToCMIF(_cmifAttach : CMIF_InOutAttachment input);
// ---------------------------------------------------------------------------
// Created:     10 April 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpProduct	: CM_Product;
	tmpTblProdDetails : CM_EntryTable;
begin
	if self.isDisabled then
		return;
	endif;

	tmpProduct	:= self.myCmbProduct.listObject.CM_Product;
	tmpTblProdDetails := self.myTblProductDtls;
	
	_cmifAttach.id 				:= self.myTxtID.text;
	if self.myCmbCargoType.listObject &lt;&gt; null then
		_cmifAttach.cargoType		:= self.myCmbCargoType.listObject.CM_CargoType.type;
	endif;
	_cmifAttach.myLocationsController	:= self.myCmbHatch.listObject.CM_LocationsController;
	_cmifAttach.myProduct		:= self.myCmbProduct.listObject.CM_Product;

	_cmifAttach.description		:= self.myTxtDescription.text;
	_cmifAttach.mark			:= self.myTxtMarks.text;
	_cmifAttach.markNumber		:= self.myTxtMarksNo.text;
	_cmifAttach.purchaseOrder	:= self.myTxtPurchaseOrder.text;
	_cmifAttach.remarks			:= self.myTxtRemarks.text;

	//_cmifAttach.quantity		:= self.myTxtQuantity.text.Integer;
	//_cmifAttach.volume			:= self.myTxtVolume.text.Real;

	//Get the values from the product details table.  Row visibility is dependant on Cargo type and 
	//product type so assume we need all of them and let the BOL validation part make that call.
	_cmifAttach.lengthString 	:= tmpTblProdDetails.getValueByName(ETRow_LengthString).String;
	_cmifAttach.widthString		:= tmpTblProdDetails.getValueByName(ETRow_WidthString).String;
	_cmifAttach.heightString	:= tmpTblProdDetails.getValueByName(ETRow_HeightString).String;
	//th2 added 19/03/2007 - wtf!? - ANY numeric product attribute can have a multiplier!!  ALWAYS divide for input and multiply for output
	if tmpProduct = null then
		_cmifAttach.quantity	:= tmpTblProdDetails.getValueByName(ETRow_Pieces).Integer;
		_cmifAttach.length		:= tmpTblProdDetails.getValueByName(ETRow_Length).Decimal; //30.1.09 cnwrd1 par #18821 
		_cmifAttach.width		:= tmpTblProdDetails.getValueByName(ETRow_Width).Decimal; //30.1.09 cnwrd1 par #18821 
		_cmifAttach.height		:= tmpTblProdDetails.getValueByName(ETRow_Height).Decimal; //30.1.09 cnwrd1 par #18821 
		_cmifAttach.density		:= tmpTblProdDetails.getValueByName(ETRow_Density).Decimal;	// ### TFS 52193 22Nov2021 NAVPW1
		_cmifAttach.volume		:= tmpTblProdDetails.getValueByName(ETRow_Volume).Decimal;
		//_cmifAttach.weight		:= tmpTblProdDetails.getValueByName(ETRow_Weight).Decimal; //ccms 1060 cnwrd1 12.1.09				//-cnwml2 MSL CCMS 1017
		_cmifAttach.weight		:= tmpTblProdDetails.getValueByName(ETRow_TotalWeight).Decimal;											//+cnwml2 MSL CCMS 1017
	else
		_cmifAttach.quantity	:= tmpProduct.myQuantity.divideValue(tmpTblProdDetails.getValueByName(ETRow_Pieces).Decimal).Integer;
		_cmifAttach.length		:= tmpProduct.getLengthValueFromDisplay(tmpTblProdDetails.getValueByName(ETRow_Length).Decimal).Decimal; //30.1.09 cnwrd1 par #18821 
		_cmifAttach.width		:= tmpProduct.getWidthValueFromDisplay(tmpTblProdDetails.getValueByName(ETRow_Width).Decimal).Decimal; //30.1.09 cnwrd1 par #18821 
		_cmifAttach.height		:= tmpProduct.getHeightValueFromDisplay(tmpTblProdDetails.getValueByName(ETRow_Height).Decimal).Decimal; //30.1.09 cnwrd1 par #18821 
		_cmifAttach.density		:= tmpProduct.myDensityDec.divideValue(tmpTblProdDetails.getValueByName(ETRow_Density).Decimal).Decimal;	// ### TFS 52193 22Nov2021 NAVPW1
		_cmifAttach.volume		:= tmpProduct.myVolume.divideValue(tmpTblProdDetails.getValueByName(ETRow_Volume).Decimal).Decimal;
		//_cmifAttach.weight 		:= tmpProduct.getWeightValueFromDisplay(tmpTblProdDetails.getValueByName(ETRow_Weight).Decimal).Decimal; //30.1.09 cnwrd1 par #18821 			//-cnwml2 MSL CCMS 1017
		_cmifAttach.weight		:= tmpProduct.getWeightValueFromDisplay(tmpTblProdDetails.getValueByName(ETRow_TotalWeight).Decimal).Decimal;										//+cnwml2 MSL CCMS 1017
	endif;
	
	// Also set base values

	_cmifAttach.state 			:= TI_STATE_ONSHIP;
	_cmifAttach.bolType			:= BOLType_GeneralBillOfLading;
	_cmifAttach.myTerminal 		:= self.myForm.myTerminal;
	_cmifAttach.voyageCode 		:= self.myForm.myCurrentVoyage.code;
	_cmifAttach.imExStatus 		:= TI_IMEX_STATUS_IMPORT;
	
	if self.myForm.cmbLoadPort.myObject &lt;&gt; null then
		_cmifAttach.loadPortCode	:= self.myForm.cmbLoadPort.myObject.CM_Port.code;
	endif;
	
	if self.myForm.cmbOperator.myObject &lt;&gt; null then
		_cmifAttach.operatorCode 	:= self.myForm.cmbOperator.myObject.CM_Operator.code;
	endif;


epilog

end;</source>
        <Parameter name="_cmifAttach" type="CMIF_InOutAttachment" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setCntrlDefaults" id="c08910e7-9dad-4d20-ba39-f4b5dbdb52f9">
        <source>setCntrlDefaults() protected;
//-----------------------------------------------------------------------
//	Created:	05 April 2006	by Jason Chapman  (cnwjc2)
//-----------------------------------------------------------------------
vars

begin
	inheritMethod();

	if self.isInPainter then
		return;
	endif;
	
	self.picClosed.borderStyle	:= Picture.BorderStyle_None;
	self.picOpen.borderStyle	:= Picture.BorderStyle_None;
	

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setControlsFromRowFrame" id="e021e022-10eb-45e4-85ed-22b0feb864b1">
        <source>setControlsFromRowFrame(_rowFrame: CMUI_RowFrameGCBOLItem);
//----------------------------------------------------------------
//	Created:	18 April 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	tmpCargoType	: CM_CargoType;
	tmpRowFrame		: CMUI_RowFrameGCBOLItem;
begin
	tmpRowFrame := _rowFrame;

	inheritMethod(tmpRowFrame);
	

	tmpCargoType := tmpRowFrame.myCmbCargoType.listObject.CM_CargoType;
	self.myCmbCargoType.listObject := tmpCargoType;

	if CM_GeneralCargoController.hasInstance(tmpRowFrame.myCmbHatch.listObject) then
		self.myCmbHatch.listObject := tmpRowFrame.myCmbHatch.listObject;
	endif;
	
	self.myCmbProduct.setCargoType(tmpCargoType);
	self.myCmbProduct.setObject(tmpRowFrame.myCmbProduct.listObject.CM_Product);
	
	self.myTxtDescription.text := tmpRowFrame.myTxtDescription.text;
	self.myTxtID.text := tmpRowFrame.myTxtID.text;
	self.myTxtMarks.text := tmpRowFrame.myTxtMarks.text;
	self.myTxtMarksNo.text := tmpRowFrame.myTxtMarksNo.text;
	self.myTxtPurchaseOrder.text := tmpRowFrame.myTxtPurchaseOrder.text;
	self.myTxtRemarks.text := tmpRowFrame.myTxtRemarks.text;
	//th2 PAR 13656 - pre-populate product defaults if any
	self.myCmbProduct.click(self.myCmbProduct);
	
end;</source>
        <Parameter name="_rowFrame" type="CMUI_RowFrameGCBOLItem"/>
    </JadeMethod>
    <JadeMethod name="setDetailsForProduct" id="5a7b07e3-6147-439e-a14a-55da6cc2bd17">
        <source>setDetailsForProduct();
// ---------------------------------------------------------------------------
// Created:     08 May 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpCargoType	: CM_CargoType; 
	tmpProduct	: CM_Product;
	obj			: Object;
	entRow		: EntTableRowTransient;
	prodAttr	: CM_ProductAttr;
	attrStr		: String;
	idx			: Integer;
	tbl			: CM_EntryTable;
begin

	tbl := self.myTblProductDtls;
	//if app.getMyUserCode = 'CNWSH3' then
	//	process.debug;
	//endif;	
	tmpCargoType := self.myCmbCargoType.listObject.CM_CargoType;
	tmpProduct := self.myCmbProduct.listObject.CM_Product;
	// cnwrs1 dec 2006 no point in continuing if there is no product
	if tmpProduct = null then
		return;
	endif;
	foreach obj in self.myTblProductDtls.allEntRowTransients do
		entRow := obj.EntTableRowTransient;
		prodAttr := tmpProduct.getProdAttrFromName(entRow.name);
		if prodAttr = null then
			continue;
		endif;
		attrStr := entRow.name;
		if tmpCargoType.allAttributesOnProduct.includes(prodAttr.name) and prodAttr.isViewable then
			
			idx := tbl.showRowByName(attrStr, false);
			tbl.setCellText(idx, tbl.ColumnHeading, prodAttr.displayName);
			
			if prodAttr.validationType = prodAttr.ValidationType_Codes then
				if attrStr = ETRow_WidthString then
					tbl.accessCell(idx, tbl.ColumnValue).cellControl := self.myCmbWidthCodes;
				elseif attrStr = ETRow_HeightString then
					tbl.accessCell(idx, tbl.ColumnValue).cellControl := self.myCmbHeightCodes;				
				elseif attrStr = ETRow_LengthString then
					tbl.accessCell(idx, tbl.ColumnValue).cellControl := self.myCmbLengthCodes;				
				elseif attrStr = ETRow_Type then
					tbl.accessCell(idx, tbl.ColumnValue).cellControl := self.myCmbTypeCodes;
				endif;	
			endif;
			//th2 noticed and fixed 10/12/2006 - should be setting the product default value
			if prodAttr.myType = Integer then
				tbl.accessCell(idx, tbl.ColumnValue).inputType := Table.InputType_TextNumeric;
				if prodAttr.CM_ProdAttrInteger.multiplier &lt;&gt; 1 then
					tbl.accessedCell.decimals := 4;
				else
					tbl.accessedCell.decimals := 0;
				endif;
			elseif prodAttr.myType = Decimal then
				tbl.accessCell(idx, tbl.ColumnValue).inputType := Table.InputType_TextNumeric;
				tbl.accessedCell.decimals := 4;
			endif;
			
			tbl.setCellText(idx, tbl.ColumnValue, prodAttr.getDisplayValueString);
		else
			tbl.hideRowByName(attrStr, false);
		endif;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="8f5c53c0-80fd-454c-b25b-79293de9fa5d">
        <updating/>
        <source>setForUpdate(_cmifAttach: CMIF_InOutAttachment) updating;
//----------------------------------------------------------------
//	Created:	07 April 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	tmpTI		: CM_TrackedItem;
	disableEdit	: Boolean;
	lc			: CM_LocationsController;
	enableHatch	: Boolean;
	result		: Decimal[22,4];
//	idx			: Integer;
begin
	
	self.myCMIFAttach	:= _cmifAttach;
	
	tmpTI := _cmifAttach.myProxyTrackedItem;
	
	if tmpTI = null then
		return;
	endif;

	disableEdit := tmpTI.site &lt;&gt; TI_SITE_ONSHIP;
	
	self.myCmbCargoType.listObject := tmpTI.myCargoType;
	
	//self.myCmbCargoType.listIndex	:=	self.myCmbCargoType.findObject(tmpTI.myCargoType);
	
	//if tmpTI.myCargoType &lt;&gt; null then
	//	self.myCmbCargoType.cnEcSetTextIndex(tmpTI.myCargoType.description);
	//endif;

	lc := _cmifAttach.myLocationsController;
	
	if lc &lt;&gt; null
	and CM_GeneralCargoController.hasInstance(lc)
	then
		enableHatch := true;
		
		if self.myCmbHatch.findObject(lc) &gt; 0 then
			self.myCmbHatch.listObject := lc;//_cmifAttach.myLocationsController;//tmpTI.myPrimaryActualLocation;
		else
			//what?
// cnwdad1 22/10/2008 - PAR #18235.  Cannot add an entry becuase combobox is using a listCollection.
//			idx := self.myCmbHatch.addItem(lc.getID);
//			self.myCmbHatch.itemObject[idx] := lc;
//			self.myCmbHatch.listObject := lc;
			self.myCmbHatch.cnEcSetTextIndex(lc.getID());
		endif;
	else
		enableHatch := false;
	endif;
	
	self.myCmbProduct.setCargoType(tmpTI.myCargoType);
	self.myCmbProduct.setObject(tmpTI.myProduct);
	
	self.setDetailsForProduct();
	
	self.myTxtDescription.text := tmpTI.description;
	self.myTxtID.text := tmpTI.id;
	self.myTxtMarks.text := tmpTI.mark;
	self.myTxtMarksNo.text := tmpTI.markNumber;
	self.myTxtPurchaseOrder.text := tmpTI.purchaseOrder;
	self.myTxtRemarks.text := tmpTI.remarks;
	
	if tmpTI.myProduct &lt;&gt; null and tmpTI.myProduct.myQuantity.multiplier &lt;&gt; 1 then
		result := tmpTI.myProduct.myQuantity.multiplyValue(tmpTI.quantity);
		if result mod 1 = 0 then
			self.myTblProductDtls.setValueByName(ETRow_Pieces, result.Integer);
		else
			self.myTblProductDtls.setValueByName(ETRow_Pieces, result);
		endif;
	else
		self.myTblProductDtls.setValueByName(ETRow_Pieces, tmpTI.quantity);
	endif;
	
	if tmpTI.myProduct &lt;&gt; null and tmpTI.myProduct.getMyLengthMultiplier() &lt;&gt; 1 then //02.2.09 cnwrd1 par #18821 
		result := tmpTI.myProduct.getMyLengthDisplayValue(tmpTI.length); //02.2.09 cnwrd1 par #18821 
		if result mod 1 = 0 then
			self.myTblProductDtls.setValueByName(ETRow_Length, result.Integer);
		else
			self.myTblProductDtls.setValueByName(ETRow_Length, result);
		endif;
	else
		self.myTblProductDtls.setValueByName(ETRow_Length, tmpTI.length);
	endif;
	
	if tmpTI.myProduct &lt;&gt; null and tmpTI.myProduct.getMyWidthMultiplier() &lt;&gt; 1 then //02.2.09 cnwrd1 par #18821 
		result := tmpTI.myProduct.getMyWidthDisplayValue(tmpTI.width); //02.2.09 cnwrd1 par #18821 
		if result mod 1 = 0 then
			self.myTblProductDtls.setValueByName(ETRow_Width, result.Integer);
		else
			self.myTblProductDtls.setValueByName(ETRow_Width, result);
		endif;
	else
		self.myTblProductDtls.setValueByName(ETRow_Width, tmpTI.width);
	endif;
	
	if tmpTI.myProduct &lt;&gt; null and tmpTI.myProduct.getMyHeightMultiplier() &lt;&gt; 1 then //02.2.09 cnwrd1 par #18821 
		result := tmpTI.myProduct.getMyHeightDisplayValue(tmpTI.height); //02.2.09 cnwrd1 par #18821 
		if result mod 1 = 0 then
			self.myTblProductDtls.setValueByName(ETRow_Height, result.Integer);
		else
			self.myTblProductDtls.setValueByName(ETRow_Height, result);
		endif;
	else
		self.myTblProductDtls.setValueByName(ETRow_Height, tmpTI.height);
	endif;
	
	if tmpTI.myProduct &lt;&gt; null and tmpTI.myProduct.myVolume.multiplier &lt;&gt; 1 then
		result := tmpTI.myProduct.myVolume.multiplyValue(tmpTI.getMyTotalVolume);
		if result mod 1 = 0 then
			self.myTblProductDtls.setValueByName(ETRow_Volume, result.Integer);
		else
			self.myTblProductDtls.setValueByName(ETRow_Volume, result);
		endif;
	else
		self.myTblProductDtls.setValueByName(ETRow_Volume, tmpTI.getMyTotalVolume);
	endif;
	 
	if tmpTI.myProduct &lt;&gt; null and tmpTI.myProduct.getMyWeightMultiplier() &lt;&gt; 1 then //02.2.09 cnwrd1 par #18821 
		//result := tmpTI.myProduct.getMyWeightDisplayValue(tmpTI.weight); //02.2.09 cnwrd1 par #18821 				//-cnwml2 MSL CCMS 1017
		result := tmpTI.myProduct.getMyWeightDisplayValue(tmpTI.totalWeight);										//+cnwml2 MSL CCMS 1017
		if result mod 1 = 0 then 
			//self.myTblProductDtls.setValueByName(ETRow_Weight, result.Integer);									//-cnwml2 MSL CCMS 1017
			self.myTblProductDtls.setValueByName(ETRow_TotalWeight, result.Integer);								//+cnwml2 MSL CCMS 1017
		else
			//self.myTblProductDtls.setValueByName(ETRow_Weight, result);											//-cnwml2 MSL CCMS 1017
			self.myTblProductDtls.setValueByName(ETRow_TotalWeight, result);										//+cnwml2 MSL CCMS 1017
		endif;
	else
		//self.myTblProductDtls.setValueByName(ETRow_Weight, tmpTI.weight);											//-cnwml2 MSL CCMS 1017
		self.myTblProductDtls.setValueByName(ETRow_TotalWeight, tmpTI.totalWeight);										//+cnwml2 MSL CCMS 1017
	endif;
	
	//th2 should have always been text attributes here
	if CM_BreakBulkGeneric.hasInstance(tmpTI) then
		self.myTblProductDtls.setValueByName(ETRow_LengthString, tmpTI.CM_BreakBulkGeneric.lengthString);
		self.myTblProductDtls.setValueByName(ETRow_HeightString, tmpTI.CM_BreakBulkGeneric.heightString);
		self.myTblProductDtls.setValueByName(ETRow_WidthString, tmpTI.CM_BreakBulkGeneric.widthString);
	endif;
	
	self.enableEditControls(not disableEdit);
	self.myCmbHatch.enabled := enableHatch;	
end;</source>
        <Parameter name="_cmifAttach" type="CMIF_InOutAttachment"/>
    </JadeMethod>
    <JadeMethod name="setFrameDefaults" id="65bce78b-a6b5-42e9-b9f0-e20b1c7f6580">
        <updating/>
        <source>setFrameDefaults(pFrame: Frame input) updating, protected;
//-----------------------------------------------------------------------
//	Created:	05 April 2006	by Jason Chapman  (cnwjc2)
//-----------------------------------------------------------------------
vars

begin
	inheritMethod(pFrame);

	pFrame.borderStyle		:= self.BorderStyle_None;
	pFrame.autoRedraw 		:= true;


end;</source>
        <access>protected</access>
        <Parameter name="pFrame" type="Frame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProductCombo" id="c97b9ca1-be1c-4a47-8a70-bdf3a8728e6f">
        <source>setProductCombo() protected;
//----------------------------------------------------------------
//	Created:	06 April 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	if self.myCmbCargoType.listObject &lt;&gt; null then
		self.myCmbProduct.setCargoType(self.myCmbCargoType.listObject.CM_CargoType);
	endif;

end;</source>
