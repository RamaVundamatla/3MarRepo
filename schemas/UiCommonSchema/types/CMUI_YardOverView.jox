    <JadeMethod name="translateForm" id="efc50f8f-7dc7-4171-b417-d0b828be0c8e">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0008261, locale);
	btnAddDimension.translateBubbleHelp(Xlat_0001196, locale);
	btnAddDimension.translateCaption(Xlat_0001198, locale);
	btnCancel.translateCaption(Xlat_0001207, locale);
	btnCancelDimensn.translateBubbleHelp(Xlat_0001192, locale);
	btnCancelDimensn.translateCaption(Xlat_0001194, locale);
	btnCargoHeights.translateBubbleHelp(Xlat_0001197, locale);
	btnCargoHeights.translateCaption(Xlat_0001199, locale);
	btnDeleteDim.translateBubbleHelp(Xlat_0001202, locale);
	btnDeleteDim.translateCaption(Xlat_0001208, locale);
	btnDimensions.translateBubbleHelp(Xlat_0001203, locale);
	btnDimensions.translateCaption(Xlat_0001209, locale);
	btnFlipH.translateBubbleHelp(Xlat_0001204, locale);
	btnFlipH.translateCaption(Xlat_0001210, locale);
	btnFlipV.translateBubbleHelp(Xlat_0001205, locale);
	btnFlipV.translateCaption(Xlat_0001211, locale);
	btnRefresh.translateBubbleHelp(Xlat_0001206, locale);
	btnRefresh.translateCaption(Xlat_0001212, locale);
	btnSave.translateCaption(Xlat_0001213, locale);
	btnSaveDimension.translateBubbleHelp(Xlat_0001193, locale);
	btnSaveDimension.translateCaption(Xlat_0001195, locale);
	frmLevelColour.translateCaption(Xlat_0001201, locale);
	mnuArea.translateCaption(Xlat_0008262, locale);
	mnuCargoHeight.translateCaption(Xlat_0008263, locale);
	mnuCargoHeightAll.translateCaption(Xlat_0008264, locale);
	mnuChangeColour.translateCaption(Xlat_0008265, locale);
	mnuContext.translateCaption(Xlat_0008266, locale);
	mnuHideLegend.translateCaption(Xlat_0008267, locale);
	mnuRefresh.translateCaption(Xlat_0008268, locale);
	mnuRestrictions.translateCaption(Xlat_0008269, locale);
	mnuSavePositions.translateCaption(Xlat_0008270, locale);
	mnuZoom.translateCaption(Xlat_0008271, locale);
	mySDF.translateCaption(Xlat_0001214, locale);
	mySDFBackground.translateCaption(Xlat_0001200, locale);
	mySDFTop.translateCaption(Xlat_0001215, locale);
end;</source>
