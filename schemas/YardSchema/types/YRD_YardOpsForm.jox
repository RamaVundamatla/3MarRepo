    <JadeMethod name="getFilteredWLEs" id="2b5a5c92-4afe-4077-a681-9a2ac18b4c2b">
        <source>getFilteredWLEs(_wleFilteredArray: CM_WLEArray input);
// -----------------------------------------------------------------------------
// Created:		22 July 2009 by consw1
//
// Purpose:		Get WLEs for display
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	dependantWLEs : Boolean;
	job : CM_Job;
	wle : CM_WorkListEntry;
	wleArray : CM_WLEArray;
	wleArrayForYard : CM_WLEArray;
	wleSelected : CM_WLESet;
	woDetail : CM_WorkOrderDtl;
	woDetailColl : ObjectSet;
	workOrder : CM_WorkOrder;
	workOrderColl : CM_WorkOrderSet;

begin

	if self.myTerminal.myYardJobSheet = null then	//17 May 2012	NDL	Par 28193
		return;
	endif;
		
	create wleArrayForYard transient;
	self.myTerminal.myYardJobSheet.getAllWLEs(wleArrayForYard);
	
	foreach wle in wleArrayForYard do
		if self.includeWLE(wle) 
		and self.filterJob(wle.job) then
			_wleFilteredArray.add(wle);
		endif;
	endforeach;
	
	//  Include incomplete tasks that are required by the ones selected

	if not self.chkDependantTsks.value then
		return;
	endif;
	
	create woDetailColl transient;
	create workOrderColl transient;
	
	foreach wle in _wleFilteredArray do
		woDetail := wle.getWorkOrderTIDtl();
		if woDetail &lt;&gt; null and not woDetailColl.includes(woDetail) then
			woDetailColl.add(woDetail);
			workOrder := woDetail.myParent;
			if workOrder &lt;&gt; null and not workOrderColl.includes(workOrder) then
				workOrderColl.add(workOrder);
			endif;
		endif;
	endforeach;
	
	create wleArray transient;
	create wleSelected transient;
	_wleFilteredArray.copy(wleSelected);

	foreach workOrder in workOrderColl do
		dependantWLEs := false;
		foreach woDetail in workOrder.allWoDtls reversed, discreteLock where woDetail.isKindOf(CM_WorkOrderTIDtl) do
			if dependantWLEs then
				//  Include incomplete tasks prior to selected ones
				foreach job in woDetail.CM_WorkOrderTIDtl.allJobs where job.status &lt;&gt; JOB_COMPLETE do
					wleArray.clear();
					job.getAllWLEs(wleArray);		
					foreach wle in wleArray where self.includeWLE(wle) and wle.status &lt;&gt; WLE_COMPLETED do
						if not wleSelected.includes(wle) then
							wleSelected.add(wle);
						endif;
					endforeach;
				endforeach;					
			else
				//  Does this Work Order Detail record include a WLE that has been selected for display?
				dependantWLEs := woDetailColl.includes(woDetail);
			endif;
		endforeach;
	endforeach;
	
	_wleFilteredArray.clear();
	foreach wle in wleArrayForYard where wleSelected.includes(wle) do
		_wleFilteredArray.add(wle);
	endforeach;
	
epilog
	delete wleArray;
	delete wleArrayForYard;
	delete wleSelected;
	delete woDetailColl;
	delete workOrderColl;
end;</source>
        <Parameter name="_wleFilteredArray" type="CM_WLEArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getSelectedJobs" id="657ee114-162f-4d4d-8985-d6d1d2245fd9">
        <source>getSelectedJobs(_jobArray : CM_JobArray input);
// -----------------------------------------------------------------------------
// Created:		26 August 2009 by consw1
//
// Purpose:		Get selected Jobs from Jobs Table.
//
// Parameters:	
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	invalidObject : Boolean;
	obj : Object;

begin
	on Exception do app.handleDeletedObject(exception, obj, invalidObject);

	foreach obj in self.tblJobs.allSelectedObjects do
		invalidObject := false;
		if obj = null or not obj.isKindOf(CM_Job) then
			continue;
		endif;
		if not invalidObject then
			_jobArray.add(obj.CM_Job);
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_jobArray" type="CM_JobArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTaskTypeForJob" id="ad973e7f-80f8-4bfa-ba7e-f19df74ace72">
        <source>getTaskTypeForJob(_job : CM_Job) : Object;
// -----------------------------------------------------------------------------
// Created:		25 August 2009 by consw1
//
// Purpose:		Get a reference for the form's Task Type filtering.
//
// Parameters:	
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
// 14/06/2022	navcs2		ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema
// 29/03/2023  navma1		Bug 57384: EUP - Error 1300 when opening Yard Ops Screen
// -----------------------------------------------------------------------------

vars
	
begin
	if _job = null then
		return null;
	endif;
	
	if _job.isKindOf(CM_WOToDoTaskJob) then					
		if _job.CM_WOToDoTaskJob.isToDoForCargoWorkOrder then		//29.03.2023 navma1 #57384		
			return CM_WodToDo;
		else
			return _job.CM_WOToDoTaskJob.myToDoTaskDesc;
		endif;
	elseif _job.isKindOf(CM_YardJob) then
		return CM_WodMove;
	elseif _job.isKindOf(CM_WOPackJob) then
		return CM_WodPack;
	elseif _job.isKindOf(CM_WOUnpackJob) then
		return CM_WodUnpack;
	elseif _job.isKindOf(CM_WOExportReturnedJob) then		 //14.06.2022 navcs2 #53038
		return CM_WodExportReturn;
	elseif _job.isKindOf(CM_WOReceiveCargoJob) then 		//14.06.2022 navcs2 #53038
		return CM_WodReceive;
	elseif _job.isKindOf(CM_WOReleaseCargoJob) then 		//14.06.2022 navcs2 #53038
		return CM_WodRelease;
	elseif _job.isKindOf(CM_WOChangeVoyageJob) then 		//14.06.2022 navcs2 #53038
		return CM_WodNullVoyage;
	endif;
	
	return null;

epilog

end;</source>
        <Parameter name="_job" type="CM_Job"/>
        <ReturnType type="Object"/>
    </JadeMethod>
