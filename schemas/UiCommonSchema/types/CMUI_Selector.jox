// ---------------------------------------------------------------------------
// Created:     22 January 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	
	if self.tblCriteria.sheets = 6 then //arbitry limit - display a warning, don't complain beyond that if they want to be retarded.
		app.msgBox("It is likely at this point that you are unsure about using selector correctly, or at least in an optimal way, if you" &amp; CrLf &amp;
					'require more than a few query sheets. It is recomended that you read the documentation in the JMT users' &amp; CrLf &amp;
					'guide for more information by pressing the F1 key or selecting it from the help menu','Warning - sheet count', MsgBox_Exclamation_Mark_Icon);
	endif;
	
	self.doAddSheet();
	self.createDefaultCriteriaLines();
	self.evaluateUpDown();

end;</source>
