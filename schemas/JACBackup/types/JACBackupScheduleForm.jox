    <JadeMethod name="selectFile" id="f6fd9594-4796-4401-b382-8824d720432e">
        <source>selectFile(_filePath: String output; _fileName: String output);
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
//Allows the user to choose a backup file to run when logs close
vars
	dialog: CMDFileOpen;
	str: String;
	pos: Integer;
begin
	create dialog transient;
	dialog.createPrompt := false;
	dialog.fileMustExist := true;

	if dialog.open = 0 then
		str := dialog.fileName;
		pos := str.pos(dialog.fileTitle.trimBlanks,1);
		str := str[1:pos-2];
		_filePath := str;
		_fileName := dialog.fileTitle;

	else
		_filePath:=null;
		_fileName:=null;
	endif;
epilog
	delete dialog;
end;</source>
        <Parameter name="_filePath" type="String" usage="output"/>
        <Parameter name="_fileName" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="selectFolder" id="d8edcb1b-abef-4e09-b057-3d7a460afa5c">
        <source>selectFolder():String;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	fn: FileFolder;
begin
	create fn transient;
	fn.fileName := fn.browseForFolder("Select Backup Location","");
	return fn.fileName;
epilog
	delete fn;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setValidObjects" id="ffeedc1f-b71a-4a4b-a1cc-41ae6cb5422a">
        <updating/>
        <source>setValidObjects() updating;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.chkSDSLogs.enabled := false;
	self.chkSDSSecondary.enabled := false;
	self.btnBackupAbort.enabled := false;
	self.btnNew.enabled := false;
	self.btnBackupAbort.enabled := false;
	self.btnServerApp.enabled := false;
	self.cbxBackupDays.enabled := false;
	self.chkDBLogs.enabled := false;
	self.chkDebug.enabled := false;
	self.chkLocalLogs.enabled := false;
	self.chkLogCompress.enabled := false;
	self.chkLogVerify.enabled := false;
	self.chkRemoteLogs.enabled := false;
	self.chkSDSSecondary.enabled := false;
	self.label2.enabled := false;
	self.label3.enabled := false;
	self.label5.enabled := false;
	self.label6.enabled := false;
	self.label7.enabled := false;
	self.label8.enabled := false;
	self.label9.enabled := false;
	self.label10.enabled := false;
	self.tbBinaryBackPath.enabled := false;
	self.tbEmailAddress.enabled := false;
	self.tbLocalLogPath.enabled := false;
	self.tbRemoteLogPath.enabled := false;
	self.tbSMTPServer.enabled := false;

	if app.computerName = app.getServerCompName and not app.isSDSSecondaryDB then
		self.btnNew.enabled	:=	true;
		
		if not self.backupRunning and app.jacIsAppRunning(JACBackupServerAppName) then
			self.btnBackupAbort.enabled	:=	true;
		endif;
		
		self.btnServerApp.enabled	:=	true;
		self.cbxBackupDays.enabled	:=	true;
		self.chkDBLogs.enabled		:=	true;
		self.chkDebug.enabled		:=	true;
		self.chkLocalLogs.enabled	:=	true;
		self.chkLogCompress.enabled	:=	true;
		self.chkLogVerify.enabled	:=	true;
		self.chkRemoteLogs.enabled	:=	true;
		
		if app.isSDSDatabase then
			self.chkSDSSecondary.enabled	:=	true;
			chkSDSLogs.enabled				:=	true;
		endif;
		
		self.label2.enabled				:=	true;
		self.label3.enabled				:=	true;
		self.label5.enabled				:=	true;
		self.label6.enabled				:=	true;
		self.label7.enabled				:=	true;
		self.label8.enabled				:=	true;
		self.label9.enabled				:=	true;
		self.label10.enabled			:=	true;
		self.tbBinaryBackPath.enabled	:=	true;
		self.tbEmailAddress.enabled		:=	true;
		self.tbLocalLogPath.enabled		:=	true;
		self.tbRemoteLogPath.enabled	:=	true;
		self.tbSMTPServer.enabled		:=	true;
	else
		if app.computerName = app.getServerCompName then
			self.btnServerApp.enabled	:=	true;
		endif;
	endif;
	
	if app.isSDSSecondaryBackup then
		self.tbBinaryBackPath.text := app.myServerAppObject.binarySecBackupPath;
		self.label10.caption := "Binary Backup Path (SDS):";
		
		if app.computerName = app.getServerCompName then
		endif;
	else
		self.tbBinaryBackPath.text := app.myServerAppObject.binaryBackupPath;
		self.label10.caption := "Binary Backup Path:";
	endif;
	
// cnwdad1 07/08/2006 - The edit form has been changed to only allow updates when appropriate.
	self.btnEdit.enabled	:=	false;
//	self.btnEdit.enabled	:=	true;
	self.btnReset.enabled	:=	false;
	self.btnDel.enabled		:=	false;
	self.caption			:=	"Online Backup Schedule";
	
	if app.isSDSDatabase then
		if app.isSDSSecondaryDB then
			self.caption	:=	self.caption&amp;' (Secondary DB)';
		else
			self.caption	:=	self.caption&amp;' (Primary DB)';
			
			if app.myServerAppObject.secondarySDSIsAlive then
				self.caption	:=	self.caption&amp;' - Secondary ControlApp is running.';
			else
				self.caption	:=	self.caption&amp;' - Secondary ControlApp is not running.';
			endif;
		endif;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="3bf15b15-cd9b-4f27-8ef9-e2c3437daaf1">
