    <JadeMethod name="getEDIFileByManifest" id="7a5ccbf5-e0bf-434e-a4fd-de572f1f6ca0">
        <source>getEDIFileByManifest(_manifest : String; _guid : String; _terminal : CM_Terminal) : CM_EDIFile;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 26 June 2023
TFS#		: 58506
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	manifest 	: String;
	guid 		: String;
	ediFile		: CM_EDIFile;
	iter1		: Iterator;
begin

	manifest	:= _manifest.trimBlanks();
	guid		:= _guid.trimBlanks();
	
	if manifest = null then
		return null;
	endif;
	
	if _terminal.myEdiConfig.allEDIFilesByEdiClientRef.isEmpty then
		return null;
	endif;
	// get the last CM_EDIFile matching the supplied client reference.
	iter1	:= _terminal.myEdiConfig.allEDIFilesByEdiClientRef.createIterator;
	_terminal.myEdiConfig.allEDIFilesByEdiClientRef.startKeyLeq( manifest, iter1 );
	while iter1.back( ediFile ) do 
		if ediFile &lt;&gt; null and ediFile.ediClientRef = manifest and ediFile.guid = guid then
			return ediFile;	
			break;
		endif;
	endwhile;
	
	return null;
epilog
	delete iter1;
end;</source>
        <Parameter name="_manifest" type="String"/>
        <Parameter name="_guid" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="CM_EDIFile"/>
    </JadeMethod>
    <JadeMethod name="getEDIFileByRelRequest" id="fed8293e-2343-4a26-bdda-bb666314d3e1">
        <source>getEDIFileByRelRequest(_relRequestId : String; _terminal : CM_Terminal) : CM_EDIFile;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 24 July 2023
TFS#		: 55938
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	releaseRequestCode 	: String;
	ediFile				: CM_EDIFile;
	iter1				: Iterator;
begin

	releaseRequestCode	:= _relRequestId.trimBlanks();
	
	if releaseRequestCode = null then
		return null;
	endif;
	
	if _terminal.myEdiConfig.allEDIFilesByEdiClientRef.isEmpty then
		return null;
	endif;
	// get the last CM_EDIFile matching the supplied client reference.
	iter1	:= _terminal.myEdiConfig.allEDIFilesByEdiClientRef.createIterator;
	_terminal.myEdiConfig.allEDIFilesByEdiClientRef.startKeyLeq( releaseRequestCode, iter1 );
	while iter1.back( ediFile ) do 
		if ediFile &lt;&gt; null and ediFile.ediClientRef = releaseRequestCode and ediFile.fileStatus = DB_Loaded and ediFile.myEDIFileType &lt;&gt; null and ediFile.myEDIFileType.type = EDIFileType_CallOff then
			return ediFile;	
			break;
		endif;
	endwhile;
	
	return null;
epilog
	delete iter1;
end;</source>
        <Parameter name="_relRequestId" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="CM_EDIFile"/>
    </JadeMethod>
    <JadeMethod name="setFromTI" id="16b992b7-3647-49c2-8d23-6ce6eaa7f3c8">
        <updating/>
        <source>setFromTI(theTI : CM_TrackedItem input; _camAgent : CM_CamControllerAgent input ) updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 22 June 2023
TFS#		: 58506
Function	:

*** Changes ***
Date			Name		TFS#		Description
06/07/2023		navcs2		Bug 59014: FR | 54536 EUP - Damage and Repair Missing or Incorrect Fields in Message
****************************************************/

begin
	self.id := self.generateGUID();
	self.date := app.actualTimeAppServer.localToUTCTime;
	self.receiver := theTI.myOperator.debtor.code; // change to CM_TrackedItem::myOperator.debtor.financialID when exist
	self.sender := theTI.getMyTerminal().code;
	self.status := Status_Create;
	if _camAgent.CM_CamControllerAgent.isRestart then
		self.status := Status_Replace;
	endif;
	self.type := _camAgent.myCurrentCamProtocol.code;	
end;
</source>
        <Parameter name="theTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setFromVehicleBooking" id="08c26c4f-db48-4f3c-9b6c-8fb31ee97401">
        <updating/>
        <source>setFromVehicleBooking(_vehicleBooking : CM_VehicleBookingTimeSlot input; _type : String) updating;
/*
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 June 2023	jlier1	Initial creation 58839

*/

vars

begin
	self.id := self.generateGUID();
	self.date := app.actualTimeAppServer.localToUTCTime;
	self.number := _vehicleBooking.id;
	self.receiver := "TAS";
	self.sender := _vehicleBooking.getMyTerminal().code;
	self.status := Status_Create;
	self.type := _type;
epilog

end;</source>
        <Parameter name="_vehicleBooking" type="CM_VehicleBookingTimeSlot" usage="input"/>
        <Parameter name="_type" type="String"/>
    </JadeMethod>
