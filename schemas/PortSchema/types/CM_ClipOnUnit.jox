    <JadeMethod name="getParent" id="88ed467f-8cf9-49b1-b63c-2ac498bb428e">
        <source>getParent(): CM_TrackedItem;

vars

begin
	if self.myReefer &lt;&gt; null then
		return self.myReefer;
	endif;
	return self.myParent;
end;</source>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getParentLocation" id="6e0c5933-84b4-42fe-af20-65ab377a43a6">
        <source>getParentLocation(): CM_LocationsController;

vars

begin
	if self.myParent &lt;&gt; null then
		return self.myParent.getPrimaryLocation(REAL_MODE);
	elseif self.myReefer &lt;&gt; null then
		return self.myReefer.getPrimaryLocation(REAL_MODE);
	endif;
end;</source>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="getPicture" id="e0e9f36e-de1a-416e-911a-75f3b7a4818e">
        <source>getPicture(): Binary;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	thePicture : Binary;
begin
	
	if not self.myTerminal.getConfig(ShowCargoPicture).Boolean then
		return null;
	endif;

	thePicture := app.myRoot.getConfig(PicCargoCOU).Binary; // DEFAULT

	return thePicture;

end;</source>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="isChild" id="b295e95d-9874-4b5a-a9d0-e3dd1bc226b4">
        <source>isChild(): Boolean;
//AJA 30/4/01: Subclassed to check the myReefer reference
vars

begin
	if self.myReefer &lt;&gt; null then
		return true;
	else
		return inheritMethod();
	endif;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
