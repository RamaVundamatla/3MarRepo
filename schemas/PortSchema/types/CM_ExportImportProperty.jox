    <JadeMethod name="myProperty" id="6d7a8ed1-dd66-4d11-b2b2-3a46d73cd3ad">
        <methodInvocation>mapping</methodInvocation>
        <source>myProperty(set: Boolean; _value: Property io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 January 2026	naviv1	Initial creation MTN 36791 - JADE Core Framework - Export/Import Registry Foundation

*/

vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
	else
		_value := self.myExportImportClass.myClass.getPropertyInHTree(self.propertyName);
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Property" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="2057fe7c-2c62-47d8-bef8-d0e4163538d8">
        <updating/>
        <source>setForCreate(_pxyProperty : CM_ExportImportProperty) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 January 2026	naviv1	Initial creation MTN 36791 - JADE Core Framework - Export/Import Registry Foundation

*/

vars

begin
	self.displayName := _pxyProperty.displayName;
	self.propertyName := _pxyProperty.propertyName;
	self.includeInExport := _pxyProperty.includeInExport;
	self.expandReference := _pxyProperty.expandReference;
	self.isAttribute := _pxyProperty.isAttribute;
	self.isReference := _pxyProperty.isReference;
	self.isCollection := _pxyProperty.isCollection;
	self.isParentReference := _pxyProperty.isParentReference;
	self.myKeyName := _pxyProperty.myKeyName;
	self.referencedClassName := _pxyProperty.referencedClassName;
epilog

end;</source>
        <Parameter name="_pxyProperty" type="CM_ExportImportProperty"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="3c307181-0288-4486-ba16-2b1e593ed644">
        <updating/>
        <source>setForUpdate(_proxyProperty : CM_ExportImportProperty) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 January 2026	naviv1	Initial creation MTN 36791 - JADE Core Framework - Export/Import Registry Foundation
*/

begin
    self.propertyName := _proxyProperty.propertyName;
    self.includeInExport := _proxyProperty.includeInExport;
	self.isParentReference := _proxyProperty.isParentReference;

    self.expandReference := _proxyProperty.expandReference;
    
   self.referencedClassName := _proxyProperty.referencedClassName;
   self.isAttribute := _proxyProperty.isAttribute;
   self.isCollection := _proxyProperty.isCollection;
   self.isReference := _proxyProperty.isReference;

   self.displayName := _proxyProperty.displayName;
   self.myKeyName := _proxyProperty.myKeyName;

end;</source>
        <Parameter name="_proxyProperty" type="CM_ExportImportProperty"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="0ffc8f77-ad50-423d-855b-a06368fee8ef">
        <updating/>
        <source>setProxy(_property: Property;
    _include: Boolean;
    _expand: Boolean;
    _displayName: String;
    _refClassName: String;
	_isAttribute : Boolean;
	_isReference : Boolean;
	_isCollection : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 January 2026	naviv1	Initial creation MTN 36791 - JADE Core Framework - Export/Import Registry Foundation

*/

begin
    self.propertyName := _property.name;
    self.includeInExport := _include;
	if not self.includeInExport then
		self.isParentReference := true;
	endif;

    self.expandReference := _expand;
    
   self.referencedClassName := _refClassName;
   self.isAttribute := _isAttribute;
   self.isCollection := _isCollection;
   self.isReference := _isReference;
    
    if _displayName &lt;&gt; "" then
        self.displayName := _displayName;
    else
        self.displayName := _property.name;
    endif;
end;</source>
        <Parameter name="_property" type="Property"/>
        <Parameter name="_include" type="Boolean"/>
        <Parameter name="_expand" type="Boolean"/>
        <Parameter name="_displayName" type="String"/>
        <Parameter name="_refClassName" type="String"/>
        <Parameter name="_isAttribute" type="Boolean"/>
        <Parameter name="_isReference" type="Boolean"/>
        <Parameter name="_isCollection" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="9b010a80-8eaa-4d14-aa8c-ce844e366564">
        <source>validateMe();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 January 2026	naviv1	Initial creation MTN 36791 - JADE Core Framework - Export/Import Registry Foundation
*/

vars
	className : String;
	
begin
	className := self.myExportImportClass.className;
	
	if self.propertyName = null or self.myProperty = null then
		app.raiseCMException2(Err_InvalidAttrForClass, self.propertyName, className, null, null);
	endif;
end;</source>
    </JadeMethod>
</Class>
