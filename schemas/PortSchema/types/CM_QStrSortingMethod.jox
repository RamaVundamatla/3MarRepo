<Class name="CM_QStrSortingMethod" id="c026a8af-9933-4b58-9601-a35cf042b8f2">
    <superclass name="CM_QStringLookupProperty"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="create" id="44417897-ffd4-4cab-9ad7-9dd6e5cb3e4d">
        <updating/>
        <source>create() updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 13 June 2023
TFS#		: 58581
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	queryOperator	: CM_QueryOperator;
begin

	if self.isTransient then	
		return;
	endif;

	create queryOperator as CM_QStringIsOneOf persistent;
	self.allAllowedOperators.add(queryOperator);	
end;</source>
    </JadeMethod>
    <JadeMethod name="getValueForObject" id="dfed5383-99f0-4606-9e4c-533f5dbbf300">
        <source>getValueForObject(_obj: Object; _op: CM_QueryOperator input): Any;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 13 June 2023
TFS#		: 58581
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	propValue : String; 
begin
	if self.propertyName = CM_TrackedItem::sortingMethod.name then
		propValue := _obj.CM_TrackedItem.sortingMethod;
	
		if self.needToUpperCase then
			propValue := propValue.toUpper;
		endif;
		return propValue;
	else
	
		return inheritMethod(_obj, _op);
	endif;

epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="setComboValues" id="8a805ba2-6299-4068-a3a7-dd42556467a4">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 13 June 2023
TFS#		: 58581
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	sortingMethod			: CM_SortingMethod;
	sortingMethodDict		: CM_SortingMethodByCodeDict;
begin
	_combo.clear();
	sortingMethodDict := app.myRoot.allSortingMethods;
	
	foreach sortingMethod in sortingMethodDict do
		_combo.itemObject[_combo.addItem(sortingMethod.code &amp; '   ' &amp; sortingMethod.description)] := sortingMethod;
	endforeach;

	if CM_QStringLookup.hasInstance(_queryOperator) then
		_combo.listObject := sortingMethodDict[_queryOperator.CM_QStringLookup.selectionValue];
	elseif CM_QStringLookupNotEqual.hasInstance(_queryOperator) then
		_combo.listObject := sortingMethodDict[_queryOperator.CM_QStringLookupNotEqual.selectionValue];
	endif;
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="76d5b269-3f6a-48ad-9ba3-6b3a2e6f605b">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QueryOperator; _passport: CM_Passport);
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 13 June 2023
TFS#		: 58581
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	sortingMethod 		: CM_SortingMethod;
	sortingMethodDict 	: CM_SortingMethodByCodeDict;
	selectionValue,
	idx				: Integer;
	array			: ObjectArray;
begin
	sortingMethodDict := app.myRoot.allSortingMethods;
	
	_tbl.rows := _tbl.fixedRows;
	
	array := _tbl.getPropertyValue('allSelectedObjects').ObjectArray;
	array.clear;
	
	foreach sortingMethod in sortingMethodDict do
		selectionValue := 0;
		if _operator &lt;&gt; null and  _operator.CM_QStringIsOneOf.allSelectionValues.includes(sortingMethod.code) then
			selectionValue := 1;
			array.add(sortingMethod);
		endif;
		idx := _tbl.addItem(selectionValue.String &amp; Tab  &amp; sortingMethod.code &amp; ' (' &amp; sortingMethod.description&amp; ')');
		_tbl.accessRow(idx).itemObject := sortingMethod;
	endforeach;
	
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="6abd03d6-8d9e-4583-ab6d-2c06e0af3ddb">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 13 June 2023
TFS#		: 58581
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	sortingMethod	: CM_SortingMethod;
	str				: String;
	numRows,
	idx				: Integer;
	sa				: StringArray;

begin

	create sa transient;
	
	numRows := _tbl.rows;
	foreach idx in (_tbl.fixedRows + 1) to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			sortingMethod := _tbl.accessRow(idx).itemObject.CM_SortingMethod;
			sa.add(sortingMethod.code);
		endif;
	endforeach;
	
	_op.setSearchValue(sa);

epilog
	delete sa;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="581bf600-5c71-4353-af82-8c8f51d6bcd8">
        <source>translateToDisplayValue(_value: Any): String;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 13 June 2023
TFS#		: 58581
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

begin
	
	if _value.isKindOf(CM_SortingMethod) then
		if _value &lt;&gt; null then
			return _value.CM_SortingMethod.code;
		else 
			return null;
		endif;
	else
		return _value.String;
	endif;
	return null;
	
end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="e486f9c4-10c1-4c5e-bec1-116575c80dd1">
        <source>translateToSearchValue(_value: Any): Any;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 13 June 2023
TFS#		: 58581
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	invalidObj 		: Boolean;
	object			: CM_SortingMethod;
	returnVal		: String;
	
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then			
			return _value;
		endif;

		if _value.isKindOf(CM_SortingMethod) then
			object := _value.CM_SortingMethod;
		endif;
		
		if _value.isKindOf(String) then
			returnVal := _value.String;
		endif;
	endif;
	
	if object &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, object, invalidObj);
		
		returnVal := object.code;
	endif;
	
	return returnVal;
	
end;
</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
