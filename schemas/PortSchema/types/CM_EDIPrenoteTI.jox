    <JadeMethod name="getDisplayStringForAttribute" id="51b94b01-0ed1-4942-944a-cb3fbf7cd60a">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//----------------------------------------------------------------
//	Created:	12 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//05 Apr 2012	cnwrs1		Par 29391 - EDI RORO Stowage Advice hazard codes
//23 Apr /2014	cnwdap1		PAR #33005 CCMS SFW 1381 Imperial measurements for EDI user defined layouts
//11 Jul 2014	cnwrs1	Par 34566 CCMS 2346 Suzano - Viagram Prenote file 
//20 Oct 2015 	cnwma1  PAR #36634 EDI userdefined prenote  doesnot always register null values. (see Par 36548) 
// 17 Nov 2015	cnwma1	PAR #37167 Issue processing inbound cargo
// 03 May 2016	cnwdap1	TFS #1699 Verified Gross Mass changes
// 13 Jun 2022	jlika1	TFS 53316 - EUP - GEN - Additional Dimensions For Cargo - PortSchema
// 21 Nov 2022	navma1	ChangeRequest 55424: MTN - Improve the performance of Edi file loading
// 18/07/2023	navcs2	Bug 58991: EUP - Fields not in Column Organiser
// 19 Jul 2023	jlirs1	TFS 59187 (59019) EUP - Manifest Processing - Container Reference Field
// 31 Aug 2023	navdap1	Initial creation TFS 60125 EUP | FR 53824 - Wagon Type is populated in Road Manifest EDI Data
// 06 Mar 2024	navhn30	Bug 62299: EUP | FR 53824 - Transport Manifest - Ship Add Fields Users Will Need to Update On Screen
vars
	strSize		: Integer;
	rowName, 
	type		: String;
	wagClass 	: CM_WagonClass;
begin

	if _attrName = ETRow_Temperature or
	   _attrName = ETRow_PackTempC or
	   _attrName =  ETRow_PackTempF then
		if self.temperature = NULL_TEMPERATURE then
			return null;
		endif;
	elseif _attrName = ETRow_OutOfGauge then
		return null;
	elseif _attrName = ETRow_LocationId then
		strSize := self.locationId.length;
		if strSize &gt;= 6 then
			//hide the leading zero
			return self.locationId[strSize-5:6];
		endif;
	elseif _attrName = ETRow_WeightTons then
		return (self.weight * .001).asStringWeightJMT;
	elseif _attrName = ETRow_CarbonDioxide then
		return self.getCarbonDioxide.asNullCarbonDioxide;
	elseif _attrName = ETRow_Oxygen then
		return self.getOxygen.asNullOxygen;
	elseif _attrName = ETRow_Vent then
		return self.vent.asNullDecimal;
	elseif _attrName = ETRow_Humidity then
		return self.getHumidity.asNullHumidity;
	
	// cnwjk3 CCMS 1758
	elseif _attrName = ETRow_Mark then
		return self.mark;
	elseif _attrName = ETRow_MarkNumber then
		return self.markNumber;
	elseif _attrName = ETRow_TotalWeight then											//+cnwml2 MSL CCMS 1017
		return self.weight.asStringWeightJMT();
	elseif _attrName = ETRow_Height then
		return self.height.asStringMeasurementJMT();		
	elseif _attrName = ETRow_Width then
		return self.width.asStringMeasurementJMT();		
	elseif _attrName = ETRow_Length then
		return self.length.asStringMeasurementJMT();
	elseif _attrName = ETRow_ImportReleasePIN then //cnwgb1 21881 10.12.09
		return self.getOperatorImportReleasePIN();
	
	elseif _attrName = ETRow_SealNumberVent then							//21.11.2022 navma1 #55424
		if self.myAttachedItems.isNotEmpty then
			return self.sealNumberVent;
		endif;
		return null;
	elseif _attrName = ETRow_SealShipper then								//21.11.2022 navma1 #55424
		if self.myAttachedItems.isNotEmpty then
			return self.sealShipper;
		endif;
		return null;
	elseif _attrName = ETRow_SealTerminalOperator then						//21.11.2022 navma1 #55424
		if self.myAttachedItems.isNotEmpty then
			return self.sealTerminalOperator;
		endif;
		return null;
	elseif _attrName = ETRow_SealUnknown then								//21.11.2022 navma1 #55424
		if self.myAttachedItems.isNotEmpty then
			return self.sealUnknown;
		endif;
		return null;
	elseif _attrName = ETRow_SealNum then									//21.11.2022 navma1 #55424
		if self.myAttachedItems.isNotEmpty then
			return self.sealNum;
		endif;
		return null;
	elseif _attrName = ETRow_OverHeight then
		if self.overHeight = NULL_INTEGER then
			return null;
		else
			return self.overHeight.String;
		endif;
	//cnwmc5 - 23 Jan 2014 - PAR 33001
	elseif _attrName = ETRow_OverLengthBack then
		if self.overLengthBack = NULL_INTEGER then
			return null;
		else
			return self.overLengthBack.String;
		endif;
	//cnwmc5 - 23 Jan 2014 - PAR 33001
	elseif _attrName = ETRow_OverLengthFront then
		if self.overLengthFront = NULL_INTEGER then
			return null;
		else
			return self.overLengthFront.String;
		endif;
	//cnwmc5 - 23 Jan 2014 - PAR 33001
	elseif _attrName = ETRow_OverWidthLeft then
		if self.overWidthLeft = NULL_INTEGER then
			return null;
		else
			return self.overWidthLeft.String;
		endif;
	//cnwmc5 - 23 Jan 2014 - PAR 33001
	elseif _attrName = ETRow_OverWidthRight then
		if self.overWidthRight = NULL_INTEGER then
			return null;
		else
			return self.overWidthRight.String;
		endif;
	elseif _attrName = ETRow_WagonClass then	//13 May 2014	NDL	Par 33615
		// TFS 60125 don't show wagon class for a Road Transport Manifest
		if self.myEDIData.isGateDoc and self.myEDIData.CM_EDIDataGateDoc.myTransportManifest &lt;&gt; null
		and self.transportMode = TI_TRANSMODE_ROAD_STR then
			return null;
		endif;
		// TFS 60125 end
		
		if self.wagonClass &lt;&gt; null then
			return self.wagonClass;
		endif;
		wagClass := self.getMyTerminal.getWagonClass(wagonNumber, wagonClass);
		if wagClass &lt;&gt; null then
			return wagClass.code;
		else	
			return null;
		endif;
	elseif _attrName = ETRow_TimeAllowedOffPower then	//20/10/2015 cnwma1 PAR #36634
		if self.timeAllowedOffPower &lt;&gt; NULL_ALLOWABLE_TIME_OFF_POWER then
			return self.timeAllowedOffPower.String;
		else	
			return null;
		endif;	
	elseif _attrName = ETRow_PackTime then		      //17/11/2015 cnwma1 PAR #37167
		if self.packTime &lt;&gt; NULL_TIME then
			return self.packTime.String;
		else	
			return null;
		endif;	
		
	elseif _attrName = ETRow_CargoGroupId then	//15 Feb 2016	NDL	Par 37544
		return self.cargoGroupId;
		
	elseif _attrName = ETRow_IsCertifiedWeight then							// TFS #1699
		return self.isWeightCertified.getYes;								// TFS #1699
	elseif _attrName = ETRow_WeightCertifiedName then						// TFS #1699
		return self.weightCertifiedName;									// TFS #1699
	elseif _attrName = ETRow_WeightCertifiedReference then					// TFS #1699
		return self.weightCertifiedReference;								// TFS #1699
	
	elseif _attrName = ETRow_HeatTreated then	//24 Apr 2017	NDL	TFS 3414
		return self.heatTreated;
		
	elseif _attrName = ETRow_StoreOnPallet then	//24 Apr 2017	NDL	TFS 3414
		return self.storeOnPallet;
		
	elseif _attrName = ETRow_PalletType then	//24 Apr 2017	NDL	TFS 3414
		return self.palletType;
	// jlika1 TFS 53316 --&gt;	
	elseif _attrName = ETRow_Grade then		
			return self.grade;
	elseif _attrName = ETRow_Grammage then
		if self.grammage &gt; 0 then
			return self.grammage.asStringJMT;
		endif;	
	elseif _attrName = ETRow_Diameter then
		return null; // will be taken over by the measurement row		
	elseif _attrName = ETRow_RollingLength then
		return null; // will be taken over by the measurement row
	// jlika1 TFS 53316 &lt;--			
	elseif _attrName = ETRow_OperatorExportRelNumber then //jlier1 TFS 53030 6/9/22
		return self.operatorExportReleaseNumber;
	elseif _attrName = ETRow_ImCodes or _attrName = ETRow_Hazards or _attrName = ETRow_Hazardous then	//21.11.2022 navma1 #55424
		return self.getHazardsAsString();
	// 18/07/2023	navcs2	Bug 58991 Start
	elseif _attrName = ETRow_VbsNumber then
		if self.myEDIData.isTransportManifest then
			if self.myEDIData.CM_EDIDataTransManifest.transportReferenceInternal &lt;&gt; null then
				return self.myEDIData.CM_EDIDataTransManifest.transportReferenceInternal;
			elseif self.myEDIData.CM_EDIDataTransManifest.transportReferenceCustomer &lt;&gt; null then
				return self.myEDIData.CM_EDIDataTransManifest.transportReferenceCustomer;
			else
				return null;
			endif;
		else 
			return null;
		endif;
	elseif _attrName = ETRow_ShippingLineCode then
		return self.carrierCode;
	elseif _attrName = ETRow_ContainerNumberText then		// 19 Jul 2023	jlirs1	TFS 59187 (59019) EUP
		return self.getContainerNumberText();
	elseif _attrName = ETRow_VesselCodeForManifest then		//  06.03.24		navhn30		TFS # 62299
		if self.getVoyage &lt;&gt; null then 
			return self.getVoyage.code;
		endif;
		return null;
		
	elseif _attrName = ETRow_CargoTypeContents then
		return self.cargoTypeContents.String;
		
	elseif _attrName.isMeasurementType then									// PAR #33005
		_attrName.getRowNameMeasureType(rowName, type);						// PAR #33005
		return self.getMeasurementStringForAttrib(rowName, type, _short);	// PAR #33005
	endif;
	// 18/07/2023	navcs2	Bug 58991 Start
	
	return inheritMethod(_attrName, _short);

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getHazardsAsString" id="7e764968-85b3-4330-a0ff-c7677209cecf">
        <source>getHazardsAsString(): String;
//
//02 Feb 2012	cnwrs1	Par 29076 Fix up Hazard Processing in EDI
//
vars
	tmpHazards : ObjectArray;
	hazards : CM_HazardByCodeDict;
	haz : CM_Hazard;
	str : String;
begin
	create tmpHazards transient;
	create hazards transient;
	if self.imCodes.isEmpty then
		return null;
	endif;
	self.getProxyHazards(self.imCodes, tmpHazards, false);
	tmpHazards.copy(hazards);
	if hazards.isEmpty then
		return null;
	endif;
	foreach haz in hazards do
		str := str &amp; haz.getTableDisplay(false, true) &amp; ", ";
	endforeach;
	str := str[1:str.length - 2];
	return str;
epilog
	tmpHazards.purge();
	delete tmpHazards;
	delete hazards;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
