// ---------------------------------------------------------------------------
// Created:     23 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
		return app.getTerminologyAlternate(null, null, 'Consignee', CM_TermExpressionPlural, 'Consignees') &amp; '/' &amp;
			app.getTerminologyAlternate(null, null, CM_TerminologyConsignor, CM_TermExpressionPlural, 'Consignors') &amp;
