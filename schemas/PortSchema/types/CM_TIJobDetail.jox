    <JadeMethod name="getDisplayStringForAttribute" id="edc4119e-ec2a-41be-8588-32b8735378cc">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Jun 2024 navnk30 Bug 64601: FR | 54883 - Start and End Times for Operations in Mobile App

*/

vars

begin
	if _attrName = ETRow_Date or _attrName = ETRow_TransactionDT then
		if self.type = TRANS_TYPE_TIJOBSTART then
			return self.systemToLocalTime(self.getJobStart()).shortCurrentLocaleFormat();
		elseif self.type = TRANS_TYPE_TIJOBCOMPLETE then
			return self.systemToLocalTime(self.getJobEnd()).shortCurrentLocaleFormat();
		endif;
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
