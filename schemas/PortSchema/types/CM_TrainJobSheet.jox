        <Inverse name="CM_Train::myJobSheet"/>
    </ExplicitInverseRef>
    <JadeMethod name="getTrain" id="765c0e39-e6c4-47a3-85ae-2ac3787d2166">
        <source>getTrain() : CM_Train;
// ---------------------------------------------------------------------------
// Created:     11 June 2009 by cnwab1
