    <JadeMethod name="cnEcGetNameAndMemory" id="a273e013-f133-42ec-971c-9795a9e576d1">
        <source>cnEcGetNameAndMemory(pMachineName:String output; pTotalMemory:Integer output);
// --------------------------------------------------------------------------------
// Created:		21 January 2002 by cnwdad1
//
// Purpose:		Returns the machine name and total memory from the database server
//				node's machine.
//
// Parameters:	pFreeMemory - The amount of free memory.
//				pFreeDiskSpace - The amount of free disk space.
//				pDriveName - The default drive letter.
//
// Returns:		The above parameter values.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	errorNumber		: Integer;
	availableMemory	: Integer;		// availableMemory is not used.
	appServerName	: String;
	errorText		: String;

begin
	pTotalMemory	:=	0;
	appServerName	:=	app.computerNameAppServer();
	
	// To be consistent with computer names received via ping responses, we
	// replace any semi-colons with underscores (we assume that semi-colons
	// in computer names are unlikely).
	appServerName.replaceChar(';', '_');
	pMachineName	:=	appServerName.trimBlanks();
	
	// Arm an exception handler to guard against something going wrong in
	// cnEcGetTotalAndAvailableMemory (eg: external functions are not available).
	on Exception do global.cnEcXHandlerResumeNext(exception, errorNumber, errorText);
	
	node.cnEcGetMemory(pTotalMemory, availableMemory);

	// If an exception occurs in cnEcGetTotalAndAvailableMemory, our handler armed
	// above will resume to here and we'll just return from this method.
end;</source>
        <Parameter name="pMachineName" type="String" usage="output"/>
        <Parameter name="pTotalMemory" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetNoOfProcessors" id="e8b2253e-bfa6-41b7-978d-b10a3bcd33a7">
        <source>cnEcGetNoOfProcessors():Integer protected;
// --------------------------------------------------------------------------------
// Created:		07 June 2006 by cnwdad1
//
// Purpose:		Fetches the number of processors that are installed on the machine
//				where this method is executing.
//
// Parameters:	None
//
// Returns:		The number of installed processors.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	PROCESSOR_INTEL_386     : Integer = 386;
	PROCESSOR_INTEL_486     : Integer = 486;
    PROCESSOR_INTEL_PENTIUM : Integer = 586;
    PROCESSOR_MIPS_R4000    : Integer = 4000;
    PROCESSOR_ALPHA_21064   : Integer = 21064;
vars
	sysInfoStructure            : Binary;
	dwOemID                     : Integer;
	dwPageSize                  : Integer;
	lpMinimumApplicationAddress : Integer;
	lpMaximumApplicationAddress : Integer;
	dwActiveProcessorMask       : Integer;
	dwNumberOrfProcessors       : Integer;
	dwProcessorType             : Integer;
begin
	sysInfoStructure [ 32 : 1 ] := 0.Binary;
    call cnEcGetSystemInfo(sysInfoStructure);
    dwOemID                     := sysInfoStructure[ 1 : 4].Integer;
	dwPageSize                  := sysInfoStructure[ 5 : 4].Integer;
	lpMinimumApplicationAddress := sysInfoStructure[ 9 : 4].Integer;
	lpMaximumApplicationAddress := sysInfoStructure[ 13 : 4].Integer;
	dwActiveProcessorMask       := sysInfoStructure[ 17 : 4].Integer;
	dwNumberOrfProcessors       := sysInfoStructure[ 21 : 4].Integer;
	dwProcessorType             := sysInfoStructure[ 25 : 4].Integer;

	return dwNumberOrfProcessors;
end;</source>
        <access>protected</access>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetNoOfProcessorsAppServ" id="2104de41-4d52-450f-b05f-afa4ef699ef7">
        <source>cnEcGetNoOfProcessorsAppServ():Integer;
// --------------------------------------------------------------------------------
// Created:		07 June 2006 by cnwdad1
//
// Purpose:		Fetches the number of processors that are installed on the machine
//				where the Application Server node is running.
//
// Parameters:	None
//
// Returns:		The number of installed processors.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	PROCESSOR_INTEL_386     : Integer = 386;
	PROCESSOR_INTEL_486     : Integer = 486;
    PROCESSOR_INTEL_PENTIUM : Integer = 586;
    PROCESSOR_MIPS_R4000    : Integer = 4000;
    PROCESSOR_ALPHA_21064   : Integer = 21064;
vars

	dwOemID                     : Integer;
	dwPageSize                  : Integer;
	lpMinimumApplicationAddress : Integer;
	lpMaximumApplicationAddress : Integer;
	dwActiveProcessorMask       : Integer;
	dwNumberOrfProcessors       : Integer;
	dwProcessorType             : Integer;
	sysInfoStructure            : Binary;

begin
	sysInfoStructure [ 32 : 1 ] := 0.Binary;
    call cnEcGetSystemInfoAppServer(sysInfoStructure);
    dwOemID                     := sysInfoStructure[ 1 : 4].Integer;
	dwPageSize                  := sysInfoStructure[ 5 : 4].Integer;
	lpMinimumApplicationAddress := sysInfoStructure[ 9 : 4].Integer;
	lpMaximumApplicationAddress := sysInfoStructure[ 13 : 4].Integer;
	dwActiveProcessorMask       := sysInfoStructure[ 17 : 4].Integer;
	dwNumberOrfProcessors       := sysInfoStructure[ 21 : 4].Integer;
	dwProcessorType             := sysInfoStructure[ 25 : 4].Integer;

	return dwNumberOrfProcessors;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetNoOfProcessorsClient" id="4a373979-e537-4a3e-9626-6b3618dd92db">
