<Class name="CM_Invoice" id="4529ae8a-afbe-436a-b70e-48423e581738">
    <superclass name="CM_FinancialObject"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>A collection of invoice lines which represent charges to be paid together.
Typically one open invoice per debtor and invoice type.
Invoices are either manually closed or automatically at the of a financial period and then exported into an external financial system.
Payment of the invoices is outside the scope of JMT, other than those paid via the cash module.</text>
    <DbClassMap file="invoice"/>
