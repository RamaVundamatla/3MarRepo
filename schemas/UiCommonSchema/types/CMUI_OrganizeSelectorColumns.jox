    <JadeMethod name="doResetToDefault" id="b0d4a216-6854-4bd7-a9d9-66cb0c940213">
        <source>doResetToDefault() protected;
// ---------------------------------------------------------------------------
// Created:     26 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	cargoBOLType			: CM_CargoBOLType;
	menuRoot				: CM_MenuRootQuery;
begin
	self.allColumns.clear();
	self.allVisibleColumns.clear();
	beginTransaction;
	if self.myCargoBOLType = null then
		menuRoot := app.myRoot.myQueryMenuRoot;
		menuRoot.resetSelectorColumns(true);
		menuRoot.allColumns.copy(self.allColumns);
		menuRoot.allVisibleColumns.copy(self.allVisibleColumns);
		
	else
		cargoBOLType := self.myCargoBOLType;
		cargoBOLType.resetSelectorColumns(true);
		cargoBOLType.allSelectorColumns.copy(self.allColumns);
		cargoBOLType.allSelectorVisibleColumns.copy(self.allVisibleColumns);
	endif;
	commitTransaction;
	
	self.loadColumns();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResize" id="e619191a-251c-4fda-97a1-151cbc6d7166">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:     23 June 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
constants
	Gap = 5;
vars

begin
	inheritMethod();
	
	self.tblColumns.top 	:= self.frmToolbar.height;
	self.tblColumns.width := self.width - 13;
	self.tblColumns.height := self.height - 60;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doSort" id="20fb17ee-ebde-4b90-a895-03c7fd7a6917">
        <updating/>
        <source>doSort() protected, updating;
// -------------------------------------------
// Created 10 August 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	self.saveColumnOrder();
	
	if self.allVisibleColumns.isEmpty then
		app.msgBox('You must select at least one column to display','Nothing selected', MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	self.modalResult := IDOK;
	self.unloadForm;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doTblDragDrop" id="130eefd7-48a6-4973-b9ec-4d2810b2c383">
        <updating/>
        <source>doTblDragDrop(table: Table input; win: Window input; x: Real; y: Real) updating, protected;
// ---------------------------------------------------------------------------
// Created:     24 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	queryProperty			: CM_QueryProperty;
	selected				: Boolean;
	pickUpRow,
	dropCol,
	dropRow			: Integer;
begin
	table.getCellFromPosition(x, y, dropRow, dropCol);
	pickUpRow := self.rowPickUp;
	
	if dropRow = pickUpRow then
		return;
	endif;
	
	if (dropRow &gt; table.rows) or (dropRow &lt; table.fixedRows) then
		dropRow := table.rows;//bung it on the end
	endif;

	selected := (table.getCellText(pickUpRow, 1) = '1');
	queryProperty := table.accessRow(pickUpRow).itemObject.CM_QueryProperty;
	if queryProperty = null then
		return;
	endif;
	
	table.removeItem(pickUpRow);
	table.addItemAt(selected.cnEcGetTableCheckBoxValue &amp; Tab &amp; queryProperty.niceName, dropRow);
	table.accessRow(dropRow).itemObject := queryProperty;
end;</source>
        <access>protected</access>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doTblDragOver" id="de3673c6-60d6-4d5b-b278-f6d60d56c02a">
        <updating/>
        <source>doTblDragOver(table: Table input; win: Window input; x: Real; y: Real; state: Integer) updating, protected;
// ---------------------------------------------------------------------------
// Created:     24 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	dragCol,
	dragRow			: Integer;
	tbl				: CMUI_ListTable;
begin
	tbl := self.tblColumns;
	tbl.clearAllSelected();
	tbl.getCellFromPosition(x, y, dragRow, dragCol);

	if (dragRow &lt;= tbl.rows) and (dragRow &gt; tbl.fixedRows) then
		tbl.accessRow(dragRow).selected := true;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="state" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doTblMouseDown" id="d2df55a7-764f-4618-92bb-1c45a4f27bc1">
        <updating/>
        <source>doTblMouseDown(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) protected, updating;
// ---------------------------------------------------------------------------
// Created:     24 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.origXPos := x;
	self.origYPos := y;
	
	self.rowPickUp := self.tblColumns.row;

end;</source>
        <access>protected</access>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="loadColumns" id="605ccf98-4e7f-4bad-80f9-926725506450">
        <source>loadColumns() protected;
// ---------------------------------------------------------------------------
// Created:     23 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	qProp			: CM_QueryProperty;
	propDict		: CM_QueryPropertyDict;
	qryProp			: CM_QueryProperty;
	visibleColumns,
	columns		: StringArray;
	tbl				: CMUI_ListTable;
	attrName		: String;
	selected		: Boolean;
begin
	tbl := self.tblColumns;
	tbl.rows := 0;
	
	propDict := self.myQDef.allQueryProperties;
	visibleColumns := self.allVisibleColumns;
	columns := self.allColumns;
	
	foreach attrName in columns do
		qryProp := propDict[attrName];
		if qryProp = null then
			continue;
		endif;
		selected := visibleColumns.includes(qryProp.propertyName);
		tbl.accessRow(tbl.addItem(selected.cnEcGetTableCheckBoxValue &amp; Tab &amp; qryProp.niceName)).itemObject := qryProp;
	endforeach;		


end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="86db3512-3238-4c9c-8be3-6e2068ab48d1">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
// ---------------------------------------------------------------------------
// Created:     23 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	menuUserQuery	: CM_MenuUserQuery;

begin
	self.doResize();
	inheritMethod();
	if self.myQDef = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Query definition object passed in was null');
		return;
	endif;

	self.loadColumns();
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="saveAsDefaultForMode" id="e687f65c-f47d-4960-9582-cfa106f1423b">
        <updating/>
        <source>saveAsDefaultForMode() protected, updating;
// ---------------------------------------------------------------------------
// Created:     24 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815
	
begin
	
	if self.myCargoBOLType &lt;&gt; null then
	
		//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			app.myTrxUA.trxUpdateCargoTypeSelectorCols(self.myCargoBOLType, self.allColumns, self.allVisibleColumns, app.myPassport);
		
			if app.myPassport.trxCompletedOK then
				break;
			else
				theResult := app.showErrorWarningDialog('Selector mode default columns update', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			return;
			
		endwhile;
	
	else//setting default for tracked item mode- hangs off query menu root object
		beginTransaction;
		app.myRoot.myQueryMenuRoot.setSelectorColumns(self.allColumns, self.allVisibleColumns);
		commitTransaction;
		
	endif;
	
	self.saveColumnOrder();
	self.modalResult := IDOK;
	self.unloadForm;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="saveColumnOrder" id="b8a20abe-abf8-438e-b118-b1465caef6b2">
        <source>saveColumnOrder() protected;
// ---------------------------------------------------------------------------
// Created:     24 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	queryProp			: CM_QueryProperty;
	row,
	numRows				: Integer;
	tbl					: CMUI_ListTable;
	colArray,
	visArray			: StringArray;	
	isVisible			: Boolean;
	
begin
	tbl := self.tblColumns;
	numRows := tbl.rows;
	
	colArray := self.allColumns;
	visArray := self.allVisibleColumns;
	colArray.clear();
	visArray.clear();
	
	foreach row in 1 to numRows do
		queryProp := tbl.accessRow(row).itemObject.CM_QueryProperty;
		colArray.add(queryProp.propertyName);
		if tbl.accessCell(row, 1).text = '1' then
			visArray.add(queryProp.propertyName);
		endif;
	endforeach;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="c94890df-fd08-473f-bdc9-d5e5c9e68913">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     23 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	modeDescr			: String;
begin
	inheritMethod();

	self.modalResult := IDCANCEL;
	self.toolbarStyle	:= self.ToolbarStyle_ShowNoHide;
	self.showToolbar	:= true;
	
	self.btnCancel.visible := false;
	self.btnOk.visible := false;
	
	if self.myCargoBOLType = null then
		modeDescr := 'Tracked Item';
	else
		modeDescr := self.myCargoBOLType.description;
	endif;
	
end;</source>
    </JadeMethod>
