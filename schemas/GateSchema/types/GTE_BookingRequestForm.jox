        <source>btnRemarks_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 November 2008	cnwer1	Initial creation

*/

vars

begin
	self.txtRemarksMore.text:=self.txtRemarks.text;
