    <JadeMethod name="clickLocationBtn" id="aed29dec-0b64-420a-a4a2-2a81a3555d94">
        <updating/>
        <source>clickLocationBtn( btn: Button input ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 September 2018	jlgndl1	Initial creation	TFS 3950

*/

vars

	lc : CM_LocationsController;

begin

	lc := btn.userObject.CM_LocationsController;
	if lc = null then
		return;
	endif;
	
	self.myMobileGenericAgent.setMyYardLocation( lc );
	self.gotoForm( MOB_HHTruckLoaderAllCargo, false );
	
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
