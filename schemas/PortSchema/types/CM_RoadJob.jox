    <JadeMethod name="lockVehicleTerminalAreaLocns" id="42dc912d-b8b3-49d1-9da8-bd51d9561199">
        <source>lockVehicleTerminalAreaLocns();
// ---------------------------------------------------------------------------
// Created:     27 April 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpVehicle	: CM_Vehicle;
	tmpLC		: CM_LocationsController;
	tmpTA		: CM_TerminalArea;
begin

	tmpVehicle := self.myVehicle;
	if tmpVehicle = null then
		return;
	endif;

	tmpLC := tmpVehicle.locationsController;
	if tmpLC = null then
		return;
	endif;
	
	tmpTA := tmpLC.myTerminalArea;
	if tmpTA = null then
		return;
	endif;
	
	// done here to avoid a deadlock later.  This way
	// we lock the tmpTA.allLocationsControllers dict BEFORE we lock
	// the allJobsByOrder dict.  This avoids a deadlock where we
	// are entering BOLs and the new job is added to the jobSheet
	// prior to the vehicles locations controller terminal area being update
	exclusiveLock(tmpTA.allLocationsControllers);

end;</source>
    </JadeMethod>
    <JadeMethod name="myOperator" id="0d70b418-4ce3-4486-b112-b048b7f0b343">
        <methodInvocation>mapping</methodInvocation>
        <source>myOperator(set: Boolean; _value: CM_Operator io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Jan 2022	navlw1	Initial creation TFS# 52455
06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars
	operator : CM_Operator;
	request : CM_Request;
begin
	if set then
		// set code here
	else
		// get code here
		if self.myVehicleVisit &lt;&gt; null then  // TFS 52787 NAVAB1 24FEB2022
			operator := self.myVehicleVisit.getOperatorForRelease();
			if operator = null then
				operator := self.myVehicleVisit.getOperatorForReceive();
			endif;
		endif;
		if operator = null then
			foreach request in self.allRequests discreteLock do		//06.03.2025 navma1 #MTN-34179
				if request.myOriginatingBulkRelease &lt;&gt; null then
					operator := request.myOriginatingBulkRelease.myOperator;
				endif;
				if operator &lt;&gt; null then
					break;
				endif;
			endforeach;
		endif;
		_value := operator;
	endif;
epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_Operator" usage="io"/>
    </JadeMethod>
    <JadeMethod name="printDriverDetails" id="3fb25b50-8511-48cf-9764-4702755b51e7">
        <updating/>
        <source>printDriverDetails(_copies : Integer; _printPreview : Boolean; _jrwReport : JadeReportWriterReport; _printer : String) updating;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 26 June 2007
//
// Changed On	Changed By  Reason
// ----------	----------	--------------------------------------------
// 22 Feb 2010	consw1		PAR #21156 - Gate Config Report Names
// 16 Mar 2010	consw1		PAR #22886 - Leaking report transients
//04/01/2017                    cnwrh7     TFS2899 Cargo Attribute Filter for Driver Instructions
// 25 Sep 2017	jlgmd1		TFS #6995 - Error 75768 in Road Gate print option
//----------------------------------------------------------------------
vars
	
	jadeReport				: JadeReport;
	inTrans					: Boolean;
	reportString			: String;
	printerName 			: String;

	
	
	repFormatDict 			: CM_ReportFormatMatchCritDict;	
	iterRep 				: Iterator;
	repMatchCrit			: CM_DriverInstructionFormat;	
	iterTi 					: Iterator;
	allWLEs,matchingWLEs	: CM_WLESet;
	wle						: CM_WorkListEntry;
	
begin
	inTrans := process.isInTransactionState();

	if _copies = null or _copies = 0 then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Attempt to print 0 copies');
		return;		//Exception ?
	endif;

	// The JRW process about to be kicked off sometimes fails when it compiles. One possible reason maybe an odd job id as this is used in the query in JRW
	if not self.jobId.trimBlanks.isValidKey then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Road Receipt Job Id is invalid! ' &amp; self.String);
		return;		//Exception ?
	endif;	
	
	//epr 29185 1/3/12 printer name can be null will print to default printer
	printerName := _printer;
	app.printer.setPrinter(printerName);

	if _printPreview then
		create jadeReport transient;
		jadeReport.description := "Default";
		jadeReport.copies:=_copies; //epr par 32663 31/10/13
		app.printer.setReport(jadeReport);
	endif;	
	
	// Par 13155 Changed this to cater for a passed in report 
	if _jrwReport = null then
				//reportString := 'CM_Buckslip1';//par 13812
				//reportString := 'CM_DriverDetails'; 
				//reportString := self.myTerminal.getRoadReceiptReport();
		if self.myTerminal &lt;&gt; null then
			//find matching criteira report String
			reportString := self.myTerminal.getConfig(GateDriverInstructionsReport).String;
			if reportString = null then
				reportString := DefRep_GateDriverInstructions;
			endif;
				
			if self.myTerminal.hasAlternateFormatsByContext( CM_ReportFormatMatchCriteria.DriverCriteriaInt ) = 0 then										//+TFS2899	No Alternate Report for Criterias 
				// PAR #27851 print to lineflow via text file
				if self.printDriverDetailsViaTxtDot(reportString) then										//+TFS2899 Tidy up ?Txt ? Dot Code
					//return;
				else
					self.printDriversViaDefPrinter(_copies,_printPreview,reportString,_jrwReport,null);
				endif;
			else			
				
				//Alternate Reports Match Criterias
				create allWLEs transient;
				create matchingWLEs transient;
				self.workListEntries.copy(allWLEs);

				if not allWLEs.isEmpty then
					
					create repFormatDict transient;
					self.myTerminal.getAlternateFormatsByContext( repFormatDict, CM_ReportFormatMatchCriteria.DriverCriteriaInt);
					iterRep := repFormatDict.createIterator;
					
					while iterRep.next( repMatchCrit ) do
						matchingWLEs.clear;
							
						iterTi := allWLEs.createIterator;
						while iterTi.next(wle) do
							if wle.myTrackedItem = null then
								continue;
							endif;
							if repMatchCrit.matches( wle.myTrackedItem ) then
								matchingWLEs.add(wle);
								allWLEs.remove(wle);
							endif;
						endwhile;
						delete iterTi;
							
						if not matchingWLEs.isEmpty then		//these tis should be processed against this format
							self.printDriversViaDefPrinter(_copies,_printPreview,repMatchCrit.reportName,_jrwReport,matchingWLEs);
						endif;
						if allWLEs.isEmpty then
							return;									// none left to process
						endif;
						
					endwhile;
					// If there is any cargo left over, print using the user defined 'default' report for the gate. (Not the system default)
					// reportString := DefRep_GateDriverInstructions;			// TFS 6995
					self.printDriversViaDefPrinter(_copies,_printPreview,reportString,_jrwReport,allWLEs);
				endif;
			endif;
		endif;
	else	//jrwReport not null
		self.printDriversViaDefPrinter(_copies,_printPreview,null, _jrwReport,null);
	endif;
epilog
	delete repFormatDict;
	delete iterRep;
//	app.cmsEndLoad(ls);
end;</source>
        <Parameter name="_copies" type="Integer"/>
        <Parameter name="_printPreview" type="Boolean"/>
        <Parameter name="_jrwReport" type="JadeReportWriterReport"/>
        <Parameter name="_printer" type="String"/>
    </JadeMethod>
    <JadeMethod name="printDriverDetailsViaTxtDot" id="7dcf285c-05c0-46d0-a905-ffd21b67f8c2">
        <source>printDriverDetailsViaTxtDot(_reportString : String) : Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
06 January 2017		cnwrh7	Initial creation TFS 2899 Tidy up TXT and DOT codes
25 September 2017	jlgmd1	TFS #6995 - Error 75768 in Road Gate print option

*/

vars
	isTXT,
	isDOT			: Boolean;

	gteEntity 		: CMGTE_Entity;
	jrwTrans		: CM_JRWAnyDataObject;
	ti 				: CM_TrackedItem;
	termDict		: CM_TerminalByCodeDict;
	proxyClones 	: ObjectSet;
	
begin

	isTXT := _reportString.pos("?TXT", 1) &gt; 0; 			// TFS 6995
	if not isTXT then									// TFS 6995
		isDOT := _reportString.pos("?DOT", 1) &gt; 0;		// TFS 6995
	endif;												// TFS 6995
	
	if isTXT or isDOT then								// TFS 6995

		// TFS 6995 - Reinstate the data population for JRW
		jrwTrans := app.myQAFilter.createJRWTransient(CM_JRWAnyDataObject).CM_JRWAnyDataObject;
		create termDict transient;
		termDict.add(self.myTerminal);
		jrwTrans.setAllTerminals(termDict);
		create proxyClones transient;										
		jrwTrans.myDataObject := self.getCloneForPrinting(proxyClones);

		if isTXT then
			app.printReportViaTextFile(_reportString);
			return true;
		//12 Nov 2012	NDL	Par 30682
		elseif isDOT and self.myVehicleVisit &lt;&gt; null then
			if self.myVehicleVisit.allReceivedTrackedItems.isEmpty and self.myVehicleVisit.allReleasedTrackedItems.isEmpty then
				foreach gteEntity in self.myVehicleVisit.allGateEntities do
					app.printReportDotMatrix(_reportString,gteEntity,false);
				endforeach;
			else
				foreach ti in self.myVehicleVisit.allReceivedTrackedItems do
					if ti.isContainer then
						app.printReportDotMatrix(_reportString,ti.CM_Container,false);
					endif;
				endforeach;
				foreach ti in self.myVehicleVisit.allReleasedTrackedItems do
					if ti.isContainer then
						app.printReportDotMatrix(_reportString,ti.CM_Container,false);
					endif;
				endforeach;
			endif;	
			return true;
		endif;
	endif;
	
	return false;
epilog
	if jrwTrans &lt;&gt; null then
		delete jrwTrans;
	endif;
	
	delete termDict;
	
	if proxyClones &lt;&gt; null then
		proxyClones.purge();
	endif;
	delete proxyClones;
end;</source>
        <access>protected</access>
        <Parameter name="_reportString" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="printDriversViaDefPrinter" id="648316f0-6fec-4989-8ad3-bca0c6463533">
        <updating/>
        <source>printDriversViaDefPrinter(_copies : Integer; _printPreview : Boolean; _reportString : String;  _jrwReport : JadeReportWriterReport;
													_matchingWLEs : CM_WLESet input) updating,protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 January 2017	cnwrh7	Initial creation TFS2899
26/01/2016	cnwma1	Tfs #3203:PAR38550 QNS - Driver details on landscape format
*/

vars
	jrwManager 		: JadeReportWriterManager;
	transientRep		: JadeReportWriterReport;
	jrwReport			: JadeReportWriterReport;
	jrwTrans				 : CM_JRWAnyDataObject;
	jadeReport			: JadeReport;
	termDict				: CM_TerminalByCodeDict;
	proxyClones 		: ObjectSet;
	pxyWle,
	wle 						: CM_WorkListEntry;
	pxyRoadJob      : CM_RoadJob;
	orientation				: Integer;
	iNotUsed : Integer;
	collate : Boolean;
begin
	if _copies = null or _copies = 0 then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Attempt to print 0 copies');
		return;		//Exception ?
	endif;
	
	if _printPreview then
		create jadeReport transient;
		jadeReport.description := "Default";
		jadeReport.copies:=_copies; //epr par 32663 31/10/13
		app.printer.setReport(jadeReport);
	endif;	

	jrwTrans := app.myQAFilter.createJRWTransient(CM_JRWAnyDataObject).CM_JRWAnyDataObject;
	create termDict transient;
	termDict.add(self.myTerminal);
	jrwTrans.setAllTerminals(termDict);
	//jrwTrans.myDataObject := self;									//-cnwas3 par 24727
	create proxyClones transient;										//+cnwas3 par 24727
	if _matchingWLEs = null or _matchingWLEs.isEmpty then
		jrwTrans.myDataObject := self.getCloneForPrinting(proxyClones); 	//+cnwas3 par 24727
	else
		beginLoad;
			pxyRoadJob := self.pxyCreateUpdateProxy();
		endLoad;
		pxyRoadJob.workListEntries.purge();
		proxyClones.add(pxyRoadJob);
		if pxyRoadJob.myRFIDTag &lt;&gt; null then
			proxyClones.add(pxyRoadJob.myRFIDTag);
		endif;
		foreach wle in _matchingWLEs discreteLock do
			beginLoad;
				pxyWle:=wle.pxyCreateUpdateProxy();
			endLoad;
			pxyWle.setJob(pxyRoadJob);
			proxyClones.add(pxyWle);
			//jrwTrans.myDataObject.workListEntries.add();
		endforeach;
		jrwTrans.myDataObject :=pxyRoadJob;
	endif;
	
	if _jrwReport= null then
		jrwManager := app.createReportWriterManager();
		transientRep := jrwManager.getReport(_reportString);
		if transientRep = null then
			app.raiseUnexpectedProgramError(class.name, method.name, "Driver Instructions report class not specified in gate config (" &amp; _reportString &amp; " does not exist)");
			return;
		endif;
		jrwReport := transientRep;
	else
		jrwReport := _jrwReport;
	endif;
	
	jrwReport.setOutputDestination(JadeReportWriterReport.PRINTER);
	
	jrwReport.getPageOptions(iNotUsed,orientation,iNotUsed,iNotUsed,iNotUsed,iNotUsed,iNotUsed,iNotUsed,collate,iNotUsed);//26/01/2016 cnwma1 TFS #3203

	//jrwReport.setPageOptions(Print_A4, Print_Portrait, _copies, 0, 0, 0, 20, 0, false, 0); //26/01/2016 cnwma1 TFS #3203
	jrwReport.setPageOptions(Print_A4, orientation, _copies, 0, 0, 0, 20, 0, false, 0); //26/01/2016 cnwma1 TFS #3203

	if _printPreview then
		jrwReport.setPreviewOptions(false, true, false, true, null);
	endif;
//	app.cmsBeginLoad(ls);
	jrwReport.run;

	if _printPreview then
		app.printPreviewModal(jadeReport); //epr par 32899 1/11/13
	else
		delete jadeReport;
	endif;		
epilog
	delete jrwManager;
	delete jrwTrans;
	delete termDict;
	if proxyClones &lt;&gt; null then
		proxyClones.purge();	//cnwas3 par 24727 purging all the proxies that have been created in the cloning for printing process
	endif;
	delete proxyClones;
//	delete jadeReport;
end;</source>
        <access>protected</access>
        <Parameter name="_copies" type="Integer"/>
        <Parameter name="_printPreview" type="Boolean"/>
        <Parameter name="_reportString" type="String"/>
        <Parameter name="_jrwReport" type="JadeReportWriterReport"/>
        <Parameter name="_matchingWLEs" type="CM_WLESet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="printInterchangeReport" id="a57283f5-ac0a-4a53-a037-e93c396d3299">
        <updating/>
        <source>printInterchangeReport(_copies : Integer; _printPreview : Boolean; _printer : String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 January 2019	jlgndl1	Initial creation	TFS 40479

*/

vars
	
	jadeReport				: JadeReport;
	inTrans					: Boolean;
	reportString			: String;
	printerName 			: String;

	repFormatDict 			: CM_ReportFormatMatchCritDict;	
	iterRep 				: Iterator;
	repMatchCrit			: CM_InterchangeReportFormat;	
	iterTi 					: Iterator;
	allWLEs,matchingWLEs	: CM_WLESet;
	wle						: CM_WorkListEntry;
	copies					: Integer;
	
begin
	inTrans := process.isInTransactionState();

	if _copies = null or _copies = 0 then
		app.raiseCMException( Print_config_with_zero_copies, null, null );
		return;
	endif;

	// The JRW process about to be kicked off sometimes fails when it compiles. One possible reason maybe an odd job id as this is used in the query in JRW
	if not self.jobId.trimBlanks.isValidKey then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Road Receipt Job Id is invalid! ' &amp; self.String);
		return;		//Exception ?
	endif;	
	
	printerName := _printer;
	app.printer.setPrinter(printerName);

	if _printPreview then
		create jadeReport transient;
		jadeReport.description := "Default";
		jadeReport.copies:=_copies;
		app.printer.setReport(jadeReport);
	endif;	
	

	
	if self.myTerminal &lt;&gt; null then
		//find matching criteira report String
		reportString := self.myTerminal.getConfig(GateInterchangeReport).String;
		if reportString = null
		and self.myTerminal.hasAlternateFormatsByContext( CM_ReportFormatMatchCriteria.InterchangeCriteriaInt ) = 0 then
			app.raiseCMException( Interchang_report_configured, null, null );
			return;
		endif;
				
		//Alternate Reports Match Criterias
		create allWLEs transient;
		create matchingWLEs transient;
		self.workListEntries.copy(allWLEs);

		if not allWLEs.isEmpty then
			
			create repFormatDict transient;
			self.myTerminal.getAlternateFormatsByContext( repFormatDict, CM_ReportFormatMatchCriteria.InterchangeCriteriaInt );
			iterRep := repFormatDict.createIterator;
			
			while iterRep.next( repMatchCrit ) do
				matchingWLEs.clear;
					
				iterTi := allWLEs.createIterator;
				while iterTi.next(wle) do
					if wle.myTrackedItem = null then
						continue;
					endif;
					if repMatchCrit.matches( wle.myTrackedItem ) then
						matchingWLEs.add(wle);
						allWLEs.remove(wle);
					endif;
				endwhile;
				delete iterTi;
				
				printerName := repMatchCrit.getPrinterName();
				app.printer.setPrinter(printerName);
				copies := repMatchCrit.numCopies.max(1);
					
				if not matchingWLEs.isEmpty then		//these tis should be processed against this format
					self.printDriversViaDefPrinter( copies, _printPreview, repMatchCrit.reportName, null, matchingWLEs );
				endif;
				if allWLEs.isEmpty then
					return;									// none left to process
				endif;
				
			endwhile;
			// If there is any cargo left over, print using the user defined 'Interchange' report for the gate.
			if reportString &lt;&gt; null then
				self.printDriversViaDefPrinter( _copies, _printPreview, reportString, null, allWLEs );
			endif;
		endif;
		
	endif;
	
epilog

	delete repFormatDict;
	delete iterRep;

end;</source>
        <Parameter name="_copies" type="Integer"/>
        <Parameter name="_printPreview" type="Boolean"/>
        <Parameter name="_printer" type="String"/>
    </JadeMethod>
    <JadeMethod name="printJadeReceipt" id="1a46f8e8-1c18-4d2a-a3ed-9525486f6b28">
        <source>printJadeReceipt(pCopies : Integer; pPreview : Boolean);
//--------------------------------------------------------------
//Created: 16 January 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	rep 		: CMS_GTERoadReceipt;
	jadeReport	: JadeReport;
begin

	//Build the xreport form
	create rep;
	rep.setupReport(self);
	//Do printer settings
	app.printer.orientation := Print_Landscape;
	app.printer.copies := pCopies;
//	app.printer.printPreview := pPreview;
	app.printer.printPreview := false;
	app.printer.printPreviewAllowPrint := true;
	
	if pPreview then
		create jadeReport transient;
		jadeReport.copies:=pCopies; //epr par 32663 31/10/13
		app.printer.setReport(jadeReport);
	endif;
	
	//Output xreport elements to print buffer
	app.printer.print(rep.fHeader);
	app.printer.print(rep.fBatData);	
	app.printer.print(rep.fSpacer);	
	app.printer.print(rep.fBody);	
	app.printer.print(rep.fSpacer);	
	app.printer.print(rep.fFooter);

	if pPreview then
		jadeReport.description := rep.name;
		app.printPreview(jadeReport, true);
	else
		app.printer.close;
	endif;

	abortTransaction;

epilog
	delete rep;
end;</source>
        <Parameter name="pCopies" type="Integer"/>
        <Parameter name="pPreview" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="printReceipt" id="bd8cf595-4a53-428f-9652-059f1568f353">
        <updating/>
        <source>printReceipt(copies : Integer; pPrintPreview : Boolean; _jrwReport : JadeReportWriterReport input) updating;
// ---------------------------------------------------------------------------
// Created:		January 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Changed On	Changed By  Reason
// ----------	----------	--------------------------------------------
// 16 Mar 2010	consw1		PAR #22886 - Leaking report transients
// ---------------------------------------------------------------------------
vars
	termDict : CM_TerminalByCodeDict;
	jadeReport					: JadeReport;
	jrwManager	: JadeReportWriterManager;
	jrwReport	: JadeReportWriterReport;
	jrwTrans : CM_JRWAnyDataObject;
	transientRep : JadeReportWriterReport;
	ls 			: Boolean;
	reportString : String;
begin

	if copies = null or copies = 0 then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Attempt to print 0 copies');
		return;		//Exception ?
	endif;

	// The JRW process about to be kicked off sometimes fails when it compiles. One possible reason maybe an odd job id as this is used in the query in JRW
	if not self.jobId.trimBlanks.isValidKey then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Road Receipt Job Id is invalid! ' &amp; self.String);
		return;		//Exception ?
	endif;	

//	app.printer.abort();
	if pPrintPreview then
		create jadeReport transient;
		jadeReport.description := "Road Receipt";
		jadeReport.copies:=copies; //epr par 32663 31/10/13
		app.printer.setReport(jadeReport);
	endif;	
	
	jrwTrans := app.myQAFilter.createJRWTransient(CM_JRWAnyDataObject).CM_JRWAnyDataObject;
	create termDict transient;
	termDict.add(self.myTerminal);
	jrwTrans.setAllTerminals(termDict);
	jrwTrans.myDataObject := self;	
	
	// Par 13155 Changed this to cater for a passed in report 
	if _jrwReport = null then
		reportString := self.myTerminal.getRoadReceiptReport();//par 13812
		jrwManager := app.createReportWriterManager();
		transientRep := jrwManager.getReport(reportString);
		if transientRep = null then
			app.raiseUnexpectedProgramError(class.name, method.name, "Gate Road Receipt report class not specified in terminal config (" &amp; reportString &amp; " does not exist)");
			return;
		endif;
		jrwReport := transientRep;
	else
		jrwReport := _jrwReport;
	endif;

	jrwReport.setOutputDestination(JadeReportWriterReport.PRINTER);
	
	// params = documentType; orientation; copies; topOfPage; bottomOfPage; leftMargin; rightMargin; borderWidth; collate; duplex
	jrwReport.setPageOptions(Print_A4, Print_Landscape, copies, 0, 0, 0, 20, 0, false, 0);
	if pPrintPreview then
		jrwReport.setPreviewOptions(false, true, false, true, null);
	endif;
//	app.cmsBeginLoad(ls);
	jrwReport.run;

	if pPrintPreview then
		app.printPreview(jadeReport, true);
	else
		delete jadeReport;
	endif;
	
epilog
	delete transientRep;
	delete jrwTrans;
	delete jrwManager;
	delete termDict;
//	app.cmsEndLoad(ls);
end;</source>
        <Parameter name="copies" type="Integer"/>
        <Parameter name="pPrintPreview" type="Boolean"/>
        <Parameter name="_jrwReport" type="JadeReportWriterReport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="f4a5d498-f8e0-4ff9-9a5f-f65979f884bf">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Date		    Who			Reason
01 July 2010	cnwas3	  	par 24727
20/04/2011		cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
							trying to create the proxy
*/

vars
	proxyJob : CM_RoadJob;
	completedOK		: Boolean;
begin
	//proxyJob := inheritMethod();

	proxyJob := self.cloneSelf(true);
	
	self.allReceiveTrackedItems.copy(proxyJob.allReceiveTrackedItems);
	self.allReleaseTrackedItems.copy(proxyJob.allReleaseTrackedItems);
	self.allWorkingDeviceIDs.copy(proxyJob.allWorkingDeviceIDs);
	
	proxyJob.myBatNumber := self.myBatNumber;
	proxyJob.myCarrier := self.myCarrier;
	proxyJob.myDriver := self.myDriver;
	proxyJob.myGate := self.myGate;
	if self.myRFIDTag &lt;&gt; null then
		proxyJob.myRFIDTag := self.myRFIDTag.pxyCreateUpdateProxy();
	endif;
	proxyJob.myTerminal := self.myTerminal;
	proxyJob.myVehicle := self.myVehicle;
	proxyJob.myVehicleVisit := self.myVehicleVisit;
		
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyJob;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyJob;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="recordVisit" id="e1d002a3-97ff-4107-9cd8-94c82a7a84dc">
        <updating/>
        <source>recordVisit(_setTimeOut : Boolean; _chkIfVehicleReadyToLeave : Boolean) updating;
/* NFS 3711 This function stores of details of the job to a vehicle visit record
to allow performance tracking of vehicle visits. Gets called on completion of the
road job in ::updateStatus. Should be in txn state....

// Lorcan 15/4/2006 - Changed visitRecord to use new reference to myVehicleVisit
/*

Date		Who		Reason
30 May 2008	cnwkpd1	PAR #16837 - Move final updating code out of epilog to prevent exceptions
					causing further issues
25 May 2009 concms1	par 19715 - create Ready to Leave VVRD
22 Mar 2011 cnwer1  PAR 25573 - changed from using job::isVehicleFreeToGo to just using is job = complete does 
							 - should now only ever be free to go is job is complete

PARAMETERS

_setTimeOut:	should only be true when called from the departureProcess and the
				vehicle is actually leaving the terminal.
_setVehicleReleased: should only be called from the updateStatus method. Indicates we
				should check if the vehicle is ready to leave, and set vehicleReleased
				
18 Jun 2013	cnwcs5	par 31670 - new _context parameter for createVehicleVisitDetail method
18 Mar 2025 jlier1 MTN-34117 18/3/25 - deadlock - tidied up removed unused code
*/	
vars
    vehicle 	 		: CM_Vehicle;
    timeIn,
    timeOut				: TimeStamp;
begin

	vehicle := self.myVehicle;
	if vehicle = null then
		app.writeLog("Vehicle was null for visit record", 0);	//to track loss of bat numbers 
		return;
	endif;

	exclusiveLock(self);

	//exclusiveLock(app.myPassport.myTerminal.allVehicleVisits);
	exclusiveLock(self.myTerminal.allVehicleVisits);	//18 May 2012	NDL	Par 29596
	
	if self.myVehicleVisit &lt;&gt; null then
		// see if it needs updaing
		timeIn := self.myVehicleVisit.timeIn;
	 	//We have already recorded the stats and they are probably messing about with the job now
		// 31890 this gets called several times for a single gate in/out, from WLE and Job rebuildStatus to Job.updateStatus
		//  so this logging is just noise, remove it
		///app.writeLog("Vehicle already has a visit record at this time.", 0);	//to track loss of bat numbers 
	else
		// create one
		create self.myVehicleVisit persistent;
		if app.name = "GateKiosk01App" then	//21 May 2020	NDL	TFS 49167
			self.myVehicleVisit.setVisitNumber( self.myTerminal.getNextGateTransactionNumber() );
		endif;
	
		timeIn := self.creationTime;
	endif;
	
	if (not timeIn.isValid()) then
		// belts and braces
		timeIn := self.createdTime;
	endif;

	// at the time of departure
	if _setTimeOut then
		timeOut := app.serverTimestampAtTrxStart;	
	else
		timeOut := null;
	endif;
	
	self.myVehicleVisit.setFromJob(timeIn, self);
	
	// NOTE that we still check self.vehicleReleased here as we only want to set this once
	
	if _chkIfVehicleReadyToLeave  and self.vehicleReleased = null and  self.status = JOB_COMPLETE  then   
		self.vehicleReleased := app.serverTimestampAtTrxStart;
		self.myVehicleVisit.createVisitRecordDetail(VisitRecord_ReadyToLeave, null, null);	// par 31670
		self.batNumber := null;							// 09/11/2011 cnwmh5 #28626 - Returned to this method
		self.myBatNumber := null;
	endif;

	//GD CCMS 1002 

	if self.isReceiptRequired //&lt;&lt;-- they want a receipt
	and (not app.isRTApp) 
	and self.autoComplete then
		//app.runRoadReceiptForeground(self);
		//app.myPassport.causeEvent(app.myPassport.myTerminal.getTerminalEvent(Event_Road_Receipt_Report), false, self.myVehicleVisit);
		app.myPassport.causeEvent(self.myTerminal.getTerminalEvent(Event_Road_Receipt_Report), false, self.myVehicleVisit);	//18 May 2012	NDL	Par 29596
		self.receiptCopies := self.receiptCopies + 1;
		self.receiptPrintedDT := timeOut;
	endif;		

	

epilog
	
end;</source>
        <Parameter name="_setTimeOut" type="Boolean"/>
        <Parameter name="_chkIfVehicleReadyToLeave" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="recordedDwellTime" id="0c5398ec-58c1-46a6-b1aa-71a1ec82eccd">
        <source>recordedDwellTime() : Integer;
//This is the recorded dwell time, which gets closed off when the vehicle is serviced
//The other dwell time property continues to increment until the job is erased 
vars
	aT	:	Time;
	isPos	:	Integer;
	numDays	:	Integer;
	mins : Integer;
begin

	if vehicleReleased = null then		//Job not complete yet
		aT := app.actualTimeServer.differenceAsTime(creationTime, isPos, numDays);
	else
		aT := vehicleReleased.differenceAsTime(creationTime, isPos, numDays);
	endif;
	return (numDays * 24 * 60) + (aT.hour * 60) + aT.minute + 1;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="removeTI" id="771adf59-aaf0-4150-a6b3-09e7eb1777bb">
        <updating/>
        <source>removeTI(_ti : CM_TrackedItem input; _request : CM_Request) updating;
// ---------------------------------------------------------------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 29 Aug 2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition 
// ---------------------------------------------------------------------------
// 11 May 2018	jlgrs1	make delete Terminal work
// 05 Jun 2025  navma1  MTN-34114  MTN - Performance Improvements - Remove Class::FirstInstance usage  
vars
	cargoType : CM_CargoType;
begin

	exclusiveLock(self);

	if (_ti = null or _request = null ) then
		app.setContinueCMExceptions(false);
		app.raiseCMException(ERR_TI_LINK_PARAM, null, null);
		return;		
	endif;
	
	if (not _request.isKindOf(CM_YardRequest)) then
		// if this ever happens then may need to look at reworking this method
		app.setContinueCMExceptions(false);
		app.raiseUnexpectedProgramError(class.name, method.name, 'Request is of unhandled type (' &amp; _request.String &amp; ')');
		return;
	endif;

	sharedLock(_request);
	exclusiveLock(_ti);

	//-----------------------
	// Update appropriate instvar on TI
	//-----------------------
	//Check link, if already us, or Null, OK, else error!
	
	if _request.CM_YardRequest.isReceipt then
		if _ti.jobRoadReceive = null then 
			return; 
		endif;
		
		cargoType := _ti.myCargoType;						//05.06.2025 navma1 #MTN-34114
		
		if self = _ti.jobRoadReceive then
			//epr par 32730 10/10/13
			if self.myVehicleVisit &lt;&gt; null and (cargoType.isBreakBulkMulti or cargoType.isBulkMulti) then	//11 Apr 2018	NDL	TFS 37921	//05.06.2025 navma1 #MTN-34114
				if self.myVehicleVisit.hasCargoRemovedForCargoId(_ti.id) then
					return;
				endif;
			endif;
			
			self.allReceiveTrackedItems.tryRemove(_ti);

		else
			//11 Apr 2018	NDL	TFS 37921
			if cargoType.isBreakBulkMulti or cargoType.isBulkMulti	
			then
				// The latest job on the TI isn't us, so we also can't be in self.allReceiveTrackedItems because its inversed.
				// Must be nothing to worry about.
				return;
			endif;
			
			if _ti.jobRoadReceive &lt;&gt; null or
			   _ti.jobRoadReceive &lt;&gt; null then
				app.setContinueCMExceptions(false);
				app.raiseCMException1(ERR_TI_HAS_REC_JOB, _ti.id, null, null);
				return;
			endif;
		endif;
	else
		if _ti.jobRoadRelease = null then
			return;
		elseif self = _ti.jobRoadRelease  then
			self.allReleaseTrackedItems.tryRemove(_ti);
			//epr par 34469 4/9/14 undone 35202 12/11/2014 as needed to be kept for Penn Dock Receipt reporting from process road exit
		endif;
	endif;

	self.updateObjectEdition(self);	// par 30292

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_request" type="CM_Request"/>
    </JadeMethod>
    <JadeMethod name="removeWLE" id="43ac2184-4a7c-45d1-b8dc-7a59b9cbd25d">
        <updating/>
        <source>removeWLE(_wle: CM_WorkListEntry io; _reason: String) updating;
/*
Date		Who		Reason
17 Jun 2013	cnwcs5	Initial Creation - par 31670. A little refactoring. Record reson for a deleted entry
									   new _context parameter for createVehicleVisitDetail method plus
									   actually record reson entry was created on VVRD
28/01/2019 	JLGNS1	Bug 43075: STWR Ticket 42865: STWR - RE: Ticket 41369
14 May 2024 navma1	Bug 64124: MTN - Cancel VVR Doesn't use Deferred Updates
*/
vars
	visit				: CM_VehicleVisitRecord;
	prenotedTI			: CM_TrackedItem;
	moveAllCargoBack	: Boolean;
	ti					: CM_TrackedItem;
	cargoType			: CM_CargoType;
begin	
	self.exclusiveLock(self);

	if _wle = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException(ERR_NO_OBJECT, null, null);
		return;		
	endif;
	
	self.exclusiveLock(_wle);
	self.sharedLock(_wle.myRequest);
	
	//18 Feb 2011	NDL	Par 27046
	visit := self.myVehicleVisit;
	
	if visit &lt;&gt; null then
		visit.createVisitRecordDetail(VisitRecord_Deleted_Entry, _reason, _wle);	// par 31670
	endif;

	ti := _wle.myTrackedItem;										//14.05.2024 navma1 #64124
	
	if self.workListEntries.size = 1 then
		if visit &lt;&gt; null then
		
			// TFS 43075 JLGAB1 If the TI was prenoted and there is no current prenote for it to be merged into then 
			//									we are 'moving' the whole lot from the truck back to prenote.
			if ti &lt;&gt; null then
				cargoType := ti.myCargoType;
			endif;
			
			if cargoType &lt;&gt; null then
				prenotedTI		  := ti.myTerminal.allNotifiedTIsByCargoTypeId[cargoType.id,_wle.myTrackedItem.id];	// TFS 43075 JLGAB1		//14.05.2024 navma1 #64124
				moveAllCargoBack  := ti.wasPrenotified and prenotedTI = null;										// TFS 43075 JLGAB1		//14.05.2024 navma1 #64124
			endif;
			_wle.CM_YardWLE.deleteCurrentEntry(moveAllCargoBack,_reason);				//Bug 43075		NICK		// TFS 43075 Reason
			app.myUtilityUA.utlUpdateVVRCancel(  self.CM_RoadJob.myVehicleVisit , _reason , app.myPassport); // cnwrd1 par 22624 3.5.2010
		endif;
	endif;

	if app.myPassport.isOpsViewEnabled(_wle.getMyTerminal()) then
		_wle.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_DELETE,BGP_OpsViewWSRequest.OPS_TYPE_WLE, _wle); // ### TFS 51853 27AUG2021 NAVAB1
		
		if _wle.myTrackedItem &lt;&gt; null then	 // TFS 53009 anantra - 9th March 2022
			_wle.myTrackedItem.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_DELETE, 
														BGP_OpsViewWSRequest.OPS_TYPE_TRACKEDITEM, 
														_wle.myTrackedItem  );
		endif;

	endif;
	
	inheritMethod (_wle, _reason);
epilog

end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="io"/>
        <Parameter name="_reason" type="String"/>
    </JadeMethod>
    <JadeMethod name="setAutoComplete" id="cc98ca48-b0ca-4ef0-a48a-e9bda830fe7a">
        <updating/>
        <source>setAutoComplete(_value : Boolean)updating;
/*
	Created on 05 May 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	autoComplete := _value;
end;</source>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setEntryOverrideFlag" id="230a9bd7-eebc-4e17-a2d3-701d7678511a">
        <source>setEntryOverrideFlag();
//See CM_Job description...
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	wle	:	CM_WorkListEntry;
	flags	:	Integer;
	rtqe : CM_RTQueueEntry;
begin
	flags := 0;
	flags := flags.bitOr(MP_RT_AUTOPLAN );
	flags := flags.bitOr(MP_RT_IGNORE_WARNINGS );

	foreach wle in self.workListEntries do
		foreach rtqe in wle.allRTQueueEntries do
			rtqe.overRideFlags := flags;
		endforeach;
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="ae59fe2b-24af-43c0-b2d0-3da028bc649e">
        <updating/>
        <source>setForCreate(proxyJob: CM_RoadJob; _theTerminal: CM_Terminal) updating;
// ---------------------------------------------------------------------------
// Created:     30 May 2003 by cnwrs2
//
// Purpose:   
// 08 Feb 2024 navhl20 ChangeRequest 62084:[62379] EUP | Retrospective Operations - [54177.010] - Road Entry
// ---------------------------------------------------------------------------
vars

begin

	self.autoComplete 		:= proxyJob.autoComplete;
	self.batNumber			:= proxyJob.batNumber;
	self.carrierId			:= proxyJob.carrierId;
	self.jobNumber 			:= proxyJob.jobNumber;
	self.isReceiptRequired 	:= proxyJob.isReceiptRequired;
	self.regNumber			:= proxyJob.regNumber;
	self.roadTransAreaId	:= proxyJob.roadTransAreaId;
	self.myGate				:= proxyJob.myGate;
	self.driverId			:= proxyJob.driverId;
	self.myDriver			:= proxyJob.myDriver; // PAR 17703
	self.myCarrier 			:= proxyJob.myCarrier;
	self.myVehicle			:= proxyJob.myVehicle;
	self.myBatNumber		:= proxyJob.myBatNumber;
	self.myTerminal 		:= _theTerminal;
	self.retrospectiveDT 	:= proxyJob.retrospectiveDT;				//08.02.2023 navhl20 #62084[62379]
	
	if self.myBatNumber &lt;&gt; null then
		self.myBatNumber.setMyTerminal(self.myTerminal);
	endif;
	
	inheritMethod(proxyJob, _theTerminal);

end;</source>
        <Parameter name="proxyJob" type="CM_RoadJob"/>
        <Parameter name="_theTerminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setMyRFIDTag" id="05b7f334-dfc3-4c1b-8b65-2d925921a056">
        <updating/>
        <source>setMyRFIDTag(_rfidTag : CM_RFIDTag input) updating;
/*
Date		Who		Reason
23 Aug 2006	cnwer1	Initial creation - PAR#xxxx
18 Jun 2013	cnwcs5	par 31670 - new _context parameter for createVehicleVisitDetail method
19 Dec 2013	cnwdap1	PAR #32849 CCMS PEN 2321 Security Gate - don't free up the rfid tag here if we have a Security Gate,
															exit from the security gate will free up the rfid tag
*/
vars
	previous : CM_RFIDTag;
	rtEntry : CM_RTQueueEntry;
	vehicle : CM_Vehicle;
	vvrAssignedRFID : String;
begin
	if self.myRFIDTag &lt;&gt; _rfidTag then
	
		previous := self.myRFIDTag;
		vvrAssignedRFID:=self.myVehicleVisit.getRFIDTag ; //epr par 36908 17/9/15
		if _rfidTag = null then
			// deassigning
			// par #21849 If we have a Security Gate, RFID will be unassigned by Security Gate					// PAR #32849
			if vvrAssignedRFID &lt;&gt; null  then									// PAR #32849
				self.myVehicleVisit.createVisitRecordDetail (VisitRecord_DeassignRFIDTag, self.myRFIDTag, null);// par 31670
			endif;																								// PAR #32849
		else	
			// assigning
			// PAR #32849 If we have a security gate, we've already created an "Assign RFID Tag" detail			// PAR #32849
			if vvrAssignedRFID = null or not vvrAssignedRFID = _rfidTag.code  then 
				self.myVehicleVisit.createVisitRecordDetail (VisitRecord_AssignRFIDTag, _rfidTag, null);		// par 31670
			endif;																								// PAR #32849
		endif;
		
		self.myRFIDTag := _rfidTag;	
		
		//23 Apr 2012	NDL	Par 29417
		if not self.isTransient then
			//if previous &lt;&gt; null then																			// PAR #32849
			if previous &lt;&gt; null and not self.myTerminal.getConfig(SiteHasSecurityGate).Boolean   then				// PAR #32849
				global.causeEvent(self.myTerminal.getTerminalEvent(Event_RFIDTagFree), false, previous);
			endif;
			if _rfidTag &lt;&gt; null then
				global.causeEvent(self.myTerminal.getTerminalEvent(Event_RFIDTagInUse), false, _rfidTag);
			else
				vehicle := self.myVehicleVisit.vehicle;
				if vehicle &lt;&gt; null then
					app.myEventManager.createSingleObjInfoNoteEvt(vehicle, self.myTerminal.getTerminalEvent(Vehicle_Update_Event), vehicle);
				endif;
			endif;
			if not self.allEntries.isEmpty then
				foreach rtEntry in self.allEntries do
					if rtEntry.myQueue &lt;&gt; null then
						app.myEventManager.createSingleObjInfoNoteEvt(rtEntry.myQueue , self.myTerminal.getTerminalEvent(Event_Update_Queue_Entry), rtEntry );
					endif;
				endforeach;
			endif;
		endif;		
	endif;

epilog

end;</source>
        <Parameter name="_rfidTag" type="CM_RFIDTag" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMyVehicleVisitRecord" id="f94a4f1a-552c-4265-9449-46bc0589a171">
        <updating/>
        <source>setMyVehicleVisitRecord(_vvRec : CM_VehicleVisitRecord) updating;
// ---------------------------------------------------------------------------
