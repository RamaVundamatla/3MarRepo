    <JadeMethod name="tblSpellDict_sysNotify" id="426bae77-70dc-4222-8408-c5bde5c8a099">
        <controlMethod name="Table::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblSpellDict_sysNotify(table: Table input; eventType: Integer; theObject: Object; eventTag: Integer) updating;
// --------------------------------------------------------------------------------
// Created:		07 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if theObject.isKindOf(CnEcSpellWordByName) then
		self.setWordCount(theObject.CnEcSpellWordByName);
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
