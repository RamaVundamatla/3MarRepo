        <source>setLineNumber(_lineNumber:Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 July 2022	navtnr20	ChangeRequest 53974: EUP - OUT - Additional Fields on Release Line Level

*/

vars

begin
