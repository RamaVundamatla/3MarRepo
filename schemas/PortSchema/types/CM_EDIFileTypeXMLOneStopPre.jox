    <JadeMethod name="processSeals" id="eb33c1d6-4401-460e-8878-cae06f32da6b">
        <source>processSeals(	_xmlElementSeal : JadeXMLElement;
				_ediFile: CM_EDIFile input;
				_ediPreNote : CM_EDIPrenoteTI input
				):Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 August 2016	cnwndl1	Initial creation	TFS 2276 / 2565

*/

vars

	xmlSubElement : JadeXMLElement;
	str : String;

begin

	xmlSubElement := null;
	xmlSubElement := _xmlElementSeal.getElementByTagName(self.TagNumber); 
	if xmlSubElement &lt;&gt; null then
		str := xmlSubElement.textData.trimBlanks;
		if str &lt;&gt; null then
			_ediPreNote.sealNum := str;
		endif;
		
	endif;
	
	




	return true;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_xmlElementSeal" type="JadeXMLElement"/>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_ediPreNote" type="CM_EDIPrenoteTI" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="processVGM" id="e4ebbf98-781f-4cd1-9bf8-390e2a7dc825">
        <source>processVGM(	_xmlElementVGM : JadeXMLElement;
			_ediFile: CM_EDIFile input;
			_ediPreNote : CM_EDIPrenoteTI input
			):Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01/09/2016	cnwndl1	Initial creation	TFS 2276 / 2565
07/07/2017	cnwdap1	TFS 4492 SNO VERMAS Changes
*/

vars
	xmlSubElement : JadeXMLElement;
	str, timeStr : String;
	timestamp : TimeStamp;
	date : Date;
	time : Time;

begin
	// VGM structure is as follows
	// &lt;VGMCertificateStatement&gt;
	//		&lt;MethodOfWeightCalculation&gt;SM1&lt;/MethodOfWeightCalculation&gt;
	//		&lt;WeightVerificationDate&gt;CCYYMMDDHHMMZZZ&lt;/WeightVerificationDate&gt;
	//		&lt;WeightCertificateIssuingParty&gt;
	//			&lt;NameOfIssuingParty&gt;CONTAINER WEIGHING LTD&lt;/NameOfIssuingParty&gt;
	//			&lt;Street&gt;STREET&lt;/Street&gt;
	//			&lt;City&gt;CITY&lt;/City&gt;
	//			&lt;Country&gt;COUNTRY&lt;/Country&gt;
	//		&lt;/WeightCertificateIssuingParty&gt;
	//		&lt;Declarant&gt;
	//			&lt;NameOfDeclarant&gt;JOE BLOGGS&lt;/NameOfDeclarant&gt;
	//			&lt;CompanyOfDeclarant&gt;J EXPORTER&lt;/CompanyOfDeclarant&gt;
	//			&lt;DeclarantPhone&gt;0424222333&lt;/DeclarantPhone&gt;
	//			&lt;DeclarantEmail&gt;JBLOKE@EMAIL.COM&lt;/DeclarantEmail&gt;
	//		&lt;/Declarant&gt;
	//		&lt;EDISignature&gt;JOE BLOKE&lt;/EDISignature&gt;
	// &lt;/VGMCertificateStatement&gt;
	
	//21 Aug 2017	NDL	TFS 5846
	if _xmlElementVGM = null then
		 return true;
	endif;
	
	// easy stuff first - Method of weight calculation
	xmlSubElement := null;
	xmlSubElement := _xmlElementVGM.getElementByTagName(self.TagMethodOfWeightCalculation);
	if xmlSubElement &lt;&gt; null then
		str := xmlSubElement.textData.trimBlanks;
		if str &lt;&gt; null then
			_ediPreNote.vgmCommsType := str;
		endif;
	endif;
	
	// Weight verification date
	xmlSubElement := null;
	xmlSubElement := _xmlElementVGM.getElementByTagName(self.TagWeightVerificationDate);
	if xmlSubElement &lt;&gt; null then
		str := xmlSubElement.textData.trimBlanks;
		if str &lt;&gt; null then
			if str.length = 12 then
				_ediPreNote.vgmDeterminationDT := str.asTimeStampFromXMLFormat;
			elseif str.length = 15 then
				timeStr := str[1:12];
				timestamp.setDateTime(timeStr[1:4].Integer, timeStr[5:2].Integer, timeStr[7:2].Integer, timeStr[9:2].Integer, timeStr[11:2].Integer, null, null);
				timestamp := app.myTimeZoneHelper.convertTimeFromUtc(timestamp, app.myTimeZoneHelper.getSystemTimeZoneID);
				_ediPreNote.vgmDeterminationDT := timestamp;
			endif;
		endif;
	endif;
	
	// EDI signature
	xmlSubElement := null;
	xmlSubElement := _xmlElementVGM.getElementByTagName(self.TagEDISignature);
	if xmlSubElement &lt;&gt; null then
		str := xmlSubElement.textData.trimBlanks;
		if str &lt;&gt; null then
			_ediPreNote.weightCertifiedName := str;
		endif;
	endif;
	
	// now WeightCertificateIssuingParty section
	xmlSubElement := null;
	xmlSubElement := _xmlElementVGM.getElementByTagName(self.TagWeightCertIssuingParty);
	if xmlSubElement &lt;&gt; null then
		if not self.processWeightCertIssuingParty( xmlSubElement, _ediFile, _ediPreNote ) then
			return false;
		endif;
	endif;
	
	// now Declarant section
	xmlSubElement := null;
	xmlSubElement := _xmlElementVGM.getElementByTagName(self.TagDeclarant);
	if xmlSubElement &lt;&gt; null then
		if not processDeclarant( xmlSubElement, _ediFile, _ediPreNote ) then
			return false;
		endif;
	endif;
	
	return true;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_xmlElementVGM" type="JadeXMLElement"/>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_ediPreNote" type="CM_EDIPrenoteTI" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="processWeightCertIssuingParty" id="39eb6240-88d4-47db-96a1-c368d388b7d6">
        <source>processWeightCertIssuingParty(	_xmlElementParty : JadeXMLElement;
								_ediFile : CM_EDIFile input;
								_ediPreNote : CM_EDIPrenoteTI input	) : Boolean protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 05/07/2017	cnwdap1		Initial creation TFS 4492 SNO VERMAS Changes
//
vars
	xmlSubElement : JadeXMLElement;
	str, street, city, country : String;

begin
	// WeightCertificateIssuingParty segment is structured as follows
	//	&lt;WeightCertificateIssuingParty&gt;
	//		&lt;NameOfIssuingParty&gt;CONTAINER WEIGHING LTD&lt;/NameOfIssuingParty&gt;
	//		&lt;Street&gt;STREET&lt;/Street&gt;
	//		&lt;City&gt;CITY&lt;/City&gt;
	//		&lt;Country&gt;COUNTRY&lt;/Country&gt;
	//	&lt;/WeightCertificateIssuingParty&gt;
	
	// Name Of Issuing Party
	xmlSubElement := null;
	xmlSubElement := _xmlElementParty.getElementByTagName(self.TagNameOfIssuingParty);
	if xmlSubElement &lt;&gt; null then
		str := xmlSubElement.textData.trimBlanks;
		if str &lt;&gt; null then
			_ediPreNote.weightCertifiedReference := str;
		endif;
	endif;
	
	// Street
	xmlSubElement := null;
	xmlSubElement := _xmlElementParty.getElementByTagName(self.TagStreet);
	if xmlSubElement &lt;&gt; null then
		street := xmlSubElement.textData.trimBlanks;
	endif;
	// City
	xmlSubElement := null;
	xmlSubElement := _xmlElementParty.getElementByTagName(self.TagCity);
	if xmlSubElement &lt;&gt; null then
		city := xmlSubElement.textData.trimBlanks;
	endif;
	// Country
	xmlSubElement := null;
	xmlSubElement := _xmlElementParty.getElementByTagName(self.TagCountry);
	if xmlSubElement &lt;&gt; null then
		country := xmlSubElement.textData.trimBlanks;
	endif;
	if street &lt;&gt; null or city &lt;&gt; null or country &lt;&gt; null then
	//	str := street &amp; Space &amp; city &amp; Space &amp; country;
		str := street &amp; CrLf &amp; city &amp; CrLf &amp; country;	//15 Nov 2017	NDL	TFS 7779 - de-referenced by String
		_ediPreNote.vgmMail := str;
	endif;
	
	return true;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_xmlElementParty" type="JadeXMLElement"/>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_ediPreNote" type="CM_EDIPrenoteTI" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
