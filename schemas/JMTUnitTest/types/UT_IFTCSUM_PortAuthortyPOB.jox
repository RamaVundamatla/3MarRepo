			self.assertEqualMsg(ti.weight.String, "246910.0000", "For Cargo On Ship 2"); 
			self.assertEqualMsg(ti.totalVolume.String, "2351.4670", "For Cargo On Ship 2"); 
			self.assertEqualMsg(ti.commodity, "", "For Cargo On Ship 2");
			self.assertEqualMsg(ti.consignee, "00172", "For Cargo On Ship 2");
			self.assertEqualMsg(ti.getImExStatusString, "Import", "For Cargo on ship 2");
		elseif ti.billOfLading = "00000003" then
			self.assertEqualMsg(ti.cargoTypeDescr, "Cannon", "For Cargo On Ship 3"); 
			self.assertEqualMsg(ti.getPortOfOrigin(), "", "For Cargo On Ship 3"); 
			self.assertEqualMsg(ti.billOfLading, "00000003", "For Cargo On Ship 3");
			self.assertEqualMsg(ti.dischargePort, "AUPKL", "For Cargo On Ship 3"); 
