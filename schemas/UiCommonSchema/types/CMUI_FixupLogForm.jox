    <JadeMethod name="setLogInfoLevels" id="0916e7ce-c6fb-4e04-9c2e-94fcd43ad210">
        <source>setLogInfoLevels( _byNotification : Boolean; _newLevel : Integer );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 November 2019	jlgndl1	Initial creation	TFS 47053

*/

vars

	index : Integer;
	logLevelStr : String;
	allPreSelected : StringArray;

begin

	if _byNotification then
		create allPreSelected transient;
		self.allSelectedLevels.copy( allPreSelected );
		self.setCurrentCapt( _newLevel );
	else
		self.setCurrentCapt( app.logLevel );
	endif;

	self.tblLogLevel.visible := self.chkGeneral.value;
	self.lblLogLevels.visible := self.tblLogLevel.visible;
	self.tblLogLevel.clearTable;
	self.allSelectedLevels.clear();
	
	if self.tblLogLevel.visible then
		foreach index in 0 to 5 do
		
			if _byNotification then
				if index &gt; _newLevel then
					break;
				endif;
			else
				if index &gt; app.logLevel then
					break;
				endif;
			endif;
			
			logLevelStr := app.getLoggingLevelString( index );
			
			if _byNotification then
				if allPreSelected.includes( logLevelStr ) then
					//it was selected before
					self.tblLogLevel.addItem( "1" &amp; Tab &amp; logLevelStr);
				else
					//it wasn't selected before
					self.tblLogLevel.addItem( "0" &amp; Tab &amp; logLevelStr);
				endif;
			else
				//default behaviour
				self.tblLogLevel.addItem( "1" &amp; Tab &amp; logLevelStr);
			endif;
			self.allSelectedLevels.add( logLevelStr );
			
		endforeach;
	endif;

epilog

	delete allPreSelected;

end;</source>
        <Parameter name="_byNotification" type="Boolean"/>
        <Parameter name="_newLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="a956ed43-c76b-487b-8a9f-dabc089fd3aa">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 May 2011	cnwndl1	Initial creation
29 Nov 2018	NDL	TFS 42103 - limit view to those items you are allowed to see, because the form is now public... not just developers

*/

vars

	showConfigOption : Boolean;
	showAutoPlanOption : Boolean;
	showQueuing : Boolean;
	showInvoicing : Boolean;
	
	userTerminal : CM_UserTerminal;
	terminal : CM_Terminal;

begin
	
	inheritMethod();
	
	self.caption := "System Logging form";
	
	app.setMyLoggingForm( self );
	
	if not app.isSpecial() then
	
		self.chkStack.value := false;
		self.chkStack.visible := false;
		
		self.chkTime.value := false;
		self.chkTime.visible := false;
		
		self.btnInspect.visible := false;
	endif;
	
	if not app.isDevelopmentSystem or not app.isSpecial() then
	
		self.chkTrxError.value := false;
		self.chkTrxError.visible := false;
		
		self.chkTrxMethods.value := false;
		self.chkTrxMethods.visible := false;
		
	endif;
	
	showConfigOption := app.getMyUser.canDo(null, PmAdmConfigView) or app.getMyUser.canDo(null, PmAdmConfigMaint);
	if not showConfigOption then
		self.chkConfig.value := false;
		self.chkConfig.visible := false;
	endif;
	
	foreach userTerminal in app.getMyUser.allUserTerminals do
		terminal := userTerminal.myTerminal;
		if not showAutoPlanOption then
			if terminal.isAutoPlanningEnabled() then
				// ### JIRA 33505 30DEC2024 NAVAB1 Mod_YardPlanning is now part of base module if app.getMyUser.canDo(terminal, Mod_YardPlanning) then
					showAutoPlanOption := true;
				//endif;
			endif;
		endif;
		if not showQueuing then
			showQueuing := app.getMyUser.canDo(terminal, PmAdmQueueView) or app.getMyUser.canDo(terminal, PmAdmQueueMaint);
		endif;
		if not showInvoicing then
			showInvoicing := app.getMyUser.canDo(terminal, PmAdmTransactionmapView) or app.getMyUser.canDo(terminal, PmAdmTransactionmapMaint);
		endif;
	endforeach;
	
	if not showAutoPlanOption then
		self.chkAutoPlan.value := false;
		self.chkAutoPlan.visible := false;
	endif;
	
	if not showInvoicing then
		self.chkInvoice.value := false;
		self.chkInvoice.visible := false;
	endif;
	
	self.setLogInfoLevels( false, 0 );	//	26 Nov 2019	NDL	TFS 47053
	self.beginNotification(process, EVENT_APP_LOG_LEVEL, Response_Continuous, 0);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tblLogLevel_click" id="ba156a22-2d6c-4ac1-a6f7-5f5e732ea751">
        <controlMethod name="CMUI_ListTable::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblLogLevel_click(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 November 2019	jlgndl1	Initial creation	TFS 47053

*/

vars

	rowIndex : Integer;
	logLevelStr : String;
	selectMe : Boolean;

begin

	rowIndex := self.tblLogLevel.row;
	if rowIndex &lt; 1 or rowIndex &gt; self.tblLogLevel.rows then
		return;
	endif;
	logLevelStr := self.tblLogLevel.accessCell( rowIndex, 2 ).text; 
	
	selectMe := self.tblLogLevel.accessCell( rowIndex, 1 ).text = "1"; // Value after the click action
	
	if selectMe then
		if not self.allSelectedLevels.includes( logLevelStr ) then
			self.allSelectedLevels.add( logLevelStr );
		endif;
	else
		if self.allSelectedLevels.includes( logLevelStr ) then
			self.allSelectedLevels.remove( logLevelStr );
		endif;
	endif;
	
	return;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="7b59dea6-ad8d-482d-9759-636a6df14792">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 05 December 2019 08:09:05.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0017366, locale);
	btnClear.translateBubbleHelp(Xlat_0016043, locale);
	btnClear.translateCaption(Xlat_0016044, locale);
	btnClose.translateBubbleHelp(Xlat_0016045, locale);
	btnClose.translateCaption(Xlat_0016046, locale);
	btnFile.translateBubbleHelp(Xlat_0016047, locale);
	btnFile.translateCaption(Xlat_0016048, locale);
	btnFind.translateBubbleHelp(Xlat_0016049, locale);
	btnFind.translateCaption(Xlat_0016050, locale);
	btnInspect.translateBubbleHelp(Xlat_0016887, locale);
	btnInspect.translateCaption(Xlat_0016888, locale);
	btnLogLevel.translateBubbleHelp(Xlat_0023830, locale);
	btnLogLevel.translateCaption(Xlat_0023831, locale);
	btnPrint.translateBubbleHelp(Xlat_0016051, locale);
	btnPrint.translateCaption(Xlat_0016052, locale);
	chkAutoPlan.translateBubbleHelp(Xlat_0016889, locale);
	chkAutoPlan.translateCaption(Xlat_0016053, locale);
	chkCardLog.translateBubbleHelp(Xlat_0016890, locale);
	chkCardLog.translateCaption(Xlat_0016054, locale);
	chkConfig.translateBubbleHelp(Xlat_0016891, locale);
	chkConfig.translateCaption(Xlat_0016055, locale);
	chkGeneral.translateBubbleHelp(Xlat_0016892, locale);
	chkGeneral.translateCaption(Xlat_0016056, locale);
	chkInvoice.translateBubbleHelp(Xlat_0021243, locale);
	chkInvoice.translateCaption(Xlat_0021244, locale);
	chkPermissions.translateBubbleHelp(Xlat_0016893, locale);
	chkPermissions.translateCaption(Xlat_0016057, locale);
	chkStack.translateBubbleHelp(Xlat_0016897, locale);
	chkStack.translateCaption(Xlat_0016059, locale);
	chkTime.translateBubbleHelp(Xlat_0016898, locale);
	chkTime.translateCaption(Xlat_0016060, locale);
	chkTrxError.translateBubbleHelp(Xlat_0016899, locale);
	chkTrxError.translateCaption(Xlat_0016900, locale);
