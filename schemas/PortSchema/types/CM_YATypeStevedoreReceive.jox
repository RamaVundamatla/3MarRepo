    <JadeMethod name="isStorageDetailMatch" id="6e4778ce-341a-4c51-afff-a22e25cfdfdf">
        <source>isStorageDetailMatch(_criteria: CM_YACriteria; _ti: CM_TrackedItem; _tiTrx: CM_TITransaction): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Oct 2020 cnwma1 ChangeRequest 50112: ASPA - GCI Stevedores

*/
vars 
	stevedore : CM_Stevedore;
begin
	
	
	if _tiTrx &lt;&gt; null then	
		if _tiTrx.stevedoreCode &lt;&gt; null then
			stevedore := app.myRoot.allStevedores[ _tiTrx.stevedoreCode ];
		endif;
	else
		stevedore := app.myRoot.allStevedores [_ti.stevedoreCodeRecieve];
	endif;
	
	if _criteria.myYAData.CM_YADataObjects.matchesStorage(stevedore) then
		return true;
	endif;
	
	// default value
	if _criteria.myYAData.isKindOf(CM_YADataPattern) and
	   _criteria.myYAData.CM_YADataPattern.pattern = null then
		return true;
	endif;
	
	return false;
end;</source>
        <Parameter name="_criteria" type="CM_YACriteria"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_tiTrx" type="CM_TITransaction"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
