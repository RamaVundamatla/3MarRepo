<Class name="CM_QStrCustDocAgentMethod" id="00e25380-e86d-4d0c-a622-a51d5cbeb782">
    <superclass name="CM_QStringLookupMethod"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="create" id="01e655ae-d7ce-406d-a5df-fe7a317fa8db">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/09/2023	navkc1	CR 60426 Task 60570: Jade - Cust Doc on TI and Trans Selector Query

*/

vars
	operator	: CM_QStringIsOneOf;
begin
	if self.isTransient() then
		return;
	endif;
	
	create operator as CM_QStringIsOneOf persistent;
	self.allAllowedOperators.add(operator);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getControlNameForOperator" id="ee09877f-26a3-4367-b07a-e88e8f859f6f">
        <source>getControlNameForOperator(_operator: CM_QueryOperator): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/09/2023	navkc1	CR 60426 Task 60570: Jade - Cust Doc on TI and Trans Selector Query

*/

vars

begin
	
	if CM_QReferenceLookup.hasInstance(_operator) then
		return 'cmbCustDocAgent';
	endif;

epilog

end;</source>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getValueForObject" id="e9493867-fdf3-46c7-ab1c-af91e891a2f9">
        <source>getValueForObject(_obj: Object; _op: CM_QueryOperator input): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/09/2023	navkc1	CR 60426 Task 60570: Jade - Cust Doc on TI and Trans Selector Query

*/

vars
	agentCode	: String;
	agent		: CM_CustomsAgent;
begin

	if self.propertyName = CM_TrackedItem::getCustomDocAgentCodeForSel.name then
		agentCode := _obj.sendMsg(self.propertyName).String;
		
		agent := app.myRoot.allCustomsAgents[agentCode];
		
		if agent &lt;&gt; null then
			return agent.code;
		endif;
		
		return inheritMethod(_obj, _op);
	else
		return inheritMethod(_obj, _op);
	endif;

epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="setComboValues" id="4df24ca7-624b-46d6-b1c5-931f4633f31e">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/09/2023	navkc1	CR 60426 Task 60570: Jade - Cust Doc on TI and Trans Selector Query
*/

vars
	agent					: CM_CustomsAgent;
begin

	_combo.clear();
	
	foreach agent in app.myRoot.allCustomsAgents do
		_combo.itemObject[_combo.addItem(agent.code &amp; " - " &amp; agent.name)] := agent;
	endforeach;

epilog
	
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="6c1b9ef2-5dc0-4fca-b5d9-be62a7c957af">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/09/2023	navkc1	CR 60426 Task 60570: Jade - Cust Doc on TI and Trans Selector Query

*/

vars
	selectionValue			: Integer;
	idx						: Integer;
	agent					: CM_CustomsAgent;
begin
	
	_tbl.clear();
	_tbl.rows := 0;
	
	foreach agent in app.myRoot.allCustomsAgents do
		selectionValue := 0;
		if _operator &lt;&gt; null then
			if _operator.CM_QStringIsOneOf.allSelectionValues.includes(agent.code) then
				selectionValue := 1;
			endif;
		endif;
		
		idx := _tbl.addItem(selectionValue.String &amp; Tab &amp; agent.code &amp; " - " &amp; agent.name);
		_tbl.accessRow(idx).itemObject := agent;
		_tbl.row := idx;
		_tbl.change(_tbl);
	endforeach;

epilog
	
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="4760d7a3-303c-4de7-88e2-28312e3ad75b">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/09/2023	navkc1	CR 60426 Task 60570: Jade - Cust Doc on TI and Trans Selector Query

*/

vars
	agent			: CM_CustomsAgent;
	stringArray		: StringArray;
	numRows,
	index			: Integer;
	string			: String;
begin
	
	create stringArray transient;
	numRows := _tbl.rows;
	
	foreach index in (_tbl.fixedRows + 1) to numRows do
		string := _tbl.accessCell(index, 1).text;
		
		if string = TableCheckBox_Selected then
			agent := _tbl.accessRow(index).itemObject.CM_CustomsAgent;
			stringArray.add(agent.code);
		endif;
	endforeach;
	
	_op.setSearchValue(stringArray);

	
epilog
	
	delete stringArray;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="9ac3ba19-daad-4e67-a732-7ee26dd6b44d">
        <source>translateToDisplayValue(_value: Any): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/09/2023	navkc1	CR 60426 Task 60570: Jade - Cust Doc on TI and Trans Selector Query

*/

vars

begin
	if _value.isKindOf(CM_CustomsAgent) then
		if _value &lt;&gt; null then
			return _value.CM_CustomsAgent.code;
		else
			return null;
		endif;
	else
		return _value.String;
	endif;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="39eade29-ceca-4992-a1b0-c1b93aa76b0a">
        <source>translateToSearchValue(_value: Any): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/09/2023	navkc1	CR 60426 Task 60570: Jade - Cust Doc on TI and Trans Selector Query

*/

vars
	invalidObj 	: Boolean;
	object 		: CM_CustomsAgent;
	returnVal 	: String;
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then
			return _value;
		endif;
		
		if _value.isKindOf(CM_CustomsAgent) then
			object := _value.CM_CustomsAgent;
		endif;
	endif;
	
	if object &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, object, invalidObj);
		
		returnVal := object.code;
	endif;
	
	return returnVal;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
