    <JadeMethod name="keyDown" id="20356953-1fe1-483c-89f5-73a02624d6b9">
        <updating/>
        <source>keyDown(textbox: TextBox input; keyCode: Integer io; shift: Integer) updating;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	// cnwdad1 14/07/2000 - Added the following check.
	if self.readOnly then
		inheritMethod(textbox, keyCode, shift);
		return;

	elseif keyCode = JSS_KEY_ARROWLEFT then
		if self.cursorPosition &gt; 1 then
			self.cursorPosition	:=	self.cursorPosition - 1;

			if self.text[self.cursorPosition:1] = self.myDateFormat.separator then
				self.cursorPosition	:=	self.cursorPosition - 1;
				self.selStart	:=	self.cursorPosition;
			endif;
		endif;
		
	elseif keyCode = JSS_KEY_ARROWRIGHT then
		if self.cursorPosition &lt; self.text.length() then
			self.cursorPosition	:=	self.cursorPosition + 1;

			if self.text[self.cursorPosition:1] = self.myDateFormat.separator then
				if self.cursorPosition &lt; self.text.length() then
					self.cursorPosition	:=	self.cursorPosition + 1;
				endif;

				self.selStart	:=	self.cursorPosition - 2;
			endif;
		else
			self.cursorPosition	:=	self.text.length() + 1;
		endif;
		
	elseif keyCode = JSS_KEY_HOME then
		self.cursorPosition	:=	1;
		
	elseif keyCode = JSS_KEY_END then
		self.cursorPosition	:=	self.text.length() + 1;
		
	elseif keyCode = J_key_Back then
		if self.cursorPosition &gt; 1 then
			self.cursorPosition	:=	cursorPosition - 1;

			if self.text[self.cursorPosition:1] = self.myDateFormat.separator then
				if self.cursorPosition &gt; 1 then
					self.cursorPosition	:=	self.cursorPosition - 1;
					self.selStart		:=	self.cursorPosition;
					self.text.jssReplaceCharacter('0'.Character, self.cursorPosition);
					keyCode				:=	0;
					self.selStart		:=	self.cursorPosition - 1;
				endif;
				
			else
				self.text.jssReplaceCharacter('0'.Character, self.cursorPosition);
				keyCode			:=	0;
				self.selStart	:=	self.cursorPosition - 1;
			endif;

		else
			keyCode	:=	0;
		endif;
		
	elseif keyCode = J_key_Stop then
		self.text.jssReplaceCharacter('0', self.cursorPosition);
		self.selStart	:=	self.cursorPosition - 1;
		keyCode	:=	0;
	endif;

	inheritMethod(textbox, keyCode, shift);
end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="keyPress" id="f6bbec40-781f-4e16-a556-3d9e8ca0aac4">
        <updating/>
        <source>keyPress(textbox: TextBox input; keyCode: Integer io) updating;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if	(not self.readOnly)								// cnwdad1 14/07/2000.
	and ((keyCode = J_key_0)
	or (keyCode = J_key_1)
	or (keyCode = J_key_1)
	or (keyCode = J_key_2)
	or (keyCode = J_key_3)
	or (keyCode = J_key_4)
	or (keyCode = J_key_5)
	or (keyCode = J_key_6)
	or (keyCode = J_key_7)
	or (keyCode = J_key_8)
	or (keyCode = J_key_9)
	or (keyCode = J_key_Space))
	and ((self.cursorPosition &lt;= self.text.length))
	then
		if (keyCode = J_key_Space) then
			keyCode	:=	J_key_0;
		endif;

		self.text.jssReplaceCharacter(keyCode.Character, self.cursorPosition);
		self.cursorPosition	:=	self.cursorPosition + 1;

		if self.cursorPosition &lt; textbox.text.length()
		and textbox.text[self.cursorPosition:1] = self.myDateFormat.separator
		then
			self.cursorPosition	:=	self.cursorPosition + 1;
		endif;

		keyCode				:=	0;
		textbox.selStart	:=	self.cursorPosition - 1;
	else
		keyCode	:=	0;
	endif;

	inheritMethod(textbox, keyCode);
	
	if (not self.isChanged) then
		self.isChanged	:=	true;
		self.firstChange(self);
	endif;
end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="lostFocus" id="1700a2b6-203d-48ba-aa35-5a30baca86a4">
        <updating/>
        <source>lostFocus(textbox: TextBox input) updating;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.date.parseForCurrentLocale(self.text);
	self.isDateValid	:=	self.date.isValid();

	if (not self.isDateValid) then
		if (not self.isDateBlank()) then
			// If at least part of the date was entered, then give an audio
			// prompt to the User that it is invalid (as it must be to have
			// gotten into here).
			global.beep();
		endif;

		self.text	:=	self.getNumericDateFormat(null);
	endif;

	inheritMethod(textbox);
end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="readOnly" id="8e007a45-93db-4929-be6d-60416f43360a">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>readOnly(set: Boolean; value: Boolean io) updating, mapping;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if isTransient() = true then
		if set then
			inheritMethod(set, value);
			
			if app.getName() = "Jade" then
				if value then
					backColor	:=	self.getSystemColor(Window.Color_3DFace);
					tabStop		:=	false;
				else
					backColor	:=	self.getSystemColor(Window.Color_Window);
					tabStop		:=	true;
				endif;
			else
				if value then
					backColor	:=	Gray;
					tabStop		:=	false;
				else
					backColor	:=	White;
					tabStop		:=	true;
				endif;
			endif;

			// Make sure that a repaint is done.
			self.refresh();
		else
			inheritMethod(set, value);
		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setDate" id="41bae583-dfc1-46e2-a8ea-ec182e2a504f">
        <updating/>
        <source>setDate(pDate:Date) updating;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		Sets the receiver's current date.
//
// Parameters:	pDate - The new date value.
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pDate = null or (not pDate.isValid) then
		self.text			:=	self.getNumericDateFormat(null);
		self.date			:=	null;
	else
		self.text			:=	self.getNumericDateFormat(pDate);
		self.date			:=	pDate;
		self.isDateValid	:=	true;
	endif;
	
	self.isChanged	:=	false;
end;</source>
        <Parameter name="pDate" type="Date"/>
    </JadeMethod>
    <JadeMethod name="text" id="d6a40af7-53d4-41cb-ab76-8b6a4d5b3863">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>text(set: Boolean; value: String io) updating, mapping;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		Mapping method for the "text" property.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	today	: Date;
	
begin
	if (not self.isInPainter())
	and self.myDateFormat &lt;&gt; null
	and (not set)
	then
		if today.parseForCurrentLocale(value) then
			value	:=	self.getNumericDateFormat(today);
		endif;
	endif;
	
	inheritMethod(set, value);
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="855fdc41-0014-4e22-94b7-9a846907ea5b">
        <updating/>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	today	: Date;

begin
	if (not self.isInPainter()) then
		self.myDateFormat	:=	app.currentLocaleInfo.dateInfo;

		if self.isDefaultToToday then
			self.text			:=	self.getNumericDateFormat(today);
			self.date			:=	today;
			self.isDateValid	:=	(self.date.isValid);
		else
			self.text			:=	self.getNumericDateFormat(null);
			self.date			:=	null;
			self.isDateValid	:=	false;
		endif;

		self.cursorPosition	:=	1;
	endif;

	inheritMethod(cntrl, persistCntrl);
end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
