    <JadeMethod name="setupForm" id="791c133c-cacf-4fbf-af47-fb86e0ef41be">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	app.mousePointer := Window.MousePointer_HourGlass;
	self.centreWindow();
	self.initGroupBox();
	self.showToolbar := true;
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	inheritMethod();
	self.addToolbarControls();
	self.doResize();
epilog
	app.mousePointer := Window.MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="a9843c49-764a-4c73-9cf3-54df2142d438">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0006680, locale);
	lblRequests.translateCaption(Xlat_0003111, locale);
	magCargo.translateCaption(Xlat_0003112, locale);
end;</source>
    </JadeMethod>
</GUIClass>
