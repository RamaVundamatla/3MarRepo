    <JadeMethod name="isOSTiBeside" id="f3ce9f53-166a-47ea-bb14-cb3e9bd4c8b6">
        <source>isOSTiBeside(_lc: CM_LocationsController; _height: Integer) : Boolean protected;

/*

Purpose:			Checks whether any OS TIs are *right* beside the given location controller and height

Parameters:			

Return Value:		


Date				Who		Reason
10 April 2018		jlgmd1	Initial creation TFS 37853 - Fix drawing spaces around containers whos length doesn't fit the standard 20ft grid

*/

vars
	ti,
	stackTi	: CM_TrackedItem;
begin
	while true do :checkTiLoop
		foreach ti in _lc.allTrackedItemOSBackEnds do
			ti.myPrimaryActualLocation.getTIAtHeight(stackTi, _height, REAL_MODE);
			if stackTi &lt;&gt; null then
				break checkTiLoop;
			endif;
		endforeach;
		foreach ti in _lc.allTrackedItemOSBackEndsPd do
			ti.myPrimaryPlannedLocation.getTIAtHeight(stackTi, _height, PLANNING_MODE);
			if stackTi &lt;&gt; null then
				break checkTiLoop;
			endif;
		endforeach;
		foreach ti in _lc.allTrackedItemOSBackEndsQd do
			ti.myPrimaryQueuedLocation.getTIAtHeight(stackTi, _height, QUEUE_MODE);
			if stackTi &lt;&gt; null then
				break checkTiLoop;
			endif;
		endforeach;
		return false;
	endwhile;
	
	return true;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <Parameter name="_height" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
