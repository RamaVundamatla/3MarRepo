    <JadeMethod name="trxCreateEDIShipManifest" id="f0c1c504-9efb-42c4-941b-ecb315fa00d4">
        <updating/>
        <source>trxCreateEDIShipManifest(_allProxyVoyages: CM_ObjectArray; _allCmifPrenotes: CMIF_TIObjectArray; _validateOnly: Boolean; _terminal: CM_Terminal; _ediData : CM_EDIData; _passport: CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:	15 October 2009 By Graeme Black cnwgb1
// Status: 	
// Purpose:	Create a Ship Manifest from EDI ( CCMS MES 1008 cnwgb1)
// ---------------------------------------------------------------------------
vars
	objectVoyage : Object; 
	proxyVoyage : CM_Voyage;
	proxyGlobalVoyage : CM_VoyageGlobal;
	realVoyage : CM_Voyage;
	interfacePrenote : CMIF_TIObject;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;

	foreach objectVoyage in _allProxyVoyages do
		proxyVoyage := objectVoyage.CM_Voyage;
		create proxyGlobalVoyage transient;
		proxyGlobalVoyage.setProxy(proxyVoyage.code, proxyVoyage.vesselCode, null, null, null, null, null, 0, null, app.myRoot);
		proxyVoyage.setMyVoyageGlobalArrival(proxyGlobalVoyage);		
		// Perform the operation
		app.myUtilityCA.utlCreateVoyage(proxyVoyage, realVoyage, null, null, false, _passport);
		if _passport.hasErrors() then
			return;
		endif;		
		//realVoyage := null;
		delete proxyGlobalVoyage;
//write realVoyage.myTerminal.allVoyagesByCode[realVoyage.code, realVoyage.arrivedDT]; //Delete cnwgb1
	endforeach;

	foreach interfacePrenote in _allCmifPrenotes do
		if interfacePrenote.isKindOf(CMIF_PreNote) then
			if app.isSubTerminalsOn(interfacePrenote.myTerminal) then
				if interfacePrenote.mySubTerminal = null then
					interfacePrenote.setSubTerminalDefault();
				endif;
			endif;
			
			interfacePrenote.validateForCreate(_passport);
			
			if _passport.allErrors.size &gt; 100 then
				app.setContinueCMExceptions(false);  // dh 10/7/2008 par 17254 added this option for performance
			else
				app.setContinueCMExceptions(true);
			endif;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Item is not a preNote (' &amp; interfacePrenote.String &amp; ')');
		endif;
	endforeach;
	
	if _passport.hasErrors() then
		return;
	endif;
	
	app.setContinueCMExceptions(true);

	if not _validateOnly then
		_passport.useTIDictDeferUpdate := true;
		_passport.useTITransactionDeferUpdate := true;
	endif;
	
	app.myUtilityCA.utlCreatePreNotes(_allCmifPrenotes, _validateOnly, _passport);
	
	if _validateOnly then
		app.cmsAbortTransaction();
		return; //ccms1845
	endif;
	if app.myPassport.noErrors then //ccms1845
		app.myUtilityUA.utlSetEDIDataStatus(_ediData, CM_EDIFile.EDI_STATUS_DBLOADED, null); //ccms1845
	endif;

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <text>to be deleetd
//04 Feb 2013	cnwrs1	Par 31119 include Tranships as ROBs for EDI Proposed</text>
        <Parameter name="_allProxyVoyages" type="CM_ObjectArray"/>
        <Parameter name="_allCmifPrenotes" type="CMIF_TIObjectArray"/>
        <Parameter name="_validateOnly" type="Boolean"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_ediData" type="CM_EDIData"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
