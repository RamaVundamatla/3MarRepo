    <JadeMethod name="convertBaseToTarget" id="55950964-14c2-4f87-88b7-5da01409d5bb">
        <source>convertBaseToTarget(pMeasure: Real; pUnitTo: Integer): Real protected;
// --------------------------------------------------------------------------------
// Created:		26 May 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	convertedMeasure	: Real;
	
begin
	if pUnitTo = self.BARRELS_OIL then
		convertedMeasure	:=	pMeasure / 158.987294928;

	elseif pUnitTo = self.BUSHELS_UK then
		convertedMeasure	:=	pMeasure / 36.36872;

	elseif pUnitTo = self.BUSHELS_US then
		convertedMeasure	:=	pMeasure / 35.23907016688;

	elseif pUnitTo = self.CENTILITRES then
		convertedMeasure	:=	pMeasure / 0.01;

	elseif pUnitTo = self.CUBIC_CENTIMETRES then
		convertedMeasure	:=	pMeasure / 0.001;

	elseif pUnitTo = self.CUBIC_DECAMETRES then
		convertedMeasure	:=	pMeasure / 1000000;

	elseif pUnitTo = self.CUBIC_DECIMETRES then
		convertedMeasure	:=	pMeasure / 1;
		
	elseif pUnitTo = self.CUBIC_FEET then
		convertedMeasure	:=	pMeasure / 28.316846592;

	elseif pUnitTo = self.CUBIC_INCHES then
		convertedMeasure	:=	pMeasure / 0.016387064;

	elseif pUnitTo = self.CUBIC_METRES then
		convertedMeasure	:=	pMeasure / 1000;

	elseif pUnitTo = self.CUBIC_MILLIMETRES then
		convertedMeasure	:=	pMeasure / 0.000001;

	elseif pUnitTo = self.CUBIC_YARDS then
		convertedMeasure	:=	pMeasure / 764.554857984;

	elseif pUnitTo = self.DECILITRES then
		convertedMeasure	:=	pMeasure / 0.1;

	elseif pUnitTo = self.FLUID_OUNCES_UK then
		convertedMeasure	:=	pMeasure / 0.0284130625;

	elseif pUnitTo = self.FLUID_OUNCES_US then
		convertedMeasure	:=	pMeasure / 0.0295735295625;

	elseif pUnitTo = self.GALLONS_DRY_US then
		convertedMeasure	:=	pMeasure / 4.40488377086;

	elseif pUnitTo = self.GALLONS_LIQUID_US then
		convertedMeasure	:=	pMeasure / 3.785411784;

	elseif pUnitTo = self.GALLONS_UK then
		convertedMeasure	:=	pMeasure / 4.54609;

	elseif pUnitTo = self.LITRES then
		convertedMeasure	:=	self.measure;

	elseif pUnitTo = self.LITRES_1901_TO_1964 then
		convertedMeasure	:=	pMeasure / 1.000028;

	elseif pUnitTo = self.MILLILITRES then
		convertedMeasure	:=	pMeasure / 0.001;

	elseif pUnitTo = self.PINTS_DRY_US then
		convertedMeasure	:=	pMeasure / 0.5506104713575;

	elseif pUnitTo = self.PINTS_LIQUID_US then
		convertedMeasure	:=	pMeasure / 0.473176473;

	elseif pUnitTo = self.PINTS_UK then
		convertedMeasure	:=	pMeasure / 0.56826125;

	elseif pUnitTo = self.QUARTS_DRY_US then
		convertedMeasure	:=	pMeasure / 1.101220942715;

	elseif pUnitTo = self.QUARTS_LIQUID_US then
		convertedMeasure	:=	pMeasure / 0.946352946;

	elseif pUnitTo = self.QUARTS_UK then
		convertedMeasure	:=	pMeasure / 1.1365225;

	else
		JSSException.raise_(JSS_X_03004, "[" &amp; pUnitTo.String &amp; "] is an unknown unit of volume to convert to.");

	endif;
epilog
	return convertedMeasure;
end;</source>
        <access>protected</access>
        <Parameter name="pMeasure" type="Real"/>
        <Parameter name="pUnitTo" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="convertToBaseUnit" id="bdf64948-b740-440e-b859-7a90fa6128cf">
        <source>convertToBaseUnit(pUnitFrom: Integer): Real protected;
// --------------------------------------------------------------------------------
// Created:		26 May 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	convertedMeasure	: Real;
	
begin
	if pUnitFrom = self.BARRELS_OIL then
		convertedMeasure	:=	self.measure * 158.987294928;

	elseif pUnitFrom = self.BUSHELS_UK then
		convertedMeasure	:=	self.measure * 36.36872;

	elseif pUnitFrom = self.BUSHELS_US then
		convertedMeasure	:=	self.measure * 35.23907016688;

	elseif pUnitFrom = self.CENTILITRES then
		convertedMeasure	:=	self.measure * 0.01;

	elseif pUnitFrom = self.CUBIC_CENTIMETRES then
		convertedMeasure	:=	self.measure * 0.001;

	elseif pUnitFrom = self.CUBIC_DECAMETRES then
		convertedMeasure	:=	self.measure * 1000000;

	elseif pUnitFrom = self.CUBIC_DECIMETRES then
		convertedMeasure	:=	self.measure * 1;
		
	elseif pUnitFrom = self.CUBIC_FEET then
		convertedMeasure	:=	self.measure * 28.316846592;

	elseif pUnitFrom = self.CUBIC_INCHES then
		convertedMeasure	:=	self.measure * 0.016387064;

	elseif pUnitFrom = self.CUBIC_METRES then
		convertedMeasure	:=	self.measure * 1000;

	elseif pUnitFrom = self.CUBIC_MILLIMETRES then
		convertedMeasure	:=	self.measure * 0.000001;

	elseif pUnitFrom = self.CUBIC_YARDS then
		convertedMeasure	:=	self.measure * 764.554857984;

	elseif pUnitFrom = self.DECILITRES then
		convertedMeasure	:=	self.measure * 0.1;

	elseif pUnitFrom = self.FLUID_OUNCES_UK then
		convertedMeasure	:=	self.measure * 0.0284130625;

	elseif pUnitFrom = self.FLUID_OUNCES_US then
		convertedMeasure	:=	self.measure * 0.0295735295625;

	elseif pUnitFrom = self.GALLONS_DRY_US then
		convertedMeasure	:=	self.measure * 4.40488377086;

	elseif pUnitFrom = self.GALLONS_LIQUID_US then
		convertedMeasure	:=	self.measure * 3.785411784;

	elseif pUnitFrom = self.GALLONS_UK then
		convertedMeasure	:=	self.measure * 4.54609;

	elseif pUnitFrom = self.LITRES then
		convertedMeasure	:=	self.measure;

	elseif pUnitFrom = self.LITRES_1901_TO_1964 then
		convertedMeasure	:=	self.measure * 1.000028;

	elseif pUnitFrom = self.MILLILITRES then
		convertedMeasure	:=	self.measure * 0.001;

	elseif pUnitFrom = self.PINTS_DRY_US then
		convertedMeasure	:=	self.measure * 0.5506104713575;

	elseif pUnitFrom = self.PINTS_LIQUID_US then
		convertedMeasure	:=	self.measure * 0.473176473;

	elseif pUnitFrom = self.PINTS_UK then
		convertedMeasure	:=	self.measure * 0.56826125;

	elseif pUnitFrom = self.QUARTS_DRY_US then
		convertedMeasure	:=	self.measure * 1.101220942715;

	elseif pUnitFrom = self.QUARTS_LIQUID_US then
		convertedMeasure	:=	self.measure * 0.946352946;

	elseif pUnitFrom = self.QUARTS_UK then
		convertedMeasure	:=	self.measure * 1.1365225;

	else
		JSSException.raise_(JSS_X_03003, "[" &amp; pUnitFrom.String &amp; "] is an unknown unit of volume to convert from.");

	endif;
epilog
	return convertedMeasure;
end;</source>
        <access>protected</access>
        <Parameter name="pUnitFrom" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
</Class>
