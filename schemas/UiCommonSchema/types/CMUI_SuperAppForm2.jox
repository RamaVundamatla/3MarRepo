    <JadeMethod name="lblUserName_click" id="0c9358b3-ed5f-4964-84b6-6f4965b16e33">
        <controlMethod name="Label::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lblUserName_click(label: Label input) updating;
// ---------------------------------------------------------------------------
// Created:     02 June 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	compName : String;
begin

	if app.check() then
		compName := app.computerNameAppServer();
		
		if app.isInternalEnvironment(true) and process.getComputerName.toUpper &lt;&gt; "NAVMD1B" then
			app.setSpecial('01/12/3000'.TimeStamp);
			label.foreColor := Red;
			global.causeEvent(EVENT_SPECIAL_USER, true, null);

		else
			self.getSuperUserPassword(); // this calls GetData on SuperApp2Form PAR 17588 -  IsSpecial extra check is used outside JMT Plant - PAR 17588
		endif;
	else
		app.setSpecial(null);
		label.foreColor := Black;
	endif;
end;</source>
        <Parameter name="label" type="Label" usage="input"/>
    </JadeMethod>
