<Class name="CM_AutoTaskClearFiles" id="65516e97-36a1-4244-826d-efb1f7c109e5">
    <superclass name="CM_AutoTask"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;Clear Files&lt;/display&gt;</text>
    <DbClassMap file="backgroundprocess"/>
    <PrimAttribute name="applyToSubfolders" id="c813eb80-8b76-4fd5-b52c-f34adc8a1e90">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="directoryPath" id="35071516-a33b-41be-b1e4-a972ac32ca6e">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="fileMask" id="a7650770-13bf-4d73-a6df-4f2b74f1aa1a">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="isToDelete" id="4d3bba22-1d6e-405c-a916-9dda571b9af6">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="numberOfDaysOld" id="98599ceb-3f69-487e-8dbc-7f98d1303648">
        <embedded/>
