<Class name="CM_WOWagonToDoWLE" id="da73a122-b0ff-45e1-8c9b-abed9ccd2d6e">
    <superclass name="CM_WOToDoWLE"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <ExplicitInverseRef name="myWagon" id="26ba2f2a-2e63-429b-a04b-66cb54ffb15e">
        <transientToPersistentAllowed/>
        <embedded/>
        <type name="CM_Wagon"/>
        <access>readonly</access>
        <Inverse name="CM_Wagon::allWorkOrderWLEs"/>
    </ExplicitInverseRef>
    <JadeMethod name="addToDoTask" id="93ae9531-1f65-4072-bfce-209b88a28b55">
        <updating/>
        <source>addToDoTask() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
23 November 2022	navcs2	ChangeRequest 56691:[56120] EUP - Allow Completing ToDo Work order tasks at Complete ToDo Task Screen

*/

vars
	toDoDesc 		: CM_ToDoTaskDesc;
	wagonTask		: CM_ToDoTask;
	passport 		: CM_Passport;
	
begin
	
	if self.myWagon = null then
		//throw error
		return;
	endif;
	
	passport := app.myPassport;
	
	toDoDesc := self.job.CM_WOToDoTaskJob.myToDoTaskDesc;

	if wagonTask = null then //add task
		wagonTask := self.myWagon.createToDoTask(toDoDesc.code, self.job.myWorkOrderDtlToDo); // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
		self.job.myWorkOrderDtlToDo.allToDoTasks.add(wagonTask);
	endif;
	
	self.myToDoTask := wagonTask;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setMyWagon" id="4c8d1513-b938-41d3-87b7-6e562ae523fd">
        <updating/>
        <source>setMyWagon(_wagon : CM_Wagon) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
23 November 2022	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs

*/

vars

begin
	self.myWagon := _wagon;
	
	self.addToDoTask();
epilog

end;</source>
        <Parameter name="_wagon" type="CM_Wagon"/>
    </JadeMethod>
</Class>
