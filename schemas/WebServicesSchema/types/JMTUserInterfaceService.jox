    <JadeWebServicesMethod name="getSealTypes" id="05dc9c36-afb8-4e60-81a7-33f67836e711">
        <source>getSealTypes() : WS_SealTypesResponse webService;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 October 2011	cnwndl1	Initial creation	Par 28303

*/

vars
	response		: WS_SealTypesResponse;
	completedOK		: Boolean;
	
	sealType		: CM_SealType;
