    <JadeMethod name="tIFTMCS_03A_PAR26152" id="b8723bb7-cd9b-415c-99f6-343aad6e22d1">
        <updating/>
        <source>tIFTMCS_03A_PAR26152() updating;
// cnwrs1 - for emails
//25 Jun 2015	cnwrs1	Par 33901/36027 - Default booking commodity
constants
	VoyageName	= "UTV111";
	BookingNo	= "IFTMCS_03A";
	Vessel		= "MISBOAT2";
	
vars
	vessel		: CM_Vessel;
	voyage		: CM_Voyage;
	ediFile		: CM_EDIFile;
	text		: String;
	tempStr		: String;
	
begin
	self.deleteVoyage( VoyageName );
	self.deleteVessel( Vessel );
	self.deleteBooking( BookingNo );
	self.opts.addAssoc( ETRow_LloydsNumber, '9227341' );
	vessel := self.addVesselCellular( Vessel, self.getOperator( self.getProfileSetting( UT_Profile.P_OPERATOR ).asString ));
	self.assertNotNullMsg( vessel, "Add vessel failed" );
	voyage := self.addVoyageWithContainerStructur( VoyageName, Vessel, 'MIS', self.getProfileSetting( UT_Profile.P_SHIPPING_LINE ).asString );
	self.setTerminalConfig(EdiBookingCommodity, false); 
	
	text :=
"UNB+UNOC:1+MISC BERHAD+SFL+0908210954:1403110+207'"&amp;
"UNH+1403111+IFTMCS:D:03A:UN'"&amp;
"BGM+770+8993-0+5'"&amp;
"DTM+137:200908210954:203'"&amp;
"LOC+88+NZPOE'"&amp;
"RFF+BN:"&amp;BookingNo&amp;"'"&amp;
"TDT+20+"&amp;VoyageName&amp;"+1++MIS:172:87+++9227341:146::"&amp;Vessel&amp;"'"&amp;
"LOC+9+NZPOE'"&amp;
"LOC+11+DEBRV'"&amp;
"LOC+7+IDBLW'"&amp;
"NAD+MS+MISC BERHAD'"&amp;
"EQD+CN++2210+++5'"&amp;
"EQN+7'"&amp;
"MEA+AAE+AAB+KGM:47000'"&amp;
"FTX+AAA+++PAINT'"&amp;
"UNT+16+1403111'"&amp;
"UNZ+1+1403110'";
	
	ediFile := self.ediLoadFileName(text, EDIFileType_Unknown, "IFTMCS", "IFTMCS1"&amp;method.name);
	self.assertNotNull( ediFile );
	
	// NOTE: status of 19 is DB Partially Loaded
	self.ediVerify( ediFile );
	self.assertEqualMsg( ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS, 'The EDI file status was expected to be "Verify errors"' );
	
	tempStr	:= app.myPassport.getAllErrorsWarningsAsString();
	self.assertEqualMsg( tempStr, "Code :70099. An invalid Commodity 'PAIN' was specified.", 'The expected error message is wrong during verification' );
	
	// now check that just doing a DB Load also gives the same error.
	self.ediDBLoad( ediFile );
	tempStr	:= 'DBLoad Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL, CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS);
	
	tempStr	:= app.myPassport.getAllErrorsWarningsAsString();
	self.assertEqualMsg( tempStr, "Code :70099. An invalid Commodity 'PAIN' was specified.", 'The expected error message is wrong during DBLoad' );
	
	text :=
"UNB+UNOC:1+MISC BERHAD+SFL+0908210954:1403110+207'"&amp;
"UNH+1403111+IFTMCS:D:03A:UN'"&amp;
"BGM+770+8993-0+5'"&amp;
"DTM+137:200908210954:203'"&amp;
"LOC+88+NZPOE'"&amp;
"RFF+BN:"&amp;BookingNo&amp;"'"&amp;
"TDT+20+"&amp;VoyageName&amp;"+1++MIS:172:87+++9227341:146::"&amp;Vessel&amp;"'"&amp;
"LOC+9+NZPOE'"&amp;
"LOC+11+DEBRV'"&amp;
"LOC+7+IDBLW'"&amp;
"NAD+MS+MISC BERHAD'"&amp;
"EQD+CN++2210+++5'"&amp;
"EQN+7'"&amp;
"MEA+AAE+AAB+KGM:47000'"&amp;
"FTX+AAA+++UT_4'"&amp;
"UNT+16+1403111'"&amp;
"UNZ+1+1403110'";
	
	ediFile := self.ediLoadFileName(text, EDIFileType_Unknown, "IFTMCS", "IFTMCS2"&amp;method.name);
	self.assertNotNull(ediFile);
	
	self.ediVerify(ediFile);
	tempStr	:= 'Verified failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS, tempStr);
	
	tempStr	:= app.myPassport.getAllErrorsWarningsAsString();
	self.assertEqualMsg(tempStr, "Code :86180. The Cargo Type used (ISO Container) is not valid for the Commodity (UT_4).", 'The expected error message is wrong during verification' );
	
	self.ediDBLoad( ediFile );
	self.assertIsOneOf(ediFile.fileStatus, "DBLoad failed", CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL, CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS);
	
	tempStr	:= app.myPassport.getAllErrorsWarningsAsString();
	self.assertEqualMsg(tempStr, "Code :86180. The Cargo Type used (ISO Container) is not valid for the Commodity (UT_4).", 'The expected error message is wrong during verification' );

epilog

end;
</source>
    </JadeMethod>
    <JadeMethod name="tIFTMCS_03A_PAR26681" id="2b88aeff-bca9-47fe-8767-c60e9668dda0">
        <source>tIFTMCS_03A_PAR26681();
// cnwrs1 - for emails
//25 Jun 2015	cnwrs1	Par 33901/36027 - Default booking commodity
constants
	VoyageName	= "PAR26681";
	BookingNo	= "IFTMCS_03A";
	Vessel		= "PAR26681";
	ErrorMessage1 = "Code :70099. An invalid Commodity 'PAIN' was specified.";
vars
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	ediFile : CM_EDIFile;
	text : String;
	tempStr : String;
	length : Integer;
	ediBookingAllowPartial : Boolean;
	ediBookingCommodity : Boolean;
begin
	ediBookingAllowPartial := self.getTerminal().getConfig(EdiBookingAllowPartial).Boolean;
	ediBookingCommodity := self.getTerminal().getConfig(EdiBookingCommodity).Boolean;
	self.deleteVoyage(VoyageName);
	self.deleteVessel(Vessel);
	self.deleteBooking(BookingNo);
	self.opts.addAssoc( ETRow_LloydsNumber, '9227341' );
	vessel := self.addVesselCellular(Vessel, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.assertNotNullMsg(vessel, "Add vessel failed");
	voyage := self.addVoyageWithContainerStructur(VoyageName, Vessel, 'MIS', self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.setTerminalConfig(EdiBookingCommodity, false);
	self.setTerminalConfig(EdiBookingAllowPartial, true);
	
	text :=
"UNB+UNOC:1+MISC BERHAD+SFL+0908210954:1403110+207'"&amp;
"UNH+1403111+IFTMCS:D:03A:UN'"&amp;
"BGM+770+8993-0+5'"&amp;
"DTM+137:200908210954:203'"&amp;
"LOC+88+NZPOE'"&amp;
"RFF+BN:"&amp;BookingNo&amp;"'"&amp;
"TDT+20+"&amp;VoyageName&amp;"+1++MIS:172:87+++9227341:146::"&amp;Vessel&amp;"'"&amp;
"LOC+9+NZPOE'"&amp;
"LOC+11+DEBRV'"&amp;
"LOC+7+IDBLW'"&amp;
"NAD+MS+MISC BERHAD'"&amp;
"EQD+CN++2210+++5'"&amp;
"EQN+7'"&amp;
"MEA+AAE+AAB+KGM:47000'"&amp;
"FTX+AAA+++PAINT'"&amp;
"UNT+16+1403111'"&amp;
"UNZ+1+1403110'";
	
	ediFile := self.ediLoadFileName(text, EDIFileType_Unknown, "IFTMCS", "IFTMCS1"&amp;method.name);
	self.assertNotNull(ediFile);
	self.ediVerify(ediFile);
	tempStr	:= 'Verifiy failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS, tempStr);
	
	tempStr	:= app.myPassport.getAllErrorsWarningsAsString();
	length := ErrorMessage1.length;
	self.assertEqualMsg(tempStr[1:length], ErrorMessage1, 'The expected error message was wrong during verification');
	
//	self.ediDBLoad(ediFile);
//	tempStr	:= 'DBLoad failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
//	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	
//	tempStr	:= app.myPassport.getAllErrorsWarningsAsString();
//	length := ErrorMessage1.length;
//	self.assertEqualMsg(tempStr[1:length], ErrorMessage1, 'The expected error message was wrong during loading');

	self.setTerminalConfig(EdiBookingCommodity, true);
	
	text :=
"UNB+UNOC:1+MISC BERHAD+SFL+0908210954:1403110+207'"&amp;
"UNH+1403111+IFTMCS:D:03A:UN'"&amp;
"BGM+770+8993-0+5'"&amp;
"DTM+137:200908210954:203'"&amp;
"LOC+88+NZPOE'"&amp;
"RFF+BN:"&amp;BookingNo&amp;"'"&amp;
"TDT+20+"&amp;VoyageName&amp;"+1++MIS:172:87+++9227341:146::"&amp;Vessel&amp;"'"&amp;
"LOC+9+NZPOE'"&amp;
"LOC+11+DEBRV'"&amp;
"LOC+7+IDBLW'"&amp;
"NAD+MS+MISC BERHAD'"&amp;
"EQD+CN++2210+++5'"&amp;
"EQN+7'"&amp;
"MEA+AAE+AAB+KGM:47000'"&amp;
"FTX+AAA+++PAINT'"&amp;
"UNT+16+1403111'"&amp;
"UNZ+1+1403110'";
	
	ediFile := self.ediLoadFileName(text, EDIFileType_Unknown, "IFTMCS", "IFTMCS2"&amp;method.name);
	self.assertNotNull(ediFile);
	self.ediVerify(ediFile);
	tempStr	:= 'Verifiy failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, tempStr);
	
//	tempStr	:= app.myPassport.getAllErrorsWarningsAsString();
//	length := ErrorMessage1.length;
//	self.assertEqualMsg(tempStr[1:length], ErrorMessage1, 'The expected error message was wrong during verification');
	
	self.ediDBLoad(ediFile);
	tempStr	:= 'DBLoad failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	
//	tempStr	:= app.myPassport.getAllErrorsWarningsAsString();
//	length := ErrorMessage1.length;
//	self.assertEqualMsg(tempStr[1:length], ErrorMessage1, 'The expected error message was wrong during DB loading');

	// now do it all again with EdiBookingAllowPartial turned off
	self.setTerminalConfig(EdiBookingCommodity, false);
	self.setTerminalConfig(EdiBookingAllowPartial, false);
	
	text :=
"UNB+UNOC:1+MISC BERHAD+SFL+0908210954:1403110+207'"&amp;
"UNH+1403111+IFTMCS:D:03A:UN'"&amp;
"BGM+770+8993-0+5'"&amp;
"DTM+137:200908210954:203'"&amp;
"LOC+88+NZPOE'"&amp;
"RFF+BN:"&amp;BookingNo&amp;"'"&amp;
"TDT+20+"&amp;VoyageName&amp;"+1++MIS:172:87+++9227341:146::"&amp;Vessel&amp;"'"&amp;
"LOC+9+NZPOE'"&amp;
"LOC+11+DEBRV'"&amp;
"LOC+7+IDBLW'"&amp;
"NAD+MS+MISC BERHAD'"&amp;
"EQD+CN++2210+++5'"&amp;
"EQN+7'"&amp;
"MEA+AAE+AAB+KGM:47000'"&amp;
"FTX+AAA+++PAINT'"&amp;
"UNT+16+1403111'"&amp;
"UNZ+1+1403110'";
	
	ediFile := self.ediLoadFileName(text, EDIFileType_Unknown, "IFTMCS", "IFTMCS3"&amp;method.name);
	self.assertNotNull(ediFile);
	self.ediVerify(ediFile);
	tempStr	:= 'Verifiy failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS, tempStr);
	
	tempStr	:= app.myPassport.getAllErrorsWarningsAsString();
	length := ErrorMessage1.length;
	self.assertEqualMsg(tempStr[1:length], ErrorMessage1, 'The expected error message was wrong during verification');
	
//	self.ediDBLoad(ediFile);
//	tempStr	:= 'DBLoad failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
//	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	
//	tempStr	:= app.myPassport.getAllErrorsWarningsAsString();
//	length := ErrorMessage1.length;
//	self.assertEqualMsg(tempStr[1:length], ErrorMessage1, 'The expected error message was wrong during loading');

	self.setTerminalConfig(EdiBookingCommodity, true);
	
	text :=
"UNB+UNOC:1+MISC BERHAD+SFL+0908210954:1403110+207'"&amp;
"UNH+1403111+IFTMCS:D:03A:UN'"&amp;
"BGM+770+8993-0+5'"&amp;
"DTM+137:200908210954:203'"&amp;
"LOC+88+NZPOE'"&amp;
"RFF+BN:"&amp;BookingNo&amp;"'"&amp;
"TDT+20+"&amp;VoyageName&amp;"+1++MIS:172:87+++9227341:146::"&amp;Vessel&amp;"'"&amp;
"LOC+9+NZPOE'"&amp;
"LOC+11+DEBRV'"&amp;
"LOC+7+IDBLW'"&amp;
"NAD+MS+MISC BERHAD'"&amp;
"EQD+CN++2210+++5'"&amp;
"EQN+7'"&amp;
"MEA+AAE+AAB+KGM:47000'"&amp;
"FTX+AAA+++PAINT'"&amp;
"UNT+16+1403111'"&amp;
"UNZ+1+1403110'";
	
	ediFile := self.ediLoadFileName(text, EDIFileType_Unknown, "IFTMCS", "IFTMCS4"&amp;method.name);
	self.assertNotNull(ediFile);
	self.ediVerify(ediFile);
	tempStr	:= 'Verifiy failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, tempStr);
	
//	tempStr	:= app.myPassport.getAllErrorsWarningsAsString();
//	length := ErrorMessage1.length;
//	self.assertEqualMsg(tempStr[1:length], ErrorMessage1, 'The expected error message was wrong during verification');
	
	self.ediDBLoad(ediFile);
	tempStr	:= 'DBLoad failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	
//	tempStr	:= app.myPassport.getAllErrorsWarningsAsString();
//	length := ErrorMessage1.length;
//	self.assertEqualMsg(tempStr[1:length], ErrorMessage1, 'The expected error message was wrong during loading');

epilog

end;
</source>
    </JadeMethod>
    <JadeMethod name="tIFTMCS_CommodityXlation" id="e1dda4af-0f7e-4301-96c7-ccd58e296cfa">
        <source>tIFTMCS_CommodityXlation();
// cnwrs1
/*
Date		Who		Reason
10 April 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
//13 May 2016	cnwrs1	TFS 1987 CargoSubType EDI Xlation
// 10 Sep 2019	cnwrs1	TFS 46030
*/
constants
	VoyageName		= "MSC001";
	Vessel 			= "UTBOAT";
	LloydsNumber = "91919191";
	BookingId1	= "BK08062001";
	BookingId2	= "BK08062002";
	BookingId3	= "BK08062003";
	BookingId4	= "BK08062004";
	BookingId5	= "BK08062005";
	BookingId6	= "BK08062006";
	BookingId7	= "BK08062007";
	BookingId8	= "BK08062008";
	BookingId9	= "BK08062009";
vars
	vessel		: CM_Vessel;
	voyage		: CM_Voyage;
	ediFile		: CM_EDIFile;
	ediTI		: CM_EDITrackedItem;
	text		: String;
	tempStr		: String;
	booking	: CM_BookingRef;
	operatorCode : String;
	operator	:CM_Operator;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	self.setTerminalConfig(EdiBookingCommodity, false);
	operatorCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString;
	operator := self.getOperator (operatorCode);
	
	self.deleteEDIInwardXlation ("COD", XLATION_TYPE_COMMODITY_BYOP, operator, null);
	
	self.deleteVoyage(VoyageName);
	self.deleteVessel(Vessel);
	vessel := self.addVesselCellular(Vessel, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.assertNotNullMsg(vessel, "Add vessel failed");
	voyage := self.addVoyageWithContainerStructur(VoyageName, Vessel, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.deleteBooking(BookingId1);
	self.deleteBooking(BookingId2);
	self.deleteBooking(BookingId3);
	self.deleteBooking(BookingId4);
	self.deleteBooking(BookingId5);
	self.deleteBooking(BookingId6);

	self.createEDIXlation ("COD", "FISH", XLATION_TYPE_COMMODITY_BYOP, false, operator, null, NULL_TEMPERATURE, NULL_TEMPERATURE);
	self.createEDIXlation ("COD", "FZFS", XLATION_TYPE_COMMODITY_BYOP, false, operator, null, -21, -19);

	// Load  BAPLIE file
	text :=
"UNB+UNOC:1+"&amp;operatorCode&amp;"+SFL+0908210954:1403110+207'
UNH+1403111+IFTMCS:D:03A:UN'
BGM+770+8993-0+5'
DTM+137:200908210954:203'
LOC+88+NZPOE'
RFF+BN:"&amp;BookingId1&amp;"'
TDT+20+"&amp;VoyageName&amp;"+1++"&amp;operatorCode&amp;":172:87+++" &amp; LloydsNumber &amp; ":146::"&amp;Vessel&amp;"'
LOC+9+NZPOE'
LOC+11+AUSYD'
LOC+7+IDBLW'
NAD+MS+"&amp;operatorCode&amp;"'
EQD+CN++2210+++5'
EQN+7'
MEA+AAE+AAB+KGM:17000'
FTX+AAA+++NAZARD'
DGS+IMD+5.1+2014'
UNT+16+1403111'
UNH+1403111+IFTMCS:D:03A:UN'
BGM+770+8993-0+5'
DTM+137:200908210954:203'
LOC+88+NZPOE'
RFF+BN:"&amp;BookingId2&amp;"'
TDT+20+"&amp;VoyageName&amp;"+1++"&amp;operatorCode&amp;":172:87+++" &amp; LloydsNumber &amp; ":146::"&amp;Vessel&amp;"'
LOC+9+NZPOE'
LOC+11+AUSYD'
LOC+7+IDBLW'
NAD+MS+"&amp;operatorCode&amp;"'
EQD+CN++2210+++5'
EQN+7'
MEA+AAE+AAB+KGM:17000'
FTX+AAA+++JUNK'
FTX+AAA+++FZFS'
FTX+AAA+++JUNK'
UNT+18+1403111'
UNH+1403111+IFTMCS:D:03A:UN'
BGM+770+8993-0+5'
DTM+137:200908210954:203'
LOC+88+NZPOE'
RFF+BN:"&amp;BookingId3&amp;"'
TDT+20+"&amp;VoyageName&amp;"+1++"&amp;operatorCode&amp;":172:87+++" &amp; LloydsNumber &amp; ":146::"&amp;Vessel&amp;"'
LOC+9+NZPOE'
LOC+11+AUSYD'
LOC+7+IDBLW'
NAD+MS+"&amp;operatorCode&amp;"'
EQD+CN++2210+++5'
EQN+7'
MEA+AAE+AAB+KGM:17000'
FTX+AAA+++COD'
DGS+IMD+8:1234+2586''
UNT+16+1403111'
UNH+1403111+IFTMCS:D:03A:UN'
BGM+770+8993-0+5'
DTM+137:200908210954:203'
LOC+88+NZPOE'
RFF+BN:"&amp;BookingId4&amp;"'
TDT+20+"&amp;VoyageName&amp;"+1++"&amp;operatorCode&amp;":172:87+++" &amp; LloydsNumber &amp; ":146::"&amp;Vessel&amp;"'
LOC+9+NZPOE'
LOC+11+AUSYD'
LOC+7+IDBLW'
NAD+MS+"&amp;operatorCode&amp;"'
EQD+CN++2210+++5'
EQN+7'
MEA+AAE+AAB+KGM:17000'
DGS+IMD+3.1:3139+1263+++'
DGS+IMD+8:1234+2586'
UNT+16+1403111'
UNH+1403111+IFTMCS:D:03A:UN'
BGM+770+8993-0+5'
DTM+137:200908210954:203'
LOC+88+NZPOE'
RFF+BN:"&amp;BookingId5&amp;"'
TDT+20+"&amp;VoyageName&amp;"+1++"&amp;operatorCode&amp;":172:87+++" &amp; LloydsNumber &amp; ":146::"&amp;Vessel&amp;"'
LOC+9+NZPOE'
LOC+11+AUSYD'
LOC+7+IDBLW'
NAD+MS+"&amp;operatorCode&amp;"'
EQD+CN++2210+++5'
EQN+7'
MEA+AAE+AAB+KGM:17000'
TMP+2+-10:CEL'
UNT+20+1403111'
UNH+1403111+IFTMCS:D:03A:UN'
BGM+770+8993-0+5'
DTM+137:200908210954:203'
LOC+88+NZPOE'
RFF+BN:"&amp;BookingId7&amp;"'
TDT+20+"&amp;VoyageName&amp;"+1++"&amp;operatorCode&amp;":172:87+++" &amp; LloydsNumber &amp; ":146::"&amp;Vessel&amp;"'
LOC+9+NZPOE'
LOC+11+AUSYD'
LOC+7+IDBLW'
NAD+MS+"&amp;operatorCode&amp;"'
EQD+CN++2210+++4'
EQN+7'
MEA+AAE+AAB+KGM:17000'
TMP+7+-10:CEL'
UNT+20+1403111'
UNH+1403111+IFTMCS:D:03A:UN'
BGM+770+8993-0+5'
DTM+137:200908210954:203'
LOC+88+NZPOE'
RFF+BN:"&amp;BookingId8&amp;"'
TDT+20+"&amp;VoyageName&amp;"+1++"&amp;operatorCode&amp;":172:87+++" &amp; LloydsNumber &amp; ":146::"&amp;Vessel&amp;"'
LOC+9+NZPOE'
LOC+11+AUSYD'
LOC+7+IDBLW'
NAD+MS+"&amp;operatorCode&amp;"'
EQD+CN++22R1+++4'
EQN+7'
MEA+AAE+AAB+KGM:17000'
FTX+AAA+++COD'
TMP+2+-20:CEL'
UNT+20+1403111'
UNH+1403111+IFTMCS:D:03A:UN'
BGM+770+8993-0+5'
DTM+137:200908210954:203'
LOC+88+NZPOE'
RFF+BN:"&amp;BookingId6&amp;"'
TDT+20+"&amp;VoyageName&amp;"+1++"&amp;operatorCode&amp;":172:87+++" &amp; LloydsNumber &amp; ":146::"&amp;Vessel&amp;"'
LOC+9+NZPOE'
LOC+11+AUSYD'
LOC+7+IDBLW'
NAD+MS+"&amp;operatorCode&amp;"'
EQD+CN++2231+++5'
EQN+7'
MEA+AAE+AAB+KGM:17000'
FTX+AAA+++REEF'
DGS+IMD+9+3082+++NONE+NONE+++9'
TMP+2+-10:CEL'
UNZ+1+1403110'";
	
	ediFile := self.ediLoadFileName(text, EDIFileType_Unknown, "IFTMCS", "IFTMCS"&amp;method.name);
	self.assertNotNull(ediFile);
	tempStr	:= 'Load failed ' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString();
	self.assertNotNullMsg(ediFile.ediData, tempStr);
	
	foreach ediTI in ediFile.ediData.allEDITrackedItems do
		if ediTI.isKindOf (CM_EDIBookingHeaderTI) then
			continue;
		endif;
		
		if ediTI.CM_EDIBookingItemTI.id = BookingId1 then
			self.assertEqualMsg (ediTI.CM_EDIBookingItemTI.commodity, "NAZA", BookingId1);
			self.assertEqualMsg (ediTI.CM_EDIBookingItemTI.commodityDescription, "NAZARD", BookingId1);
		elseif ediTI.CM_EDIBookingItemTI.id = BookingId2 then
			self.assertEqualMsg (ediTI.CM_EDIBookingItemTI.commodity, "FZFS", BookingId2);
			self.assertEqualMsg (ediTI.CM_EDIBookingItemTI.commodityDescription, "FZFS", BookingId2);
		elseif ediTI.CM_EDIBookingItemTI.id = BookingId3 then
			self.assertEqualMsg (ediTI.CM_EDIBookingItemTI.commodity, "FISH", BookingId3);
			self.assertEqualMsg (ediTI.CM_EDIBookingItemTI.commodityDescription, "COD", BookingId3);
		elseif ediTI.CM_EDIBookingItemTI.id = BookingId4 then
			//self.assertEqualMsg (ediTI.CM_EDIBookingItemTI.commodity, "HAZD", BookingId4);
			self.assertEqualMsg (ediTI.CM_EDIBookingItemTI.commodityDescription, null, BookingId4);
		elseif ediTI.CM_EDIBookingItemTI.id = BookingId5 then
			//self.assertEqualMsg (ediTI.CM_EDIBookingItemTI.commodity, "REEF", BookingId5);
			self.assertEqualMsg (ediTI.CM_EDIBookingItemTI.commodityDescription, null, BookingId5);
		elseif ediTI.CM_EDIBookingItemTI.id = BookingId6 then
			self.assertEqualMsg (ediTI.CM_EDIBookingItemTI.commodity, "REEF", BookingId6);
			self.assertEqualMsg (ediTI.CM_EDIBookingItemTI.commodityDescription, "REEF", BookingId6);
		elseif ediTI.CM_EDIBookingItemTI.id = BookingId7 then
			//self.assertEqualMsg (ediTI.CM_EDIBookingItemTI.commodity, "MT", BookingId7);
			self.assertEqualMsg (ediTI.CM_EDIBookingItemTI.commodityDescription, null, BookingId7);
		elseif ediTI.CM_EDIBookingItemTI.id = BookingId8 then
			self.assertEqualMsg (ediTI.CM_EDIBookingItemTI.commodity, "FZFS", BookingId8);
			self.assertEqualMsg (ediTI.CM_EDIBookingItemTI.commodityDescription, "COD", BookingId8);
		endif;
	endforeach;
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
end;

</source>
    </JadeMethod>
    <JadeMethod name="tIFTMCS_UNB_Sender" id="d529fd42-d08d-4546-a041-fb7a76b4d242">
        <source>tIFTMCS_UNB_Sender();
// 17 may 2011 cnwrs1
//Purpose:	Par 25093 - Sets up the EDI Sender Operator from correct segments.
constants
	VoyageName = 'PAR25093';
	BoatName = 'PAR25093Boat';
	LloydsNumber = '15935724';
	ContainerId = 'PAR25093009';
	BookingId	= 'PAR25093';
vars
	tempStr	: String;
	ediText	: String;
	ediTI : CM_EDITrackedItem;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	ediFile	: CM_EDIFile;
	passport : CM_Passport;
	mskOperator : CM_Operator;
begin
	passport := app.myPassport;
	self.deleteVoyage(VoyageName);
	voyage	:= self.getVoyage(VoyageName);
	self.assertIsDeleted(voyage);
	
	self.deleteVessel(BoatName);
	vessel	:= self.getVessel(BoatName);
	self.assertIsDeleted(vessel);
	
	// now set up cleanly
	self.opts.addAssoc(ETRow_LloydsNumber, LloydsNumber);
	vessel	:= self.addVesselCellular(	BoatName,
										self.getOperator("MSL"));
	self.assertNotNullMsg(vessel, 'Add vessel failed');
	
	voyage	:= self.addVoyageWithContainerStructur(	VoyageName,
													BoatName,
													"MSL", 
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage failed');
	mskOperator := app.myRoot.allOperators["MSK"];
	if not voyage.allOperators.includes(mskOperator) then				// 06/12/2012 cnwmh5
		beginTransaction;
		voyage.allOperators.add(mskOperator);
		commitTransaction;
	endif;
	
	// load the "edi file" data here.
	ediText :=
"UNA:+,? '
UNB+UNOC:1+MAEU+SFL+0908210954:1403110+207'
UNH+1403111+IFTMCS:D:03A:UN'
BGM+770+8993-0+5'
DTM+137:200908210954:203'
LOC+88+NZPOE'
RFF+BN:"&amp;BookingId&amp;"'
TDT+20+"&amp;VoyageName&amp;"+1++MSL:172:87+++"&amp;LloydsNumber&amp;":146::"&amp;BoatName&amp;"'
LOC+9+NZPOE'
LOC+11+DEBRV'
LOC+7+IDBLW'
NAD+MS+MSL'
EQD+CN++2210+++5'
EQN+7'
MEA+AAE+AAB+KGM:147000'
FTX+AAA+++PAINT'
UNT+16+1403111'
UNZ+1+1403110'";
	// load the edi data, verify and load to database
	ediFile	:= self.ediLoadFileName(ediText, EDIFileType_Unknown, "IFTMCS", "IFTMCS1"&amp;method.name);
	self.assertNotNull(ediFile);
	self.assertEqual(ediFile.ediData.operatorCode, "MSK");		// expected MSK
	// Now check the actual data has been loaded correctly.
	ediTI := ediFile.ediData.allEDITrackedItems.first;
	self.assertEqual(ediTI.CM_EDIBookingHeaderTI.operatorCode, "MSK");	//expected MSK
//
// this time the UNB does not have a sender code that can xlate to a valid operator now the file is MSL
//
	ediText :=
"UNA:+,? '
UNB+UNOC:1+PORKY+SFL+0908210954:1403110+207'
UNH+1403111+IFTMCS:D:03A:UN'
BGM+770+8993-0+5'
DTM+137:200908210954:203'
LOC+88+NZPOE'
RFF+BN:"&amp;BookingId&amp;"'
TDT+20+"&amp;VoyageName&amp;"+1++MSL:172:87+++"&amp;LloydsNumber&amp;":146::"&amp;BoatName&amp;"'
LOC+9+NZPOE'
LOC+11+DEBRV'
LOC+7+IDBLW'
NAD+MS+MSL'
EQD+CN++2210+++5'
EQN+7'
MEA+AAE+AAB+KGM:147000'
FTX+AAA+++PAINT'
UNT+16+1403111'
UNZ+1+1403110'";
	// load the edi data, verify and load to database
	ediFile	:= self.ediLoadFileName(ediText, EDIFileType_Unknown, "IFTMCS", "IFTMCS2"&amp;method.name);
	self.assertNotNull(ediFile);
	self.assertEqual(ediFile.ediData.operatorCode, "PORK");		// expected MSL
	// Now check the actual data has been loaded correctly.
	ediTI := ediFile.ediData.allEDITrackedItems.first;
	self.assertEqual(ediTI.CM_EDIBookingHeaderTI.operatorCode, "MSL");	//expected MSK
end;</source>
    </JadeMethod>
    <JadeMethod name="uIFTMCS_CommodityXlation" id="dba18fb2-f42f-4392-a87a-146bf52f1fc0">
        <source>uIFTMCS_CommodityXlation();
//cnwrs1	the version from xmast
/*
Date		Who		Reason
10 April 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
//13 May 2016	cnwrs1	TFS 1987 CargoSubType EDI Xlation
*/
constants
	VoyageName		= "MSC001";
	Vessel 			= "UTBOAT";
