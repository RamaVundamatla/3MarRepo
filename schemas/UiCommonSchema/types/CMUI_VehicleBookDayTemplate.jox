    <JadeMethod name="btnUpdTime_click" id="6e73b10c-cd41-4e49-a775-45bb75bb975a">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnUpdTime_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 April 2013	cnwndl1	Initial creation	Par 31393

*/

vars
	vssTemplate : CMUI_VehicleBookTimeTemplate;
	timeTemp : CM_VehicleBookingTimeTemplate;
	
begin

	if self.tblTimes.row &gt; self.tblTimes.fixedRows and self.tblTimes.row &lt;= self.tblTimes.rows then
		timeTemp := self.tblTimes.accessRow( self.tblTimes.row ).itemObject.CM_VehicleBookingTimeTemplate;
	endif;
	
	if timeTemp = null then
		return;
	endif;

	vssTemplate := app.loadForm(CMUI_VehicleBookTimeTemplate, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_VehicleBookTimeTemplate;
	if vssTemplate &lt;&gt; null then
		vssTemplate.CMUI_VehicleBookTimeTemplate.setMyTemplates( self.myDayTemplate, timeTemp );
		vssTemplate.setParentForm(self);
		vssTemplate.showModal;
		self.initTblTimes();
	endif;

epilog

end;</source>
