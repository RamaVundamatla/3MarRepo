/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23/12/2024	navkc1 JIRA Story MTN-33491: MTN | License - EDI Bundles Methods

*/

vars

begin
	
	return CM_EDIFileType.EDI_Bundle_SUZANO;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleXMLExceptions" id="540574f6-3c94-46ca-9791-86cce62fd706">
        <source>handleXMLExceptions(_exception : Exception) : Integer;
//
//27 Oct 2015	cnwrs1	Par37082 special file name longer than 30 chars
//
vars
	returnVal : Integer;
begin
	returnVal := Ex_Pass_Back;

	if _exception.errorCode = 8901 then
		returnVal := Ex_Resume_Next;	
	endif;

	return returnVal;
end;</source>
        <Parameter name="_exception" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="includeVoyage" id="3d8e71f4-8c9c-45c2-85f7-0911286cd88c">
        <source>includeVoyage(_camProtocol: CM_CamProtocol; _voyage: CM_Voyage; _trx :CM_Transaction; _camAgent : CM_CamControllerAgent; _logExcluded: Boolean): Boolean protected;
/*

Purpose: Like most Warehouse-based CAMS these messages don't have voyages attached. 

Parameters:

Return Value:		


Date		Who		Reason
18 Jul 2014 cnwgb1	Initial creation (copied from X12_322) PAR 34561 CCMS 2346
//16 Sep 2015	cnwrs1	Par 36860 allow any voyage
*/
vars
	result	:Boolean;
begin
/*	result := _voyage.isCellularVoyage or _voyage.isNullVoyage;
	
	if not result and _logExcluded then
		_camAgent.logReasonForExclusion (_trx, 'Voyage is not cellular or null voyage');
	endif;
*/	
	return true;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_trx" type="CM_Transaction"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent"/>
