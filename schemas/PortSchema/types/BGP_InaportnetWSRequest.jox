    <JadeMethod name="updateActivityHistory" id="7d74aeac-891c-4cd0-a1fd-1e2f4b798abc">
        <source>updateActivityHistory(	_agent : CM_InaportnetWSConsumerAgent ;
						_response : CMIF_InaportnetWSResponse) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 November 2018	jlger1	Initial creation 42098

*/

vars
	pxy : CM_ActivityHistoryExtInterface;
	description : String;
	statusCode,
	statusMessage : String;
begin
		
	if _agent.myLastActivityHistory = null then	
		return;
	endif;
		
	beginLoad;
	pxy:=_agent.myLastActivityHistory.pxyCreateUpdateProxy();	
	endLoad;
	
	if pxy = null then
		return ;
	endif;
	
	if self.myMarineTimings &lt;&gt; null then
		pxy.setMyVoyage(self.myMarineTimings.myMovement.getMyVoyage);
	else
		pxy.setMyVoyage(self.myVoyage);
	endif;
	description := _agent.definitionName &amp;" " &amp; pxy.requestName;
	if _response &lt;&gt; null then
		pxy.setSuccess(_response.isSuccess);
		description := description &amp; " sent and responded with ";
		if _response.isSuccess then
			description:=description &amp; "success";
		else
			_response.getStatus(statusCode,statusMessage);
			description:=description &amp; "error, statusCode=" &amp; statusCode.String ;
		endif;
	else
		description := description &amp; " was sent and timed out with no response";
	endif;
	pxy.setDescription(description);
	
	app.myTrxUA.trxUpdateActivityHistory(pxy, app.myPassport);
epilog
	endLoad;
	
	delete pxy;
end;</source>
        <access>protected</access>
        <Parameter name="_agent" type="CM_InaportnetWSConsumerAgent"/>
        <Parameter name="_response" type="CMIF_InaportnetWSResponse"/>
    </JadeMethod>
    <JadeMethod name="updateVoyageWorkOrder" id="f3f76b62-af4c-444b-b5fb-8cec787d0e68">
        <source>updateVoyageWorkOrder(_voyage : CM_Voyage input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 September 2018	jlger1	Initial creation
26 March 2024		navpw1	TFS: 62849 (62927) - Reverted Code by changing call to trxUpdateWorkOrder

*/

vars
	pxyWorkOrder : CM_WorkOrder;
	pxyWorkOrderDtl : CM_WorkOrderVoyageDtl;
begin
	if _voyage = null then
		return;
	endif;
	
	beginLoad;
	pxyWorkOrder:=self.myVoyageWorkOrder.pxyCreateUpdateProxy;
	endLoad;
	pxyWorkOrder.CM_WorkOrderVoyage.setMyVoyage(_voyage);
	pxyWorkOrder.setTaskStatus(WO_STATUS_PENDING);
	
	pxyWorkOrderDtl:=pxyWorkOrder.getWorkOrderDetailOfType(WO_TASK_CARGOINITIAL).CM_WorkOrderVoyageDtl;
	
	if pxyWorkOrderDtl &lt;&gt; null and pxyWorkOrderDtl.CM_WodVoyageCargoRequest.myBerth = null  then
		if  _voyage.myHMSVoyageData &lt;&gt; null then															// TFS 39964
			if _voyage.getMovementArrival &lt;&gt; null then // TFS 39349
				pxyWorkOrderDtl.CM_WodVoyageCargoRequest.setMyBerth( _voyage.getMovementArrival.getMyBerth);		// TFS 39349 use arrival
			endif;
	endif;	
	endif;
	
	app.myPassport.setWarningsIgnored( true);
	app.myPassport.setWarningsAcknowledged( true);
	app.myTrxUA.trxUpdateWorkOrder(pxyWorkOrder,true,app.myPassport);
epilog
	endLoad;
	delete pxyWorkOrder;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
    </JadeMethod>
</Class>
