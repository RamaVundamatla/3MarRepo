    <JadeMethod name="tblWorkEntries_mouseMove" id="01ca8d97-630e-4ede-8e1d-6f7d3076cfbd">
        <controlMethod name="Table::mouseMove"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblWorkEntries_mouseMove(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
//--------------------------------------------------------------
//Created: 18 March 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	tmpHeight : Real;	
begin

	if table.fixedRows &gt; 0 then
		tmpHeight := table.accessRow(table.fixedRows).height;
		if origYPos &lt;= tmpHeight then
			return;
		endif;
	endif;
	if table.row &gt; table.fixedRows then	
		self.tblWLEMouseMoveEvent(table, button, shift, x, y);
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
