    <JadeMethod name="translateForm" id="9905d2cf-6773-45eb-91d5-04c92475a587">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0006311, locale);
	btnFilterOnBoard.translateCaption(Xlat_0002365, locale);
	btnNextItem.translateCaption(Xlat_0002367, locale);
	btnNextT.translateBubbleHelp(Xlat_0002366, locale);
	btnNextT.translateCaption(Xlat_0002368, locale);
	btnPrevItems.translateCaption(Xlat_0002369, locale);
	btnSelectAll.translateCaption(Xlat_0002370, locale);
	lbEntered.translateCaption(Xlat_0002371, locale);
	lbFilterHatch.translateCaption(Xlat_0002372, locale);
	lbFilterLot.translateCaption(Xlat_0002373, locale);
	lbFilterPlace.translateCaption(Xlat_0002374, locale);
	lbRemaining.translateCaption(Xlat_0002375, locale);
	lbRequired.translateCaption(Xlat_0002376, locale);
	lblAddNoNumbers.translateCaption(Xlat_0002377, locale);
	lblIdFilter.translateCaption(Xlat_0002378, locale);
	lblLocation.translateCaption(Xlat_0002379, locale);
	lblPage.translateCaption(Xlat_0002380, locale);
	lblRequired.translateCaption(Xlat_0002381, locale);
	lblSelected.translateCaption(Xlat_0002382, locale);
	mnuColumnOrganiser.translateCaption(Xlat_0006312, locale);
	mnuContextMenu.translateCaption(Xlat_0006313, locale);
	mnuInspectObject.translateCaption(Xlat_0006314, locale);
	mnuShowOrganiser.translateCaption(Xlat_0006315, locale);
	optLoadOutItem.translateCaption(Xlat_0002383, locale);
	optLoadOutLocn.translateCaption(Xlat_0002384, locale);
	optLocnDockets.translateCaption(Xlat_0002385, locale);
	optLocnDtlsLocn.translateCaption(Xlat_0002386, locale);
	optLocnDtlsLogs.translateCaption(Xlat_0002387, locale);
	optNoNumber.translateCaption(Xlat_0002388, locale);
	shtHeader.translateCaption(Xlat_0002389, locale);
	shtItemDetails.translateCaption(Xlat_0002390, locale);
	shtLocationDtls.translateCaption(Xlat_0002391, locale);
	shtNoNumbers.translateCaption(Xlat_0002392, locale);
	shtOnBoard.translateCaption(Xlat_0002393, locale);
end;</source>
    </JadeMethod>
