    <JadeMethod name="getExtremePoints" id="b24efa31-1523-4db5-8e99-e3108a1df058">
        <source>getExtremePoints(_positionX : Integer; _positionY : Integer;  _points : PointArray; _resultX, _resultY : Integer io);
// ---------------------------------------------------------------------------
// Created:     10 January 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	minX, maxX,minY, maxY : Integer;
	aPoint, returnPoint : Point;
begin
	minX := 999999999;
	minY := 999999999;

	foreach aPoint in _points discreteLock do
		// EXTREME X
		if _positionX = CM_Graphic.Position_Right then
			if aPoint.x &gt; maxX then
				_resultX := aPoint.x;
				maxX := aPoint.x;
			endif;
		elseif _positionX = CM_Graphic.Position_Left then
			if aPoint.x &lt; minX then
				_resultX := aPoint.x;
				minX := aPoint.x;
			endif;
		endif;
		// EXTREME Y
		if _positionY = CM_Graphic.Position_Top then
			if aPoint.y &lt; minY then
				_resultY := aPoint.y;
				minY := aPoint.y;
			endif;
		elseif _positionY = CM_Graphic.Position_Bottom then
			if aPoint.y &gt; maxY then
				_resultY := aPoint.y;
				maxY := aPoint.y;
			endif;
		endif;
	endforeach;
		
epilog

end;</source>
        <Parameter name="_positionX" type="Integer"/>
        <Parameter name="_positionY" type="Integer"/>
        <Parameter name="_points" type="PointArray"/>
        <Parameter name="_resultX" type="Integer" usage="io"/>
        <Parameter name="_resultY" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getGraphicObject" id="8fbc9922-451e-446f-8da6-a01781450540">
        <source>getGraphicObject(_point : Point) : CM_Graphic;
/*
Purpose:			
Date		Who		Reason
05 August 2011	cnwab1	Initial creation
*/

vars
	theObject : Object;
	thePointArray : PointArray;
	invalidObject : Boolean;
	
begin
	on Exception do app.handleDeletedObject(exception, theObject, invalidObject); // 31053 If this kicks off the next statement is a continue anyway so have not added any extra coding

	foreach theObject in self.allPointGraphics do : outerLoop
		thePointArray := theObject.CM_LayoutGraphic.pointsPolygon;
		
		if invalidObject then // 31053 
			continue;
		endif;
		
		if thePointArray[1].x = _point.x and thePointArray[1].y = _point.y then
			return theObject.CM_Graphic;
		endif;
	endforeach;
	return null;
epilog

end;</source>
        <Parameter name="_point" type="Point"/>
        <ReturnType type="CM_Graphic"/>
    </JadeMethod>
    <JadeMethod name="handleNonExistantMethod" id="4d764d9d-9484-492d-964d-4b5fdc78b432">
        <source>handleNonExistantMethod(_exc : Exception) : Integer;
// ---------------------------------------------------------------------------
// Created:     Dec 2010 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

constants
	InvalidMethod	= 1010;
	
vars
	returnVal		: Integer;
	
begin
	returnVal := Ex_Pass_Back;
	if _exc.errorCode = InvalidMethod then
			if _exc.resumable then
				returnVal := Ex_Resume_Next;
			endif;
	endif;


epilog
	return returnVal;
	
end;</source>
        <Parameter name="_exc" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="hasCurrentPoint" id="fbffc43b-0a28-4470-b1b1-6b349624b1bf">
        <source>hasCurrentPoint() : Boolean;
/*
Purpose:			
Date		Who		Reason
25 June 2012	cnwab1	Initial creation
*/

vars

begin
	
	if self.dragLastPoint &lt;&gt; null then
		if self.dragLastPoint.x = 0 and self.dragLastPoint.y = 0 then
			return false;
		endif;
	else
		return false;
	endif;
	
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isForPlanning" id="0aac3607-bbb5-4001-bc63-a4bfa6d0c4be">
