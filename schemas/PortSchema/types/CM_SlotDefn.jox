    <JadeMethod name="getGridDefnStr" id="7039367e-3df3-46c6-8cb1-cf0ee2bfd1fe">
        <source>getGridDefnStr(_gridView : Integer) : String protected;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		FROM VOYAGE - get actual properties
// ---------------------------------------------------------------------------
vars
	theColumnOrdinal,
	theRowOrdinal 	: Integer;
	bayDefnFortyFoot,
	rtnStr			: String;


begin
	
	if _gridView = CM_CellularVoyageStructure.GRID_VIEW_BAY then
		// the ordinals for tiers are upside down, as far as the GUI grid controll is concerned, so this flips the ordinal
		if self.ordinalDeck = DeckOnDeck then
			theRowOrdinal := self.myBay.allTiersOnDeck.size - (self.ordinalTier - 1);
		else
			theRowOrdinal := self.myBay.allTiersUnderDeck.size - (self.ordinalTier - 1);
		endif;
		// the ordinals for cells are NOT upside down
		theColumnOrdinal := self.ordinalCell;

	elseif _gridView = CM_CellularVoyageStructure.GRID_VIEW_PROFILE then
		theColumnOrdinal := self.myBay.ordinalBay;
		theRowOrdinal := self.ordinalTier;
		
	endif;

	rtnStr := self.getGridDefnLineType() &amp; GridData_Delimiter &amp;
			theRowOrdinal.String &amp; GridData_Delimiter &amp;
			theColumnOrdinal.String &amp; GridData_Delimiter &amp;
			getOidStringForObject(self) &amp; GridData_Delimiter &amp;
			self.unavailable.Integer.String &amp; GridData_Delimiter &amp;
			self.watercooled.Integer.String &amp; GridData_Delimiter &amp;
			self.doors20Aft.Integer.String &amp; GridData_Delimiter &amp;
			bayDefnFortyFoot &amp; GridData_Delimiter &amp;
			self.motor20Aft.Integer.String &amp; GridData_Delimiter &amp;
			self.motor40Aft.Integer.String &amp; GridData_Delimiter &amp;
			self.mtOnly.Integer.String &amp; GridData_Delimiter &amp;
			self.heavy.Integer.String &amp; GridData_Delimiter &amp;
			self.voltageType.Integer.String &amp; GridData_Delimiter &amp;
			self.power.Integer.String &amp; GridData_Delimiter &amp;
			self.reefer.Integer.String;
			
	return rtnStr;
	
end;</source>
        <access>protected</access>
        <Parameter name="_gridView" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getGridXMLdefn" id="df7d662b-0c9e-479d-9549-dbe2bf1016f9">
        <source>getGridXMLdefn(_gridView : Integer) : String; //_afterBridge : Boolean
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		FROM VOYAGE - get actual properties
// ---------------------------------------------------------------------------
vars
	sml : String;
	theColumnOrdinal, theRowOrdinal : Integer;
	s1,s2,s3,s4,s5,s6,s7,s8,s9,s10,s11,s12,s13,s14,s15,s16 : String;

begin
	
	if _gridView = CM_CellularVoyageStructure.GRID_VIEW_BAY then
		// the ordinals for tiers are upside down, as far as the GUI grid controll is concerned, so this flips the ordinal
		if self.ordinalDeck = DeckOnDeck then
			theRowOrdinal := self.myBay.allTiersOnDeck.size - (self.ordinalTier - 1);
		else
			theRowOrdinal := self.myBay.allTiersUnderDeck.size - (self.ordinalTier - 1);
		endif;
		// the ordinals for cells are NOT upside down
		theColumnOrdinal := self.ordinalCell;

	elseif _gridView = CM_CellularVoyageStructure.GRID_VIEW_PROFILE then
		theColumnOrdinal := self.myBay.ordinalBay;
		theRowOrdinal := self.ordinalTier;
		
	endif;

	s1 := theColumnOrdinal.String.padLeadingZeros(2);
	s2 := theRowOrdinal.String.padLeadingZeros(2);
	s3 := getOidStringForObject(self);
	s4 := self.unavailable.Integer.String;
	s5 := self.watercooled.Integer.String;
	s6 := self.doors20Aft.Integer.String;
	s13 := self.doors40Aft.Integer.String;
	if self.myBay.isAftBay then
		s7 := self.fortyBack.Integer.String;
	else
		s7 := self.fortyFront.Integer.String;
	endif;
	s8 := self.motor20Aft.Integer.String;
	s9 := self.motor40Aft.Integer.String;
	s10 := self.mtOnly.Integer.String;
	s11 := self.power.Integer.String;
	s12 := self.reefer.Integer.String;
	s14 := self.is30.Integer.String; // PAR 16415 CCMS 1029
	s15 := self.is45.Integer.String; // PAR 16415 CCMS 1029
	s16 := self.is53.Integer.String; // PAR 16415 CCMS 1029
	
	sml :=  "&lt;SD&gt;" &amp; s3 &amp; "&lt;/SD&gt;&lt;Ord&gt;" &amp; s1 &amp; s2 &amp; "&lt;/Ord&gt;&lt;na&gt;" &amp; s4 &amp; 
			"&lt;/na&gt;&lt;wc&gt;" &amp; s5 &amp; "&lt;/wc&gt;&lt;d20&gt;" &amp; s6 &amp; "&lt;/d20&gt;&lt;d40&gt;" &amp; s13 &amp; "&lt;/d40&gt;" &amp; 
			 "&lt;f40&gt;" &amp; s7 &amp; "&lt;/f40&gt;&lt;m20&gt;" &amp; s8 &amp; "&lt;/m20&gt;&lt;m40&gt;" &amp; s9 &amp; 
			 "&lt;/m40&gt;&lt;mt&gt;" &amp; s10 &amp; "&lt;/mt&gt;" &amp; "&lt;vt&gt;" &amp; self.voltageType.String &amp; "&lt;/vt&gt;&lt;hv&gt;" &amp; self.heavy.Integer.String &amp; "&lt;/hv&gt;" &amp; 
			 "&lt;pw&gt;" &amp; s11 &amp; "&lt;/pw&gt;&lt;rf&gt;" &amp; s12 &amp; "&lt;/rf&gt;&lt;f30&gt;" &amp; s14 &amp; "&lt;/f30&gt;&lt;f45&gt;" &amp; s15 &amp; "&lt;/f45&gt;&lt;f53&gt;" &amp; s16 &amp; "&lt;/f53&gt;";// PAR 16415 CCMS 1029
	return sml;
end;</source>
        <Parameter name="_gridView" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
