    <JadeMethod name="addAlert" id="8cb34595-7865-4fa1-a251-ff283f82e922">
        <source>addAlert(str	:	String; msgSeverity : Integer);
//
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------------
// 16/09/2016	cnwdap1		TFS 2629 Messina ITS / RTQ notification flood issues
vars
	alert		:	CM_SystemAlert;
	terminal	: 	CM_Terminal;
begin
	create alert;
	//---------------------
	//This is a "hidden" alert, only displayed when they look at it directly
	//---------------------
	alert.isNotMainDisplayed := true;

	alert.details := str;
	alert.setSeverity(msgSeverity);
	//-----------
	//Tell alert to add itself to system
	//-----------
	alert.add;
	alert.setLinkedTo(self);
//	terminal := app.getMyTerminal();
	terminal := self.myQueue.getMyTerminal();
	if terminal &lt;&gt; null then
		//self.causeEvent(terminal.getTerminalEvent(RTQueueEntry_Update_Event), false, null);		// TFS 2629
		self.causeEvent(terminal.getTerminalEvent(RTQueueEntry_Alert_Event), false, null);			// TFS 2629
	endif;
end;</source>
        <Parameter name="str" type="String"/>
        <Parameter name="msgSeverity" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addTIToMultiDirectorTasks" id="473fbfc6-600e-4f51-b657-32d9fcb14b9d">
        <source>addTIToMultiDirectorTasks( _ti : CM_TrackedItem input ; _terminal : CM_Terminal);

/*

Purpose: Add the ti to all the director tasks on all entries.

Parameters:			

Return Value:		


Date		Who		Reason
16 November 2010	cnwrd1	Initial creation
//cnwrd1 par 25681 18.11.2010 multi machine director moves

*/

vars

begin

	if _ti = null then
		return;
	endif;
	
	//called from task.addTIToDirectorTask
	
	if self.allTasks.first &lt;&gt; null and self.allTasks.first.taskType = TASK_DIRECTOR and self.allTasks.first.ti = null then
		self.allTasks.first.setStatus(TASK_ALLOCATED);
		self.allTasks.first.addTIToDirectorTask(_ti);
	endif;
	
	if self.myNextRelatedEntry &lt;&gt; null then
		self.myNextRelatedEntry.addTIToMultiDirectorTasks(_ti, _terminal);
	endif;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="addTask" id="ac2c9bc4-0281-40c8-baed-ffeba667e89b">
        <updating/>
        <source>addTask(task	: CM_RTQueueTask io ) updating;
//Adds a passed in task to the entry's tasks.
vars
	existingTask	:	CM_RTQueueTask;
begin
	if self.allTasks.isEmpty = false then
		//-------------
		//Add ourselves to the relationships of the other tasks
		//-------------
		foreach existingTask in self.allTasks do
			existingTask.relatedTasks.add(task);
			task.relatedTasks.add(existingTask);
		endforeach;
	endif;
	task.relatedTasks.add(task);
	task.setMyEntry(self);
end;</source>
        <Parameter name="task" type="CM_RTQueueTask" usage="io"/>
    </JadeMethod>
    <JadeMethod name="addToAlerts" id="1c2c73cd-689b-4410-98b6-b1be52af1b60">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_AlertAlarm::addToAlerts"/>
        </interfaceImplements>
        <updating/>
        <source>addToAlerts(alert: CM_SystemAlert) updating;
//Adds the passed in persistant alert to the system.
// 29 Aug 2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition 
// 16 Sep 2016	cnwdap1	TFS 2629 Messina ITS / RTQ notification floods
vars
	terminal : CM_Terminal;
begin

	self.alerts.add(alert);
	self.updateObjectEdition(self);	// par 30292

	terminal := self.myQueue.getMyTerminal();
	
	if terminal &lt;&gt; null then
		//self.causeEvent(terminal.getTerminalEvent(RTQueueEntry_Update_Event), false, null);		// TFS 2629
		self.causeEvent(terminal.getTerminalEvent(RTQueueEntry_Alert_Event), false, null);			// TFS 2629
	endif;
end;</source>
        <Parameter name="alert" type="CM_SystemAlert"/>
    </JadeMethod>
    <JadeMethod name="addToTotalMoved" id="d3bbed94-b49d-402d-9e20-387c3201d7ae">
        <updating/>
        <source>addToTotalMoved( _moved : Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 May 2013	cnwrd1	Initial creation

*/

vars
	totalLeft : Integer;
	totalToMove : Integer;
	terminal : CM_Terminal;
begin

	totalLeft := self.quantity - self.totalMoved ;
	
	
	if _moved = 0 then 
		totalToMove := totalLeft;
		else
		totalToMove := _moved;
	endif;

	if ( self.totalMoved + totalToMove ) &gt; self.quantity then
		app.raiseCMException2(Canno_picku_units_move_items_r, _moved.asStringJMT, totalLeft.asStringJMT, 'Move Count', null);
	endif;
	
	self.totalMoved := self.totalMoved + totalToMove;
	
	if self.totalMoved = self.quantity then
		self.allTasks.first.setStatusComplete();
		self.updateStatus(TASK_COMPLETE);//epr 17/2/15 par 35702 CCMS 2457
	endif;
	
	//epr par 31707 11/6/13
	if not self.isTransient then
		//send note to update
		terminal := self.myQueue.getMyTerminal();	
		if terminal &lt;&gt; null then 
			self.causeEvent(terminal.getTerminalEvent(RTQueueEntry_Update_Event), false, null);
			app.myEventManager.createSingleObjInfoNoteEvt(self.myQueue , terminal.getTerminalEvent(Event_Update_Queue_Entry), self );
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_moved" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addToWeightMoved" id="d38cac07-6a67-4183-a597-c30aebf22019">
        <updating/>
        <source>addToWeightMoved(_movedWeight : Decimal) updating;
/*

Date		Who		Reason
19 March 2014	cnwer1	Initial creation PAR

*/

vars
	weightLeft ,
	weightToMove,
	density : Decimal [14,4];
	terminal : CM_Terminal;
	ct : CM_CargoType;
	moveWeightStr ,
	weightLeftStr : String;
begin

	weightLeft := self.weight - self.weightMoved ;
	
	
	if _movedWeight = 0 then 
		weightToMove := weightLeft;
		else
		weightToMove := _movedWeight;
	endif;

	if ( self.weightMoved + weightToMove ) &gt; self.weight then
		ct:= self.getCargoType;
		density := self.myWorkListEntry.getDensity;
		moveWeightStr:= ct.getBulkTrackByDisplayForWeight(_movedWeight,density,true);
		weightLeftStr:=ct.getBulkTrackByDisplayForWeight(weightLeft,density,true);
		app.raiseCMException2(Canno_picku_units_move_items_r, moveWeightStr,weightLeftStr, 'Move Count', null);
	endif;
	
	self.weightMoved := self.weightMoved + weightToMove;
	
	if self.weightMoved = self.weight then
		self.allTasks.first.setStatusComplete();
		self.updateStatus(TASK_COMPLETE);//epr 17/2/15 par 35702 CCMS 2457
	endif;
	
	//epr par 31707 11/6/13
	if not self.isTransient then
		//send note to update
		terminal := self.myQueue.getMyTerminal();	
		if terminal &lt;&gt; null then 
			self.causeEvent(terminal.getTerminalEvent(RTQueueEntry_Update_Event), false, null);
			app.myEventManager.createSingleObjInfoNoteEvt(self.myQueue , terminal.getTerminalEvent(Event_Update_Queue_Entry), self );
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_movedWeight" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="areAllBreakBulksEqualStatus" id="e4d4cd4d-a56b-44d1-8ec6-00bd9acff707">
        <source>areAllBreakBulksEqualStatus(statusToCheck : Integer) : Boolean;
/*

Date		Who		Reason
19 Feb 2015	cnwer1	Initial creation PAR 35702
06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars
	breakBulkQE : CM_RTQueueEntry;
	task	: CM_RTQueueTask;
begin
	foreach breakBulkQE in self.allBreakBulkMoves discreteLock do
		foreach task in breakBulkQE.allTasks discreteLock do			//06.03.2025 navma1 #MTN-34179
			//Collect all statuses
			if task.status &lt;&gt; statusToCheck then
				return false;
			endif;
		endforeach;
	endforeach;
	return true;
epilog

end;</source>
        <Parameter name="statusToCheck" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="areAllTasksEqualStatus" id="27a52c95-edbf-4cd9-ba74-724aa8fbb3fc">
        <source>areAllTasksEqualStatus(statusToCheck : Integer) : Boolean	;
/*
//Returns true if all task statuses are == passed in status,
//else returns false.
//Statustocheck is a Global type ofRTQueueTaskStatus
 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
06 Mar 2025 navma1  	MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/
vars
	task	: CM_RTQueueTask;
	
begin
 	foreach task in  self.allTasks discreteLock do		//06.03.2025 navma1 #MTN-34179
		//Collect all statuses
		if task.status &lt;&gt; statusToCheck then
			return false;
		endif;
	endforeach;
	
	//epr par 35702 4/3/15 CCMS 2457
	return self.areAllBreakBulksEqualStatus(statusToCheck);
end;</source>
        <Parameter name="statusToCheck" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="areTasksUnactionedOrHeld" id="1fe33bff-d621-4f80-8ca3-da574405f7a3">
        <source>areTasksUnactionedOrHeld() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 July 2013	cnwmc5	Initial creation		PAR 31553

*/

vars
	task	: CM_RTQueueTask;
begin
 	foreach task in allTasks do
		if task.status &lt;&gt; TASK_UNACTIONED
		and task.status &lt;&gt; TASK_USER_HELD 
		and task.status &lt;&gt; TASK_SYS_HELD then
			return false;
		endif;
	endforeach;
	
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="autoCompleteCraneTasks" id="87413736-e8bb-417c-bebf-a8158d6e58b9">
        <updating/>
        <source>autoCompleteCraneTasks() updating;
//If there are any tasks here that are CRANE tasks, see if the crane has R/T.
//If it does not, then complete the tasks automatically. (move to ship/Move from ship).
vars
	crane		:	CM_Crane;
	aTask		: CM_RTQueueTask;
	txnParams	: CMIF_TITransactionController;
	ti			: CM_TrackedItem;
	lc			: CM_LocationsController;
begin

	if not self.myJob.isKindOf(CM_VoyageJob) then
		return;
	endif;

	aTask := findFirstCraneTask();

	if aTask = null then 
		//--------------
		//No crane Tasks
		//--------------
		return;
	endif;

	ti := self.myWorkListEntry.myTrackedItem;
	//------------------
	//Make sure all preceeding tasks have been completed
	//------------------
	if self.allTasks.indexOf(aTask) &gt; 1 then
		if self.allTasks[self.allTasks.indexOf(aTask)-1].status &lt;&gt; TASK_COMPLETE then
			return;
		endif;
	endif;

	crane := self.getJobCrane();
	if crane = null then
		return;
	endif;
	//---------------
	//Does crane have R/T?
	//---------------
	if crane.hasRadioTelemetry then
		//--------------
		//Is it doing BOTH the pickup/Setdown.
		//--------------
		if crane.useRTForPickup and crane.useRTForSetDown then
			//Crane will look after both.
			return;
		endif;
		if not crane.useRTForSetDown then
			//--------------------
			//Crane uses R/T for pickup, but NOT set down. Complete set
			//down tasks ONLY.
			//--------------------
			if aTask.taskType = TASK_PICKUP then
				//-----------------
				//The 1st uncompleted crane task is a pickup. The crane will do this
				//for us using its R/T. We quit here, and get called in its pickupevent.
				//-----------------
				return;
			elseif aTask.taskType = TASK_SETDOWN then
				//Auto-Complete this. (should complete the job too!)
				aTask.setStatus(TASK_COMPLETE);
			else
				return;	//God knows!
			endif;			
		endif;
	else
		//------------------
		//Crane has NO Radio Telemetry. We must auto-complete all crane tasks.
		//------------------
		 lc := ti.getPrimaryLocation(QUEUE_MODE);
		//ti.moveToLocation(lc, null, null, crane, REAL_MODE, true, true, false, false,  aTask.taskType = TASK_PICKUP,  false, null,null,app.myPassport);		// TFS 2651
		ti.moveToLocation(lc, null, null, crane, REAL_MODE, true, true, false, false,  aTask.taskType = TASK_PICKUP,  false, null,null,null,null,null,app.myPassport);	// TFS 2651

	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="changeIMVsFinalEntryMachineGrp" id="3e6aa159-59a9-4f1e-bf45-e7e36662dd24">
        <updating/>
        <source>changeIMVsFinalEntryMachineGrp() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 February 2011	cnwer1	Initial creation

*/

vars
	nextEntry : CM_RTQueueEntry;
	targetTA : CM_TerminalArea;
	sourceLocation, 
	targetLocation : CM_LocationsController;
	newMachineTypeGrp :Integer;
	arbiter 	: CM_RTQueueArbiter;
	subQueue 		: CM_SubQueue;
	newQueue 		:CM_RadioTelemetryQueue;
begin
	if self.machineTypeGroup &lt;&gt; MACHINETYPEGRP_IMV then
		return;
	endif;
	
	nextEntry:= self.myNextRelatedEntry;
	//is possible if going on to a ship
	if nextEntry = null then
		return;
	endif;
	
	targetLocation:=nextEntry.getTargetLocation;
	
	if targetLocation = null then
		return;
	endif;
	
	if not targetLocation.isKindOf(CM_YardController) then
		return;
	endif;
	
	targetTA:= targetLocation.CM_YardController.myTerminalArea;
	
	if targetTA.isKindOf(CM_StraddleStack) then
		newMachineTypeGrp:=MACHINETYPEGRP_STRADDLE;
	elseif targetTA.isKindOf(CM_RTGArea) then
		newMachineTypeGrp:=MACHINETYPEGRP_RTG;
	else
		if newMachineTypeGrp = 0 then
			newMachineTypeGrp:=MACHINETYPEGRP_LIFTER;
		endif;
	endif;
	
	create arbiter transient;
	
	sourceLocation:=self.myWorkListEntry.getSourceLocation;
	subQueue				:= sourceLocation.getOverrideQueue();
	if subQueue = null then
		subQueue := targetLocation.getOverrideQueue();
	endif;
	
	arbiter.setForUpdate(self.getTrackedItem,self.myJob,sourceLocation,targetLocation,subQueue, self.myWorkListEntry,self.getMyTerminal);
	arbiter.entry:=nextEntry;
	newQueue:=arbiter.getQueue;
	
	nextEntry.machineTypeGroup:= newMachineTypeGrp;
	nextEntry.allTasks.last.machineTypeGroup:=newMachineTypeGrp;
	nextEntry.myRTMoveMethodRule:=null;
	self.setMyRTMoveMethodRule(null);
	self.myPreviousRelatedEntry.setMyRTMoveMethodRule(null);
	if newQueue &lt;&gt; null then
		nextEntry.myQueue.removeQueueEntry(nextEntry);
		
		newQueue.addQueueEntry(nextEntry);
	endif;
	
	
epilog
	delete arbiter;
end;</source>
    </JadeMethod>
    <JadeMethod name="checkTasksHaveMachineCoverage" id="1d1b7617-f051-4e7b-b5c4-4097093d6bc5">
        <updating/>
        <source>checkTasksHaveMachineCoverage() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 March 2010	cnwer1	Initial creation

*/

vars
	task : CM_RTQueueTask;
	//allMessages : StringArray512;
begin
	task:=self.allTasks.first;
	
	if self.myQueue = null then
		return;
	endif;
	
	if task.queryMachineCoverage(null ) then	
	// not calling self.setHasMachineCoverage beacuse don't want to send the notes
		
		self.hasMachineCoverage:=true;
	endif;
		
	
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="checkTwinCarryTwoTasks" id="2041b243-3cdc-4045-9bc7-3f13fe2cc1c9">
        <source>checkTwinCarryTwoTasks(_firstPickupTask ,_secondPickupTask :CM_RTQueueTask; useSourceLocation : Boolean) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 January 2009	cnwer1	Initial creation

*/

vars
	firstLC,
	secondLC : CM_LocationsController;
	firstHeight,
	secondHeight : Integer;
begin
	
	

	if _firstPickupTask = null or _secondPickupTask = null then
		app.writeStatement("a task is missing");
		return false;
	endif;
	
	if useSourceLocation then
		firstLC:=_firstPickupTask.sourceLocation;
		secondLC:=_secondPickupTask.sourceLocation;
	else
		firstLC:=_firstPickupTask.targetLocation;
		secondLC:=_secondPickupTask.targetLocation;
	endif;
	
	if firstLC = null or secondLC = null then
		app.writeStatement( "can not find a location  controller");
		return false;
	endif;
	
	
	//have to really wait for the door direction to be done to determine which location is prior or next
	//at this stage just make prior location is to the left of current
	if firstLC.myTerminalArea &lt;&gt; secondLC.myTerminalArea then 
		app.writeStatement("in different terminal areas");
		return false;
	endif;
	
	if secondLC.isKindOf(CM_GridController) then
			if not firstLC.CM_GridController.canTwinLiftWithNextController and
				not secondLC.CM_GridController.canTwinLiftWithPrevController then		
				app.writeStatement( "locations can't twin lift with each other");
				return false;
			endif;
		
			//think i can safely assume since they are both in the same terminal area that they have the same type of controllers 
			
			//need to check the currentSourceLC previous controller is equal to the priorSource LC
			if secondLC.CM_GridController.myPreviousController &lt;&gt; firstLC.CM_GridController then
				app.writeStatement( "current source lc my previous controller &lt;&gt; prior entries source lc");
				return false;
			endif;
	
			//then check that they are at the same height
			
			//current height will be the height of the entrys pickup tracked item
			firstHeight:=_firstPickupTask.ti.getPositionInStack(REAL_MODE);
			secondHeight:=_secondPickupTask.ti.getPositionInStack(REAL_MODE);
			if firstHeight &lt;&gt; secondHeight then
				app.writeStatement( "heights are different");
				return false;
			endif;
			return true;
		
	elseif secondLC.isKindOf(CM_VehicleController) or secondLC.isKindOf(CM_BlockController) then
		// it might be a road job but is definitely on a truck
		//need to check the currentSourceLC  is equal to the priorSource LC should both be on the same vehicle
		if secondLC &lt;&gt; firstLC then
			return false;
		endif;
		return true;
	elseif secondLC.isKindOf(CM_SlotController) then
		if secondLC.CM_SlotController.myBayVoyage.myHold &lt;&gt; firstLC.CM_SlotController.myBayVoyage.myHold then
			return false;
		endif;
		if secondLC.CM_SlotController.cellId &lt;&gt; firstLC.CM_SlotController.cellId then
			return false;
		endif;
		
		if secondLC.CM_SlotController.tierId &lt;&gt; firstLC.CM_SlotController.tierId then
			return false;
		endif;
		return true;
	else
	// if they are on a ship i.e. slot controller or
	// if on ship we can test that the two are next two each other
	
	// if they are on a block controller assume they are next to each other
		return true;
	endif;
	
	return false;
	
	
	
epilog

end;</source>
        <Parameter name="_firstPickupTask" type="CM_RTQueueTask"/>
        <Parameter name="_secondPickupTask" type="CM_RTQueueTask"/>
        <Parameter name="useSourceLocation" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="convertDirectorNullVoyageProc" id="d7db5026-b306-4582-b9c8-24cc18e9937f">
        <source>convertDirectorNullVoyageProc( directorTask  : CM_RTQueueTask; _passport : CM_Passport input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 December 2012	cnwndl1	Initial creation	Par 30766 - We used to set the voyage on a null voyage ti,  
						during the planning, and we still need to, so teh hand held lander can find it.

*/

vars

	ti : CM_TrackedItem;
	term : CM_Terminal;
	nullVoyage : CM_Voyage;
	wlesVoyage : CM_Voyage;
	txnParams : CMIF_TITransactionController;
	txn : CM_TITransaction;
		
begin

	if self.myWorkListEntry.isBulkRelease or ( self.myJob.isVoyageAllocLoad and directorTask.ti.isEmpty)  //cnwrd1 needs to work for mts for voyage alloc loading too
//	and  self.isMultiMachineDirector()  // do it for even single machine moves cnwrd1 
	and self.myWorkListEntry.isKindOf(CM_VoyageWLE)
	then
		ti := directorTask.ti;
		term := self.myWorkListEntry.getMyTerminal;
		if term = null then
			return;
		else
			nullVoyage := term.getNullVoyage;
		endif;
		wlesVoyage := self.myWorkListEntry.CM_VoyageWLE.getVoyage;
		
		if	ti &lt;&gt; null
		and ti.myVoyage = nullVoyage or ti.myVoyage = null or (ti.isStorage and ti.isEmpty)		// 20/03/2013 cnwar2 #31296 - update voyage if storage MT
		and wlesVoyage &lt;&gt; null
		then
			// the ti doesn't have a real voyage, an dteh wle does
			// so set the voyage on the ti...
			
			create txnParams transient;
			txnParams.type := TRANS_TYPE_EDIT;
			txnParams.myTrackedItem := ti;
			txnParams.myTerminal := term;
			txnParams.dateTime := app.serverTimestampAtTrxStart;
			txn := ti.createTransaction(txnParams, _passport);
			
			if txn &lt;&gt; null then
				if ti.myVoyage = null then			
					txn.CM_Edit.fieldsValues.add(CM_TrackedItem::myVoyage.name &amp; " ' ' =&gt;  " &amp; wlesVoyage.code);
				else
					txn.CM_Edit.fieldsValues.add(CM_TrackedItem::myVoyage.name &amp; ti.myVoyage.code &amp; " =&gt;  " &amp; wlesVoyage.code);
				endif;
				ti.setMyVoyage(wlesVoyage, _passport);				
			endif;
		
		endif;
	endif;

epilog

	delete txnParams;
	
end;
</source>
        <Parameter name="directorTask" type="CM_RTQueueTask"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="convertDirectorTaskToMove" id="18fa17a4-a3e5-44ae-a360-ccb20a83d830">
        <updating/>
        <source>convertDirectorTaskToMove(	_directorTask : CM_RTQueueTask input; 
							_allocateMachineToTask : Boolean;
							_passport : CM_Passport input) updating;
//Looks at the tasks in this entry, if we find a director task, complete it,
//and build a set of standard move tasks to replace it...

/*

Date		Who		Reason
17 Feb 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift
					Renamed as part of refactoring methods
08 Jul 2009	cnwkpd1	PAR #20230 - Prevent attempt to allocate twin Director task during convert
10 Aug 2010 cnwer1	PAR #25236 - director tasks need wle set
13 Mar 2013 cnwer1	PAR 30908 - in truck loader app needed to convert director to move without a machine involved
                               - without conversion no future move is created and entries never get tidied up
17 May 2017 cnwer1	TFS 996 vmt generic changed method params to pass in task and a param to indicate to allocate director task created
								to the machine.  This is so I can get rid of method convertDirectorTaskToMove2
*/

vars
//	arbiter	:	CM_RTQueueArbiter;
	heldMachine	:	CM_Machine;
	nextMachine	:	CM_Machine;
	newBBTask,
	firstNewTask,
	nextTask 	:	CM_RTQueueTask;
	directorTask  : CM_RTQueueTask;
	nextEntryMoveTask  : CM_RTQueueTask;
	control : CMIF_MoveController;
	messageLogger : CM_MachineRTQueueEntryLogger;
	myFutureMovePlanned : CM_FutureMove;
	
begin
	//epr TFS 995 17/5/17 removed reliance on mediator
	directorTask := _directorTask;
	if not allTasks.includes(directorTask) then
		app.setContinueCMExceptions(false);
		app.raiseCMException(ERR_DIRECTOR_CONVERT, null, null);
		return;
	endif;
	if directorTask.taskType &lt;&gt; TASK_DIRECTOR then
		app.setContinueCMExceptions(false);
		app.raiseCMException(ERR_DIRECTOR_CONVERT, null, null);
		return;
	endif;
	//-------------------
	//OK, get directors stuff, and build moveTasks
	//-------------------
	//The director's ti is the one we are going to do the moves on...
	//it was set by RTQueueTask's "addTIToDirector" method.
	//We QUEUE move it, and adds tasks to this entry..\
	if directorTask.ti = null then
		app.raiseCMException1(ERR_NO_OBJECT, "No TI to link to director", null, null);
		return;
	endif;
	//-------------------
	//Queue move the TI to the Target location
	//-------------------
	
	//03 Dec 2012	NDL	Par 30766 - We used to set the voyage on a null voyage ti, 
	//								during the planning move bit, and we still need to.
	self.convertDirectorNullVoyageProc( directorTask, _passport );

	// HAVE TO MAKE SURE ALL THIS WORKS WITH MULTIPLE MACHINES.
	create control transient;
	control.setMoveMode(QUEUE_MODE);
	control.isSystemMove := true;
	control.myRTQueueEntry := self;
	control.setMyTrackedItem(directorTask.ti);

	//cnwrd1 par 25681 18.11.2010 multi machine director moves
	if directorTask.isFirstDirectorTask then
		control.setMyToPrimaryLocation( directorTask.getMultiDirectorUltimateTarget() );
	endif;
	
	if control.myToPrimaryLocation = null then
	//else
		control.setMyToPrimaryLocation(directorTask.targetLocation);
	endif;	
	control.isDirectorMove := true;
	//epr par 25236 4/8/10
	control.setMyWorkListEntry(self.myWorkListEntry);
//	control.isForcedMove := self.overRideFlags &lt;&gt; 0;
	app.myUtilityUA.utlUpdateMoveTrackedItem(control, _passport);
	if (not app.myPassport.noErrors) then
		app.convertErrorsWarningsToAlert(app.getErrorString1(Failed_Queue_Director,self.id), _passport.allErrorWarnings);
		app.raiseCMException1(Failed_Queue_Director_Alerts, self.id,null,null); //epr 13/3/13 not an unexpected error just failed to queue
		return;
	endif;
	
	directorTask.ti.copyReleaseJobToTI(self.myWorkListEntry);
	
		
	if self.myWorkListEntry.isBulkRelease  // set the planned move reference on the queued move
 	 and self.myWorkListEntry.isKindOf(CM_VoyageWLE) then
		self.myWorkListEntry.myFutureMove.CM_FutureMoveQueued.setMyFutureMovePlanned( myFutureMovePlanned.CM_FutureMovePlanned);
	endif;
	

	//-------------------
	//Store off machine, we re-attach it later..
	//-------------------
	if directorTask.machine &lt;&gt; null then
		heldMachine := directorTask.machine;
	endif;
	//-------------------
	//Destroy the directorTask BEFORE we create the new tasks
	//-------------------
	directorTask.ti := null;	//Remove this ref. If we dont do this,
											//then the TI gets unqueued before we get a chance to work it!!!
	//-------------
	//Leave the director task here, we may need to deassign later											
	//At this point, the director task is back to its original condition, apart from
	//being complete.
	//-------------
	directorTask.setStatusComplete();
	
	//cnwrd1 par 25681 18.11.2010 multi machine director moves
	if directorTask.isFirstDirectorTask then
		//should have multiple director tasks on multiple entries here.
		directorTask.myEntry.setMutliDirectorComplete();
	endif;

	
	firstNewTask := self.getTaskOfType(TASK_BREAKBULK,null);
	if firstNewTask &lt;&gt; null then	
		app.myUtilityUA.utlBreakBulkMasterAccept(firstNewTask,newBBTask);
	endif;
	
	
	if heldMachine &lt;&gt; null then
		//----------------
		//Re-allocate this machine to the new task
		//----------------
		firstNewTask := self.getTaskOfType(TASK_PICKUP, null); //arbiter.entry.getTaskOfType(TASK_PICKUP);
	
		//06/07/2010 cnwdz2 24640
		if firstNewTask = null then
			app.setContinueCMExceptions(false);
			app.raiseCMException(ERR_TASKUNAVAILABLE, null, null);
			return;
		endif;
		if _allocateMachineToTask then
			firstNewTask.allocateMachineToTask(heldMachine, false, false);
			// CCMS 1309 DVB 15/02/2005
			create messageLogger transient;
			messageLogger.myMachine:=heldMachine;
			if not firstNewTask.queryMachineAssign(heldMachine, true, false,false,true,true, messageLogger) then
				//----------------
				//Error! Machine cannot pickup
				//----------------
				app.setContinueCMExceptions(false);
				app.raiseCMException2(ERR_MACH_ASSIGN, heldMachine.id.trimRight, "Machine is unsuitable, see Alert Log for details...", null, null);
				return;
			endif;
			if firstNewTask.taskType = TASK_PICKUP then
				heldMachine.executeGetNextTask( false);		// PAR #20230
			endif;
		else
			//epr TFS 995 VMT generic changes get rid of the convertDIrectorTaskTOMove2 that does everything but this because its used for twin director and
			//does extra validtion before assigning to a machine
			firstNewTask.setMachine(heldMachine);
		endif;
	endif;
	
	
	//check mutli director machine assigns - may need refactoring out
	
	if directorTask.isFirstDirectorTask then			
		nextEntryMoveTask := directorTask.myEntry.getNextEntryFirstMoveTask();
		
		nextTask := directorTask.myEntry.getNextEntryFirstDirectorTask; //cnwrd1 par 26797 21.1.2011
		//nextMachine := directorTask.myEntry.getNextEntryFirstTask.myMachine;
		nextMachine := nextTask.myMachine;
		if nextEntryMoveTask &lt;&gt; null and nextMachine &lt;&gt; null then
			if not nextMachine.allCurrentQueueTasks.includes(nextEntryMoveTask) then
				nextEntryMoveTask.setMachine(nextMachine );			
				nextEntryMoveTask.allocateMachineToTask( nextMachine , false, false);			
				nextEntryMoveTask.setStatus(TASK_ACCEPTED);
			endif;
		endif;
	endif;
	
	//04 Aug 2014	NDL	Par 34675
//	if self.myWorkListEntry &lt;&gt; null and self.myWorkListEntry.isAnyId() then
	if self.myWorkListEntry &lt;&gt; null and self.myWorkListEntry.isAnyId() and not self.myWorkListEntry.isAnyAmount then	//10 Feb 2021	NDL	TFS 50666
		self.createNextAnyIdTask();
	endif;
	
	
epilog
	delete control;
	delete messageLogger;
end;</source>
        <Parameter name="_directorTask" type="CM_RTQueueTask" usage="input"/>
        <Parameter name="_allocateMachineToTask" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="convertDirectorTaskToMove2" id="ae329188-7fd1-4827-81cf-071af1b2b271">
        <updating/>
        <source>convertDirectorTaskToMove2(mediator: CM_RTConnectMediator io; _passport : CM_Passport input) updating;
//Looks at the tasks in this entry, if we find a director task, complete it,
//and build a set of standard move tasks to replace it...

/*

Date		Who		Reason
17 Feb 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift
					Renamed as part of refactoring methods
08 Jul 2009	cnwkpd1	PAR #20230 - Prevent attempt to allocate twin Director task during convert
10 Aug 2010 cnwer1	PAR #25236 - director tasks need wle set
13 Mar 2013 cnwer1	PAR 30908 - in truck loader app needed to convert director to move without a machine involved
                               - without conversion no future move is created and entries never get tidied up
*/

vars
//	arbiter	:	CM_RTQueueArbiter;
	heldMachine	:	CM_Machine;
	nextMachine	:	CM_Machine;
	firstNewTask,
	nextTask 	:	CM_RTQueueTask;
	directorTask  : CM_RTQueueTask;
	nextEntryMoveTask  : CM_RTQueueTask;
	control : CMIF_MoveController;
	messageLogger : CM_MachineRTQueueEntryLogger;
	myFutureMovePlanned : CM_FutureMove;
	
begin
	directorTask := mediator.task;
	if not allTasks.includes(directorTask) then
		app.setContinueCMExceptions(false);
		app.raiseCMException(ERR_DIRECTOR_CONVERT, null, null);
		return;
	endif;
	if directorTask.taskType &lt;&gt; TASK_DIRECTOR then
		app.setContinueCMExceptions(false);
		app.raiseCMException(ERR_DIRECTOR_CONVERT, null, null);
		return;
	endif;
	//-------------------
	//OK, get directors stuff, and build moveTasks
	//-------------------
	//The director's ti is the one we are going to do the moves on...
	//it was set by RTQueueTask's "addTIToDirector" method.
	//We QUEUE move it, and adds tasks to this entry..\
	if directorTask.ti = null then
		app.raiseCMException1(ERR_NO_OBJECT, "No TI to link to director", null, null);
		return;
	endif;
	//-------------------
	//Queue move the TI to the Target location
	//-------------------
	
	//03 Dec 2012	NDL	Par 30766 - We used to set the voyage on a null voyage ti, 
	//								during the planning move bit, and we still need to.
	self.convertDirectorNullVoyageProc( directorTask, _passport );

	// HAVE TO MAKE SURE ALL THIS WORKS WITH MULTIPLE MACHINES.
	create control transient;
	control.setMoveMode(QUEUE_MODE);
	control.isSystemMove := true;
	control.myRTQueueEntry := self;
	control.setMyTrackedItem(directorTask.ti);

	//cnwrd1 par 25681 18.11.2010 multi machine director moves
	if directorTask.isFirstDirectorTask then
		control.setMyToPrimaryLocation( directorTask.getMultiDirectorUltimateTarget() );
	endif;
	
	if control.myToPrimaryLocation = null then
	//else
		control.setMyToPrimaryLocation(directorTask.targetLocation);
	endif;	
	control.isDirectorMove := true;
	//epr par 25236 4/8/10
	control.setMyWorkListEntry(self.myWorkListEntry);
//	control.isForcedMove := self.overRideFlags &lt;&gt; 0;
	app.myUtilityUA.utlUpdateMoveTrackedItem(control, _passport);
	if (not app.myPassport.noErrors) then
		app.convertErrorsWarningsToAlert(app.getErrorString1(Failed_Queue_Director,self.id), _passport.allErrorWarnings);
		app.raiseCMException1(Failed_Queue_Director_Alerts, self.id,null,null); //epr 13/3/13 not an unexpected error just failed to queue
		return;
	endif;
	
	directorTask.ti.copyReleaseJobToTI(self.myWorkListEntry);
	
		
	if self.myWorkListEntry.isBulkRelease  // set the planned move reference on the queued move
 	 and self.myWorkListEntry.isKindOf(CM_VoyageWLE) then
		self.myWorkListEntry.myFutureMove.CM_FutureMoveQueued.setMyFutureMovePlanned( myFutureMovePlanned.CM_FutureMovePlanned);
	endif;
	

	//-------------------
	//Store off machine, we re-attach it later..
	//-------------------
	if directorTask.machine &lt;&gt; null then
		heldMachine := directorTask.machine;
	endif;
	//-------------------
	//Destroy the directorTask BEFORE we create the new tasks
	//-------------------
	directorTask.ti := null;	//Remove this ref. If we dont do this,
											//then the TI gets unqueued before we get a chance to work it!!!
	//-------------
	//Leave the director task here, we may need to deassign later											
	//At this point, the director task is back to its original condition, apart from
	//being complete.
	//-------------
	directorTask.setStatusComplete();
	
	//cnwrd1 par 25681 18.11.2010 multi machine director moves
	if directorTask.isFirstDirectorTask then
		//should have multiple director tasks on multiple entries here.
		directorTask.myEntry.setMutliDirectorComplete();
	endif;
	
	firstNewTask := self.getTaskOfType(TASK_PICKUP, null); //arbiter.entry.getTaskOfType(TASK_PICKUP);

	firstNewTask.setMachine(heldMachine);
	//firstNewTask.setStatus(TASK_ACCEPTED);
/*
	if heldMachine &lt;&gt; null then
		//----------------
		//Re-allocate this machine to the new task
		//----------------
		firstNewTask := self.getTaskOfType(TASK_PICKUP, null); //arbiter.entry.getTaskOfType(TASK_PICKUP);
		//06/07/2010 cnwdz2 24640
		if firstNewTask = null then
			app.setContinueCMExceptions(false);
			app.raiseCMException(ERR_TASKUNAVAILABLE, null, null);
			return;
		endif;
		mediator.task := firstNewTask;
		firstNewTask.allocateMachineToTask(heldMachine, false, false);
		// CCMS 1309 DVB 15/02/2005
		create messageLogger transient;
		messageLogger.myMachine:=heldMachine;
		if not firstNewTask.queryMachineAssign(heldMachine, true, false,false,true,true, messageLogger) then
			//----------------
			//Error! Machine cannot pickup
			//----------------
			app.setContinueCMExceptions(false);
			app.raiseCMException2(ERR_MACH_ASSIGN, heldMachine.id.trimRight, "Machine is unsuitable, see Alert Log for details...", null, null);
			return;
		endif;
//		genMediator := mediator;
		//heldMachine.executeGetTasks(mediator, false);		// PAR #20230
	endif;
	
	*/
	//check mutli director machine assigns - may need refactoring out
	
	if directorTask.isFirstDirectorTask then			
		nextEntryMoveTask := directorTask.myEntry.getNextEntryFirstMoveTask();
		
		nextTask := directorTask.myEntry.getNextEntryFirstDirectorTask; //cnwrd1 par 26797 21.1.2011
		//nextMachine := directorTask.myEntry.getNextEntryFirstTask.myMachine;
		nextMachine := nextTask.myMachine;
		if nextEntryMoveTask &lt;&gt; null and nextMachine &lt;&gt; null then
			nextEntryMoveTask.setMachine(nextMachine );			
			nextEntryMoveTask.allocateMachineToTask( nextMachine , false, false);			
			nextEntryMoveTask.setStatus(TASK_ACCEPTED);
		endif;
	endif;
	
	
epilog
	delete control;
	delete messageLogger;
end;</source>
        <Parameter name="mediator" type="CM_RTConnectMediator" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="convertMoveToDirector" id="c310126c-f943-4aaf-ad0b-a630da903f1e">
        <updating/>
        <source>convertMoveToDirector() updating;
/*
This method does a serious amount of work. 
We are called when the user requires to "back out" the currently executing director task
from its completed status, to an unactioned status, ready to go with the original job.
This means that any tasks currently underway are allowed to complete
and the current director is resurected, its job is reset back to unactioned
and all set up to go again. So, when they ask for a TI again, its it all goes around again.
*/
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	aTask	: CM_RTQueueTask;
	directorTask	: CM_RTQueueTask;
	aTI	:	CM_TrackedItem;
	flags	:	Integer;
	term	: CM_Terminal;
begin

	foreach aTask in self.allTasks do
		if aTask.taskType = TASK_DIRECTOR then
			break;
		endif;
	endforeach;			
	if aTask = null or aTask.taskType &lt;&gt; TASK_DIRECTOR then
		//hmmm, no director task!
		return;
	endif;
	directorTask := aTask;
	//------------------
	//We have the director task, are there any others?
	//------------------
	//----------------
	//Force the director task BACK to unactioned
	//----------------
	aTask.status := TASK_UNACTIONED;

	if self.allTasks.size = 1 then
		//-----------------
		//Unconverted yet..No other tasks
		//-----------------
		return;
	endif;
	if not self.myJob.isKindOf(CM_YardJob) then
		app.setContinueCMExceptions(false);
		app.raiseCMException(ERR_INVALID_JOB, null, null);
		return;
	endif;
	//---------------
	//Find the TI involved, and remove it from the JOB.
	//---------------
	foreach aTask in allTasks discreteLock, reversed do
		if aTask.taskType = TASK_PICKUP then
			break;
		endif;
	endforeach;			

	if aTask = null or aTask.taskType &lt;&gt; TASK_PICKUP then
		//hmmm, no pickup task!
		app.setContinueCMExceptions(false);
		app.raiseCMException2(ERR_NOTASKOFTYPE, TASK_PICKUP_DESC, self.queueId, null, null);
		return;
	endif;
 	aTI := aTask.ti;
	//--------------
	//Is the TI's queued location STILL == its original queued locn, if so
	//they havent over-written the location for the original ti!!!
	//This is supposed to be used for when a box has been picked up, and
	//found to be NO good!
	//--------------
	if aTI.getPrimaryLocation(QUEUE_MODE) = directorTask.targetLocation then
		app.setContinueCMExceptions(false);
		app.raiseCMException1(ERR_REDIRECTOR, aTI.id.trimRight, null, null);
		return;
	endif;
	
	// if pickup task has not been completed then dont allow Director task to be recreated
	//	as this leads to errors with the WLE down the track. Can re-create if is on set down task 
	if aTask.status &lt;&gt; TASK_COMPLETE then  
		app.setContinueCMExceptions(false);
		app.raiseCMException1(ERR_REDIRECTOR_PICKUP, aTI.id.trimRight,null, null);
		return;
	endif;
	
	//--------------
	//Delink TI from Job
	//--------------
	self.myWorkListEntry.setMyTrackedItem(null);
	self.myJob.CM_YardJob.removeTI(aTI, self.myWorkListEntry.myRequest);	
	self.myWorkListEntry.rebuildStatus(); //epr par 25573 6/2/2011 trying to not have so many status update methods was updateStatus
	term := self.myQueue.getMyTerminal();
	if term &lt;&gt; null then
		self.causeEvent(term.getTerminalEvent(RTQueueEntry_Update_Event), false, null);
	endif;
//	self.myJob.updateStatus();	This is done in wle's call above
	//--------------
	//This should do it. The setDown needs to "go around", and present the
	//Director task (its the first task, and is now "unactioned" I hope)
	//--------------
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="create" id="77c2dfb0-f1d0-4caf-a349-6b12370b3100">
        <updating/>
        <source>create() updating;

vars
	now 	: TimeStamp;
	term	: CM_Terminal;
begin
	addedDT := now;
	term := app.getMyTerminalDO_NOT_USE();
	if term &lt;&gt; null then
		self.causeEvent(term.getTerminalEvent(RTQueueEntry_Update_Event), false, null);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="createExtraTasks" id="785c00bf-c84d-41b8-8c1e-20d8c5ac18cd">
        <updating/>
        <source>createExtraTasks(_controller : CMIF_MoveController; _futureMove : CM_FutureMoveQueued input) updating;

// cnwdvb1 19 June 2003 
/*
Date		Who		Reason
16 Feb 2010	consw1	PAR #22383 - Allow for multiple machine moves when actioning a Director Task
25 Oct 2012 cnwer1 	PAR #30507
*/

vars

	arbiter 	: CM_RTQueueArbiter;	
	ti			: CM_TrackedItem;
	term		: CM_Terminal;
	entry		: CM_RTQueueEntry;
	alert		: CM_SystemAlert;

begin

	ti := _controller.myTrackedItem;	
 	create arbiter transient;
	arbiter.job := self.myJob;
	arbiter.entry := self;
	arbiter.sourceLocation := ti.getPrimaryLocation(REAL_MODE);
	arbiter.targetLocation := ti.getPrimaryLocation(QUEUE_MODE);
	arbiter.ti := ti;
	arbiter.queue := self.myQueue;

	//--------------------
	//Get pickup &amp; setdown tasks
	//--------------------
	// Only returns queue entries for non overstow moves.
	entry := ti.getQueueEntry();
	if _controller.isOverstowMove then
		arbiter.sourceLocation.getPickupTasks(arbiter, _controller.isOverstowMove);
		arbiter.targetLocation.getSetdownTasks(arbiter, _controller.isOverstowMove);
	else
		arbiter.myTerminal := ti.myTerminal;
		arbiter.wle := self.myWorkListEntry;
		//epr 30507 24/10/12 
		if self.myRTMoveMethodRule &lt;&gt; null then
			arbiter.setMyRTMoveMethodRule(self.myRTMoveMethodRule);
		endif;
		//epr par 32408 6/9/13
		arbiter.myBulkReleaseMaster:=self.myBreakBulkMaster;
		arbiter.enqueueTI();
	endif;

	// cnwrd1 par 28725 - putting this back in because it caused major issues, the now non held queue task can be worked THEN the overstow move is worked, this has moved a container back from ship to wharf!
	// we will HOLD this RTQ task now and when we set down the overstow task we will unhold it and allow it to be worked this should prevent it from being 'forgotten' by the queue/machines.
	//	08 Mar 2011	NDL	Par 27156 / CCMS 2030
	if entry &lt;&gt; null then
		if entry.status &lt;&gt; ENTRY_WORKING then
			create alert;
			//alert.details := ti.id.trimBlanks &amp; " Queue Entry set to HELD to prevent conflicting overstow move.";
			alert.details := ti.id.trimBlanks &amp; app.getErrorString(Queue_entry_held_preve_conflct);
			alert.setSeverity(SEVERE_WARNING);
			alert.add;
			alert.setLinkedTo(entry);
			entry.setEntryStatus(QSTATUS_HELD);
		endif;
	endif; 
	if _controller.isOverstowMove then	
		self.sortMyOverstowTasks(_controller);
	endif;
	self.exclusiveLock(_futureMove);

	_futureMove.setRTQueueEntry(self, false);
//	term := app.getMyTerminal();
	term := self.myQueue.getMyTerminal();
	if term &lt;&gt; null then
		self.causeEvent(term.getTerminalEvent(RTQueueEntry_Update_Event), false, 0);
	endif;
	
epilog
	delete arbiter;
end;</source>
        <Parameter name="_controller" type="CMIF_MoveController"/>
        <Parameter name="_futureMove" type="CM_FutureMoveQueued" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createNextAnyIdTask" id="1b8da717-2fb6-44f8-a5a7-8a000fdf3ffd">
        <source>createNextAnyIdTask();
/*

Purpose:			

			We have a release by ID that is for a list of TIs, the existing task
			has just been converted from a director task to a real TI queued move
			so it is time to create the
			next director task. ( BUT Only if there are still cargo items to process. )
	

Return Value:		

Date		Who		Reason
04 August 2014	cnwndl1	Initial creation	Par 34675

*/

vars

	myRequest : CM_Request;
	source : CM_LocationsController;
	ti : CM_TrackedItem;
	iter : Iterator;
	bulkRel : CM_BulkRelease;
	iter2 : Iterator;
	request : CM_Request;
	count : Integer;

begin

	myRequest := self.myWorkListEntry.myRequest;
	if myRequest &lt;&gt; null then
		source := myRequest.getFirstLocationForAnyId();
	endif;
	
	ti := self.myWorkListEntry.myTrackedItem;
	
	//populate the 'release details' captured at the gate onto the selected TI
	app.myUtilityUA.utlUpdTiFromIsAnyIdRelease(ti, myRequest.CM_DeliveryRequest, app.myPassport);
	
	//TIs are allowed on multiple Releases in parallel
	//auto complete any related RTQ tasks for related requests that have no more cargo
	//as a result of the ti on this entry now being spoken for...
	
	if ti &lt;&gt; null then
		iter := ti.allBulkReleasesAssigned.createIterator;
		while iter.next( bulkRel ) do
			count := bulkRel.getAnyIdAvailableTiCount();
			
			if count = 0 then
				// there are no available tis anymore, close down any existing rtq tasks for these requests
				iter2 := bulkRel.allRequestsBeingActioned.createIterator;
				while iter2.next( request ) do
					if not request.isAnyId() then
						continue;
					endif;
					app.myUtilityUA.utlCompleteAnyIdExtraTasks(request.CM_DeliveryRequest, app.myPassport);
				endwhile;
				delete iter2;
			endif;
			
		endwhile;
		delete iter;
	endif;
	
	if source = null then
		// no source found means no unprocessed TIs left to go.
		return;
	endif;
	
	app.myUtilityCA.utlCreateAnyIDDirectorTask(self.myWorkListEntry, app.myPassport);
	

epilog

	delete iter;
	delete iter2;

end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="9c37816b-050f-48e4-8239-0c6b04a114a4">
        <updating/>
        <source>delete() updating;
// -------------------------------------------
// Created 10 March 2005 by cnwdvb1
// -------------------------------------------
/*	Put some backup code to try and stop ti myQueue reference
	being left set somehow - */
vars

	ti			: CM_TrackedItem;
	terminal	: CM_Terminal;
	machine 	: CM_Machine;
begin

	if self.isTransient then
		return;
	endif;
	terminal := self.getMyTerminal;
	if terminal = null then
		terminal:=app.getMyTerminalDO_NOT_USE;
	endif;
	// Just incase it is being delete by parent child relationship.
	if self.myQueue &lt;&gt; null then
	  	if terminal &lt;&gt; null then
			app.myEventManager.createSingleObjInfoNoteEvt(self.myQueue,terminal.getTerminalEvent(Event_Delete_Queue_Entry),self);	
		endif;	
	endif;
	
	if terminal &lt;&gt; null then
		self.causeEvent(terminal.getTerminalEvent(RTQueueEntry_Delete_Event), false, false);	
	endif;
	
	
	
	if self.myWorkListEntry &lt;&gt; null then
		ti := self.myWorkListEntry.myTrackedItem;
		// DVB changed 10/08/06
		if ti &lt;&gt; null  then
			ti.removeFromQueue(self); //epr par 25307 11/8/10
		endif;
	endif;

	
end;</source>
    </JadeMethod>
    <JadeMethod name="deleteEntry" id="d3636536-f26a-46bc-abea-c5b9ec95337a">
        <updating/>
        <source>deleteEntry(_onlyOverStows : Boolean; _ti : CM_TrackedItem) : Boolean updating;
//Nukes us, removes us from the queue, removes references to the TI
//NOTE:The deleteTask does the UNQUEUE.
/*

Date		Who		Reason
12 Mar 2010	cnwkpd1	PAR #23167 - Reinstate old behaviour of sending _onlyOverStows as userInfo
					with delete notification
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance
// 20 Dec 2018	jlgrs1	TFS 42112 STWO Deadlocks with Mobile apps
*/

vars
	numCleaned	: Integer;
	term		: CM_Terminal;
	iter		: Iterator;
	task		: CM_RTQueueTask;
	taskArray	: CM_RTQueueTaskArray;
	
begin
	if (self.status = ENTRY_UNACTIONED) or 
	   (self.status = ENTRY_COMPLETE) or 
	   (self.status = ENTRY_USER_HELD) or
	   (self.status = ENTRY_SYSTEM_HELD)	//22 Apr 2015	NDL	Par 36014
	   then
		//We are happy here, do nothing
	endif;
	exclusiveLock(self);

	if self.myJob &lt;&gt; null then
		exclusiveLock(self.myJob);
	endif;
	//-------------
	//Call the delete method on each task, this undoes the queued moves etc
	//-------------
//	term := app.getMyTerminal();
	term := self.myQueue.getMyTerminal();
	if term &lt;&gt; null then
		self.causeEvent(term.getTerminalEvent(RTQueueEntry_Delete_Event), false, _onlyOverStows);	// PAR #23167
	endif;
	
	create taskArray transient;
	self.allTasks.copy(taskArray);
	iter := taskArray.createIterator();
	while iter.next(task) do
		if (not _onlyOverStows)
		or (task.isOverstowTask and task.ti = _ti) then
			task.deleteTask();
		endif;
	endwhile;
	
	if _onlyOverStows then
		return true;
	endif;

	//has to be done before myQueue is deleted
	//------------------
	//Clear out any alerts hooked in here
	//------------------
	self.eraseAlerts();

// 20 Dec 2018	jlgrs1	TFS 42112 STWO Deadlocks with Mobile apps
	if not self.tryLock(self.myWorkListEntry.allRTQueueEntries, Exclusive_Lock, Transaction_Duration, LockTimeout_Server_Defined) then
		self.exclusiveLock(self.myWorkListEntry.allRTQueueEntries);
	endif;
	if not self.tryLock(self.allOverstowQueueEntries, Exclusive_Lock, Transaction_Duration, LockTimeout_Server_Defined) then
		self.exclusiveLock(self.allOverstowQueueEntries);
	endif;
	if not self.tryLock(self.myQueue.allEntries, Exclusive_Lock, Transaction_Duration, LockTimeout_Server_Defined) then
		self.exclusiveLock(self.myQueue.allEntries);
	endif;

	delete self;
	return true;
epilog	
	delete iter;
	delete taskArray;
end;</source>
        <Parameter name="_onlyOverStows" type="Boolean"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="entryDescription" id="c49b9b56-5125-4d43-aaae-ba526d691b19">
        <source>entryDescription() : String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 February 2011	cnwer1	Initial creation par 26495

*/

vars
	ti : CM_TrackedItem;
	theDescription, tiId : String;
	firstTask, lastTask : CM_RTQueueTask;
	 
begin
	ti := self.getTrackedItem;
	if ti &lt;&gt; null then
		tiId:=ti.id;
	else
		tiId :=self.myWorkListEntry.myRequest.getId;	
	endif;

	firstTask:=self.getDirectorOrPickupTask;
	 
	if firstTask &lt;&gt; null and firstTask.taskType = TASK_DIRECTOR then // par 29286 cnwrd1 
		theDescription:= app.getErrorString3(Director_from_to,tiId,firstTask.sourceLocationId,firstTask.targetLocationId);
	elseif firstTask &lt;&gt; null and  firstTask.taskType = TASK_MOVE then // par 29286 cnwrd1 
		theDescription:= app.getErrorString3(Moved_from_to,tiId,firstTask.sourceLocationId,firstTask.targetLocationId);
	else
		lastTask := self.getDirectorOrSetDownTask;
		if lastTask &lt;&gt; null then//cnwrd1 ccms 2014 22.3.2010
			app.writeLog(method.qualifiedName &amp; Tab &amp; "firstTask.targetLoction is " &amp; firstTask.targetLocationId &amp; ", lastTask.sourceLocation is " &amp; lastTask.sourceLocationId, LogINFO);
		theDescription:= app.getErrorString3(Picked_up_from_setdown_at,tiId,firstTask.sourceLocationId,lastTask.targetLocationId);
		endif;		
	endif;
	
	return theDescription;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="eraseAlerts" id="8086fecf-2ce8-48fa-b571-19bfb7a6cebf">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_AlertAlarm::eraseAlerts"/>
        </interfaceImplements>
        <source>eraseAlerts();

	/*
		this method stub has been automatically generated by Jade to satisfy interface implementation requirements
	*/
/*

Purpose:			


Return Value:		


Date		Who		Reason
20 February 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars


	iter : Iterator;
	alert : CM_SystemAlert;
	invalidAlert : Boolean;
begin

	if app.isUnitTestGarbageCollect then
		return;
	endif;
	on Exception do app.handleDeletedObject(exception,alert,invalidAlert);
	iter:=self.alerts.createIterator;
	while iter.next(alert) do
	// tidy up this manual collection
		alert.setReviewed(true);
		if invalidAlert then
			invalidAlert:=false;
			continue;
		endif;
		alert.setLinkedTo(null);
	endwhile;

epilog
	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="findControlAllocatedTaskToMach" id="cbba7124-e2ee-48bd-b1e8-8eb7c49eded1">
        <source>findControlAllocatedTaskToMach(_machine : CM_Machine) : CM_RTQueueTask;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 June 2010	cnwer1	Initial creation

*/

vars
	
begin

	if _machine.hasAllocatedQueueTasks then
		if _machine.isQueueEntryAllocated(self) then
			return self.getFirstUncompletedTask();
		endif;
	endif;

	return null;

epilog

end;</source>
        <Parameter name="_machine" type="CM_Machine"/>
        <ReturnType type="CM_RTQueueTask"/>
    </JadeMethod>
    <JadeMethod name="findFirstCraneTask" id="b493680d-8e56-47e0-a059-b1ab50ae3623">
        <source>findFirstCraneTask()	: CM_RTQueueTask;
//Finds first available crane task.
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	aTask :	CM_RTQueueTask;
begin
	foreach aTask in self.allTasks do
		if aTask.status &lt;&gt; TASK_COMPLETE then
			if aTask.isCraneTask() then
				return aTask;
			endif;
		endif;
	endforeach;
	return null;
end;</source>
        <ReturnType type="CM_RTQueueTask"/>
    </JadeMethod>
    <JadeMethod name="findNonOverstowTaskOfType" id="c11d2aad-2efd-4061-b53f-76caf5be582e">
        <source>findNonOverstowTaskOfType(_taskType : Integer) : CM_RTQueueTask;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 July 2010	cnwer1	Initial creation

*/

vars
	aTask	: CM_RTQueueTask;
begin

	foreach aTask in self.allTasks discreteLock do
		if aTask.taskType &lt;&gt; _taskType then
			continue;				
		endif;
		if aTask.isOverstowTaskAuto then
			continue;
		endif;
		
		return aTask;
	endforeach;


	return null;
epilog

end;</source>
        <Parameter name="_taskType" type="Integer"/>
        <ReturnType type="CM_RTQueueTask"/>
    </JadeMethod>
    <JadeMethod name="findOfferedTask" id="83eca43b-d2f3-4c19-8d9b-82b39a6ca1db">
        <source>findOfferedTask() : CM_RTQueueTask;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 May 2010	cnwer1	Initial creation

*/

vars
	tTask : CM_RTQueueTask;
begin
	tTask := self.findTaskOfType(TASK_PICKUP, TASK_OFFERED);
	if tTask &lt;&gt; null then
		return tTask;
	endif;
	
	tTask := getTaskOfType(TASK_MOVE, TASK_OFFERED);
	if tTask &lt;&gt; null then
		return tTask;
	endif;
	
	tTask := getTaskOfType(TASK_DIRECTOR, TASK_OFFERED);

	return tTask;
		
epilog

end;</source>
        <ReturnType type="CM_RTQueueTask"/>
    </JadeMethod>
    <JadeMethod name="findQueueFutureMoveForTI" id="119f3985-1f15-4d48-a9d5-5067b5dc7b61">
        <source>findQueueFutureMoveForTI(_trackedItem : CM_TrackedItem) : CM_FutureMoveQueued;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 December 2008	cnwer1	Initial creation par 18665

*/

vars
	queuedFutureMove : CM_FutureMoveQueued;
begin

	foreach queuedFutureMove in self.allQueuedFutureMoves discreteLock do
		if queuedFutureMove.myTrackedItem = _trackedItem then
			return queuedFutureMove;
		endif;
	endforeach;

	return null;

epilog

end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <ReturnType type="CM_FutureMoveQueued"/>
    </JadeMethod>
    <JadeMethod name="findTaskOfType" id="f9c489bf-ff77-4914-a977-f75ab46df231">
        <source>findTaskOfType(_taskType : Integer; _status : Integer) : CM_RTQueueTask;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 December 2008	cnwer1	Initial creation

*/

vars

	aTask	: CM_RTQueueTask;
begin

	foreach aTask in self.allTasks discreteLock do
		if aTask.taskType = _taskType then
			//-------------------
			// a status with 0 is unactioned so may want to find that 
			if _status &lt;&gt; NULL_INTEGER then
				if _status = aTask.status then
					return aTask;
				endif;
			else
				// if NULL_INTEGER is passed in as status just return first task of _taskType found
				return aTask;
			endif;
		endif;
	endforeach;
	return null;

epilog

end;</source>
        <Parameter name="_taskType" type="Integer"/>
        <Parameter name="_status" type="Integer"/>
        <ReturnType type="CM_RTQueueTask"/>
    </JadeMethod>
    <JadeMethod name="getAOverstowedTask" id="a6885baa-9eed-44b4-b631-23ee0a67cce1">
        <source>getAOverstowedTask(	_machine : CM_Machine;
					_tTask : CM_RTQueueTask io;
					_tandemTI : CM_TrackedItem;
					_sideAccessDirection : Integer input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 May 2010	cnwer1	Initial creation
03 Aug 2010 cnwer1	Par 25204
*/

vars
	terminal : CM_Terminal;
	overstowedTI,
	taskTI	: CM_TrackedItem;
	allOverstowedTIs 	: CM_TIArray;
	originalTask : CM_RTQueueTask;
	currentQEntry : CM_RTQueueEntry;
	sideAccessDirection : Integer;
	vehicleConfig : CM_RTVehicleConfig;
	voyageJob	  : CM_VoyageJob;
	machine			: CM_Machine;
	fqm 			: CM_FutureMoveQueued;
begin
		
	terminal:=self.getMyTerminal();
	if terminal = null then
		return;
	endif;
	
	vehicleConfig:=terminal.getRTVehicleConfigForObject(_machine);
	
	originalTask:=_tTask;
	taskTI:=_tTask.ti;
	create allOverstowedTIs transient;
	//epr CCMS 1099 25/5/10 overstow config moved 
	if 	vehicleConfig.overstowMoveMode = CM_RTVehicleConfig.OSTOW_AUTOPLAN then   //SFW1030 04/08/2008
		sideAccessDirection:=_sideAccessDirection;
		if terminal.isAutoPlanOverstowsUsingYA or (_machine.machineType = MACHINETYPE_RTG or _machine.machineType = MACHINETYPE_RMG) then //ccms 1025 	
			// _checkQueueEntryIndex is set to false this means that it will get all overstowed tis regardless of any that may be queue ahead
			taskTI.getAllOverstowedTIs(allOverstowedTIs,false,sideAccessDirection,_machine);			
			//cnwrd1 makes sense to me we remove the tandem ti from this collection before we do the autoplanning?	Otherwise we plan the bottom box of a tandem lift somewhere else and then skip that move(correctly) later
			//cnwrd1 par 27654 2.6.2011
			if _tandemTI &lt;&gt; null and not allOverstowedTIs.isEmpty then
				if allOverstowedTIs.includes(_tandemTI) then
					allOverstowedTIs.remove(_tandemTI);
				endif;
			endif;
			//epr par 31773 27/6/13
			app.myUtilityUA.utlAutoPlanOverstowedCargo(taskTI,allOverstowedTIs,taskTI.myTerminalArea,null,null,null,true,app.myPassport);
			if app.myPassport.hasErrors then
				return;
			endif;
			
			if not allOverstowedTIs.isEmpty then
				currentQEntry:=allOverstowedTIs.first.getQueueEntry;
				if currentQEntry &lt;&gt; null then
					_tTask := currentQEntry.getTaskOfType(TASK_PICKUP, null);
				else
					_tTask:=null;
				endif;
			else
				_tTask := self.getTaskOfType(TASK_PICKUP, null);	
			endif;
			
		else
			//epr TFS 37584 4/5/18
			currentQEntry := self;
			taskTI.moveOverstowingBoxes(currentQEntry, _tandemTI,_machine,sideAccessDirection);
			_tTask := self.getTaskOfType(TASK_PICKUP, null);		//and we should now have a new pickup task
		endif;
	// epr par 26016 otago 15/10/10 want to be able to go get next task and be given the task or in list be able to accept
	// we will still give an error if it is overstowed at move time
	elseif vehicleConfig.overstowMoveMode = CM_RTVehicleConfig.OSTOW_ACCEPT_ONLY then
		_tTask:= originalTask;
		return;
	else
		sideAccessDirection:=_sideAccessDirection;
		taskTI.getAllOverstowedTIs(allOverstowedTIs,false,sideAccessDirection,_machine);
		if _tandemTI &lt;&gt; null and not allOverstowedTIs.isEmpty then
			if allOverstowedTIs.includes(_tandemTI) then
				allOverstowedTIs.remove(_tandemTI);
			endif;
		endif;
		
		if not allOverstowedTIs.isEmpty then
			overstowedTI:=allOverstowedTIs.first;
			currentQEntry:=overstowedTI.getQueueEntry;
			if currentQEntry &lt;&gt; null then
				if currentQEntry.myJob &lt;&gt; null and currentQEntry.myJob.isKindOf(CM_VoyageJob) then
					voyageJob:=currentQEntry.myJob.CM_VoyageJob;
				endif;
				//if load job then always give no task rather than finding any other overstowed moves
				if voyageJob &lt;&gt; null and not voyageJob.isDischarge then
					_tTask := null;
				else
					_tTask := currentQEntry.getTaskOfType(TASK_PICKUP, null);
				endif;
			else
				_tTask:=null;
			endif;
			
			//epr TFS 5254 10/7/17 overstow manual for the web create a task with no target
			if _tTask = null and vehicleConfig.overstowMoveMode = CM_RTVehicleConfig.OSTOW_MANUAL and (app.isWebApp) then
				machine:=_machine;
				_tTask:=app.myUtilityUA.utlMachineCreateInitiatedMove(overstowedTI,null,machine,null,null,false,true,app.myPassport);
				if _tTask &lt;&gt; null then
					fqm:=_tTask.getFutureMoveForTI(overstowedTI);
					if fqm &lt;&gt; null then
						fqm.setOverstowedQueueEntries(taskTI);
					endif;
				endif;
			endif;				
		endif;
	endif;
	
	//check this task is appropriate Par 25204 3/8/10
	if _tTask &lt;&gt; null and _tTask &lt;&gt; originalTask then
		if not _machine.isInQueue(_tTask.myEntry.myQueue) then
			_tTask:=null;
			return;
		endif;
		
		if not _tTask.queryMachineAssign(_machine, false, false,false,true,true, null) then
			_tTask:=null;
		endif;
	endif; 
epilog
	delete allOverstowedTIs;
end;</source>
        <Parameter name="_machine" type="CM_Machine"/>
        <Parameter name="_tTask" type="CM_RTQueueTask" usage="io"/>
        <Parameter name="_tandemTI" type="CM_TrackedItem"/>
        <Parameter name="_sideAccessDirection" type="Integer" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getATaskForMachine" id="dc7987b9-1579-46be-973b-6a07848ab926">
        <source>getATaskForMachine(	task	:	CM_RTQueueTask io;	
						mach	:	CM_Machine;
						_tademTI : CM_TrackedItem;
						_sideAccessDirection : Integer input;
						_messageLogger  	: CM_MachineRTQueueEntryLogger input);
//Called from the queue object, search through our tasks to see if
//anything here suits... If so, populate the  task object
//Remember, the tasks are a series of units of work to do ONE MOVE!
//We only therefore need to check the pickup task!

/*

Date		Who		Reason
17 Feb 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift
					Renamed as part of refactoring methods
28 Sep 2009	cnwer1	PAR#20698 - IMV machines do not do overstow moves or move restricted boxes so can ignore that option
21 Jan 2009	cnwer1	CCMS 1025
09 Mar 2010	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface
30 Jun 2010	cnwkpd1	PAR #24495 - ITS interface can not be sent automatic overstow moves,
					but can be sent manual ones
23 Feb 2012	cnwer1	PAR 28126 - changes for  tandem manual overstown lifting
28 Jun 2013 cnwer1  PAR 31745 - do the queryMachineAssign after we get the overstow task not before
12 Dec 2022	navmk20	Bug 55781: PNL - Unable to move over stowed &amp; connected queued reefers - Vehicle Apps
*/

vars
	tTask				:	CM_RTQueueTask;
	aStr				:	String;
	machId				:	String;
	strickAccessCheck 	: Boolean;
	invalid : Boolean;
	edition : Integer;
	
begin
	if  _messageLogger &lt;&gt; null then
		 _messageLogger.myQueueEntry:=self;
	endif;
	machId := mach.id.trimRight;
	aStr := "Machine Test :" &amp; machId &amp; " ";
	
	tTask := self.getATaskGeneric(aStr, mach);
	if tTask = null then
		return;
	endif;

	// if its a tandem don't do strickaccess becase the machine::canMachineAccessRestrictedTA will fail if the os box is the tandem ti
	// we check os after this anyway
	//cnwrd1 par 29846	12.7.2012
	if mach.canAutoResequenceOnPickup() and tTask.targetLocation.isKindOf(CM_StackController) then  //we may resequence later and we will check the location then
		strickAccessCheck:=false;
	else
		strickAccessCheck:=_tademTI = null;
	endif;
	
	//-------------
	//Test the task is NOT overstowed!
	//-------------
	//if tTask.ti &lt;&gt; null and app.myMediator.session.getMyTerminal().getConfig(AutoPlanShiftOverStows).Boolean then
	if mach.machineType &lt;&gt; MACHINETYPE_IMV and tTask.ti &lt;&gt; null then
	
		//14 May 2021 NDL - found in unit test
		on Exception do app.handleDeletedObject( exception, tTask.ti, invalid );
		edition := tTask.ti.edition;
		if invalid then
			task := null;
			return;
		endif;
		on Exception do null; //12.12.2022 navmk20 TFS 55781
		self.getAOverstowedTask(mach,tTask,_tademTI,_sideAccessDirection);
		if tTask = null then
			task := tTask;
			return;
		endif;
	endif;
	
	//-------------
	//Ask task if it likes the machine
	//-------------
	if not tTask.queryMachineAssign(mach, false, false,false,strickAccessCheck,true, _messageLogger) then
		return;
	endif;
	
	//if IMV don't worry about overstow stuff we can't move if anyway //EPR PAR 20698 28/9/09
	if mach.machineType = MACHINETYPE_IMV then
		exclusiveLock(tTask); //doing this so not to change anything
		task := tTask;
		return;
	endif;
		
	

	// The ITS interface does not handle automatically generated overstow moves (refer par 22786)
	// PAR #24495 - changed to use new method isOverstowTaskAuto 
	if tTask &lt;&gt; null and tTask.isOverstowTaskAuto and mach.myITSInterfaceLoggedOn &lt;&gt; null then
		return;
	endif;
	
	//-------------
	//Should be ok by here...
	//Set the reference, and return back up the stack..
	//-------------
	if tTask &lt;&gt; null then
		exclusiveLock(tTask);
	endif;
	task := tTask;
epilog

end;</source>
        <Parameter name="task" type="CM_RTQueueTask" usage="io"/>
        <Parameter name="mach" type="CM_Machine"/>
        <Parameter name="_tademTI" type="CM_TrackedItem"/>
        <Parameter name="_sideAccessDirection" type="Integer" usage="input"/>
        <Parameter name="_messageLogger" type="CM_MachineRTQueueEntryLogger" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getATaskGeneric" id="ceec51a0-546f-4566-88c9-fb2fbc518754">
        <source>getATaskGeneric(aStr : String io; mach : CM_Machine) : CM_RTQueueTask;

// Created by cnwdvb1 on 19 May 2006
// 23/3/2011 cnwer1  par 25573 - with multi machine moves - jobs can be complete with rt queue entries that still need to be completed -&gt; removed the block of validation below
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars

	tTask : CM_RTQueueTask;

begin

	if status &lt;&gt; ENTRY_UNACTIONED then
		//This entry is either working, or complete or whatever, we dont want it!
		if status &lt;&gt; ENTRY_COMPLETE then	//No message for completed tasks, fairly obvious
			aStr := aStr &amp; app.getErrorString2(QEntry_status_mustb_unactioned, id.trimRight,self.statusString); //epr par 25495 19/8/10 fixed up string literals 
			mach.addLogEntry(aStr);
		endif;
		return null;	
	endif;
	if allTasks.isEmpty then
		return null;
	endif;

	//-----------
	//Get pickup task
	//-----------
	tTask := getTaskOfType(TASK_PICKUP, null);
	if tTask = null then
		tTask := getTaskOfType(TASK_MOVE, null);
		if tTask = null then
			tTask := getTaskOfType(TASK_DIRECTOR, null);
			if tTask = null then
				//epr TFS 995 Vmt generic never worked with breakbult
				tTask := getTaskOfType(TASK_BREAKBULK,null);
				if tTask = null then
					mach.addLogEntry(app.getErrorString1(QEntry_no_unactioned_pickup,id.trimRight));
					return null;
				endif;
			endif;
		endif;
	endif;

	//-------------
	//Is this task any good?
	//-------------
	if tTask.status &lt;&gt; TASK_UNACTIONED then
		mach.addLogEntry(app.getErrorString1(QEntry_no_unactioned_pickup,id.trimRight));
		return null;	//Its under way...
	endif;
	if tTask.machine &lt;&gt; null then
		mach.addLogEntry(app.getErrorString2(QEntry_next_task_worked,id.trimRight,tTask.machine.id.trimRight));
		return null;	//double check, its under way...
	endif;
	
	return tTask;
end;</source>
        <Parameter name="aStr" type="String" usage="io"/>
        <Parameter name="mach" type="CM_Machine"/>
        <ReturnType type="CM_RTQueueTask"/>
    </JadeMethod>
