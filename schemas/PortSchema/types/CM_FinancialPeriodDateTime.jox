    <JadeMethod name="getDisplayStringForAttribute" id="5ba7739e-e3d1-4f30-bdf6-db89f64e308e">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if _attrName = ETRow_PeriodDate then
		return self.dateTime.date.String;
	elseif _attrName = ETRow_PeriodTime then
		return self.dateTime.time.String;
	elseif _attrName = ETRow_Name then
		return self.dateTime.String &amp; Tab &amp; self.remarks;
	else
		return inheritMethod(_attrName, _short);
	endif;
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
