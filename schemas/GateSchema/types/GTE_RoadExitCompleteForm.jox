        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblReceivals_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 27 June 2007
//
//----------------------------------------------------------------------

vars
	xLeft,
	yTop	: Real;
begin
	xLeft := x;
	yTop := y;

	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop); 
	self.doShowHideContextMnuItems(table.CM_DataTable);
	self.popupMenu(mnuContextTable, xLeft.Integer, yTop.Integer);
	
	return false;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
