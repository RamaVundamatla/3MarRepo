begin
	delete self.myAutoPlan;
end;</source>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="81b92f65-bb68-49ed-b624-90035e9d2c14">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     02 June 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if _attrName = ETRow_TotalEmpty or
	   _attrName = ETRow_TotalMatching or
	   _attrName = ETRow_TotalNonMatching or
	   _attrName = ETRow_TotalPositions then
		return inheritMethod(_attrName, _short);
	
	elseif self.myYardAllocation &lt;&gt; null then
		return self.myYardAllocation.getDisplayStringForAttribute(_attrName, _short);
	endif;
	
	return null;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNonMatchYAForTI" id="bf0eb5ee-f497-4246-974d-a5d36b148f9a">
        <source>getNonMatchYAForTI(_ti : CM_TrackedItem);
// ---------------------------------------------------------------------------
// Created:		03 May 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	self.myAutoPlan.attachTI(_ti);
	if _ti.myPrimaryActualLocation &lt;&gt; null then
		_ti.myPrimaryActualLocation.getDontMatchYAForTI(_ti, self.myAutoPlan,self.allYardAllocationsForTI);
	endif;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getNonMatchingTIs" id="28ec1f85-6245-4a14-88f5-8390d6508a3b">
        <updating/>
        <source>getNonMatchingTIs(_ya : CM_YardAllocation; _tis : CM_TIByIdDict input) updating;
// ---------------------------------------------------------------------------
// Created:		November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	usedMatching		: Integer;
	usedNotMatching		: Integer;
	emptyPositions		: Integer;
	positionCount		: Integer;
	blockObj			: CM_YABlock;

begin
	if _tis = null then
		return;
	endif;
	if _ya = null then
		return;
	endif;
	
	self.myYardAllocation	:= _ya;

	foreach blockObj in _ya.allYABlocksIn discreteLock do
		blockObj.getNonMatchingTIs(_tis, self.myAutoPlan);
	endforeach;
end;</source>
        <Parameter name="_ya" type="CM_YardAllocation"/>
        <Parameter name="_tis" type="CM_TIByIdDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setYardAllocation" id="7264bf1c-128e-41e5-8586-b65afaf82da2">
        <updating/>
        <source>setYardAllocation(_ya : CM_YardAllocation; pIsShowStats:Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     02 June 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	usedMatching		: Integer;
	usedNotMatching		: Integer;
	emptyPositions		: Integer;
	positionCount		: Integer;
	blockObj			: CM_YABlock;

begin

	self.myYardAllocation	:= _ya;

	self.totalEmpty			:=	0;
	self.totalMatching		:=	0;
	self.totalNonMatching	:=	0;
	self.totalPositions		:=	0;
	
	if _ya = null then
		return;
	endif;
	
	if pIsShowStats then
		foreach blockObj in _ya.allYABlocksIn do
			blockObj.getUsageStats(usedMatching, usedNotMatching, emptyPositions, positionCount, self.myAutoPlan);
			self.totalMatching		:=	self.totalMatching + usedMatching;
			self.totalNonMatching	:=	self.totalNonMatching + usedNotMatching;
			self.totalEmpty			:=	self.totalEmpty + emptyPositions;
			self.totalPositions		:=	self.totalPositions + positionCount;
		endforeach;
	endif;
end;</source>
        <Parameter name="_ya" type="CM_YardAllocation"/>
        <Parameter name="pIsShowStats" type="Boolean"/>
    </JadeMethod>
</Class>
