    <JadeMethod name="addObjectsToTable" id="63ab844f-40b2-46e6-8bed-62e7a18701ba">
        <updating/>
        <source>addObjectsToTable(_numItems: Integer io) updating;
//-----------------------------------------
// Created: February 2004 By: cnwgd1
// 11/07/2025		naviv1		MTN-35226 : MTN - Usage of Iterator.getCurrentKeys  
//-----------------------------------------
vars
	tiNotDict,
    tiDict		: CM_TIByCargoTypeIdDict;
	ti			: CM_TrackedItem;
	tmpCargoId,
	keyCargoId,
	numTIs,
	savePointer	: Integer;
	tmpPassport	: CM_Passport;
	//ls,
	breakOut	: Boolean;
	iter1,
	iter2		: Iterator;
	keyTiId		: String;
	tmpCargoType: CM_CargoBOLType;
begin

	if (not self.isFirstActivateComplete) and self.myFilterVoyage = null then
		return;
	endif;
	
	app.setStatusLineCaption('Loading tracked items');
	
	savePointer := app.mousePointer;
	app.mousePointer := Window.MousePointer_HourGlass;
	
	tmpPassport := app.myPassport;

	if self.allCargoTypesForCEDO.isEmpty then
		return;
	endif;

	if self.myFilterVoyage &lt;&gt; null then
		tiDict := self.myFilterVoyage.allOnsiteTIsByCargoTypeId;
		tiNotDict := self.myFilterVoyage.allNotifiedTIsByCargoTypeId;						
	else
		tiDict := self.myTerminal.allOnsiteTIsByCargoTypeId;
		tiNotDict := self.myTerminal.allNotifiedTIsByCargoTypeId;						
	endif;

	// Get the total number of TIs involved from both onsite (tiDict) and notified dicts
	numTIs := tiNotDict.size + tiDict.size;
	
	self.progressStart(numTIs, app.getErrorString(Cancel), null, null,app.getErrorString(LoadingDataIntoView));
	self.frmModalDialog.refreshNow;
	
	iter1 := tiDict.createIterator();
	iter2 := tiNotDict.createIterator();

	foreach tmpCargoType in self.allCargoTypesForCEDO do
		tmpCargoId := tmpCargoType.id;	
		tiDict.startKeyGeq(tmpCargoId, null, iter1);
		// Add Onsite cargo to table
		while iter1.next(ti) do
			self.progressUpdate;
			iter1.getCurrentKeys(keyCargoId,keyTiId); //MTN-35226
			if keyCargoId &gt; tmpCargoId then
				break;
			endif;
			if self.includeObject(ti, tmpPassport) then
				self.addObjectToTable(ti, _numItems, breakOut);
			endif;
			if breakOut then
				break;
			endif;
			if self.modalDialogReturnValue = self.ModalDialogReturn_Default then
				// Cancel button pressed
				return;
			endif;		
		endwhile;
	
		tiNotDict.startKeyGeq(tmpCargoId, null, iter2);	
		// Add prenotified cargo to table			
		while iter2.next(ti) do
			self.progressUpdate;
			iter2.getCurrentKeys(keyCargoId,keyTiId);  //MTN-35226
			if keyCargoId &gt; tmpCargoId then
				break;
			endif;
			if self.includeObject(ti, tmpPassport) then
				self.addObjectToTable(ti, _numItems, breakOut);
			endif;
			if breakOut then
				break;
			endif;
			if self.modalDialogReturnValue = self.ModalDialogReturn_Default then
				// Cancel button pressed
				return;
			endif;			
		endwhile;
	endforeach;		
	
epilog
	delete iter1;
	delete iter2;
	app.setStatusLineCaption('');
	progressFinish;
	app.mousePointer := savePointer;
end;</source>
        <Parameter name="_numItems" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="addStopsColumns" id="078e1473-408d-4090-8607-43b9a6268c2c">
        <updating/>
        <source>addStopsColumns() updating;
//-----------------------------------------
// Created: 20 November 2003 By: cnwgd1
//-----------------------------------------
vars
	aStopTable : CM_StopsTable;
	theUser : CM_User;
	term	: CM_Terminal;	
begin
	
	theUser := app.getMyUser();
	term := self.myTerminal;
	// Stops are in a class of their own now so add all of them AKB2002JUNE
	// DVB CCMS 1235
//	foreach aStop in app.myRoot.allStopsTable do
	foreach aStopTable in app.myRoot.allAvailableStopsTables do
		if theUser.canViewStop(term, aStopTable) then
			// Create a transient entRow for this column
			self.zAddTransientEntTblRow(aStopTable.code, ETRow_Stops &amp; Tab &amp; aStopTable.id.String, Table.InputType_CheckBox);
		endif;
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="armNotesForObject" id="ff96bacb-bca6-4876-8ea7-5c84c1423f41">
        <source>armNotesForObject(_obj: Object);
// ---------------------------------------------------------------------------
// Created:     29 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	self.beginNotification(_obj, Object_Delete_Event, Response_Continuous, 0);
	self.beginNotification(_obj, Object_Update_Event, Response_Continuous, 0);

	// effectively a delete from the visible list
	self.beginNotification(_obj, self.myTerminal.getTerminalEvent(TIEvent_Terminal_Release), Response_Continuous, 0);

end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
