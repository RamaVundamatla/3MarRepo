    <JadeMethod name="toolbarShowCaptions" id="53008ce3-7efc-494b-9c14-3dad6109b515">
        <updating/>
        <source>toolbarShowCaptions(_showCaptions: Boolean) updating;
//
//19 Jan 2017	cnwrs1	TFS 3137 - resize the form when show captions is on
//
vars
	currentHeight : Real;
	newHeight : Real;
	heightDiff : Real;
begin
	currentHeight := self.frmToolbar.height;
	inheritMethod(_showCaptions);
	newHeight := self.frmToolbar.height;
	heightDiff := newHeight - currentHeight;
	self.fldVoyageConfig.top := self.fldVoyageConfig.top + heightDiff;
	self.fldVoyageConfig.height := self.fldVoyageConfig.height - heightDiff;
	self.doResize();
end;
</source>
        <Parameter name="_showCaptions" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="8d7e51e5-634b-48cf-bce4-cf9aea821c8f">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 10 August 2018 11:52:04.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0022880, locale);
	btnColourCode.translateCaption(Xlat_0013334, locale);
	btnEdit.translateCaption(Xlat_0013335, locale);
	lblDefaultColour.translateCaption(Xlat_0013340, locale);
	shtColorCoding.translateCaption(Xlat_0014484, locale);
	shtConfigTerm.translateCaption(Xlat_0013342, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="unload" id="54de81f8-9a93-44b6-bb86-e5d7f9807749">
