    <JadeMethod name="getDefaultResourcesForCMIFMove" id="b0e85c0a-90a7-4837-a29a-5115fa4c8cd1">
        <source>getDefaultResourcesForCMIFMove(_cmifMovement : CMIF_HMS_WorkingMovement );
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 24/01/2014	cnwdap1		Initial creation PAR #33337 CCMS PTR 2214 HMS Enhancements
//
vars
	resourceUsed,
	newResourceUsed		: CMIF_HMS_ResourceUsed;
	resource			: HMS_Resource;
	tmpMoveResource		: HMS_ResourceTypeForMovement;
	tmpResourceType		: HMS_ResourceType;	
	lastVoyage 			: CM_Voyage;
	lastVoyageData		: HMS_VoyageData;
	lastMovement		: HMS_VoyageMovement;
	
begin
	if _cmifMovement = null then
		return;
	endif;

	tmpMoveResource := self.allDefaultMovementResources[_cmifMovement.moveType];

	if tmpMoveResource &lt;&gt; null then

		// where possible set default resource to that of last voyage
		lastVoyage := self.myHarbour.getVesselsLastVoyage(self.getMyVessel.code);
		if lastVoyage &lt;&gt; null then
			lastVoyageData := lastVoyage.myHMSVoyageData;
		endif;				
		if lastVoyageData &lt;&gt; null then
			lastMovement := lastVoyageData.getMovementForMoveType(_cmifMovement.moveType);
		endif;		
			
		foreach tmpResourceType in tmpMoveResource.allResourceTypes do
			create newResourceUsed transient;
			newResourceUsed.notYetSaved := true;
			newResourceUsed.myViewController := _cmifMovement.myViewController;
			newResourceUsed.myWorkingMovement := _cmifMovement;
			newResourceUsed.myResourceType := tmpResourceType;
			
			// Lorcan PAR 11920 When creating a shift from the graphical view the default is that it is InContract
			newResourceUsed.isPartOfContract := true;

			if lastMovement &lt;&gt; null then
				newResourceUsed.myResource := lastMovement.getDefaultResourceForType(tmpResourceType);
			endif;
						
		endforeach;
	endif;

end;</source>
        <Parameter name="_cmifMovement" type="CMIF_HMS_WorkingMovement"/>
    </JadeMethod>
    <JadeMethod name="getDisplayString" id="a113187c-23ca-45b7-b31a-980f79c05828">
        <source>getDisplayString(): String;
//--------------------------------------------------
// Created:	29 March 2004 By: cnwgd1
//--------------------------------------------------
vars

begin

	//PAR3818
	return self.myVoyage.vesselName &amp; ' ('&amp; self.myVoyage.code &amp; ')';				
	//return self.myVoyage.code &amp; ' ' &amp; self.myVoyage.vesselName;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="ca5a1dfa-f627-4fcc-8c98-e56ecb84ffcd">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//--------------------------------------------------
// Created:	06 April 2004 By: cnwgd1
//--------------------------------------------------
vars

	berth : HMS_Berth;

begin
	if _attrName = ETRow_HmsMovementFromPort
	or _attrName = ETRow_LastPort
	or _attrName = ETRow_MyPortFrom then
		if self.myPortFrom &lt;&gt; null then
			return self.myPortFrom.description;
		else
			return null;
		endif;
	elseif _attrName = ETRow_HmsMovementToPort
	or _attrName = ETRow_MyPortTo then
		if self.myPortTo &lt;&gt; null then	
			return self.myPortTo.description;
		else
			return null;
		endif;
	elseif _attrName = ETRow_CargoToDischarge then
		//return app.getYesNo(not self.allCommodityDischarge.size&gt;0) // ### TFS 53132 21Apr2022 NAVPW1 - Obsolete now using Cargo Forecasts instead on CM_Voyage
		return app.getYesNo(not self.myVoyage.allCargoForecasts.dischargeCommoditiesIsEmpty); // ### TFS 53132 21Apr2022 NAVPW1
	elseif _attrName = ETRow_CargoToLoad then
		//return app.getYesNo(self.allCommodityLoad.size&gt;0);		// ### TFS 53132 21Apr2022 NAVPW1 - Obsolete now using Cargo Forecasts instead on CM_Voyage
		return app.getYesNo(not self.myVoyage.allCargoForecasts.loadCommoditiesIsEmpty);	 // ### TFS 53132 21Apr2022 NAVPW1
	elseif _attrName = ETRow_VesselName then
		return self.myVoyage.vesselName;
	elseif _attrName = ETRow_ShipType then
		if self.myVesselType &lt;&gt; null then
			return self.myVesselType.description;
		endif;
		return 'N/A';
	elseif _attrName = ETRow_Pilots then
		return self.getPilotsUsed();

	elseif _attrName = ETRow_MyLineCompany then
		return self.getLineCompaniesUsed();
				
	elseif _attrName = ETRow_Agents then
		return self.getAgentsUsed();
	elseif _attrName = ETRow_MyShippingAgent then
		return self.getAllAgentsUsed();
	elseif _attrName = ETRow_Drafts then
		return self.getMovementDrafts();
	
	elseif _attrName = ETRow_ToBerthPreference
	or _attrName = ETRow_MyBerth then
		if self.getMyBerth &lt;&gt; null then
			return self.getMyBerth.getDisplayDetails(_short);
		else
			return null;
		endif;
	elseif _attrName = ETRow_MyTidalClassArrival then
		if self.myTidalClass &lt;&gt; null then
			return self.myTidalClass.description;
		endif;
		return null;		
	elseif _attrName = ETRow_MyTidalClassDept then
		if self.myTidalClassDept &lt;&gt; null then
			return self.myTidalClassDept.description;
		endif;
		return null;
	elseif _attrName = ETRow_VisitType then
		if self.myVisitType &lt;&gt; null then
			return self.myVisitType.description;
		endif;
		return null;	
	elseif _attrName = ETRow_MyVesselCategoryIn then
		if self.myVesselCategoryIn &lt;&gt; null then
			return self.myVesselCategoryIn.description;
		endif;
		return null;
	elseif _attrName = ETRow_MyVesselCategoryOut then
		if self.myVesselCategoryOut &lt;&gt; null then
			return self.myVesselCategoryOut.description;
		endif;
		return null;				
	elseif _attrName = ETRow_MyVesselType
	or _attrName = ETRow_MyHMSVesselType then
		if self.myVesselType &lt;&gt; null then
			return self.myVesselType.description;
		endif;
		return null;
	elseif _attrName = ETRow_HasFixedProp then
		if self.hasFixedProp then
			return 'Fixed';
		else
			return 'Variable';		
		endif;
	elseif _attrName = ETRow_ProcessingStatus then
		return self.myVoyage.statusDescription;	
	elseif _attrName = ETRow_TripReference then
		return self.myVoyage.code;
	elseif _attrName = ETRow_Dockage then
		return '0';				
	elseif _attrName = ETRow_LengthOverall then
		return self.dim_LengthOverall.asStringJMT();
	elseif _attrName = ETRow_GrossRegTonnes then
		return self.dim_GrossRegTonnes.asStringJMT();
	elseif _attrName = ETRow_NetRegTonnes then
		return self.dim_NetRegTonnes.asStringJMT();	// 30680 CCMS QNS 2178
	elseif _attrName = ETRow_DeadWeight then
		return self.dim_DeadWeight.asStringJMT();
	elseif _attrName = ETRow_Beam then
		return self.dim_Beam.asStringJMT();
	elseif _attrName = ETRow_DraftFore then
		return self.dim_DraftFore.asStringJMT();
	elseif _attrName = ETRow_DraftAft then
		return self.dim_DraftAft.asStringJMT();
	elseif _attrName = ETRow_BridgeToBow then
		return self.dist_BridgeToBow.asStringJMT();
	elseif  _attrName = ETRow_BridgeToStern then
		return self.dist_BridgeToStern.asStringJMT();
	elseif _attrName = ETRow_BowToFwdBay then
		return self.dist_BowToFwdContainer.asStringJMT();
	elseif _attrName = ETRow_SternToAftBay then
		return self.dist_SternToAftContainer.asStringJMT();
	elseif _attrName = ETRow_SternToBunker then
		return self.dist_SternToBunker.asStringJMT();
	//	09 Oct 2012	NDL	Par 30490
	elseif _attrName = ETRow_FirstRealBerth then
		berth := self.getMyFirstPhysicalBerth;
		if berth &lt;&gt; null then
			return berth.getDisplayDetails(_short);
		else
			return null;
		endif;
		
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="f0a7d50b-26d8-49f2-bf88-8856677e8c0d">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
//--------------------------------------------------
// Created:	02 August 2004 By: cnwgd1
//--------------------------------------------------
/*

Date		Who		Reason
20 Mar 2008	cnwkpd1	PAR #16245 - correct the display when there's no "Arrives From Port"

*/

vars
	tmpStr : String;
	prefBerth : HMS_BerthPreference;
	block : CM_DataContainerBlock;
	passport : CM_Passport;
	movement : HMS_VoyageMovement;
	tmpVessel : CM_Vessel;
	tmpVoyage : CM_Voyage;
	portCmbOrderDescrFirst : Boolean;
begin
	inheritMethod(_dataContainer);
	
	tmpVoyage := self.myVoyage;
	portCmbOrderDescrFirst := app.myRoot.getConfig(PortCmbOrderDescrFirst).Boolean;
	
	block := _dataContainer.addNewBlock;
	block.addNewItem('Vessel Name', DC_Label, 1, null);
	block.addNewItem(self.vesselName, DC_Data, 1, null);

	// Vessel arrival and departure category--------------------
	tmpStr := null;
	block := _dataContainer.addNewBlock;
	block.addNewItem('Vessel Category', DC_Label, 1, null);
	if self.myVesselCategoryIn &lt;&gt; null then	
		tmpStr := self.myVesselCategoryIn.description;
	endif;
	if self.myVesselCategoryOut &lt;&gt; null
	and self.myVesselCategoryOut &lt;&gt; self.myVesselCategoryIn then
		if tmpStr &lt;&gt; null then	
			tmpStr := tmpStr &amp; '; ' &amp; self.myVesselCategoryOut.description;
		else
			tmpStr := self.myVesselCategoryOut.description;		
		endif;
	endif;
	if tmpStr = null then
		tmpStr := 'None Selected';			
	endif;
	block.addNewItem(tmpStr, DC_Data, 1, null);	
	//------------------------------------------------------------				
	
	if tmpVoyage &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem('Voyage Code', DC_Label, 1, null);
		block.addNewItem(tmpVoyage.code, DC_Data, 1, null);			
	endif;
	
	block := _dataContainer.addNewBlock;
	block.addNewItem('Vessel Type', DC_Label, 1, null);
	if self.myVesselType &lt;&gt; null then	
		block.addNewItem(self.myVesselType.description, DC_Data, 1, null);
	else
		block.addNewItem('None Selected', DC_Data, 1, null);				
	endif;	

	block := _dataContainer.addNewBlock;
	block.addNewItem('Country Code', DC_Label, 1, null);
	block.addNewItem(self.countryCode, DC_Data, 1, null);

	block := _dataContainer.addNewBlock;
	block.addNewItem('Arrives From Port', DC_Label, 1, null);
	if self.myPortFrom &lt;&gt; null then			
		tmpStr := self.myPortFrom.getDisplayFormatted(portCmbOrderDescrFirst);
		block.addNewItem(tmpStr, DC_Data, 1, null);
	else
		// PAR #16245 - Handle no selected Arrives From Port
		block.addNewItem('None Selected', DC_Data, 1, null);				
	endif;
	
	block := _dataContainer.addNewBlock;
	block.addNewItem('LOA', DC_Label, 1, null);
	block.addNewItem(self.dim_LengthOverall.String &amp; ' m', DC_Data, 1, null);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem('GRT', DC_Label, 1, null);
	block.addNewItem(self.dim_GrossRegTonnes.String &amp; ' T', DC_Data, 1, null);	

	// QNS 2178
	block := _dataContainer.addNewBlock;
	block.addNewItem('NRT', DC_Label, 1, null);
	block.addNewItem(self.dim_NetRegTonnes.String &amp; ' T', DC_Data, 1, null);	

	block := _dataContainer.addNewBlock;
	block.addNewItem('Preferred Berth', DC_Label, 1, null);
	prefBerth := self.allBerthPreferencesArray.first;
	if prefBerth &lt;&gt; null then
		block.addNewItem(prefBerth.berthName, DC_Data, 1, null);		
	else
		block.addNewItem('None Selected', DC_Data, 1, null);			
	endif;

	block := _dataContainer.addNewBlock;
	block.addNewItem('Shipping Agent', DC_Label, 1, null);
	if self.myShippingAgent &lt;&gt; null then
		block.addNewItem(self.myShippingAgent.description, DC_Data, 1, null);
	else
		block.addNewItem('None Selected', DC_Data, 1, null);			
	endif;		
	
	block := _dataContainer.addNewBlock;
	block.addNewItem('Visit Type', DC_Label, 1, null);
	if self.myVisitType &lt;&gt; null then
		block.addNewItem(self.myVisitType.getDisplayString(), DC_Data, 1, null);
	else
		block.addNewItem('None Selected', DC_Data, 1, null);			
	endif;		
	
	block := _dataContainer.addNewBlock;
	block.addNewItem('Default Tidal Classes', DC_Label, 1, null);
	if self.myTidalClass &lt;&gt; null then
		tmpStr := 'Arrive ' &amp; self.myTidalClass.code;
	endif;
	if self.myTidalClassDept &lt;&gt; null then
		tmpStr := tmpStr &amp; '; Depart ' &amp; self.myTidalClassDept.code;
	endif;
	if tmpStr = null then
		tmpStr := 'None Selected';
	endif;	
	block.addNewItem(tmpStr, DC_Data, 1, null);			
					
	if tmpVoyage &lt;&gt; null then
	
		block := _dataContainer.addNewBlock;
		block.addNewItem('Shipping Line', DC_Label, 1, null);
		if tmpVoyage.myShippingLine &lt;&gt; null then
			block.addNewItem(tmpVoyage.myShippingLine.description, DC_Data, 1, null);
		else
			block.addNewItem('None Selected', DC_Data, 1, null);			
		endif;		
			
		block := _dataContainer.addNewBlock;
		block.addNewItem('Voyage Remarks', DC_Label, 1, null);
		block.addNewItem(self.shortComment &amp; ' ' &amp; tmpVoyage.remarks, DC_Data, 1, null);
	endif;
	
	
	block := _dataContainer.addNewBlock;
	block.addNewItem('General Remarks', DC_Label, 1, null);
	block.addNewItem(self.remarksGeneral, DC_Data, 1, null);
	
	passport := app.myPassport;
	if passport.myUser.canDo(passport.myTerminal, PmHMSPilotView) then
		block := _dataContainer.addNewBlock;
		block.addNewItem('Pilot Remarks', DC_Label, 1, null);
		block.addNewItem(self.remarksPilotOnly, DC_Data, 1, null);
	endif;
	
	foreach movement in self.allVoyageMovements do
		movement.getExtraInfo(_dataContainer);
	endforeach;

	tmpVessel := self.getMyVessel();
	if tmpVessel &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem('Vessel Remarks', DC_Label, 1, null);
		block.addNewItem(tmpVessel.getRemarks(true), DC_Data, 1, null);	
	endif;	
	
	if tmpVoyage &lt;&gt; null
	and app.myCurrentUserCan(passport.myTerminal, Mod_Invoicing) then
		block := _dataContainer.addNewBlock;
		block.addNewItem("Invoice Status", DC_Label, 1, self);
		block.addNewItem(tmpVoyage.statusInvoiceString, DC_Data, 1, self);
	endif;
	
	if tmpVoyage &lt;&gt; null then
		block := _dataContainer.addNewBlock;		//13.05.2022 navsrk	53142
		block.addNewItem(app.getErrorString(Cargo_Forecast), DC_Label, 1, self);	//13.05.2022 navsrk	53142
		block.addNewItem(tmpVoyage.getCargoForecastStr, DC_Data, 1, self);	//13.05.2022 navsrk	53142
	endif;

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getFutureMovementsForConv" id="6bc6149e-cffa-442f-94e3-7365d37fc644">
        <source>getFutureMovementsForConv( asAtTimeStamp : TimeStamp; futureMovements : HMS_VoyageMovementSet input );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 May 2012	cnwndl1	Initial creation	Par 29496
05/03/2015	cnwmh5	Transient Leak
*/

vars

	iter : Iterator;
	voyageMovement : HMS_VoyageMovement;

begin

	iter := self.allVoyageMovements.createIterator;
	while iter.next( voyageMovement ) do
		if voyageMovement.occursOnDTNEW &gt;= asAtTimeStamp then
			futureMovements.addNoDuplicates(voyageMovement, false);
		endif;
	endwhile;

epilog
	delete iter;
end;</source>
        <Parameter name="asAtTimeStamp" type="TimeStamp"/>
        <Parameter name="futureMovements" type="HMS_VoyageMovementSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getLineCompaniesUsed" id="1fecd905-b7f0-4680-ba59-5ee094bac4da">
        <source>getLineCompaniesUsed() : String;
//--------------------------------------------------
// Created:	16 September 2004 By: cnwgd1
//--------------------------------------------------
vars
	lineCompanyUsed : String;
	movement : HMS_VoyageMovement;
begin

	foreach movement in self.allVoyageMovements do
		// Check to see if selected pilot is used for any of the voyages movements
		if movement.myLineCompany &lt;&gt; null then
			lineCompanyUsed	:= lineCompanyUsed &amp; movement.myLineCompany.description[1:20] &amp; "; ";
		else
			lineCompanyUsed := lineCompanyUsed &amp; "N/A; ";
		endif;
	
	endforeach;
		
	if lineCompanyUsed.length &gt; 1 then
		// Trim last comma and space
	 	lineCompanyUsed := lineCompanyUsed[1:(lineCompanyUsed.length - 2)];
	endif;
	
	return lineCompanyUsed;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMovementDrafts" id="02c3f17a-bc0c-4025-a685-9bb188b7b46d">
        <source>getMovementDrafts() : String;
//--------------------------------------------------
// Created:	16 September 2004 By: cnwgd1
//--------------------------------------------------
vars
	drafts : String;
	movement : HMS_VoyageMovement;
begin

	foreach movement in self.allVoyageMovements do
		drafts := drafts &amp; movement.draftMax.String &amp; "m; ";	//4.1.1 Draft enhancement
	endforeach;
		
	if drafts.length &gt; 1 then
		// Trim last comma and space
		drafts := drafts[1:(drafts.length - 2)];
 	endif;					

	return drafts;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMovementFirstChargeable" id="6fe28898-bd85-438e-bb83-47097cb9a369">
        <source>getMovementFirstChargeable(_movement : String):HMS_VoyageMovement;
// ---------------------------------------------------------------------------
// Created:		JULY 2006 By Andrew Bishop cnwab1
//
// Purpose:		VERY Important. This has to use the movement type passed in to find the first charable movement
//				This means for instance that we pass in DEPARTURE and we find the ARRIVAL
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/
vars
	aWharf : HMS_Wharf;
	aRes : HMS_Resource;
	move : HMS_VoyageMovement;
	iter : Iterator;
begin
	iter := self.allVoyageMovements.createIterator();

	while iter.next(move) do
		
		aWharf := move.getMyWharf();
		aRes := aWharf.getResourceForHarbourMovement(_movement,HMS_Wharf.First_Resource);
		if aRes = null then
			continue; // not chargeable
		endif;
		
		return move;
	endwhile;
	
	return self.allVoyageMovements.first; // PAR 12364 send the arrival if none of the wharves are chargeable
//	return null;

epilog
	delete iter;		// PAR #26678
	
end;</source>
        <Parameter name="_movement" type="String"/>
        <ReturnType type="HMS_VoyageMovement"/>
    </JadeMethod>
    <JadeMethod name="getMovementFirstRealBerth" id="7ae8a1d9-1c44-4068-9d0f-11f961c48365">
        <source>getMovementFirstRealBerth() : HMS_VoyageMovement;

/*

Purpose:			Get the first movement for the receiver to a real Berth


Return Value:		Movement object, or null of there is none


Date		Who		Reason
17 Apr 2008	cnwkpd1	PAR #16521 - Changes for Short Term Movements report

*/

vars
	movement		: HMS_VoyageMovement;
		
begin
	foreach movement in self.allVoyageMovements discreteLock do
		if not movement.isLogicalBerth then
			return movement;
		endif;
	endforeach;
	
	return null;
	
	
epilog

end;</source>
        <ReturnType type="HMS_VoyageMovement"/>
    </JadeMethod>
    <JadeMethod name="getMovementForDateTime" id="326a8d98-da88-4b89-8621-5cb7ed18649c">
        <source>getMovementForDateTime(_dateTime : TimeStamp) : HMS_VoyageMovement;
/*
Purpose:// TFS 40747 			
Date				Who			Reason
SEPTEMBER 2018		CNWAB1		Initial creation
*/

vars
	tmpMovement	: HMS_Movement;

begin
	if self.allVoyageMovements = null then
		return null;
	endif;
	
	if self.allVoyageMovements.size &lt; 1 then
		return null;
	endif;
	
	//match movement to date
	return self.allVoyageMovements.getAtKeyLeq(_dateTime);
	

end;
</source>
        <Parameter name="_dateTime" type="TimeStamp"/>
        <ReturnType type="HMS_VoyageMovement"/>
    </JadeMethod>
    <JadeMethod name="getMovementForMoveType" id="f7e5d525-ca9a-4ed5-b421-ab491c458ace">
        <source>getMovementForMoveType(_moveType : String) : HMS_VoyageMovement;
//--------------------------------------------------
// Created:	06 April 2004 By: cnwgd1
//--------------------------------------------------
vars
	move : HMS_VoyageMovement;
begin
	if _moveType = null then
		return null;
	endif;
	foreach move in self.allVoyageMovements do
		if move.moveType = _moveType then
			return move;
		endif;
	endforeach;
	return null;
end;</source>
        <Parameter name="_moveType" type="String"/>
        <ReturnType type="HMS_VoyageMovement"/>
    </JadeMethod>
    <JadeMethod name="getMyBerth" id="6c445899-6fc1-441b-b943-3945064063cc">
        <source>getMyBerth() : HMS_Berth;
// ---------------------------------------------------------------------------
// Created:     03 January 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/* Changes

Date		Name	TFS#		Description
============================================================================
23/09/2019 	jlgka1 	TFS 45614 	JMT - Refactoring remove Voyage Commodity Scenario mode
============================================================================*/
begin	
	if self.myBerth &lt;&gt; null then
		return self.myBerth;
