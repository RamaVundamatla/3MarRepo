    <JadeMethod name="setFromXML" id="07fc4e50-6e9d-4b91-940e-49107e312baf">
        <updating/>
        <source>setFromXML(_str: String; _root: CM_MenuRoot; _constValue: Integer; _childValues: IntegerArray; _systemOnly: Boolean; _passedInMenuId : String) updating;

// Created by cnwdvb1 on 20 December 2006
//
// 29/11/12 PJS		PAR #30787
/* Changes

Date		Name	TFS#		Description
============================================================================
20/09/2019 jlgka1 TFS 45614 	JMT - Refactoring remove Voyage Commodity Scenario mode
============================================================================*/
vars
	currHeading	 : String;
	menuUserItem : CM_MenuUserItem;
begin
	currHeading := self.heading;
	inheritMethod(_str, _root, _constValue, _childValues, _systemOnly, _passedInMenuId);
	
	// if heading has changed then ensure that the users details macth for completeness
	if self.heading &lt;&gt; currHeading then
		foreach menuUserItem in self.allMenuUserItems do
			menuUserItem.setHeading(self.heading);
		endforeach;
	endif;
end;</source>
        <Parameter name="_str" type="String"/>
        <Parameter name="_root" type="CM_MenuRoot"/>
        <Parameter name="_constValue" type="Integer"/>
        <Parameter name="_childValues" type="IntegerArray"/>
        <Parameter name="_systemOnly" type="Boolean"/>
        <Parameter name="_passedInMenuId" type="String"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="ab94c086-0b49-4007-9b19-07dd77637440">
        <updating/>
        <source>setProxy(_heading : String; 
		_classNameToCreate : String; 
		_pictureButton : String; 
		_pictureButtonDown : String; 
		_pictureIcon : String; 
		_schemaName : String; 
		_windowClassName : String; 
		_permissionValue : Integer;
		_isSystemDetail : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     22 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars


begin
	inheritMethod(_heading, _classNameToCreate, _pictureButton, 
				_pictureButtonDown, _pictureIcon, _schemaName, _windowClassName, _permissionValue,
				_isSystemDetail);
end;</source>
        <Parameter name="_heading" type="String"/>
        <Parameter name="_classNameToCreate" type="String"/>
        <Parameter name="_pictureButton" type="String"/>
        <Parameter name="_pictureButtonDown" type="String"/>
        <Parameter name="_pictureIcon" type="String"/>
        <Parameter name="_schemaName" type="String"/>
        <Parameter name="_windowClassName" type="String"/>
        <Parameter name="_permissionValue" type="Integer"/>
        <Parameter name="_isSystemDetail" type="Boolean"/>
    </JadeMethod>
</Class>
