    <JadeMethod name="controlNamePrefix" id="93692d4d-9f1e-4c5d-a927-892a6b1d0430">
        <source>controlNamePrefix(): String;

begin
	return 'jhs';
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="mouseDown" id="b18155db-9138-4a97-87da-60ff8ae9a215">
        <updating/>
        <source>mouseDown(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;

begin
	if button = Window.MouseButton_Left then
		if self.myDragControl = null then
			self.myDragControl := self.loadControl(form.controlCount + 1).CnEcHorizontalSplitter;
		endif;
		
		self.myDragControl.visible	:=	true;
		self.myDragControl.move(self.left, self.top, self.width, self.height);
		self.myDragControl.caption	:=	'';
		self.myDragControl.zOrder(1);
	endif;

	inheritMethod(frame, button, shift, x, y);
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="mouseMove" id="6e15d8dd-6700-40a9-b074-2b64aeef9c1f">
        <updating/>
        <source>mouseMove(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;

vars
	minWidth, minHeight : Integer;
begin
	if button = Window.MouseButton_Left then
		if self.myDragControl &lt;&gt; null and self.parent.Control.canResize(x.Integer, 0, minWidth, minHeight) then
			self.myDragControl.move(self.myDragControl.left, (self.top + y), self.myDragControl.width, self.myDragControl.height);
		elseif self.myDragControl &lt;&gt; null then
			self.myDragControl.move(self.myDragControl.left, minHeight, self.myDragControl.width, self.myDragControl.height);
		endif;
	endif;

	inheritMethod(frame, button, shift, x, y);
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="mouseUp" id="9d9c1161-d7c2-4449-b37a-8410bd442958">
        <updating/>
        <source>mouseUp(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;

vars
	minWidth, minHeight : Integer;

begin
	if button = Window.MouseButton_Left then
		if self.myDragControl &lt;&gt; null  and self.parent.Control.canResize(x.Integer, 0, minWidth, minHeight) then
			self.move(self.left, self.myDragControl.top, self.width, self.height);
			delete self.myDragControl;
			self.visible	:=	true;
			self.zOrder(1);
			self.parent.cnEc_MouseUp(self, button, shift, x, y);
		else
			self.move(self.left, minHeight, self.width, self.height);
			delete self.myDragControl;
			self.visible	:=	true;
			self.zOrder(1);
			self.parent.cnEc_MouseUp(self, button, shift, x, y);
		endif;
	endif;

	inheritMethod(frame, button, shift, x, y);
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="5fcff329-22c5-4e62-8e46-03b7fe5dc7a4">
        <updating/>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating;

begin
	//cnwmc5 - PAR #31051
	if not self.isInPainter then
		if not app.isUsingSkin() then
			self.bevelOuter			:=	Frame.Bevel_Raised;
			self.bevelOuterWidth	:=	1;
			self.boundaryBrush		:=	Frame.BoundaryBrush_Solid;
			self.borderStyle		:=	Window.BorderStyle_None;
			self.bevelInner			:=	Frame.Bevel_None;
		else
			self.skinCategoryName	:= "hgrip";
		endif;
	endif;
	
	self.height				:=	5;
	self.bevelInnerWidth	:=	0;
	self.boundaryWidth		:=	0;
	self.caption			:=	null;
	self.width				:=	self.parent.width;
	self.mousePointer		:=	Window.MousePointer_NS;

	inheritMethod(cntrl, persistCntrl);
end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
