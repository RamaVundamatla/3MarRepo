    <JadeMethod name="doCancel" id="afa7d97f-5f5e-4610-84c8-fe23a7b813ff">
        <updating/>
        <source>doCancel() updating, protected;
// ---------------------------------------------------------------------------
// Created:     17 June 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.modalResult := MsgBox_Return_Cancel;
	self.unloadForm();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSave" id="a34774b3-1551-4d79-bd6a-49c24f05fd51">
        <updating/>
        <source>doSave() updating, protected;
// ---------------------------------------------------------------------------
// Created:     17 June 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpCode,
	tmpDescr	: String;
	tmpClass	: Class;
	
begin

	tmpCode		:= self.txtCode.text;
	tmpDescr	:= self.txtDescription.text;
	tmpClass	:= self.cmbClassToCreate.listObject.Class;

	if (not self.validate(tmpCode, tmpClass)) then
		return;
	endif;
	
	self.myPassport.setTestDetails(tmpCode, tmpDescr, tmpClass);
	
	self.modalResult := MsgBox_Return_OK;
	self.unloadForm();

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="init" id="3b98dabc-da01-465b-aa1a-b36c66200e98">
        <updating/>
        <source>init(_trxName : String; _baseClass : Class; _passport : CM_Passport) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     17 June 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if _passport = null or _baseClass = null then
		app.msgBox('passport or baseClass is null', 'Error', MsgBox_OK_Only);
		return false;
	endif;
	
	self.caption := 'Record test for ' &amp; _trxName;
	self.myPassport	:= _passport;
	self.populateCmbClassToCreate(_baseClass);

	// assume a cancel.  the save sets to ok
	self.modalResult := MsgBox_Return_Cancel;

	// set these to null at start to prevent a 
	// test being recorded from previous data
	self.myPassport.setTestDetails(null, null, null);

	return true;

end;</source>
        <Parameter name="_trxName" type="String"/>
        <Parameter name="_baseClass" type="Class"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="populateCmbClassToCreate" id="0bce8079-6b17-4c7a-8626-f53027905830">
        <source>populateCmbClassToCreate(_baseClass : Class) protected;
// ---------------------------------------------------------------------------
// Created:     17 June 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
begin

	self.allClasses.add(_baseClass);
	_baseClass.allLocalSubclasses(self.allClasses);
	self.cmbClassToCreate.listCollection(self.allClasses,  false, 0);
	self.cmbClassToCreate.listObject := _baseClass;
end;</source>
        <access>protected</access>
        <Parameter name="_baseClass" type="Class"/>
    </JadeMethod>
    <JadeMethod name="validate" id="5028a246-9c90-4d46-baa4-dec34d37ee7b">
        <source>validate(_code : String; _classToCreate : Class) : Boolean protected;
// ---------------------------------------------------------------------------
// Created:     17 June 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if _code = null then
		app.msgBox('You must enter a code', 'Error', MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return false;
	endif;

	if _classToCreate = null then
		app.msgBox('You must select a class to create', 'Error', MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return false;
	endif;
	
	return true;

end;</source>
        <access>protected</access>
        <Parameter name="_code" type="String"/>
        <Parameter name="_classToCreate" type="Class"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
