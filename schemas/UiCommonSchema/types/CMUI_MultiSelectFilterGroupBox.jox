        <updating/>
        <source>handleFilterTextChange(_filterTextBox : CMUI_FilterTextBox) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Jul 2024	navnk30	ChangeRequest 64536: MTN - Adding Filter to column organizer screen - Selected Columns. Task 64537.

*/

vars

begin
	if _filterTextBox = self.txtFilterBoxLeft then
		self.filterLeftListBox();
	else
		self.filterRightListBox();
	endif;
epilog

end;</source>
