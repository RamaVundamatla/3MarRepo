<Class name="CMIF_ImageProcessingHelper" id="631aa27c-84e1-4aba-811b-4ec6b7922285">
    <superclass name="CMIF_DotNetWrap"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmsmap"/>
    <ImplicitInverseRef name="myImageProcessingHelper" id="0af0bda9-30fc-44a5-93e3-85205b9673de">
        <embedded/>
        <type name="MTNImageProcessingHelper"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="create" id="4e9992b3-ca5f-45d3-a899-bd920fb9fece">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 November 2025	navsp1	Initial creation 

*/

vars
	hadException	: Boolean;
	fileName		: String;
	iniValue		: String;
	usePresentation	: Boolean;
	
begin
	on Exception do self.handleExceptions(exception, hadException);
	
	create self.myImageProcessingHelper transient;
	if self.myImageProcessingHelper &lt;&gt; null then
		self.myImageProcessingHelper.usePresentationClient := self.usePresentationClient;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="5c74f014-a0a8-45f9-a289-b15e085bac50">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 November 2025	navsp1	Initial creation

*/

vars

begin
    delete self.myImageProcessingHelper;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getImageDataByDimension" id="11244373-acb0-4ead-80f5-c2dfd5cfb2d6">
        <source>getImageDataByDimension(imageData:Binary ; thumbWidth:Integer; errors:StringUtf8 output):Binary;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 November 2025	navsp1	Initial creation MTN-36650 Integrate DotNet Image Library for Automatic Thumbnail Generation in Thin Client

*/


vars
	resultData      : Binary;
    excOccurred		: Boolean;
begin
    on Exception do self.handleExceptions(exception, excOccurred);
	app.writeLog(method.qualifiedName, LogTRACE);
    
	resultData := self.myImageProcessingHelper.getImageDataByDimension(imageData, thumbWidth, errors);
    return resultData;
end;
</source>
        <Parameter name="imageData" type="Binary"/>
        <Parameter name="thumbWidth" type="Integer"/>
        <Parameter name="errors" type="StringUtf8" usage="output"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
