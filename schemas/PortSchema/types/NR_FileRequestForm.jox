        <source>setJRWINISetting(_itemName : String) protected;
/*
----------   ----------  --------------------------------------------------
Created:	05 December 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

	iniFileName			: String;
	newVal				: Boolean;
	value				: String;
begin
	iniFileName 	:= app.getIniFileName();

	value := app.getProfileString(iniFileName, self.JRWINI_Section, _itemName, null);
