    <JadeMethod name="setForCreate" id="2db49ccb-452f-4ef1-9bf9-dcc63d76a5f7">
        <updating/>
        <source>setForCreate( _rtH : RootHotFixes; _from, _to : Integer ) updating;
// created	31 Dec 2007 by cnwvu1
vars
	rtS	: RootHotFixSuper;
begin

	self.myRootHotFix	:= _rtH;
	self.setRange( 0, 0 );
	
end;
</source>
        <Parameter name="_rtH" type="RootHotFixes"/>
        <Parameter name="_from" type="Integer"/>
        <Parameter name="_to" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setRange" id="24d303dc-65aa-4193-9f51-e4d749f7f4e8">
        <updating/>
        <source>setRange( _from, _to : Integer ) updating;
//created	31 Dec 2007 by cnwvu1
vars
	rtS	: RootHotFixSuper;
	
begin

	rtS := app.myRootHotFix.myRootHotFixSuper;

	rtS.hotfixFrom	:= _from;
	rtS.hotfixTo	:= _to;

end;
</source>
        <Parameter name="_from" type="Integer"/>
        <Parameter name="_to" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="singleUserFound" id="9a397a47-2c79-4a8f-9cda-f0aaa7b6fda2">
        <source>singleUserFound( _strArray : StringArray ) : Boolean;
/* ---------------------------------------------------------------------------
Created:	22 December 2008	by cnwvu1

Purpose:	Par18697. Dec 2008
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	txtSingleUser	: String;
	str	: String;
	pos	: Integer;
	
begin

	txtSingleUser := app.myRootHotFix.TXT_SINGLEUSER;
	
	foreach str in _strArray do
		if str.pos( txtSingleUser, 1) &gt; 0 then
			return true;
		endif;
	endforeach;
	
	return false;

end;</source>
        <Parameter name="_strArray" type="StringArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
