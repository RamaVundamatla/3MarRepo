//--------------------------------------------------------------
vars
	assistant 	: LOG_Assistant;
	logGrade	: CM_LogGrade;
begin

	self.tblHeaderDtls.setValueByControlName(combobox.name, combobox.text);
	if self.origValueStr &lt;&gt; combobox.text then	
		assistant := self.myAssistant.LOG_Assistant;
		logGrade := combobox.listObject.CM_LogGrade;
//		assistant.setLogType(self.tblHeaderDtls, self.cmbType, logGrade, null);
//		assistant.setLogTreatment(self.tblHeaderDtls, self.cmbTreatment, logGrade, null);	
//		assistant.setLogLength(self.tblHeaderDtls, self.cmbLength, logGrade, null);
		self.cmbType.setObjectAndGrade(null, logGrade);
		self.tblHeaderDtls.setValueByControlName(self.cmbType.name, null);
		self.cmbTreatment.setObjectAndGrade(null, logGrade);
		self.tblHeaderDtls.setValueByControlName(self.cmbTreatment.name, null);
		self.cmbLength.setObjectAndGrade(null, logGrade);
		self.tblHeaderDtls.setValueByControlName(self.cmbLength.name, null);
	endif;	
end;</source>
