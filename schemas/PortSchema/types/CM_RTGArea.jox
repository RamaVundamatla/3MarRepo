    <JadeMethod name="deckingLocationsForLane" id="9e2f93b1-832e-48f1-8136-a87aef1355ab">
        <source>deckingLocationsForLane(_lane: Integer; _locations: CM_LCArray io);
//05 January 2009	cnwdw1	
// Return the decking locations for a lane
vars
	gridRow: CM_GridRow;
	rowCount: Integer;
	laneCount: Integer;
begin
	foreach gridRow in self.allGridRows do

		if laneCount &gt; _lane then
			break;
		endif;
		if laneCount = _lane and gridRow.isDeckable then
			gridRow.allControllersByColumn.copy(_locations);
		endif;
	endforeach;

end;</source>
        <Parameter name="_lane" type="Integer"/>
        <Parameter name="_locations" type="CM_LCArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doObjectVolatilityConversion" id="84a3b20c-bcdd-472c-969c-51b0833d3cbd">
        <updating/>
        <source>doObjectVolatilityConversion(_converter: CM_ObjectVolatilityConverter input; _logIndent: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 May 2010	cnwkpd1	PAR #23525 - System performance enhancements

*/

vars

begin
	inheritMethod(_converter, _logIndent);

	_converter.doChangeVolatilityOfObject(self.allRTGBays, _logIndent);
	_converter.doChangeVolatilityOfObject(self.allRTGBaysByLaneIdDict, _logIndent);
	
	
epilog

end;</source>
        <Parameter name="_converter" type="CM_ObjectVolatilityConverter" usage="input"/>
        <Parameter name="_logIndent" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="erase" id="5693ee59-0a60-407c-bba5-1bf15bd2863d">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
/*
----------   ----------  --------------------------------------------------
Created:	11 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	rtgLane				: CM_RTGLane;
	taGroup 			: CM_TerminalAreaGroup;
	interchangeArea     : CM_InterchangeArea;
	interchangeAreaArray : CM_InterchangeAreaArray;
begin

	if self.isTransient then
		if self.allTerminalAreaGroups.size &gt; 0 then
			foreach taGroup in self.allTerminalAreaGroups do
				rtgLane:=taGroup.CM_RTGLane;
				if rtgLane.isTransient then
					delete rtgLane;
				endif;
			endforeach;
		endif;

	endif;	

	create interchangeAreaArray transient;
	self.allAssociatedInterchangeAreas.copy(interchangeAreaArray);
	foreach interchangeArea in interchangeAreaArray do
		if interchangeArea.isKindOf(CM_GantryInterchangeArea) then
			delete interchangeArea;
		endif;
	endforeach;

	inheritMethod(_eraseLevel);

epilog
	delete interchangeAreaArray;
end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="findLocation" id="124a70a6-ae6a-4afc-8a28-aaca6b1319ed">
        <source>findLocation(_strs: StringArray; _noException : Boolean; _foundLC: CM_LocationsController io; _foundHeight: Integer io);
// ---------------------------------------------------------------------------
// Created:		21 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		location ID has no spaces and row and column labels are numeric zero filled. 
//					This means that the row/column label will always be 4 characters
//					format of full location is Area ID, Lane ID, Bay ID, Row ID - A23301 means Area 'A', Lane 2, bay 33 row 1
//					NOTE. Row labels are repeated 01-07 within lanes
//
// ---------------------------------------------------------------------------
vars
	tmpStr : String;
	rowStrLength	: Integer;
	isTruckLane,
	isTopInterchange: Boolean;
	colStr, rowStr,
	icLabel : String;
	rtgColumn : CM_RTGColumn;
	row : CM_GridRow;
begin

	if _strs.isEmpty then
		return;
	endif;
	// ### REMOVE TA id from front of string
	tmpStr := _strs[1];
	if tmpStr.length = self.id.length then // par #12776 16/10/2006
		return;
	else
		if tmpStr[1:self.id.length] = self.id then
			tmpStr := tmpStr[self.id.length + 1:end];
		endif;
	endif;
	
	//epr par 21526 - rows can be upto 4 characters 
	/*
		get row label length
		start at end less the min of 4 (the row label max that can be entered) or
		tStr length less 1 (assume col label is atleast 1 char)
	*/
	
	//label length for rows should all be the same
	//rowStrLength := self.allGridRows.first.label.length;
	rowStrLength:=4.min(tmpStr.length-1);
	while rowStrLength &gt;=1  do
		rowStr:=tmpStr[(tmpStr.length  - rowStrLength) + 1:end];
		row:=self.allGridRowsByLabel[rowStr];
		if row &lt;&gt; null then
			break;
		endif;
		rowStrLength:=rowStrLength-1;
	endwhile;
	
	if row = null then
		if tmpStr.length &lt; 2 then // PAR # 23010
			return;
		endif;
		if tmpStr[(tmpStr.length -2) + 1:end] = "00" then
			rowStrLength:=2;
			isTruckLane:=true;
		//or no row is entered must be for a interchange area
		elseif self.allGridColumnsByLabel[tmpStr] &lt;&gt; null then
			rowStrLength:=0;
			isTruckLane:=true;
		else
			return;
		endif;
	endif;
	
	
	colStr := tmpStr[1:tmpStr.length-rowStrLength];
	if rowStrLength &gt; 0 then
		rowStr := tmpStr[(tmpStr.length-rowStrLength) + 1:end];
	endif;
	
	
	//will be used when string is coming from an RTG Telegram "00" is defined as the truck lane
	if isTruckLane then // this is the truck row
		//make sure we find the grid controller in the first row
		rowStr := self.allGridRows.first.label;
		isTruckLane := true;
	endif;	
			
	
	if self.use40ftIds then 
		_foundLC := self.allGridControllersBy40ftId[rowStr &amp; colStr];
	endif;
	
	if _foundLC = null then
		_foundLC := self.allGridControllersByName[rowStr &amp; colStr];
	endif;
	
	if  isTruckLane then
		//will be in the first controller for the interchange column for the rtg column
		if _foundLC &lt;&gt; null and _foundLC.isKindOf(CM_RTGController) then
			rtgColumn:=_foundLC.CM_RTGController.myGridColumn.CM_RTGColumn;
			
			if _strs.size &gt; 1 then
				icLabel :=_strs[2];
			endif;
			
			if icLabel = self.topLabel then
				if  rtgColumn.myTopGantryICColumn &lt;&gt; null then
					_foundLC:=rtgColumn.myTopGantryICColumn.allControllersByRow.first;
				endif;
			elseif icLabel = self.bottomLabel then
				if  rtgColumn.myBottomGantryICColumn &lt;&gt; null then
					_foundLC:=rtgColumn.myBottomGantryICColumn.allControllersByRow.first;
				endif;
			endif;
			if _foundLC &lt;&gt; null then
				//always check the top one first
				if rtgColumn.myTopGantryICColumn &lt;&gt; null then
					_foundLC:=rtgColumn.myTopGantryICColumn.allControllersByRow.first;
				elseif rtgColumn.myBottomGantryICColumn &lt;&gt; null then
					_foundLC:=rtgColumn.myTopGantryICColumn.allControllersByRow.first;
				endif;
			endif;
		endif;
	endif;


epilog

end;</source>
        <Parameter name="_strs" type="StringArray"/>
        <Parameter name="_noException" type="Boolean"/>
        <Parameter name="_foundLC" type="CM_LocationsController" usage="io"/>
        <Parameter name="_foundHeight" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getColumnForLabel" id="b989a955-e925-4692-8024-ab2030431aa3">
        <source>getColumnForLabel(pLabel : String) : Integer;
// ---------------------------------------------------------------------------
// Created:     11 June 2009 by cnwjo3
//
// Purpose:     return the RTG column number

// Returns:     column number
vars
	rtgCol	: CM_RTGColumn;
begin
	rtgCol := self.allGridColumnsByLabel[pLabel].CM_RTGColumn;
	if rtgCol = null then
		return 0;
	endif;
	
	return rtgCol.column;
end;</source>
        <Parameter name="pLabel" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="57068a8b-4fed-4776-b69f-7cf576a1cc11">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 August 2009	cnwer1	Initial creation

*/

vars
	rtgArea,
	realRTGArea: CM_RTGArea;
	rtgLane : CM_RTGLane;
begin
	if self.isTransient then
		realRTGArea:=app.myProxyManager.getRealObject(self).CM_RTGArea;
	else
		realRTGArea:=self;
	endif;
	if _attrName = ETRow_SideInterchangePos then
		
		if realRTGArea &lt;&gt; null then
			return realRTGArea.getSideInterchangeAreaPosition.toGantryInterchangePosString;
		endif;
		return null;
	elseif _attrName = ETRow_PreviousLaneArea then
		if realRTGArea &lt;&gt; null then
			rtgArea:=realRTGArea.getPreviousRTGAreaInRTGLane;
			if rtgArea = null then
				return null;
			else
				return rtgArea.id;
			endif;
		else
			return null;
		endif;
	elseif _attrName = ETRow_NextLaneArea then
		if realRTGArea &lt;&gt; null then
			rtgArea:=realRTGArea.getNextRTGAreaInRTGLane;
			if rtgArea = null then
				return null;
			else
				return rtgArea.id;
			endif;
		else
			return null;
		endif;
	elseif _attrName = ETRow_LaneGrouping then
		if realRTGArea &lt;&gt; null then
			rtgLane:=realRTGArea.getRTGLane;
			if rtgLane = null then
				return null;
			else
				return rtgLane.label;
			endif;
		else
			return null;
		endif;
	else
		return inheritMethod(_attrName, _short);
	endif;
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
