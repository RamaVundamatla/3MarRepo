    <JadeMethod name="setupMethods_Headings" id="6caf3b28-f750-4329-8bfd-21e28123febd">
        <lockReceiver/>
        <updating/>
        <source>setupMethods_Headings( _format : CM_OutputFormat_XTAB ) protected, updating;
// ---------------------------------------------------------------------------
// Created:     20 November 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
constants
	Parameters_PUT = '_sa :StringArray;';
	Parameters_GET = '_sa :StringArray';
	Parameters_StartKeyGTR = '_sa :StringArray';
	
vars
	strParams			: String;
	strParam			: String;
	int					: Integer;
	tabs				: Integer;
	rows				: Integer;
	cols				: Integer;
	tot					: Integer;
	
begin
	delete self.myJadeMethod_GET;
	delete self.myJadeMethod_PUT;
	delete self.myJadeMethod_StartKeyGTR;
	
	tabs	:= _format.allTabs.size;
	rows	:= _format.allRows.size;
	
	if rows = 0 then
		rows := 1;	// dummy entry
	endif;
	
	cols	:= _format.allColumns.size;
	tot		:= tabs + rows + cols;
	
	// create transient methods to getEntryFor a ti and to updateEntry for a ti
	// build up parameter list for the get/put methods
	foreach int in 1 to (tot) do
		// we only want tabs and columns in this collection
		if int &gt; tabs and int &lt;= tabs + rows then
			continue;
		endif;
		
		strParam := '_sa[' &amp; int.String &amp; ']';

		if strParams = null then
			strParams := strParam;
		else
			strParams := strParams &amp; ',' &amp; strParam;
		endif;
	endforeach;
	
	// now create methods we will need to hanlde variable number of keys
	self.myJadeMethod_GET			:= self.createTransientMethod(	self.Method_GET,
																	Parameters_GET,
																	strParams,
																	'method_GET' );
	
	self.myJadeMethod_PUT			:= self.createTransientMethod(	self.Method_PUT,
																	Parameters_PUT,
																	strParams,
																	'method_PUT' );
	
	self.myJadeMethod_StartKeyGTR	:= self.createTransientMethod(	self.Method_StartKeyGTR,
																	Parameters_StartKeyGTR,
																	strParams,
																	'method_StartKeyGTR' );
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_format" type="CM_OutputFormat_XTAB"/>
    </JadeMethod>
    <JadeMethod name="setupMethods_XTAB" id="aee11f65-c539-47be-9d13-d923a279b2fb">
        <lockReceiver/>
        <updating/>
        <source>setupMethods_XTAB(_format :CM_OutputFormat_XTAB)protected, updating;
// ---------------------------------------------------------------------------
// Created:     20 November 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
constants
	Parameters_PUT = '_level : Integer; _sa : StringArray;';
	Parameters_GET = '_level : Integer; _sa : StringArray';
	Parameters_StartKeyGTR = '_level : Integer; _sa : StringArray';
vars
	strParams, strParam	:String;
	int, numTabs, numRows, numCols,
	intStart, intEnd	:Integer;
begin
	delete self.myJadeMethod_GET;
	delete self.myJadeMethod_PUT;
	delete self.myJadeMethod_StartKeyGTR;
	
	numTabs := _format.allTabs.size;
	numRows := _format.allRows.size;
	numCols := _format.allColumns.size;
	
	// in this method we can treat the dummy rows/cols as real rows/cols
	if numRows = 0 then
		numRows := 1;	// dummy row grouping
	endif;
	if numCols = 0 then
		numCols := 1;	// dummy column grouping
	endif;
	
	// create transient methods to getEntryFor a ti and to updateEntry for a ti
	// build up parameter list for the get/put methods
	foreach int in 1 to numTabs do
		strParam := '_sa[' &amp; int.String &amp; ']';
		
		if strParams = null then
			strParams := strParam;
		else
			strParams := strParams &amp; ',' &amp; strParam;
		endif;
	endforeach;
	
	if strParams = null then	
		strParams := '_level';
	else
		strParams := strParams &amp; ',' &amp; '_level';
	endif;
	// rows
	intStart 	:= numTabs + 1;
	intEnd 		:= numTabs + numRows;
	
	foreach int in intStart to intEnd do
		strParam	:= '_sa[' &amp; int.String &amp; ']';
		strParams 	:= strParams &amp; ',' &amp; strParam;
	endforeach;
	
	// columns
	intStart 	:= numTabs + numRows + 1;
	intEnd 		:= numTabs + numRows + numCols;
	foreach int in intStart to intEnd do
		strParam	:= '_sa[' &amp; int.String &amp; ']';
		strParams	:= strParams &amp; ',' &amp; strParam;
	endforeach;
	
	// now create methods we will need to handle variable number of keys
	self.myJadeMethod_GET			:= self.createTransientMethod(	self.Method_GET,
																	Parameters_GET,
																	strParams,
																	'method_GET' );
	
	self.myJadeMethod_PUT			:= self.createTransientMethod(	self.Method_PUT,
																	Parameters_PUT,
																	strParams,
																	'method_PUT' );
	
	self.myJadeMethod_StartKeyGTR	:= self.createTransientMethod(	self.Method_StartKeyGTR,
																	Parameters_StartKeyGTR,
																	strParams,
																	'method_StartKeyGTR' );
	
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_format" type="CM_OutputFormat_XTAB"/>
    </JadeMethod>
    <JadeMethod name="setup_Headings" id="52d1dbcf-143a-451e-b940-d44626b4fa2c">
        <lockReceiver/>
        <updating/>
        <source>setup_Headings( _format : CM_OutputFormat_XTAB ) : Boolean updating;

// ---------------------------------------------------------------------------
// Created:     20 November 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 21/01/2009	cnwrl1		Handle UE causing errors (CCMS SFW 1047 - Totals Only Lists)
// ---------------------------------------------------------------------------

vars
	col			: CM_XTABGrouping;
	tab			: CM_XTABGrouping;
	error1322	: Boolean;
	
begin
	on Exception do self.handleException1322( exception, error1322 );
	
	if self.hasBeenSetup then
		self.clear;
		self.clearKeys;
	endif;
	
	// set membership and keys 
	self.setMembership( CMIF_OutputGrouping );
	
	foreach tab in _format.allTabs do
		self.addExternalKey( String,tab.getKeyLength, tab.descending, false );
		if error1322 then		// Total key size exceeds 512 characters.
			return false;
		endif;
	endforeach;
	
	foreach col in _format.allColumns do
		self.addExternalKey( String, col.getKeyLength, col.descending, false );
		if error1322 then		// Total key size exceeds 512 characters.
			return false;
		endif;
	endforeach;
	
	self.endKeys( false );
	
	self.setupMethods_Headings( _format );
	
	return true;
	
epilog
	
end;</source>
        <Parameter name="_format" type="CM_OutputFormat_XTAB"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setup_XTAB" id="6fcfb4f5-60bb-40be-ab76-bd2a3c4013ec">
        <lockReceiver/>
        <updating/>
        <source>setup_XTAB( _format : CM_OutputFormat_XTAB ) : Boolean updating;

// ---------------------------------------------------------------------------
// Created:     20 November 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 21/01/2009	cnwrl1		Handle UE causing errors (CCMS SFW 1047 - Totals Only Lists)
// ---------------------------------------------------------------------------

vars
	col				: CM_XTABGrouping;
	row				: CM_XTABGrouping;
	tab				: CM_XTABGrouping;
	error1322		: Boolean;
	
begin
	on Exception do self.handleException1322( exception, error1322 );
	
	if self.hasBeenSetup then
		self.clear;
		self.clearKeys;
	endif;
	
	// set membership and keys 
	self.setMembership( CMIF_OutputGrouping );
	
	foreach tab in _format.allTabs do
		self.addExternalKey( String, tab.getKeyLength, tab.descending, false );
		if error1322 then		// Total key size exceeds 512 characters.
			return false;
		endif;
	endforeach;
	
	// level
	// 0 = main XTAB
	// 1 = summary by row 1
	// 2 = summary by row 2 etc etc
	self.addExternalKey( Integer, null, false, false );
	
	foreach row in _format.allRows do
		self.addExternalKey( String, row.getKeyLength, row.descending, false );
		if error1322 then		// Total key size exceeds 512 characters.
			return false;
		endif;
	endforeach;
	
	if _format.allRows.isEmpty then
		// add a dummy key - it will contain a dummy value just for columns detail grouping
		self.addExternalKey( String, CMIF_OutputFormatAgent_XTAB.Dummy_Detail_Value.length, false, false );
		if error1322 then		// Total key size exceeds 512 characters.
			return false;
		endif;
	endif;
	
	foreach col in _format.allColumns do
		self.addExternalKey( String, col.getKeyLength, col.descending, false );
		if error1322 then		// Total key size exceeds 512 characters.
			return false;
		endif;
	endforeach;
	
	if _format.allColumns.isEmpty then
		// add a dummy key - it will contain a dummy value just for columns detail grouping
		self.addExternalKey( String, CMIF_OutputFormatAgent_XTAB.Dummy_Detail_Value.length, false, false );
		if error1322 then		// Total key size exceeds 512 characters.
			return false;
		endif;
	endif;
	
	self.endKeys( false );
	
	self.setupMethods_XTAB( _format );
	
	return true;
	
epilog
	
end;</source>
