    <JadeMethod name="getVoyageForArrivingDTTerminal" id="5a12143e-6f1a-432c-8bde-e641e89be54a">
        <source>getVoyageForArrivingDTTerminal(_arrivalDT : TimeStamp; _terminal : CM_Terminal) : CM_Voyage;
// ---------------------------------------------------------------------------
// Created:     22 February 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	voyage,
	voy		: CM_Voyage;
begin

	if _arrivalDT &lt;&gt; null then
		voy := self.allVoyages.getAtKeyLeq(_arrivalDT, _terminal).CM_Voyage;
		if _terminal &lt;&gt; voy.myTerminal then
			voy := null;
		endif;
	endif;

	if voy = null then
		/* after CCMS C3 1124, arrival date is now being set but this method is always called with a null date
		//	the self.allVoyage keys are arrival date then terminal, which is probably for Comalco but C3 log voyages
		//	are all unique by terminal for each global voyage, so the arrival date to differentiate them doesn't help.
		//	Old code:
		voy := self.allVoyages.getAtKeyGeq(null, _terminal).CM_Voyage;
		if  voy &lt;&gt; null and  _terminal &lt;&gt; voy.myTerminal then
			voy := null;
		endif;
		*/
		// 33293 Jan 2014 just find the voyage by terminal, don't use the arrival date which is not always known by the method caller
		//	a little slower but safer (typically only a few entries here)
		foreach voyage in self.allVoyages do
			if voyage.myTerminal = _terminal then
				voy := voyage;
				break;
			endif;
		endforeach;
				
	endif;

	return voy;

end;</source>
        <Parameter name="_arrivalDT" type="TimeStamp"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
