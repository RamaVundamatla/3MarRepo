    <JadeMethod name="getVoyageDescription" id="3f70f3e7-c7b5-4bd6-becd-89ae7c14147b">
        <source>getVoyageDescription() : String;
// ---------------------------------------------------------------------------
// Created:     19 August 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tmpStr : String;
	tmpDT : TimeStamp;
	tmpVoy : CM_Voyage;
begin
	if self.myBookingReference = null then
		return null;
	endif;
	
	tmpVoy := self.myBookingReference.myVoyage;
	if tmpVoy = null then
		return null;
	endif;
	
	tmpStr :=  tmpVoy.vesselCode &amp; " " &amp; tmpVoy.vesselName.trimBlanks &amp; " - " &amp; tmpVoy.code;
	
	tmpDT := tmpVoy.departedDT;
	if tmpDT.isValid() then
		tmpStr := tmpStr &amp; " - " &amp; tmpDT.asStringJMT();
	endif;
	
	return tmpStr;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
