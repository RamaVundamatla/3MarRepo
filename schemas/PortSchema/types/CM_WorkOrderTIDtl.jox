    <JadeMethod name="getVBSExternalRef" id="447b624e-a5e7-40d6-9417-fd5bc8efc749">
        <source>getVBSExternalRef(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/11/2024	navkc1 JIRA Story MTN-19092: EUP | 54014 - Work Orders Enhancements - Improved Search and usability

*/

vars
	returnStr,
	str			: String;
	vbsSet		: CM_ObjectSet;
	vbs			: CM_VehicleBookingTimeSlot;
begin
	
	create vbsSet transient;
	
	self.getVehicleBookingSlots(vbsSet);
	
	foreach vbs in vbsSet as CM_VehicleBookingTimeSlot do
		str := vbs.externalReference;
		
		if str = null then
			continue;
		endif;
		
		/*
		if returnStr = null then
			returnStr := str;
		else
			if returnStr.pos(str, 1) &gt; null then
				continue;
			else
				returnStr &amp;= Comma &amp; str;
			endif;
		endif;
		*/
		
		returnStr.addStringToList(str, Comma); //04/04/2025	navkc1 JIRA Story MTN-33940
	endforeach;
	
	return str;

epilog
	delete vbsSet;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVehicleBookingSlots" id="f3aa64ce-9792-421f-be0d-1b159ffd6770">
        <source>getVehicleBookingSlots(_vbsSet : CM_ObjectSet io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 December 2024		navma1	Initial creation
26/11/2024	navkc1 JIRA Story MTN-19092: EUP | 54014 - Work Orders Enhancements - Improved Search and usability
*/

vars
	wleJob,
	job 	: CM_Job;
	wle 	: CM_WOWLE;
	operWle : CM_WorkListEntry;
	vvr		: CM_VehicleVisitRecord;
begin
	if self.getTransport &lt;&gt; TI_TRANSMODE_ROAD then
		return;
	endif;
	
	foreach job in self.allJobs discreteLock do
		
		foreach  wle in job.workListEntries as CM_WOWLE discreteLock do
			operWle:= wle.myOperationalWLE;
			
			if operWle = null then
				continue;
			endif;
			
			wleJob := operWle.job;
			
			if wleJob = null or not wleJob.isRoadJob() then
				continue;
			endif;
			
			vvr := wleJob.CM_RoadJob.myVehicleVisit;
			
			if vvr = null then
				continue;
			endif;
			
			vvr.allVehicleBookingSlots.copyNoDuplicates(_vbsSet, false);
		endforeach;
	endforeach;
epilog

end;</source>
        <Parameter name="_vbsSet" type="CM_ObjectSet" usage="io"/>
    </JadeMethod>
