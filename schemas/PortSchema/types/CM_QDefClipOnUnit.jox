<Class name="CM_QDefClipOnUnit" id="31085775-ae50-4ee4-a3a4-1e251bdfabba">
    <superclass name="CM_QDefMachinery"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="createProperties" id="f04c07f4-7edb-400a-b3df-fbeef2606e2e">
        <source>createProperties();
// ---------------------------------------------------------------------------
// Created:     22 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	tmpProp		: CM_QueryProperty;
begin
	inheritMethod();

	create tmpProp as CM_QCOUTypeProperty persistent;
	tmpProp.set('COU Type', 'couType', self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);



end;</source>
    </JadeMethod>
</Class>
