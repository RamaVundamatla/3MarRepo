    <JadeMethod name="fixXlatFormLblCaption" id="bc66d749-949b-4de7-881d-e897a00b0d86">
        <source>fixXlatFormLblCaption();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 June 2024	navlc30	Initial creation

*/

vars
	transAgent 	: CM_TranslationAgent;
	tmpArray : StringArray;
begin
	app.initialize();


	create transAgent transient;
	create tmpArray transient;

	tmpArray.add('Xlat_0026219');
	transAgent.trxLoadSpecificTranslations(tmpArray);
	return;


epilog
	delete tmpArray;
	delete transAgent;
end;</source>
    </JadeMethod>
    <JadeMethod name="purgeOldEdiFile" id="39074e75-3b48-4f1f-81f0-9da785dbcccc">
        <source>purgeOldEdiFile();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 November 2024	navlc30	Initial creation
22 Nov 2024 navlc30 JIRA 19275 MSL- Huge quantity of EDI data to delete
*/

vars
	terminal : CM_Terminal;	
	ediConfig : CM_EDIConfig;
	allEDIFilesForTerm : CM_EDIFileByCreatedTSDict;
	ediFile : CM_EDIFile;	
	numDeleted : Integer;
	totalNumber : Integer;
	finishTs : TimeStamp;
	nextCommitTs : TimeStamp;
	now : TimeStamp;
	purgeDays		: Integer;
	purgeDate		: Date;
	numProcessed : Integer;
	totalNumberAfter : Integer;	
	iter		: Iterator;
	breakOuter  : Boolean;
begin
	app.initialize();
	process.setPersistentDeadlockPriority(-10);
	app.writeLog(method.qualifiedName &amp; " purgeOldEdiFile start", LogINFO);

	
	foreach terminal in  app.myRoot.allTerminals discreteLock do
		ediConfig := terminal.myEdiConfig;
		if ediConfig &lt;&gt; null then
			allEDIFilesForTerm := ediConfig.ediFiles;
			totalNumber := totalNumber + allEDIFilesForTerm.size();
		endif;
	endforeach;
	
	finishTs := app.actualTimeServer.addSeconds(3600);
	nextCommitTs := app.actualTimeServer.addSeconds(10);

	
	purgeDays 	:= 365;
	purgeDate	:= null;
		
	if purgeDays &gt; 0 then
		purgeDate := app.actualTimeServer.date - purgeDays;
	endif;	
	
	app.writeLog(method.qualifiedName &amp; " purge start time : " &amp; app.actualTimeServer.String, LogINFO);	
	
	beginTransaction;
	
		foreach terminal in  app.myRoot.allTerminals discreteLock do
			app.writeLog(method.qualifiedName &amp; " Processing for Terminal : " &amp; terminal.code &amp; " and current time is : " &amp; app.actualTimeServer.String, LogINFO);			
			ediConfig := terminal.myEdiConfig;		
			allEDIFilesForTerm := ediConfig.ediFiles;
			iter := allEDIFilesForTerm.createIterator();			 

				while iter.next(ediFile) do
					if ediFile.createdTime.Date &lt;= purgeDate then
						if ediFile.fileStatus = 4 then
							delete ediFile;
							numDeleted := numDeleted  + 1;
						endif;	
					endif;
					
					numProcessed := numProcessed +1;
					
					now := app.actualTimeAppServer();
					
					//see if its time to end
					if now &gt;= finishTs then
						app.writeLog("Time limit (60 mins) reached, stopping early", LogINFO);
						breakOuter := true;						
						break;
					endif;					
					
					// commit in batches to reduce the final commit time to keep close to our 60 second limit
					if now &gt;= nextCommitTs then
						commitTransaction;
						nextCommitTs := now.addSeconds(10);
						beginTransaction;
					endif;
				endwhile;	
				app.writeLog(method.qualifiedName &amp; " Current delete count is : " &amp; numDeleted.String &amp; " and current time is : " &amp; app.actualTimeServer.String, LogINFO);
				if breakOuter = true then
					break;
				endif;
		endforeach;
	
	commitTransaction;
	app.writeLog(method.qualifiedName &amp; " Overall purge end time : " &amp; app.actualTimeServer.String, LogINFO);
	app.writeLog(method.qualifiedName &amp; " totalNumberBefore : " &amp; totalNumber.String &amp; " numProcessed : " &amp; numProcessed.String &amp; " numDeleted : " &amp; numDeleted.String , LogINFO);
	
	foreach terminal in  app.myRoot.allTerminals do
		ediConfig := terminal.myEdiConfig;
		if ediConfig &lt;&gt; null then
			allEDIFilesForTerm := ediConfig.ediFiles;
			totalNumberAfter := totalNumberAfter + allEDIFilesForTerm.size();
		endif;
	endforeach;
	
	app.writeLog(method.qualifiedName &amp; " totalNumberAfter  : " &amp; totalNumberAfter.String, LogINFO);		
	app.writeLog(method.qualifiedName &amp; " purgeOldEdiFile End", LogINFO);	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="updateMyDensityDesc" id="64f8b889-88ed-4031-9c31-ef70aa16e45e">
        <source>updateMyDensityDesc();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 June 2025	navlc30	Initial creation
25 Jun 2024 navlc30 JIRA-34995 - Issue occurring while switch to another reserve item on release request screen
*/

vars
	objArr : ObjectArray;
	prod : CM_Product;
	//prodAttr : CM_ProdAttrDecimal;
begin
	create objArr transient;
	
	CM_Product.allInstances(objArr,0, true);
	
	beginTransaction;
	foreach prod in objArr as CM_Product do
		if prod.myDensityDec = null then
			prod.createProductAttributes();
		endif;
	endforeach;
	commitTransaction;
epilog

end;</source>
    </JadeMethod>
</Class>
