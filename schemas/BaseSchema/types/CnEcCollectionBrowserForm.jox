    <JadeMethod name="tblObjects_click" id="67c48730-ed16-4e56-809b-c842ab780db1">
        <controlMethod name="CnEcDesignTable::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblObjects_click(table: Table input) updating;
// --------------------------------------------------------------------------------
// Created:		21 January 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if tblObjects.row &gt; 1 then
		btnOk.enabled		:=	true;
		btnClearAll.enabled	:=	true;
	else
		btnOk.enabled		:=	false;
		btnClearAll.enabled	:=	false;
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
