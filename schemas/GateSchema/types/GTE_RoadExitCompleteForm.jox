    <JadeMethod name="doAddNewListEntry" id="4241cf93-8701-48f9-8c0a-4997d2d620c4">
        <updating/>
        <source>doAddNewListEntry(_deliveryRequest : CM_DeliveryRequest io ) updating, protected;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 22 June 2007
//
//----------------------------------------------------------------------

vars
	result : Integer;
begin
	if _deliveryRequest = null then
		app.msgBox('Please select a release by type from the list to add a work list entry to.', 'Make Selection', MsgBox_Information_Icon + MsgBox_OK_Only);	
		return;
	endif;

	app.mousePointer := MousePointer_HourGlass;			
		
	while true do
		app.myTrxUA.trxUpdateReleaseWLEQty(_deliveryRequest, 1, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog('Add work list entry', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;
	
epilog 
	app.mousePointer := MousePointer_Default;			
end;</source>
        <access>protected</access>
        <Parameter name="_deliveryRequest" type="CM_DeliveryRequest" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doAddTrailerAndNewWorkEntry" id="c1d49bdd-77fe-4297-8b61-0065e2cff716">
        <updating/>
        <source>doAddTrailerAndNewWorkEntry() :Boolean updating, protected;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 20 June 2007
//
// User is adding a trailer to existing Release, so we also want to add a wle
//----------------------------------------------------------------------
// 11/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state

vars
	releaseObj 			: CMIF_ReleaseById;
	tiArrayObj			: CMIF_TIObjectArray;
	ioCommonObj			: CMIF_InOutCommon;
	pxyTI,
	trackedItemObj		: CM_TrackedItem;
	tiMaster 			: CM_TIMaster;
	result 				: Integer;
	loadState			: Boolean;
	roadJob : CM_RoadJob;
begin
	app.cmsBeginLoad(loadState);
	
	tiMaster := self.cmbTrailers.listObject.CM_TIMaster;
	
	trackedItemObj := tiMaster.allTis.last;
	
	if trackedItemObj = null then
		return false;
	endif;
	
	create ioCommonObj transient;
	create tiArrayObj transient;
	create releaseObj transient;
		
	releaseObj.ignoreWarnings			:=	true;
	releaseObj.id						:=	trackedItemObj.id;
	releaseObj.consigneeCode			:=	trackedItemObj.consignee;
	releaseObj.consignorVoyageCode		:=	trackedItemObj.consignorVoyageCode;

	releaseObj.eirNumber				:=	trackedItemObj.eirNumber;
	releaseObj.remarks					:=	trackedItemObj.remarks;
	releaseObj.cargoType				:=	trackedItemObj.cargoType;
	releaseObj.myTerminal				:=	self.myTerminal;
	
	tiArrayObj.add(releaseObj);
	
	ioCommonObj.carrierCode := self.myJob.CM_RoadJob.myVehicle.carrierCode;
	ioCommonObj.myTerminal := self.myTerminal;
	ioCommonObj.regNumber := self.myVehicle.code;
	ioCommonObj.jobExists := true;
	//ioCommonObj.autoComplete := true;
	ioCommonObj.roadTransAreaId	:=	self.myTerminal.getConfig(DefRoadOpsArea).String.trimRight();

	releaseObj.setMyInOutCommon(ioCommonObj);
	// Finally, call the Road In/Out transaction.
	
	app.myPassport.setWarningsIgnored(true);
	
	while true do
		//app.myTrxCA.trxCreateInOutVehicle(ioCommonObj, app.myPassport);		//cnwmc5 - 22 Jan 2015 - PAR 35518
		app.myTrxCA.trxCreateInOut(ioCommonObj, tiArrayObj, app.myPassport, null);	//TFS 53107, AjitM, navam1
		if app.myPassport.trxCompletedOK() then
			self.clearErrorWarnings();
		else
			result := app.showErrorWarningDialog('Assign To Release', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	
		endif;
		break;
	endwhile;
	
	if app.myPassport.trxCompletedOK() then
		return true;
	endif;
epilog	
	app.cmsEndLoad(loadState);				// 11/04/2011 cnwmh5 #27347
	delete tiArrayObj;
	delete ioCommonObj;
	delete releaseObj;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
