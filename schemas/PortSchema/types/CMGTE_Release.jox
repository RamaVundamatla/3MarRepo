    <JadeMethod name="setDeliveryReleaseNumber" id="8c74e10f-b3be-48ea-8a2b-4bef7c57e0cf">
        <updating/>
        <source>setDeliveryReleaseNumber(_deliveryReleaseObj : Object) updating;

/*

Purpose:			Sets the delivery release number based on the following rules:
					1) Delivery Release Number entered in Road Gate
					2) Delivery Release Number entered in Release Request
					3) Release Request code

Parameters:			

Return Value:		


Date		Who		Reason
30 November 2010	cnwmh5	Initial creation #26400

*/

vars
	
	fromGate		: CMIF_FlexiGateController;
	fromBulkRelease	: CM_BulkRelease;
	
	deliveryRelease	: String;
	
begin

	deliveryRelease := self.deliveryReleaseNumber;

	if _deliveryReleaseObj.isKindOf(CMIF_FlexiGateController) then
		fromGate := _deliveryReleaseObj.CMIF_FlexiGateController;
	elseif _deliveryReleaseObj.isKindOf(CM_BulkRelease) then
		fromBulkRelease := _deliveryReleaseObj.CM_BulkRelease;
	endif;
	
	// from gate and has a delivery release number
	if fromGate &lt;&gt; null and fromGate.deliveryRelease &lt;&gt; null then
		deliveryRelease := fromGate.deliveryRelease;
	endif;
	
	// not from gate and have a bulk release
	if deliveryRelease = null and fromBulkRelease &lt;&gt; null then
		deliveryRelease := fromBulkRelease.getDeliveryReleaseNumber();
	endif;

	// update deliveryReleaseNumber
	self.deliveryReleaseNumber := deliveryRelease;
	
epilog

end;</source>
        <Parameter name="_deliveryReleaseObj" type="Object"/>
    </JadeMethod>
