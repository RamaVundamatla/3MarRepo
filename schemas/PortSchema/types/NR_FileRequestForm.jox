    <JadeMethod name="btnSearch_click" id="b79cf8a2-9502-4f56-8153-8dfca7d4953e">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnSearch_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
09 December 2019	jlgmd1	Initial creation
09 January 2019		jlgmd1	TFS 48181 Warn users that doing an Activity search might take some time

*/

vars
	
begin

	if self.fldMain.topSheet = self.shtParser then	
		// Inform the user we are doing something
		self.setStatusCaption("Searching...", false);
		
		// Clear the previous results
		self.clearTblResults();
		
		// Set the agents values
		self.setParserAgentValues();
		
		// Warn people that an Activity only search may take a few minutes
		if self.myParserAgent.searchType = CM_LogParserAgent.SearchType_Activity then
			if (app.msgBox("Search may take a few minutes. Are you sure you wish to continue ?", "Warning", MsgBox_Yes_No) = MsgBox_Return_No) then
				return;
			endif;
		endif;
		
		self.myParserAgent.doSearch(); // TFS 47162 jlgzm1 13/12/2019
	endif;

epilog

end;</source>
