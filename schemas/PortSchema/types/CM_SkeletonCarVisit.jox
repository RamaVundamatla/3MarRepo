    <JadeMethod name="getPicture" id="47b89fa6-db76-4ab3-81bd-6dc3441f7146">
        <source>getPicture(): Binary;
/*
Purpose:			
Date				Who			Reason
NOV 2016		CNWAB1		Initial creation
*/


vars

	thePicture : Binary;
	
begin

	if not self.getTerminal().getConfig(ShowCargoPicture).Boolean then // PAR 21182
		return null;
	endif;
	
	thePicture := app.myRoot.getConfig(PicSkeletoncarJMT).Binary;
	if thePicture = null then
		thePicture := app.myRoot.getConfig(PicWagon).Binary;
	endif;

	return thePicture;

epilog

end;</source>
        <ReturnType type="Binary"/>
    </JadeMethod>
