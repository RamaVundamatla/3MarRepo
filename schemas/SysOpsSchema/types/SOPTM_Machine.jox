    <JadeMethod name="doEditDelay" id="fd26eb34-8ceb-4395-9192-a498c1b5effc">
        <source>doEditDelay(_table :CM_DataTable input)protected;
// ---------------------------------------------------------------------------
// Created:     01 April 2011 by cnwcs5
// Purpose:     Show delay edit form for selected delay start/end in the history
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	form	:SOP_TableMaintForm;
	history	:CM_MachineHistory;
	row		:Integer;
	delay	:CM_Delay;
begin
	form	:= self.myForm;
	row		:= _table.row;
	
	if row &lt;= _table.fixedRows then 
		return;	// nothing to do
	endif;
	
	history := _table.accessRow (row).itemObject.CM_MachineHistory;
	
	if history = null then 
		return;
	endif;
	
	if history.CM_MachineHistory.isDelayStartHistory or
		history.CM_MachineHistory.isDelayEndHistory then
		delay := history.CM_MachineDelayHistory.getDelay;
	endif;

	if delay = null then 
		return;
	endif;

	form.myAssistant.showDelayEditForm (null, delay, null, false, form.myMasterMenuAction);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doExtractHistory" id="ccb362fa-81f6-4075-9b1b-d8b4a433a124">
        <source>doExtractHistory();

/*

Purpose:		
Parameters:		
Return Value:	

Date				Who		Reason
20 May 2009			cnwrl1	Initial creation as part of PAR 19668 - CCMS 1814 - Interface History

*/
	
vars
	theForm		: SOP_TableMaintForm;
	
begin
	app.mousePointer	:= Busy;
	
	theForm	:= self.myForm;
	if theForm.myCurrentObject = null then
		// hopefully never happens but just in case...
		return;
	endif;
	
	if   theForm.shtViewTable1.visible then
		self.myForm.doExtractTableToCSV( self.myForm.tblDataView1 );
	else
		self.myForm.doExtractTableToCSV( self.myForm.tblDataView3 );
	endif;
	
epilog
	app.mousePointer	:= Idle;
	
end;
</source>
    </JadeMethod>
