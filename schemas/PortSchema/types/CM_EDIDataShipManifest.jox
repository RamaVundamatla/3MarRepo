    <JadeMethod name="isShipManifestForLoad" id="beeadedd-bfc4-4091-aba6-529170ad20e1">
        <source>isShipManifestForLoad() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 July 2024	navra1	Initial creation for //navra1 - CR-65068/Task-64641 - Auto Comparison - 15th July 2024

*/

vars
	isLoad : Boolean;
	ediTi : CM_EDITrackedItem;
begin
	foreach ediTi in self.allEDITrackedItems do
		if ediTi.isKindOf(CM_EDICargoOnSiteTI) then
			isLoad := true;
			break;
		elseif ediTi.isKindOf(CM_EDICargoOnShipTI) then
			isLoad := false;
			break;
		endif;
	endforeach;

	return isLoad;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
