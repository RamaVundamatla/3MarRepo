    <JadeMethod name="addOutput" id="3327d4e6-6a31-4323-b1a0-1d58f44e0334">
        <source>addOutput( _str : String );

/*

Purpose:			

Parameters:		Called by sendMsg from 	CM_FixupHandlerAgent::writeOutputToMyForm to pass back the agents ouptput to this form

Return Value:		


Date		Who		Reason
05 May 2011	cnwndl1	Initial creation	Par 27438

*/

vars

	quickReference : String;
	message: String;

begin

	message := self.txtOutput.text;
	message := message &amp; _str;
	self.txtOutput.text := message;
	self.txtOutput.doWindowEvents(0);	//15 Dec 2011	NDL	Par 28855
	return;
	
	quickReference := CM_FixupHandlerAgent::writeOutputToMyForm.name;

epilog

end;
</source>
        <Parameter name="_str" type="String"/>
    </JadeMethod>
