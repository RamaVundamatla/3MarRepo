    <JadeMethod name="getEntryTableViewName" id="f61431c6-37b6-49f1-8288-3966084b4fdc">
        <source>getEntryTableViewName(): String;
/*

Purpose:			


Return Value:		


Date		Who		Reason
07 March 2008	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	return 'bgpAutoViewConflictReport';


epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getValueForRow" id="267edd25-f6cb-465d-98fa-698f80eb157e">
        <source>getValueForRow(_rowName: String; _obj: Object output): Any;
/*

Purpose:			


Return Value:		


Date		Who		Reason
07 March 2008	cnwer1	Initial creation - PAR#xxxx

*/
vars
	harbour : HMS_Harbour;
	str : String;
begin
	if _rowName = ETRow_BgpCheckToDate then
		return self.checkToDate;
	elseif _rowName = ETRow_EmailRecipient then
		return self.emailRecipient;
	elseif _rowName = ETRow_BgpHarbours then
		if self.myHarbour &lt;&gt; null then
			return self.myHarbour.code;
		endif;
	elseif _rowName = ETRow_ServerFilePath then
		return self.networkPath;
	endif;
	return inheritMethod(_rowName, _obj);


epilog

end;</source>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_obj" type="Object" usage="output"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="36f0be11-023b-478f-b6ca-c2d450291442">
        <updating/>
        <source>setForCreate(_pxyAutoTask: CM_AutoTaskConflictReport) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
07 March 2008	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	inheritMethod(_pxyAutoTask);
	self.requestClassName 	:= BGP_ConflictsReport.name;
	self.emailRecipient 	:= _pxyAutoTask.emailRecipient;
	self.checkToDate	:= _pxyAutoTask.checkToDate;
	self.networkPath	:= _pxyAutoTask.networkPath;
	self.myHarbour:=_pxyAutoTask.myHarbour;

epilog

end;</source>
        <Parameter name="_pxyAutoTask" type="CM_AutoTaskConflictReport"/>
    </JadeMethod>
