<Class name="P_ContainerController" id="f1f453b8-0bb1-44d4-b597-a3a64070e57b">
    <superclass name="P_Controller"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="pattern"/>
    <JadeMethod name="addContainer" id="48df7af9-172e-4983-9d0b-5dceb44e0213">
        <source>addContainer(_containerInfo: IContainerInfo): CM_Container;
//28 October 2009	cnwdw1	
//
vars
	pxyTI, ti: CM_TrackedItem;	
	cargoType: CM_CargoType;
	operator: CM_Operator;
	terminal: CM_Terminal;
begin
	operator := app.myRoot.allOperators[_containerInfo.getOperator];
	terminal := app.myRoot.allTerminals[_containerInfo.getTerminal];
	cargoType := app.myRoot.allCargoTypesById[TI_CargoType_Container];
	pxyTI := terminal.createTI(cargoType, true);
	pxyTI.setPxyFromDefaultTI(terminal, TI_CargoType_Container, 
				_containerInfo.getId, _containerInfo.getCommodity, operator);
	pxyTI.changeState(TI_STATE_NORMAL, app.myPassport);
	pxyTI.setISOType(_containerInfo.getISOType);
	pxyTI.setWeight(4000, null, null);
	
	app.myTrxCA.trxCreateTIWithMove(pxyTI, ti, null, app.myPassport);

	return ti.CM_Container;
end;</source>
        <Parameter name="_containerInfo" type="IContainerInfo"/>
        <ReturnType type="CM_Container"/>
    </JadeMethod>
</Class>
