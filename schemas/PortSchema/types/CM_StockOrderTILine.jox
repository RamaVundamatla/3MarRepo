    <JadeMethod name="pxyCreateUpdateProxy" id="861eeff9-13c3-4808-904a-227eae6c07ec">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     02 July 2002 by cnwsb1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// ---------------------------------------------------------------------------
vars
	pxyLine : CM_StockOrderTILine;
	completedOK		: Boolean;
	
begin
	pxyLine := inheritMethod();

	pxyLine.myTrackedItem	:= self.myTrackedItem;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyLine;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyLine;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="f9c6a60b-29fa-4606-b437-d58987d76992">
        <updating/>
        <source>setForCreate(_pxyLine: CM_StockOrderTILine) updating;
// ---------------------------------------------------------------------------
// Created:     26 June 2002 by cnwsb1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	bolOutLine				: CM_BOLOutStockOrderLineTI;
begin
	inheritMethod(_pxyLine);
	
	self.myTrackedItem := _pxyLine.myTrackedItem;
	
	create bolOutLine persistent;
	bolOutLine.setForCreate(null, self, null);

end;</source>
        <Parameter name="_pxyLine" type="CM_StockOrderTILine"/>
    </JadeMethod>
