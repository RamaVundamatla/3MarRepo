    <JadeMethod name="getFileNameFormat" id="8c52e38e-1395-4f81-ba33-ca9b65fd2e79">
        <source>getFileNameFormat(_finObject : CM_FinancialObject) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Dec 2019 cnwma1 ChangeRequest 47851: QTS - Integration with Oracle Fusion Cloud

*/

vars
	fileName : String;
begin
	if _finObject.isKindOf(CM_Invoice) then
		fileName := "ar_invoice_" &amp; _finObject.CM_Invoice.sequenceNum.padLeadingWith('0', 6);
	
	elseif _finObject.isKindOf(CM_CashReceipt) then
		fileName := "ar_receipt_" &amp; _finObject.CM_CashReceipt.getExportSequence().padLeadingWith('0', 6);
	
	elseif _finObject.isKindOf(CM_CashCredit) then
		fileName := "ar_credit_" &amp; _finObject.CM_CashCredit.getExportSequence().padLeadingWith('0', 6);
	endif;
	
	
	return fileName;
epilog

end;</source>
        <Parameter name="_finObject" type="CM_FinancialObject"/>
        <ReturnType type="String"/>
    </JadeMethod>
