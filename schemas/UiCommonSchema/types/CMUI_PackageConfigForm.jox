	chkBaplie.translateCaption(Xlat_0000611, locale);
	chkCams.translateCaption(Xlat_0007936, locale);
	chkPrefixEmailSubWithInvNo.translateBubbleHelp(Xlat_0026748, locale);
	chkPrefixEmailSubWithInvNo.translateCaption(Xlat_0026749, locale);
	chkSendToDebtorEmail.translateBubbleHelp(Xlat_0026750, locale);
	chkSendToDebtorEmail.translateCaption(Xlat_0026751, locale);
	grpBaplieDtl.translateCaption(Xlat_0000623, locale);
