	app.setContinueCMExceptions(false);

	beginTransaction;

	app.myUtilityUA.utlUpdateTaskSwitchIMV(pProxyRTQueueTask, _passport);

epilog
	self.finaliseActivityWithPassport(_passport);

end;</source>
