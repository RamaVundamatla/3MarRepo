    <JadeMethod name="load" id="8cd90a77-f3a5-4593-89aa-6806a2e1c2c8">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

begin
	app.mousePointer	:=	Busy;
	inheritMethod();
	self.loadForm();
epilog
	app.mousePointer	:=	Idle;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadForm" id="7c623d84-02ea-49de-ad7b-361a5909b487">
        <updating/>
        <source>loadForm()updating, protected;

begin
	self.centreWindow();
	
	btnVeto.visible			:=	false;
	btnFormatter.visible	:=	false;
	btnRebuild.visible		:=	false;
	btnHubble.visible		:=	false;
	cmbSchemas.visible 		:=	false;
	lblSelectSchema.visible	:=	false;
	self.populateCmbSchemas();
	btnLogIn.visible		:=	true;
	
	//upgrade code. NDL 27/10/2000
	self.doUgradeFormatsWithSchemaInfo(); 
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateCmbSchemas" id="82f62825-1e87-4fd1-96ca-f60f9a64a630">
        <source>populateCmbSchemas() protected;

vars
	schemaObj	: Schema;
	
begin
	cmbSchemas.clear();
	
	foreach schemaObj in Schema.instances do
		cmbSchemas.addItem(schemaObj.name);
	endforeach;
	
	if app.myCnEcXmlSchema &lt;&gt; null then 
		cmbSchemas.listIndex := cmbSchemas.findStringExact(1,app.myCnEcXmlSchema.name);
	else
		cmbSchemas.listIndex := 1;			
	endif;
	
	if cmbSchemas.text &lt;&gt; "" then
		app.cnEcSetXmlSchema(cmbSchemas.text);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setRebuildIsRequired" id="352421e3-79e1-46b6-92df-3a8afb3a0e3a">
        <updating/>
        <source>setRebuildIsRequired(pValue:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		11 March 2001 by cnwdad1
//
// Purpose:		Set a boolean flag to indicate whether a rebuild of the formats is
//				required.
//
// Parameters:	pValue - True if a rebuild is required.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.aIsRebuildDefFormatsRequired &lt;&gt; pValue then
		self.aIsRebuildDefFormatsRequired	:=	pValue;
	endif;
end;</source>
        <Parameter name="pValue" type="Boolean"/>
    </JadeMethod>
</GUIClass>
