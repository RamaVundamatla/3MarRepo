<Class name="CMUI_ViewLogArea2" id="0aafa368-372c-480f-b724-246d80f15183">
    <superclass name="CMUI_ViewRestrictions"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <JadeMethod name="getDataClass" id="fbd2a09b-e6de-4f26-b854-14464cb71b93">
        <source>getDataClass(): Class;

vars

begin
	return CM_LogController;
end;</source>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="setSelected" id="cfdcdac3-9362-4893-99b9-24e331535d6f">
        <source>setSelected(_restriction: CM_LocationRestriction;
		    _multiOne,
		    _multiTwo,
		    _multiThree,
		    _multiFour,
		    _multiFive,
		    _multiSix,
		    _multiSeven,
		    _multiEight: CMUI_MultiSelectGroupBox input);

vars

	log : CM_LocationRestrictLog;

begin

	log := _restriction.CM_LocationRestrictLog;
	if log &lt;&gt; null then
		//26/08/2009 cnwdz2 PAR20519
		_multiOne.setSelected(log.allOperators);
		_multiTwo.setSelected(log.allLogSpecies);
		_multiThree.setSelected(log.allLogGrades);
		_multiFour.setSelected(log.allLogTypes);
		_multiFive.setSelected(log.allLogTreatments);
		_multiSix.setSelected(log.allLogLengths);
	endif;
	

end;</source>
        <Parameter name="_restriction" type="CM_LocationRestriction"/>
        <Parameter name="_multiOne" type="CMUI_MultiSelectGroupBox" usage="input"/>
        <Parameter name="_multiTwo" type="CMUI_MultiSelectGroupBox" usage="input"/>
        <Parameter name="_multiThree" type="CMUI_MultiSelectGroupBox" usage="input"/>
        <Parameter name="_multiFour" type="CMUI_MultiSelectGroupBox" usage="input"/>
        <Parameter name="_multiFive" type="CMUI_MultiSelectGroupBox" usage="input"/>
        <Parameter name="_multiSix" type="CMUI_MultiSelectGroupBox" usage="input"/>
        <Parameter name="_multiSeven" type="CMUI_MultiSelectGroupBox" usage="input"/>
        <Parameter name="_multiEight" type="CMUI_MultiSelectGroupBox" usage="input"/>
    </JadeMethod>
</Class>
