    <JadeMethod name="cnEcGetDuplicate" id="d4404148-26de-438c-bca4-c7adaa3f3c8f">
        <source>cnEcGetDuplicate(pFormat: CnEcXmlFormat; pInput: CnEcXmlStructureInstance): Object;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 September 2014	cnwndl1	Initial creation	Par 34893

*/

vars

	code : String;
	commodity : CM_Commodity;

begin

	code := self.cnEcXMLGetTheAttributeValue( pFormat, pInput, self.class.name, "code" ).String; 
	
	if code &lt;&gt; null then
		commodity := app.myRoot.allCommodities.getAtKey( code );
	endif;

epilog

	return commodity;

end;</source>
        <Parameter name="pFormat" type="CnEcXmlFormat"/>
        <Parameter name="pInput" type="CnEcXmlStructureInstance"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="delete" id="cb448a11-86e5-4259-9c50-00ac9fad6268">
        <updating/>
        <source>delete() updating;
// cnwrs1 june 2006 was missing
vars
	
begin

	//04 Apr 2019	NDL	TFS 44194
	if app.myAlternateDict &lt;&gt; null then
		app.myAlternateDict.setCommodityDictNeedsRefresh();
	endif;
		
	self.resetAuditsDuringDelete();	//21 Jan 2021	NDL	TFS 50152
end;</source>
    </JadeMethod>
    <JadeMethod name="displayForXlation" id="352d4326-fd74-4e02-8fad-2e9035cbf7f5">
        <source>displayForXlation(_codeFirst : Boolean) : String;

vars

begin
	if _codeFirst then
		return self.code.trimBlanks&amp;' ['&amp;self.description.trimBlanks&amp;']';
	else
		return self.description.trimBlanks&amp;' ['&amp;self.code.trimBlanks&amp;']';
	endif;
end;
</source>
        <Parameter name="_codeFirst" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="erase" id="508928d4-68b4-4c35-9040-308e56c5a138">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;

// 25/03/2013	cnwcs5	CCMS POL 2097 / par 31259
vars

begin
	self.exclusiveLock(self);

	self.eraseXlations (self.allXlations, NORMAL_ERASE);
	
	inheritMethod(_eraseLevel);
end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDisplayDetails" id="1b9b4f68-5312-4ec2-8d2d-07d930fdb0b3">
        <source>getDisplayDetails(_short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     Aug 2004	cnwrs1
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------

vars

begin
	if _short then
		return self.code;
	else
		return '('&amp;self.code&amp;')  '&amp;self.description;
	endif;
end;</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="fdb5a9e4-8043-4079-9f94-a6e93e10f2b6">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     30 May 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 14 Apr 2014	cnwdb2		PAR #33977  
// ---------------------------------------------------------------------------
vars

begin

	if _attrName = ETRow_SpecialStow then
		if self.mySpecialStow &lt;&gt; null then
			return self.mySpecialStow.description;
		endif;
		return null;
		
	elseif _attrName = ETRow_RequiresWeighing then
		return self.requiresWeighing.getYesNo();
		
	endif;
	
	return inheritMethod(_attrName, _short);
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
