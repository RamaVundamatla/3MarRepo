    <JadeMethod name="centreHorizontallyInParent" id="f1d26207-5fce-4b0b-8f9d-3e4f37af9f93">
        <updating/>
        <source>centreHorizontallyInParent() updating;

begin
	if parent &lt;&gt; null then 
		self.left := (parent.width - self.width)/2;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="centreVerticallyInParent" id="e80ffe3e-f70c-4049-85d3-333095ebac8e">
        <updating/>
        <source>centreVerticallyInParent() updating;

begin
	if parent &lt;&gt; null then 
		top := (parent.height - height) / 2;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="getHorizontalOffset" id="8cb3c9f3-e038-4704-ab34-8f5146ad7811">
        <source>getHorizontalOffset(offsetType: Integer): Real;

vars
	offset:            Real;
	persistObj:        Window;
	parentPersistObj:  Window;
begin
	persistObj := getPersistentObject();
	parentPersistObj := parent.getPersistentObject();

	if offsetType = Horizontal_Offset_Left_Edge then
		offset := persistObj.left;
	elseif offsetType = Horizontal_Offset_Right_Edge then
		offset := parentPersistObj.width - (persistObj.left + persistObj.width);
	elseif offsetType = Horizontal_Offset_Centre then
		offset := (parentPersistObj.width / 2) - ( persistObj.left + (persistObj.width / 2) );
	endif;

	return offset;
end;</source>
        <Parameter name="offsetType" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getHorizontalOffsetType" id="9577d348-50a1-4e08-ab2f-44996ece1cc8">
        <source>getHorizontalOffsetType(): Integer;

vars
	offsetType:        Integer;
	leftEdgeOffset:    Real;
	centralOffset:     Real;
	rightEdgeOffset:   Real;
	offset:            Real;
	persistObj:        Window;
	parentPersistObj:  Window;
begin
	persistObj := getPersistentObject();
	parentPersistObj := parent.getPersistentObject();

	leftEdgeOffset := persistObj.left;

	// offset from centre of parent to centre of control
	//    = (centre point of parent) - (centre point of control in parent)
	centralOffset := (parentPersistObj.width / 2) - ( leftEdgeOffset + (persistObj.width / 2) );

	rightEdgeOffset := parentPersistObj.width - leftEdgeOffset - persistObj.width;

	// now compare absolute values
	offset := leftEdgeOffset.abs();
	offsetType := Horizontal_Offset_Left_Edge;

	if rightEdgeOffset.abs() &lt;= offset then
		offset := rightEdgeOffset.abs();
		offsetType := Horizontal_Offset_Right_Edge;
	endif;

	// lets leave out the central thing for the moment
	/*
	if centralOffset.abs() &lt;= offset then
		offset := centralOffset.abs();
		offsetType := Horizontal_Offset_Centre;
	endif;
	*/

	return offsetType;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getParentDepth" id="4a9c1984-3b1c-4ee1-9b78-524291ee5b32">
        <source>getParentDepth(): Integer;

begin
	if parent.isKindOf(Control) then
		return (parent.Control.getParentDepth() + 1);
	else
		return 1;
	endif;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getVerticalOffset" id="9b75543f-18a8-4654-8881-a2222db2dfb5">
        <source>getVerticalOffset(offsetType: Integer): Real;

vars
	offset:            Real;
	persistObj:        Window;
	parentPersistObj:  Window;
	menuCorrection:  Real;
begin
	persistObj := getPersistentObject();
	parentPersistObj := parent.getPersistentObject();

	if parent.isKindOf(Form) then
		menuCorrection := (parent.getPersistentObject().height - parent.getPersistentObject().Form.clientHeight) - (parent.height - parent.Form.clientHeight);
	endif;

	if offsetType = Vertical_Offset_Top_Edge then
		offset := persistObj.top;
	elseif offsetType = Vertical_Offset_Bottom_Edge then
		offset := parentPersistObj.height - (persistObj.top + persistObj.height) - menuCorrection;
	elseif offsetType = Vertical_Offset_Centre then
		offset := (parentPersistObj.height / 2) - ( persistObj.top + (persistObj.height / 2) );
	endif;

	return offset;
end;</source>
        <Parameter name="offsetType" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getVerticalOffsetType" id="95836570-a537-42e4-8a85-97278b2f7f92">
        <source>getVerticalOffsetType(): Integer;

vars
	offsetType:        Integer;
	topEdgeOffset:     Real;
	centralOffset:     Real;
	bottomEdgeOffset:  Real;
	offset:            Real;
	persistObj:        Window;
	parentPersistObj:  Window;
begin
	persistObj := getPersistentObject();
	parentPersistObj := parent.getPersistentObject();

	topEdgeOffset := persistObj.top;

	// offset from centre of parent to centre of control
	//    = (centre point of parent) - (centre point of control in parent)
	centralOffset := (parentPersistObj.height / 2) - ( topEdgeOffset + (persistObj.height / 2) );

	bottomEdgeOffset := parentPersistObj.height - topEdgeOffset - persistObj.height;

	// now compare absolute values
	offset := topEdgeOffset.abs();
	offsetType := Vertical_Offset_Top_Edge;

	if bottomEdgeOffset.abs() &lt;= offset then
		offset := bottomEdgeOffset.abs();
		offsetType := Vertical_Offset_Bottom_Edge;
	endif;

	// lets leave out the central thing for the moment
	/*
	if centralOffset.abs() &lt;= offset then
		offset := centralOffset.abs();
		offsetType := Vertical_Offset_Centre;
	endif;
	//*/

	return offsetType;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setBackForeColor" id="8794aba2-c839-4701-a99d-97681a51a31a">
        <updating/>
        <source>setBackForeColor(_backColor: Integer; _foreColor: Integer) updating;
/*
	Created on 02 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	inheritMethod(_backColor, _foreColor);
	self.foreColor	:=	_foreColor;
end;</source>
        <Parameter name="_backColor" type="Integer"/>
        <Parameter name="_foreColor" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setPositionLeftFromType" id="9ee4f820-3355-424f-a2fe-2f0a845057ea">
        <updating/>
        <source>setPositionLeftFromType(offset: Real; offsetType: Integer) updating;

begin
	if offsetType = Horizontal_Offset_Left_Edge then
		// offset is distance from left edge of parent to left edge of control
		left := offset;
	elseif offsetType = Horizontal_Offset_Right_Edge then
		// offset is distance from right edge of parent to right edge of control
		left := parent.width - (offset + width);
	elseif offsetType = Horizontal_Offset_Centre then
		// offset is distance from centre of parent to centre of control
		left := (parent.width / 2) - ( offset + (width / 2) );
	else
		// invalid horizontal offset type...
		app.writeStatement( "invalid horizontal offset type: " &amp; offsetType.String);
	endif;
end;</source>
        <Parameter name="offset" type="Real"/>
        <Parameter name="offsetType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setPositionTopFromType" id="1d15bcf0-1143-4632-bd31-6b6bc73ce989">
        <updating/>
        <source>setPositionTopFromType(offset: Real; offsetType: Integer) updating;

begin
	if offsetType = Vertical_Offset_Top_Edge then
		// offset is distance from top edge of parent to top edge of control
		top := offset;
	elseif offsetType = Vertical_Offset_Bottom_Edge then
		// offset is distance from bottom edge of parent to bottom edge of control
		top := parent.height - offset - height;
	elseif offsetType = Vertical_Offset_Centre then
		// offset is distance from centre of parent to centre of control
		top := (parent.height / 2) - ( offset + (height / 2) );
	else
		// invalid vertical offset type...
		app.writeStatement( "invalid vertcal offset type: " &amp; offsetType.String);
	endif;
end;</source>
        <Parameter name="offset" type="Real"/>
        <Parameter name="offsetType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setSizeAndPosition" id="a793c624-36b3-4bdf-a27a-cc023f3927a7">
        <updating/>
        <source>setSizeAndPosition() updating;

vars
	offsetType:  Integer;
	offset:      Real;
begin
	if relativeHeight then
		setSizeHeight();
	else
		height := getPersistentObject.height;
	endif;

	if relativeWidth then
		setSizeWidth();
	else
		width := getPersistentObject.width;
	endif;

	if relativeLeft then
		offsetType := getHorizontalOffsetType();
		offset := getHorizontalOffset(offsetType);
		setPositionLeftFromType(offset, offsetType);
	endif;

	if relativeTop then
		offsetType := getVerticalOffsetType();
		offset := getVerticalOffset(offsetType);
		setPositionTopFromType(offset, offsetType);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setSizeHeight" id="b6f9a14f-86a4-4f33-a3e4-84f95dda39bd">
        <updating/>
        <source>setSizeHeight() updating;

vars
	menuCorrection:  Real;
begin
	if parent.isKindOf(Form) then
		menuCorrection := (parent.getPersistentObject().height - parent.getPersistentObject().Form.clientHeight) - (parent.height - parent.Form.clientHeight);
	endif;

	height := parent.height - (parent.getPersistentObject().height - getPersistentObject().height) + menuCorrection;
end;</source>
    </JadeMethod>
    <JadeMethod name="setSizeWidth" id="c2d3574c-3dfb-4b0f-a079-0273f24bce1d">
        <updating/>
        <source>setSizeWidth() updating;

begin
	width := parent.width - (parent.getPersistentObject().width - getPersistentObject().width);
end;</source>
    </JadeMethod>
    <JadeMethod name="writeParents" id="b7b30162-18ce-4a95-b686-d13d4976f027">
        <source>writeParents( parentString : String io );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 January 2012	cnwndl1	Initial creation

*/

vars

	parent : Window;

begin

	if self.parent = null then
		write parentString;
		return;
	endif;

	if self.parent.class.inheritsFrom(Control) then
		parentString := parentString &amp; CrLf &amp; self.parent.String;
		self.parent.Control.writeParents( parentString );
		return;
	endif;
	
	write parentString;

epilog

end;</source>
        <Parameter name="parentString" type="String" usage="io"/>
    </JadeMethod>
</GUIClass>
