        <source>utlDeleteXlation(_xlation :CM_Xlation io; _passport : CM_Passport input);
/*
Date		Who		Reason
16 Dec 2008	conks1	Initial creation
12/03/2013	cnwcs5	CCMS POL 2097 / par 31259
*/
vars

begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);

	app.myValDA.valXlation(_xlation);

