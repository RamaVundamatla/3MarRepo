    <JadeMethod name="doBtnCancelClick" id="3f8acf91-1a21-40c8-be62-5e7cd9dc4cea">
        <updating/>
        <source>doBtnCancelClick() updating;
// ---------------------------------------------------------------------------
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//18/10/17 jlgns1 TFS 7115 PKT - Vehicle visit dispute occurs at GATE OUT
// ---------------------------------------------------------------------------

vars
	form: 		GTE_VehicleTurnaroundReason;
	result:		Integer;
		realVVR : CM_VehicleVisitRecord;
begin
	
	
	if not app.myCurrentUserCan(self.myTerminal, PmGteBulkOutMaint) then
		return;
	endif;
	
	realVVR := getVvrFromTable();
	
	self.myBulkGateAgent.myRealVVR := realVVR;
	 
	if realVVR = null then
		return;
	endif;
	

	
	form := app.loadForm(GTE_VehicleTurnaroundReason, 
							GTE_Assistant, 
							false, false, true, 
							self.myTerminal, null).GTE_VehicleTurnaroundReason;
	result := form.showModal();
	if result = IDOK then
		if realVVR.myRoadJob = null and realVVR.isUpdatable and not realVVR.isCancelled then		
			self.doVehicleVisitCancel(form.txtReason.text);
		else	
			if  realVVR.status = CM_VehicleVisitRecord.Status_Unverified then
				if realVVR.myRoadJob = null then
						
					self.doUpdateChangeStatus();
				else
					self.deleteCurrentJobEntry(form.txtReason.text);
				endif;
			endif;
		endif;
	else
		return;
	endif;	
	
	
	self.clearForm();
	self.txtRegno.setFocus();			

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnGetWeightClick" id="1933c889-d954-482e-9278-bf5f0b969daa">
        <updating/>
        <source>doBtnGetWeightClick() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 March 2017	cnwns1	Initial creation
19 April 2018	jlgns1 Bug 38134: PKT - Weight Discrepancy
*/

vars
	newWeight 		: Decimal[16,4];
	hasTimedOut 	: Boolean;
	timeOutSeconds 	: Integer;
begin

	if self.mySerialWeightIntController &lt;&gt; null then	//19 Jul 2021	NDL	TFS 51575
	
		timeOutSeconds := self.myBulkGateAgent.myWeighBridge.timeOutSeconds;											//Bug 38134
		
		newWeight :=self.mySerialWeightIntController.getLatestWeight(app.actualTimeServer, hasTimedOut,timeOutSeconds);	//Bug 38134
		
		self.lblWeighbridgeMessage.caption := self.mySerialWeightIntController.latestReturnValue &amp; self.mySerialWeightIntController.latestWeightSetAt.time.formatAsHHMMSSmmm;	//Bug 38134
			
		self.txtWeightOUT.setValue(newWeight);
		
		self.myBulkGateAgent.setRetrievedWeight(newWeight);
		
		self.setWeighbridgeLabel(hasTimedOut);																			//Bug 38134
		
		self.getCargoWeight();
	
	//19 Jul 2021	NDL	TFS 51575
	elseif self.myOtherWeightIntController &lt;&gt; null and self.myOtherWeightIntController.myConnection &lt;&gt; null then
	
		self.setWeighbridgeLabel(false);
		self.myOtherWeightIntController.closeConnection();					//to be sure that Connection is closed
		
		if self.myOtherWeightIntController.testMode &gt; 0 then
			//development only process, to allow testing to follow the process without a real weighbridge
			on ConnectionException do self.handleSpecialDevNoConn( exception );
		endif;
		
		self.myOtherWeightIntController.doOpen();
		
		//will only do this bit if it doesn't get an exception ( or is handled by the local one above, i.e. a dev env no connection )
		self.setWeighbridgeLabel(false);
		
	endif;
		
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildGateCombo" id="e1d1556b-5b5c-4c80-87b5-8bf5675a3e87">
        <updating/>
        <source>doBuildGateCombo() protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason

*/

vars
	gate 		: CM_Gate;
	gateArea 	: CM_GateArea;
	gateAreaUsage : CM_GateAreaUsage;
begin

	self.cmbGate.clear();
	foreach gate in self.myTerminal.allGates do
		if gate.hasPGateAreas_OUT then
			gateAreaUsage := gate.allGateAreas_OUT.first();
			if gateAreaUsage &lt;&gt; null then
				gateArea := gateAreaUsage.myGateArea;
				if gateArea &lt;&gt; null then
					self.cmbGate.addItemObject(gate.name, gate);
				endif;
			endif;
		endif;
	endforeach;
	
	if self.myTerminal.allGates.size() &gt; 0 then	
		self.setDefaultGate();																		
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
