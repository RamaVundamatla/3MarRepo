    <JadeMethod name="getValueForObject" id="04ee7857-aa81-4181-ab36-66cc95d509fa">
        <source>getValueForObject(_obj: Object; _op: CM_QueryOperator input): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 20 August 2014	cnwdap1		Initial creation PAR #33235 
//
vars
	pos 		: Integer;
	propName 	: String;
	measure 	: String;
	prop		: Property;
	value 		: Decimal [22,10];

begin
	pos := self.propertyName.pos(CN_UNDERSCORE, 1);
	if pos = null then
		return inheritMethod(_obj, _op);
	endif;
	
	measure := self.propertyName[1:pos-1];		// get measurement type from prefix
	propName := self.propertyName[pos+1:end]; 	// remove measurement type prefix to get property name
	prop := _obj.class.getPropertyInHTree(propName);
	if prop &lt;&gt; null then
		value := _obj.getPropertyValue(propName).Decimal;
	else
		value := _obj.sendMsgWithParams(propName).Decimal;
	endif;
	return app.convertMeasurementForDisplay(measure, value);// &amp; Space &amp; measure;
epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
        <ReturnType type="Any"/>
    </JadeMethod>
