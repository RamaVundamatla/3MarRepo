    <JadeMethod name="isValidForGenSet" id="1467622a-46eb-470e-b12e-45c3a45e1b25">
        <source>isValidForGenSet( _theTI : CM_Object ) : Boolean;
/* ---------------------------------------------------------------------------
Created:	25 August 2008	by cnwvu1

Purpose:	Par 17775. ccms1045.
			It task Generator Set Attachment is active, Generator Set Detachment
			should be hidden when adding a task. And vice versa.
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	task	: CM_ToDoTask;
	found	: Boolean;
	genSetAttached : Boolean;
	
begin

	if not self.isForGenSetAttachDetach() then
		return true;	//all other To Do Tasks are valid all the time
	endif;

	if _theTI.isKindOf(CM_TIMaster) then
		return self.isValidForGenSetTIMaster(_theTI.CM_TIMaster);
		
	elseif _theTI.isKindOf(CM_TrackedItem) then
		return self.isValidForGenSetTI(_theTI.CM_TrackedItem);
		
	else
		return false;	// Attach/Detach Generator not visible for other classes
		
	endif;
	
end;</source>
        <Parameter name="_theTI" type="CM_Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isValidForGenSetTI" id="ab4b1675-1391-4aae-814d-331da8cf4378">
        <source>isValidForGenSetTI( _theTI : CM_TrackedItem ) : Boolean protected;
/* ---------------------------------------------------------------------------
Created:	21 January 2009	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	task	: CM_ToDoTask;
	found	: Boolean;
	genSetAttached : Boolean;

begin

	if _theTI.isKindOf(CM_Container) and not _theTI.CM_Container.isReefer then	//Par18227
		return false;	//for non reefers GenSet Attach/Detach are always not valid - not visible
	endif;
	
	//Further validation depends on ti type and generator atached/detached
	foreach task in _theTI.allToDoTasksToDo do

		if task.toDoTaskDesc &lt;&gt; null and		// Nov 2011 from cargo enquiry testing
		   task.toDoTaskDesc.isForGenSetAttachDetach() then
			found := true;
			if task.toDoTaskDesc &lt;&gt; self then
				return false;	// there is another of the pair already active
			endif;
		endif;
		
	endforeach;

	if found then	// there is only one To Do Task for Generator attaching/detaching, and it cannot be added once again
		return false;
	endif;
	
	// no one found. So, Generator Set attached or Generator Set Detached are visible according to genSet attached.
	if _theTI.isKindOf( CM_Container ) then
		genSetAttached := _theTI.CM_Container.getGenerator &lt;&gt; null;
		
	elseif _theTI.isKindOf( CM_TILC ) then
		genSetAttached := _theTI.CM_TILC.myGenerator &lt;&gt; null;
		
	else
		return false;	// unknown ti type
	endif;
	
	// to disable / enable To Do Tasks
	if self.trxTypeOnCompletion = TRANS_TYPE_AttachGenerator then
		if genSetAttached then
			return false;
		else
			return true;
		endif;
		
	elseif self.trxTypeOnCompletion = TRANS_TYPE_DetachGenerator then
		if genSetAttached then
			return true;
		else
			return false;
		endif;
	
	else	// unknown trxType
		return false;
	
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isValidForGenSetTIMaster" id="52ec2c2e-2ce2-46b3-b01b-d618714a344b">
        <source>isValidForGenSetTIMaster( _tiM : CM_TIMaster ) : Boolean protected;
/* ---------------------------------------------------------------------------
Created:	21 January 2009	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	taskDesc	: CM_ToDoTaskDesc;
	found		: Boolean;
	
begin

	if not _tiM.canHaveGeneratorAttached() then
		return false;
	endif;
	
	//Further validation depends on ti type and generator atached/detached
	foreach taskDesc in _tiM.allToDoTaskDesc do

		if taskDesc.isForGenSetAttachDetach() then
			found := true;
			if taskDesc &lt;&gt; self then
				return false;	// there is another of the pair already active
			endif;
		endif;
		
	endforeach;

	if found then	// there is only one To Do Task for Generator attaching/detaching, and it cannot be added once again
		return false;
	endif;
	
	return true;

end;</source>
        <access>protected</access>
        <Parameter name="_tiM" type="CM_TIMaster"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="5d4c94c4-1413-4a04-97b2-87d16c2b12b6">
        <source>pxyCreateUpdateProxy(): SelfType;
// -------------------------------------------
// Created 12 December 2005 by cnwdvb1
// -------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when trying to create the proxy
// 31 Oct 2022  navma1 		ChangeRequest 56634[54259]: EUP - Todo Task Description Maintenance

vars

	toDo			: SelfType;
	completedOK		: Boolean;
	taskCrit,
	pxyTaskCrit		: CM_TaskCriteria;
	
begin
	
	toDo :=	 inheritMethod();
	
	toDo.myTransactionType := self.myTransactionType;
	toDo.myEventType 		:= self.myEventType; 			// ### TFS #56634[54259] 28NOV2022 NAVAB1 
	
	self.allCargoTypes.copy(toDo.allCargoTypes);
	self.allResourceTypes.copy(toDo.allResourceTypes);		//18 Dec 2009	NDL	CCMS MES 1006
	
	//14 Oct 2010	NDL Par 23991
	if not self.allAllowedEditSubTerms.isEmpty then
		self.allAllowedEditSubTerms.copy(toDo.allAllowedEditSubTerms);	
	endif;
	if not self.allAllowedReleaseTerms.isEmpty then
		self.allAllowedReleaseTerms.copy(toDo.allAllowedReleaseTerms);	
	endif;	
	
	if not self.allTaskCriteria.isEmpty() then	// TFS 2443
		foreach taskCrit in self.allTaskCriteria do
			pxyTaskCrit := taskCrit.pxyCreateUpdateProxy;
			pxyTaskCrit.setProxyBaseData(taskCrit.allAutoApplyActions, taskCrit.moveOnCompletion, taskCrit.moveOnCreation, taskCrit.myTerminal, toDo,
											taskCrit.allAvailableResourceGroups, taskCrit.allMandatoryResourceGroups	// ### TFS 58761 (60739) 16Nov2023 NAVPW1
											);
		endforeach;
	endif;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return toDo;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete toDo;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setAllAllowedEditSubTerms" id="99658bcf-7ee5-44d6-88ea-62b6d84ea34c">
        <updating/>
        <source>setAllAllowedEditSubTerms( _allSubTerminals : CM_SubTerminalByCodeDict )updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 October 2010	cnwndl1	Initial creation	Par 23991 - for data migration

*/

vars

begin

	self.allAllowedEditSubTerms.clear();
	if not _allSubTerminals.isEmpty then
		_allSubTerminals.copy( self.allAllowedEditSubTerms );
	endif;
	
epilog

end;</source>
        <Parameter name="_allSubTerminals" type="CM_SubTerminalByCodeDict"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="25244016-6db9-4195-94d4-9307069a15e9">
        <updating/>
        <source>setForCreate(pProxyToDoTaskDesc : CM_ToDoTaskDesc) updating;

vars
	maxTask			: CM_ToDoTaskDesc;
	user 			: CM_User;
	userTerminal	: CM_UserTerminal;
	termSecRole 	: CM_SecurityRole;
	
begin
	pProxyToDoTaskDesc.raiseExceptionIfNotTransient(method);
	self.setForUpdate(pProxyToDoTaskDesc);
	
	maxTask := app.myRoot.allToDoTaskDescriptions.last();
	
	if maxTask = null then
		self.code := 1;
	else
		self.code := maxTask.code + 1;
	endif;
	
	self.sortKey	:=	pProxyToDoTaskDesc.sortKey;

	self.myRoot := app.myRoot;
	
	//app.myRoot.mySecurityRoleTerminal.addToDoTaskToRootRole(self);
	// 22/01/2016 cnwar2 #37414 - now add to user's role and all roles above this
	user := app.myPassport.myUser;
	foreach userTerminal in user.allUserTerminals do
	
		termSecRole := userTerminal.mySecurityRole;
		while termSecRole &lt;&gt; null do
			if (not termSecRole.allToDoTasksAddRemove.includes(self)) then
				termSecRole.allToDoTasksAddRemove.add(self);
			endif;
			if (not termSecRole.allToDoTasksComplete.includes(self)) then
				termSecRole.allToDoTasksComplete.add(self);
			endif;
			
			termSecRole := termSecRole.myParentRole;
		endwhile;
		
	endforeach;

end;</source>
        <Parameter name="pProxyToDoTaskDesc" type="CM_ToDoTaskDesc"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="31ebce5f-0936-43a0-ac8d-2560eab3fad3">
        <updating/>
        <source>setForUpdate(pProxyToDoTaskDesc : CM_ToDoTaskDesc) updating;
/*
02 Nov 2022 navds20 ChangeRequest 56634[54259]: EUP - Todo Task Description Maintenance
11 Dec 2023	jlizm1	TFS 61654 CUX ToDo Task don't block RTL
*/
vars
	resourceType : CM_Object;
begin
	self.description			:=	pProxyToDoTaskDesc.description.trimBlanks;
	self.shortDescription		:=	pProxyToDoTaskDesc.shortDescription.trimBlanks;
	self.reportDescription		:=	pProxyToDoTaskDesc.reportDescription;
	self.emptyReportColumn		:=	pProxyToDoTaskDesc.emptyReportColumn;
	self.trxTypeOnCompletion	:=	pProxyToDoTaskDesc.trxTypeOnCompletion;
	self.trxTypeOnCreation 		:= pProxyToDoTaskDesc.trxTypeOnCreation; 			//cnwrs1 CCMS 1826 29 July 2010
	self.myTransactionType      :=  pProxyToDoTaskDesc.myTransactionType;
	self.myEventType			:=  pProxyToDoTaskDesc.myEventType;					//02/11/2022 navds20 TFS  #56634[54259]
	self.requiresWorkOrder		:=  pProxyToDoTaskDesc.requiresWorkOrder;			//+cnwml2 SFW CCMS 1075
	self.type					:= pProxyToDoTaskDesc.type;							//02/11/2022 navds20 TFS  #56634[54259]
	self.doNotBlockRTL			:= pProxyToDoTaskDesc.doNotBlockRTL;
	
	
	self.setRequiredExtraInfo(pProxyToDoTaskDesc.requiredExtraInfo);    			//19 Feb 2010	#cnwdz2	par22432 SFW 1071
	
	if pProxyToDoTaskDesc.sortKey &lt;&gt; self.sortKey then
		self.sortKey	:=	pProxyToDoTaskDesc.sortKey;
	endif;
	
	self.allCargoTypes.clear();
	pProxyToDoTaskDesc.allCargoTypes.copy(self.allCargoTypes);
	
	//18 Dec 2009	NDL	CCMS MES 1006
	self.allResourceTypes.clear();
	foreach resourceType in pProxyToDoTaskDesc.allResourceTypes do
		self.allResourceTypes.add(resourceType);
	endforeach;
	
	//14 Oct 2010	NDL Par 23991
	self.allAllowedEditSubTerms.clear();
	if not pProxyToDoTaskDesc.allAllowedEditSubTerms.isEmpty then
		pProxyToDoTaskDesc.allAllowedEditSubTerms.copy(self.allAllowedEditSubTerms);	
	endif;
	self.allAllowedReleaseTerms.clear();
	if not pProxyToDoTaskDesc.allAllowedReleaseTerms.isEmpty then
		pProxyToDoTaskDesc.allAllowedReleaseTerms.copy(self.allAllowedReleaseTerms);	
	endif;	

epilog

end;</source>
        <Parameter name="pProxyToDoTaskDesc" type="CM_ToDoTaskDesc"/>
    </JadeMethod>
