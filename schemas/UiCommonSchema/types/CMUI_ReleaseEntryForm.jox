end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="91527fd7-0b1f-4623-b7c8-0b63e10d296a">
        <updating/>
        <source>doSave() : Boolean updating;
//--------------------------------------------------
// Created:	10 February 2006 By: cnwgd1
//--------------------------------------------------
vars
	intFaceObject	: CMIF_BulkRelease;
	result			: Integer;
	newRelease		: CM_BulkRelease;
begin
	if self.trackedItemDetailsChanged and (not self.checkDoAbandonTIChanges()) then
		return false;
	endif;
	
	create intFaceObject as CMIF_BulkReleaseTIs transient;	
	
	if (not self.setIntFaceObject(intFaceObject)) then
		return false;
	endif;
	
	while true do
		//epr par 30703 15/11/12 - after warnig reset release back to txt
		/*
			beacuse trx aborted the next auto generated no is the old value
			by setting it back to what it was will force it to go get the release number again
			and this will stop the duplicate vehicle visit errors later
		*/
		intFaceObject.releaseNo := self.txtGatePass.text;
		
		app.myTrxCA.trxCreateBulkReleaseCMIF_BR(intFaceObject, newRelease, app.myPassport);
		if app.myPassport.trxCompletedOK then
			break;
		else
			result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			
		endif;
		return false;
	endwhile;

	return true;
	
epilog

	delete intFaceObject;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSelectTI" id="e653f5a5-d2f9-4ba9-837f-0dcdfa6f958c">
        <updating/>
        <source>doSelectTI(_ti : CM_TrackedItem) updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	26 March 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	foundIdx			: Integer;
begin
	self.trackedItemDetailsChanged := false;
	self.mySelectedTI := _ti;
	
	if _ti = null then
		return;
	endif;

	self.txtCommodity.text 	:= _ti.getCommodityDesc();
	self.txtCommodity.enabled := false;
	self.txtQuantity.text 	:= _ti.totalQuantity.String;
	self.txtVolume.text 	:= _ti.getMyTotalVolume.String;
	//self.txtWeight.text 	:= _ti.weight.asStringWeightJMT();					//-cnwml2 MSL CCMS 1017
	self.txtWeight.text 	:= _ti.totalWeight.asStringWeightJMT();				//+cnwml2 MSL CCMS 1017
	
	if _ti.myCargoType.allowDuplicates then
		self.txtQuantity.enabled := true;
		self.txtVolume.enabled := true;
		self.txtWeight.enabled := true;
	else
		self.txtQuantity.enabled := false;
		self.txtVolume.enabled := false;
		self.txtWeight.enabled := false;
	endif;
	
	self.txtDescription.text := _ti.description;
	self.txtMark.text 		:= _ti.mark;
	self.txtMarkNumber.text	:= _ti.markNumber;
	
	foundIdx := self.cmbTI.findString(1, _ti.id);
	if foundIdx &gt; 0 then
		self.cmbTI.text := _ti.id;
	else
		self.cmbTI.text := null;
	endif;
	

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getDrivers" id="59049cc7-91ab-43d6-ac22-05d5363a4c7d">
        <source>getDrivers();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
20 June 2024		jlizm1	Initial creation TFS 63908 Allow duplicate driver names

*/

vars
	driver 			: CM_DriverDetails;
	currentDriver 	: CM_DriverDetails;
	driverSet 		: CM_DriverDetailsSet;
	
begin
	if not self.myTerminal.getConfig(AllowDupDriverNames).Boolean then
		return;
	endif;
	
	if self.txtReceivedBy.text.trimBlanks() = null then
		self.showHideDriverCode(false);
		return;
	endif;
	
	create driverSet transient;
	self.myTerminal.findDriversWithName(self.txtReceivedBy.text.trimBlanks(), driverSet);
	
	if driverSet.size &lt; 2 then
		self.showHideDriverCode(false);
		return;
	endif;
	
	if self.cmbDriverCode.listObject &lt;&gt; null then
		currentDriver := self.cmbDriverCode.listObject.CM_DriverDetails;
	endif;
	
	self.cmbDriverCode.listCollection(driverSet, false, ComboBox.DisplayCollection_Forward);
	
	if currentDriver &lt;&gt; null then
		self.cmbDriverCode.setIndexFromObject(currentDriver);
	endif;
	
	self.showHideDriverCode(true);
	
epilog
	delete driverSet;
	
end;</source>
    </JadeMethod>
