    <JadeMethod name="isoTypeIsSameGroupAs" id="b8ee3e8c-21e9-4ec1-b6de-fef1a68c98c7">
        <source>isoTypeIsSameGroupAs(_isoType: CM_ISOType): Boolean;
// ---------------------------------------------------------------------------
// Created:		22 April 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	myISOType : CM_ISOType;
begin
	
	myISOType := app.myRoot.allISOTypes[self.isoType];
	if myISOType = null then
		return false;	//don't know
	else
		return myISOType.isSameGroup(_isoType);		//yes or no
	endif;
	
end;</source>
        <Parameter name="_isoType" type="CM_ISOType"/>
