    <JadeMethod name="pxyCreateUpdateProxy" id="607bd54b-e921-4c7b-9c35-242035fa45a7">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:		October 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	 pxyMe : SelfType;
	 completedOK		: Boolean;
begin
	pxyMe :=  inheritMethod();
	
	pxyMe.myBank := self.myBank;
	pxyMe.myDebtor := self.myDebtor;
	pxyMe.myInvoiceLineDesc := self.myInvoiceLineDesc;
	pxyMe.myInvoiceType := self.myInvoiceType;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyMe;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyMe;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
