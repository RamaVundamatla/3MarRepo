    <JadeMethod name="getDisplayStringForAttribute" id="84dd998d-6c9c-4916-88bf-0dc37431a78f">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//--------------------------------------------------
// Created:	16 September 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	if _attrName = ETRow_VesselName then
		return null;
	elseif _attrName = ETRow_MoveType
	or _attrName = ETRow_OccursOnDT then
		if self.myMovement &lt;&gt; null then
			return self.myMovement.getDisplayStringForAttribute(_attrName, _short);
		elseif self.myHMSVoyageData &lt;&gt; null then
			return self.myHMSVoyageData.getTimePeriod();
		endif;
		return null;		
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
