	self.initDataExtractField(_fields, CM_Container.name, "planningState", fieldName, STRING, "Planning State", "The current planned state of a container if it has a planned location", STRING, "0 - not planned, 1 - Notified, 2 - Received State, 3 - Planned Load State, 4 - Loaded ,5 - Planned Discharge State, 6 -  Discharged,7 - Delivered, 8 - Planned Shift State, 9 - Shifted State");

