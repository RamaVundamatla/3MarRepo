    <JadeMethod name="trxCreateLogScalingData" id="ce2bf84e-6c4f-41ee-8d9e-ccdef0ee689b">
        <updating/>
        <source>trxCreateLogScalingData(_proxyHdr:CM_LogScalingHdr input; _passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 12 April 2002 By: cnwgd1
//--------------------------------------------------------------
// 11/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
vars
	st	: Integer;
	ext			: CM_BOLExtLogIn;
	logDocket 	: CM_BOLIn;
	isMatched	: Boolean;

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(true);
	
	_proxyHdr.resetAverages();
	_proxyHdr.validateForCreate();

	endLoad;

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	// Done in this way so that we don't hold the lock on the collection for
	// the duration of the transaction
	beginLoad;
	logDocket := _proxyHdr.getMatchingBOL();
	endLoad;

	_passport.useTITransactionDeferUpdate := true;
	_passport.useTIDictDeferUpdate := true;

	// Start the transaction
	app.writeLog(method.name &amp; '  start with BOL ' &amp; _proxyHdr.bolNumber, LogINFO);
	st := app.clock;

	// First transaction to add data and match if can
	beginTransaction;
	
	isMatched := _proxyHdr.attemptMatch(logDocket,false, _passport);   //epr TFS 3769 3/4/17
 
	//  PAR 20627 - change to single begin/commmit so warnings can be handled correctly
	//if _passport.noErrors then
	//	_passport.doDeferredUpdates();
	//endif;
	
	if _passport.hasErrorsOrWarnings then
		return;
	endif;

	//  PAR 20627 - change to single begin/commmit so warnings can be handled correctly
	//app.cmsCommitTransaction(_passport);
	
	if isMatched then
		// DVB 02/02/04 Need to reset these attributes here because
		// doDeferredUpdates sets them to false.
		_passport.useTITransactionDeferUpdate := true;
		_passport.useTIDictDeferUpdate := true;
		ext := logDocket.myExtension.CM_BOLExtLogIn;
		
		// second transaction here to move to location
		//beginTransaction;				//  PAR 20627 - change to single begin/commmit so warnings can be handled correctly
		ext.completeRoadInProcessForBOL(_passport);
	else
		// so that finalize works correctly
		//beginTransaction;				//  PAR 20627 - change to single begin/commmit so warnings can be handled correctly
	endif;

	if _passport.noErrors then
		_passport.doDeferredUpdates();
	endif;

epilog
	endLoad;				// 11/04/2011 cnwmh5 #27347
	self.finaliseActivityWithPassport(_passport);
	app.writeLog(method.name &amp; '  complete (' &amp; (app.clock - st).String &amp; ') numLogs = ' &amp; _proxyHdr.allLogScalingDtls.size.String, LogINFO);

end;</source>
        <Parameter name="_proxyHdr" type="CM_LogScalingHdr" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCreateLogScalingMerge" id="f044e443-ce60-4196-a115-81a719656d7f">
        <updating/>
        <source>trxCreateLogScalingMerge(_proxyFirstHdr : CM_LogScalingHdr input; _realSecondHdr : CM_LogScalingHdr io;
						_passport : CM_Passport input) updating;

// cnwdvb1 26 November 2002 

vars
	realLogScalingHdr	: CM_LogScalingHdr;
	expectedEdition		: Integer;
	terminal			: CM_Terminal;

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	app.writeLog('LogScalingDataMerge - start', LogINFO);

	_proxyFirstHdr.pxyGetRealObjectAndEdition(realLogScalingHdr, expectedEdition);
	
	if realLogScalingHdr = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_LogType.name, null, null);
		return;
	endif;
	
	_proxyFirstHdr.resetAverages();

	// use a session lock here so does not get unlocked by endLoad after validation
	lock(realLogScalingHdr, Exclusive_Lock, Session_Duration, LockTimeout_Server_Defined);
	lock(_realSecondHdr, Exclusive_Lock, Session_Duration, LockTimeout_Server_Defined);

	if _passport.noErrors and realLogScalingHdr.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Log Scaling Header', null, null);
		return;
	endif;

	if _proxyFirstHdr.bolNumber &lt;&gt; _realSecondHdr.bolNumber then	
		app.raiseCMException(Err_InvalidDocketForMerge, null, null);
	endif;
	
	if _proxyFirstHdr.operatorCode &lt;&gt; _realSecondHdr.operatorCode then
		app.raiseCMException(Err_InvalidSupplierForMerge, null, null);
	endif;
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	beginTransaction;
	terminal := _passport.myTerminal;
	// delete the old header
	if _passport.noErrors then
		terminal.causeEvent(terminal.getTerminalEvent(BOLRecon_Delete_Event), false, _realSecondHdr);	
		_realSecondHdr.erase(NORMAL_ERASE);
	endif;

	// update the new header
	if _passport.noErrors then
		realLogScalingHdr.setForUpdate(_proxyFirstHdr);
	endif;

	if _passport.noErrors then
		terminal.causeEvent(terminal.getTerminalEvent(BOLRecon_Update_Event), false, realLogScalingHdr);	
	endif;

epilog
	self.finaliseActivityWithPassport(_passport);
	if realLogScalingHdr &lt;&gt; null then
		unlock(realLogScalingHdr);
	endif;
	if _realSecondHdr &lt;&gt; null then
		unlock(_realSecondHdr);
	endif;
	app.writeLog('LogScalingDataMerge - complete', LogINFO);
end;</source>
        <Parameter name="_proxyFirstHdr" type="CM_LogScalingHdr" usage="input"/>
        <Parameter name="_realSecondHdr" type="CM_LogScalingHdr" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCreateLogScalingSplit" id="f6c3e9d5-d301-4f21-8c90-94fb80c580ee">
        <updating/>
        <source>trxCreateLogScalingSplit(_proxyOldHdr, _proxyNewHdr : CM_LogScalingHdr input; _passport : CM_Passport input) updating;

// cnwdvb1 26 November 2002 
// 11/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state

vars
	logDocket			: CM_BOLIn;
	realOldHdr			: CM_LogScalingHdr;
	expectedEdition		: Integer;
	extMatch 			: CM_BOLExtLogIn;
	terminal			: CM_Terminal;
	isMatched			: Boolean;
	
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);

	_proxyNewHdr.validateForSplit();
	_proxyOldHdr.validateForSplit();

	_proxyNewHdr.resetAverages();
	_proxyOldHdr.resetAverages();

	_proxyOldHdr.pxyGetRealObjectAndEdition(realOldHdr, expectedEdition);
	
	if realOldHdr = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_LogType.name, null, null);
		return;
	endif;

	endLoad;

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	beginLoad;
	logDocket := _proxyNewHdr.getMatchingBOL();
	endLoad;

	_passport.useTITransactionDeferUpdate := true;
	_passport.useTIDictDeferUpdate := true;
	terminal := _passport.myTerminal;
	
	// Start the transaction
	beginTransaction;
	exclusiveLock(realOldHdr);

	if _passport.noErrors and realOldHdr.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Log Scaling Header', null, null);
		return;
	endif;

	if _passport.hasErrors then
		return;
	endif;
	
	isMatched := _proxyNewHdr.attemptMatch(logDocket,false, _passport);  //epr TFS 3769 3/4/17

	if _passport.noErrors then
		realOldHdr.setForUpdate(_proxyOldHdr);
		if _passport.noErrors then
			terminal.causeEvent(terminal.getTerminalEvent(BOLRecon_Update_Event), false, realOldHdr);	
		endif;
	endif;
	
	if _passport.hasErrorsOrWarnings then
		return;
	endif;

	//  PAR 20627 - change to single begin/commmit so warnings can be handled correctly
	//if _passport.noErrors then
	//	_passport.doDeferredUpdates();
	//endif;
	//app.cmsCommitTransaction(_passport);
	
	if isMatched then
		// Need to reset these attributes here because
		// doDeferredUpdates sets them to false.
		_passport.useTITransactionDeferUpdate := true;
		_passport.useTIDictDeferUpdate := true;
		extMatch := logDocket.myExtension.CM_BOLExtLogIn;
		//  PAR 20627 - change to single begin/commmit so warnings can be handled correctly
		//beginTransaction;		
		extMatch.completeRoadInProcessForBOL(_passport);
	else
		// done so finaliseActivity works correctly
		//  PAR 20627 - change to single begin/commmit so warnings can be handled correctly
		//beginTransaction;
	endif;

	if _passport.noErrors then
		_passport.doDeferredUpdates();
	endif;

epilog
	endLoad;				// 11/04/2011 cnwmh5 #27347
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_proxyOldHdr" type="CM_LogScalingHdr" usage="input"/>
        <Parameter name="_proxyNewHdr" type="CM_LogScalingHdr" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
