    <JadeWebServicesMethod name="deleteContact" id="8bc611b0-bbc8-4296-80bb-27c258d20f20">
        <source>deleteContact(contact : WS_ContactRequest) : WS_ContactResponse webService;

/*

Purpose:			Delete an existing Email Address contact for the current user.

Parameters:			Title and Email Address for new contact

Return Value:		Response object (with errors)


Date		 Who	Reason
23 Feb 2009	cnwdz2	PAR #17554 - Development of new RIA Web Service application

*/

vars
	response		: WS_ContactResponse;
	completedOK		: Boolean;
	lEmailAddress	: String;
	existingEmail	: CM_EmailAddress2;
	user			: CM_User;

begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	user := app.getMyUser();
	if user = app.myPublicUser then 
		return null;
	endif;
	
	foreach lEmailAddress in contact.allEmailsToDelete do
		existingEmail := app.myRoot.allEmailAddressesByAddress[lEmailAddress];
		
		//cnwmc5 - 26 Sep 2014 - PAR 34888
		if user.allEmailsICanSee.includes(existingEmail) then
			// Remove it from the users 'allEmailsICanSee' collection using a proper trx..
			app.myTrxUA.trxUpdateRemoveEmailFromUser(existingEmail, app.myPassport);
			
		//	beginTransaction;
		//		user.allPrivateEmails.removeKey(lEmailAddress);
		//		delete existingEmail;
		//	commitTransaction;
		//else 
		//	existingEmail := app.myRoot.getEmailAddressForUser(lEmailAddress, user);
		//	if existingEmail &lt;&gt; null and user.allEmailsICanSee.includes(existingEmail) then
		//		app.raiseCMException1(Have_permi_delet_this_syste_em, existingEmail.emailAddress,
		//						  null, 
		//						  null);
		//		
		//		response.allEmailsFailedToDelete.add(existingEmail.emailAddress);
		//	endif;
		endif;
	endforeach;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;

		
epilog
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

end;
</source>
        <text>Delete an existing Email Address contact for the current user.</text>
        <wsdlName>deleteContact</wsdlName>
        <Parameter name="contact" type="WS_ContactRequest"/>
        <ReturnType type="WS_ContactResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="deleteDelay" id="eb0c6849-b783-4dbe-9978-cb28d08cb830">
        <source>deleteDelay(request : WS_DelayUpdateRequest) : WS_Response webService;
/*
Purpose:			
Date				Who			Reason
JUNE 2015		CNWAB1		Initial creation
*/


vars
	response		: WS_Response;
	completedOK		: Boolean;
	delay		: CM_Delay;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Check security access to this message, if required
	app.checkCurrentUserHasAccess(PmHandHeldShipDelays);		// Replace with appropriate permission
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	// Perform validation
	//epr TFS 5535 4/8/17 
	if request.myDelay &lt;&gt; null then
		delay:=app.myPassport.getObjectOfTypeFromOid(request.myDelay.cmObjectId,CM_Delay).CM_Delay;
		if app.myPassport.hasErrors then
			completedOK := true;
			return response;
		endif;
	endif;
	if delay = null then
		app.raiseCMException1(Matching_found, app.getErrorString(Delay), null, null);
		completedOK := true;
		return response;
	endif;
	
	// Do the delete
	app.myPassport.setWarningsIgnored(request.warningsAcknowledged);
	app.myTrxDA.trxDeleteDelay(delay, app.myPassport);
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	
epilog
		
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
