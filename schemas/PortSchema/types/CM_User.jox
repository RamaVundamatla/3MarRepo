    <JadeMethod name="isValidPassword" id="4e1f3c85-d762-4b10-b143-efc7a82da915">
        <updating/>
        <source>isValidPassword(_pwd : String) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:			06 April 2001 by cnwdwq1
// Purpose:			!     
// encrypt and compare incoming password (plain text) against
// stored encryted password
// Parameters:	None
// Returns:			Nothing
// Changed On	Changed By	Reason
// ----------	----------	--------------------------------------------------
// 16/01/2001   cnwrs1      remove toUpper on password as passwords are AlWAYS case insensitive
// ---------------------------------------------------------------------------
vars
	pword, pwordUpper, pwordLower,
	currentPword: String;
	caseSensitive	: Boolean;
	theBin		: Binary;
	
begin
	
	
	// Password is still the same since strong password enhancement.
	if (not self.isUseStrongPassword) then
		// Upper case the password and pretend that case is important.
		pword := _pwd.toUpper; //wrong
		caseSensitive := true;	
	else
		// Just use the password as it is type in.
		pword := _pwd;
		// Find out if we are worried about being case sensitive.
    	//caseSensitive := self.useCaseSensitive();
		
		if self.code = SUPERUSER_Str then
			// For SUPERUSER always treat as case sensitive regardless of system settings
			caseSensitive := true;
		else
			caseSensitive := self.useCaseSensitive();
		endif;
	endif;
	//AER 3.08.2007
	//This order of validation applies only for 7.5.3 - 
	//In Lmast(7.5.2))the "IF" statement described below is validated backwords.
	//This version is the correct one and will be applied in the next version.
	
	// Try and match the input password with saved password.
	if app.encryptPassword(self.code, pword, self.isNewEncryptionImplemented) = self.currentPassword then
	// cnwrs1 mar 2006 implement new password format
		if not self.isNewEncryptionImplemented then
			self.isNewEncryptionImplemented := true;
			self.setPassword(pword, true);
		endif;
		return true;
		
	elseif (not caseSensitive) then
		// If is not case sensitive then we try to log in by either uppercasing or lowercasing the password.
		pwordUpper := _pwd.toUpper;
		pwordLower := _pwd.toLower;
		if app.encryptPassword(self.code, pwordUpper, self.isNewEncryptionImplemented) = self.currentPassword  or
		   app.encryptPassword(self.code, pwordLower, self.isNewEncryptionImplemented) = self.currentPassword then
			return true;
		endif;
	endif;
		
	
	return false;
end;</source>
        <Parameter name="_pwd" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isViewFormType" id="ba544860-f23e-408a-9afe-7617faf50a36">
        <source>isViewFormType(_constantValue : Integer) : Boolean;
/*

Purpose: Returns TRUE if the form-type associated with the Permission constant is a View Form-Type (not a 'Maint' Maintenance Form-Type)

Parameters:			

Return Value:		

Date				Who		TFS		Reason
04 Sep 2019			jlgdi1	45802	Initial creation
05 November 2019	jlgmd1	TFS 46820 - Fix for Sys Menu Items not showing
05 October 2020		jlgmd1	49758	Move 'special' user checking to one place

*/

vars
	permObj : CM_PermissionObject;
	
begin
	if _constantValue &gt; Mod_BaseView and self.isInternalSystemUser() then
		// Always show all System Menu Items for the JMTSupport user
		return true;
	endif;

	permObj := app.myAlternateDict.getPermissionByConstValue(_constantValue);
	return (permObj &lt;&gt; null) and (permObj.formType = ViewType);
end;</source>
        <Parameter name="_constantValue" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="needsAlertAlarm" id="df823059-e71e-437a-8b68-aea937e47aa3">
        <source>needsAlertAlarm() : Boolean;
/*

Purpose:			


Return Value:		


Date		Who		Reason
30 Aug 2006	cnwer1	Initial creation - PAR#xxxx
06 Nov 2008	cnwkpd1	Performance enhancement - use dictionary key for reviewed status
	
*/

vars
	alertType 	: CM_SystemAlertType;
	iter		: Iterator;
	alert 		: CM_SystemAlert;	

begin
	foreach alertType in self.allSystemAlertTypes do
		 
		 delete iter;
		 iter := alertType.allSystemAlerts.createIterator;
		 alertType.allSystemAlerts.startKeyGeq(false, null, iter);			// KPD 06/11/2008
		 
		 while iter.next(alert) do
		 	if alert.reviewed then
		 		break;														// KPD 06/11/2008
		 	endif;
			return true;
		 endwhile;
		 
	endforeach;

	return false;

	
epilog
	delete iter;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="needsEventAlarm" id="14b0b656-f230-46e5-ac2f-a2c10eafa1df">
        <source>needsEventAlarm() : Boolean;
/*
----------   ----------  --------------------------------------------------
Created:	17 July 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	eventType 	: CM_EventType;

begin
	foreach eventType in self.allEventTypes do
		if (not eventType.allEventTransactions.isEmpty) then
			return true;
		endif;
	endforeach;


	return false;

end;

</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="e3474b2b-f69a-4ec5-bedc-efd12170b800">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:			09 April 2001 by cnwdwq1
// Purpose:			!     
// Parameters:	None
// Returns:			Nothing
// Changed On	Changed By	Reason
// ----------	----------	--------------------------------------------------
// 10/09/2008	concms1		par 17903/ccms 1741 Welcome Screen - interim solution
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// 18/05/2015	cnwmh5		Move setShowWelcomeScreen after copies current state data as was giving
//							a transient leak because state data hadn't been copied.
// ---------------------------------------------------------------------------
vars

	aUser,
	proxy :  CM_User;
	realUserTerminal,
	pxyUserTerminal	: CM_UserTerminal;
	emailICanSee		: CM_EmailEntity;
	alertType			: CM_SystemAlertType;
	eventType			: CM_EventType;
	stateObject, pxyState : CM_StateObject;	// par 17903
	i : Integer;
	completedOK		: Boolean;
begin

	proxy := inheritMethod();
	//------------------
	//Copy over references
	//------------------
	self.allDataAccessControllers.copy(proxy.allDataAccessControllers);
//	self.allSecurityRoles.copy(proxy.allSecurityRoles);
	
	foreach realUserTerminal in self.allUserTerminals do
		pxyUserTerminal := realUserTerminal.pxyCreateUpdateProxy();
		pxyUserTerminal.setMyUserForProxy(proxy);
	endforeach;
	
	foreach emailICanSee in self.allEmailsICanSee do
		proxy.allEmailsICanSee.add(emailICanSee);
	endforeach;
	
	foreach alertType in self.allSystemAlertTypes do
		proxy.allSystemAlertTypes.add(alertType);
	endforeach;

	foreach eventType in self.allEventTypes do
		proxy.allEventTypes.add(eventType);
	endforeach;
	
//	par 17093 start	
	////proxy.setShowWelcomeScreen (self.getShowWelcomeScreen);
// 	par 17903 end

	foreach i in 1 to self.allSubSystemStateObjects.size do //+ cnwmd1 Par 22287
		stateObject := self.allSubSystemStateObjects[i];
		if stateObject &lt;&gt; null then
			pxyState 	:= stateObject.pxyCreateUpdateProxy();
			proxy.CM_User.allSubSystemStateObjects[i] := pxyState;
		endif;
	endforeach;
	
	// 18/05/2015 cnwmh5
	proxy.setShowWelcomeScreen (self.getShowWelcomeScreen);

	proxy.myEmailEntity := self.myEmailEntity;
	proxy.mySystemSecurityRole := self.mySystemSecurityRole;
	proxy.myOrganisation := self.myOrganisation;
	proxy.myLocale := self.myLocale;
	proxy.myRoot := self.myRoot;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="refreshUserCargoType" id="522f65c9-a7a6-4324-af15-ff3f0f1dde85">
        <source>refreshUserCargoType(_userCargoType : CM_UserConfigCargoType) protected;
/* Sep 2011 CCMS 1776 called from getUserCargoType for a user-defined config.  Parameter is transient.
  Make a list of all current attributes
   and a second list of all current ent table rows from the cargo type enquiry ent table defs.
  Attributes which have rows no longer in the ent table defs are removed and rows which have no attribute have
   a new attribute for them added to the last user tab.
*/
vars
	defName		: String;
	tableDefs	: StringArray;
	attributes	: ObjectArray;
	attrRows	: ObjectArray;
	rows		: ObjectArray;
	obj			: Object;
	uctab		: CM_UserConfigTab;
	attr		: CM_UserConfigAttribute;
	cargoType	: CM_CargoBOLType;
	tableRoot	: CM_EntTableDataRoot;
	entTableDef	: EntTableDef;
	entRow		: EntTableRow;
begin
	create attributes transient;
	create attrRows transient;
	foreach uctab in _userCargoType.allUserConfigTabs do
		foreach attr in uctab.allAttributes do
			attributes.add(attr);
			attrRows.add(attr.myEntTableRow);
		endforeach;
	endforeach;

	create rows transient;
	create tableDefs transient;
	tableRoot := app.myRoot.myEntTableDataRoot;
	cargoType := _userCargoType.myCargoBOLType;
	cargoType.allEnquiryEntTableDefs.copy(tableDefs);
	if tableDefs.isEmpty then // just use a default def, if cargo.  BOLs don't get into here.
		if cargoType.isKindOf(CM_CargoType) then
			tableDefs.add(ETDef_DefaultCargoEnt);
		endif;
	endif;
	foreach defName in tableDefs do
		// not tranships, handled separately
		if defName = ETDef_TranshipData then
			continue;
		endif;
		// 26555 moved from CM_ContainerEnqForm
		if cargoType.isKindOf(CM_CargoType) and
		   cargoType.CM_CargoType.productType = ProductType_Vehicle then
			//if defName = ETDef_WHGeneralData or		// 34529 WHGeneralData is now used for vehicles
			if defName = ETDef_WHReceiveRelease then
				continue;
			endif;
		endif;
		entTableDef := tableRoot.allEntTableDefs[defName];
		if entTableDef &lt;&gt; null then
			foreach entRow in entTableDef.allEntTableRows do
				rows.add(entRow);
			endforeach;
		endif;
	endforeach;
	
	foreach obj in attributes do
		attr := obj.CM_UserConfigAttribute;
		entRow := attr.myEntTableRow;
		if not rows.includes(entRow) then
			attr.erase(NORMAL_ERASE);
		endif;
	endforeach;
	
	foreach obj in rows do
		entRow := obj.EntTableRow;
		if not attrRows.includes(entRow) then
			create attr transient;
			attr.setup(uctab, entRow);	// uctab is the last row from the foreach above
		endif;
	endforeach;
epilog
	delete attributes;
	delete attrRows;
	delete rows;
	delete tableDefs;
end;</source>
        <access>protected</access>
        <Parameter name="_userCargoType" type="CM_UserConfigCargoType"/>
    </JadeMethod>
    <JadeMethod name="removeEmailAddress" id="b99a2bff-d40c-4c2a-9fb3-7d0e1cf7b0bd">
