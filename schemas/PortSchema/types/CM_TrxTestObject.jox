    <JadeMethod name="setForCreate" id="fbda9f24-b1ba-49f1-8fbd-632be022bca5">
        <updating/>
        <source>setForCreate(_pxy : CM_TrxTestObject; _controller : CM_TrxTestController) updating;
// ---------------------------------------------------------------------------
// Created:     03 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	_pxy.raiseExceptionIfNotTransient(method);
	
	_controller.doUpdate();

	self.number := 1;

end;</source>
        <Parameter name="_pxy" type="CM_TrxTestObject"/>
        <Parameter name="_controller" type="CM_TrxTestController"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="7c32a18e-5c7e-451a-839e-6dca31fef4d4">
