/* ---------------------------------------------------------------------------
Created:	15 October 2008	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	if pAttrName = ETRow_MyGeneratorType then
		if self.myGeneratorType &lt;&gt; null then
			return self.myGeneratorType.getDisplayDetails(null);
		endif;
		
	else
		return inheritMethod(pAttrName);

	endif;

	return null;
	
end;</source>
