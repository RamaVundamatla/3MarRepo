    <JadeMethod name="setInitialControlValues" id="e68d8c7f-63b9-44d2-814c-93089000cb8b">
        <updating/>
        <source>setInitialControlValues() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 July 2012	cnwndl1	Initial creation	Par 29968
*/

vars

	headings 	: String;
	index 		: Integer;
	drTerm 		: CM_DebtorTerminal;
	now 		: Date;
begin

	self.setNavigatorHeading( self.caption );

	self.showToolbar := false;

	self.minimumHeight := 440;
	self.minimumWidth := 805;
	
	self.frmMain.borderStyle := 0;
	self.frmMain.top := 0;
	self.frmMain.parentAspect := 3;
	
	self.initChargesTable();
	self.initPaymentsTable();
	
	if self.myAssistant = null then
		create self.myAssistant transient;
	endif;

	self.myAssistant.comboBoxMethodOfPayment( self.cmbMOP, false );
	
	self.myAssistant.comboBoxConsignorCashOnlyDr( self.cmbConsignee, null, CONSIGNEE, self.myTerminal );
	
	if self.cmbConsignee.listCount = 1 then
		self.cmbConsignee.listIndex := 1;
	endif;
	
	self.txtDateFrom.setDate( now.Date.cnEcAddMonths( -1 ) );
	
		
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setMyDebtor" id="91fb29d3-8752-4d66-b9bc-7229164bbfad">
        <updating/>
        <source>setMyDebtor( _debtor : CM_Debtor ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 July 2012	cnwndl1	Initial creation	Par 29968

*/

vars

begin

	self.myDebtor := _debtor;
	
	if self.myDebtor = null then
		self.lblDebtor.caption := null;
		self.lblDrName.caption := null;
		
	else
		self.lblDebtor.caption := app.getErrorString(Cash_debtor);
		self.lblDrName.caption := self.myDebtor.getListName;

	endif;
	
epilog

end;</source>
