    <JadeMethod name="rfcLocation" id="da31d3d1-5ca5-4caf-ba16-ecaa41080b7a">
        <source>rfcLocation(_container : CM_TrackedItem/*CM_Container*/) : String protected;
// cnwdvb1 29 April 2003 
// 14/12/2009	cnwdap1		CCMS MES 1007 Any tracked item can now be a reefer
vars
	
	message	: String;
begin

	message := "   "&amp;"        "&amp; _container.locationId.replaceString(" ", "").trimBlanks.padBlanks(16);
	//message := "   "&amp;"        "&amp; _container.locationId.trimBlanks.padBlanks(16);
	return message[1:27];

end;</source>
