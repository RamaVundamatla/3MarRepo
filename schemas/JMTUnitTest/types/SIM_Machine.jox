    <JadeMethod name="doAccept" id="a674b377-3799-4dae-af75-83e0bb85e65c">
        <updating/>
        <source>doAccept(_task: SIM_Task) updating;

vars

begin
	if _task = null then
		return;
	endif;
	
	self.myTask := _task;
	self.myTask.accept(self);
	if not self.isCrane then 
		self.dsl.machineAcceptTask(self.myMachine, _task.getTask());
	endif;
	
	self.moving();
	self.logMessage(LOG_BRIEF, "Machine " &amp; self.myMachine.id &amp; 
			" has accepted task " &amp; self.getTaskId &amp; 
			" pickup of " &amp; self.getTaskCargoId &amp; 
			" from " &amp; self.getTaskSourceId &amp; " to " &amp; self.getTaskTargetId);
	self.logMessage(LOG_FULL, "Task " &amp; self.getTaskDisplay());
epilog

end;</source>
        <Parameter name="_task" type="SIM_Task"/>
    </JadeMethod>
    <JadeMethod name="doPickup" id="9d570d36-1e30-4695-b2c4-2885ce33012a">
        <updating/>
        <source>doPickup() updating;

vars
	ti1, ti2: CM_TrackedItem;
begin
	if not self.isCrane then
		if self.isPrevTaskACrane() then  // Voyage Discharge so need to do crane move
			ti1 := self.getTaskTrackedItem();
			self.dsl.machineCraneActionPickup(self.myMachine, ti1, ti2);
		endif;
		self.dsl.machinePickup(self.myMachine);
	endif;
	self.logMessage(LOG_BRIEF, "Machine " &amp; self.myMachine.id &amp; " has picked up " &amp; self.getTaskCargoId &amp; " from " &amp; self.getTaskSourceId);
	self.logMessage(LOG_FULL, "Task " &amp; self.getTaskDisplay());
	self.myTask.complete();
	self.myTask := self.myTask.getNext;
	self.myTask.accept(self);
	self.moving();
	self.logMessage(LOG_FULL, "Machine " &amp; self.myMachine.id &amp; " moving to setdown task" &amp; self.getTaskDisplay());

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSetdown" id="02e5141d-507e-4a45-962a-32daae273825">
        <updating/>
        <source>doSetdown() updating;
vars
	targetId: String;
begin
	if self.isNextTaskACrane then
		targetId := self.getNextTaskTargetId();
	else
		targetId := self.getTaskTargetId();
	endif;
	self.logMessage(LOG_BRIEF, "Machine " &amp; self.myMachine.id &amp; " has set down " &amp; self.getTaskCargoId &amp; " to " &amp; targetId);
	self.logMessage(LOG_FULL, "Task " &amp; self.getTaskDisplay());
	if not self.isCrane then
		self.dsl.machineSetdownTask(self.myMachine, self.myTask.getTask(), targetId);
	endif;
	self.myTask.complete();
epilog

end;</source>
    </JadeMethod>
