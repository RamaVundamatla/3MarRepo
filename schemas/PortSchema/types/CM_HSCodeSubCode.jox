    <JadeMethod name="getDisplayStringForAttribute" id="c2c00a7d-d6c3-4b57-967c-7ca02f383ebb">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
09 December 2022		jlizm1	Initial creation TFS 55280 Harmonized System Codes

*/

vars
	heading : CM_HSCodeHeading;
	
begin
	if _attrName = ETRow_Type then
		return app.getErrorString(Sub_code);
		
	elseif _attrName = ETRow_HeadingDescription then
		if self.myHSCode = null or self.myHSCode.myHSHeading = null then
			return null; 
		endif;
		heading := self.myHSCode.myHSHeading;
		if heading.description.length &gt; 50 then
			return heading.description[1:50] &amp; "...";
		else
			return heading.description;
		endif;
	elseif _attrName = ETRow_UnitQuantity then
		return self.unitQuantity;
	elseif _attrName = ETRow_ExternalRef1 then
		return self.externalRef1;
	elseif _attrName = ETRow_ExternalRef2 then
		return self.externalRef2;
	elseif _attrName = ETRow_ExternalRef3 then
		return self.externalRef3;
	elseif _attrName = ETRow_HsParentCode then
		if self.myHSCode &lt;&gt; null then
			return self.myHSCode.id;			
		endif;
		return null;	
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFullDescription" id="a0f4f083-7861-4730-95f6-ad58537703f8">
        <source>getFullDescription(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
09 December 2022		jlizm1	Initial creation TFS 55280 Harmonized System Codes

*/

vars

begin
	
	if self.myHSCode = null then
		return inheritMethod;
	endif;
	
	return self.myHSCode.getFullDescription() &amp; ": " &amp; self.description;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
