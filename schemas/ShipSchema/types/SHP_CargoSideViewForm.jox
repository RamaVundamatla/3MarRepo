    </JadeMethod>
    <JadeMethod name="getPositionForRemarks" id="99f947c5-2dd0-4c67-bafd-ad484a3f0cc8">
        <source>getPositionForRemarks(_slot :CM_ROROSlotDefnVoyage; _left, _top :Real output):Boolean protected;
/*
Date		Who		Reason
30 Jul 2012	cnwcs5	Initial creation - par 29124
*/
vars
	point1, point2	:Point;
begin
	// find the top left position for the location
	self.myROROLocnDrawingController.allSlotDefnsByX1Y1X2Y2.findObjectInDictGetXY (_slot, point1, point2);

	if point1 = null then
		return false;
	endif;
	
	_left 	:= (point1.x) + 5;
	_top 	:= (point1.y) + 5;

	return true;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_slot" type="CM_ROROSlotDefnVoyage"/>
        <Parameter name="_left" type="Real" usage="output"/>
        <Parameter name="_top" type="Real" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getSelectedCellsTIs" id="38a43588-3341-41c6-9eeb-cbd9e9efbc68">
        <source>getSelectedCellsTIs(_tiSet : ObjectArray input);
/*
Date		    Who			Reason
12 August 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars
	deckItem : CM_DeckItem;
	iterator : Iterator;
	tmpLocnDefn : CM_ROROLocnDefnVoyage;
	slotDefn   : CM_ROROSlotDefn;
	slotCntrl : CM_ROROSlotController;
	ti : CM_TrackedItem;
	obj : Object;
	allTIs : CM_TIArray;
begin
	if _tiSet = null or self.myROROLocnDrawingController = null or self.myROROLocnDrawingController.allSelectedObjects.isEmpty() then 
		return;
	endif;
	
	_tiSet.clear();
	
	create allTIs transient;
	self.myROROLocnDrawingController.getSelectedTIsForMode(allTIs);
	allTIs.copy(_tiSet);
	return;
	
	iterator := self.myROROLocnDrawingController.allSelectedObjects.createIterator();
	if iterator = null then
		return;
	endif;
	
	while iterator.next(obj) do
		if obj.isKindOf(CM_ROROSlotController) then
			slotCntrl := obj.CM_ROROSlotController;
			foreach ti in slotCntrl.allTrackedItems do
					_tiSet.addExclusive(ti);
			endforeach;
		else
			tmpLocnDefn  := obj.CM_ROROLocnDefnVoyage;		
			foreach slotDefn in tmpLocnDefn.allROROSlotDefnByOrdinal do
				if slotDefn.CM_ROROSlotDefnVoyage.mySlotController &lt;&gt; null then
					slotCntrl := slotDefn.CM_ROROSlotDefnVoyage.mySlotController;
					foreach ti in slotCntrl.allTrackedItems do
						_tiSet.add(ti);
					endforeach;
				endif;
			endforeach;
		endif;
	endwhile;
epilog
	delete iterator;
end;</source>
        <Parameter name="_tiSet" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="b6447d7a-5e12-49bd-96c3-f089c1b34ac7">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
/*
Date		    Who			Reason
26 July 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars
	xmlStr	: String;
//	entRow	: EntTableRow;	
begin
	xmlStr := inheritMethod();

	xmlStr := xmlStr &amp; global.formatAsXML(XML_TagShowExports,self.btnViewExport.value.Integer.String);

	return xmlStr;

	
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handlePosFrameViewMouseMove" id="41fc470c-88a4-4c0f-8a18-5b1d9cef6322">
        <updating/>
        <source>handlePosFrameViewMouseMove(frame: SHP_ROROLocnDrawingFrame input; button: Integer; shift: Integer; x: Real; y: Real) updating, protected;
/*
Date		    Who			Reason
27 July 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars
	theScale,
	tmpLeft,
	tmpTop	: Real;
	theX, 
	theY 	: Integer;
begin
	//theScale := self.positionScale;
	
	tmpLeft := frame.left;
	tmpTop := frame.top;
	
	if tmpLeft &lt; 0 then
		tmpLeft := 0;
	elseif tmpLeft &gt; frame.parent.width then
		tmpLeft := frame.parent.width;
	endif;
	
	if tmpTop &lt; 0 then
		tmpTop := 0;
	elseif tmpTop &gt; frame.parent.height then
		tmpTop := frame.parent.height;
	endif;
	
	theX := tmpLeft.Integer;
	theY := tmpTop.Integer;
	
	self.frmLocationSlots.scrollTo(theX, theY);
	
end;</source>
        <access>protected</access>
        <Parameter name="frame" type="SHP_ROROLocnDrawingFrame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="handleSlotsDblClickEvent" id="af707046-14a1-4fa2-9261-a56dff2956fe">
        <updating/>
        <source>handleSlotsDblClickEvent(_obj: Object) updating;
/*
Date		    Who			Reason
09 September 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/


vars
	tmpTxt : String;
	theJob : CM_VoyageJob;
	cntrl : SHP_ROROLocnDrawingController;
	slot : CM_ROROSlotController;
	req : CM_RORORequest;
	doneSelect : Boolean;
	tiSet : ObjectArray;
	locnDefn : CM_ROROLocnDefnVoyage;
	slotDefn : CM_ROROSlotDefn;
	ti : CM_TrackedItem;
	tis: CM_TIArray;
begin	
	
	if _obj = null then		
		return;
	endif;

	cntrl := self.myROROLocnDrawingController;
	
	create tis transient;
	
	if _obj.isA(CM_ROROSlotController) then
			slot := _obj.CM_ROROSlotController;
			

			if self.myROROPlanningForm.modeView = ShpDisplayMode_ColCodeLoad then // PAR 28990
				slot.getAllPlannedTrackedItems(tis, true, false);
			else
				foreach ti in slot.allTrackedItems discreteLock do
					tis.addExclusive(ti);
				endforeach;
			endif;
	elseif _obj.isA(CM_ROROLocnDefnVoyage) then
			locnDefn  := _obj.CM_ROROLocnDefnVoyage;		
			foreach slotDefn in locnDefn.allROROSlotDefnByOrdinal do
				if slotDefn.CM_ROROSlotDefnVoyage.mySlotController &lt;&gt; null then
					slot := slotDefn.CM_ROROSlotDefnVoyage.mySlotController;
					if self.myROROPlanningForm.modeView = ShpDisplayMode_ColCodeLoad then // PAR 28990
						slot.getAllPlannedTrackedItems(tis, true, false);
					else
						foreach ti in slot.allTrackedItems discreteLock do
							tis.addExclusive(ti);
						endforeach;
					endif;
				endif;
			endforeach;
	endif;
	
	tis.removeInvalidObjects();
	tis.removeDuplicateObjects();
	
	if tis.isEmpty() then		
		app.msgBox(app.getErrorString(Select_some_cargo_enquire), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);		
		return;
	endif;	
	
	self.myAssistant.showCargoEnquiryForTIs(tis.first().CM_TrackedItem,tis,self.myMasterMenuAction,false);		
epilog
	delete tiSet;
end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="handleSlotsMouseUpEvent" id="473ea380-dc2d-4518-a32a-a04ed7bf7522">
        <updating/>
        <source>handleSlotsMouseUpEvent(_obj: Object; shift: Integer) updating;
/*
Date		    Who			Reason
15 July 2011	cnwas3	  	Initial creation: CCMS 1035 CargoSideView form
*/

vars
	tmpTxt 		: String;
	theJob 		: CM_VoyageJob;
	cntrl 		: SHP_ROROLocnDrawingController;
	slot 		: CM_ROROSlotController;
	req 		: CM_RORORequest;
	doneSelect 	: Boolean;
begin	
	
	if _obj = null then		
		return;
	endif;

	cntrl := self.myROROLocnDrawingController;
	
	if _obj.isA(CM_ROROSlotController) then 
		slot := _obj.CM_ROROSlotController;
		
		self.myCurrentROROLocnDefn 	:= slot.mySlotDefn.myROROLocnDen;
		self.myCurrentROROSlotDefn 	:= slot.mySlotDefn;
		app.myDraggedTrackedItem 	:= slot.getTIAtIndex(REAL_MODE,1);

		self.lstHazard.showOnlySelectedFromObjectRORO(self.myCurrentROROLocnDefn);
				
		if not cntrl.removeObject(slot, cntrl.mySideViewFrame, true) then
			// Load CC mode and this request has a job, so select all other slots in that job.
			if cntrl.modeWork = SHP_ROROPlanningForm.WorkMode_Job then
				if cntrl.modeView = ShpDisplayMode_ColCodeLoad then
					req := slot.myRORORequestLoad;
					
					if req &lt;&gt; null then
						theJob := req.myJob.CM_VoyageJob;
						
						if theJob &lt;&gt; null then
							cntrl.selectObjectsForJob(theJob, true, true);
							self.myROROPlanningForm.myROROPlanDrawController.selectSlotsForJob(slot);
							self.myROROPlanningForm.doSetJobComboForClick(theJob);
							doneSelect := true;
						endif;
					endif;
				elseif cntrl.modeView = ShpDisplayMode_ColCodeDisch then
					req := slot.myRORORequestDischarge;
					
					if req &lt;&gt; null then
						theJob := req.myJob.CM_VoyageJob;
						
						if theJob &lt;&gt; null then
							cntrl.selectObjectsForJob(theJob, false, true);
							self.myROROPlanningForm.myROROPlanDrawController.selectSlotsForJob(slot);
							self.myROROPlanningForm.doSetJobComboForClick(theJob);
							doneSelect := true;
						endif;
					endif;
				endif;
				
				if theJob = null then
					//epr par 29098
					self.myROROPlanningForm.cmbWorkPoint.listIndex 	:= -1;
					self.myROROPlanningForm.cmbWPJob.listIndex 		:= -1;
					self.myROROPlanningForm.myCurrentJob := null; // PAR 31652
				endif;
			endif;

			if not doneSelect then
				if not shift.isControlKeyPressed and not shift.isShiftKeyPressed then // ALT KEY ONLY
					if shift.isAltKeyPressed then
						cntrl.selectObjectAlt(slot, cntrl.mySideViewFrame, true);
					else
						cntrl.selectObject(slot, cntrl.mySideViewFrame, true);
					endif;
				endif;
			endif;
		
		else
			self.myCurrentROROSlotDefn := null;
		endif;
		
		tmpTxt :=  slot.mySlotDefn.code;
		
	elseif _obj.isKindOf(CM_ROROLocnDefn) then 
		self.myCurrentROROLocnDefn := _obj.CM_ROROLocnDefn;
		self.myCurrentROROSlotDefn := null;
		
		self.myROROLocnDrawingController.setupDimensions(); //cnwas3 par 28401
		
		if not cntrl.removeObject(_obj.CM_ROROLocnDefn, cntrl.myOverViewFrame, true) then
			cntrl.removeAllObjectsByClass(CM_ROROLocnDefnVoyage, cntrl.myOverViewFrame);
			cntrl.selectObject(_obj.CM_ROROLocnDefnVoyage, cntrl.myOverViewFrame, true);
		endif;
		
		//cnwmc5 - PAR 31091 - sets the dimensions back to whatever they were..
		self.myROROLocnDrawingController.scaleDimensions(self.scaleFactor);
		
		tmpTxt := self.myCurrentROROLocnDefn.code;

		self.lstHazard.showOnlySelectedFromObjectRORO(self.myCurrentROROLocnDefn);
	else
		return;
	endif;
	
	self.setUpPlannedToLCs();

	if theJob &lt;&gt; null then
		tmpTxt := tmpTxt &amp; " | " &amp; " Job: " &amp; theJob.jobNum; 
	endif;

	self.setStatusCaption(tmpTxt,false);			
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initFromUserWindow" id="b52cef4c-9af5-49fe-b718-3474e441597c">
