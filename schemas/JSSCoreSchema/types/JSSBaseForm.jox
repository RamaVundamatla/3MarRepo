    <JadeMethod name="doEnableControls" id="4e72c44c-5c14-45e0-a40d-82cb836618f1">
        <source>doEnableControls() protected;
// --------------------------------------------------------------------------------
// Created:		27 May 2002 by cnwdad1
//
// Purpose:		Standard method to enable or disable a form's controls.  This method
//				is automatically invoked by the doFormInitialize method, so normally
//				the only time this method needs to be explicitly called is in
//				response to user-events (i.e. mouseClick etc.).
//
//				****************************************************************
//				* This method should be reimplemented, where necessary, of any *
//				* subclass forms, in any subschemas.						   *
//				****************************************************************
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormInitialize" id="39eca58f-f49f-4de8-8da4-f3358f80e01c">
        <updating/>
        <source>doFormInitialize() updating, protected;
// --------------------------------------------------------------------------------
// Created:		13 February 2002 by cnwdad1
//
// Purpose:		Standard method to handle a form's initialization, such as after
//				the formLoad event, or after an update has occurred.  This method
//				is automatically invoked by this form's formLoad event, and by the
//				doFormUpdate method (assuming that method's behaviour is inherited),
//				so normally there's no need to explicity call this method.
//
//				****************************************************************
//				* This method should be reimplemented, where necessary, of any *
//				* subclass forms, in any subschemas.						   *
//				****************************************************************
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.doEnableControls();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormLoad" id="e496339e-af95-453f-ac48-ef551dd87de1">
        <updating/>
        <source>doFormLoad() updating, protected;
// --------------------------------------------------------------------------------
// Created:		13 February 2002 by cnwdad1
//
// Purpose:		Standard method to handle a form's load event.  It is automatically
//				invoked by this form's load event, so there's no need to explicitly
//				call this method from form subclasses.
//
//				****************************************************************
//				* This method should be reimplemented, where necessary, of any *
//				* subclass forms, in any subschemas.						   *
//				****************************************************************
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormUnload" id="e09c8e12-726b-4b84-8fc0-eb620cbc7d43">
        <updating/>
        <source>doFormUnload() updating, protected;
// --------------------------------------------------------------------------------
// Created:		23 May 2002 by cnwdad2
//
// Purpose:		Standard method to handle a form's unload event.  It is automatically
//				invoked by this form's unload event, so there's no need to explicitly
//				call this method from form subclasses.
//
//				****************************************************************
//				* This method should be reimplemented, where necessary, of any *
//				* subclass forms, in any subschemas.						   *
//				****************************************************************
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormUpdate" id="e0621d59-5a9a-40da-a954-1b162b9c44bd">
        <updating/>
        <source>doFormUpdate(pIsDelete:Boolean):Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		13 February 2002 by cnwdad1
//
// Purpose:		Standard method to handle a form's updating, i.e. gather the data
//				from the form, and send it to a transaction agent.
//
//				****************************************************************
//				* This method should be reimplemented, where necessary, of any *
//				* subclass forms, in any subschemas.						   *
//				****************************************************************
//
// Parameters:	pIsDelete - True if the update is to delete an object.
//
// Returns:		True if the update was successful, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.doFormInitialize();
	
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="pIsDelete" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doFormValidate" id="9e2e5f43-a319-4155-8f87-0bc6690b1409">
        <updating/>
        <source>doFormValidate(pIsDelete:Boolean):Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		13 February 2002 by cnwdad1
//
// Purpose:		Standard method to handle a form's data validation, i.e. gather the
//				data from the form, and check that it is okay.  This method is not
//				for validating an application's (model) rules, but simply to check
//				for GUI-related errors.  Typically, this method would be called
//				before the doFormUpdate method.
//
//				****************************************************************
//				* This method should be reimplemented, where necessary, of any *
//				* subclass forms, in any subschemas.						   *
//				****************************************************************
//
// Parameters:	pIsDelete - True if the validation is for deleting an object.
//
// Returns:		True if the form's data is valid, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="pIsDelete" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="load" id="0bb718f6-f2bd-4c40-8283-a86b73e43a49">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
// --------------------------------------------------------------------------------
// Created:		13 February 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	self.doFormLoad();
	self.doFormInitialize();
epilog
	app.mousePointer	:=	Idle;
end;</source>
    </JadeMethod>
    <JadeMethod name="resynchObjectAndSetEdition" id="fb4aed88-ba22-42b1-9bd9-280e435d6d5c">
        <updating/>
        <source>resynchObjectAndSetEdition(pTheObject:Object) updating, protected;
// --------------------------------------------------------------------------------
// Created:		13 February 2002 by cnwdad1
//
// Purpose:		Resynchronizes the target object and stores its edition.
//
// Parameters:	pTheObject - The object to resynch and store the edition.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// --------------------------------------------------------------------------------
/*
	Use of "resynchObject" is preferable to "resynch" as it uses an object that
	is already	resident in cache (self) to resynchronize another object.  This
	is preferable to sending resynch to the object to be resynchronized, as if
	it is not in cache, it will have to be fetched from the server to dispatch
	the resynch method, whereupon it will be marked as obsolete.  If the object
	passed to resynchObject is not in cache, it does nothing.
*/
begin
	if pTheObject = null then
		self.aObjectEdition	:=	0;
	else
		self.aObjectEdition	:=	pTheObject.edition;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pTheObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="selectTableRow" id="d7c91a95-4558-45e7-a344-e24b3991b500">
        <source>selectTableRow(pTheTable:Table input) protected;
// --------------------------------------------------------------------------------
// Created:		11 April 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	columnPointer		: Integer;
	columnCount			: Integer;
	firstNonFixedColumn	: Integer;

begin
	pTheTable.clearAllSelected();
	columnCount			:=	pTheTable.columns;
	firstNonFixedColumn	:=	pTheTable.fixedColumns + 1;

	if (pTheTable.row &gt; pTheTable.fixedRows) then
		foreach columnPointer in firstNonFixedColumn to columnCount do
			pTheTable.setCellSelected(pTheTable.row, columnPointer, true);	
		endforeach;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pTheTable" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="unload" id="771f9869-6308-41ae-ae84-a342dd276f21">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
// --------------------------------------------------------------------------------
// Created:		23 May 2002 by cnwdad2
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.doFormUnload();
end;</source>
    </JadeMethod>
</GUIClass>
