    <JadeMethod name="getExitGate" id="9b540869-3a86-404e-892b-f47cd5e51083">
        <source>getExitGate():CM_Gate;
// ---------------------------------------------------------------------------
// Created:     17 August 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
//				Return exit gate for current job
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	vehicle		:CM_Vehicle;
	lc			:CM_YardController;
	gate		:CM_Gate;
	gateArea	:CM_GateArea;
	area		:CM_TerminalArea;
begin
	/* 	Rules:
		1. if vehicle currently in outward gate lane use that gate
		2. use default out gate for interchange area associated with current vehicle location
		3. use gate through which vehicle entered terminal
		4. use default out-gate for terminal
	*/

	vehicle := self.myVehicle;
	lc		:= vehicle.myPrimaryActualLocation;
	if lc = null then
		return null;
	endif;
	
	if lc.isGateAreaLocation then
		gateArea 	:= lc.myTerminalArea.CM_GateArea;
		gate		:= gateArea.getFirstExitGate;	
		// Note: In future we will need to have more rules to determine which exit gate to pick
		// This will work for our existing customers right now
	else
		area	:= lc.myTerminalArea;
		
		if area &lt;&gt; null and area.isInterchangeArea then	// should always be true
			gate 	:= area.CM_InterchangeArea.myDefaultOutGate;
		endif;
	endif;
	
	if gate &lt;&gt; null then
		return gate;
	endif;
	
	// same gate we came in
	gate := self.getGateIn;
	
	if gate &lt;&gt; null and gate.isOutGate then
		return gate;
	endif;
	
	gate := self.myTerminal.getDefaultGate_OUT;
	
	return gate;
epilog

end;</source>
        <ReturnType type="CM_Gate"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="c5da4bb3-dcb3-4ea2-94b8-5d39cf3c0844">
        <source>getExtraInfo(_dataContainer: CM_DataContainer) ;


vars
	block : CM_DataContainerBlock;

begin
	inheritMethod(_dataContainer);
	
	if self.myVehicle &lt;&gt; null
	and self.myVehicle.carrier &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Carrier), DC_Label, 1, self.myVehicle.carrier);
		block.addNewItem(self.myVehicle.carrier.description, DC_Data, 1, self.myVehicle.carrier);
	endif;
	
	if self.myVehicleVisit &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Visit_number), DC_Label, 1, self.myVehicleVisit);
		block.addNewItem(self.myVehicleVisit.visitNumber, DC_Data, 1, self);
	endif;
	
	if self.batNumber &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(CM_Bat_Number), DC_Label, 1, self);
		block.addNewItem(self.batNumber, DC_Data, 1, self);
	endif;
	
	if self.status = JOB_COMPLETE then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(CM_Completed_Time_Date), DC_Label, 1, self);
		block.addNewItem(self.systemToLocalTime(self.vehicleReleased).shortCurrentLocaleFormat(), DC_Data, 1, self);
	endif;


end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getFirstGateAreaIn" id="789b4169-78a0-4073-b8eb-0cee7be22730">
        <source>getFirstGateAreaIn() : CM_GateArea;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 February 2010	cnwer1	Initial creation

*/

vars
	gateAreaUsage : CM_GateAreaUsage;
begin	
	if self.myGate = null then
		return null;
	endif;
	
	gateAreaUsage:=self.myGate.allGateAreas_IN.first;
