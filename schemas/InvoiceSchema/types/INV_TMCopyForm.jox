    <JadeMethod name="sortPaths" id="1db5523a-986c-4d24-9f51-3dfee389e9af">
        <source>sortPaths(_paths : HugeStringArray input; _items : ObjectArray input) protected;
// sort the paths and associated objects to show in the same sequence as the main transaction map form
vars
	dynaDict	: DynaDictionary;
	iter		: Iterator;
	assoc		: CM_Association;
	obj			: Object;
	index		: Integer;
	str			: String;
begin
	create dynaDict transient;
	dynaDict.setMembership(CM_Association);
	dynaDict.addExternalKey(String, 500, false, false);
	dynaDict.endKeys(true);
	
	foreach str in _paths do
		index := index + 1;
		obj := _items[index];
		create assoc transient;
		assoc.setPropertyValue("stringValue", str);
		assoc.setPropertyValue("objectValue", obj);
		dynaDict[str[1:500]] := assoc;
	endforeach;
	
	_paths.clear();
	_items.clear();
	
	iter := dynaDict.createIterator();
	while iter.next(assoc) do
		str := assoc.getPropertyValue("stringValue").String;
		obj := assoc.getPropertyValue("objectValue").Object;
		_paths.add(str);
		_items.add(obj);
	endwhile;
epilog
	if dynaDict &lt;&gt; null then
		dynaDict.purge();	// delete CM_Associations
	endif;
	delete iter;
	delete dynaDict;
end;
</source>
        <access>protected</access>
        <Parameter name="_paths" type="HugeStringArray" usage="input"/>
        <Parameter name="_items" type="ObjectArray" usage="input"/>
    </JadeMethod>
