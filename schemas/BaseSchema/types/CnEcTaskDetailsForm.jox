    <JadeMethod name="clearDaily" id="aae4e8fc-87db-4577-940c-1e12455cf541">
        <source>clearDaily() protected;

begin
	chkMon.value := false;
	chkTue.value := false;
	chkWed.value := false;
	chkThu.value := false;
	chkFri.value := false;
	chkSat.value := false;
	chkSun.value := false;
	txtDailyTime.setTime(null);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="clearEveryMins" id="f1c906e6-e057-41a3-8330-55796074d466">
        <source>clearEveryMins() protected;

begin
	txtEveryMinutes.setValue(0);
end;</source>
