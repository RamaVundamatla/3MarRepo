    <JadeMethod name="getData" id="9857d022-d987-434c-b758-7f84570acea2">
        <updating/>
        <source>getData(pText: String input; pType: Integer input) updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theReturn : Integer;
	newVessel:CM_Vessel;
	result : Boolean;
begin
	app.mousePointer := Window.MousePointer_HourGlass;
	if pType = self.GetData_CopyVessel then
		if app.myRoot.allVessels[pText.trimBlanks] &lt;&gt; null then
			app.msgBox(pText.trimBlanks &amp; " Already Exists! Code Must be Unique, Try Again", "Copy Error", MsgBox_OK_Only);
			return;
		endif;

		theReturn := app.msgBox("Do You Want To Make A Copy Of " &amp; self.myCurrentVessel.name &amp; " To " &amp; pText.trimBlanks &amp; "?", "Copy Confirmation", MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
		if theReturn = MsgBox_Return_Yes then
			app.myTrxCA.trxCreateVesselClone(pText.trimBlanks,self.myCurrentVessel,newVessel, app.myPassport);
			result := app.myPassport.trxCompletedOK;
			if result then
				self.cmbVessel.setObject(newVessel);			
				self.setMyCurrentVessel(newVessel);
				global.beep;
			endif;
		endif;

	endif;
epilog
	app.mousePointer := Window.MousePointer_Default;

end;</source>
        <Parameter name="pText" type="String" usage="input"/>
        <Parameter name="pType" type="Integer" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getDimensionValue" id="d2d94a7f-73c5-4789-95c2-ab24bceb8672">
        <source>getDimensionValue(_entRowName : String) : Any protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars
	entTableDef : EntTableDef;
	entTableRow : EntTableRow;
	foundRow 	: Integer;
begin

	entTableDef  := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_KeyDimensions];
	entTableRow := entTableDef.getEntTableRow(_entRowName);
	foundRow:=1;
	if self.tblDimensions.findObjectInRow(entTableRow,foundRow) then
		return  self.tblDimensions.accessCell(foundRow,2).text.asDecimalJMT(); 
	endif;
	
	return null;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_entRowName" type="String"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="getPxyVesselDataHarbour" id="977e5b96-9e8c-4f62-8285-7f09eb837c8b">
        <source>getPxyVesselDataHarbour(): HMS_VesselDataHarbour protected;
//--------------------------------------------------
// Created:	22 September 2005 By: cnwgd1
//--------------------------------------------------
vars
	obj : Object;
	pxyVDH,
	tmpVDH : HMS_VesselDataHarbour;
	
begin
	// Update resources set as default for a vessel
	if self.mode = self.Mode_View then
		return null;
	endif;
	
	if self.myCurrentHarbour = null then
		return null;
	endif;
	
	pxyVDH := self.allProxyVessDataHarbour[self.myCurrentHarbour];

	if pxyVDH &lt;&gt; null then
		return pxyVDH;
	endif;

	if self.mode = self.Mode_Update and self.myCurrentVesselData &lt;&gt; null then
		tmpVDH := self.myCurrentVesselData.allVesselDataForHarbour[self.myCurrentHarbour];
		
		if tmpVDH &lt;&gt; null then
			pxyVDH := tmpVDH.cloneMySelf(true);
			self.allProxyVessDataHarbour.add(pxyVDH);
			return pxyVDH;
		endif;
	endif;

	create pxyVDH transient;
	
	pxyVDH.setProxy(null,
					false,
					false,
					null,
					null,
					null,
					null,
					null,
					null,
					null,
					self.myCurrentHarbour,
					null,
					null,
					null,
					null,
					null,
					null);
	
	self.allProxyVessDataHarbour.add(pxyVDH);

	return pxyVDH;
end;</source>
        <access>protected</access>
        <ReturnType type="HMS_VesselDataHarbour"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="2a5bbb65-847c-40b4-981e-52ea644a0b5c">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
// --------------------------------------------------------------------------------
// Created:		23 April 2007 by cnwdad1
//
// Purpose:		Save off details of certain data that we want restored for the current
//				user the next time they open this form.
//
// Parameters:	None
//
// Returns:		The XML string which will be stored against the user's session.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	xmlStream		: String;
	harbourCode		: String;
	
begin
	xmlStream	:=	inheritMethod();
	
	if cmbHarbourVD.listIndex = CNEC_NULL_INDEX then
		harbourCode	:=	null;
	else
		harbourCode	:=	cmbHarbourVD.listObject.HMS_Harbour.code;
	endif;
		
	xmlStream	:=	xmlStream &amp; global.formatAsXML(self.XML_Harbour, harbourCode);	
	
	if self.shtVesselStruct.visible then
		if self.grpExtRamps.visible then
			xmlStream:=xmlStream &amp; self.tblExtRamps.getXmlStrForColumns(true);
		endif;
		
		xmlStream:=xmlStream &amp; self.tblSections.getXmlStrForColumns(true);
		
		xmlStream:=xmlStream &amp; self.tblTanks.getXmlStrForColumns(true);
	endif;
	
	return xmlStream;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleSystemNotification" id="a5dcbebe-ad19-4c22-9d61-54d93e3dbf80">
        <updating/>
        <source>handleSystemNotification(eventType: Integer; theObject: Object; eventTag: Integer) updating;
//--------------------------------------------------
// Created:	26 September 2005 By: cnwgd1
//--------------------------------------------------
begin
	if eventType = Object_Delete_Event then
		if theObject = self.myCurrentVessel then
//			if self.cmbVessel.myObject &lt;&gt; null then
//				app.msgBox(app.getErrorString1(ObjectDeletedByOtherUser, self.caption), 'Warning', MsgBox_OK_Only + MsgBox_Information_Icon);
//			endif;
			
			self.cmbVessel.setObject(null);
			self.myCurrentVessel := null;
			self.doBaseFormCancel();
		endif;
		
	elseif eventType = Object_Update_Event then
		if theObject = self.myCurrentVessel then
			if self.mode &lt;&gt; self.Mode_View then
				if app.msgBox(app.getErrorString1(ObjectUpdatedByAnotherUserEdit, self.caption), 'Warning', MsgBox_OK_Cancel + MsgBox_Exclamation_Mark_Icon) = MsgBox_Return_OK then
					self.doBaseFormCancel();
					self.doBtnEdit();
				else
					self.doBaseFormCancel();
				endif;
			else
				self.setMyCurrentVessel(self.cmbVessel.listObject.CM_Vessel);
			endif;
		endif;
	endif;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initComboBoxes" id="d7b4dbad-5a36-4931-92f3-72667992551e">
        <updating/>
        <source>initComboBoxes()updating;
//--------------------------------------------------
// Created:	05 September 2005 By: cnwgd1
//--------------------------------------------------
begin
	self.doBuildComboVesselAccessType();
	//epr TFS 3614 10/4/17
	
	self.cmbVessel.initialise(false);
	
	if (not self.shtHMSHarbour.visible)  then
		// Not licensed for HMS module
		return;
	endif;

	//Initialise all harbour specific combo boxes
	self.doBuildCombosHarbour();
end;</source>
    </JadeMethod>
    <JadeMethod name="initDimensionsTbl" id="69821e25-9235-466f-bbd8-d294807d828d">
        <updating/>
        <source>initDimensionsTbl() updating;
//-----------------------------------------
// Created: Augus 2005 By: cnwgd1
//-----------------------------------------

constants
	MetreUnits ="m";
	TonneUnits = "T";

vars
	entTableDef : EntTableDef;
	entTableRow  : EntTableRow;
	newRow, maxLength,decimals		: Integer;
	unit 		: String;
	view		: EntTableView;

begin
	
	self.tblDimensions.visible:=true;
	self.tblDimensions.borderColorSingle:=self.getSystemColor(Control.Color_3DShadow);
	self.tblDimensions.clear;
	self.tblDimensions.columns:=3;
	self.tblDimensions.sortColumn[1] := 1;
	self.tblDimensions.sortType[1] := Table.SortType_Alpha;



	entTableDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_KeyDimensions];

	self.tblDimensions.accessColumn(2).width:=60;
	self.tblDimensions.accessColumn(3).width:=25;
	self.tblDimensions.accessColumn(1).width:= self.tblDimensions.clientWidth -  100;
	self.tblDimensions.accessColumn(3).enabled:=false;
	self.tblDimensions.accessColumn(1).enabled:=false;	// 15/03/2013 cnwar2 #30972
	
	self.tblDimensions.addItemAt(Tab &amp; app.getErrorString(Value) &amp; Tab &amp;app.getErrorString(Unit) ,1);
	self.tblDimensions.fixedRows:=1;
	self.tblDimensions.rows:=1;

	view:=entTableDef.allEntTableViews["hmsDimensions"];

	
	foreach entTableRow in view.allEntTableRows do
		newRow:=self.tblDimensions.addItemObject(entTableRow,entTableRow.getHeading(null,self.myTerminal,app.myCurrentLocale));

		if entTableRow.name = ETRow_DeadWeight or
			entTableRow.name = ETRow_GrossRegTonnes or
			entTableRow.name = ETRow_NetRegTonnes then
			unit := TonneUnits;
		else
			unit:=MetreUnits;
		endif;
		self.tblDimensions.accessCell(newRow,2).inputType:=entTableRow.inputType;
		if entTableRow.myEntTableCellControl &lt;&gt; null then
			maxLength:= entTableRow.myEntTableCellControl.getMaxLength;
			decimals := entTableRow.myEntTableCellControl.getDecimals;
			if maxLength &lt;&gt; 0 then
				self.tblDimensions.accessCell(newRow,2).maxLength:=maxLength;
			endif;
			if decimals &lt;&gt; 0 then
				self.tblDimensions.accessCell(newRow,2).decimals:=decimals;
			endif;
			
		endif;
		self.tblDimensions.accessCell(newRow,3).text:=unit;
	endforeach;
	
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="initForm" id="5df9f390-6061-49fe-958c-cff6b511a451">
        <updating/>
        <source>initForm() updating;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// 13 Mar 2013	PJS			PAR #31232
// ---------------------------------------------------------------------------
vars
	tmpTerm		: CM_Terminal;
	tmpUserT	: CM_UserTerminal;
	tmpUser		: CM_User;
	
begin

	
	// Prioritise self.myTerminal over the application call as this can result in the incorrect terminal being returned due
	// to notes changing the terminal in the passport - cnwcp2 - 20/2/2009 - PAR#18073
	tmpTerm := self.myTerminal;
	
	if tmpTerm = null then
		tmpTerm	:=	app.getMyTerminalDO_NOT_USE();
		if tmpTerm = null then
			tmpUser	:=	app.getMyUser();
			
			if tmpUser &lt;&gt; null then
				tmpUserT	:=	tmpUser.allUserTerminals.first();
				
				if tmpUserT &lt;&gt; null then
					tmpTerm	:=	tmpUserT.getRealTerminal();
				endif;
			endif;
		endif;
	endif;

	if tmpTerm &lt;&gt; null then
		self.cmbShippingAgent.isDisplayByName	:=	tmpTerm.getConfig(ComboByNameAgent).Boolean;
		self.cmbShippingLine.isDisplayByName	:=	tmpTerm.getConfig(ComboByNameLine).Boolean;
		self.cmbVessel.isDisplayByName			:=	tmpTerm.getConfig(VesselComboByName).Boolean;		
	endif;	

	self.btnShipGraphics.visible	:=	app.isSpecial();
	
	//epr 11/3/14 removing voyage commodity planning as part of bulk CCMS 1366
	self.shtVesselDetails.visible:=true;	
	
	
	
	
	if self.shtHMSHarbour.visible  then
		// licensed for HMS							
		self.initHMSTables();
	else
		self.initDimensionsTbl();	
		self.ckbCoastalVessel.enabled := false;
	endif;
	
	//epr 11/3/14 removing voyage commodity planning as part of bulk CCMS 1366

	self.initStructuralTables();

	
		//31232
	
	tblVesselStruct.setValueColumn(0, getSystemColor(Color_Window), false, false);
	self.setColorsForEntryTable(tblVesselStruct);
	self.initTblVesselStructure(self.tblVesselStruct, ETDef_VesselStructTbl);
	
	self.fldVessel.tabsStyle			:=	Folder.TabsStyle_RightSloped;
	self.fldVessel.useSheetBackColors	:=	true;
	self.fldVessel.setDefaultSheetBackColors();
	self.fldVessel.initSheetBackColors();
	self.initVesselAllocSheet();
	
	self.beginClassNotification(CM_Vessel, false, Object_Update_Event, Response_Continuous, 0);
	self.beginClassNotification(CM_Vessel, false, Object_Delete_Event, Response_Continuous, 0);		
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="initFromUserWindow" id="63d8e250-172f-4481-a73b-bc7762ee38e6">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;
// --------------------------------------------------------------------------------
// Created:		23 April 2007 by cnwdad1
//
// Purpose:		Restore details that were saved the last time this form was opened
//				by the current user.
//
// Parameters:	_userWindow - A reference to the "User Window" object on which saved
//					information is stored.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	xmlStream		: String;
	keyValue		: String;
	startPos		: Integer;
	harbourObj		: HMS_Harbour;
	terminalObj		: CM_Terminal;
	
begin
	inheritMethod(_userWindow);
	
	xmlStream	:=	_userWindow.xmlInfo;
	
	// Get the previously saved Harbour.
	
	startPos	:=	1;
	keyValue	:=	xmlStream.cnEcGetNextTagValueOfName(self.XML_Harbour, startPos);
	
	if startPos &gt; 0 and keyValue &lt;&gt; null then
		harbourObj				:=	app.myRoot.allHarbours[keyValue];
		self.aMySavedHarbour	:=	harbourObj;
	endif;
	
	
end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="initHMSHarbourDetails" id="647a5439-3fae-4370-8207-7acad2fab04a">
        <source>initHMSHarbourDetails();
//--------------------------------------------------
// Created:	09 March 2004 By: cnwgd1
//--------------------------------------------------
vars
	tmpCol : Integer;
	
begin
	if (not self.shtHMSHarbour.visible)  then
		// not licensed for HMS
		self.lblHarbour.visible		:=	false;
		self.cmbHarbourVD.visible	:=	false;		
		return;
	endif;
		
	if app.myRoot.isMultiHarbour then
		self.lblHarbour.visible		:=	true;
		self.cmbHarbourVD.visible	:=	true;
	else
		self.lblHarbour.visible		:=	false;
		self.cmbHarbourVD.visible	:=	false;
		self.cmbHarbourVD.enabled	:=	false;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="initHMSTables" id="e063a32d-dfc6-4f76-a83a-8ae147466e69">
        <updating/>
        <source>initHMSTables() updating, protected;
//--------------------------------------------------
// Created:	09 March 2004 By: cnwgd1
//--------------------------------------------------
vars
	entTableDef	: EntTableDef;
	tmpTable : CM_DataTable;
	
begin
	if (not self.shtHMSHarbour.visible) then
		// not licensed for HMS
		return;
	endif;
		
	self.lstResTypeArriva.tabStop	:=	true;					
	self.lstResTypeDepart.tabStop	:=	true;					
	self.lstResTypeShift.tabStop	:=	true;					
	
	self.initHMSHarbourDetails();
	
	self.grpBerthage.parentAspect:=GroupBox.ParentAspect_CenterHorz;
	self.grpHarbour.parentAspect := GroupBox.ParentAspect_CenterHorz;
	
	// Berth Preferences Table
	tmpTable := self.tblPrefBerth;	
	entTableDef	:= app.myController.getEntTableDef(ETDef_BerthPrefVoyage);
	tmpTable.setTblDataEntRowsFromDef(entTableDef);
	tmpTable.selectMode := Table.SelectMode_CurrentRow;
	tmpTable.selectionType := CM_DataTable.SelectionType_Row;
	tmpTable.autoSize := tmpTable.AutoSize_Column;
	tmpTable.tabKey := J_key_Tab;
	tmpTable.accessRow(1).backColor := self.colorHeadingColumn;
	
	self.initHMSTidalClassTbl(self.tblCurrentsArriv);
	self.initHMSTidalClassTbl(self.tblCurrentsDepar);

	self.initDimensionsTbl();	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initHMSTidalClassTbl" id="912c2a31-2737-4964-bfc6-4872794d6673">
        <source>initHMSTidalClassTbl(_theTable : CM_DataTable input);

vars	
	tmpStr : String;
begin
	
	// Make table readOnly
	_theTable.readOnly := true;
	_theTable.rows := 0;

	// Set table input modes
	_theTable.accessMode := _theTable.AccessMode_Column;
	_theTable.column := 1;
	_theTable.inputType := _theTable.InputType_None;	
	_theTable.column := 2;
	_theTable.inputType := _theTable.InputType_None;
	_theTable.alignment := _theTable.Alignment_Right;
	_theTable.column := 3;
	_theTable.inputType := _theTable.InputType_None;
	_theTable.alignment := _theTable.Alignment_Center;


	// Set dimensions table headings
	tmpStr := "Direction and Tide Type" &amp; Tab &amp; "Max current " &amp; Tab &amp; "Unit ";
	_theTable.addItem(tmpStr);
	_theTable.accessRow(1).backColor  :=  self.colorHeadingColumn;

	// Set enteries in "Titles" column
	tmpStr := "Arrival, maximum flood tide" &amp; Tab &amp; ' ' &amp; Tab &amp; "knots";
	_theTable.addItem(tmpStr);	
	tmpStr := "Arrival, maximum ebb tide" &amp; Tab &amp; ' ' &amp; Tab &amp; "knots";
	_theTable.addItem(tmpStr);
	tmpStr := "Departure, maximum flood tide" &amp; Tab &amp; ' ' &amp; Tab &amp; "knots";
	_theTable.addItem(tmpStr);	
	tmpStr := "Departure, maximum ebb tide" &amp; Tab &amp; ' ' &amp; Tab &amp; "knots";
	_theTable.addItem(tmpStr);
	
	_theTable.fixedRows := 1;
	_theTable.fixed3D := true;
	
end;</source>
        <Parameter name="_theTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="initStructuralTables" id="468ac5ff-a2ad-459c-af0b-c49908094b7a">
        <source>initStructuralTables() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	entDef : EntTableDef;
	
	
begin

	self.tblTanks.fixedRows:=1;
	self.tblTanks.borderColorSingle:=self.getSystemColor(Control.Color_3DShadow);
	self.tblTanks.selectMode:= Table.SelectMode_WholeRows;
	entDef := app.myController.getEntTableDef(ETDef_VesselTanks);
	if entDef = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'EntDef ETDef_VesselTanks not found');
		return;
	endif;
	
	self.tblTanks.setTblDataEntRowsFromDef(entDef);
	
	
	
	self.tblExtRamps.fixedRows:=1;
	self.tblExtRamps.borderColorSingle:=self.getSystemColor(Control.Color_3DShadow);
	self.tblExtRamps.selectMode:= Table.SelectMode_WholeRows;
	entDef := app.myController.getEntTableDef(ETDef_ExternalRamp);
	if entDef = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'EntDef ETDef_VesselTanks not found');
		return;
	endif;
	
	self.tblExtRamps.setTblDataEntRowsFromDef(entDef);
	
	

	self.tblSections.fixedRows:=1;
	self.tblSections.borderColorSingle:=self.getSystemColor(Control.Color_3DShadow);
	self.tblSections.selectMode:= Table.SelectMode_WholeRows;
	entDef := app.myController.getEntTableDef(ETDef_VesselSections);
	if entDef = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'EntDef ETDef_VesselSections not found');
		return;
	endif;
	
	self.tblSections.setTblDataEntRowsFromDef(entDef);
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initTblVesselStructure" id="95c6dbb8-244a-4638-96f0-57666c0c843e">
        <source>initTblVesselStructure(	pTable	 : CM_EntryTable;
						pDef	 : String) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 March 2013	cnwpjs1	Initial creation  PAR # 31232

*/

vars
	entTableControl	: EntTableDef;
	theTable		: CM_EntryTable;
	
begin

	theTable := pTable;
	theTable.rows := 0;
		
	theTable.optimiseRowHeight := true;
	
	entTableControl := app.myController.getEntTableDef(pDef);
	theTable.setEntTableDef(entTableControl, null, 'entTableDefSetupWarning');

	
	theTable.visible := true;
	theTable.pictureViewMethod := 'picViewMethod';
	theTable.pictureLoadMethod := 'picLoadMethod';
	theTable.pictureExtractMethod := 'picExtractMethod';
	//theTable.optimiseHeadingColumn();
	theTable.headingColumnWidth := 145;
	
	theTable.resetSize();
	
	myAssistant.entryTableVesselStructureType(theTable);
			
				
end;</source>
        <access>protected</access>
        <Parameter name="pTable" type="CM_EntryTable"/>
        <Parameter name="pDef" type="String"/>
    </JadeMethod>
    <JadeMethod name="initVesselAllocSheet" id="8eb78e71-a5ea-401e-97af-f8b422b9c97f">
        <updating/>
        <source>initVesselAllocSheet() updating;
/*
Date		    Who			Reason
04 August 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form VAC
*/

vars
	ct : CM_YACriteriaType;
	vessel : CM_Vessel;
begin
	
	/* //13/06/2025	navkc1 JIRA MTN 34963 - use new MSG filter control
	vessel := self.myCurrentVessel;
	if vessel &lt;&gt; null and vessel.myVoyageAllocationConfig &lt;&gt; null then
		self.myVoyageAllocConfig := vessel.myVoyageAllocationConfig;
	else
		self.myVoyageAllocConfig := null;
	endif;
	self.allYACriteriaTypesForVoyages.clear();
	self.allVAAvailable.clear();
	self.allVASelected.clear();
	self.lstAvailable.clear();
	self.lstSelected.clear();
	
	foreach ct in app.myRoot.allYACriteriaTypes where ct.isVoyageAllocationCT do	
		self.allYACriteriaTypesForVoyages.add(ct);
		if self.myVoyageAllocConfig &lt;&gt; null then
			if  self.myVoyageAllocConfig.allOpCriteria.includes(ct) then
				continue;
			endif;
		endif;
		
		self.allVAAvailable.add(ct.description);
		self.lstAvailable.addItem(ct.description);
	endforeach;
	
	if self.myVoyageAllocConfig &lt;&gt; null then	
		foreach ct in self.myVoyageAllocConfig.allOpCriteria do
			self.allVASelected.add(ct.description);
			self.lstSelected.addItem(ct.description);
		endforeach;		
	endif;	
	
	self.setVADefaultColourCombo();
	*/
	
	self.doInitVesselAllocMsg(); //13/06/2025	navkc1 JIRA MTN 34963
end;</source>
    </JadeMethod>
    <JadeMethod name="keyDown" id="4df8325e-d697-4e73-b76a-e3f667117247">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
//--------------------------------------------------
// Created:	03 October 2005 By: cnwgd1
//--------------------------------------------------
vars
	theActiveControl	: Control;

begin

	if self.fldVessel.topSheet &lt;&gt; self.shtVesselDetails then
		if keyCode = J_key_Tab then
			theActiveControl := app.activeControl;
	
			if shift = 0 and theActiveControl = self.ckbHasRamps then
				// moving forward into table
				self.tblDimensions.row := self.tblDimensions.fixedRows + 1;
	
			elseif shift = 1 and theActiveControl = self.fldVessel then
				// moving back into table
				self.tblDimensions.row := self.tblDimensions.rows;
			endif;
		else
			inheritMethod(keyCode, shift);		
		endif;
	else
		inheritMethod(keyCode, shift);
	endif;
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="load" id="7083fb9a-c4ca-41fc-b212-82a18459bc43">
