    <JadeMethod name="setRTGState" id="f761c042-fd06-4c0b-a561-938621b42f02">
        <updating/>
        <source>setRTGState(_value : Integer) updating;
/*

Purpose:	sets the rtgState attribute and depending on the prior value and the value you are setting it to fires
			a note to do the twistlock read or rfid read (to do)


Return Value:		


Date		Who		Reason
27 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	startTwistRead : Boolean;
begin
	if rtgState = _value then
		return;
	endif;
	
	if rtgState = IDLE then
		if _value &lt;&gt; PICKINGUP then
			self.writeLog(method.name &amp; " can not change from rtg state " &amp; rtgState.String &amp; " " &amp; _value.String);
			return;
		endif;
	endif;
	
	rtgState:=_value;

	
epilog

end;</source>
        <Parameter name="_value" type="Integer"/>
    </JadeMethod>
