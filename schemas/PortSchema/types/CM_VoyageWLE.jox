    <JadeMethod name="getWeight" id="124327cb-836a-43ec-9ff1-3b02483a92be">
        <source>getWeight() : Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 June 2010	cnwmh5	Initial creation #20661

*/

vars

	weight	: Integer;

begin

	if self.myTrackedItem &lt;&gt; null then
		weight := self.myTrackedItem.totalWeight.Integer;
	else
		if self.isBulkRelease() then
			weight := self.myRequest.getBulkReleaseReserveDetail.getAverageWeight();
