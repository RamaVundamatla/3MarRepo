    <JadeMethod name="delete" id="e0435f85-e737-47ff-99c8-ce28b5c02be3">
        <updating/>
        <source>delete() updating;

vars

begin
	if self.isKindOf(CM_CargoAllocServiceBroker) 
	or self.isKindOf(CM_InventoryServiceBroker) then // ### TFS 51219 25MAY2021 NAVAB1
		return;
	endif;
	
	
	if not self.isTransient() then
		self.allInvoiceAllocations.purge();
	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="getChildrenSize" id="15dd5244-131e-48ef-9e3b-c81de7d0ba8e">
        <source>getChildrenSize() : Integer;
//	used to get the number of columns when showing allocation details in a table
vars
	result	: Integer;
	ya		: CM_YardAllocation;
	invAlloc	: CM_InvoiceAllocation;
	qm		: CM_QuantityMap;
	qrm		: CM_QuantityRangeMap;
begin
	foreach ya in self.allInvoiceAllocations do
		invAlloc := ya.CM_InvoiceAllocation;
		qm := invAlloc.myQuantityMap;
		foreach qrm in qm.allQuantityRanges do
			// TFS 40620 result := result + qrm.allInvoiceLinesUsed.size;
			result := result + qrm.allTMInvoiceLineMappings.size;// TFS 40620
		endforeach;
	endforeach;

	return result;
end;
</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
