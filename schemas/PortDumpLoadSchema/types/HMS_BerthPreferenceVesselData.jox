<Class name="HMS_BerthPreferenceVesselData">
    <JadeMethod name="importPLXMLReference" id="d99cc7d3-def8-492e-af7e-443d24eb36bf">
        <source>importPLXMLReference(_name, _theCode, _referencesBlock: String): Object;

vars

begin
	if _name = "myRoot" then
		return app.myRoot;
	elseif _name = "myBerth" then
		return app.getMyHarbour().allBerths[_theCode];
	elseif _name = "myVesselDataHarbour" then
		if _theCode &lt;&gt; null then
			return app.getMyHarbour();
		endif;
	else
		return null;
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_theCode" type="String"/>
        <Parameter name="_referencesBlock" type="String"/>
        <ReturnType type="Object"/>
    </JadeMethod>
</Class>
