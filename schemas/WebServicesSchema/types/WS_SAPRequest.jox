<Class name="WS_SAPRequest" id="34400407-5384-4c2b-a529-47936c981dd7">
    <superclass name="WS_ExternalRequest"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <JadeMethod name="getInvoice" id="28747783-66cb-4ba5-b9b6-44bdc07bb810">
        <source>getInvoice(_terminal : CM_Terminal; _invoiceNbr : String) : CM_Invoice;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 03/07/2018	jlgdap1		Initial creation TFS 38639 PEL1 SAP Receive Paid Status
// 27/07/2018   cnwma1		ChangeRequest 39698: PEL1 - SAP Enable SAP interfaces
vars
	invoice : CM_Invoice;
	bank : CM_Bank;
	term,tmpTerm : CM_Terminal;
	sapTermCode : String;
begin

	if  _invoiceNbr.length &lt; 5 then
		term:= null;
	endif;
	sapTermCode := _invoiceNbr[5:3];
	foreach tmpTerm in app.myRoot.allTerminals do
		if tmpTerm.getConfigAdditionalInfo1 = sapTermCode then
			 term:=tmpTerm;
			 break;
		endif;
	endforeach;
	
	if term &lt;&gt; null then
		foreach bank in term.companies discreteLock do 
			invoice := bank.allInvoicesByExternalCode.getAtKeyGeq(_invoiceNbr.trimBlanks);
			
			if invoice &lt;&gt; null then
				//if invoice.externalFinancialId = _invoiceNbr.trimBlanks then
				if invoice.getExternalFinancialId() = _invoiceNbr.trimBlanks then //08/12/2025	navkc1 JIRA 36262
					return invoice;
				endif;
			endif;
		endforeach;
	endif;
	return null;
epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_invoiceNbr" type="String"/>
        <ReturnType type="CM_Invoice"/>
    </JadeMethod>
</Class>
