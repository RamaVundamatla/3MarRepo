    <JadeMethod name="adjustEndXForCargo" id="7a854c77-fa3c-4947-843a-5c0c9862c17f">
        <updating/>
        <source>adjustEndXForCargo() updating;
// ---------------------------------------------------------------------------
// Created:     19 January 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	key1, key2 : Point;
	returnX : Real;
	gcNext, gcLC : CM_GridController;
begin
	if self.myLocationsController = null then
		return;
	endif;
	returnX := self.x2;
	
	gcLC :=  self.myLocationsController.CM_GridController;
	
	gcNext := gcLC.myNextController;
	if gcNext &lt;&gt; null then
		if self.allGridObjects.findObjectInDictGetXY(gcNext, key1, key2)  then
			returnX := key1.x - 2;
		endif;
	endif;
	
	
	self.x2 := returnX;
end;</source>
    </JadeMethod>
    <JadeMethod name="adjustStartEndXForOffsets" id="4fa81432-0c62-442d-bc79-fde852869b95">
        <updating/>
        <source>adjustStartEndXForOffsets(_theTI : CM_TrackedItem;_startX,_endX : Real io) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 November 2010	cnwer1	Initial creation

*/

vars
	offsetFlexi,
	lcMultiplier : Real;
begin
	//adjust the start and end x because of offset caused by 30 &amp; 45 or 53 ft containers
	offsetFlexi:= self.myLocationsController.offsetFlexi;
	if _theTI &lt;&gt; null then
		lcMultiplier := _theTI.getMultiplierForDrawing();
	endif;
	if self.flipHorizontal then
		_startX:=self.x1 + (self.columnWidth - ((offsetFlexi/20) * self.columnWidth));
		if lcMultiplier &lt;&gt; 0 then
			_endX:=_startX - (lcMultiplier * self.columnWidth); 
		endif;
	else
		
		_startX:=self.x1  + ((offsetFlexi/20) * self.columnWidth); 
		if lcMultiplier &lt;&gt; 0 then
			_endX := _startX + (lcMultiplier * self.columnWidth); 
		endif;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_startX" type="Real" usage="io"/>
        <Parameter name="_endX" type="Real" usage="io"/>
    </JadeMethod>
    <JadeMethod name="calcRoRoTranslationOffsets" id="1138e9e8-478c-4c48-8e47-884434cbc47c">
        <source>calcRoRoTranslationOffsets(_x, _y : Integer; _ta: CM_RoRoLaneArea; _angle : Real; _ox1, _oy1, _ox2, _oy2 : Real output ) protected;

/*

Purpose:			
	Used only for rotation of RoRo areas. Calculates the distance of translation required on both x and y axis after rotating the
	rectangle that represents a RoRo Terminal Area's bounding rectangle.
	
	When we come to render a rotated RoRo Area in the Satellite view, we have the following information:
	
	 - origin x
	 - origin y
	 - width
	 - height
	 
	 All the rotation drawing code calculates the rectangles to be drawn as if there is no rotation, then, prior to
	 rendering, the rectangles are rotated accordingly (the rotation origin being the centre point of the RoRo Area bounding rectangle).   
	 
	 Example:   
	 
	 We have this information
	 
	 ------------
	 |          |
	 ------------
	 
	 After rotation, we have something like this
	 
			------
			|    |
			|    |
			|    |
			|    |
			------
			
	We then need to translate the co-ordinates to the origin x and origin y  (i.e shift it left and down):
	
	------
	|    |
	|    |
	|    |
	|    |
	------
	
	We record the distance we shifted the rotated rectangle to bring it back to origin x, origin y.
	
	I refer to those distances as the translation offsets.  Then wherever we rotate something that sits inside a 
	RoRo Area, we apply those translation offsets to bring the rectangles within the bounding rectangle of the 
	terminal area.	

Parameters:			

Return Value:		


Date		Who		Reason
27 January 2010	cnwjk3	Initial creation

*/

vars
	origx, origy,
	cx, cy,
	nx1, ny1,
	nx2, ny2,
	x1, y1,
	x2, y2			: Real;
	borderWidth		: Integer;
begin
	borderWidth 	:= CM_RoRoLaneArea.SAT_RORO_BORDER_WIDTH;
	self.myDrawingFrame.drawStyle := Frame.DrawStyle_Solid;
	self.myDrawingFrame.drawWidth := borderWidth;
		
	x1 := _x;
	y1 := _y;
	x2 := _x + _ta.getSatDrawWidthInPixels(self.scaleFactor) + (borderWidth/2);
	y2 := _y + _ta.getSatDrawHeightInPixels(self.scaleFactor) + (borderWidth/2);
	origx := x1;
	origy := y1;
		
	// Calculate rotation point
	self.getRoRoAreaMidPoint(_ta, x1, y1, cx, cy); 

	self.rotateRectangle(x1, y1, x2, y2, _angle, cx, cy); 

	nx1 := x1;
	nx2 := x2;
	ny1 := y1;
	ny2 := y2;
	
	self.translateRectanglePoints(nx1, ny1, nx2, ny2, origx, origy);

	// We need to record how much we move the TA along the X and Y axis and add these offsets
	// to the lanes that we rotate.  This is because the lanes rotation origin point is the centre point
	// of the terminal, so once the lanes have been rotated we add the offsets accordingly, so that they
	// line up correctly within the terminal area.
	_ox1 := nx1 - x1;
	_ox2 := nx2 - x2;
	_oy1 := ny1 - y1;
	_oy2 := ny2 - y2;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_x" type="Integer"/>
        <Parameter name="_y" type="Integer"/>
        <Parameter name="_ta" type="CM_RoRoLaneArea"/>
        <Parameter name="_angle" type="Real"/>
        <Parameter name="_ox1" type="Real" usage="output"/>
        <Parameter name="_oy1" type="Real" usage="output"/>
        <Parameter name="_ox2" type="Real" usage="output"/>
        <Parameter name="_oy2" type="Real" usage="output"/>
    </JadeMethod>
    <JadeMethod name="calcRotatedFlippedRectangle" id="5f1884a6-af86-4c7b-8b67-666a69be0ac6">
        <source>calcRotatedFlippedRectangle(_x1, _y1, _x2, _y2 : Real io; _ta : CM_RoRoLaneArea; 
							_tx, _ty, _angle : Real; 
							_flipHorizontal, _flipVertical : Boolean; 
							_ox1, _oy1, _ox2, _oy2 : Real) protected;
/*

Purpose:	Rotate and flip a rectangle relative to a terminal area's rectangle			

Parameters:			
			_x1, y1, _x2, _y2		: The un-flipped/un-rotated rectangle co-ords
			_tx, ty					: Terminal area top-left co-ords
			_angle					: Angle of rotation
			_flipHorizontal			: true if you want to flip rectangle horizontally
			_flipVertical			: true if you want to flip rectangle vertically
			_ox1, _oy1, _ox2, _oy2	: Translation offsets - see drawRoRoBorder() for info
Return Value:		
			_x1, y1, _x2, _y2		: Return the flipped/rotated rectangle co-ords

Date		Who		Reason
25 January 2010	cnwjk3	Initial creation

*/

vars
	cx, cy,
	taDrawWidth,
	taDrawHeight	: Real;
begin

	if _angle = 90 or _angle = 270 then
		taDrawWidth  := _ta.getSatDrawHeightInPixels(self.scaleFactor);	
		taDrawHeight := _ta.getSatDrawWidthInPixels(self.scaleFactor);	
	else
		taDrawWidth := _ta.getSatDrawWidthInPixels(self.scaleFactor);
		taDrawHeight := _ta.getSatDrawHeightInPixels(self.scaleFactor);	
	endif;

	// Rotate relative to the terminal area's mid point
	self.getRoRoAreaMidPoint(_ta, _tx, _ty, cx, cy); 
		
	self.rotateRectangle(_x1, _y1, _x2, _y2, _angle, cx, cy);
		
	// Adjust the lanes to line up with the terminal area (as it will have been moved after rotation)
	_x1 := _x1 + _ox1;
	_x2 := _x2 + _ox2;
	_y1 := _y1 + _oy1;
	_y2 := _y2 + _oy2;
	
	if _flipHorizontal then
		_x1 := self.flipPointX(_tx, taDrawWidth, _x1);
		_x2 := self.flipPointX(_tx, taDrawWidth, _x2);		
	endif;

	if _flipVertical then
		_y1 := self.flipPointY(_ty, taDrawHeight, _y1);
		_y2 := self.flipPointX(_ty, taDrawHeight, _y2);		
	endif;

	self.normaliseRealRectanglePoints(_x1, _y1, _x2, _y2);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_x1" type="Real" usage="io"/>
        <Parameter name="_y1" type="Real" usage="io"/>
        <Parameter name="_x2" type="Real" usage="io"/>
        <Parameter name="_y2" type="Real" usage="io"/>
        <Parameter name="_ta" type="CM_RoRoLaneArea"/>
        <Parameter name="_tx" type="Real"/>
        <Parameter name="_ty" type="Real"/>
        <Parameter name="_angle" type="Real"/>
        <Parameter name="_flipHorizontal" type="Boolean"/>
        <Parameter name="_flipVertical" type="Boolean"/>
        <Parameter name="_ox1" type="Real"/>
        <Parameter name="_oy1" type="Real"/>
        <Parameter name="_ox2" type="Real"/>
        <Parameter name="_oy2" type="Real"/>
    </JadeMethod>
    <JadeMethod name="clearRTGMachineWorkzones" id="b788b860-1dd5-4c4e-a273-c58a7247343a">
        <source>clearRTGMachineWorkzones() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 December 2010	cnwer1	Initial creation

*/

vars
	cmifMachineWorkzone : CMIF_MachineWorkzone;
	workzoneFrame : Frame;
begin
	foreach cmifMachineWorkzone in self.allCMIFMachineWorkzones do
		workzoneFrame:=self.findMachineWorkzoneFrame(cmifMachineWorkzone);
		if workzoneFrame &lt;&gt; null then
			workzoneFrame.visible:=false;
		endif;
	endforeach;
	self.allCMIFMachineWorkzones.purge;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
