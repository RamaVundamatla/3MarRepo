    <JadeMethod name="pxyCreateUpdateProxy" id="b66178bc-366a-4719-bd92-fc81f9dcc73f">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 July 2014	cnwndl1	Initial creation

*/

vars

	proxy : CM_QuickAccessUser;

begin

	proxy := inheritMethod();
	proxy.myUser := self.myUser;
	
	return proxy;

epilog

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="ed209584-5ef8-431a-a514-6c4051ed8151">
        <updating/>
        <source>setForUpdate(_proxy: CM_QuickAccessUser ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 May 2014	cnwndl1	Initial creation

*/

vars

begin

	inheritMethod(_proxy);
	
	self.myUser := _proxy.myUser;

epilog

end;</source>
        <Parameter name="_proxy" type="CM_QuickAccessUser"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="14a4b83d-53c8-4822-b065-d79e4f53a41e">
        <updating/>
        <source>setProxy(	_helpDescription : String;
			_permissionInteger : Integer;
			_shortCode : String;
			_isForm : Boolean;
			_allowsOption : Boolean;
			_user : CM_User
			) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 May 2014	cnwndl1	Initial creation

*/

vars

begin

	self.allowsOption := _allowsOption;
	self.isForm := _isForm;
	self.helpDescription := _helpDescription;
	self.permissionInteger := _permissionInteger;
	self.shortCode := _shortCode;
	self.myUser := _user;

epilog

end;</source>
        <Parameter name="_helpDescription" type="String"/>
        <Parameter name="_permissionInteger" type="Integer"/>
        <Parameter name="_shortCode" type="String"/>
        <Parameter name="_isForm" type="Boolean"/>
        <Parameter name="_allowsOption" type="Boolean"/>
        <Parameter name="_user" type="CM_User"/>
    </JadeMethod>
