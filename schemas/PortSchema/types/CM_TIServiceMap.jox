    <JadeMethod name="includesProductGroup" id="b6ac83b7-6f5c-4021-94ba-9bf9eae9352c">
        <source>includesProductGroup(_prodGroup : CM_ProductGroup) : Boolean;
// ---------------------------------------------------------------------------
// Created:		09 February 2006  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	amap : CM_ProductGroupMap;
begin
	
	return self.allProductGroupMaps[_prodGroup.code] &lt;&gt; null;
