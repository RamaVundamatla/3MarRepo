    <JadeMethod name="translateForm" id="528550ba-1e84-4a13-987e-455694081cf7">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 20 September 2023 14:51:21.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0025341, locale);
	btnAdd.translateCaption(Xlat_0025342, locale);
	btnArgFind.translateCaption(Xlat_0025343, locale);
	btnArgFindClose.translateCaption(Xlat_0025344, locale);
	btnClear.translateCaption(Xlat_0025345, locale);
	btnClose.translateCaption(Xlat_0025346, locale);
	btnDown.translateCaption(Xlat_0025347, locale);
	btnQrySave.translateCaption(Xlat_0026454, locale);
	btnQrySaveAs.translateCaption(Xlat_0026455, locale);
	btnRemove.translateCaption(Xlat_0025348, locale);
	btnSearch.translateCaption(Xlat_0025349, locale);
	btnUp.translateCaption(Xlat_0025350, locale);
	btnUpdate.translateCaption(Xlat_0025351, locale);
	btnresultsscreen.translateCaption(Xlat_0025352, locale);
	chkAll.translateCaption(Xlat_0025353, locale);
	lblAnd.translateCaption(Xlat_0025354, locale);
	lblArgument.translateCaption(Xlat_0025355, locale);
	lblAttribute.translateCaption(Xlat_0025356, locale);
	lblFind.translateCaption(Xlat_0025357, locale);
	lblOperation.translateCaption(Xlat_0025358, locale);
	lblQryDescription.translateCaption(Xlat_0026456, locale);
	lblQryName.translateCaption(Xlat_0026457, locale);
	lblSelectorQuery.translateCaption(Xlat_0025359, locale);
	mnuColumnOrganiser.translateCaption(Xlat_0025360, locale);
	mnuContextMenu.translateCaption(Xlat_0025361, locale);
	optAll.translateCaption(Xlat_0025362, locale);
	optSelected.translateCaption(Xlat_0025363, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="txtArgFind_keyDown" id="eca9fd37-f7f3-4b9a-b99c-1cefd85d0a04">
        <controlMethod name="TextBox::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtArgFind_keyDown(textbox: TextBox input; keyCode: Integer io; shift: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Dec 2022 navtnr20	TFS CR 55301 Task 55553: UI - New Selector Dialog
*/

vars
	type,
	remaining		: Integer;
begin
	if self.getTimerStatus(self.Timer_TableData_Filter, type, remaining) then
		self.endTimer(self.Timer_TableData_Filter);
	endif;
	
	self.beginTimer(500, Timer_OneShot, self.Timer_TableData_Filter);
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="txtArgument_firstChange" id="8b03933b-5073-4030-8d5e-9be437b603e2">
        <controlMethod name="TextBox::firstChange"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtArgument_firstChange(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Dec 2022 navtnr20	TFS CR 55301 Task 55553: UI - New Selector Dialog
*/

vars

begin
	self.queryLineChanged := true;
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
