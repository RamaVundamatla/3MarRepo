    <JadeMethod name="addJAS" id="6ae074de-5819-4e5d-9be3-7807443fd3fb">
        <updating/>
        <source>addJAS(_jas : Decimal) updating;

vars

begin

	self.totalLotJAS := self.totalLotJAS + _jas;
	self.totalPlaceJAS := self.totalPlaceJAS + _jas;
	self.totalSupplierJAS := self.totalSupplierJAS + _jas;
	
end;</source>
        <Parameter name="_jas" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="addMeans" id="7d2041c5-2191-49c1-bbb2-715d0e471034">
        <updating/>
        <source>addMeans(_len, _mean : Decimal; _count : Integer) updating;

vars

begin

	self.allLengths.add(_len);
	self.allSedMeans.add(_mean);
	self.allItems.add(_count);
	self.allSupplierLengths.add(_len);
	self.allSupplierSedMeans.add(_mean);
	self.allSupplierItems.add(_count);


end;</source>
        <Parameter name="_len" type="Decimal"/>
        <Parameter name="_mean" type="Decimal"/>
        <Parameter name="_count" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addPcs" id="e66796b6-5da0-41a6-afcb-5c326e1a2534">
        <updating/>
        <source>addPcs(_pcs : Integer) updating;

vars

begin

	self.totalLotPcs := self.totalLotPcs + _pcs;
	self.totalPlacePcs := self.totalPlacePcs + _pcs;
	self.totalSupplierPcs := self.totalSupplierPcs + _pcs;
	

end;</source>
        <Parameter name="_pcs" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addWeight" id="9fd87ffd-09de-421f-951e-a7f3c48b5226">
        <updating/>
        <source>addWeight(_weight : Decimal) updating;

vars

begin

	self.totalLotWeight 			:= self.totalLotWeight + _weight;
	self.totalSupplierWeight		:= self.totalSupplierWeight + _weight;

end;</source>
        <Parameter name="_weight" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="clear" id="6d3c8d79-3fa0-474f-807e-1ee7caaf0aa7">
        <updating/>
        <source>clear(_type : Integer) updating;

vars

begin

	if _type = Place then
		self.totalPlacePcs 			:= 0;
		self.totalPlaceJAS			:= 0;
	elseif _type = Supplier then
		self.totalSupplierPcs 		:= 0;
		self.totalSupplierJAS		:= 0;
		self.totalSupplierWeight	:= 0;
		self.allSupplierLengths.clear;
		self.allSupplierSedMeans.clear;
		self.allSupplierItems.clear;
	elseif _type = Lot then
		self.totalLotPcs			:= 0;
		self.totalLotJAS			:= 0;
		self.totalLotWeight			:= 0;
		
		self.allItems.clear;
		self.allLengths.clear;
		self.allSedMeans.clear;
	endif;

end;</source>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getAverageSED" id="e1745ff3-e3fc-41de-a6be-3d8762652c2f">
        <source>getAverageSED() : Decimal;

vars

begin

	return global.calcAverageSEDMeanMixed(self.allLengths, self.allSedMeans, self.allItems);

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getSupplierAverageSED" id="92aa3211-e5fd-434f-8343-1942d4f5a2b1">
        <source>getSupplierAverageSED() : Decimal;
// ---------------------------------------------------------------------------
// Created:     10 January 2006	cnwhjg1
//
// Purpose:     PAR11175 - supplier totals for sed not being calc correctly. 
// ----------   ----------  --------------------------------------------------

vars

begin

	return global.calcAverageSEDMeanMixed(self.allSupplierLengths, self.allSupplierSedMeans, self.allSupplierItems);

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
</Class>
