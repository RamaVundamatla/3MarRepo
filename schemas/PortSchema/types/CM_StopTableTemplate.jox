    <JadeMethod name="getAuditText" id="aec450ac-b323-4d1a-888a-902aac3182a5">
        <source>getAuditText(): String;

vars
	txt		: String;
	tmpStr	: String;
	applyArea, preventArea, processArea : Integer;
	voyage : CM_Voyage;
begin
	txt[10000] := '*';
	txt := null;
	txt := inheritMethod();
	foreach applyArea in self.allApplyAreas do
		if tmpStr = null then
			tmpStr := self.myStopTable.convertTypeToString(applyArea);
		else
			tmpStr := tmpStr &amp; ', ' &amp; self.myStopTable.convertTypeToString(applyArea);
		endif;
	endforeach;

	txt := txt &amp; 'Set Stops On ' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	
	tmpStr := null;
	foreach preventArea in self.allPreventAreas do
		if tmpStr = null then
			tmpStr := self.myStopTable.convertTypeToString(preventArea);
		else
			tmpStr := tmpStr &amp; ', ' &amp; self.myStopTable.convertTypeToString(preventArea);
		endif;
	endforeach;
    txt := txt &amp; 'Stops Prevent Actions ' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	
	tmpStr := null;
	foreach processArea in self.allProcessAreas do
		if tmpStr = null then
			tmpStr := self.myStopTable.convertTypeToString(processArea);
		else
			tmpStr := tmpStr &amp; ', ' &amp; self.myStopTable.convertTypeToString(processArea);
		endif;
	endforeach;
	txt := txt &amp; 'Processing Options ' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;

	tmpStr := null; //ccms1824 cnwrs1 May 2009
	foreach voyage in self.allHoldVoyages do
		if tmpStr = null then
			tmpStr := voyage.code;
		else
			tmpStr := tmpStr &amp; ', ' &amp; voyage.code;
		endif;
	endforeach;
	txt := txt &amp; 'Hold Voyages ' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;

	return txt;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayDetails" id="757e844d-11f1-4d0b-8f20-e7a891101320">
        <source>getDisplayDetails(_short: Boolean): String;
 //ccms1824 cnwrs1 may 2009
vars
	txt		: String;
	tmpStr	: String;
	applyArea, preventArea, processArea : Integer;
	voyage : CM_Voyage;
begin
	txt[10000] := '*';
	txt := null;
//	txt := inheritMethod(_short)&amp;CrLf;
	txt := txt &amp; 'Terminal ' &amp; '=' &amp; self.myTerminal.code &amp; CrLf;
	if self.isNotSet then
		txt := txt &amp; "Not Setup" &amp; CrLf;
	else
		txt := txt &amp; 'Is Child Ignore ' &amp; "=" &amp; self.isChildIgnore.String &amp; CrLf;
		txt := txt &amp; 'Is Child Only ' &amp; "=" &amp; self.isChildOnly.String &amp; CrLf;
		txt := txt &amp; 'Is Coastal Ignore ' &amp; "=" &amp; self.isCoastalIgnore.String &amp; CrLf;
		txt := txt &amp; 'Is Coastal Only ' &amp; "=" &amp; self.isCoastalOnly.String &amp; CrLf;
//		txt := txt &amp; 'Is Tranship Ignore ' &amp; "=" &amp; self.isTranshipIgnore.String &amp; CrLf;
//		txt := txt &amp; 'Is Tranship Only ' &amp; "=" &amp; self.isTranshipOnly.String &amp; CrLf;
		txt := txt &amp; 'Is Full ' &amp; "=" &amp; self.isFull.String &amp; CrLf;
		txt := txt &amp; 'Is MT ' &amp; "=" &amp; self.isMT.String &amp; CrLf;
		foreach applyArea in self.allApplyAreas do
			if tmpStr = null then
				tmpStr := self.myStopTable.convertTypeToString(applyArea);
			else
				tmpStr := tmpStr &amp; ', ' &amp; self.myStopTable.convertTypeToString(applyArea);
			endif;
		endforeach;
	
		txt := txt &amp; 'Set Stops On ' &amp; "=" &amp; tmpStr &amp; CrLf;
		
		tmpStr := null;
		foreach preventArea in self.allPreventAreas do
			if tmpStr = null then
				tmpStr := self.myStopTable.convertTypeToString(preventArea);
			else
				tmpStr := tmpStr &amp; ', ' &amp; self.myStopTable.convertTypeToString(preventArea);
			endif;
		endforeach;
		txt := txt &amp; 'Stops Prevent Actions ' &amp; "=" &amp; tmpStr &amp; CrLf;
		
		tmpStr := null;
		foreach processArea in self.allProcessAreas do
			if tmpStr = null then
				tmpStr := self.myStopTable.convertTypeToString(processArea);
			else
				tmpStr := tmpStr &amp; ', ' &amp; self.myStopTable.convertTypeToString(processArea);
			endif;
		endforeach;
		txt := txt &amp; 'Processing Options ' &amp; "=" &amp; tmpStr &amp; CrLf;
	
		tmpStr := null; //ccms1824 cnwrs1 May 2009
		foreach voyage in self.allHoldVoyages do
			if tmpStr = null then
				tmpStr := voyage.code;
			else
				tmpStr := tmpStr &amp; ', ' &amp; voyage.code;
			endif;
		endforeach;
		txt := txt &amp; 'Hold Voyages ' &amp; "=" &amp; tmpStr &amp; CrLf;
	endif;
	return txt;
end;
</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
