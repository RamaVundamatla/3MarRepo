    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="allCargoSummaries" id="2ad4ca90-332d-47ed-a0d8-13cd9f34c3d2">
        <memberTypeInverse/>
        <type name="WS_CargoSummaryArray"/>
    </ImplicitInverseRef>
