    <JadeMethod name="valBulkRelease" id="91e63457-d48f-44f2-a15d-68c9ee7b79fc">
        <updating/>
        <source>valBulkRelease(_pxyReleaseRequest : CM_BulkRelease;
				_allTIPins : CM_StringDict;  //cnwrd1 par 25594 10.12.2010
				_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     22 February 2001 by cnwrs2
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 12/02/2012	cnwcs5		par 28756 - changed parameter usage from input to constant for _pxyReleaseReqesst
// ---------------------------------------------------------------------------
vars
	
begin

	self.raiseExceptionIfNull(_pxyReleaseRequest, 'Proxy Release Request');
	
	_pxyReleaseRequest.validateForCreate(_passport);
	
	_pxyReleaseRequest.validateCargoOperatorPins(_allTIPins);  //cnwrd1 CCMS POL 2032 par 25594 10.12.2010
end;</source>
        <Parameter name="_pxyReleaseRequest" type="CM_BulkRelease"/>
        <Parameter name="_allTIPins" type="CM_StringDict"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="valBulkReleaseCMIF_BR" id="592bc1b9-8233-4da2-9495-925aa7db43b4">
        <updating/>
        <source>valBulkReleaseCMIF_BR(pIntFaceBulkRelease : CMIF_BulkRelease input; pProxyBulkRelease : CM_BulkRelease output;
			_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     22 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin

	self.raiseExceptionIfNull(pIntFaceBulkRelease, 'Bulk Release Interface Item');

	create pProxyBulkRelease transient;
	pIntFaceBulkRelease.updateProxy(pProxyBulkRelease);

	if pIntFaceBulkRelease.type = BR_TYPE_BOL then
		pIntFaceBulkRelease.validateForGCRelease(_passport);
	endif;
	
	if _passport.hasErrors then
		return;
	endif;
	
	pProxyBulkRelease.validateForCreate(_passport);
	
end;</source>
