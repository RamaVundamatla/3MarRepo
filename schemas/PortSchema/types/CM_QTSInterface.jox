    </JadeMethod>
    <JadeMethod name="mapper" id="6584889a-13d3-49ef-873b-f588dfbaad34">
        <source>mapper(_object : Object; _key : String): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 January 2020	jlgma1	Initial creation

*/

vars
	cashRec  	: CM_CashReceipt;
	cashCredit  : CM_CashCredit;
	value    	: String;
	mop      	: CM_PaymentMethod;
	voyage   	: CM_Voyage;
	debtor   	: CM_Debtor;
	cashInv     : CM_Invoice;
	user		: CM_User;
	recDate     : Date;
	voyageCode,
	userName,
	recBank,
	recDtFormatted,
	recMopCode,
	recMopDesc,
	recCheque,
	recComments,
	recPosRef,
	recInvNbr,
	reccheque : String;
begin
	if _object.isKindOf(CM_CashReceipt) then
		cashRec 		 := _object.CM_CashReceipt;
		mop     		 := cashRec.myPaymentMethod;
		voyage  		 := cashRec.myVoyage;
		debtor  		 := cashRec.getDebtor;
		cashInv 		 := cashRec.myCashInvoice;
		user   			 := cashRec.myUser;
		recDate	         := cashRec.createdTime.Date;
		recDtFormatted   := recDate.format("yy") &amp; recDate.month.padLeadingWith("0",2) &amp;  recDate.day.padLeadingWith("0",2);
		
		if user &lt;&gt; null then
			userName := user.code;
		endif;
		if cashInv &lt;&gt; null then
			recInvNbr 	:= cashInv.getExternalInvoiceNumber();
			recComments := cashInv.narration;
		endif;
		if voyage &lt;&gt; null then
			voyageCode := voyage.code;
		endif;
		if mop &lt;&gt; null then
			recMopCode := mop.code;
			recMopDesc := mop.description;
			
			if mop.isCheque then
				recBank 	 := cashRec.chequeBank;
				recCheque    := cashRec.chequeNumber;
			elseif mop.isPOS  then
				recPosRef := cashRec.externalReceiptNumber;
			endif;
		
		
		endif;
		
		if _key = "CustomerName" then
			value := debtor.name;
			
		elseif _key = "DepositDate" then
			value := recDtFormatted;
		elseif _key = "ChequeNumber" then
			value := recCheque;
		elseif _key = "ChequeBank" then
			value := recBank;
		elseif _key = "CashInv" then
			value := recInvNbr;
		elseif _key = "Voyage" then
			value := voyageCode;
		elseif _key = "PosRef" then
			value := recPosRef;
		elseif _key = "CreatedBy" then
			value := userName;
		elseif _key = "MopCode" then
			value := recMopCode;
		elseif _key = "MopDesc" then
			value := recMopDesc;
		elseif _key = "ReceiptAmount" then
			value := cashRec.cashValue.String;
		elseif _key = "Comments" then
			value := recComments;
		elseif _key = "CashReceiptNumber" then
			value := cashRec.externalInvoiceNumber;
		elseif _key = "CustomerAccNumber" then
			value := debtor.decfinName;
		endif;
	
	elseif _object.isKindOf (CM_Invoice) then
	
	
	elseif _object.isKindOf (CM_CashCredit) then
		cashCredit := _object.CM_CashCredit;
		if _key = "sequenceNum" then
			value := cashCredit.sequenceNum.String;		
		endif;
	endif;
	
	return value;
epilog

end;</source>
        <Parameter name="_object" type="Object"/>
        <Parameter name="_key" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setExternalInvoiceNumber" id="e79a5e63-75c4-44fe-acfb-66188837925f">
        <source>setExternalInvoiceNumber(_invoice: CM_Invoice): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Dec 2019 cnwma1 ChangeRequest 47851: QTS - Integration with Oracle Fusion Cloud

*/

vars
	year,
	sequenceKey,
	tmpStr,
	externalNumber	: String;
	sequenceNum			: Integer;
	invoiceTotal 		: Decimal [23,6];
	bank           	 	: CM_Bank;
begin
	bank         := _invoice.bank;
	invoiceTotal := _invoice.getTotalAmount;
	
	if invoiceTotal &lt; 0 then
		tmpStr := bank.code &amp; "/"; //&amp; self.Type_Credit_Invoice &amp; "/";
	else
		tmpStr := bank.code &amp; "/" ;//&amp; self.Type_CASH_Invoice &amp; "/";
	endif;
	
	sequenceKey := SN_PostedInvoice;
	
	if _invoice.postedDT.isValid then		
		year 		:= _invoice.postedDT.date.year.padLeadingWith('0', 4);
		sequenceKey := sequenceKey &amp; year[3:2];	
	endif;
	
	sequenceNum := bank.getSeqNum(sequenceKey);
	tmpStr	 	:= tmpStr &amp; sequenceNum.padLeadingWith('0', 6);
	
	
	if year &lt;&gt; null then
		externalNumber := tmpStr &amp; '/' &amp; year;
	else
		externalNumber := tmpStr;
	endif;
	
	
	return externalNumber;
	
epilog

end;</source>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <ReturnType type="String"/>
    </JadeMethod>
