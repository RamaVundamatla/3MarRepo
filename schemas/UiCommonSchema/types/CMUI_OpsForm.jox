    <JadeMethod name="mnuToggleMultiSelect_click" id="87ef97fe-8a27-4f91-8add-b5cd4d4b7db7">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuToggleMultiSelect_click(menuItem: MenuItem input) updating;
//--------------------------------------------------------------
//Created: 16 April 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if self.tblWorkEntries.multiSelect = self.tblWorkEntries.MultiSelect_Simple then
		self.tblWorkEntries.multiSelect := self.tblWorkEntries.MultiSelect_None;
		self.mnuToggleMultiSelect.checked := false;	
	else
		self.tblWorkEntries.multiSelect := self.tblWorkEntries.MultiSelect_Simple;		
		self.mnuToggleMultiSelect.checked := true;			
	endif;
end;</source>
