    <JadeMethod name="getCriteriaSingleCMIF" id="9cc728ce-8771-40f1-b79b-80aab0e9aad5">
        <source>getCriteriaSingleCMIF( _cmifArray : CMIF_Array input; _criteriaType :CM_YACriteriaType; _value : Any );

/*

Purpose:		Update/add transient maintenance object for given criteria type

Parameters:			

Return Value:		


Date			Who		Reason
16 January 2023	navmv20	TFS 55650 Task 55701: Jade - Contracts XML Extract TRX

*/

vars
	cmifCriteria : CMIF_YACriteriaPriority;
	cmifObject : CMIF_Object;
	itemCode : String;
	proxyCriteria: CM_YACriteria;

begin
	
	// Create an Add Criteria request
	
	create proxyCriteria transient;
	itemCode := _criteriaType.description.cnEcUpto(CM_YACriteriaPriority::code.length -1);
	proxyCriteria.setProxy(_criteriaType, _value, itemCode);
	cmifCriteria := proxyCriteria.getTransient();
	cmifCriteria.setFlag(true, false, false);
	_cmifArray.add(cmifCriteria);
	
epilog

end;</source>
        <Parameter name="_cmifArray" type="CMIF_Array" usage="input"/>
        <Parameter name="_criteriaType" type="CM_YACriteriaType"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="getCurrentContextForAudit" id="7470a34b-dbd3-44f9-9354-1da707023832">
        <source>getCurrentContextForAudit():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 February 2021	jlgndl1	Initial creation	TFS 50152 - migrated from  CM_Object::getAuditText

*/

vars

	context : String;	
	activeForm : Form;	
	activeControl : Control;	

begin

	if app.applicationType = app.ApplicationType_GUI then
		activeForm := app.activeForm();
		if activeForm &lt;&gt; null then
			context := activeForm.name;
		else
			if app.name = HandHeldApp
			or app.name = VehicleMountedApp
			or app.name = VehicleMountedWithDevice1
			or app.name = HandHeldWithDevApp1
			then
				context := app.getHandHeldCurrentFormName();
			endif; 
		endif;
		if context = null then
			activeControl := app.activeControl();
			if activeControl &lt;&gt; null then
				activeForm := activeControl.form;
				if activeForm &lt;&gt; null then
					context := activeForm.name;
				endif;
			endif;
		endif;
	elseif app.isWebApp then
		context := app.name;
	endif;
	
	return context;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCurrentContextNiceName" id="4c6fb942-c473-47f8-a54b-8ee8f0d7c298">
        <source>getCurrentContextNiceName():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 February 2021	jlgndl1	Initial creation	TFS 50152

*/

vars

	rawStr : String;
	hyphenIndex : Integer;
	index : Integer;
	char : Character;
	lastChar : Character;
	minusTwoChar : Character;
	outputStr : String;

begin

	rawStr := getCurrentContextForAudit();
	if rawStr = null then
		return null;
	endif;
	
	//the rawStr will be a class name.
	
	hyphenIndex := rawStr.pos("_",1) + 1; //Find the first hypen and get the first position after that
											// if there isn't one we atartat one anyway.
	foreach index in hyphenIndex to rawStr.length do
		char := rawStr[index];
		if index = hyphenIndex then //its the first character, just add it.
			outputStr := outputStr &amp; char;
		else
			if lastChar.isLower and char.isUpper then // start of a new word, add a space. like TrackedItem
				outputStr := outputStr &amp; " " &amp; char;
			elseif minusTwoChar &lt;&gt; null and char.isLower and lastChar.isUpper and minusTwoChar.isUpper then
				//add space before lastchar as we have an upper case abbreviation before the new word like EDIType
				outputStr := outputStr[1:outputStr.length -1] &amp; " " &amp; lastChar &amp; char;
			else
				outputStr := outputStr &amp; char; // just add the character
			endif;
		endif;
		minusTwoChar := lastChar;
		lastChar := char;
	endforeach;
	
	return outputStr;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCurrentLocaleString" id="62610bd9-2d02-4d3e-8434-55612740b0ab">
        <source>getCurrentLocaleString() : String;
// ---------------------------------------------------------------------------
// Created:     01 April 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
07 Sep 2012	cnwkpd1	PAR #30306 - tidy up About Box display
	
*/

vars
	tmpJadeLocale,
	tmpJadeLocaleForLocale	: Locale;
	tmpLocale	: CM_Locale;
	rtnStr		: String;
begin
	tmpLocale := self.myCurrentLocale;
	if tmpLocale &lt;&gt; null then
		tmpJadeLocaleForLocale := currentSchema.getLocale(tmpLocale.localeId);
	endif;
	tmpJadeLocale := self.currentLocale;
	
	if tmpJadeLocale = tmpJadeLocaleForLocale then
		rtnStr := tmpJadeLocale.makeLocaleName &amp; ' (' &amp; tmpJadeLocale.name &amp; ')';
	elseif tmpJadeLocaleForLocale &lt;&gt; null then
		rtnStr := 'JMT ' &amp; tmpJadeLocaleForLocale.makeLocaleName &amp; ', ' &amp;
				  'System ' &amp; tmpJadeLocale.makeLocaleName;
	else
		rtnStr := 'JMT ' &amp; 'null' &amp; ', ' &amp;
				  'System ' &amp; tmpJadeLocale.makeLocaleName;
	endif;
	
	return rtnStr;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDamageDescrForLoc" id="d86507e6-cb3a-4fb0-96d9-f61e0836c457">
        <source>getDamageDescrForLoc(_damageLoc : Integer) : String;
/*
----------   ----------  --------------------------------------------------
Created:	20 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if _damageLoc = DamageLocation_Left then
		return app.getErrorString(Left);
	elseif _damageLoc = DamageLocation_Right then
		return app.getErrorString(Right);
	elseif _damageLoc = DamageLocation_Top then
		return app.getErrorString(Damage_Descr_Top);
	elseif _damageLoc = DamageLocation_Bottom then
		return app.getErrorString(Damage_Descr_Bottom);
	elseif _damageLoc = DamageLocation_Front then
		return app.getErrorString(Damage_Descr_Front);
	elseif _damageLoc = DamageLocation_Back then
		return app.getErrorString(Damage_Descr_Back);
	elseif _damageLoc = 7 then
		return "All";
	else
		return 'Error: unhandled damage location';
	endif;
	
	
	

end;


</source>
        <Parameter name="_damageLoc" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDamageDescrForPosition" id="fb053dd7-94a0-47e1-9074-0889208fb122">
        <source>getDamageDescrForPosition(_damagePosition : CM_DamagePosition) : String;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		13 August 2009
//
// Implemented version: JMT 7.7.3
// Date  		User  		Change
// 13/08/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
//----------------------------------------------------------------------
vars

begin
	if _damagePosition = null then
		if  app.myPassport.myTerminal.getConfig(DamageDetailsOptional).Boolean then		// 1/06/2023 navcs2	Task 58120
			return null;
		else
			app.raiseUnexpectedProgramError('CM_Damage', method.qualifiedName, 'No Damage Position passed in');
		endif;								
	endif;
	
	return _damagePosition.description;
	//return app.myRoot.allDamagePositionsByCode[_damagePosition.code].description;
	
epilog
end;</source>
        <Parameter name="_damagePosition" type="CM_DamagePosition"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDamageLocForDescr" id="b2250902-0381-4cb3-8d88-fbf6086a0b09">
        <source>getDamageLocForDescr(_damageDescr : String) : Integer;
/*
----------   ----------  --------------------------------------------------
Created:	20 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if _damageDescr = app.getErrorString(Left) then
		return DamageLocation_Left;
	elseif _damageDescr = app.getErrorString(Right) then
		return DamageLocation_Right;
	elseif _damageDescr = app.getErrorString(Damage_Descr_Top)then
		return DamageLocation_Top;
	elseif _damageDescr = app.getErrorString(Damage_Descr_Bottom) then
		return DamageLocation_Bottom;
	elseif _damageDescr = app.getErrorString(Damage_Descr_Front) then
		return DamageLocation_Front;
	elseif _damageDescr = app.getErrorString(Damage_Descr_Back) then
		return DamageLocation_Back;
	elseif _damageDescr = "All" then
		return 7;
	endif;
	
	return null;

end;


</source>
        <Parameter name="_damageDescr" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDamagePositonForDescr" id="b72c2f0d-0200-450f-bce5-2354508a9643">
