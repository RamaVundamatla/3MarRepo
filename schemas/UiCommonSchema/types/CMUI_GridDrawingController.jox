    <JadeMethod name="removeAllObjectsByClass" id="ef9f6b05-e3bc-4ac7-be45-2d8d741a4d0c">
        <updating/>
        <source>removeAllObjectsByClass(_class : Class; _frame : CMUI_GridAreaDrawingFrame input) : Boolean updating;
/*
Purpose:			
Date		Who		Reason
08 August 2011	cnwab1	Initial creation
*/

vars
	obj : Object;
	objs : ObjectSet;
begin
	if _class = null then
		return false;
	endif;
create objs transient;

	foreach obj in self.allSelectedObjects  discreteLock where obj.class = _class do
		objs.add(obj);
//		self.allSelectedObjects.remove(obj);

//		if _redraw and _frame &lt;&gt; null then
//			_frame.drawObject(obj, self);
//		elseif _redraw and _frame = null then
//			app.raiseUnexpectedProgramError(class.name, method.name, 'Cannot redraw object as _frame parameter is null');
//		endif;
	endforeach;
	foreach obj in objs  discreteLock  do
		self.allSelectedObjects.remove(obj);

		_frame.drawObject(obj, self);
	endforeach;	
		return true;

epilog
delete objs;
end;</source>
        <Parameter name="_class" type="Class"/>
        <Parameter name="_frame" type="CMUI_GridAreaDrawingFrame" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="removeObject" id="77c3eda3-afde-4d00-bf6f-ef4a3a7a6c4a">
        <updating/>
        <source>removeObject(_obj : Object; _frame : CMUI_GridAreaDrawingFrame input; _redraw : Boolean) : Boolean updating;
/*
Purpose:			
Date				Who			Reason
AUGUST 2011		CNWAB1		Initial creation
*/

vars

begin
	if _obj = null then
		return false;
	endif;
	if (self.allSelectedObjects.includes(_obj)) then

		self.allSelectedObjects.remove(_obj);
//		self.allObjectEditions.remove(_obj);

		if _redraw and _frame &lt;&gt; null then
			_frame.drawObject(_obj, self);
		elseif _redraw and _frame = null then
			app.raiseUnexpectedProgramError(class.name, method.name, 'Cannot redraw object as _frame parameter is null');
		endif;
		return true;
	endif;
	
	return false;

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_frame" type="CMUI_GridAreaDrawingFrame" usage="input"/>
        <Parameter name="_redraw" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="rotatePoint" id="5be86dc2-159a-4e4d-9b13-972025df9282">
        <source>rotatePoint( _x1, _y1 : Real io;  _angle : Real; _originx, _originy : Real) protected;

/*

Purpose:			
		Rotate the given point by the given angle, using the given point of origin to rotate around.
Parameters:			
		_x1			: x of point
		_y1 		: y of point
		_angle		: Angle to rotate in degrees
		_originx	: x of rotation point 
		_originy	: y of rotation point 
Return Value:		
		_x1 &amp; _y1 are updated with the rotated point

Date		Who		Reason
01 December 2009	cnwjk3	ccms 1018

*/

vars
	angle_cos,
	angle_sin,
	tempx,
	tempy,
	x1, y1,
	x2, y2			: Real;
begin
	
	//  Pre-calculate these for efficiency
	angle_cos := _angle.cos();
	angle_sin := _angle.sin();
	
	// Rotate point
	tempx := _x1;
	tempy := _y1;
	x1 := (angle_cos * (tempx - _originx) - angle_sin * (tempy - _originy)) + _originx;
	y1 := (angle_sin * (tempx - _originx) + angle_cos * (tempy - _originy)) + _originy;
		
	// Pass back the rotated point
	_x1 := x1;
	_y1 := y1;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_x1" type="Real" usage="io"/>
        <Parameter name="_y1" type="Real" usage="io"/>
        <Parameter name="_angle" type="Real"/>
        <Parameter name="_originx" type="Real"/>
        <Parameter name="_originy" type="Real"/>
    </JadeMethod>
    <JadeMethod name="rotateRectangle" id="fc1195ef-42e6-4b46-9fa2-353c50560ed5">
        <source>rotateRectangle( _x1, _y1, _x2, _y2 : Real io;  _angle : Real; _originx, _originy : Real) protected;

/*

Purpose:			
		Rotate the given rectangle points by the given angle, using the given point of origin to rotate around.
Parameters:			
		_x1			: Top-left x of rectangle
		_y1 		: Top-left y of rectangle
		_x2 		: Bottom-right x of rectangle
		_y2 		: Bottom-right y of rectangle
		_angle		: Angle to rotate in degrees
		_originx	: x of rotation point 
		_originy	: y of rotation point 
Return Value:		
		_x1, y1, _x2, y2 are updated with the rotated rectangle points

Date		Who		Reason
01 December 2009	cnwjk3	ccms 1018

*/

vars
	angle_cos,
	angle_sin,
	tempx,
	tempy,
	x1, y1,
	x2, y2			: Real;
begin
	
	//  Pre-calculate these for efficiency
	angle_cos := _angle.cos();
	angle_sin := _angle.sin();
	
	// Rotate top-left point
	tempx := _x1;
	tempy := _y1;
	x1 := (angle_cos * (tempx - _originx) - angle_sin * (tempy - _originy)) + _originx;
	y1 := (angle_sin * (tempx - _originx) + angle_cos * (tempy - _originy)) + _originy;

	
	// Rotate bottom-right point
	tempx := _x2;
	tempy := _y2;
	x2 := (angle_cos * (tempx - _originx) - angle_sin * (tempy - _originy)) + _originx;
	y2 := (angle_sin * (tempx - _originx) + angle_cos * (tempy - _originy)) + _originy;
	
	// Re-jig things so the final rectangle points go from left to right.  Not mathematically
	// necessary, but more logical to work with later on.
	if x1 &gt; x2 then
		tempx := x1;
		x1 := x2;
		x2 := tempx;
	endif;

	if y1 &gt; y2 then
		tempy := y1;
		y1 := y2;
		y2 := tempy;
	endif;
	
	// Pass back the new rectangle points
	_x1 := x1;
	_y1 := y1;
	_x2 := x2;
	_y2 := y2;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_x1" type="Real" usage="io"/>
        <Parameter name="_y1" type="Real" usage="io"/>
        <Parameter name="_x2" type="Real" usage="io"/>
        <Parameter name="_y2" type="Real" usage="io"/>
        <Parameter name="_angle" type="Real"/>
        <Parameter name="_originx" type="Real"/>
        <Parameter name="_originy" type="Real"/>
    </JadeMethod>
    <JadeMethod name="selectObject" id="742e64e6-66c8-4d75-9cb5-424861da19e8">
        <updating/>
        <source>selectObject(_obj : Object; _frame : CMUI_GridAreaDrawingFrame input; _redraw : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     05 February 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if _obj = null then
		return;
	endif;
	
	if (not self.allSelectedObjects.includes(_obj)) then
		if self.allSelectedObjects.isEmpty() then
			self.startHighlighter();
		endif;

		self.allSelectedObjects.add(_obj);
		self.allObjectEditions.add(_obj);

		if _redraw and _frame &lt;&gt; null then
			_frame.drawObject(_obj, self);
		elseif _redraw and _frame = null then
			app.raiseUnexpectedProgramError(class.name, method.name, 'Cannot redraw object as _frame parameter is null');
		endif;
	endif;

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_frame" type="CMUI_GridAreaDrawingFrame" usage="input"/>
        <Parameter name="_redraw" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="selectObjectAlt" id="fb4c5b22-401d-4973-920d-bc69d0d5725b">
        <updating/>
        <source>selectObjectAlt(_obj : Object; _frame : CMUI_GridAreaDrawingFrame input; _redraw : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     05 February 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if _obj = null then
		return;
	endif;

	if (not self.allSelectedObjectsAlt.includes(_obj)) then
		self.allSelectedObjectsAlt.add(_obj);
		self.allObjectEditions.add(_obj);
		if _redraw then
			_frame.drawObject(_obj, self);
		endif;
	endif;

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_frame" type="CMUI_GridAreaDrawingFrame" usage="input"/>
        <Parameter name="_redraw" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="selectSingleObject" id="0117503a-7d4a-432f-bfbe-db43936bbda7">
        <updating/>
        <source>selectSingleObject(_frame : CMUI_GridAreaDrawingFrame input; x, y : Real; 
				_isAlt : Boolean) : Object updating;
// ---------------------------------------------------------------------------
// Created:     29 January 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpObj	: Object;
	xy1, xy2	: Point;
begin

	if _frame = null then
		return null;
	endif;

	tmpObj := _frame.getObjectAndPointsForPosition(x.Integer, y.Integer, xy1, xy2);
	
	if tmpObj = null then
		return tmpObj;
	endif;

	if _isAlt then
		self.selectObjectAlt(tmpObj, _frame, false);
	else
		self.selectObject(tmpObj, _frame, false);
	endif;

	_frame.drawObjectAt(tmpObj, xy1.x, xy1.y, xy2.x, xy2.y, self);

	return tmpObj;
	
end;</source>
        <Parameter name="_frame" type="CMUI_GridAreaDrawingFrame" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="_isAlt" type="Boolean"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="setAmPrinting" id="b72a4d22-c224-446a-9c26-a609923ebfd3">
        <updating/>
        <source>setAmPrinting(_amPrinting : Boolean; _printOutputSize : Integer; _separateODUD: Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     13 January 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	self.amPrinting := _amPrinting;

	if _amPrinting then
		self.printOutputStyle := _printOutputSize;
		//largeOutput := (amPrinting and theScaleFactor = SHP_BayArea.PrintScaleLarge);
		//mediumOutput := (amPrinting and theScaleFactor = SHP_BayArea.PrintScaleMedium);
		//smallOutput := (amPrinting and theScaleFactor = SHP_BayArea.PrintScaleSmall);

		if _printOutputSize = PrintOutput_Large then
			if _separateODUD then
				self.rowHeight 		:= PrintScaleLargeHeightSeparate;
			else
				self.rowHeight 		:= PrintScaleLargeHeight;
			endif;
			self.columnWidth 	:= PrintScaleLargeWidth;
			self.printSeparateODUD := _separateODUD;
		else
			self.rowHeight 		:= (RowHeightDefault *  self.scaleFactor).Integer;
			self.columnWidth	:= (ColumnWidthDefault * self.scaleFactor).Integer;
			self.printSeparateODUD := false;
		endif;
	else
		self.printOutputStyle := PrintOutput_None;
	endif;

end;</source>
        <Parameter name="_amPrinting" type="Boolean"/>
        <Parameter name="_printOutputSize" type="Integer"/>
        <Parameter name="_separateODUD" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setAttrPositions" id="9ddda37e-77b1-4663-9ec7-1e82d56652cd">
        <updating/>
        <source>setAttrPositions(_displayMode: Integer) updating, protected;
// ---------------------------------------------------------------------------
// Created:     02 September 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	yOffset,
	theX, theY		: Integer; 
	tmpY,
	tmpScaleFactor	: Real;
begin

	tmpScaleFactor := self.scaleFactor;

	if tmpScaleFactor = ScaleFactor_4 then
		yOffset := 3;			
	endif;
	
	theX := (self.columnWidth / 2).Integer + 2;
	theY := (self.rowHeight / 2).Integer - 5;
	
	if tmpScaleFactor = ScaleFactor_9 then
		tmpY := (self.rowHeight - 35).Integer + yOffset;

		self.attrX1 := 2;
		self.attrY1 := tmpY;
		self.attrX2 := 22;
		self.attrY2 := tmpY;
		self.attrX3 := 42;
		self.attrY3 := tmpY;
		self.attrX4 := 62;
		self.attrY4 := tmpY;
		
		self.attrMaxNum := 4;

	elseif tmpScaleFactor = ScaleFactor_6 then
		tmpY := (self.rowHeight - 24).Integer + yOffset;

		self.attrX1 := 2;
		self.attrY1 := tmpY;
		self.attrX2 := 20;
		self.attrY2 := tmpY;
		self.attrX3 := 38;
		self.attrY3 := tmpY;

		self.attrMaxNum := 3;

	elseif tmpScaleFactor = ScaleFactor_4 then
		tmpY := (self.rowHeight - 24).Integer + yOffset;

		self.attrX1 := 2;
		self.attrY1 := tmpY;
		self.attrX2 := 15;
		self.attrY2 := tmpY;
		self.attrX3 := 28;
		self.attrY3 := tmpY;

		self.attrMaxNum := 3;

	elseif tmpScaleFactor = ScaleFactor_3 then
		tmpY := (self.rowHeight - 15).Integer + yOffset;

		self.attrX1 := 2;
		self.attrY1 := tmpY;
		self.attrX2 := 15;
		self.attrY2 := tmpY;

		self.attrMaxNum := 2;

	else
		tmpY := ((rowHeight / 3) * 2).Integer - 4 + yOffset;

		self.attrX1 := 1;
		self.attrY1 := tmpY;
		self.attrX2 := theX.Integer;
		self.attrY2 := tmpY;

		self.attrMaxNum := 2;

	endif;


end;</source>
        <access>protected</access>
        <Parameter name="_displayMode" type="Integer"/>
    </JadeMethod>
