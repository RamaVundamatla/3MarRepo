    <JadeMethod name="getLabel" id="cbbcff87-a56c-4c41-b67e-91ce7cce41c1">
        <source>getLabel(): String;
// ---------------------------------------------------------------------------
// Created:		14 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	tmpLabel : String;
	tmpPos : Integer;
begin
	tmpLabel := inheritMethod();
	
	if tmpLabel = null then  //cnwrd1 whilst looking at unrelated par (17605) label is null raises UE below
		return tmpLabel;
	endif;
	
	/*
	Date		Who		Reason
	18 Sep 2008	cnwdz2	PAR #17930 - solve label overlap problem.
	*/
	//if tmpLabel[1:1] = "&lt;" then
	if tmpLabel.containsOneOf("&lt;") then
		tmpPos := tmpLabel.pos("&gt;",1);
		tmpPos := tmpPos + 1;
		tmpLabel := tmpLabel[tmpPos : end];
	endif;
	
	return tmpLabel;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLaneLabel" id="bf815a77-e408-4280-b13f-fb19ac25de65">
        <source>getLaneLabel() : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 January 2009	cnwjk3	SFW1030

*/

vars
	label	: String;
	pos		: Integer;
begin
	// Format of label is &lt;LL&gt;RRCC
	pos := 2;
	label := self.label.scanUntil("&gt;", pos);
	if pos = 0 then
		return null;
	else
		return label;
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
