	//kill off all the stops being generated.
	//allStopTableTemplates
	foreach stopTemp in term.allStopTableTemplates do
		beginTransaction;
		delete stopTemp;
		commitTransaction;
	endforeach;
	
	defVoyage := term.getConfig(DefVoyage).CM_Voyage;
	
	foreach rtQueueTask in CM_RTQueueTask.instances do
		if not global.isValidObject(rtQueueTask.myMachine) then
			beginTransaction;
			rtQueueTask.setPropertyValue(CM_RTQueueTask::myMachine.name, null);
			commitTransaction;
		endif;
	endforeach;
	
	foreach voyage in term.allVoyagesArchived do
		if defVoyage &lt;&gt; null and voyage = defVoyage then
			continue;
		endif;
		self.deleteVoyage( voyage.code );
	endforeach;
	foreach voyage in term.allVoyagesByCode do
		if defVoyage &lt;&gt; null and voyage = defVoyage then
			continue;
		endif;
		self.deleteVoyage( voyage.code );
	endforeach;
	
	beginTransaction;
	term.setConfig(DefVoyage,null);
	commitTransaction;
	
	if defVoyage &lt;&gt; null then
		self.deleteVoyage(defVoyage.code);
	endif;
	
