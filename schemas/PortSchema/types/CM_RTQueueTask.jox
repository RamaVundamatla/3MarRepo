    <JadeMethod name="getDirectorOutstanding" id="3415d6fd-5d2c-4111-a8f7-c217503ce906">
        <source>getDirectorOutstanding() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Dec 2021	jlier1	Initial creation 52595

*/

vars
	wle 			: CM_WorkListEntry;
	request  		: CM_Request;
	cargoType 		: CM_CargoType;
begin
	if self.taskType &lt;&gt; TASK_DIRECTOR then
		return null;
	endif;
	wle:=self.myEntry.myWorkListEntry;
	if wle &lt;&gt; null then
		request :=wle.myRequest;
	endif;
	
	if request = null then
		return null;
	endif;
	
	if request &lt;&gt; null then
		cargoType:= request.getCargoType;
	endif;
	
	if cargoType &lt;&gt; null and  cargoType.allowDuplicates then
		return  self.myEntry.getAmountLeftToMoveDisplay;
	else
		return request.myJob.getCountUnactionedWLE.String;		// TFS 47079
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDirectorTaskCargo" id="09857476-d5e1-4876-b0d8-4f8ad49fc484">
        <source>getDirectorTaskCargo( 	_cargoId : String;
						_allDirectorCargo :CM_TIArray input;
						_twinTI : CM_TrackedItem);
/*

Date		Who		Reason
14 August 2014	cnwer1	Initial creation PAR
16/09/2019	JLGNS1	Bug 46475: PNL - Tandem Director Tasks from Gridded Block Stacks
07/09/2021	jlier1	TFS 51588  - for release to road or rail do not show ready to ship or cargo in a load voyage job
*/

vars
	twinLoc,
	sourceLC : CM_LocationsController;
	sourceTA : CM_TerminalArea;
	request : CM_Request;
	coll : Collection;
	deleteColl : Boolean;
	iter : Iterator;
	ti : CM_TrackedItem;
	sideAccessDirection : Integer;
	tiArray	: CM_TIArray;
	 errorString : String;
	direction	: Integer;
	invalidObj : Boolean;
	isReleaseToRoadOrRail   : Boolean;
	job						: CM_Job;
	tiLc					: CM_LocationsController;
	machConfig 	: CM_RTVehicleConfig;
begin
	if not self.taskType = TASK_DIRECTOR then
		return;
	endif;
	
	sourceLC:=self.sourceLocation;
	request:= self.myEntry.getMyRequest();
	sourceTA:=self.getDirectorTaskSourceTA;
	self.getDirectorTaskCargoColl(coll,deleteColl);
	
	iter:=coll.createIterator;
	
	on CM_Exception do app.validationExHandler(exception, app.myPassport);
	on Exception do app.handleDeletedObject(exception,self,invalidObj);
	app.setContinueCMExceptions(true);
	
	//jlier1 TFS 51588 2/9/21 - if releasing to road or rail and cargo is ready to ship then don't show on directors list
	if request &lt;&gt; null then
		if request.isReleaseType then
			job:=request.myJob;			
			if job &lt;&gt; null and (job.isKindOf(CM_RoadJob) or job.isKindOf(CM_RailJob)) then
				isReleaseToRoadOrRail:=true;
			endif;
		endif;
	endif;
	
		
	if self.machine &lt;&gt; null then
		machConfig:=self.getMyTerminal.getRTVehicleConfigForObject(self.machine);
	endif;
	
	create tiArray transient;
	while iter.back(ti) do
		if invalidObj then
			return;
		endif;
		
		if _allDirectorCargo.includes(ti) then
			continue;
		endif;
		
		//epr TFS 6863 13/9/17
		if _cargoId &lt;&gt; null then
			if not (ti.id.startsWith(_cargoId) or ti.id.endsWith(_cargoId)) then
				continue;
			endif;	
		endif;
		//jlier1 TFS 51588 2/9/21
		if isReleaseToRoadOrRail then
			if ti.readyToShip then //or ti.getFirstAvailableLoadJob &lt;&gt; null then
				continue;
			endif;
		endif;
		
		if self.isAnyId then //04 Aug 2014	NDl Par 34675
			if not ti.isTiAvailableForAnyIdSelection() then
				continue;
			endif;
			_allDirectorCargo.add(ti);
			continue;
		endif;
		
		app.myPassport.clearErrorsWarnings();
		
		ti.testAgainstRequest(request);
	
		//epr 24/5/17 noticed in vmt generic changes
		if self.myMachine &lt;&gt; null then
			if not self.myMachine.canMachineMoveTI(ti,self.myEntry,self.targetLocation,false,null) then
				continue;
			endif;
		endif;
		
		tiLc := ti.myPrimaryActualLocation;
		
		if _twinTI &lt;&gt; null then
			if not _twinTI.myPrimaryActualLocation.canTwinLiftWithLocation(tiLc,_twinTI,ti,REAL_MODE,direction,errorString) then
				continue;
			endif;
		endif;
		
		//epr par 24995 14/7/10
		if app.myPassport.hasErrorsOrNonIgnoredWarnings then
			app.myPassport.dumpErrorWarnings;
			continue;
		endif;
		
		//cnwrd1 par 32041 if we have a sourceTA then make sure the TI is in that source TA... (used to filter some BR assigned cargo)
		if sourceTA &lt;&gt; null and tiLc.myTerminalArea &lt;&gt; null and  tiLc.myTerminalArea &lt;&gt; sourceTA then	
			continue;
		endif;
		
		if tiLc &lt;&gt; null and tiLc.isKindOf(CM_GridController) then
			
			if sourceTA.isKindOf(CM_ForkLiftStack) then	
				//cnwrd1 par 29352 3.4.2012 - if we are GBS  area we want to check overstow like this
				//sideAccessDirection := null;
				//tiArray.clear();
				//ti.getAllOverstowedTIs(tiArray,false,sideAccessDirection,null);
				//17/9/25   jlier1 MTN-35637
				if self.machine &lt;&gt; null and self.machine.isTandemLift then	//Bug 46475
					if ti.numOverstows &gt; 1 then								//Bug 46475
						continue;											//Bug 46475
					endif;													//Bug 46475
				else	
					//Bug 46475
					if ti.numOverstows &gt; 0 then
						//17/9/25   jlier1 MTN-35637
						if machConfig = null or (machConfig.overstowMoveMode &lt;&gt; CM_RTVehicleConfig.OSTOW_NONE and (machConfig.maxNumberOverstowForDriver &lt;&gt; 0 and ti.numOverstows &gt; machConfig.maxNumberOverstowForDriver))  then			
							continue;
						endif;
					endif;
				endif;
			else					
				if ti.numOverstows &gt; 0 then
				//17/9/25   jlier1 MTN-35637
				// Filter out TIs which aren't at the top of the stack - NOpe top of stack could still be oevrstowed!!
					if machConfig = null or (machConfig.overstowMoveMode &lt;&gt; CM_RTVehicleConfig.OSTOW_NONE and (machConfig.maxNumberOverstowForDriver &lt;&gt; 0 and ti.numOverstows &gt; machConfig.maxNumberOverstowForDriver))  then			
						continue;
					endif;
				endif;
			endif;
		endif;
		
		_allDirectorCargo.add(ti);

	endwhile;
	
	
	//epr TFS 49398 - 5/7/21 if last one tested had errors would stop all valid cargo from being displayed
	app.myPassport.clearErrorsWarnings();
epilog
	if deleteColl then
		delete coll;
	endif;
	delete iter;
	delete tiArray;
end;</source>
        <Parameter name="_cargoId" type="String"/>
        <Parameter name="_allDirectorCargo" type="CM_TIArray" usage="input"/>
        <Parameter name="_twinTI" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getDirectorTaskCargoColl" id="cffcfc6c-aa5e-4f80-86bb-393183c7e7e2">
        <source>getDirectorTaskCargoColl( _coll :  Collection output; _isTransient : Boolean output) protected;
/*   Gets the collection of cargo from which to test against the release

Date			Who		Reason
14 Aug 2014		cnwer1	Initial creation PAR
19 Nov 2025		navpw1	JIRA: MTN-36370 - Fixed transient leak
04 Dec 2025		navma1  MTN-36742 AAT- Webb Dock West (WDCT) experiencing slowness    
*/

vars
	request 	  : CM_Request;
	allTIs		  : ObjectSet;
	gridObjTis	  : CM_TIArray;
	sourceTA 	  : CM_TerminalArea;
	isInternalJob : Boolean;
	job 		  : CM_Job;
begin
	request		:= self.myEntry.getMyRequest();
	sourceTA	:= self.getDirectorTaskSourceTA;
	job 		:= self.myEntry.myJob;
	
	if job &lt;&gt; null and job.isKindOf(CM_YardInternalJob) then
		isInternalJob:=true;
	endif;
	
	create allTIs transient;		
	//epr if it is an internal job we don't want to see the list of assigned to move but the available in the source area to move
	if not isInternalJob and request.hasAssignedItems(allTIs) then				//04.12.2025 navma1 #MTN-36742		
		_coll			:= allTIs;
		_isTransient	:= true;
	elseif sourceTA.isKindOf(CM_BlockStack) then
		_coll			:= sourceTA.CM_BlockStack.myLocationsController.allTrackedItems;
		_isTransient	:= false;
		delete allTIs;				// ### JIRA: MTN-36370 19Nov2025 NAVPW1 - Causes unit test transient leaks
	elseif self.myGridObject &lt;&gt; null then  //cnwrd1 par 29352 3.4.2012 if we have a grid object we want to look there
		create gridObjTis transient;
		self.myGridObject.getTIs(gridObjTis, REAL_MODE);
		_coll			 := gridObjTis;
		_isTransient	 := true;
		delete allTIs;				// ### JIRA: MTN-36370 19Nov2025 NAVPW1 - Causes unit test transient leaks
	else
		allTIs.clear;
		if sourceTA &lt;&gt; null then
		sourceTA.getAllLocationsTrackedItems(allTIs);
		endif;
		_coll:= allTIs;
		
		_isTransient:=true;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_coll" type="Collection" usage="output"/>
        <Parameter name="_isTransient" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getDirectorTaskSourceTA" id="fbf74c58-fa0e-458d-9e3f-77b94d9ffcd1">
        <source>getDirectorTaskSourceTA() : CM_TerminalArea;
/*

Date		Who		Reason
14 August 2014	cnwer1	Initial creation PAR

*/

vars
	request : CM_Request;
	sourceTA : CM_TerminalArea;
begin
	request:= self.myEntry.getMyRequest();
	
	if self.sourceLocation &lt;&gt; null and
	   self.sourceLocation.isGridLocation() then
		sourceTA:= self.sourceLocation.myTerminalArea;
	elseif self.sourceLocation.isKindOf(CM_BlockController) then
		sourceTA:=self.sourceLocation.myTerminalArea;
	elseif self.sourceLocation.isKindOf(CM_RoRoController) then	//29 May 2012	NDL	Par 29641
		sourceTA:=self.sourceLocation.myTerminalArea;
	elseif self.sourceLocation.isKindOf(CM_IrregularBlockController) then   // CCMS 2384
		sourceTA:=self.sourceLocation.myTerminalArea;
	elseif self.sourceLocation.isKindOf(CM_BulkLocation) then
		sourceTA := self.sourceLocation.myTerminalArea;
	else
		sourceTA:=request.getSourceTA();
	endif;
	
	return sourceTA;
epilog

end;</source>
        <ReturnType type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="d0e4e51f-261c-4364-9cb8-0dd4fa6f9afa">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 January 2009	cnwer1	Initial creation
02 May 2016	cnwns1	TFS 488 - Multi Timezone Support
16 Dec 2021 jlier1	TFS 52595
25 Feb 2022	jlier1	TFS 52833- still need CR#
20 Jun 2022	navdap1	TFS 53362 EUP Master Data interface customers between TOS and ERP
25 Aug 2022 jlier1	TFS 54490 
01 Feb 2023	navak20 Task 56395: EUP - Remedial 53131 - Add missing field in Vehicle RT Config and Vehicle App
17 Apr 2023	jlika1	TFS 56650 - PNL - Vehicle RT Config "Release" &amp; "Receipt" Carrier
27 Apr 2023	jlika1	TFS 57154 - CUX | New mafi related fields for display in the vehicle app
22 Nov 2023	jlika1	TFS 61135 61143 CUX | Cargo Priority - Vehicle App
24 Nov 2023	jlizm1	TFS 61273 add Onboard Isotype group field
12 Dec 2023	jlika1	TFS 61189 61649 RTL - Vehicle Apps fields
23 Jan 2023	jlika1	TFS 62128 CUX | Additional fields in Vehicle App
19 Feb 2024 navbk1  CR  55466 SNO - Can the elapsedTime field as available in the in Vehicle Mounted Terminal ( for Old Thin Client ) be made available in the Vehicle Apps as well 
11 Mar 2024	jlika1	TFS 62803 CUX | Onboard cargo - new get methods and additional locations
18 Mar 2024	jlika1	TFS 62840 CUX | Remove one of the fields displaying onboard cargo IDs
16 Oct 2024 navma1	MTN-33090 MTN - Error 1239 when calling MTNInternalAPIService::getTasks
17 Dec 2024 navbk1  NXL - Vehicle app displaying the minimum information while trying to access in Android System
*/

vars
	overstowed,
	overstowedAtMoveTime : Boolean;
	sideAccessDirection,
	numberAlerts 		 : Integer;
	twinTI				 : CM_TrackedItem;
	task 				 : CM_RTQueueTask;
	request 			 : CM_Request;
	temp 				 : Real;
	trailer 		 	 : CM_TILC;
	job				 	 : CM_Job;
	vvr				 	 : CM_VehicleVisitRecord;																	// 19.02.24 navbk1 CR 55466
	time   			 	 : Integer;																					// 19.02.24 navbk1 CR 55466
	customerPriority 	 : CM_CustomerPriority;
	rTVehicleConfig		 : CM_RTVehicleConfig;
	rTMoveMethodRule	 : CM_RTMoveMethodRule;
	wle					 : CM_WorkListEntry;
begin

	if _attrName = ETRow_Status 	or
	   _attrName = ETRow_QueuePos	or
	   _attrName = ETRow_EntryPos   or
	   _attrName = ETRow_TwinCarry  or
	   _attrName = ETRow_Info       or
	   _attrName = ETRow_TaskPos	then
		return null;
	elseif  _attrName = ETRow_QueueId or _attrName = ETRow_QueueID then
		return self.myEntry.queueId;
	elseif _attrName = ETRow_ItemId or _attrName = ETRow_ContainerID or _attrName = ETRow_Id then
		return self.getTaskId();		
	elseif _attrName = ETRow_TaskStatus then
		return self.statusString;
	elseif _attrName = ETRow_Task then
		return self.taskTypeId;
	elseif _attrName = ETRow_Overstow then	// PAR 21532 CCMS SFW 1025
		self.isOverStowedRTQueue(overstowed,overstowedAtMoveTime,sideAccessDirection);
		return app.getYesBlank(overstowedAtMoveTime);
	elseif _attrName = ETRow_Or then
		return self.myEntry.getOverRideFlag();
	elseif _attrName = ETRow_Alerts then
		numberAlerts := self.getNumberOfAlerts;
		if numberAlerts &gt; 0 then
			return numberAlerts.asStringJMT;
		endif;
		return null;
	elseif _attrName = ETRow_Assigned then
		return self.getMachineID();
	elseif _attrName = ETRow_Time then
		return self.systemToLocalTime(self.machineAssignedDT).asStringJMT(); //02 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	elseif _attrName = ETRow_Source or _attrName = ETRow_SourceLocation then
		// 23099, director tasks from gridded areas
		return self.getSourceLocationId;
	elseif _attrName = ETRow_Target then
		return self.getTargetLocationForDisplay();
	elseif _attrName = ETRow_Voyage then
		return self.getVoyageCode();
	elseif _attrName = ETRow_TaskOid then
		return self.getOidString();
	elseif _attrName = ETRow_EntryOid then
		return self.myEntry.String;
	
	elseif _attrName = ETRow_RtMoveMethod then
		rTMoveMethodRule := self.myEntry.myRTMoveMethodRule;
		if  rTMoveMethodRule &lt;&gt; null then
			return rTMoveMethodRule.getDisplayDetails(true);
		endif;
		return null;
	elseif _attrName = ETRow_IsDefaultMoveMethod then
		rTMoveMethodRule := self.myEntry.myRTMoveMethodRule;
		if rTMoveMethodRule &lt;&gt; null then
			return rTMoveMethodRule.isDefault.getYes();
		endif;
		return null;
	elseif _attrName = ETRow_DoorDirection then
		return self.getDoorDirection;
	elseif _attrName = ETRow_Operator then
		if app.myRoot.getConfig(ComboByNameOperator).Boolean then	// TFS 53362
			return self.getOperatorDesc;							// TFS 53362
		endif;														// TFS 53362
		return self.getOperatorCode();
	elseif _attrName = ETRow_Weight then
		if self.ti &lt;&gt; null then
			return self.ti.getDefaultTotalWeightDisplay();
		endif;
		return null;
	elseif _attrName = ETRow_Damaged then
		if self.ti &lt;&gt; null then
			return self.ti.damaged.asStringJMT;
		endif;
		return null;
	elseif _attrName = ETRow_Colour then
		return self.getColour;
	elseif _attrName = ETRow_Amount then
		return self.getMoveAmountDisplay();
	elseif _attrName = ETRow_FinalTargetLoc then
		wle := self.myEntry.myWorkListEntry;
		if wle &lt;&gt; null then
			return wle.getFinalTaskTargetLocId;
		endif;
		return null;
	elseif _attrName = ETRow_CargoType then
		return self.getCargoTypeDesc();
	elseif _attrName = ETRow_CargoSubType then
		return self.getCargoSubTypeDesc();
	elseif _attrName = ETRow_Carrier then
		return self.getCarrier();
	elseif _attrName = ETRow_Commodity then
		if self.ti &lt;&gt; null then
			return self.ti.commodity;
		endif;
		return null;
	elseif _attrName = ETRow_DischargePort then
		if self.ti &lt;&gt; null then
			return self.ti.dischargePort;
		endif;
		return null;
	elseif _attrName = ETRow_Grade then
		return self.getAVGradeDesc();
	elseif _attrName = ETRow_IsCA then
		if self.ti &lt;&gt; null then
			return (self.ti.isControlledAtmosphere).asStringJMT;
		endif;
		return null;
	elseif _attrName = ETRow_QueueID then
		return self.queueId;
	elseif _attrName = ETRow_RfidTag then
		return self.getRFIDNumber;
	elseif _attrName = ETRow_Voyage then
		return self.getVoyageCode;
	elseif _attrName = ETRow_IsoGroup then
		return self.getISOGroupCode;
	elseif _attrName = ETRow_IsoType then
		return self.getISOTypeCode;
	elseif _attrName = ETRow_Remarks then
		return self.getRemarks;
	elseif  _attrName = ETRow_TempC then
		if self.ti &lt;&gt; null then	
			temp:=self.ti.getTemperature();
			//jlier1 TFS 55139 17/10/22
			if temp &lt;&gt; NULL_TEMPERATURE then			
				return temp.asStringJMT;
			endif;
		endif;
		return null;
	elseif  _attrName = ETRow_TempF then
		if self.ti &lt;&gt; null and ti.displayTempFahrenheit  then
			return self.ti.temperatureInFahrenheit.asStringJMT;
		endif;
		return null;
	elseif _attrName = ETRow_TwinLift then
		return self.myEntry.getTwinCarryFlayDisplay();
	elseif  _attrName = ETRow_JobID then
		job := self.myEntry.myJob;
		if job &lt;&gt; null then
			return  job.jobId;
		endif;
		return null;
	elseif _attrName = ETRow_Mark then
		return self.getMark;
	elseif _attrName = ETRow_ReleaseRequestNumber then
		return self.getReleaseRequestID;
	elseif _attrName = ETRow_TwinLoadContainerId then
		if self.ti &lt;&gt; null then
			twinTI:=ti.getTwinVoyageLoadTI;
			if twinTI &lt;&gt; null then
				return twinTI.id;
			endif;
		endif;
		return null;
	elseif _attrName = ETRow_ToDoTasks then
		if self.ti &lt;&gt; null then
			return ti.getToDoTasksDisplay(ti.allToDoTasksToDo, false);
		endif;
		return null;
	elseif _attrName = ETRow_Consignee then	
		return self.getConsignee;
	elseif _attrName = ETRow_Consignor then// 25 Aug 2022 jlier1	TFS 54490 
		return self.getConsignor();
	elseif _attrName = ETRow_ModifiedDoor then
		rTVehicleConfig :=  app.myPassport.myTerminal.myRTVehicleConfig;
		if rTVehicleConfig &lt;&gt; null then
			return rTVehicleConfig.getDoorDirHookString(self,self.isPickUp);
		endif;
		return null;
	elseif _attrName = ETRow_ModifiedIsoType then
		rTVehicleConfig :=  app.myPassport.myTerminal.myRTVehicleConfig;
		if rTVehicleConfig &lt;&gt; null and self.ti &lt;&gt; null then
			return rTVehicleConfig.getIsoTypeHookString(self.ti);
		endif;
		return null;
	elseif _attrName = ETRow_ModifiedSource then
		rTVehicleConfig := app.myPassport.myTerminal.myRTVehicleConfig;
		if  rTVehicleConfig = null then
			return null;
		endif;
		if self.isPickUp then
			 task := self;		
		else	
			task := self.myEntry.getDirectorOrPickupTask();	
		endif;
			
		if task &lt;&gt; null then
			return rTVehicleConfig.getLocationHookString(task,true);
		endif;
		return null;
	elseif _attrName = ETRow_ModifiedTarget then
		
		rTVehicleConfig := app.myPassport.myTerminal.myRTVehicleConfig;
		if rTVehicleConfig = null then
			return null;
		endif;
		if self.isSetDown then
			task:=self;		
		else	
			task := self.myEntry.getDirectorOrSetDownTask();	
		endif;
			
		if task &lt;&gt; null then
			return rTVehicleConfig.getLocationHookString(task,false);
		endif;
		return null;
	elseif _attrName = ETRow_OverdimensionalText then
		if self.ti = null then
			return null;
		endif;
		return self.ti.getODDescription;
	elseif _attrName = ETRow_AllTIHazards then
		if self.ti &lt;&gt; null then
			return self.ti.getAllHazardsAsString();			//16.10.2024 navma1 #MTN-33090
		endif;
		return null;
	elseif _attrName = ETRow_PreTripDate then
		if self.ti = null then
			return null;
		endif;
		
		return self.ti.getPreTripDTLocalTZ().asStringJMT;	
	elseif _attrName = ETRow_DwellDays then
		if self.ti = null then
			return null;
		endif;
		return self.ti.getDwellDays.asStringJMT;	
	elseif _attrName = ETRow_IsOverDimension then
		if self.ti = null then
			return null;
		endif;
		
		return self.ti.isOverDimensions.asStringJMT;
	elseif _attrName = ETRow_AlternativeId then
		//jlier1 TFS 53530 25/8/22
		if self.ti &lt;&gt; null then
			return self.ti.alternativeId;
		endif;
		return null;
	elseif _attrName = ETRow_IsHeavyDuty then
		//jlier1 TFS 54531  25/8/22
		if self.ti &lt;&gt; null then
			return app.getYesNo(self.ti.getIsHeavyDuty);
		else
			//jlier1 TFS 54814 13/9/22
			request :=self.getTaskRequest;
			if request &lt;&gt; null and request.isDeliveryRequest then
				return app.getYesNo(request.CM_DeliveryRequest.heavyRated);
			endif;
		endif;
		return null;
	elseif _attrName = ETRow_TrailerID then
		//jlier1 TFS 54676  20/10/22 
		if self.ti &lt;&gt; null then
			if self.ti.isTILC then
				trailer:=self.ti.CM_TILC;
			else
				trailer:= self.ti.getCurrentTrailer;
			endif;	
			if trailer &lt;&gt; null then
				return trailer.id;
			endif;
		endif;
		return null;
	elseif _attrName = ETRow_TrailerLocation then
		//jlier1 TFS 54676 1 20/10/22 
		if self.ti &lt;&gt; null then	
			if self.ti.isTILC then
				trailer:=self.ti.CM_TILC;
			else
				trailer:= self.ti.getCurrentTrailer;
			endif;	
			if trailer &lt;&gt; null then
				return trailer.locationId;
			endif;	
		endif;
		return null;
	elseif _attrName = ETRow_TrailerOperator then
		//jlier1 TFS 54676  20/10/22 
		if self.ti &lt;&gt; null then	
			if self.ti.isTILC then
				trailer:=self.ti.CM_TILC;
			else
				trailer:= self.ti.getCurrentTrailer;
			endif;	
			if trailer &lt;&gt; null then
				return trailer.getOperatorDisplay;
			endif;
			
		endif;
		return null;
	elseif _attrName = ETRow_HighestCargoHeight then
		//jlier1 TFS 54676  20/10/22 
		if self.ti &lt;&gt; null then
			if self.ti.isTILC then
				trailer:=self.ti.CM_TILC;
			else
				trailer:= self.ti.getCurrentTrailer;
			endif;	
			
			if trailer &lt;&gt; null then
				return trailer.getHighestCargoHeightDisplay();
			endif;
		endif;
		return null;
	elseif _attrName = ETRow_TrailerType then
		//jlier1 TFS 54676 26/10/22
		if self.ti &lt;&gt; null then
			if self.ti.isTILC then
				trailer:=self.ti.CM_TILC;
			else
				trailer:=self.ti.getCurrentTrailer;
			endif;
			
			if trailer &lt;&gt; null then
				return trailer.getTrailerTypeDesc();
			endif;
		endif;
		return null;
	// 01.02.2023 navak20 TFS 56395
	elseif _attrName = ETRow_ShippingLineCode then
		if self.ti &lt;&gt; null then
			return ti.getShippingLineCode();
		endif;
		return null;
	elseif	_attrName = ETRow_ShippingLineDesc then
		if self.ti &lt;&gt; null then
			return ti.getShippingLineDesc();
		endif;
		return null;
	elseif	_attrName = ETRow_ReceiptCarrier then
		if self.ti &lt;&gt; null then
			return ti.getCarrier();
		endif;
		return null;	
	elseif _attrName = ETRow_ObCargoTypes then 
		if self.ti &lt;&gt; null then
			return ti.getOnboardCargoTypes();	
		endif;
		return null;
	elseif _attrName = ETRow_ObCargoSubtypes then 
		if self.ti &lt;&gt; null then
			return ti.getOnboardSubTypes();
		endif;
		return null;
	elseif _attrName = ETRow_ObISOTypes then 
		if self.ti &lt;&gt; null then
			return ti.getOnboardISOTypes();
		endif;
		return null;
	elseif _attrName = ETRow_ObISOTypeGroups then 
		if self.ti &lt;&gt; null then
			return ti.getOnboardISOTypeGroups();
		endif;
		return null;
	elseif _attrName = ETRow_ObHaz then 
		if self.ti &lt;&gt; null then
			return ti.getOnboardHazardous();
		endif;
		return null;
	elseif _attrName = ETRow_ObHazDetails then 
		if self.ti &lt;&gt; null then
			return ti.getOnboardHazDetails();
		endif;
		return null;
	elseif _attrName = ETRow_ObReefer then 
		if self.ti &lt;&gt; null then
			return ti.getOnboardReefer();
		endif;
		return null;
	elseif _attrName = ETRow_ObStops then 
		if self.ti &lt;&gt; null then
			return ti.getOnboardHasStops();
		endif;
		return null;
	elseif _attrName = ETRow_ObStopTypes then 
		if self.ti &lt;&gt; null then
			return ti.getOnboardStopsDetails();
		endif;
		return null;
	elseif _attrName = ETRow_ObDamage then 
		if self.ti &lt;&gt; null then
			return ti.getOnboardDamaged();
		endif;
		return null;
	elseif	_attrName = ETRow_ReleaseCarrier then
		if self.ti &lt;&gt; null then
			if ti.releaseCarrier &lt;&gt; null then
				return ti.getCarrier();
			else
				job :=  self.myEntry.myJob;
				if job &lt;&gt; null and job.isRoadJob and job.isRelease() and job.CM_RoadJob.myCarrier &lt;&gt; null then
					return job.CM_RoadJob.myCarrier.code;
				endif;
			endif;
		endif;
		return null;
	elseif _attrName = ETRow_MyCustomerPriority then 
		if self.ti &lt;&gt; null then
			customerPriority :=  self.ti.getCustomerPriority();						//16.10.2024 navm1 #
			if customerPriority &lt;&gt; null then
				return customerPriority.getDisplayDetails(false);
			endif;
		endif;
		return null;
	elseif _attrName = ETRow_ReadyToLoad then 
		if self.ti &lt;&gt; null then
			return ti.readyToLoad.getYesNo();
		endif;
		return null;
	elseif _attrName = ETRow_TareWeight then 
		if self.ti &lt;&gt; null then
			return ti.getTareWeightDisplay();
		endif;
		return null;
	elseif _attrName = ETRow_ContentsStatus then 
		if self.ti &lt;&gt; null then
			return ti.getContentsStatusDesc(true);
		endif;
		return null;
	elseif _attrName = ETRow_ObTemperatures then 
		if self.ti &lt;&gt; null then
			return ti.getOnboardTemperatures();
		endif;
		return null;
	elseif _attrName = ETRow_ObCommodities then 
		if self.ti &lt;&gt; null then
			return ti.getOnboardCommodities();
		endif;
		return null;
	elseif _attrName = ETRow_ObConsignorConsignee then 
		if self.ti &lt;&gt; null then
			return ti.getOnboardConsigneeConsignor();
		endif;
		return null;
	elseif _attrName = ETRow_CargoWeight then 
		if self.ti &lt;&gt; null then
			return ti.getDefaultCargoWeightDisplay();
		endif;
		return null;
	elseif _attrName = ETRow_CargoOnboard then 
		if self.ti &lt;&gt; null then
			return ti.getOnboardCargoId();
		endif;
		return null;
	elseif _attrName = ETRow_CargoPlannedOnboard then 
		if self.ti &lt;&gt; null then
			return ti.getOnboardPlannedCargo();
		endif;
		return null;
	elseif _attrName = ETRow_CargoQueuedOnboard then 
		if self.ti &lt;&gt; null then
			return ti.getOnboardQueuedCargo();
		endif;
		return null;
	elseif _attrName = ETRow_ElapsedTime then                                                          // 19.02.24 navbk1 CR 55466
		if self.myEntry &lt;&gt; null then
			job := self.myEntry.myJob;
		endif;
	
		if job.isRoadJob then
			vvr := job.CM_RoadJob.myVehicleVisit;
			if vvr &lt;&gt; null then
				time := vvr.getElapsedTime();
			endif;
		else
			time := (app.actualTimeServer.getDifferenceInMinutes(self.createdTime) + 1);
		endif;
		if time &gt;0 then
			return time.asDHMString();
		endif;
		return null;
	elseif _attrName = ETRow_ImexStatus then													//17.12.2024 navbk1 #33677
		if self.ti &lt;&gt; null then
			return ti.getImExStatusString();
		endif;
		return null;
	elseif _attrName = ETRow_CargoTypeCodeForCntnt then
		
		if self.ti &lt;&gt; null then
			return ti.getCargoTypeCodeForContents(); //02/10/2025	navkc1 JIRA 36144 
		endif;
		
		return null;
	elseif _attrName = ETRow_CargoTypeForCntnt then
		
		if self.ti &lt;&gt; null then
			return ti.getCargoTypeDescForContents(); //02/10/2025	navkc1 JIRA 36144 
		endif;
		
		return null;
	elseif _attrName = ETRow_CargoSubTypeCodeForCntnt then
		
		if self.ti &lt;&gt; null then
			return ti.getCargoSubTypeCodeForContents(); //02/10/2025	navkc1 JIRA 36144 
		endif;
		
		return null;
	elseif _attrName = ETRow_CargoSubTypeForCntnt then
		
		if self.ti &lt;&gt; null then
			return ti.getCargoSubTypeDescForContents(); //02/10/2025	navkc1 JIRA 36144 
		endif;
		
	return null;
	else
		return inheritMethod(_attrName, _short);
	endif;
	
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDoorDirection" id="6f6e85df-c258-4788-99f1-883a460cb248">
