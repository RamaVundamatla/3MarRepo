    <JadeMethod name="activateDoManually" id="2b825497-3457-496e-802d-a165259a39d8">
        <updating/>
        <source>activateDoManually() updating;
//********************************************************************
//
// Created by: cnwsh3
//
// Date: 09 December 2003
//
//********************************************************************
vars

begin
	self.doManually := true;
end;</source>
    </JadeMethod>
    <JadeMethod name="addItemObject" id="0ee982e2-667a-46b6-b31d-dc0936cc539c">
        <updating/>
        <source>addItemObject(_str : String; _obj : Object) : Integer updating;
// ---------------------------------------------------------------------------
// Created:     18 February 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	idx	: Integer;

begin

	idx := self.addItem(Tab &amp; _str);
	if _obj &lt;&gt; null then
		self.accessRow(idx).itemObject := _obj;
	endif;
	return idx;

end;</source>
        <Parameter name="_str" type="String"/>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addSelectedObject" id="93a97f2b-12b6-4400-948a-2a816911d08a">
        <updating/>
        <source>addSelectedObject(_obj : Object) updating;
// ---------------------------------------------------------------------------
// Created:     01 December 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	idx	: Integer;
begin
	if _obj = null then
		return;
	endif;
	if (not self.allSelectedObjects.includes(_obj)) then
		self.allSelectedObjects.add(_obj);
		if self.findObjectInRow(_obj, idx) then
			self.accessCell(idx, self.chkBoxColumn).text := TableCheckBox_Selected;
		endif;
	endif;
	
end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="areAllRowsSelected" id="52efc20a-5505-4572-b18c-3abfbdbc19c7">
        <updating/>
        <source>areAllRowsSelected(_selected : Boolean) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:		November 2006 By Andrew Bishop NAVAB1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	idx,
	max			: Integer;
begin
	max := self.rows;
	
	if max &lt; 1 then
		return true;
	endif;
	
	foreach idx in 1 to max do
		if (self.accessCell(idx, self.chkBoxColumn).text =TableCheckBox_Selected) &lt;&gt; _selected then
			return false;
		endif;
	endforeach;

	return true;
end;</source>
        <Parameter name="_selected" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="change" id="f23a1a07-bbc5-476e-9b10-d30174471e8a">
        <updating/>
        <source>change(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:     01 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	obj	: Object;
	
begin

	inheritMethod(table);

	if table.row &gt; 0 and table.row &lt;= table.rows then
		obj := table.accessRow(table.row).itemObject;
		if self.rowChecked(table.row) then
			if (not self.allSelectedObjects.includes(obj)) then
				self.allSelectedObjects.add(obj);
			endif;
		else
			if self.allSelectedObjects.includes(obj) then
				self.allSelectedObjects.remove(obj);
			endif;
		endif;
	endif;
	
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="chkBoxFirst" id="37073455-3e65-4115-b8be-5b90bdaa041f">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>chkBoxFirst(set: Boolean; _value: Boolean io) updating, mapping;
// ---------------------------------------------------------------------------
// Created:     01 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if set then
		if _value then
			self.chkBoxColumn 	:= 1;
		else
			self.chkBoxColumn 	:= self.columns;
		endif;
	else
		_value := (self.chkBoxColumn = 1);
	endif;
	
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="clear" id="7d70d92b-a406-4d53-b4a8-145a3a757cda">
        <executionLocation>client</executionLocation>
        <source>clear() clientExecution;
//----------------------------------------------------------------
//	Created:	29 October 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	inheritMethod();


epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="clearSelected" id="facb7578-cae0-449d-bde5-d86add1d4865">
        <updating/>
        <source>clearSelected() updating;

vars
	maxRows, theFirstRow, idx, chkCol	: Integer;
begin
	self.allSelectedObjects.clear;
	
	chkCol 		:= self.chkBoxColumn;
	maxRows 	:= self.rows;
	theFirstRow := self.fixedRows + 1;
	
	foreach idx in theFirstRow to maxRows do
		self.accessCell(idx, chkCol).text 	:= TableCheckBox_NotSelected;
		self.accessRow(idx).selected 		:= false;
	endforeach;

	if maxRows &gt;= theFirstRow then
		self.row := theFirstRow;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="clearTable" id="65534968-cc1b-4df7-9fcc-e292cbd1258f">
        <updating/>
        <source>clearTable() updating;
//--------------------------------------------------
// Created:	25 November 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.allSelectedObjects.clear();
	self.clear();
	self.rows := 0;	
end;</source>
    </JadeMethod>
    <JadeMethod name="click" id="abc23c2e-b3bb-40ae-964b-b491ea08be55">
        <updating/>
        <source>click(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:     01 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	cell	: JadeTableCell;
	theRow : Integer;
begin
	if table.readOnly then
		return;
	endif;
	theRow := table.row;

	if table.userInputEnabled and (theRow &gt; 0 and theRow &lt;= table.rows) then
		self.highlightRow(theRow);
		if self.doManually then
			// the click occured in column 2 so we will need to
			// change the value of the checkbox manually
			cell := table.accessCell(theRow, self.chkBoxColumn);
			if cell.text = TableCheckBox_NotSelected then
				cell.text := TableCheckBox_Selected;
			else
				cell.text := TableCheckBox_NotSelected;
			endif;
			self.doManually := false;
			table.change(table);
		endif;
	endif;
	
	inheritMethod(table);
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="create" id="81a7a152-ff22-4172-9691-5f13d8dfff23">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     01 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 13/08/2013	cnwdap1		PAR #32123 Remove write statement
// ---------------------------------------------------------------------------
vars

begin
//write self.class.name &amp; '::' &amp; method.name;	// PAR #32123
	self.rows 		:= 0;
	self.columns 	:= 3;
	self.fixedRows 	:= 0;
	self.fixedColumns := 0;
	
	self.selectMode := SelectMode_Row;
	self.gridLines	:= false;
	self.scrollBars	:= ScrollBars_Vertical;
	self.autoSize	:= AutoSize_ColumnMinimum;

	self.chkBoxFirst := true;

	
end;</source>
    </JadeMethod>
    <JadeMethod name="deselectAll" id="6b59c6ed-eae4-49b4-8c6e-8000c312a69c">
        <updating/>
        <source>deselectAll()updating;
// ---------------------------------------------------------------------------
// Created:		August 2007 By Andrew Bishop NAVAB1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	numRows,
	rowIdx		: Integer;
	jRow		: JadeTableRow;
begin
	numRows := self.rows;
	if numRows = 0 then
		return;
	endif;
	
	self.allSelectedObjects.clear();


	foreach rowIdx in 1 to numRows do
		jRow := self.accessRow(rowIdx);
		if not jRow.visible then
			continue;
		endif;
		self.accessCell(rowIdx, self.chkBoxColumn).text := TableCheckBox_NotSelected;

	endforeach;


end;</source>
    </JadeMethod>
    <JadeMethod name="findObject" id="cd09cdcd-10c8-4cd6-b78a-68898dc91127">
        <updating/>
        <source>findObject(_obj : Object; _rowIdx : Integer io) : Boolean updating;
//-----------------------------------------
//Created: January 2003 By: cnwgd1
//-----------------------------------------
vars
	idx,
	startPos,
	numRows		: Integer;
	found		: Boolean;
	tableRow	: JadeTableRow;
	
begin

	numRows := self.rows;
	if _rowIdx &gt; numRows then
		return found;
	endif;
	startPos := (self.fixedRows + 1).max(_rowIdx);
	if startPos &gt; numRows then
		return found;
	endif;	 
	
	foreach idx in startPos to numRows do
		tableRow := self.accessRow(idx);
		if tableRow.itemObject = _obj then
			found 	:= true;
			_rowIdx := idx;
			break;
		endif;
	endforeach;

epilog
	return found;
	
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_rowIdx" type="Integer" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findObjectInRow" id="348d7ac1-e5e9-4d0a-94c0-03654c7b05df">
        <updating/>
        <source>findObjectInRow(_obj : Object; _rowIdx : Integer io) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     15 September 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	idx,
	startPos,
	numRows		: Integer;
	found		: Boolean;
	
begin
	if _obj = null then
		return found;
	endif;
	
	numRows := self.rows;
	if _rowIdx &gt; numRows then
		return found;
	endif;
	startPos := (self.fixedRows + 1).max(_rowIdx);
	if startPos &gt; numRows then
		return found;
	endif;	 
	
	foreach idx in startPos to numRows do
		if self.accessRow(idx).itemObject = _obj then
			found 	:= true;
			_rowIdx := idx;
			break;
		endif;
	endforeach;

epilog
	return found;
	
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_rowIdx" type="Integer" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getChkBoxColumn" id="8a9e53b4-5118-42ad-bfe7-797251398036">
        <source>getChkBoxColumn() : Integer;
/*
Purpose:			
Date		Who		Reason
21 September 2016	NAVAB1	Initial creation
*/

vars

begin
	return self.chkBoxColumn;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getSelInvTypeFromDisplay" id="64c6785c-477c-4cdc-849a-c0817857dde9">
        <source>getSelInvTypeFromDisplay() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Sep 2019	jlgsl4	TFS 46287 - SNO - Selector Query Invoice Report error
*/

vars
	invoiceDesc : CM_InvoiceDesc;
	selectedTypes : String;
	index, textRow : Integer;
	listTable : UT_ListTable;
begin
	listTable := self;
	if self.chkBoxFirst then
		textRow := self.chkBoxColumn + 1;
	else
		textRow := self.chkBoxColumn - 1;
	endif;	
	foreach index in 1 to self.rows do
		if self.allSelectedObjects.includes(listTable.accessRow(index).itemObject) then
			if selectedTypes &lt;&gt; null then
				selectedTypes := selectedTypes &amp; ', ';
			endif;
			selectedTypes := selectedTypes &amp; listTable.accessRow(index).itemObject.CM_InvoiceDesc.description;
		endif;
	endforeach;
	if selectedTypes = null then
		selectedTypes := "**Any**";
	endif;
	return selectedTypes;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSelectedAsStringArray" id="4c9baf66-dcd2-411d-bbd5-5c17a2d8e257">
        <updating/>
        <source>getSelectedAsStringArray(_stringArray : StringArray input) updating;
//--------------------------------------------------
// Created:	05 May 2005 By: cnwgd1
//--------------------------------------------------
vars
	col,
	idx,
	max	: Integer;
begin
	if _stringArray = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'null array');
		return;
	endif;

	max := self.rows;
	
	if max &lt; 1 then
		return;
	endif;

	if self.chkBoxFirst then
		col := self.chkBoxColumn + 1;
	else
		col := self.chkBoxColumn - 1;
	endif;	
	
	foreach idx in 1 to max do
		if self.accessCell(idx, self.chkBoxColumn).text = TableCheckBox_Selected then
			_stringArray.add(self.accessCell(idx, col).text);
		endif;
	endforeach;
	
end;</source>
        <Parameter name="_stringArray" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getSelectedFromDisplay" id="2e866f59-1e39-4b7a-9e80-c2242abd99fe">
        <source>getSelectedFromDisplay() : String;
// -------------------------------------------
// Created 26 October 2004 by cnwdvb1
// -------------------------------------------
vars

	obj 	: Object;
	str		: String;
	idx,
	max,
	txtRow,
	pos		: Integer;
	lstTbl	: UT_ListTable;

begin

	max := self.rows;
	pos := 1;
	lstTbl := self;
	if lstTbl.chkBoxFirst then
		txtRow := lstTbl.chkBoxColumn + 1;
	else
		txtRow := lstTbl.chkBoxColumn - 1;
	endif;
	
	foreach idx in 1 to max do
		if self.allSelectedObjects.includes(lstTbl.accessRow(idx).itemObject) then
			if str &lt;&gt; null then
				str := str &amp; ', ';
			endif;
			str := str &amp; lstTbl.accessCell(idx, txtRow).text; 
		endif;
	endforeach;

	return str;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSelectedObjectsWithDupes" id="84a2ae29-b29f-488b-82e8-3a5c406d941f">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>getSelectedObjectsWithDupes(_objectArray : ObjectArray input)updating, clientExecution;
//--------------------------------------------------
// Created:	05 May 2005 By: cnwgd1
//--------------------------------------------------
vars
	col,
	idx,
	max	: Integer;
	obj : Object;
begin
	if _objectArray = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'null array');
		return;
	endif;

	_objectArray.clear();
	
	max := self.rows;
	
	if max &lt; 1 then
		return;
	endif;

	if self.chkBoxFirst then
		col := self.chkBoxColumn + 1;
	else
		col := self.chkBoxColumn - 1;
	endif;	
	
	foreach idx in 1 to max do
		if self.accessCell(idx, self.chkBoxColumn).text = TableCheckBox_Selected then
			obj := self.accessRow(idx).itemObject;
			_objectArray.add(obj);
		endif;
	endforeach;
	
end;</source>
        <Parameter name="_objectArray" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getSelectedString" id="a60eaf04-3602-4513-8b95-0d6881f56e20">
        <source>getSelectedString(pAttrName : String) : String;
// ---------------------------------------------------------------------------
// Created:     23 March 2001 by cnwrs2
//
// Purpose:     Returns a string of all the selected objects
//
// Parameters:  The attribute name on the object to display (eg. code)
//
// Returns:     The string of all the selected objects.
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
// 17/09/2008	concms1	par 17963	Stops user does not have permission for are includeed in display
// 01/10/2008	consw1	Par 17090 	Replace app.getMyTerminal with form's myTerminal

vars
	obj	: Object;
	str	: String;
	
begin
	if self.allSelectedObjects.size = 0 then
		if self.useAnyStringWhenNonSelected then
			str := Any_String;
		endif;
	else 
		foreach obj in self.allSelectedObjects do 
			/*if obj.isKindOf (CM_StopsTable) then 	// par 17963
				if not app.getMyUser.canViewStop (self.getMyTerminalFromForm, obj.CM_StopsTable) then	// par 17963
					continue;						// par 17963
				endif;								// par 17963
			endif;*/									// par 17963
			if str &lt;&gt; null then
				str := str &amp; ', ';
			endif;
			str := str &amp; obj.getPropertyValue(pAttrName).String.trimBlanks;
		endforeach;
	endif;

	return str;
			
end;</source>
        <Parameter name="pAttrName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSelectedStringXML" id="3bf558a3-0fb3-4a10-947b-30f43c8c2146">
        <source>getSelectedStringXML(_attrName, _tag : String) : String;

// cnwdvb1 20 March 2003 

vars
	obj	: Object;
	tmp,
	str	: String;
	
begin
	if self.allSelectedObjects.size = 0 then
		str := Any_String;
	else
		foreach obj in self.allSelectedObjects do 
			if str &lt;&gt; null then
				str := str &amp; ', ';
			endif;
			tmp := obj.getPropertyValue(_attrName).String; 
			str := str &amp; tmp.cnEcGetTagValueOfName(_tag); 
		endforeach;
	endif;
	return str;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_tag" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSelectedStrings" id="3df43076-7939-4c16-9a59-da19f6c804a6">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>getSelectedStrings(_stringArray : CM_StringArray input)updating, clientExecution;
//--------------------------------------------------
// Created:	05 May 2005 By: cnwgd1
//--------------------------------------------------
vars
	col,
	idx,
	max	: Integer;
	obj : Object;
begin
	if _stringArray = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'null array');
		return;
	endif;

	max := self.rows;
	
	if max &lt; 1 then
		return;
	endif;

	if self.chkBoxFirst then
		col := self.chkBoxColumn + 1;
	else
		col := self.chkBoxColumn - 1;
	endif;	
	
	foreach idx in 1 to max do
		if self.accessCell(idx, self.chkBoxColumn).text = TableCheckBox_Selected then
			obj := self.accessRow(idx).itemObject;
			if CM_TransactionType.hasInstance(obj) then
				//PAR11768 cnwsh3  Changed as CM_EventNotificationRequest is getting a class name in the event type which is in turn
				//being displayed on web apps and is causing the description on some displays to be cryptic.
				//_stringArray.add(obj.CM_TransactionType.classNameToCreate);
				_stringArray.add(obj.CM_TransactionType.description);
			else
				_stringArray.add(self.accessCell(idx, col).text);
			endif;
		endif;
	endforeach;
	
end;</source>
        <Parameter name="_stringArray" type="CM_StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getXMLStringForSelected" id="62ae82e2-e89d-4214-97d2-d49cb9560b0e">
        <source>getXMLStringForSelected(_attrNames : StringArray) : String;
// -------------------------------------------
// Created 18 February 2004 by cnwdvb1
// -------------------------------------------
vars

	obj	: Object;
	str,
	tmp,
	attrName	: String;

begin

	if not self.allSelectedObjects.isEmpty then
		str := self.formatAsXMLPrefix(XMLTag_ListTable &amp; self.name);
		foreach obj in self.allSelectedObjects do
			tmp := null;
			foreach attrName in _attrNames do
				if tmp &lt;&gt; null then
					tmp := tmp &amp; ',';
				endif;
				tmp := tmp &amp; obj.getPropertyValue(attrName).String;
			endforeach;
			str := str &amp;  global.formatAsXML(XMLTag_SelectedValue, tmp);
		endforeach;
		str := str &amp; self.formatAsXMLSuffix(XMLTag_ListTable &amp; self.name);
	endif;
	return str;

end;</source>
        <Parameter name="_attrNames" type="StringArray"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="highlightRow" id="4446ac63-370e-43ca-b090-4c763d300943">
        <updating/>
        <source>highlightRow(pRow : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     01 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if pRow &gt; 0 and pRow &lt;= self.rows then

		if self.accessCell(pRow, self.chkBoxColumn).text[1] = TableCheckBox_NotSelected then
			self.accessRow(pRow).selected := true;
		else
			self.accessRow(pRow).selected := false;
		endif;

	endif;

end;</source>
        <Parameter name="pRow" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="mouseDown" id="c6310ce5-d5df-4692-ae5f-ddc4da0c3842">
        <updating/>
        <source>mouseDown(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:     01 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	inheritMethod(table, button, shift, x, y);

