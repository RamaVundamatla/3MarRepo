    <JadeMethod name="initForm" id="e8bb7b66-35d8-4bee-a61c-7db50e1d57c6">
        <updating/>
        <source>initForm()updating;
//--------------------------------------------------
// Created:	19 July 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	app.initialize();
	self.myRoot := CM_Root.firstInstance;
	app.myPassport.setMyUserFromCode('SUPERUSER');
	self.initToDoTaskTable();
	self.initCargoEnqTable();
	self.cmbAvGrade.initialise(false);
	self.centreWindow();
end;</source>
    </JadeMethod>
    <JadeMethod name="initToDoTaskTable" id="86fbc766-84a3-4168-9aa6-03a2fe71e779">
        <source>initToDoTaskTable();
//--------------------------------------------------
// Created:	19 July 2005 By: cnwgd1
//--------------------------------------------------
vars	
begin

	self.tblDataToDo.rows := 1;
	self.tblDataToDo.accessCell(1, 1).text := 'Tasks In System' &amp; Tab &amp; 'Select' &amp; Tab &amp; 'Done' &amp; Tab &amp; 'Last Complete';	
	
	self.tblDataToDo.accessColumn(2).inputType := self.tblDataToDo.InputType_CheckBox;
	self.tblDataToDo.accessColumn(3).inputType := self.tblDataToDo.InputType_CheckBox;	
	self.tblDataToDo.accessColumn(2).alignment := self.tblDataToDo.Alignment_Center;
	self.tblDataToDo.accessColumn(3).alignment := self.tblDataToDo.Alignment_Center;	
	self.tblDataToDo.accessColumn(3).enabled := true;
	self.tblDataToDo.accessColumn(4).enabled := false;	
	
	self.populateToDoTableForInit();
	
end;</source>
    </JadeMethod>
