    <JadeMethod name="setProxy" id="1bdfc1f4-0930-40b0-a67e-8308a52c6ec4">
        <updating/>
        <source>setProxy(_code, _description : String; _isPieceCountError, _notAvailableForEntry: Boolean; _iDriversPieceCount : Integer)updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 January 2010	cnwas3	Initial creation

*/

vars

begin
	self.setSuperClassDetailsForProxy(_code, _description,_notAvailableForEntry,null);
	self.myRoot := app.myRoot;
	
epilog

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_isPieceCountError" type="Boolean"/>
        <Parameter name="_notAvailableForEntry" type="Boolean"/>
        <Parameter name="_iDriversPieceCount" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="54f90e5a-a6ac-4180-b851-d440a4237652">
        <source>validateForCreate();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 January 2010	cnwas3	Initial creation

*/

vars

begin
	if app.myRoot.allDocketErrorTypes.includesKey(self.code) &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.description, null, null);
	endif;
	inheritMethod();

epilog

end;</source>
    </JadeMethod>
