    <JadeMethod name="generatePDF417" id="c45ca42b-ceb3-41ff-b191-6edde629ed2c">
        <updating/>
        <source>generatePDF417(code:StringUtf8; x:Real; y:Real; width:Real; height:Real; rowCount:Integer; columnCount:Integer; xyRatio:Real; filename:StringUtf8):Boolean updating;
	// 


begin

	return jadeDotNetMethod('GeneratePDF417', code, x, y, width, height, rowCount, columnCount, xyRatio, filename).Boolean;

end;
</source>
        <wsdlName>GeneratePDF417</wsdlName>
        <Parameter name="code" type="StringUtf8"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="width" type="Real"/>
        <Parameter name="height" type="Real"/>
        <Parameter name="rowCount" type="Integer"/>
        <Parameter name="columnCount" type="Integer"/>
        <Parameter name="xyRatio" type="Real"/>
        <Parameter name="filename" type="StringUtf8"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
