<Class name="CM_FileConversionAgent" id="b48aace4-060f-478d-9397-2a18670ae04e">
    <superclass name="CM_Agent"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <ImplicitInverseRef name="allOutputFiles" id="4542b08b-0260-4492-be3a-5d3999fd69b2">
        <memberTypeInverse/>
        <type name="CM_FileStorageArray"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="inputFile" id="e591d2ed-e03d-4ada-8508-6ed731721c7d">
        <embedded/>
        <type name="File"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <PrimAttribute name="inputFileBlob" id="11d331ee-c1fd-4797-be12-efb4e9143821">
        <type name="Binary"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="utilityName" id="2e2c6196-8202-4ca1-a56f-faca2c5602d0">
        <length>31</length>
        <embedded/>
        <virtual/>
        <type name="String"/>
        <access>readonly</access>
        <text>Name of binary in server bin dir</text>
    </PrimAttribute>
    <JadeMethod name="delete" id="da00f2fe-0ed0-46f9-b5bb-774778daa3f7">
        <updating/>
        <source>delete() updating;
//----------------------------------------------------------------
//	Created:	27 October 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	if self.inputFile &lt;&gt; null then
		delete self.inputFile;
	endif;
	
	self.allOutputFiles.purge;

end;</source>
    </JadeMethod>
    <JadeMethod name="setInputFile" id="b80f3596-c00f-4cd4-af55-a4e40170e682">
        <updating/>
        <source>setInputFile(_file: File) updating;
//----------------------------------------------------------------
//	Created:	27 October 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	tmpFile	: File;
begin
	tmpFile := _file;
	
	self.inputFile := tmpFile;
	
	if tmpFile &lt;&gt; null then
		tmpFile.kind := File.Kind_Binary;
		tmpFile.open;
		self.inputFileBlob := tmpFile.readBinary(tmpFile.fileLength);
	endif;
	
epilog
	if tmpFile &lt;&gt; null then
		tmpFile.close;
	endif;
	
end;</source>
        <Parameter name="_file" type="File"/>
    </JadeMethod>
    <JadeMethod name="utilityName" id="10a9b942-c236-4ff7-be17-67d9b4cc7d23">
        <methodInvocation>mapping</methodInvocation>
        <source>utilityName(set: Boolean; _value: String io) mapping;
//----------------------------------------------------------------
//	Created:	27 October 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	_value := "";

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
</Class>
