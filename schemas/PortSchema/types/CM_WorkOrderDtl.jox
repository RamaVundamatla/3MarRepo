    <JadeMethod name="createBulkRelease" id="d3cb8829-39c7-4aab-bcba-77c4203a7706">
        <source>createBulkRelease(_releaseRequestType : Integer): CM_BulkRelease;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Sep 2021 navma1  ChangeRequest 51002: MTN - Web Portal Cargo Work Orders
15 Jul 2022	navcs2	ChangeRequest 53932: MTN - Jobs Changes
08 Feb 2023 navma1  ChangeRequest 56457:[56458] EUP - [Refactor] - Allowing different sets of cargo items per work order task
17 Mar 2023 navma1	Defect 57178: MTN - Packing Release Request id is using the task id when actioning the Pack Work Order
12 Apr 2023 navma1  ChangeRequest 57569:[57570] EUP - [Framework] Refactor Actioning Work Order Tasks
20 Jul 2023	navdap1	TFS 58923 EUP CallOff EDI Data Type / Data Load
*/

vars
	pxyRelease		: CM_BulkRelease;
	release 		: CM_BulkRelease;
	terminal        : CM_Terminal;
	subTerminal 	: CM_SubTerminal;
	wod             : CM_WorkOrderDtl;
	ti              : CM_TrackedItem;
	operator        : CM_Operator;
	voyage          : CM_Voyage;
	dischargePort   : CM_Port;
	commodity,       
	consigneeCode,
	consignorCode   : String;
	booking         : CM_BookingRef;
	availableTIs 	: CM_TISet;
	pxyReserveTI 	: CM_ReserveTI;
	bulkReleaseId	: String;
begin
	
	if not self.myParent.isKindOf(CM_WorkOrderTI) then 							//06.03.2023 navma1 #56457:[56458]
		return null;
	endif;
	
	terminal := self.myParent.myTerminal;
	ti       := self.CM_WorkOrderTIDtl.allSelectedTIs.first;
	wod      := self;
	
	if terminal.isUseYardJobsForCargoWo then									//17.03.2023 navma1 #57178
		bulkReleaseId := self.taskID;
	else
		bulkReleaseId := self.myParent.id;
	endif;
	
	if wod.isKindOf(CM_WodPack) then
		
		operator 		:= wod.CM_WodPack.myOperator;
		subTerminal		:= wod.CM_WodPack.mySubTerminal;
		operator 		:= wod.CM_WodPack.myOperator;
		voyage			:= wod.CM_WodPack.myVoyage;
		booking			:= wod.CM_WodPack.myBookingRef;
		dischargePort   := wod.CM_WodPack.myDischargePort;
		commodity       := wod.CM_WodPack.commodity;
		
		if wod.CM_WodPack.myConsignee &lt;&gt; null then
			consigneeCode  := wod.CM_WodPack.myConsignee.code;
		endif;
		
		if wod.CM_WodPack.myConsignor &lt;&gt; null then
			consignorCode  := wod.CM_WodPack.myConsignor.code;
		endif;
		
		create availableTIs transient;
		wod.CM_WodPack.allPackingTIs.copyNoDuplicates(availableTIs,false);
		self.CM_WorkOrderTIDtl.allSelectedTIs.copyNoDuplicates(availableTIs,false);
		
	elseif wod.isKindOf(CM_WodExportReturn) then
		
		if ti &lt;&gt; null then
			operator		:= ti.myOperator;
			if app.isSubTerminalsOn(terminal) then	
				subTerminal	:= ti.mySubTerminal;				
			endif;																	
		endif;
		
		create availableTIs transient;
		//wod.CM_WodExportReturn.allAvailableTIs.copy(availableTIs);			//12.04.2023 navma1 #57569:[57570]
		wod.CM_WodExportReturn.allActionedTIs.copy(availableTIs);				//12.04.2023 navma1 #57569:[57570]
	endif;
	
	
	create pxyRelease transient;
	
	// 15/07/2022 navcs2 53932 
	pxyRelease.setProxy(	bulkReleaseId,
						_releaseRequestType,
						false,
						BR_ACTIVE,						//08.02.2023 navma1 #56457:[56458]
						null,
						null, 
						null, 
						null, 
						consigneeCode,
						null, 
						consignorCode, 
						null,
						null, 
						app.actualTimeServer,
						null, 
						null, 
						null, 
						null,
						null, 
						null, 
						booking,
						null,
						null, 
						dischargePort,
						null, 
						null, 
						terminal, 
						operator,
						null, 
						voyage,
						null, 
						false,
						null,
						null, 
						null, 
						subTerminal, 
						null, 
						null,
						true,
						null, 
						null, 
						null, 
						null, 
						null, 
						null, 
						null, 
						null,
						null);
							
	foreach ti in availableTIs do
		
		create pxyReserveTI transient;
		
		pxyReserveTI.setMyHeader(pxyRelease);
		pxyReserveTI.addTI(ti);
		
		if ti.myCargoType.isBulkByWeight or ti.myCargoType.isBulkByVolume then
			pxyReserveTI.setWeightRequested(ti.totalWeight);
		else
			pxyReserveTI.setTotalRequested(ti.totalQuantity);
		endif;
		
	endforeach;
	
	
	app.myUtilityCA.utlCreateBulkRelease(pxyRelease, release, booking, null, null, null, app.myPassport);	// TFS 58923
	
	return release;
	
epilog
	delete pxyRelease;
	delete availableTIs;
end;</source>
        <Parameter name="_releaseRequestType" type="Integer"/>
        <ReturnType type="CM_BulkRelease"/>
    </JadeMethod>
