        <updating/>
        <source>mnuFileExit_click(menuItem: MenuItem input) updating;
// --------------------------------------------------------------------------------
// Created:		04 July 2002 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.setState(Busy);
	unloadForm();
epilog
	self.setState(Idle);
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mnuFileNewFolder_click" id="f36cdfda-2a6f-4437-a71e-bbe74c5ae1e8">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuFileNewFolder_click(menuItem: MenuItem input) updating;
// --------------------------------------------------------------------------------
// Created:		04 July 2002 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	IS_FILE_NODE		: Boolean = false;
	IS_FILE_RENAME		: Boolean = false;
	
vars
	theFileNameForm		: JSSFMFileNameForm;
	directoryName		: String;
	nodeType			: Integer;
	nodeOption			: Integer;
	isUnix				: Boolean;
	
begin
	self.setState(Busy);
	
	nodeType	:=	self.aCurrentTableNode;
	
	if nodeType = self.LISTBOX_NODE_LOCAL_FOLDER or nodeType = self.LISTBOX_NODE_LOCAL_FILE then
		isUnix	:=	false;
	elseif nodeType = self.LISTBOX_NODE_APP_SERVER_FOLDER or nodeType = self.LISTBOX_NODE_APP_SERVER_FILE then
		isUnix	:=	self.aIsUnixAppServer;
	elseif nodeType = self.LISTBOX_NODE_DB_SERVER_FOLDER or nodeType = self.LISTBOX_NODE_DB_SERVER_FILE then
		isUnix	:=	self.aIsUnixDbServer;
	endif;
	
	create theFileNameForm;
	theFileNameForm.setFileNameInfo(null, self.aCurrentTablePath, isUnix, IS_FILE_NODE, IS_FILE_RENAME);
	theFileNameForm.showModal();
	self.getServiceInterfaceSettings();
	
	if theFileNameForm.modalResult = self.JSS_MODAL_CANCEL_ALL then
		return;
	else
		directoryName	:=	theFileNameForm.aNewFileName;
		
		if nodeType = self.LISTBOX_NODE_LOCAL_FOLDER or nodeType = self.LISTBOX_NODE_LOCAL_FILE then
			nodeOption	:=	JSSFMFileManagerService.NODE_TARGET_CLIENT;
		elseif nodeType = self.LISTBOX_NODE_APP_SERVER_FOLDER or nodeType = self.LISTBOX_NODE_APP_SERVER_FILE then
			nodeOption	:=	JSSFMFileManagerService.NODE_TARGET_APPSERVER;
		elseif nodeType = self.LISTBOX_NODE_DB_SERVER_FOLDER or nodeType = self.LISTBOX_NODE_DB_SERVER_FILE then
			nodeOption	:=	JSSFMFileManagerService.NODE_TARGET_DBSERVER;
		endif;
		
		self.getFileAgent().createDirectory(directoryName, nodeOption);
		self.listUpdateWithNewDirectory(lstDirTop, directoryName);
		self.listUpdateWithNewDirectory(lstDirBottom, directoryName);
		lstDirTop.click(lstDirTop);
		lstDirBottom.click(lstDirBottom);
	endif;
epilog
	self.setState(Idle);
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mnuFilePasteBackground_click" id="af8b17a5-d265-4095-944d-01fd51b462df">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuFilePasteBackground_click(menuItem: MenuItem input) updating;
// --------------------------------------------------------------------------------
// Created:		17 September 2002 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	targetPath			: String;
	nodeType			: Integer;
	targetNodeOption	: Integer;
	isTargetSet			: Boolean;
	theListbox			: ListBox;
	isTargetUnix		: Boolean;
	
begin
	self.setState(Busy);
	
	if self.aMyMenuList &lt;&gt; null then
		isTargetSet	:=	true;
		targetPath	:=	self.listGetQualifiedName(self.aMyMenuList, self.aMyMenuList.listIndex);
		nodeType	:=	self.aMyMenuList.itemData[self.aMyMenuList.listIndex];
		
	elseif self.aMyMenuTable &lt;&gt; null then
		// First, we must check that the user has selected a target directory in
		// the appropriate listbox.
		
		if self.aMyMenuTable = tblFilesTop then
			theListbox	:=	lstDirTop;
		elseif self.aMyMenuTable = tblFilesBottom then
			theListbox	:=	lstDirBottom;
		else
			isTargetSet	:=	false;
		endif;
		
		if theListbox = null then
			isTargetSet	:=	false;
		else
			if theListbox.listIndex = JSS_NULL_INDEX then
				isTargetSet	:=	false;
			else
				isTargetSet	:=	true;
				targetPath	:=	self.listGetQualifiedName(theListbox, theListbox.listIndex);
				nodeType	:=	theListbox.itemData[theListbox.listIndex];
			endif;
		endif;
	else
		return;
	endif;
	
	if isTargetSet then
		isTargetUnix	:=	false;
		
		if nodeType = self.LISTBOX_NODE_LOCAL_FOLDER or nodeType = self.LISTBOX_NODE_LOCAL_FILE then
			targetNodeOption	:=	JSSFMFileManagerService.NODE_TARGET_CLIENT;
		elseif nodeType = self.LISTBOX_NODE_APP_SERVER_FOLDER or nodeType = self.LISTBOX_NODE_APP_SERVER_FILE then
			targetNodeOption	:=	JSSFMFileManagerService.NODE_TARGET_APPSERVER;
			isTargetUnix		:=	self.aIsUnixAppServer;
		elseif nodeType = self.LISTBOX_NODE_DB_SERVER_FOLDER or nodeType = self.LISTBOX_NODE_DB_SERVER_FILE then
			targetNodeOption	:=	JSSFMFileManagerService.NODE_TARGET_DBSERVER;
			isTargetUnix		:=	self.aIsUnixDbServer;
		else
			return;
		endif;
		
		self.doPasteSelectedNodesBackground(targetPath, targetNodeOption, isTargetUnix);
	else
		app.msgBox(	"A target directory has not been selected.",
					"Copy Error",
					MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		return;
	endif;
epilog
	self.setState(Idle);
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mnuFilePaste_click" id="67f5aeea-ba31-4de1-8c00-f97350c12318">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuFilePaste_click(menuItem: MenuItem input) updating;
// --------------------------------------------------------------------------------
// Created:		04 July 2002 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	targetPath			: String;
	nodeType			: Integer;
	targetNodeOption	: Integer;
	isTargetSet			: Boolean;
	theListbox			: ListBox;
	isTargetUnix		: Boolean;
	
begin
	self.setState(Busy);
	
	if self.aMyMenuList &lt;&gt; null then
		isTargetSet	:=	true;
		targetPath	:=	self.listGetQualifiedName(self.aMyMenuList, self.aMyMenuList.listIndex);
		nodeType	:=	self.aMyMenuList.itemData[self.aMyMenuList.listIndex];
		
	elseif self.aMyMenuTable &lt;&gt; null then
		// First, we must check that the user has selected a target directory in
		// the appropriate listbox.
		
		if self.aMyMenuTable = tblFilesTop then
			theListbox	:=	lstDirTop;
		elseif self.aMyMenuTable = tblFilesBottom then
			theListbox	:=	lstDirBottom;
		else
			isTargetSet	:=	false;
		endif;
		
		if theListbox = null then
			isTargetSet	:=	false;
		else
			if theListbox.listIndex = JSS_NULL_INDEX then
				isTargetSet	:=	false;
			else
				isTargetSet	:=	true;
				targetPath	:=	self.listGetQualifiedName(theListbox, theListbox.listIndex);
				nodeType	:=	theListbox.itemData[theListbox.listIndex];
			endif;
		endif;
	else
		return;
	endif;
	
	if isTargetSet then
		isTargetUnix	:=	false;
		
		if nodeType = self.LISTBOX_NODE_LOCAL_FOLDER or nodeType = self.LISTBOX_NODE_LOCAL_FILE then
			targetNodeOption	:=	JSSFMFileManagerService.NODE_TARGET_CLIENT;
		elseif nodeType = self.LISTBOX_NODE_APP_SERVER_FOLDER or nodeType = self.LISTBOX_NODE_APP_SERVER_FILE then
			targetNodeOption	:=	JSSFMFileManagerService.NODE_TARGET_APPSERVER;
			isTargetUnix		:=	self.aIsUnixAppServer;
		elseif nodeType = self.LISTBOX_NODE_DB_SERVER_FOLDER or nodeType = self.LISTBOX_NODE_DB_SERVER_FILE then
			targetNodeOption	:=	JSSFMFileManagerService.NODE_TARGET_DBSERVER;
			isTargetUnix		:=	self.aIsUnixDbServer;
		else
			return;
		endif;
		
		self.doPasteSelectedNodes(targetPath, targetNodeOption, isTargetUnix);
	else
		app.msgBox(	"A target directory has not been selected.",
					"Copy Error",
					MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		return;
	endif;
epilog
	self.setState(Idle);
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mnuFileRename_click" id="5f9a5a08-a3b3-4f8a-8c29-3fb6b4ee1c30">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuFileRename_click(menuItem: MenuItem input) updating;
// --------------------------------------------------------------------------------
// Created:		04 July 2002 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theContainer		: JSSFMFolder;
	
begin
	self.setState(Busy);
	
	create theContainer transient;
	
	if self.aMyMenuList &lt;&gt; null then
		self.doGetSelectedListFolder(self.aMyMenuList, theContainer);
	elseif self.aMyMenuTable &lt;&gt; null then
		self.doGetSelectedTableFiles(self.aMyMenuTable, theContainer);
	else
		return;
	endif;
	
	if theContainer.allFileNodes.isEmpty() then
		delete theContainer;
	else
		self.aAllCutAndPasteObjects.purge();
		self.aAllCutAndPasteObjects.add(theContainer);
	endif;
	
	self.doRenameSelectedNodes();
epilog
	delete theContainer;
	
	self.setState(Idle);
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mnuFile_click" id="4d6aff11-4dfb-4392-8b94-af9b4e8492cc">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuFile_click(menuItem: MenuItem input) updating;
// --------------------------------------------------------------------------------
// Created:		23 September 2002 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theActiveControl	: Control;
	
begin
	self.setState(Busy);
	
	theActiveControl	:=	app.activeControl;
	
	if theActiveControl = lstDirTop then
		self.menuEnableForList(lstDirTop);
	elseif theActiveControl = lstDirTop then
		self.menuEnableForList(lstDirBottom);
	elseif theActiveControl = tblFilesTop then
		self.menuEnableForTable(tblFilesTop);
	elseif theActiveControl = tblFilesBottom then
		self.menuEnableForTable(tblFilesBottom);
	endif;
epilog
	self.setState(Idle);
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
