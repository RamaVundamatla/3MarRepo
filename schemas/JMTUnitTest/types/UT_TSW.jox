	//Delete TSW MPI External Inspect - 6 sided STOP
	realStopsTableExt := self.getRoot.getStopTableForId(UT_ExtStopId);
	if realStopsTableExt &lt;&gt; null then
		self.deleteStopsTable(UT_ExtStopId);
		self.assertIsDeletedMsg(realStopsTableExt, "Global Setup - realStopsTableExt");
		self.logMessage("Deleted Stops Table: Id:'" &amp; UT_ExtStopId.String &amp; " Code: " &amp; UT_ExtStopCode);
	endif;
	
	//Create TSW MPI External Inspect - 6 sided STOP
	create pxyStopsTable transient;
	pxyStopsTable.setProxy(false, UT_ExtStopCode, UT_ExtStopHeading, UT_ExtStopCode, null, UT_ExtStopId, null, false, false, app.myRoot, null, app.myPassport.myUser.code, null);
	
