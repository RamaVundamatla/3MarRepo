    <DbClassMap file="jsslicense_default"/>
    <JadeMethod name="trxCreateCustomerLicense" id="7ab718f6-97e4-4b2d-be57-1f4580dfc1ec">
        <source>trxCreateCustomerLicense(	pTheServiceManager:JSSLKServiceManager input;
							pCustomerName:String;
							pProductCode:String;
							pLicenseKey:String;
							pTheRoot:JSSLKRoot;
							pTheCustomerLicense:JSSLKCustomerLicense output);
// --------------------------------------------------------------------------------
// Created:		17 January 2003 by cnwdad1
//
// Purpose:		Creates a Customer License object.
//
// Parameters:	pTheServiceManager - A refeence to the peer schema's service manager object.
//				pCustomerName - The license name of the license holder.
//				pProductCode - A unique code identifying the product being licensed.
//				pLicenseKey - The customer/product license key.
//				pTheRoot - A reference to the schema's root object.
//				pTheCustomerLicense - A reference to the newly created Customer License object.
//
// Returns:		The newly created Customer License object, as an output parameter.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theCustomerLicense	: JSSLKCustomerLicense;
	
begin
	self.checkTransactionState();
	
	if self.isDoTransactionState then
		on Exception do self.xHandlerCommon(exception);
	endif;
	
	theCustomerLicense	:=	pTheRoot.allCustomerLicenses[pCustomerName, pProductCode];
	
	if theCustomerLicense = null then
		if self.isDoTransactionState then
			beginTransaction;
		endif;
		
		theCustomerLicense	:=	pTheRoot.createCustomerLicense(pTheServiceManager, pCustomerName, pProductCode, pLicenseKey);
		
		if self.isDoTransactionState then
			commitTransaction;
		endif;
		
		pTheCustomerLicense	:=	theCustomerLicense;
	else
		pTheServiceManager.raiseJSSException2(JSS_EX_00077, pCustomerName, pProductCode);
	endif;
end;</source>
        <Parameter name="pTheServiceManager" type="JSSLKServiceManager" usage="input"/>
        <Parameter name="pCustomerName" type="String"/>
        <Parameter name="pProductCode" type="String"/>
        <Parameter name="pLicenseKey" type="String"/>
        <Parameter name="pTheRoot" type="JSSLKRoot"/>
        <Parameter name="pTheCustomerLicense" type="JSSLKCustomerLicense" usage="output"/>
    </JadeMethod>
    <JadeMethod name="trxCreateRoot" id="130bf5e5-acc1-4374-b9eb-d2de9d55ec98">
        <source>trxCreateRoot(pTheRoot:JSSLKRoot output);
// --------------------------------------------------------------------------------
// Created:		15 January 2003 by cnwdad1
//
// Purpose:		Creates the schema's singleton root object.
//
// Parameters:	pTheRoot - A reference to the newly created root object.
//
// Returns:		A reference to the new root object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theRoot		: JSSLKRoot;
	
begin
	self.checkTransactionState();
	
	if self.isDoTransactionState then
		on Exception do self.xHandlerCommon(exception);
	endif;
	
	if JSSLKRoot.instances.size() &gt; 0 then
		self.myServiceManager.raiseJSSException(JSS_EX_00076);
		return;
	endif;
	
	if self.isDoTransactionState then
		beginTransaction;
	endif;
	
	create theRoot persistent;
	
	if self.isDoTransactionState then
		commitTransaction;
	endif;
	
	pTheRoot	:=	theRoot;
end;</source>
        <Parameter name="pTheRoot" type="JSSLKRoot" usage="output"/>
    </JadeMethod>
    <JadeMethod name="trxDeleteCustomerLicense" id="c42401cd-1543-4652-b56d-675de7027272">
        <source>trxDeleteCustomerLicense(pTheServiceManager:JSSLKServiceManager input; pTheRoot:JSSLKRoot; pCustomerName:String; pProductCode:String);
// --------------------------------------------------------------------------------
// Created:		17 January 2003 by cnwdad1
//
// Purpose:		Deletes a Customer License object.
//
// Parameters:	pTheServiceManager - A refeence to the peer schema's service manager object.
//				pTheRoot - A reference to the schema's root object.
//				pCustomerName - The license name of the license holder.
//				pProductCode - A unique code identifying the product being licensed.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theLicense	: JSSLKCustomerLicense;
	
begin
	self.checkTransactionState();
	
	if self.isDoTransactionState then
		on Exception do self.xHandlerCommon(exception);
	endif;
	
	theLicense	:=	pTheRoot.allCustomerLicenses[pCustomerName, pProductCode];
	
	if theLicense = null then
		pTheServiceManager.raiseJSSException2(JSS_EX_00080, pCustomerName, pProductCode);
	endif;
	
	if self.isDoTransactionState then
		beginTransaction;
	endif;
	
	exclusiveLock(theLicense);
	delete theLicense;
	
	if self.isDoTransactionState then
		commitTransaction;
	endif;
end;</source>
        <Parameter name="pTheServiceManager" type="JSSLKServiceManager" usage="input"/>
        <Parameter name="pTheRoot" type="JSSLKRoot"/>
        <Parameter name="pCustomerName" type="String"/>
        <Parameter name="pProductCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="trxDeleteRoot" id="ffa52a66-80c5-45ad-9d21-adc657e39828">
        <source>trxDeleteRoot(pTheRoot:JSSLKRoot io);
// --------------------------------------------------------------------------------
// Created:		15 January 2003 by cnwdad1
//
// Purpose:		Deletes the specified root object.
//
// Parameters:	pTheRoot - A reference to the schema's root object to be deleted.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.checkTransactionState();
	
	if self.isDoTransactionState then
		on Exception do self.xHandlerCommon(exception);
	endif;
	
	if self.isDoTransactionState then
		beginTransaction;
	endif;
	
	exclusiveLock(pTheRoot);
	delete pTheRoot;
	
	if self.isDoTransactionState then
		commitTransaction;
	endif;
end;</source>
        <Parameter name="pTheRoot" type="JSSLKRoot" usage="io"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateCustomerLicense" id="8327acfb-d60a-4f50-89e5-b58f80b439ef">
        <source>trxUpdateCustomerLicense(	pTheCustomerLicense:JSSLKCustomerLicense input;
							pRequiredEdition:Integer;
							pTheServiceManager:JSSLKServiceManager input;
							pCustomerName:String;
							pProductCode:String;
							pLicenseKey:String;
							pTheRoot:JSSLKRoot);
// --------------------------------------------------------------------------------
// Created:		17 January 2003 by cnwdad1
//
// Purpose:		Updates the properties of the specified Customer License object.
//
// Parameters:	pTheCustomerLicense - A reference to the Customer License object.
//				pRequiredEdition - The required object edition of the Customer License object.
//					If this is zero, then edition checking will not be performed.
//				pTheServiceManager - A refeence to the peer schema's service manager object.
//				pCustomerName - The license name of the license holder.
//				pProductCode - A unique code identifying the product being licensed.
//				pLicenseKey - The customer/product license key.
//				pTheRoot - A reference to the schema's root object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theCustomerLicense	: JSSLKCustomerLicense;
	
begin
	self.checkTransactionState();
	
	if self.isDoTransactionState then
		on Exception do self.xHandlerCommon(exception);
	endif;
	
	theCustomerLicense	:=	pTheRoot.allCustomerLicenses[pCustomerName, pProductCode];
	
	if theCustomerLicense = null then
		pTheServiceManager.raiseJSSException2(JSS_EX_00079, pCustomerName, pProductCode);
	
	elseif theCustomerLicense &lt;&gt; null and theCustomerLicense &lt;&gt; pTheCustomerLicense then
		pTheServiceManager.raiseJSSException2(JSS_EX_00077, pCustomerName, pProductCode);
		
	else
		if self.isDoTransactionState then
			beginTransaction;
		endif;

// djc: you're placing a lock on this, but say an exception were to occur and the commit was not executed,
// who would unlock it?  do you have an exception handler armed somewhere?  or are you assuming that the
// user will catch it and do an abortTransaction to release locks?		
		exclusiveLock(theCustomerLicense);
		
		if pRequiredEdition &lt;&gt; 0 then
			if pRequiredEdition &lt;&gt; theCustomerLicense.edition then
				pTheServiceManager.raiseJSSException2(JSS_EX_00078, "Customer License", theCustomerLicense.customerName);
			endif;
		endif;
		
		theCustomerLicense.updateMe(pTheServiceManager, pCustomerName, pProductCode, pLicenseKey, pTheRoot);
		
		if self.isDoTransactionState then
			commitTransaction;
		endif;
	endif;
end;</source>
        <Parameter name="pTheCustomerLicense" type="JSSLKCustomerLicense" usage="input"/>
        <Parameter name="pRequiredEdition" type="Integer"/>
        <Parameter name="pTheServiceManager" type="JSSLKServiceManager" usage="input"/>
        <Parameter name="pCustomerName" type="String"/>
        <Parameter name="pProductCode" type="String"/>
        <Parameter name="pLicenseKey" type="String"/>
        <Parameter name="pTheRoot" type="JSSLKRoot"/>
    </JadeMethod>
</Class>
