    <JadeMethod name="addToolbarControls" id="025f4881-2a47-4adb-972c-4f48d8159acc">
        <updating/>
        <source>addToolbarControls() updating, protected;
/*
------------------------------------------------------------------------
Created:			15 September 2003 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/

vars
	toolbar	: CMUI_Toolbar;

begin
	inheritMethod();
	toolbar := self.frmToolbar;
	
	toolbar.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnRefresh, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPerfOpts, CMUI_Toolbar.Control_Alignment_Left);
	self.btnPerfOpts.enabled := false;	//Disable until the performance graph tab is enabled
	toolbar.addButton(self.btnSample, CMUI_Toolbar.Control_Alignment_Left);
	self.btnSample.enabled := false;	//Disable until the performance graph tab is enabled

	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);

end;</source>
        <access>protected</access>
    </JadeMethod>
