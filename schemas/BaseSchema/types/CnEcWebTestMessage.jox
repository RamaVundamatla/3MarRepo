This class describes the details for an individual Test Message.
To be used, a the Test Message must be assigned to a Web Test.</text>
    <DbClassMap file="WebTest"/>
    <ExplicitInverseRef name="allTestResults" id="4cd16bba-c4eb-45dd-a4eb-a2e1ab5c8c60">
        <kind>parent</kind>
        <updateMode>automatic</updateMode>
        <type name="CnEcWebTestResultDict"/>
        <access>readonly</access>
        <Inverse name="CnEcWebTestResult::myTestMessage"/>
    </ExplicitInverseRef>
    <PrimAttribute name="messageData" id="0fcbfaf7-9adf-490d-adab-dfd86721ab31">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="messageName" id="9625d139-fc88-4bab-b3b2-dce988cc7fb4">
        <length>61</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <ExplicitInverseRef name="myBaseRoot" id="19bd8ee5-b4f7-4820-bc46-727a6f999990">
        <kind>child</kind>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CnEcBaseRoot"/>
        <access>readonly</access>
        <Inverse name="CnEcBaseRoot::allWebTestMessages"/>
    </ExplicitInverseRef>
    <PrimAttribute name="webServerName" id="f3d70674-aad9-4eb9-9dbb-c5213629a123">
        <length>256</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="webServerPath" id="32c35eaa-d168-442b-b0c0-92fdb1102b04">
        <length>256</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="clearResults" id="39b32666-1653-4822-af38-41246f872942">
        <updating/>
        <source>clearResults() updating;
// --------------------------------------------------------------------------------
// Created:		01 June 2000 by cnwdad2
//
// Purpose:		Clear (purge) the receiver's collection of web test results.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.allTestResults.purge();
end;</source>
    </JadeMethod>
    <JadeMethod name="createWebTestResult" id="eef5167f-b8c8-41f7-b5b0-ba333e938398">
        <updating/>
        <source>createWebTestResult(pTimeRequested:TimeStamp;
					pTimeReceived:TimeStamp;
					pResponseData:String):CnEcWebTestResult updating;
// --------------------------------------------------------------------------------
// Created:		01 June 2000 by cnwdad2
//
// Purpose:		Create a web test result object.
//
// Parameters:	pTimeRequested - Timestamp that the test mesage started.
//				pTimeReceived - Timestamp that the test message responded.
//				pResponseData - The test message response.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.myBaseRoot.createWebTestResult(self, pTimeRequested, pTimeReceived, pResponseData);
end;</source>
        <Parameter name="pTimeRequested" type="TimeStamp"/>
        <Parameter name="pTimeReceived" type="TimeStamp"/>
        <Parameter name="pResponseData" type="String"/>
        <ReturnType type="CnEcWebTestResult"/>
    </JadeMethod>
    <JadeMethod name="delete" id="82debdeb-2d35-4cea-802f-e28ec71b89ef">
        <updating/>
        <source>delete() updating;
// --------------------------------------------------------------------------------
// Created:		02 June 2000 by cnwdad2
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	webTest	: CnEcWebTest;

begin
	foreach webTest in app.myBaseRoot.allWebTests do
		webTest.removeTestMessage(self);
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="getDisplay" id="3a1dc989-7796-4f3c-9601-3d0c2fc5359e">
        <source>getDisplay():String;
// --------------------------------------------------------------------------------
// Created:		06 June 2000 by cnwdad1
//
// Purpose:		Get a display value for the receiver showing its details.
//
// Parameters:	None
//
// Returns:		The display string.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return	"Message Name: " &amp; self.messageName &amp;
			CrLf &amp; "Server Name: " &amp; self.webServerName &amp;
			CrLf &amp; "Server Path: " &amp; self.webServerPath &amp;
			CrLf &amp; CrLf &amp; "Message Data: " &amp; CrLf &amp; self.messageData;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initializeMe" id="7f211051-01c0-465f-a9b8-0225ec9793a0">
        <updating/>
        <source>initializeMe(	pBaseRoot:CnEcBaseRoot;
				pMessageName:String;
				pMessageData:String;
				pWebServerName:String;
				pWebServerPath:String) updating;
// --------------------------------------------------------------------------------
// Created:		01 June 2000 by cnwdad2
//
// Purpose:		Initialize the receiver's property values.
//
// Parameters:	pBaseRoot - The BaseSchema root object.
//				pMessageName - The name of the test message.
//				pMessageData - The test body, such as an HTML page or an XML message.
//				pWebServerName - The name of the HTTP web server.
//				pWebServerPath - The path on the HTTP web server.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	// Set the property values...

	self.messageData			:=	pMessageData;
	self.webServerName			:=	pWebServerName;
	self.webServerPath			:=	pWebServerPath;

	// Now set any key property values...

	self.messageName			:=	pMessageName;

	// Last, set any references...

	self.myBaseRoot				:=	pBaseRoot;
end;</source>
        <Parameter name="pBaseRoot" type="CnEcBaseRoot"/>
        <Parameter name="pMessageName" type="String"/>
        <Parameter name="pMessageData" type="String"/>
        <Parameter name="pWebServerName" type="String"/>
        <Parameter name="pWebServerPath" type="String"/>
    </JadeMethod>
    <JadeMethod name="updateMe" id="bfa59942-de8f-4515-a3f2-be8b6ec6dd72">
        <updating/>
        <source>updateMe(	pMessageData:String;
			pWebServerName:String;
			pWebServerPath:String) updating;
// --------------------------------------------------------------------------------
// Created:		01 June 2000 by cnwdad2
//
// Purpose:		Update the receiver's property values.
//
// Parameters:	pMessageData - The test body, such as an HTML page or an XML message.
//				pWebServerName - The name of the HTTP web server.
//				pWebServerPath - The path on the HTTP web server.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	// Set the property values...

	self.messageData			:=	pMessageData;
	self.webServerName			:=	pWebServerName;
	self.webServerPath			:=	pWebServerPath;

	// Last, set any references...
end;</source>
        <Parameter name="pMessageData" type="String"/>
        <Parameter name="pWebServerName" type="String"/>
        <Parameter name="pWebServerPath" type="String"/>
    </JadeMethod>
</Class>
