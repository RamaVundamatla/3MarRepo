    <JadeMethod name="btnApply_click" id="cd40be7e-03be-470a-890b-b2f9c366d4c6">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnApply_click(btn: Button input) updating;

begin
	app.mousePointer	:=	Busy;
	self.doFormUpdate(false);
	self.doEnableButtons();
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnClose_click" id="458a52c6-e5e0-465d-8bc6-d0a0e3962ad3">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnClose_click(btn: Button input) updating;

begin
	app.mousePointer	:=	Busy;
	self.unloadForm();
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnDeleteReport_click" id="02beb3ae-70f9-4a7f-8ad3-89fbfeb4c9b2">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnDeleteReport_click(btn: Button input) updating;

begin
	app.mousePointer	:=	Busy;

	if self.aMyReport = null then
		return;
	endif;
	
	if hasQueuedEntries(txtName.text.trimBlanks) then
		app.msgBox("There are Reports in print queues related to this Report Definition", "Deletion aborted", MsgBox_OK_Only);
	elseif self.doFormUpdate(true) then
		unloadForm();
	endif;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
