    <JadeMethod name="doSendOnePortVesselMovementReq" id="39abe25a-f7bd-4a8c-82ac-5e940dc95910">
        <updating/>
        <source>doSendOnePortVesselMovementReq(_webService : CM_QshipsWebServiceDef; _type : String; _date : String; _port : String; _terminal : CM_Terminal): String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 July 2024	navsp1	Initial creation TFS ChangeRequest 63842: NSW | OnePort Integration Dev

*/
vars
	verb,
	endpoint,
	jsonPostData,
	url,
	resultString	: String;
	resultCode 		: Integer;
	pxyActivity 		: CM_EWSActivityQships;
	activity			: CM_EWSActivityQships;
begin
	
	url :=	 _webService.baseEndpoint;
	if url[url.length:1] &lt;&gt; "/" then
		url := url &amp; "/";
	endif;
	
	_webService.getEndpointMethodAndValue(_type, verb, endpoint);
	if verb = null or endpoint = null then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "No verb or endpoint set up for " &amp; _type &amp; " messages", LogERROR);
		app.doRaiseAlert( _webService.name &amp; " is not set up correctly for " &amp; _type &amp; " messages");
		return resultString;
	endif;
	url := url &amp; endpoint &amp; "/" &amp; _date &amp; "/" &amp; _port;	
	
	resultString := self.doSendHTTPRequest(url, verb, self.getAdditionalHeadersForHTTP(), jsonPostData, resultCode);	
	
	//Record the activity
	create pxyActivity transient;		
	pxyActivity.initialiseActivity("VesselMovementsNSWPorts Request", _webService.name, _terminal, null, "G", QshipsInterface.name, null, null);
	pxyActivity.setRequest(url);
	activity := app.myTrxCA.trxCreateEWSActivityHistory(pxyActivity,app.myPassport).CM_EWSActivityQships;
				
	if resultCode = HttpResponseNoContent then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "NODATA: Response from " &amp; _type &amp; " App was " &amp; resultCode.String &amp; ":" &amp; resultString, LogERROR);
		
	elseif resultCode &lt;&gt; HttpResponseOK and resultCode &lt;&gt; HttpResponseCreated then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "FAILED: Response from " &amp; _type &amp; " App was " &amp; resultCode.String &amp; ":" &amp; resultString, LogERROR);
		
		//Record the activity
		create pxyActivity transient;		
		pxyActivity.initialiseActivity("VesselMovementsNSWPorts Request failed", _webService.name, _terminal, null, "G", QshipsInterface.name, null, null);
		pxyActivity.setRequest(url);
		activity := app.myTrxCA.trxCreateEWSActivityHistory(pxyActivity,app.myPassport).CM_EWSActivityQships;
		
	elseif resultCode = HttpResponseOK or resultCode = HttpResponseCreated then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "SUCCESS: Response from " &amp; _type &amp; " App was " &amp; resultCode.String &amp; ":" &amp; resultString, LogDEBUG);
	endif;
	
	return resultString;
epilog
	
end;</source>
        <Parameter name="_webService" type="CM_QshipsWebServiceDef"/>
        <Parameter name="_type" type="String"/>
        <Parameter name="_date" type="String"/>
        <Parameter name="_port" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVoyageExportDataByDomainAndDates" id="8c16c6d7-b4cc-4d2e-b183-4312b303a0c3">
        <updating/>
        <source>getVoyageExportDataByDomainAndDates(_sessionKey : String; 
									_domainId: Integer; 
									_lastSuccesfulTS: TimeStamp io; 
									_webService : CM_QshipsWebServiceDef;
									_terminal : CM_Terminal) : Qships_GetVoyageExportDataByDomainAndDatesResponse updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 07 October 2022
TFS#		: 54892
Function	:

*** Changes ***
Date			Name		TFS#		Description
01/05/20223		jlika1		57800		MTN - QShips POST message not shown in External Web Service Monitor form
09/10/2023		jlika1		TFS 60753	POB | Q-Ships 55717.080 - Date Range of QShips Query
18/10/2023		navdap1		TFS 60921	POB - QShips External Web Service Last Successful Date Time
****************************************************/

vars
	request			: Qships_GetVoyageExportDataByDomainAndDates;
	response 		: Qships_GetVoyageExportDataByDomainAndDatesResponse;	
	xmlStr, 
	resultString 	: String;
	resultCode 		: Integer;
	xmlDoc 			: JadeXMLDocument;
	element, 
	child, 
	attribute 		: JadeXMLElement;
	childNode, 
	attributeNode 	: JadeXMLNode;
	allEDIVoyageTIs : CM_EDITIArray;
	ediVoyage 		: CM_EDIQshipsVoyageTI;
	movement 		: CM_EDIQshipsMovementTI;
	vessel 			: CM_EDIQshipsVesselTI;
	fromDate		: Date;
	fromTime		: Time;
	strFromDate		: String;	
	toDate			: Date;
	toTime			: Time;
	strToDate		: String;
	pxyActivity		: CM_EWSActivityQships;
	requestActivity	: CM_EWSActivityQships;	
	beforeLSD		: Integer;
	afterRT			: Integer;
begin
	create request transient;
	request.aSessionKey := _sessionKey;
	request.domainID := _domainId;	
	beforeLSD := _webService.queryHrsBeforeLSD;
	afterRT := _webService.queryDaysAfterRT;
	
	/*
	The value in the FromStartDate field of the request sent to QShips should be [a configurable number of hours] (defaulting to 1) before the last successful date/time.
	The value in the ToStartDate field of the request sent to QShips should be [a configurable number of days] (defaulting to 20) after the date and time the request is being sent.
	*/
	
	if _lastSuccesfulTS.isValid then
		if beforeLSD &lt;&gt; 0 then
			request.fromStartDate := _lastSuccesfulTS.subtractHoursAndMinutes(beforeLSD);
		else 
			request.fromStartDate := _lastSuccesfulTS.subtractHoursAndMinutes(1);
		endif;
	else
		request.fromStartDate := app.actualTimeServer().subtractHoursAndMinutes(24);
	endif;
	
	if afterRT &lt;&gt; 0 then
		request.toStartDate := app.actualTimeServer().addDays(afterRT);	
	else
		request.toStartDate := app.actualTimeServer().addDays(20);	
	endif;
	
	fromDate := request.fromStartDate.Date;
	fromTime := request.fromStartDate.Time;
	strFromDate := fromDate.format("yyy-MM-dd")&amp;"T"&amp;fromTime.formatAsHHMMSSmmm&amp;"Z";		
	
	toDate := request.toStartDate.Date;
	toTime := request.toStartDate.Time;
	strToDate := toDate.format("yyy-MM-dd")&amp;"T"&amp;toTime.formatAsHHMMSSmmm&amp;"Z";		
		
	xmlStr := '&lt;soap12:Envelope xmlns:soap12="http://www.w3.org/2003/05/soap-envelope"&gt;
			  &lt;soap12:Body&gt;
				&lt;GetVoyageExportDataByDomainAndDates xmlns="http://kleinsystem.com/webservices/"&gt;
				  &lt;DomainID&gt;' &amp; request.domainID.String &amp; '&lt;/DomainID&gt;
				  &lt;FromStartDate&gt;' &amp; strFromDate &amp;'&lt;/FromStartDate&gt;
				  &lt;ToStartDate&gt;' &amp; strToDate &amp;'&lt;/ToStartDate&gt;
				  &lt;aSessionKey&gt;' &amp; request.aSessionKey &amp; '&lt;/aSessionKey&gt;
				&lt;/GetVoyageExportDataByDomainAndDates&gt;
			  &lt;/soap12:Body&gt;
			&lt;/soap12:Envelope&gt;';
	
	
	// log the request
	app.writeLog(method.qualifiedName &amp; Tab &amp; "Sending request to Qships: '" &amp; xmlStr &amp; "'", LogDEBUG);
	create pxyActivity transient;
	pxyActivity.initialiseActivity(	BGP_QshipsRequest.Description_Post, 
									_webService.name, 
									_terminal, 
									null,
									"A".Character,
									"Request",
									false,
									null);
									
	pxyActivity.initialiseValues(_webService.domainName, _webService.clientType, _webService.serviceVersion);
	pxyActivity.setRequest(xmlStr);
	pxyActivity.setRequestName(method.name);	
	requestActivity := app.myTrxCA.trxCreateEWSActivityHistory(pxyActivity, app.myPassport).CM_EWSActivityQships;	
	delete pxyActivity;
	
	create response transient;
	
	response.getVoyageExportDataByDomainAndDatesResult := self.doSendHTTPRequest(self.baseEndpoint, "POST", 'Content-Type: application/soap+xml;charset=UTF-8;action="http://kleinsystem.com/webservices/GetVoyageExportDataByDomainAndDates"', xmlStr, resultCode);		
		
	if resultCode = HttpResponseNoContent then
		if requestActivity &lt;&gt; null then
			app.myTrxUA.trxUpdateEWSActivityStatus(requestActivity, BGP_QshipsRequest.Status_BGP_NoData, app.myPassport);
		endif;
		app.writeLog(method.qualifiedName &amp; Tab &amp; "NODATA: Response from Qships was " &amp; resultCode.String &amp; ":" &amp; resultString, LogERROR);
		
	elseif resultCode &lt;&gt; HttpResponseOK or response.getVoyageExportDataByDomainAndDatesResult = null then
		if requestActivity &lt;&gt; null then
			app.myTrxUA.trxUpdateEWSActivityStatus(requestActivity, BGP_QshipsRequest.Status_BGP_Request_Failure, app.myPassport);
		endif;
		app.writeLog(method.qualifiedName &amp; Tab &amp; "FAILED: Response from Qships was " &amp; resultCode.String &amp; ":" &amp; resultString, LogERROR);
	elseif resultCode = HttpResponseOK then
		if requestActivity &lt;&gt; null then
			app.myTrxUA.trxUpdateEWSActivityStatus(requestActivity, BGP_QshipsRequest.Status_BGP_Created, app.myPassport);
		endif;
		app.writeLog(method.qualifiedName &amp; Tab &amp; "SUCCESS: Response from Qships was " &amp; resultCode.String &amp; ":" &amp; resultString, LogERROR);
	endif;
	if requestActivity &lt;&gt; null then
		// Log the response
		app.writeLog(method.qualifiedName &amp; Tab &amp; "Response from Qships was " &amp; resultCode.String &amp; ":" &amp; resultString, LogDEBUG);	
		app.myTrxUA.trxUpdateEWSActivityResponse(requestActivity, response.getVoyageExportDataByDomainAndDatesResult, resultCode, app.myPassport);
	endif;
	
	// TFS 60921 set last successful date/time to "now" if we got a response from QShips
	// (rather than setting it to the "end date" of the query)
	//_lastSuccesfulTS := request.toStartDate;
	if resultCode.isOneOf(HttpResponseNoContent, HttpResponseOK) then
		_lastSuccesfulTS := app.actualTimeServer;
	endif;
	
	return response;
epilog
	delete pxyActivity;
end;</source>
        <Parameter name="_sessionKey" type="String"/>
        <Parameter name="_domainId" type="Integer"/>
        <Parameter name="_lastSuccesfulTS" type="TimeStamp" usage="io"/>
        <Parameter name="_webService" type="CM_QshipsWebServiceDef"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="Qships_GetVoyageExportDataByDomainAndDatesResponse"/>
    </JadeMethod>
    <JadeMethod name="login" id="fb5593d0-2a5d-4982-b4e7-e4fcc9edc032">
        <updating/>
        <source>login() : Qships_LoginResponse updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 05 October 2022
TFS#		: 54892
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	request 	: Qships_Login;	
	response	: Qships_LoginResponse;
begin
	create request transient;
	request.aClientType := self.clientType;
	request.aUser := self.usercode;
	request.aPasswd := self.password;
	request.aVersion := self.serviceVersion;	
	
	response := myQshipsAgent.login(request);		
	
	return response;
epilog
	delete request;
	
end;</source>
        <ReturnType type="Qships_LoginResponse"/>
    </JadeMethod>
    <JadeMethod name="setupFromWebServiceDefinition" id="b3a4f9e5-65ed-4be7-b0a6-a055abf43a38">
        <updating/>
        <source>setupFromWebServiceDefinition(_definition: CM_QshipsWebServiceDef) updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 05 October 2022
TFS#		: 54892
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

begin
	inheritMethod(_definition);
	
	self.clientType	:= _definition.clientType;
	self.domainName := _definition.domainName;
	self.lastSuccessfullTS := _definition.lastSuccessfullTS;
	self.serviceVersion := _definition.serviceVersion;
end;</source>
        <Parameter name="_definition" type="CM_QshipsWebServiceDef"/>
    </JadeMethod>
</Class>
