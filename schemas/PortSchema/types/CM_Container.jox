    <JadeMethod name="cargoIF_GetStringForETRow" id="00e86c45-a135-4a0b-bd4c-939ecb6e7b65">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_CargoField::getStringForETRow"/>
        </interfaceImplements>
        <source>cargoIF_GetStringForETRow(pAttrName : String): String;

	/*
		this method stub has been automatically generated by Jade to satisfy interface implementation requirements
	*/
/*
	Created on 18 January 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	tmpReal : Real;
begin
	if pAttrName = ETRow_AvailabilityGradeCode then
		return availabilityGrade.String;
	elseif pAttrName = ETRow_CarriageTempC then
		return app.getTemperatureDisplay(getTemperature, false, false);
	elseif pAttrName = ETRow_CarriageTempF then
		return app.getTemperatureDisplay(getTemperature, false, true);
	elseif pAttrName = ETRow_CoolingType then
		return app.coolingTypeENumToString(getCoolingType, false);
	elseif pAttrName = ETRow_VoltageType then
		return app.voltageTypeENumToString(getVoltageType, false);
	elseif pAttrName = ETRow_Humidity then
		if self.getHumidity &lt;&gt; NULL_HUMIDITY then
			return self.getHumidity.asNullHumidity;
		else
			return null;
		endif;
	elseif pAttrName = ETRow_Ventilation then
		if self.getVentilation &lt;&gt; NULL_VENTILATION then
	   		return self.getVentilation.asStringJMT; //par19252 cnwrs1 may 2009
		else
			return null;
	   	endif;
	elseif pAttrName = ETRow_Oxygen then					// CCMS 1654 - slw 15/09/2008
		return getOxygen.asNullOxygen;
	elseif pAttrName = ETRow_CarbonDioxide then				// CCMS 1654 - slw 15/09/2008
		return getCarbonDioxide.asNullCarbonDioxide;
	elseif pAttrName = ETRow_AllowableTimeOffPower then	
		return self.getAllowableTimeOffPower.asNullDecimal;
	else
		return inheritMethod(pAttrName);
	endif;
	
	return null;
end;</source>
        <Parameter name="pAttrName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="changeISOType" id="82d732dc-0461-4981-b6ae-f7b1b190681e">
        <updating/>
        <source>changeISOType(newISOType: String; _updateController: CMIF_TIUpdateController input; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:			30 May 2001 by cnwdwq1
// Purpose:			!     
// Parameters:	None
// Returns:			Nothing
// Changed On	Changed By		Reason
// ----------	----------		--------------------------------------------------
// 28/11/2009	cnwdap1			CCMS 1017 - moved all reefer attributes to a new class
//								Create/erase the myReeferProperties reference here as appropriate
// 09/11/2018	jlgrh7 TFS #41447 SNO - Error Code 75793
// ---------------------------------------------------------------------------
vars
	currISO 			: CM_ISOType;
	newISO 				: CM_ISOType;
	sizeChangeNeeded 	: Boolean;
	carryOn 			: Boolean;
	oHeight, oLength 	: Integer;
	tmpLC				: CM_LocationsController;
	obj					: Object;
	measureType : CM_MeasurementType;
	tareWeightStr : String;
	tareKilosStr : String;
begin
	exclusiveLock(self);
	
	if _updateController &lt;&gt; null then
		obj := _updateController.myUserObject;
	endif;
	//Used to break out if we are updating a persistent object, yet allow
	//updates to transients to continue
	//carryOn := not process.isInTransactionState;							//-TFS41447
	carryOn := not process.isInTransactionState;								//+TFS41447  Only doing validation when it is in Transaction State
	//------------------
	// Check to see if our ISO Type has changed at all...
	//------------------
	currISO := app.myRoot.allISOTypes[self.isoType];
	newISO  := app.myRoot.allISOTypes[newISOType];

	// PAR 16415 CCMS 1029
	//	oLength := self.getLengthInUnits().Integer;
	oLength := self.getActualLength().Integer;
	oHeight := self.getHeightOfTI();

	if newISO = null then
		
		app.setContinueCMExceptions(carryOn);
		//6/11/2009 cnwdz2 20784
		if not carryOn then																								//+TFS41447
			app.raiseCMException3(ERR_INVALID_ISOTYPE, newISOType, 'Container', self.id, 'isoType', obj);
		endif;
		return;		
	endif;
	
	//13 Nov 2013	NDL	Par  32931
	if currISO &lt;&gt; null and newISO &lt;&gt; null and currISO.tareKilos &lt;&gt; newISO.tareKilos then
		//changing to an iso type that has a different default tare weight
		if newISO.tareKilos &lt;&gt; 0 and newISO.tareKilos &lt;&gt; self.getTareWeight then
			//tare weight may need to be changed.  Warn them.
			measureType := app.getDefaultMeasurementForType(Type_Weight);
			if measureType = null then
				tareWeightStr := self.getTareWeight.asStringJMT();
				tareKilosStr := newISO.tareKilos.asStringJMT();
			else
				tareWeightStr := app.convertMeasurementForDisplay(measureType.shortName, self.getTareWeight);
				tareKilosStr := app.convertMeasurementForDisplay(measureType.shortName, newISO.tareKilos);
			endif;
			if  not carryOn then																		//+TFS41447
				app.raiseCMWarning4(Chang_type_will_mean_tare_weig, newISOType, tareWeightStr, newISOType, tareKilosStr, 'isoType', self, self);
			endif;
			//app.raiseCMException4(Chang_type_will_mean_tare_weig, newISOType, tareWeightStr, newISOType, tareKilosStr, 'isoType', self);		//14 March 2018 jlgmd1 TFS #37575
		endif;
	endif;

	if currISO &lt;&gt; null 
	and currISO.isSimilarISOType(newISO) = true 
	and self.typeAttributes = newISO.typeAttributes			//currISO can be edited to match newISO - need to check against 
	and self.sizeAttributes = newISO.sizeAttributes then	//the container too not just the old iso - JC 13/04/2004
		self.isoType := newISOType;				//cnwas3 change it still (it will show up in transactions as changed from isotype xyzv =&gt; xyzv, which makes no sense for the user)
		self.typeAttributes := newISO.typeAttributes;
		self.sizeAttributes := newISO.sizeAttributes;
		return;	//No change, same size/type etc.
	endif;

	//-----------------
	// If we are not powered, or a porthole check that we are not connected to power...
	//-----------------
	if (not newISO.isPowered) and (not newISO.isMachinery) then	// POT2001/217 PAR1438/1440 missing not for newISO.isPowered RDD 21/9/01 -- added here 16/10/01 RDD
		if self.getOnPower then
			//epr par 37266 21/1/16
				if  not carryOn then																							//+TFS41447
					app.raiseCMException1(ERR_MORPH_ONPOWER, self.id, null, null);
				endif;
		endif;
	endif;

	if not newISO.isPorthole then
		// If we are not a porthole, check that we are not connected to a tower...
		if self.getTower &lt;&gt; null then
			//epr par 37266 21/1/16
					if  not carryOn then
			app.raiseCMException(ERR_MORPH_TOWER, null, null);
			endif;
		endif;
	endif;
	//------------------------------------------
	// Update our attributes so they can be accessed by the following changeTISize methods..
	//------------------------------------------
	self.isoType := newISOType;
	self.typeAttributes := newISO.typeAttributes;
	self.sizeAttributes := newISO.sizeAttributes;
	//------------------------------------------
	// Determine whether any sizeAttribute change will actually effect the locations
	// as the only things that are important are 20'/40', fullHeight/halfHeight
	//------------------------------------------
	if currISO = null then
  		return;
	endif;

	// CCMS 1017 Create/erase myReeferProperties reference as appropriate
	if currISO &lt;&gt; null and newISO &lt;&gt; null then
		if currISO.isReefer and not newISO.isReefer then
			// remove the reefer properties - we are no longer a reefer
			if self.myReeferProperties &lt;&gt; null then
				self.myReeferProperties.erase(NORMAL_ERASE);
			endif;
		elseif not currISO.isReefer and newISO.isReefer then
			self.createReeferPropertiesIfReqd("new");
		endif;
	endif;
	
//	if currISO.is20ftLong &lt;&gt; newISO.is20ftLong then
	if currISO.hasDifferentLength(newISO) then
		sizeChangeNeeded := true;
	elseif currISO.isHalfHeight &lt;&gt; newISO.isHalfHeight then
		sizeChangeNeeded := true;
	endif;
	if sizeChangeNeeded = false then
		return;
	endif;
	//-----------------
	// Check with our location controller
	// to see if we can still fit in that location...
	//-----------------
	tmpLC := getPrimaryLocation(REAL_MODE);
	if tmpLC &lt;&gt; null then
		tmpLC.changeTrackedItemSize(REAL_MODE, self, oHeight, oLength, _passport);
	endif;	
	tmpLC := getPrimaryLocation(PLANNING_MODE);
	if tmpLC &lt;&gt; null then
		tmpLC.changeTrackedItemSize(PLANNING_MODE, self, oHeight, oLength, _passport);
	endif;
	

epilog

end;</source>
        <Parameter name="newISOType" type="String"/>
        <Parameter name="_updateController" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="changeVoyage" id="c2740231-5233-4014-a840-4a4850fa143b">
        <updating/>
        <source>changeVoyage(aVoyage: CM_Voyage; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     18 September 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	newVoyage	: CM_Voyage;
	cou			: CM_ClipOnUnit;
begin
	inheritMethod(aVoyage, _passport);
	
	newVoyage := aVoyage;

	if newVoyage = null then
		// this will have been set in the inheritMethod
		newVoyage := self.myVoyage;
	endif;

	cou := self.getCou();
	
	if cou &lt;&gt; null then
		cou.changeVoyage(newVoyage, _passport);
	endif;
	
end;</source>
        <Parameter name="aVoyage" type="CM_Voyage"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="checkAvailabilityGrades" id="71bb8c01-c23e-4c40-af76-085671c675f3">
        <source>checkAvailabilityGrades(pAveGrades : IntegerArray): Boolean;
//Called from VB checkISOReq
vars
	tmpMTGrade : CM_MTGrade;
begin

	if pAveGrades.size &gt; 0 then
		if not pAveGrades.includes(self.availabilityGrade) then	
			return false;				
		endif;
	else
		return true;
	endif;

	if self.availabilityGrade = null then
		return false;
	endif;
	
	tmpMTGrade := app.myRoot.allAvailabilityGrades[self.availabilityGrade];
	if tmpMTGrade &lt;&gt; null then
		if not tmpMTGrade.isSuitableForRelease then
			return false;
		endif;	
	endif;
		
	return true;
end;</source>
        <Parameter name="pAveGrades" type="IntegerArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkBookingReference" id="cbbafd19-dac5-4701-8604-39cd55461f9f">
        <updating/>
        <source>checkBookingReference(_br: CM_BookingRef; _brItem : CM_BookingRefItem) updating;
// ---------------------------------------------------------------------------
// Created:     18 September 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 19 may 2011	cnwrs1		add self.
// 01 Oct 2019	jlgzm1		TFS 46575 Reefer options for non-containers. 
//							
// ---------------------------------------------------------------------------
vars
	now : TimeStamp;
	brItemIsContainer : Boolean;
	tempString		: String;
begin
	inheritMethod(_br, _brItem);
	now := app.actualTimeServer();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
	brItemIsContainer := CM_BRefItemContainer.hasInstance(_brItem);
	
	//PAR15531 and 15533.  Don't do these checks if we have the Basic Booking Reference Check Only flag on. 07/01/2008 See CM_Container::checkBookingReference also.
	if not self.myTerminal.getConfig(BookingRefBasicCheck).Boolean then
		if _brItem.clean = true and self.isClean = false then
			//NB: Don't care about the opposite situation
			self.createBookingRefDiscrepancy(app.getErrorString3(WARN_BOOKING_REF_DISCREP, "Clean Status", "Dirty", "Clean"), now);
			app.raiseCMWarning3(WARN_BOOKING_REF_DISCREP, "Clean Status for " &amp; self.id, "Dirty", "Clean", "", null, self);
		endif;
		
	endif; //End config for Basic Booking Reference Only config flag

end;</source>
        <Parameter name="_br" type="CM_BookingRef"/>
        <Parameter name="_brItem" type="CM_BookingRefItem"/>
    </JadeMethod>
    <JadeMethod name="checkProxyIsValid" id="39e8288c-a658-4d7e-9a3f-698051bc108c">
        <source>checkProxyIsValid(_pxyTI: CM_Container; _passport : CM_Passport input): Boolean;
// ---------------------------------------------------------------------------
// Created:     18 September 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	realTI			: CM_TrackedItem;
	expectedEdition	: Integer;

begin
	if (not inheritMethod(_pxyTI, _passport)) then
		return false;
	endif;
	
	if _pxyTI.getCou &lt;&gt; null then
		_pxyTI.getCou.pxyGetRealObjectAndEdition(realTI, expectedEdition);
		if realTI &lt;&gt; null then
			exclusiveLock(realTI);
			if _passport.noErrors and realTI.edition &lt;&gt; expectedEdition then
				app.raiseCMException1(ObjectUpdatedByAnotherUserSave, self.cargoTypeDescr, null, null);
				return false;
			endif;
		else
			//Need an exception ??					
		endif;	
	endif;

	return true;
	
end;</source>
        <Parameter name="_pxyTI" type="CM_Container"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkSameISOType" id="fc9fba6e-0f84-4074-86c5-75da8fb1e79a">
        <source>checkSameISOType(_proxyContainer : CM_Container): Boolean;
// -------------------------------------------
// Created 06 April 2004 by cnwdvb1
// -------------------------------------------
vars

begin
	return _proxyContainer.isoType = self.isoType;


end;</source>
        <Parameter name="_proxyContainer" type="CM_Container"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkTaskExpired" id="b1379db3-0a07-42b5-94f4-df1d1eb4985e">
        <updating/>
        <source>checkTaskExpired(_toDoTaskDesc : CM_ToDoTaskDesc; _passport: CM_Passport input): Boolean updating;
//--------------------------------------------------------------
//Created: 05 June 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	lastDone, now 		: TimeStamp;
	numDaysSinceLastTask,
	expiryPeriod 		: Integer;
	toDoTask 			: CM_ToDoTask;
	isToDoTaskPending 	: Boolean;
	isoType				: CM_ISOType;
begin

	inheritMethod(_toDoTaskDesc, _passport);
	
//	if _toDoTaskDesc.transactionToCreate = PRETRIP then
	if _toDoTaskDesc.trxTypeOnCompletion = TRANS_TYPE_PRETRIP then
		if (not self.checkTaskExpiredPTI) then
			return false;
		endif;
//	elseif _toDoTaskDesc.transactionToCreate = WASH then
	elseif _toDoTaskDesc.trxTypeOnCompletion = TRANS_TYPE_WASH then
		// 30/09/2009 cnwar2 #20761 - only create task for integral reefer type containers
		//isoType := self.getISOTypeObject();
		//if not (isoType.isReefer and isoType.isIntegral) then
		
		//cnwjo3 CCMS 1892, par 23587
		if not self.canWashDTExpire() then  //if its a dry container then wash task does not expire
			return false;
		endif;
		// Par 14228 Don't reset todotask unless box has already been washed once
		//if ((self.isClean) or (not self.washDT.isValid)) then
		//cnwjo3 CCMS 1892, par 23587
		if self.isClean then   //don't need to check self.washDT.isValid since it is now done in CM_Container::getCleanStatus
			return false;
		endif;
	else
//		app.raiseCMException2(WARN_TASK_TRANS_WRONG, _toDoTaskDesc.transactionToCreate, "Should be " &amp; WASH &amp; " or " &amp; PRETRIP &amp; ".", null, null);
		app.raiseCMException2(WARN_TASK_TRANS_WRONG, _toDoTaskDesc.getTrxTypeOnCompleteClassName(), "Should be " &amp; WASH &amp; " or " &amp; PRETRIP &amp; ".", null, null);
		//app.raiseUnexpectedProgramError(class.name, method.name, 'Unhandled To Do Task - ' &amp; _toDoTaskDesc.description);
		return false;
	endif;

	isToDoTaskPending := false;
	
	// Check to see if there is already a toDoTask for _toDoTaskDesc pending
	foreach toDoTask in self.allToDoTasksToDo do
		if toDoTask.toDoTaskDesc = _toDoTaskDesc and toDoTask.status = STATUS_TODO then
			app.writeLog('Auto processing Task: Already has To Do Task', LogINFO);			
			isToDoTaskPending := true;
			return false;
		endif;
	endforeach;
	
	if isToDoTaskPending then
		// There is already a _toDoTaskDesc pending.	
		return false;
	endif;

	//--------------------------------------------
	// If we made it to here then task has expired.
	//--------------------------------------------
	return true;	
		
end;</source>
        <Parameter name="_toDoTaskDesc" type="CM_ToDoTaskDesc"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkTaskExpiredPTI" id="b4787b1c-4d84-4770-9076-b06e4f21c207">
        <source>checkTaskExpiredPTI(): Boolean protected;
//--------------------------------------------------------------
//Created: 05 June 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	now : TimeStamp;
	numDaysSinceLastTask,
	expiryPeriod : Integer;
begin
	now := app.actualTimeServer();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
	expiryPeriod := self.getPTIExpiryPeriod();
	if expiryPeriod = null then
		// PTI does not expire, nothing to do then.
		return false;
	endif; 

	now := app.serverTimestampAtTrxStart;
	
	if self.getPreTripDT &lt;&gt; null then			
		numDaysSinceLastTask := now.date - self.getPreTripDT.date;
	endif;

	if numDaysSinceLastTask &lt; expiryPeriod then 
		// last pretripped withing the PTI expiry period;
		return false;
	endif;

	return true;
			
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
