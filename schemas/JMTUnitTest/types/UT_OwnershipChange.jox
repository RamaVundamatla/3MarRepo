    <JadeMethod name="createOwnershipChangePxy" id="992cf57a-43cd-4aa8-9129-fd917f590045">
        <source>createOwnershipChangePxy(_refNumber : String) : CM_OwnershipChange;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 August 2023	navmv20	CR 59440 Task 59441: Jade - Ownership Change Release Request Validation

*/

constants

	DEBTOR 		= "UT_DEBTOR_AB";
vars
	pxyOwnership				: CM_OwnershipChange;
	dateTimeCOO,dateTimeApproved,storageExpriryOperatorNew: TimeStamp;
	remarks 					: String;
	myiNCOTerm					: CM_InvoiceINCOTerm;
	myOperatorNew,
	myOperatorOid,
	myOperatorOrig,
	myOperatorStorage			: CM_Operator;
	myFreightForward			: CM_ConsigneeConsignor;
	root						: CM_Root;
	terminal					: CM_Terminal;
	myOwnerShip					: CM_OwnershipChange;
	transferedWeight, transferedVolume : Decimal[23,4];
	debtor1			: CM_Debtor;
begin
	//Create OwnershipChange
 
	dateTimeCOO		:= app.actualTimeAppServer();
	storageExpriryOperatorNew := app.actualTimeAppServer();
	root := app.myRoot;
	terminal := self.getTerminal;
	if self.opts.includesKey("Remarks") then
		remarks := self.opts.str("Remarks");
	endif;
	transferedWeight		:= 25.4578;
	transferedVolume		:= 78.8974;
	self.deleteInvINCOTerm("abcd");
	self.contractINCOCreate(myiNCOTerm, "abcd");
	
	self.deleteOperator("ABCO");
	self.deleteOperator("Oid");
	
	self.deleteOperator("OStorage");
	self.deleteConsigneeConsignor("UTFreightForward");
	myOperatorNew := self.addOperator("ABCO", "Ownership Change OperatorNew", false, 0, 0, debtor1, false, false, false, false, false, false, false, false, false, false, null, null, null, false, false, false, null, null, 0, null, false, false);
	self.assertNotNullMsg(myOperatorNew,"Operator Create Failed");
	
	myOperatorOid := self.addOperator("Oid", "Ownership Change Operatoroid", false, 0, 0, debtor1, false, false, false, false, false, false, false, false, false, false, null, null, null, false, false, false, null, null, 0, null, false, false);
	self.assertNotNullMsg(myOperatorOid,"Operator Create Failed");
	
	myOperatorOrig := app.myRoot.allOperators["Orig"];
	if myOperatorOrig = null then
		myOperatorOrig := self.addOperator("Orig", "Ownership Change OperatorOrig", false, 0, 0, debtor1, false, false, false, false, false, false, false, false, false, false, null, null, null, false, false, false, null, null, 0, null, false, false);
		self.assertNotNullMsg(myOperatorOrig,"Operator Create Failed");
	endif;
	myFreightForward := self.addConsigneeConsignor("UTFr", "FreightForward", true, false, false);
	myOperatorStorage := self.addOperator("OSto", "Ownership Change OperatorStorage", false, 0, 0, debtor1, false, false, false, false, false, false, false, false, false, false, null, null, null, false, false, false, null, null, 0, null, false, false);
	self.assertNotNullMsg(myOperatorStorage,"Operator Create Failed");
	foreach myOwnerShip in myOperatorNew.allOwnershipChangeNew do 
		if  myOwnerShip.refNumber = "ABCde" then
			deleteOwnershipChange(myOwnerShip);
		endif;
	endforeach;

    create pxyOwnership transient;
	pxyOwnership.setProxy(_refNumber,app.getMyUserCode(),"Good",app.getMyUserCode(),dateTimeCOO,null,storageExpriryOperatorNew,11,12,13,150,transferedWeight,transferedVolume,remarks,
	myFreightForward,myiNCOTerm,myOperatorNew,myOperatorOid,myOperatorOrig,myOperatorStorage,null,terminal, null);		//navra1 - TFS 64874 - 14th Aug 2024
	return pxyOwnership;
epilog

end;</source>
