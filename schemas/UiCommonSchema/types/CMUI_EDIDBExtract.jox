        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbFormat_lostFocus(_combo :ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:		25 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	
begin
	self.tblDetail.setValueByControlName(_combo.name, _combo.text);	
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbOperator_click" id="66cdd5a1-0b43-43b3-a144-e40910597d64">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbOperator_click(_combo: ComboBox input) updating;
//----------------------------------------------------------------
//	Created:	16 January 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 21/03/2012	cnwcs5	CCMS POL 2144 / Par 29312 - Extract Baplie by Operator
vars

	tbl			: CM_EntryTable;
	attrName	: String;
begin
	tbl 		:= self.tblDetail;
	attrName 	:= tbl.getAttrName(tbl.row);
	
	if attrName = ETRow_FilterOperator then
		tbl.setValueByName(ETRow_FilterOperator, _combo.text);
		self.filterOperator := _combo.listObject.CM_Operator;
		
	elseif attrName = ETRow_ExtractOperator then
		tbl.setValueByName(ETRow_ExtractOperator, _combo.text);
		self.myRecipient := _combo.listObject.CM_Operator;
		
	elseif attrName = ETRow_CargoOperator then	// par 29312 - march 2012
		tbl.setValueByName(ETRow_CargoOperator, _combo.text);
		self.myCargoOperator := _combo.listObject.CM_Operator;
		
	endif;
	

end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbOperator_displayEntry" id="f18ab5a4-6bec-4c57-ba57-570dd342ef0b">
