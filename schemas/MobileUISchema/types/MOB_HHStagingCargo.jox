    <JadeMethod name="clickButton" id="3cf44c42-df6b-462e-a180-bce315bd7e1e">
        <updating/>
        <source>clickButton( obj : Object; _toLocn : CM_LocationsController ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 October 2014	cnwndl1	Initial creation

*/

vars

	ti :  CM_TrackedItem;
	moveController : CMIF_MoveController;
	target : String;
	quantity : Integer;
	weight : Decimal [16,4];
	volume : Decimal [16,4];
	errMess : String;
	reserveDetail : CM_ReserveDetail;
	tmpWle : CM_WorkListEntry;
	wle : CM_WorkListEntry;
	amountForm : MOB_HHCargoAmountForm;
	docActions : CM_DocumentActions;

begin

	if obj &lt;&gt; null then
		ti := obj.CM_TrackedItem;
	endif;
	if _toLocn = null then
		return;
	endif;
	
	if ti &lt;&gt; null then
		target := _toLocn.getFullId;
	/*	if ti.isBulkByQuantity then
			quantity := ti.totalQuantity;
		elseif ti.isBulkByWeight then
			weight := ti.totalWeight;
		elseif ti.isBulkByVolume then
			volume := ti.totalVolume;
			weight := volume * ti.getDensity;
		endif; */
		//11 Nov 2014	NDL	Par 35146
		if ti.myCargoType.isBreakBulkMulti or 
			ti.myCargoType.isBulkMulti then
			create amountForm transient;
			amountForm.lblInfo.caption := app.getErrorString2( MoveToTarget , ti.id, target );
			amountForm.myTrackedItem := ti;
			if amountForm.showModal = IDOK then
				if amountForm.byQuantity then
					quantity := amountForm.getQuantity;
				else
					weight := amountForm.getWeightMovedKgs;
				endif;
			else
				return;
			endif;
		endif;
		
		if self.moveMode = REAL_MODE then
		
			//26 Sep 2016	NDL	TFS 2647 / 2001
			if self.myBulkRelease.allReserveDetails.size = 1 then
				reserveDetail := self.myBulkRelease.allReserveDetails.first;
			else
				reserveDetail := self.cmbRelItems.listObject.CM_ReserveDetail;
			endif;
			if reserveDetail &lt;&gt; null then
				docActions := reserveDetail.myReserveDetailActions;
			endif;
		
			app.myPassport.setWarningsIgnored(true);
			self.myMobileGenericAgent.moveTI( ti, target, _toLocn, null, false, quantity, weight, docActions );
			
		elseif moveMode = QUEUE_MODE then
			if ti.isAlreadyQueuedTo(self.myTargetLocation) then
				// must be trying to unqueue it
				foreach tmpWle in ti.allWorklistEntries do
					if tmpWle.getTargetLocation &lt;&gt; _toLocn then
						continue;
					endif;
					if tmpWle.status = WLE_COMPLETED then
						continue;
					endif;
					wle := tmpWle;
					break;
				endforeach;
				create moveController transient;
				moveController.setMoveMode(QUEUE_MODE);
				moveController.setMyTrackedItem(ti);
				moveController.setMyWorkListEntry(wle);
				app.myTrxUA.trxUpdateMoveTIUndo(moveController, app.myPassport);
				
			else
				create moveController transient;
				moveController.setMyTrackedItem(ti);
				moveController.setMyOriginatingLocation(ti.myPrimaryActualLocation);
				moveController.setMoveMode(QUEUE_MODE);	
				moveController.setMyToPrimaryLocation(_toLocn);
				app.myPassport.setWarningsIgnored(true);
				app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
				
			endif;
			
		endif;
		
		if app.myPassport.trxCompletedOK then
			self.setupChosen();
			if self.myBulkRelease.allReserveDetails.size = 1 then
				self.setupSelectable( self.myBulkRelease.allReserveDetails.first );
			else
				self.setupSelectable( self.cmbRelItems.listObject.CM_ReserveDetail );
			endif;
			self.doResizeControls(false);	//08 Jul 2016	NDL	TFS 2275 / 2216
			self.setLblTotals();
		else
			errMess := app.myPassport.getAllErrorsWarningsAsString;	
			self.msgBox( errMess, app.getErrorString(Error), MsgBox_OK_Only, true );	
		endif;
	
	endif;

epilog

	delete moveController;

end;</source>
        <Parameter name="obj" type="Object"/>
        <Parameter name="_toLocn" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="cmbRelItems_change" id="d0680176-2ab7-4ba9-ae4a-d653661873ab">
        <controlMethod name="ComboBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbRelItems_change(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 October 2014	cnwndl1	Initial creation

*/

vars

	obj : Object;
	releaseDetail : CM_ReserveDetail;

begin

	if self.cmbRelItems.listIndex &gt; 0 then
		obj := self.cmbRelItems.itemObject[self.cmbRelItems.listIndex];
		if obj &lt;&gt; null then
			releaseDetail := obj.CM_ReserveDetail;
		endif;
	endif;

	self.setupSelectable( releaseDetail );
	
	self.setLblTotals();

epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
