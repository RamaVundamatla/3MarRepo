    <JadeMethod name="loadRequestClasses" id="3a420393-a068-4446-b86e-76963d1d2604">
        <source>loadRequestClasses() protected;
// --------------------------------------------------------------------------------
// Created:		28 February 2006 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 28 May 2013		cnwrs1	ccms 1336 Par 31389 separate BGP EmailRequest to seperate read and send
// 03 Mar 2014	cnwrs1 par 33631 SFW 1373
// 16 Aug 2016	cnwdap1		TFS #1832 TSW Changes
// 15 Sep 2020	jlgdap1		TFS 49316 MTN Machine Idle Time
// 05 Oct 2022	jlika1		TFS 54892 - POB - Vessel, Voyage and Movement EDI Messages
// 02 Aug 2024	navdap1		TFS 63842 NSW | OnePort Integration
// 08 Sep 2025	navdap1		MTN-35615 ENS | Bulk Creation of Yard Allocations
// 25 Nov 2025	navdap1		MTN-36569 CPL | Reefer Runner Integration
