    <JadeMethod name="utlUpdateInvExtFields" id="07ec7460-1e6a-499b-9926-0d8c56a88020">
        <updating/>
        <source>utlUpdateInvExtFields(_cmif : CMIF_InvoiceExternalRefHeader; _updateLineRef : Boolean; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//08/12/2025	navkc1 JIRA 36262 ROS - 1 - External Reference updates in MTN 

*/

vars
	inv		: CM_Invoice;
begin
	
	self.initialiseActivity();

	app.setContinueCMExceptions(true);
	
	inv := _cmif.myInvoice;
	
	if inv = null then	
		return;
	endif;

	app.myValUA.valUpdateInvExtFields(_cmif, _passport);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;	
	endif;


	app.setContinueCMExceptions(false);

	exclusiveLock(inv);

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(inv, true);
	endif;
	
	if _passport.noErrors then
		inv.setExternalRefFields(_cmif.externalFinancialID, _cmif.externalTaxNumber, _cmif.externalNumber);
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(inv, false);
		app.myEventManager.createSingleObjInfoNoteEvt(inv, _passport.myTerminal.getTerminalEvent(Event_InvoiceUpdate), inv);
	endif; 

	//20/01/2026	navkc1 JIRA MTN 36571
	if _passport.noErrors() and _updateLineRef then
		app.myUtilityUA.utlUpdateInvLinesExtReferences(_cmif.allSummaries, app.myPassport);
	endif;
epilog

end;</source>
        <Parameter name="_cmif" type="CMIF_InvoiceExternalRefHeader"/>
        <Parameter name="_updateLineRef" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
