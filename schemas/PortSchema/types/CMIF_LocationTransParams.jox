    <JadeMethod name="myContainer" id="c0de142b-66c3-4dca-a365-a4eadead3d52">
        <methodInvocation>mapping</methodInvocation>
        <source>myContainer(set: Boolean; _value: CM_Container io) mapping;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 Nov 2008	cnwkpd1	PAR #18526 - CCMS 1767 - TCP Interface ValidateMove changes

*/

vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
	else
		if self.myTrackedItem &lt;&gt; null and self.myTrackedItem.isKindOf(CM_Container) then
			_value := self.myTrackedItem.CM_Container;
		else
			_value := null;
		endif;
	endif;


epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_Container" usage="io"/>
    </JadeMethod>
