    <JadeMethod name="setControlsForAddEdit" id="842158f0-41dd-452d-9253-56b6eb765471">
        <updating/>
        <source>setControlsForAddEdit() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09/08/2023	navkc1	CR 59580	Task 59588: UI - CustDocs Customs Shipping Line Status

*/

vars
	theForm 			: SOP_TableMaintForm;
begin
	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
	
	if theForm.mode = theForm.Mode_Add then
		theForm.tblInput1.clearValues;
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);
		theForm.tblInput1.enableRowByName(ETRow_NotAvailForEntry);
		theForm.tblInput1.enableRowByName(ETRow_Type);
		theForm.tblInput1.enableRowByName(ETRow_SetCriteria);
		theForm.tblInput1.hideRowByName(ETRow_SetCriteria,false);
		theForm.tblInput1.cnEcResizeContents();
		theForm.tblInput1.setFocus;
		theForm.tblInput1.moveFirst();
		theForm.tblInput1.gotFocus(theForm.tblInput1);
		theForm.fldInput.initSheetBackColors();
	else
		self.showThumbnail(theForm.myProxyObject.CM_ShippingLineStatus);
		theForm.tblInput1.disableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);
		theForm.tblInput1.enableRowByName(ETRow_NotAvailForEntry);
		theForm.tblInput1.enableRowByName(ETRow_Type);
		theForm.tblInput1.enableRowByName(ETRow_SetCriteria);
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="bf52a232-7c07-4755-ae3f-7b95115b265d">
        <updating/>
        <source>setCtrlsForView() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
