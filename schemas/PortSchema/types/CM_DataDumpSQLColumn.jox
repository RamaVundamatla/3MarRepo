	self.myDataDumpSQLDataType  := _proxyDataDumpSQLColumn.myDataDumpSQLDataType;
	self.sqlColumnOrdinalPosition := _proxyDataDumpSQLColumn.sqlColumnOrdinalPosition;
epilog

end;</source>
        <Parameter name="_proxyDataDumpSQLColumn" type="CM_DataDumpSQLColumn"/>
    </JadeMethod>
