    <JadeMethod name="initializeForNextAllocation" id="a8759a78-019d-46ef-bd10-41cb22ec1ec5">
        <updating/>
        <source>initializeForNextAllocation(_currentAllocation : CM_YardAllocation) updating, protected;
// -------------------------------------------
// Created 07 April 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	self.checkingSecondary := false;
	self.myCurrentAllocation := _currentAllocation;
	self.iteration := 0;
	
	if self.myCurrentCMIFYAAutoPlan &lt;&gt; null then
		self.myCurrentCMIFYAAutoPlan.allFailedLocations.clear();
		self.myCurrentCMIFYAAutoPlan.allPassedLocations.clear();
		//23 Jan 2015	NDL	Par 35547 - don't clear here, otherwise we potentially lose the first restricted position.
		//self.myCurrentCMIFYAAutoPlan.allPassedLocationsRestricted.clear(); //cnwrd1 par 29269 14.3.2012 
		self.myCurrentCMIFYAAutoPlan.allFoundTis.clear();
	endif;
	
	// Only clear these when we are processing for a single location.
	if self.isSingleProcessing() then
		if self.myCurrentCMIFYAAutoPlan &lt;&gt; null then
		//	self.myCurrentCMIFYAAutoPlan.allFoundLCs.clear();
			self.myCurrentCMIFYAAutoPlan.clearAllFoundLocations();
			self.myCurrentCMIFYAAutoPlan.allLCsLastResort.clear();
		endif;
	endif;
	
	// CCMS 1012
	self.setNumberOfFreeSpacesReq();
	
end;</source>
        <access>protected</access>
        <Parameter name="_currentAllocation" type="CM_YardAllocation"/>
    </JadeMethod>
    <JadeMethod name="isBulkReleaseBTAssignedCargo" id="410cb409-e29a-4b61-a2ca-fdfbc7b14ff2">
        <source>isBulkReleaseBTAssignedCargo(_request : CM_Request ): Boolean;

/*

Purpose:	//cnwrd1 par 32041 bulk release by type with assigned cargo should go here		

Parameters:			

Return Value:		


Date		Who		Reason
23 July 2013	cnwrd1	Initial creation
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
*/

vars
	aBulkRelease : CM_BulkRelease;
	aReserveDetail : CM_ReserveDetail;
begin
	aBulkRelease := _request.getBulkRelease;
	aReserveDetail := _request.getBulkReleaseReserveDetail;
	
	if aBulkRelease = null then
		return false ;
	endif;
		
	
	if not aBulkRelease.releaseByType then
		return false;
	endif;
	
	if aReserveDetail &lt;&gt; null and aReserveDetail.isKindOf(CM_ReserveSelection) then
		//return not aReserveDetail.allTrackedItems.isEmpty;
		return aReserveDetail.hasTi(); //23/06/2023	navkc1	CR 58406 Task 58408
	endif;
	
	return not aBulkRelease.allTrackedItemsAssigned.isEmpty;
	
epilog
	
end;</source>
        <Parameter name="_request" type="CM_Request"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isForDirectDelivery" id="8b25df52-7193-447e-b6a8-f95f1a5688f9">
        <source>isForDirectDelivery():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 January 2013	cnwndl1	Initial creation	Par 31102

*/

vars

	invalidObj : Boolean;

begin

	if self.myCurrentCMIFYAAutoPlan &lt;&gt; null then
		on Exception do app.handleDeletedObject( exception, self.myCurrentCMIFYAAutoPlan, invalidObj );
		return self.myCurrentCMIFYAAutoPlan.isForDirectDelivery();
	endif;

	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
