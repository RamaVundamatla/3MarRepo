<GUIClass name="JSSCalendarSelectForm" id="d7b65640-9fd2-4023-914f-c9f42ccaed67">
    <superclass name="JSSBaseDialogForm"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>___________________________________________________________________________

              P R O P R I E T A R Y   N O T I C E

