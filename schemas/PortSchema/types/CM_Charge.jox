end;</source>
        <Parameter name="_rate" type="Real"/>
    </JadeMethod>
    <JadeMethod name="setTaxDetails" id="2f781246-15e3-46bb-a705-18067cf6ee39">
        <updating/>
        <source>setTaxDetails() updating;
/*
Purpose:			

Date		Who		Reason
11 April 2024	navab1	CR 63369 TASK 63502 
*/

vars
	taxStr : String;
	lineAmount : Decimal[23,4];
begin

	self.taxCode := "";
	self.taxDescription := "";
	self.taxGLCode := "";
	self.taxRate := 0;

	
	// ### CODE
	taxStr:= self.getTaxDescription(false);
	if taxStr &lt;&gt; null then 
		self.taxCode := taxStr;
		if self.invoiceLine &lt;&gt; null then
			self.invoiceLine.setTaxCodes(taxStr);
		endif;
	endif;
	
	// ### DESC
	taxStr:= self.getTaxDescription(true);
	if taxStr &lt;&gt; null then 
		self.taxDescription := taxStr;
		if self.invoiceLine &lt;&gt; null then
			self.invoiceLine.setTaxDescriptions(taxStr);
		endif;
	endif;
	
	// ### GL CODE
	taxStr:= self.getTaxGLCode();
	if taxStr &lt;&gt; null then 
		self.taxGLCode := taxStr;
		if self.invoiceLine &lt;&gt; null then
			self.invoiceLine.setTaxGLCodes(taxStr);
		endif;
	endif;
	
	// ### RATE
	self.taxRate := self.getTaxRateForCharge();
	self.invoiceLine.setTaxRates(self.taxRate);


epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setVolumeBasedRange" id="7926509d-bf0b-4c50-b68a-6abcf8972e05">
        <updating/>
        <source>setVolumeBasedRange(_from, _to : Decimal;_uomObj : CM_InvoiceUnitOfMeasure; _amount : Decimal) updating;
/*
Purpose:			

Date		Who		Reason
28 April 2023	navab1	TFS BUG 57729
*/

vars
	calcType : CM_CalculationType;
begin
	self.contractVBRangeFrom := _from;
	self.contractVBRangeTo := _to;
	
	 // ### TFS CR 55653 TASK 55669 20JUN2023 NAVAB1
	if _uomObj &lt;&gt; null then
		if _uomObj.type = Invoice_UOM_Type_Weight then
			self.contractVBAccumulatedWeight := _amount;
		elseif _uomObj.type = Invoice_UOM_Type_Volume then
			self.contractVBAccumulatedVolume := _amount;
		elseif _uomObj.type = Invoice_UOM_Type_TEU then
			self.contractVBAccumulatedTEU := _amount;
		elseif _uomObj.type = Invoice_UOM_Type_Quantity then 
			self.contractVBAccumulatedQuantity := _amount.Integer;
		endif;
	else
		// ### TFS BUG 61269 21NOV2023 NAVAB1 - in case there is not a UOM object configured
		calcType := self.service.myCalculationType;
		if calcType &lt;&gt; null then
			if calcType.isWeightBased() then
				self.contractVBAccumulatedWeight := _amount;
			elseif calcType.isVolumeBased() then
				self.contractVBAccumulatedVolume := _amount;
			elseif calcType.isQuantityBased() then
				self.contractVBAccumulatedQuantity := _amount.Integer;
			endif;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_from" type="Decimal"/>
        <Parameter name="_to" type="Decimal"/>
        <Parameter name="_uomObj" type="CM_InvoiceUnitOfMeasure"/>
        <Parameter name="_amount" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="86e63b28-99dd-4595-96c1-8c78f6bec8ff">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 May 2018	jlgmp6	Initial creation	TFS37718

*/

vars
	propName	: String;

begin

	if _property = null then
		return false;
	endif;
	
	propName := _property.name;
	
	if propName = CM_Charge::isTotalSetExplicitly.name 
	then
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;
	

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="total" id="5c9ef597-cfe7-4f26-9d95-d0b8a9869e8c">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>total(set : Boolean; _value : Real io) mapping, updating;
/*

		Calculate the charge total value.  From 8.1.1 this no longer gets the current debtor/service rate 
	
Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance
31 Oct 2018 cnwma1  ChangeRequest 41703: PEL1 - Sap Integration - Post Billing Cancelled Invoice
21 Nov 2018 cnwma1  Bug 42084: PEL1 - Invoice changes in Disputed status
07 Jan 2019 cnwma1	Bug 42791: PEL1 Error 1406 - Result of Expression overflows Integer precision
19 Mar 2021 cnwma1  ChangeRequest 50925: ASPA - New Total Column in Invoice Form
18 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/ 

vars
	invoiceStatus	: Integer;
	invalid			: Boolean;
	terminal		: CM_Terminal;
	blurb			: String;
	roundDecimalOpt : Integer;
	canLogExtra		: Boolean;	//26.02.2025 navah1	#34141
begin

	if self.invoiceLine = null then
		return;
	endif;

	canLogExtra	:= app.canLogExtraDetail();		//26.02.2025 navma1 #34141
	
	// 32498 pro forma invoice lines and cash extra values
	if self.invoiceLine.invoice = null then
		if set then
			if canLogExtra then	//26.02.2025 navah1	#34141
				app.invLog(method.qualifiedName &amp; " Setting TOTAL Explicitly To " &amp; _value.String, LogINFO.String);
			endif;
			self.isTotalSetExplicitly := true;
			self.total := _value;
		else
			if self.isTotalSetExplicitly then
				_value := self.total;
			else
				_value := self.rate * self.invoiceLine.quantity;
			endif;
		endif;
		return;
	endif;

	// CCMS 1280 pro forma transient invoice line will have an invalid .invoice
	on Exception do app.handleDeletedObject(exception, self.invoiceLine.invoice, invalid);
	invoiceStatus := self.invoiceLine.invoice.status;
	
	if set then
		if self.invoiceLine &lt;&gt; null and
			app.niceName &lt;&gt; self.OVERRIDEAPPNAME  and 	// this is added so that when the corruption script is run it will allow us to change the total AKB2003OCT
			self.invoiceLine.invoice &lt;&gt; null and
			not self.isTransient() and										// 35992 allow with transients in cash collection processing
			
			(invoiceStatus = CM_Invoice.INVOICE_POSTED
			or invoiceStatus = CM_Invoice.INVOICE_POSTED_CREDIT				//04 Sep 2017	NDL	TFS 6759
			or invoiceStatus = CM_Invoice.INVOICE_POSTED_REVERSE			//04 Sep 2017	NDL	TFS 6759	
			or invoiceStatus = CM_Invoice.INVOICE_PENDING_REVERSE  			//31.10.2018 cnwma1 TFS #41703
			)
			then
			
			// TFS 39618 PATCH 1 if not (self.invoiceLine.invoice.myInvoiceProcess.isLinxProcess() and invoiceStatus = CM_Invoice.INVOICE_APPROVED) then
				if app.activeForm &lt;&gt; null and app.activeForm.class.name = "INV_CashConsolidation" then	//12 Aug 2019	NDL	TFS 44261
					// special case for TFS 44261
				else
					app.setContinueCMExceptions(false);
					app.raiseCMException(ERR_CHANGE_POSTED_NOTALLOWED, null, null);
					return;
				endif;
			// TFS 39618 PATCH 1 endif;
		endif;
		self.total := _value;
	else
		if self.status = VOID then
			_value := 0;
		else
			if invoiceStatus = CM_Invoice.INVOICE_POSTED
			or invoiceStatus = CM_Invoice.INVOICE_POSTED_CREDIT		//04 Sep 2017	NDL	TFS 6759
			or invoiceStatus = CM_Invoice.INVOICE_POSTED_REVERSE	//04 Sep 2017	NDL	TFS 6759
			or invoiceStatus = CM_Invoice.INVOICE_PENDING_REVERSE  //31.10.2018 cnwma1 TFS #41703
			then
				_value := self.total;
			elseif self.invoiceLine.status = CM_InvoiceLine.STATUS_VOIDED then
				_value := 0;
			
			elseif self.isTotalSetExplicitly then 
				_value := self.total;
			else
				// CCMS 1264 Apr 2012 rate is no longer dynamic
				_value := self.rate * self.invoiceLine.quantity; // ### CCMS 1424
			endif;
			
			// 21.11.2018 cnwma1 Bug #TFS 42084
			terminal := self.getMyTerminal();

			// ### JIRA 34909 16MAY2025 NAVAB1 - no rounding leave _value as is
/*// ### JIRA 34982 28MAY2025 NAVAB1 actually always round
			//			if app.myPassport.context = Context_Pass_InvSplitMerge then	
//				blurb  := blurb &amp; " no rounding for CASH split merge";
//			else
*/
				//19.03.2020 cnwma1 TFS #50925
				if terminal &lt;&gt; null then
					roundDecimalOpt := terminal.getConfig(InvoiceRoundLineTotal).Integer;
					if roundDecimalOpt &lt;&gt; CMIF_ConfigTerminal.InvLineRound_Value_NoRound then
						_value := _value.roundedTo(roundDecimalOpt);  
						blurb  := blurb &amp; " rounded to " &amp; _value.String;
					endif;
				endif;
				//19.03.2020 cnwma1 TFS #50925
//			endif;
		endif;
	endif;
epilog
	
	if canLogExtra then						//26.02.2025 navah1	#34141
		if self.invoiceLine = null then 	// 02/11/2018 jlgzm1 TFS 47148
			blurb := method.qualifiedName &amp; " SET: " &amp; set.String &amp; " isTotalSetExplicitly: " &amp; self.isTotalSetExplicitly.String &amp; " _value: " &amp; _value.String;
		else
			blurb := method.qualifiedName &amp; " " &amp; self.invoiceLine.sequenceNum.String &amp; " SET: " &amp; set.String &amp; " isTotalSetExplicitly: " &amp; self.isTotalSetExplicitly.String &amp; " _value: " &amp; _value.String;
		endif;
		
		app.invLog(blurb, LogINFO.String);
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Real" usage="io"/>
    </JadeMethod>
    <JadeMethod name="units" id="ce00566f-7843-4a48-8e11-8f5d1480111a">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>units(set: Boolean; value: String io) mapping, updating;

vars
	chargeByUnits : Integer;
	tmpValue : String;
begin

	if set then
		if invoiceLine &lt;&gt; null and
			invoiceLine.invoice &lt;&gt; null and
			//invoiceLine.invoice.status = CM_Invoice.INVOICE_POSTED
			invoiceLine.invoice.isPostedOrReversal	//04 Sep 2017	NDL	TFS 6759	
			then
			app.setContinueCMExceptions(false);
			app.raiseCMException(ERR_CHANGE_POSTED_NOTALLOWED, null, null);
			return;
		endif;
		// this is VIRTUAL!!
		self.units := value;
	else
		if invoiceLine &lt;&gt; null and
			invoiceLine.invoice &lt;&gt; null then
			// since this is virtual, ALWAYS show from the invoice line description 
			//invoiceLine.invoice.status &lt;&gt; CM_Invoice.INVOICE_POSTED then
			chargeByUnits := invoiceLine.invoiceLineDesc.getChargeByUnits;	// 24024 CCMS 1151 Aug 2010 cnwjre1 user hook code for invoice quantity and rate
			
			tmpValue := app.getInvoiceCalcTypeLabel(chargeByUnits,true);
			if tmpValue.length &gt; 30 then
				value := tmpValue[1:30];
			else
				value := tmpValue;
			endif;
			if value = null then
				value := "Error";
			endif;
		else
			value := self.units;
		endif;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="void" id="b20ffbce-2a45-4654-a1c4-e8328d8492a7">
        <updating/>
        <source>void() updating;

begin
	if self.overridden then
		self.invoiceLine.decrementOverridenChargeCount;
	endif;

	self.status := VOID;

	// move from charges collection on invoice line to voidCharges
	if self.invoiceLine &lt;&gt; null then
		self.voidedFrominvoiceLine := self.invoiceLine;
	endif;
	self.invoiceLine := null;
	self.rate := 0.0;
end;</source>
    </JadeMethod>
</Class>
