    <JadeMethod name="doDefaults" id="d828ea0c-2f16-410f-b94b-a2eef9c34c18">
        <source>doDefaults();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06/11/2017	jlgma1	Initial creation
07/11/2019	jlgdap1	TFS 46405 AAT Flat Rack and OOG in LOLO Planning Screen
*/

vars
	drawAttr : CM_DrawingAttribute;
	objectArr : CM_ObjectArray;
	strArray : StringArray;
begin
	create strArray transient;
	
	strArray.add(PicTIInTransit);
	strArray.add(PicTIReadyToShip);
	strArray.add(PicTICustomHold);
	strArray.add(PicTIHazard);
	strArray.add(PicSpecialStow);
	strArray.add(PicTITBA);
	strArray.add(PicTIQueued);
	strArray.add(PicTIPlanned);
	strArray.add(PicTI40Footer);
	strArray.add(PicTI45Footer);
	strArray.add(PicTI30Footer);
	strArray.add(PicTI53Footer);
	strArray.add(PicTIWaterCooled);
	strArray.add(PicTIControlledAtmos);
	strArray.add(PicTIConnected);
	strArray.add(PicTIReefer);
	strArray.add(PicTICOU);
	strArray.add(PicTIEmpty);
	strArray.add(PicTIFlat);
	strArray.add(PicTICrib);
	strArray.add(PicTIFrame);	//05 Feb 2018	NDL TFS 36752
	strArray.add(PicTIOpentop);
	strArray.add(PicTIFantainer);
	strArray.add(PicTITank);
	strArray.add(PicTIHiCube);
	strArray.add(PicTI_OD_HLW);
	strArray.add(PicTI_OD_HL);
	strArray.add(PicTI_OD_HW);
	strArray.add(PicTI_OD_H);
	strArray.add(PicTI_OD_WL);
	strArray.add(PicTI_OD_L);
	strArray.add(PicTI_OD_W);
	strArray.add(PicTIBreakBulk);
	strArray.add(PicTITimber);
	strArray.add(PicTIFlatRackEndsUp);		// TFS 46405
	strArray.add(PicTIFlatRackEndsDown);	// TFS 46405
	
	create objectArr transient;
	foreach drawAttr in CM_DrawingAttribute.instances reversed do
		if  strArray.includes(drawAttr.code) then
			objectArr.add(drawAttr);
		endif;
	endforeach;
	self.multiSelectGrp.setSelected(objectArr);
epilog
	delete strArray;
	delete objectArr;
end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="a50e2a47-e7e2-4b70-963d-145d84b2fdc6">
        <source>doSave();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 November 2017	jlgma1	Initial creation

*/

vars
	selectedDrawingAttr,availableDrawingAttr : CM_ObjectArray;
	theReturn : Integer;
begin
	create selectedDrawingAttr transient;
	create availableDrawingAttr transient;
	self.multiSelectGrp.getSelected(selectedDrawingAttr);
	
	while true do
	app.myTrxUA.trxUpdateDrawingAttrPriority(selectedDrawingAttr,false ,app.myPassport);
		if app.myPassport.trxCompletedOK then
			global.beep;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Allocation),  app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;
	
		self.multiSelectGrp.getAvailable(availableDrawingAttr);
	
	while true do
		app.myTrxUA.trxUpdateDrawingAttrPriority(availableDrawingAttr,true ,app.myPassport);
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
             global.beep;
             break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Allocation),  app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;

epilog
	delete selectedDrawingAttr;
	delete availableDrawingAttr;

end;</source>
    </JadeMethod>
    <JadeMethod name="initialiseMultiSelectGrp" id="46d4069a-26e2-42e9-9dca-7679cfbb0cbb">
        <source>initialiseMultiSelectGrp();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 November 2017	jlgma1	Initial creation

*/

vars

begin
	self.multiSelectGrp.userInputEnabled 			:= true;
	self.multiSelectGrp.availableHeading := app.getErrorString(Available_attributes);
	self.multiSelectGrp.selectedHeading := app.getErrorString(Selected_attributes);
	self.multiSelectGrp.formDisplayEntryMethodName 	:= SOP_DrawingAttributesPriority::displayCriteria.name;
	self.multiSelectGrp.displayOrderBtns(true, true);
	self.multiSelectGrp.myAvailableListBox.sorted 	:= true;		
	self.multiSelectGrp.mySelectedListBox.sorted 	:= false;
	self.multiSelectGrp.setTabIndex();
	self.multiSelectGrp.displayAddRemoveBtns(true, true);		
	self.multiSelectGrp.myBaseForm := self;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateDrawingAttr" id="8080e3f9-703a-42c8-865f-b2cba8f6dd48">
        <source>populateDrawingAttr();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 November 2017	jlgma1	Initial creation

*/

vars
	drwAttr : CM_DrawingAttribute;
	object : Object;
	drwAttrArray: ObjectArray;

begin
	
	create drwAttrArray transient;
	foreach object in app.myRoot.allDrawingAttributesByTypePri discreteLock do
		

			drwAttrArray.add(object);

 
	endforeach;

	
	//self.multiSelectGrp.setAvailable(criteriaTypes, true); 
	self.multiSelectGrp.setSelected(drwAttrArray);
	
	
	self.multiSelectGrp.setFocus();
epilog
	delete drwAttrArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="populateDrawingAttributes" id="5e548527-c983-4fc5-ac90-39d888e6f88a">
        <source>populateDrawingAttributes();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 November 2017	jlgma1	Initial creation

*/

vars
	imexConfig : CM_YAIMEXConfig;
	imexStatus : CM_IMEXStatus;
	drawAttributes: ObjectArray;
	drwAtt : CM_DrawingAttribute;
begin
	
	create drawAttributes transient;
	foreach drwAtt in app.myRoot.allDrawingAttributes discreteLock where drwAtt.isDefaultCargoIcon() do		// 22/1/18 MAP TFS36749

		if drwAtt.drawingAttrType = DrawingAttrType_TrackedItem then
			drawAttributes.add(drwAtt);
		endif;
 
	endforeach;

	
	self.multiSelectGrp.setAvailable(drawAttributes, true); 
	//self.multiSelectGrp.setSelected(self.myCurrentTransactionMap.myInvoiceAllocationConfig.allOpCriteria);
	
	
	self.multiSelectGrp.setFocus();
epilog
	delete drawAttributes;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="c55fcc34-7a86-413c-94e3-64087e206d19">
        <updating/>
        <source>setupForm()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 November 2017	jlgma1	Initial creation

*/

vars
	editable: Boolean;
begin
	inheritMethod();
	initialiseMultiSelectGrp();
	populateDrawingAttributes();
	populateDrawingAttr();

	editable := app.getMyUser.canDo(app.getMyTerminalDO_NOT_USE(), PmAdmDrawAttrPriorityMaint);
	self.multiSelectGrp.enabled := editable;
	self.btnDefaults.enabled := editable;
	self.btnSave.enabled := editable;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="ebbddcfe-fdf7-4fcb-a69d-750b22ebe33a">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 24 January 2018 16:47:16.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0022178, locale);
	btnCancel.translateCaption(Xlat_0022179, locale);
	btnDefaults.translateCaption(Xlat_0022180, locale);
	btnSave.translateCaption(Xlat_0022181, locale);
	lblBlurb.translateCaption(Xlat_0022184, locale);
	multiSelectGrp.translateCaption(Xlat_0022182, locale);
end;</source>
    </JadeMethod>
</GUIClass>
