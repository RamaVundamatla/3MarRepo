17/03/2012	cnwcs5	par 29257 - conversion of extension object properties
*/
vars

begin
	return self.criteriaType = self.CriteriaType_CARGO;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
