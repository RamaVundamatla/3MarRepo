    <DbClassMap file="basehtml"/>
    <PrimAttribute name="ruleAlign" id="b24bf22b-8482-4112-bbf4-98e0129ddbea">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="ruleColor" id="52212f57-a370-4558-970a-897cfec9a639">
        <length>41</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="ruleIsNoShade" id="66403600-8754-4d18-993e-aaae2d788d52">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="ruleSize" id="c40cc22f-8af3-4237-b160-a589e3713d62">
        <embedded/>
        <type name="Integer"/>
        <text>Specifies the thickness of the line rule (in number of pixels).</text>
    </PrimAttribute>
    <PrimAttribute name="ruleWidth" id="ec9183d0-5c07-41cf-b791-883f8472a2cf">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <text>Specifies the width of the line rule as either a certain number of
pixels or a percentage of the window by appending a percentage
sign (%) to the end of the width value.</text>
    </PrimAttribute>
    <JadeMethod name="buildTagBody" id="4e40add6-db8f-4580-903c-7ff3b5d1f2d9">
        <source>buildTagBody(): String protected;
// --------------------------------------------------------------------------------
// Created:		02 December 2001 by cnwdad1
//
// Purpose:		Refer to the CnEcHtmlTagObject implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	htmlString	: String;
	
begin
	if self.ruleAlign &lt;&gt; null then
		htmlString	:=	htmlString &amp; ' ALIGN="' &amp; self.ruleAlign &amp; '"';
	endif;
	
	if self.ruleColor &lt;&gt; null then
		htmlString	:=	htmlString &amp; ' COLOR="' &amp; self.ruleColor &amp; '"';
	endif;
	
	if self.ruleIsNoShade then
		htmlString	:=	htmlString &amp; ' NOSHADE';
	endif;
	
	if self.ruleWidth &lt;&gt; null then
		htmlString	:=	htmlString &amp; ' WIDTH="' &amp; self.ruleWidth &amp; '"';
	endif;
	
	if self.ruleSize &lt;&gt; 0 then
		htmlString	:=	htmlString &amp; ' SIZE="' &amp; self.ruleSize.String &amp; '"';
	endif;
	
	htmlString	:=	htmlString &amp; inheritMethod();
	
	return htmlString;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getHtml" id="c80a0d26-f170-4fa0-9ca9-4f3827847864">
        <source>getHtml(): String;
// --------------------------------------------------------------------------------
// Created:		02 December 2001 by cnwdad1
//
// Purpose:		Refer to the CnEcHtmlTagObject implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return '&lt;HR' &amp; self.buildTagBody() &amp; '&gt;' &amp; CrLf;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isValidAlign" id="e73857a8-b820-4659-8be6-77dd43f2da8f">
        <source>isValidAlign(pAlign:String):Boolean protected;
// --------------------------------------------------------------------------------
// Created:		01 May 2000 by cnwdad2
//
// Purpose:		Validates the receiver's alignment setting.
//
// Parameters:	pAlign - The receiver's alignment setting.
//
// Returns:		True if the alignment setting is valid, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pAlign = self.ALIGN_TOP
	or pAlign = self.ALIGN_BOTTOM
	or pAlign = self.ALIGN_CENTER
	then
		return true;
	else
		CnEcBaseHtmlException.raise_(CNEC_X_22000, '"' &amp; pAlign &amp; '" is not a valid Horizontal Rule tag alignment');
	endif;

	return false;
end;</source>
        <access>protected</access>
        <Parameter name="pAlign" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setRuleAlign" id="48f497af-7b65-40b1-ac8e-d3a035312ee0">
        <updating/>
        <source>setRuleAlign(pAlign:String) updating;
// --------------------------------------------------------------------------------
// Created:		02 May 2000 by cnwdad2
//
// Purpose:		Set the reseiver's alignment setting.
//
// Parameters:	pAlign - The alignment setting.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.isValidAlign(pAlign) then
		self.ruleAlign	:=	pAlign;
	endif;
end;</source>
        <Parameter name="pAlign" type="String"/>
    </JadeMethod>
</Class>
