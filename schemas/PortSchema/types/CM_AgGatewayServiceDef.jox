    <JadeMethod name="pxyCreateUpdateProxy" id="f53ab56a-ad99-4861-b7a8-ab0b1b63aaec">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 August 2025	navra1	Initial creation for //navra1 - MTN-34782 - 15th July 2025
11 Sep 2025		navnk30 JIRA 35707: 4 - YARA | Create a new web service definition to use to send out AG Gateway messages

*/

vars
	pxyObj : SelfType;
begin
	
	pxyObj := inheritMethod();
	
	pxyObj.msgRetentionPeriod := self.msgRetentionPeriod;
	pxyObj.recordInboundEwsHistory := self.recordInboundEwsHistory;
	pxyObj.recordOutboundEwsHistory := self.recordOutboundEwsHistory;
	pxyObj.myTerminal := self.myTerminal;
	
	return pxyObj;

epilog

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
