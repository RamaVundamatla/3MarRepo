    <JadeMethod name="valVoyageVesselChange" id="7b3149fe-f8d7-4f13-804b-f57a7d0d63f2">
        <source>valVoyageVesselChange(_pxyVoyage, _realVoyage : CM_Voyage);
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
27 July 2022	navsj20	ChangeRequest 54220: EUP - INB - Change Vessel Name

*/

vars
	
begin
	self.raiseExceptionIfNull(_pxyVoyage, "Proxy Voyage");
	_pxyVoyage.raiseExceptionIfNotTransient(method);
	
	if _realVoyage.allTITransactionsByTypeDT.isNotEmpty then
		app.raiseCMException1(Voyag_cargo_trans_vesse_canno_, _realVoyage.description, null, null);
	endif;			
	if _realVoyage.isBarge= true then
		return ;
	endif;
	if _realVoyage.allOnshipTIsByIdCargoType.isNotEmpty then
		app.raiseCMException2(Voyag_onshi_items_vesse_canno_, _realVoyage.description, _realVoyage.allOnshipTIsByIdCargoType.size.String, null, null);
	endif;
	if  _realVoyage.allJobSheetsInOrder.isNotEmpty then
		app.raiseCMException1(Voyage_jobs_vessel_cannot_chan, _realVoyage.description, null, null);
	endif;				
	if _realVoyage.allOnsiteTIsByIdCargoType.size &gt; 0 or _realVoyage.allNotifiedTIsByIdCargoType.size &gt; 0 then
		app.raiseCMWarning3(Voyag_site_items_preno_items_e, _realVoyage.description, _realVoyage.allOnsiteTIsByIdCargoType.size.String, _realVoyage.allNotifiedTIsByIdCargoType.size.String,null, null, null);
	
	endif;
epilog

end;</source>
        <Parameter name="_pxyVoyage" type="CM_Voyage"/>
        <Parameter name="_realVoyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="valWLEAllocateWodTI" id="44aa8a9d-e82e-4083-893d-ab91ba5f64ac">
        <source>valWLEAllocateWodTI(_wle : CM_WorkListEntry; _woDetail : CM_WorkOrderTIDtl; _tiAllocated : CM_TrackedItem; _passport : CM_Passport input);
// -----------------------------------------------------------------------------
// Created:		28 July 2009 by consw1
//
// Purpose:		Allocate available TI from Work Order to WLE.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	jobId : String;
	
begin
	if _wle.job &lt;&gt; null then
		jobId := _wle.job.jobId;
	endif;
	
	if _wle.myTrackedItem &lt;&gt; null then
		app.raiseCMException2(ERR_WLE_HAS_TI, jobId, _wle.myTrackedItem.id, null, null);
	elseif _woDetail = null then
		app.raiseCMException1(ERR_WLE_No_WorkOrder, jobId , null, null);
	elseif not _woDetail.isKindOf(CM_WodToDo) and not _woDetail.isKindOf(CM_WodPack) and not _woDetail.isKindOf(CM_WodMove)  then
		app.raiseCMException(ERR_TransNotValidForWODtl, null, null);
	elseif _tiAllocated = null then
		app.raiseCMException(ERR_WorkOrderHasNoAvailableTIs, null, null);
	elseif not _woDetail.allAvailableTIs.includes(_tiAllocated) then
		app.raiseCMException1(ERR_WorkOrderTINoLongerAvail, _tiAllocated.id , null, null);
	endif;

epilog

end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_woDetail" type="CM_WorkOrderTIDtl"/>
        <Parameter name="_tiAllocated" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="valWLEAssignTI" id="b582afdc-6754-457d-a853-ae290dca9547">
        <source>valWLEAssignTI(_wle : CM_WorkListEntry; _ti : CM_TrackedItem; _moveControl : CMIF_MoveController input;_passport : CM_Passport input);
//-----------------------------------------
//Created: February 2003 By: cnwgd1
//-----------------------------------------
// 13/07/2023	jlizm1	TFS 58752 Overloading cargo assigned to wagon
// 24/10/2024	navpw1	JIRA MTN-12518 - Added a check to validate the vbs max weight if vas is enabled and we are dealing with a work order
//
vars
	label, jobID	: String;
	voyAllocation	: CM_VoyageAllocation;
	slotRequest		: CM_SlotRequest;	//11 Nov 2015	NDL	Par 37092
	reserveDetail	: CM_ReserveDetail;	//11 Nov 2015	NDL	Par 37092
	relreq			: CM_BulkRelease;
	
begin
	if _moveControl.mySlotRequest &lt;&gt; null then
		slotRequest := _moveControl.mySlotRequest.CM_SlotRequest;
	endif;
	if _wle = null then
		if slotRequest &lt;&gt; null then // PAR 8084 request now passed in to make error more meaningful
			label := slotRequest.mySlotController.getFullId(); // PAR 8084 
			jobID := slotRequest.myJob.jobId; // PAR 8084 
			
			self.raiseExceptionIfNull(_wle, " cargo job holder (WLE)." &amp; Cr
										&amp;"The colour coding at " &amp; label &amp; ", has no cargo job" &amp; Cr // PAR 8084 
										&amp; "holder (WLE) for " &amp; _ti.id &amp; " to be planned to." &amp; Cr
										&amp; "Please erase the colour coding for that slot," &amp; Cr
										&amp; "then re colour code and add back into job " &amp; jobID &amp; ". Then re try to plan to this " ); 
		else
			self.raiseExceptionIfNull(_wle, 'Tracked Item Job holder (Work List Entry)'); // PAR 7951 try to make this  more user meaningful
		endif;
	endif;
	
	//24 Jun 2015	NDL	Par 36507
	if slotRequest &lt;&gt; null and not slotRequest.allAllocations.isEmpty then
		voyAllocation := slotRequest.allAllocations.first.CM_VoyageAllocation;
		if voyAllocation &lt;&gt; null then
			label := slotRequest.mySlotController.getFullId();
			voyAllocation.testAgainstSlotRequest(_ti,label);
		endif;
	endif;

	//TFS 42878 jlgzm1 27/08/2019
	if _moveControl.isDirectReleaseMove and 
	   _wle.myFutureMove &lt;&gt; null and 
	   _wle.myTrackedItem &lt;&gt; null then
		app.raiseCMException1(Alread_planne_unplan_replan_ne, _wle.myTrackedItem.id, null, null);
	endif;
	
	_wle.validateForAssignTI(_ti);
	
	//20 Jul 2017	NDL	TFS 
	if _wle.isAnyAmount then
		// should only be able to load up to requested amount to rail
		if not _wle.isRail and						// 08/11/2022 jlizm1 TFS 54118
			not app.myPassport.isVASEnabled			// ### JIRA MTN-12518 22Oct2024 NAVPW1 - We want to validate if vas enabled for road
		then
			return;
		endif;
	else
	/* // ### TFS BUG 64523 07JUNE024 NAVAB1
		if _moveControl.weight &gt; 0 and _moveControl.weight &gt; _wle.weight then
			app.raiseCMException2(Move_amount_exceeds_remaining, _moveControl.getMoveAmountDisplay(true), _wle.getMoveAmountDisplay(true), null, null);
		elseif _moveControl.quantity &gt; 0 and _moveControl.quantity &gt; _wle.quantity then
			app.raiseCMException2(Move_amount_exceeds_remaining, _moveControl.getMoveAmountDisplay(true), _wle.getMoveAmountDisplay(true), null, null);
		endif;
		*/
	endif;
	
	//11 Nov 2015	NDL	Par 37092
	//jlier1 TFS 54150 26/7/22
	reserveDetail := _wle.myRequest.myReserveDetail;
	
	// ### TFS BUG 64523 07JUNE024 NAVAB1 - this additional validation was added as part of a EUP rail release development
	if reserveDetail &lt;&gt; null then
		relreq := reserveDetail.myReserveHeader;
	endif;
	
	if relreq &lt;&gt; null
	and relreq.isRailType
	and relreq.context = RelReqContext_CargoGroupReview
	and not _wle.isAnyAmount 
	and not _wle.isReceipt then // release 
		if _moveControl.weight &gt; 0 and _moveControl.weight &gt; _wle.weight then
			app.raiseCMException2(Move_amount_exceeds_remaining, _moveControl.getMoveAmountDisplay(true), _wle.getMoveAmountDisplay(true), null, null);
		elseif _moveControl.quantity &gt; 0 and _moveControl.quantity &gt; _wle.quantity then
			app.raiseCMException2(Move_amount_exceeds_remaining, _moveControl.getMoveAmountDisplay(true), _wle.getMoveAmountDisplay(true), null, null);
		endif;
	endif;

	if reserveDetail &lt;&gt; null and _ti &lt;&gt; null and _ti.myCargoType.allowDuplicates then
		if _moveControl.weight &gt; 0 or _moveControl.quantity &gt; 0 then
			reserveDetail.validateWeightAndQuantity(_moveControl);
		endif;
	endif;
	
	// ### JIRA MTN-12518 22Oct2024 NAVPW1
	if app.myPassport.isVASEnabled and _wle.job.getWorkOrder() &lt;&gt; null then // We only want this for the vas subscription and if this is fro a work order
		_wle.validateVbsMaxWeight(reserveDetail, _moveControl.weight);
	endif;
	// ### JIRA MTN-12518 22Oct2024 NAVPW1
	
end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_moveControl" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
