<Class name="CM_InterStorageTransport" id="94861a1d-0261-4106-9ea9-4b523025f0dd">
    <superclass name="CM_TITransaction"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="invoice"/>
    <PrimAttribute name="receivingCompanyCode" id="40f2d511-5685-4bc4-9755-26605fd6efe0">
        <length>5</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="releasingCompanyCode" id="403ce16f-3ce7-43e5-9306-9c0f142cc600">
        <length>5</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="userRequestNo" id="285ad796-6117-4e39-a547-743c70d62d74">
        <length>11</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="getDisplayStringForAttribute" id="4fabda22-f598-41ed-8bd4-b4b370330705">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 June 2010	cnwndl1	Initial creation	Par 23498

*/

vars
	lDetail : String;
begin

	if _attrName = ETRow_Details  then
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
			
		else
			lDetail := "IST User Request No: " &amp; self.userRequestNo.trimBlanks;

			lDetail := lDetail &amp; " " &amp; self.urNumber.String;			
			
			return lDetail;
			
		endif;
							
	else
		return inheritMethod(_attrName, _short);
	
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEnquiryRow" id="595f3918-3ad8-41aa-a79a-19b6488cf9d8">
        <source>getEnquiryRow(): String;
// ---------------------------------------------------------------------------
// Created:  May  2001 By Andrew Bishop cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lDetail : String;
begin
	lDetail := inheritMethod();
	lDetail := lDetail &amp; "IST User Request No: " &amp; self.userRequestNo.trimBlanks;

	if lDetail &lt;&gt; "" then
		lDetail := lDetail &amp; " " &amp; self.urNumber.String;
	else
		lDetail := self.urNumber.String;
	endif;			
	
	return lDetail;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
