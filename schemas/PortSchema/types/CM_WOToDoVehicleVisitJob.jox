    <JadeMethod name="setForCreateInternal" id="078b5519-631f-482f-a12b-0e830db7cd5c">
        <updating/>
        <source>setForCreateInternal(_cmifJobParam : CMIF_WorkOrderJobParams;_terminal : CM_Terminal) updating;

/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
28 Sep 2022	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs
17 Mar 2023	navcs2	ChangeRequest 56842:[56843]: EUP - VAS Task Priority
02 Jun 2023 navma1  ChangeRequest 58296: EUP - [Framework] Delivery Dispatch Screen - Linking Road Jobs
*/


vars
	req : CM_WOVehicleVisitToDoRequest;
begin

	inheritMethod(_cmifJobParam, _terminal);													//02.06.2023 navma1 #58296
	
	self.myWorkOrderDtlToDo.CM_WodToDoVehicleVisit.allVehicleVisits.copy(self.allVehicleVisits);
	
	//---------------
	//Build a Request
	//---------------
	
	create req;	
	req.setForCreateInternal(self, _cmifJobParam);
	//---------------
	//Build the WLEs' from the request.
	//---------------
	self.createWLEs();
end;</source>
        <Parameter name="_cmifJobParam" type="CMIF_WorkOrderJobParams"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
</Class>
