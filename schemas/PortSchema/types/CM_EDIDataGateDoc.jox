    <JadeMethod name="loadDB" id="d913bdc4-f9c4-45dc-a702-9795cf612e58">
        <updating/>
        <source>loadDB(_mergeCargo: Boolean; _passport: CM_Passport input) updating;
//
// par21718 cnwrs1 Nov 2009
//02 Jul 2012	cnwrs1		Par 29927 EDI Booking Item replace not working
// 07 Nov 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
// 08 Dec 2017	jlgrs1	TFS 8281 - SNO - EDI New Coaprn Issues
// 09 Feb 2018	jlgrs1	TFS 36951 JMT Prenote Partial for GateDoc
// 30 Aug 2023	navdap1	TFS 60150 EUP | FR 53824 - Road Manifest IMPORT cargo
//
vars
	errorSet : CM_ErrorSet;
	allMatchedBRItems : CM_BookingRefItemDict;
	cmifEDIBooking : CMIF_EDIBooking;
	cmifEDIPrenote : CMIF_EDIPrenote;
	cmifEDIRequestMultiLine : CMIF_EDIRequestMultiLine;
	tmpStatus : Integer;
begin
	on Exception do validationExceptionHandler(exception, _passport);
	create errorSet transient;
	create cmifEDIBooking transient;
	create allMatchedBRItems transient;
	
	if self.myTransportManifest = null then	//27.Jun.2023 navsp1 TFS 57805 - Booking not required to process EUP manifest file
		cmifEDIBooking.status := self.status;
		cmifEDIBooking.myOperator := self.myOperator;
		cmifEDIBooking.processEDITIs(self.allEDITrackedItems, false, _passport, allMatchedBRItems); //cnwrs1 par 26223 10 nov 2010
	endif;
	
	_passport.moveErrorsToSet(errorSet);
	create cmifEDIPrenote transient;
	if cmifEDIPrenote.isExportPrenotes(self) or self.myTransportManifest &lt;&gt; null then	// TFS 60150 Euroports may send Import prenotes
		cmifEDIPrenote.loadOrVerifyForDBPartial(self.allEDITrackedItems, _passport, false);
	else
		cmifEDIPrenote.updateImportCargo(self, _passport);
	endif;
	_passport.moveErrorsToSet(errorSet);
	create cmifEDIRequestMultiLine transient;
	
	if self.myTransportManifest = null then	//27.Jun.2023 navsp1 TFS 57805 - Not required to process EUP manifest file.
		self.allEDITrackedItems.copy(cmifEDIRequestMultiLine.allEDITrackedItems);
		self.ediFileArray.copy(cmifEDIRequestMultiLine.ediFileArray);
		cmifEDIRequestMultiLine.loadOrVerifyForDB(_passport, false);
	endif;
	
	_passport.addErrorsFromSet(errorSet);
	tmpStatus := self.getStatusFromEDITrackedItems(false);
	
	if tmpStatus &lt;&gt; 0 then
		app.myTrxUA.trxSetEDIDataStatusAfterVerify(self, tmpStatus);	// par 27392 cnwrs1 14 Apr 2011
	endif;
epilog
	delete allMatchedBRItems;
	delete cmifEDIBooking;
	delete cmifEDIPrenote;
	delete cmifEDIRequestMultiLine;
	delete errorSet;
end;
</source>
        <Parameter name="_mergeCargo" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="2f1c8b80-c6e0-4f11-86d0-5791230adfab">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
//
// 11 Aug 2016	cnwrs1	Par 38117 make deleted EDI for finable
//
vars
	propName : String;
begin
	if _property = null then
		return false;
	endif;
	propName := _property.name;
	if propName = CM_EDIDataGateDoc::currentBookingCode.name or
	   propName = CM_EDIDataGateDoc::currentBookingItemCode.name then
		return false;
	endif;
	return inheritMethod(_rootClass, _property);
end;
</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
