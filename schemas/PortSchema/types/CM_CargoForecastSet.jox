    <JadeMethod name="loadCommoditiesIsEmpty" id="a9c6286b-2323-422a-b4e5-a05771388ab3">
        <source>loadCommoditiesIsEmpty() : Boolean;
/*

Purpose:			Returns whether the collection contains load commodities or not

Parameters:			NONE

Return Value:		A boolean representing whether load commodities exists in cargo forecasts collection

Date		Who		Reason
21 April 2022	navpw1	Initial creation TFS: 53132

*/

vars
	cargoForecast			: CM_CargoForecast;
	loadCommodityIsEmpty	: Boolean;
	
begin
	loadCommodityIsEmpty := true; //By Default we want to say its empty. This is to aid in avoiding confusion with inversed booleans
	
	if self.size &lt; 1 then
		return loadCommodityIsEmpty;
	endif;
	
	foreach cargoForecast in self where cargoForecast.mode = CM_CargoForecast.Mode_Load do
		if cargoForecast.myCommodity = null then
			continue;
			
		else
			loadCommodityIsEmpty := false;
			break;
			
		endif;
		
	endforeach;
	
	return loadCommodityIsEmpty;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</CollClass>
