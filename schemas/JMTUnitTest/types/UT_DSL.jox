    <JadeMethod name="createThumbnailContent" id="8b1474cd-2da8-4614-b600-4d4773b9659f">
        <source>createThumbnailContent(_originalPhoto:Binary):Binary;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
