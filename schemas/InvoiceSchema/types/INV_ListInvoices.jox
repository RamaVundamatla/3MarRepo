    <JadeMethod name="doBtnStatusPostedClick" id="50bc9be9-27d8-4fba-af64-5eb440919c88">
        <updating/>
        <source>doBtnStatusPostedClick() updating;
/*
Purpose:	TFS 39618		 861.010
Date				Who			Reason
JANUARY 2019		CNWAB1		Initial creation
22 July 2019	    cnwma1		ChangeRequest 45577: ASPA - JMT Interface to AR Oracle
14/08/2023			navkc1		Bug 59803: FR | EUP 53978 - Invoicing - Configuration Enhancements - Invoice Update - missing items
12 Feb 2024			navra1		CR 61910/Task 62303 - EUP | API Create default package to run on invoice updating status to POSTED
21 Oct 2024			navlw1		Bug MTN-33151: QTS - 1090 issue with the form being null when we do not have the correct permissions
*/

vars
	finIOClass		: CM_ExtFinanceIO;
	form			: INV_InvoiceUpdateStatus;
	invoice			: CM_Invoice;
	hasInvoice,
	hasCreditNote	: Boolean;
	
begin
	
	
	//22.07.2019 cnwma1 TFS #45577
	finIOClass := self.myTerminal.getConfig(FinancialIOClass).CM_ExtFinanceIO;
	
	if finIOClass &lt;&gt; null and finIOClass.isKindOf( CM_ASPAInterface ) then
		self.showInvoicePropFrame(ETView_InvListInvPropPostASPA);
	else
		//14/08/2023	navkc1	Bug 59803
		if self.isMTNDefaultProcess or self.isInvoiceAPIProcess then			//navra1 - CR 61910/Task 62303 - 12th Feb 2024
			//14/08/2023	navkc1	Bug 59803
			foreach invoice in self.tblData.allSelectedObjects as CM_Invoice do
				if invoice.isCreditNote() then
					hasCreditNote := true;
				else
					hasInvoice := true;
				endif;
				
				if hasCreditNote and hasInvoice then
					app.msgBox(app.getErrorString(SelectOneTypeInvCategory), app.getErrorString(Information), MsgBox_OK_Only);
					return;
				endif;
			endforeach;
			
			form := app.loadForm(INV_InvoiceUpdateStatus, INV_Assistant, false, false, false, self.myTerminal, null).INV_InvoiceUpdateStatus;
			// Start navlw1 #MTN-33151
			if form = null then 
				return;
			endif;
			// End navlw1 #MTN-33151
				
			form.setMyCurrentBank(self.myCurrentBank);
			form.setCurrentInvoice(self.myCurrentInvoice);
			form.setMyTerminal(self.myTerminal);
			self.tblData.allSelectedObjects.copy(form.allInvoices);
			form.newStatus := CM_Invoice.INVOICE_POSTED;
			form.myParentForm := self;
			form.showModal();
		else
			self.showInvoicePropFrame(ETView_InvListInvPropPost);
		endif;
	endif;

epilog

end;</source>
    </JadeMethod>
