    <JadeMethod name="siteStringToEnum" id="e3fb8b73-593b-488d-9ce6-12802c19ea77">
        <source>siteStringToEnum(_value : String) : Integer;
// ---------------------------------------------------------------------------
// Created:     04 May 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpVal	: String;
	
begin

	tmpVal := _value.toUpper;
	
	if tmpVal = TI_SITE_ONSITE_str.toUpper() then
		return TI_SITE_ONSITE;
	elseif tmpVal = TI_SITE_ONSHIP_str.toUpper() then
		return TI_SITE_ONSHIP;
	elseif tmpVal = TI_SITE_OFFSITE_str.toUpper() then
		return TI_SITE_OFFSITE;
	elseif tmpVal = TI_SITE_TBA_str.toUpper() then
		return TI_SITE_TBA;
	elseif tmpVal = SEL_QUERYSITE_NOTIFIED_STR.toUpper() then	//15 Jun 2015	NDL	Par 36347
		return SEL_QUERYSITE_NOTIFIED;
	elseif tmpVal = TI_SITE_CARGOGROUP_str.toUpper() then	//27 May 2015	NDL	Par 36338
		return TI_SITE_CARGOGROUP;
	elseif tmpVal = TI_SITE_PLACEHOLDER_str.toUpper then	//13 Mar 2020	NDL	TFS 47004
		return TI_SITE_PLACEHOLDER;
	else
		return TI_SITE_UNDEFINED;
	endif;
	
end;</source>
        <Parameter name="_value" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="sortTidalClasses" id="49c7bb86-7eb4-4fde-a83e-036b4c78b5bb">
        <source>sortTidalClasses(_oa : ObjectArray input);
// 34489 CCMS 1327 Tidal Class calculation type, sort tidal classes by description for the rate costPerUnit array
vars
	dynaDict	: DynaDictionary;
	obj			: Object;
	tidalClass	: HMS_TidalClass;
begin
	create dynaDict transient;
	dynaDict.setMembership(HMS_TidalClass);
	dynaDict.addMemberKey(HMS_TidalClass::description.name, false, true);
	dynaDict.endKeys(true);

	foreach tidalClass in self.myRoot.allTidalClasses where not tidalClass.isNotAvailableForEntry do
		dynaDict.add(tidalClass);
	endforeach;

	_oa.clear();
	foreach obj in dynaDict do
		_oa.add(obj);
	endforeach;

epilog
	delete dynaDict;
end;
</source>
        <Parameter name="_oa" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="sourceTisForRequestBestPick" id="a46157be-c0d9-458e-a46d-8c4b9676c0d0">
        <updating/>
        <source>sourceTisForRequestBestPick(_terminal : CM_Terminal; _wle : CM_WorkListEntry; _terminalArea : CM_TerminalArea; _scanTerminal : Boolean;_allLogging : StringArray input) : CM_TrackedItem updating;
// -------------------------------------------
// Created 19/02/2010	cnwjre1	CCMS 1101
//  May 2010 PAR23848 changed second param to wle 
// -------------------------------------------
// 30 Sep 2025 jlier1 MTN-35633
vars

	agent	: CM_YAAutoplanAgent;
	cmifRequest		: CMIF_YARequest;
	ti		: CM_TrackedItem;
	bol: CM_BOLIn;
begin

	if not self.checkYardAllocationLicensing(_terminal) then
	 	return null;
	endif;

	// app.myYAAgent is used in the calculation of the number of overstowed tracked items which
	//  overwrites it, so use a new agent here
	create agent transient;
	agent.initialiseForBestPick(_terminal);	//03 Mar 2011	NDL	Par 26917
	create cmifRequest transient;
	agent.setCurrentYAAutoPlan(cmifRequest);
	
	// 23848 best-pick in delivery request items
	if _wle.myRequest.isKindOf(CM_DeliveryRequest) and
	   _wle.myRequest.myOriginatingBulkRelease &lt;&gt; null and
	   not _wle.myRequest.myOriginatingBulkRelease.releaseByType and   // PAR 26671
	   _wle.myRequest.myOriginatingBulkRelease.allTrackedItemsAssigned.size &gt; 0 then
		ti := agent.bestPickReleaseTIs(_wle.myRequest.CM_DeliveryRequest);
	else
		bol := _wle.myRequest.getBOL;   // PAR 26671
		if bol &lt;&gt; null then
			//agent.initialiseForBestPickBOL(_terminal);	//03 Feb 2011	NDL	Par 26863
			ti := agent.getRequestBestPickBOL( bol, _terminalArea, _wle.myRequest);
		else
			ti := agent.getRequestBestPickTI( _terminal, _wle.myRequest, _terminalArea, _scanTerminal);
		endif;
	endif;
	
	if _allLogging &lt;&gt; null and agent.myCurrentCMIFYAAutoPlan &lt;&gt; null then
		agent.myCurrentCMIFYAAutoPlan.allVerboseLogging.copy(_allLogging);
	endif;
	
	return ti;
epilog
	delete agent;
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_terminalArea" type="CM_TerminalArea"/>
        <Parameter name="_scanTerminal" type="Boolean"/>
        <Parameter name="_allLogging" type="StringArray" usage="input"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="sourceTisForRequestYA" id="83b4f81a-b475-4ba9-908e-2af9689b6e1f">
        <updating/>
        <source>sourceTisForRequestYA(_terminal : CM_Terminal; _request : CM_Request) : CM_LocationsController updating;
// -------------------------------------------
// Created 02 June 2005 by cnwdvb1
// -------------------------------------------
vars
	lc: CM_LocationsController;
	agent: CM_YAAutoplanAgent;
begin

	if not self.checkYardAllocationLicensing(_terminal) then
	 	return null;
	endif;

	agent := self.myYAAgent;
	
	if agent.sourceTisForRequestYA(_terminal, _request) then
		lc := app.myYAAgent.getFoundLocation();
	endif;
	
	return lc;
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_request" type="CM_Request"/>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="startChangeTracker" id="281f8767-e490-4f91-a7ce-f48d3dfe216c">
        <source>startChangeTracker();
/*

Date		Who		Reason
01 Dec 2015	cnwkpd1	PAR #37256 - Application can appear to hang if there is a missing journal
06 Apr 2016	cnwkpd1	Tracker 588549 - PNL test deploy failed because the delete of expired Change Tracker 
					objects took longer than the 5 minute timeout.  Increased timeout to 10 minutes.

*/

constants
	MaxWaitTime		= 600000;		// 10 minutes
	
vars
	myDba : JadeDatabaseAdmin;
	userExitCode: Integer;
	schema : Schema;
	clss : Class;
	obj : Object;
	currentJournal : Integer;
	ctLastAuditFileNumber : Integer;
	previousAuditFileNumber : Integer;
	lastAuditFileChangeTime : Decimal[20];
	
begin
	userExitCode := 63;
	app.initialize;
	if BGP_ChangeTrackerController.instances.size &gt; 0 then
		schema := rootSchema.getSchema("JSSChangeTrackingSchema");
		if schema &lt;&gt; null then
			clss := schema.getClass("JSSCTNibblerManager");
			if clss &lt;&gt; null then
				obj := clss.firstInstance;
				if obj &lt;&gt; null then
//					beginTransaction;
//					obj.setPropertyValue("debug", false);
//					commitTransaction;
					ctLastAuditFileNumber := obj.getPropertyValue("lastAuditFileNumber").Integer;
					create myDba transient;
					myDba.closeCurrentJournal;
					currentJournal := myDba.getCurrentJournalNumber;
					app.writeLog('Start Change Tracker ctLastAuditFileNumber='&amp;ctLastAuditFileNumber.String&amp;' currentJournal='&amp;currentJournal.String,0);
					myDba.closeCurrentJournal;
					create app.myChangeTrackingInterface transient;
					app.myChangeTrackingInterface.initializeChangeTracker;
					
					lastAuditFileChangeTime := app.relativeMachineTime();		// PAR #37256
					
					while true do
						process.sleep(5000);
						obj := clss.firstInstance;
						ctLastAuditFileNumber := obj.getPropertyValue("lastAuditFileNumber").Integer;
						//currentJournal := myDba.getCurrentJournalNumber;
						app.writeLog('Checking Change Tracker ctLastAuditFileNumber='&amp;ctLastAuditFileNumber.String&amp;' currentJournal='&amp;currentJournal.String,0);
						if ctLastAuditFileNumber &gt;= currentJournal then
							break;
						endif;
						
						// PAR #37256 - Keep track of the machine time when the last update to the lastAuditFileNumber occurred
						if ctLastAuditFileNumber &lt;&gt; previousAuditFileNumber then
							previousAuditFileNumber := ctLastAuditFileNumber;
							lastAuditFileChangeTime := app.relativeMachineTime();
						endif;
						
						// PAR #37256 - If it's been more than the maximum wait time since the last journal was successfully processed,
						// then exit with an error
						if (app.relativeMachineTime() - lastAuditFileChangeTime) &gt; MaxWaitTime then
							app.writeLog('Checking Change Tracker maximum wait time ' &amp; (MaxWaitTime div 1000).String &amp; ' seconds exceeded, exiting',0);
							userExitCode := 63;
							app.myChangeTrackingInterface.finalizeChangeTracker;
							return;
						endif;
							
					endwhile;
					app.myChangeTrackingInterface.finalizeChangeTracker;
				endif;
			endif;
		endif;
	endif;
	userExitCode := 0;	

epilog
	delete myDba;
	beginTransaction;
	node.userExitCode := userExitCode;
	commitTransaction;
	app.finalize;
	terminate;

end;

</source>
    </JadeMethod>
    <JadeMethod name="startOdbcSession" id="78d8f85d-d850-4676-8e57-8f8853002d0a">
        <source>startOdbcSession(rv: RelationalView; username: String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Nov 2012	cnwkpd1	PAR #30668 - CCMS APM 2208 - ODBC access to HMS

*/

vars
	user 	: CM_User;

begin
	app.writeLog(method.qualifiedName() &amp; " relational view = " &amp; rv.name &amp; " username = " &amp; username, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053

	// check user can access the requested relational view
	user := app.myRoot.allUsers[username.toUpper];
	if user = null then
		// BAD
		app.writeLog(method.qualifiedName() &amp; " invalid username = " &amp; username, LogERROR);	//25 Nov 2019	NDL	TFS 47053
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, "invalid username", null, null);
		return;
	endif;
	
	if not self.canUserAccessRelationalView(rv, user) then
		app.writeLog(method.qualifiedName &amp; " user " &amp; username &amp; " cannot access relational view " &amp; rv.name, LogERROR);	//25 Nov 2019	NDL	TFS 47053
		app.raiseCMException3(ERR_USER_NO_ACCESS, username.toUpper, "ODBC Relational View", rv.name, null, null);
		return;
	endif;
	
epilog

end;</source>
        <Parameter name="rv" type="RelationalView"/>
        <Parameter name="username" type="String"/>
    </JadeMethod>
    <JadeMethod name="stateEnumToString" id="f37c9bcf-05d7-4cac-9841-bec2db4c8dac">
        <source>stateEnumToString(state : Integer) : String;
// ---------------------------------------------------------------------------
// Created:     04 May 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	stateStr : String;

begin

	if state = TI_STATE_UNDEFINED then
		stateStr := "Undefined";
	elseif state = TI_STATE_ARCHIVED then
		stateStr := "Archived";
	elseif state = TI_STATE_NORMAL then
//		stateStr := "On Site"; // PAR 1085
		stateStr := "Normal";
	elseif state = TI_STATE_GHOST then
		stateStr := "Ghost";
	elseif state = TI_STATE_NOTIFIED then
		stateStr := "Prenotified";
	elseif state = TI_STATE_OFFLOADED then
		stateStr := "Offloaded";
	elseif state = TI_STATE_OFFSITE then
		stateStr := "Off Site";
	elseif state = TI_STATE_ONSHIP then
		stateStr := "On ship";
	elseif state = TI_STATE_DELETED then
		stateStr := "Deleted";
	elseif state = TI_STATE_EDI then
		stateStr := "EDI";
	elseif state = TI_STATE_TBA then
		stateStr := "TBA";
	elseif state = TI_STATE_PLACEHOLDER then	//13 Mar 2020	NDL	TFS 47004
		stateStr := "Placeholder";
	//epr TFS 47132 19/12/19
	elseif state = TI_STATE_TRANSFER_FROM then
		stateStr := "Inter Terminal Transfer In Coming";
	elseif state = TI_STATE_TRANSFER_TO then
		stateStr := "Inter Terminal Transfer Out Going";
	else
		stateStr := "Unknown";
	endif;
	return stateStr;
	
end;</source>
        <Parameter name="state" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="stateEnumToStringObject" id="265c9246-8bb0-4206-9e85-6a29bcd7b4e5">
        <source>stateEnumToStringObject(_value : Integer) : CM_String;
//----------------------------------------------------------------
//	Created:	29 October 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	cmString	: CM_String;
begin
	//must be cleaned up else where - maybe use _tbl.purgeTableObjects() if going into a table
	
	create cmString transient;
	cmString.string := self.stateEnumToString(_value);
	return cmString;
	
end;</source>
        <Parameter name="_value" type="Integer"/>
        <ReturnType type="CM_String"/>
    </JadeMethod>
    <JadeMethod name="stateStringToEnum" id="8c0f76be-b46a-4f55-8f46-27d9e6d1e290">
        <source>stateStringToEnum(_str : String) : Integer;
// ---------------------------------------------------------------------------
// Created:     06 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	state : Integer;
	tmpVal	: String;

begin

	tmpVal := _str.toUpper();

	if tmpVal = "Undefined".toUpper() then
		state := TI_STATE_UNDEFINED;
		
	elseif tmpVal = "Archived".toUpper() then
		state := TI_STATE_ARCHIVED;
	
	elseif tmpVal = "Normal".toUpper() then
		state := TI_STATE_NORMAL;
		
	elseif tmpVal = "Ghost".toUpper() then
		state := TI_STATE_GHOST;
		
	elseif tmpVal = "Prenotified".toUpper() then
		state := TI_STATE_NOTIFIED;

	elseif tmpVal = "Offloaded".toUpper() then
		state := TI_STATE_OFFLOADED;
		
	elseif tmpVal = "Off Site".toUpper() then
		state := TI_STATE_OFFSITE;
		
	elseif tmpVal = "On ship".toUpper() then
		state := TI_STATE_ONSHIP;
		
	elseif tmpVal = "Deleted".toUpper() then
		state := TI_STATE_DELETED;
		
	elseif tmpVal = "EDI".toUpper() then
		state := TI_STATE_EDI;
		
	elseif tmpVal = "TBA".toUpper() then
		state := TI_STATE_TBA;
		
	elseif tmpVal = "Placeholder".toUpper then	//13 Mar 2020	NDL	TFS 47004
		state := TI_STATE_PLACEHOLDER;
		
	//epr TFS 47132 19/12/19
	elseif tmpVal = "Inter Terminal Transfer In Coming".toUpper()  then
		state := TI_STATE_TRANSFER_FROM;
	elseif tmpVal = "Inter Terminal Transfer Out Going".toUpper()  then
		state := TI_STATE_TRANSFER_TO;	
	else
		state := null;
	endif;
	
	return state;
	
end;</source>
        <Parameter name="_str" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="stateToSite" id="11a6afb6-fabc-424b-89f3-197ef7210d4a">
        <source>stateToSite( newState : Integer ) : Integer;
// ---------------------------------------------------------------------------
// Created:     28 February 2001 by cnwdwq1
// Purpose: 
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if newState = TI_STATE_UNDEFINED
	or newState = TI_STATE_GHOST
	or newState = TI_STATE_NOTIFIED
	or newState = TI_STATE_DELETED
	or newState = TI_STATE_EDI
	or newState = TI_STATE_ARCHIVED
	or newState = TI_STATE_OFFLOADED
	then
		return TI_SITE_UNDEFINED;
		
// PAR 33695	elseif newState = TI_STATE_TBA
// PAR 33695	or newState = TI_STATE_NORMAL	then
	elseif newState = TI_STATE_TBA then // PAR 33695
		return TI_SITE_TBA; // PAR 33695
		
	elseif newState = TI_STATE_PLACEHOLDER then //13 Mar 2020	NDL	TFS 47004
		return TI_SITE_PLACEHOLDER;
		
	elseif newState = TI_STATE_NORMAL	then // PAR 33695
		return TI_SITE_ONSITE;
      
	elseif newState = TI_STATE_OFFSITE then
		return TI_SITE_OFFSITE;

	elseif newState = TI_STATE_ONSHIP then
		return TI_SITE_ONSHIP;
	else
		return TI_SITE_UNDEFINED;
	endif;
end;</source>
        <Parameter name="newState" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
