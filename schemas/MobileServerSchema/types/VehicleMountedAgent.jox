    <JadeMethod name="getMoveDetails" id="7746f1f1-d58e-44b3-8e42-e1bb1c5b4b81">
        <updating/>
        <source>getMoveDetails(	_type,
				_containerId,
				_fromLoc,
				_toLoc : String io;
				_isOverstow, 
				_canEditToLoc,
				_toLocIsVehicle: Boolean io;
				_errorMsgs : DTO_HandHeldGateErrorDict input ) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
31 October 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	task,relatedTask,
	pickup,setdown: CM_RTQueueTask;
	entry :CM_RTQueueEntry;
	vehicleId : String;
	job : CM_Job;
	wle : CM_WorkListEntry;
	load,
	hasIMV: Boolean;
begin
	task:=self.getCurrentTask();
	entry:=task.myEntry;
	if task = null then
		self.addError(UNEXPECTED_PROGRAM_ERROR,app.getErrorString3(UNEXPECTED_PROGRAM_ERROR,self.class.name,method.name,"This machine does not have a rt task assigned"),_errorMsgs);
		return;
	endif;
	
	_canEditToLoc:=true;
	//don't use isOverstowTask - i don't know where that comes from
	_isOverstow:=self.isCurrentTaskTIOverstowed();
	
	if _isOverstow then
		_canEditToLoc:=true;
		_toLoc:=null;
			
		self.getNextOverstowTI(_containerId,_fromLoc, _errorMsgs);
		return;
	else 
		_containerId:=task.tiId;
		_type := self.getTaskTypeForQueueEntry(entry);
		if _type = null then
			self.addError(UNEXPECTED_PROGRAM_ERROR,app.getErrorString3(UNEXPECTED_PROGRAM_ERROR,self.class.name,method.name,"Can not determine task type"),_errorMsgs);
			return;
		endif;
		job := task.myEntry.myJob;
		wle := task.myEntry.myWorkListEntry;
		if job.isKindOf(CM_RoadJob) then
			vehicleId:=job.CM_RoadJob.myVehicle.regNumber;
		endif;
		self.getInternalMoveDetails(_fromLoc,_toLoc,_canEditToLoc,_toLocIsVehicle,_errorMsgs);
		if _type = TypeOut then
			//_fromLoc:=wle.getLocationIdForMode(REAL_MODE); 
			_toLoc := vehicleId;
			_toLocIsVehicle:=true;
		elseif _type = TypeIn then
			_canEditToLoc:=true;
			_fromLoc:=vehicleId;
			//_toLoc:=wle.getLocationIdForMode(QUEUE_MODE);
		else
			
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="_type" type="String" usage="io"/>
        <Parameter name="_containerId" type="String" usage="io"/>
        <Parameter name="_fromLoc" type="String" usage="io"/>
        <Parameter name="_toLoc" type="String" usage="io"/>
        <Parameter name="_isOverstow" type="Boolean" usage="io"/>
        <Parameter name="_canEditToLoc" type="Boolean" usage="io"/>
        <Parameter name="_toLocIsVehicle" type="Boolean" usage="io"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getMoveLocationAndIMV" id="c0214458-8e69-4495-b896-2bdd76585b8f">
        <updating/>
        <source>getMoveLocationAndIMV(toLocation : CM_LocationsController io; _imvMachine : CM_Machine output) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
17 June 2010	cnwer1	Initial creation
*/

vars

begin

	//if it was automatically done via rtg telegrams the location could be rtg lane controller in this case if the target location is a vechicle or imv 
	// we'll use that location - if there was a way when the trucks rfid tag was swiped to now where the rtg machine was in relationship to the rtg lane controller (i.e. bay)
	// i could set the vehicles current location there and then get it from CM_RTGLaneController.allVehicleMachines but there isn't at the moment
	if toLocation.isKindOf(CM_RTGLaneController) then
		if self.getMyWorkedVehicleMachine &lt;&gt; null then
			toLocation:=self.getMyWorkedVehicleMachine.getMyVehicleMachineController;
		endif;
	endif;
	
	// epr par 20700 21/9/09
	if toLocation.isKindOf(CM_MachineController) then
		_imvMachine:=toLocation.CM_MachineController.myMachine;
		//epr par 21459 29/10/09 for chassis demo enhancements 
		if toLocation.allTrackedItems.size = 1 and toLocation.allTrackedItems.first.isKindOf(CM_TILC) then
			toLocation:=toLocation.allTrackedItems.first.CM_TILC.allLCs.first;
		endif;
	else
		self.getRelatedTask();
		
		if self.myRelatedTask &lt;&gt; null then
			_imvMachine:=self.myRelatedTask.machine;		
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="toLocation" type="CM_LocationsController" usage="io"/>
        <Parameter name="_imvMachine" type="CM_Machine" usage="output"/>
    </JadeMethod>
