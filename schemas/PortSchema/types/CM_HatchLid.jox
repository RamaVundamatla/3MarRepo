    </JadeMethod>
    <JadeMethod name="validateMe" id="9691714b-dd86-4df3-8722-eb05605090a0">
        <source>validateMe() protected;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	realBay,
	bay : CM_Bay;
	hatchLid : CM_HatchLid;
begin
	bay := self.allBays.first;
	
	if self.ordinalStartBay = null and bay &lt;&gt; null then
		//app.raiseCMException1(REQUIRED_FIELD, 'Hatch Lid Start Bay', null, null);
		app.raiseCMException2(Hatch_Needs_Ord_Start, bay.allHatchLids.indexOf(self).String,bay.id, null, null);
	endif;
	if self.ordinalEndBay = null then
		//app.raiseCMException1(REQUIRED_FIELD, 'Hatch Lid End Bay', null, null);
		app.raiseCMException2(Hatch_Needs_Ord_End, bay.allHatchLids.indexOf(self).String,bay.id, null, null);
	endif;
	
	if self.ordinalUDStartCell = null then
		//app.raiseCMException1(REQUIRED_FIELD, 'Under deck start cell position', null, null);
		app.raiseCMException2(Hatch_Needs_UD_Start_CellOrd, bay.allHatchLids.indexOf(self).String,bay.id, null, null);
	endif;
	if self.ordinalUDEndCell = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'Under deck end cell position', null, null);
		app.raiseCMException2(Hatch_Needs_UD_End_CellOrd, bay.allHatchLids.indexOf(self).String,bay.id, null, null);
	endif;
	
	//epr par 35454 23/12/14
	realBay:=bay.pxyGetRealObject.CM_Bay;
	if realBay &lt;&gt; null then
		foreach hatchLid in realBay.allHatchLids do
			if hatchLid = self.pxyGetRealObject then
				continue;
			endif;
			if hatchLid.ordinalUDStartCell = self.ordinalUDStartCell and hatchLid.ordinalUDEndCell = self.ordinalUDEndCell then
				//write method.name;
				app.raiseCMException2(Hatch_already_exists,realBay.id,realBay.allCellsUnderDeckByOrdinal[ self.ordinalUDStartCell].id &amp; " - " &amp; realBay.allCellsUnderDeckByOrdinal[self.ordinalUDEndCell].id,null,null);
			endif;
			
		endforeach;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
