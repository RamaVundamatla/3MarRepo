    <JadeMethod name="globalLockExceptionHandler" id="49910ddd-f21d-4274-b518-ca71fa387ddd">
        <source>globalLockExceptionHandler(le : LockException io) : Integer;
//Attempt to handle locks
vars
 	lockedByUserCode	: String;
 	retryCount			: Integer;
begin
 	if global.isValidObject(le.targetLockedBy) then	// locking process could have gone away  
 		lockedByUserCode := le.targetLockedBy.userCode;
 		if lockedByUserCode = '' then
 			lockedByUserCode := 'not available';
 		endif;
 	endif;

 	while not tryLock(le.lockTarget, le.lockType, le.lockDuration, le.lockTimeout) do
 		retryCount := retryCount + 1;
 		if retryCount &gt; 30 then		// 30 seconds if lock timeout is 1000 mS
 			return Ex_Pass_Back;		// let another handler deal with it
 		endif;
 	endwhile;

 	return Ex_Continue;				// must have the lock if we get to here

end;</source>
        <Parameter name="le" type="LockException" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
