    <JadeMethod name="setFieldLogId" id="ea48311c-2b2c-4cd9-a186-de9574728f91">
        <source>setFieldLogId()protected;
//--------------------------------------------------------------
//Created: 29 April 2002 By: cnwgd1
//--------------------------------------------------------------
vars
//	lastNum		: Integer;
	logId, lastNum,
	nextLogId, trailingNum	: String;
begin
	logId := tblItem.getValueByName(ETRow_LogId).String;
	if logId &lt;&gt; null then
		if logId.isInteger then
			nextLogId := (logId.Integer + 1).String;
		else
			trailingNum := logId.getTrailingIntegerString();
			lastNum := logId.getTrailingInteger().String;
			lastNum := (lastNum.Integer + 1).String;			
			if trailingNum.length &gt; lastNum.length then
				nextLogId := (logId.cnEcStripAtEnd(trailingNum) &amp; lastNum.padZeros(trailingNum.length));
			else
				nextLogId := (logId.cnEcStripAtEnd(trailingNum) &amp; lastNum);			
			endif;			
			//nextLogId := (logId.cnEcStripAtEnd(lastNum.String) &amp; (lastNum.Integer + 1).String);
		endif;
	endif;
	self.tblItem.setValueByName(ETRow_LogId, nextLogId);		
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setFieldSEDs" id="6b1a5d28-cf65-445e-a087-8b169b456e13">
        <source>setFieldSEDs(_roundMin, _roundMax : Integer output) protected;
//--------------------------------------------------------------
//Created: 09 May 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	minSed, maxSed : Integer;
begin
	minSed := self.tblItem.getValueByName(ETRow_SedMin).Integer;
	maxSed := self.tblItem.getValueByName(ETRow_SedMax).Integer;
	
	_roundMin := minSed;
	_roundMax := maxSed;
	if minSed &lt; 8 then
		_roundMin := 8;
	elseif minSed &gt; 13 then
		if minSed mod 2 &gt; 0 then
			_roundMin := (minSed - 1);
		endif;
	endif;
	
	if maxSed &lt; 8 then
		_roundMax := 8;
	elseif maxSed &gt; 13 then
		if maxSed mod 2 &gt; 0 then
			_roundMax := (maxSed - 1);
		endif;
	endif;	

	if _roundMax &lt;&gt; maxSed then
		self.tblItem.setValueByName(ETRow_SedMax, _roundMax);	
	endif;
	
	if _roundMin &lt;&gt; minSed then
		self.tblItem.setValueByName(ETRow_SedMin, _roundMin);
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_roundMin" type="Integer" usage="output"/>
        <Parameter name="_roundMax" type="Integer" usage="output"/>
    </JadeMethod>
