    <JadeMethod name="canAccessReport" id="c72c82f9-95c9-46eb-bb4d-dcffa27cba26">
        <source>canAccessReport(userName: String; reportName: String): Integer;
// ---------------------------------------------------------------------------
// Created:     21 November 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	// do NOT use app.isSpecial here as
	// the "app" is the reportWriter app
	if userName.toUpper = 'SUPERUSER' then
		return FULL_ACCESS;
	endif;

	return FULL_ACCESS;
	
end;</source>
        <Parameter name="userName" type="String"/>
        <Parameter name="reportName" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
