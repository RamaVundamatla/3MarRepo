    <JadeMethod name="setEnableObjects" id="96da4166-31a9-44e1-bded-749c139debd5">
        <updating/>
        <source>setEnableObjects(_enable : Boolean) updating;

vars
	int:	Integer;
	ctl:	Control;
begin
	int:=1;
	while int&lt;=self.controlCount do
		ctl:=controls(int);
		if ctl.isKindOf(TextBox)
		or ctl.isKindOf(Button)
		or ctl.isKindOf(CheckBox)
		or ctl.isKindOf(Table) 
		or ctl.isKindOf(ListBox)
		or ctl.isKindOf(ComboBox)
		or ctl.isKindOf(OptionButton)		
		then
			ctl.enabled := _enable;
		endif;
		int := int+1;
	endwhile;

	self.cmbVessel.enabled := true;
	
	if (not app.myCurrentUserCan(self.myTerminal, PmHMSPilotView)) then
		self.txtPilotRemarks.visible := false;
		self.lblPilotRmks.visible := true;		
	endif;
	
	self.tblSummary.enabled := true;
	
end;</source>
        <Parameter name="_enable" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMeterMarks" id="0e11c5c4-8148-4872-ab15-2e94658a443e">
        <updating/>
        <source>setMeterMarks(bowMark : Decimal io; _rowIdx : Integer)updating;
//-----------------------------------------
// Created: December 2004 By: cnwgd1
//-----------------------------------------
vars
	loa			: Decimal[6,2];
	sideTo		: Integer;
	bridgeToBow,	
	sternMark,
	bridgeMark	: Decimal[12,2];
	tmpStr		: String;
	berthForMarks,
	tmpBerth	: HMS_Berth;
	tmpTable : Table;
begin
	if self.mode &lt;&gt; self.Mode_Update
	and self.mode &lt;&gt; self.Mode_Add then
		return;
	endif;
	if _rowIdx &lt; 2 then
		return;
	endif;
	if bowMark = 0 then
		return;
	endif;
	tmpTable := self.tblPrefBerth;
	
	tmpBerth := tmpTable.accessCell(_rowIdx, 1).cellControl.ComboBox.listObject.HMS_Berth;
	if tmpBerth = null then
		return;
	endif;

	tblBasicDimension.column:=2;
	tblBasicDimension.row:=2;	
	//loa := tblBasicDimension.text.Decimal;
	loa := tblBasicDimension.text.asDecimalJMT();// 01 APR 2010	NDL	Par 23556
	
	if loa &lt; 1 then
		app.msgBox(app.getErrorString(MSGBOX_ShipLOAInvalid) &amp; LOA_LowerLimit.String &amp; " and " &amp; LOA_UpperLimit.String &amp; ".", 'Error No LOA', MsgBox_OK_Only+MsgBox_Stop_Icon);
		self.lastValidRow := 0;
		self.tblBasicDimension.setFocus();
		return;
	endif;			

	// Bridge to Bow
	tblKeyDistances.column:=2;
	tblKeyDistances.row:=2;
	//bridgeToBow := tblKeyDistances.text.Decimal;
	bridgeToBow := tblKeyDistances.text.asDecimalJMT();// 01 APR 2010	NDL	Par 23556
	
	tmpStr := tmpTable.accessCell(_rowIdx, 2).text;
	if tmpStr = app.getErrorString(StarboardSideToBerth) then
		sideTo := OrientStarboardSideTo;
	else
		sideTo := OrientPortSideTo;		
	endif;
		
	tmpBerth.getBowSternBridgeMarksFromLOA(loa, bridgeToBow, sideTo, bowMark, sternMark, bridgeMark, app.getErrorString(HMS_BowMark), berthForMarks,true);

	tmpTable.accessCell(_rowIdx, 5).text := sternMark.String;
	tmpTable.accessCell(_rowIdx, 4).text := bridgeMark.String;
	tmpTable.accessCell(_rowIdx, 3).text := bowMark.String;
	tmpTable.accessedCell.cellControl.TextBox.text := bowMark.String;	

end;</source>
        <Parameter name="bowMark" type="Decimal" usage="io"/>
        <Parameter name="_rowIdx" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setMyCurrentVessel" id="71f3eeed-0d72-4fc2-8489-a8c6a9cfb636">
        <updating/>
        <source>setMyCurrentVessel(_vessel : CM_Vessel)updating, protected;
//--------------------------------------------------
// Created:	05 April 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	
	self.myCurrentVessel := _vessel;
	self.myCurrentVesselData := null;
	self.myCurrentVesselDataHarbour := null;
	
	if _vessel &lt;&gt; null then
		self.myCurrentVesselData := _vessel.myHMSVesselData;
	endif;
	if self.myCurrentVesselData &lt;&gt; null
	and self.myHarbour &lt;&gt; null then
		self.myCurrentVesselDataHarbour := self.myCurrentVesselData.allVesselDataForHarbour[self.myHarbour];
	endif;

	self.displayVesselData();
		
end;</source>
        <access>protected</access>
        <Parameter name="_vessel" type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="setPxyBerthPrefOrder" id="f65927fd-07c9-4af5-9496-eb91edaad480">
        <source>setPxyBerthPrefOrder(_pxyVesselDataHarbour : HMS_VesselDataHarbour input) protected;

vars
	bowMark,
	bridgeMark,
	sternMark,
	orientation,
	row,
	numRows : Integer;
	berth : HMS_Berth;	
	tmpTbl : Table;
	str : String;
	berthPref : HMS_BerthPreferenceVesselData;
begin
 	// This method updates the berth preference order for the selectedShip
 	tmpTbl := self.tblPrefBerth;
 	numRows := tmpTbl.rows;
	tmpTbl.column := 1;
	_pxyVesselDataHarbour.allBerthPrefByOrder.clear;

	foreach row in 2 to numRows do
		berthPref := tmpTbl.accessRow(row).itemObject.HMS_BerthPreferenceVesselData;
		if berthPref = null then
			create berthPref transient;
		endif;
		bowMark := tmpTbl.accessCell(row, 3).text.Integer;
		bridgeMark := tmpTbl.accessCell(row, 4).text.Integer;
		sternMark := tmpTbl.accessCell(row, 5).text.Integer;
		str := tmpTbl.accessCell(row, 2).text;
		if str = app.getErrorString(StarboardSideToBerth) then
			orientation := OrientStarboardSideTo;
		else
			orientation := OrientPortSideTo;			
		endif;
		berth := tmpTbl.accessCell(row, 1).cellControl.ComboBox.listObject.HMS_Berth;
		berthPref.setProxy(bowMark,	bridgeMark,	sternMark, orientation, berth, app.myPassport);

		if global.isValidObject(berthPref) then
			if (not _pxyVesselDataHarbour.allBerthPrefByOrder.includes(berthPref)) then
				_pxyVesselDataHarbour.allBerthPrefByOrder.add(berthPref);
			endif;
		endif;
	endforeach;
	
end;</source>
        <access>protected</access>
        <Parameter name="_pxyVesselDataHarbour" type="HMS_VesselDataHarbour" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setPxyDefaultResources" id="5f8d84c2-50e5-4757-b1c9-9a9744a95e8b">
        <source>setPxyDefaultResources(_pxyVesselDataHarbour : HMS_VesselDataHarbour input) protected;

vars
	numTugs,
	numRows,
	numFix,
	row,
	lstCnt,
  	count :	Integer;
  	tmpObj : Object;
  	tmpList : ListBox;
  	resource : HMS_Resource;
	moveType : String;
	coll : ObjectArray;
	lst : CMUI_ListTable;
  	moveResource : HMS_ResourceTypeForMovement;
begin
  
	// This method updates resources set as default for a vessel

 	if self.lbxResourceList.visible then
	  	count := 1;
		tmpList := self.lbxResourceList;
	  	lstCnt := tmpList.listCount;
	  	  	
	  	while count &lt;= lstCnt do
	  		tmpObj := tmpList.itemObject[count];
	  		if HMS_Resource.hasInstance(tmpObj) then
	  			resource := tmpObj.HMS_Resource;
	  		endif;
	  		if resource = null then
		  		count := count+1;
	  			continue;
	  		endif;
	  		if tmpList.itemSelected[count] then
	  			// Update collection 
	  			if (not _pxyVesselDataHarbour.allResourceDefaults.includes(resource)) then
	  				// Add resource
	  				_pxyVesselDataHarbour.allResourceDefaults.add(resource);
	  			endif;
	  		elseif _pxyVesselDataHarbour.allResourceDefaults.includes(resource) then
				// Remove resource
				_pxyVesselDataHarbour.allResourceDefaults.remove(resource);
	  		endif;
	  		count := count+1;
	  	endwhile;

	elseif self.tblResources.visible then
		//They have the invoice system for harbour
		numRows := self.tblResources.rows;
		numFix := self.tblResources.fixedRows+1;
		create coll transient;
		foreach row in numFix to numRows do
			moveResource := self.tblResources.accessRow(row).itemObject.HMS_ResourceTypeForMovement;
			if moveResource = null then
				create moveResource transient;
			elseif (not moveResource.isTransient) then
				moveResource := _pxyVesselDataHarbour.allMovementResourcesByMovement[moveResource.movementType];
			endif;
			coll.clear();
			moveType := self.tblResources.accessCell(row, self.colMoveType).text;
			numTugs := self.tblResources.accessCell(row, self.colNumTugs).text.Integer;
			lst := self.tblResources.accessCell(row, self.colResourceType).cellControl.CMUI_ListTable;
			if lst &lt;&gt; null then
				if lst.allSelectedObjects &lt;&gt; null then
					lst.allSelectedObjects.copy(coll);
				else
					app.writeStatement( 'GD ' &amp; class.name &amp;' '&amp; method.name);					
				endif;
			endif;
			moveResource.setProxy(moveType, numTugs, self.myHarbour, coll);
			
			if global.isValidObject(moveResource) then
				if (not _pxyVesselDataHarbour.allMovementResourcesByMovement.includesKey(moveResource.movementType)) then
					_pxyVesselDataHarbour.allMovementResourcesByMovement.add(moveResource);  
				endif;
			endif;
		endforeach;

  	endif;

epilog
	delete coll;  	
end;</source>
        <access>protected</access>
        <Parameter name="_pxyVesselDataHarbour" type="HMS_VesselDataHarbour" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setPxyVessel" id="5e921bf3-8c3b-443c-96c5-c7baa28296d1">
        <source>setPxyVessel(_pxyVessel : CM_Vessel input)protected;
/* Changes

Date		Name	TFS#			Description
============================================================================
04/03/2019	jlgka1	37102		STWR CAMS STANDARD CODECO Add isBarge Flag.
============================================================================*/
begin
	_pxyVessel.setProxyForVessel(	self.picShipBitmap.picture,
									self.tbxShipCode.text.trimBlanks,
									self.tbxShipName.text.trimBlanks,
									_pxyVessel.callSign,
									_pxyVessel.classLabel,
									_pxyVessel.remarks,
									_pxyVessel.clonedFromVessel,
									self.tbxLLoydsNum.text,
									0,
									0,
									_pxyVessel.craneClearance,
									_pxyVessel.vesselType,
									_pxyVessel.yearOfBuild,
									_pxyVessel.loaWithRampsDown,
									_pxyVessel.airDraft,
									_pxyVessel.maxVesselBeam,
									_pxyVessel.draftBow,
									_pxyVessel.draftStern,
									_pxyVessel.draftMid,
									_pxyVessel.buildingLine,
									true,
									false,
									_pxyVessel.myOperator,
									_pxyVessel.myDefaultTrade,
									_pxyVessel.isBarge);
end;</source>
        <access>protected</access>
        <Parameter name="_pxyVessel" type="CM_Vessel" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setPxyVesselData" id="f0e37343-aac1-4f5f-b7c8-11e20f7b80a4">
        <source>setPxyVesselData(_pxyVesselData : HMS_VesselData input)protected;

vars
	countryCode : String;
	dim_Beam,
	dim_DraftAft,
	dim_DraftFore : Decimal[5,1];
	dim_DeadWeight,
 	dim_GrossRegTonnes,
	dim_NetRegTonnes,
 	dim_LengthOverall,
 	dist_BowToFwdContainer,
 	dist_BridgeToBow,
 	dist_BridgeToStern,
 	dist_SternToAftContainer,
 	dist_SternToBunker : Integer;	
begin

	if self.cbxCountryFlag.listObject &lt;&gt; null then
		countryCode := self.cbxCountryFlag.listObject.CM_Country.code;
	endif;
	// LOA
	tblBasicDimension.column:=2;
	tblBasicDimension.row:=2;	
	dim_LengthOverall := tblBasicDimension.text.Integer;		
	// GRT
	tblBasicDimension.column:=2;
	tblBasicDimension.row:=3;
	dim_GrossRegTonnes := tblBasicDimension.text.Integer;		

	// DeadWeight
	tblBasicDimension.column:=2;
	tblBasicDimension.row:=4;
	dim_DeadWeight := tblBasicDimension.text.Integer;		

	// Beam
	tblBasicDimension.column:=2;
	tblBasicDimension.row:=5;
	//dim_Beam := tblBasicDimension.text.Decimal;	
	dim_Beam := tblBasicDimension.text.asDecimalJMT();// 01 APR 2010	NDL	Par 23556

	// Draft Fore
	tblBasicDimension.column:=2;
	tblBasicDimension.row:=6;
	//dim_DraftFore := tblBasicDimension.text.Decimal;
	dim_DraftFore := tblBasicDimension.text.asDecimalJMT();// 01 APR 2010	NDL	Par 23556
	
	// Draft Aft
	tblBasicDimension.column:=2;
	tblBasicDimension.row:=7;
	//dim_DraftAft := tblBasicDimension.text.Decimal;	
	dim_DraftAft := tblBasicDimension.text.asDecimalJMT();// 01 APR 2010	NDL	Par 23556
	
	// Bridge to Bow
	tblKeyDistances.column:=2;
	tblKeyDistances.row:=2;
	dist_BridgeToBow := tblKeyDistances.text.Integer;		
	
	// Bridge to Stern
	tblKeyDistances.column:=2;
	tblKeyDistances.row:=3;
	dist_BridgeToStern := tblKeyDistances.text.Integer;				

	// Bow to Fwd Container Bay
	tblKeyDistances.column:=2;
	tblKeyDistances.row:=4;
	dist_BowToFwdContainer := tblKeyDistances.text.Integer;				
	
	// Stern to Aft Container Bay
	tblKeyDistances.column:=2;
	tblKeyDistances.row:=5;
	dist_SternToAftContainer := tblKeyDistances.text.Integer;				
	
	// Stern to Bunker Point
	tblKeyDistances.column:=2;
	tblKeyDistances.row:=6;
	dist_SternToBunker := tblKeyDistances.text.Integer;					
		
	_pxyVesselData.setProxy(app.myRoot,
							self.ckbxCoastalVessel.value,
							false,	//_isTramper : Boolean;		//11 Sep 2018	NDL	TFS 40778
							false,	//21 Aug 2018	NDL	TFS 40347
							self.ckbxBowThrusters.value,
							self.optPropFixed.value,							
							self.ckbxHoldingTanks.value,
							self.ckbxHasRamp.value,
							self.ckbxSternThruster.value,								
							self.txtGeneralRemark.text,
							self.txtPreviousNames.text,								
							countryCode,
							dim_Beam,
							dim_DraftAft,
							dim_DraftFore,
							dim_DeadWeight,
							dim_GrossRegTonnes,
							dim_NetRegTonnes,
							dim_LengthOverall,
							dist_BowToFwdContainer,							
							dist_BridgeToBow,
							dist_BridgeToStern,
							dist_SternToAftContainer,
							dist_SternToBunker,
							self.cmbShippingLine.listObject.CM_ShippingLine,
							self.cbxShipType.listObject.HMS_VesselType);
							
end;</source>
