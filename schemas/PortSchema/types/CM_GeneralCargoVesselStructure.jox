    <JadeMethod name="cloneMySelf" id="bbebdac1-d02e-4de3-925f-c99a85ea785a">
        <source>cloneMySelf(_transient: Boolean): SelfType;
//--------------------------------------------------
// Created:	01 February 2006 By: cnwgd1
//--------------------------------------------------
vars
	newVessel : CM_GeneralCargoVesselStructure;
begin
	newVessel := inheritMethod(_transient);
	return newVessel;
end;</source>
        <Parameter name="_transient" type="Boolean"/>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="convertToUseHoldLocnDefns" id="37361fd8-178f-4b0e-9329-633d14b2bf47">
        <source>convertToUseHoldLocnDefns();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09/07/2013	cnwndl1	Initial creation	Par 31965
27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
*/

vars

	int : Integer;
	proxy : CM_GCHoldLocationDefn;
	underDeckStr : String;
	onDeckStr : String;
	realGCHoldLocnDefn : CM_GCHoldLocationDefn;
	
begin

	if self.numberOfHatches &lt; 1 then
		//no holds declared in the structure
		return;
	endif;
	
	if not self.allHoldLocnDefnByHatchPlace.isEmpty then
		//already converted or manually populated.
		return;
	endif;
	
	// OK we are going to create two locations per hold by default.
	// An 'On Deck' location, and an 'Under deck' location.
	underDeckStr := app.getErrorString1(Under_Deck,null).trimBlanks;
	onDeckStr := app.getErrorString1(On_Deck,null).trimBlanks;
	
	foreach int in 1 to self.numberOfHatches do
		delete proxy;
		create proxy transient;
		proxy.setProxy(	int,	//_hatch : Integer;
						onDeckStr,	//_name : String;
						DeckOnDeck,	//_place : Integer;
						true,	// _isOnDeck : Boolean;				// PAR #36766
						null, 	// _maxWeight : Integer;			// PAR #36766
						null,	// _maxVolume: Decimal;				// TFS 1601
						0,	// _maxHeight: Decimal;	//07 Feb 2017	NDL	TFS 3216
						1,		// _onShipCrane: Integer;			// TFS 1601
						self	//_myGCVesselStructure : CM_GeneralCargoVesselStructure
						);
		app.myTrxCA.trxCreateGCHoldLocnDefn(proxy, realGCHoldLocnDefn, app.myPassport);
		if not app.myPassport.trxCompletedOK then
			app.writeLog( 'Error : GC Vessel ' &amp; self.myVessel.code &amp; " : " &amp; app.myPassport.getAllErrorsAndWarningsAsStr, LogINFO);
			continue;
		endif;
		
		delete proxy;
		create proxy transient;
		proxy.setProxy(	int,	//_hatch : Integer;
						underDeckStr,	//_name : String;
						DeckUnderDeck,	//_place : Integer;
						false,	// _isOnDeck : Boolean;				// PAR #36766
						null,	// _maxWeight : Boolean;			// PAR #36766
						null,	// _maxVolume: Decimal;				// TFS 1601
						0,	// _maxHeight: Decimal;	//07 Feb 2017	NDL	TFS 3216
						1,		// _onShipCrane: Integer;			// TFS 1601
						self	//_myGCVesselStructure : CM_GeneralCargoVesselStructure
						);
						
		app.myTrxCA.trxCreateGCHoldLocnDefn(proxy, realGCHoldLocnDefn, app.myPassport);
		if not app.myPassport.trxCompletedOK then
			app.writeLog( 'Error : GC Vessel ' &amp; self.myVessel.code &amp; " : " &amp; app.myPassport.getAllErrorsAndWarningsAsStr, LogINFO);
			continue;
		endif;
		
	endforeach;

epilog

	delete proxy;

end;</source>
    </JadeMethod>
