<Class name="BGP_DirectoryController" id="89928ea2-b22a-41d9-9345-697b2c99a4e0">
    <superclass name="BGP_TimerController"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;This directory controller searchs a specified directory for files of a certain file mask and processes the first found.&lt;/display&gt;</text>
    <DbClassMap file="backgroundprocess"/>
    <CompAttribute name="allFiles" id="26ecfd22-e2c8-4993-b928-45e8afe50b62">
        <type name="HugeStringArray"/>
        <access>readonly</access>
    </CompAttribute>
    <PrimAttribute name="dirPath" id="8d740981-0886-4df1-b495-fccebc463161">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="dirPathProcessed" id="0d01f5fe-731d-4f69-aa71-315315d9972b">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="mask" id="ace3f20d-246d-4b5b-aa9c-f20c536053a7">
        <length>11</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <ImplicitInverseRef name="myTerminal" id="c5f67898-167b-4795-968c-bfd5072b05a7">
        <embedded/>
        <type name="CM_Terminal"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="addFilesToProcess" id="3eab7f99-adcc-4849-ba7c-6dd5596cea96">
        <source>addFilesToProcess(_files : HugeStringArray; _isProcessed : Boolean);

// cnwdvb1 12 December 2002 

vars

begin

	if _isProcessed then
//		self.allProcessedFiles.clear;
//		_files.copy(self.allProcessedFiles);
	else
		self.allFiles.clear;
		_files.copy(self.allFiles);
	endif;

end;</source>
        <Parameter name="_files" type="HugeStringArray"/>
        <Parameter name="_isProcessed" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPostRequest" id="87bba292-cbe0-44e0-b038-6a48d603761a">
        <updating/>
        <source>doPostRequest() : Boolean protected, updating;

// cnwdvb1 13 January 2003 

vars

	theFile					: String;
	fileHandle				: File;
begin

	create fileHandle transient;
	theFile := allFiles.first;
	if theFile = null then
		return false;
	endif;
	fileHandle.fileName := theFile;
	app.moveFile(fileHandle, self.dirPathProcessed, null, false); //par 21121 cnwrs1 nov 2009
	return true;
epilog
	delete fileHandle;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doProcessing" id="62e141a2-43a0-4331-baeb-9c23d93a20ce">
        <updating/>
        <source>doProcessing() : Boolean protected, updating;

// cnwdvb1 12 March 2003 
//
// cnwdad1 01/06/2010 - PAR #24335.  Sort file nodes by createdTime before processing.
//
vars
	theFileFolder			: FileFolder;
	theFileFolderProcessed	: FileFolder; 
	allFileNodes			: FileNodeArray;
	fileNode				: FileNode;
	allFileNames			: HugeStringArray;
	fileToProcess			: String;
	allSortedNodes			: DynaDictionary;
	elementObj				: Object;
	
begin
	create theFileFolder transient;
	create theFileFolderProcessed transient;
	theFileFolderProcessed.fileName := self.dirPathProcessed;
	
	if not theFileFolderProcessed.isAvailable then
		//app.raiseCMException1(RemoteDataError, 'Specified directory ' &amp; self.dirPathProcessed &amp; ' is invalid' , null, null);
		app.raiseCMException1(Directory_not_available, self.dirPathProcessed, null, null);	//13 Sep 2012	NDL	Par 30366
		return false;
	endif;
	
	theFileFolder.fileName	:=	self.dirPath;
	
	if self.mask &lt;&gt; null then
		theFileFolder.mask	:=	self.mask;
	endif;
	
	if theFileFolder.isAvailable then
		allFileNodes	:=	theFileFolder.files();
		
		if allFileNodes.size &gt; 0 then
// cnwdad1 01/06/2010 - PAR #24335.
			create allSortedNodes transient;
			allSortedNodes.setMembership(FileNode);
			allSortedNodes.addMemberKey(FileNode::createdTime.name, false, false);
			allSortedNodes.endKeys(true);
			allFileNodes.copy(allSortedNodes);
			
			create allFileNames transient;
			
			foreach elementObj in allSortedNodes where elementObj.FileNode.isAvailable() do
				fileNode		:=	elementObj.FileNode;
				fileToProcess	:=	fileNode.fileName;
				break;
			endforeach;
			
			if fileToProcess &lt;&gt; null then
				allFileNames.add(fileToProcess);
				app.myTrxUA.trxUpdateBGPDirectoryFiles(self, allFileNames, false, app.myPassport);
				
				if (not app.myPassport.trxCompletedOK) then
					//app.raiseCMException1(RemoteDataError, 'ERR &gt;&gt; trxUpdateBGPDirectoryFiles unsuccessfully processed ' &amp; self.dirPath , null, null);
					app.raiseCMException2(Unsuccessfully_processed, "trxUpdateBGPDirectoryFile", self.dirPath, null, null);	//13 Sep 2012	NDL	Par 30366
					return false;
				endif;
				return true;
			endif;
		endif;
	else
		//app.raiseCMException1(RemoteDataError, 'Specified directory ' &amp; self.dirPath &amp; ' is invalid' , null, null);
		app.raiseCMException1(Directory_not_available, self.dirPath, null, null);	//13 Sep 2012	NDL	Par 30366
	endif;
	
	return false;
epilog
	if allFileNodes &lt;&gt; null then
		allFileNodes.purge();
	endif;

	delete theFileFolder;
	delete theFileFolderProcessed;
	delete allFileNames;
	delete allSortedNodes;
end;
// cnwdad1 01/06/2010 - PAR #24335 - The following is the original method:
/*
vars

	theFileFolder,
	theFileFolderProcessed	: FileFolder; 
	files					: FileNodeArray;
	file					: FileNode;
	array					: HugeStringArray;
	fileToProcess,
	fileName				: String;
	isRemoved				: Boolean;

begin

	create theFileFolder transient;
	create theFileFolderProcessed transient;
	theFileFolderProcessed.fileName := self.dirPathProcessed;
	if not theFileFolderProcessed.isAvailable then
		app.raiseCMException1(RemoteDataError, 'Specified directory ' &amp; self.dirPathProcessed &amp; ' is invalid' , null, null);
		return false;
	endif;
			
	theFileFolder.fileName				:= self.dirPath;
	if self.mask &lt;&gt; null then
		theFileFolder.mask		:= self.mask;
	endif;
	if theFileFolder.isAvailable then
		files := theFileFolder.files();
		if files.size &gt; 0 then
			create array transient;
			foreach file in files where file.isAvailable do
				fileToProcess := file.fileName;
				break;
			endforeach;
			if fileToProcess &lt;&gt; null then
				array.add(fileToProcess);
				app.myTrxUA.trxUpdateBGPDirectoryFiles(self, array, false, app.myPassport);
				if (not app.myPassport.trxCompletedOK) then
					app.raiseCMException1(RemoteDataError, 'ERR &gt;&gt; trxUpdateBGPDirectoryFiles unsuccessfully processed ' &amp; self.dirPath , null, null);
					return false;
				endif;
				return true;
			endif;
		endif;
	else
		app.raiseCMException1(RemoteDataError, 'Specified directory ' &amp; self.dirPath &amp; ' is invalid' , null, null);
	endif;
	return false;
epilog

	if files &lt;&gt; null then
		files.purge();
	endif;

	delete theFileFolder;
	delete theFileFolderProcessed;
	delete array;
end;
*/</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doProcessingOld" id="5d7bd97a-be44-4b16-bdee-d0103e040539">
        <updating/>
        <source>doProcessingOld(): Boolean  updating, protected;

// cnwdvb1 11 December 2002 

vars

	theFileFolder	: FileFolder; 
	files			: FileNodeArray;
	file			: FileNode;
	array			: HugeStringArray;
	deleteArray		: HugeStringArray;
	fileToProcess,
	fileName		: String;
	isRemoved		: Boolean;

begin

/*	create theFileFolder transient;
	if theFileFolder.isValidPathName(self.dirPath) then
		theFileFolder.fileName	:= self.dirPath;
		if self.mask &lt;&gt; null then
			theFileFolder.mask		:= self.mask;
		endif;
		if theFileFolder.isAvailable then
			files := theFileFolder.files();
			create deleteArray transient;
			if files.size &gt; 0 then
				create array transient;
				foreach file in files where file.isAvailable do
					array.add(file.fileName);
					if not self.allProcessedFiles.includes(file.fileName) and fileToProcess = null then
						fileToProcess := file.fileName;
					endif;
				endforeach;
				self.allProcessedFiles.copy(deleteArray);
				foreach fileName in self.allProcessedFiles do
					if not array.includes(fileName) then
						deleteArray.remove(fileName);
						isRemoved := true;
					endif;
				endforeach;
				array.clear;
				if fileToProcess &lt;&gt; null then
					array.add(fileToProcess);
					app.myTrxUA.trxUpdateBGPDirectoryFiles(self, array, false, app.myPassport);
					if (not app.myPassport.trxCompletedOK) then
						app.raiseCMException1(RemoteDataError, 'ERR &gt;&gt; trxUpdateBGPDirectoryFiles unsuccessfully processed ' &amp; self.dirPath , null, null);
						return false;
					endif;
				endif;
				
				if isRemoved then
					app.myTrxUA.trxUpdateBGPDirectoryFiles(self, deleteArray, true, app.myPassport);
					if (not app.myPassport.trxCompletedOK) then
						app.raiseCMException1(RemoteDataError, 'DIRECTORY CONTROLLER ERR &gt;&gt; trxUpdateBGPDirectoryFiles unsuccessfully processed ' &amp; self.dirPath , null, null);
						return false;
					endif;
				endif;
				if array.size &gt; 0 then
					return true;
				endif;
				return false;
			else
				app.myTrxUA.trxUpdateBGPDirectoryFiles(self, deleteArray, true, app.myPassport);
				if (not app.myPassport.trxCompletedOK) then
						app.raiseCMException1(RemoteDataError, 'DIRECTORY CONTROLLER ERR &gt;&gt; trxUpdateBGPDirectoryFiles unsuccessfully processed ' &amp; self.dirPath , null, null);
						return false;
					endif;
				return false;
			endif;
		endif;
	endif;
	app.raiseCMException1(RemoteDataError, 'DIRECTORY CONTROLLER ERR &gt;&gt; Specified directory ' &amp; self.dirPath &amp; ' is invalid' , null, null);
	 return false;
epilog
	delete theFileFolder;
	delete array;
	delete deleteArray;*/
	return false;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getFields" id="c6de2c84-645f-4ec1-89e5-5eae05fe0818">
        <source>getFields(_allFields: StringArray input);
// --------------------------------------------------------------------------------
// Created:		23 February 2006 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(_allFields);
	_allFields.add(ETRow_DirectoryPath);
	_allFields.add(ETRow_DirectoryPathProcessed);
	_allFields.add(ETRow_TimerInterval);
	_allFields.add(ETRow_RequestClassName);
	_allFields.add(ETRow_Mask);
	_allFields.add(ETRow_BgpTerminal);
end;</source>
        <Parameter name="_allFields" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="initApp" id="d5234073-afcc-457e-83e0-33a177a4006f">
        <updating/>
        <source>initApp() updating;
// -------------------------------------------
// Created 04 November 2003 by cnwdvb1
// -------------------------------------------
//03 Jan 2013	cnwrs1	32983 crash after user deleted.
vars
	msg : String;
begin
	inheritMethod();
	msg := 'Monitored Requests - ' &amp; self.displayString;
	app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
	
end;</source>
    </JadeMethod>
    <JadeMethod name="isSetup" id="2b37adeb-d5ee-4e87-a6f4-422920c9ea55">
        <methodInvocation>mapping</methodInvocation>
        <source>isSetup(set: Boolean; _value: Boolean io) mapping;

// cnwdvb1 28 July 2003 

vars

begin

	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	if self.dirPath &lt;&gt; null and self.dirPathProcessed &lt;&gt; null and self.myTerminal &lt;&gt; null 
	  and self.allRequestClassesToProcess.size &gt; 0 then
		inheritMethod(set, _value);
		return;
	endif;
	_value := false;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="moveFiles" id="2a314717-5a41-4268-bc10-0c0b2ea159d8">
        <source>moveFiles(_fileManager : JSSFMPublicInterface input; _file, _directory : String; _copy, _del : Integer) : Boolean protected;

// cnwdvb1 05 February 2003 
//03 Jan 2013	cnwrs1	32983 crash after user deleted.

vars

	error		: Integer;	
	fileFolder	: FileFolder;
	files		: FileNodeArray;
	file		: FileNode;
	msg : String;
begin
	create fileFolder transient;
	fileFolder.fileName := self.dirPath;
	if fileFolder.isAvailable then
		files := fileFolder.files();
		if files.size &gt; 0 then
			foreach file in files where file.isAvailable do
				if file.fileName = _file then
					break;
				endif;
				file := null;
			endforeach;
		endif;
	endif;
	if file &lt;&gt; null then
		_fileManager.setUnixFlags(false, false);
		msg := 'Moving file ' &amp; file.fileName &amp; ' to ' &amp; _directory;
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;msg, LogERROR);	//25 Nov 2019	NDL	TFS 47053
		
		if not _fileManager.copyFile(file.fileName, _directory &amp; '\' &amp; file.name, _copy) then
			// Exception raised by manager.
			return false;
		endif;
		if not _fileManager.deleteFile(file.fileName, _del) then
			// Exception raised by manager.
			return false;
		endif;
	endif;
	return true;
epilog
	delete fileFolder;
end;</source>
        <access>protected</access>
        <Parameter name="_fileManager" type="JSSFMPublicInterface" usage="input"/>
        <Parameter name="_file" type="String"/>
        <Parameter name="_directory" type="String"/>
        <Parameter name="_copy" type="Integer"/>
        <Parameter name="_del" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setAttributesForCreate" id="561611fb-bbf9-4267-b554-27d9490a1f93">
        <updating/>
        <source>setAttributesForCreate() updating, protected;

// cnwdvb1 11 December 2002 

vars

begin

	inheritMethod();
	self.name	:= 'Directory Monitor';

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setCMIF" id="c923adf9-d2fd-4508-8139-1cf0c712dfba">
        <source>setCMIF(_cmif: CMIF_BGPManagerChildren input);

// cnwdvb1 11 December 2002 

vars

begin
	inheritMethod(_cmif);
	_cmif.dirPath			:= self.dirPath;
	_cmif.mask				:= self.mask;
	_cmif.dirPathProcessed	:= self.dirPathProcessed;
	_cmif.myTerminal		:= self.myTerminal;

end;</source>
        <Parameter name="_cmif" type="CMIF_BGPManagerChildren" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="cde2ae09-77f1-4354-954c-d97739563a10">
        <updating/>
        <source>setForUpdate(_cmif: CMIF_BGPManagerChildren) updating;

// cnwdvb1 11 December 2002 

vars

begin
	
	inheritMethod(_cmif);
	self.dirPath			:= _cmif.dirPath;
	self.dirPathProcessed	:= _cmif.dirPathProcessed;
	self.mask				:= _cmif.mask;
	self.myTerminal			:= _cmif.myTerminal;
	self.timerInterval		:= _cmif.timerInterval;
	self.setDisplayStringFromRequests();

end;</source>
        <Parameter name="_cmif" type="CMIF_BGPManagerChildren"/>
    </JadeMethod>
</Class>
