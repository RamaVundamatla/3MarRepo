    <JadeMethod name="addToolbarControls" id="aac0d65f-0a1f-4c1c-b5a5-8741b6e4063c">
        <updating/>
        <source>addToolbarControls() updating, protected;
// -------------------------------------------
// Created 28 August 2003 by cnwdvb1
// -------------------------------------------
// Date			Who		Reason
// 25/07/2025	jlizm1	MTN 35372 Add table filter to auto schedule form
vars

	toolbar	: CMUI_Toolbar;
	
begin
	inheritMethod();

	toolbar := self.frmToolbar;
	
	toolbar.addButton(self.btnNewT, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnEditT, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnDeleteT, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnActivateT, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnDeactivateT, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addFrame(self.frmTableFilter, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
	

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="btnActivateT_click" id="e10bb2ad-1205-40d9-be3d-6d850221e272">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnActivateT_click(btn: Button input) updating;
// -------------------------------------------
// Created 28 August 2003 by cnwdvb1
// -------------------------------------------
vars

begin

	self.doProcessNow(CM_AutoSchedule.Make_Now);

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnDeactivateT_click" id="08e262e8-5a61-400a-89f3-fa97143ca759">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnDeactivateT_click(btn: Button input) updating;
// -------------------------------------------
// Created 28 August 2003 by cnwdvb1
// -------------------------------------------
vars

begin


	self.doProcessNow(CM_AutoSchedule.Make_Inactive);
	
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnDeleteT_click" id="2d1bf0bf-6410-4aee-a059-4908d4ca13e9">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnDeleteT_click(btn: Button input) updating;
// -------------------------------------------
// Created 28 August 2003 by cnwdvb1
// -------------------------------------------
vars

begin

	if self.typeOfSheet = self.Sheet_Schedule then
		self.doDelete();
	else
		self.doDeleteTask();
	endif;
	self.changeButtonStates();
	
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnEditT_click" id="b531dea4-59dd-4b71-8175-7263d8b9043d">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnEditT_click(btn: Button input) updating;
// -------------------------------------------
// Created 28 August 2003 by cnwdvb1
// -------------------------------------------
vars

begin

	if self.typeOfSheet = self.Sheet_Schedule then
		self.doEdit();
	else
		self.state := State_EditTask;
		self.doEditTask();
	endif;
	self.changeButtonStates();

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnNewT_click" id="ce621e88-88c9-40c8-9bae-282f9f1854c6">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnNewT_click(btn: Button input) updating;
// -------------------------------------------
// Created 28 August 2003 by cnwdvb1
// -------------------------------------------
vars

begin

	
	if self.typeOfSheet = self.Sheet_Schedule then
		self.doNewSchedule();
	else
		self.state := State_NewTask;
		self.doNewTask(null);
	endif;
	self.changeButtonStates();
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="changeButtonStates" id="91491237-e073-445b-91e7-999df96814a8">
        <source>changeButtonStates() protected;

// cnwdvb1 15 January 2003 

vars

begin

	if self.state = State_View then
		self.btnNewT.enabled			:= true;
		self.mnuNewSchedule.enabled		:= true;
		self.btnEditT.enabled			:= true;
		self.mnuEditSchedule.enabled	:= true;
		self.btnDeleteT.enabled			:= true;
		self.mnuDeleteSchedule.enabled	:= true;
		self.btnSaveBase.enabled		:= false;
		self.mnuSave.enabled			:= false;
		self.btnCancelBase.enabled		:= false;
		self.mnuCancel.enabled			:= false;
		self.multiSelectTasks.readOnly	:= true;
		self.mnuNewTask.enabled			:= true;
		self.mnuEditTask.enabled		:= true;
		self.mnuDeleteTask.enabled		:= true;
		self.mnuSaveTask.enabled		:= false;
		self.mnuCancelTask.enabled		:= false;
		self.tblSchedules.enabled 		:= true;
		self.tblTaskDisplay.enabled		:= true;
		
		self.shtSchedule.enabled		:= true;
		self.shtTasks.enabled			:= true;
		
		if self.selectedScheduleOid &lt;&gt; null and self.typeOfSheet = self.Sheet_Schedule then
			self.btnDeactivateT.enabled		:= self.selectedScheduleOid.CM_AutoSchedule.isActive = CM_AutoSchedule.Schedule_Is_Active;
			self.mnuDeactivate.enabled		:= self.btnDeactivateT.enabled;
			self.btnActivateT.enabled		:= true;
			self.mnuActivate.enabled		:= true;
		else
			self.btnDeactivateT.enabled		:= false;
			self.btnActivateT.enabled		:= false;	
			self.mnuActivate.enabled		:= false;
			self.mnuDeactivate.enabled		:= false;
		endif;
		
	else
		self.btnNewT.enabled			:= false;
		self.mnuNewSchedule.enabled		:= false;
		self.btnEditT.enabled			:= false;
		self.mnuEditSchedule.enabled	:= false;
		self.btnDeleteT.enabled			:= false;
		self.mnuDeleteSchedule.enabled	:= false;
		self.btnSaveBase.enabled		:= true;
		self.mnuSave.enabled			:= true;
		self.btnCancelBase.enabled		:= true;
		self.mnuCancel.enabled			:= true;
		self.multiSelectTasks.readOnly 	:= false;
		self.mnuNewTask.enabled			:= false;
		self.mnuDeleteTask.enabled		:= false;
		self.mnuEditTask.enabled		:= false;
		self.mnuSaveTask.enabled		:= true;
		self.mnuCancelTask.enabled		:= true;
		self.tblSchedules.enabled 		:= false;
		
		self.btnDeactivateT.enabled		:= false;
		self.btnActivateT.enabled		:= false;
		self.mnuActivate.enabled		:= false;
		
		if self.state = self.State_EditSchedule or
		   self.state = self.State_NewSchedule then
			self.shtTasks.enabled		:= false;
		elseif self.state = self.State_EditTask or
		   self.state = self.State_NewTask then
			self.shtSchedule.enabled	:= false;
			self.tblTaskDisplay.enabled	:= false;
		endif;
	endif;
	
	
	// TFS 2101 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnNewT.enabled			:= false;
		self.mnuNewSchedule.enabled		:= false;
		self.btnEditT.enabled			:= false;
		self.mnuEditSchedule.enabled	:= false;
		self.btnDeleteT.enabled			:= false;
		self.mnuDeleteSchedule.enabled	:= false;
		self.btnSaveBase.enabled		:= false;
		self.mnuSave.enabled			:= false;
		self.btnCancelBase.enabled		:= false;
		self.mnuCancel.enabled			:= false;
		self.multiSelectTasks.readOnly 	:= false;
		self.mnuNewTask.enabled			:= false;
		self.mnuDeleteTask.enabled		:= false;
		self.mnuEditTask.enabled		:= false;
		self.mnuSaveTask.enabled		:= false;
		self.mnuCancelTask.enabled		:= false;
		self.tblSchedules.enabled 		:= true;
		
		self.btnDeactivateT.enabled		:= false;
		self.btnActivateT.enabled		:= false;
		self.mnuActivate.enabled		:= false;
		self.mnuDeactivate.enabled		:= false;
		self.multiSelectTasks.readOnly := true;

	endif;
	

end;</source>
        <access>protected</access>
    </JadeMethod>
