begin
	create webService transient;
	
	self.loginREST(webService);
	
	webService.qsData.parseNameValuePair(_queryParamString);
	response := webService.getProformaAmount();
	
	if response.allErrors.isNotEmpty() then
		return response.allErrors.first().text;
	endif;
	
	if response.allInfo.isNotEmpty() then
		return response.allInfo.first().text;
	endif;	
	
	create jsonHelper transient;
	_response := jsonHelper.generateJson(response, JadeJson.Format_Json_Microsoft);
	_totalAmount := response.WS_ProformaAmountDueResponse.totalValue;				//navtr3 29-Oct-2025 MTN-36371
	return null;
	
	ref := CM_UnitTestAgent::wsRESTGetProformaAmount.name;
epilog
	dict := webService.qsData;
	dict.purge();
	if webService.objectsToBeDeleted.isNotEmpty() then
		webService.objectsToBeDeleted.purge();
	endif;
	delete jsonHelper;
	delete webService;
end;</source>
