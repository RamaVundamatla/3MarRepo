    <JadeMethod name="printReport" id="f0fac687-9f3e-490b-8c3b-99ea0e3ffd91">
        <updating/>
        <source>printReport() protected, updating;
// ---------------------------------------------------------------------------
// Created:     03 September 2003	cnwth2
//
// Purpose:     
//			 
// Changed On	Changed By	Reason
// ----------	----------	--------------------------------------------------
// 17 Mar 2010	consw1		PAR #22886 - Leaking report transients
//	Feb 2012	cnwjre1		CCMS 1262 transaction enquiry add reporting for transactions
//	23/03/2018 	Jlgns1	Bug 37765: SNO - Event Transaction Error
//  22 Dec 2022 navhl20 	ChangeRequest 54350:[54269] EUP - VAS Work Orders Selector Query
//  17 Feb 2023	navmv20 TFS 55626 Task 55688: Jade - Selector Query Contracts
// 24/04/2023	navkc1	CR 55654 Task 55670: Jade - Contract reporting
// 18/05/2023   navlw1  CR 53902 EUP - VBS MTN - [6] - Selector Query and JRW
// ---------------------------------------------------------------------------
vars
	jrwTrack						: CM_JRWTrackedItems;
	jrwTrans						: CM_JRWTransaction;
	jrwReport						: CMUI_JRWEntityRepresentation;
	jadeReportWriterReport			: JadeReportWriterReport;
	jadeReport						: JadeReport;
	jrwManager						: JadeReportWriterManager;
	startTime						: TimeStamp;
	jrwCash 						: CM_JRWCashTransactions;
	jrwInvoice 						: CM_JRWInvoice;
//	jrwEventTrans					: CM_JRWEvents;		//Bug 37765
	jrwAudit						: CM_JRWAudit;
	jrwEventTransactions			: CM_JRWEventTransactions;	//07 Jan 2020	NDL	TFS 47780
	jrwWOTransactions				: CM_JRWWOTransaction;
	jrwInvoiceContract				: CM_JRWInvoiceContract; // 20/04/2023	navkc1	CR 55654 Task 55670
	jrwVehicleBookings				: CM_JRWVehicleBookings; // 18/05/2023 navlw1 tfs 53902
	outputFormat : Integer;
begin
	
	jrwReport := self.cmbJRWReport.listObject.CMUI_JRWEntityRepresentation;

	if jrwReport = null then
		app.msgBox(app.getErrorString2(CMUI_Please_Select, app.getErrorString(Report), app.getErrorString(Run)), app.getErrorString(CMUI_Nothing_Selected) , MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	//15 May 2014	NDL	Par 34142
	if ( self.myQDef.mode = CM_QueryDefinition.CashPayment_Query_Mode
		or self.myQDef.mode = CM_QueryDefinition.CashReceipt_Query_Mode
		) then
		jrwCash := app.myQAFilter.createJRWTransient(CM_JRWCashTransactions).CM_JRWCashTransactions;
	//15 May 2014	NDL	Par 34142	
	elseif ( self.myQDef.mode = CM_QueryDefinition.Invoice_Query_Mode
		or self.myQDef.mode = CM_QueryDefinition.InvoiceLine_Query_Mode
		//or self.myQDef.mode = CM_QueryDefinition.Contract_Query_Mode //17/02/2023 navmv20 TFS  55626 TASK 55688
		) then
		jrwInvoice := app.myQAFilter.createJRWTransient(CM_JRWInvoice).CM_JRWInvoice;
	elseif self.myQDef.mode = CM_QueryDefinition.EventTransaction_Query_Mode  then		//Bug 37765
//		jrwEventTrans	:= app.myQAFilter.createJRWTransient(CM_JRWEvents).CM_JRWEvents;//Bug 37765	
		jrwEventTransactions	:= app.myQAFilter.createJRWTransient(CM_JRWEventTransactions).CM_JRWEventTransactions;
	elseif self.myQDef.mode = CM_QueryDefinition.WorkOrderTrans_Query_Mode  then		//16.3.2023 navhl20	#54350[54269]
		jrwWOTransactions	:= app.myQAFilter.createJRWTransient(CM_JRWWOTransaction).CM_JRWWOTransaction;
	elseif self.myQDef.mode = CM_QueryDefinition.CargoTransaction_Query_Mode or			//Bug 37765	
		self.myQDef.mode = CM_QueryDefinition.BOLTransaction_Query_Mode or	//04 Nov 2019	NDL	TFS 47100
	    self.myQDef.mode = CM_QueryDefinition.HMSTransaction_Query_Mode then				//Bug 37765	
		jrwTrans := app.myQAFilter.createJRWTransient(CM_JRWTransaction).CM_JRWTransaction;
	elseif self.myQDef.mode = CM_QueryDefinition.Location_Activity_Query_Mode then	//13 Apr 2021	NDL	TFS 50906 - might be something different once the design comes out...
		app.msgBox( app.getErrorString1( NotYetImplemented, "Specific Reporting for Location Activities" ), app.getErrorString(Warning), MsgBox_Exclamation_Mark_Icon);
		return;
	elseif self.myQDef.mode = CM_QueryDefinition.Audit_Query_Mode  then					// 6/6/18 MAP TFS37718
		jrwAudit := app.myQAFilter.createJRWTransient(CM_JRWAudit).CM_JRWAudit;
	elseif self.myQDef.mode = CM_QueryDefinition.Contract_Query_Mode then // 24/04/2023	navkc1	CR 55654 Task 55670: Jade - Contract reporting
		jrwInvoiceContract := app.myQAFilter.createJRWTransient(CM_JRWInvoiceContract).CM_JRWInvoiceContract;
	elseif self.myQDef.mode = CM_QueryDefinition.VehicleBookingSlot_Query_Mode then // 18/05/2023 navlw1 tfs 53902
		jrwVehicleBookings := app.myQAFilter.createJRWTransient(CM_JRWVehicleBookings).CM_JRWVehicleBookings;
	else
		jrwTrack := app.myQAFilter.createJRWTransient(CM_JRWTrackedItems).CM_JRWTrackedItems;
	endif;

	if jrwCash = null and
		jrwInvoice = null and
		jrwTrans = null and
	//	jrwEventTrans = null and//Bug 37765	
		jrwEventTransactions = null and //07 Jan 2020	NDL	TFS 47780
		jrwWOTransactions = null and //16.3.2023 navhl20	#54350[54269]
		jrwTrack = null and
		jrwAudit = null and
		jrwInvoiceContract = null and // 24/04/2023	navkc1	CR 55654 Task 55670: Jade - Contract reporting
		jrwVehicleBookings = null // 18/05/2023 navlw1 tfs 53902
		then
		return;
	endif;
	
	//15 May 2014	NDL	Par 34142 financial reporting
	if jrwCash &lt;&gt; null then
		if self.myQDef.mode = CM_QueryDefinition.CashPayment_Query_Mode then
			jrwCash.allCashPayments.clear();
			self.myEnqController.allObjects.copy(jrwCash.allCashPayments);
		elseif self.myQDef.mode = CM_QueryDefinition.CashReceipt_Query_Mode then
			jrwCash.allCashReceipts.clear();
			self.myEnqController.allObjects.copy(jrwCash.allCashReceipts);
		elseif self.myQDef.mode = CM_QueryDefinition.CashCredit_Query_Mode then		// 37141
			jrwCash.allCashCredits.clear();
			self.myEnqController.allObjects.copy(jrwCash.allCashCredits);
		endif;
	elseif jrwInvoice &lt;&gt; null then
		if self.myQDef.mode = CM_QueryDefinition.Invoice_Query_Mode then
			jrwInvoice.allInvoices.clear();
			self.myEnqController.allObjects.copy(jrwInvoice.allInvoices);
			jrwInvoice.setCMIFInvSumF1Lines(); //10 Aug 2017	NDL	TFS 5679
		elseif self.myQDef.mode = CM_QueryDefinition.InvoiceLine_Query_Mode then
			jrwInvoice.allInvoiceLines.clear();
			self.myEnqController.allObjects.copy(jrwInvoice.allInvoiceLines);
		endif;
	elseif jrwTrack &lt;&gt; null then
		jrwTrack.allTrackedItems.clear();
		self.myEnqController.allObjects.copy(jrwTrack.allTrackedItems);
//	elseif jrwEventTrans &lt;&gt; null then											//Bug 37765
//		jrwEventTrans.allEventsByDateTime.clear();								//Bug 37765
//		self.myEnqController.allObjects.copy(jrwEventTrans.allEventsByDateTime);//Bug 37765
	elseif jrwEventTransactions &lt;&gt; null then	 //07 Jan 2020	NDL	TFS 47780
		jrwEventTransactions.allEventTransactions.clear();								
		self.myEnqController.allObjects.copy(jrwEventTransactions.allEventTransactions);
	elseif jrwWOTransactions &lt;&gt; null then					 //16.3.2023 navhl20	#54350[54269]
		jrwWOTransactions.allWOTransactions.clear();								
		self.myEnqController.allObjects.copyNoDups(jrwWOTransactions.allWOTransactions);
	elseif jrwAudit &lt;&gt; null then
		jrwAudit.allAudits.clear();
		self.myEnqController.allObjects.copy(jrwAudit.allAudits);
	elseif jrwInvoiceContract &lt;&gt; null then // 20/04/2023	navkc1	CR 55654 Task 55670
		jrwInvoiceContract.allContracts.clear();
		self.myEnqController.allObjects.copy(jrwInvoiceContract.allContracts);
	elseif jrwVehicleBookings &lt;&gt; null then // 18/05/2023 navlw1 tfs 53902
		jrwVehicleBookings.allVehicleBookings.clear();
		self.myEnqController.allObjects.copy(jrwVehicleBookings.allVehicleBookings);
	else
		jrwTrans.allTransactions.clear();
		jrwTrans.copyReportItemsToCollection(self.myEnqController.allObjects,1); // TFS 40632
		// TFS 40632 self.myEnqController.allObjects.copy(jrwTrans.allTransactions);
		
	endif;
	
	jrwManager := app.createReportWriterManager();
	
	jadeReportWriterReport := jrwManager.getReport(jrwReport.name);
	
	if jadeReportWriterReport = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Jade report ' &amp; jadeReportWriterReport.name &amp; ' could not be found');
		return;
	endif;
	
	
	// ### JIRA 33575 03DEC2024 NAVAB1
	outputFormat := self.cmbFormats.itemData[self.cmbFormats.listIndex];
	if outputFormat &lt;&gt; JadeReportWriterReport.PRINTER then
		jadeReportWriterReport.setOutputDestination(outputFormat);
		jadeReportWriterReport.setOutputFileTitle(self.txtFileName.text);
	endif;
	
	startTime := app.actualTimeServer();
	app.lockKeeperNotifyStartActivity(startTime, method, null, 'Report "' &amp; jadeReportWriterReport.name &amp; '" from selector', app.myPassport);

	app.printer.printPreview := false;
	if self.chkPrintPreview.value then
		create jadeReport transient;
		jadeReport.description := jadeReportWriterReport.name;
		app.printer.setReport(jadeReport);
		jadeReportWriterReport.run();
		app.printPreview(jadeReport, true);
	else
		jadeReportWriterReport.run();
	endif;
	
	self.showHideFrame(self.frmPrintOptions, false, true);
	
epilog
	abortTransaction;//don't trust report writer
	app.lockKeeperNotifyEndActivity(startTime, true, app.myPassport);
	delete jrwManager;
	delete jadeReportWriterReport;
	
	app.printer.close();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="resetForMode" id="6701e4da-36e5-40a2-b344-1fca5e3329d2">
        <updating/>
        <source>resetForMode(_userQuery : CM_MenuUserQuery) protected, updating;
// ---------------------------------------------------------------------------
// Created:     23 June 2003		cnwth2	
//
// Purpose:     
//
// Changed On	By			Reason
// ----------   ----------  --------------------------------------------------
// 06/05/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
// 24/05/2013	cnwdap1		PAR #31486 new query type pointing at CM_QDefBreakBulkGeneric
// 20 Nov 2013	NDL			Par 32995
// 21/03/2019	jlgzm1		TFS43705 selector query column organiser out of date
// 10 May 2023 	navlw1 		ChangeRequest 53902: EUP - VBS MTN - [6] - Selector Query and JRW
vars
	theCargoBOLType		: CM_CargoBOLType;
	visibleColArray,
	colArray			: StringArray;
	lstCount,
	idx					: Integer;
	cmb					: CMUI_ComboBox;
	navHeading			: String;
	sheet				: CMUI_Sheet;
	criteriaLineHolder	: CM_QueryCriteriaLineHolder;
	table				: CM_DataTable;
	mode				: Integer; //tfs43705
	
begin
	// JIRA 14794 - NAVAB1 30OCT2024
	if self.useEntDefColumns then
		self.resetForModeEntDef(_userQuery);
		return;
	endif;
	
	// ### JIRA 33575 06DEC2024 NAVAB1
 	if cmbFormats.listCount &gt; 0 then
		self.cmbFormats.listIndex := 1;
	endif;
	self.txtFileName.text := "";
	self.chkPrintPreview.value := true;
	self.chkPrintPreview.enabled := true;

	self.cleanUp();
	self.cmbArgument.clear();
	self.clearArgument();		// cnwjre1 from testing 17/06/2014, looks better
	
	self.btnSendReport.enabled	:=	true;
	self.btnExtract.enabled		:=	true;
	
	if self.myQDef = null then
		return;
	endif;
	app.myQAFilter.createEnqControllerForMode(self.myQDef.mode, self.myQDef.type, self.myEnqController);
	
	//can't do various things when in docket mode - can't run reports/send to screen and of course
	//we wouldn't want to let them become able to try assigning dockets to bulk releases...
	
	//14 May 2014	NDL	Par 34142
	if ( self.myQDef.type = CM_QueryDefinition.Invoicing_Query_Type or self.myQDef.type = CM_QueryDefinition.Cash_Query_Type ) then
		self.mnuSendToScreen.visible :=	false;
		self.btnSendScreen.enabled	:=	false;
		self.btnShowHideBR.enabled	:=	false;
		self.btnSendReport.enabled	:=	true;	
		self.btnExtract.enabled		:=	true;
	elseif (self.myQDef.mode &gt; BOLType_Min) and (self.myQDef.mode &lt; BOLType_Max) then
		self.mnuSendToScreen.visible :=	true;
		self.frmBulkRelease.visible	:=	false;//only non-modal frame that might be visible when changing modes
		self.btnShowHideBR.enabled	:=	false;
		self.btnSendReport.enabled	:=	false;
		self.btnExtract.enabled		:=	false;
	else
		self.mnuSendToScreen.visible :=	true;
		self.btnSendScreen.enabled	:=	true;
		self.btnShowHideBR.enabled	:=	true;
		self.btnSendReport.enabled	:=	true;	
		self.btnExtract.enabled		:=	true;
	endif;
	
	if self.myQDef.type = CM_QueryDefinition.VehicleBookingSlot_Query_Type then										//JIRA-34630
		self.mnuVbsSendLoadNA.visible  := app.myRoot.getFirstActiveEWSForEndpoint(ETRow_LoadNotification) &lt;&gt; null; 	//JIRA-34630
	endif;																											//JIRA-34630
	
	// Feb 2012 CCMS 1262 after CCMS 2013
	self.btnMoveIt.enabled := (self.myQDef.type = CM_QueryDefinition.TrackedItem_Query_Type);
	
	self.setCaptionForMode();
	
	if _userQuery = null then
		self.createDefaultCriteriaLines();
	endif;
	
	if self.myEnqController = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Initialization of enquiry controller failed for given cargoType');
		return;
	endif;
	
	if self.myEnquiryCollectionClass &lt;&gt; null then
		create self.myEnqController.allObjects as self.myEnquiryCollectionClass transient;
	else
		create self.myEnqController.allObjects as CM_ObjectSet transient;
	endif;
	
	criteriaLineHolder := self.tblCriteria.accessSheet(self.tblCriteria.topSheet).itemObject.CM_QueryCriteriaLineHolder;
	if criteriaLineHolder &lt;&gt; null then
		if self.myDefaultVoyage &lt;&gt; null then
			criteriaLineHolder.collectionBelongsTo := self.myDefaultVoyage;
		elseif self.myTerminal &lt;&gt; null then
			criteriaLineHolder.collectionBelongsTo := self.myTerminal;
		endif;
	endif;
		
	if self.cmbSelectorMode.findObject(self.myQDef) = -1 then
		self.cmbSelectorMode.addItemObject(self.myQDef.modeDescription, self.myQDef);
	endif;
	self.cmbSelectorMode.listObject := self.myQDef;
	
	//tfs43705
	if _userQuery &lt;&gt; null then
		mode := _userQuery.queryMode;
	else	
		mode := self.myQDef.mode;
	endif;
	//tfs43705
	
	if (self.myQDef.mode &lt; BOLType_Min) or (self.myQDef.mode &gt; BOLType_Max) then
		theCargoBOLType := app.myRoot.allCargoTypesById[mode]; //tfs43705
		
	else	//its not a system cargoType or a user created cargo type - must be BOLType (docket type)
		theCargoBOLType := app.myRoot.allBOLTypes[mode]; //tfs43705
	endif;
	
	create colArray transient;
	create visibleColArray transient;
	
	if (_userQuery &lt;&gt; null) and (not _userQuery.allVisibleColumns.isEmpty) then
		_userQuery.allVisibleColumns.copy(visibleColArray);								// PAR #31155
		//theCargoBOLType := app.myRoot.allCargoTypesById[_userQuery.queryMode];
		if theCargoBOLType = null then
			if _userQuery.queryMode = 0 then
				app.myRoot.myQueryMenuRoot.allColumns.copy(colArray);					// PAR #31155
			elseif _userQuery.queryMode = CM_QueryDefinition.UserDefined_Query_Mode then	// PAR #31486
				app.myRoot.myQueryMenuRoot.allUserColumns.copy(colArray);					// PAR #31486
			else
				//_userQuery.allColumns.copy(colArray);									// PAR #31155
				self.myQDef.getSelectorColumns(colArray);								// tfs43705
			endif;
		else
			theCargoBOLType.allSelectorColumns.copy(colArray);							// PAR #31155
		endif;
	elseif theCargoBOLType &lt;&gt; null then 
		theCargoBOLType.allSelectorVisibleColumns.copy(visibleColArray);				// PAR #31155
		theCargoBOLType.allSelectorColumns.copy(colArray);								// PAR #31155
	
	//29 Mar 2019	NDL	TFS 44100 - Now store the visible columns for these types too.
	elseif ( self.myQDef.type = CM_QueryDefinition.Transaction_Query_Type
	or self.myQDef.type = CM_QueryDefinition.Invoicing_Query_Type
	or self.myQDef.type = CM_QueryDefinition.Cash_Query_Type
	or self.myQDef.type = CM_QueryDefinition.Audit_Query_Type
	or self.myQDef.type = CM_QueryDefinition.VehicleBookingSlot_Query_Type // 10/05/2023 navlw1 tfs 53902
	or	self.myQDef.isKindOf(CM_QDefTILC) or	
		self.myQDef.isKindOf(CM_QDefCar))    //jlier1 TFS 64054 1/7/24
	then
		self.myQDef.getSelectorColumns(colArray);
		app.myRoot.myQueryMenuRoot.getAllNonCargoVisibleColumns( self.myQDef, visibleColArray );

	else
		//must be trackeditem mode, so use the 
		//menuRoot's column array else use the cargo types column array
		if self.myQDef.mode = CM_QueryDefinition.UserDefined_Query_Mode then								// PAR #31486
			app.myRoot.myQueryMenuRoot.allUserVisibleColumns.copy(visibleColArray);							// PAR #31486
			app.myRoot.myQueryMenuRoot.allUserColumns.copy(colArray);										// PAR #31486
		else																								// PAR #31486
			app.myRoot.myQueryMenuRoot.allVisibleColumns.copy(visibleColArray);			// PAR #31155
			app.myRoot.myQueryMenuRoot.allColumns.copy(colArray);						// PAR #31155
		endif;																								// PAR #31486
	endif;
	
	self.myCurrentCargoBOLType := theCargoBOLType;
	self.cmbJRWReport.clear();		// Feb 2012 CCMS 1262 now reporting from tracked items and transactions
	
	self.doAddMeasurementsToColOrg(visibleColArray, colArray);						// PAR #31155
	
	self.allVisibleColumns.clear();
	self.allColumns.clear();
	visibleColArray.copy(self.allVisibleColumns);
	colArray.copy(self.allColumns);
	
	self.tblResults.rows := self.tblResults.fixedRows;
	
	self.displayResultColumns(self.allVisibleColumns, theCargoBOLType);
	
	self.loadAttrCombo();
	self.loadMeasureCombo(null);													// PAR #31155
	
	navHeading := self.editHeadingForNav(self.caption);
	self.setNavigatorHeading(navHeading);

epilog
	
	delete colArray;
	delete visibleColArray;
	self.evaluateUpDown();
	
end;</source>
        <access>protected</access>
        <Parameter name="_userQuery" type="CM_MenuUserQuery"/>
    </JadeMethod>
    <JadeMethod name="resetForModeEntDef" id="1e13485b-6b28-486b-87fe-645bf1f68803">
        <updating/>
        <source>resetForModeEntDef(_userQuery : CM_MenuUserQuery) protected, updating;
// JIRA 14794 - NAVAB1 30OCT2024

vars
	theCargoBOLType		: CM_CargoBOLType;
	visibleColArray,
	colArray			: StringArray;
	result,
	lstCount,
	idx, colnum					: Integer;
	cmb					: CMUI_ComboBox;
	navHeading			: String;
	sheet				: CMUI_Sheet;
	criteriaLineHolder	: CM_QueryCriteriaLineHolder;
	table				: CM_DataTable;
	mode				: Integer; //tfs43705
	entTableDef 	: EntTableDef;
	entTableRow : EntTableRow;
	entTableRowArray : EntTableRowArray;
begin
	// ### JIRA 33575 06DEC2024 NAVAB1
 	if cmbFormats.listCount &gt; 0 then
		self.cmbFormats.listIndex := 1;
	endif;
	self.txtFileName.text := "";
	self.chkPrintPreview.value := true;
	self.chkPrintPreview.enabled := true;

	
	self.cleanUpEntDef(); // JIRA 14794 - NAVAB1 30OCT2024
	self.cmbArgument.clear();
	self.clearArgument();		
	
	self.btnSendReport.enabled	:=	true;
	self.btnExtract.enabled		:=	true;
	
	if self.myQDef = null then
		return;
	endif;
	app.myQAFilter.createEnqControllerForMode(self.myQDef.mode, self.myQDef.type, self.myEnqController);
	
	if ( self.myQDef.type = CM_QueryDefinition.Invoicing_Query_Type or self.myQDef.type = CM_QueryDefinition.Cash_Query_Type ) then
		self.mnuSendToScreen.visible :=	false;
		self.btnSendScreen.enabled	:=	false;
		self.btnShowHideBR.enabled	:=	false;
		self.btnSendReport.enabled	:=	true;	
		self.btnExtract.enabled		:=	true;
	elseif (self.myQDef.mode &gt; BOLType_Min) and (self.myQDef.mode &lt; BOLType_Max) then
		self.mnuSendToScreen.visible :=	true;
		self.frmBulkRelease.visible	:=	false;//only non-modal frame that might be visible when changing modes
		self.btnShowHideBR.enabled	:=	false;
		self.btnSendReport.enabled	:=	false;
		self.btnExtract.enabled		:=	false;
	else
		self.mnuSendToScreen.visible :=	true;
		self.btnSendScreen.enabled	:=	true;
		self.btnShowHideBR.enabled	:=	true;
		self.btnSendReport.enabled	:=	true;	
		self.btnExtract.enabled		:=	true;
	endif;
	// Feb 2012 CCMS 1262 after CCMS 2013
	self.btnMoveIt.enabled := (self.myQDef.type = CM_QueryDefinition.TrackedItem_Query_Type);
	
	self.setCaptionForMode();
	
	if _userQuery = null then
		self.createDefaultCriteriaLines();
	endif;
	
	if self.myEnqController = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Initialization of enquiry controller failed for given cargoType');
		return;
	endif;
	
	if self.myEnquiryCollectionClass &lt;&gt; null then
		create self.myEnqController.allObjects as self.myEnquiryCollectionClass transient;
	else
		create self.myEnqController.allObjects as CM_ObjectSet transient;
	endif;
	
	criteriaLineHolder := self.tblCriteria.accessSheet(self.tblCriteria.topSheet).itemObject.CM_QueryCriteriaLineHolder;
	if criteriaLineHolder &lt;&gt; null then
		if self.myDefaultVoyage &lt;&gt; null then
			criteriaLineHolder.collectionBelongsTo := self.myDefaultVoyage;
		elseif self.myTerminal &lt;&gt; null then
			criteriaLineHolder.collectionBelongsTo := self.myTerminal;
		endif;
	endif;
		
	if self.cmbSelectorMode.findObject(self.myQDef) = -1 then
		self.cmbSelectorMode.addItemObject(self.myQDef.modeDescription, self.myQDef);
	endif;
	self.cmbSelectorMode.listObject := self.myQDef;
	
	//tfs43705
	if _userQuery &lt;&gt; null then
		mode := _userQuery.queryMode;
	else	
		mode := self.myQDef.mode;
	endif;
	//tfs43705
	
	if (self.myQDef.mode &lt; BOLType_Min) or (self.myQDef.mode &gt; BOLType_Max) then
		theCargoBOLType := app.myRoot.allCargoTypesById[mode]; //tfs43705
		
	else	//its not a system cargoType or a user created cargo type - must be BOLType (docket type)
		theCargoBOLType := app.myRoot.allBOLTypes[mode]; //tfs43705
	endif;
	
	
	self.myCurrentCargoBOLType := theCargoBOLType;
	self.cmbJRWReport.clear();
	self.tblResults.rows := self.tblResults.fixedRows;
	
	entTableDef := self.getEntDefForMode(self.myQDef.mode, self.myQDef.type);
	
	
	self.allVisibleColumns.clear();
	
	if _userQuery&lt;&gt; null then
		_userQuery.allVisibleColumns.copy(self.allVisibleColumns);
		
		self.tblResults.setColumnsFromStringArray(self.allVisibleColumns);
		
	else
		self.tblResults.setMyEntTableDef(entTableDef);	
		self.tblResults.setTblDataEntRowsFromDef(entTableDef);	
		
		if self.myQDef.type = CM_QueryDefinition.Invoicing_Query_Type then
			if self.myQDef.mode = CM_QueryDefinition.InvoiceLine_Query_Mode then
		
				self.tblResults.setForm(self); 
				if app.isSpecial then
					//03/06/2025	navkc1 JIRA MTN 35022
					result := app.msgBoxCustom("Which Columns mode do you want to run with?", "Question", MsgBoxCustom_Icon_Question_Mark  + MsgBoxCustom_Default_Third, "EUP", "GHANA", "MTN Default");
					//if app.msgBox("Do you want to run with Euroports Columns?", "Question",MsgBox_Yes_No) = MsgBox_Return_Yes then
					if result = MsgBoxCustom_Return_One then
						self.tblResults.setTblDataEntRowsFromView(entTableDef,ETView_InvListInvLineEUP);
					elseif result = MsgBoxCustom_Return_Two then //19/05/2025	navkc1 JIRA EPIC-34131 STORY-34821
						self.tblResults.setTblDataEntRowsFromView(entTableDef,ETView_LinesGPHA);
					else
						self.tblResults.setTblDataEntRowsFromView(entTableDef,ETView_InvListInvLineDefault);
					endif;
					
				else
					if app.myRoot.isClientEuroPorts() then
						self.tblResults.setTblDataEntRowsFromView(entTableDef,ETView_InvListInvLineEUP);
					elseif app.myRoot.isClientGhana() then //19/05/2025	navkc1 JIRA EPIC-34131 STORY-34821
						self.tblResults.setTblDataEntRowsFromView(entTableDef,ETView_LinesGPHA);
					else
						self.tblResults.setTblDataEntRowsFromView(entTableDef,ETView_InvListInvLineDefault);
					endif;
				endif;
			endif;
		endif;
		
		

	endif;
	
	self.loadAttrCombo();
	self.loadMeasureCombo(null);													// PAR #31155
	
	navHeading := self.editHeadingForNav(self.caption);
	self.setNavigatorHeading(navHeading);

epilog
	delete entTableRowArray;
	delete colArray;
	delete visibleColArray;
	self.evaluateUpDown();
	
end;</source>
        <access>protected</access>
        <Parameter name="_userQuery" type="CM_MenuUserQuery"/>
    </JadeMethod>
    <JadeMethod name="runProformaReportForOuput" id="e7531584-d7af-403b-a9c8-11517f0504a2">
        <source>runProformaReportForOuput();
/*
Purpose:	

Date		Who		Reason
27 August 2024	navab1	CR 65817 TASK 65818
*/

vars
	tis : CM_TrackedItemArray;
begin
	if self.myEnqController.allObjects.isEmpty then
		app.msgBox(app.getErrorString(CMUI_Selector_No_Results), app.getErrorString(CMUI_Selector_No_Results), MsgBox_Exclamation_Mark_Icon);
		return;	
	endif;
	
	create tis transient;
	self.myEnqController.allObjects.copy(tis);
	
	
	/* // ### JIRA 33574 06DEC2024 NAVAB1
	// JIRA 32861 27SEP2024 NAVAB1 - Accruals Performance
	if tis.size &gt; 4000 then
		global.beep;
		app.msgBox(app.getErrorString(More_than_4000_items_time_prof),app.getErrorString(Problem), MsgBox_OK_Only);
		return;
	
	endif;
	*/
	
	self.runProformaReport(null, tis);


epilog	

	delete tis;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="saveCriteriaToParent" id="ea5c534c-de83-48c3-ad32-3b64b3b13c81">
        <source>saveCriteriaToParent() protected;
// ---------------------------------------------------------------------------
// Created:     16 December 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	currentQuery			: CM_MenuUserQuery;
	clonedCritLine,
	critLine				: CM_SelectorCriteriaLine;
	clonedProp,
	prop					: CM_QueryProperty;
	clonedOp,
	op						: CM_QueryOperator;
	numRows,
	row						: Integer;
	tbl						: CM_DataTable;
	parentForm				: CM_BaseForm;
begin
	parentForm := self.myParent;
	if parentForm = null then
		return;
	endif;
	parentForm.allSelectorCriteria.clear();
	tbl := self.tblCriteria;
	numRows := tbl.rows;
	
	foreach row in tbl.fixedRows + 1 to numRows do
		critLine := tbl.accessRow(row).itemObject.CM_SelectorCriteriaLine;
		if critLine = null then
			continue;
		endif;
		if parentForm.allSelectorCriteria.includesKey(critLine.myQueryProperty.propertyName, critLine.myQueryProperty.propertyClassName) then
			continue;
		endif;
		
		clonedCritLine := critLine.cloneSelf(true);
		clonedProp := critLine.myQueryProperty.cloneSelf(true);
		clonedOp := critLine.myQueryOperator.cloneSelf(true);
		critLine.myQueryOperator.cloneReferences(clonedOp);
		clonedCritLine.set(clonedProp, clonedOp, critLine.isUnavailableAtRunTime);
		parentForm.allSelectorCriteria.add(clonedCritLine);
	endforeach;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="sendToScreen" id="9fea9d9b-8885-4be0-8e43-0e54492fc223">
        <updating/>
        <source>sendToScreen()protected, updating;
// ---------------------------------------------------------------------------
// Created:     15 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	coll	:Collection;
	mode	:Integer;
begin
	if optSelectedOnly.value then
		coll := tblResults.allSelectedObjects;
	else
		coll := self.myEnqController.allObjects;
	endif;
	
	mode := self.myQDef.mode;
	
	self.doSendToScreen_Send (self.tblScreens, coll, mode);
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setCaptionForMode" id="3893c3af-f2d9-4c48-8b6a-a7ba95534062">
