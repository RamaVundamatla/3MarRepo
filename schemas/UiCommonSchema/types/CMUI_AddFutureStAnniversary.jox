    <JadeMethod name="getStorageDateForCal" id="c8997a58-62af-467e-a790-f7ccbdee9471">
        <source>getStorageDateForCal(_ti: CM_TrackedItem; _excludeAdditionalDays: Boolean): Date;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21/01/2025	navkc1 JIRA Bug MTN-33812: EUP - FR - Additional Storage Days - Date Selection

*/

vars

begin
	return _ti.getFutureStorageAnniversary();

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_excludeAdditionalDays" type="Boolean"/>
        <ReturnType type="Date"/>
