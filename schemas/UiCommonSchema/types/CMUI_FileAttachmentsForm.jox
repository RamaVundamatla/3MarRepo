    <JadeMethod name="setupForm" id="6f40523e-fa95-49e6-8949-ccf7f5170dcb">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
24 September 2021	jlizm1	Initial creation TFS 51963 SAL Voyage Request Changes
14 Mar 2022			navma1	ChangeRequest 52821: EUP - Documents Linked to Cargo Types
21 Mar 2022			navsrk20ChangeRequest 52821: EUP - Documents Linked to Cargo Types
26 Nov 2022  		navvt20	Task 55527: Invoice List Attachments
06 Dec 2022 		navvt20 TFS CR 55299 Task 55520: UI - File Load and File Attachment UI changes
29 Jul 2024			navnk30	Bug 65322: FR 54086 - Document attachments for Invoice - All statuses
*/

vars
	
begin
	
	self.minimumWidth  := 500;
	self.minimumHeight := 300;
	
	if self.myParent = null then
		app.msgBox(app.getErrorString(ERR_NO_OBJECT), app.getErrorString(Error), MsgBox_OK_Only);
		self.unloadForm();
		return;
	endif;
	
	// Start 25.11.2022 navtnr20 TFS 55527
	if self.myParent.isKindOf(CM_Invoice) then
		/*	if self.myParent.CM_Invoice.isPostedOrReversal then			//29.07.2024 navnk30 #65322 START
			self.btnDelete.enabled:=false;
			self.btnLoad.enabled:=false;
		else
			self.allowUpdate := true;
		endif;
		*/
		self.allowUpdate := true;										//29.07.2024 navnk30 #65322 END
	else
		self.doPermissionCheck();	//14.03.2022 navma1 #52821
	endif;
	// End 25.11.2022 navtnr20 TFS 55527
	
	
	inheritMethod();
	
	/*
	14.03.2022 navma1 #52821
	if not app.myCurrentUserCan(self.myTerminal, PmFileAttachMaint) then		
		self.btnLoad.enabled := false;
		self.btnDelete.enabled := false;
	else
		self.allowUpdate := true;
	endif;
	*/
	//self.setCaption(app.getErrorString(File_attachments) &amp; " - " &amp; self.myParent.getDisplayDetails(false)); //14.03.2022 navma1 #52821
	if self.myParent &lt;&gt; null and self.myParent.isKindOf(CM_CargoBOLType) then																								//21.03.2022 navsrk20 #52821
		self.setCaption(app.getErrorString(File_attachments) &amp; " - " &amp; self.myParent.CM_CargoBOLType.abbreviation &amp; " " &amp; self.myParent.CM_CargoBOLType.description);		//21.03.2022 navsrk20 #52821
	else																																									//21.03.2022 navsrk20 #52821
		self.setCaption(app.getErrorString(File_attachments) &amp; " - " &amp; self.myParent.getDisplayDetails(false)); 															//21.03.2022 navsrk20 #52821
	endif;																																									//21.03.2022 navsrk20 #52821
	
	self.frmMain.top := VerticalSpacing;
	self.frmMain.left := 0;
	self.frmMain.stretchHeight := true;
	self.frmMain.stretchWidth := true;
	
	self.tblFiles.stretchWidth := true;
	self.tblFiles.height := self.frmMain.height - btnView.height - 10;
	
	self.initTable();
	self.displayFileSelected(); // 15/03/2022 jlizm1 TFS 52834
	
	self.beginClassNotification(CM_FileData,false,Object_Create_Event,Response_Continuous,null); // 8 Dec 2022 navvt20 TFS 55520
	self.beginClassNotification(CM_FileData,false,Object_Delete_Event,Response_Continuous,null); // 8 Dec 2022 navvt20 TFS 55520
	self.beginClassNotification(CM_FileData,false,Object_Update_Event,Response_Continuous,null); // 8 Dec 2022 navvt20 TFS 55520

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="fcdecf32-a69d-4366-8dac-5feaa877718d">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
06 October 2021		jlizm1	Initial creation TFS 51963 SAL Voyage Request Changes
06 Dec 2022 		navvt20 TFS CR 55299 Task 55520: UI - File Load and File Attachment UI changes
*/

vars

begin
	if eventType = Object_Delete_Event then
		if theObject.isKindOf(CM_FileData) then
			self.displayFiles();
		endif;

	elseif eventType = Object_Create_Event then
		if theObject.isKindOf(CM_FileData) then
			if theObject.CM_FileData.myParent = self.myParent then
				self.displayFiles();
			endif;
		endif;
	//Start  7 Dec 2022 navvt20 TFS 55520
	elseif eventType = Object_Update_Event then
		if theObject.isKindOf(CM_FileData) then
			self.displayFiles();
		endif;
	endif;	
	// End 7 Dec 2022 navvt20 TFS 55520
epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
