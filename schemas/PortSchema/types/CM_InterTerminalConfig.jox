    <JadeMethod name="erase" id="bcaab0cb-e442-44ee-a1be-52dba4e68845">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
08 February 2010	conkc1	Initial creation
*/
vars

begin
	self.allSourceAreas.clear;
	if self.myRelease &lt;&gt; null then
		delete self.myRelease;
	endif;
	self.allInterTermTargetTermInfo.purge;
	inheritMethod(_eraseLevel);

epilog

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getAllTargetTerminals" id="b79581df-c986-4232-8c4f-5582045adc85">
        <source>getAllTargetTerminals( validTerms : CM_TerminalByCodeDict io);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 February 2010	cnwndl1	Initial creation

*/

vars

	iter : Iterator;
	interTermInfo : CM_InterTermTargetTermInfo;
	term : CM_Terminal;

begin

	iter := self.allInterTermTargetTermInfo.createIterator;
	while iter.next( interTermInfo ) do
		term := interTermInfo.myTargetTerminal;
		if validTerms.includes( term ) then
			continue;
		endif;
		validTerms.add( interTermInfo.myTargetTerminal );
	endwhile;
	
epilog

	delete iter;
	
end;</source>
        <Parameter name="validTerms" type="CM_TerminalByCodeDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getInterTerminalInfoFor" id="410988ed-2b07-47ed-9bc4-303cb5edcf95">
        <source>getInterTerminalInfoFor( term : CM_Terminal ): CM_InterTermTargetTermInfo;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 February 2010	cnwndl1	Initial creation

*/

vars

	iter : Iterator;
	interTermInfo : CM_InterTermTargetTermInfo;
	
begin
	
	if term = null then
		return null;
	endif;

	if self.allInterTermTargetTermInfo.isEmpty then
		return null;
	endif;
	
	iter := self.allInterTermTargetTermInfo.createIterator;
	while iter.next( interTermInfo ) do
		if interTermInfo.myTargetTerminal &lt;&gt; term then
			continue;
		endif;
		return interTermInfo;
	endwhile;
	
	return null;
	
epilog

	delete iter;
	
end;</source>
        <Parameter name="term" type="CM_Terminal"/>
        <ReturnType type="CM_InterTermTargetTermInfo"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="5060f5db-f84f-4f3c-a0ea-e31fcb2eb625">
        <updating/>
        <source>setForCreate( _pxyConfig : CM_InterTerminalConfig; _passport : CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 February 2010	cnwrd1	Initial creation

*/

vars
	interTermTargetTermInfo    : CM_InterTermTargetTermInfo;
	newInterTermTargetTermInfo : CM_InterTermTargetTermInfo;
	terminalArea               : CM_TerminalArea;
begin
	
	self.setForUpdate( _pxyConfig );

	foreach interTermTargetTermInfo in _pxyConfig.allInterTermTargetTermInfo do

		create newInterTermTargetTermInfo persistent;
		newInterTermTargetTermInfo.update(interTermTargetTermInfo);
		self.allInterTermTargetTermInfo.add(newInterTermTargetTermInfo);
		if _passport.hasErrors then
			return;
		endif;
		
	endforeach;
	
	foreach terminalArea in _pxyConfig.allSourceAreas do
		self.allSourceAreas.add(terminalArea);
	endforeach;
		
epilog

end;</source>
        <Parameter name="_pxyConfig" type="CM_InterTerminalConfig"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="a2907925-c243-4ff4-99f2-44c99f5a3eec">
        <updating/>
        <source>setForUpdate( _pxyConfig : CM_InterTerminalConfig) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 February 2010	cnwrd1	Initial creation

*/
vars

begin

	self.configName                 := _pxyConfig.configName;
	self.myGate                     := _pxyConfig.myGate;
	self.myLaneController           := _pxyConfig.myLaneController;
	if self.myRelease = null then
		self.myRelease                  := _pxyConfig.myRelease;
	endif;
	self.mySourceTerminal           := _pxyConfig.mySourceTerminal;
	self.autoAssignCargoOnMoveIn    := _pxyConfig.autoAssignCargoOnMoveIn;
	self.autoUnassignCargoOnMoveOut := _pxyConfig.autoUnassignCargoOnMoveOut;

epilog

end;</source>
        <Parameter name="_pxyConfig" type="CM_InterTerminalConfig"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="7d3e79b8-c28d-4af4-b35d-b945e0cc22b1">
        <updating/>
        <source>setProxy(_configName                 : String;
		 _myGate                     : CM_Gate;
		 _myLaneController           : CM_GateAreaLaneController;
		 _myRelease                  : CM_InterTerminalBulkRelease;
		 _mySourceTerminal           : CM_Terminal;
		 _selectedTerminalAreas      : CM_TerminalAreaSet;
		 _autoAssignCargoOnMoveIn    : Boolean;
		 _autoUnassignCargoOnMoveOut : Boolean) updating;

/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 February 2010	cnwrd1	Initial creation
*/
vars

begin

	self.configName       := _configName;
	self.myGate           := _myGate;
	self.myLaneController := _myLaneController;
	self.myRelease        := _myRelease;
	self.mySourceTerminal := _mySourceTerminal;
	if _selectedTerminalAreas &lt;&gt; null then
		_selectedTerminalAreas.copy(self.allSourceAreas);
	endif;
	self.autoAssignCargoOnMoveIn    := _autoAssignCargoOnMoveIn;
	self.autoUnassignCargoOnMoveOut := _autoUnassignCargoOnMoveOut;
	
epilog

end;</source>
        <Parameter name="_configName" type="String"/>
        <Parameter name="_myGate" type="CM_Gate"/>
        <Parameter name="_myLaneController" type="CM_GateAreaLaneController"/>
        <Parameter name="_myRelease" type="CM_InterTerminalBulkRelease"/>
        <Parameter name="_mySourceTerminal" type="CM_Terminal"/>
        <Parameter name="_selectedTerminalAreas" type="CM_TerminalAreaSet"/>
        <Parameter name="_autoAssignCargoOnMoveIn" type="Boolean"/>
        <Parameter name="_autoUnassignCargoOnMoveOut" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setRelease" id="14b29ab4-b977-44a2-886c-d2d9fbef3009">
        <updating/>
        <source>setRelease(_release : CM_InterTerminalBulkRelease) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
08 February 2010	conkc1	Initial creation
*/
vars

begin
	self.myRelease := _release;
epilog

end;</source>
        <Parameter name="_release" type="CM_InterTerminalBulkRelease"/>
    </JadeMethod>
    <JadeMethod name="updateSelectedTerminalAreas" id="c824ec0a-e0ac-4e7b-905f-6a34a2b27763">
        <updating/>
        <source>updateSelectedTerminalAreas(prxyInterTerminalConfig : CM_InterTerminalConfig) updating;
/*
Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
08 February 2010	conkc1	Initial creation

*/
vars
	terminalArea : CM_TerminalArea;
begin
	//
	// For those Terminal Areas in the proxy but not in existing object - add them
	//
	foreach terminalArea in prxyInterTerminalConfig.allSourceAreas do
		if self.allSourceAreas.includes(terminalArea) = false then
			self.allSourceAreas.add(terminalArea);
		endif;
	endforeach;
	//
	// For those Terminal Areas in the existing object but not in the proxy - remove them
	//
	foreach terminalArea in self.allSourceAreas do
		if prxyInterTerminalConfig.allSourceAreas.includes(terminalArea) = false then
			self.allSourceAreas.remove(terminalArea);
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="prxyInterTerminalConfig" type="CM_InterTerminalConfig"/>
    </JadeMethod>
    <JadeMethod name="updateTargetTerminalInfo" id="b9b6dbf4-31cb-433c-835d-8150359edad5">
        <updating/>
        <source>updateTargetTerminalInfo(prxyInterTerminalConfig : CM_InterTerminalConfig) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
08 February 2010	conkc1	Initial creation

*/
vars
	interTermTargetTermInfo     : CM_InterTermTargetTermInfo;
	prxyInterTermTargetTermInfo : CM_InterTermTargetTermInfo;
	found                       : Boolean;
begin
	//
	// For those InterTermTargetTermInfo's in the existing object but not in the proxy - remove them
	//
	foreach interTermTargetTermInfo in self.allInterTermTargetTermInfo do 
		found := false;
		foreach prxyInterTermTargetTermInfo in prxyInterTerminalConfig.allInterTermTargetTermInfo 
				where prxyInterTermTargetTermInfo.myTargetTerminal = interTermTargetTermInfo.myTargetTerminal do
					interTermTargetTermInfo.update(prxyInterTermTargetTermInfo);
					found := true;
					break ;
		endforeach;
		// 
		// Not found so remove it
		//
		if found = false then
			self.allInterTermTargetTermInfo.remove(interTermTargetTermInfo);
		endif;

	endforeach;
	//
	// For those InterTermTargetTermInfo's in the proxy but not in existing object - add them
	//
	foreach prxyInterTermTargetTermInfo in prxyInterTerminalConfig.allInterTermTargetTermInfo do
		found := false;
		foreach interTermTargetTermInfo in self.allInterTermTargetTermInfo 
				where prxyInterTermTargetTermInfo.myTargetTerminal = interTermTargetTermInfo.myTargetTerminal do
					found := true;
					break;
		endforeach;
		// 
		// Not found so create a persistent
		//
		if found = false then
			create interTermTargetTermInfo persistent;
			interTermTargetTermInfo.update(prxyInterTermTargetTermInfo);
			self.allInterTermTargetTermInfo.add(interTermTargetTermInfo);
		endif;

	endforeach;

epilog

end;</source>
        <Parameter name="prxyInterTerminalConfig" type="CM_InterTerminalConfig"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="6c84a265-7b75-4e37-ab0a-7cd7ad89028a">
        <source>validateForCreate();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 February 2010	cnwrd1	Initial creation

*/

vars
	release : CM_InterTerminalBulkRelease;
begin

	release := self.mySourceTerminal.allBulkReleasesByCodeDate[self.myRelease.code, self.myRelease.dateRequested].CM_InterTerminalBulkRelease;
	if release &lt;&gt; null then
		app.raiseCMException1(InterTermBulkReleaseCodeExists, " '" &amp; self.myRelease.code &amp; "' " &amp; self.myRelease.dateRequested.String, null, null);
	endif;

	self.validateForUpdate(null);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="63dadfe9-b9ae-47a1-998b-5643e25482c6">
        <source>validateForDelete();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 February 2010	cnwrd1	Initial creation

*/
vars
	bulkRel : CM_InterTerminalBulkRelease;
begin

	// check if our release has cargo on?
	bulkRel := self.myRelease;
	if bulkRel &lt;&gt; null then
		if bulkRel.allTrackedItemsAssigned.size &gt; 0 or
			bulkRel.allTrackedItemsReleased.size &gt; 0 then
			//raise a warning - but currently this is not required ???
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="da2b47e9-9c9d-4257-8021-4c84532b04ed">
        <source>validateForUpdate(realInterTerminalConfig : CM_InterTerminalConfig);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 February 2010	cnwrd1	Initial creation

*/

vars
	terminalArea : CM_TerminalArea;
begin
	foreach terminalArea in self.allSourceAreas do
		if terminalArea.myInterTerminalConfig &lt;&gt; null then
			if terminalArea.myInterTerminalConfig &lt;&gt; realInterTerminalConfig then
				app.raiseCMException2(TermAreaAlreadyAssigned, " '" &amp; terminalArea.id &amp; "'"," '" &amp; terminalArea.myInterTerminalConfig.configName &amp; "'", null, null);
			endif;
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="realInterTerminalConfig" type="CM_InterTerminalConfig"/>
    </JadeMethod>
</Class>
