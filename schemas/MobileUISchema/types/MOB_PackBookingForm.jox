    <JadeMethod name="btn_Cancel_click" id="a56f32d0-d2fc-4c12-afcc-92f303d428f2">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btn_Cancel_click(btn: Button input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 23/03/2015	cnwdap1		Initial creation PAR #35895 CCMS PNL 2461
//
vars

begin
	app.mousePointer	:=	Busy;
	self.doCloseForm();
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
