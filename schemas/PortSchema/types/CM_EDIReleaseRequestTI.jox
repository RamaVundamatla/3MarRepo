    <JadeMethod name="getDisplayStringForAttribute" id="2bbb4725-82d2-4ae9-9c20-96a5732fff7a">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 Nov 2015	cnwkpd1	PAR #36821 - Added weight to Release Request EDI
13 Jun 2022	jlika1	TFS 53316 - EUP - GEN - Additional Dimensions For Cargo - PortSchema
*/

vars
	rowName, type	: String;

begin
	
	if _attrName = ETRow_ExpiryDate then
		if self.expiryTimeStamp.isValid then
			return self.expiryTimeStamp.date.asStringJMT;
		endif;
		return null;
		
	elseif _attrName = ETRow_ExpiryTime then
		if self.expiryTimeStamp.isValid then
			return self.expiryTimeStamp.time.asStringJMT;
		endif;
		return null;
	elseif _attrName = ETRow_Grade then		
			return self.grade;
	elseif _attrName = ETRow_Grammage then
		if self.grammage &gt; 0 then
			return self.grammage.asStringJMT;
		endif;	
	elseif _attrName = ETRow_Diameter then
		return null; // will be taken over by the measurement row		
	elseif _attrName = ETRow_RollingLength then
		return null; // will be taken over by the measurement row
		
	elseif _attrName.isMeasurementType then
		_attrName.getRowNameMeasureType(rowName, type);
		return self.getMeasurementStringForAttrib(rowName, type, _short);
	endif;
	
	return inheritMethod(_attrName, _short);
	
epilog

end;
</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
