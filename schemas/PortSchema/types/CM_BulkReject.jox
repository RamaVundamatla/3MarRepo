    <JadeMethod name="getNumberOfTis" id="e3c68406-5dd5-4522-acab-8f5a5ac876b5">
        <source>getNumberOfTis(): Integer;

// cnwdvb1 30 July 2003 
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls

vars

	ti		: CM_TrackedItem;
	count	: Integer;

begin

	foreach ti in self.allTis do
		if ti.state = TI_STATE_DELETED then
			count := count + 1;
		endif;
	endforeach;
	return count;

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
