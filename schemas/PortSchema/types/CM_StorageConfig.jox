    <JadeMethod name="getMyCompulsoryCalendar" id="688894d8-5a60-458d-ae87-aaffc1e02e61">
        <source>getMyCompulsoryCalendar():CM_Calendar;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 September 2017	jlgndl1	Initial creation	TFS 7032

*/

vars

	edition : Integer;
	invalid : Boolean;

begin

	if self.myCompulsoryCalendar = null then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject( exception, self.myCompulsoryCalendar, invalid );
	
	edition := self.myCompulsoryCalendar.edition;
	if invalid then
		return null;
	endif;
	
	return self.myCompulsoryCalendar;

epilog

end;</source>
        <ReturnType type="CM_Calendar"/>
    </JadeMethod>
    <JadeMethod name="getNumWorkAndCompChargeDays" id="ab16b97f-f66e-43e8-a924-b308bb75f3d8">
        <source>getNumWorkAndCompChargeDays( _startDate : Date; _endDate : Date; _tiTrx : CM_TITransaction ):Integer;
/*

Purpose:			Works out how many days in the period should be charged
					based on the two calendars.

Parameters:			

Return Value:		

Date		Who		Reason
22 September 2017	jlgndl1	Initial creation	TFS 7032

*/

vars

	storageConfigType : CM_StorageConfigType;
	
begin

	// re-write for TFS 7032	NDL	06 Nov 2017
	storageConfigType := self.myTerminal.getMyStorageConfigType;
	return storageConfigType.getNumWorkAndCompChargeDays(	 self.myWorkingDaysCalendar,	//_workCal : CM_Calendar;
															self.getMyCompulsoryCalendar,	//_compCal : CM_Calendar;
															_startDate,	//_startDate : Date;
															_endDate,	//_endDate : Date;
															_tiTrx	//_tiTrx : CM_TITransaction
															);

	
epilog

end;</source>
        <Parameter name="_startDate" type="Date"/>
        <Parameter name="_endDate" type="Date"/>
        <Parameter name="_tiTrx" type="CM_TITransaction"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getReceivalDateOptionStr" id="953f3331-5c72-48f1-a2d0-1a1c3b06be2d">
        <source>getReceivalDateOptionStr(_dateOption : Integer) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//08/06/2023	navkc1	CR 58007 Task 58008: JADE - Storage Config - Audits

*/

vars

begin
	if _dateOption = Storage_RailActualReceival then
		return Storage_RailActualReceivalStr;
	elseif _dateOption = Storage_RailActualUnload then
		return Storage_RailActualUnloadStr;
	elseif _dateOption = Storage_RoadActualReceival then
		return Storage_RoadActualReceivalStr;
	elseif _dateOption = Storage_RoadActualUnload then
		return Storage_RoadActualUnloadStr;
	elseif _dateOption = Storage_UnpackActualUnpack then
		return Storage_UnpackActualUnpackStr;
	elseif _dateOption = Storage_UnpackSameAsParent then
		return Storage_UnpackSameAsParentStr;
	endif;
epilog

end;</source>
        <Parameter name="_dateOption" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getShipReceDescption" id="bd0dec77-dc56-466b-89d7-f5b612502237">
        <source>getShipReceDescption() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
// 10 Oct 2017    jlgrh7 TFS #7228 ADP - Storage Configuration Validation and Auditing

*/


vars

begin
	if self.shipReceivalType = Voyage_Actual_Discharge then
		return Voyage_Actual_Discharge_Str;
	elseif self.shipReceivalType = Voyage_Pilot_On_Board then
		return Voyage_Pilot_On_Board_Str;
	elseif self.shipReceivalType = Voyage_Anchor_Down then
		return Voyage_Anchor_Down_Str;
	elseif self.shipReceivalType = Voyage_Arrival then
		return Voyage_Arrival_Str;
	elseif self.shipReceivalType = Voyage_Labour_On_Board then
		return Voyage_Labour_On_Board_Str;
	elseif self.shipReceivalType = Voyage_Ship_Exchange_Start then
		return Voyage_Ship_Exchange_Start_Str;
	elseif self.shipReceivalType = Voyage_Rec_Labour_Ashore then
		return Voyage_Rec_Labour_Ashore_Str;
	elseif self.shipReceivalType = Voyage_Rec_Ship_Exch_End then
		return Voyage_Rec_Ship_Exch_End_Str;
	elseif self.shipReceivalType = Voyage_General_Landing then
		return Voyage_General_Landing_Str;
	else 
		return null;
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getShipReleDescption" id="9ccca775-1edf-48dd-b4bf-71eed0aa95d0">
        <source>getShipReleDescption() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
// 10 Oct 2017    jlgrh7 TFS #7228 ADP - Storage Configuration Validation and Auditing

*/


vars

begin
	if self.shipReleaseType = Voyage_Actual_Load then
		return Voyage_Actual_Load_Str;
	elseif self.shipReleaseType = Voyage_Ship_Exchange_End then
		return Voyage_Ship_Exchange_End_Str;
	elseif self.shipReleaseType = Voyage_First_Day_Avail then
		return Voyage_First_Day_Avail_Str;
	elseif self.shipReleaseType = Voyage_Labour_Ashore then
		return Voyage_Labour_Ashore_Str;
	elseif self.shipReleaseType = Voyage_Departed then
		return Voyage_Departed_Str;
	elseif self.shipReleaseType = Voyage_Pilot_Return then
		return Voyage_Pilot_Return_Str;
	elseif self.shipReleaseType = Voyage_Rel_Ship_Exch_Start then
		return Voyage_Rel_Ship_Exch_Start_Str;
	elseif self.shipReleaseType = Voyage_Rel_Labour_Onboard then
		return Voyage_Rel_Labour_Onboard_Str;
	elseif self.shipReleaseType = Voyage_General_Landing then
		return Voyage_General_Landing_Str;
	else 
		return null;
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleExceptionForXMLLoad" id="fc104ccf-4b20-476a-9a88-f7d1bc687651">
        <source>handleExceptionForXMLLoad(exception1 : Exception input; _errorStore : CM_ErrorSet input) : Integer;

/*

Purpose:			Show all errors to the user when loading file

Parameters:			

Return Value:		


Date				Who		Reason
08 February 2018	jlgmd1	TFS 36934 - STWO - Nothing happens when loading STORAGECONFIG in PROD

*/

vars
	err : CM_Error;
begin
	if _errorStore = null then
		// nothing to do
		return Ex_Pass_Back;
	endif;
	
	create err transient;
	err.setErrorText(exception1.errorItem &amp; " : " &amp; exception1.extendedErrorText, false);
	
	if not _errorStore.includes(err) then
		_errorStore.add(err);
	endif;
	
	return Ex_Resume_Next;
epilog

end;</source>
        <Parameter name="exception1" type="Exception" usage="input"/>
        <Parameter name="_errorStore" type="CM_ErrorSet" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="includesCriteriaType" id="6e2dd96d-48f8-4208-9e55-c24aa5bdfc24">
        <source>includesCriteriaType(_type : Integer) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 September 2012	cnwer1	Initial creation SFW 1295

*/

vars
	allCriteriaByType : CM_YACritetriaTypeByTypeDict;
begin
	create allCriteriaByType transient;
	 self.allYACriteriaTypes.copy(allCriteriaByType);
	 
	return  allCriteriaByType[_type] &lt;&gt; null;
epilog
	delete allCriteriaByType;
end;</source>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includesTriggerType" id="6b063c1f-6951-4deb-a881-fa14f27a66b8">
        <source>includesTriggerType(_type : Integer) : Boolean;
/*
Purpose: Return true if the storage config trigger incldues _type
	// PAR 36472
Date		Who		Reason
23 June 2015	cnwdw1	Initial creation
*/
vars
	trigger: CM_StorageTrigger;
begin
	foreach trigger in self.allStorageTriggers do
		if trigger.attributeType = _type then
			return true;
		endif;
	endforeach;
	return false;
epilog

end;</source>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="37310450-ec1b-41a6-85a1-9437fb3e4e76">
        <source>pxyCreateUpdateProxy() : SelfType;
// 13 September 2012	cnwjre1	CCMS SFW 1295 Free Storage Days
//26 Jul 2019	NDL	TFS 45574
vars
	proxyStorageConfig	: CM_StorageConfig;
begin
	proxyStorageConfig := inheritMethod();
	proxyStorageConfig.firstDayTimeCutoff := self.firstDayTimeCutoff;
	proxyStorageConfig.includeFirstDay := self.includeFirstDay;
	proxyStorageConfig.includeLastDay := self.includeLastDay;
	
	proxyStorageConfig.shipReceivalType := self.shipReceivalType;
	proxyStorageConfig.shipReleaseType := self.shipReleaseType;

	proxyStorageConfig.myWorkingDaysCalendar := self.myWorkingDaysCalendar;
	proxyStorageConfig.myCompulsoryCalendar := self.getMyCompulsoryCalendar;	//20 Sep 2017	NDL	TFS 7032
	self.allYACriteriaTypes.copy(proxyStorageConfig.allYACriteriaTypes);
	return proxyStorageConfig;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="reorderStorageAllocCriteria" id="d387b6e2-667a-45a6-9aa0-61b26db49c4e">
        <updating/>
        <source>reorderStorageAllocCriteria(_types : CM_YACriteriaTypeArray) updating, protected;
// CCMS 1295 free storage days
// add new criteria to and delete old criteria from existing storage details, 
//  re-order criteria in existing storage details to new sequence.
//20/04/2023	navkc1	Bug 57628: CUX-Adding Criteria to Transaction Mapping allocation configuration results in error
vars
	itemCode	: String;
	nullValue	: String;
	priorityValue,
	sortValue	: Real; //20/04/2023	navkc1	Bug 57628 Needs to be the same type as receive
	crit	: CM_YACriteria;
	criteria		: CM_YACriteriaPriority;
	proxyCriteria	: CM_YACriteria;
	criteriaType	: CM_YACriteriaType;
	storageDetail	: CM_StorageDetail;
	newTypes : ObjectArray;
	oa		: ObjectArray;
	obj		: Object;
begin
	create newTypes transient;
	_types.copy(newTypes);

	create oa transient;
	foreach storageDetail in self.allStorageDetails do
		// update each storage detail criteria
		foreach criteria in storageDetail.allCriteria do
			if newTypes.includes(criteria.myYACriteriaType) then
				continue;
			else 			// delete old criteria
				app.myUtilityDA.utlDeleteYACriteriaPriority(criteria, app.myPassport);
			endif;
		endforeach;
		foreach obj in newTypes do
			criteriaType := obj.CM_YACriteriaType;
			crit := storageDetail.allCriteriaByType[criteriaType.type];
			if crit = null then
				// create new null-valued criteria for this storage detail
				create proxyCriteria transient;
				itemCode := criteriaType.description.cnEcUpto(CM_YACriteriaPriority::code.length - 1);
				nullValue := "";
				if criteriaType.isBooleanType() then
					nullValue := CM_YADataBoolean.VALUE_FALSE.String;
				endif;
				proxyCriteria.setProxy(criteriaType, nullValue, itemCode);
				proxyCriteria.CM_YACriteria.setYardAllocation(storageDetail);
		
				app.myUtilityCA.utlCreateYACriteriaPriority(proxyCriteria, criteria, app.myPassport);
				
			endif;
		endforeach;
		
		// sort remaining criteria into the new sequence
		oa.clear();
		foreach criteriaType in _types do
			crit := storageDetail.allCriteriaByType[criteriaType.type];
			if crit &lt;&gt; null then
				oa.add(crit);
			endif;
		endforeach;

		// detach and re-attach each criteria from CM_StorageDetail.allCriteria with new priority (the allCriteria key)
		sortValue := 0;
		foreach obj in oa do
			crit := obj.CM_YACriteria;
			crit.setYardAllocation(null);
			priorityValue	:=	2 ^ sortValue;
			crit.setPriorityValue(priorityValue);
			sortValue		:=	sortValue + 1;
		endforeach;
		foreach obj in oa do
			crit := obj.CM_YACriteria;
			crit.setYardAllocation(storageDetail);
		endforeach;
	endforeach;
epilog
	delete newTypes;
	delete oa;
end;
</source>
        <access>protected</access>
        <Parameter name="_types" type="CM_YACriteriaTypeArray"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="2055455c-f475-4b4c-b405-c9a325c431be">
        <updating/>
        <source>setForCreate(_proxyStorageConfig : CM_StorageConfig; _passport : CM_Passport input) updating;
// 13 September 2012	cnwjre1	CCMS SFW 1295 Free Storage Days
vars
	proxyStorageDetail, newStorageDetail : CM_StorageDetail;
	proxyFutureStorageMapping, newFutureStorageMapping : CM_FutureStorageMapping;
	proxyQuantityMap, realQuantityMap : CM_QuantityMap;
begin
	_proxyStorageConfig.raiseExceptionIfNotTransient(method);

	self.setForUpdate(_proxyStorageConfig,_passport);
	self.myTerminal := _proxyStorageConfig.myTerminal;
	
	
end;</source>
        <Parameter name="_proxyStorageConfig" type="CM_StorageConfig"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForCreateWholeStructure" id="d5d16157-2670-40ca-9e0a-dc1900d01361">
        <updating/>
        <source>setForCreateWholeStructure(_proxyStorageConfig : CM_StorageConfig; _passport : CM_Passport input) updating;
/*
Purpose:			
Date				Who			Reason
JULY 2017		CNWAB1		Initial creation
14/06/2023		navkc1		CR 58024 Task 58025: JADE - Storage Config - Future Storage Mapping Import Export
*/
vars
	proxyStorageDetail, newStorageDetail : CM_StorageDetail;
	proxyFutureStorageMapping, newFutureStorageMapping : CM_FutureStorageMapping;
	proxyQuantityMap, realQuantityMap,
	proxyQuantityMapChild, realQuantityMapChild : CM_QuantityMap;
	proxyQuantityRange, realQuantityRange,
	proxyQuantityRangeChild, realQuantityRangeChild: CM_QuantityRangeMap;
	cleanUpProxies : ObjectArray;	//26 Sep 2017	NDL	TFS 7032
begin
	_proxyStorageConfig.raiseExceptionIfNotTransient(method);

	// ### STORAGE CONFIG
	self.setForUpdate(_proxyStorageConfig,_passport);
	self.myTerminal := _proxyStorageConfig.myTerminal;
	
	create cleanUpProxies transient;	//26 Sep 2017	NDL	TFS 7032
	
	// ### STORAGE DETAILS
	foreach proxyStorageDetail in _proxyStorageConfig.allStorageDetails discreteLock do
		
		
		proxyStorageDetail.setMyStorageConfig(self);
		cleanUpProxies.add(proxyStorageDetail);	//26 Sep 2017	NDL	TFS 7032
		
		create newStorageDetail;
		newStorageDetail.setForCreate(proxyStorageDetail);
		
	
		// ### FUTURE MAPPINGS
		foreach proxyFutureStorageMapping in proxyStorageDetail.allFutureStorageMappings discreteLock do
			create newFutureStorageMapping;
			newFutureStorageMapping.setMyStorageGroup(proxyFutureStorageMapping.myStorageGroup); // myStorageGroup is REAL
			newFutureStorageMapping.setStorageDetail(newStorageDetail);
			
			// ### QUANTITY MAP
			create realQuantityMap;
			
			proxyQuantityMap := proxyFutureStorageMapping.myQuantityMap;
			realQuantityMap.setForCreateFutureStorage(proxyQuantityMap, newFutureStorageMapping);
			
			// ### QUANTITY RANGES
			foreach proxyQuantityRange in proxyQuantityMap.allQuantityRanges discreteLock do
				create realQuantityRange;
				realQuantityRange.setForCreateWholeStructure(proxyQuantityRange, realQuantityMap);
				
				// ### CHILD QUANTITY MAP 14/06/2023	navkc1	CR 58024 Task 58025
				proxyQuantityMapChild := proxyQuantityRange.myChildQuantityMap;
				if proxyQuantityMapChild &lt;&gt; null then
					create realQuantityMapChild;
					realQuantityMapChild.setForCreateFutureStorage(proxyQuantityMapChild, null);
					realQuantityMapChild.myParentFinancialObject := realQuantityRange;
					// ### CHILD QUANTITY RANGES
					foreach proxyQuantityRangeChild in proxyQuantityMapChild.allQuantityRanges discreteLock do
						create realQuantityRangeChild;
						realQuantityRangeChild.setForCreateWholeStructure(proxyQuantityRangeChild, realQuantityMapChild);
					endforeach;
				endif;
				
			endforeach;
		endforeach;
	endforeach;

epilog

	//26 Sep 2017	NDL	TFS 7032
	if cleanUpProxies &lt;&gt; null then
		if not cleanUpProxies.isEmpty then
			cleanUpProxies.purge();
		endif;
		delete cleanUpProxies;
	endif;
	
end;</source>
        <Parameter name="_proxyStorageConfig" type="CM_StorageConfig"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="f314e3d8-42b0-49a1-ae13-45859d7ce463">
        <updating/>
        <source>setForUpdate(_proxyStorageConfig : CM_StorageConfig;_passport : CM_Passport input) updating;
// 13 September 2012	cnwjre1	CCMS SFW 1295 Free Storage Days
//26 Jul 2019	NDL	TFS 45574
// 26/05/2023	navkc1	CR 58009 Task 58010: UI - Storage Config - Storage Configuration Receival
vars
	pxyStorageTrigger, 
	realStorageTrigger : CM_StorageTrigger;
	allDeleteStorageTriggers : CM_StorageTriggerSet;
	sd : CM_StorageDetail;
begin
	// if the criteria sequence changes, need to make the same change to the criteria of each existing invoice allocation,
	//  to keep the sequence of criteria and data correct on the forms
	
	// TFS 4271 this was incorrectly adding all the attributes to each allocation, this is wrong only the attributes with values should be on the allocation;
	//					otherwise the priority value of the allocation is wrong.
//	if self.allYACriteriaTypes.size &gt; 0 and
//	   not self.allYACriteriaTypes.membersSame(_proxyStorageConfig.allYACriteriaTypes) then
//		self.reorderStorageAllocCriteria(_proxyStorageConfig.allYACriteriaTypes);
//	endif;

	self.allYACriteriaTypes.clear();
	_proxyStorageConfig.allYACriteriaTypes.copy(self.allYACriteriaTypes);
	
	
	self.firstDayTimeCutoff := _proxyStorageConfig.firstDayTimeCutoff;
	self.includeFirstDay := _proxyStorageConfig.includeFirstDay;
	self.includeLastDay := _proxyStorageConfig.includeLastDay;
	
	self.shipReceivalType := _proxyStorageConfig.shipReceivalType;
	self.shipReleaseType := _proxyStorageConfig.shipReleaseType;
	
	// 26/05/2023	navkc1	CR 58009 Task 58010
	self.roadReceivalType := _proxyStorageConfig.roadReceivalType;
	self.railReceivalType := _proxyStorageConfig.railReceivalType;
	self.unpackReceivalType := _proxyStorageConfig.unpackReceivalType;
	
	self.myWorkingDaysCalendar := _proxyStorageConfig.myWorkingDaysCalendar;
	self.myCompulsoryCalendar := _proxyStorageConfig.getMyCompulsoryCalendar;	//20 Sep 2017	NDL	TFS 7032
	
	
	create allDeleteStorageTriggers transient;
	self.allStorageTriggers.copy(allDeleteStorageTriggers);
	
	foreach pxyStorageTrigger in _proxyStorageConfig.allStorageTriggers discreteLock do
		
		realStorageTrigger:=self.allStorageTriggers[pxyStorageTrigger.attributeType];
		if realStorageTrigger = null then
			create realStorageTrigger persistent;
			
			realStorageTrigger.setForCreate(pxyStorageTrigger,self,_passport);
		else
			realStorageTrigger.setForUpdate(pxyStorageTrigger,_passport);
			allDeleteStorageTriggers.remove(realStorageTrigger);
		endif;
		
	endforeach;
	
	allDeleteStorageTriggers.purge;
	// TFS 4271
	foreach sd in self.allStorageDetails do
		sd.setPriority();
	endforeach;
epilog
	delete allDeleteStorageTriggers;
end;</source>
        <Parameter name="_proxyStorageConfig" type="CM_StorageConfig"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="13013f6b-e459-4cff-a753-c3492bdb3465">
        <updating/>
        <source>setProxy(_criteria : CM_YACriteriaTypeArray; 
		 _triggers : CM_StorageTriggerByType;
		_firstDayTimeCutoff : Time;
		_includeFirstDay : Boolean;
		_includeLastDay : Boolean;
		 _terminal : CM_Terminal;
		 _shipReceivalType : Integer;
		 _shipReleaseType : Integer;
		 _calendar : CM_Calendar;
		 _compulsory : CM_Calendar;	//20 Sep 2017	NDl	TFS 7032
		 _roadReceivalType : Integer;	// 26/05/2023	navkc1	CR 58009 Task 58010
		 _railReceivalType : Integer;	// 26/05/2023	navkc1	CR 58009 Task 58010
		 _unpackReceivalType : Integer	// 26/05/2023	navkc1	CR 58009 Task 58010
		 ) updating;

vars
	storageTrigger : CM_StorageTrigger;
begin
	self.allYACriteriaTypes.clear();
	_criteria.copy(self.allYACriteriaTypes);
	
	self.firstDayTimeCutoff := _firstDayTimeCutoff;
	self.includeFirstDay := _includeFirstDay;
	self.includeLastDay := _includeLastDay;
	self.myTerminal := _terminal;
	self.shipReceivalType := _shipReceivalType;
	self.shipReleaseType := _shipReleaseType;
	self.myWorkingDaysCalendar := _calendar;
	self.myCompulsoryCalendar := _compulsory;	//20 Sep 2017	NDL	TFS 7032
	self.roadReceivalType := _roadReceivalType; // 26/05/2023	navkc1	CR 58009 Task 58010
	self.railReceivalType := _railReceivalType; // 26/05/2023	navkc1	CR 58009 Task 58010
	self.unpackReceivalType := _unpackReceivalType; // 26/05/2023	navkc1	CR 58009 Task 58010
	
	if _triggers &lt;&gt; null then
		foreach storageTrigger in _triggers discreteLock do
			storageTrigger.setMyStorageConfig(self);
		endforeach;
	endif;
end;
</source>
        <Parameter name="_criteria" type="CM_YACriteriaTypeArray"/>
        <Parameter name="_triggers" type="CM_StorageTriggerByType"/>
        <Parameter name="_firstDayTimeCutoff" type="Time"/>
        <Parameter name="_includeFirstDay" type="Boolean"/>
        <Parameter name="_includeLastDay" type="Boolean"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_shipReceivalType" type="Integer"/>
        <Parameter name="_shipReleaseType" type="Integer"/>
        <Parameter name="_calendar" type="CM_Calendar"/>
        <Parameter name="_compulsory" type="CM_Calendar"/>
        <Parameter name="_roadReceivalType" type="Integer"/>
        <Parameter name="_railReceivalType" type="Integer"/>
        <Parameter name="_unpackReceivalType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromXMLLoad" id="c0432db7-e075-4731-8231-e7202f0a3c5f">
        <updating/>
        <source>setProxyFromXMLLoad(_jadeXMLElement : JadeXMLElement input;_errorStore : CM_ErrorSet input;  _term : CM_Terminal) : Boolean updating;
/*
Purpose:			
Date		Who		Reason
04 July 2017	cnwab1	Initial creation
21 Jul 2017		cnwma1	TFS #5409:STWO - Storage Slab Auto Commercial Hold
08 Feb 2018		jlgmd1	TFS #36934 - STWO - Nothing happens when loading STORAGECONFIG in PROD
26/05/2023		navkc1	CR 58009 Task 58010: UI - Storage Config - Storage Configuration Receival
14/06/2023		navkc1	CR 58024 Task 58025: JADE - Storage Config - Future Storage Mapping Import Export
16/06/2023		navkc1	CR 58221 Task 58222: UI - Ownership Change Free Days
29/02/2023		navkc1 	CR 61899 Task 61904: Jade - Storage TRX
*/

vars
	root : CM_Root;
	iter			: Iterator;
	xmlElement		: JadeXMLElement;
	
	// #### JadeXMLNode
	xmlNodeStorageConfig, xmlNode, xmlCriteriaNode, xmlFutureStorageObjectNode, xmlNodeStorageTrig, xmlNodeStorageTrigObj,xmlNodeCriteria,xmlNodeCriteriaObj,
	xmlQuantityMapNode, xmlAllCriteriaNode, xmlQtyMapNode, xmlAllQtyMaps , xmlAllInvLineMap,xmlInvLineMap, xmlinvLineGroupType,
	xmlQuantityMapNodeChild, xmlQtyMapNodeChild, xmlAllQtyMapsChild, xmlAllAdditionalCalendarNode, xmlAdditionalCalendarNode :JadeXMLNode;
	
	// #### String
	criDesc, firstDayTimeCutoff, includeFirstDay, includeLastDay, lastDayTimeCutoff, shipReceivalType, shipReleaseType,
	chargeDays, chargedDaysType, chargedDaysWorking, freeDaysType, freeDaysWorking, freeStorageDays, noCharge, noStorageIfNotFullyReceived, 
	receivalDateRule, stopCompletionFreeDays, allowMultiRangeSplit, allowOthersOption, code, color, description, expiryDate, expiryType, stcode,stdescription,
	ccode, cdesc, invLineGrpName, invoiceLineDescStr, calcTypeCode, critTypeStr,critItemCode,critItemValues,critItemPriority,tranMapName,tranMapdesc, vesselCatCode,
	xmlTagStr,xmlNodeStr : String;
	
	// #### Integer
	mappingType, rangeStart,rangeEnd, rangeType, mapValue, invLineGrpType, attributeType,criType, transferTypeInt,
	mappingTypeSub, rangeStartSub, rangeEndSub, rangeTypeSub: Integer;
	
	// #### Boolean
	chargeZero, resetFreeStorageDays, crIsUsed, chargeZeroSub: Boolean;
	
	yaCriteria : CM_YACriteria;
	allCriTypes : CM_YACriteriaTypeArray; 
	realCriType, critType : CM_YACriteriaType;
	qtyMap, qtyMapChild : CM_QuantityMap;
	qtyRangeMap, qtyRangeMapChild : CM_QuantityRangeMap;
	calcType, calcTypeSub : CM_CalculationType;
	bank : CM_Bank;
	realInvLineGroupType : CM_TranMapInvoiceLineGroupType;
	pxyInvLineMapping :CM_TranMapInvoiceLineMapping;
	invoiceLineDesc : CM_InvoiceLineDesc;
	realStorageGroup : CM_TerminalAreaStorageGroup;
	proxyStorageConfig, sconfig : CM_StorageConfig;
	pxyStorageDetail : CM_StorageDetail;
	pxyFSM : CM_FutureStorageMapping;
	realCalendar : CM_Calendar;
	pxyStorageTrigger : CM_StorageTrigger;
	err : CM_Error;
	fsStop :CM_StopsTable; //21.07.2017 cnwma1 TFS #5409
	realCompulsory : CM_Calendar; //20 Sep 2017	NDL	TFS 7032
	transferType: CM_VoyageJobTransferType;
	vesselCategory: HMS_VesselCategory;
	roadReceival,
	railReceival,
	childReceival : String; // 26/05/2023	navkc1	CR 58009 Task 58010
	detailRoadReceival,
	detailShipReceival,
	detailRailReceival,
	detailChildReceival : String; // 29/05/2023	navkc1	CR 58011 Task 58012
	allAdditionalCalendar : CM_CalendarByCodeDict;
	additionalCalendar : CM_Calendar;
	allCalendarTransients	: ObjectArray;
	obj : Object;
	cooFreeDays : String;		//16/06/2023	navkc1	CR 58221 Task 58222
	cooFreeDaysType : String;	//16/06/2023	navkc1	CR 58221 Task 58222
	stoDtlIncludeFirstDay, 
	stoDtlIncludeLastDay : String; //29/02/2023	navkc1 CR 61899 Task 61904
begin
	if _jadeXMLElement = null then
		return false;
	endif;
	
	tranMapName		:= null;
	tranMapdesc		:= null;
	root			:= app.myRoot;
	bank := _term.getDefaultCompanyBank();
	
	
	proxyStorageConfig := self;
	
	on Exception do self.handleExceptionForXMLLoad(exception, _errorStore);		//08 Feb 2018 jlgmd1 TFS #36934
	
	create allCalendarTransients transient; //14/06/2023	navkc1	CR 58024 Task 58025
	
	iter := _jadeXMLElement.childNodes.createIterator;
	while iter.next(xmlNode) do
	
		// STORAGE CONFIG
		xmlElement := xmlNode.JadeXMLElement;
		if xmlElement.tagName = "name" then
			tranMapName := xmlElement.textData.String;
		elseif xmlElement.tagName = "firstDayTimeCutoff" then
			firstDayTimeCutoff := xmlElement.textData.String;
		elseif xmlElement.tagName = "includeFirstDay" then
			includeFirstDay := xmlElement.textData.String;
		elseif xmlElement.tagName = "includeLastDay" then
			includeLastDay := xmlElement.textData.String;
		elseif xmlElement.tagName = "lastDayTimeCutoff" then
			lastDayTimeCutoff := xmlElement.textData.String;
		elseif xmlElement.tagName = "shipReceivalType" then
			shipReceivalType := xmlElement.textData.String;
		elseif xmlElement.tagName = "shipReleaseType" then
			shipReleaseType := xmlElement.textData.String;
		elseif xmlElement.tagName = "truckReceivalType" then // 26/05/2023	navkc1	CR 58009 Task 58010
			roadReceival := xmlElement.textData.String;
		elseif xmlElement.tagName = "wagonReceivalType" then // 26/05/2023	navkc1	CR 58009 Task 58010
			railReceival := xmlElement.textData.String;
		elseif xmlElement.tagName = "childReceivalType" then // 26/05/2023	navkc1	CR 58009 Task 58010
			childReceival := xmlElement.textData.String;
		elseif xmlElement.tagName = "allStorageDetails" then
			
			// FOR EACH STORAGE DETAIL
			foreach xmlNodeStorageConfig in xmlElement.childNodes do
				create pxyStorageDetail transient;


				// EACH ATTRIBUTE ON STORAGE DETAIL	
				foreach xmlNode  in xmlNodeStorageConfig.childNodes do
					xmlTagStr := xmlNode.JadeXMLElement.tagName;
					xmlNodeStr := xmlNode.JadeXMLElement.textData;
					
					
					if xmlTagStr = "code" then
						code :=xmlNodeStr.String;
					elseif  xmlTagStr = "color" then
						color := xmlNodeStr.String;
					elseif  xmlTagStr = "description" then
						description := xmlNodeStr.String;
					elseif  xmlTagStr = "chargeDays" then
						chargeDays := xmlNodeStr.String;
					elseif  xmlTagStr = "chargedDaysType" then
						chargedDaysType := xmlNodeStr.String;
					elseif  xmlTagStr = "chargedDaysWorking" then
						chargedDaysWorking := xmlNodeStr.String;
					elseif  xmlTagStr = "freeDaysType" then
						freeDaysType := xmlNodeStr.String;
					elseif  xmlTagStr = "freeDaysWorking" then
						freeDaysWorking := xmlNodeStr.String;
					elseif  xmlTagStr = "freeStorageDays" then
						freeStorageDays := xmlNodeStr.String;
					elseif  xmlTagStr = "noCharge" then
						noCharge := xmlNodeStr.String;
					elseif  xmlTagStr = "noStorageIfNotFullyReceived" then
						noStorageIfNotFullyReceived := xmlNodeStr.String;
					elseif  xmlTagStr = "receivalDateRule" then
						receivalDateRule := xmlNodeStr.String;
					elseif  xmlTagStr = "stopCompletionFreeDays" then
						stopCompletionFreeDays := xmlNodeStr.String;
					elseif xmlTagStr = "futureStorageStop" then  //21.07.2017 cnwma1 TFS #5409
						fsStop := app.myRoot.getStopTableForId(xmlNodeStr.Integer); //21.07.2017 cnwma1 TFS #5409
					elseif  xmlTagStr = "allowMultiRangeSplit" then
						allowMultiRangeSplit := xmlNodeStr.String;
					elseif  xmlTagStr = "allowOthersOption" then
						allowOthersOption := xmlNodeStr.String;
					elseif  xmlTagStr = "expiryDate" then
						expiryDate := xmlNodeStr.String;
					elseif  xmlTagStr = "expiryType" then
						expiryType := xmlNodeStr.String;
					elseif xmlTagStr = "detailTruckReceivalType" then // 29/05/2023	navkc1	CR 58011 Task 58012
						detailRoadReceival := xmlNodeStr.String;
					elseif xmlTagStr = "detailShipReceivalType" then // 29/05/2023	navkc1	CR 58011 Task 58012
						detailShipReceival := xmlNodeStr.String;
					elseif xmlTagStr = "detailWagonReceivalType" then // 29/05/2023	navkc1	CR 58011 Task 58012
						detailRailReceival := xmlNodeStr.String;
					elseif xmlTagStr = "detailChildReceivalType" then // 29/05/2023	navkc1	CR 58011 Task 58012
						detailChildReceival := xmlNodeStr.String;
					elseif xmlTagStr = "cooFreeDays" then	//16/06/2023	navkc1	CR 58221 Task 58222
						cooFreeDays := xmlNodeStr.String;
					elseif xmlTagStr = "cooFreeDaysType" then	//16/06/2023	navkc1	CR 58221 Task 58222
						cooFreeDaysType := xmlNodeStr.String;
					elseif xmlTagStr = "stoDtlIncludeFirstDay" then //29/02/2023	navkc1 CR 61899 Task 61904
						stoDtlIncludeFirstDay := xmlNodeStr.String;
					elseif xmlTagStr = "stoDtlIncludeLastDay" then //29/02/2023	navkc1 CR 61899 Task 61904
						stoDtlIncludeLastDay := xmlNodeStr.String;
					elseif  xmlNode.JadeXMLElement.tagName = "allCriteria" then
							foreach  xmlAllCriteriaNode in xmlNode.childNodes do
								create yaCriteria transient;
								
								foreach  xmlCriteriaNode in xmlAllCriteriaNode.childNodes do 
									xmlTagStr := xmlCriteriaNode.JadeXMLElement.tagName;
									xmlNodeStr := xmlCriteriaNode.JadeXMLElement.textData;
									if xmlTagStr = "myYACriteriaType" then
										critTypeStr :=xmlNodeStr.String;
									elseif xmlTagStr = "priorityValue"then
										critItemPriority := xmlNodeStr.String;
									elseif xmlTagStr = "code"then
										critItemCode := xmlNodeStr.String;
									elseif xmlTagStr = "myYAData"then
										critItemValues :=xmlNodeStr.String.toUpper;
									endif;
								endforeach;
								critType := app.myRoot.allYACriteriaTypes.getAtKey(critTypeStr.Integer);	//Cargo Type
								yaCriteria.setProxy(critType,critItemValues,critItemCode);
								yaCriteria.setPriorityValue(critItemPriority.asRealJMT);	
							
								yaCriteria.setYardAllocation(pxyStorageDetail);
						    endforeach;
							
					elseif  xmlNode.JadeXMLElement.tagName = "allFutureStorageMappings" then
					
							// FOR EACH FUTURE STORAGE MAPPING
							// EACH &lt;CM_FutureStorageMapping&gt;
							foreach xmlQuantityMapNode in xmlNode.childNodes do
								create pxyFSM transient;
								
								// EACH ATTRIBUTE
								foreach xmlFutureStorageObjectNode in xmlQuantityMapNode.childNodes do
									xmlTagStr := xmlFutureStorageObjectNode.JadeXMLElement.tagName;
									xmlNodeStr := xmlFutureStorageObjectNode.JadeXMLElement.textData;
									
									if  xmlTagStr = "CM_QuantityMap" then
											
											create qtyMap transient;
											pxyFSM.setQuantityMap(qtyMap);
											
											// FOR EACH QUANTITY MAP
											foreach xmlQuantityMapNode in xmlFutureStorageObjectNode.childNodes do
											
												xmlTagStr := xmlQuantityMapNode.JadeXMLElement.tagName;
												xmlNodeStr := xmlQuantityMapNode.JadeXMLElement.textData;
												
												if xmlTagStr = "chargeZero" then
													chargeZero:= xmlNodeStr.Boolean;
													qtyMap.setChargeZero( chargeZero);
												elseif xmlTagStr = "mappingType" then
													mappingType :=xmlNodeStr.Integer;
													qtyMap.setMappingType(mappingType );
												elseif  xmlTagStr = "myCalculationType" then
													calcTypeCode:=xmlNodeStr.String;
													calcType :=app.myRoot.allCalculationTypesByCode[calcTypeCode];
													qtyMap.setMyCalculationType(calcType);
												elseif  xmlTagStr = "allQuantityRanges" then
														foreach  xmlAllQtyMaps in xmlQuantityMapNode.childNodes do
															create qtyRangeMap transient;
															foreach xmlQtyMapNode in xmlAllQtyMaps.childNodes do
																xmlTagStr := xmlQtyMapNode.JadeXMLElement.tagName;
																xmlNodeStr := xmlQtyMapNode.JadeXMLElement.textData;
																
																if xmlTagStr = "rangeStart" then
																	rangeStart := xmlNodeStr.Integer;
																elseif  xmlTagStr = "rangeEnd" then
																	rangeEnd := xmlNodeStr.Integer;
																elseif  xmlTagStr = "rangeType" then
																	rangeType := xmlNodeStr.Integer;
																elseif  xmlTagStr = "allTMInvoiceLineMappings" then
																	
																	foreach xmlAllInvLineMap in xmlQtyMapNode.childNodes do
																		create pxyInvLineMapping transient;
																		
																		foreach xmlInvLineMap in xmlAllInvLineMap.childNodes do
																			xmlTagStr := xmlInvLineMap.JadeXMLElement.tagName;
																			xmlNodeStr := xmlInvLineMap.JadeXMLElement.textData;
																			if xmlTagStr = "mapValue" then
																				mapValue :=xmlNodeStr.Integer;
																			elseif  xmlTagStr =  "myTMInvoiceLineDesc" then
																				invoiceLineDescStr := xmlNodeStr.String;
																				invoiceLineDesc := bank.invoiceLineDescriptors[invoiceLineDescStr];
																				if invoiceLineDesc = null then																										//08 Feb 2018 jlgmd1 TFS #36934
																					create err transient;																											//08 Feb 2018 jlgmd1 TFS #36934
																					err.setErrorText("Invoice Line Type '" &amp; invoiceLineDescStr &amp; "' does not exist in terminal '" &amp;_term.code &amp; "'", false);		//08 Feb 2018 jlgmd1 TFS #36934
																					if not _errorStore.includes(err) then																							//08 Feb 2018 jlgmd1 TFS #36934
																						_errorStore.add(err);																										//08 Feb 2018 jlgmd1 TFS #36934
																					endif;																															//08 Feb 2018 jlgmd1 TFS #36934
																				endif;																																//08 Feb 2018 jlgmd1 TFS #36934
																			elseif  xmlTagStr =  "myTransferType" then
																				transferTypeInt := xmlNodeStr.Integer;
																				transferType := app.myRoot.allVoyageJobTransferTypes[transferTypeInt];
																				if transferType = null then
																					create err transient;
																					err.setErrorText("Transfer Type '" &amp; transferTypeInt.String &amp; "' does not exist in terminal '" &amp;_term.code &amp; "'", false);
																					if not _errorStore.includes(err) then
																						_errorStore.add(err);
																					endif;
																				endif;
																			elseif  xmlTagStr =  "myVesselCategory" then
																				vesselCatCode := xmlNodeStr.String;
																				vesselCategory := app.myRoot.allVesselCategories[vesselCatCode];
																				if vesselCategory = null then
																					create err transient;
																					err.setErrorText("Vessel Category '" &amp; vesselCatCode &amp; "' does not exist in terminal '" &amp;_term.code &amp; "'", false);
																					if not _errorStore.includes(err) then
																						_errorStore.add(err);
																					endif;
																				endif;
																			elseif  xmlTagStr =  "CM_TranMapInvoiceLineGroupType" then 
																				
																				foreach xmlinvLineGroupType in xmlInvLineMap.childNodes do
																					if xmlinvLineGroupType.JadeXMLElement.tagName ="type" then
																						invLineGrpType :=xmlinvLineGroupType.JadeXMLElement.textData.Integer;
																					elseif  xmlinvLineGroupType.JadeXMLElement.tagName ="name" then
																						invLineGrpName :=xmlinvLineGroupType.JadeXMLElement.textData.String;
																					endif;
																				endforeach;
																				realInvLineGroupType := root.allTMInvLineGrpTypes[invLineGrpType];
																			endif;
																		endforeach;
																		
																		pxyInvLineMapping.update(mapValue, invoiceLineDesc, qtyRangeMap, realInvLineGroupType, transferType, vesselCategory, null, null, null);
																	endforeach;
																//14/06/2023	navkc1	CR 58024 Task 58025 - Child Quantity Map
																elseif xmlTagStr = "CM_QuantityMapSub" then
																	
																	create qtyMapChild transient;
																	
																	foreach xmlQuantityMapNodeChild in xmlQtyMapNode.childNodes do
																		xmlTagStr := xmlQuantityMapNodeChild.JadeXMLElement.tagName;
																		xmlNodeStr := xmlQuantityMapNodeChild.JadeXMLElement.textData;
																		
																		if xmlTagStr = "chargeZero" then
																			chargeZeroSub := xmlNodeStr.Boolean;
																		elseif xmlTagStr = "mappingType" then
																			mappingTypeSub := xmlNodeStr.Integer;
																		elseif xmlTagStr = "myCalculationType" then
																			calcTypeCode:=xmlNodeStr.String;
																			calcTypeSub :=app.myRoot.allCalculationTypesByCode[calcTypeCode];
																			qtyMapChild.setMyCalculationType(calcTypeSub);
																		elseif xmlTagStr = "allQuantitySubRanges" then
																			// Child Quantity Map ranges
																			foreach xmlAllQtyMapsChild in xmlQuantityMapNodeChild.childNodes do
																				
																				create qtyRangeMapChild transient;
																				
																				foreach xmlQtyMapNodeChild in xmlAllQtyMapsChild.childNodes do
																					xmlTagStr := xmlQtyMapNodeChild.JadeXMLElement.tagName;
																					xmlNodeStr := xmlQtyMapNodeChild.JadeXMLElement.textData;
																					
																					if xmlTagStr = "rangeStart" then
																						rangeStartSub := xmlNodeStr.Integer;
																					elseif xmlTagStr = "rangeEnd" then
																						rangeEndSub := xmlNodeStr.Integer;
																					elseif xmlTagStr = "rangeType" then
																						rangeTypeSub := xmlNodeStr.Integer;
																					elseif xmlTagStr = "allTMInvoiceLineMappings" then
																						// Child Quantity Map Range Invoice Line
																						foreach xmlAllInvLineMap in xmlQtyMapNodeChild.childNodes do
																							create pxyInvLineMapping transient;
																							
																							foreach xmlInvLineMap in xmlAllInvLineMap.childNodes do
																								xmlTagStr := xmlInvLineMap.JadeXMLElement.tagName;
																								xmlNodeStr := xmlInvLineMap.JadeXMLElement.textData;
																								if xmlTagStr = "mapValue" then
																									mapValue :=xmlNodeStr.Integer;
																								elseif  xmlTagStr =  "myTMInvoiceLineDesc" then
																									invoiceLineDescStr := xmlNodeStr.String;
																									invoiceLineDesc := bank.invoiceLineDescriptors[invoiceLineDescStr];
																									if invoiceLineDesc = null then																										//08 Feb 2018 jlgmd1 TFS #36934
																										create err transient;																											//08 Feb 2018 jlgmd1 TFS #36934
																										err.setErrorText("Invoice Line Type '" &amp; invoiceLineDescStr &amp; "' does not exist in terminal '" &amp;_term.code &amp; "'", false);		//08 Feb 2018 jlgmd1 TFS #36934
																										if not _errorStore.includes(err) then																							//08 Feb 2018 jlgmd1 TFS #36934
																											_errorStore.add(err);																										//08 Feb 2018 jlgmd1 TFS #36934
																										endif;																															//08 Feb 2018 jlgmd1 TFS #36934
																									endif;																																//08 Feb 2018 jlgmd1 TFS #36934
																								elseif  xmlTagStr =  "myTransferType" then
																									transferTypeInt := xmlNodeStr.Integer;
																									transferType := app.myRoot.allVoyageJobTransferTypes[transferTypeInt];
																									if transferType = null then
																										create err transient;
																										err.setErrorText("Transfer Type '" &amp; transferTypeInt.String &amp; "' does not exist in terminal '" &amp;_term.code &amp; "'", false);
																										if not _errorStore.includes(err) then
																											_errorStore.add(err);
																										endif;
																									endif;
																								elseif  xmlTagStr =  "myVesselCategory" then
																									vesselCatCode := xmlNodeStr.String;
																									vesselCategory := app.myRoot.allVesselCategories[vesselCatCode];
																									if vesselCategory = null then
																										create err transient;
																										err.setErrorText("Vessel Category '" &amp; vesselCatCode &amp; "' does not exist in terminal '" &amp;_term.code &amp; "'", false);
																										if not _errorStore.includes(err) then
																											_errorStore.add(err);
																										endif;
																									endif;
																								elseif  xmlTagStr =  "CM_TranMapInvoiceLineGroupType" then 
																									
																									foreach xmlinvLineGroupType in xmlInvLineMap.childNodes do
																										if xmlinvLineGroupType.JadeXMLElement.tagName ="type" then
																											invLineGrpType :=xmlinvLineGroupType.JadeXMLElement.textData.Integer;
																										elseif  xmlinvLineGroupType.JadeXMLElement.tagName ="name" then
																											invLineGrpName :=xmlinvLineGroupType.JadeXMLElement.textData.String;
																										endif;
																									endforeach;
																									realInvLineGroupType := root.allTMInvLineGrpTypes[invLineGrpType];
																								endif;
																							endforeach;
																							
																							pxyInvLineMapping.update(mapValue, invoiceLineDesc, qtyRangeMapChild, realInvLineGroupType, transferType, vesselCategory, null, null, null);
																						endforeach;
																					endif;
																					
																					qtyRangeMapChild.setProxy(qtyMapChild, rangeStartSub, rangeEndSub, rangeTypeSub);
																				endforeach;
																			endforeach;
																		endif;
																		
																	endforeach;
																	qtyMapChild.setProxy(qtyRangeMap, chargeZeroSub, mappingTypeSub, calcTypeSub, null);
																//14/06/2023	navkc1	CR 58024 Task 58025 - Child Quantity Map end
																endif;
															endforeach;
															qtyRangeMap.setProxy(qtyMap,rangeStart,rangeEnd,rangeType);
														endforeach;
													
												endif;
											endforeach;
											qtyMap.setProxy(null,chargeZero,mappingType,calcType,pxyFSM);
											
									elseif  xmlTagStr = "CM_TerminalAreaStorageGroup" then
											foreach  xmlAllCriteriaNode in xmlFutureStorageObjectNode.childNodes do
												xmlTagStr := xmlAllCriteriaNode.JadeXMLElement.tagName;
												xmlNodeStr := xmlAllCriteriaNode.JadeXMLElement.textData;
												if xmlTagStr = "code" then
													stcode :=xmlNodeStr.String;
												elseif  xmlTagStr = "description" then
													stdescription := xmlNodeStr.String;
												endif;
											endforeach;
											
											realStorageGroup := _term.allTerminalAreaStorageGroups[stcode];
											if realStorageGroup &lt;&gt; null then
												pxyFSM.setMyStorageGroup(realStorageGroup);
											else
												create err transient;
												err.setErrorText("Terminal Area Storage Group '" &amp; stcode &amp; "' does not exist in terminal '" &amp;_term.code &amp; "'", false);
												if not _errorStore.includes(err) then
													_errorStore.add(err);
												endif;

											endif;
											
									endif;

								endforeach;
								
								if _errorStore.isEmpty() then
									pxyFSM.setStorageDetail(pxyStorageDetail);
								endif;
							endforeach;
					//14/06/2023	navkc1	CR 58024 Task 58025 - Additional Calendars in Storage Details
					elseif xmlNode.JadeXMLElement.tagName = "allAdditionalCalendars" then
						create allAdditionalCalendar transient;
						allCalendarTransients.add(allAdditionalCalendar);
						foreach xmlAllAdditionalCalendarNode in xmlNode.childNodes do
							
							foreach xmlAdditionalCalendarNode in xmlAllAdditionalCalendarNode.childNodes do
								xmlTagStr := xmlAdditionalCalendarNode.JadeXMLElement.tagName;
								xmlNodeStr := xmlAdditionalCalendarNode.JadeXMLElement.textData;
								
								if xmlTagStr = "code" then
									ccode :=xmlNodeStr.String;
								elseif  xmlTagStr = "description" then
									// We don't really need to process description during LOAD
									continue;
									cdesc := xmlNodeStr.String;
								endif;
								
								additionalCalendar := root.allCalendars[ccode];
								if additionalCalendar = null then
									create err transient;
									err.setErrorText("Additional Calendar '" &amp; ccode &amp; "' does not exist in system", false);
									if not _errorStore.includes(err) then
										_errorStore.add(err);
									endif;
									continue;
								endif;
								
								if not allAdditionalCalendar.includes(additionalCalendar) then
									allAdditionalCalendar.add(additionalCalendar);
								endif;
							endforeach;
						endforeach;
					//14/06/2023	navkc1	CR 58024 Task 58025 - Additional Calendars in Storage Details end
					endif;
				endforeach;
				
				if _errorStore.isEmpty() then
					pxyStorageDetail.setValues(chargedDaysType.Integer,freeDaysType.Integer,freeStorageDays.Integer,proxyStorageConfig, chargeDays.Integer,
															0,stopCompletionFreeDays.Integer, receivalDateRule.Integer, noStorageIfNotFullyReceived.Boolean,fsStop, description, detailRoadReceival.Integer, detailShipReceival.Integer, detailRailReceival.Integer, detailChildReceival.Integer, allAdditionalCalendar,
															cooFreeDays.Integer, cooFreeDaysType.Integer, stoDtlIncludeFirstDay.asBooleanJMT(), stoDtlIncludeLastDay.asBooleanJMT()); //21.07.2017 cnwma1 TFS #5409
					pxyStorageDetail.setProxy(code, description, "", 0,0,expiryType.Integer, expiryDate.Date, color.Integer, 
														false, 0, 0, null,0, false, false, null, null,false,_term);
				endif;
			endforeach;
		elseif xmlElement.tagName = "myWorkingDaysCalendar" then
		
			foreach xmlNodeStorageConfig in xmlElement.childNodes do


				// EACH ATTRIBUTE ON STORAGE DETAIL	
				foreach xmlNode  in xmlNodeStorageConfig.childNodes do
					xmlTagStr := xmlNode.JadeXMLElement.tagName;
					xmlNodeStr := xmlNode.JadeXMLElement.textData;
					
					
					if xmlTagStr = "code" then
						ccode :=xmlNodeStr.String;
					elseif  xmlTagStr = "description" then
						cdesc := xmlNodeStr.String;
					endif;
				endforeach;
				
				realCalendar := root.allCalendars[ccode];
				if realCalendar = null then
					create err transient;
					err.setErrorText("Calendar '" &amp; ccode &amp; "' does not exist in system", false);
					if not _errorStore.includes(err) then
						_errorStore.add(err);
					endif;
				endif;
				realCalendar := _term.allCalendars[ccode];
				if realCalendar = null then
					create err transient;
					err.setErrorText("Calendar '" &amp; ccode &amp; "' does not exist in terminal '" &amp;_term.code &amp; "'", false);
					if not _errorStore.includes(err) then
						_errorStore.add(err);
					endif;
				endif;
				
			endforeach;
			
		//20 Sep 2017	NDL	TFS 7032
		elseif xmlElement.tagName = "myCompulsoryCalendar" then
		
			foreach xmlNodeStorageConfig in xmlElement.childNodes do


				// EACH ATTRIBUTE ON STORAGE DETAIL	
				foreach xmlNode  in xmlNodeStorageConfig.childNodes do
					xmlTagStr := xmlNode.JadeXMLElement.tagName;
					xmlNodeStr := xmlNode.JadeXMLElement.textData;
					
					
					if xmlTagStr = "code" then
						ccode :=xmlNodeStr.String;
					elseif  xmlTagStr = "description" then
						cdesc := xmlNodeStr.String;
					endif;
				endforeach;
				
				realCompulsory := root.allCalendars[ccode];
				if realCompulsory = null then
					create err transient;
					err.setErrorText("Calendar '" &amp; ccode &amp; "' does not exist in system", false);
					if not _errorStore.includes(err) then
						_errorStore.add(err);
					endif;
				endif;
				realCompulsory := _term.allCalendars[ccode];
				if realCompulsory = null then
					create err transient;
					err.setErrorText("Calendar '" &amp; ccode &amp; "' does not exist in terminal '" &amp;_term.code &amp; "'", false);
					if not _errorStore.includes(err) then
						_errorStore.add(err);
					endif;
				endif;
				
			endforeach;
		
		
		elseif xmlElement.tagName = "allStorageTriggers" then
			// FOR EACH STORAGE TRIGGER &lt;/CM_StorageTrigger&gt;
			foreach xmlNodeStorageTrig in xmlElement.childNodes do
				create pxyStorageTrigger transient;

				foreach xmlNodeStorageTrigObj in xmlNodeStorageTrig.childNodes do
						xmlTagStr := xmlNodeStorageTrigObj.JadeXMLElement.tagName;
						xmlNodeStr := xmlNodeStorageTrigObj.JadeXMLElement.textData;
						
						if xmlTagStr = "attributeType" then
							attributeType :=xmlNodeStr.Integer;
						elseif  xmlTagStr = "resetFreeStorageDays" then
							resetFreeStorageDays := xmlNodeStr.Boolean;
						endif;
				endforeach;
			
				if _errorStore.isEmpty() then
					pxyStorageTrigger.setProxy(attributeType, resetFreeStorageDays, proxyStorageConfig);
				endif;
			endforeach;
		elseif xmlElement.tagName = "allYACriteriaTypes" then
			create allCriTypes transient;
			// FOR EACH CRITERIA TYPE &lt;CM_YACriteriaType&gt;
			foreach xmlNodeCriteria in xmlElement.childNodes do
				foreach xmlNodeCriteriaObj in xmlNodeCriteria.childNodes do
						xmlTagStr := xmlNodeCriteriaObj.JadeXMLElement.tagName;
						xmlNodeStr := xmlNodeCriteriaObj.JadeXMLElement.textData;
						
						if xmlTagStr = "description" then
							criDesc :=xmlNodeStr.String;
						elseif  xmlTagStr = "isUsed" then
							crIsUsed := xmlNodeStr.Boolean;
						elseif  xmlTagStr = "type" then
							criType := xmlNodeStr.Integer;
						endif;
				endforeach;
				realCriType := root.allYACriteriaTypes[criType];
				if realCriType &lt;&gt; null then
					allCriTypes.addExclusive(realCriType);
				endif;
			endforeach;
		endif;
	endwhile;

	if _errorStore.isEmpty() then
		proxyStorageConfig.setProxy(allCriTypes,null,firstDayTimeCutoff.Time,includeFirstDay.Boolean, includeLastDay.Boolean, 
											_term, shipReceivalType.Integer, shipReleaseType.Integer, realCalendar, realCompulsory, roadReceival.Integer, railReceival.Integer, childReceival.Integer);
		return true;		//08 Feb 2018 jlgmd1 TFS #36934
	endif;
	
	return false;			//08 Feb 2018 jlgmd1 TFS #36934
epilog
	on Exception do null;
	delete iter;
	delete allCriTypes;
	
	foreach obj in allCalendarTransients do
		delete obj;
	endforeach;
	
	delete allCalendarTransients;
end;</source>
        <Parameter name="_jadeXMLElement" type="JadeXMLElement" usage="input"/>
        <Parameter name="_errorStore" type="CM_ErrorSet" usage="input"/>
        <Parameter name="_term" type="CM_Terminal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="9c304c46-da26-48fd-8076-bb94b5446e35">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
// 10 Oct 2017    jlgrh7 TFS #7228 ADP - Storage Configuration Validation and Auditing

*/

vars
	propName	: String;
begin
	if _property = null then
		return false;
	endif;
	propName := _property.name;
	
	if	propName = CM_StorageConfig::allYACriteriaTypes.name or
		propName = CM_StorageConfig::allStorageTriggers.name or 
		propName = CM_StorageConfig::includeFirstDay.name or
		propName = CM_StorageConfig::includeLastDay.name or
		propName = CM_StorageConfig::firstDayTimeCutoff.name or
		propName = CM_StorageConfig::shipReceivalType.name or
		propName = CM_StorageConfig::shipReleaseType.name
		then
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;
epilog
end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="b60ee4c2-e839-4943-8578-bdd9fdce767e">
        <source>validateForCreate();
// 13 September 2012	cnwjre1	CCMS SFW 1295 Free Storage Days
begin

	if self.myTerminal = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "Config Terminal", null, null);
		app.raiseCMException(Input_required_field_confTerm, null, null); // cnwdb2	PAR 35364
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="c9327fa1-f43b-4b89-ad30-bbb48c926954">
        <source>validateForDelete();
// 13 September 2012	cnwjre1	CCMS SFW 1295 Free Storage Days
// 06 Oct 2017	jlgrh7 TFS7228 ADP - Storage Configuration Validation and Auditing
vars
	realStorageDetail : CM_StorageDetail;			//+TFS7228
	realYaCriteria			: CM_YACriteria;					//+TFS7228
	foundCriteriaUsed : Boolean;								//+TFS7228
begin
// TFS7228  Starts Get All Data from Proxy Object
	foreach realStorageDetail in  self.allStorageDetails do : searchCriteriaData                  
		foreach realYaCriteria in realStorageDetail.allCriteria do			
			if realYaCriteria.myYAData.getDataValue &lt;&gt; null then
				foundCriteriaUsed := true;
				break searchCriteriaData;
			endif;
		endforeach;
	endforeach;
	if foundCriteriaUsed then
		app.raiseCMException1(ERR_Delete_StorageConfig, realYaCriteria.myYACriteriaType.description, null,null);
	endif;

epilog
end;
</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="8f2a37d2-ada9-4ea0-a342-759c2e293ace">
        <source>validateForUpdate(_realStorageConfig : CM_StorageConfig );
// 13 September 2012	cnwjre1	CCMS SFW 1295 Free Storage Days
// 06 Oct 2017	jlgrh7 TFS7228 ADP - Storage Configuration Validation and Auditing

vars
	
	pxyYaCriteriaType: CM_YACriteriaType;
	realYaCriteriaType : CM_YACriteriaType;
	
	
	realStorageDetail : CM_StorageDetail;			//+TFS7228
	realYaCriteria			: CM_YACriteria;					//+TFS7228
	pxyYaCriteriaDesArray : StringArray;				//+TFS7228
	foundCriteria : Boolean;											//+TFS7228
	
begin
	
	if self.myTerminal = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "Config Terminal", null, null);
		app.raiseCMException(Input_required_field_confTerm, null, null); // cnwdb2	PAR 35364
	endif;
	// TFS7228  Starts Get All Data from Proxy Object
	create pxyYaCriteriaDesArray transient;
	foreach pxyYaCriteriaType in  self.allYACriteriaTypes do
		if not pxyYaCriteriaDesArray.includes(pxyYaCriteriaType.description) then
			pxyYaCriteriaDesArray.add(pxyYaCriteriaType.description);
		endif;
	endforeach;
	
	foreach realYaCriteriaType in _realStorageConfig.allYACriteriaTypes do				//Find difference from Real Object
		if not pxyYaCriteriaDesArray.includes(realYaCriteriaType.description) then	//RealYaCriteriaType has been deleted		
			if _realStorageConfig.allStorageDetails.size() &gt;0 then
					foreach realStorageDetail in  _realStorageConfig.allStorageDetails do : searchCriteriaData                  
							foreach realYaCriteria in realStorageDetail.allCriteria where realYaCriteria.myYACriteriaType.description =realYaCriteriaType.description do
									if realYaCriteria.myYAData.getDataValue &lt;&gt; null then
										foundCriteria := true;
										break searchCriteriaData;
									endif;
							endforeach;
					endforeach;
				endif;
			if foundCriteria then
				app.raiseCMException1(ERR_Delete_StorageConfigAttr, realYaCriteria.myYACriteriaType.description, null,null);
			endif;
				
		endif;
	endforeach;
	
epilog
	delete pxyYaCriteriaDesArray;
end;</source>
