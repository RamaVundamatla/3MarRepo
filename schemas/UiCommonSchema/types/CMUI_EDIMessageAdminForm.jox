    <JadeMethod name="addToolbarControls" id="a56eb7a1-f89c-4034-8473-594cd4315c4e">
        <updating/>
        <source>addToolbarControls() updating, protected;
// ---------------------------------------------------------------------------
// Created:     20 April 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	frm			: CMUI_Toolbar;
	canUpdate	:Boolean;
begin	
	canUpdate := app.myCurrentUserCan(self.myTerminal, self.permissionMaint);
	
	frm := self.frmToolbar;
	frm.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnExportCSVQE, CMUI_Toolbar.Control_Alignment_Left);
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnShowSearcher, CMUI_Toolbar.Control_Alignment_Left);
	
	if canUpdate then
		frm.addButton(self.btnEditItem, CMUI_Toolbar.Control_Alignment_Left);
		frm.addButton(self.btnDelete, CMUI_Toolbar.Control_Alignment_Left);
	endif;
	
	frm.addButton(self.btnSelectAll, CMUI_Toolbar.Control_Alignment_Left);
	
	if canUpdate then
		frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
		frm.addButton(self.btnShowLoadNew, CMUI_Toolbar.Control_Alignment_Left);
		frm.addButton(self.btnExtractNew, CMUI_Toolbar.Control_Alignment_Left);
	endif;
	
	inheritMethod();
	
	self.addToolbarControlsLoadFile;
end;</source>
        <access>protected</access>
    </JadeMethod>
