        <source>btnEditStatus_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		27 May 2009 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	editForm		: GTE_EditBookRefStatusForm;
	allBookingRefs	: CM_BookingRefSet;
	
begin
	create allBookingRefs transient;
	tblData.allSelectedObjects.copy(allBookingRefs);
	
	if allBookingRefs.isEmpty() then
		return;
	endif;
	
	create editForm transient;
	editForm.setBookingRefs(allBookingRefs);
	editForm.setMyTerminal(self.myTerminal);
	editForm.showModal();
epilog
	delete allBookingRefs;
end;</source>
