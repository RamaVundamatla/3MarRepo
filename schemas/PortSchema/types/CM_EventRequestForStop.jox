    <JadeMethod name="pxyCreateUpdateProxy" id="6ba10bf7-d78e-429b-a72d-0174b3edee18">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 May 2019	jlgndl1	Initial creation	TFSD 43918

*/

vars

	pxy	: CM_EventRequestForStop;
	completedOK : Boolean;

begin

	pxy := inheritMethod();
	
	pxy.myGrade := self.myGrade;
	pxy.myToDoTaskDesc := self.myToDoTaskDesc;
	
	completedOK := true;
	return pxy;

epilog

	if not completedOK then
		delete pxy;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="raiseAlert" id="9f5d7a16-3dd7-42f6-97f9-922328b5aec3">
        <source>raiseAlert( _ti : CM_TrackedItem; _str : String );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 May 2019	jlgndl1	Initial creation	TFS 43918

*/

vars

	msg : String;

begin

	msg := _ti.id &amp; " - " &amp; _str;
	app.createAlert( msg, true );

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_str" type="String"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="71ff1c97-f906-4f0e-afed-7532e2860101">
        <updating/>
        <source>setForCreate(_pxyEventRequest: CM_EventRequestForStop; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 May 2019	jlgndl1	Initial creation	TFS 43918

*/

vars

	realStopTableTemplate : CM_StopTableTemplate;
	pxyStopTable : CM_StopsTable;
	stopTable : CM_StopsTable;
	terminal : CM_Terminal;

begin

	inheritMethod(_pxyEventRequest, _passport);
	
	if _pxyEventRequest.myStopTableTemplate &lt;&gt; null then
		stopTable := _pxyEventRequest.myStopTableTemplate.myStopTable;
		if stopTable &lt;&gt; null and stopTable.isTransient then
			pxyStopTable := stopTable;
			stopTable := pxyStopTable.pxyGetRealObject();
		endif;
		terminal := _pxyEventRequest.myStopTableTemplate.myTerminal;
		if terminal &lt;&gt; null and stopTable &lt;&gt; null then
			realStopTableTemplate := stopTable.allStopTableTemplates.getAtKey( terminal, stopTable );
		endif;
	endif;
	
	if realStopTableTemplate &lt;&gt; null then
		self.setMyStopTemplate( realStopTableTemplate );
	endif;
	
	

epilog

end;</source>
        <Parameter name="_pxyEventRequest" type="CM_EventRequestForStop"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMyStopTemplate" id="d3a238aa-ef75-4859-a946-e1a93220ea61">
        <updating/>
        <source>setMyStopTemplate( _myStopTableTemplate : CM_StopTableTemplate ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 May 2019	jlgndl1	Initial creation	TFS 43918

*/

vars

begin

	self.myStopTableTemplate := _myStopTableTemplate;

epilog

end;</source>
        <Parameter name="_myStopTableTemplate" type="CM_StopTableTemplate"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="5088d707-668c-4b4b-b6df-6198e3462aa2">
        <source>validateMe(_passport: CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 May 2019	jlgndl1	Initial creation	TFS 43918

*/

vars

	address : String;

begin

	if self.type &lt;= EventRequestTypeNull
	or self.type &gt;= EventRequestTypeMax then
		app.raiseCMException(Input_required_field_type, null, null); 
	endif;
	
	foreach address in self.allEmailAddresses do
		app.validateEmailAddress(address);
	endforeach;
	
	if self.isNotify and self.allEmailAddresses.isEmpty then
		app.raiseCMException(Input_required_field_recipient, ETRow_EmailAddress, null); 
	endif;
	
	if _passport.hasErrors then
		return;
	endif;
	
	if self.type = EventRequestTypeGrade then
		if self.myGrade = null then
			app.raiseCMException(Input_required_field_grade,null,null);
		endif;	
	endif;
	
	if self.type = EventRequestTypeToDo then
		if self.myToDoTaskDesc = null then
			app.raiseCMException(Input_required_field_toDo,null,null);
		endif;
	endif;
	
	if self.type = EventRequestTypeRemarks then
		if self.cargoRemarks = null then
			app.raiseCMException(Input_required_remarks,null,null);
		endif;
	endif;
	
	if self.type = EventRequestTypeWeight then
		if self.totalWeight = NULL_WEIGHT then
			app.raiseCMException(Total_weight_should_not_zero, null,null); 
		endif;
		
		if self.myTerminal.getConfig(CertifiedWeightNeedsVGM).Boolean then									
			if self.isWeightCertified and self.weightCertifiedName = null and self.reference = null then	
				app.raiseCMException(Weigh_certi_name_must_entered, null, null);							
			endif;																							
		endif;																								
	endif;

epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
