    <JadeMethod name="showAdditionalRemarks" id="b6c06582-f9ab-44ab-8d4e-3a7cee3bf673">
        <source>showAdditionalRemarks( _rem1 : String; _rem2 : String );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 May 2018	jlgndl1	Initial creation	TFS 38566

*/

vars

	msg : String;

begin

	if _rem1.trimBlanks &lt;&gt; null then
		msg := app.getEntTableRowTranslation(ETRow_RemarksAdditional1,ETGrp_CargoDetails) &amp; ":" &amp; CrLf &amp; Tab &amp; _rem1;
	endif;
	if _rem2.trimBlanks &lt;&gt; null then
		if msg.trimBlanks &lt;&gt; null then
			msg := msg  &amp; CrLf;
		endif;
		msg := msg  &amp; app.getEntTableRowTranslation(ETRow_RemarksAdditional2,ETGrp_CargoDetails) &amp; ":" &amp; CrLf &amp; Tab &amp; _rem2;
	endif;

	if msg.trimBlanks &lt;&gt; null then	
		app.msgBox( msg, app.getErrorString(Attention), MsgBox_OK_Only );
	endif;

epilog

end;</source>
        <Parameter name="_rem1" type="String"/>
        <Parameter name="_rem2" type="String"/>
    </JadeMethod>
    <JadeMethod name="showBulkReleaseDtl" id="49b05346-686a-48d1-8407-de7aa1af85fc">
        <source>showBulkReleaseDtl();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 September 2011	cnwndl1	Initial creation	Par 24455

*/

vars

	data : String;
	assistant : GTE_Assistant;
	bulkRelease	: CM_BulkRelease;
	aSheet : GTE_Sheet;
	cnt, idx : Integer;
	extraTbl, mainTbl : CM_EntryTable;
	aTI : CM_TrackedItem;
	txtBRStr : String;
	reserve : CM_ReserveDetail;
	invalidBulkRelease : Boolean;
	
begin

	on Exception do app.handleDeletedObject(exception, bulkRelease, invalidBulkRelease);
	
	self.btnRelAction.enabled := false;
	
	if self.tblBulkRelease.row &gt; self.tblBulkRelease.fixedRows 
	and self.tblBulkRelease.accessRow(self.tblBulkRelease.row).selected then

		reserve := self.tblBulkRelease.accessRow(self.tblBulkRelease.row).itemObject.CM_ReserveDetail;
		bulkRelease := reserve.myReserveHeader;
	
		txtBRStr := "Total Requested" &amp; Tab &amp; reserve.getDisplayStringForAttribute(ETRow_TotalRequested, false) &amp; CrLf &amp;
					"Outstanding" &amp; Tab &amp;  reserve.getDisplayStringForAttribute(ETRow_QuantityRemaining, false) &amp; CrLf &amp;
					
					"Being Actioned" &amp; Tab &amp; reserve.getDisplayStringForAttribute(ETRow_RequestsBeingActioned, false) &amp; CrLf &amp;
					"Delivered To Date" &amp; Tab &amp; bulkRelease.getDisplayStringForAttribute(ETRow_DeliveredToDate, false) &amp; CrLf  &amp;
					reserve.getReleaseDetails();
		// ### ITEMS Assigned
		data := "";
		foreach aTI in bulkRelease.allTrackedItemsAssigned do
			if data = null then
				data := aTI.id;
			else
				data := data &amp; ', ' &amp; aTI.id;
			endif;
		endforeach;
		txtBRStr := txtBRStr &amp; CrLf &amp; "Attachments:" &amp; Tab &amp; data &amp; CrLf;		
		// ### ITEMS Delivered
		cnt := bulkRelease.releasedItemStrings.size;
		data := "";
		if cnt &gt; 0 then
			foreach idx in 1 to cnt do
				data := data &amp; bulkRelease.releasedItemStrings[idx] &amp; CrLf;		
			endforeach;
		endif;		
		txtBRStr := txtBRStr &amp;  CrLf &amp; "Items Delivered:" &amp; CrLf &amp; data;		
		
		if invalidBulkRelease then 
			return;
		endif;
		
		self.txtBulkRelease.text := txtBRStr;
		
		if self.myRealVVR &lt;&gt; null and (not self.myRealVVR.isIncomplete) then
			self.btnRelAction.enabled := false;
		else
			self.btnRelAction.enabled := true;
		endif;
		
	endif;

end;</source>
    </JadeMethod>
