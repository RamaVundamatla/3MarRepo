    <JadeMethod name="buildListEntries" id="b9541477-fabe-4433-a118-3a274e0fc5f9">
        <source>buildListEntries():String protected;
// --------------------------------------------------------------------------------
// Created:		06 December 2001 by cnwdad1
//
// Purpose:		Build the HTML for the list entries, and return the result.
//
// Parameters:	None
//
// Returns:		The HTML stream.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	listEntry	: String;
	htmlString	: String;
	
begin
	if self.allListEntries.cnEcIsNotEmpty() then
		foreach listEntry in self.allListEntries do
			htmlString	:=	'&lt;LI&gt;' &amp; listEntry &amp; '&lt;/LI&gt;' &amp; CrLf;
		endforeach;
	else
		foreach listEntry in self.allHugeListEntries do
			htmlString	:=	'&lt;LI&gt;' &amp; listEntry &amp; '&lt;/LI&gt;' &amp; CrLf;
		endforeach;
	endif;
epilog
	return htmlString;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getListEntry" id="c7a8472c-0634-4a1e-9b1f-50e7cfe94565">
        <source>getListEntry(pEntryIndex:Integer):String protected;
// -----------------------------------------------------------------------------
// Created:		09 December 2001 by cnwdad1
//
// Purpose:		Return a list entry for the specified element index.
//
// Parameters:	None
//
// Returns:		The list entry string value.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	if self.allListEntries.cnEcIsNotEmpty() then
		if pEntryIndex &gt; 0 and pEntryIndex &lt;= self.allListEntries.size() then
			return self.allListEntries[pEntryIndex];
		else
			return null;
		endif;
	else
		if pEntryIndex &gt; 0 and pEntryIndex &lt;= self.allHugeListEntries.size() then
			return self.allHugeListEntries[pEntryIndex];
		else
			return null;
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pEntryIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isValidType" id="56973dd3-af27-494f-98db-49dc9fec926a">
        <source>isValidType(pType:String):Boolean protected, abstract;</source>
        <abstract/>
        <access>protected</access>
        <Parameter name="pType" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setListType" id="0768a01b-daeb-453f-8d4a-275d0113dda2">
        <updating/>
        <source>setListType(pType:String) updating;
// --------------------------------------------------------------------------------
// Created:		06 December 2001 by cnwdad1
//
// Purpose:		Set the type of list (i.e. ordered or unordered).
//
// Parameters:	pType - The type of list.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.isValidType(pType) then
		self.listType	:=	pType;
	endif;
end;</source>
        <Parameter name="pType" type="String"/>
    </JadeMethod>
</Class>
