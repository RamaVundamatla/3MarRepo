	self.setupCmdButtons( 2, app.getErrorString(Save), app.getErrorString(Back), null, null, null );
	
	self.setupControls();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="tblDamage_rowColumnChg" id="877a3045-b09e-4b28-9e02-38da47b317d5">
        <controlMethod name="Table::rowColumnChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblDamage_rowColumnChg(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 January 2015	cnwndl1	Initial creation	Par 35558

*/

vars

begin

	if table.row = table.rows and table.column = table.columns then
		self.tblDamage.addNewRow();
	endif;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="52af32ca-4b3a-4aaf-b823-dd00993931f7">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0015213, locale);
	lblDamageFor.translateCaption(Xlat_0015214, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
</GUIClass>
