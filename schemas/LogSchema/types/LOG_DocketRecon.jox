    <JadeMethod name="updateTableDisplays" id="73218682-f204-4759-af50-d6b737b8e590">
        <updating/>
        <source>updateTableDisplays(_object : Object; _eventType : Integer) updating;
//--------------------------------------------------------------
//Created: 31 October 2002 By: cnwgd1
//--------------------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	str			: String;
	rowIdx		: Integer;
	theTable	: CM_DataTable;
	bol			: CM_BOL;
	bolExt		: CM_BOLExtLog;
begin

	if _eventType = BOLRecon_Delete_Event or
	  (not global.isValidObject(_object)) then
	  	//Find object in table and remove it
	  	self.removeDeletedObject(_object);
	  	return;
	endif;
	
	//Belts and braces, not interested if object does not belong to this forms terminal
	//Find which table the object should be in
	if _object.isKindOf(CM_BOL) then
		bol := _object.CM_BOL;
		if bol.myTerminal &lt;&gt; self.myTerminal then
			return;
		endif;
		
		theTable := self.tblDocketData;
	elseif _object.isKindOf(CM_LogScalingHdr) then
		if _object.CM_LogScalingHdr.myTerminal &lt;&gt; self.myTerminal then
			return;
		endif;	
		theTable := self.tblHeaderData;
	elseif _object.isKindOf(CM_BOLOutHeader) then
		if _object.CM_BOLOutHeader.myTerminal &lt;&gt; self.myTerminal then
			return;
		endif;	
		theTable := self.tblHeaderData;		
	else
		//Not an object this form is interested in
		return;
	endif;

	//Get text to be displayed
	str := self.tableDataDisplayRow(theTable, _object.CM_Object);

	//Add new row to table	
	if _eventType = BOLRecon_Create_Event then
		if bol &lt;&gt; null and 
		   bol.myExtension &lt;&gt; null and 
		   (not bol.myExtension.isMatchedAndMoved) then
			rowIdx := theTable.addItem(str);
			theTable.accessRow(rowIdx).itemObject := _object;					
		else		  
			rowIdx := theTable.addItem(str);
			theTable.accessRow(rowIdx).itemObject := _object;					
		endif;	
		//rowIdx := theTable.addItem(str);
		//theTable.accessRow(rowIdx).itemObject := _object;		

	//Find object in table and update it
	elseif _eventType = BOLRecon_Update_Event then
		if theTable.findObjectInRow(_object, rowIdx) then
			theTable.removeItem(rowIdx);
		endif;
		if bol &lt;&gt; null and 
		   bol.myExtension &lt;&gt; null then
		   	if  (not bol.myExtension.isMatchedAndMoved) then
				rowIdx := theTable.addItem(str);
				theTable.accessRow(rowIdx).itemObject := _object;	
			endif;
		else
			// Must be scaling header.
			rowIdx := theTable.addItem(str);
			theTable.accessRow(rowIdx).itemObject := _object;					
		endif;
	//Remove matched object from table
	elseif _eventType = BOLRecon_Matched_Event then
		if bol &lt;&gt; null and bol.myExtension &lt;&gt; null then
			if bol.myExtension.isMatchedAndMoved then
				theTable.removeItemObject(_object);
		    endif;
		else
			theTable.removeItemObject(_object);
		endif;
	endif;

	//Reset the current selected object in table if need be
	self.resetTableSelected(theTable);
	
	//Resort the table (docket number order) and colour rows (blues)
	self.resortColourTable(theTable, 1);
		
end;</source>
        <Parameter name="_object" type="Object"/>
        <Parameter name="_eventType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="userNotify" id="fd9040bd-5085-445c-b24e-3bd61d9c0898">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
//--------------------------------------------------------------
//Created: 01 November 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	event : Integer;
begin
	event := self.myTerminal.getEventFromTerminalEvent(eventType);
	self.updateTableDisplays(userInfo.Object, event);
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</GUIClass>
