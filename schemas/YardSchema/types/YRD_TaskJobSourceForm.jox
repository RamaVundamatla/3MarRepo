    <JadeMethod name="checkAndSaveCurrent" id="03ef9e05-c64c-4159-b8e5-4a4e70231c2a">
        <updating/>
        <source>checkAndSaveCurrent() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 January 2010	cnwrd1	Initial creation

*/

vars
	idx : Integer;
	heading : String;
begin
	idx := self.lstSources.listIndex;
	if idx &lt; 1 then
		idx := 1;
	endif;
	
	if self.lstSources.itemLevel[idx] = 1 then
		heading := self.lstSources.text;
		if heading = self.headingBulkReleases then
			self.doAddBulkRelease();
		elseif heading = self.headingRequests then		
			if ( self.cmbISOGroup.listObject &lt;&gt; null or self.cmbReqISOType.listObject &lt;&gt; null ) and self.txtReqRequested.text &lt;&gt; null then
				self.doAddRequest();
			endif;
		elseif heading = self.headingWorkOrders then
			self.doAddWorkOrder();
		elseif heading = self.headingBookings then
			self.doAddBooking();
		endif;
		return;
	endif;

epilog

end;</source>
    </JadeMethod>
