    <JadeMethod name="attributeAreaAdd" id="86df72b4-efec-4c22-8fd8-8ec6257bfaeb">
        <source>attributeAreaAdd(_attrArea : CM_AttributeArea);
// ---------------------------------------------------------------------------
// Created:     24 March 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.attributeAreas.includes(_attrArea) then
		// remove and re-add at end
		self.attributeAreas.remove(_attrArea);
	endif;
	self.attributeAreas.add(_attrArea);

	if (not self.attributeAreasByTermAreaId.includes(_attrArea)) then
		self.attributeAreasByTermAreaId.add(_attrArea);
	endif;

end;</source>
        <Parameter name="_attrArea" type="CM_AttributeArea"/>
    </JadeMethod>
    <JadeMethod name="attributeAreaRemove" id="adfc6365-7697-4a6c-91e0-14eca15ff352">
