    <JadeMethod name="initializeForActivity" id="fb6c121a-a8ba-4f22-8869-0421276689a8">
        <updating/>
        <source>initializeForActivity(_ewsOpsView: CM_EWSActivityOpsview; _opsViewTable : CMIF_OpsViewTables) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 May 2022	navsp1	Initial creation TFS#53569

*/

vars
	n4Carrier	: CMIF_RefCarrierService;
begin
	if _opsViewTable.isKindOf(CMIF_RefCarrierService) then
		n4Carrier					:=	_opsViewTable.CMIF_RefCarrierService;
		n4Carrier.gkey		   		:= n4Carrier.generateFullGKey(self, "");
		n4Carrier.id                := n4Carrier.generateFullGKey(self, "").String;
		n4Carrier.name				:= self.description;
		n4Carrier.carrier_mode  	:= n4Carrier.Carrier_mode_Vessel;
		n4Carrier.life_cycle_state	:= n4Carrier.n4LifeCycleState(self);
	endif;
epilog

end;</source>
        <Parameter name="_ewsOpsView" type="CM_EWSActivityOpsview"/>
        <Parameter name="_opsViewTable" type="CMIF_OpsViewTables"/>
    </JadeMethod>
