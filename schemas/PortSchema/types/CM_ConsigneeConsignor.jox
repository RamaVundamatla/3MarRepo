    <JadeMethod name="setProxy" id="54e206cc-4346-469e-a068-d8e091a4c074">
        <updating/>
        <source>setProxy(	pCode,pDescription : String;
			_notAvailableForEntry,
			_secureExportPartner : Boolean;
			pDerogationNumber,
			pEmailAddress:String;
			pColour,pOrder:Integer;
			pConsignGroup:CM_ConsigneeConsignorGroup;
			pDebtor:CM_Debtor;
			_showOOWRemarks : Boolean;
			pIsConsignee,
			pIsConsignor,
			pIsFreightFwdr : Boolean;
			_emailPINAddresses : CM_EmailEntityByTypeNameDict input;
			_license : String;
			_licenseExpiryDate : Date;							//cnwmc5 - 19/12/2012 - HAT 2198 - added _license and _expiryDate
			_isUsedForPacking : Boolean	;// PAR #35895 
			_isRestricted  : Boolean; // 3.8.2017 cnwma1 TFS #5209		
			_isInternal : Boolean) updating;	//jlier1 TFS 57087 27/6/23	
//
// Changed On	By			Reason
// ----------	--------	------------------------------------------------
// 25/03/2015	cnwdap1		PAR #35895 CCMS PNL 2461 Added isUsedForPacking attribute
// 03 Aug 2017	cnwma1		TFS #5209:PEN - Release Request Stop
// 12 Sep 2023	jlika1	TFS 60388		EUP | FR 53824 - Consignee / Consignor Description Field Length
begin
//FD for consign derogation
	self.raiseExceptionIfNotTransient(method);
	
	self.code					:= pCode[1:5];
	self.isNotAvailableForEntry	:= _notAvailableForEntry;
	self.description			:= pDescription[1:100];
	self.colour					:= pColour;
	self.debtor					:= pDebtor;
	self.myConsignGroup			:= pConsignGroup;
	self.order					:= pOrder;
	self.derogationNumber		:= pDerogationNumber;
	self.emailAddress			:= pEmailAddress;
	self.secureExportPartner	:= _secureExportPartner;
	self.myRoot					:= app.myRoot;
	self.showOOWRemarks			:= _showOOWRemarks;
	
	//par#12903 3/11/2006
	self.isConsignor := pIsConsignor;
	self.isConsignee := pIsConsignee;
	self.isFreightFwdr  := pIsFreightFwdr;
	self.isInternal:=self.isFreightFwdr and _isInternal; //jlier1 TFS 57087 27/6/23	
	//cnwmc5 - 19/12/2012 - HAT 2198
	self.license				:= _license;
	self.licenseExpiryDate		:= _licenseExpiryDate;
	
	self.isUsedForPacking		:= _isUsedForPacking;					// PAR #35895
	self.isRestricted			:= _isRestricted; // 3.8.2017 cnwma1 TFS #5209
	self.allPINNotifyEmailAddresses.clear();
	
	if _emailPINAddresses &lt;&gt; null then
		_emailPINAddresses.copy(self.allPINNotifyEmailAddresses);
	endif;
end;</source>
        <Parameter name="pCode" type="String"/>
        <Parameter name="pDescription" type="String"/>
        <Parameter name="_notAvailableForEntry" type="Boolean"/>
        <Parameter name="_secureExportPartner" type="Boolean"/>
        <Parameter name="pDerogationNumber" type="String"/>
        <Parameter name="pEmailAddress" type="String"/>
        <Parameter name="pColour" type="Integer"/>
        <Parameter name="pOrder" type="Integer"/>
        <Parameter name="pConsignGroup" type="CM_ConsigneeConsignorGroup"/>
        <Parameter name="pDebtor" type="CM_Debtor"/>
        <Parameter name="_showOOWRemarks" type="Boolean"/>
        <Parameter name="pIsConsignee" type="Boolean"/>
        <Parameter name="pIsConsignor" type="Boolean"/>
        <Parameter name="pIsFreightFwdr" type="Boolean"/>
        <Parameter name="_emailPINAddresses" type="CM_EmailEntityByTypeNameDict" usage="input"/>
        <Parameter name="_license" type="String"/>
        <Parameter name="_licenseExpiryDate" type="Date"/>
        <Parameter name="_isUsedForPacking" type="Boolean"/>
        <Parameter name="_isRestricted" type="Boolean"/>
        <Parameter name="_isInternal" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="8bc03653-e38b-4657-975b-1a4a34d21316">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;

// cnwdvb1 25 June 2003 

vars
	propName	: String;

begin

	propName := _property.name;

	if	propName = CM_ConsigneeConsignor::myRootByDesc.name or
	propName = CM_ConsigneeConsignor::order.name or
	propName = CM_ConsigneeConsignor::secureExportPartner.name or
	propName = CM_ConsigneeConsignor::showOOWRemarks.name then
		return false;
	endif;
	return inheritMethod(_rootClass, _property);

end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="9b7d17f8-8bdb-4441-9c19-615f139c8c72">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if app.myRoot.allConsigneeConsignors[self.code] &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.code, null, null);
	endif;

	self.validateMe(null);
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="5f661d92-f2bc-48e9-a025-5db8d62118ea">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 26 june 2008	concms1		par 17268 CAMs message by freight forwarder
//11/04/2019 	JLGNS1	Bug 44243: PEL1 add inverses to prevent deleting consigniees if used in a WODCargoRequest
// ---------------------------------------------------------------------------
vars

	whereUsed : String;

begin

	if self.allBookingRefsByRef.size &gt; 0 then
		app.raiseCMException2(ObjectStillHasEntries, self.code, "Booking References", null, null);
	endif;
	
	if self.allDataAccessControllers.size &gt; 0 then
		app.raiseCMException2(ObjectStillHasEntries, self.code, "Data Access Controllers", null, null);
	endif;
	
	if self.hasStockOrders() then
		app.raiseCMException2(ObjectStillHasEntries, self.code, "Stock Orders", null, null);
	endif;

	if self.allCamGroupsForFF.size &gt; 0 then													// par 17268
		app.raiseCMException2(ObjectStillHasEntries, self.code, "CAM Groups", null, null);	// par 17268
	endif;																					// par 17268
	
	if self.allWodCargoRequests.isNotEmpty then																									//Bug 44243
		app.raiseCMException2(ObjectStillHasEntries, self.code, self.allWodCargoRequests.size.String, app.getErrorString(Work_order), null);	//Bug 44243
	endif;	
	
	//10 Nov 2020	NDL	TFS 50279
	if self.isUsedinConfig( whereUsed ) then
		app.raiseCMException2(ERR_CANNOT_DELETE, self.code, whereUsed, null, self);
	endif;
	
	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="1cb12ee4-b147-4e93-97c6-5926124e7fd2">
        <source>validateForUpdate(_consigneeConsignor : CM_ConsigneeConsignor);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 16/04/2013	cnwcs5		par 31259 - Validate change of code here instead of calling validateForCreate from valConsigneeConsignor
// 21/10/2020	jlgdap1		TFS 50107 GUQ Error 1310 Transaction Map - Cargo Allocationm
// ---------------------------------------------------------------------------
vars

	consigneeConsignor	:CM_ConsigneeConsignor;
	whereUsed : String;
	
begin
	consigneeConsignor := app.myRoot.allConsigneeConsignors[self.code];
	
	//if consigneeConsignor &lt;&gt; null and consigneeConsignor &lt;&gt; consigneeConsignor then	// TFS 50107
	if consigneeConsignor &lt;&gt; null and consigneeConsignor &lt;&gt; _consigneeConsignor then	// TFS 50107
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.code, null, null);
	endif;
	
	self.validateMe(_consigneeConsignor);
	
	//10 Nov 2020	NDL	TFS 50279
	if self.isNotAvailableForEntry then
		if self.isUsedinConfig( whereUsed ) then
			app.raiseCMException1(Not_make_not_availa_while, whereUsed, null, self);
		endif;
	endif;
	
end;</source>
        <Parameter name="_consigneeConsignor" type="CM_ConsigneeConsignor"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="42c48204-bf71-4215-ac85-79bc33a7018a">
        <source>validateMe(_consigneeConsignor : CM_ConsigneeConsignor) protected;
// 16/12/2014  cnwdb2	PAR 35364
vars
	consign	: CM_ConsigneeConsignor;
	str 	: String;
begin
	if self.code = null then
		str := app.getTerminologyAlternate(null, null, CM_TerminologyConsignor, CM_TermExpressionSingular, 'Consignor'); 
		
	//	app.raiseCMException1(REQUIRED_FIELD, 'Consignee/' &amp; str &amp; ' Code', null, null);
		app.raiseCMException1(Input_required_field_consgnCod, str , null, null); // cnwdb2	PAR 35364

	endif;
	
	if self.description = null then
		str := app.getTerminologyAlternate(null, null, CM_TerminologyConsignor, CM_TermExpressionSingular, 'Consignor'); 
		
	//	app.raiseCMException1(REQUIRED_FIELD, 'Consignee/' &amp; str &amp; ' Description', null, null);
		app.raiseCMException1(Input_required_field_consgDesc, str , null, null); // cnwdb2	PAR 35364


	endif;

	// check we don't have two with the same description
	if app.myRoot.getConfig(ConsigneeConsignorCmbOrdDescr).Boolean then
		consign := app.myRoot.allConsigneeConsignorsForDescr[self.description];
		
		if (consign &lt;&gt; null) and (consign &lt;&gt; _consigneeConsignor) then
			app.raiseCMException1(DupConsigneeDescrForCreate, consign.code, null, null);
		endif;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_consigneeConsignor" type="CM_ConsigneeConsignor"/>
    </JadeMethod>
</Class>
