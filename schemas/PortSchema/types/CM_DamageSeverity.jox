Date		Who		Reason
28 June 2022	navhl20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details

*/

vars

begin
	self.description 			:= _pxyDamageSeverity.description;
	self.code 					:= _pxyDamageSeverity.code;
	self.isNotAvalableForEntry := _pxyDamageSeverity.isNotAvalableForEntry;
	self.level					:= _pxyDamageSeverity.level;
	self.myTerminal				:= _pxyDamageSeverity.myTerminal;
	self.myRoot					:= null;
epilog

end;</source>
