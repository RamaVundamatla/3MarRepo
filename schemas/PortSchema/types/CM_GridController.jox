    <JadeMethod name="updateGridLocationQueueEntries" id="defd4b52-6684-4f40-8b2c-32ff7d9af3dd">
        <source>updateGridLocationQueueEntries();

/*

Purpose: par 31239 send notes for gridded area height display	

Parameters:			

Return Value:		


Date		Who		Reason
15 July 2013	cnwrd1	Initial creation

*/

vars
	fQM : CM_FutureMove;
	rtEntry : CM_RTQueueEntry;
begin

	if self.myTerminalArea &lt;&gt; null and self.myTerminalArea.isStraddleStack then
		foreach fQM in self.allQueuedFutureMoves do
			if fQM.isKindOf(CM_FutureMoveQueued) then			
				foreach rtEntry in fQM.CM_FutureMoveQueued.allRTQueueEntries do		
					rtEntry.causeEvent(self.myTerminal.getTerminalEvent(RTQueueEntry_Update_Event), false, null);		//cnwmc5 - 21 Nov 2013 - PAR 32952 - this was causing the RT queue form to not remove queue entries correctly..
					rtEntry.sendNotesForRelatedEntry();
				endforeach;
			endif;
		endforeach;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validate" id="56b0a8e0-56b8-492a-a2ae-4e1269c7a110">
        <source>validate(_passport : CM_Passport input) protected;
// ---------------------------------------------------------------------------
// Created:     28 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 23/12/2014  cnwdb2	PAR 35364
// ---------------------------------------------------------------------------
vars
	theLabel : String;
begin
	inheritMethod(_passport);
	
	
	if self.myGridRow = null then

		app.raiseCMException2(ERR_INVALID_VALUE, 'Grid Row', self.String, null, null);
	else
		theLabel := theLabel &amp; self.myGridRow.label;
	endif;

	if self.myGridColumn = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Grid Column', null, null);
		app.raiseCMException(Input_required_field_GrdCol, null, null); // cnwdb2	PAR 35364

	else
		theLabel := theLabel &amp; self.myGridColumn.label;
	endif;

	if self.ident = null then
//		app.raiseCMException1(REQUIRED_FIELD, ' Grid Controller ID ' &amp; theLabel, ETRow_Id, null);
		app.raiseCMException1(Input_required_field_grdContId,  theLabel, ETRow_Id, null); // cnwdb2	PAR 35364
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateCargoMatchForMultiMove" id="40fa8658-79d6-4d19-91f4-5ee12fd24108">
        <source>validateCargoMatchForMultiMove(_ti: CM_TrackedItem): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 September 2011	cnwndl1	Initial creation	Par 28035

*/

vars
	
	existingTi : CM_TrackedItem;
	futureMove : CM_FutureMove;
	isSameLength : Boolean;
	invalid : Boolean;

begin

	// have to make sure any other cargo q'd planned or already in this position is the same size, 
	// cos we will be stacking it...

	on Exception do app.handleDeletedObject(exception,existingTi,invalid);
	on Exception do app.handleDeletedObject(exception,futureMove,invalid);

	if not self.allTrackedItems.isEmpty then
		existingTi := self.allTrackedItems.first;
	elseif not self.allPlannedFutureMoves.isEmpty then
		futureMove := self.allPlannedFutureMoves.first;
		if futureMove &lt;&gt; null then
			existingTi := futureMove.getTrackedItem;
		endif;
	elseif not self.allQueuedFutureMoves.isEmpty then
		futureMove := self.allQueuedFutureMoves.first;
		if futureMove &lt;&gt; null then
			existingTi := futureMove.getTrackedItem;
		endif;
	endif;
	
	if invalid then
		return false;
	endif;
	  
	if existingTi &lt;&gt; null then
		isSameLength := (existingTi.getLengthInUnits = _ti.getLengthInUnits);
		if invalid then
			return false;
		endif;
		return isSameLength;
	endif;
	
	// any back end hanging into this primary space is in any mode a problem...
	if not self.allTrackedItemOSBackEnds.isEmpty then
		return false;
	elseif not self.allTrackedItemOSBackEndsQd.isEmpty then
		return false;
	elseif not self.allTrackedItemOSBackEndsPd.isEmpty then
		return false;
	endif;
	
	//nothing here at all is good.
	return true;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateControllersFor53" id="0ad58b37-a6ba-453f-ae8d-0144fff20294">
        <updating/>
        <source>validateControllersFor53(set : CM_GridControllersByRowColumn) : Boolean updating;
/*

Purpose:			Checks that all the controllers required for a 53 foot container
					satisfy the conditions

Parameters:			Set of controllers for the Area
Return Value:		True if OK , False if not


Date		Who		Reason
01 September 2008	conkc1	Initial creation

*/
vars
	nextGC                  : CM_GridController;
	container               : CM_Container;
	trackedItem             : CM_TrackedItem;
	totalLength             : Integer;
begin

	nextGC := self;
	totalLength := 20 - self.offset53;
	while true do

		if nextGC.getFreeSpaceCheckNextCont(set) = false then
			return false;
		endif;
		//
		// Get Next Controller
		//
		nextGC := nextGC.myNextController;
		//
		// Next controller must be able to take a 53 foot container
		//
		if nextGC.is53ft = false then
			return false;
		endif;

		trackedItem := nextGC.allTrackedItems.first;
		if trackedItem &lt;&gt; null then
			if trackedItem.isKindOf(CM_Container) = false then
				return false;
			endif;
			container  := trackedItem.CM_Container;

			if nextGC.offset53 &lt;&gt; -1 then
				if container.is20 = true then
					return false;
				elseif container.is40 = true and container.is45 = false then
					return false;
				elseif container.is30 = true and nextGC.offset30 &gt; nextGC.offset53 then
					return true;
				elseif container.is45 = true and nextGC.offset45 &gt; nextGC.offset53 then
					return true;
				elseif container.is53 = true then
					return true;
				else
					return false;
				endif;
			else
				return false;
			endif;
		else
			if nextGC.offset53 &lt;&gt; -1 then
				return true;
			endif;
		endif;
		totalLength := totalLength + 20;
		//
		// Check if we have processed enough Controllers
		// Happens when the offset53 on self is 14. The next starts at 0
		//
		if totalLength &gt; 53 then
			return true;
		endif;
	endwhile;

epilog

end;</source>
        <Parameter name="set" type="CM_GridControllersByRowColumn"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateMoveTo" id="6a2ec0b1-17ff-4646-bf63-ede4adc44a1c">
        <source>validateMoveTo(_control: CMIF_MoveController input);
/*
 ------------------------------------------------------------------------
Created:			13 September 2001 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	lc : CM_LocationsController;
	tAutoPlanMove : CMIF_AutoMovePlan;
	theNotSuitableForTIString : String;
	firstTi : CM_TrackedItem;
	griddedStackHeight1 : CM_GriddedTAStackHeight;
	griddedStackHeight2 : CM_GriddedTAStackHeight;
	restrictionName1 : String;
	restrictionName2 : String;
begin
	
	inheritMethod(_control);

 	if self = _control.myToPrimaryLocation then
		//------------------- RE-ENTRANT PROTECTION PORTION - CALLED ONCE -----------------------------
		//As the primary target we have already been locked by the _control object.
		//(or by the caller)
		//-------------------
		//get the extent of the TI in terms of other LC's of this type we have to span
		//------------------
		theNotSuitableForTIString := null;
		theNotSuitableForTIString := self.getSpannedToLCsNEW(_control);
		if theNotSuitableForTIString = null then
			theNotSuitableForTIString := self.validateSpannedtoOffsetLCs(_control);
		endif;
		
		if theNotSuitableForTIString &lt;&gt;  null then
			//epr par 31492 14/8/13 only give error when moving in real mode otherwise warning
			if _control.moveMode = REAL_MODE then
				app.raiseCMException3(Err_Cannot_Move, _control.myTrackedItem.id, self.getFullId(),  theNotSuitableForTIString, null, null);// PAR 18647
			else
				app.raiseCMWarning3(Err_Cannot_Move, _control.myTrackedItem.id, self.getFullId(),  theNotSuitableForTIString,null,null,null);// PAR 18647
			endif;
		endif;
		
		//24 Sep 2020	NDL	TFS 49984
		if _control.myTrackedItem &lt;&gt; null and not self.getMyTerminalArea.allGriddedTAStackHeights.isEmpty then
			griddedStackHeight1 := self.getGriddedStackHeightObj( firstTi );
			if firstTi &lt;&gt; null then
				griddedStackHeight2 := self.getMyTerminalArea.allGriddedTAStackHeights.getFirstMatching( _control.myTrackedItem );
				if griddedStackHeight1 &lt;&gt; griddedStackHeight2 then	
					if ( griddedStackHeight1 &lt;&gt; null and griddedStackHeight1.neverMix ) or ( griddedStackHeight2 &lt;&gt; null and griddedStackHeight2.neverMix ) then
						if griddedStackHeight1 &lt;&gt; null then
							restrictionName1 := griddedStackHeight1.name;
						else
							restrictionName1 := app.getErrorString(NoMatch);
						endif;
						if griddedStackHeight2 &lt;&gt; null then
							restrictionName2 := griddedStackHeight2.name;
						else
							restrictionName2 := app.getErrorString(NoMatch);
						endif;
						app.raiseCMException2( Restr_does_not_permi_mixin_car, restrictionName1, restrictionName2, null, null );	
					endif;
				endif;
			endif;
		endif;
	
		//------------------
		//check each one of these, RENTRANT call.
		//------------------
		_control.doToSecondaryLocationsLock();
		foreach lc in _control.myToSecondaryLocations do
			lc.validateMoveTo(_control);
			// If there is 40' box, two locations are checked and messages are doubled. 25271 23/08/2010
			if app.myPassport &lt;&gt; null and app.myPassport.hasErrors then
				break;
			endif;
		endforeach;
	endif;
	
	// DVB put this here so a forced move still sets up secondary locations. 02/09/03
	if _control.isForcedMove then
		return;
	endif;
	
	//------------------------
	//This is the standard stuff to validate any move here	
	//------------------------
	if self.includesTI(_control.myTrackedItem, _control.moveMode) then
		//-----------------
		//If the TI is already here (AND we are the primary location), then simply return.
		//This is essentially a "null" move to where we are already.
		//-----------------
		if _control.myOriginatingLocation = self then
			return;
		endif;
	endif;
	//---------------------------
	//  Creat a transient automoveplan from our move_controller so we can share
	//  same code as the autoPlan tests.
	//---------------------------
	tAutoPlanMove := _control.createAsAutoMovePlan();
	tAutoPlanMove.setOriginatingController(self);

	if self &lt;&gt; _control.myToPrimaryLocation then // AKB2002JULY added
		tAutoPlanMove.checkingSecondary := true; // AKB2002JULY added
	endif;
	
	self.testIsControllerAvailable(tAutoPlanMove);
	
	//---------------------------
	//  TEST : Vertically full
	//---------------------------
	if not tAutoPlanMove.checkingSecondary then // AKB2003APRIL added - for 40's was checking the next and its next
		self.isStackFull(tAutoPlanMove);
	endif;
	
	self.testIsControllerLocnRestricted(tAutoPlanMove);
	
	//-------------------------
	//Perform following tests only once
	//-------------------------
	// DVB. Let machine controller through here. 10/02/2006
	if (self &lt;&gt; _control.myToPrimaryLocation ) and (not _control.myToPrimaryLocation.isKindOf(CM_MachineController)) then
		return;
	endif;
	
	//-------------------------
	//Do a whole heap of tests, if an error, we jump out, else continue testing
	//-------------------------
	self.testIsDiffDischPort(tAutoPlanMove);
	self.testIsDiffVoyage(tAutoPlanMove);
	self.testIsRequirePower(tAutoPlanMove);
	self.testIsRequireTower(tAutoPlanMove);
	self.testOverstowPlannedOrQueued(tAutoPlanMove);
	self.testTAAccess(tAutoPlanMove); // cnwrd1 16.7.2008 par #16861
	
epilog
	delete tAutoPlanMove;
end;</source>
        <Parameter name="_control" type="CMIF_MoveController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateSpannedtoOffsetLCs" id="475d46f2-285c-49a1-b20c-7d96390230a1">
        <source>validateSpannedtoOffsetLCs(_control : CMIF_MoveController input) : String;
// ---------------------------------------------------------------------------
// Created:		03 April 2008 By Andrew Bishop cnwab1
//
// Purpose:		Taking into consideration the offset on ME and how many controllers the TI will need, 
//					is there room for the TI between my offset (which is the end of the TI already on me) and the 
//					offset on the LC where this TIs backend will end.
//
// ---------------------------------------------------------------------------
vars
	otherTI, tmpTI : CM_TrackedItem;
	tmpMess, tmpLen : String;
	nextGC, tmpGC : CM_GridController;
	nextNull : Boolean;
	numNext, nextCount, offsetCheck : Integer;
	check1, check2 : Class;
begin
	tmpMess := inheritMethod(_control);
	
	if tmpMess &lt;&gt; null then
		return tmpMess;
	endif;
	
	tmpTI := _control.myTrackedItem;

	if self.isOverhang then
		check1 := CM_GridController;
		check2 := CM_GridController;
	else
		check1 := self.class;
		check2 := CM_OverhangController;
	
	endif;
	

	// PAR 16094
	if tmpTI.isAttributeTrue(TI_Attrib_IsFortyFive) then
		tmpLen := "45";
		numNext := 2;
		offsetCheck := 15;
	elseif tmpTI.isAttributeTrue(TI_Attrib_IsFiftyThree) then
		tmpLen := "53";
		numNext := 2;
		offsetCheck := 7;
	elseif tmpTI.isAttributeTrue(TI_Attrib_IsThirty) then
		tmpLen := "30";
		numNext := 1;
		offsetCheck := 10;
	else
		if tmpTI.isAttributeTrue(TI_Attrib_IsForty) then
			tmpLen := "40";
		else
			tmpLen := "20";
		endif;
		
		// PAR 21069 if self.offsetFlexi &gt; 0 then
		if self.offsetFlexi &gt; 0 and self.offsetFlexi &lt; 20 then // PAR 21069
			nextGC := self.getNextControllerOfType(check1).CM_GridController; // PAR 18682
			if nextGC = null then
				return app.getErrorString3(ERR_NO_MOVE_ODD, tmpTI.id, tmpLen, tmpLen); 
	//		elseif (not nextGC.allTrackedItems.isEmpty() and  not nextGC.allTrackedItems.includes(tmpTI))  then // PAR 19490
	//			return app.getErrorString3(ERR_NO_MOVE_ODD, tmpTI.id, tmpLen, tmpLen); // PAR 18682
			elseif self.allTrackedItems.size &lt;&gt; nextGC.allTrackedItems.size then //17 Jun 2021	NDL	TFS 51168
				return app.getErrorString3(ERR_NO_MOVE_ODD, tmpTI.id, tmpLen, tmpLen); 
			else
				if tmpTI.isAttributeTrue(TI_Attrib_IsForty) then
					nextGC := nextGC.getNextControllerOfType(check1).CM_GridController; // PAR 18682
					if nextGC = null then
						return app.getErrorString3(ERR_NO_MOVE_ODD, tmpTI.id, tmpLen, tmpLen); // PAR 18682
					else
						return null;
					endif;
				// 20
				elseif nextGC.allTrackedItems.isEmpty() then // PAR 19490
					return null;
				elseif not nextGC.allTrackedItems.isEmpty() and  nextGC.allTrackedItems.includes(tmpTI) then
					return null;
				else
					return app.getErrorString3(ERR_NO_MOVE_ODD, tmpTI.id, tmpLen, tmpLen); // PAR 19490
				endif;
			endif;
		else
			return null; // 20 and 40
		endif;
	endif;

	// we are trying to work out if there is enough room for teh TI starting from SELF until the next lot of TIs
	// however if there is already TIs here and SELF is the primary then nothing to check, cos we are checking the empty gaps
	if not self.allTrackedItems.isEmpty() then
		otherTI := self.allTrackedItems.first;
		if otherTI.myPrimaryActualLocation = self then
			return null;
		endif;
	endif;
	
	nextGC := self;
	while true do
		tmpGC := nextGC; // PAR 18682
		nextGC := tmpGC.getNextControllerOfType(check1).CM_GridController; // PAR 18682
		if nextGC = null then // PAR 18682
			nextGC := tmpGC.getNextControllerOfType(check2).CM_GridController; // PAR 18682
		endif;
		if nextGC &lt;&gt; null then
			nextCount := nextCount + 1;
			if nextCount = numNext then
				if ((self.offsetFlexi &gt; offsetCheck) or self.getStrictOffsetForTI(tmpTI) &gt; offsetCheck ) 
				and (self.offsetFlexi &lt; 20) 
				and nextGC &lt;&gt; null then 
//					nextGC := nextGC.getNextControllerOfType(self.class).CM_GridController;
					tmpGC := nextGC;
					nextGC := tmpGC.getNextControllerOfType(check1).CM_GridController; // PAR 18682
					if nextGC = null then // PAR 18682
						nextGC := tmpGC.getNextControllerOfType(check2).CM_GridController; // PAR 18682
					endif;
				endif;
				if nextGC &lt;&gt; null 
				and tmpGC.allTrackedItems.isEmpty() then // PAR 19490
					return self.isThereRoomForTI(nextGC, _control, tmpTI);
				elseif nextGC &lt;&gt; null and not nextGC.allTrackedItems.isEmpty() and not nextGC.allTrackedItems.includes(tmpTI) then		// 03/11/2014 cnwmh5
					return app.getErrorString3(ERR_NO_MOVE_ODD, tmpTI.id, tmpLen, tmpLen); // PAR 18682
				else
					return null;
				endif;
			else
				if not nextGC.allTrackedItems.isEmpty() and not nextGC.allTrackedItems.includes(tmpTI) then
					return app.getErrorString3(ERR_NO_MOVE_ODD, tmpTI.id, tmpLen, tmpLen); // PAR 18682
				endif;
			endif;
		else
			return app.getErrorString3(ERR_NO_MOVE_ODD, tmpTI.id, tmpLen, tmpLen); // PAR 18682
		endif;
	endwhile;

	return null;
end;</source>
        <Parameter name="_control" type="CMIF_MoveController" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="validateSpannedtoOffsetLCsOLD" id="1f767513-f303-42be-bbf8-415cbe506648">
        <source>validateSpannedtoOffsetLCsOLD(_control : CMIF_MoveController) : String;
// ---------------------------------------------------------------------------
// Created:		03 April 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	otherTI, tmpTI : CM_TrackedItem;
	tmpMess : String;
	nextGC : CM_GridController;
	nextNull : Boolean;
begin
//	tmpMess := inheritMethod(_control);
	
	if tmpMess &lt;&gt; null then
		return tmpMess;
	endif;
	
	tmpTI := _control.myTrackedItem;

	// PAR 16094
	if tmpTI.isAttributeTrue(TI_Attrib_IsFortyFive) then
		nextGC := self.getNextControllerOfType(self.class).CM_GridController;
		if nextGC &lt;&gt; null then
			nextGC := nextGC.getNextControllerOfType(self.class).CM_GridController;
			if nextGC &lt;&gt; null then
				otherTI := nextGC.allTrackedItems.first;
				if  otherTI &lt;&gt; null 
				and not otherTI.isAttributeTrue(TI_Attrib_IsFortyFive) then
					// PAR 18647 was return tmpTI.id &amp; " is a 45 foot container, " &amp; otherTI.id &amp; " at location " &amp; otherTI.myPrimaryActualLocation.getFullId() &amp; " is in the way." ;
					return app.getErrorString4(ERR_NO_ROOM_ODD, tmpTI.id, "45", otherTI.id, otherTI.myPrimaryActualLocation.getFullId()); // PAR 18647
				endif;
			else
				nextNull := true; // PAR 17385

			endif;
		else
			nextNull := true; // PAR 17385
//			return tmpTI.id &amp; " is a 45 foot container, there is no room for a 45 footer here."; // PAR 16997
		endif;
		if nextNull then
			 // PAR 16997 was return tmpTI.id &amp; " is a 45 foot container, there is no room for a 45 footer here."; // PAR 16997
			return app.getErrorString3(ERR_NO_MOVE_ODD, tmpTI.id, "45", "45"); // PAR 18647
		endif;
					

	endif;
	if tmpTI.isAttributeTrue(TI_Attrib_IsFiftyThree) then
		nextGC := self.getNextControllerOfType(self.class).CM_GridController;
		if nextGC &lt;&gt; null then
			nextGC := nextGC.getNextControllerOfType(self.class).CM_GridController;
			if nextGC &lt;&gt; null then

				otherTI := nextGC.allTrackedItems.first;
				if  otherTI &lt;&gt; null 
				and not otherTI.isAttributeTrue(TI_Attrib_IsFiftyThree) then
					 // PAR 18647 was return tmpTI.id &amp; " is a 53 foot container, " &amp; otherTI.id &amp; " at location " &amp; otherTI.myPrimaryActualLocation.getFullId() &amp; " is in the way." ;
					return app.getErrorString4(ERR_NO_ROOM_ODD, tmpTI.id, "53", otherTI.id, otherTI.myPrimaryActualLocation.getFullId()); // PAR 18647
				endif;
			
				nextGC := nextGC.getNextControllerOfType(self.class).CM_GridController;
				if nextGC &lt;&gt; null then
					otherTI := nextGC.allTrackedItems.first;
					if  otherTI &lt;&gt; null 
					and not otherTI.isAttributeTrue(TI_Attrib_IsFiftyThree) then
						 // PAR 18647 was return tmpTI.id &amp; " is a 53 foot container, " &amp; otherTI.id &amp; " at location " &amp; otherTI.myPrimaryActualLocation.getFullId() &amp; " is in the way." ;
						return app.getErrorString4(ERR_NO_ROOM_ODD, tmpTI.id, "53", otherTI.id, otherTI.myPrimaryActualLocation.getFullId()); // PAR 18647
					endif;
				else
					nextNull := true; // PAR 16997
				endif;
			else
				nextNull := true; // PAR 16997
			endif;
		else
			nextNull := true; // PAR 16997
		endif;
		 // PAR 16997
		if nextNull then
			 // PAR 18647 was return tmpTI.id &amp; " is a 53 foot container, there is no room for a 53 footer here.";
			return app.getErrorString3(ERR_NO_MOVE_ODD, tmpTI.id, "53", "53"); // PAR 18647
		endif;
	endif;
	if tmpTI.isAttributeTrue(TI_Attrib_IsThirty) then
		nextGC := self.getNextControllerOfType(self.class).CM_GridController;
		if nextGC &lt;&gt; null then
			otherTI := nextGC.allTrackedItems.first;
			if  otherTI &lt;&gt; null 
			and not otherTI.isAttributeTrue(TI_Attrib_IsThirty) then
				 // PAR 18647 was return tmpTI.id &amp; " is a 30 foot container, " &amp; otherTI.id &amp; " at location " &amp; otherTI.myPrimaryActualLocation.getFullId() &amp; " is in the way." ;
				return app.getErrorString4(ERR_NO_ROOM_ODD, tmpTI.id, "30", otherTI.id, otherTI.myPrimaryActualLocation.getFullId()); // PAR 18647
			endif;
		else
			// PAR 16997 return tmpTI.id &amp; " is a 30 foot container, there is no room for a 30 footer here."; // PAR 16997
			return app.getErrorString3(ERR_NO_MOVE_ODD, tmpTI.id, "30", "30"); // PAR 18647
		endif;
	endif;

end;</source>
        <Parameter name="_control" type="CMIF_MoveController"/>
