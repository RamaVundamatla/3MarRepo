    <JadeMethod name="tblWLEMouseMoveEvent" id="0288fb98-3b00-43e3-a80c-5b4991ea4b2f">
        <updating/>
        <source>tblWLEMouseMoveEvent(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
//--------------------------------------------------------------
//Created: 18 April 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	theTI : CM_TrackedItem;
begin

	if self.myCurrentWLE = null and self.myCurrentTrackedItem = null then
		return;
	endif;

	// check drag/drop detected
	if button &lt;&gt; 1 or (not app.dragDetected(x, y, self.origXPos, self.origYPos)) then
	   return;
	endif;

	
	if self.myCurrentTrain &lt;&gt; null then
		if self.moveModeForm &lt;&gt; PLANNING_MODE then
			if not self.myCurrentTrain.isCompletelyConfirmed(false) then
				app.msgBox(app.getErrorString(Canno_this_move_mode_uncon_tra), app.getErrorString(Move_mode), MsgBox_Exclamation_Mark_Icon);
				return;
			endif;
		endif;
	endif;
	
	self.origXPos := 0;
	self.origYPos := 0;	
	
	// check there is a trackedItem to move
	if self.myCurrentWLE &lt;&gt; null then
		theTI := self.myCurrentWLE.myTrackedItem;
	endif;
	
	if theTI = null then
		theTI := self.myCurrentTrackedItem;
	endif;
	
	if theTI = null then
		return;
	endif;

	app.myDraggedTrackedItem := theTI;
	self.dragTrackedItem(theTI, self.myCurrentWLE, self.tblWorkEntries);
	self.tblWorkEntries.row := self.tblWorkEntries.fixedRows; //PAR 17940
	self.myCurrentWLE := null;
	self.myCurrentTrackedItem := null;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="tblWLEReceiveDrop" id="df9b83e8-d6db-45eb-b25f-1e9b1fceb1c3">
        <updating/>
        <source>tblWLEReceiveDrop() updating;
/*
----------   ----------  --------------------------------------------------
Created:	01 December 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if app.myMoveController &lt;&gt; null then
		if app.myMoveController.moveMode = PLANNING_MODE 
		and ( app.myMoveController.myOriginatingForm &lt;&gt; null and app.myMoveController.myOriginatingForm.name &lt;&gt; "YRD_LoadList") then // DO  NOT TRANSLATE
		
		
			//app.msgBox('Planning is not allowed in rail operations. Only instant moving and queueing of cargo item is permitted.','Plan mode not allowed',MsgBox_Exclamation_Mark_Icon);//- cnwmd1, CCMS 1067, Par 19710
			app.msgBox(app.getErrorString(Planning_NotAllow_Rail_ops),app.getErrorString(Plan_mode_NotAllowed),MsgBox_Exclamation_Mark_Icon); //+ cnwmd1, CCMS 1067, Par 19710
			
			return;
		endif;
	endif;
	inheritMethod();
		


end;


</source>
    </JadeMethod>
    <JadeMethod name="tblWLEUpdateWle" id="12af439e-7f4f-4ed0-ac58-9caf0d580620">
        <updating/>
        <source>tblWLEUpdateWle(_wle: CM_WorkListEntry; _mode: Integer) updating;
//--------------------------------------------------------------
//Created: 27 May 2003 By: cnwgd1
//
// Changed On   Changed By  Reason
// ----------   ----------  ------------------------------------
// 09/07/2009	consw1		PAR 20215 - WLE table not refreshed properly
// 03/09/2015	cnwdap1		PAR #36210 Filter out WLEs for other rail rakes 
//17 Nov 2016 cnwrs1	Par 37738 TFS 2949 incorrect UPSP rail location being displayed
//10 Feb 2017	cnwndl1		TFS 3407 - exception handler needs to be protected from null object
//--------------------------------------------------------------
vars
	
	ioType			: Integer;
	foundLC			: CM_LocationsController;			// PAR #36210
	invalid : Boolean;
	str : String;
begin
	on Exception do app.handleDeletedObject(exception, self.myCurrentJSIORake, invalid);		 // PAR 37738
//	str := self.myCurrentJSIORake.asStringJMT;
//	if invalid then
//		return;
//	endif;
	if _mode = self.Mode_Delete or (not global.isValidObject(_wle)) then
		self.tblWorkEntries.removeItemObject(_wle);
		if _wle.String = self.myCurrentWLE.String then
			self.tblWLEChange(null);
		endif;
		return;
	endif;

	if (not CM_YardWLE.hasInstance(_wle)) or 
	   (not CM_RailJob.hasInstance(_wle.job)) then
		return;
	endif;
	
	
	on Exception do app.handleDeletedObject(exception, self.myCurrentJSIORake, invalid);
	
	if self.myCurrentJSIORake &lt;&gt; null then // ### DCTG exception AKB2007JUN
		ioType := self.myCurrentJSIORake.inOut.outwards;
		
		if invalid then	//10 Feb 2017	cnwndl1		TFS 3407
			self.myCurrentJSIORake := null;
			
		else
			//th2 added - test whether viewing inwards or outwards rail before updating work list entry table
			if (ioType = Rail_JSIO_Type_In and _wle.job.isRelease) or
			(ioType = Rail_JSIO_Type_Out and not _wle.job.isRelease) then
				return;
			endif;
			// PAR 26564- wle is for a train jobsheet so ignore as we are looking at a rail area's jobsheet
			if _wle.job.myJobSheet &lt;&gt; null 
			and _wle.job.myJobSheet.isTrainJS() then
				return;
			endif;
			// PAR #36210 Is this WLE for my rake area									// PAR #36210
			if self.myCurrentRailArea &lt;&gt; null and self.myCurrentTrain = null then		// PAR #36210
				foundLC := _wle.getTargetLocation;										// PAR #36210
				if foundLC.isKindOf(CM_WagonController) and foundLC.CM_WagonController.myTerminalArea &lt;&gt; self.myCurrentRailArea then	// PAR #36210
					return;																// PAR #36210
				endif;																	// PAR #36210
			endif;																		// PAR #36210
			
		endif;
	endif;
	
	// We are looking at a train's jobsheet
	// PAR 26564
	if self.myCurrentTrain &lt;&gt; null then
		if _wle.job.myJobSheet &lt;&gt; null 
		and _wle.job.myJobSheet &lt;&gt; self.myCurrentTrain.myJobSheet then
			return;
		endif;
	
	endif;

	if not self.includeRailJob(_wle.job.CM_RailJob) then
		self.tblWorkEntries.removeItemObject(_wle);
		self.doNotableRemove(_wle.myTrackedItem);		
		return;	
	endif;
			
	if self.myCurrentJob = _wle.job then
		self.updateAddWle(_wle, _mode);	
		self.tblWorkEntries.clearAllSelected(); // PAR 19710
		self.myCurrentWLE := null; // PAR 19710
	else
		self.updateAddWle(_wle, _mode);
	endif;
end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="toggleGraphicAndInfo" id="19ab1a37-05fe-443d-81dd-5db7a9febec4">
        <updating/>
        <source>toggleGraphicAndInfo() updating;
// ---------------------------------------------------------------------------
// Created:     24 August 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

lc : Control;
begin
	lc := self.splExtraInfo.getPropertyValue("myLeftControl").Control;
	if lc.visible  then
		self.xmlShowGraphic := false;
		self.xmlShowMacroInfo := true;
	else
		self.xmlShowGraphic := true;
		self.xmlShowMacroInfo := false;
	
	endif;
	if self.xmlShowGraphic then
		// HIDE MACRO INFO
		self.splExtraInfo.hideRightControl(true);
		self.mnuToggleExtraInfo.caption := app.getErrorString(Show_macro_info); //self.MNU_EXTRAINFO_SHOW;
		
		// SHOW GRAPHIC
		self.splExtraInfo.showLeftControl(100, true);
		self.mnuToggleTransportView.caption := app.getErrorString(Hide_graphic_view);
		self.mnuShowGraphic.caption := app.getErrorString(Hide_graphic_view);
		self.frmRakeToolbar.visible := true;
		self.tblInfoSmall.visible := true;
	else
	// HIDE GRAPHIC
		self.splExtraInfo.hideLeftControl( true);
		self.mnuToggleTransportView.caption := app.getErrorString(Show_graphic_view);
		self.mnuShowGraphic.caption := app.getErrorString(Show_graphic_view);
		self.frmRakeToolbar.visible := false;
		self.tblInfoSmall.visible := true;
	
	// SHOW MACRO INFO
		self.splExtraInfo.showRightControl(100 , true);
		self.mnuToggleExtraInfo.caption := app.getErrorString(Hide_macro_info); //self.MNU_EXTRAINFO_HIDE;
	endif;
	
	lc := self.splExtraInfo.getPropertyValue("myHorizontalSplitter").Control;
	lc.visible := false;
	
	self.doResizeGridContainer;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="togglePostDepart" id="675fad7d-f0cc-4c1f-b974-67eb239411b8">
        <updating/>
        <source>togglePostDepart() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 November 2009	cnwndl1	Initial creation

*/

vars
	hours : Integer;
begin

	hours := app.getMyTerminalDO_NOT_USE.getConfig(RailPostDepartVisHrs).Integer;
	
	hours := 24;
	
	if hours &lt; 1 then	// shouldn't be visible.
		self.setPostDepart();
		return;
	endif;
	
	doBuildQueryTrainList();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="2f05bff9-fbb1-4ed4-95ba-d8a543315d06">
