	app.myTrxCA.trxCreateStopsTable(pxyStopsTable, realStopsTableExt, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(realStopsTableExt, "Global Setup - realStopsTableExt");
	self.logMessage("Created Stops Table: Id:'" &amp; UT_ExtStopId.String &amp; " Code: " &amp; UT_ExtStopCode);
	
	
	//Delete Customs Action TSW BACC B07
	realCustomsAction := app.myRoot.allEDIActions[UT_BaccCustomsActionName];
	if realCustomsAction &lt;&gt; null then
		self.deleteEDIAction(UT_BaccCustomsActionName, null, EDIKeyField_Clearance);
		self.assertIsDeletedMsg(realCustomsAction, "realCustomsAction");
		self.logMessage("Deleted Customs Action: Id:'" &amp; UT_BaccCustomsActionName);
	endif;
	
	realCustomsAction := null;
	
	//Create Customs Action TSW BACC B07
	create pxyCustomsAction transient;
	pxyCustomsAction.setProxy(UT_BaccCustomsActionName, UT_BaccCustomsActionKeyword, EDIKeyField_Clearance, EDIAction_Remove, realStopsTableBacc, CM_EDIFileTypeXMLJMTInternal.firstInstance, null, null, null, CM_EDIAction.RoleCode_GC);
	app.myTrxCA.trxCreateEDIAction(pxyCustomsAction, realCustomsAction, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(realCustomsAction, "Global Setup - realCustomsAction");
	self.logMessage("Created Customs Action: Id:'" &amp; UT_BaccCustomsActionName);
	
	delete pxyCustomsAction;
	
	//Delete Customs Action TSW BACC B08
	realCustomsAction := app.myRoot.allEDIActions[UT_BaccB08CustomsActionName];
	if realCustomsAction &lt;&gt; null then
		self.deleteEDIAction(UT_BaccB08CustomsActionName, null, EDIKeyField_Clearance);
		self.assertIsDeletedMsg(realCustomsAction, "realCustomsAction");
		self.logMessage("Deleted Customs Action: Id:'" &amp; UT_BaccB08CustomsActionName);
	endif;
	
	realCustomsAction := null;
	
	//Create Customs Action TSW BACC B08
	create pxyCustomsAction transient;
	pxyCustomsAction.setProxy(UT_BaccB08CustomsActionName, UT_BaccB08CustomsActionKeyword, EDIKeyField_Clearance, EDIAction_Remove, realStopsTableBacc, CM_EDIFileTypeXMLJMTInternal.firstInstance, null, null, null, CM_EDIAction.RoleCode_GC);
	app.myTrxCA.trxCreateEDIAction(pxyCustomsAction, realCustomsAction, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(realCustomsAction, "Global Setup - realCustomsAction");
	self.logMessage("Created Customs Action: Id:'" &amp; UT_BaccB08CustomsActionName);
	
	delete pxyCustomsAction;
	
	//Delete Customs Action TSW Add External
	realCustomsAction := app.myRoot.allEDIActions[UT_ExtCustomsActionName];
	if realCustomsAction &lt;&gt; null then
		self.deleteEDIAction(UT_ExtCustomsActionName, null, EDIKeySegment_FTXDIN);
		self.assertIsDeletedMsg(realCustomsAction, "realCustomsAction");
		self.logMessage("Deleted Customs Action: Id:'" &amp; UT_ExtCustomsActionName);
	endif;
	
	realCustomsAction := null;
	
	//Create Customs Action TSW Add External
	create pxyCustomsAction transient;
	pxyCustomsAction.setProxy(UT_ExtCustomsActionName, UT_ExtCustomsActionKeyword, EDIKeySegment_FTXDIN, EDIAction_Add, realStopsTableExt, CM_EDIFileTypeXMLJMTInternal.firstInstance, null, null, null, null);
	app.myTrxCA.trxCreateEDIAction(pxyCustomsAction, realCustomsAction, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(realCustomsAction, "Global Setup - realCustomsAction");
	self.logMessage("Created Customs Action: Id:'" &amp; UT_ExtCustomsActionName);
	
	delete pxyCustomsAction;
	
	//Delete Customs Action TSW Add Internal
	realCustomsAction := app.myRoot.allEDIActions[UT_IntCustomsActionName];
	if realCustomsAction &lt;&gt; null then
		self.deleteEDIAction(UT_IntCustomsActionName, null, EDIKeySegment_FTXDIN);
		self.assertIsDeletedMsg(realCustomsAction, "realCustomsAction");
		self.logMessage("Deleted Customs Action: Id:'" &amp; UT_IntCustomsActionName);
	endif;
	
	realCustomsAction := null;
	
	//Create Customs Action TSW Add Internal
	create pxyCustomsAction transient;
	pxyCustomsAction.setProxy(UT_IntCustomsActionName, UT_IntCustomsActionKeyword, EDIKeySegment_FTXDIN, EDIAction_Add, realStopsTableInt, CM_EDIFileTypeXMLJMTInternal.firstInstance, null, null, null, null);
	app.myTrxCA.trxCreateEDIAction(pxyCustomsAction, realCustomsAction, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(realCustomsAction, "Global Setup - realCustomsAction");
	self.logMessage("Created Customs Action: Id:'" &amp; UT_IntCustomsActionName);
	
	delete pxyCustomsAction;
	
	//Delete Customs Action MPI Import Stop
	realCustomsAction := app.myRoot.allEDIActions[UT_DefaultCAMpi];
	if realCustomsAction &lt;&gt; null then
		self.deleteEDIAction(UT_DefaultCAMpi, null, EDIKeyField_Clearance);
		self.assertIsDeletedMsg(realCustomsAction, "realCustomsAction");
		self.logMessage("Deleted Customs Action: Id:'" &amp; UT_DefaultCAMpi);
	endif;
	
	realCustomsAction := null;
	
	self.logMessage("Global Setup: Finished" &amp; CrLf);
	
	/*
	**	Scenario 1:
	**	Test 1 Start - Test Role Code that is TT. Cargo is Coastal, Break-Bulk and on BOL. Should add the BACC Underbond HOLD stop with stopId as 879
	*/
	
	/*
	** Setup
	*/
	header := "Scenario 1 - Test 1 - ";
	self.logMessage(header &amp; "Started");
	
	create tiSet transient;
	
	// create cargo - two containers
	ti1 := self.addContainerAtLocation(UT_Container1, operator, "22G1", "GENL", TI_IMEX_STATUS_STORAGE, blockStack.myLocationsController);
	ti2 := self.addContainerAtLocation(UT_Container2, operator, "22G1", "GENL", TI_IMEX_STATUS_STORAGE, blockStack.myLocationsController);
	
	tiSet.add(ti1);
	tiSet.add(ti2);
	
	foreach ti in tiSet do
		self.addStopById(ti, UT_StopId);
	endforeach;
	
	create additionalDetails transient;
	
	//Container 1
	create jdo transient;
    jdo.addProperty("statementDescription", String);
	jdo.addProperty("statementDescription2", String);
	jdo.addProperty("statementTypeCode", String);
	jdo.addProperty("statementTypeCode2", String);
	jdo.addProperty("sequenceNumeric", String);
	jdo.addProperty("documentSectionCode", String);
	jdo.addProperty("transportEquipmentId", String);
	
    jdo.setPropertyValue("statementDescription", "EXTERNAL,INTERNAL");
	jdo.setPropertyValue("statementTypeCode", "MCS");
	jdo.setPropertyValue("statementDescription2", "seq:1,takenTo:CentrePort Limited, 2 Fryatt Quay, Pipitea, Wellington,for:EXTERNAL,INTERNAL,instructions:Empty container(s) to be inspected by MPI; 6-sided external and internal inspection required,issuedDate:Wednesday, 24 September 2025 3:55:32 PM,issuedBy:MPI SYSTEMS,transportEquipment:PHL00856");
	jdo.setPropertyValue("statementTypeCode2", "ICN");
	jdo.setPropertyValue("sequenceNumeric", "1");
	jdo.setPropertyValue("documentSectionCode", "31B");
	jdo.setPropertyValue("transportEquipmentId", UT_Container1);
	
	additionalDetails.add(jdo);
	
	//Container 2
	create jdo transient;
    jdo.addProperty("statementDescription", String);
	jdo.addProperty("statementDescription2", String);
	jdo.addProperty("statementTypeCode", String);
	jdo.addProperty("statementTypeCode2", String);
	jdo.addProperty("sequenceNumeric", String);
	jdo.addProperty("documentSectionCode", String);
	jdo.addProperty("transportEquipmentId", String);
	
    jdo.setPropertyValue("statementDescription", "MPI APPROVAL TO MOVE TO ATF");
	jdo.setPropertyValue("statementTypeCode", "MCS");
	jdo.setPropertyValue("statementDescription2", "seq:2,takenTo:Ports of Auckland - Akld, Ports of Auckland, Auckland,for:MPI APPROVAL TO MOVE TO ATF,instructions:.Container(s) to be checked by Nominated Accredited Person,issuedDate:Wednesday, 24 September 2025 3:55:32 PM,issuedBy:MPI SYSTEMS,transportEquipment:PHL00857");
	jdo.setPropertyValue("statementTypeCode2", "ICN");
	jdo.setPropertyValue("sequenceNumeric", "2");
	jdo.setPropertyValue("documentSectionCode", "31B");
	jdo.setPropertyValue("transportEquipmentId", UT_Container2);
	
	additionalDetails.add(jdo);
	
	ediText := self.zTSWFtxDinStorageGenFile("GC", "B08", "MPIBIO", UT_VesselCode, UT_VoyageCode, additionalDetails);
	self.assertNotNullMsg(ediText, header &amp; "Setup - ediText");
	
	/*
	** Run
	*/
	ediFile := self.ediLoadFileName(ediText, EDIFileType_XML, UT_EDIUserDefName, UT_EDIUserDefName &amp; method.name);
	self.assertNotNullMsg(ediFile, header &amp; "ediFile");
	
	// should be 1 edi tracked item
	self.assertEqualMsg(ediFile.ediData.allEDITrackedItems.size, 2, header &amp; "EDI Data has incorrect number of EDI tracked items | Expected: '2' | Actual: '" &amp; ediFile.ediData.allEDITrackedItems.size.String &amp; "'");
	
	self.ediVerify(ediFile);
	self.assertIsOneOf(ediFile.fileStatus, header &amp; 'Verify Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString, CM_EDIFile.EDI_STATUS_VERIFIED, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.logMessage(header &amp; "EDI Verified successfully");
	
	self.ediDBLoad(ediFile);
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, header &amp; "Expected: '" &amp; app.getString(Loaded) &amp; "' | Actual: '" &amp; self.zGetEdiStatus(ediFile.fileStatus) &amp; "' |  Errors: " &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString);
	self.assertNoTrxErrorsOrWarnings();
	self.logMessage(header &amp; "EDI DB Loaded successfully");
	
	/*
	** Assert
	*/
	// Check the cargo for import stop
	create allErrors transient;
	// Check the cargo for import stop
	foreach ti in tiSet do
		if ti.id = UT_Container1 then
			// stop should have been added
			if not ti.isStopSet(UT_IntStopId) then
				allErrors.add(header &amp; "Stop '" &amp; UT_IntStopId.display &amp; Space &amp; realStopsTableInt.heading.display &amp; "' does not exist for cargo '" &amp; ti.id &amp; "'");
			endif;
			
			if not ti.isStopSet(UT_ExtStopId) then
				allErrors.add(header &amp; "Stop '" &amp; UT_ExtStopId.display &amp; Space &amp; realStopsTableExt.heading.display &amp; "' does not exist for cargo '" &amp; ti.id &amp; "'");
			endif;
			
			if not ti.isStopSet(UT_StopId) then
				// stop should have been removed
				allErrors.add(header &amp; "Stop '" &amp; UT_StopId.display &amp; Space &amp; realStopsTableBacc.heading.display &amp; "' does not exist for cargo '" &amp; ti.id &amp; "'");
			endif;
			
		else
			if ti.isStopSet(UT_StopId) then
				// stop should have been removed
				allErrors.add(header &amp; "Stop '" &amp; UT_StopId.display &amp; Space &amp; realStopsTableBacc.heading.display &amp; "' exists for cargo '" &amp; ti.id &amp; "'");
			endif;
		endif;
		
	endforeach;
	
	self.assertEqualMsg(allErrors.isEmpty, true, allErrors.concatenate(CrLf));
	
	/*
	** Cleanup
	*/
	
	if additionalDetails &lt;&gt; null and additionalDetails.isNotEmpty then
		additionalDetails.purge;
	endif;
	
	delete additionalDetails;
	delete allErrors;
	
	self.logMessage(header &amp; "Finished - PASSED" &amp; CrLf);
	
	/*
	**	Test 1 End - 
	*/
	
	/*
	**	Scenario 1:
	**	Test 2 Start - 
	*/
	
	/*
	** Setup
	*/
	header := "Scenario 1 - Test 2 - ";
	self.logMessage(header &amp; "Started");
	
	//Remove Manual stops
	self.clearStopWithExpiry(ti1, realStopsTableExt, null, null);
	self.clearStopWithExpiry(ti1, realStopsTableInt, null, null);
	
	create additionalDetails transient;
	
	//Container 1
	create jdo transient;
    jdo.addProperty("statementDescription", String);
	jdo.addProperty("statementDescription2", String);
	jdo.addProperty("statementTypeCode", String);
	jdo.addProperty("statementTypeCode2", String);
	jdo.addProperty("sequenceNumeric", String);
	jdo.addProperty("documentSectionCode", String);
	jdo.addProperty("transportEquipmentId", String);
	
    jdo.setPropertyValue("statementDescription", "RELEASED");
	jdo.setPropertyValue("statementTypeCode", "MCS");
	jdo.setPropertyValue("statementDescription2", "seq:1,for:RELEASE,by:MPI,instructions:Sea container released,issuedDate:Wednesday, 24 September 2025 3:58:03 PM,issuedBy:Winter  Adrian,transportEquipment:PHL00856");
	jdo.setPropertyValue("statementTypeCode2", "ICN");
	jdo.setPropertyValue("sequenceNumeric", "1");
	jdo.setPropertyValue("documentSectionCode", "31B");
	jdo.setPropertyValue("transportEquipmentId", UT_Container1);
	
	additionalDetails.add(jdo);
	
	//Container 2
	create jdo transient;
    jdo.addProperty("statementDescription", String);
	jdo.addProperty("statementDescription2", String);
	jdo.addProperty("statementTypeCode", String);
	jdo.addProperty("statementTypeCode2", String);
	jdo.addProperty("sequenceNumeric", String);
	jdo.addProperty("documentSectionCode", String);
	jdo.addProperty("transportEquipmentId", String);
	
	jdo.setPropertyValue("sequenceNumeric", "2");
	jdo.setPropertyValue("transportEquipmentId", UT_Container2);
	
	additionalDetails.add(jdo);
	
	ediText := self.zTSWFtxDinStorageGenFile("GC", "B07", "MPIBIO", UT_VesselCode, UT_VoyageCode, additionalDetails);
	self.assertNotNullMsg(ediText, header &amp; " Setup - ediText");
	
	/*
	** Run
	*/
	ediFile := self.ediLoadFileName(ediText, EDIFileType_XML, UT_EDIUserDefName, UT_EDIUserDefName &amp; method.name);
	self.assertNotNullMsg(ediFile, header &amp;  "ediFile");
	
	// should be 1 edi tracked item
	self.assertEqualMsg(ediFile.ediData.allEDITrackedItems.size, 2, header &amp; "EDI Data has incorrect number of EDI tracked items | Expected: '2' | Actual: '" &amp; ediFile.ediData.allEDITrackedItems.size.String &amp; "'");
	
	self.ediVerify(ediFile);
	self.assertIsOneOf(ediFile.fileStatus, header &amp; 'Verify Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString, CM_EDIFile.EDI_STATUS_VERIFIED, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.logMessage(header &amp; "EDI Verified successfully");
	
	self.ediDBLoad(ediFile);
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, header &amp; "Expected: '" &amp; app.getString(Loaded) &amp; "' | Actual: '" &amp; self.zGetEdiStatus(ediFile.fileStatus) &amp; "' |  Errors: " &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString);
	self.assertNoTrxErrorsOrWarnings();
	self.logMessage(header &amp; "EDI DB Loaded successfully");
	
	/*
	** Assert
	*/
	// Check the cargo for import stop
	create allErrors transient;
	// Check the cargo for import stop
	foreach ti in tiSet do
		if ti.id = UT_Container1 then
			// stop should have been added
			if ti.isStopSet(UT_IntStopId) then
				allErrors.add(header &amp; "Stop '" &amp; UT_IntStopId.display &amp; Space &amp; realStopsTableInt.heading.display &amp; "' exists for cargo '" &amp; ti.id &amp; "'");
			endif;
			
			if ti.isStopSet(UT_ExtStopId) then
				allErrors.add(header &amp; "Stop '" &amp; UT_ExtStopId.display &amp; Space &amp; realStopsTableExt.heading.display &amp; "' exists for cargo '" &amp; ti.id &amp; "'");
			endif;
			
			if ti.isStopSet(UT_StopId) then
				// stop should have been removed
				allErrors.add(header &amp; "Stop '" &amp; UT_StopId.display &amp; Space &amp; realStopsTableBacc.heading.display &amp; "' exists for cargo '" &amp; ti.id &amp; "'");
			endif;
			
		else
			if ti.isStopSet(UT_StopId) then
				// stop should have been removed
				allErrors.add(header &amp; "Stop '" &amp; UT_StopId.display &amp; Space &amp; realStopsTableBacc.heading.display &amp; "' exists for cargo '" &amp; ti.id &amp; "'");
			endif;
		endif;
		
	endforeach;
	
	self.assertEqualMsg(allErrors.isEmpty, true, allErrors.concatenate(CrLf));
	
	/*
	** Cleanup
	*/
	delete tiSet;
	
	if additionalDetails &lt;&gt; null and additionalDetails.isNotEmpty then
		additionalDetails.purge;
	endif;
	
	delete additionalDetails;
	delete allErrors;
	
	self.logMessage(header &amp; "Finished - PASSED" &amp; CrLf);
	
	/*
	**	Scenario 1:
	**	Test 2 End
	*/
	
	/*
	**	Scenario 2:
	**	Test 1 Start:
	**	Before EDI Load:	UT_Container3 &amp; UT_Container4 has the following stops applied (TSW Awaiting BACC)
	**	After EDI Load:		UT_Container3 has the following stops applied (None), UT_Container4 has the following stops applied (TSW Awaiting BACC, MPI External Inspect - 6 sided, TSW MPI Internal Inspect)
	*/
	
	/*
	** Setup
	*/
	header := "Scenario 2 - Test 1 - ";
	self.logMessage(header &amp; "Started");
	
	create tiSet transient;
	
	// create cargo - two containers
	ti3 := self.addContainerAtLocation(UT_Container3, operator, "22G1", "GENL", TI_IMEX_STATUS_STORAGE, blockStack.myLocationsController);
	ti4 := self.addContainerAtLocation(UT_Container4, operator, "22G1", "GENL", TI_IMEX_STATUS_STORAGE, blockStack.myLocationsController);
	
	tiSet.add(ti3);
	tiSet.add(ti4);
	
	foreach ti in tiSet do
		self.addStopById(ti, UT_StopId);
	endforeach;
	
	create additionalDetails transient;
	
	//Container 1
	create jdo transient;
    jdo.addProperty("statementDescription", String);
	jdo.addProperty("statementDescription2", String);
	jdo.addProperty("statementTypeCode", String);
	jdo.addProperty("statementTypeCode2", String);
	jdo.addProperty("sequenceNumeric", String);
	jdo.addProperty("documentSectionCode", String);
	jdo.addProperty("transportEquipmentId", String);
	
    jdo.setPropertyValue("statementDescription", "MPI APPROVAL TO MOVE TO ATF");
	jdo.setPropertyValue("statementTypeCode", "MCS");
	jdo.setPropertyValue("statementDescription2", "seq:1,takenTo:CentrePort Limited, 2 Fryatt Quay, Pipitea, Wellington,for:EXTERNAL,INTERNAL,instructions:Empty container(s) to be inspected by MPI; 6-sided external and internal inspection required,issuedDate:Wednesday, 24 September 2025 3:55:32 PM,issuedBy:MPI SYSTEMS,transportEquipment:" &amp; UT_Container3);
	jdo.setPropertyValue("statementTypeCode2", "ICN");
	jdo.setPropertyValue("sequenceNumeric", "1");
	jdo.setPropertyValue("documentSectionCode", "31B");
	jdo.setPropertyValue("transportEquipmentId", UT_Container3);
	
	additionalDetails.add(jdo);
	
	//Container 2
	create jdo transient;
    jdo.addProperty("statementDescription", String);
	jdo.addProperty("statementDescription2", String);
	jdo.addProperty("statementTypeCode", String);
	jdo.addProperty("statementTypeCode2", String);
	jdo.addProperty("sequenceNumeric", String);
	jdo.addProperty("documentSectionCode", String);
	jdo.addProperty("transportEquipmentId", String);
	
	jdo.setPropertyValue("statementDescription", "EXTERNAL,INTERNAL");
	jdo.setPropertyValue("statementTypeCode", "MCS");
	jdo.setPropertyValue("statementDescription2", "seq:2,takenTo:Ports of Auckland - Akld, Ports of Auckland, Auckland,for:MPI APPROVAL TO MOVE TO ATF,instructions:.Container(s) to be checked by Nominated Accredited Person,issuedDate:Wednesday, 24 September 2025 3:55:32 PM,issuedBy:MPI SYSTEMS,transportEquipment:" &amp; UT_Container4);
	jdo.setPropertyValue("statementTypeCode2", "ICN");
	jdo.setPropertyValue("sequenceNumeric", "2");
	jdo.setPropertyValue("documentSectionCode", "31B");
	jdo.setPropertyValue("transportEquipmentId", UT_Container4);
	
	additionalDetails.add(jdo);
	
	ediText := self.zTSWFtxDinStorageGenFile("GC", "B08", "MPIBIO", UT_VesselCode, UT_VoyageCode, additionalDetails);
	self.assertNotNullMsg(ediText, header &amp; "Setup - ediText");
	
	/*
	** Run
	*/
	ediFile := self.ediLoadFileName(ediText, EDIFileType_XML, UT_EDIUserDefName, UT_EDIUserDefName &amp; method.name);
	self.assertNotNullMsg(ediFile, header &amp; "ediFile");
	
	// should be 1 edi tracked item
	self.assertEqualMsg(ediFile.ediData.allEDITrackedItems.size, 2, header &amp; "EDI Data has incorrect number of EDI tracked items | Expected: '2' | Actual: '" &amp; ediFile.ediData.allEDITrackedItems.size.String &amp; "'");
	
	self.ediVerify(ediFile);
	self.assertIsOneOf(ediFile.fileStatus, header &amp; 'Verify Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString, CM_EDIFile.EDI_STATUS_VERIFIED, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.logMessage(header &amp; "EDI Verified successfully");
	
	self.ediDBLoad(ediFile);
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, header &amp; "Expected: '" &amp; app.getString(Loaded) &amp; "' | Actual: '" &amp; self.zGetEdiStatus(ediFile.fileStatus) &amp; "' |  Errors: " &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString);
	self.assertNoTrxErrorsOrWarnings();
	self.logMessage(header &amp; "EDI DB Loaded successfully");
	
	/*
	** Assert
	*/
	// Check the cargo for import stop
	create allErrors transient;
	// Check the cargo for import stop
	foreach ti in tiSet do
		if ti.id = UT_Container4 then
			// stop should have been added
			if not ti.isStopSet(UT_IntStopId) then
				allErrors.add(header &amp; "Stop '" &amp; UT_IntStopId.display &amp; Space &amp; realStopsTableInt.heading.display &amp; "' does not exist for cargo '" &amp; ti.id &amp; "'");
			endif;
			
			if not ti.isStopSet(UT_ExtStopId) then
				allErrors.add(header &amp; "Stop '" &amp; UT_ExtStopId.display &amp; Space &amp; realStopsTableExt.heading.display &amp; "' does not exist for cargo '" &amp; ti.id &amp; "'");
			endif;
			
			if not ti.isStopSet(UT_StopId) then
				// stop should have been removed
				allErrors.add(header &amp; "Stop '" &amp; UT_StopId.display &amp; Space &amp; realStopsTableBacc.heading.display &amp; "' does not exist for cargo '" &amp; ti.id &amp; "'");
			endif;
			
		else
			if ti.isStopSet(UT_StopId) then
				// stop should have been removed
				allErrors.add(header &amp; "Stop '" &amp; UT_StopId.display &amp; Space &amp; realStopsTableBacc.heading.display &amp; "' exists for cargo '" &amp; ti.id &amp; "'");
			endif;
		endif;
		
	endforeach;
	
	self.assertEqualMsg(allErrors.isEmpty, true, allErrors.concatenate(CrLf));
	
	/*
	** Cleanup
	*/
	
	if additionalDetails &lt;&gt; null and additionalDetails.isNotEmpty then
		additionalDetails.purge;
	endif;
	
	delete additionalDetails;
	delete allErrors;
	
	self.logMessage(header &amp; "Finished - PASSED" &amp; CrLf);
	
	/*
	**	Scenario 2:
	**	Test 1 End
	*/
	
	/*
	**	Scenario 2:
	**	Test 2 Start
	**	Before EDI Load:		UT_Container3 &amp; UT_Container4 has the following stops applied (TSW Awaiting BACC, MPI External Inspect - 6 sided, TSW MPI Internal Inspect)
	**	After EDI Load:			UT_Container3 has the following stops applied (None), UT_Container4 has the following stops applied (None)
	**	Manually Removed Stops:	UT_Container4 (MPI External Inspect - 6 sided, TSW MPI Internal Inspect)
	*/
	
	/*
	** Setup
	*/
	header := "Scenario 2 - Test 2 - ";
	self.logMessage(header &amp; "Started");
	
	//Remove Manual stops
	self.clearStopWithExpiry(ti4, realStopsTableExt, null, null);
	self.clearStopWithExpiry(ti4, realStopsTableInt, null, null);
	
	create additionalDetails transient;
	
	//Container 1
	create jdo transient;
    jdo.addProperty("statementDescription", String);
	jdo.addProperty("statementDescription2", String);
	jdo.addProperty("statementTypeCode", String);
	jdo.addProperty("statementTypeCode2", String);
	jdo.addProperty("sequenceNumeric", String);
	jdo.addProperty("documentSectionCode", String);
	jdo.addProperty("transportEquipmentId", String);
	
    jdo.setPropertyValue("statementDescription", "MPI APPROVAL TO MOVE TO ATF");
	jdo.setPropertyValue("statementTypeCode", "MCS");
	jdo.setPropertyValue("statementDescription2", "seq:1,takenTo:Ports of Auckland - Akld, Ports of Auckland, Auckland,for:MPI APPROVAL TO MOVE TO ATF,by:ACCREDITED PERSON,instructions:.Container(s) to be checked by Nominated Accredited Person,issuedDate:Wednesday, 24 September 2025 4:29:36 PM,issuedBy:MPI SYSTEMS,transportEquipment:" &amp; UT_Container3 &amp; "," &amp; UT_Container4);
	jdo.setPropertyValue("statementTypeCode2", "ICN");
	jdo.setPropertyValue("sequenceNumeric", "1");
	jdo.setPropertyValue("documentSectionCode", "31B");
	jdo.setPropertyValue("transportEquipmentId", UT_Container3);
	
	additionalDetails.add(jdo);
	
	//Container 2
	create jdo transient;
    jdo.addProperty("statementDescription", String);
	jdo.addProperty("statementDescription2", String);
	jdo.addProperty("statementTypeCode", String);
	jdo.addProperty("statementTypeCode2", String);
	jdo.addProperty("sequenceNumeric", String);
	jdo.addProperty("documentSectionCode", String);
	jdo.addProperty("transportEquipmentId", String);
	
	jdo.setPropertyValue("statementDescription", "MPI APPROVAL TO MOVE TO ATF");
	jdo.setPropertyValue("statementTypeCode", "MCS");
	jdo.setPropertyValue("sequenceNumeric", "2");
	jdo.setPropertyValue("documentSectionCode", "31B");
	jdo.setPropertyValue("transportEquipmentId", UT_Container4);
	
	additionalDetails.add(jdo);
	
	ediText := self.zTSWFtxDinStorageGenFile("GC", "B07", "MPIBIO", UT_VesselCode, UT_VoyageCode, additionalDetails);
	self.assertNotNullMsg(ediText, header &amp; "Setup - ediText");
	
	/*
	** Run
	*/
	ediFile := self.ediLoadFileName(ediText, EDIFileType_XML, UT_EDIUserDefName, UT_EDIUserDefName &amp; method.name);
	self.assertNotNullMsg(ediFile, header &amp; "ediFile");
	
	// should be 1 edi tracked item
	self.assertEqualMsg(ediFile.ediData.allEDITrackedItems.size, 2, header &amp; "EDI Data has incorrect number of EDI tracked items | Expected: '2' | Actual: '" &amp; ediFile.ediData.allEDITrackedItems.size.String &amp; "'");
	
	self.ediVerify(ediFile);
	self.assertIsOneOf(ediFile.fileStatus, header &amp; 'Verify Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString, CM_EDIFile.EDI_STATUS_VERIFIED, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.logMessage(header &amp; "EDI Verified successfully");
	
	self.ediDBLoad(ediFile);
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, header &amp; "Expected: '" &amp; app.getString(Loaded) &amp; "' | Actual: '" &amp; self.zGetEdiStatus(ediFile.fileStatus) &amp; "' |  Errors: " &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString);
	self.assertNoTrxErrorsOrWarnings();
	self.logMessage(header &amp; "EDI DB Loaded successfully");
	
	/*
	** Assert
	*/
	// Check the cargo for import stop
	create allErrors transient;
	// Check the cargo for import stop
	foreach ti in tiSet do
		if ti.id = UT_Container4 then
			// stop should have been added
			if ti.isStopSet(UT_IntStopId) then
				allErrors.add(header &amp; "Stop '" &amp; UT_IntStopId.display &amp; Space &amp; realStopsTableInt.heading.display &amp; "' exists for cargo '" &amp; ti.id &amp; "'");
			endif;
			
			if ti.isStopSet(UT_ExtStopId) then
				allErrors.add(header &amp; "Stop '" &amp; UT_ExtStopId.display &amp; Space &amp; realStopsTableExt.heading.display &amp; "' exists for cargo '" &amp; ti.id &amp; "'");
			endif;
			
			if ti.isStopSet(UT_StopId) then
				// stop should have been removed
				allErrors.add(header &amp; "Stop '" &amp; UT_StopId.display &amp; Space &amp; realStopsTableBacc.heading.display &amp; "' exists for cargo '" &amp; ti.id &amp; "'");
			endif;
			
		else
			if ti.isStopSet(UT_StopId) then
				// stop should have been removed
				allErrors.add(header &amp; "Stop '" &amp; UT_StopId.display &amp; Space &amp; realStopsTableBacc.heading.display &amp; "' exists for cargo '" &amp; ti.id &amp; "'");
			endif;
		endif;
		
	endforeach;
	
	self.assertEqualMsg(allErrors.isEmpty, true, allErrors.concatenate(CrLf));
	
	/*
	** Cleanup
	*/
	delete tiSet;
	
	self.logMessage(header &amp; "Finished - PASSED" &amp; CrLf);
	
	/*
	**	Scenario 2:
	**	Test 2 End
	*/
	
	/*
	** Global Cleanup
	*/
	self.logMessage("Global Cleanup: Started");
	
	//Delete BlockStack
	self.deleteTerminalArea(UT_BlockStack);
	self.logMessage("Deleted Blockstack: Id:'" &amp; UT_BlockStack);
	
	//Delete Voyage
	self.deleteVoyage(UT_VoyageCode);
	self.logMessage("Deleted Voyage: Id:'" &amp; UT_VoyageCode);
	
	//Delete Vessel
	self.deleteVessel(UT_VesselCode);
	self.logMessage("Deleted Vessel: Id:'" &amp; UT_VesselCode);
	
	
	//Delete Customs Action TSW BACC B07
	realCustomsAction := app.myRoot.allEDIActions[UT_BaccCustomsActionName];
	if realCustomsAction &lt;&gt; null then
		self.deleteEDIAction(UT_BaccCustomsActionName, null, EDIKeyField_Clearance);
		self.assertIsDeletedMsg(realCustomsAction, "realCustomsAction");
		self.logMessage("Deleted Customs Action: Id:'" &amp; UT_BaccCustomsActionName);
	endif;
	
	realCustomsAction := null;
	
	//Delete Customs Action TSW BACC B08
	realCustomsAction := app.myRoot.allEDIActions[UT_BaccB08CustomsActionName];
	if realCustomsAction &lt;&gt; null then
		self.deleteEDIAction(UT_BaccB08CustomsActionName, null, EDIKeyField_Clearance);
		self.assertIsDeletedMsg(realCustomsAction, "realCustomsAction");
		self.logMessage("Deleted Customs Action: Id:'" &amp; UT_BaccB08CustomsActionName);
	endif;
	
	realCustomsAction := null;
	
	//Delete Customs Action TSW Add External
	realCustomsAction := app.myRoot.allEDIActions[UT_ExtCustomsActionName];
	if realCustomsAction &lt;&gt; null then
		self.deleteEDIAction(UT_ExtCustomsActionName, null, EDIKeySegment_FTXDIN);
		self.assertIsDeletedMsg(realCustomsAction, "realCustomsAction");
		self.logMessage("Deleted Customs Action: Id:'" &amp; UT_ExtCustomsActionName);
	endif;
	
	realCustomsAction := null;
	
	//Delete Customs Action TSW Add Internal
	realCustomsAction := app.myRoot.allEDIActions[UT_IntCustomsActionName];
	if realCustomsAction &lt;&gt; null then
		self.deleteEDIAction(UT_IntCustomsActionName, null, EDIKeySegment_FTXDIN);
		self.assertIsDeletedMsg(realCustomsAction, "realCustomsAction");
		self.logMessage("Deleted Customs Action: Id:'" &amp; UT_IntCustomsActionName);
	endif;
	
	realCustomsAction := null;
	
	//Set Stops not available for entry
	beginTransaction;
	realStopsTableBacc.setPropertyValue(CM_StopsTable::isNotAvailableForEntry.name, true);
	realStopsTableInt.setPropertyValue(CM_StopsTable::isNotAvailableForEntry.name, true);
	realStopsTableExt.setPropertyValue(CM_StopsTable::isNotAvailableForEntry.name, true);
	app.cmsCommitTransaction(app.myPassport);
	
	realStopsTableDefaultExt := self.getRoot.getStopTableForId(945);
	realStopsTableDefaultInt := self.getRoot.getStopTableForId(72);
	realStopsTableDefaultMpi := self.getRoot.getStopTableForId(788);
	
	//Create Customs Action MPI Import Stop
	create pxyCustomsAction transient;
	pxyCustomsAction.setProxy(UT_DefaultCAMpi, UT_DefaultCAMpiActionKeyword, EDIKeyField_Clearance, EDIAction_Add, realStopsTableDefaultMpi, CM_EDIFileTypeXMLJMTInternal.firstInstance, null, null, null, null);
	app.myTrxCA.trxCreateEDIAction(pxyCustomsAction, realCustomsAction, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(realCustomsAction, "Global Setup - realCustomsAction");
	self.logMessage("Created Customs Action: Id:'" &amp; UT_DefaultCAMpi);
	
	self.logMessage("Global Cleanup: Finished");
	
	completedOk := true;
	
epilog
	if not completedOk and realStopsTableBacc &lt;&gt; null and realStopsTableInt &lt;&gt; null and realStopsTableExt &lt;&gt; null then
		abortTransaction;
		beginTransaction;
		realStopsTableBacc.setPropertyValue(CM_StopsTable::isNotAvailableForEntry.name, true);
		realStopsTableInt.setPropertyValue(CM_StopsTable::isNotAvailableForEntry.name, true);
		realStopsTableExt.setPropertyValue(CM_StopsTable::isNotAvailableForEntry.name, true);
		commitTransaction;
	endif;
	
	if additionalDetails &lt;&gt; null and additionalDetails.isNotEmpty then
		additionalDetails.purge;
	endif;
	
	delete additionalDetails;
	
	delete systemUTHelper;
	delete terminalUTHelper;
	delete pxyStopsTable;
	delete pxyCustomsAction;
	delete processAreasArr;
	delete setAreasArr;
	delete checkAreasArr;
	delete cargoTypeSet;
	delete imexStatusSet;
	delete tiSet;
	delete allErrors;
	

end;</source>
    </JadeMethod>
    <JadeMethod name="tTSWcntnr_IM1_830" id="e2df530c-b09e-422f-bf32-446625dd33f7">
        <source>tTSWcntnr_IM1_830();
// jlgdap1
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Sep 2019	jlgsl4	861.080 cut - add more TSW UTs
*/
constants
	USER_DEF_NAME	= 'TSW';
	VoyageName1		= 'PAR24050_1';
	BoatName1		= 'PAR24050Boat1';
	ContName		= 'UTUT1011011';
	TestOperator	= 'MSL';
vars
	tempStr			: String;
	billOfLadingStr	: String;
	ediText			: String;
	container		: CM_Container;
	operator		: CM_Operator;
	vessel			: CM_Vessel;
	voyage			: CM_Voyage;
	stopsTable		: CM_StopsTable;
	ediFile			: CM_EDIFile;
begin	
	// Set up our required terminal config parameters (these are automatically set back after the test finishes)
	self.setTerminalConfig(GateInAutoBOLNumber, true);
    self.setTerminalConfig(NoImportStops, false);
	
	// Get our operator
	operator := self.getOperator(TestOperator);
	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; TestOperator.display);
	
	// Get our stops table
	stopsTable := self.getRoot.getStopTableForId(TI_Stop_Customs);
	self.assertNotNullMsg(stopsTable, 'StopsTable ' &amp; TI_Stop_Customs.display &amp; ' does not exist');
	self.assertTrueMsg(stopsTable.isImportStop(self.getTerminal), "Expecting Customs Import Docs Stop to be an Import stop");
	self.assertTrueMsg(stopsTable.isValidForFulls(true, self.getTerminal), "Expecting Customs Import Docs stop 'Is Full' and 'Is MT' to be true");	
	
	// delete required voyages and vessels
	self.deleteVoyage(VoyageName1);
	voyage	:= self.getVoyage(VoyageName1);
	self.assertIsDeleted(voyage);
	
	self.deleteVessel(BoatName1);
	vessel	:= self.getVessel(BoatName1);
	self.assertIsDeleted(vessel);
	
	// delete the cargo - this should have already been done if on the voyage, but just in case.
	self.deleteCargo(ContName, self.getRoot.allCargoTypesById[TI_CargoType_Container]);
	container := self.getTrackedItem(ContName).CM_Container;
	self.assertIsDeleted(container);
	
	// Create the required voyage and vessel
	vessel := self.addVesselCellular(BoatName1, operator);
	self.assertNotNullMsg(vessel, 'Add vessel ' &amp; BoatName1.display &amp; ' failed');
	
	voyage	:= self.addVoyageWithContainerStructur(VoyageName1,
													BoatName1,
													TestOperator, 
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage ' &amp; VoyageName1 &amp; ' failed');
	
	// finally add this cargo to the voyage
	self.opts.addAssocIfNotNull(ETRow_CargoType, TI_CargoType_Container);
	container := self.addContainerForExport(ContName,
										operator,
										"2200",
										null,					// commodity is not needed
										TI_IMEX_STATUS_IMPORT,	// import not export
										null,					// booking id
										voyage.code,
										null,					// dischargePort
										null).CM_Container;		// transhipToPort
	tempStr	:= 'Adding container ' &amp; ContName.display &amp; ' failed.' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container, tempStr);
	
	// Check that container has "Customs Import Doc" stop on.
	tempStr	:= 'Stop ' &amp; TI_Stop_Customs.display &amp; Space &amp; stopsTable.heading.display &amp; ' does not exist for container ' &amp; ContName.display;
	self.assertEqualMsg(container.isStopSet(TI_Stop_Customs), true, tempStr);
	
	// This gets set each time by the system - see CM_TrackedItem::setForCreate and Gate configuration form
	billOfLadingStr	:= container.billOfLading;
	tempStr	:= 'BillOfLading has not been set up';
	self.assertEqualMsg(billOfLadingStr &lt;&gt; null, true, tempStr);
	
	// This is an untransformed message similar to what we would get back from the customs web service
	ediText	:=
		"&lt;DocumentMetadata xmlns='urn:wco:datamodel:WCO:DM:1' xmlns:xsi='http://www.w3.org/2001/XMLSchema-instance'&gt;
		  &lt;WCODataModelVersion&gt;3.2&lt;/WCODataModelVersion&gt;
		  &lt;WCODocumentName&gt;RES&lt;/WCODocumentName&gt;
		  &lt;CountryCode&gt;NZ&lt;/CountryCode&gt;
		  &lt;AgencyAssignedCustomizedDocumentName&gt;RESIM1&lt;/AgencyAssignedCustomizedDocumentName&gt;
		  &lt;AgencyAssignedCustomizedDocumentVersion&gt;V1.1&lt;/AgencyAssignedCustomizedDocumentVersion&gt;
		  &lt;CommunicationMetaData&gt;
			&lt;Recipient&gt;
			  &lt;ID&gt;40048675B&lt;/ID&gt;
			  &lt;RoleCode&gt;GC&lt;/RoleCode&gt;
			&lt;/Recipient&gt;
		  &lt;/CommunicationMetaData&gt;
		  &lt;Response xmlns='urn:wco:datamodel:WCO:ResponseModel:1'&gt;
			&lt;IssueDateTime formatCode='204' &gt;20180301093226&lt;/IssueDateTime&gt;
			&lt;FunctionalReferenceID&gt;99&lt;/FunctionalReferenceID&gt;
			&lt;FunctionCode&gt;23&lt;/FunctionCode&gt;
			&lt;OverallDeclaration&gt;
			  &lt;Declaration&gt;
				&lt;ID&gt;80741537&lt;/ID&gt;
				&lt;FunctionalReferenceID&gt;CH010318_IM11&lt;/FunctionalReferenceID&gt;
				&lt;TotalGrossMassMeasure unitCode='KGM' &gt;1500&lt;/TotalGrossMassMeasure&gt;
				&lt;VersionID&gt;3&lt;/VersionID&gt;
				&lt;CancellationDateTime formatCode='204' &gt;20180301093226&lt;/CancellationDateTime&gt;
				&lt;JurisdictionDateTime formatCode='102' &gt;20180305&lt;/JurisdictionDateTime&gt;
				&lt;Submitter&gt;
				  &lt;Name&gt;CH Brokers&lt;/Name&gt;
				&lt;/Submitter&gt;
				&lt;Agent&gt;
				  &lt;Name&gt;CH Brokers&lt;/Name&gt;
				&lt;/Agent&gt;
				&lt;BorderTransportMeans&gt;
				  &lt;Name&gt;" &amp; BoatName1 &amp; "&lt;/Name&gt;
				  &lt;ID&gt;8765432&lt;/ID&gt;
				  &lt;TypeCode&gt;1&lt;/TypeCode&gt;
				  &lt;JourneyID&gt;" &amp; VoyageName1 &amp; "&lt;/JourneyID&gt;
				&lt;/BorderTransportMeans&gt;
				&lt;Carrier&gt;
				  &lt;Name&gt;ANL LINE&lt;/Name&gt;
				&lt;/Carrier&gt;
				&lt;GoodsShipment&gt;
				  &lt;Consignment&gt;
					&lt;TransportContractDocument&gt;
					  &lt;ID&gt;BILL123456&lt;/ID&gt;
					  &lt;TypeCode&gt;BM&lt;/TypeCode&gt;
					  &lt;Pointer&gt;
						&lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
						&lt;DocumentSectionCode&gt;31B&lt;/DocumentSectionCode&gt;
					  &lt;/Pointer&gt;
					&lt;/TransportContractDocument&gt;
					&lt;TransportEquipment&gt;
					  &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
					  &lt;FullnessCode&gt;5&lt;/FullnessCode&gt;
					  &lt;ID&gt;" &amp; ContName &amp; "&lt;/ID&gt;
					  &lt;Pointer&gt;
						&lt;DocumentSectionCode&gt;42A&lt;/DocumentSectionCode&gt;
					  &lt;/Pointer&gt;
					  &lt;Pointer&gt;
						&lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
						&lt;DocumentSectionCode&gt;93A&lt;/DocumentSectionCode&gt;
					  &lt;/Pointer&gt;
					&lt;/TransportEquipment&gt;
				  &lt;/Consignment&gt;
				&lt;/GoodsShipment&gt;
				&lt;Importer&gt;
				  &lt;Name&gt;CH Importers&lt;/Name&gt;
				&lt;/Importer&gt;
				&lt;Packaging&gt;
				  &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
				  &lt;QuantityQuantity&gt;55&lt;/QuantityQuantity&gt;
				  &lt;TypeCode&gt;CT&lt;/TypeCode&gt;
				&lt;/Packaging&gt;
				&lt;UnloadingLocation&gt;
				  &lt;ID&gt;NZNSN&lt;/ID&gt;
				&lt;/UnloadingLocation&gt;
				&lt;ResponsibleGovernmentAgency&gt;
				  &lt;ID&gt;NZCS&lt;/ID&gt;
				&lt;/ResponsibleGovernmentAgency&gt;
			  &lt;/Declaration&gt;
			&lt;/OverallDeclaration&gt;
			&lt;Status&gt;
			  &lt;EffectiveDateTime formatCode='204' &gt;20180301093226&lt;/EffectiveDateTime&gt;
			  &lt;NameCode&gt;830&lt;/NameCode&gt;
			  &lt;Pointer&gt;
				&lt;DocumentSectionCode&gt;07B&lt;/DocumentSectionCode&gt;
			  &lt;/Pointer&gt;
			  &lt;Pointer&gt;
				&lt;DocumentSectionCode&gt;42A&lt;/DocumentSectionCode&gt;
			  &lt;/Pointer&gt;
			  &lt;Pointer&gt;
				&lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
				&lt;DocumentSectionCode&gt;08B&lt;/DocumentSectionCode&gt;
				&lt;TagID&gt;G007&lt;/TagID&gt;
			  &lt;/Pointer&gt;
			&lt;/Status&gt;
		  &lt;/Response&gt;
		&lt;/DocumentMetadata&gt;";

	// load the edi data, verify and load to database
	ediText := ediText.replace("statusText", "WOF"); // set message's GoodsStatusCode to write-off eg. clear stop
	ediFile	:= self.ediLoadFileName(ediText, EDIFileType_XML, USER_DEF_NAME, USER_DEF_NAME &amp; method.name);
	self.assertNotNull(ediFile);
	
	// Some common statuses are:
	// 3 = EDI_STATUS_VERIFIED, 14 = EDI_STATUS_VERIFIED_WARNINGS
	// 5 = EDI_STATUS_DBLOADED, 19 = EDI_STATUS_DBLOADED_PARTIAL
	self.ediVerify( ediFile );
	tempStr	:= 'Verify Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_VERIFIED, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	
	self.ediDBLoad(ediFile);

	tempStr	:= 'DBLoad Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	self.assertNoTrxErrorsOrWarnings();
	
	// Check that container has "Customs Import Doc" stop off.
	tempStr	:= 'Stop ' &amp; TI_Stop_Customs.display &amp; Space &amp; stopsTable.heading.display &amp; ' still exists for container ' &amp; ContName.display;
	self.assertEqualMsg(container.isStopSet(TI_Stop_Customs), false, tempStr);

	// Check that container has 'IM1AllClear' set.
	tempStr	:= 'Container ' &amp; ContName &amp; ' does not have IM1AllClear set';
	self.assertEqualMsg(container.hasTSWAllClear(TI_Stop_Customs), true, tempStr);
	
	// now test that ICR can't add 'Customs Import Doc' back b/c of IM1AllClear
	ediText	:=
		"&lt;DocumentMetadata xmlns='urn:wco:datamodel:WCO:DM:1' xmlns:xsi='http://www.w3.org/2001/XMLSchema-instance'&gt;
		  &lt;WCODataModelVersion&gt;3.2&lt;/WCODataModelVersion&gt;
		  &lt;WCODocumentName&gt;RES&lt;/WCODocumentName&gt;
		  &lt;CountryCode&gt;NZ&lt;/CountryCode&gt;
		  &lt;AgencyAssignedCustomizedDocumentName&gt;RESICR&lt;/AgencyAssignedCustomizedDocumentName&gt;
		  &lt;AgencyAssignedCustomizedDocumentVersion&gt;V1.0&lt;/AgencyAssignedCustomizedDocumentVersion&gt;
		  &lt;CommunicationMetaData&gt;
			&lt;Recipient&gt;
			  &lt;ID&gt;51358641J&lt;/ID&gt;
			  &lt;RoleCode&gt;GC&lt;/RoleCode&gt;
			&lt;/Recipient&gt;
		  &lt;/CommunicationMetaData&gt;
		  &lt;Response xmlns='urn:wco:datamodel:WCO:ResponseModel:1'&gt;
			&lt;IssueDateTime formatCode='204' &gt;20180718145109&lt;/IssueDateTime&gt;
			&lt;FunctionalReferenceID&gt;354&lt;/FunctionalReferenceID&gt;
			&lt;FunctionCode&gt;24&lt;/FunctionCode&gt;
			&lt;OverallDeclaration&gt;
			  &lt;Declaration&gt;
				&lt;ID&gt;99156761&lt;/ID&gt;
				&lt;AcceptanceDateTime formatCode='204' &gt;20180718145109&lt;/AcceptanceDateTime&gt;
				&lt;FunctionalReferenceID&gt;PW_ICR008&lt;/FunctionalReferenceID&gt;
				&lt;VersionID&gt;1&lt;/VersionID&gt;
				&lt;Submitter&gt;
				  &lt;Name&gt;EXT ONline Broker&lt;/Name&gt;
				&lt;/Submitter&gt;
				&lt;BorderTransportMeans&gt;
				  &lt;Name&gt; " &amp; BoatName1 &amp; "&lt;/Name&gt;
				  &lt;TypeCode&gt;1&lt;/TypeCode&gt;
				  &lt;ArrivalDateTime formatCode='102'&gt;20180720&lt;/ArrivalDateTime&gt;
				  &lt;FirstArrivalLocationID&gt;NZWLG&lt;/FirstArrivalLocationID&gt;
				  &lt;JourneyID&gt;" &amp; VoyageName1 &amp; "&lt;/JourneyID&gt;
				&lt;/BorderTransportMeans&gt;
				&lt;Consignment&gt;
				  &lt;GoodsStatusCode StatusType='CLEARANCE'&gt;HLD&lt;/GoodsStatusCode&gt;
				  &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
				  &lt;Consignee&gt;
					&lt;Name&gt;Maersk Line&lt;/Name&gt;
				  &lt;/Consignee&gt;
				  &lt;Consignor&gt;
					&lt;Name&gt;Maersk&lt;/Name&gt;
				  &lt;/Consignor&gt;
				  &lt;TransportContractDocument&gt;
					&lt;ID&gt;1236467&lt;/ID&gt;
					&lt;TypeCode&gt;BM&lt;/TypeCode&gt;
				  &lt;/TransportContractDocument&gt;
				  &lt;TransportEquipment&gt;
					&lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
					&lt;FullnessCode&gt;4&lt;/FullnessCode&gt;
					&lt;ID&gt;" &amp; ContName &amp; "&lt;/ID&gt;
				  &lt;/TransportEquipment&gt;
				  &lt;UnloadingLocation&gt;
					&lt;ID&gt;NZWLG&lt;/ID&gt;
				  &lt;/UnloadingLocation&gt;
				&lt;/Consignment&gt;
				&lt;ResponsibleGovernmentAgency&gt;
				  &lt;ID&gt;NZCS&lt;/ID&gt;
				&lt;/ResponsibleGovernmentAgency&gt;
			  &lt;/Declaration&gt;
			&lt;/OverallDeclaration&gt;
			&lt;Status&gt;
			  &lt;EffectiveDateTime formatCode='204'&gt;20180718145109&lt;/EffectiveDateTime&gt;
			  &lt;NameCode&gt;C06&lt;/NameCode&gt;
			  &lt;ReleaseDateTime formatCode='204' &gt;20180718145109&lt;/ReleaseDateTime&gt;
			  &lt;Pointer&gt;
				&lt;DocumentSectionCode&gt;07B&lt;/DocumentSectionCode&gt;
			  &lt;/Pointer&gt;
			  &lt;Pointer&gt;
				&lt;DocumentSectionCode&gt;42A&lt;/DocumentSectionCode&gt;
			  &lt;/Pointer&gt;
			  &lt;Pointer&gt;
				&lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
				&lt;DocumentSectionCode&gt;08B&lt;/DocumentSectionCode&gt;
				&lt;TagID&gt;G007&lt;/TagID&gt;
			  &lt;/Pointer&gt;
			&lt;/Status&gt;
		  &lt;/Response&gt;
		&lt;/DocumentMetadata&gt;";

	// load the edi data, verify and load to database
	ediFile	:= self.ediLoadFileName(ediText, EDIFileType_XML, USER_DEF_NAME, USER_DEF_NAME &amp; method.name);
	self.assertNotNull(ediFile);
	
	// Some common statuses are:
	// 3 = EDI_STATUS_VERIFIED, 14 = EDI_STATUS_VERIFIED_WARNINGS
	// 5 = EDI_STATUS_DBLOADED, 19 = EDI_STATUS_DBLOADED_PARTIAL
	self.ediVerify( ediFile );
	tempStr	:= 'Verify Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_VERIFIED, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	
	self.ediDBLoad(ediFile);

	tempStr	:= 'DBLoad Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	self.assertNoTrxErrorsOrWarnings();
	
	// Check the container still has "Customs Import Doc" stop off.
	tempStr	:= 'Stop ' &amp; TI_Stop_Customs.display &amp; Space &amp; stopsTable.heading.display &amp; ' still exists for container ' &amp; ContName.display;
	self.assertEqualMsg(container.isStopSet(TI_Stop_Customs), false, tempStr);
epilog
	self.deleteContainer(ContName);
	self.deleteVoyage(VoyageName1);
	self.deleteVessel(BoatName1);
end;</source>
    </JadeMethod>
    <JadeMethod name="tTSWcntnr_IM1_B06" id="4f3b8d01-2a6f-4c3f-9b56-ef1d2e51e3ac">
        <source>tTSWcntnr_IM1_B06();
// jlgdap1
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Sep 2019	jlgsl4	861.080 cut - add more TSW UTs
*/
constants
	USER_DEF_NAME	= 'TSW';
	VoyageName1		= 'PAR24050_1';
	BoatName1		= 'PAR24050Boat1';
	ContName		= 'UTUT1011011';
	TestOperator	= 'MSL';
vars
	tempStr			: String;
	billOfLadingStr	: String;
	ediText			: String;
	container		: CM_Container;
	operator		: CM_Operator;
	vessel			: CM_Vessel;
	voyage			: CM_Voyage;
	stopsTable		: CM_StopsTable;
	ediFile			: CM_EDIFile;
	previousLogLevel	: Integer;
begin
	previousLogLevel := app.logLevel;
//	app.changeLogLevel(LogTRACE);

	// Set up our required terminal config parameters (these are automatically set back after the test finishes)
	self.setTerminalConfig(GateInAutoBOLNumber, true);
    self.setTerminalConfig(NoImportStops, false);
	
	// Get our operator
	operator := self.getOperator(TestOperator);
	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; TestOperator.display);
	
	// Get our stops table
	stopsTable := self.getRoot.getStopTableForId(TI_Stop_MAF);
	self.assertNotNullMsg(stopsTable, 'StopsTable ' &amp; TI_Stop_MAF.display &amp; ' does not exist');
	self.assertTrueMsg(stopsTable.isImportStop(self.getTerminal), "Expecting MAF Stop to be an Import stop");
	self.assertTrueMsg(stopsTable.isValidForFulls(false, self.getTerminal), "Expecting MAF stop 'Is Full' to be true");

	// delete required voyages and vessels
	self.deleteVoyage(VoyageName1);
	voyage	:= self.getVoyage(VoyageName1);
	self.assertIsDeleted(voyage);
	
	self.deleteVessel(BoatName1);
	vessel	:= self.getVessel(BoatName1);
	self.assertIsDeleted(vessel);
	
	// delete the cargo - this should have already been done if on the voyage, but just in case.
	self.deleteCargo(ContName, self.getRoot.allCargoTypesById[TI_CargoType_Container]);
	container := self.getTrackedItem(ContName).CM_Container;
	self.assertIsDeleted(container);
	
	// Create the required voyage and vessel
	vessel := self.addVesselCellular(BoatName1, operator);
	self.assertNotNullMsg(vessel, 'Add vessel ' &amp; BoatName1.display &amp; ' failed');
	
	voyage	:= self.addVoyageWithContainerStructur(VoyageName1,
													BoatName1,
													TestOperator, 
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage ' &amp; VoyageName1 &amp; ' failed');
	self.addVoyageToEDIProcessing(voyage);

	// finally add this cargo to the voyage
	/*self.opts.addAssocIfNotNull(ETRow_CargoType, TI_CargoType_Container); // --&gt; 861.080
	container := self.addContainerForExport(ContName,
										operator,
										"2200",
										null,					// commodity is not needed
										TI_IMEX_STATUS_IMPORT,	// import not export
										null,					// booking id
										voyage.code,
										null,					// dischargePort
										null).CM_Container;		// transhipToPort*/ // &lt;-- 861.080
	container := self.addContainerOnShip(ContName, // --&gt; 861.080
										operator,
										"2200",
										null,
										null,
										voyage,
										"NZPOE",
										VoyageName1).CM_Container; // &lt;-- 861.080
	tempStr	:= 'Adding container ' &amp; ContName.display &amp; ' failed.' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container, tempStr);
	
	// Check that the container has "Customs Import Doc" stop on.
	tempStr	:= 'Stop ' &amp; TI_Stop_MAF.display &amp; Space &amp; stopsTable.heading.display &amp; ' does not exist for container ' &amp; ContName.display;
	self.assertEqualMsg(container.isStopSet(TI_Stop_MAF), true, tempStr);
	
	// This gets set each time by the system - see CM_TrackedItem::setForCreate and Gate configuration form
	billOfLadingStr	:= container.billOfLading;
	tempStr	:= 'BillOfLading has not been set up';
	self.assertEqualMsg(billOfLadingStr &lt;&gt; null, true, tempStr);
	
	// This is an untransformed message similar to what we would get back from the customs web service
	ediText	:=
		"&lt;DocumentMetadata xmlns='urn:wco:datamodel:WCO:DM:1' xmlns:xsi='http://www.w3.org/2001/XMLSchema-instance'&gt;
		  &lt;WCODataModelVersion&gt;3.2&lt;/WCODataModelVersion&gt;
		  &lt;WCODocumentName&gt;RES&lt;/WCODocumentName&gt;
		  &lt;CountryCode&gt;NZ&lt;/CountryCode&gt;
		  &lt;AgencyAssignedCustomizedDocumentName&gt;RESIM1&lt;/AgencyAssignedCustomizedDocumentName&gt;
		  &lt;AgencyAssignedCustomizedDocumentVersion&gt;V1.1&lt;/AgencyAssignedCustomizedDocumentVersion&gt;
		  &lt;CommunicationMetaData&gt;
			&lt;Recipient&gt;
			  &lt;ID&gt;40048675B&lt;/ID&gt;
			  &lt;RoleCode&gt;GC&lt;/RoleCode&gt;
			&lt;/Recipient&gt;
		  &lt;/CommunicationMetaData&gt;
		  &lt;Response xmlns='urn:wco:datamodel:WCO:ResponseModel:1'&gt;
			&lt;IssueDateTime formatCode='204' &gt;20180301082338&lt;/IssueDateTime&gt;
			&lt;FunctionalReferenceID&gt;94&lt;/FunctionalReferenceID&gt;
			&lt;FunctionCode&gt;23&lt;/FunctionCode&gt;
			&lt;AdditionalDocument&gt;
			  &lt;CategoryCode&gt;BAC&lt;/CategoryCode&gt;
			  &lt;ImageBinaryObject mimeCode='application/pdf' uri='idd_EED5F009-1B64-41B4-8803-2D360B8DCAA2' filename='PDF9-80741533-2018-03-01-0803683023.pdf' &gt;Attached&lt;/ImageBinaryObject&gt;
			&lt;/AdditionalDocument&gt;
			&lt;AdditionalInformation&gt;
			  &lt;StatementDescription&gt;MPI APPROVAL TO MOVE TO ATF 123 Test Wellington 6012&lt;/StatementDescription&gt;
			  &lt;StatementTypeCode&gt;DIN&lt;/StatementTypeCode&gt;
			&lt;/AdditionalInformation&gt;
			&lt;OverallDeclaration&gt;
			  &lt;Declaration&gt;
				&lt;ID&gt;80741533&lt;/ID&gt;
				&lt;AcceptanceDateTime formatCode='204' &gt;20180301082338&lt;/AcceptanceDateTime&gt;
				&lt;FunctionalReferenceID&gt;CH010318_IM11&lt;/FunctionalReferenceID&gt;
				&lt;TotalGrossMassMeasure unitCode='KGM' &gt;1500&lt;/TotalGrossMassMeasure&gt;
				&lt;VersionID&gt;1&lt;/VersionID&gt;
				&lt;JurisdictionDateTime formatCode='102' &gt;20180305&lt;/JurisdictionDateTime&gt;
				&lt;Submitter&gt;
				  &lt;Name&gt;CH Brokers&lt;/Name&gt;
				&lt;/Submitter&gt;
				&lt;Agent&gt;
				  &lt;Name&gt;CH Brokers&lt;/Name&gt;
				&lt;/Agent&gt;
				&lt;BorderTransportMeans&gt;
				  &lt;Name&gt;" &amp; BoatName1 &amp; "&lt;/Name&gt;
				  &lt;ID&gt;8765432&lt;/ID&gt;
				  &lt;TypeCode&gt;1&lt;/TypeCode&gt;
				  &lt;JourneyID&gt;" &amp; VoyageName1 &amp; "&lt;/JourneyID&gt;
				&lt;/BorderTransportMeans&gt;
				&lt;Carrier&gt;
				  &lt;Name&gt;ANL LINE&lt;/Name&gt;
				&lt;/Carrier&gt;
				&lt;GoodsShipment&gt;
				  &lt;Consignment&gt;
					&lt;TransportContractDocument&gt;
					  &lt;ID&gt;BILL123456&lt;/ID&gt;
					  &lt;TypeCode&gt;BM&lt;/TypeCode&gt;
					  &lt;Pointer&gt;
						&lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
						&lt;DocumentSectionCode&gt;31B&lt;/DocumentSectionCode&gt;
					  &lt;/Pointer&gt;
					&lt;/TransportContractDocument&gt;
					&lt;TransportEquipment&gt;
					  &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
					  &lt;FullnessCode&gt;5&lt;/FullnessCode&gt;
					  &lt;ID&gt;" &amp; ContName &amp; "&lt;/ID&gt;
					  &lt;Pointer&gt;
						&lt;DocumentSectionCode&gt;42A&lt;/DocumentSectionCode&gt;
					  &lt;/Pointer&gt;
					  &lt;Pointer&gt;
						&lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
						&lt;DocumentSectionCode&gt;93A&lt;/DocumentSectionCode&gt;
					  &lt;/Pointer&gt;
					&lt;/TransportEquipment&gt;
				  &lt;/Consignment&gt;
				&lt;/GoodsShipment&gt;
				&lt;Importer&gt;
				  &lt;Name&gt;CH Importers&lt;/Name&gt;
				&lt;/Importer&gt;
				&lt;Packaging&gt;
				  &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
				  &lt;QuantityQuantity&gt;55&lt;/QuantityQuantity&gt;
				  &lt;TypeCode&gt;CT&lt;/TypeCode&gt;
				&lt;/Packaging&gt;
				&lt;UnloadingLocation&gt;
				  &lt;ID&gt;NZNSN&lt;/ID&gt;
				&lt;/UnloadingLocation&gt;
				&lt;ResponsibleGovernmentAgency&gt;
				  &lt;ID&gt;MPIBIO&lt;/ID&gt;
				&lt;/ResponsibleGovernmentAgency&gt;
			  &lt;/Declaration&gt;
			&lt;/OverallDeclaration&gt;
			&lt;Status&gt;
			  &lt;EffectiveDateTime formatCode='204' &gt;20180301082338&lt;/EffectiveDateTime&gt;
			  &lt;NameCode&gt;B06&lt;/NameCode&gt;
			  &lt;ReleaseDateTime formatCode='204' &gt;20180301082338&lt;/ReleaseDateTime&gt;
			  &lt;Pointer&gt;
				&lt;DocumentSectionCode&gt;07B&lt;/DocumentSectionCode&gt;
			  &lt;/Pointer&gt;
			  &lt;Pointer&gt;
				&lt;DocumentSectionCode&gt;42A&lt;/DocumentSectionCode&gt;
			  &lt;/Pointer&gt;
			  &lt;Pointer&gt;
				&lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
				&lt;DocumentSectionCode&gt;08B&lt;/DocumentSectionCode&gt;
				&lt;TagID&gt;G007&lt;/TagID&gt;
			  &lt;/Pointer&gt;
			&lt;/Status&gt;
		  &lt;/Response&gt;
		&lt;/DocumentMetadata&gt;";

	// load the edi data, verify and load to database
	ediFile	:= self.ediLoadFileName(ediText, EDIFileType_XML, USER_DEF_NAME, USER_DEF_NAME &amp; method.name);
	self.assertNotNull(ediFile);
	
	// Some common statuses are:
	// 3 = EDI_STATUS_VERIFIED, 14 = EDI_STATUS_VERIFIED_WARNINGS
	// 5 = EDI_STATUS_DBLOADED, 19 = EDI_STATUS_DBLOADED_PARTIAL
	self.ediVerify( ediFile );
	tempStr	:= 'Verify Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_VERIFIED, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	
	self.ediDBLoad(ediFile);

	tempStr	:= 'DBLoad Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	self.assertNoTrxErrorsOrWarnings();
	
	// Check that container has "MAF" stop off.
	tempStr	:= 'Stop ' &amp; TI_Stop_MAF.display &amp; Space &amp; stopsTable.heading.display &amp; ' still exists for container ' &amp; ContName.display;
	self.assertEqualMsg(container.isStopSet(TI_Stop_MAF), false, tempStr);
epilog
	self.deleteContainer(ContName);
	self.deleteVoyage(VoyageName1);
	self.deleteVessel(BoatName1);
	app.changeLogLevel(previousLogLevel);
end;</source>
    </JadeMethod>
    <JadeMethod name="tTSWcntnr_OCR_C07" id="70b18fa2-df01-4cbf-8e6c-d98913b4b6be">
        <source>tTSWcntnr_OCR_C07();
// jlgdap1
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 Sep 2019	jlgsl4	Further TSW UTs required - OCR
*/
constants
	BLOCKSTACK = 'UTBS2';
	CONTAINER = 'UTUT100011';
	VESSEL = 'UTV1';
	VOYAGE = 'UTV10';
	OPERATOR = 'UTOP';
	USER_DEF_NAME	= 'TSW';
vars
	blockStack : CM_BlockStack;
	container : CM_TrackedItem;
	operator : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	ediText, tempStr : String;
	ediFile : CM_EDIFile;
	stopsTable : CM_StopsTable;	
begin
	self.deleteTerminalArea(BLOCKSTACK);
	blockStack := self.addBlockStack(BLOCKSTACK, 10, null);
	
	stopsTable := self.getRoot.getStopTableForId(TI_Stop_CustomsDocs);
	self.assertNotNullMsg(stopsTable, 'StopsTable ' &amp; TI_Stop_Customs.display &amp; ' does not exist');
	
	self.deleteContainer(CONTAINER);
	container := self.addContainerAtLocation(CONTAINER, null, '2100', 'GENL', TI_IMEX_STATUS_EXPORT, blockStack.myLocationsController);
	
	operator := self.getOperator(OPERATOR);
	self.assertNotNull(operator);
	
	self.deleteVessel(VESSEL);
	vessel := self.addVesselGeneralCargo(VESSEL, operator, 5);
	self.assertNotNull(vessel);
	self.deleteVoyage(VOYAGE);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL, OPERATOR, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 2);
	self.assertNotNull(voyage);

	beginTransaction;	
	container.setMyVoyage(voyage, app.myPassport);
	commitTransaction;
	
	ediText :=
		"&lt;DocumentMetadata xmlns='urn:wco:datamodel:WCO:DM:1' xmlns:xsi='http://www.w3.org/2001/XMLSchema-instance'&gt;
		  &lt;WCODataModelVersion&gt;3.2&lt;/WCODataModelVersion&gt;
		  &lt;WCODocumentName&gt;RES&lt;/WCODocumentName&gt;
		  &lt;CountryCode&gt;NZ&lt;/CountryCode&gt;
		  &lt;AgencyAssignedCustomizedDocumentName&gt;RESOCR&lt;/AgencyAssignedCustomizedDocumentName&gt;
		  &lt;AgencyAssignedCustomizedDocumentVersion&gt;V1.1&lt;/AgencyAssignedCustomizedDocumentVersion&gt;
		  &lt;CommunicationMetaData&gt;
			&lt;Recipient&gt;
			  &lt;ID&gt;51365627A&lt;/ID&gt;
			  &lt;RoleCode&gt;N2&lt;/RoleCode&gt;
			&lt;/Recipient&gt;
		  &lt;/CommunicationMetaData&gt;
		  &lt;Response xmlns='urn:wco:datamodel:WCO:ResponseModel:1'&gt;
			&lt;IssueDateTime formatCode='204' &gt;20190115140615&lt;/IssueDateTime&gt;
			&lt;FunctionalReferenceID&gt;960&lt;/FunctionalReferenceID&gt;
			&lt;FunctionCode&gt;24&lt;/FunctionCode&gt;
			&lt;OverallDeclaration&gt;
			  &lt;Declaration&gt;
				&lt;ID&gt;62756699&lt;/ID&gt;
				&lt;AcceptanceDateTime formatCode='204' &gt;20190115140615&lt;/AcceptanceDateTime&gt;
				&lt;FunctionalReferenceID&gt;PPOE_OCR001&lt;/FunctionalReferenceID&gt;
				&lt;VersionID&gt;1&lt;/VersionID&gt;
				&lt;Submitter&gt;
				  &lt;Name&gt;EXT ONline Broker&lt;/Name&gt;
				&lt;/Submitter&gt;
				&lt;BorderTransportMeans&gt;
				  &lt;Name&gt;" &amp; VESSEL &amp; "&lt;/Name&gt;
				  &lt;ID&gt;9876543&lt;/ID&gt;
				  &lt;TypeCode&gt;1&lt;/TypeCode&gt;
				  &lt;DepartureDateTime formatCode='102' &gt;20190115&lt;/DepartureDateTime&gt;
				  &lt;JourneyID&gt;" &amp; VOYAGE &amp; "&lt;/JourneyID&gt;
				&lt;/BorderTransportMeans&gt;
				&lt;Consignment&gt;
				  &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
				  &lt;AdditionalDocument&gt;
					&lt;ID&gt;99998888&lt;/ID&gt;
					&lt;TypeCode&gt;EDO&lt;/TypeCode&gt;
				  &lt;/AdditionalDocument&gt;
				  &lt;AssociatedTransportDocument&gt;
					&lt;ID&gt;BILL999888777&lt;/ID&gt;
					&lt;TypeCode&gt;BM&lt;/TypeCode&gt;
				  &lt;/AssociatedTransportDocument&gt;
				  &lt;TransportContractDocument&gt;
					&lt;ID&gt;MB123456&lt;/ID&gt;
					&lt;TypeCode&gt;MB&lt;/TypeCode&gt;
					&lt;Consolidator&gt;
					  &lt;Name&gt;FHL Limited&lt;/Name&gt;
					&lt;/Consolidator&gt;
				  &lt;/TransportContractDocument&gt;
				  &lt;TransportEquipment&gt;
					&lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
					&lt;FullnessCode&gt;7&lt;/FullnessCode&gt;
					&lt;ID&gt;" &amp; CONTAINER &amp; "&lt;/ID&gt;
				  &lt;/TransportEquipment&gt;
				&lt;/Consignment&gt;
				&lt;ExitOffice&gt;
				  &lt;ID&gt;NZPOE&lt;/ID&gt;
				&lt;/ExitOffice&gt;
				&lt;ResponsibleGovernmentAgency&gt;
				  &lt;ID&gt;NZCS&lt;/ID&gt;
				&lt;/ResponsibleGovernmentAgency&gt;
			  &lt;/Declaration&gt;
			&lt;/OverallDeclaration&gt;
			&lt;Status&gt;
			  &lt;EffectiveDateTime formatCode='204' &gt;20190115140615&lt;/EffectiveDateTime&gt;
			  &lt;NameCode&gt;C07&lt;/NameCode&gt;
			  &lt;ReleaseDateTime formatCode='204' &gt;20190115140615&lt;/ReleaseDateTime&gt;
			  &lt;Pointer&gt;
				&lt;DocumentSectionCode&gt;07B&lt;/DocumentSectionCode&gt;
			  &lt;/Pointer&gt;
			  &lt;Pointer&gt;
				&lt;DocumentSectionCode&gt;42A&lt;/DocumentSectionCode&gt;
			  &lt;/Pointer&gt;
			  &lt;Pointer&gt;
				&lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
				&lt;DocumentSectionCode&gt;08B&lt;/DocumentSectionCode&gt;
				&lt;TagID&gt;G007&lt;/TagID&gt;
			  &lt;/Pointer&gt;
			&lt;/Status&gt;
		  &lt;/Response&gt;
		&lt;/DocumentMetadata&gt;";
		
	ediFile := self.ediLoadFileName(ediText, EDIFileType_XML, USER_DEF_NAME, USER_DEF_NAME &amp; method.name);
	self.assertNotNull(ediFile);
	
	self.ediVerify(ediFile);
	tempStr	:= 'Verify Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_VERIFIED, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	
	self.ediDBLoad(ediFile);

	tempStr	:= 'DBLoad Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	self.assertNoTrxErrorsOrWarnings();
	
	// Check the container has no "CEDO" stop
	tempStr	:= 'Stop ' &amp; TI_Stop_CustomsDocs.display &amp; Space &amp; stopsTable.heading.display &amp; ' still exists for container ' &amp; CONTAINER;
	self.assertEqualMsg(container.isStopSet(TI_Stop_CustomsDocs), false, tempStr);
epilog
	self.deleteContainer(CONTAINER);
	self.deleteTerminalArea(BLOCKSTACK);
	self.deleteVoyage(VOYAGE);
	self.deleteVessel(VESSEL);
end;</source>
    </JadeMethod>
    <JadeMethod name="tTSWplugin_IM1_819" id="32c4b40b-a434-4d5e-a75d-6690e65ab2f9">
        <source>tTSWplugin_IM1_819();
// jlgdap1
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Aug 2019	jlgsl4	TFS 45356 - JMT - Create Unit Test that tests TSW plugin output
*/
constants
	USER_DEF_NAME	= 'TSW';
vars
	ediText	: String;
	ediFile	: CM_EDIFile;
	ediTI 	: CM_EDICustomStopTI;
	tempStr : String;
begin
	// This is an untransformed message similar to what we would get back from the Customs web service
	ediText	:=
"&lt;?xml version='1.0'?&gt;
&lt;DocumentMetaData xmlns='urn:wco:datamodel:WCO:DM:1'&gt;
  &lt;WCODataModelVersion&gt;3.2&lt;/WCODataModelVersion&gt;
  &lt;WCODocumentName&gt;RES&lt;/WCODocumentName&gt;
  &lt;CountryCode&gt;NZ&lt;/CountryCode&gt;
  &lt;AgencyAssignedCustomizedDocumentName&gt;RESIM1&lt;/AgencyAssignedCustomizedDocumentName&gt;
  &lt;AgencyAssignedCustomizedDocumentVersion&gt;V1.1&lt;/AgencyAssignedCustomizedDocumentVersion&gt;
  &lt;CommunicationMetaData&gt;
    &lt;Recipient&gt;
      &lt;ID&gt;51363182A&lt;/ID&gt;
      &lt;RoleCode&gt;GC&lt;/RoleCode&gt;
    &lt;/Recipient&gt;
  &lt;/CommunicationMetaData&gt;
  &lt;Response xmlns='urn:wco:datamodel:WCO:ResponseModel:1'&gt;
    &lt;IssueDateTime formatCode='204'&gt;20181116104137&lt;/IssueDateTime&gt;
    &lt;FunctionalReferenceID&gt;202&lt;/FunctionalReferenceID&gt;
    &lt;FunctionCode&gt;24&lt;/FunctionCode&gt;
    &lt;AdditionalInformation&gt;
      &lt;StatementDescription&gt;1 LOOSE PACKAGE(S) OR ITEM(S)&lt;/StatementDescription&gt;
      &lt;StatementTypeCode&gt;DIN&lt;/StatementTypeCode&gt;
    &lt;/AdditionalInformation&gt;
    &lt;OverallDeclaration&gt;
      &lt;Declaration&gt;
        &lt;ID&gt;9846485&lt;/ID&gt;
        &lt;AcceptanceDateTime formatCode='204'&gt;20181116104137&lt;/AcceptanceDateTime&gt;
        &lt;FunctionalReferenceID&gt;PNSN_IM1005_2&lt;/FunctionalReferenceID&gt;
        &lt;TotalGrossMassMeasure unitCode='KGM'&gt;10500&lt;/TotalGrossMassMeasure&gt;
        &lt;VersionID&gt;1&lt;/VersionID&gt;
        &lt;JurisdictionDateTime formatCode='102'&gt;20181118&lt;/JurisdictionDateTime&gt;
        &lt;Submitter&gt;
          &lt;Name&gt;EXT ONline Broker&lt;/Name&gt;
        &lt;/Submitter&gt;
        &lt;Agent&gt;
          &lt;Name&gt;EXT ONline Broker&lt;/Name&gt;
        &lt;/Agent&gt;
        &lt;BorderTransportMeans&gt;
          &lt;Name&gt;TRANS FUTURE 7&lt;/Name&gt;
          &lt;ID&gt;9326093&lt;/ID&gt;
          &lt;TypeCode&gt;1&lt;/TypeCode&gt;
          &lt;JourneyID&gt;TRF70107&lt;/JourneyID&gt;
        &lt;/BorderTransportMeans&gt;
        &lt;Carrier&gt;
          &lt;Name&gt;NSA&lt;/Name&gt;
        &lt;/Carrier&gt;
        &lt;GoodsShipment&gt;
          &lt;Consignment&gt;
            &lt;TransportContractDocument&gt;
              &lt;ID&gt;AKNEN2366&lt;/ID&gt;
              &lt;TypeCode&gt;BM&lt;/TypeCode&gt;
              &lt;Pointer&gt;
                &lt;DocumentSectionCode&gt;42A&lt;/DocumentSectionCode&gt;
              &lt;/Pointer&gt;
              &lt;Pointer&gt;
                &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
                &lt;DocumentSectionCode&gt;93A&lt;/DocumentSectionCode&gt;
              &lt;/Pointer&gt;
            &lt;/TransportContractDocument&gt;
          &lt;/Consignment&gt;
        &lt;/GoodsShipment&gt;
        &lt;Importer&gt;
          &lt;Name&gt;EXT ONline Importer&lt;/Name&gt;
        &lt;/Importer&gt;
        &lt;Packaging&gt;
          &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
          &lt;QuantityQuantity&gt;55&lt;/QuantityQuantity&gt;
          &lt;TypeCode&gt;VN&lt;/TypeCode&gt;
        &lt;/Packaging&gt;
        &lt;UnloadingLocation&gt;
          &lt;ID&gt;NZNSN&lt;/ID&gt;
        &lt;/UnloadingLocation&gt;
        &lt;ResponsibleGovernmentAgency&gt;
          &lt;ID&gt;NZCS&lt;/ID&gt;
        &lt;/ResponsibleGovernmentAgency&gt;
      &lt;/Declaration&gt;
    &lt;/OverallDeclaration&gt;
    &lt;Status&gt;
      &lt;EffectiveDateTime formatCode='204'&gt;20181116104137&lt;/EffectiveDateTime&gt;
      &lt;NameCode&gt;819&lt;/NameCode&gt;
      &lt;ReleaseDateTime formatCode='204'&gt;20181116104137&lt;/ReleaseDateTime&gt;
      &lt;Pointer&gt;
        &lt;DocumentSectionCode&gt;07B&lt;/DocumentSectionCode&gt;
      &lt;/Pointer&gt;
      &lt;Pointer&gt;
        &lt;DocumentSectionCode&gt;42A&lt;/DocumentSectionCode&gt;
      &lt;/Pointer&gt;
      &lt;Pointer&gt;
        &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
        &lt;DocumentSectionCode&gt;08B&lt;/DocumentSectionCode&gt;
        &lt;TagID&gt;G007&lt;/TagID&gt;
      &lt;/Pointer&gt;
    &lt;/Status&gt;
  &lt;/Response&gt;
&lt;/DocumentMetaData&gt;";
	// load the edi data then check the resulting Customs Stop TI
	ediFile	:= self.ediLoadFileName(ediText, EDIFileType_XML, USER_DEF_NAME, USER_DEF_NAME &amp; method.name);
	self.assertNotNull(ediFile);
	ediTI := ediFile.ediData.allEDITrackedItems.first().CM_EDICustomStopTI;
	self.assertNotNull(ediTI);

	tempStr := "Pack count from &lt;QuantityQuantity&gt; should be 55, is " &amp; ediTI.packCount.asStringJMT();
	self.assertEqualMsg(ediTI.packCount, 55, tempStr);
	
	tempStr := "MAF Instructions should be '1 LOOSE PACKAGE(S) OR ITEM(S)', is " &amp; ediTI.mafInstructions;
	self.assertEqualMsg(ediTI.mafInstructions, "1 LOOSE PACKAGE(S) OR ITEM(S)", tempStr);

	tempStr := "Response Status from &lt;NameCode&gt; should be 819, is " &amp; ediTI.responseStatus;
	self.assertEqualMsg(ediTI.responseStatus, '819', tempStr);
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="zCargoDischargeWithHouseBOL" id="8b702960-62d6-40a1-9625-5fd002c0e2ec">
        <source>zCargoDischargeWithHouseBOL(_cargoId : String;
				_cargoType	: CM_CargoType;
				_lc : CM_LocationsController;
				_voyage : CM_Voyage;
				_operator : CM_Operator;
				_bol : String;
				_blockStack : CM_BlockStack) : CM_TrackedItem protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 March 2025	naviv1	Initial creation

*/

vars
	cargoOnship,
	cargoOnsite		: CM_TrackedItem;
begin
	cargoOnship := self.addCargoBulkAtLocation(_cargoId, _cargoType, 500, _lc, null, TI_IMEX_STATUS_IMPORT, _voyage, _operator, null);
	self.assertEqual(cargoOnship.totalWeight, 500.Decimal);
	
	// assign house bol number and voyage
	beginTransaction;
	cargoOnship.setPropertyValue(CM_TrackedItem::houseBillOfLading.name, _bol);
	cargoOnship.setMyVoyage(_voyage,app.myPassport);
	commitTransaction;
	self.moveBulk(cargoOnship, _blockStack,500);
	cargoOnsite := getTrackedItemAtLocation(_cargoId, _blockStack.myLocationsController);
	return cargoOnsite;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_cargoId" type="String"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_bol" type="String"/>
        <Parameter name="_blockStack" type="CM_BlockStack"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
