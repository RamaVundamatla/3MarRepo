    <JadeMethod name="btnTransferTypeCancel_click" id="3e816324-df07-4189-b918-90ddc5914e3e">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnTransferTypeCancel_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 Nov 2018	cnwma1	ChangeRequest 42141: PEL1 - Allow changing transfer type for ISO Containers

*/

