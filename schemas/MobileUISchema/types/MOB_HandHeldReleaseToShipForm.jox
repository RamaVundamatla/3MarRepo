vars

begin

	self.doResize();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="selectBayCell" id="02791c23-3ba2-4a63-905b-37694acfcade">
        <updating/>
        <source>selectBayCell() updating;
// Select the next uncompleted slot in the job
// 17/03/2015	cnwmh5	Tranisent Leaks
vars
	job : CM_VoyageJob;
	workListEntries : CM_WLEArray;
	workListEntry : CM_WorkListEntry;
	slotController : CM_SlotController;
begin
	self.tblBay.clearAllSelected();
	job := self.getSessionAgent().myJob;
	if job &lt;&gt; null then
		create workListEntries transient;
		job.getSequenceSortedWLEs(workListEntries);
		foreach workListEntry in workListEntries do
			if workListEntry.status &lt;&gt; WLE_COMPLETED then
				break;
			endif;
		endforeach;
		if workListEntry &lt;&gt; null then
			slotController := workListEntry.myRequest.CM_SlotRequest.mySlotController;
			selectBayCellForSlotController(slotController);
		endif;
	endif;
epilog
	delete workListEntries;
end;
</source>
    </JadeMethod>
    <JadeMethod name="selectBayCellForSlotController" id="c954d0a5-5334-4d71-9bd6-f856c06616a8">
        <updating/>
        <source>selectBayCellForSlotController(slotController : CM_SlotController) : Boolean updating;
// Find and select the bay slot in the table that matches this slotController
// Return true if cell in the table is selected
vars
	cell : JadeTableCell;
	selectedCell : JadeTableCell;
	row, column : Integer;
	availableCellRow, availableCellColumn : Integer;
begin
	// Search all the bay slots to find a match for the slotController
	self.tblBay.clearAllSelected();
	foreach row in 2 to tblBay.rows do :outer
		foreach column in 2 to tblBay.columns do
			cell := tblBay.accessCell(row, column);
			if self.isAvailableSlot(cell.itemObject.CM_SlotController) then
				// If the controllers match, then we have found the slot the tracked item was planned for
				if cell.itemObject.CM_SlotController = slotController then
					selectedCell := cell;
					break outer;
				else
					availableCellRow := row;
					availableCellColumn := column;
				endif;
			endif;
		endforeach;
	endforeach;		
	
	// Didn't find the matching cell for this tracked item (may be on another deck or bay)
	// so just use any available slot
	if selectedCell = null and availableCellRow &lt;&gt; 0 and availableCellColumn &lt;&gt; 0 then
		selectedCell := tblBay.accessCell(availableCellRow, availableCellColumn);
	endif;
	
	if selectedCell &lt;&gt; null then
		tblBay.row := selectedCell.row;
		tblBay.column := selectedCell.column;
		if selectedCell.row &gt; 3 then
			tblBay.topRow := selectedCell.row - 1;
		endif;
		if selectedCell.column &gt; 4 then
			tblBay.leftColumn := selectedCell.column - 2;
		endif;
		cell.selected := true;
		self.doSlotSelected();
		return true;
	endif;
	
	return false;
end;
</source>
        <Parameter name="slotController" type="CM_SlotController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="selectBayCellForTrackedItem" id="74e44639-ddbe-4de2-84e3-0b9e125cf231">
        <updating/>
        <source>selectBayCellForTrackedItem(trackedItem : CM_TrackedItem) : Boolean updating;
// Find the bay slot that this tracked item has been planned to. If cannot find then just select
// any of the incomplete slots for current job
vars
	trackedItemFutureMove : CM_FutureMovePlanned;
	slotController : CM_SlotController;
begin
	trackedItemFutureMove := trackedItem.getFutureMoveOfType(PLANNING_MODE, TI_FutureMovePlanned).CM_FutureMovePlanned;
	if trackedItemFutureMove &lt;&gt; null then
		slotController := trackedItemFutureMove.getPrimaryLocation().CM_SlotController;
	endif;
	return self.selectBayCellForSlotController(slotController);
end;
</source>
        <Parameter name="trackedItem" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="selectCraneXferAreaTrackedItem" id="a5607fcd-b520-48ce-9102-79e820a5a9a6">
        <source>selectCraneXferAreaTrackedItem();
// Select a tracked itme in the crane transfer area table that matches the currently selected bay cell
vars
	slotController, twinSlotController : CM_SlotController;
	trackedItem : CM_TrackedItem;
	row : Integer;
begin
	if tblCraneXferArea.row &gt; 0 then
		tblCraneXferArea.clearAllSelected();
		if tblBay.selected then
			slotController := tblBay.accessCell(tblBay.row, tblBay.column).itemObject.CM_SlotController;
			// If this is a twin lift then select the twin item as well
			twinSlotController := null;
			if self.isTwinLift then
				twinSlotController := self.getTwinSlotController(slotController);
			endif;
			foreach row in 1 to tblCraneXferArea.rows do
				trackedItem := tblCraneXferArea.accessCell(row, 1).itemObject.CM_TrackedItem;
				if slotController.includesTI(trackedItem, PLANNING_MODE) or
				   (twinSlotController &lt;&gt; null and twinSlotController.includesTI(trackedItem, PLANNING_MODE)) then
					tblCraneXferArea.row := row;
					tblCraneXferArea.selected := true;
					doTrackedItemSelected();
				endif;
			endforeach;
		endif;
	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="setNotifications" id="5e31a211-906e-4c74-bd81-e5860b16ffff">
        <source>setNotifications();
// Want to know when a new tracked item is put in the crane transfer area
// adm 270509 Par 19483 myTerminal
vars
	craneTransferArea : CM_CraneTransferArea;
begin
	craneTransferArea := self.getDataAgent().getJobCraneXferArea(self.getSessionAgent().myJob);
	if craneTransferArea &lt;&gt; null then
		self.beginNotification(craneTransferArea,
								self.myTerminal().getTerminalEvent(EVENT_TI_MOVE_TO_LOCATION), Response_Continuous, null);
		self.beginNotification(craneTransferArea,
							self.myTerminal().getTerminalEvent(EVENT_TI_MOVE_FROM_LOCATION), Response_Continuous, null);
	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="setSessionParameters" id="68c1979c-265d-4605-9683-e2669aa3cd7d">
        <updating/>
        <source>setSessionParameters() updating;
// Set the parameters in the form we are going to next
// Need to match up the two tracked items selected with the forward and aft bay
vars
	row : Integer;
	selectedSlotController : CM_SlotController;
	forwardSlotController, aftSlotController : CM_SlotController;
	isForwardBay : Boolean;
	trackedItem : CM_TrackedItem;
begin
	inheritMethod();
	
	if self.isTwinLift then
		selectedSlotController := tblBay.accessCell(tblBay.row, tblBay.column).itemObject.CM_SlotController;
		// Is the bay on display the forward or aft bay of the twin lift
		isForwardBay := selectedSlotController.myBayVoyage.isForwardBay();
		if isForwardBay then
			forwardSlotController := selectedSlotController;
			aftSlotController := self.getTwinSlotController(selectedSlotController);
		else
			aftSlotController := selectedSlotController;
			forwardSlotController := self.getTwinSlotController(selectedSlotController);
		endif;
		
		self.getSessionAgent().myForwardSlotController := forwardSlotController;
		self.getSessionAgent().myAftSlotController := aftSlotController;
			
		self.getSessionAgent().myForwardTI := null;
		self.getSessionAgent().myAftTI := null;
		
		// find the two tracked items selected in the list
		foreach row in 1 to tblCraneXferArea.rows do
			if tblCraneXferArea.accessCell(row, 1).selected then
				trackedItem := tblCraneXferArea.accessCell(row, 1).itemObject.CM_TrackedItem;
				// Is the future move target, the forward slot
				if trackedItem.getLocationsArray(PLANNING_MODE, 1).first = forwardSlotController then
					if self.getSessionAgent().myForwardTI &lt;&gt; null then
						self.getSessionAgent().myAftTI := self.getSessionAgent().myForwardTI;
					endif;
					self.getSessionAgent().myForwardTI := trackedItem;
				// Is the future move target, the aft slot
				elseif trackedItem.getLocationsArray(PLANNING_MODE, 1).first = aftSlotController then
					if self.getSessionAgent().myAftTI &lt;&gt; null then
						self.getSessionAgent().myForwardTI := self.getSessionAgent().myAftTI;
					endif;
					self.getSessionAgent().myAftTI := trackedItem;
				// Future move is not for this release so assign to either fore or aft (which ever is empty)
				elseif self.getSessionAgent().myForwardTI = null then
					self.getSessionAgent().myForwardTI := trackedItem;
				else
					self.getSessionAgent().myAftTI := trackedItem;
				endif;
			endif;
		endforeach;
	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="9fbc3253-67fd-4ce0-812f-8838516b3b88">
        <updating/>
        <source>setupForm() updating, protected;

vars

	form : MOB_HandHeldForm;
	
begin

	self.myHandHeldCheckerAgent := app.myHandHeldCheckerAgent;
	
	inheritMethod();
	
	self.setupControlFromParent(	self.frmMain, self, 0, 0 );	//22 Nov 2010	NDL Par 25074
	
	self.isTwinLift := false;
	self.refreshForm();
	
	form := self;
	self.myHandHeldCheckerAgent.doApplyConfigColours( form );	//22 Nov 2010	NDL Par 25074
	
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showTwinLift" id="4f13a4e7-2773-46ef-b070-1bd467a69ebc">
        <source>showTwinLift() protected;
//03 June 2008	cnwdw1	
//
begin
	if self.isTwinLift then
		lblLiftType.caption := "TWIN";
		self.btnOK.caption := "Next";
	else
		lblLiftType.caption := "";
		self.btnOK.caption := "OK";
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
