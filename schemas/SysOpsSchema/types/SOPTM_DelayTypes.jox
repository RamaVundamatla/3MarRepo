    <JadeMethod name="changeRequiresVoyage" id="be6cbe75-a0aa-4e96-b303-344a2b4e2715">
        <source>changeRequiresVoyage( _isSet : Boolean );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 August 2018	jlgndl1	Initial creation	TFS 40309

*/

vars

begin

	if _isSet then
		 self.myForm.tblInput1.showRowByName(ETRow_MyVoyageEvent,false);
	else
		self.myForm.tblInput1.hideRowByName(ETRow_MyVoyageEvent,false);
		self.myForm.cmbVoyageEvent.listIndex := -1;
		self.myForm.tblInput1.setValueByName( ETRow_MyVoyageEvent, null );
	endif;

epilog

end;</source>
        <Parameter name="_isSet" type="Boolean"/>
    </JadeMethod>
