    <JadeMethod name="showRowColumnInfo" id="9cdb8916-3957-448d-a9bf-61f23173f81b">
        <source>showRowColumnInfo(_horiz : Boolean; _x: Real; _y: Real; _isByRowColumn : Boolean);
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		Show info for row/column (invoked from form by clicking on row/column heading).
//
// ---------------------------------------------------------------------------
/*
Date		Who		Reason
12 Dec 2008 consw1	SFW1030 - Re-write method to handle flipping of view and also selective views for Yard Allocation enhancements
*/

vars
	iter : Iterator;
	gridController : CM_GridController;
	go : CM_GridObject;
	obj : Object;
	offset : Integer;
	x1, y1, x2, y2 : Integer;
	
begin
	if self.myTerminalArea = null then
		return;
	endif;

	iter := self.allGridObjects.createIterator;
	
	if _horiz then
		offset := _x.Integer;
		self.allGridObjects.startKeyGeq(offset, 0, 0, 0, iter );
		while iter.back(obj) do
			self.allGridObjects.getIteratorKeys(x1, y1, x2, y2, iter);
			if offset &gt;= x1 and offset &lt;= x2 then
				if obj.isKindOf(CM_GridController) then
					gridController := obj.CM_GridController;
					break;
				endif;
			endif;
		endwhile;
	else
		while iter.next(obj) do
			offset := _y.Integer;
			self.allGridObjects.getIteratorKeys(x1, y1, x2, y2, iter);
			if offset &gt;= y1 and offset &lt;= y2 then
				if obj.isKindOf(CM_GridController) then
					gridController := obj.CM_GridController;
					break;
				endif;
			endif;
		endwhile;
	endif;

	if gridController = null then
		return;
	endif;

	go := gridController.myGridRow;

	if _horiz and _isByRowColumn then
		go := gridController.myGridColumn;
	elseif not _horiz and not _isByRowColumn then
		go := gridController.myGridColumn;
	endif;

	if go.hasGap then
		return;
	endif;
	
	if self.myYardGridAreaForm &lt;&gt; null then
		self.myYardGridAreaForm.showExtraInfo(go);
	endif;

epilog
	delete iter;
end;</source>
        <Parameter name="_horiz" type="Boolean"/>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_y" type="Real"/>
        <Parameter name="_isByRowColumn" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showSelectionBounds" id="5129e43b-0f27-44c1-a1e6-74e5f7833775">
        <source>showSelectionBounds();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 January 2009	cnwjk3	SFW1030

*/

vars
	obj 		: Object;
	xy1, xy2 	: Point;
begin
	foreach obj in self.allSelectionBoundsObjects do
		if self.allSelectionBoundsObjects.findObjectInDictGetXY(obj, xy1, xy2) &lt;&gt; null then 
			self.getDrawingFrame().drawRectangle(xy1.x, xy1.y, xy2.x, xy2.y, Red );		
		endif;
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="userNotification" id="fae912a8-f9d9-4ddd-8c91-be8a6e338ff9">
        <updating/>
        <source>userNotification(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
26 May 2008	cnwkpd1	PAR #16814 - Handle invalid objects in notifications
12 Nov 2008 consw1	SFW1030 - Yard Allocation enhancements
*/

vars
	event				: Integer; 
	noteRecord			: CMIF_NotificationRecord;
	userInfoStr         : String;
	invalidObject,
	invalidObject1		: Boolean;
begin
	event := self.myTerminal.getEventFromTerminalEvent(eventType);
	
	// Put this here because occasionally system is in invalid loadstate. Needle in a haystack stuff.
	endLoad;
	
	if self.currentlyMinimised then
	
		if userInfo.isKindOf(Object) then
			//userInfoStr := userInfo.Object.getOidString();
			userInfoStr := self.getOidStringForObject(userInfo.Object);
		else
			userInfoStr := userInfo.String;
		endif;

		if eventType = self.noteTALocationDelete then 	// PAR14090 - cnwvu1
			// PAR14090. When it was minimised, the other user could delete a labourRestriction. 
			//We have to remove the labourRestriction from the allNotificationsReceived collection and organize only the last notification
			noteRecord := self.allNotificationsReceived[self.noteTALocationCreate, theObject, eventTag, userInfoStr];
			if noteRecord &lt;&gt; null then
				self.allNotificationsReceived.remove(noteRecord);	// remove Create event
			endif;
			noteRecord := self.allNotificationsReceived[self.noteTALocationUpdate, theObject, eventTag, userInfoStr];
			if noteRecord &lt;&gt; null then	// remove Update event
				self.allNotificationsReceived.remove(noteRecord);
			endif;
		endif;

		// Create or Update events go into the list. And delete events as well
		noteRecord := self.allNotificationsReceived[eventType, theObject, eventTag, userInfoStr];
		if noteRecord = null then
			create noteRecord transient;
			noteRecord.eventType := eventType;
			noteRecord.myObject := theObject;
			noteRecord.eventTag := eventTag;
			noteRecord.userInfoString := userInfoStr;
			self.allNotificationsReceived.add(noteRecord);
		endif;
		
		return;//processed when minimised state ends
	endif;
	
	on Exception do app.handleDeletedObject(exception, theObject, invalidObject);	// PAR #16814
	on Exception do app.handleDeletedObject(exception, self, invalidObject1);	// PAR #16814
	
	if userInfo &lt;&gt; null then
		if (eventType = self.noteTALocationCreate 
			or eventType = self.noteTALocationUpdate 
			or eventType = self.noteTALocationDelete) then
			self.userNotificationLocation(eventType,theObject,eventTag,userInfo);
			/*
				Date		 Who		Reason
			25 July 2008	cnwdz2	  Par16866 - show a message and the area selector to the users of the YardGridAreaForm and the GridOverviewForm
			                                     after receiving a terminal area deletion event.
			*/
			if invalidObject then				
				if self.myYardGridAreaForm &lt;&gt; null and self.myYardGridAreaForm.visible then
					//self.myYardGridAreaForm.btnSelectAreasCl.enabled := false;
					//self.myYardGridAreaForm.showAreaSelector;
					self.myYardGridAreaForm.btnSelectAreasSh_click(self.myYardGridAreaForm.btnSelectAreasSh);
				endif;			
			endif;

		elseif (eventType = self.noteTAYardAllocationCreate
			or eventType = self.noteTAYardAllocationUpdate
			or eventType = self.noteTAYardAllocationDelete) then
			if self.myYardGridAreaForm = null then
				self.userNotificationYardAllocation(eventType,theObject,eventTag,userInfo);
			else
				self.userNotificationYardAllocLines(eventType,theObject,eventTag,userInfo);
			endif;

		elseif (eventType = self.noteTIUpdate) then // PAR 10328.
			self.userNotificationTI(eventType,theObject,eventTag,userInfo); // PAR 10328.
//		elseif (eventType = self.noteTAReverseDecking) then
//			self.userNotificationReverseDecking(eventType,theObject,eventTag,userInfo);

		elseif eventType = self.noteTAMove 
		or eventType = self.myTerminal.getTerminalEvent(EVENT_TI_MOVE_BACKEND) then
		
			self.userNotificationAreaUpdate(eventType,theObject,eventTag,userInfo);
		elseif eventType = self.myTerminal.getTerminalEvent(TIEvent_Transit_Status_Update) then // TRANSHIP STUFF
			self.allSelectedObjects.rebuild();
			self.userNotificationAreaUpdate(self.noteTIUpdate,theObject,eventTag,userInfo);
		else
			inheritMethod(eventType, theObject, eventTag, userInfo);
		endif;
	else
		inheritMethod(eventType, theObject, eventTag, userInfo);
	endif;
epilog
	//if  then
		self.drawFromNote := false;
	//endif;
	// belts and braces to ensure any possible locks are cleared.
	// We should not be in loadstate anyway
	endLoad;

/*	process.profilerStop();
	process.profilerReport('d:\cnwdmast\prof.log');
	
	write class.name &amp; '::' &amp; method.name &amp; ' completed - ' &amp; (app.clock - s).String;*/
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="userNotificationAreaUpdate" id="ecaae524-4803-4d55-af97-883f2eb0e53d">
        <updating/>
        <source>userNotificationAreaUpdate(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
26 May 2008	cnwkpd1	PAR #16814 - Replace global.commonResumInvalidObjHandler

*/

vars
	anLC : CM_GridController;
	event,idx		: Integer;
	breakOut, gotException : Boolean;
	aTI : CM_TrackedItem;
	selForm : CMUI_Selector;
	aMove : CM_Move;
	src : String;
	tX1, tY1, tX2, tY2, tmp1 : Real;

begin
	on Exception do app.handleDeletedObject(exception, anLC, gotException);		// PAR #16814
	if userInfo.isKindOf(CM_GridController) then
		anLC := userInfo.CM_GridController;
	endif;
	
	if anLC = null then
		return;
	endif;

//if process.isCnwab1() then
//app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 1. eventType: " &amp; eventType.String);
//endif;
	if eventType = self.noteTAMove or eventType = self.noteTIUpdate then
		// ###########################
		// Check to see if this location controller is on our form
		self.drawFromNote := true;
		if self.useSelectorObjects then
			foreach aTI in anLC.allTrackedItems do
				self.userNotificationHandleSelector(aTI,breakOut);
			endforeach;
		endif;
		
		self.drawObject(self.myDrawingFrame, anLC);
		
		//epr par 30524 19/10/12
		if anLC.allTrackedItems.first &lt;&gt; null and  anLC.allTrackedItems.first.myPrimaryActualLocation = anLC and anLC.allTrackedItems.first.myOSBackEndLocation &lt;&gt; null then
			self.drawObject(self.myDrawingFrame, anLC.allTrackedItems.first.myOSBackEndLocation);
		endif;
		
		if gotException then
			// Exception handler resumes here if anLC was invalid.
			return;
		endif;
	endif;
epilog
	self.drawFromNote := false;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="userNotificationHandleSelector" id="23e4121e-fb1f-49cd-9721-d408d71e6a56">
        <updating/>
        <source>userNotificationHandleSelector(aTI : CM_TrackedItem; breakOut : Boolean io) updating;
// ---------------------------------------------------------------------------
// Created:		02 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	selForm 	: CMUI_Selector;
	noteRecord	: CMIF_NotificationRecord;
begin
	
	if self.myYardGridAreaForm &lt;&gt; null then
		selForm := self.myYardGridAreaForm.mySelectorForm;
	endif;
	// PAR 11208
	if not global.isValidObject(self.mySelectorEnquiryController) then
		self.mySelectorEnquiryController := null;
	endif;
	if self.mySelectorEnquiryController &lt;&gt; null then
		if not self.mySelectorEnquiryController.includesObject(aTI,breakOut,app.myPassport) then
			if self.allSelectorTIs.includes(aTI) then
				self.allSelectorTIs.remove(aTI);
				if self.allSelectedObjects.includes(aTI) then
					self.allSelectedObjects.remove(aTI); // PAR 11180
				endif;
				if selForm &lt;&gt; null then
					selForm.doRemoveTIObject(aTI);
				endif;
				if self.mySelectorEnquiryController.allObjects.includes(aTI) then
					self.mySelectorEnquiryController.allObjects.remove(aTI);
				endif;
			endif;
		else
			if self.myYardGridAreaForm &lt;&gt; null then
			
			else
				if not self.allSelectorTIs.includes(aTI) then
					self.allSelectorTIs.add(aTI);
					if selForm &lt;&gt; null then
						selForm.doAddTIObject(aTI);
					endif;
				endif;
			endif;
		endif;
		self.doPostSelector();
	endif;
epilog
	endLoad;
end;</source>
        <Parameter name="aTI" type="CM_TrackedItem"/>
        <Parameter name="breakOut" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="userNotificationLocation" id="9bf84d35-7e88-40f0-a247-5e7ff42117cc">
        <updating/>
        <source>userNotificationLocation(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 07/11/2012	cnwcs5	par 30475 - remove location restrictions
vars
	lController : CM_LocationsController;
	anObject : Object;
	aLabRest : CM_LabourRestriction;
	aSBS : CM_SubBlockStack;
	theLCS : CM_LCArray;
	oidStr : String;
	lcHolder : CMIF_LocationControllersByOid;
begin
	if userInfo.isKindOf(Object) then //18/02/2011 cnwdz2 par26887
		anObject := userInfo.Object;
	endif;
	
	if anObject &lt;&gt; null then
		if anObject.isKindOf(CM_TerminalArea)  then
			self.drawSelf(true);
			return;
		elseif eventType = self.noteTALocationDelete then // DELETE
			if anObject.isKindOf(CM_LabourRestriction) or anObject.isKindOf(CM_SubBlockStack) then
				create theLCS transient;
				oidStr := self.getOidStringForObject(anObject);
				
				lcHolder := self.allOIDSbyOIDString[oidStr];
				if lcHolder &lt;&gt; null then
					lcHolder.allLocationControllers.copy(theLCS);
					self.allOIDSbyOIDString.remove(lcHolder);
					delete lcHolder;
				endif;
			elseif anObject.isKindOf(CM_TerminalSubArea) then 
				return; // ignore as not drawn by this controller. the event is fired on delete for this for the location maint screen. 
			endif;
		else // CREATE or UPDATE
			create theLCS transient;
			
			if anObject.isKindOf(CM_LabourRestriction) then
				aLabRest := anObject.CM_LabourRestriction;
				aLabRest.allLocationControllers.copy(theLCS);
			elseif anObject.isKindOf(CM_SubBlockStack) then
				aSBS := anObject.CM_SubBlockStack;
				aSBS.allByPassedControllers.copy(theLCS);
			endif;
			if eventType = self.noteTALocationUpdate then // UPDATE
				if anObject.isKindOf(CM_LabourRestriction) or anObject.isKindOf(CM_SubBlockStack) then
					oidStr := self.getOidStringForObject(anObject);
					// check this collection incase of a resize
					lcHolder := self.allOIDSbyOIDString[oidStr];
					if lcHolder &lt;&gt; null then
						foreach lController in lcHolder.allLocationControllers do
							self.drawObject(self.myDrawingFrame, lController);
						endforeach;
						lcHolder.allLocationControllers.clear();
						theLCS.copy(lcHolder.allLocationControllers);
					endif;
				endif;
			endif;
		endif;
	else
		return;
	endif;

	self.drawFromNote := true;
	
	foreach lController in theLCS do
		self.drawObject(self.myDrawingFrame, lController);
	endforeach;
	//endif;
epilog
	self.drawFromNote := false;
	delete theLCS;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="userNotificationLocationUpdate" id="3e09b954-bda2-4e56-bc5e-8dbfde89f073">
        <updating/>
        <source>userNotificationLocationUpdate(theObject : Object; theLCS : CM_LCArray) updating;
// ---------------------------------------------------------------------------
// Created:		28 October 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 07/11/2012	cnwcs5	par 30475 - remove location restrictions
vars
	key1, key2 					: Point;
	lcx1,lcx2,lcy1,lcy2,x1,x2,y1,y2, tmpX,tmpY, idx, cellH, theFillColour, stackHght : Integer;
	lController 				: CM_LocationsController;
	anObject				 	: Object;
	isLabour, isSBS, isBlank 	: Boolean;
begin
	if theObject.isKindOf(CM_LabourRestriction) then
		isLabour := true;
	elseif theObject.isKindOf(CM_SubBlockStack) then
		isSBS := true;
	else
		isBlank := true;
	endif;


	stackHght := self.getHeightOfStack;	// PAR 21532 CCMS SFW 1025
	foreach lController in theLCS do
		self.allGridObjects.findObjectInDictGetXY(lController,key1, key2);
		if lController.hasPower() then 
			theFillColour := self.POWER_FILL_COLOUR;
		else
			theFillColour := Gray;
		endif;
		
		lcx1 := key1.x;
		lcx2 := key2.x;
		x1 := key1.x;
		x2 := key2.x;
		lcy1 := key1.y;
		lcy2 := key2.y;
		
		cellH := ((lcy2 - lcy1) / stackHght).Integer;
		tmpX := lcx1;
		tmpY := lcy1;
		
		foreach idx in 1 to stackHght do
	
			anObject := self.getObjectAndPointsForPosition(tmpX,tmpY,key1, key2,CM_TrackedItem);
			
			if anObject = null then
				y1 := tmpY;
				y2 := tmpY + cellH;
				if isLabour then
					self.drawLabour(self.myDrawingFrame, theObject.CM_LabourRestriction, x1,y1,x2,y2);
				elseif isBlank then
					self.drawBlankSpace(self.myDrawingFrame, theFillColour,null,x1,y1,x2,y2, true);
				endif;
				
			endif;
			tmpY := tmpY + cellH;

		endforeach;
	endforeach;

end;</source>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="theLCS" type="CM_LCArray"/>
    </JadeMethod>
    <JadeMethod name="userNotificationReverseDecking" id="3cc18979-f34e-4a83-8f17-716f87c22748">
        <updating/>
        <source>userNotificationReverseDecking(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	anObject : Object;
begin

	anObject := userInfo.Object;


	if anObject &lt;&gt; null then
		if  eventType = self.noteTAReverseDecking then
			self.drawSelfVLabels();
		endif;		
	endif;
epilog
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="userNotificationTI" id="346899f9-93ea-43b9-a034-86d92083f39e">
        <updating/>
        <source>userNotificationTI(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
26 May 2008	cnwkpd1	PAR #16814 - Replace global.commonResumInvalidObjHandler

*/

vars
	lController : CM_LocationsController;
	event		: Integer;
	breakOut, gotException : Boolean;
	aTI : CM_TrackedItem;
	selForm : CMUI_Selector;
	futureMove : CM_FutureMove;
	queuedMove : CM_FutureMoveQueued;
	redrawObjects : ObjectArray;
	obj : Object;
begin
	on Exception do app.handleDeletedObject(exception, lController, gotException);		// PAR #16814

	if userInfo.isKindOf(CM_TrackedItem) then
		aTI := userInfo.CM_TrackedItem;
	else
		return;
	endif;

	self.userNotificationHandleSelector(aTI,breakOut);
	
	//28 Mar 2012	NDL	Par 28123 - Not refreshing the back ends, or the different views when a ti is edited..
	//tis using greater than one location controller are drawn in more than one place in Gridded Block Stacks graphics...
	create redrawObjects transient;
	
	foreach lController in aTI.allLocations where self.allGridObjects.includes(lController) do
		redrawObjects.addExclusive( lController );
	endforeach;
				
	if self.displayMode = DISPLAY_MODE_QUEUE then
		if not aTI.allQueuedFutureMoves.isEmpty then
			foreach futureMove in aTI.allQueuedFutureMoves do
				foreach lController in futureMove.CM_FutureMoveQueued.allLocationsControllers where self.allGridObjects.includes(lController) do
					redrawObjects.addExclusive( lController );
				endforeach;
			endforeach;
		endif; 
	elseif self.displayMode = DISPLAY_MODE_PLAN then
		if not aTI.allPlannedFutureMoves.isEmpty then
			foreach futureMove in aTI.allPlannedFutureMoves do
				foreach lController in futureMove.CM_FutureMovePlanned.allLocationsControllers where self.allGridObjects.includes(lController) do
					redrawObjects.addExclusive( lController );
				endforeach;
			endforeach;
		endif;
	endif;
	
	foreach obj in redrawObjects do
		self.drawObject(self.myDrawingFrame, obj);
	endforeach;
	

	//self.drawObject(self.myDrawingFrame, aTI);
		
	
	return;

/*


	if self.displayMode = DISPLAY_MODE_PLAN then
		lController := aTI.myPrimaryPlannedLocation;
	elseif self.displayMode = DISPLAY_MODE_QUEUE then
		lController := aTI.myPrimaryQueuedLocation;
	elseif self.displayMode = DISPLAY_MODE_ACTUAL then
		lController := aTI.myPrimaryActualLocation;
	endif;	
	
	if lController &lt;&gt; null then 
		self.userNotificationAreaUpdate(eventType,theObject, eventTag, lController);
	endif;
*/
epilog
	self.drawFromNote := false;
	delete redrawObjects;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="userNotificationYardAllocLines" id="01ae3231-5b6b-47bd-af80-a08033762bb6">
        <updating/>
        <source>userNotificationYardAllocLines(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
12 November 2008	consw1	Initial creation
28 September 2009	consw1	PAR 20063 - Invalid Object Reference Exception
*/

vars
	needRefresh	: Boolean;
	obj 		: Object;
	yalloc		: CM_YardAllocation;
	invalidYA	: Boolean;
	
begin
	on Exception do app.handleDeletedObject(exception, yalloc, invalidYA);

	yalloc := userInfo.CM_YardAllocation;
	
	//epr par 25601 13/12/10

	if yalloc.allTerminalAreas.includes(self.myTerminalArea.CM_GridArea) then
		
		//if we are creating then we wont be in a filter
		if eventType = self.noteTAYardAllocationCreate then //cnwrd1 par 26697 6.1.2011
			needRefresh := true;
		//if there is no filter then draw
		elseif self.allYardAllocationsFilter.isEmpty then
			needRefresh := true;
		else
			//else yard allocation has to be the filter ya
			if self.allYardAllocationsFilter.includes(yalloc) then
				needRefresh := true;
			endif;
		endif;
	else
		// range may of been deleted 
		if self.allGridObjects.includes(yalloc) then
			needRefresh := true;
		endif;
	endif;
		
	if needRefresh or
	   invalidYA then
		self.refreshYardAllocationLines();
	endif;
	

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="userNotificationYardAllocation" id="126f22ec-8ee8-482e-b026-d185c06274b8">
        <updating/>
        <source>userNotificationYardAllocation(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
26 Mat 2008	cnwkpd1	PAR #16814 - handle invalid objects in notifications
07/11/2012	cnwcs5	par 30475 - remove location restrictions
*/

vars
	yalloc 			: CM_YardAllocation;
	anObject 		: Object;
	invalidObject	: Boolean;
	
begin
	if self.myTerminalArea = null then
		return;
	endif;
	anObject := userInfo.Object;

//app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' 1.' &amp; anObject.String);
	if anObject &lt;&gt; null then
		yalloc := anObject.CM_YardAllocation;
		
		on Exception do app.handleDeletedObject(exception, yalloc, invalidObject);	// PAR #16814

		// ### Not showing allocations so do nothing
		if not self.myDrawingFrame.myOverlayViewingFrame.visible // ### PAR 10552
		 and eventType = Event_YardAllocationUpdate then // PAR 13341

			if  yalloc.allTerminalAreas.includes(self.myTerminalArea.CM_GridArea) and eventType = Event_YardAllocationUpdate  then // ### PAR 10552
				self.myYardGridAreaForm.setYardAllocLegend();
				return;
			endif;
		endif;
		
		if  eventType = self.noteTAYardAllocationDelete then
			self.myDrawingFrame.myOverlayDrawingFrame.allObjects.clear;
			self.myDrawingFrame.myOverlayDrawingFrame.allPoints.clear;
			// Carry on through to update lengend.
		else
			// ### not for my terminal area so do nothing.
			if not yalloc.allTerminalAreas.includes(self.myTerminalArea.CM_TerminalArea) then // ### PAR 10552
				if self.myDrawingAttrController.allYardAllocations.includes(yalloc) then // as delete. We were displaying this but our TA has been removed from the allocation
					self.myDrawingFrame.myOverlayDrawingFrame.allObjects.clear;
					self.myDrawingFrame.myOverlayDrawingFrame.allPoints.clear;
				else
					return;
				endif;			
			endif;
		endif;
						
		self.myDrawingFrame.myOverlayDrawingFrame.myCurrentYardAllocation := null;
		self.myDrawingFrame.myOverlayViewingFrame.myCurrentYardAllocation := null;

		self.getYardAllocationPoints(false); // draw on viewing frame
		self.myDrawingAttrController.allYardAllocations.clear;
		// CCMS 1013
		//foreach yalloc in self.myTerminalArea.allYardAllocations discreteLock where yalloc.isDisabled = false do
		foreach yalloc in self.myTerminalArea.CM_TerminalArea.allYardAllocations discreteLock where (not yalloc.isDisabled and yalloc.includeInYardDisplays()) do
			self.myDrawingAttrController.allYardAllocations.addNoDuplicates(yalloc,false);
		endforeach;

		if  self.myYardGridAreaForm  &lt;&gt; null then
			self.myYardGridAreaForm.setYardAllocLegend();
		endif;
		
		self.myDrawingFrame.myOverlayDrawingFrame.drawAllYAFrames();
		
	endif;
epilog
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</Class>
