    <JadeMethod name="updateDamageDefinition" id="2356306a-e534-41f9-83f1-2be8e871d62d">
        <source>updateDamageDefinition(_damageDef : Any);

/*

Purpose:		Update Damange Definition

Date			Who		Reason
03/04/2014		cnwmh5	Initial creation

*/

vars

	pxyDamageDef				: CM_DamageDefinitionCode;
	damageDef					: CM_DamageDefinitionCode;
	
	loadState					: Boolean;
	description 				: String;

begin

	if _damageDef.isKindOf(String) then
		damageDef := app.myRoot.allDamageDefinitionCodes[_damageDef.String];	
	else
		damageDef := _damageDef.CM_DamageDefinitionCode;
	endif;
	
	if damageDef = null then
		return;
	endif;
	
	app.cmsBeginLoad(loadState);
	pxyDamageDef := damageDef.pxyCreateUpdateProxy();
	app.cmsEndLoad(loadState);
	
	description := damageDef.description;
	if self.opts.includesKey("Description") then
		description := self.opts.str("Description");
	endif;
	
	pxyDamageDef.setProxy(damageDef.code, description, damageDef.allCargoTypes,damageDef.allMachineTypesByType);
	
	app.myTrxUA.trxUpdateDamageDefCode(pxyDamageDef, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
epilog

	app.cmsEndLoad(loadState);

	delete pxyDamageDef;

end;</source>
        <Parameter name="_damageDef" type="Any"/>
    </JadeMethod>
    <JadeMethod name="updateDamageInstance" id="e83a40b8-8f9b-4a09-9958-72fd9d518bc0">
        <source>updateDamageInstance(damageInstance : CM_DamageInstance io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 July 2022	navhl20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details

*/

vars
	pxyDI					: CM_DamageInstance;
	loadState,new,repair					: Boolean;
begin
	if damageInstance = null then 
		return;
	endif;
	
	app.cmsBeginLoad(loadState);
	pxyDI := damageInstance.pxyCreateUpdateProxy();
	app.cmsEndLoad(loadState);
	
	pxyDI.setProxy(damageInstance.myTrackedItem,null,damageInstance.myDamageDefinition,damageInstance.myDamagePosition,
								damageInstance.remarks,true,damageInstance.quantity,damageInstance.myDamageSeverity,damageInstance.locationString,damageInstance.myDamagePlace,damageInstance.myDamageParty,
								damageInstance.myDamageReason,damageInstance.myRepairReason,35.Decimal,app.actualTimeServer,1,damageInstance.repairRemarks,app.actualTimeServer);
								
	new := false;
	repair := true;
	self.ignoreTrxWarnings(true);
	app.myTrxUA.trxUpdateDamageInstance(pxyDI, damageInstance.myTrackedItem, damageInstance.myTIMaster, new,repair ,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
epilog
	app.cmsEndLoad(loadState);
	delete pxyDI;
end;</source>
