    <JadeMethod name="create" id="67c5178c-63e3-4c79-ae4f-c696fce71be6">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 November 2023 navmv20 Bug 61113: FR | 54089 - EUP - Invoice contracts - Selector query - Missing fields

*/
vars
	oper : CM_QueryOperator;

begin
	if self.isTransient then 
		return;
	endif;
	
	self.allAllowedOperators.clear;
	
	create oper as CM_QIntArrayLookupEqual persistent;
	self.allAllowedOperators.add(oper);
	
	create oper as CM_QIntArrayLookupNotEqual persistent;
	self.allAllowedOperators.add(oper);
	
	create oper as CM_QIntegerArrIsOneOf persistent;
	self.allAllowedOperators.add(oper);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="getKeyLengthForXTABDictionary" id="2794c654-6fa1-4a95-afff-7588468a82f8">
        <source>getKeyLengthForXTABDictionary(): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 November 2023 navmv20 Bug 61113: FR | 54089 - EUP - Invoice contracts - Selector query - Missing fields

*/

vars
	length	:Integer;
begin

	length := INV_VOL_BASED_PERIOD_STR.length;
	length := length.max(INV_VOL_BASED_VOYAGE_STR.length);
	
	return length;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
