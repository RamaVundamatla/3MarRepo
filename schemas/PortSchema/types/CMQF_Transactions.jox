    <JadeMethod name="cloneReferences" id="65c53329-01c6-4e5f-8f9d-f93c95d57117">
        <updating/>
        <source>cloneReferences(_obj: CMQF_Transactions; _transient : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     18 October 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 27/7/09      JMH		MES1011 Handle new allQry collections
// 26/05/2022 	navhl20 TFS 53430  EUP - Sub Carrier registration in MTN
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(_obj, _transient);
//	self.allTransTypeDescriptions.clear();								// cnwrl1 07/09/2009 PAR 20198 - what it was
//	_obj.allTransTypeDescriptions.copy(self.allTransTypeDescriptions);	// cnwrl1 07/09/2009 PAR 20198 - what it was
	self.allTxnTypes.clear();
	_obj.allTxnTypes.copy(self.allTxnTypes);
	self.setMyVoyage( _obj.getMyVoyage );
	self.setMyCarrier(_obj.getMyCarrier);				//26/05/2022 navhl20 TFS 53430 		
	self.setMySubCarrier(_obj.getMySubCarrier);			//26/05/2022 navhl20 TFS 53430 
	self.setMyShippingLine(_obj.getMyShippingLine);	 // ### TFS BUG 56660 23FEB2023 NAVAB1
	
	// MES1011
	allQryCargoTypesExcluded.clear();
	allQryCargoTypesIncluded.clear();
	allQryContentStatus.clear();
	allQryImexStatus.clear();
	
	_obj.allQryCargoTypesExcluded.copy(self.allQryCargoTypesExcluded);
	_obj.allQryCargoTypesIncluded.copy(self.allQryCargoTypesIncluded);
	_obj.allQryContentStatus.copy(self.allQryContentStatus);
	_obj.allQryImexStatus.copy(self.allQryImexStatus);
end;</source>
        <Parameter name="_obj" type="CMQF_Transactions"/>
        <Parameter name="_transient" type="Boolean"/>
    </JadeMethod>
