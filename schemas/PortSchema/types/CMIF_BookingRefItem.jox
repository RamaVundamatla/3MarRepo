    <JadeMethod name="set" id="482b9b36-e14d-4b44-b74c-f78047bdc0b5">
        <updating/>
        <source>set( 	pCargoType : Integer;
		 pClean : Boolean;
		 pCommodity, pDescription : String;
		 pHazards : ObjectArray;
		 pHumidity : Decimal;
		 pInspected : Boolean;
		 pIsoType : String;
		 pQuantity : Integer;
		 pRemarks : String;
		 pTemperature : Real;
		 pVentilation : Decimal; //par19252 cnwrs1 may 2009
		 pOxygen : Decimal;				// CCMS 1654 - slw 11/09/2008
		 pCarbonDioxide : Decimal;		// CCMS 1654 - slw 11/09/2008
		 pCurtainsIn : Boolean;			// CCMS 1654 - slw 11/09/2008
		 pHeight,
		 pLength,
		 pWidth 	: Decimal;
		 pHeightStr,
		 pLengthStr,
		 pWidthStr,
		 pTypeStr,
		 pShippingMarks : String;
		 pDensity : Integer;
		 pVolume : Real;
		 pProductQuantity : Integer;
		 pWeight : Decimal; //02.2.09 cnwrd1 par #18821 
		 pCubicMetres : Real; 
		 pProduct : CM_Product;
		 pChangedByUser : Boolean;
		 pEDIBookingRefTI : CM_EDIBookingRefTI;
		 _rawEDIData : String;
		 _generatorType: CM_GeneratorType //cnwrd1 par 18220 23.2.09
		 ) updating; 
/*
	Created on 12 February 2008
	
	by Debby Hutchison
	
	Purpose:
*/
// adm 160310 Par 22937 remove bolType
vars
	tmpHazards	: CM_HazardByCodeDict;
begin
//	self.bolType			:= pBOLType; 
	self.cargoType			:= pCargoType;
	self.clean				:= pClean;
	if pChangedByUser and self.commodity &lt;&gt; pCommodity then
		self.blnCommodityChanged := true;
	endif;
	self.blnChangedByUser	:= pChangedByUser;
	self.commodity 			:= pCommodity;
	self.cubicMetres		:= pCubicMetres;
	self.description 		:= pDescription;
	
	create tmpHazards transient;
	pHazards.copy(tmpHazards);
	self.setHazards(tmpHazards);		//CCMS 1203

	self.setHumidity( pHumidity );
	self.inspected			:= pInspected;
	self.isoType			:= pIsoType;
	
	self.quantity			:= pQuantity;
	self.remarks			:= pRemarks.trimBlanks;
	self.temperature		:= pTemperature;
	self.ventilation		:= pVentilation;
	self.setOxygen( pOxygen );				// CCMS 1654 - slw 11/09/2008
	self.setCarbonDioxide( pCarbonDioxide );		// CCMS 1654 - slw 11/09/2008
	self.curtainsIn			:= pCurtainsIn;			// CCMS 1654 - slw 11/09/2008
	self.weight				:= pWeight;
	self.height				:= pHeight;
	self.length				:= pLength;
	self.width				:= pWidth;
	self.heightString		:= pHeightStr;
	self.lengthString		:= pLengthStr;
	self.widthString		:= pWidthStr;
	self.typeString			:= pTypeStr;
	self.density			:= pDensity;
	self.volume				:= pVolume;
	self.productQuantity	:= pProductQuantity;
		
	// set the references with inverses that will add to the appropriate collections
	self.myProduct			:= pProduct;
	self.myEDIBookingRefTI  := pEDIBookingRefTI;
	self.rawEDIData 		:= _rawEDIData;
	self.shippingMarks		:= pShippingMarks; // Nelson Anca  09/05/2008
	
	self.myGeneratorType	:= _generatorType; //cnwrd1 par 18220 23.2.09
	
epilog
	delete tmpHazards;
end;</source>
        <Parameter name="pCargoType" type="Integer"/>
        <Parameter name="pClean" type="Boolean"/>
        <Parameter name="pCommodity" type="String"/>
        <Parameter name="pDescription" type="String"/>
        <Parameter name="pHazards" type="ObjectArray"/>
        <Parameter name="pHumidity" type="Decimal"/>
        <Parameter name="pInspected" type="Boolean"/>
        <Parameter name="pIsoType" type="String"/>
        <Parameter name="pQuantity" type="Integer"/>
        <Parameter name="pRemarks" type="String"/>
        <Parameter name="pTemperature" type="Real"/>
        <Parameter name="pVentilation" type="Decimal"/>
        <Parameter name="pOxygen" type="Decimal"/>
        <Parameter name="pCarbonDioxide" type="Decimal"/>
        <Parameter name="pCurtainsIn" type="Boolean"/>
        <Parameter name="pHeight" type="Decimal"/>
        <Parameter name="pLength" type="Decimal"/>
        <Parameter name="pWidth" type="Decimal"/>
        <Parameter name="pHeightStr" type="String"/>
        <Parameter name="pLengthStr" type="String"/>
        <Parameter name="pWidthStr" type="String"/>
        <Parameter name="pTypeStr" type="String"/>
        <Parameter name="pShippingMarks" type="String"/>
