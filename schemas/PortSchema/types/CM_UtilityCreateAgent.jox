    <JadeMethod name="utlCreateCashCredit" id="569353ed-c108-4c18-a24b-06558b674cf0">
        <source>utlCreateCashCredit(_proxyCashCredit : CM_CashCredit input; _newCashCredit : CM_CashCredit output; _proxyDetails : ObjectArray; _passport : CM_Passport input);
// 14 January 2016	cnwjre1	TFS 985 37141 cash credits
vars
	obj				: Object;
	pxyDetail,
	creditDetail	: CM_CashCreditDetail;
	totalCredit		: Decimal[16, 6];
	bank : CM_Bank;
begin
	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	app.myValCA.valCashCredit(_proxyCashCredit);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);

	
	_proxyCashCredit.pxySetBank(_proxyDetails); // TFS 38732 refactored bank to use bank on cargo, which is stored on credit details.
	
	
	create _newCashCredit as _proxyCashCredit.class persistent;
	_newCashCredit.setForCreate(_proxyCashCredit);
	
	foreach obj in _proxyDetails do
		pxyDetail := obj.CM_CashCreditDetail;
		create creditDetail persistent;
		creditDetail.setForCreate(pxyDetail);
		creditDetail.setDerivedFromCredit(_newCashCredit);
		totalCredit := totalCredit + creditDetail.cashValue;	// 18/1/18 MAP TFS8065
	endforeach;

	_newCashCredit.setCashValue(totalCredit);					// 18/1/18 MAP TFS8065

	if _passport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(_newCashCredit);
	endif;
end;
</source>
        <Parameter name="_proxyCashCredit" type="CM_CashCredit" usage="input"/>
        <Parameter name="_newCashCredit" type="CM_CashCredit" usage="output"/>
        <Parameter name="_proxyDetails" type="ObjectArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
