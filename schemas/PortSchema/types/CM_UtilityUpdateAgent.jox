    <JadeMethod name="utlUpdateROROLocnDefnNonPxy" id="06d58416-2943-4545-a820-e9b61ba46f60">
        <updating/>
        <source>utlUpdateROROLocnDefnNonPxy(_startLocn : CM_ROROLocnDefn; _code : String;_isRotatable : Boolean;_remarks : String; _passport : CM_Passport input) updating;
/*
Date		    Who			Reason
03 August 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars

	realDeckItem	: CM_DeckItem;
	expectedEdition	: Integer;
	beforeAuditText, 
	afterAuditText: String;
	theDeckItem : CM_ROROLocnDefn;
begin

	self.initialiseActivity();

	theDeckItem := _startLocn.CM_ROROLocnDefn;
	
	if theDeckItem = null then
		return;
	endif;
	
	exclusiveLock(theDeckItem);
	
	//theDeckItem.myDeckLayerLayout.setForUpdateRotate(theDeckItem, _items, _split, _clear);
	theDeckItem.setCode(_code,true);
	theDeckItem.setProxyIsRotatable(_isRotatable);
	theDeckItem.setProxyRemarks(_remarks);
	
epilog

end;</source>
        <Parameter name="_startLocn" type="CM_ROROLocnDefn"/>
        <Parameter name="_code" type="String"/>
        <Parameter name="_isRotatable" type="Boolean"/>
        <Parameter name="_remarks" type="String"/>
