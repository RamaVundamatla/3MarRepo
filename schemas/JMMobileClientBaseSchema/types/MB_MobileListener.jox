<JadeWebServiceProviderClass name="MB_MobileListener" id="3c3b893b-a371-4664-8190-c2b639691c9c">
    <superclass name="JadeWebServiceProvider"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="mbTransient"/>
    <JadeWebServicesMethod name="sendHeyYouMessage" id="e70ac77b-82dd-4924-bc06-8183e2e8242b">
        <usesRPC>default</usesRPC>
        <source>sendHeyYouMessage(_message : String) webService;

vars

begin
//	write class.name &amp; '::' &amp; method.name &amp; ' Received message &gt;&gt; ' &amp; _message;
	//app.msgBox(_message, 'Hey You', MsgBox_OK_Only);
	node.causeEvent(Event_HeyYouMessage, true, _message);
end;</source>
        <Parameter name="_message" type="String"/>
    </JadeWebServicesMethod>
</JadeWebServiceProviderClass>
