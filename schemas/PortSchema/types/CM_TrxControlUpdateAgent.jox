        <updating/>
        <source>trxUpdatePackUnpack(_theMoveController : CMIF_MoveController input;_noCharge : Boolean;
					_thePackTIs, _theUnpackTIs : CM_TIArray;
					_unpackFromRelease : Boolean;
					_theProxyParentTI : CM_TrackedItem input;
					_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		September  2002 By Andrew Bishop cnwab1
//
// Purpose:		CM_TISet
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	
	_passport.useTIDictDeferUpdate := true;
	_passport.useTITransactionDeferUpdate := true;

	
	beginTransaction;


	//The proxy TI should have its original untouched children and the two TI_Arrays contain what is to add and what is to remove.
	//Move controller is for unpacking to a location..... more work to be done.
	app.myUtilityUA.utlUpdatePackUnpack(_theMoveController,
										_noCharge,
										_thePackTIs,
										_theUnpackTIs,
										_unpackFromRelease,
										_theProxyParentTI,
										TI_UPDMODE_NORMAL,
										_passport);
	
	if _passport.noErrors() then
		_passport.doDeferredUpdates();
	endif;
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
