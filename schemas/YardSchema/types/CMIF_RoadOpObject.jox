    <JadeMethod name="displayWLEsShowRT" id="a40d441c-cc66-497a-afa9-c372480f704c">
        <source>displayWLEsShowRT(	_row,_col : Integer)protected;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		The new Queue and Planned icons do not have a Q or a P in them 
//				so use letters instead and this method sets the colours
//				Should only be called from self.tblWLESetRowColour()
// ---------------------------------------------------------------------------

vars
	theCell : JadeTableCell;

begin

	theCell := self.myDataTable.accessCell(_row,_col);
	
	if theCell.text.pos("H",1) &gt; 0  then
		//Job entry is held
		if theCell.backColor = Red then
			theCell.foreColor := White; // Incase the line is overstowed, i.e. the background is RED
		else
			theCell.foreColor := Red;
		endif;
		theCell.fontBold := true;
		
	elseif theCell.text.pos("P",1) &gt; 0 then
		//Job entry is planned
		theCell.foreColor := Green;

	elseif theCell.text.pos("Q",1) &gt; 0 then
		//Job entry is Queued
		if theCell.backColor = Red then
			theCell.foreColor := White; // Incase the line is overstowed, i.e. the background is RED
		else
			theCell.foreColor := Red;
		endif;
		
	// TFS42878 jlgzm1 30/08/2019
	elseif theCell.text.pos("DR",1) &gt; 0 then
		//Job entry is a direct release
		theCell.foreColor := Green;
	else
		theCell.foreColor := Blue;		
	endif;		

end;</source>
        <access>protected</access>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_col" type="Integer"/>
    </JadeMethod>
