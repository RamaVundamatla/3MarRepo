// Parameters:	_isDelete - True if a delete should be done.
//
// Returns:		True if the update was successful, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="_isDelete" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForm" id="87fa1b5f-2869-47af-8b3c-8c260b6b04f4">
