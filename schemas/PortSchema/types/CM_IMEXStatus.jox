<Class name="CM_IMEXStatus" id="ee7c38fc-0248-482a-b0a0-181b9ee14d91">
    <superclass name="CM_CargoStatus"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>

TI_IMEX_STATUS_IMPORT = 1
TI_IMEX_STATUS_EXPORT = 2
TI_IMEX_STATUS_STORAGE = 3
TI_IMEX_STATUS_REMAINONBOARD = 6
TI_IMEX_STATUS_TRANSHIP = 7</text>
    <DbClassMap file="terminal"/>
    <Constant name="Unknown_IMEXStatus" id="9c376e5f-5eec-40c3-a324-6847886c94cf">
        <source>"Unknown"</source>
        <type name="String"/>
    </Constant>
    <ExplicitInverseRef name="allYAOverstowRules" id="d5efe6b4-9d0d-45c0-b146-eb052be61208">
        <transientToPersistentAllowed/>
        <updateMode>automatic</updateMode>
        <type name="CM_YAOverstowRuleByTermDict"/>
        <access>readonly</access>
        <text>
This holds the default overstow rule for this terminal for this IMEX status.</text>
        <Inverse name="CM_YAOverstowRule::allImexStatuses"/>
    </ExplicitInverseRef>
    <PrimAttribute name="allowInterModalTransit" id="f118e798-c3c8-4394-9f2e-6b8c2981cb8e">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="auditId" id="75614e2a-cafb-4af3-8e12-cba10eda3052">
        <source>auditId(): String;
// ---------------------------------------------------------------------------
// Created:     May 2006 by cnwrs1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	return self.description.trimBlanks();
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="e51dd942-c168-45f0-b991-aea9be78c57c">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
02 May 2022			jlizm1	Initial creation TFS 53084 GPHA revceival/release of tranship cargo

*/

vars

begin

	if _attrName = ETRow_InterModal then
		if self.code = TI_IMEX_STATUS_TRANSHIP then
			return self.allowInterModalTransit.asStringJMT;
		else
			return null;
		endif;
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getYADisplay" id="a532c045-7736-4982-8f7d-2146b9e3090d">
        <source>getYADisplay(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
18 December 2008	consw1	Initial creation

*/

vars

begin
	if self.code = TI_IMEX_STATUS_NULL and self.description = null then
		return "No IMEX";
	endif;

	return self.description;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getYAIdentifier" id="c7afe2d4-287e-47c6-990b-203fb50d86c2">
        <source>getYAIdentifier(): String;

/*

Purpose:		Refer to superclass implementation.

Date			Who		Reason
26 August 2008	consw1	Initial creation

*/

vars

begin
	if self.code = TI_IMEX_STATUS_NULL and self.abbreviation = null then
		return "NONE";
	endif;

	return self.abbreviation;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getYAOverstowRuleForTerminal" id="91b21aed-5dc1-432a-bc43-3c9f1d51e4e6">
        <source>getYAOverstowRuleForTerminal(_terminal : CM_Terminal) : CM_YAOverstowRule;
// -------------------------------------------
// Created 13 September 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	return self.allYAOverstowRules.getAtKey(_terminal);
	

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="CM_YAOverstowRule"/>
    </JadeMethod>
    <JadeMethod name="setAllowInterModalTransit" id="11204bc9-7295-4714-bc07-7208c7faab68">
        <updating/>
        <source>setAllowInterModalTransit( _allow : Boolean ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
02 May 2022			jlizm1	Initial creation TFS 53083 GPHA revceival/release of tranship cargo

*/

vars

begin

	self.allowInterModalTransit := _allow;

epilog

end;</source>
        <Parameter name="_allow" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="5647108f-b14a-46ca-b391-2772bbb0607c">
        <updating/>
        <source>setForUpdate(pProxyStatus: SelfType) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
02 May 2022			jlizm1	Initial creation TFS 53083 GPHA revceival/release of tranship cargo

*/

vars

begin
	inheritMethod(pProxyStatus);
	
	self.allowInterModalTransit	:= pProxyStatus.allowInterModalTransit;

epilog

end;</source>
        <Parameter name="pProxyStatus" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="7b5a8d03-5eb0-46be-95be-8a8d83e6d576">
        <source>validateForCreate();
/*
------------------------------------------------------------------------
Created:			09 June 2003 by cnwdwq1
Purpose:			Dave Q's code
Parameters:		
Returns:			
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														
------------------------------------------------------------------------
*/
begin
	if app.myRoot.allImexStatuses[self.code] &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.code.String, null, null);
	endif;

	self.validateForUpdate();
end;</source>
    </JadeMethod>
</Class>
