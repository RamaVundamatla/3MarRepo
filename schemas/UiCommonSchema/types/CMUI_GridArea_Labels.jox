    <JadeMethod name="checkLabel" id="c648537b-b29c-496d-b4ad-fd063acc7f42">
        <source>checkLabel(_label : String) : Boolean protected;

vars
	pos : Integer;
begin

	if _label = null then
		return true;
	else
		//epr par 21526
		pos:=1;
		_label.scanUntil(Space,pos);
		if pos &lt;&gt; 0 then
			app.raiseCMException2(ERR_INVALID_VALUE," label", "Can not include spaces.", null, null);
			return false;
		
		endif;
	
		if labelCheckArray.includes(_label) then
			// Error.
			app.raiseCMException1(LabelsMustBeUnique,null, null, null);
			return false;
		endif;
		
		if _label.length &gt; 10 then
			// Error.
			app.raiseCMException2(ERR_STRING_TO_LONG, 'label', '10', null, null); 
			return false;
		endif;
		
		labelCheckArray.add(_label);
		return true;
		
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_label" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
