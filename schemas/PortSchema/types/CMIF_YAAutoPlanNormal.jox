    <JadeMethod name="isRepairActivity_Match" id="21bd6c0f-3711-40f6-835a-1962ce6065ba">
        <source>isRepairActivity_Match(_yaData: CM_YADataObjects): Boolean;
/*
Purpose - 	
Who - NAVAB1
Date - 14AUG2024
ADO - CR 65144 TASK 65396
*/

vars
	damInstance : CM_DamageInstance;
	tran : CM_RepairDetail;
begin
	if _yaData.isEmpty() then
		return true;
	endif;

	if self.myTrackedItem = null then
		return true;
	endif;
	
	
	// if any of the damage instances match return true
	foreach damInstance in self.myTrackedItem.allDamageInstances discreteLock do
		if _yaData.matches(damInstance.myRepairReason) then
			return true;
		endif;
	
	endforeach;

	 // BUG 65738 NAVAB1 23AUG2024 - if configured damage instance are deleted when repaired. So check for the transaction
	tran := self.myTrackedItem.getLastTransOfType(TRANS_TYPE_REPAIR_DETAILS).CM_RepairDetail;
	if tran &lt;&gt; null then
		if _yaData.matches(tran.myRepairReason) then
			return true;
		endif;
		
	endif;
	
	return false;
epilog

end;</source>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
