    <JadeMethod name="makeTDTSegment" id="f9aa1345-73f6-4037-a43d-2d46596f7bf0">
        <source>makeTDTSegment(_protocol :CM_CamProtocol; _group :HugeStringArray input) : String protected;
//
//20 May 2016	cnwrs1	TFS 2008 - Vermas file changes
//
constants
	MESSAGE	= "TDT";
vars
	msg	: String;
	plus : Character; 
	colon : Character; 
	singleQuote : Character;
begin
	plus		:= _protocol.elementSeparator;
	colon		:= _protocol.subElementSeparator;
	singleQuote	:= _protocol.segmentTerminator;
	
	msg := MESSAGE &amp; plus; 
	if _group &lt;&gt; null then
		_group.add (msg);
	endif;
	
	msg := msg &amp; singleQuote;
			
	return msg;
end;
</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeTMDSegment" id="adc34e31-a1c3-49b0-b786-fefe521af17e">
        <source>makeTMDSegment(_protocol : CM_CamProtocol;  _group :HugeStringArray input) : String protected;
/*
Purpose:			
Parameters:			
Return Value:		
Date		Who		Reason
15 October 2014	cnwmc5	Initial creation
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
constants
	MESSAGE = "TMD";
vars
	plus, singleQuote 	: Character;
	msg 				: String;
	
begin
	plus := _protocol.elementSeparator;
	singleQuote	:= _protocol.segmentTerminator;
	
	//Will always be +3..
	msg := 	MESSAGE 
			&amp; plus &amp; '3' 
			&amp; singleQuote;
			
	if _group &lt;&gt; null then
		_group.add (msg);
	endif;
	
	return msg;
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeTMPSegment" id="1d0edb65-7bf9-41ae-9f53-f2301cc2acf4">
        <source>makeTMPSegment(_protocol :CM_CamProtocol; _group :HugeStringArray input; _qualifier :Integer; _temp :Real; _tempQual:String):String protected;
/*
Purpose:	Make a TMP segment
Returns:	null if there is not a valid temperature

Date		Who		Reason
09 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
constants
	MESSAGE	= "TMP";
vars
	msg, temp					:String;
	plus, colon, singleQuote,
	decimalCharacter			:Character;
begin
	if _temp = NULL_TEMPERATURE then
		return null;
	endif;
	
	plus		:= _protocol.elementSeparator;
	colon		:= _protocol.subElementSeparator;
	singleQuote	:= _protocol.segmentTerminator;
	
	if _protocol.tempLeadingZerosNoDecimal then
		// leading zeros for temp - no decimal places
		if _temp &lt; 0 then
			temp := _temp.Integer.positive.stringWithLeadingZeros(3) &amp; "-";
		else
			temp := _temp.Integer.positive.stringWithLeadingZeros(3);
		endif;
	else
		temp 				:= _temp.roundedTo (CM_CamProtocol.DecimalPlaces).String;
		decimalCharacter 	:= _protocol.decimalCharacter;
	
		if temp.pos (CM_CamProtocol.Default_DecimalCharacter, 1) = 0 then
			// a whole number - we need to show .0
			temp := temp &amp; decimalCharacter &amp; '0';
			
		elseif decimalCharacter &lt;&gt; CM_CamProtocol.Default_DecimalCharacter then
			temp.replaceChar (CM_CamProtocol.Default_DecimalCharacter, decimalCharacter);
		endif;	
	endif;
	

	
	msg := MESSAGE &amp; plus &amp; 
			_qualifier.String &amp; plus &amp;
			temp &amp; colon &amp; _tempQual;
			
	msg := msg &amp; singleQuote;

	if _group &lt;&gt; null then
		_group.add (msg);
	endif;
	
	return msg;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_qualifier" type="Integer"/>
        <Parameter name="_temp" type="Real"/>
        <Parameter name="_tempQual" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeUNASegment" id="7d5f50e1-4ee3-4efe-8d1a-a5aa9d96b8d3">
        <source>makeUNASegment(_protocol :CM_CamProtocol):String protected;
/*
Purpose:	Make a UNA segment - eg. "UNA:+.? '"

			Note the space before the segment terminator is reserved for future use

Date		Who		Reason
09 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
*/
constants
	MESSAGE	= "UNA";
	SPACE = ' ';
vars
	msg	:String;
	plus, colon, singleQuote, decimal, escape	:Character;
begin
	_protocol.getDefaultCharacters (decimal, plus, escape, singleQuote, colon);
	
	msg := MESSAGE &amp; colon &amp; plus &amp; decimal &amp; escape &amp; SPACE &amp; singleQuote;
			
	return msg;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeUNBSegment" id="7c62361c-d56a-4145-bd45-354df993947c">
        <source>makeUNBSegment(_protocol :CM_CamProtocol; _syntaxId :String; _syntaxVersion :Integer;
				_senderId, _senderQual, _recipientId, _recipientQual:String;
				_seqNumber :Integer; _080 :String; _useLongYear :Boolean; _runDateTime : TimeStamp):String protected;
/*
Purpose:	Make a UNB segment 

Date			Who		Reason
09 May 2011		cnwcs5	Initial creation - CCMS SCT 2058/par 27460
*/
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
//04 Jul 2022	jlizm1	TFS 53754 LNX Different local and server time zones causing incorrect edi outputs
constants
	MESSAGE	= "UNB";
	SPACE = ' ';
vars
	msg	:String;
	plus, colon, singleQuote, decimal, escape	:Character;
	dateTime : TimeStamp;
begin
	_protocol.getDefaultCharacters (decimal, plus, escape, singleQuote, colon);
	
	msg := MESSAGE &amp; plus &amp;
			_syntaxId &amp; colon &amp; _syntaxVersion.String &amp; plus &amp; 
			_senderId;
	if _senderQual &lt;&gt; null then
		msg := msg &amp; colon &amp; _senderQual;
	endif;
	
	msg := msg &amp; plus &amp;	_recipientId;
			
	if _recipientQual &lt;&gt; null then
		msg := msg &amp; colon &amp; _recipientQual;
	endif;
	// 040
	dateTime := _runDateTime.systemToLocalTime(_protocol.terminal.timeZoneID);	// TFS 53754
	if _useLongYear then
		msg := msg &amp; plus &amp; dateTime.date.longYearEDI() &amp; colon &amp; dateTime.time.shortFormatEDI();
	else
		msg := msg &amp; plus &amp;	dateTime.date.shortYearEDI() &amp; colon &amp; dateTime.time.shortFormatEDI();			
	endif;
	
	// 050
	msg := msg &amp; plus &amp; _seqNumber.String;
	// 080 - not used much
	if _080 &lt;&gt; null then
		msg := msg &amp; plus &amp; plus &amp; plus &amp; _080;
	endif;
	
	msg := msg &amp; singleQuote;
			
	return msg;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_syntaxId" type="String"/>
        <Parameter name="_syntaxVersion" type="Integer"/>
        <Parameter name="_senderId" type="String"/>
        <Parameter name="_senderQual" type="String"/>
        <Parameter name="_recipientId" type="String"/>
        <Parameter name="_recipientQual" type="String"/>
        <Parameter name="_seqNumber" type="Integer"/>
        <Parameter name="_080" type="String"/>
        <Parameter name="_useLongYear" type="Boolean"/>
        <Parameter name="_runDateTime" type="TimeStamp"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeUNHSegment" id="2a8f7c38-f310-420a-a92d-60d68c67c2e7">
        <source>makeUNHSegment(_protocol :CM_CamProtocol; _number :Integer; _fileType, _msgVersion, _msgReleaseNo, _agency, _association, _030 :String; _runDateTime : TimeStamp):String protected;
/*
Purpose:	Make a UNH segment
Parameters:	_number - unique number
			_fileType - eg. CODECO, COARRI
			_msgVersion - eg. D
			_msgReleaseNo - eg. 95B
			_agency - eg. UN
			_association - eg ITG14

Date		Who		Reason
09 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
*/
constants
	MESSAGE	= "UNH";
vars
	msg	:String;
	plus, colon, singleQuote	:Character;
begin
	plus		:= _protocol.elementSeparator;
	colon		:= _protocol.subElementSeparator;
	singleQuote	:= _protocol.segmentTerminator;
	
	msg := MESSAGE &amp; plus &amp; 
			_number.String &amp; plus &amp; 
			_fileType &amp; colon &amp; _msgVersion &amp; colon &amp; _msgReleaseNo &amp; colon &amp; _agency;
			
	if _association &lt;&gt; null then
		msg := msg &amp; colon &amp; _association;
	endif;
	
	if _030 &lt;&gt; null then
		msg := msg &amp; plus &amp; _030;
	endif;
	
	msg := msg &amp; singleQuote;
			
	return msg;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_number" type="Integer"/>
        <Parameter name="_fileType" type="String"/>
        <Parameter name="_msgVersion" type="String"/>
        <Parameter name="_msgReleaseNo" type="String"/>
        <Parameter name="_agency" type="String"/>
        <Parameter name="_association" type="String"/>
        <Parameter name="_030" type="String"/>
        <Parameter name="_runDateTime" type="TimeStamp"/>
        <ReturnType type="String"/>
    </JadeMethod>
