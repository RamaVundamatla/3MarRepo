    <JadeMethod name="auditId" id="58521ddb-c15e-4e54-9e4b-85e9b8ef7718">
        <source>auditId(): String;
// ---------------------------------------------------------------------------
// Created:     May 2006 by cnwrs1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	return self.lower.String &amp; " &gt; " &amp; self.upper.String;
end;</source>
