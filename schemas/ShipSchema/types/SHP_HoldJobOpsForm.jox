    <JadeMethod name="doMnuTasksAddClick" id="a032cfc9-8b6f-4c8c-967a-1d170d209485">
        <updating/>
        <source>doMnuTasksAddClick(menuItem: MenuItem input) updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/01/2017	cnwdap1		Initial creation TFS 3220 LNX Voyage Operatinos Enhancements
//
vars
	tmpTI : CM_TrackedItem;
	taskDesc : CM_ToDoTaskDesc;
	tiSet : CM_TISet;
	result : Integer;
	
begin
	if menuItem = null then
		return;
	else
		taskDesc := menuItem.userObject.CM_ToDoTaskDesc;
	endif;

	tmpTI := self.mnuCargo.userObject.CM_TrackedItem;
	if tmpTI = null then
		return;
	endif;
	
	create tiSet transient;
	self.tblJobDetails.allSelectedObjects.copy(tiSet);
	
	if (not tiSet.includes(tmpTI)) then
		tiSet.add(tmpTI);
	endif;
	
	while true do
		app.myTrxUA.trxUpdateTIToDoTaskAddBulk(taskDesc, tiSet, app.myPassport);
		if app.myPassport.trxCompletedOK then
			break;
		else
			result := app.showErrorWarningDialog('Add Todo Task', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			
		endif;
		
		break;
	endwhile;

epilog
	delete tiSet;
end;</source>
        <access>protected</access>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuTasksCompleteClick" id="f73d19e4-6446-4a54-bd12-1b280c9ca665">
        <updating/>
        <source>doMnuTasksCompleteClick(menuItem: MenuItem input) updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/01/2017	cnwdap1		Initial creation TFS 3220 LNX Voyage Operations Enhancements
//
vars
	tmpTI : CM_TrackedItem;
	taskDesc : CM_ToDoTaskDesc;
	realTiSet : CM_TISet;
	result : Integer;
	ti : CM_TrackedItem;
	tiTask : CM_ToDoTask;
	pxyTiSet : CM_TISet;
	resourceUsageProxys : CM_ResourceTypeUsageSet;
	
begin
	if menuItem = null then
		return;
	endif;
	
	if menuItem.userObject = null then
		return;
	endif;
	
	taskDesc := menuItem.userObject.CM_ToDoTaskDesc;
	
	tmpTI := self.mnuCargo.userObject.CM_TrackedItem;
	if tmpTI = null then
		return;
	endif;
	
	create realTiSet transient;
	self.tblJobDetails.allSelectedObjects.copy(realTiSet);
	
	if (not realTiSet.includes(tmpTI)) then
		realTiSet.add(tmpTI);
	endif;
	
	create pxyTiSet transient;
	if not self.myAssistant.doTaskProxySetForComplete( taskDesc.code, pxyTiSet, tmpTI, realTiSet, resourceUsageProxys) = IDOK then
		return;
	endif;
				
	while true do
		app.myTrxUA.trxUpdateTIToDoTaskCmpltBulk(taskDesc, pxyTiSet, resourceUsageProxys, app.myPassport);
		if app.myPassport.trxCompletedOK then
			break;
		else
			result := app.showErrorWarningDialog('Complete Todo Task', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;

epilog
	if pxyTiSet &lt;&gt; null and not pxyTiSet.isEmpty then
		pxyTiSet.purge;
	endif;
	delete pxyTiSet;
	delete realTiSet;
end;</source>
        <access>protected</access>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuTasksRemoveClick" id="a79adc32-2b35-4bc1-bb28-3feee2fc3872">
        <updating/>
        <source>doMnuTasksRemoveClick(menuItem: MenuItem input) updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/01/2017	cnwdap1		Initial creation TFS 3220 LNX Voyage Operations Enhancements
//
vars
	tmpTI : CM_TrackedItem;
	taskDesc : CM_ToDoTaskDesc;
	tiSet : CM_TISet;
	result : Integer;
	
begin
	if menuItem = null then
		return;
	endif;
	if menuItem.userObject = null then
		return;
	endif;

	taskDesc := menuItem.userObject.CM_ToDoTaskDesc;
	tmpTI := self.mnuCargo.userObject.CM_TrackedItem;
	if tmpTI = null then
		return;
	endif;
	
	create tiSet transient;
	self.tblJobDetails.allSelectedObjects.copy(tiSet);
	
	if (not tiSet.includes(tmpTI)) then
		tiSet.add(tmpTI);
	endif;
	
	while true do
		app.myTrxUA.trxUpdateTIToDoTaskRemBulk(taskDesc, tiSet, app.myPassport);
		if app.myPassport.trxCompletedOK then
			break;
		else
			result := app.showErrorWarningDialog('Remove Todo Task', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;

epilog
	delete tiSet;
end;</source>
        <access>protected</access>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doNotableAdd" id="3511e692-ed50-429b-916f-f04c1c414154">
        <source>doNotableAdd(_wle : CM_WorkListEntry);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 26 January 2017	cnwdap1		Initial creation TFS 3220 LNX Voyage Operations Enhancements
//
vars

begin
	if _wle = null then
		return;
	endif;
	
	if (not global.isValidObject(_wle)) then
		return;
	endif;
	
	if (not self.allDisplayedWLEs.includes(_wle)) then
		self.allDisplayedWLEs.add(_wle);
	endif;
epilog

end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="doNotableClear" id="1f5468ea-2cd1-4282-b257-aaef5f57beab">
        <updating/>
        <source>doNotableClear() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 26/01/2017	cnwdap1		Initial creation TFS 3220 LNX Voyage Operations Enhancements
//
vars

begin
	if self.listeningForClassNotes then
		self.listeningForClassNotes := false;
		self.endClassNotification( CM_TrackedItem, false, Any_System_Event );
	endif;
	self.allDisplayedWLEs.clear;
