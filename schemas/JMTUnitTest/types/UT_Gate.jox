    <JadeMethod name="iPrenoteWeightCertify" id="8fa8473e-5b4f-4826-8e9a-72a08374626c">
        <updating/>
        <source>iPrenoteWeightCertify() updating;
/*

Purpose:			TFS 1882

Date		Who		Reason
26 May 2016	cnwmk3	Initial creation

*/

vars
	booking				: CM_BookingRef;
	ti					: CM_TrackedItem;
	vvr 				: CM_VehicleVisitRecord;
	voyage1				: CM_Voyage;
	vessel 				: CM_Vessel;
	prenoteCriteria 	: CM_TermPrenoteWeightCriteria;
	prenoteCriteria1 	: CM_TermPrenoteWeightCriteria;
	pxyCriteria			: CM_YACriteria;
	critCargoType 		: CM_YATypeCargoType;
	itemCode			: String;
	terminal			: CM_Terminal;
	pxyTerminal			: CM_Terminal;
	pxyTerminal1		: CM_Terminal;
	tmpConfig			: CMIF_ConfigTerminal;
begin
	terminal := self.getTerminal;
	self.assertNotNull(terminal);
	
	// Terminal Config - Gate sheet. Prenote Certified Weight Validation criteria.  Check when in edit mode can enter and save criteria.

	create prenoteCriteria transient;
	prenoteCriteria.setMyTerminal(terminal);
	
	critCargoType := CM_YATypeCargoType.firstInstance;
	itemCode := critCargoType.description.cnEcUpto(CM_YACriteriaPriority::code.length -1);
	
	create pxyCriteria transient;
	pxyCriteria.setProxy(critCargoType, "CONT", itemCode);
	prenoteCriteria.allCriteria.add(pxyCriteria);

	create tmpConfig transient;
	tmpConfig.setFromPersistentData(terminal);
	
	beginLoad;
	pxyTerminal := terminal.pxyCreateUpdateProxy();
	endLoad;
	beginTransaction;
	pxyTerminal.myPrenoteWeightCriteria.setForUpdate(prenoteCriteria);
	commitTransaction;
	
	app.myTrxUA.trxUpdateTerminal(pxyTerminal, tmpConfig, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	// delete everything first
	deleteContainer("PRENOTE002");
	self.deleteBooking("UT_BOOKING01");
	deleteVoyage("UT_BOOK01");
	deleteVessel("UTBOAT");
	self.deleteVehicle("UT_TRK56");
	
	vessel := addVesselCellular("UTBOAT", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNull(vessel);
	voyage1 := addVoyageWithContainerStructur("UT_BOOK01", "UTBOAT", self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	assertNotNull(voyage1);

	
	booking := self.addBookingForContainer("UT_BOOKING01", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), voyage1, "NZAKL", "2200", "MT");
	assertNotNull(booking);
	
	//Prenotes - Check on save if the cargo matches the entered validation criteria an error is displayed if Is Weight Certified is not checked for Containers 
	//it will also error if Weight Certified By and/or Authorised Person for Certified Weight are blank.
	
	self.expectTrxError(Certifed_weight_required);
	self.expectTrxError(Input_req_weight_certified_by);
	self.expectTrxError(Input_req_auth_per_cert_weight);
	self.opts.purge();
	self.opts.addAssoc("IsWeightCertified", true);
	ti := self.addPrenotedContainer(booking.allBookingRefItems.first,  "PRENOTE001");
	self.assertNoTrxErrorsOrWarnings();
	self.assertNull(ti);
	
	self.opts.purge();
	self.opts.addAssoc("IsWeightCertified", true);
	self.opts.addAssoc("WeightCertBy", "TESTER");
	self.opts.addAssoc("AuthorisedPerson", "TESTER");
	ti := self.addPrenotedContainer(booking.allBookingRefItems.first,  "PRENOTE002");
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(ti);
	
	self.opts.purge();
	self.opts.addAssoc("IsWeightCertified", true);
	vvr := self.gateInContainer("UT_TRK56", "PRENOTE002", "2200", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString).code, "GENL", self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString));
	self.assertNoTrxErrorsOrWarnings();
	self.assertNull(vvr.myRoadJob);
	
	self.opts.purge();
	self.opts.addAssoc("IsWeightCertified", true);
	self.opts.addAssoc("WeightCertBy", "TESTER");
	self.opts.addAssoc("AuthorisedPerson", "TESTER");
	vvr := self.gateInContainer("UT_TRK56", "PRENOTE002", "2200", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString).code, "GENL", self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString));
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(vvr.myRoadJob);
	
	assertEqual(ti.isWeightCertified, true);
	assertEqual(ti.weightCertifiedName, "TESTER");
	assertEqual(ti.weightCertifiedReference, "TESTER");
	
	self.workVehicle(vvr);
	assertEqual(vvr.myRoadJob.status, JOB_COMPLETE);
	
	self.roadExit(vvr);
	assertIsDeleted(vvr.myRoadJob);
	
	create prenoteCriteria1 transient;
	prenoteCriteria1.setMyTerminal(terminal);
	
epilog	
	delete pxyCriteria;
	delete prenoteCriteria;
	beginTransaction;
	delete pxyTerminal;
	commitTransaction;
	
	beginTransaction;
	pxyTerminal1 := terminal.pxyCreateUpdateProxy();
	pxyTerminal1.myPrenoteWeightCriteria.setForUpdate(prenoteCriteria1);
	commitTransaction;
	
	app.myTrxUA.trxUpdateTerminal(pxyTerminal1, tmpConfig, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	delete tmpConfig;
	delete prenoteCriteria1;
	beginTransaction;
	delete pxyTerminal1;
	commitTransaction;
end;</source>
    </JadeMethod>
