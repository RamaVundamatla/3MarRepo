    <JadeMethod name="getObjects" id="1155ba3d-184d-4711-8109-227a64d9c6db">
        <source>getObjects(objects: ObjectLongNameDict input);
//05 August 2008	cnwdw1	
// Return a dict of objects for this criteria type
vars
	commodityGroup: CM_CommodityGroup;
begin
	foreach commodityGroup in app.myRoot.allCommodityGroups do
		objects[commodityGroup.getYAIdentifier] := commodityGroup;
	endforeach;
end;</source>
        <Parameter name="objects" type="ObjectLongNameDict" usage="input"/>
    </JadeMethod>
