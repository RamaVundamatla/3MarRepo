    <JadeMethod name="doLoadCmbQryOperator" id="1025ce05-a2f9-45cf-bd9c-5e609c74f37d">
        <updating/>
        <source>doLoadCmbQryOperator() updating, protected;
// ---------------------------------------------------------------------------
// Created:     17 September 2003	cnwth2
//
// Purpose:     
//	03/08/2022  navds20   Bug 54202: EUP - Combo Boxes not adhereing to configuration (operator and Stevedore)
// ----------   ----------  --------------------------------------------------
vars
	opDict			: CM_OperatorByCodeDict;
	op		 		: CM_Operator;
	idx 			: Integer;
	passport 		: CM_Passport;
	cmb				: CMUI_ComboBox;
	failedDAC  :CM_DataAccessController;
	byName			: Boolean;
begin
	cmb := self.cmbQryOperator;
	cmb.clear();
	cmb.addItem(Any_String);
	
	passport := app.myPassport;
	opDict := app.myRoot.allOperators;
	
	byName := app.myRoot.getConfig(ComboByNameOperator).Boolean;
	foreach op in opDict do
		if not op.canUserAccessSelf(null, failedDAC, passport) then
			continue;
		endif;
		
		//start 03/08/2022 navds20 TFS 54202
		if byName then
			cmb.itemObject[cmb.addItem(op.description)] := op;
		else
			cmb.itemObject[cmb.addItem(op.code &amp; " - " &amp; op.description)] := op;
		endif;
		//end 03/08/2022 navds20 TFS 54202
		
	endforeach;
	
	cmb.text := Any_String;
	self.tblQuery.setValueByName(ETRow_OperatorCode, Any_String);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doLoadCmbQryProduct" id="37ae0ef8-c3ec-4a44-be7b-60541264b863">
        <source>doLoadCmbQryProduct(_cargoType : CM_CargoType) protected;
// ---------------------------------------------------------------------------
// Created:     24 February 2003		cnwth2	
//
// Purpose:     		 
//
// Changed On	By			Reason
// ----------   ----------  --------------------------------------------------
// 047/05/2020	jlgdap1		TFS 49252 CPL Cargo Types not showing in System Admin
vars
	pro			: CM_Product;
	cmb			: CMUI_ComboBox;
begin
	cmb := self.cmbQryProduct;
	cmb.clear();
	cmb.addItem(Any_String);
	
	if _cargoType &lt;&gt; null then
		if _cargoType.id &gt; TI_CargoBOLType_Max and
		   //_cargoType.id &lt; TI_CargoBOLType_JMTMax then									// TFS 49252
		   (_cargoType.id &lt; TI_CargoBOLType_JMTMax or app.myRoot.isClientCentrePort) then	// TFS 49252
			foreach pro in _cargoType.allProducts do
				//epr tfs 19/4/16
				if pro.isNotActive then
					continue;
				endif;
				cmb.itemObject[cmb.addItem(pro.code &amp; '   ' &amp; pro.description)] := pro;
			endforeach;
		endif;
	endif;
		
	cmb.text := Any_String;
	self.tblQuery.setValueByName(ETRow_Product, Any_String);
	
end;</source>
        <access>protected</access>
        <Parameter name="_cargoType" type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="doLoadCmbQryRow" id="3d3237b7-ff60-4b25-8953-1ec963889468">
        <updating/>
        <source>doLoadCmbQryRow(_ta : CM_TerminalArea) updating, protected;
// ---------------------------------------------------------------------------
// Created:     25 February 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	lc			 	: CM_LocationsController;
	cmb				: ComboBox;
	idx : Integer;
begin
	cmb := self.cmbQryRow;
	cmb.clear();
	cmb.addItem(Any_String);
	
	if _ta &lt;&gt; null then
	
		// PAR 32308
		if _ta.isKindOf(CM_IrregularBlockArea) then
			self.allLCsSet.clear();
			_ta.CM_IrregularBlockArea.getValidLCsCollectionForMove(self.allLCsSet);
			self.myAssistant.comboBoxLocationControllers(cmb, self.allLCsSet, false);
			
			if self.myInitialisationLC &lt;&gt; null then
				idx := cmb.findObject(self.myInitialisationLC);
				if idx &gt; 0 then
					cmb.listObject := self.myInitialisationLC;		
				endif;
			endif;
		else
			foreach lc in _ta.allLocationsControllers do
				cmb.itemObject[cmb.addItem(lc.getID)] := lc;
			endforeach;
			//if only one lc, then auto select
			if _ta.allLocationsControllers.size = 1 then
				lc := _ta.allLocationsControllers.first;
				cmb.text := lc.getID;
				self.tblQuery.setValueByName(ETRow_Row, cmb.text);
				return;			
			endif;
		endif;
	endif;
	
	cmb.text := Any_String;
	self.tblQuery.setValueByName(ETRow_Row, Any_String);
		
end;</source>
        <access>protected</access>
        <Parameter name="_ta" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="doLoadCmbQryTAType" id="7bf6c0d5-3dc4-4aec-8be8-c8350dd2e11b">
        <updating/>
        <source>doLoadCmbQryTAType() updating, protected;
// ---------------------------------------------------------------------------
// Created:     14 February 2003		cnwth2	
//
// Purpose:     Loads ONLY THE RELIVANT terminal area types in to the TAType combo
//			 
// ----------   ----------  --------------------------------------------------
/*

Date		Who		Reason
10 Jun 2008	cnwkpd1	PAR #16753 - CCMS SFW 1003 - General Cargo Graphical Screens
08 Sep 2022	jlika1	TFS 54699 - CUX - MAFI Handling Enhancements - MAFI Heap Terminal Area
*/

vars

	taType 		: CM_TerminalAreaType;
	idx 		: Integer;
	taTypeDict	: CM_TATypeByTypeDict;
	cmb			: CMUI_ComboBox;
begin
	cmb := self.cmbQryTAType;
	cmb.clear();
	taTypeDict := app.myRoot.allTerminalAreaTypes;
	
	if app.getMyUser().canDo(self.myTerminal, Mod_GeneralCargo) then
		taType := taTypeDict[TA_TYPE_IRREGULAR_BLOCK_AREA];		// was TA_TYPE_GENERAL_CARGO_AREA
		if taType &lt;&gt; null then
			cmb.itemObject[cmb.addItem(taType.description)] := taType;
		endif;
	endif;
	
	/*	
	Date		Who		Reason
	22 Sep 2008	cnwdz2	PAR #17975 - For logs need to be able to see log areas	
	*/	
	if app.getMyUser().canDo(self.myTerminal, Mod_Logs) then
		taType := taTypeDict[TA_TYPE_LOGAREA];	
		if taType &lt;&gt; null then
			cmb.itemObject[cmb.addItem(taType.description)] := taType;
		endif;
	endif;

	
	cmb.itemObject[cmb.addItem(taTypeDict[TA_TYPE_COU_CRIB_PACK_UNPACK].description)] := taTypeDict[TA_TYPE_COU_CRIB_PACK_UNPACK];
	cmb.itemObject[cmb.addItem(taTypeDict[TA_TYPE_CONT_PACK_REPACK].description)] := taTypeDict[TA_TYPE_CONT_PACK_REPACK];
	cmb.itemObject[cmb.addItem(taTypeDict[TA_TYPE_BLOCK_STACK].description)] := taTypeDict[TA_TYPE_BLOCK_STACK];
	
	cmb.itemObject[cmb.addItem(taTypeDict[TA_TYPE_RECTRANS].description)] := taTypeDict[TA_TYPE_RECTRANS];
	cmb.itemObject[cmb.addItem(taTypeDict[TA_TYPE_RELTRANS].description)] := taTypeDict[TA_TYPE_RELTRANS];
	
	cmb.itemObject[cmb.addItem(taTypeDict[TA_TYPE_DEPOT_LCL].description)] := taTypeDict[TA_TYPE_DEPOT_LCL];
	cmb.itemObject[cmb.addItem(taTypeDict[TA_TYPE_FORK_LIFT_STACK].description)] := taTypeDict[TA_TYPE_FORK_LIFT_STACK];
	cmb.itemObject[cmb.addItem(taTypeDict[TA_TYPE_GENERATOR_STORE_AREA].description)] := taTypeDict[TA_TYPE_GENERATOR_STORE_AREA];
	cmb.itemObject[cmb.addItem(taTypeDict[TA_TYPE_MAFI].description)] := taTypeDict[TA_TYPE_MAFI];
	
	taType := taTypeDict[TA_TYPE_DEPOT_LCL];
	if taType = null then
		return;
	endif;
	
	cmb.text := taType.description;
	self.tblQuery.setValueByName(ETRow_TerminalAreaType, taType.description);
	self.doLoadCmbQryTerminalAreas(taType, null);

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doLoadCmbQryTerminalAreas" id="cd1215fe-ac8b-40ec-925a-71aea00e6ade">
        <updating/>
        <source>doLoadCmbQryTerminalAreas(_taType : CM_TerminalAreaType; 
							_terminalArea : CM_TerminalArea) updating,  protected;
// ---------------------------------------------------------------------------
// Created:     20 February 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	areaType 	: CM_TerminalAreaType;
	ta		 	: CM_TerminalAreaMaster;
	idx 		: Integer;
	cmb			: CMUI_ComboBox;

begin
	cmb := self.cmbQryTermArea;
	cmb.clear();
	cmb.addItem(Any_String);

	if _taType &lt;&gt; null then
		foreach ta in _taType.allTerminalAreasByTerminal 
			where ta.myTerminal = self.myTerminal do		// PAR 18513
			
			cmb.itemObject[cmb.addItem(ta.id)] := ta;
		endforeach;
	endif;
	
	cmb.text := Any_String;
	self.tblQuery.setValueByName(ETRow_TerminalArea, Any_String);
	self.doLoadCmbQryRow(null);
		
end;</source>
        <access>protected</access>
        <Parameter name="_taType" type="CM_TerminalAreaType"/>
        <Parameter name="_terminalArea" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="doLoadCmbQryVoyage" id="12211253-8b29-4482-af32-ef913ee95c69">
        <source>doLoadCmbQryVoyage() protected;
// ---------------------------------------------------------------------------
// Created:     17 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	voyDict			: CM_VoyageByCodeArrivalDT;
	voy		 		: CM_Voyage;
	defVoyage 		: String;
	idx 			: Integer;
	cmb				: CMUI_ComboBox;
begin
	cmb := self.cmbQryVoyage;
	cmb.clear();
	cmb.addItem(Any_String);

	defVoyage := self.myTerminal.getDefaultVoyageCode();
	voyDict := self.myTerminal.allVoyagesByCode;
	
	foreach voy in voyDict do
		if voy.code &lt;&gt; defVoyage then
			cmb.itemObject[cmb.addItem(voy.getDisplayDetails(false))] := voy;
		endif;
	endforeach;

	self.tblQuery.setValueByName(ETRow_QryVoyage, Any_String);
	cmb.text := Any_String;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doLoadCmbVoyage" id="c558cd3f-bedb-416b-aefc-2099556059f2">
        <updating/>
        <source>doLoadCmbVoyage() updating, protected;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	voyDict,
	voyAchived		: CM_VoyageByCodeArrivalDT;
	voy		 		: CM_Voyage;
//	defVoyage 		: String;
	idx 			: Integer;
	cmb				: CMUI_ComboBox;
begin
	cmb := self.cmbVoyageRight;
	cmb.clear();
	cmb.addItem(null);

//	defVoyage := self.myTerminal.getDefaultVoyageCode();removed by cnwyl1 for par 13109
	voyAchived := self.myTerminal.allVoyagesArchived;//added by cnwyl1 for par 13109
	voyDict := self.myTerminal.allVoyagesByCode;
	
	
	foreach voy in voyDict do
		cmb.itemObject[cmb.addItem(voy.getDisplayDetails(false))] := voy;
	endforeach;
	
	
	// Voyage - cnwrd1 par 25546 25.8.2010 wrong thing wrong place.
	/*
	self.myAssistant.comboBoxVoyageCurrent(cmb,
									null,
									true,
									false,
									false,
									true,
									true,
									false,
									true,
									false,
									true);
									*/
	
	//added by cnwyl1 for par12877
	//if the voyage has been achived, the combox will show just only one this particular voyage.
	if self.myTI &lt;&gt; null then
		if (cmb.findObject(self.myTI.myVoyage) = -1) and (voyAchived.includes(self.myTI.myVoyage)) then
			cmb.itemObject[cmb.addItem(self.myTI.myVoyage.code &amp; Tab &amp; self.myTI.myVoyage.description)] := self.myTI.myVoyage;	
		endif;
	endif;	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doLoadCountryOfOrigin" id="0865297c-59ee-488e-bf70-ca6d1e2e26b7">
        <source>doLoadCountryOfOrigin();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 August 2022	navak20	TFS ChangeRequest 54441: EUP - Additional Field - Country of Origin

*/

vars
	cmb				: CMUI_ComboBox;
	countryDict	: CM_CountryByCodeDict;
	country    : CM_Country;

begin
	cmb := self.cmbCountryOfOrigin;
	cmb.clear();

	countryDict := app.myRoot.allCountries;
	
	cmb.addItem(Any_String);
	
	foreach country in countryDict do
		if country.isNotAvailableForEntry then
			continue;
		endif;
		
		cmb.itemObject[cmb.addItem(country.code &amp; '  ' &amp; country.description)] := country;
	endforeach;
	
	self.tblQuery.setValueByName(ETRow_CountryOfOrigin, Any_String);
	cmb.text := Any_String;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doLoadShippingLine" id="687af96a-92e3-47c8-b674-0178e84a0029">
        <source>doLoadShippingLine();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 May 2022	navak20	ChangeRequest 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI

*/

vars
	cmb				: CMUI_ComboBox;
	shippingLineDict	: CM_ShippingLineByCodeDict;
	shippingLine    : CM_ShippingLine;

begin
	cmb := self.cmbShippingLine;
	cmb.clear();

	shippingLineDict := app.myRoot.allShippingLines;
	
	cmb.addItem(Any_String);
	
	foreach shippingLine in shippingLineDict do
		if shippingLine.isNotAvailableForEntry then
			continue;
		endif;
		
		cmb.itemObject[cmb.addItem(shippingLine.code &amp; '  ' &amp; shippingLine.description)] := shippingLine;
	endforeach;
	
	self.tblQuery.setValueByName(ETRow_ShippingLine, Any_String);
	cmb.text := Any_String;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doMakeHazAttachmentBtnClick" id="5ae7c15a-0fc3-4f16-8df2-37ee88f2ff27">
        <updating/>
        <source>doMakeHazAttachmentBtnClick() protected, updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 22/06/2015	cnwdap1		Initial creation PAR #63421 Hazaardous Materials Handling
//
vars
	ti			: CM_TrackedItem;
	pxyTI		: CM_TrackedItem;
	cargoType	: Integer;
	attachments	: ObjectArray;
	booking		: CM_BookingRef;
	
begin
	if not self.checkContainerHasBeenEntered then
		app.msgBox(app.getErrorString(YRDContainerForAttachment), app.getErrorString(Nothing_Selected), MsgBox_OK_Only + MsgBox_Information_Icon);
		self.tblContainer.goToRowByName(ETRow_ContainerID);
		return;
	endif;
	
	if self.cmbCargoType.listObject &lt;&gt; null then
		cargoType := self.cmbCargoType.listObject.CM_CargoType.id;
		ti := self.myTerminal.allOnsiteTIsByCargoTypeId[cargoType, self.cmbTrackedItem.text].CM_TrackedItem;
		if ti = null then
			app.msgBox(app.getErrorString(YRDInvalidContSelected), app.getErrorString(InvalidContainer), MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
	endif;
	
	if self.cmbBooking.listObject &lt;&gt; null then
		booking := self.cmbBooking.listObject.CM_BookingRef;
	endif;
	
	create attachments transient;
	pxyTI := ti.pxyGetProxyObject();
	if pxyTI = null then
		pxyTI := app.createUpdateProxy(ti).CM_TrackedItem;
	endif;
	pxyTI.getAllChildHazards(attachments);
	
	self.myAssistant.showHazardousChildrenForm(	self.myTerminal,
												true, false, false,
												pxyTI,
												null,
												booking,
												attachments,
												self,
												self.myMasterMenuAction	);

epilog
	delete attachments;
	delete pxyTI;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doMakeLCLAttahmentsBtnClick" id="9c2cf9f3-99e8-42bc-949c-3ff12ec17156">
        <updating/>
        <source>doMakeLCLAttahmentsBtnClick() protected, updating;
// ---------------------------------------------------------------------------
// Created:     18 November 2003	cnwth2
//
// Purpose:     
// 13 Apr 2024	navnk30 	Bug 63247: EUP Testing | Container Weights not updated when Making New LCL
// ----------   ----------  --------------------------------------------------
vars
	ti					: CM_TrackedItem;
	attachFrm			: CMUI_AttachBreakBulkModal;
	cargoType			: Integer;
begin
	if not self.checkContainerHasBeenEntered then
		app.msgBox(app.getErrorString(YRDContainerForAttachment), app.getErrorString(Nothing_Selected), MsgBox_OK_Only + MsgBox_Information_Icon);
		self.tblContainer.goToRowByName(ETRow_ContainerID);
		return;
	endif;
	
	if self.cmbCargoType.listObject &lt;&gt; null then			//+cnwml2 PAR23431
	//+cnwml2 PAR23045
		cargoType := self.cmbCargoType.listObject.CM_CargoType.id;
		
		ti := self.myTerminal.allOnsiteTIsByCargoTypeId[cargoType, self.cmbTrackedItem.text].CM_TrackedItem;
		if ti = null then
			app.msgBox(app.getErrorString(YRDInvalidContSelected), app.getErrorString(InvalidContainer), MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
	endif;
	
	
	
	if self.mnuEnhanced.checked then
		//06 Dec 2013	NDL	Par 32854
		self.myAssistant.showMakeLCL(	self,	//_parentForm : CM_BaseForm;
										//ti,	//_relatedObj : Object;		//13.04.2024 navnk30 #63247
										ti.myPrimaryActualLocation,			//13.04.2024 navnk30 #63247
										true,	//_modal : Boolean;
										3,	//_columns : Integer;
										160,	//_controlWidth : Integer
										true); // PAR 35740
		
		//epr par 34711 26/8/14 don't need to call anything to update the ti with newly created LCL here because that is handled by notes
		return; 
	
	else
		attachFrm := app.getForm(CMUI_AttachBreakBulkModal.name).CMUI_AttachBreakBulkModal;
		
		if attachFrm = null then
			attachFrm := app.loadForm(CMUI_AttachBreakBulkModal, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_AttachBreakBulkModal;
		endif;
		
		//+cnwml2 PAR23045
		attachFrm.aMyTerminalArea := self.cmbQryTermArea.listObject.CM_TerminalArea;
		if self.cmbQryTAType.listObject &lt;&gt; null then //default to currently queried TA type
			attachFrm.aTerminalAreaType := self.cmbQryTAType.listObject.CM_TerminalAreaType.type;
		else
			attachFrm.aTerminalAreaType := app.myRoot.allTerminalAreaTypes[TA_TYPE_BLOCK_STACK].type;
		endif;
		attachFrm.aMyLocationsController := self.cmbQryRow.listObject.CM_LocationsController;			//+cnwml2 PAR24785
	
		attachFrm.aMyCargoType := app.myRoot.allCargoTypesById[TI_CargoType_LCL];
		//attachFrm.
		if self.cmbOperatorRight.listObject &lt;&gt; null then							//13.04.2024 navnk30 #63247
			attachFrm.aMyOperator := self.cmbOperatorRight.listObject.CM_Operator;
		else
			attachFrm.aMyOperator := self.cmbQryOperator.listObject.CM_Operator; 
		endif;
		if ti.isKindOf(CM_Container) then
//			attachFrm.aMyMasterTI := ti.CM_Container;				//13.04.2024 navnk30 #63247
			attachFrm.aUseMasterContainer := true;
		else
//			attachFrm.aMyMasterTI := ti;							//13.04.2024 navnk30 #63247
			attachFrm.aUseMasterContainer := false;
		endif;
		attachFrm.aIsForCreation := true;
		attachFrm.showModal;
		//epr par 34711 26/8/14 don't need to call anything to update the ti with newly created LCL here because that is handled by notes	
	
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doMnuCargoLabelPrint" id="c7fd9bc9-b0b6-4f30-b96c-f9f225e2c4fc">
        <source>doMnuCargoLabelPrint(_table : CM_DataTable; _mnu : MenuItem);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 January 2010	cnwndl1	Initial creation	CCMS MES 1004

*/

vars
	tiArray : CM_ObjectArrayActual;
	obj : Object;
begin
	
	if _table.allSelectedObjects.isEmpty and _mnu.userObject = null then
		return;
	endif;
	
	create tiArray transient;
	
	foreach obj in _table.allSelectedObjects do
		if obj.isKindOf(CM_TrackedItem) then
			tiArray.add( obj.CM_TrackedItem );
		endif;
	endforeach;
	
	if _mnu.userObject &lt;&gt; null then
		if not tiArray.includes(_mnu.userObject.CM_TrackedItem) then
			tiArray.add( _mnu.userObject.CM_TrackedItem );
		endif;
	endif;
	
	if tiArray.isEmpty then
		return;
	endif;
	
	self.myAssistant.showCargoIdLabelPrintForm(tiArray);
	
	
epilog

	delete tiArray;
	
end;</source>
        <Parameter name="_table" type="CM_DataTable"/>
        <Parameter name="_mnu" type="MenuItem"/>
    </JadeMethod>
    <JadeMethod name="doMnuColumnOrganiserClick" id="00b04b60-9ffb-48f3-b657-0501b983373c">
        <source>doMnuColumnOrganiserClick( _menuItem : MenuItem input; _dataTable : CM_DataTable ) protected;

/*
Purpose:	Allow the supplied table to be column organised.

Date		Who		Reason
13/10/2010	cnwrl1	Initial creation as part of PAR 23899/25674 - Pack/Unpack form column organiser.
05/04/2013	cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements
*/
	
vars
	dataTable		: CM_DataTable;
		
begin
	dataTable	:= _dataTable;
	if _dataTable = null then
		// need to pass in the table wanting to organise
		return;
	endif;
	
	//epr par 33900 4/4/14 measurement columns now handled on column orgainser form
	dataTable.showColumnOrganiserFrm( self.myTerminal, null );								// PAR #31155
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_menuItem" type="MenuItem" usage="input"/>
        <Parameter name="_dataTable" type="CM_DataTable"/>
    </JadeMethod>
    <JadeMethod name="doModalMessageDisplay" id="c4ea5c55-bc06-4171-bee7-d904acfa34a0">
        <source>doModalMessageDisplay(_ti : CM_TrackedItem; _showWarning : Boolean);
//********************************************************************
//
// Created by: cnwsh3
//
// Date: 30 September 2004
//
//********************************************************************
vars
	noPackMsg : String;
	ti : CM_TrackedItem;
	isoGroup	: CM_ISOTypeGroup;
	booking	: CM_BookingRef;
	bookingRefItem	: CM_BookingRefItem;
begin
	ti := _ti;
	if (not self.cbIgnoreWarnings.value) then
		if ti.hasToDoTasks then
			if noPackMsg = null then
				noPackMsg := app.getErrorString(HasToDoTasks);
			else
				noPackMsg := noPackMsg &amp;  CrLf &amp; " &amp; " &amp; app.getErrorString(HasToDoTasks);
			endif;
		endif;
		
		if noPackMsg &lt;&gt; null then
			app.msgBox(app.getErrorString(CannotPack) &amp; " " &amp; ti.id &amp; ". " &amp; noPackMsg &amp; ". " &amp; app.getErrorString(TheseMustBeRemovedFirst),
							app.getErrorString(Pack_) &amp; ti.id, MsgBox_OK_Only);
				
			self.setState(STATE_DISABLED);
		else
			self.setState(STATE_ENABLED);	
		endif;
	else
		self.setState(STATE_ENABLED);	
	endif;
	
	// DVB changed AGAIN 6/09/06
	// ONLY WANT TO SHOW THIS WARNING FOR SELECTION OF TI AND ONLY IF THEY WANT WARNINGS
	if ti.isKindOf(CM_Container) then
		if (ti.CM_Container.contentsStatus = TI_CONTENTS_STATUS_FCL) and (_showWarning and not self.cbIgnoreWarnings.value) then
			app.msgBox(app.getErrorString1(TheContentsStatusOfContainer, ti.id), app.getErrorString(Warning), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);	
		endif;
		// 27720 cnwjre1 July 2011 give warning of difference of ISO group/type between booking and container
		if not self.cbIgnoreWarnings.value then
			booking	:= self.cmbBooking.listObject.CM_BookingRef;
			bookingRefItem := self.cmbBookingItem.listObject.CM_BookingRefItem;
			if booking &lt;&gt; null and 
			   bookingRefItem = null then
				bookingRefItem := booking.allBookingRefItems.first;
			endif;
			if bookingRefItem &lt;&gt; null then
				if bookingRefItem.isoTypeGroup &lt;&gt; null then
					if ti.CM_Container.isoGroup &lt;&gt; null and
					   bookingRefItem.isoTypeGroup &lt;&gt; ti.CM_Container.isoGroup then
						app.msgBox(app.getErrorString2(Booking_contain_ISO_group, bookingRefItem.isoTypeGroup, ti.CM_Container.isoGroup), app.getErrorString(Warning), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);	
					elseif ti.CM_Container.isoType &lt;&gt; null then
						isoGroup := app.myRoot.allISOTypeGroups[bookingRefItem.isoTypeGroup];
						if isoGroup &lt;&gt; null and 
						   not ti.isoTypeBelongsToGroup(isoGroup) then
							app.msgBox(app.getErrorString2(Booking_contain_ISO_group, bookingRefItem.isoTypeGroup, ti.CM_Container.isoType), app.getErrorString(Warning), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);	
						endif;
					endif;
				elseif bookingRefItem.isoType &lt;&gt; null and
				   ti.CM_Container.isoType &lt;&gt; null and
				   bookingRefItem.isoType &lt;&gt; ti.CM_Container.isoType then
					app.msgBox(app.getErrorString2(Booking_contain_ISO_type, bookingRefItem.isoType, ti.CM_Container.isoType), app.getErrorString(Warning), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);	
				endif;
			endif;
		endif;
	endif;
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_showWarning" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPackComCancelClick" id="03d2069c-649e-42c9-bec4-37fde012dad9">
        <source>doPackComCancelClick();
//----------------------------------------------------------------
//	Created:	29 September 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	
	self.sptMain.enabled := true;
	self.frmToolbar.enabled := true;
	self.frmPackComplete.visible := false;
end;</source>
    </JadeMethod>
    <JadeMethod name="doPackSelected" id="13a46856-c6e1-400a-b598-c3eb04dd3867">
        <updating/>
        <source>doPackSelected() updating, protected;
// ---------------------------------------------------------------------------
// Created:     20 February 2003		cnwth2	
//
// Purpose:     
//			 
// Changed On	By			Reason
// ----------   ----------  --------------------------------------------------
// 22/07/2013	cnwdap1		PAR #31196 If TI is a Tranship, don't change imex status
vars
	contentsStatus		: CM_ContentsStatus;
	contRange			: CM_ContRange;
	numRows,
	row					: Integer;
	tbl					: CM_DataTable;
	foundRow			: Boolean;
	ti					: CM_TrackedItem;
begin
	if self.myTI = null then
		app.msgBox(app.getErrorString(YouMustSelectAContainerFirst), app.getErrorString(Nothing_Selected), MsgBox_OK_Only + MsgBox_Information_Icon	);
		return;
	endif;

	tbl := self.tblUnpacked;
	numRows := tbl.rows;
	
	contRange := app.myRoot.lookupContainerRange(self.myTI.id);
	
	//packing an item removes it from the unpacked table, and puts it in the packed table, so the number of
	//rows in tblUnpacked will be changing each time we load one of the selected items (they can multi-select) 
	//hence the need for the while loop
	while true do : trueLoop
		foundRow := false;
		foreach row in tbl.fixedRows + 1 to numRows do : rowLoop
			if tbl.accessRow(row).selected then
				foundRow := true;
				ti := tbl.accessedRow.itemObject.CM_TrackedItem;
				if (not self.packItem(false, ti, contRange, row)) then
					break trueLoop;
				else
					break rowLoop;
				endif;
			endif;
		endforeach;
		
		if foundRow = false then //no more rows are selected
			break trueLoop;
		endif;
		numRows := tbl.rows;	
	endwhile;
	
	if self.myTI.isKindOf(CM_Container) then					//+cnwml2 PAR23314
		if self.tblPacked.rows = self.tblPacked.fixedRows then
			// 05 May 2015	NDL	Par 36160 - remove "SuppressImexUpdateOnPack" check
			// 02/03/2009 cnwar2 #18775 - new config to prevent auto updating of imex or commodity
		//	if self.myTerminal.getConfig(SuppressImexUpdateOnPack).Boolean then
		//		self.setContentsStatus(TI_CONTENTS_STATUS_EMPTY);
		//	else
				self.setContentsImExStatus(TI_CONTENTS_STATUS_EMPTY, TI_IMEX_STATUS_STORAGE);
		//	endif;
		else
			// PAR 18775 - Don't change unless this is the first item to be packed
			if self.tblPacked.rows = (self.tblPacked.fixedRows + 1) then
				// 05 May 2015	NDL	Par 36160 - remove "SuppressImexUpdateOnPack" check
				// 02/03/2009 cnwar2 #18775 - new config to prevent auto updating of imex or commodity
			//	if self.myTerminal.getConfig(SuppressImexUpdateOnPack).Boolean then
			//		self.setContentsStatus(TI_CONTENTS_STATUS_LCL);
			//	else
					//self.setContentsImExStatus(TI_CONTENTS_STATUS_LCL, TI_IMEX_STATUS_EXPORT);	// PAR #31196
					self.setContentsImExStatus(TI_CONTENTS_STATUS_LCL, self.theTIimexStatus);		// PAR #31196
			//	endif;
			endif;
		endif;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doPopulatePackUnpackChildren" id="e7a13737-4efe-4d6a-9457-cad5a4723114">
        <updating/>
        <source>doPopulatePackUnpackChildren(_thePackTIs, _theUnpackTIs : CM_TIArray input) protected, updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 06 Jul 2010	cnwkpd1		PAR #24795 - Tidy up notifications and performance of Pack/Unpack
// ---------------------------------------------------------------------------

vars
	childItemsListed 	: CM_TISet;			// Changed from array for performance
	aChild 				: CM_TrackedItem;
	anObject 			: Object;
	idx 				: Integer;
	
begin
	create childItemsListed transient;
	//create children transient;//PAR 22954

	// WORK OUT WHAT IS NEW TO PACK
	foreach idx in self.tblPacked.fixedRows + 1 to self.tblPacked.rows do
		anObject := self.tblPacked.accessRow(idx).itemObject;
		if anObject = null then
			continue;
		endif;
		
		childItemsListed.addNoDuplicates(anObject.CM_TrackedItem, false);
		if not self.myTI.allChildren.includes(anObject.CM_TrackedItem) then//cnwsh3 - PAR25103 - allChildren collection has been unprotected reversing the need for changes from PAR22954
		//if not self.myTI.hasChild(anObject.CM_TrackedItem) then
			_thePackTIs.add(anObject.CM_TrackedItem);
		endif;
		
	endforeach;

	// WORK OUT WHAT HAS GONE TO UNPACK
	//self.myTI.getAllChildren(children);//PAR 22954
	//foreach aChild in children do
	foreach aChild in self.myTI.allChildren do//cnwsh3 - PAR25103 - allChildren collection has been unprotected reversing the need for changes from PAR22954
		if not childItemsListed.includes(aChild) then
			_theUnpackTIs.add(aChild);		
		endif;
		
	endforeach;
	
epilog
	delete childItemsListed;
end;</source>
        <access>protected</access>
        <Parameter name="_thePackTIs" type="CM_TIArray" usage="input"/>
        <Parameter name="_theUnpackTIs" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="f6243b94-32d0-45e0-8338-aa438ef6859a">
        <updating/>
        <source>doRefresh() updating, protected;
//********************************************************************
//
// Created by: cnwsh3
//
// Date: 12 January 2004
//
// Changed On	Changed By	Reason
// ----------	----------	------------------------------------------
// 24/07/2009	consw1		PAR 20335 - SFW1075 To Do Task Scheduling
//********************************************************************
vars

begin
	inheritMethod();

	if self.allInitialisationTIs.isEmpty() then
		self.doSearch();
	else
		self.displayInitialisationTIs();
	endif;

	self.doDisplayTrackedItem(false);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doRepackSelected" id="5abb236a-d999-4f2a-88c5-71b3240c45fd">
        <updating/>
        <source>doRepackSelected()updating, protected;
//********************************************************************
//
// Created by: cnwsh3
//
// Date: 24 November 2003
//
//********************************************************************
vars
	contRange			: CM_ContRange;
	tbl					: CM_DataTable;
	foundRow			: Boolean;
	childTI				: CM_TrackedItem;
	obj					: Object;
	child				: CM_TrackedItem;
	warningOK			: Boolean;
	
begin
	self.isUsedForRepack := true;
	self.allPackedItems.clear();

	//Mostly validation from here so should be own method from here..........	
	if self.repackHasOccured then
		app.msgBox("You have already set a piece of cargo to repack.  Click save to commit changes.", "Repack Ready To Be Saved", MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	endif;
	//create children transient;//PAR 22954
	tbl := self.tblUnpacked;
	obj := tbl.accessRow(tbl.row).itemObject;
	
	if (obj = null) then	
		app.msgBox(app.getErrorString(ContainerToEmptySelection), app.getErrorString(InvalidContainer), MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	endif;
	
	if (not CM_Container.hasInstance(obj)) or 
	   (not tbl.accessRow(tbl.row).selected) then
	   global.beep();
		app.msgBox(app.getErrorString(ContainerToEmptyInvalid), app.getErrorString(SelectAContainer), MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	endif;

	//Check to ensure container is valid is made at the beginning of the method.	
	self.myTIToEmpty := obj.CM_TrackedItem;

	if self.myTI = null or (not self.myTI.isEmpty) then
		app.msgBox(app.getErrorString(SelectEmptyContainer) &amp; CrLf &amp; app.getErrorString(PleaseSelectAnotherContainer), app.getErrorString(SelectAContainer), MsgBox_OK_Only + MsgBox_Information_Icon	);
		self.tblContainer.setFocus();
		self.tblContainer.goToRowByName(ETRow_ContainerID);
		return;
	endif;	
	
	if self.myTI = self.myTIToEmpty then
		app.msgBox(app.getErrorString(ContainerIsTheSame),  app.getErrorString(SameContainer), MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	endif;
	
	// We can select any container onsite so check to see if the container is in fact in the repack area.	
	if self.myTI.myTerminalArea.type &lt;&gt; TA_TYPE_CONT_PACK_REPACK then
		app.msgBox(app.getErrorString(ContainerNotInRepack), app.getErrorString(InvalidContainer), MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	endif;
	
	contRange := app.myRoot.lookupContainerRange(self.myTI.id);
	//...............To here.

	//Change the details of the container displayed here
	warningOK := self.assignContainerDetails( self.myTIToEmpty ,contRange);
	
	if not warningOK then
		return;
	endif;
	
	if self.myTIToEmpty.hasChildren then
		//self.myTIToEmpty.getAllChildren(children);//PAR 22954
		//foreach child in children do
		foreach child in self.myTIToEmpty.allChildren do//cnwsh3 - PAR25103 - allChildren collection has been unprotected reversing the need for changes from PAR22954
			self.addTblDataRow(null, child, self.tblPacked);
			self.allPackedItems.add(child);
			
		endforeach;
	endif;
	
	if self.myTI.isKindOf(CM_Container) then
		self.setContentsImExStatus(self.myTIToEmpty.CM_Container.contentsStatus, self.myTIToEmpty.getImExStatus);
	endif;
	//Let the form know the repack has occured so it doesn't do it again.
	self.repackHasOccured := true;
	self.btnCancelBase.enabled := true;		// 28474 disable Cancel until change made
	
epilog
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResetSearch" id="c71f0143-69ac-4ee9-a246-4684c35b5cef">
        <updating/>
        <source>doResetSearch() protected, updating;
// ---------------------------------------------------------------------------
// Created:     17 September 2003	cnwth2
//
// Purpose:     
//	27 May 2022	navak20	ChangeRequest 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI	
// 19 August 2022	navak20	TFS ChangeRequest 54441: EUP - Additional Field - Country of Origin	 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.doLoadCmbQryTAType();
	self.doLoadCmbQryCargoTypes();
	self.doLoadCmbQryOperator();
	self.doLoadCmbQryVoyage();
	self.doLoadCmbQryDisPorts(self.cmbQryVoyage.listObject.CM_Voyage);
	self.doLoadCmbQryDestPort();
	self.tblQuery.setValueByName(ETRow_Id, null);
	self.doLoadShippingLine();		// 27.05.2022 navak20 TFS 53204
	self.doLoadCountryOfOrigin();	// 19.08.2022 navak20 TFS 54441
	self.tblQuery.setFocus();
	self.tblQuery.moveFirst();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResize" id="dec9a15f-feba-418b-af20-0f61cc0d820c">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tbl			: CM_EntryTable;
begin
	self.sptMain.top := self.frmToolbar.height;	
	tbl := self.tblQuery;
	tbl.top := self.frmQueryToolbar.height;

	inheritMethod();


end;</source>
    </JadeMethod>
    <JadeMethod name="doRestoreReleaseAndBooking" id="d71a1428-c8be-4ad2-841b-6691a13944c0">
        <updating/>
        <source>doRestoreReleaseAndBooking(_release : CM_BulkRelease; _booking : CM_BookingRef; _bookingItem : CM_BookingRefItem) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06/08/2010	cnwdap1	Initial creation PAR #23925 CCMS MES 1072
*/
vars
	idx	: Integer;

begin
	if _release &lt;&gt; null then
		idx := self.cmbBR.findObject(_release);
		self.cmbBR.listIndex := idx;
		cmbBR_lostFocus(cmbBR);
	endif;
	if _booking &lt;&gt; null then
		self.doShowExportBookings();
		idx := self.cmbBooking.findObject(_booking);
		self.cmbBooking.listIndex := idx;
		self.cmbBookingItem.setMyBookingRef(null);
		self.loadBookingItems(_booking, _bookingItem);
		idx := self.cmbBookingItem.findObject(_bookingItem);
		self.cmbBookingItem.listIndex := idx;
		//self.cmbBooking_lostFocus(self.cmbBooking);
		self.tblContainer.setValueByControlName(self.cmbBooking.name, self.cmbBooking.text);
		self.tblContainer.setValueByControlName(self.cmbBookingItem.name, self.cmbBookingItem.text);
	endif;
epilog

end;</source>
        <Parameter name="_release" type="CM_BulkRelease"/>
        <Parameter name="_booking" type="CM_BookingRef"/>
        <Parameter name="_bookingItem" type="CM_BookingRefItem"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="5fd88a90-e6bc-42d1-906d-409729eb52be">
        <updating/>
        <source>doSave() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 April 2011	cnwndl1	Initial creation	- moved original code from "doBaseFormSave" to here, so we can call within a deadlock retry
07 Sep 2011		cnwdap1	PAR #28089 - Was finding Archived bookings by just doinga getAtkey on the
								terminal.allBookingRefsByRef collection - use the combo box object instead
26 June 2012	cnwdap1	PAR #29735 New parameter for CM_TrackedItem::setBookingRefAndItem
// 23/11/2015   cnwma1      PAR #37201 - Impossible to Unpack items from cntr packed in the 8.4.2
// 13/04/2024	navnk30 	Bug 63247: EUP Testing | Container Weights not updated when Making New LCL
*/

vars
	charged,
	loadState  					: Boolean;
	thePackTIs,	
	theUnpackTIs 				: CM_TIArray;
	realChild,
	pxyContainer				: CM_TrackedItem;
	cmifPack	 				: CMIF_PackUnpack;
	theMoveController 			: CMIF_MoveController;
	lc							: CM_LocationsController;
	result						: Integer;
	booking						: CM_BookingRef;
	bookingItem					: CM_BookingRefItem;
	errorText					: String;
	child : CM_TrackedItem;
	
begin
	self.mousePointer := Window.MousePointer_HourGlass;
	if (self.isUsedForRepack) then
		self.doBaseRepackSave();
		return;
	endif;

	if self.myTI = null then
		app.msgBox(app.getErrorString(YouMustSelectAContainerFirst), app.getErrorString(Nothing_Selected), MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	endif;
	// ##################
	// Make a proxy copy of our TI
	app.cmsBeginLoad(loadState);
	pxyContainer := self.myTI.pxyCreateUpdateProxy();
	
	//booking := self.myTerminal.allBookingRefsByRef[self.tblContainer.getValueByName(ETRow_BookingReference).String];	// PAR #28089
	/* cnwma1 23/11/2015 PAR #37201
	booking := self.cmbBooking.listObject.CM_BookingRef;																// PAR #28089
	bookingItem := self.cmbBookingItem.listObject.CM_BookingRefItem;			//+cnwml2 PAR25870
	//pxyContainer.setBookingRefAndItem(booking, bookingItem, app.myPassport);			// PAR #29735
	pxyContainer.setBookingRefAndItem(booking, bookingItem, true, app.myPassport);		// PAR #29735
	*/
	// ##################
	//update the container info by setting cmifPackUnpack from the container entry table
	create cmifPack transient;
	cmifPack.setValuesFromTI(pxyContainer);  //cnwjo3 par 19515
	self.setCMIFPackUnpackFromTbl(cmifPack, pxyContainer);
	pxyContainer.setPxyFromCMIF_PackUnpack(cmifPack, self.tblPacked.hasNoData(), errorText );	// #26529 10/01/2011. Parameters have been added.
	if errorText &lt;&gt; null then	// #26529 10/01/2011
		endLoad;
		app.msgBox(errorText, null, MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	endif;
	//23/11/2015 cnwma1 PAR #37201
	booking := self.cmbBooking.listObject.CM_BookingRef;						
	bookingItem := self.cmbBookingItem.listObject.CM_BookingRefItem;			
	pxyContainer.setBookingRefAndItem(booking, bookingItem, true, app.myPassport);	
	//23/11/2015 cnwma1 PAR #37201
	// ##################
	// this is used to create pack and unpack transactions
	create thePackTIs transient;
	create theUnpackTIs transient;
	self.doPopulatePackUnpackChildren(thePackTIs, theUnpackTIs);
	// ##################
	// throw them all at the TRX
	//app.myPassport.setWarningsIgnored(self.cbIgnoreWarnings.value);
	if self.cbIgnoreWarnings.enabled then
		app.myPassport.warningsAcknowledged := self.cbIgnoreWarnings.value;
	else
		app.myPassport.warningsAcknowledged := false;
	endif;
	//#######################
	//setup the move controller
	//if not unpacking then lc will be null, and the move controllers toLocation will be null. This is correct, as the move done
	//to the child items being packed sets their location to null, as thence it is retrieved from the parent.
	
//	if (pxyContainer.isKindOf(CM_Container)) and (cmifPack.contentsStatus = TI_CONTENTS_STATUS_EMPTY) and
//	   ((pxyContainer.isOverDimensions) or  (pxyContainer.allTIHazards.size &gt; 0)) then
	// 15 Mar 2012	NDL	Par 29250
	if (pxyContainer.isKindOf(CM_Container)) and (cmifPack.contentsStatus = TI_CONTENTS_STATUS_EMPTY) then
		//if thePackTIs.isEmpty then	//11 Jan 2013	NDL	Par 30912	//13.04.2024 navnk30 #63247
		if self.tblPacked.rows = self.tblPacked.fixedRows then			//13.04.2024 navnk30 #63247
			pxyContainer.updateHazardODWhenUnpack();
		endif;
	else
		//23 Jul 2013	NDL	Par 32023 - DPH automatically add any child hazards to the parent.
		pxyContainer.updateHazardsWhenPacking( thePackTIs );
	endif;
	
	if (not theUnpackTIs.isEmpty()) then 
		lc := self.cmbQryRow.listObject.CM_LocationsController;
		if lc = null then
			endLoad;
			app.msgBox(	app.getErrorString(YouMustSelectARowYRD) &amp; CrLf &amp; app.getErrorString(ForTheItemsThatNeedUnpack),
						app.getErrorString(UnpackingLocationNotSelected),
						MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
	endif;
	
	create theMoveController transient;
	theMoveController.setMyToPrimaryLocation(lc);
	theMoveController.setMyOriginatingLocation(self.myTI.getPrimaryLocation(REAL_MODE));
	theMoveController.setMoveMode(REAL_MODE);
	theMoveController.isSystemMove := true;
	theMoveController.isForcedMove := true;
	charged := self.cbCharged.value;
	//##########################

	while true do
		app.myTrxUA.trxUpdatePackUnpack(theMoveController, (not charged), thePackTIs, theUnpackTIs, false, pxyContainer, app.myPassport);

		//08 Apr 2011	NDL	Par 20392 - now handled in 'doBaseFormSave'
		if app.myPassport.hadDeadlock = true then
			return;
		endif;
		
		if app.myPassport.trxCompletedOK() then
			// Clear errors/warnings from form and err/warnings window
			self.allPackedItems.clear();
			self.allUnpackedItems.clear();
			self.clearErrorWarnings();
			self.btnCancelBase.enabled := false;		// 28474 disable Cancel until change made
			
			if self.tblContainer.getValueByName(ETRow_CompleteTransaction).String = app.getString(Default) then
				if (not thePackTIs.isEmpty()) then
					self.addPackComplete(thePackTIs);				//+cnwml2 PAR24046
				elseif (not theUnpackTIs.isEmpty()) then
					self.addUnpackComplete(theUnpackTIs);			//+cnwml2 PAR24046
				else
					self.addPackComplete(thePackTIs);				//+cnwml2 PAR24046
				endif;
			elseif self.tblContainer.getValueByName(ETRow_CompleteTransaction).String = app.getString(Pack_Complete) then
				self.addPackComplete(thePackTIs);
			elseif self.tblContainer.getValueByName(ETRow_CompleteTransaction).String = app.getString(Unpack_Complete) then
				self.addUnpackComplete(theUnpackTIs);
			endif;
			
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(PackUnpack), app.myPassport,ErrWarnMode_Update + ErrWarnMode_CanAckWarnings); // ErrWarnMode_Update); ErrWarnMode_AddUpdate
			if app.myPassport.noErrors()
			and result = IDOK
			then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			if app.myPassport.hasWarningsToAcknowledge then
				cbIgnoreWarnings.value := false;
				cbIgnoreWarnings.enabled := true;
			endif;
			
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			break;
		endif;
	endwhile;
	
	self.cmbCompTrans.text := app.getString(Default);		//always set it back to default +cnwml2 PAR24046
	self.tblContainer.setValueByName(ETRow_CompleteTransaction, self.cmbCompTrans.text);

epilog
	self.mousePointer := Window.MousePointer_Default;
	if theUnpackTIs &lt;&gt; null then 
		foreach realChild in theUnpackTIs do
			delete realChild.pxyGetProxyObject();
		endforeach;
	endif;

	delete thePackTIs;
	delete theUnpackTIs;
	delete pxyContainer;
	delete cmifPack;
	delete theMoveController;
	
	app.cmsEndLoad(loadState);
	//app.myPassport.setWarningsIgnored(false);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSearch" id="3706d64f-e6c2-4d52-a86c-e5cbacc7454b">
        <updating/>
        <source>doSearch() updating, protected;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
/*
Date		Who		Reason
06 Jul 2010	cnwkpd1	PAR #24795 - Tidy up notifications and performance of Pack/Unpack
20 Aug 2010	cnwdap1	PAR #23925 CCMS MES 1076 Reset Filter Export Booking button
09 Apr 2013	cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements
23 May 2022	navak20	ChangeRequest 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
19 August 2022	navak20	TFS ChangeRequest 54441: EUP - Additional Field - Country of Origin
*/

vars
	theTI 				: CM_TrackedItem;
	theFilter			: CMQF_TrackedItem;
	containerID 		: String;
	tbl					: CM_DataTable;
	emptyCommodity		: String;
	isForRepack			: Boolean;
	taType				: CM_TerminalAreaType;
	includeTI			: Boolean;
	reason				: String;
	release				: CM_BulkRelease;
	reserve				: CM_ReserveDetail;

begin
	self.mousePointer := Window.MousePointer_HourGlass;
	
	tbl := self.tblUnpacked;
	self.disarmNotesForTableObjects(tbl);		// PAR #24795
	tbl.rows := tbl.fixedRows;

	theFilter := self.myFilterObject;
	theFilter.reset();
	theFilter.allTerminals.add(self.myTerminal);
	emptyCommodity := self.myTerminal.getDefaultEmptyCommodity();
		
	if self.cmbQryTAType.listObject = null then
		app.msgBox(app.getErrorString(YouMustSelectATerminalAreaType), app.getErrorString(InsufficientInput), MsgBox_Exclamation_Mark_Icon);
		return;
	else
		taType := cmbQryTAType.listObject.CM_TerminalAreaType;
		if taType.allTerminalAreasByTerminal.size &gt; 0 then
			if self.cmbQryTermArea.listObject = null then
				app.msgBox(app.getString(YoMustSelectATerminalArea), app.getString(InsufficientInput), MsgBox_Exclamation_Mark_Icon);
				return;
			endif;
		endif;
	endif;
	
	self.btnFilterExport.value := false;		// PAR #23925
	theFilter.terminalAreaTypes.add(self.cmbQryTAType.listObject.CM_TerminalAreaType.type);	
	theFilter.setMyTerminalArea( self.cmbQryTermArea.listObject.CM_TerminalArea );
	theFilter.setMyLocationsController( self.cmbQryRow.listObject.CM_LocationsController );
	theFilter.setMyCargoType( self.cmbQryCargoType.listObject.CM_CargoType );
	theFilter.setMyProduct( self.cmbQryProduct.listObject.CM_Product );
	theFilter.myOperator := self.cmbQryOperator.listObject.CM_Operator;
	theFilter.setMyVoyage( self.cmbQryVoyage.listObject.CM_Voyage );
	theFilter.setMyShippingLine( self.cmbShippingLine.listObject.CM_ShippingLine ); 	// 23.05.2022 navak20 TFS 53204
	theFilter.setCountryOfOrigin(self.cmbCountryOfOrigin.listObject.CM_Country);		// 19.08.2022 navak20 TFS 54441
	
	//When checking the repack area, we only want to show the containers that are in that area.  The user can then only select
	//containers designated for repacking.  
	isForRepack := (theFilter.terminalAreaTypes[1] = TA_TYPE_CONT_PACK_REPACK).Boolean;

	self.isUsedForRepack := isForRepack;
	self.btnRepack.visible := isForRepack;
	self.btnPack.visible := (not isForRepack);
	self.btnUnpack.visible := (not isForRepack);
	
	if isForRepack then
		if self.myTI &lt;&gt; null then
			containerID := self.myTI.id;
		endif;
		self.myAssistant.comboBoxTrackedItemForRepack(self.cmbTrackedItem, self.myTerminal, containerID); 
	else
		if self.previousTerminalArea = TA_TYPE_CONT_PACK_REPACK then
			self.myAssistant.comboBoxTrackedItemCmb(self.cmbTrackedItem, TI_CargoType_Container, TI_STATE_NORMAL, self.myTI);
		endif;
	endif;
	
	self.frmToolbar.positionToolbarControls();
	
	//if self.cmbQryDisPort.listObject &lt;&gt; null then
	if self.cmbQryDisPort.myObject &lt;&gt; null then
		//theFilter.dischargePort := self.cmbQryDisPort.listObject.CM_Port.code;
		theFilter.dischargePort := self.cmbQryDisPort.myObject.CM_Port.code;
	else
		 theFilter.dischargePort := null;
	endif;
	
	//if self.cmbQryDestPort.listObject &lt;&gt; null then
	if self.cmbQryDestPort.myObject &lt;&gt; null then
		//theFilter.destinationPort := self.cmbQryDestPort.listObject.CM_Port.code;
		theFilter.destinationPort := self.cmbQryDestPort.myObject.CM_Port.code;
	else
		theFilter.destinationPort := null;
	endif;
	theFilter.id := self.tblQuery.getValueByName(ETRow_Id).String;	
	
	// 17/02/2011 cnwar2 #27048
	theFilter.includeTranships := true;
	
	//go get the TIs
	// CCMS 1533
	self.allQryTis.clear();
	
	theFilter.filterObjects(self.allQryTis, app.myPassport);
	if self.allQryTis.isEmpty then
		return;
	endif;
	
	if theFilter.getMyLocationsController &lt;&gt; null then
		self.armNotesForObject(theFilter.getMyLocationsController);
	endif;
	
	// 37288 TFS 1199 optional filtering of to-be packed cargo
	if self.chbFilter.value then
		release := self.cmbBR.listObject.CM_BulkRelease;
	endif;
	// CCMS 1533
	foreach theTI in self.allQryTis do
		if theTI.myParent &lt;&gt; null then
			continue;
		endif;
		includeTI := true;
		if release &lt;&gt; null then				// 37288 TFS 1199 filtering of to-be packed cargo
			includeTI := false;
			foreach reserve in release.allReservePackingChildren do			// child details
				if not reserve.isKindOf( CM_ReserveSelection ) then
					continue;
				endif;
				if release.allTrackedItemsReleased.includes(theTI) then
					continue;
				endif;
				// if this cargo matches any reserve selection then it is a candidate for packing
				if theTI.testAgainstReserveSelection( reserve.CM_ReserveSelection, reason, true, null ) then
					includeTI := true;
					break;
				endif;
			endforeach;
		endif;
		if includeTI then
			self.addTblDataRow(null, theTI, self.tblUnpacked);
		endif;
	endforeach;
	
	self.resortDataTable(self.tblUnpacked);
	
	//self.resetMeasurementRows(self.tblContainer);																								// PAR #31155
	//self.loadMeasurementTypes(self.tblContainer, self.tblContainer.myEntTableDef.name, self.tblContainer.myEntTableDef.allEntTableRows, true);	// PAR #31155
	
	//self.tblUnpacked.leftColumn := 1;
	self.frmQuery.visible := false;
	self.previousTerminalArea := theFilter.terminalAreaTypes[1];
	
epilog

	self.mousePointer := Window.MousePointer_Default;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSelectExportBooking" id="fd9993b0-df7a-49d8-ab53-24871622232c">
        <updating/>
        <source>doSelectExportBooking(_ti : CM_TrackedItem) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06/08/2010	cnwdap1	Initial creation PAR #23925
*/
vars
	bookingSelectForm	: CMUI_SelectBookingRefForm;
	linkedBooking		: CM_BookingRef;
	selectedBooking		: CM_BookingRef;
	enteredBooking		: CM_BookingRef;

begin
	// display all export bookings associated with the stock booking on the ti
	if _ti.myBookingRefItem = null or _ti.myBookingRefItem.allLinkedExportBookings.isEmpty then
		app.msgBox(app.getErrorString1((NotLinkedToExpBook), _ti.id), "Invalid Cargo", MsgBox_OK_Only);				//+cnwml2 PAR25677
		return;
	endif;
	
	if _ti.myBookingRefItem.allLinkedExportBookings.size = 1 then
		selectedBooking := _ti.myBookingRefItem.allLinkedExportBookings.first;
	else
	
		create bookingSelectForm;
		foreach linkedBooking in _ti.myBookingRefItem.allLinkedExportBookings do
			bookingSelectForm.allBookingRefs.add(linkedBooking);
		endforeach;
		bookingSelectForm.txtDestination.visible := false;
		bookingSelectForm.lDestination.visible := false;
		
		bookingSelectForm.showModal();
		
		if bookingSelectForm.modalResult = ModalResultOK then
			selectedBooking := bookingSelectForm.myCurrentBookingRef;
		else
			selectedBooking := null;
		endif;
	endif;
	
	if selectedBooking &lt;&gt; null then
		enteredBooking := self.cmbBooking.listObject.CM_BookingRef;
		if enteredBooking &lt;&gt; null and enteredBooking &lt;&gt; selectedBooking then		//+cnwml2 PAR25677 CCMS MSL 1076
			app.msgBox(app.getErrorString3((CannotAssignExportBook), _ti.id, enteredBooking.bookingReference, selectedBooking.bookingReference), "Invalid Booking", MsgBox_OK_Only);
		else
			self.displayTableBooking(selectedBooking);
		endif;
	endif;
	
epilog
	delete bookingSelectForm;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="doShowExportBookings" id="718dc6b8-a7e6-4145-b897-b522b7dc4f39">
        <updating/>
        <source>doShowExportBookings() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/082010	cnwdap1	Initial creation PAR #23925 CCMS MES 1076
*/
vars
	terminal 	: CM_Terminal;
	booking 	: CM_BookingRef;
	idx			: Integer;
	count		: Integer;
	tooMany		: Boolean;
	msg : String;

begin
	terminal := self.myTerminal;
	self.cmbBooking.clear();
	foreach booking in terminal.allBookingRefsByRef do
		// only interested in active export bookings
		if booking.isStockBookingRef or booking.status.isOneOf(BOOKING_REF_CLOSED, BOOKING_REF_ARCHIVED) then
			continue;
		endif;
		
		//23 Jan 2014	NDL	Par 31853
		count := count + 1;
		if count &gt;= 31999 then
			tooMany := true;
			break;
		endif;
		
		//+cnwml2 PAR25679 MSL CCMS 1076
		// we will now show only all active export bookings 
		// that have linked stock bookings
		//if booking.allLinkedStockBookingItems.isEmpty then
		//	continue;
		//endif;
		idx := self.cmbBooking.addItem(booking.bookingReference);
		self.cmbBooking.itemObject[idx] := booking;
	endforeach;
	
	//23 Jan 2014	NDL	Par 31853
	if tooMany then
		msg := app.getErrorString(Not_activ_expor_booki_able_dis);
		app.createAlert( msg, true );
		app.msgBox( msg, app.getErrorString(Warning), MsgBox_OK_Only );
	endif;
	
epilog

end;</source>
    </JadeMethod>
