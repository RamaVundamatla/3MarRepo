    <JadeMethod name="formatFailureDetails" id="90ccdd87-2d89-45a5-bf9a-29be402cdfe4">
        <source>formatFailureDetails(_summary : String) : String;

/*

Purpose:			Formats the summary results so that no line is longer than 990 characters as
					CM_SmtpConnection::validateASCIIMessage only allows messages lines of 1000 characters

Parameters:			_summary	: Summary details		

Return Value:		Returns the summary with lines formatted with 990 characters or less


Date				Who		Reason
06 September 2011	cnwmh5	Initial creation
21/02/2017			cnwmh5	Fix issue where if no ' ' found then set pos2 to 990.
							Binary/Hex string with spaces in it
01/11/2024			navmd1	Fixed index out of bounds issue if linelength is exactly 990
*/

vars

	tmpString			: String;
	pos					: Integer;
	formattedSummary	: String;
	lineLength			: Integer;
	pos2				: Integer;
	string2				: String;
	length				: Integer;
	
begin
	
	// get the length of the summary
	length := _summary.length;
	//write length.String;
	
	pos := -1;		// 23/8/2012 - cnwmc5
	
	while true do
	
		pos := pos + 2;	
		//write pos.String;
		if pos &gt; length then
			break;
		endif;
		
		// get the details up until CrLf
		tmpString := _summary.scanUntil(CrLf, pos);
		//write pos.String &amp; Tab &amp; tmpString;
		if pos = 0 then
			formattedSummary := formattedSummary &amp; CrLf &amp; tmpString;
			break;
		endif;
	
		// get the length of the line read
		lineLength := tmpString.length;
		
		// process while lineLength is &gt;= 990
		while lineLength &gt; 990 do
		
			// get the 1st 990 characters and check for the 1st space reversed
			string2 := tmpString[1:990];
			pos2 := string2.reversePos(" ");
			if pos2 = 0 then						// 21/03/2017 cnwmh5
				pos2 := 990;
			endif;
			
			// string to return is from 1st character to 1st space reversed
			formattedSummary := formattedSummary &amp; CrLf &amp; tmpString[1:pos2];
			
			// set the temporary string to being pos of 1st space reversed (&lt;= 990) to end
			tmpString := Tab &amp; Tab &amp; tmpString[pos2+1:end];
		
			// get the lineLength
			lineLength := tmpString.length;
		
		endwhile;
		
		// either lineLength &lt; 990 or &gt; 990 and something left over
		formattedSummary := formattedSummary &amp; CrLf &amp; tmpString;
		
	endwhile;
	
	return formattedSummary;

epilog

end;</source>
        <Parameter name="_summary" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
