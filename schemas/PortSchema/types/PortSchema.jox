    <JadeMethod name="handlePrecisionError" id="b3b81006-da6d-48c7-8777-0b4a7b1e64cf">
        <source>handlePrecisionError(_exception : Exception; _precisionError : Boolean io) : Integer;
// --------------------------------------------------------------------------------
// Created:		31 Mar 2014	cnwrs1	Par 33805
//
// Purpose:		Handle Precision errors gracefully
// 18/10/2017	TFS #7378 :MSL - SQL
// 06/05/2024	jlika1	TFS 63742 CUX - 14075   Too many digits in text of numeric TextBox or JadeEditMask
vars
	returnVal : Integer;
begin
	returnVal := Ex_Pass_Back;
	if _exception.errorCode = 4033 or _exception.errorCode =1406 or _exception.errorCode = 14075  then  //18.10.2017 cnwma1 TFS #7378 then
		_precisionError := true;
		if _exception.resumable then
			returnVal := Ex_Resume_Next;
		endif;
	endif;
	return returnVal;
end;</source>
        <Parameter name="_exception" type="Exception"/>
        <Parameter name="_precisionError" type="Boolean" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleRefreshErrors" id="51314ff1-e035-439a-a822-552ae303d4eb">
        <updating/>
        <source>handleRefreshErrors(_exObj: Exception; _exOccurred: Boolean output) : Integer updating;
/*

Purpose:			Log, but ignore all errors in setting refresh parameters during startup

Parameters:			

Return Value:		


Date			Who		Reason
29 May 2019		jlgmd1	Initial creation TFS 42569
// 11 Jul 2019	jlgrs1	TFS45051 JMT terminate on a SDS secondary exception ie a takeover has happened.
*/
vars
	retVal : Integer;
	msg : String;
begin
	if _exObj.errorCode = 1228 or 
	   _exObj.errorCode = 1295 or 
	   _exObj.errorCode = 3015 or 
	   _exObj.errorCode = 3037 then
		abortTransaction;
		abortTransientTransaction;
		msg := class.name&amp;'::'&amp;method.name&amp;' SDS Exception, cant continue,'&amp;_exObj.errorCode.String&amp;' '&amp;_exObj.extendedErrorText&amp;' processApp= '&amp;process.persistentApp.name&amp;' '&amp;process.userInfo&amp;' ('&amp;process.node.String&amp;", "&amp;process.String&amp;')';
		app.writeLog(msg, LogFATAL);	//26 Nov 2019	NDL	TFS 47053
		terminate;
	endif;

	_exOccurred := true;

	app.doDumpStack(_exObj);
	
	retVal := Ex_Abort_Action;
	if _exObj.resumable then
		retVal := Ex_Resume_Next;	// Go back to the method that armed us
	endif;
	
	return retVal;
epilog

end;</source>
        <Parameter name="_exObj" type="Exception"/>
        <Parameter name="_exOccurred" type="Boolean" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleRemoveFileException" id="56671863-14ce-4517-a10c-8c21c62be5d4">
        <source>handleRemoveFileException(_exc : FileException;
						  _fileName : String;
						  _exceptionOccurred : Boolean io) : Integer protected;

/*

Purpose:			Handle file exceptions during an attempt to remove files

Parameters:			Exception, filename

Return Value:		Exception return code, _exceptionOccurred updated


Date		Who		Reason
19 Jan 2009	cnwkpd1	PAR #17554 - Development of new RIA Web Service application

*/

vars
	returnVal		: Integer;
	msg				: String;
	
begin
	returnVal := Ex_Pass_Back;

	msg := _exc.class.name &amp; " " &amp; _exc.errorCode.String &amp; " deleting " &amp; _fileName &amp; ", returning Ex_Resume_Next";
	app.writeLog(msg, LogERROR);	//26 Nov 2019	NDL	TFS 47053

	_exceptionOccurred := true;
	returnVal := Ex_Resume_Next;
		

epilog
	return returnVal;
	
end;</source>
        <access>protected</access>
        <Parameter name="_exc" type="FileException"/>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_exceptionOccurred" type="Boolean" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleTransactionMapError" id="2408ada2-6a8f-48b2-86b6-22054f014877">
        <source>handleTransactionMapError(_exc : CM_Exception; _excOccurred : Boolean io) : Integer;
/*

Purpose:			Handle specific Transaction Map configuration errors by ignoring them. To be used in
					situations where system functionality relies on these being ignored.

Parameters:			

Return Value:		

Date		Who		Reason
30 Nov 2017	jlgkpd1	Initial creation - TFS 7995 - Logon Event charge creation issue

*/

vars

begin
	if _exc.errorCode = ERR_TRANSACTION_MAP or
	   _exc.errorCode = Input_required_field_EvtInvBnk or
	   _exc.errorCode = Input_required_field_evtInvNCT then
		_excOccurred := true;
		app.writeLog(method.qualifiedName &amp; " errorCode=" &amp; _exc.errorCode.String, LogERROR);	//26 Nov 2019	NDL	TFS 47053
		return Ex_Resume_Next;
	endif;
	
	return Ex_Pass_Back;

epilog

end;</source>
        <Parameter name="_exc" type="CM_Exception"/>
        <Parameter name="_excOccurred" type="Boolean" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleUE14025" id="718dad51-92a2-4ab6-98fc-c09d56214b5d">
        <source>handleUE14025(_exc : Exception; _reachedMaxSize : Boolean output): Integer;
/* ---------------------------------------------------------------------------
Created:	26 January 2011	by cnwvu1

Purpose:	PAR 26289. Handles the exception, when the number of items has reached max allowable size (32000)
			alowable for a table or combobox.
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	returnVal		: Integer;

begin

	returnVal := Ex_Pass_Back;

	if _exc.errorCode = 14025 then
		_reachedMaxSize := true;
		if _exc.resumable then
			returnVal := Ex_Resume_Next;
		endif;
	endif;

epilog
	return returnVal;

end;</source>
        <Parameter name="_exc" type="Exception"/>
        <Parameter name="_reachedMaxSize" type="Boolean" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleUE14051" id="fa198db9-266d-45de-b3a1-b6cb6ca45228">
        <updating/>
        <source>handleUE14051(_exObj: Exception; _exOccurred : Boolean output ): Integer updating;
/*

Date		Who		Reason
15 September 2016	cnwer1	Initial creation TFS 2606

*/

vars

begin
	if _exObj.errorCode = 14051 then
		_exOccurred := true;
		abortTransaction;
		abortTransientTransaction;
		if _exObj.resumable then
			return Ex_Resume_Next;
		else
			return Ex_Abort_Action;
		endif;
	endif;
	return Ex_Pass_Back;
epilog

end;</source>
        <Parameter name="_exObj" type="Exception"/>
        <Parameter name="_exOccurred" type="Boolean" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="hasAcknowledgedTIConnectError" id="cc22fc1a-ad6a-4a40-9a35-87c51a24bd4d">
        <source>hasAcknowledgedTIConnectError() : Boolean;
/*

Date		Who		Reason
14 May 2015	cnwer1	Initial creation PAR
31 Mar 2020 cnwma1  Bug 48757: SNO - Power disconnection
*/

vars

begin
	if app.myPassport.errorsToIgnore.includes(MACH_LIFT_POWER) then  //31.03.2020 cnwma1 #48757
		return true;
