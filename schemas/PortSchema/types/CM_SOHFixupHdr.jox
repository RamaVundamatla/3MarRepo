<Class name="CM_SOHFixupHdr" id="97dd6a2c-110d-453d-af1c-56c81b0ae395">
    <superclass name="CM_Object"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="terminal"/>
    <ExplicitInverseRef name="allSOHTransactions" id="1b27e748-1964-4c75-bca3-a76ccd313330">
        <updateMode>automatic</updateMode>
        <type name="CM_SOHTransactionSet"/>
        <access>readonly</access>
        <Inverse name="CM_SOHFixup::mySOHFixupHdr"/>
    </ExplicitInverseRef>
    <PrimAttribute name="dateTime" id="e0857ec6-cb23-4cae-a479-3c70b3039afd">
        <embedded/>
        <type name="TimeStamp"/>
        <access>readonly</access>
    </PrimAttribute>
    <ExplicitInverseRef name="myTerminal" id="f5f332e6-65f5-4f79-9325-a59e9f8fe5f7">
        <kind>child</kind>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_Terminal"/>
        <access>readonly</access>
        <Inverse name="CM_Terminal::allSOHFixups"/>
    </ExplicitInverseRef>
    <PrimAttribute name="userCode" id="e82261f6-715f-490d-af9f-2ad3e7de97d8">
        <length>11</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="init" id="4a5c736b-d2ab-42ad-9268-279eb633a7b1">
        <updating/>
        <source>init(_userCode : String; _terminal : CM_Terminal) updating;
// ---------------------------------------------------------------------------
// Created:     14 January 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.dateTime	:= app.serverTimestampAtTrxStart;
	self.userCode	:= _userCode;
	
	self.myTerminal	:= _terminal;

end;</source>
        <Parameter name="_userCode" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
</Class>
