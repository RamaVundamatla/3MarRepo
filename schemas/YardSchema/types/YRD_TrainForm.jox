    <JadeMethod name="btnWarnings_click" id="90d3c5c7-9381-4fee-92c9-8165d26738c2">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnWarnings_click(btn: Button input) updating;
/* ---------------------------------------------------------------------------
Created:     18 February 2010 by cnwrs2

Purpose:     
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	if self.mySelectedTrain = null then
		self.btnWarnings.value := false;
	elseif (not btn.value) then
		self.hideTableWarnings();
		self.resize();
	else
		//self.isWarningsVisible := true;
		if self.getWarnings(self.mySelectedTrain) then
			self.displayWarnings();
			self.resize();
		else
			// set the button to the "up" position
			app.msgBox(app.getErrorString1(NoWarn_errs_for_train, ' ' &amp; self.mySelectedTrain.code), app.getErrorString(Info), MsgBox_OK_Only + MsgBox_Information_Icon);
			self.btnWarnings.value := false;
		endif;
	endif;
	
	self.isWarningsVisible := self.btnWarnings.value;

epilog

end;</source>
