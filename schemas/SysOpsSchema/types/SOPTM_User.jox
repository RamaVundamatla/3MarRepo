    <JadeMethod name="createNewEmailForUser" id="b705ab4a-f32c-4dd7-96c2-849f422ae1cc">
        <source>createNewEmailForUser(_title, _email: String): CM_EmailEntity;
//----------------------------------------------------------------
//	Created:	02 March 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	errObj					: CM_Error;
	ignoreWarnings,rtnValue	: Boolean;
	newEmailAddress,
	proxyEmailAddress		: CM_EmailAddress2;
	lEmailAddress, lTitle	: String; 
begin

	lEmailAddress := _email.trimWhiteSpace;
	if lEmailAddress = null then
		return null;
	endif;
	
	lTitle := _title.trimWhiteSpace;
	if lTitle = null then
		lTitle := lEmailAddress;
	endif;

 	create proxyEmailAddress transient;
	
	proxyEmailAddress.setProxyForEmailAddress(lTitle, lEmailAddress, null);

	app.myTrxCA.trxCreateEmailAddress2(proxyEmailAddress, newEmailAddress,app.myPassport);
	
	return newEmailAddress;

end;</source>
        <Parameter name="_title" type="String"/>
        <Parameter name="_email" type="String"/>
        <ReturnType type="CM_EmailEntity"/>
    </JadeMethod>
