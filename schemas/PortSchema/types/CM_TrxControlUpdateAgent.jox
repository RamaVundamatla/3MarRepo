    <JadeMethod name="trxProcessEDIVoyageConsist" id="aeffae3f-8d51-4b1d-a6fb-bd55d8a1dc93">
        <updating/>
        <source>trxProcessEDIVoyageConsist(_cmifVoyageConsist : CMIF_VoyageConsist io; _validateOnly : Boolean; _passport : CM_Passport input) updating;
//
// cnwrs1 Jan 2010 CCMS 1008 1006 Messina Ship Mainfest
//
// 06/08/2012	cnwcs5	par 30136 - EDI BGP Split
//14 Feb 2013	cnwrs1	Par 31143 EDI TRX not handling dbLoadErrors after no verify errors
//04 Aug 2014	cnwrs1	Par 34668	EDI Status can be wrong if doDeferredUpdate fails
//03 Nov 2022	jlika1	TFS 54892  POB - Vessel, Voyage and Movement EDI Messages
//06 Sep 2023	jlika1	TFS 59855	59168 - 55715.050 Update of Vessel Details
//29 Jan 2025	navcs2	MTN-33798	NSW | OnePort - Vessel Default Trade Lost When Voyage Updated

vars
	prxyVoyage, 
	realVoyage 				: CM_Voyage;
	obj 					: Object;
	realVessel 				: CM_Vessel;
	hasStructure, 
	includeStructure 		: Boolean;
	conflictManager 		: CMIF_HMS_ConflictsManager;
	tmpGlobalVoyage 		: CM_VoyageGlobal;
	status 					: Integer;
	ediData					: CM_EDIData;		// par 30136 Aug 2012
	prxyVessel				: CM_Vessel;	
	updVessel				: CM_Vessel;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	if _validateOnly then
		app.setContinueCMExceptions(true);
	else
		app.setContinueCMExceptions(false);
	endif;
	
	beginTransaction;
	
	_passport.useTIDictDeferUpdate 			:= true;
	_passport.useTITransactionDeferUpdate 	:= true;
	
	//MTN-33536 - process the vessel first before the voyages
	foreach obj in _cmifVoyageConsist.allUpdPrxyVessels do
		prxyVessel := obj.CM_Vessel;
		realVessel 		:= app.myRoot.getVesselByName(prxyVessel.name);							//29 Jan 2025	navcs2	MTN-33798
		if realVessel &lt;&gt; null and realVessel.myDefaultTrade &lt;&gt; null then						//29 Jan 2025	navcs2	MTN-33798
			prxyVessel.setMyDefaultTrade(realVessel.myDefaultTrade);							//29 Jan 2025	navcs2	MTN-33798
		endif;
		app.myUtilityUA.utlUpdateVessel(prxyVessel, false, false, conflictManager, _passport); 
	endforeach;
	
	foreach obj in _cmifVoyageConsist.allAddPrxyVoyages do
		prxyVoyage 		:= obj.CM_Voyage;
		realVessel 		:= app.myRoot.getVesselByName(prxyVoyage.vesselName);
		tmpGlobalVoyage := app.myRoot.allVoyagesGlobal[prxyVoyage.code];
		
		if realVessel = null then
			prxyVessel := _cmifVoyageConsist.allVesselsByName[prxyVoyage.vesselName];
			app.myUtilityCA.utlCreateVessel(prxyVessel, realVessel, conflictManager, _passport);	
		endif;
		
		app.myUtilityCA.utlCreateVoyage(prxyVoyage, realVoyage, realVessel, tmpGlobalVoyage, true, _passport); //cnwrs1 10 Mar 2010
	endforeach;
	
	////MTN-33536 - Moved to before the voyage process
	//foreach obj in _cmifVoyageConsist.allUpdPrxyVessels do
	//	prxyVessel := obj.CM_Vessel;
	//		
	//	app.myUtilityUA.utlUpdateVessel(prxyVessel, false, false, conflictManager, _passport); 
	//endforeach;
	
	foreach obj in _cmifVoyageConsist.allUpdPrxyVoyages do
		prxyVoyage := obj.CM_Voyage;
		
		// cnwrl1 20/05/2010 PAR 24012 - start of coding
		// We do not want to delete the structure if it exists.
		hasStructure	:= prxyVoyage.myCellularVoyageStructure &lt;&gt; null;
	
		app.myUtilityUA.utlUpdateVoyage(hasStructure, includeStructure, prxyVoyage, conflictManager, false, _passport); //cnwrs1 10 mar 2010
	endforeach;
	
	foreach obj in _cmifVoyageConsist.allDelPrxyVoyages do
		realVoyage := obj.CM_Voyage;
		app.myUtilityDA.utlDeleteVoyage(realVoyage, _passport);
	endforeach;

	ediData := _cmifVoyageConsist.myEDIData;
	
	if _validateOnly and _passport.noErrors then
		// sucessful validate - abort then update status in new transaction
		// we need to abort here as it won't get done for us in self.finaliseActivityWithPassport
		app.cmsAbortTransaction();
		return;
	else
		if _passport.noErrors() then
			// sucessful DB Load so update status in same transaction
			_passport.doDeferredUpdates();
			if _passport.noErrors() then
				// use passport to get new status for EDI Data
				status := ediData.getStatusAfterVerifyOrDBLoad (_validateOnly, _passport);
				app.myUtilityUA.utlSetEDIDataStatusAfterVerify(ediData, status);
			endif;
		endif;
	endif;
epilog
	self.finaliseActivityWithPassport(_passport);

	if _validateOnly or _passport.hasErrors then
		// use passport to get new status for EDI Data
		status := ediData.getStatusAfterVerifyOrDBLoad (_validateOnly, _passport);
		app.myTrxUA.trxSetEDIDataStatusAfterVerify(ediData, status);	// par 27392 cnwrs1 14 Apr 2011
	endif;
end;</source>
        <Parameter name="_cmifVoyageConsist" type="CMIF_VoyageConsist" usage="io"/>
        <Parameter name="_validateOnly" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxProcessEDIVoyageConsistPart" id="97e9f38c-136d-4586-ab66-4136fde6e175">
        <updating/>
        <source>trxProcessEDIVoyageConsistPart(_cmifVoyageConsist : CMIF_VoyageConsist io; _validateOnly : Boolean; _existingErrors : CM_ErrorSet input; _passport : CM_Passport input) updating;
//
// Purpose:			Allows the partial processing of Voyage EDI files - if an individual voyage doesn't verify, then leave it 
//					and proceed to the next voyage to see if it will verify and DB Load. 
//					1. Get all the voyagesfor add / update
//					2. Sort them in to processing order (NSW and POB Voyage updates can also include Vessel adds/updates
//					   so we put the vessel add/update first, then the corresponding voyage add/update next
//					3. Do the updates, keeping track of which items succeed and fail, and updating the EDI TI status to reflect this
//					4. At the end, decide on the status for the EDI Data as a whole, base don the status of the EDI TIs
//					   - all successful - VERIFIED or DBLOADED (depnding on _validateOnly flag)
//					   - some successful, others failed - VERIFIED_ERRORS or DBLOADED_PARTIAL
//					   - all failed - VERIFIED_ERRORS or DBLOADED_PARTIAL
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 04/08/2025	navdap1		Initial creation MTN-35604 NSW - Load Partial Voyage EDI
// 18/09/2025	navdap1		MTN-36071 MTN - OnePort messages showing errors
//
constants
	Voyage_Code : String = "voyageCode";
	Arrival_Date_Time : String = "arrivalDateTime";
	My_Voyage : String = "myVoyage";
	My_Vessel : String = "myVessel";
	My_Mode : String = "mode";
	ObjType : String = "objType";
	
vars
	pxyVoyage, realVoyage : CM_Voyage;
	vessel, realVessel : CM_Vessel;
	dynaVoyage, newDynaVoyage: JadeDynamicObject;
	allData : DynaDictionary;
	obj, checkObj : Object;
	ediData : CM_EDIData;
	status : Integer;
	currentVoyageCode : String;
	allVoyages : ObjectArray;
	conflictMgr : CMIF_HMS_ConflictsManager;
	errorSet : CM_ErrorSet;
	globalVoyage : CM_VoyageGlobal;
	failedVoyages, successfulVoyages : StringArray;
	vessels : ObjectSet;

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(true);
	if not _validateOnly then
		_passport.setWarningsAcknowledged(true);
		_passport.setWarningsIgnored(true);
	endif;
	
	ediData := _cmifVoyageConsist.myEDIData;
	create failedVoyages transient;
	create successfulVoyages transient;
	
	// Create a dyna dictionary to sort dynamic objects into the correct order (for an individual voyage, 
	// any vessel update needs to be done before the voyage add / update)
	create allData transient;
	allData.setMembership(Object);
	allData.addExternalKey(String, 20, false, true);		// voyage code
	allData.addExternalKey(Integer, 4, false, false);		// type - 1 is vessel, 2 is voyage, 3 is movement
	allData.addExternalKey(TimeStamp, 20, false, true);		// arrival date (null for vessel)
	allData.endKeys(true);
	
	// Create a template dynamic object
	create dynaVoyage transient;
	dynaVoyage.addProperty(Voyage_Code, String);
	dynaVoyage.addProperty(ObjType, Integer);				// 1 is vessel, 2 is voyage, 3 is movement
	dynaVoyage.addProperty(Arrival_Date_Time, TimeStamp);
	dynaVoyage.addProperty(My_Voyage, Object);
	dynaVoyage.addProperty(My_Vessel, Object);
	dynaVoyage.addProperty(My_Mode, String);
	
	// Get all the voyages that we're updating / adding
	create allVoyages transient;
	_cmifVoyageConsist.allAddPrxyVoyages.copy(allVoyages);
	_cmifVoyageConsist.allUpdPrxyVoyages.copy(allVoyages);
	
	// Build a collection of temporary objects
	// NSW and POB processing have vessel proxies and voyage proxies.
	// Other standard voyage consist processing has just voyage proxies.
	// If we have vessel proxies, we group the objects for a voyage into the CM_Vessel proxy first, then the CM_Voyage proxy
	// The CM_Voyage proxy already has movements, ports of rotation and any cutoffs set on it.
	// Process the voyages
	foreach obj in allVoyages do
		pxyVoyage := obj.CM_Voyage;
		
		// Do we have a matching vessel proxy for this voyage?
		foreach checkObj in _cmifVoyageConsist.allUpdPrxyVessels do
			vessel := checkObj.CM_Vessel;
			if vessel.code = pxyVoyage.vesselCode then
				// Yes we have a match - create a dynamic object for the vessel
				newDynaVoyage := dynaVoyage.cloneSelf(true);
				// Set the properties for the vessel 
				newDynaVoyage.setPropertyValue(Voyage_Code, pxyVoyage.code);
				newDynaVoyage.setPropertyValue(ObjType, 1);
				newDynaVoyage.setPropertyValue(Arrival_Date_Time, pxyVoyage.arrivedDT);
				newDynaVoyage.setPropertyValue(My_Voyage, null);
				newDynaVoyage.setPropertyValue(My_Vessel, vessel);
				newDynaVoyage.setPropertyValue(My_Mode, "U");
				// Add it to our dynamic dictionary
				allData.putAtKey(	newDynaVoyage.getPropertyValue(Voyage_Code), 
									newDynaVoyage.getPropertyValue(ObjType), 
									newDynaVoyage.getPropertyValue(Arrival_Date_Time), 
									newDynaVoyage	);
				break;
			endif;
		endforeach;
		
		// Now the voyage details
		newDynaVoyage := dynaVoyage.cloneSelf(true);
		// Set the properties for the voyage 
		newDynaVoyage.setPropertyValue(Voyage_Code, pxyVoyage.code);
		newDynaVoyage.setPropertyValue(ObjType, 2);
		newDynaVoyage.setPropertyValue(Arrival_Date_Time, pxyVoyage.arrivedDT);
		newDynaVoyage.setPropertyValue(My_Voyage, pxyVoyage);
		newDynaVoyage.setPropertyValue(My_Vessel, null);
		//if _cmifVoyageConsist.allUpdPrxyVessels.includes(pxyVoyage) then	// MTN-36071
		if _cmifVoyageConsist.allUpdPrxyVoyages.includes(pxyVoyage) then	// MTN-36071 Helps if you check the correct collection
			newDynaVoyage.setPropertyValue(My_Mode, "U");
		else
			newDynaVoyage.setPropertyValue(My_Mode, "A");
		endif;
		
		// Add it to our dynamic dictionary
		allData.putAtKey(	newDynaVoyage.getPropertyValue(Voyage_Code), 
							newDynaVoyage.getPropertyValue(ObjType), 
							newDynaVoyage.getPropertyValue(Arrival_Date_Time), 
							newDynaVoyage	);
	endforeach;
	
	// For NSW and POB, every vessel in _cmifVoyageConsist.allUpdPrxyVessels will have a matching entry
	// from the vessel associated with a allUpdPrxyVoyages or allAddPrxyVoyages voyage
	// For other clients this will be empty, as you can't create vessels through a normal Voyage Consist
	
	// Now we have the vessels and voyages in the right order, we can start doing some work
	create errorSet transient;
	beginTransaction;
	
	foreach obj in allData do
		// Vessel Update
		if obj.getPropertyValue(ObjType).Integer = 1 then	// this is a vessel update / create
			currentVoyageCode := obj.getPropertyValue(Voyage_Code).String;
			vessel := obj.getPropertyValue(My_Vessel).CM_Vessel;
			
			// MTN-36071 We don't want to stop for warnings, just do the updates
			_passport.setWarningsIgnored(true);
			_passport.setWarningsAcknowledged(true);
			app.myUtilityUA.utlUpdateVessel(vessel, false, false, conflictMgr, _passport);
			if _passport.hasErrors then
				// No good trying to update the voyage - continue
				failedVoyages.tryAdd(currentVoyageCode);
				create vessels transient;
				realVessel := app.myProxyManager.getRealObject(vessel).CM_Vessel;
				vessels.add(realVessel);
				app.myProxyManager.updateProxyEditions(vessels);
				delete vessels;
				continue;
			endif;
			create vessels transient;
			realVessel := app.myProxyManager.getRealObject(vessel).CM_Vessel;
			vessels.add(realVessel);
			app.myProxyManager.updateProxyEditions(vessels);
			delete vessels;
			
		elseif obj.getPropertyValue(ObjType).Integer = 2 then	// this is a voyage update / create
			// Did we have a vessel update not work? Just ignore me then
			if currentVoyageCode = obj.getPropertyValue(Voyage_Code).String and _passport.hasErrors then
				continue;
			endif;
			
			pxyVoyage := obj.getPropertyValue(My_Voyage).CM_Voyage;
			currentVoyageCode := pxyVoyage.code;
			vessel := app.myRoot.getVesselByName(pxyVoyage.vesselName);
			globalVoyage := app.myRoot.allVoyagesGlobal[pxyVoyage.code];
			
			// MTN-36071 We don't want to stop for warnings, just do the updates
			_passport.setWarningsIgnored(true);
			_passport.setWarningsAcknowledged(true);
			if obj.getPropertyValue(My_Mode).String = "A" then
				app.myUtilityCA.utlCreateVoyage(pxyVoyage, realVoyage, vessel, globalVoyage, true, _passport);
			else
				app.myUtilityUA.utlUpdateVoyage(pxyVoyage.myCellularVoyageStructure &lt;&gt; null, false, pxyVoyage, conflictMgr, false, _passport);
			endif;
			
			if _passport.noErrors then
				// Update the EDI TIs related to this voyage and vessel
				successfulVoyages.tryAdd(currentVoyageCode);
			else
				failedVoyages.tryAdd(currentVoyageCode);
			endif;
		endif;
		
		_passport.moveErrorsToSet(errorSet);
	endforeach;
	
	_passport.addErrorsFromSet(errorSet);
	_passport.addErrorsFromSet(_existingErrors);
	
	if _validateOnly then
		// sucessful validate - abort then update status in new transaction
		// we need to abort here as it won't get done for us in self.finaliseActivityWithPassport
		app.cmsAbortTransaction();
		return;
	else
		if _passport.noErrors() then
			// sucessful DB Load so update status in same transaction
			_passport.doDeferredUpdates();
			if _passport.noErrors() then
				app.myUtilityUA.utlUpdatePartialVoyagEDIStatus(ediData.CM_EDIDataVoyage, _validateOnly, failedVoyages, successfulVoyages, errorSet, _passport);
				// use passport to get new status for EDI Data
				status := ediData.getStatusAfterVerifyOrDBLoad (_validateOnly, _passport);
				app.myUtilityUA.utlSetEDIDataStatusAfterVerify(ediData, status);
			endif;
		endif;
	endif;
	
	// If we got this far, and we've successfully created a voyage, we need to fool the passport
	// into thinking everything's fine
	errorSet.clear;
	if not successfulVoyages.isEmpty() then
		_passport.moveErrorsToSet(errorSet);
	endif;
	
epilog
	self.finaliseActivityWithPassport(_passport);
	
	// Put the errors we hid away back on the passport so the statuses get updated correctly
	if not errorSet.isEmpty() then
		_passport.addErrorsFromSet(errorSet);
	endif;
	
	if _validateOnly or _passport.hasErrors then
		errorSet.clear;
		_passport.moveErrorsToSet(errorSet);
		app.myTrxUA.trxUpdatePartialVoyagEDIStatus(ediData.CM_EDIDataVoyage, _validateOnly, failedVoyages, successfulVoyages, errorSet, _passport);
		_passport.addErrorsFromSet(errorSet);
		// use passport to get new status for EDI Data
		status := ediData.getStatusAfterVerifyOrDBLoad (_validateOnly, _passport);
		app.myTrxUA.trxSetEDIDataStatusAfterVerify(ediData, status);	// par 27392 cnwrs1 14 Apr 2011
	endif;
	
	if allData &lt;&gt; null then
		allData.purge;
	endif;
	delete allData;
	delete dynaVoyage;
	delete allVoyages;
	delete errorSet;
	delete failedVoyages;
	delete successfulVoyages;
	delete vessels;
end;
</source>
        <Parameter name="_cmifVoyageConsist" type="CMIF_VoyageConsist" usage="io"/>
        <Parameter name="_validateOnly" type="Boolean"/>
        <Parameter name="_existingErrors" type="CM_ErrorSet" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxProcessEDIWagon" id="291c2e0c-8149-45f7-b261-d180128b3359">
        <updating/>
        <source>trxProcessEDIWagon(_ediData :CM_EDIDataWagon input; _validateOnly : Boolean; _passport : CM_Passport input) updating;
/* Changes

Date		Name	TFS#		Description
============================================================================
14 Feb 2013	cnwrs1	Par 31143 	EDI TRX not handling dbLoadErrors after no verify errors take 4
04 Aug 2014	cnwrs1	Par 34668	EDI Status can be wrong if doDeferredUpdate fails
16 May 2016	cnwns1	TFS 488 	Multi Timezone Support
03 Sep 2019 jlgka1 	TFS 45332 	STWR - Better Forms and Interfaces for EDI Module
20 Oct 2020	jlgmd1	TFS 50204	Refactor progress updates to superclass method
============================================================================*/

vars
	partsDone 		 : Integer;
	partsInJob 		 : Integer;
	progressStr 	 : String;
	progressTS 		 : TimeStamp;
	ediTI 			 : CM_EDITrackedItem;
	terminal 		 : CM_Terminal;			//jlgka1 TFS 45332
	status 			 : Integer;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	if _validateOnly then
		app.setContinueCMExceptions(true);
	else
		app.setContinueCMExceptions(false);
	endif;

	beginTransaction;
	
	_passport.useTITransactionDeferUpdate := false; 
	_passport.useTIDictDeferUpdate := false;
//utl
	
	partsInJob	:= _ediData.allEDITrackedItems.size();
	partsDone	:= null;
	terminal	:= _ediData.getMyTerminal();			//jlgka1 TFS 45332
	
	progressStr	:= app.getString(Loading_EDI_Data_Total, partsInJob.display);
	progressTS	:= app.actualTimeServer();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	_ediData.updateProgress(progressTS, progressStr, partsInJob, partsDone, true, _passport);
	
	foreach ediTI in _ediData.allEDITrackedItems do
		partsDone := partsDone + 1;
		_ediData.updateProgress(progressTS, progressStr, partsInJob, partsDone, false, _passport);
		
		_ediData.zLoadDB(ediTI.CM_EDIWagonTI, terminal, _passport);  
		
	endforeach;
	
	_ediData.updateProgress(progressTS, progressStr, partsInJob, partsDone, true, _passport);

	if _validateOnly and _passport.noErrors then
		// sucessful validate - abort then update status in new transaction
		// we need to abort here as it won't get done for us in self.finaliseActivityWithPassport
		app.cmsAbortTransaction();
		return;
	else
		if _passport.noErrors() then
			// sucessful DB Load so update status in same transaction
			_passport.doDeferredUpdates();
			if _passport.noErrors() then
				// use passport to get new status for EDI Data
				status := _ediData.getStatusAfterVerifyOrDBLoad (_validateOnly, _passport);
				app.myUtilityUA.utlSetEDIDataStatusAfterVerify(_ediData, status);
			endif;
		endif;
	endif;
epilog
	self.finaliseActivityWithPassport(_passport);

	if _validateOnly or _passport.hasErrors then
		// use passport to get new status for EDI Data
		status := _ediData.getStatusAfterVerifyOrDBLoad (_validateOnly, _passport);
		app.myTrxUA.trxSetEDIDataStatusAfterVerify(_ediData, status);	// par 27392 cnwrs1 14 Apr 2011
	endif;
end;</source>
        <Parameter name="_ediData" type="CM_EDIDataWagon" usage="input"/>
        <Parameter name="_validateOnly" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxProcessEventReqStops" id="308030c4-a077-45e6-990a-4244e9f538f2">
        <updating/>
        <source>trxProcessEventReqStops(_terminal :CM_Terminal; _ti :CM_TrackedItem input; _passport :CM_Passport input)updating;
// ---------------------------------------------------------------------------
// Created:     13 December 2010 by cnwcs5 ccms mes 1112 / par 24464
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 22/06/2011	cnwcs5	par 27167 - renamed method (was trxProcessEventReqStopsPreNote)
//								  - changed _terminal parameter usage
// 06 Oct 2025 	navhl20 Bug MTN-36085: MTN | Dead Lock (1081) on CM_TITransactionByTypeDateDict
// ---------------------------------------------------------------------------
begin
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	if _passport.myStateChangeController &lt;&gt; null then
		_passport.myStateChangeController.initForObject(_ti); //jlier1 TFS 61676 14/12/23 
	endif;
	
	_passport.useTITransactionDeferUpdate := true; 				//06.10.2025 navhl20 #36085
	_passport.useTIDictDeferUpdate := true;						//06.10.2025 navhl20 #36085
	
	beginTransaction;

	app.setContinueCMExceptions(true);
	_terminal.actionEventRequestStops (_ti, _passport);
	
	if _passport.noErrors then									//06.10.2025 navhl20 #36085
		_passport.doDeferredUpdates();
	endif;
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxProcessStopsEDIOnShip" id="301815f8-680a-45cb-9e57-fbbd4b107128">
        <updating/>
        <source>trxProcessStopsEDIOnShip(_voyage: CM_Voyage input; _passport: CM_Passport input) updating;
//----------------------------------------------------------------
//	Created:	15 February 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 21/06/0211	cnwcs5	par 27167 - remove code to process stop requests in this method
vars

begin

	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	beginTransaction;

	if not _passport.myUser.canDo(_passport.myTerminal, PmShipProcessEDI) then
		app.raiseCMException1(NoPermission, 'perform this task', null, null);
		return;
	endif;

	if _voyage = null then
		return;
	endif;
	
	app.setContinueCMExceptions(true);
	// setup BGP to process stops for this voyage
	_voyage.processStopsEDIOnShip(_passport);
	// this method used to process stop requests but now this is done in the BGP
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxProcessUSCustomsStops" id="daa0e11f-5682-42c6-b5e4-f40544ab8072">
        <updating/>
        <source>trxProcessUSCustomsStops(_ediData :CM_EDIDataUSCustomsMessage input; _validateOnly : Boolean; _passport : CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 November 2019	jlgns1	Initial creation
6/11/2019	JLGNS1	ChangeRequest 46721: PEN - CAMIR Message Processing
20/10/2020	jlgmd1	TFS 50204	Refactor progress updates to superclass method
*/
vars
	partsDone : Integer;
	partsInJob : Integer;
	progressStr : String;
	progressTS : TimeStamp;
	ediTI : CM_EDITrackedItem;
	status : Integer;
	ediUSCustomsMessageTI :	CM_EDIUSCustomsMessageTI;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	if _validateOnly then
		app.setContinueCMExceptions(true);
	else
		app.setContinueCMExceptions(false);
	endif;

	beginTransaction;
	
	_passport.useTITransactionDeferUpdate := false; 
	_passport.useTIDictDeferUpdate := false;
//utl
	partsInJob	:= _ediData.allEDITrackedItems.size();
	partsDone	:= null;
	
	progressStr	:= app.getString(Loading_EDI_Data_Total, partsInJob.display);
	progressTS	:= app.actualTimeServer();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	_ediData.updateProgress(progressTS, progressStr, partsInJob, partsDone, true, _passport);
	
	foreach ediTI in _ediData.allEDITrackedItems do
		partsDone := partsDone + 1;
		_ediData.updateProgress(progressTS, progressStr, partsInJob, partsDone, false, _passport);
		
		ediUSCustomsMessageTI := ediTI.CM_EDIUSCustomsMessageTI;
		if ediUSCustomsMessageTI.id &lt;&gt; null then
			_ediData.zLoadDBcont(ediTI.CM_EDIUSCustomsMessageTI, _passport);
		endif;
	endforeach;
	
	_ediData.updateProgress(progressTS, progressStr, partsInJob, partsDone, true, _passport);
	
	if _validateOnly and _passport.noErrors then
		// sucessful validate - abort then update status in new transaction
		// we need to abort here as it won't get done for us in self.finaliseActivityWithPassport
		app.cmsAbortTransaction();
		return;
	else
		if _passport.noErrors() then
			// sucessful DB Load so update status in same transaction
			_passport.doDeferredUpdates();
			if _passport.noErrors() then
				// use passport to get new status for EDI Data
				status := _ediData.getStatusAfterVerifyOrDBLoad (_validateOnly, _passport);
				app.myUtilityUA.utlSetEDIDataStatusAfterVerify(_ediData, status);
			endif;
		endif;
	endif;
epilog
	self.finaliseActivityWithPassport(_passport);

	if _validateOnly or _passport.hasErrors then
		// use passport to get new status for EDI Data
		status := _ediData.getStatusAfterVerifyOrDBLoad (_validateOnly, _passport);
		app.myTrxUA.trxSetEDIDataStatusAfterVerify(_ediData, status);	// par 27392 cnwrs1 14 Apr 2011
	endif;
end;</source>
