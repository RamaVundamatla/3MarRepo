/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 Nov 2024 navlc30 JIRA 33242 EUP | Kiosk - Default Additional question shown with incorrect subtype and commodity

*/

vars

begin
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="match" id="ed7e3219-364e-4b9b-9f51-8cc424235b41">
        <source>match(_criteria: CM_YACriteria): Boolean;
//30 January 2009	cnwdw1	
// Retunr true if the criteria are the same
vars

begin
	return self.myYAData.getYAIdentifier = _criteria.myYAData.getYAIdentifier;
end;</source>
        <Parameter name="_criteria" type="CM_YACriteria"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="f98972d4-23e3-4107-af75-1e6e4829bfb3">
        <source>pxyCreateUpdateProxy(): SelfType;
// --------------------------------------------------------------------------------
// Created:		23 March 2005 by cnwdad1
//
// Purpose:		Deep clone the receiver.
//
// Parameters:	None
//
// Returns:		A reference to a transient clone of the receiver.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// --------------------------------------------------------------------------------
vars
	proxyObj		: SelfType;
	proxyDataObj	: CM_YAData;
	completedOK		: Boolean;
	
begin
	proxyObj	:=	inheritMethod();
	
	proxyObj.myYACriteriaType	:=	self.myYACriteriaType;
	
	if self.myYAData &lt;&gt; null then
		proxyDataObj		:=	self.myYAData.pxyCreateUpdateProxy();
		proxyObj.myYAData	:=	proxyDataObj;
	endif;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyObj;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyObj;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="resolveIntendedRelModePattern" id="755d4c1a-49f6-4162-9e57-fa68912873a1">
        <source>resolveIntendedRelModePattern(pattern: String; valueArray: IntegerArray input) protected;
// 24/02/2011	cnwmh5	#26912
//
begin
	myYACriteriaType.resolveIntendedRelModePattern(pattern, valueArray);
end;</source>
        <access>protected</access>
        <Parameter name="pattern" type="String"/>
        <Parameter name="valueArray" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="resolvePattern" id="bd860bc3-6508-4e92-b5d4-831f7db8d332">
        <source>resolvePattern(pattern: String; objectSet: ObjectSet input; _raiseException: Boolean) protected;
//01 August 2008	cnwdw1	
//
begin
	myYACriteriaType.resolvePattern(pattern, objectSet, _raiseException);
end;</source>
        <access>protected</access>
