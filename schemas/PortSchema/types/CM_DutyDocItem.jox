    <JadeMethod name="getPackingTypeString" id="525e2827-1aa4-4ac7-9683-cf06da1c2d40">
        <source>getPackingTypeString():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 December 2012	cnwndl1	Initial creation

*/
vars
	agent: CM_DutyDocAgent;
begin
	
	create agent transient;
