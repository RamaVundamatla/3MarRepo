    <JadeMethod name="setReadOnly" id="6eb2071b-ee74-43e9-928c-ca22556386ce">
        <updating/>
        <source>setReadOnly() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
