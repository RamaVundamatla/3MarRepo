    <JadeMethod name="setOOWVoyageDetails" id="b1091077-1cd9-42a9-89bc-30156366cfb4">
        <updating/>
        <source>setOOWVoyageDetails(_shipExchangeDate : TimeStamp; _starboardBerthed : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		02 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	aJS					: CM_JobSheet;
	oldShipExchangeDate : TimeStamp;	//cnwmc5 - 16 Oct 2013 - PAR 32793
begin
	self.starboardBerthed := _starboardBerthed;
	
	//used in the validation for the start time of the cranes that are alocated to a
	oldShipExchangeDate	:= self.shipExchangeDate;	//cnwmc5 - 16 Oct 2013 - PAR 32793
	self.shipExchangeDate := _shipExchangeDate;
	
	//cnwmc5 - 16 Oct 2013 - PAR 32793 - sets all the cranes exchange dates
	foreach aJS in self.allJobSheets do
		aJS.setWorkStartedForOOW(_shipExchangeDate, oldShipExchangeDate);
	endforeach;
end;</source>
        <Parameter name="_shipExchangeDate" type="TimeStamp"/>
        <Parameter name="_starboardBerthed" type="Boolean"/>
    </JadeMethod>
