    <JadeMethod name="trxCreateYATemplate" id="370d5651-5d55-4852-b615-d62510b425b7">
        <updating/>
        <source>trxCreateYATemplate(_proxyYATemplate: CM_YATemplate input;
						_proxyCriteria: CMIF_Array;
						_yATemplate: CM_YATemplate output;	
						_passport : CM_Passport input) updating;
//17 July 2008	cnwdw1	
// Create a Yard Allocation Template and return the newly created persisted object
vars
	ya: CM_YardAllocation;
begin
	self.initialiseActivityWithPassport(_passport, method);
	on Exception do self.agtPassportExHandler(exception, _passport);
	on LockException do self.agtPassportLockExHandler(exception, _passport);
	app.setContinueCMExceptions(false);
	
	beginTransaction;
	
	// Create a Yard Allocation object first
	app.myUtilityCA.utlCreateYardAllocation(_proxyYATemplate.myYardAllocation, _proxyCriteria, ya, _passport);
	
	if _passport.noErrors() then
		// Now create the Template object and attach the just created yard allocation object
		app.myUtilityCA.utlCreateYATemplate(_proxyYATemplate, _yATemplate, ya, _passport);
	endif;
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_proxyYATemplate" type="CM_YATemplate" usage="input"/>
        <Parameter name="_proxyCriteria" type="CMIF_Array"/>
        <Parameter name="_yATemplate" type="CM_YATemplate" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCreateYardActivity" id="a229587f-bc1a-40ed-8fde-ceaac9ca4e63">
        <updating/>
        <source>trxCreateYardActivity(	_tiSet : CM_TISet;
						_yardActivityType : Integer;
						_actionTime : TimeStamp;
						_passport : CM_Passport input
						) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 July 2020	jlgndl1	Initial creation	TFS 49581

*/

vars

	ti : CM_TrackedItem;
	proxyClass : Class;
	newJob : CM_YardActivity;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do self.agtPassportExHandler(exception, _passport);
	on LockException do self.agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	
	proxyClass := CM_YardActivity@getProxyClassForType( _yardActivityType );
	if proxyClass = null then
		app.raiseCMException( Reefer_type_selected, null, null );
		return;
	endif;
	
	if _tiSet = null or _tiSet.isEmpty then
		app.raiseCMException( Reefers_selected, null, null );
		return;
	endif;
	
	if not _actionTime.Date.isValid then
		app.raiseCMException1(Action_date_time_require, CM_YardActivity@getStringFromType( _yardActivityType ), null, null);
	endif;
	
	// Start the transaction.
	
	beginTransaction;
	
	// Perform the operation.
	
	foreach ti in _tiSet do
	
		newJob := ti.createReeferJob( proxyClass, _actionTime, _passport );
		
		if _passport.hasErrors then
			break;
		endif;
		
									
		ti.createReeferJobInformation(newJob,null,false ); // ### TFS 51300 07JUL2021 NAVAB1

	endforeach;
epilog

	self.finaliseActivityWithPassport(_passport);
	
end;</source>
        <Parameter name="_tiSet" type="CM_TISet"/>
        <Parameter name="_yardActivityType" type="Integer"/>
        <Parameter name="_actionTime" type="TimeStamp"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCreateYardAllocation" id="4a8f5cd2-e3d6-4cff-aec4-27c75e174d27">
        <updating/>
        <source>trxCreateYardAllocation(pProxyObj:CM_YardAllocation input;
						pAllTransientCriteriaObj:CMIF_Array;
						pYardAllocationObj:CM_YardAllocation output;
						_passport : CM_Passport input) updating;
// --------------------------------------------------------------------------------
// Created:		27 April 2005 by cnwdad1
//
// Purpose:		Transaction to creates a new Yard Allocation objects, and its
//				associated YA Blocks, and YA Criteria.
//
// Parameters:	pProxyObj - A reference to the proxy YA object.
//				pAllTransientCriteriaObj - A collection of transient Criteria objects.
//				pYardAllocationObj - A reference to the new YA object.
//				_passport - A reference to the user's "passport" object.
//
// Returns:		A reference parameter to the new YA object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//	20/04/2023	navkc1		Bug 57628: CUX-Adding Criteria to Transaction Mapping allocation configuration results in error
// --------------------------------------------------------------------------------
vars
	cmifObject		: CMIF_Object;
	transientObj	: CMIF_YACriteriaPriority;
	proxyObj		: CM_YACriteriaPriority;
	priorityValue	: Real;
	sortValue		: Real; //20/04/2023	navkc1	Bug 57628 Needs to be the same type as receive
	
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do self.agtPassportExHandler(exception, _passport);
	on LockException do self.agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	sortValue	:=	0;
	
	// Now calculate the Yard Allocation priority values on the proxy objects, working
	// backwards from the least important.
	
	foreach cmifObject in pAllTransientCriteriaObj reversed do
		transientObj	:=	cmifObject.CMIF_YACriteriaPriority;
		
		if transientObj.isDeleted then
			continue;
		endif;
		
		proxyObj		:=	transientObj.myProxy;
		priorityValue	:=	2 ^ sortValue;
		proxyObj.setPriorityValue(priorityValue);
		sortValue		:=	sortValue + 1;
	endforeach;
	
	// Start the transaction.
	
	beginTransaction;
	
	// Perform the operation.
	
	app.myUtilityCA.utlCreateYardAllocation(pProxyObj, pAllTransientCriteriaObj, pYardAllocationObj, _passport);
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="pProxyObj" type="CM_YardAllocation" usage="input"/>
        <Parameter name="pAllTransientCriteriaObj" type="CMIF_Array"/>
        <Parameter name="pYardAllocationObj" type="CM_YardAllocation" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCreateYardInternalDelivery" id="002ed4d2-7cb5-4ef0-86f3-35b7da73a670">
        <updating/>
        <source>trxCreateYardInternalDelivery(_proxyJob:CM_YardInternalJob input; _newJob:CM_YardInternalJob output; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		create a yard internal job for a yard to yard delivery request
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;

	// Perform the operation
	app.myUtilityCA.utlCreateYardInternalDelivery(_proxyJob,_newJob, _passport);
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_proxyJob" type="CM_YardInternalJob" usage="input"/>
        <Parameter name="_newJob" type="CM_YardInternalJob" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCreateYardInternalDeliveryR" id="b3de827f-0db2-4bbc-85c8-fbce87016a8d">
        <updating/>
        <source>trxCreateYardInternalDeliveryR(_proxyJob:CM_YardInternalJob input; _newJob:CM_YardInternalJob output;
								_proxyReq:CM_YardDeliveryRequest input; _newReq:CM_YardDeliveryRequest output;_addToRTQ:Boolean;
								_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		create a yard internal JOB AND REQUEST, for a yard to yard delivery request
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);
	
	// DVB added 30/05/2005
	app.initialiseForStartAutoPlan(_passport);
	
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;

	// Perform the operation
	app.myUtilityCA.utlCreateYardInternalDelivery(_proxyJob,_newJob, _passport);
	if _passport.noErrors() then
//		self.initialiseActivityWithPassport(_passport, method);
		_proxyReq.setJob(_newJob);
		app.myUtilityCA.utlCreateYardDeliveryRequest(_proxyReq,_newReq, _passport);
		if _passport.noErrors() then
			if _addToRTQ then
				_newJob.enqueueJob();
			endif;
		endif;
	endif;	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_proxyJob" type="CM_YardInternalJob" usage="input"/>
        <Parameter name="_newJob" type="CM_YardInternalJob" usage="output"/>
        <Parameter name="_proxyReq" type="CM_YardDeliveryRequest" usage="input"/>
        <Parameter name="_newReq" type="CM_YardDeliveryRequest" usage="output"/>
        <Parameter name="_addToRTQ" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
