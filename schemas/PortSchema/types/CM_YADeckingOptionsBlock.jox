    <JadeMethod name="getLocationCellArray" id="27660ddb-29b2-4118-bef6-4a2f54ea156c">
        <source>getLocationCellArray(_in: Boolean): CM_YALocationCellArray;
//----------------------------------------------------------------
//	Created:	27 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	if _in then
		return self.allYALocationCellsIn;
	else
		return self.allYALocationCellsOut;
	endif;
end;</source>
        <Parameter name="_in" type="Boolean"/>
        <ReturnType type="CM_YALocationCellArray"/>
    </JadeMethod>
    <JadeMethod name="getNextLevelRule" id="1ecadfc9-c8bd-4f2d-88b0-1e1a488df8ab">
        <source>getNextLevelRule(_fromHeight: Integer; _isInRule: Boolean): CM_YADeckingRule;
//----------------------------------------------------------------
//	Created:	18 May 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	gridObject	: CM_GridObject;
	rule		: CM_YADeckingRule;
begin

	gridObject := self.myYABlock.getGridObject();
	
	if gridObject = null then
		return null;
	endif;
	
	if CM_GridRow.hasInstance(gridObject) then
		if gridObject.myDeckingOptions &lt;&gt; null then
			if _isInRule then
				foreach rule in gridObject.myDeckingOptions.allDeckingRulesIn do
					if _fromHeight &gt;= rule.heightFrom 
					and _fromHeight &lt;= rule.heightTo then
						return rule;
					endif;
				endforeach;
			else
				foreach rule in gridObject.myDeckingOptions.allDeckingRulesOut do
					if _fromHeight &gt;= rule.heightFrom 
					and _fromHeight &lt;= rule.heightTo then
						return rule;
					endif;
				endforeach;
			endif;
		endif;
	endif;
	
	return null;
end;</source>
        <Parameter name="_fromHeight" type="Integer"/>
        <Parameter name="_isInRule" type="Boolean"/>
        <ReturnType type="CM_YADeckingRule"/>
    </JadeMethod>
    <JadeMethod name="getRulesStr" id="c0023cb1-8133-4256-811c-cadb639e7e80">
        <source>getRulesStr(pIsSortIn: Boolean): String;

vars

begin

	if self.myYABlock &lt;&gt; null and self.myYABlock.isKindOf(CM_YABlockRTG) then
		return 'RTG Rule';
	endif;
	
	return inheritMethod(pIsSortIn);
end;
</source>
        <Parameter name="pIsSortIn" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
