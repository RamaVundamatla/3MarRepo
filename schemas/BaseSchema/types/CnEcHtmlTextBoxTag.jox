    <DbClassMap file="basehtml"/>
    <PrimAttribute name="inputMaxLength" id="7357795c-fd4a-4806-9982-ab0c33131738">
        <embedded/>
        <type name="Integer"/>
        <text>Specifies that maximum number of characters that can be
entered into a text field.</text>
    </PrimAttribute>
    <PrimAttribute name="inputSize" id="0028d653-0530-413c-b660-39130b63dae0">
        <embedded/>
        <type name="Integer"/>
        <text>Specifies the width of the text field in characters, or the
width and height in characters and lines of a TextArea.</text>
    </PrimAttribute>
    <JadeMethod name="buildTagBody" id="bb3527b7-c796-4a74-9549-155d34b6b41e">
        <source>buildTagBody(): String protected;
// --------------------------------------------------------------------------------
// Created:		02 December 2001 by cnwdad1
//
// Purpose:		Refer to the CnEcHtmlTagObject implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	htmlString	: String;

begin
	htmlString	:=	inheritMethod() &amp; ' SIZE="' &amp; self.inputSize.String &amp; '"';
	
	if self.inputMaxLength &lt;&gt; 0 then
		htmlString	:=	htmlString &amp; ' MAXLENGTH="' &amp; self.inputMaxLength.String &amp; '"';
	endif;
	
	return htmlString;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="create" id="557f7462-1f0d-4d3d-9acc-32ac368bae6b">
        <updating/>
        <source>create() updating;
// -----------------------------------------------------------------------------
// Created:		30 November 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	self.inputType	:=	self.TYPE_TEXT;
end;</source>
    </JadeMethod>
</Class>
