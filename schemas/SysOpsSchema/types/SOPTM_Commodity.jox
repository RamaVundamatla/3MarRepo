    <JadeMethod name="includeObject" id="cb1bc0cf-aa49-4d5d-881d-119c213e8136">
        <updating/>
        <source>includeObject(_obj: Object; _passport: CM_Passport): Boolean updating;
// --------------------------------------------------------------------------------
// Created:		24 April 2006 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.includeNotAvailableEntries then
		return true;
	else
		return not _obj.CM_Commodity.isNotAvailableForEntry;
	endif;
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initShtMultiSelect" id="d5fea3a2-b7b8-457a-8c98-7fb6fc9ff728">
        <source>initShtMultiSelect();
/* ---------------------------------------------------------------------------
Created:	20 May 2009	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	theForm	: SOP_TableMaintForm;

begin
	inheritMethod();

	theForm := self.myForm;
	theForm.mulSelect1.setVisibleButtons(true,true,false);
	self.setupMultiSelect1(app.getErrorString(CargoTypes), app.myRoot.allCargoTypesById, SOP_TableMaintForm::displayEntryCargoType.name);
	theForm.mulSelect1.myBaseForm	:= theForm;
	theForm.mulSelect1.mySelectedListBox.sorted := true;


end;</source>
    </JadeMethod>
