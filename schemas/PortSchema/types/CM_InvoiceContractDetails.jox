    <JadeMethod name="getCurrentRateForDisplay" id="023b4f15-cc47-4ec6-8c2c-8aa94a900aea">
        <source>getCurrentRateForDisplay() : CM_InvoiceContractRateEntry;
/*
Purpose:		for display get the current 'valid' rate entry. Valid means there is a valid date range in the DB.	

Date		Who		Reason
29 November 2023	navab1	BUG 61268
*/

vars
	now, fromts : TimeStamp;
	iterEntry : Iterator;
	entry, lastOne : CM_InvoiceContractRateEntry;
	firstRate : CM_InvoiceContractRate;
begin

	firstRate := self.allInvoiceContractRates.first;
	
	if firstRate &lt;&gt; null then
		entry := firstRate.getCurrentRateForDisplay();
	endif;
	
	return entry;
epilog

end;</source>
        <ReturnType type="CM_InvoiceContractRateEntry"/>
    </JadeMethod>
