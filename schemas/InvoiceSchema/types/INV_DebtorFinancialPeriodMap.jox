        <updating/>
        <source>doQuery() updating;

vars

begin
	self.myCurrentDebtor := self.cmbDebtor.listObject.CM_DebtorNode;

	self.doQueryDebtor();
	inheritMethod();
end;</source>
    </JadeMethod>
    <JadeMethod name="doQueryDebtor" id="5dbb0531-33c0-4043-a4cb-7aab7814babf">
        <updating/>
        <source>doQueryDebtor() updating;
// 24/04/2013	cnwcs5	par 30652 - remove resynch/resynchObject method calls
// 7 Nov 2022 	navrk21 Bug 55204: MTN - Accural Type for Debtor is incorrect
vars
	theDebtors:	CM_DebtorNodeByNameDict;
	dn:			CM_DebtorNode;
	invType:	CM_InvoiceDesc;
	mapping:	CM_DebtorBankInvTypeDtl;
	row:		Integer;
	column:		Integer;
	count:		Integer;
	pd:			CMS_Progress;
	ls: Boolean;
	mapTable : Table;
	bank : CM_Bank;
	rdg: CM_RootDebtorGroup;
begin
	// 35872 get business unit from query, handle change
	if self.cmbBank.visible then
		bank := self.cmbBank.listObject.CM_Bank;
	else
		bank := self.myCurrentBank;
	endif;
	if bank = null then
		return;
	endif;
	if bank &lt;&gt; self.myCurrentBank then
		self.myCurrentBank := bank;
		self.doCmbTypesBuild();
		self.loadTypes();
	endif;
	rdg := bank.getRootDebtorGroup();

	create theDebtors transient;
	mapTable := self.tblData;
	if self.myCurrentDebtor &lt;&gt; null then
//	TFS 2682	self.setCaption("Debtor Financial Periods - " &amp; self.myCurrentDebtor.name &amp; " " &amp; bank.code);
		self.setCaption(bank.code &amp; " Debtor Financial Periods - " &amp; self.myCurrentDebtor.name );
	else
	//	TFS 2682	self.setCaption(bank.code &amp; " Debtor Financial Periods - All Debtors" );
		self.setCaption( "Debtor Financial Periods - All Debtors " &amp; bank.code );
	endif;

	self.setNavigatorHeading(self.caption);
	
	on CM_ProgressException do haltProgress(exception, ls);

	create pd;
	pd.setBackground(self.backColor);
	pd.show;
	pd.setAction("Loading Debtors...");

	app.cmsBeginLoad(ls);

	mapTable.columns := 1;
	mapTable.column := 1;
	mapTable.row := 1;
	mapTable.fixedRows := 1;

	if self.myCurrentDebtor &lt;&gt; null then
		self.myCurrentDebtor.getDebtors(theDebtors);
	else
		rdg.getDebtors(theDebtors);
	endif;
	
	mapTable.columns := theDebtors.size + 1;
	column := 1;
	pd.progress.partsInJob := theDebtors.size;
	foreach dn in theDebtors do
		if dn.isKindOf(CM_DebtorGroup) then
			continue;
		endif;
		if not global.isValidObject(dn) then
			continue;
		endif;
		
		column := column + 1;
		
		row := 1;
		mapTable.accessCell(row,column).text := dn.name;
		mapTable.accessColumn(column).itemObject := dn;
		foreach invType in bank.invoiceTypes where not invType.isNotAvailableForEntry do
			row := row + 1;
			
			mapping := bank.allDebtorBankInvTypeDtls[dn.CM_Debtor, invType];
			if mapping &lt;&gt; null then
				if mapping.myFinancialPeriodEnd &lt;&gt; null then	// from TFS 2076
					mapTable.accessCell(row,column).text := mapping.myFinancialPeriodEnd.description;
				endif;
				mapTable.accessedCell.fontBold := true;
				mapTable.accessedCell.foreColor := Black;
			 else
				//mapTable.accessCell(row,column).text := invType.getAccrualTypeDescription();		// 07.11.2022 navrk21 TFS 55204
				mapTable.accessCell(row,column).text := invType.getAccrualTypeDescDebtor(null);		// 07.11.2022 navrk21 TFS 55204
				mapTable.accessedCell.fontBold := false;
				mapTable.accessedCell.foreColor := DarkGray;
			endif;
			mapTable.accessedCell.itemObject := mapping;
		endforeach;

		count := count + 1;
		pd.progress.partsDone := count;
		app.doWindowEvents(0);
	endforeach;
	
	self.doComboDebtorUpdateBuild(theDebtors);
	
	mapTable.row := 1;
	mapTable.column := 1;

	self.setEnableObjects();
	mapTable.accessColumn(2).width := 100;
epilog
	app.cmsEndLoad(ls);
	delete pd;

	delete theDebtors;
end;</source>
