	self.myWeightType 		:= _myMeasurementType;//TFS3153
	
	self.deviceAddress 		:= _deviceAddress;	//25 May 2017	NDL	TFS 4383
	self.updateCargoMode 	:= _updateCargoMode;	//05 Jul 2019	NDL	TFS 44965
	
	self.canUpdateRTS 		:= _canUpdateRTS;	//11 May 2020	NDL	TFS 49296
	self.deviceId			:= _deviceId;	// ### TFS 52773 1APR2022 NAVPW1
	
epilog

end;</source>
