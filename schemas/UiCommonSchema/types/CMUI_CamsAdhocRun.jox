    <JadeMethod name="doOK" id="0c4394dc-c66d-4602-a034-2cdc0fd714cd">
        <updating/>
        <source>doOK() updating;
/*

Date		Who		Reason
08 September 2015	cnwer1	Initial creation PAR
// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

	startDateTime,
	localStartDT	: TimeStamp;
	endDateTime,
	localEndDT		: TimeStamp;
	runDateTime		: TimeStamp;
	camProtocol		: CM_CamProtocol;
	camsController  : CM_CamControllerAgent;
	camTaskHistory  : CM_CamTaskHistory;
	aFile			: File;
	fileName		: String;
begin
	
	camProtocol:=cmbProtocol.listObject.CM_CamProtocol;
	if camProtocol = null then
		return;
	endif;
	
	localStartDT.setDate(self.txtStartDate.getDate());		// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	localStartDT.setTime(self.txtStartTime.getTime());		// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	runDateTime := app.actualTimeServer;
	
	localEndDT.setDate(self.txtEndDate.getDate());			// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	localEndDT.setTime(self.txtEndTime.getTime());			// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	startDateTime := self.localToSystemTime(localStartDT);	// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	endDateTime	  := self.localToSystemTime(localEndDT);	// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	on Exception do null global;
	app.setPassBackExceptions(true, true);
	create camsController transient;
	camsController.setMyTerminal(self.myTerminal);
	camsController.setCAMSEmail(self.myTerminal);
	
	camTaskHistory:= camProtocol.taskHistoryByProtocolSeq[camProtocol, 0];
	if camTaskHistory &lt;&gt; null then
		beginTransaction;
		camTaskHistory.clearRawData;
		commitTransaction;
	endif;
	camsController.adhocTask(camProtocol, startDateTime, endDateTime, runDateTime, true, false);	//this does runs the adhoc cams
	
	camTaskHistory 	:= camsController.myCurrentCamProtocol.taskHistoryByProtocolSeq[camsController.myCurrentCamProtocol, camsController.processSeqNumber];
	if camTaskHistory &lt;&gt; null then
		fileName := self.myTerminal.getConfig_FileDirectory(CamsFileDirectory).String.trimRight&amp;'\'&amp;camTaskHistory.camProtocol.code.trimBlankCharacters.removeInvalidChars &amp; "\" &amp; camTaskHistory.fileName; //cnwrs1 par19312 June 2009 
		create aFile transient;
			
		aFile.kind := File.Kind_Unknown_Text;	// 1/3/16 cnwmp6 PAR 36286 unicode version
		aFile.fileName := fileName;
		aFile.mode := File.Mode_Input;
		
		if aFile.tryOpen 
		and (app.computerName.toUpper = camTaskHistory.computerName.toUpper) then
			aFile.close;
			app.createExternalProcess("notepad.exe " &amp; fileName, false );	
		endif;
	endif;
	self.modalResult := IDOK;
	self.unloadForm;

epilog
	delete camsController;
	delete aFile;


end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="613549b7-a6f8-45d9-9d0d-c10f330a7c2a">
        <updating/>
        <source>setupForm() updating;
/*

Date		Who		Reason
08 September 2015	cnwer1	Initial creation PAR
// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	localNow : TimeStamp;
begin
	inheritMethod();
	self.cmbProtocol.listCollection(self.myTerminal.camProtocols, true, 0);
	if self.myCamsProtocol &lt;&gt; null then
		self.cmbProtocol.cnEcSetObjectIndex(self.myCamsProtocol);
	endif;
	
	localNow := self.systemToLocalTime(app.actualTimeServer);	// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.txtEndDate.setDate(localNow.date);						// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.txtEndTime.setTime(localNow.time);						// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.txtStartDate.setDate(localNow.date-2);					// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.txtStartTime.setTime(localNow.time);					// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="0b43cf30-e612-4efe-8aa2-017598563f2b">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 09 September 2015.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0020913, locale);
	label1.translateCaption(Xlat_0020914, locale);
	label1_1.translateCaption(Xlat_0020915, locale);
	label1_2.translateCaption(Xlat_0020916, locale);
end;</source>
    </JadeMethod>
</GUIClass>
