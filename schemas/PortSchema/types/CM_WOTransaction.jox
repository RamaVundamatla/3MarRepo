    <JadeMethod name="getCargoIMEX" id="1aa114de-1793-4abe-9208-ee88083ad798">
        <source>getCargoIMEX():CM_IMEXStatus;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Jan 2023	navhl20	ChangeRequest 54350:[54269] EUP - VAS Work Orders Selector Query
08 Feb 2023 navma1  ChangeRequest 56457:[56458] EUP - Allowing different sets of cargo items per work order task [Refactor]
*/

vars

begin
	
	if not self.hasCargoWorkOrderDetails  then
		return null;
	endif;

	
	if self.myWorkOrderDetail.CM_WorkOrderTIDtl.allSelectedTIs.isEmpty() then						//08.02.2023 navma1 #56457:[56458]
		return null;
	endif;
	
	return self.myWorkOrderDetail.CM_WorkOrderTIDtl.allSelectedTIs.first.getImExStatusObject();		//08.02.2023 navma1 #56457:[56458]
epilog

end;</source>
        <ReturnType type="CM_IMEXStatus"/>
    </JadeMethod>
