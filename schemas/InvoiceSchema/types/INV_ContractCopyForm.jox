    <JadeMethod name="doCmbDebtorBuild" id="ddc0e02f-70e5-48c9-b624-b58be7d489ae">
        <source>doCmbDebtorBuild();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 March 2023	navkc1	Initial creation CR #55652 Task 57014: UI - Contract Copy UI

*/

vars
	debtor,
	realContractDebtor		: CM_Debtor;
	debtorTerminal : CM_DebtorTerminal;

begin
	
	// CR #55652 Task 57014: UI - Contract Copy UI
	foreach debtorTerminal in self.myTerminal.allDebtorTerminals discreteLock do
		debtor := debtorTerminal.myDebtor;
		self.cmbDebtor.addItemObject(debtor.name, debtor);
	endforeach;
		
	realContractDebtor := self.myRealInvoiceContract.myDebtor;
	
	if realContractDebtor &lt;&gt; null then
		cmbDebtor.setIndexFromObject(realContractDebtor);
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doPopulateDataFromOriContract" id="ba427937-7fae-4c35-8dad-558424df67d4">
        <source>doPopulateDataFromOriContract();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30/01/2023	navkc1 Bug 61265: EUP | FR 54089 - Invoice contracts - Copy function attributes.

*/

vars
	oriContract : CM_InvoiceContract;
	
begin
	
	oriContract := self.myRealInvoiceContract;
	
	// Start Date time
	self.mskStartDate.setDate(self.systemToLocalTime(oriContract.fromTS).date());
	self.mskStartTime.setTime(self.systemToLocalTime(oriContract.fromTS).time());
	
	// End Date time
	self.mskEndDate.setDate(self.systemToLocalTime(oriContract.toTS).date());
	self.mskEndTime.setTime(self.systemToLocalTime(oriContract.toTS).time());
	
	// Primary
	self.chkPrimary.value := oriContract.primary;
	
	// Active
	self.chkActive.value := oriContract.active;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="a6464d0f-67bc-427e-9817-19562785e84c">
        <updating/>
        <source>doSave() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 March 2023	navkc1	Initial creation CR #55652 Task 57014: UI - Contract Copy UI

*/

vars
	debtor			: CM_Debtor;
	
	description,
	contractId		: String;
	
	todayDate		: Date;
	
	fromTS,
	toTS			: TimeStamp;
	
	pxyContract,
	realContract	: CM_InvoiceContract;
	theReturn 		: Integer;
	
	active,
	primary,
	validOnly		: Boolean;
	
begin
	
	contractId 	:= self.txtContractId.text;
	debtor		:= self.cmbDebtor.itemObject[self.cmbDebtor.listIndex].CM_Debtor;
	validOnly	:= self.chkValid.value;
	
	todayDate	:= app.actualTimeServer().date();
	
	pxyContract := self.myRealInvoiceContract.cloneForCopy(true, validOnly, todayDate, true); // ### BUG 56908 21MAR2023 NAVAB1
	
	active := self.chkActive.value; //30/01/2023	navkc1 Bug 61265
	primary := self.chkPrimary.value; //30/01/2023	navkc1 Bug 61265
	description := self.txtDescription.text; //30/01/2023	navkc1 Bug 61265
	
	//30/01/2023	navkc1 Bug 61265
	fromTS.setDate(self.mskStartDate.getDate());
	fromTS.setTime(self.mskStartTime.getTime());
	
	//30/01/2023	navkc1 Bug 61265
	toTS.setDate(self.mskEndDate.getDate());
	toTS.setTime(self.mskEndTime.getTime());
	
	pxyContract.setProxy(	active,
							contractId,
							self.localToSystemTime(fromTS),
							self.localToSystemTime(toTS),
							primary,
							pxyContract.myBusinessUnit,
							pxyContract.myTerminal,
							debtor,
							description
							);
							
	while true do
		app.myTrxCA.trxCopyInvoiceContract(pxyContract, realContract, app.myPassport);
		
		if app.myPassport.trxCompletedOK() then
			self.clearErrorWarnings();
			app.msgBox(app.getErrorString(Invoice_contrac_create_success), app.getErrorString(Message),MsgBox_OK_Only);
			self.unloadForm();
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Invoice_contract_create), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);
		endif;
		break;
	endwhile;
	
epilog
	pxyContract.deleteClonedProxy();
	delete pxyContract;
end;</source>
    </JadeMethod>
    <JadeMethod name="setCaption" id="b6fcf0be-511c-4cc6-a06c-f229a3c26cda">
        <updating/>
        <source>setCaption(_caption: String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 March 2023	navkc1	Initial creation CR #55652 Task 57014: UI - Contract Copy UI

*/

vars
	myCaption		: String;
begin
	
	myCaption := self.caption &amp; " (" &amp; self.myRealInvoiceContract.auditId() &amp; ")";
	
	if self.myBusinessUnit &lt;&gt; null then
		myCaption &amp;= " " &amp;  self.myBusinessUnit.code;
	endif;

	inheritMethod(myCaption);
	
epilog

end;</source>
        <Parameter name="_caption" type="String"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="db5fc98c-e931-43c5-9f9f-38f46465613a">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 March 2023	navkc1	Initial creation CR #55652 Task 57014: UI - Contract Copy UI
30/01/2023		navkc1 	Bug 61265: EUP | FR 54089 - Invoice contracts - Copy function attributes.
*/

vars

begin
	inheritMethod();
	
	self.doCmbDebtorBuild();
	
	self.doPopulateDataFromOriContract(); //30/01/2023	navkc1 Bug 61265
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="e10c34b2-be37-4f89-900d-f0a2dbba1624">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 31 January 2024 10:29:04.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0025807, locale);
	btnCancel.translateCaption(Xlat_0025808, locale);
	btnSave.translateCaption(Xlat_0025809, locale);
	lblActive.translateCaption(Xlat_0026649, locale);
	lblContractId.translateCaption(Xlat_0025810, locale);
	lblDebtor.translateCaption(Xlat_0025811, locale);
	lblDescription.translateCaption(Xlat_0026650, locale);
	lblEnd.translateCaption(Xlat_0026651, locale);
	lblPrimary.translateCaption(Xlat_0026652, locale);
	lblStart.translateCaption(Xlat_0026653, locale);
	lblValid.translateCaption(Xlat_0025812, locale);
end;</source>
    </JadeMethod>
