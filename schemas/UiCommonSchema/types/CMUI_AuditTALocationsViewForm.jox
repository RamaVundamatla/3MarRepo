    <JadeMethod name="getXMLSettingsForSave" id="10cf7196-ee58-422e-ae2f-30bcbc230be2">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
// ---------------------------------------------------------------------------
// Created:     10 March 2011 by cnwcs5
// Purpose:     Remember time span for last inquiry - only if the end date is today
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// ---------------------------------------------------------------------------
vars
	xml 				: String; 
	dateFrom, dateTo	:Date;
	days				: Integer; 
begin
	dateFrom 	:= self.txtQDateStart.getDate;
	dateTo		:= self.txtQDateEnd.getDate;
	// only record days in past if they are doiing query ending today
	if dateTo = self.systemToLocalTime(app.actualTimeServer).date and// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		dateFrom &lt;&gt; null then
		days := dateTo - dateFrom;
	else
		days := 7;
	endif;
	
	xml := inheritMethod();

	xml := xml &amp; global.formatAsXML (XMLTag_Days, days.String);
	
	return xml;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSetup" id="3a79ec4a-6889-4c72-92a5-52c822ae4873">
        <updating/>
        <source>getXMLSettingsForSetup()updating, protected;
// ---------------------------------------------------------------------------
// Created:     10 March 2011 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	userWindow	: CM_UserWindow;
	xml, value 	: String;
	hideMacro	: Boolean;
begin
	userWindow := self.myUserWindow;
	
	if userWindow = null then
		userWindow := app.getUserWindow(self.name, false);
		if userWindow = null then
			return;
		endif;
	endif;

	xml 	:= userWindow.xmlInfo;
 	value 	:= xml.cnEcGetTagValueOfName(self.XMLTag_Days);

 	if value &lt;&gt; null then
 		self.daysToGoBack := value.Integer;
 	endif;
	
 	value := xml.cnEcGetTagValueOfName(XML_HM);

 	if value &lt;&gt; null then
 		hideMacro := value.Integer.Boolean;
 	endif;
	
	self.xmlMacro := hideMacro;

end;
</source>
        <access>protected</access>
    </JadeMethod>
