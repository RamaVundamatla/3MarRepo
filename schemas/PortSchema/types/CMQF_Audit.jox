<Class name="CMQF_Audit" id="3a739852-ca8a-4755-b827-ae2a50b6c45a">
    <superclass name="CMQF_FilterReports"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <ImplicitInverseRef name="allUsers" id="6e2b4f0e-58f9-43ea-8680-b0c706388b3a">
        <memberTypeInverse/>
        <type name="CM_UserSet"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myCMObject" id="4389e8c0-c856-4977-aa19-bc15f12b714c">
        <embedded/>
        <type name="CM_Object"/>
        <access>protected</access>
    </ImplicitInverseRef>
