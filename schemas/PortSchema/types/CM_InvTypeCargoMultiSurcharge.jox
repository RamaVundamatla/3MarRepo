    <JadeMethod name="allCargoSubTypesDescription" id="bdaf6cce-de3f-4ca4-b3b9-ff679ebdc6bc">
        <source>allCargoSubTypesDescription() : String;
/*

Purpose:			Gets all the cargo sub types descriptions on the cargo surcharge truncated to 100 chars long and uses ellipsis to show its longer

Parameters:			NONE

Return Value:		String	Representing all cargo sub type descriptions upto 100 chars long

Date		Who		Reason
26 October 2022	navpw1	Initial creation TFS: 54565 (54385) - EUP - Inv Config - Invoice Surcharges

*/

vars
	cargoSubType				: CM_Product;
	cargoSubTypesDescription	: String;
	
begin
	if self.allCargoSubTypes.isEmpty then
		return null;
		
	endif;
	
	foreach cargoSubType in self.allCargoSubTypes do
		cargoSubTypesDescription &amp;= cargoSubType.description &amp; ", ";
		if cargoSubTypesDescription.length &gt; 100 then
			break;
		endif;
	endforeach;
	
	if cargoSubTypesDescription.length &gt; 0 then
		cargoSubTypesDescription := cargoSubTypesDescription.stripTrailingChar(",");
		cargoSubTypesDescription := cargoSubTypesDescription.formatWithEllipsis(1, 99, true);
	endif;
	
	return cargoSubTypesDescription;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
