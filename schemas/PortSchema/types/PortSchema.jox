    <JadeMethod name="getJadeAndJMTVersion" id="9121d6da-a786-45eb-b5f5-a8f4833fb528">
        <updating/>
        <source>getJadeAndJMTVersion() updating;

/*

Purpose:		Write the Jade Version and JMT Version / Hotfix version and system
				e.g. cnw?mast to a file for the InterimCut Automation process to pick up

Date			Who		Reason
18/03/2015		cnwmh5	Initial creation

*/

/*

Purpose:		

Date			Who		Reason
19 March 2015	cnwmh5	Initial creation

*/

vars

	file					: File;

	systemName				: String;
	tempStr					: String;
	pos						: Integer;
	directory				: String;
	
begin

	app.initialize();
	
	directory := app.getJadeInstallDir();
	pos := 1;
	pos := directory.reversePos("\");
	directory := directory[1:pos];
	directory := directory &amp; "logs";
		
	create file transient;
	file.mode := File.Mode_Output;	// 4/3/16 cnwmp6 PAR 36286 unicode version
	file.fileName := directory &amp; "\AutmationRunDetails.txt";
	file.usePresentationFileSystem := true;
	if file.isAvailable then
		file.purge();
	endif;
	
	// get the system name
	tempStr := app.getJadeInstallDirAppServer();
	pos := 1;
	systemName := tempStr.scanUntil("\", pos);
	pos := pos + 1;
	systemName := tempStr.scanUntil("\", pos);
	
	file.writeLine(app.cnGetJadeVersion() &amp; ";" &amp; app.myRoot.getVersionAndPatchLevel());
	
epilog

	delete file;

	terminate;

end;</source>
    </JadeMethod>
    <JadeMethod name="getJadeErrorString" id="d9ae7a33-e348-4ac8-843c-ddddbbe07505">
        <source>getJadeErrorString(errorCode : Integer) : String protected;
// ---------------------------------------------------------------------------
// Created:			21 May 2001 by cnwdwq1
// Purpose:			Creates a temp exception, and asks the exception to get the jade string     
// Parameters:	None
// Returns:			Nothing
// Changed On	Changed By		Reason
// ----------			----------			--------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	ex : Exception;
begin
	if errorCode &gt; self.baseErrorNum then
		return "Unknown Jade Exception :" &amp; errorCode.String &amp; " greater than baseNum! " &amp; self.baseErrorNum.String;
	endif;
	create ex;
	ex.errorCode := errorCode;
	return ex.text();
epilog
	delete ex;
end;</source>
        <access>protected</access>
        <Parameter name="errorCode" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getJadeLogDir" id="1a72ca6d-4db0-473d-b9e6-fedff138fe5c">
        <source>getJadeLogDir() : String;
// ---------------------------------------------------------------------------
// Created:     07 October 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	isAppServer	: Boolean;
	iniFileName,
	dirName		: String;
	ff			: FileFolder;
begin
	isAppServer	:= node.isApplicationServer;
	if isAppServer then
		iniFileName := self.getIniFileNameAppServer();
		dirName := self.getProfileStringAppServer(iniFileName, 'JadeLog', 'LogDirectory', null);
	else
		iniFileName := self.getIniFileName();
		dirName := self.getProfileString(iniFileName, 'JadeLog', 'LogDirectory', null);
	endif;
	
	if dirName = null then
		if isAppServer then
			return app.getTempDirAppServer();
		endif;
		return app.getTempDir();
	endif;
	
	create ff transient;
	ff.fileName := dirName;
	ff.usePresentationFileSystem := false;
	
	if (not ff.isAvailable) then
		if isAppServer then
			return app.getTempDirAppServer();
		endif;
		return app.getTempDir();
	endif;
	
	return dirName;

epilog
	delete ff;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getJobPriorityJobName" id="ed21db18-107c-4490-b6da-16016a6e5d1d">
