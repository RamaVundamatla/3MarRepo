    <JadeMethod name="matchOperator" id="620682c8-d57e-4694-be52-938b306ad993">
        <source>matchOperator(_restriction :  CM_LocationRestrictLog input) : Boolean protected;
/*

Date		Who		Reason
02 October 2015	cnwer1	Initial creation PAR 37018

*/

vars

begin
	if self.myOperator &lt;&gt; null then
		if _restriction = null then
			return false;
		endif;
		if not _restriction.allOperators.includes(self.myOperator) then
			return false;
		endif;		
	endif;
	return true;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_restriction" type="CM_LocationRestrictLog" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="matchStatus" id="818a605b-77d0-4b4e-9338-716b2def304f">
        <source>matchStatus(_logRow : CM_LogController) : Boolean protected;

vars
	localStart,
	localEnd,
	localStatus:	TimeStamp;
	oneDay:			TimeStampInterval;

begin
	oneDay.set(1, 0);
	localStart.setDate(self.startDate);
	localStart.setTime("0:00:00".Time);
	localEnd.setDate(self.endDate);
	localEnd.setTime("0:00:00".Time);
	if localEnd.isValid() then
		localEnd := localEnd + oneDay;
	endif;
	localStatus := self.systemToLocalTime(_logRow.statusDateTime);
	
	if self.status = Status_OpenClosed then
		if _logRow.status = LC_Status_Open or _logRow.status = LC_Status_Closed then
			return true;
		endif;
	
	elseif self.status = Status_Open_Only then
		if _logRow.status = LC_Status_Open then
			return true;
		endif;
	
	elseif self.status = Status_Closed_Only then
		if _logRow.status = LC_Status_Closed then
			return true;
		endif;
	
	elseif self.status = Status_Archived then
		if _logRow.status = LC_Status_Archived then
			if localStart.isValid() and (localStatus &lt; localStart) then
				return false;
			endif;
			if localEnd.isValid() and (localStatus &gt;= localEnd) then
				return false;
			endif;
			return true;
		endif;
	
	elseif self.status = Status_Empty then
		if _logRow.status = LC_Status_PhysicallyEmpty then
			if localStart.isValid() and (localStatus &lt; localStart) then
				return false;
			endif;
			if localEnd.isValid() and (localStatus &gt;= localEnd) then
				return false;
			endif;
			return true;
		endif;
	
	endif;
	
	return false;
		
end;</source>
        <access>protected</access>
        <Parameter name="_logRow" type="CM_LogController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="matchVoyage" id="55a1d4d6-f25c-499a-9890-87cde2565b3a">
        <source>matchVoyage(_logRow : CM_LogController) : Boolean protected;
/*

Date		Who		Reason
02 October 2015	cnwer1	Initial creation PAR 37018

*/

vars
	soh			: CM_SOHLocation;
	allocation	: CM_StockOrderAllocation;
begin
	
	if self.myVoyage = null then
		return true;
	endif;
	
	
	if _logRow.allProductLocations.isEmpty then
		return false;
	endif;
	
	foreach soh in _logRow.allProductLocations do
		if  soh.allStockOrderAllocations.isEmpty then
			continue;
		endif;
		
		foreach allocation in soh.allStockOrderAllocations do
			if (not allocation.isKindOf(CM_StockOrderSummaryAlloc)) then
				continue;
			endif;
			if allocation.myStockOrderHeader = null then
				continue;
			endif;
			if allocation.myStockOrderHeader.myVoyage = self.myVoyage then
				return true;
			endif;		
		endforeach;
		
	endforeach;
	
	return false;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_logRow" type="CM_LogController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setDetails" id="919fe89c-f79b-4770-877a-84a79a95d511">
        <updating/>
        <source>setDetails( _terminalCode,
			_terminalArea,
			_locationID,
			_locationOID,
			_operator,
			_status : String;
			_isDocketChecked,
			_isCheckScaled,
			_isInspected,
			_isFumigated : String;
			_voyageCode,
			_voyageOid,
			_species,
			_grade,
			_type,
			_treatment,
			_length : String;
			_startDate,
			_endDate : Date;
			_passport : CM_Passport) updating;
/*

Date		Who		Reason
01 October 2015	cnwer1	Initial creation PAR 37018

*/

vars
	root : CM_Root;
	lcStrings : StringArray;
	foundHeight : Integer;
begin
	root := CM_Root.firstInstance;
	if _terminalCode = null then
		self.myTerminal:=_passport.myTerminal;
	else
		self.myTerminal :=root.allTerminals[_terminalCode];
		if self.myTerminal = null then
			app.raiseCMException(ERR_TerminalCode_Invalid,null,null);
		endif;
		
	endif;
	if self.myTerminal &lt;&gt; null then
		if _locationOID &lt;&gt; null then
			self.myLC:= _locationOID.asOid.CM_LocationsController;
		else
			if _terminalArea &lt;&gt; null and _terminalArea &lt;&gt; Any_String then
				self.myTerminalArea:=self.myTerminal.allTerminalAreasByTypeId[TA_TYPE_LOGAREA,_terminalArea];
				if self.myTerminalArea = null then
					app.raiseCMException1(Err_InvalidTerminalArea,_terminalArea,null,null);
				endif;
			endif;
			if self.myTerminalArea &lt;&gt; null and _locationID &lt;&gt; null then
				create lcStrings transient;
				lcStrings.add(_locationID);
				self.myTerminalArea.findLocation(lcStrings,true,self.myLC,foundHeight);
				
				if self.myLC = null then
					app.raiseCMException1(ERR_INVALID_LOCN,_locationID,null,null);
				endif;
			endif;
		endif;
	endif;
	
	self.locationID:=_locationID;
	
	self.myOperator:=root.allOperators[_operator];
	if _operator &lt;&gt; null and _operator &lt;&gt; Any_String  and self.myOperator = null then
		app.raiseCMException1(ERR_INVALID_OPERATOR,_operator,null,null);
	endif;
	if _voyageOid &lt;&gt; null then
		self.myVoyage:=_voyageOid.asOid.CM_Voyage;
		if self.myVoyage = null then
			app.raiseCMException1(ERR_INVALID_VOYAGE,_voyageOid,null,null);
		endif;
	elseif _voyageCode &lt;&gt; null then
		if self.myTerminal &lt;&gt; null then
			self.myVoyage:=self.myTerminal.lookupVoyage(_voyageCode,null,false);
		endif;
		if self.myVoyage = null then
			app.raiseCMException1(ERR_INVALID_VOYAGE,_voyageCode,null,null);
		endif;
	endif;

	self.isCheckScaled:=_isCheckScaled;
	self.isDocketChecked:=_isDocketChecked;
	self.isFumigated:=_isFumigated;
	self.isInspected:=_isInspected;
	if _status &lt;&gt; Status_Closed_Only 
		and _status &lt;&gt; Status_Empty 
		and _status &lt;&gt; Status_OpenClosed
		and _status &lt;&gt; Status_Archived 
		and _status &lt;&gt; Status_Open_Only then
		if _status = "Open" then
			self.status:=Status_Open_Only;
		elseif _status = "Closed" then
			self.status:=Status_Closed_Only;
		elseif _status = "Open Closed" then
			self.status:=Status_OpenClosed;
		else
			app.raiseCMException1(Invalid_status,_status,null,null);
		endif;
	else
		self.status:=_status;
	endif;
	
	self.logGrade:=_grade;
	self.getLogLengthFilters(_length);
	self.logSpecies:=_species;
	self.logTreatment:=_treatment;
	self.logType:=_type;
	
	self.startDate := _startDate;
	self.endDate := _endDate;
epilog
	delete lcStrings;
end;</source>
        <Parameter name="_terminalCode" type="String"/>
        <Parameter name="_terminalArea" type="String"/>
        <Parameter name="_locationID" type="String"/>
        <Parameter name="_locationOID" type="String"/>
        <Parameter name="_operator" type="String"/>
        <Parameter name="_status" type="String"/>
        <Parameter name="_isDocketChecked" type="String"/>
        <Parameter name="_isCheckScaled" type="String"/>
        <Parameter name="_isInspected" type="String"/>
        <Parameter name="_isFumigated" type="String"/>
        <Parameter name="_voyageCode" type="String"/>
        <Parameter name="_voyageOid" type="String"/>
        <Parameter name="_species" type="String"/>
        <Parameter name="_grade" type="String"/>
        <Parameter name="_type" type="String"/>
        <Parameter name="_treatment" type="String"/>
        <Parameter name="_length" type="String"/>
        <Parameter name="_startDate" type="Date"/>
        <Parameter name="_endDate" type="Date"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
</Class>
