    <JadeMethod name="cloneControl" id="f58fe8ed-b0e8-4a0a-b01e-9386b516841d">
        <source>cloneControl(pControl : Control; pSheet : GTE_Sheet io) : Control protected;
// ---------------------------------------------------------------------------
// Created:     09 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	newCntrl	: Control;
	
begin
	newCntrl := pControl.loadControl(self.maxSheetId);
	newCntrl.parent := pSheet;
	pSheet.allControlsByName.add(newCntrl);

	if newCntrl.isKindOf(GTE_ComboBox) or
	   newCntrl.isKindOf(GTE_ComboOperator) or
	   newCntrl.isKindOf(GTE_ComboISOType) or
//	   newCntrl.isKindOf(GTE_DateBox2) or	
	   newCntrl.isKindOf(GTE_ListTable) or
	   newCntrl.isKindOf(GTE_HazardListTable) or
	   // DVB changed 15/09/06
	   newCntrl.isKindOf(GTE_ComboPorts) or
	   newCntrl.isKindOf(GTE_TextBox) then
//	   newCntrl.isKindOf(GTE_TimeEntry) then
		newCntrl.setPropertyValue('mySheet', pSheet);
	endif;
	
	newCntrl.automaticCellControl := pControl.automaticCellControl;

	return newCntrl;
end;</source>
        <access>protected</access>
        <Parameter name="pControl" type="Control"/>
        <Parameter name="pSheet" type="GTE_Sheet" usage="io"/>
        <ReturnType type="Control"/>
    </JadeMethod>
    <JadeMethod name="cloneSheet" id="0458f39b-9dee-4050-af9a-21fe1922575a">
        <updating/>
        <source>cloneSheet(pSheet : GTE_Sheet; pMainDef, pExtraDef : String) : GTE_Sheet updating, protected;

//--------------------------------------------------------------------------------------------
// 19/11/2009	cnwmh5		PAR21492 - add cmbSysSubType
// 14/04/2010	cnwdap1		PAR #23565 load consignor/consignee/freight forwarder combos here now
//										CMUI_Assistant::comboBoxConsignor is fixed to stop double loading
// 20/05/2013	cnwdap1		PAR #31574 Allowable Time Off Power editing
//--------------------------------------------------------------------------------------------
vars
	newSheet		: GTE_Sheet;
	tmpRow			: Integer;
	cntrl			: Control;
	newCntrl		: Control;
	tblMainCntrl	: CM_EntryTable;
	tblExtraCntrl	: CM_EntryTable;
	cargoTypeText	: String;
	assistant		: GTE_Assistant;
	inputSplitter	: CMUI_SplitContainer;
	comboId			: ComboBox;
	whArea			: CM_RowArea;			
	
	mainDef,
	extraDef		: EntTableDef;
	usedControls	: StringArray;
	dischargeCombo,
	transhipCombo	: GTE_ComboPorts;
	
begin
	assistant := self.myAssistant.GTE_Assistant;

	create usedControls transient;

	if pMainDef &lt;&gt; null then
		mainDef := app.myController.getEntTableDef(pMainDef);
		mainDef.allControls.copy(usedControls);
	endif;

	if pExtraDef &lt;&gt; null then
		extraDef := app.myController.getEntTableDef(pExtraDef);
		extraDef.allControls.copy(usedControls);
	endif;
	maxSheetId := maxSheetId + 1;

	newSheet := pSheet.loadControl(maxSheetId).GTE_Sheet;
	newSheet.setCaption('');
	newSheet.parent := fldInOut;
	newSheet.backColor := self.backColor;
	
	// clone the controls on the sheet
	
	inputSplitter := self.cloneControl(sptInput, newSheet).CMUI_SplitContainer;
	//newCntrl := self.cloneControl(btnDeleteSheet, newSheet);	// btnDelete is no longer on the sheet (rjs 25/5/01)

	if usedControls.includes(GTE_InOutForm::cmbBulkRelease.name) then
		newCntrl := self.cloneControl(cmbBulkRelease, newSheet);
		assistant.comboBoxBulkRelease(newCntrl.ComboBox, null);
	endif;
	
	if usedControls.includes(GTE_InOutForm::cmbCommodity.name) then
		newCntrl := self.cloneControl(cmbCommodity, newSheet);
		// DVB changed 30/09/04
//		assistant.comboBoxCommodity(newCntrl.ComboBox, null);
		newCntrl.CMUI_ComboCommodity.setObject(null);
	endif;

	if usedControls.includes(GTE_InOutForm::cmbGenSetType.name) then
		newCntrl := self.cloneControl(cmbGenSetType, newSheet);
	endif;
	
	if usedControls.includes(GTE_InOutForm::cmbConsignTop.name) then
		newCntrl := self.cloneControl(cmbConsignTop, newSheet);
		assistant.comboBoxConsignor(newCntrl.ComboBox, null, CONSIGNOR);
	endif;
	
	if usedControls.includes(GTE_InOutForm::cmbConsignee.name) then
		newCntrl := self.cloneControl(cmbConsignee, newSheet);
		//PAR14911 Was causing items to be populated twice.  Now relies on the control initialize instead. 26/9/2007
		// PAR #23565 fixed assistant.comboBoxConsignor to stop double loading
		assistant.comboBoxConsignor(newCntrl.ComboBox, null,CONSIGNEE);
	endif;
	
	
	if usedControls.includes(GTE_InOutForm::cmbConsignor.name) then
		newCntrl := self.cloneControl(cmbConsignor, newSheet);
		//PAR14911 Was causing items to be populated twice.  Now relies on the control initialize instead. 26/9/2007
		// PAR #23565 fixed assistant.comboBoxConsignor to stop double loading
		assistant.comboBoxConsignor(newCntrl.ComboBox, null, CONSIGNOR);
	endif;
	// 20/11/2006 par#12903 Mohammad
	if usedControls.includes(GTE_InOutForm::cmbFreightFwdr.name) then
		newCntrl := self.cloneControl(cmbFreightFwdr, newSheet);
		//PAR14911 Was causing items to be populated twice.  Now relies on the control initialize instead. 26/9/2007
		// PAR #23565 fixed assistant.comboBoxConsignor to stop double loading
		assistant.comboBoxConsignor(newCntrl.ComboBox, null, FREIGHT_FORWARDER);
	endif;
	
	if usedControls.includes(GTE_InOutForm::cmbCouISOType.name) then
		newCntrl := self.cloneControl(cmbCouISOType, newSheet);
		assistant.comboBoxISOType(newCntrl.ComboBox, null);
	endif;

	if usedControls.includes(GTE_InOutForm::cmbDestination.name) then
		newCntrl := self.cloneControl(cmbDestination, newSheet);
		newCntrl.CMUI_ComboPorts.myAssistant := self.myAssistant;
		newCntrl.CMUI_ComboPorts.showAllDestinations := true;
	//	assistant.comboBoxDestination(newCntrl.ComboBox, null);
	endif;
	
	if usedControls.includes(GTE_InOutForm::cmbDestTerminal.name) then
		newCntrl := self.cloneControl(cmbDestTerminal, newSheet);
		assistant.comboBoxDestTerminal(newCntrl.ComboBox, self.myTerminal, null);
	endif;		

	if usedControls.includes(GTE_InOutForm::cmbDischarge.name) then
		newCntrl := self.cloneControl(cmbDischarge, newSheet);
		dischargeCombo := newCntrl.GTE_ComboPorts;
		dischargeCombo.myAssistant := self.myAssistant;
		dischargeCombo.isDisabledPortCodeSelector := true;	// 20/05/2010 cnwar2 #24261
		
//		controller.comboBoxDischarge(newCntrl.ComboBox, null, null);
	endif;
	
	if usedControls.includes(GTE_InOutForm::cmbTranship.name) then		///cnwas3 ccms 1028
		newCntrl := self.cloneControl(cmbTranship, newSheet);
		transhipCombo := newCntrl.GTE_ComboPorts;
		transhipCombo.myAssistant := self.myAssistant;
	endif;
	
	if usedControls.includes(GTE_InOutForm::cmbHdlCntr1.name) then
		newCntrl := self.cloneControl(cmbHdlCntr1, newSheet);
	endif;
	if usedControls.includes(GTE_InOutForm::cmbHdlCntr2.name) then
		newCntrl := self.cloneControl(cmbHdlCntr2, newSheet);
	endif;
	if usedControls.includes(GTE_InOutForm::cmbHdlSubCntr1.name) then
		newCntrl := self.cloneControl(cmbHdlSubCntr1, newSheet);
	endif;
			
	if usedControls.includes(GTE_InOutForm::cmbISOType.name) then
		newCntrl := self.cloneControl(cmbISOType, newSheet);
	//	assistant.comboBoxISOType(newCntrl.ComboBox, null);
	endif;

	if usedControls.includes(GTE_InOutForm::cmbImexStatus.name) then
		newCntrl := self.cloneControl(self.cmbImexStatus, newSheet);
		assistant.comboBoxIMEXStatus(newCntrl.ComboBox, null);
	endif;	

	if usedControls.includes(GTE_InOutForm::cmbLoggingOrg.name) then
		newCntrl := self.cloneControl(self.cmbLoggingOrg, newSheet);
		newCntrl.CMUI_ComboLoggingOrg.initialise(true);						//cnwmc5 - 2 April 2014 - CCMS 1127
	endif;			

	if usedControls.includes(GTE_InOutForm::cmbLogLength.name) then
		newCntrl := self.cloneControl(cmbLogLength, newSheet);
		//assistant.comboBoxLogLength(newCntrl.ComboBox, null, null);
	endif;
	if usedControls.includes(GTE_InOutForm::cmbLogGrade.name) then
		newCntrl := self.cloneControl(cmbLogGrade, newSheet);
		//assistant.comboBoxLogGrade(newCntrl.ComboBox, null, null);
	endif;
	if usedControls.includes(GTE_InOutForm::cmbLogSpecies.name) then
		newCntrl := self.cloneControl(cmbLogSpecies, newSheet);
		//assistant.comboBoxLogSpecies(newCntrl.ComboBox, null, null);
	endif;
	if usedControls.includes(GTE_InOutForm::cmbDocketError.name) then //ccms 1110
		newCntrl := self.cloneControl(cmbDocketError, newSheet);
		assistant.comboBoxLogDocketError(newCntrl.ComboBox, null);
	endif;
	if usedControls.includes(GTE_InOutForm::cmbLogType.name) then
		newCntrl := self.cloneControl(cmbLogType, newSheet);
		//assistant.comboBoxLogType(newCntrl.ComboBox, null, null);
	endif;	
	if usedControls.includes(GTE_InOutForm::cmbMTGrade.name) then
	// CCMS 1235
		newCntrl := self.cloneControl(cmbMTGrade, newSheet);
//		assistant.comboBoxMTGrade(newCntrl.ComboBox, null);
	endif;

	if usedControls.includes(GTE_InOutForm::cmbAvGrade.name) then
		newCntrl := self.cloneControl(cmbAvGrade, newSheet);
		cmbAvGrade.setObject(null);
//		assistant.comboBoxAvailabilityGrade(newCntrl.ComboBox, null);
	endif;	
	
	if usedControls.includes(GTE_InOutForm::cmbCustomsAgent.name) then
		newCntrl := self.cloneControl(cmbCustomsAgent, newSheet);
		cmbCustomsAgent.setObject(null);
	endif;	
	
	if usedControls.includes(GTE_InOutForm::cmbOperator.name) then
		newCntrl := self.cloneControl(cmbOperator, newSheet);
		newCntrl.GTE_ComboOperator.setObject(null);
	// CCMS 1235
//		assistant.comboBoxOperator(newCntrl.ComboBox, null, null);
	endif;

	if usedControls.includes(GTE_InOutForm::cmbOperatorGroup.name) then
		newCntrl := self.cloneControl(cmbOperatorGroup, newSheet);
		assistant.comboBoxOperatorGroup(newCntrl.ComboBox, null, true);
	endif;

	if usedControls.includes(GTE_InOutForm::cmbProduct.name) then
		newCntrl := self.cloneControl(cmbProduct, newSheet);
		assistant.comboBoxProduct(newCntrl.CMUI_ComboBox, null, null, null);
		//cmbProduct.setObject(null);
	endif;
	if usedControls.includes(GTE_InOutForm::cmbScaler.name) then
		newCntrl := self.cloneControl(cmbScaler, newSheet);
//		assistant.comboBoxUser(newCntrl.ComboBox, null);
	endif;	
	if usedControls.includes(GTE_InOutForm::cmbSrcLocn.name) then
		newCntrl := self.cloneControl(cmbSrcLocn, newSheet);
		//assistant.comboBoxSrcLocn(newCntrl.ComboBox, null, null);
	endif;
	if usedControls.includes(GTE_InOutForm::cmbSrcSubLocn.name) then
		newCntrl := self.cloneControl(cmbSrcSubLocn, newSheet);
		//assistant.comboBoxSrcSubLocn(newCntrl.ComboBox, null, null);
	endif;
	if usedControls.includes(GTE_InOutForm::cmbSrcSubSubLocn.name) then
		newCntrl := self.cloneControl(cmbSrcSubSubLocn, newSheet);
		//assistant.comboBoxSrcSubSubLocn(newCntrl.ComboBox, null, null);
	endif;
	if usedControls.includes(GTE_InOutForm::cmbSupplier.name) then
		newCntrl := self.cloneControl(cmbSupplier, newSheet);
		assistant.comboBoxSupplier(newCntrl.ComboBox, null);
	endif;		
	if usedControls.includes(GTE_InOutForm::cmbStockOrder.name) then
		newCntrl := self.cloneControl(cmbStockOrder, newSheet);
		assistant.comboBoxStockOrderHeader(newCntrl.ComboBox, null, null);
	endif;			
		
	if usedControls.includes(GTE_InOutForm::cmbTI.name) then
		newCntrl := self.cloneControl(cmbTI, newSheet);
		// DVB changed 25/06/2007 to select id as it is type in
		newCntrl.GTE_ComboBox.style := 3;
		newCntrl.GTE_ComboBox.useManualDropDown := true;
		assistant.comboBoxTrackedItemCmb(newCntrl.ComboBox, TI_CargoType_Container, TI_STATE_NORMAL, null);
	endif;

	if usedControls.includes(GTE_InOutForm::cmbTiType.name) then
		newCntrl := self.cloneControl(cmbTiType, newSheet);
		assistant.comboBoxCargoBolType(newCntrl.ComboBox, app.myPassport.getDefaultCargoBOLTypeId(), true, true, true, true);
		// This is the new one for after 7.4.1 release
		//assistant.comboBoxCargoBOLTypeGate(newCntrl.ComboBox, app.myPassport.getDefaultCargoBOLTypeId(), true, true, true);
		cargoTypeText := newCntrl.ComboBox.text;
	endif;
	
// cnwdad1 13/05/2009 - CCMS 1735.
	if app.isSubTerminalsOn(self.myTerminal) then
		if usedControls.includes(GTE_InOutForm::cmbSubTerminal.name) then
			newCntrl := self.cloneControl(cmbSubTerminal, newSheet);
			assistant.comboBoxSubTerminal(newCntrl.ComboBox, null, self.myTerminal);
		endif;		
	endif;
	
	if usedControls.includes(GTE_InOutForm::cmbTerminal.name) then
		newCntrl := self.cloneControl(cmbTerminal, newSheet);
		assistant.comboBoxTerminal(newCntrl.ComboBox, null, null);
	endif;		

	if usedControls.includes(GTE_InOutForm::cmbRowArea.name) then
		newCntrl := self.cloneControl(cmbRowArea, newSheet);
		assistant.comboBoxRowArea(newCntrl.ComboBox, whArea);
	endif;
	
	if usedControls.includes(GTE_InOutForm::cmbTermArea.name) then
		newCntrl := self.cloneControl(cmbTermArea, newSheet);
		assistant.comboBoxTerminalArea(newCntrl.ComboBox, TA_TYPE_BLOCK_STACK, null);
	endif;
	if usedControls.includes(GTE_InOutForm::cmbTreatment.name) then
		newCntrl := self.cloneControl(cmbTreatment, newSheet);
		//assistant.comboBoxLogTreatment(newCntrl.ComboBox, null, null);
	endif;							

	if usedControls.includes(GTE_InOutForm::cmbVoyage.name) then
		newCntrl := self.cloneControl(cmbVoyage, newSheet);
//		assistant.comboBoxVoyageCode(newCntrl.ComboBox, null, false);
		assistant.comboBoxVoyageCurrent(newCntrl.ComboBox,
										self.myTerminal.getNullVoyage(),
										true,
										false,
										false,
										true,
										true,
										true,
										true,
										false,
										true);
		newCntrl := self.cloneControl(cmbVoyage2, newSheet);
//		assistant.comboBoxVoyageCodeNote(newCntrl.CMUI_ComboForVoyageActive, null);
		assistant.comboBoxVoyageCurrent(self.cmbVoyage2,
										self.myTerminal.getNullVoyage(),
										true,
										false,
										false,
										true,
										true,
										true,
										true,
										false,
										true);
	endif;

	if usedControls.includes(GTE_InOutForm::lstDischarge.name) then
		newCntrl := self.cloneControl(lstDischarge, newSheet);
		assistant.listTableDischarge(newCntrl.CMUI_ListTable, null, null);
	endif;
/*	CCMS 1203 JC
	if usedControls.includes(GTE_InOutForm::lstHazard.name) then
		newCntrl := self.cloneControl(lstHazard, newSheet);
		assistant.listTableHazard(newCntrl.CMUI_ListTable);
	endif;
*/
	if usedControls.includes(GTE_InOutForm::lstHazardList.name) then
		newCntrl := self.cloneControl(lstHazardList, newSheet);
		//assistant.listTableHazard(newCntrl.CMUI_ListTable);
	endif;

	if usedControls.includes(GTE_InOutForm::lstMTGrade.name) then
		newCntrl := self.cloneControl(lstMTGrade, newSheet);
		assistant.listTableMTGrade(newCntrl.CMUI_ListTable, null, null);
	endif;

	if usedControls.includes(GTE_InOutForm::txtBookingRef.name) then
		newCntrl := self.cloneControl(txtBookingRef, newSheet);
	endif;
	
	//AER 13/03/2008 CCMS 1003
	if usedControls.includes(GTE_InOutForm::cmbBRItem.name) then
		newCntrl := self.cloneControl(cmbBRItem, newSheet);
	endif;
	
//	if usedControls.includes(GTE_InOutForm::txtFellDate.name) then
//		newCntrl := self.cloneControl(txtFellDate, newSheet);
//	endif;
	
//	if usedControls.includes(GTE_InOutForm::txtPackTime.name) then
//		newCntrl := self.cloneControl(txtPackTime, newSheet);
//	endif;

//	if usedControls.includes(GTE_InOutForm::txtTimeOffPower.name) then
//		newCntrl := self.cloneControl(txtTimeOffPower, newSheet);
//	endif;

	if usedControls.includes(GTE_InOutForm::txtQuantity.name) then
		newCntrl := self.cloneControl(txtQuantity, newSheet);
	endif;
	if usedControls.includes(GTE_InOutForm::txtDPCount.name) then
		newCntrl := self.cloneControl(txtDPCount, newSheet);
		//self.tblExtra.hideRowByName(ETRow_DriversPieceCount,false);
	endif;

	if usedControls.includes(GTE_InOutForm::txtTrackedItemID.name) then
		newCntrl := self.cloneControl(txtTrackedItemID, newSheet);
	endif;
	if usedControls.includes(GTE_InOutForm::cmbLogLocation.name) then
		newCntrl := self.cloneControl(cmbLogLocation, newSheet);
		assistant.comboBoxLocationControllers(newCntrl.ComboBox, null, false);
	endif;
	
	if usedControls.includes(GTE_InOutForm::cmbLogOperation.name) then
		newCntrl := self.cloneControl(cmbLogOperation, newSheet);
		//assistant.comboBoxLocationControllers(newCntrl.ComboBox, null);
	endif;
	
	// 23/02/2010 cnwar2 #22457
	if usedControls.includes(GTE_InOutForm::cmbTrailerType.name) then
		newCntrl := self.cloneControl(cmbTrailerType, newSheet);
	endif;
	
	if usedControls.includes(GTE_InOutForm::txtTimeOffPower.name) then	// PAR #31574
		newCntrl := self.cloneControl(txtTimeOffPower, newSheet);		// PAR #31574
	endif;																// PAR #31574

	// 19/11/2009 cnwmh5 par21492 - Start
	//if usedControls.includes(GTE_InOutForm::cmbSysSubType.name) then
	newCntrl := self.cloneControl(cmbSysSubType, newSheet);
	assistant.comboboxSysSubType(null, null, null, newCntrl.CMUI_ComboBox, self.tblExtra);
	//endif;
	// 19/11/2009 cnwmh5 par21492 - End
	
	tblMainCntrl := tblMain.loadControl(maxSheetId).CM_EntryTable;
	tblMainCntrl.parent := inputSplitter;
	newSheet.myTblMain := tblMainCntrl;
	newSheet.allControlsByName.add(tblMainCntrl);
	tblMainCntrl.warningMethod := GTE_InOutForm::entTableWarning.name;
	tblMainCntrl.optimiseRowHeight := true;

	tblExtraCntrl := tblExtra.loadControl(maxSheetId).CM_EntryTable;
	tblExtraCntrl.parent := inputSplitter;
	newSheet.myTblExtra := tblExtraCntrl;
	newSheet.allControlsByName.add(tblExtraCntrl);
	tblExtraCntrl.warningMethod := GTE_InOutForm::entTableWarning.name;
	tblExtraCntrl.optimiseRowHeight := true;

	if pExtraDef = null then
		tblExtraCntrl.visible := false;
	endif;

	inputSplitter.setupChildControls();

	newSheet.visible := true;
	newSheet.showMySheet;

	// Setup the tables after cloning all the controls
	// as the cells may use cloned controls.

	if mainDef &lt;&gt; null then
		self.initEntryTable(tblMainCntrl, mainDef);
		tblMainCntrl.setValueByName(ETRow_CargoType, cargoTypeText);
	endif;

	if extraDef &lt;&gt; null then
		self.initEntryTable(tblExtraCntrl, extraDef);
	endif;

	assistant.mainExtraSplitterRatio(tblMainCntrl, tblExtraCntrl, inputSplitter);
	assistant.mainExtraSyncColWidths(tblMainCntrl, tblExtraCntrl);	

	self.fldInOut.initSheetBackColors();
	
// cnwdad1 13/05/2009 - CCMS 1735.
	if not app.isSubTerminalsOn(self.myTerminal) then
		tblExtraCntrl.hideRowByName(ETRow_MySubTerminal, false);
	endif;
	
	return newSheet;
epilog
	if usedControls &lt;&gt; null then
		delete usedControls;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pSheet" type="GTE_Sheet"/>
        <Parameter name="pMainDef" type="String"/>
        <Parameter name="pExtraDef" type="String"/>
        <ReturnType type="GTE_Sheet"/>
    </JadeMethod>
