    </JadeMethod>
    <JadeMethod name="initHandHeldDebugApp" id="9fe12fed-bf3f-4015-920b-d5b3514dc6a5">
        <updating/>
        <source>initHandHeldDebugApp() updating;
// start from app.debugApplication.  Device is passed in a shared transient CM_ViewObjectColour
vars
	param	: CM_ViewObjectColour;
	device	: CM_Object;
	oa		: ObjectArray;
	obj		: Object;
begin
	param := CM_ViewObjectColour.firstProcessTransientInstance();
	create oa transient;
	CM_ViewObjectColour.allSharedTransientInstances(oa, 999999, false);
	foreach obj in oa do
		param := obj.CM_ViewObjectColour;
		break;
	endforeach;
	if param = null then
		terminate;
	else
		device := param.myObject;
		beginTransientTransaction;
		delete param;
		commitTransientTransaction;
		self.initialiseHandHeldWithDevApp(device);
	endif;
epilog
	delete oa;
end;
</source>
    </JadeMethod>
    <JadeMethod name="initVehicleMountAppWithDevice" id="2b814309-cd3c-4836-a4ab-2c396af2a6ba">
        <updating/>
        <source>initVehicleMountAppWithDevice(_device : Object )updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 April 2010	cnwer1	Initial creation

*/

vars
	errorStr : String;
begin
	self.initialize();
	self.setIsBackGroundApp(true);
	self.isRTApp:=true;  //epr par 25190 
	
	self.getTerminalRTDeviceOpenMax("VehicleMountedApp", _device.CM_RadioTelemetryDevice);			// 31/08/2011 cnwmh5 #28091
	
	create self.myLogonAgent as VehicleMountedLogonAgent;
	self.myLogonAgent.initWithDevice(_device.CM_RadioTelemetryDevice);
	
	
	//check this first don't make user type in login details if not setup
	if not self.myLogonAgent.validateRTDeviceDetails(errorStr) then
		if errorStr &lt;&gt; null then
			app.msgBox(errorStr,app.getErrorString(Logon_error), MsgBox_Exclamation_Mark_Icon);
			terminate;
		endif;
	endif;
	
	//epr par 29196 1/3/12
	if self.myLogonAgent.myTerminal.myRTVehicleConfig = null then
		// give error  need to set up the RT Vehicle Config
		app.msgBox(app.getErrorString(Cannot_start_VehicleRTConfig),app.getErrorString(Logon_error), MsgBox_Exclamation_Mark_Icon);
		terminate;
	endif;
	
	create self.myVMAgent transient;
	self.myVMAgent.setDetailsFromLogonAgent(self.myLogonAgent.VehicleMountedLogonAgent);
	//epr par 33147 6/12/13
	self.myLogonAgent.setMediator(self.myVMAgent.myMediator);
	
	if app.myPassport.hasErrors then
		app.msgBox(app.myPassport.allErrors.first.text,app.getErrorString(Logon_error), MsgBox_Exclamation_Mark_Icon);
			terminate;
	endif;
	
	create self.myHandHeldCheckerAgent transient;	//06 May 2013	NDL	Par 31506
	
	
epilog
	
end;</source>
        <Parameter name="_device" type="Object"/>
    </JadeMethod>
    <JadeMethod name="initVehicleMountedDebugApp" id="3f6fad3b-b0c2-461e-9d2b-6b393f9c0d6f">
        <updating/>
        <source>initVehicleMountedDebugApp() updating;
// start from app.debugApplication.  Device is passed in a shared transient CM_ViewObjectColour
vars
	param	: CM_ViewObjectColour;
	device	: CM_Object;
	oa		: ObjectArray;
	obj		: Object;
begin
	param := CM_ViewObjectColour.firstProcessTransientInstance();
	create oa transient;
	CM_ViewObjectColour.allSharedTransientInstances(oa, 999999, false);
	foreach obj in oa do
		param := obj.CM_ViewObjectColour;
		break;
	endforeach;
	if param = null then
		terminate;
	else
		device := param.myObject;
		beginTransientTransaction;
		delete param;
		commitTransientTransaction;
		self.initVehicleMountAppWithDevice(device);
	endif;
epilog
	delete oa;
end;
</source>
    </JadeMethod>
    <JadeMethod name="initialiseHandHeldApp" id="469252c0-03f1-410d-8c87-1751d4853129">
        <updating/>
        <source>initialiseHandHeldApp() updating;
// ---------------------------------------------------------------------------
// Created:	28 November 2008 By Graeme Black cnwgb1
// Status: 	Unfinished
// Purpose:	
// ---------------------------------------------------------------------------
begin
	self.initialize();
	self.getTerminalRTDeviceOpenMax(HandHeldAppIniFileSection, null);			// 31/08/2011 cnwmh5 #28091
	create self.myEnquiryAgent transient;
	create self.myMobileGUIAgent as MOB_HandHeldAgent;
	create self.myLogonAgent as HandHeldLogonAgent;
	self.myLogonAgent.initWithDevice(null);
	self.myMobileGUIAgent.setHomeForm(MOB_HandHeldMenuForm);
	create self.myHandHeldCheckerAgent transient;	// 25 Jan 2010	NDL	CCMS MES 1005
	/*
	self.myMobileGUIAgent.setHelpDescription(CrLf &amp;
			'Function Keys' &amp; CrLf &amp; CrLf &amp;
			'F1 - toggle help' &amp; CrLf &amp;
			'F3 - undo completed slot' &amp; CrLf &amp;
			'F4 - toggle twin lift' &amp; CrLf &amp;
			'F5 - refresh');*/
end;
</source>
    </JadeMethod>
