    <JadeMethod name="runReport" id="a83ab3c3-c228-44cb-9623-9712ea9aa761">
        <source>runReport();

/*
Date			Who		Reason
28 July 2016	cnwar2	Initial creation

*/
vars
	
begin
	if optCSV.value then
		runReportCSV();
	elseif optCSVMonthly.value then
		runReportMonthly();
	elseif optPrinter.value then
		runReportPrinter();
	endif;
			
end;</source>
    </JadeMethod>
    <JadeMethod name="runReportCSV" id="59ab81b3-ebce-4065-81fb-5700ba48b931">
        <source>runReportCSV();

/*
Date			Who		Reason
03 August 2016	cnwar2	Initial creation

*/
vars
	file 	 	 : File;
	line, line1	 : String;
	contact  	 : DEV_SupportContact;
	state	 	 : DEV_SupportState;
	timezone 	 : DEV_SupportTimezone;
	first 		 : Boolean;
	ts			 : TimeStamp;
	
begin
	if txtFileName.text = '' then
		app.msgBox('No file path entered', 'Error', 48);
		return;
	endif;

	create file;
	file.fileName := txtFileName.text;
	file.kind := File.Kind_Unknown_Text;
	if not file.tryOpen() then
		app.msgBox('Unable to open file', 'Error', 48);
		return;
	endif;
		
	first := true;
	foreach contact in self.myRoot.allContacts do
	
		// Parameters
		if self.cmbCustomerRpt.text &lt;&gt; '*ALL*' and contact.customer &lt;&gt; self.cmbCustomerRpt.text then
			continue;
		endif;
		if self.cmbOwnerRpt.text &lt;&gt; '*ALL*' and contact.owner &lt;&gt; self.cmbOwnerRpt.text then
			continue;
		endif;
		if self.cmbTimezone.text &lt;&gt; '*ALL*' and contact.myTimezone.name &lt;&gt; self.cmbTimezone.text then
			continue;
		endif;
		if self.txtOpenedStart.text &lt;&gt; '' and contact.openedTS.Date &lt; self.txtOpenedStart.text.Date then
			continue;
		endif;
		if self.txtOpenedEnd.text &lt;&gt; '' and contact.openedTS.Date &gt; self.txtOpenedEnd.text.Date then
			continue;
		endif;
		if self.txtClosedStart.text &lt;&gt; '' then
			if contact.getCurrentState &lt;&gt; 'Closed' then
				continue;
			endif;
			if contact.allStates.last.startTS.Date &lt; self.txtClosedStart.text.Date then
				continue;
			endif;
		endif;
		if self.txtClosedEnd.text &lt;&gt; '' then
			if contact.getCurrentState &lt;&gt; 'Closed' then
				continue;
			endif;
			if contact.allStates.last.startTS.Date &gt; self.txtClosedEnd.text.Date then
				continue;
			endif;
		endif;
		if chkFailedKPI1.value and contact.kpi1FailedBy = '' then
			continue;
		endif;
		if chkFailedKPI2.value and contact.kpi2FailedBy = '' then
			continue;
		endif;
		if chkFailedKPI3.value and contact.kpi3FailedBy = '' then
			continue;
		endif;
	
		// Details
		line  := '';
		line1 := '';
		if chkContact.value then
			line1 := line1 &amp; 'Contact/PAR Number';
			line  := line &amp; contact.number.String &amp; Tab;
		endif;
		if chkTFS.value then
			line1 := line1 &amp; 'TFS Number';
			line  := line &amp; contact.tfsNumber.String &amp; Tab;
		endif;
		if chkCustomer.value then
			line1 := line1 &amp; 'Customer';
			line  := line &amp; contact.customer &amp; Tab;
		endif;
		if chkTimezone.value then
			line1 := line1 &amp; 'Timezone';
			line  := line &amp; contact.myTimezone.name &amp; Tab;
		endif;
		if chkOwner.value then
			line1 := line1 &amp; 'Owner';
			line  := line &amp; contact.owner &amp; Tab;
		endif;
		if chkDescription.value then
			line1 := line1 &amp; 'Description';
			line  := line &amp; contact.description &amp; Tab;
		endif;
		if chkDescription.value then
			line1 := line1 &amp; 'Topic';
			line  := line &amp; contact.topic &amp; Tab;
		endif;
		if chkDescription.value then
			line1 := line1 &amp; 'Release Opened';
			line  := line &amp; contact.releaseOpened &amp; Tab;
		endif;
		if chkOpened.value then
			line1 := line1 &amp; 'Date/Time Opened';
			line  := line &amp; contact.openedTS.String &amp; Tab;
		endif;
		if chkMovedToDev.value then
			line1 := line1 &amp; 'Date/Time Moved to Development';
			ts 	  := contact.getMovedToDevTS();
			if ts.isValid then
				line := line &amp; ts.String &amp; Tab;
			else
				line := line &amp; Tab;
			endif;
		endif;
		if chkClosed.value then
			line1 := line1 &amp; 'Date/Time Closed';
			if contact.getCurrentState = 'Closed' then
				line := line &amp; contact.allStates.last.startTS.String &amp; Tab;
			else
				line := line &amp; Tab;
			endif;
		endif;
		if chkKPI1.value then
			line1 := line1 &amp; 'KPI1 Initial Call';
			line  := line &amp; contact.getKPI1Report() &amp; Tab;
		endif;
		if chkKPI2.value then
			line1 := line1 &amp; 'KPI2 Plan of Action';
			line  := line &amp; contact.getKPI2Report() &amp; Tab;
		endif;
		if chkKPI3.value then
			line1 := line1 &amp; 'KPI3 Resolution';
			line  := line &amp; contact.getKPI3Report() &amp; Tab;
		endif;
		if chkDuration.value then
			line1 := line1 &amp; 'Total Duration';
			line  := line &amp; contact.getTotalDuration() &amp; Tab;
		endif;
		if chkRemarks.value then
			line1 := line1 &amp; 'Remarks';
			line  := line &amp; contact.remarks.removeTabCrLfs() &amp; Tab;
		endif;
		
		if first then
			file.writeLine(line1);
			first := false;
		endif;
		file.writeLine(line);
	endforeach;
	
	app.msgBox('Report printed successfully', 'Error', 0);
epilog
	file.close();
	delete file;
end;</source>
    </JadeMethod>
    <JadeMethod name="runReportMonthly" id="bcf0b800-7fe3-4c37-be54-c80444540bcf">
        <source>runReportMonthly();

/*
Date			Who		Reason
08 August 2016	cnwar2	Initial creation

*/
vars
	file 	 	 : File;
	contact  	 : DEV_SupportContact;
	state	 	 : DEV_SupportState;
	timezone 	 : DEV_SupportTimezone;
	ts			 : TimeStamp;
	startDate, endDate : Date;
	line, movedToDev, closed, releasePatched, supportEndDate, 
	supportTimeTaken, devTimeTaken, releaseReleased, custWaitTime : String;
	
begin
	if txtFileName.text = '' then
		app.msgBox('No file path entered', 'Error', 48);
		return;
	endif;

	create file;
	file.fileName := txtFileName.text;
	file.kind := File.Kind_Unknown_Text;
	if not file.tryOpen() then
		app.msgBox('Unable to open file', 'Error', 48);
		return;
	endif;
		
	startDate := app.actualTimeServer().date;
	if startDate.month = 1 then
		startDate.setDate(1,12,startDate.year-1);
	else
		startDate.setDate(1,startDate.month-1,startDate.year);
	endif;
	if startDate.month = 12 then
		endDate.setDate(31,startDate.month,startDate.year);
	else
		endDate.setDate(1,startDate.month+1,startDate.year);
		endDate := endDate - 1;
	endif;
	
	
	//------------------------------------------------
	line := "CONTACTS OPENED between " &amp; startDate.String &amp; " and " &amp; endDate.String;
	file.writeLine(line);
	
	line := 'Number' &amp; Tab &amp; 'Customer' &amp; Tab &amp; 'Description' &amp; Tab &amp; 'Topic' &amp; Tab &amp; 'Opened' &amp; Tab &amp; 'Release Opened' &amp; Tab &amp; 'State' &amp; Tab &amp; 
			'Moved to Dev' &amp; Tab &amp; 'Closed' &amp; Tab &amp; 'Release Patched' &amp; Tab &amp; 'Support End Date' &amp; Tab &amp; 'Support Time Taken';
	file.writeLine(line);
	foreach contact in self.myRoot.allContacts do
	
		// Parameters
		if contact.openedTS.Date &lt; startDate then
			continue;
		endif;
		if contact.openedTS.Date &gt; endDate then
			continue;
		endif;
	
		// Details
		if contact.getCurrentState = 'Closed' then
			closed := contact.allStates.last.startTS.String;
		else
			closed := "";
		endif;
		ts := contact.getMovedToDevTS();
		if ts.isValid then
			movedToDev 		:= ts.String;
			supportEndDate  := movedToDev;
		else
			movedToDev 		:= "";
			supportEndDate 	:= closed;
		endif;
		if supportEndDate = "" then
			supportTimeTaken := "NA";
		else
			supportTimeTaken := (supportEndDate.TimeStamp.date - contact.openedTS.date).String;
		endif;
		if movedToDev = "" or closed = "" then
			releasePatched := "";
		else
			releasePatched := self.getReleasePatched(closed);
		endif;
		
		line  := contact.number.String &amp; Tab &amp; contact.customer &amp; Tab &amp; contact.description &amp; Tab &amp; contact.topic &amp; Tab &amp;
				 contact.openedTS.String &amp; Tab &amp; contact.releaseOpened &amp; Tab &amp; contact.getCurrentState() &amp; Tab &amp; movedToDev &amp; Tab &amp;
				 closed &amp; Tab &amp; releasePatched &amp; Tab &amp; supportEndDate &amp; Tab &amp; supportTimeTaken;
					
		file.writeLine(line);
	endforeach;
	
	
	//------------------------------------------------
	file.writeLine(CrLf);
	line := "PARS PATCHED between " &amp; startDate.String &amp; " and " &amp; endDate.String;
	file.writeLine(line);
	
	line := 'Number' &amp; Tab &amp; 'Customer' &amp; Tab &amp; 'Description' &amp; Tab &amp; 'Topic' &amp; Tab &amp; 'Opened' &amp; Tab &amp; 'Release Opened' &amp; Tab &amp; 'State' &amp; Tab &amp; 
			'Moved to Dev' &amp; Tab &amp; 'Closed' &amp; Tab &amp; 'Release Patched' &amp; Tab &amp; 'Dev Time Taken' &amp; Tab &amp; 'Release Released Date' &amp; Tab &amp; 'Customer Wait Time';
	file.writeLine(line);
	
	foreach contact in self.myRoot.allContacts do
	
		// Parameters
		if contact.getCurrentState() &lt;&gt; 'Closed' then
			continue;
		endif;
		ts := contact.getMovedToDevTS();
		if not ts.isValid then
			continue;	// closed as contact
		endif;
		movedToDev := ts.String;
		ts := contact.allStates.last.startTS;	// closure date
		if ts.Date &lt; startDate then
			continue;
		endif;
		if ts.Date &gt; endDate then
			continue;
		endif;
	
		// Details
		closed 			:= contact.allStates.last.startTS.String;
		devTimeTaken 	:= (closed.TimeStamp.date - movedToDev.TimeStamp.date).String;
		releasePatched 	:= self.getReleasePatched(closed);
		releaseReleased := self.getReleaseReleased(releasePatched);
		custWaitTime 	:= (releaseReleased.Date - contact.openedTS.date).String;
		
		line  := contact.number.String &amp; Tab &amp; contact.customer &amp; Tab &amp; contact.description &amp; Tab &amp; contact.topic &amp; Tab &amp;
				 contact.openedTS.String &amp; Tab &amp; contact.releaseOpened &amp; Tab &amp; contact.getCurrentState() &amp; Tab &amp; movedToDev &amp; Tab &amp;
				 closed &amp; Tab &amp; releasePatched &amp; Tab &amp; devTimeTaken &amp; Tab &amp; releaseReleased &amp; Tab &amp; custWaitTime;
				 
		file.writeLine(line);
	endforeach;
	
		
	app.msgBox('Report printed successfully', 'Error', 0);
epilog
	file.close();
	delete file;
end;</source>
    </JadeMethod>
    <JadeMethod name="runReportPrinter" id="e831564b-3de3-48b1-aebe-6cd406647b55">
        <source>runReportPrinter();

/*
Date			Who		Reason
03 August 2016	cnwar2	Initial creation

*/
vars
	contact			: DEV_SupportContact;
	jrwManager	 	: JadeReportWriterManager;
	jrwReport	 	: JadeReportWriterReport;
	reportString 	: String;
	numberOfCopies	: Integer;
	printPreview	: Boolean;
	
begin
	beginTransaction;
	self.myRoot.allContactsRpt.clear;
	foreach contact in self.myRoot.allContacts do
	
		// Parameters
		if self.cmbCustomerRpt.text &lt;&gt; '*ALL*' and contact.customer &lt;&gt; self.cmbCustomerRpt.text then
			continue;
		endif;
		if self.cmbOwnerRpt.text &lt;&gt; '*ALL*' and contact.owner &lt;&gt; self.cmbOwnerRpt.text then
			continue;
		endif;
		if self.cmbTimezone.text &lt;&gt; '*ALL*' and contact.myTimezone.name &lt;&gt; self.cmbTimezone.text then
			continue;
		endif;
		if self.txtOpenedStart.text &lt;&gt; '' and contact.openedTS.Date &lt; self.txtOpenedStart.text.Date then
			continue;
		endif;
		if self.txtOpenedEnd.text &lt;&gt; '' and contact.openedTS.Date &gt; self.txtOpenedEnd.text.Date then
			continue;
		endif;
		if self.txtClosedStart.text &lt;&gt; '' then
			if contact.getCurrentState &lt;&gt; 'Closed' then
				continue;
			endif;
			if contact.allStates.last.startTS.Date &lt; self.txtClosedStart.text.Date then
				continue;
			endif;
		endif;
		if self.txtClosedEnd.text &lt;&gt; '' then
			if contact.getCurrentState &lt;&gt; 'Closed' then
				continue;
			endif;
			if contact.allStates.last.startTS.Date &gt; self.txtClosedEnd.text.Date then
				continue;
			endif;
		endif;
		if chkFailedKPI1.value and contact.kpi1FailedBy = '' then
			continue;
		endif;
		if chkFailedKPI2.value and contact.kpi2FailedBy = '' then
			continue;
		endif;
		if chkFailedKPI3.value and contact.kpi3FailedBy = '' then
			continue;
		endif;
		self.myRoot.allContactsRpt.add(contact);
	endforeach;
	commitTransaction;
	
	app.printer.setPrinter(cmbPrinter.text);
	numberOfCopies 	:= 1;	 // txtPrintCopies.text.Integer;
	printPreview	:= true; // chkPrintPreview.value;
	
	reportString := 'KPIStatsReport';
	create jrwManager transient;
	jrwReport := jrwManager.getReport(reportString);
	if jrwReport = null then
		app.msgBox('Cannot find JRW report design "' &amp; reportString &amp; '"', 'Error', 48);
		return;
	endif;
	
	jrwReport.setOutputDestination(JadeReportWriterReport.PRINTER);
		
	jrwReport.setPageOptions(Print_A4, Print_Portrait, numberOfCopies, 0, 0, 0, 20, 0, false, 0);
	if printPreview then
		jrwReport.setPreviewOptions(true, true, false, true, null);
	endif;
	
	jrwReport.setParameter('openedStart', self.txtOpenedStart.text);
	jrwReport.setParameter('openedEnd', self.txtOpenedEnd.text);
	jrwReport.setParameter('closedStart', self.txtClosedStart.text);
	jrwReport.setParameter('closedEnd', self.txtClosedEnd.text);
	jrwReport.setParameter('customer', self.cmbCustomerRpt.text);
	jrwReport.setParameter('timezone', self.cmbTimezone.text);
	jrwReport.setParameter('owner', self.cmbOwnerRpt.text);
	jrwReport.setParameter('KPI1', self.chkFailedKPI1.value.getYesNo);
	jrwReport.setParameter('KPI2', self.chkFailedKPI2.value.getYesNo);
	jrwReport.setParameter('KPI3', self.chkFailedKPI3.value.getYesNo);

	jrwReport.run;
	
epilog
	delete jrwReport;
	delete jrwManager;
end;</source>
    </JadeMethod>
    <JadeMethod name="tblClosed_click" id="7d75bacb-1e6a-47e4-9f7f-3961259be2c8">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblClosed_click(table: Table input) updating;

/*
Date			Who		Reason
13 July 2016	cnwar2	Initial creation

*/
vars
	contactNum  : String;
	contact		: DEV_SupportContact;
	state		: DEV_SupportState;
	startTS,
	endTS		: String;
	logging		: String;
	
begin
	self.lblItemHistoryClosed.caption 	:= "Item History";
	self.lblRemarksClosed.caption 		:= "Remarks";
	self.tblClosedHistory.rows 			:= 1;
	self.txtRemarksClosed.text			:= "";
	
	contactNum := self.tblClosed.accessCell(tblClosed.row,1).text;
	
	if not contactNum.isInteger then
		return;
	endif;
	
	myCurrentContact := self.myRoot.allContacts.getAtKey(contactNum.Integer);
	if myCurrentContact = null then
		return;
	endif;
	
	self.lblItemHistoryClosed.caption 	:= "Item History - Contact " &amp; myCurrentContact.number.String;
	self.lblRemarksClosed.caption 		:= "Remarks - Contact " &amp; myCurrentContact.number.String;
	self.txtRemarksClosed.text			:= myCurrentContact.remarks;
	
	foreach state in myCurrentContact.allStates do
		startTS := state.startTS.date.format("dd/MM") &amp; " " &amp; state.startTS.time.format("HH:mm");
		if state.endTS.isValid then
			endTS 	 := state.endTS.date.format("dd/MM") &amp; " " &amp; state.endTS.time.format("HH:mm");
		else
			endTS := "----";
		endif;
		
	
		self.tblClosedHistory.addItem(state.type &amp; Tab &amp; startTS &amp; Tab &amp; endTS &amp; Tab &amp; state.getDurationStr(logging));
		
		if state.type = 'Pending Response' then
			self.tblClosedHistory.accessRow(self.tblClosedHistory.rows).backColor := #DDDDDD;
		endif;
		if state.type = 'Active Support' then
			self.tblClosedHistory.accessRow(self.tblClosedHistory.rows).backColor := #FFBBBB;
		endif;
		if state.type = 'Architect/Dev Support' then
			self.tblClosedHistory.accessRow(self.tblClosedHistory.rows).backColor := #FFBBFF;
		endif;
		if state.type = 'Active Development' then
			self.tblClosedHistory.accessRow(self.tblClosedHistory.rows).backColor := #FFDDDD;
		endif;
		if state.type = 'Closed' then
			self.tblClosedHistory.accessRow(self.tblClosedHistory.rows).backColor := #AAAAAA;
		endif;
	endforeach;
	
	
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblClosed_dblClick" id="c66128b3-28b7-4a00-8e03-81fb48a48c81">
