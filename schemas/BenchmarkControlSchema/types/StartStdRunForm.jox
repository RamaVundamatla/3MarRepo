    <JadeMethod name="doGoCreateJobFile" id="161f5f66-5257-4b96-8188-b61efab9a71f">
        <updating/>
        <source>doGoCreateJobFile() updating;

vars
	folder,archiveid,totalRun,s:String;
	f:File;
	i,j:Integer;
begin
	addResults(null);
	s := txtRunid.text; //7012
	if s.cnContains("\") then
		i := s.pos("\", 1);
		s := s[i+1:end];
	endif;
	
	uniqueId := cmbProduct.text &amp; '_'
			&amp; app.actualTimeAppServer.date.format('yyyyMMdd') &amp; '_'
			&amp; app.actualTimeAppServer.time.format('HHmmss') &amp; '_'
			&amp; s;
	app.setEmailAddress;	
	totalRun := cmbTotalRuns.text;
	create f;
	//f.fileName := '\\cnwchcs118\jobs\' &amp; targetHost &amp; '\creatorout\creator' &amp; uniqueId &amp; '.job';
	f.fileName := '\\cnwchcs118\jobs\' &amp; targetHost &amp; '\creatorout\' &amp; app.computerName[4:3].toLower &amp; '_' &amp; uniqueId &amp; '.job';
	f.usePresentationFileSystem := false;  // on Creator machine
	f.mode := File.Mode_Output;
	addResults('creating ' &amp; f.fileName);
	f.writeLine('InitSession '&amp;uniqueId&amp; ',"C:\thinbin\creator\jade.exe","appServer=cnwchcs118.cnw.co.nz appServerPort=51824 schema=BenchmarkControlSchema app=DoCommand endjade '&amp;
				';InitSession;'&amp;cmbProduct.text&amp;';'&amp;uniqueId&amp;';'&amp;cmbArchive.text.replace(".rar", "")&amp;';'&amp;app.actualTimeAppServer.date.format('yyyyMMdd')&amp;'_'&amp;cmbRapHost.text[7:3]&amp;'\'&amp;txtRunid.text
	            &amp;';v:\AutoRunArchives\'&amp;cmbProduct.text&amp;'\'&amp;cmbArchive.text&amp;';'&amp;app.myEmailAddress&amp;';'&amp;clientMachines.String&amp;';'&amp;cmbTotalRuns.text&amp;';",,5,,,,');
	
	f.writeLine('BmkStdRun extract 1 '&amp;uniqueId&amp; ',"C:\thinbin\creator\jade.exe","appServer=cnwchcs118.cnw.co.nz appServerPort=51824 schema=BenchmarkControlSchema app=BmkStdRun",,90,,,,');			
	foreach j in 1 to cmbTotalRuns.text.Integer do 
		f.writeLine('BmkStdRun run '&amp;j.String&amp; ' '&amp;uniqueId&amp; ',"C:\thinbin\creator\jade.exe","appServer=cnwchcs118.cnw.co.nz appServerPort=51824 schema=BenchmarkControlSchema app=BmkStdRun",,90,,,,');
	endforeach;
	f.close;

	f.mode := File.Mode_Input;
	while not f.endOfFile do
		addResults(f.readLine);
	endwhile;
	f.close;
epilog
	delete f;
end;</source>
    </JadeMethod>
    <JadeMethod name="doGoCreateJobFile_orig" id="095e7937-a845-4a11-8816-dbf22b7e1659">
        <updating/>
        <source>doGoCreateJobFile_orig() updating;

vars
	folder:String;
	f:File;
begin
	addResults(null);
	create f;
	//f.fileName := '\\cnwchcs118\jobs\' &amp; targetHost &amp; '\creatorout\creator' &amp; uniqueId &amp; '.job';
	f.fileName := '\\cnwchcs118\jobs\' &amp; targetHost &amp; '\creatorout\' &amp; app.computerName[4:3].toLower &amp; '_' &amp; uniqueId &amp; '.job';
	f.usePresentationFileSystem := false;  // on Creator machine
	f.mode := File.Mode_Output;
	addResults('creating ' &amp; f.fileName);
	f.writeLine('addstdrun,,\\cnwchcs118\T$\jblpcre\server\c_misc\configurationfiles\' &amp; uniqueId &amp; '.jobchg' &amp; ',,,,,,');
	f.close;

	f.mode := File.Mode_Input;
	while not f.endOfFile do
		addResults(f.readLine);
	endwhile;
	f.close;
epilog
	delete f;
end;


</source>
    </JadeMethod>
    <JadeMethod name="doRunSumGen" id="2840b4a7-f147-46dc-8f76-4d48c1786426">
        <updating/>
        <source>doRunSumGen() updating;

vars
	sfb:FrmServerFileBrowser;
	statsDir,cmdLine,cmdLine2, cmdLinef3, cmdLinef,pattern,renamer,s,t:String;
	ff:FileFolder; fn:FileNode;
	f,f2, f3 : File;
	retCode : Integer;
begin
	
	create sfb;
	sfb.myParentForm:=self;
	sfb.selectedItem:="T:\BenchMarkResults\JCC";
	sfb.init("Browse for File on " &amp; app.dbServerComputerName, "Select results folder", null);
	sfb.showModal;
	statsDir:=sfb.selectedItem;

	if statsDir &lt;&gt; null then
		statsDir:=OtherResultsFolder&amp;statsDir[3:end];
		create ff;
		ff.fileName:=statsDir;
		foreach fn in ff.files where fn.isKindOf(FileFolder) do
			s:=fn.name[1:fn.name.length-1];
			/*if s[s.length] = "_" then
				s:=s[1:s.length-1];
			endif;*/
			if s = t then continue; endif;
			if pattern = null then
				pattern:=s;
			else
				pattern:=pattern&amp;","&amp;s;
			endif;
			t:=s;
		endforeach;
		read pattern;
		renamer := "false";
		read renamer;
		if pattern &lt;&gt; null then
			cmdLine:="c:\cardinal\bin\jblsummarygenerator -basedir "&amp;statsDir&amp;"  -pattern "&amp;pattern&amp;" -outfile "&amp;statsDir&amp;"\jblsummary_"&amp;pattern&amp;".xls";
			
			if renamer = "true" then 
				cmdLine := cmdLine &amp; " -renamer true";
			endif;
			
			addResults(null);
			//doCmd(cmdLine, " &gt;&gt; "&amp;statsDir&amp;"\sumgen.log");
			doCmd(cmdLine);
			addResults("summary file: "&amp;statsDir&amp;"\jblsummary_"&amp;pattern&amp;".xls");
			
			// Open Excel if in default location
			create f;
			cmdLinef := "C:\Program Files (x86)\Microsoft Office\Office12\excel.exe";
			f.fileName:= cmdLinef;
			
			if f.isAvailable then
				cmdLine := cmdLinef;
			else 
				// Just try and run excel 
				cmdLine := "excel.exe";
			endif; 
			
			//if f.isAvailable or f3.isAvailable then
			create f2;
			cmdLine2 := statsDir&amp;"\jblsummary_"&amp;pattern&amp;".xls";
			f2.fileName:= cmdLine2;
			
			if f.isAvailable and f2.isAvailable  then
				cmdLine:= '"' &amp; cmdLine &amp;'" "' &amp; cmdLine2 &amp; '"'; 
				
				node.createExternalProcess(null,cmdLine,null,null,true,false,retCode);
				addResults("Started Excel "&amp; cmdLine &amp; retCode.String);
			
			elseif f2.isAvailable  then
				cmdLine:= cmdLine &amp; ' "' &amp; cmdLine2 &amp; '"'; 
				node.createExternalProcess(null,cmdLine,null,null,true,false,retCode);
				addResults("tried to start Excel "&amp; cmdLine &amp; retCode.String);
			
			else 
				addResults("Excel is there but the output file isn't");
			endif;
			//else 
			//addResults("I dont know where excel is located");
			//endif;
		endif;
	endif;
epilog
	delete sfb;
	delete ff;
	delete f;
	delete f2;
	//delete f3;
end;</source>
    </JadeMethod>
    <JadeMethod name="formLoad" id="a5b5dd42-b2bf-4a8c-8d88-630a83b460c2">
        <updating/>
        <source>formLoad() updating;

begin
	if app.getEnvid &lt;&gt; "jblpcre" then
		txtResults.backColor := 11053271;
	endif;
	
	loadProducts;
	loadSimpleCombos;
	loadHosts;
	loadClientMachines;

	setCaption;
	create outputFile;
	outputFile.usePresentationFileSystem := true;
	cmbProduct.setFocus;
	resize;
end;</source>
    </JadeMethod>
    <JadeMethod name="keyDown" id="5970c186-dd1e-47f5-80c5-913147921697">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;

begin
	if keyCode=65 and shift=2 then  // Ctrl+A
		txtResults.setFocus;
		txtResults.selStart:=0;
		txtResults.selLength:=-1;
		keyCode:=0;
	
	elseif keyCode=27 then  // Esc
		mnuFileExit_click(null);
		keyCode:=0;
	endif;
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="load" id="19590741-ab82-47bc-9110-c6da85c17a71">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

begin
	formLoad;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadArchive" id="a6340beb-4ddf-45ba-b6de-cffee7555064">
        <updating/>
        <source>loadArchive() updating;

vars
	fn : FileNode;
	ff : FileFolder;
	
begin
	create ff;
	ff.fileName := "\\" &amp; cmbRapHost.text &amp; "\v$\autorunarchives\" &amp; cmbProduct.text;
	
	foreach fn in ff.files do 
		cmbArchive.addItem(fn.name);
	endforeach;
	
	cmbArchive.listIndex := cmbArchive.findString(0, fn.name[1:4] &amp; "7012");
	if cmbArchive.listIndex = -1 then
		cmbArchive.listIndex := cmbArchive.listCount;
	endif;
	txtRunid.text := cmbArchive.text.replace(".rar", "")[5:end];
epilog
	delete ff;
end;
</source>
    </JadeMethod>
    <JadeMethod name="loadClientMachines" id="98b0d518-fe87-466f-9539-b0058ea6da7c">
        <updating/>
        <source>loadClientMachines() updating;

begin
	if cmbProduct.text = 'CMIS'
	or cmbProduct.text = 'JCC'
	or cmbProduct.text = 'JMT' then
		clientMachines := 2;
	elseif cmbProduct.text = 'mtl' then
		clientMachines := 4;
	else
		clientMachines := 1;
	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="loadHosts" id="cc79566e-ea55-4a5f-b438-38abab953703">
        <updating/>
        <source>loadHosts() updating;

vars
	i:Integer;
begin
	cmbRapHost.addItem('cnwchcs4');
	cmbRapHost.addItem('cnwchcs25');
	cmbRapHost.addItem('cnwchcs55');
	cmbRapHost.text:='cnwchcs25';
	cmbRapHost_click(null);
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="loadProducts" id="3f710647-c0fb-4f81-b9e8-63e35cc556da">
        <updating/>
        <source>loadProducts() updating;

begin
	cmbProduct.addItem("Autodino");
	cmbProduct.addItem("CMIS");
	cmbProduct.addItem("JCC");
	cmbProduct.addItem("mtl");
	cmbProduct.addItem("skidemo");
	cmbProduct.addItem("sku");
	cmbProduct.addItem("StartStopTest");
	cmbProduct.listIndex := 1;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadSimpleCombos" id="2e9043d7-5247-46ef-8640-99ace6e128b0">
        <updating/>
        <source>loadSimpleCombos() updating;

vars
	i:Integer;
begin
	foreach i in 1 to 10 do
		cmbTotalRuns.addItem(i.String);
	endforeach;
	cmbTotalRuns.listIndex := 3;
end;</source>
    </JadeMethod>
