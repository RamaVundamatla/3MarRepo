    <JadeMethod name="getInvoiceConsolidation" id="5f47ef67-c04a-4f64-bb00-d75022f8c586">
        <updating/>
        <source>getInvoiceConsolidation(sortDict : ObjectArray io; _consolidate : Boolean; _oneLine : Boolean)  : Real updating;
/*
Purpose:			
Date		Who		Reason
14 January 2014	cnwab1	Initial creation
*/
	// SEE UT_Invoicing::tConsolidatedInvoiceQtyRate to test consolidation to one line

vars
	tmpInvLineStat : CM_InvoiceLineStatByNarQtyDict;
	invLineStatDict:     CM_InvoiceLineStatByNarManDict;
	invLineStatDictCol:     CM_InvoiceLineStatByNarManDict;
	invLineStatXXXDict:  CM_InvLineStatByMnPrnOrNarDict;
	invLineStat:         CM_InvoiceLineStat;
invStatTotal : Real;
begin

	create invLineStatDict transient;
	create invLineStatXXXDict transient;
	//Consolidate By Narration/IsManual&amp;False
	//The narration may have DIFF RATE, so consolidation is by Narration, Rate, IsManual
	// Also populates Narration from an Invoice Line Consolidation if present.
	invStatTotal := self.getInvoiceStats(invLineStatDict, null, false, false);
	if _consolidate then
		// Consolidates by Narration on  an Invoice Line Consolidation object and the Rate
		invLineStatDictCol := self.getInvoiceStatsConsolidate(invLineStatDict);
		invLineStatDict.purge();
		invLineStatDictCol.copy(invLineStatXXXDict); // PAR 33175
 // PAR 33175		invLineStatDictCol.copy(sortDict); // PAR 33175
		if _oneLine then
			// Consolidates by Narration on  an Invoice Line Consolidation object and the Quantity
			tmpInvLineStat := self.getInvoiceStatsConsolidate2One(invLineStatDictCol);
			// PAR 33175 invLineStatDictCol.purge;
			// PAR 33175 tmpInvLineStat.copy(invLineStatDictCol);
			invLineStatXXXDict.purge(); // PAR 33175
			tmpInvLineStat.copy(invLineStatXXXDict); // PAR 33175
			
		endif;
		// PAR 33175 invLineStatDict.purge;
		// PAR 33175 invLineStatDictCol.copy(invLineStatDict);
	else // PAR 33175
//		invLineStatDict.copy(sortDict); // PAR 33175
		invLineStatDict.copy(invLineStatXXXDict); // PAR 33175
	endif;
	
	invLineStatXXXDict.copy(sortDict);
	
	return invStatTotal;
epilog
	delete invLineStatXXXDict;
	delete invLineStatDict;
	delete invLineStatDictCol;
	delete invLineStatDict;
	delete tmpInvLineStat;
end;</source>
        <Parameter name="sortDict" type="ObjectArray" usage="io"/>
        <Parameter name="_consolidate" type="Boolean"/>
        <Parameter name="_oneLine" type="Boolean"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getInvoiceCopiedFromExtStr" id="d55831d3-220a-4864-923c-aa55db456b80">
        <source>getInvoiceCopiedFromExtStr() : String;
/*

Purpose:			//16/10/2024	navkc1	JIRA Bug MTN-12541
					It's changed to be "Copied From Ext", when user select Invoice/Credit Note and Copy as Invoice/Credit Note
					E.g
					Invoice 1
					User select Invoice 1 and copy as Invoice 2
					Invoice 2.myOtherInvoice will have reference to Invoice 1
					Invoice 1.allOtherInvoices will have reference to Invoice 2

Parameters:			

Return Value:		

Date		Who		Reason
//09/08/2024	navkc1 CR 64894 Task 65269: Jade New Columns for Data Extract

*/

vars
	str		: String;
	inv		: CM_Invoice;
	
begin
	inv := self.myOtherInvoice;
	
	//if inv &lt;&gt; null and inv.isInvoice() then
	if inv &lt;&gt; null then //16/10/2024	navkc1	JIRA Bug MTN-12541
		str := inv.externalNumber;
	endif;
	
	return str;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
