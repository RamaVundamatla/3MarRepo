    <JadeMethod name="updateItemInTable" id="cb60cbb8-3e96-4876-b3d4-ce9fbebbdc83">
        <updating/>
        <source>updateItemInTable(_transaction : CM_Transaction; _rowIdx: Integer) protected, updating;
// Feb 2012 CCMS 1262, update table from notification
vars
	rowObj 	: Object;
	tbl 	: CM_DataTable;
	enqRow	: String;
	trans	: CM_Transaction;
begin
	trans := _transaction;
	if trans = null then
		return;
	endif;

	tbl := self.tblTransactions;
	rowObj	:= tbl.accessRow(_rowIdx).itemObject;
	
	if rowObj &lt;&gt; trans then
		return;
	endif;

	enqRow := rowObj.CM_Transaction.getAttributeStringForDefArray(tbl.allTblDataEntRows);
	tbl.accessCell(_rowIdx, 1).text := enqRow;
		
end;</source>
        <access>protected</access>
        <Parameter name="_transaction" type="CM_Transaction"/>
        <Parameter name="_rowIdx" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="updateTableColumnFilters" id="ccbf421a-2878-414a-9fc3-d90365c5ff81">
        <updating/>
        <source>updateTableColumnFilters(_table: Table; _allFilterColumns: CM_ColumnFilterDict) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 March 2014	cnwndl1	Initial creation

*/

vars

begin
	
	if self.allColumnFilters = null then
		create self.allColumnFilters transient;  // this is a non exclusive collection.
	endif;

	self.allColumnFilters.replaceAllFiltersForTable( _table, _allFilterColumns );
	self.showSearchCriteria();


epilog

end;</source>
        <Parameter name="_table" type="Table"/>
        <Parameter name="_allFilterColumns" type="CM_ColumnFilterDict"/>
    </JadeMethod>
    <JadeMethod name="userNotify" id="ee5f87fc-206d-473c-8593-0123fc8653f0">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:     30 June 2008 by cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 14/05/2010		cnwdap1			CCMS 1116 Tranship changes
// ---------------------------------------------------------------------------

vars
	event 	: Integer;
	row		: Integer;
begin 
	event := self.myTerminal.getEventFromTerminalEvent(eventType);
	
	if event = EVENT_TRAN_RESYNC then
		if self.mode = self.Mode_CargoItem_Enquiry then
			self.initTblTrans();
			self.showTransactions();
			self.showCharges();
			// 37012 the initTblTrans call above hs just set this caption correctly
			///self.shtCharges.caption :=	app.getErrorString(Charges) &amp; " (" &amp; self.tblCharges.rows.String &amp; ")";
		else 
			if self.tblTransactions.findObjectInRow(theObject, row) then
				self.updateItemInTable(theObject.CM_Transaction, row);
			endif;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="woTransactionSearch" id="99285cee-8710-4a01-be4a-af7bd7f9c339">
        <updating/>
        <source>woTransactionSearch() updating, protected;
/*
Purpose:		TFS 39237	
Date				Who			Reason
JUNE 2018		CNWAB1		Initial creation
12 Dec 2019 	cnwma1		Bug 47966: STWO - Transaction Enquiry ignores midnight 'Time To'
14/07/2025		naviv1	MTN-35226	MTN - Usage of Iterator.getCurrentKeys  	
*/

vars
	type			: Integer;
	iter			: Iterator;
	workorderObj		: CM_WOTransaction;
	dateDict		: CM_WOTransByDateTime;
	typeDateDict	: CM_WOTransByTypeDateTime;
	keyTimeStamp	: TimeStamp;
	startTimeStamp	: TimeStamp;
	endTimeStamp	: TimeStamp;
	keyType			: Integer;
	atLimit			: Boolean;
	breakOut		: Boolean;
	passport		: CM_Passport;
	user			: CM_User;

begin
	passport := app.myPassport;
	user := app.getMyUser();

	startTimeStamp.setDate(self.filterDateFrom);
	startTimeStamp.setTime(self.filterTimeFrom);
	
	endTimeStamp.setDate(self.filterDateTo);
	endTimeStamp.setTime(self.filterTimeTo);
	
	if self.cmbSearchTranTyp.listIndex &gt; 0 then
		type := self.cmbSearchTranTyp.itemData[self.cmbSearchTranTyp.listIndex];
	endif;
	
	if type = 0 then
		// date search
		dateDict := self.myTerminal.allWOTransByDateTime;
		iter 	 :=	dateDict.createIterator();
		dateDict.startKeyGeq(startTimeStamp, iter);
	
		while iter.next(workorderObj) do
			iter.getCurrentKeys(keyTimeStamp);  //MTN-35226
		
			if endTimeStamp.isValid  and keyTimeStamp &gt; endTimeStamp then
				break;
			endif;
		
			if self.includesWOObject(workorderObj, breakOut, passport) then
				atLimit := self.addObjectToCollection(workorderObj, user);
			endif;
			
			if atLimit or  breakOut then
				break;
			endif;
		endwhile;
	else
		// transaction type search
		typeDateDict := self.myTerminal.allWOTransByTypeDateTime;
		iter 		 :=	typeDateDict.createIterator();
		typeDateDict.startKeyGeq(type, startTimeStamp, iter);
	
		while iter.next(workorderObj) do
			iter.getCurrentKeys(keyType, keyTimeStamp);  //MTN-35226
		
			if type &lt;&gt; keyType then
				break;
			endif;
			
			if endTimeStamp.isValid  and keyTimeStamp &gt; endTimeStamp then
				break;
			endif;
		
			if self.includesWOObject(workorderObj, breakOut, passport) then
				atLimit := self.addObjectToCollection(workorderObj, user);
			endif;
			
			if atLimit or  breakOut then
				break;
			endif;
		endwhile;
	endif;
	self.searchCancelled := breakOut;

epilog
	delete iter;
end;</source>
        <access>protected</access>
    </JadeMethod>
</GUIClass>
