	endif;
	
	if not isChanged then
		app.writeLog('***logNoStateChange*** : '    &amp; ' TRX : '	  	 			&amp; self.testDescription
											   &amp; ' || Deferred Updates : ' 			&amp; self.useTIDictDeferUpdate.String
											   &amp; ' || No Key changes', LOGLEVEL);
	endif;

	//return isChanged;
	
epilog

end;</source>
