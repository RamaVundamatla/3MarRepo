    <JadeMethod name="validateDelete" id="f24c5dd8-71a7-4584-9e37-06472bfc25ed">
        <source>validateDelete(_passport: CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 April 2023	navhl20	ChangeRequest 57712:[54552] EUP - Delivery Dispatch – Adding Work Point Types

*/

vars

begin
	if self.isSystemType then
		app.raiseCMException1(Work_point_type_system_type, self.code, null, null);
	endif;
	if self.allWorkPoints.isNotEmpty then
		app.raiseCMException1(Cannot_Delete_WPT, self.code, null, null);
	endif;
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateUpdate" id="17520f58-4b03-419a-b4c2-c58f9e531e06">
        <source>validateUpdate(_passport: CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 April 2023	navhl20	ChangeRequest 57712:[54552] EUP - Delivery Dispatch – Adding Work Point Types

*/

vars
	realWPT,
	realDamageSeverityLevel,
	existWPT,
	existingDamageSeverityLevel		: CM_WorkPointType;
begin
	if self.code = null then
		app.raiseCMException(Input_required_field_code, ETRow_Code, self);
	endif;
	
	if self.description = null then
		app.raiseCMException(Input_required_field_desc, ETRow_Description, self); 
	endif;
	
	if self.type = null then
		app.raiseCMException(Input_required_field_type, ETRow_Type, self); 
	endif;
	
	existWPT	:= self.myTerminal.allWorkPointTypes[self.type,self.code];
	realWPT		:= self.pxyGetRealObject();
	
	if existWPT &lt;&gt; null and
	   (realWPT = null or //in which case we are trying add a new one that is duplicate
	   existWPT &lt;&gt; realWPT) //in which case we are trying update one to be same as another
	   then
		app.raiseCMException2(Wp_code_alrea_exist_type, self.code,app.getWorkPointTypeString(self.type), null, null); 
	endif;
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
