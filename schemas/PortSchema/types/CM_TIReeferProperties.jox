    <JadeMethod name="temperatureInFahrenheit" id="12d4b7d9-25ca-4f4f-a5bd-736230380f2c">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>temperatureInFahrenheit(set: Boolean; value: Real io) mapping, updating;
/*
Purpose:			CCMS 1007 Allow for reefer details on booking and CM_TrackedItem, not just CM_Container

Parameters:			

Return Value:		

Date		Who		Reason
25/11/2009	cnwdap1	Initial creation
23/02/2015	cnwdap1	PAR #35672 Don't round the temperature conversion, otherwise -7.6F turns in to -8F,
					which is not the way it's defined in the temperature conversion table. Round to 2 DP
*/
vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		//temperature is the real deal
	else
		//just return fahr temp
		//value := app.temperatureConversion(true,self.temperature).rounded;		// PAR #35672
		value := app.temperatureConversion(true,self.temperature).roundedTo(2);		// PAR #35672
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="Real" usage="io"/>
    </JadeMethod>
    <JadeMethod name="towerId" id="c748e2bd-25eb-420e-b82c-b0df7748fe08">
        <source>towerId() : String;
/*
Purpose:			CCMS 1007 Allow for reefer details on booking and CM_TrackedItem, not just CM_Container

Parameters:			

Return Value:		

Date		Who		Reason
25/11/2009	cnwdap1	Initial creation
*/
vars

begin
	if self.tower &lt;&gt; null then
		return self.tower.id;
	else
		return null;
	endif;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
