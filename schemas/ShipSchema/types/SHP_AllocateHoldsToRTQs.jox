    </JadeMethod>
    <JadeMethod name="loadComboVoyageQueues" id="20c6657d-51d2-4a43-8e1c-7cf473a1bd5a">
        <source>loadComboVoyageQueues();
/*
Purpose:			
Date		Who		Reason
02 February 2015	cnwab1	Initial creation
*/

vars
	obj : CM_Object;
	objSet : CM_ObjectSetActual;
	availableWorkPoints : ObjectArray;
	craneOrWp : CM_Object;
begin
	self.cmbRTQueues.clear();
	
	self.cmbRTQueues.sorted := true;
	
	create objSet transient;
	self.myCurrentVoyage.findAllMyCranesAndWorkpoints(objSet);
	
	foreach obj in objSet discreteLock do
		craneOrWp := obj.CM_Object;
		self.cmbRTQueues.addItemObject(craneOrWp.getName(), craneOrWp);
	endforeach;
	
	self.cmbRTQueues.sorted := false;
	
	self.cmbRTQueues.addItemAt("",1);
epilog

	delete objSet;
	delete availableWorkPoints;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadTableCranesWPs" id="c03d7d99-151a-49a1-b77f-d30e9caea143">
        <source>loadTableCranesWPs();
/*
Purpose:			
Date		Who		Reason
02 February 2015	cnwab1	Initial creation
*/

vars
	hold : CM_GeneralCargoController;
	obj, objKey : CM_Object;
	iter : Iterator;
	tmpStr : String;
begin
	self.tblData.rows := 0;
	self.tblData.addItem("Item" &amp; Tab &amp; "RT Queue");
	self.tblData.fixedRows := 1;
	self.tblData.selectMode := Table.SelectMode_Multiple;
	self.tblData.multiSelect := CM_BaseTable.MultiSelect_Simple;
	self.tblData.selectionType := 1;
	
	if self.myCurrentVoyage = null then
		return;
	endif;
	
	self.copyCraneWPAllocations();
	
	if self.myCurrentVoyage.myShipBlockStack&lt;&gt; null then // self.myCurrentVoyage.myShipBlockStack will never be null
		obj := self.allCranesWPsByHolds.getAtKey(self.myCurrentVoyage.myShipBlockStack); // use the ship block stack to ge the crane or wp that it is allocated to
		tmpStr := "";
		if obj &lt;&gt; null then
			tmpStr := obj.getName();
		endif;
		self.tblData.addItemObject(self.myCurrentVoyage.myShipBlockStack, self.myCurrentVoyage.myShipBlockStack.getFullId() &amp; Tab &amp; tmpStr);
	endif;
	
	if self.myCurrentVoyage.myGeneralCargoVoyage&lt;&gt; null then
		foreach  hold in self.myCurrentVoyage.myGeneralCargoVoyage.allLocationsByHatchPlace discreteLock do
			obj := self.allCranesWPsByHolds.getAtKey(hold); // use the hold to get the crane or wp that it is allocated to
			tmpStr := "";
			if obj &lt;&gt; null then
				tmpStr := obj.getName();
			endif;
			self.tblData.addItemObject(hold, hold.getFullId() &amp; Tab &amp; tmpStr);
	
		endforeach;
	endif;
	
epilog
	delete iter;
end;</source>
    </JadeMethod>
