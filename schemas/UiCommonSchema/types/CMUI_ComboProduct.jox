    <JadeMethod name="displayEntry" id="d23ad66a-56a9-409c-bde8-06d8b1fde63f">
        <controlMethod name="ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>displayEntry(combobox: ComboBox input; obj: CM_Product; lstIndex: Integer): String updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:     26 July 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
begin
	if obj = null then
		return null;
	endif;

	if self.excludeRow(combobox, obj, lstIndex) then
		return null;
	else
		return obj.code &amp; '  ' &amp; obj.description;
	endif;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="obj" type="CM_Product"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="excludeRow" id="7233dfe0-1195-4bf2-b9fc-947ab7eef9b5">
        <controlMethod name="CMUI_ComboBoxObject::excludeRow"/>
        <methodInvocation>event</methodInvocation>
        <source>excludeRow(_comboboxObj: ComboBox input; _object: Object; _lstIndex: Integer): Boolean protected;
// --------------------------------------------------------------------------------
// Created:		22 April 2009 by cnwjo3
//
// Purpose:		Remove any products from a collection that do not match the Operator set.
//				Products will not be removed if:
//					the Operator is not set for this combo box
//					the Operator is not set on the Product
//					the Operator set for this combo box is the same as the Operator set on the Product
vars
	operatorObj	: CM_Operator;
	productObj	: CM_Product;
	iter : Iterator;
begin
	productObj	:=	_object.CM_Product;
	
	//epr TFS 1846 18/4/16
	if productObj.isNotActive then
		return true;
	endif;
	
	if productObj.myOperator = null then
		// Products with a null Operator are available to everyone.
		return false;
	endif;
	
	operatorObj	:=	self.myOperator;
	
	if operatorObj = null then
		//if operator hasn't been set for this ComboProduct do not exclude, ie: display all products
		return false;
	endif;
	
	if productObj.myOperator &lt;&gt; operatorObj then
		//if product's operator is not the same as what is set exclude product
		return true;
	endif;
	
	return false;

	//return inheritMethod(_comboboxObj, _object, _lstIndex);
end;</source>
        <access>protected</access>
        <Parameter name="_comboboxObj" type="ComboBox" usage="input"/>
        <Parameter name="_object" type="Object"/>
        <Parameter name="_lstIndex" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCollectionJMT" id="f81471d3-f195-4d41-ac2b-0af8f3e28702">
        <source>getCollectionJMT(): Collection protected;
// ---------------------------------------------------------------------------
// Created:     26 July 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin
	if self.myCargoType = null then 
		return inheritMethod();
	else
		return self.myCargoType.allProducts;
	endif;

end;</source>
        <access>protected</access>
        <ReturnType type="Collection"/>
    </JadeMethod>
    <JadeMethod name="setCargoType" id="5e7f217c-4465-47ab-8af1-f10de17ae693">
        <updating/>
        <source>setCargoType(_cargoType : CM_CargoType)updating;
// ---------------------------------------------------------------------------
// Created:     26 July 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin

	if self.myCargoType &lt;&gt; _cargoType then 
		self.myCargoType := _cargoType;
		self.text := null;
		self.amInitialised := false; // so will re populate on next gotfocus. 
	endif;	

end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="setObject" id="ea995269-b3d1-4396-9cb8-b4d4ee67cca4">
        <updating/>
        <source>setObject(_value: CM_Product) updating;
// ---------------------------------------------------------------------------
// Created:     21 September 2005	cnwhjg1
//
// Purpose:     if cargotype not set in code then set here when object is set 
//				so combo populates with correct objects. 
// ----------   ----------  --------------------------------------------------
vars

begin
	if _value &lt;&gt; null then 
		if _value.code = SystemProductCode then	//  CCMS 1080 (PAR19704) July 2009
			return;	//hide system unvisible product type. See CM_CargoType.mySystemProductType text info.
		else
			if self.myCargoType = null or self.myCargoType &lt;&gt; _value.myCargoType then 
				self.myCargoType := _value.myCargoType;
				self.amInitialised := false;
			endif;
		endif;
	endif;

	inheritMethod(_value);

end;</source>
        <Parameter name="_value" type="CM_Product"/>
    </JadeMethod>
    <JadeMethod name="setOperator" id="b26c9ba7-dbbb-43ee-9453-5e96b17a9ec9">
        <updating/>
        <source>setOperator(_operator : CM_Operator) updating;
// ---------------------------------------------------------------------------
// Created:     18/4/2008 cnwjo3
//
// Purpose:     set the operator to be used in excludeRow method
// ----------   ----------  --------------------------------------------------
vars

begin
	if self.myOperator &lt;&gt; _operator then
		self.myOperator := _operator;
		self.amInitialised := false;
	endif;
end;</source>
        <Parameter name="_operator" type="CM_Operator"/>
    </JadeMethod>
