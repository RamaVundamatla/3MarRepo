    <JadeMethod name="getExceptionDetails" id="8055ee71-d80a-4713-9cf7-861fec44f8c6">
        <source>getExceptionDetails(_exObj : Exception) : String protected;
// ---------------------------------------------------------------------------
// Created:     28 January 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	errorDetails	: String;
	theObject		: Object;
	errorShort		: String;

begin
	errorDetails	:=	"* Error " &amp; _exObj.errorCode.String &amp; ": " &amp;
						_exObj.text() &amp; " " &amp;
						_exObj.extendedErrorText;
	
	errorDetails	:=	errorDetails.trimBlanks() &amp; CrLf &amp; " Application: " &amp; app.name &amp; CrLf &amp;
						"      Schema: " &amp; currentSchema.name &amp; CrLf &amp;
						"        Type: " &amp; _exObj.class().name;
	
	if _exObj.reportingMethodDesc &lt;&gt; null then
		if _exObj.reportingMethodDesc.isKindOf(PrimMethodCallDesc) then
			errorDetails	:=	errorDetails.trimBlanks() &amp; CrLf &amp; "    Reported: " &amp;
								_exObj.reportingMethodDesc.receiverAsString().String &amp; " " &amp;
								_exObj.reportingMethodDesc.getName();
		else
			errorDetails	:=	errorDetails.trimBlanks() &amp; CrLf &amp; "    Reported: " &amp;
								_exObj.reportingMethodDesc.getReceiver().String &amp; " " &amp;
								_exObj.reportingMethodDesc.getName();
		endif;
	endif;

	if _exObj.currentMethodDesc &lt;&gt; null then
		if _exObj.currentMethodDesc.isKindOf(PrimMethodCallDesc) then
			errorDetails	:=	errorDetails.trimBlanks() &amp; CrLf &amp; "   Caused by: " &amp;
								_exObj.currentMethodDesc.receiverAsString().String &amp; " " &amp;
								_exObj.currentMethodDesc.getName();
		else
			errorDetails	:=	errorDetails.trimBlanks() &amp; CrLf &amp; "   Caused by: " &amp;
								_exObj.currentMethodDesc.getReceiver().String &amp; " " &amp;
								_exObj.currentMethodDesc.getName();
		endif;
	endif;

	theObject	:=	_exObj.errorObject();
	errorShort	:=	_exObj.errorItem;

 	if global.isValidObject(theObject) then
		errorDetails	:=	errorDetails.trimBlanks() &amp; CrLf &amp; "Error Object: " &amp; theObject.String;
	endif;

 	if errorShort &lt;&gt; null then
		errorDetails	:=	errorDetails.trimBlanks() &amp; CrLf &amp; "  Error Item: " &amp; errorShort;
	endif;
	
	errorDetails	:=	errorDetails.trimBlanks() &amp; CrLf &amp; " Continuable: " &amp; app.getYesNo(_exObj.continuable);
	errorDetails	:=	errorDetails.trimBlanks() &amp; CrLf &amp; "   Resumable: " &amp; app.getYesNo(_exObj.resumable);
epilog
	return errorDetails;
end;</source>
        <access>protected</access>
        <Parameter name="_exObj" type="Exception"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVersionString" id="281fa3f6-798e-4596-a986-9d02d567cbdd">
        <source>getVersionString(): String ;
/*

Date		Who		Reason
25 May 2015	cnwer1	Initial creation TFS 336 - monthly releases

*/

vars
	nextPos	: Integer;
	tmpStr	: String;
	className : String;
	versionString : String;
begin
	className:=self.class.name;
	nextPos := className.pos('_', 1);
	if nextPos = 0 then
		return null;
	endif;
	tmpStr:=className[nextPos+1 : end];
	nextPos		:= 1;
	versionString		:= tmpStr.scanUntil("_", nextPos) &amp; ".";
	nextPos		:= nextPos + 1;
	versionString		:= versionString &amp; tmpStr.scanUntil("_", nextPos) &amp; ".";
	nextPos		:= nextPos + 1;
	versionString		:= versionString &amp; tmpStr.scanUntil("_", nextPos);
	return versionString;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleSiteSpecificItems" id="21973e1e-56d7-4d17-871d-ef8d71104486">
        <source>handleSiteSpecificItems();
/*

Purpose:	To provide a means of limiting some functionality to specific sites only		

Parameters:			

Return Value:		

Date		Who		Reason
24 Sep 2012	cnwpjs1	Initial creation  Par #30391 Voyae Rationalisation

*/

vars
	menuPermissions		: IntegerArray;
	permissions			: IntegerArray;
	permAgent			: CM_PermissionAgent;
	menuAgent			: CM_MenuAgent;
	translationAgent	: CM_TranslationAgent;
begin
 	
	create menuPermissions transient;
	create permissions transient;
	create permAgent transient;
	permAgent.getSpecificPermissionsToRemove(menuPermissions,permissions);
	
	// remove menu items first
	if menuPermissions.isNotEmpty then
		create menuAgent transient;
		menuAgent.trxRemoveNavMenuItems(menuPermissions);
	endif;
	
	// now the permissions objects (stored as translatables)
	if permissions.isNotEmpty then
		create translationAgent transient;
		translationAgent.trxRemoveXLATPermissions(permissions);
	endif;
			
epilog
	delete menuPermissions;
	delete permissions;
	delete menuAgent;
	delete translationAgent;
	delete permAgent;

end;</source>
    </JadeMethod>
    <JadeMethod name="hasScriptBeenRunAtAll" id="5ad62d6d-2727-44a3-ba15-068713153522">
        <source>hasScriptBeenRunAtAll(_scriptName : String;_controller  : CnEcReleaseController) : Boolean;
/*
/*

Date		Who		Reason
21 May 2015	cnwer1	Initial creation TFS 336 - Monthly releases

*/

vars
	releaseHistoryIter : Iterator;
	releaseHistory :  	CnEcReleaseHistoryMaster;
	portRelease : PortSchemaRelease;
	result : Boolean;
	msg : String;
begin
	if app.myBaseRoot = null then
		return false;
	endif;
	
	releaseHistoryIter:=app.myBaseRoot.allReleaseHistoryMasters.createIterator;
	result:=false;
	while releaseHistoryIter.back(releaseHistory) do
		if releaseHistory.myUpgrader = null then
			continue;
		endif;
		portRelease:=releaseHistory.myUpgrader.PortSchemaRelease;
		
		if portRelease.allScriptsRun[_scriptName] &lt;&gt; null then
			result:= true;
			break;
		endif;
				
	endwhile;
	
	if result then
		msg := "&gt;&gt;&gt;&gt; Script " &amp; _scriptName &amp; " has already been run in " &amp; portRelease.myHistoryMaster.fullReleasePatchNumber;
		app.writeLog(msg, LogINFO);
		if _controller &lt;&gt; null then
			_controller.logEntry(msg) ;	
		endif;
	endif;
	
	return result;
epilog
	delete releaseHistoryIter;

end;</source>
        <Parameter name="_scriptName" type="String"/>
        <Parameter name="_controller" type="CnEcReleaseController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasScriptBeenRunThisRelease" id="a10616f9-90e6-4a8c-8978-52c0389a6448">
        <source>hasScriptBeenRunThisRelease(_scriptName : String; _controller  : CnEcReleaseController) : Boolean;
/*

Date		Who		Reason
21 May 2015	cnwer1	Initial creation TFS 336 - Monthly releases

*/

vars
	releaseHistoryIter : Iterator;
	releaseHistory :  	CnEcReleaseHistoryMaster;
	portRelease : PortSchemaRelease;
	result : Boolean;
	scriptRun : CM_String;
	msg : String;
begin
	releaseHistoryIter:=app.myBaseRoot.allReleaseHistoryMasters.createIterator;
	result:= false;
	while releaseHistoryIter.back(releaseHistory) do
					
		if releaseHistory.myUpgrader = null then
			continue;
		endif;
		if releaseHistory.myUpgrader =  self then
			continue;
		endif;
		
		portRelease:=releaseHistory.myUpgrader.PortSchemaRelease;
		if portRelease.getVersionString() &lt;&gt; app.myRoot.versionString then
			break;
		endif;		
		if portRelease.allScriptsRun[_scriptName] &lt;&gt; null then		
			result:= true;
			break;
		endif;
				
	endwhile;
	
	if result then
		msg := "&gt;&gt;&gt;&gt; Script " &amp; _scriptName &amp; " has already been run in " &amp; releaseHistory.fullReleasePatchNumber;
		app.writeLog(msg, LogINFO);
		if _controller &lt;&gt; null then
			_controller.logEntry(msg);
		endif;
	endif;
	
	return result;
epilog
	delete releaseHistoryIter;

end;</source>
        <Parameter name="_scriptName" type="String"/>
        <Parameter name="_controller" type="CnEcReleaseController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initRTConfigAutoSearchDir" id="271e793e-5e6d-482e-bff2-fa5732c6fc73">
        <source>initRTConfigAutoSearchDir( _controller: CnEcReleaseController );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 November 2017	jlgndl1	Initial creation	TFS 7427

*/

vars

	rtVehicleConfig : CM_RTVehicleConfig;

begin

	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;
	app.writeLog(method.qualifiedName &amp; " Initialise new 'autoSearchDirector' attribute on 'CM_RTVehicleConfig'", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Initialising new 'autoSearchDirector' attribute on 'CM_RTVehicleConfig'(s)");
	endif;
	
	beginTransaction;
	foreach rtVehicleConfig in CM_RTVehicleConfig.instances do
		rtVehicleConfig.initAutoSearchDirector();
	endforeach;
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Initialise new 'autoSearchDirector' attribute on 'CM_RTVehicleConfig' - Complete", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Initialising new 'autoSearchDirector' attribute on 'CM_RTVehicleConfig'(s) - Completed") ;	
	endif;
	self.addScriptRun(method.name);
	
epilog

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="loadDrawingAttributes" id="b0921f8c-111a-49bc-8038-edc666256fbe">
