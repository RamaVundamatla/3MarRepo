    <JadeMethod name="erase" id="c9e54a0a-c14c-4032-ac87-98372d342a49">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     2001 By Andrew Bishop cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	controller : CM_LocationsController;
	gridCol	 : CM_GridColumn;
	gridRow : CM_GridRow;
begin
	if app.myPassport.isOpsViewEnabled(self.myTerminal) then // ### TFS 51854 08FEB2022 NAVAB1
		self.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_DELETE,BGP_OpsViewWSRequest.OPS_TYPE_TERMINALAREA, self); // ### TFS 51854 08FEB2022 NAVAB1
	endif;	


	foreach controller in self.allGridControllersByRowColumn do
		controller.CM_YardController.erase(_eraseLevel);
	endforeach;

	if self.allGridColumns.size &gt; 0 and self.allGridColumns.first.isTransient then
		foreach gridCol in self.allGridColumns do
			gridCol.erase(_eraseLevel);
		endforeach;
	endif;
	if self.allGridRows.size &gt; 0 and self.allGridRows.first.isTransient then
		foreach gridRow in self.allGridRows do
			gridRow.erase(_eraseLevel);
		endforeach;
	endif;
	
	inheritMethod(_eraseLevel);
	
epilog

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="findController" id="39ebcda0-f7c5-4fb8-8b9f-c53def67f105">
        <source>findController(_locnStr : String; _height : Integer io) : CM_GridController;
// ---------------------------------------------------------------------------
// Created:		21 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars	
	foundHeight : Integer;
	tmpStr 		: String;
	wholeString : String;
	row			: String;
	col			: String;
	rowCol		: String;
	lc			: CM_GridController;
begin
	wholeString := _locnStr;
	//----------------------
	//Derive the Row
	//----------------------
	if wholeString.length &lt;= 1 then
		//Only 1 char for row/col!
		return null;
	endif;
	
	//Try by name without the possible height character
	tmpStr :=wholeString.reverse[2:end].reverse;

	lc := self.allGridControllersByName[tmpStr];
	if lc &lt;&gt; null then
		return lc;
	endif;

	if wholeString.length &gt; 2 then
		if wholeString[1].Character.isAlpha and wholeString[2].Character.isAlpha then
			//2 alphas for row, simply update..
			row :=wholeString[1 : 2];
			if wholeString.length &gt;= 3 then
				wholeString := wholeString[3 : end];
			else
				wholeString := null;
			endif;
		elseif wholeString[1].Character.isAlpha and wholeString[2].Character.isNumeric then
			//1st is alpha, 2nd is numeric, we have finished with row
			row :=wholeString[1 : 1];
			if wholeString.length &gt;= 2 then
				wholeString :=wholeString[2 : end];
			else
				wholeString := null;
			endif;
		elseif wholeString[1].Character.isNumeric and wholeString[2].Character.isNumeric then
			//2 digits in row
			row :=wholeString[1 : 1];
			if wholeString.length &gt;= 2 then
				wholeString :=wholeString[2 : end];
			else
				wholeString := null;
			endif;
		else
			return null;	//god knows!
		endif;
	else // single character ROW and  COLUMN
		row := "0" &amp;wholeString[1 : 1];
		if wholeString.length = 2 then
			wholeString :=wholeString[2:1];
		else
			wholeString := null;
		endif;
	
	endif;
	
	if wholeString = null then
		return null;	//Need some column stuff!
	endif;

	//----------------------
	//Derive the Column
	//----------------------
	if wholeString.length &gt;= 2 then
		if wholeString[1].Character.isAlpha and wholeString[2].Character.isAlpha then
			//2 alphas for col, simply update..
			col :=wholeString[1 : 2];
			if wholeString.length &gt; 2 then
				wholeString :=wholeString[3 : end];
			endif;
		elseif wholeString[1].Character.isAlpha and wholeString[2].Character.isNumeric then
			//1st is alpha, 2nd is numeric, we have finished with col
			col :=wholeString[1 : 1];
			if wholeString.length &gt;= 2 then
				wholeString :=wholeString[2 : end];
			else
				wholeString := null;
			endif;
		elseif wholeString[1].Character.isNumeric and wholeString[2].Character.isNumeric then
			//2 digits in col
			col :=wholeString[1 : 2];	
			if wholeString.length &gt; 2 then
				wholeString :=wholeString[3 : end];
			endif;
		else
			return null;	//god knows!
		endif;
	else // single character COLUMN
		col := "0" &amp;wholeString[1 : 1];
		wholeString := null;
	endif;
	//----------------------
	//Derive the Height part
	//----------------------
	if wholeString.length &gt; 0 and wholeString[1].Character.isNumeric then
		foundHeight :=wholeString[1:1].Integer;
		_height := foundHeight;
	endif;
	//----------------------
	//See if we have the lc
	//----------------------
	rowCol := row &amp; col;
	rowCol := rowCol.toUpper;

	lc := self.allGridControllersByName[rowCol];
	if lc = null then
		return null;
	endif;	
	
	
	return lc;
end;</source>
        <Parameter name="_locnStr" type="String"/>
        <Parameter name="_height" type="Integer" usage="io"/>
        <ReturnType type="CM_GridController"/>
    </JadeMethod>
    <JadeMethod name="findLocation" id="2587743d-4109-48b2-ac44-2dd25bf476d3">
        <source>findLocation(_strs: StringArray; _noException : Boolean; _foundLC: CM_LocationsController io; _foundHeight: Integer io);
//--------------------------------------------------------------
//Created: 22 April 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	tStr : String;
	lc : CM_GridController;
begin
	//20 Feb 2014	NDL	Par 33550
	//inheritMethod(_strs, _noException, _foundLC, _foundHeight);
	_foundLC := null;	//20 Feb 2014	NDL	Par 33550
	_foundHeight := NULLINDEX;	//20 Feb 2014	NDL	Par 33550
	
	if _strs.isEmpty then
		return;
	endif;
	tStr := _strs[1].trimBlanks;

	if tStr = null then
		return;
	endif;	
	
	//epr par 24463 13/7/10
	if self.use40ftIds then
		lc := self.allGridControllersBy40ftId[tStr];
	endif;
	
	if lc = null then
		lc := self.allGridControllersByName[tStr];	
	endif;
	
	if lc = null then
		return;
	endif;	

	if lc.mySubBlockStack &lt;&gt; null then
		//Tell the sub-block to findLocation
		lc.mySubBlockStack.findLocation(_strs, _noException, _foundLC, _foundHeight);
	else
		_foundLC := lc;
	endif;
	
end;</source>
        <Parameter name="_strs" type="StringArray"/>
        <Parameter name="_noException" type="Boolean"/>
        <Parameter name="_foundLC" type="CM_LocationsController" usage="io"/>
        <Parameter name="_foundHeight" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="findYABlock" id="14324f19-5ccb-4576-9082-b91fdb4fd9b8">
        <source>findYABlock(_locationText: String; _topLeftLC: CM_LocationsController output; _bottomRightLC: CM_LocationsController output; _taViewPos : CM_TerminalAreaViewPosition): Boolean;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/01/2009	cnwjk3	SFW1030
15/11/2011	cnwdap1	PAR #28514 A yard allocation can now be entered as CC-CC, so we need to include all rows in this case
					Also need to cater for 40ft labels being entered
*/
vars
	locText 	: String;
	colFrom,
	colTo,
	rowFrom,
	rowTo		: String;
	tmpRow		: String;
	tmpCol		: String;
begin
	if _locationText = null then
		if not self.getMaxRowColString(locText) then
			return false;
		endif;
	else
		locText := _locationText.trimBlanks();
	endif;
	
	self.parseRowColString(locText, colFrom, colTo, rowFrom, rowTo);
	
	if colFrom &lt;&gt; null and colTo &lt;&gt; null and rowFrom &lt;&gt; null and rowTo &lt;&gt; null then
		
	elseif rowFrom &lt;&gt; null and rowTo &lt;&gt; null and colFrom = null and colTo = null then
		// only rows have been specified, so we want to include all columns in each row.		
		colFrom := self.getMinColLabel();
		colTo := self.getMaxColLabel();
		
	elseif colFrom &lt;&gt; null and colTo &lt;&gt; null and rowFrom = null and rowTo = null then			// PAR #28514
		// only columns have been specified, so we want to include all rows in each column		// PAR #28514
		rowFrom := self.getMinRowLabel();														// PAR #28514
		rowTo := self.getMaxRowLabel();															// PAR #28514
		
	else
		return false;
	endif;

	//par 19654 found that par 19707 needs to go into condition
	// PAR 19308
	if _taViewPos &lt;&gt; null then
		self.getRotatedFlippedRowColText(rowFrom, rowTo, colFrom, colTo,_taViewPos);
	else
		//par 19707 cnwjo3
		if self.getRowForLabel(rowFrom) &gt; self.getRowForLabel(rowTo) then
			tmpRow := rowFrom;
			rowFrom := rowTo;
			rowTo := tmpRow;
		endif;
	
		//par 19707 cnwjo3
		if self.getColumnForLabel(colFrom) &gt; self.getColumnForLabel(colTo) then
			tmpCol := colFrom;
			colFrom := colTo;
			colTo := tmpCol;
		endif;
	endif;

	
	
	_topLeftLC := self.allGridControllersByName[ rowFrom &amp; colFrom ];
	
	if _topLeftLC = null and self.use40ftIds then													// PAR #28514
		// use whatever has been passed in and see if we find a 40ft ID to match					// PAR #28514
		_topLeftLC := self.allGridControllersBy40ftId[ rowFrom &amp; colFrom ];							// PAR #28514
		// if we have found a match, we have in _topLeftLC the left-most bay of the 40ft ID area 	// PAR #28514
	endif;																							// PAR #28514
		
	if _topLeftLC = null  then
		return false;
	endif;

	_bottomRightLC := self.allGridControllersByName[ rowTo &amp; colTo ];
	
	if _bottomRightLC = null and self.use40ftIds then												// PAR #28514
		_bottomRightLC := self.allGridControllersBy40ftId[ rowTo &amp; colTo ];							// PAR #28514
		// if we hav found a match on 40ft ID, what we have in _bottomRightLC is the left-hand bay	// PAR #28514
		// of the 40ft area - we need to get the right-hand bay 									// PAR #28514
		if _bottomRightLC &lt;&gt; null and _bottomRightLC &lt;&gt; self.allGridControllersByName.last then		// PAR #28514
			_bottomRightLC := self.allGridControllersByName.getAtKeyGtr(_bottomRightLC.ident);		// PAR #28514
		endif;																						// PAR #28514
	endif;																							// PAR #28514
	
	if _bottomRightLC = null  then
		return false;
	endif;
	
	return true;
epilog

end;</source>
        <Parameter name="_locationText" type="String"/>
        <Parameter name="_topLeftLC" type="CM_LocationsController" usage="output"/>
        <Parameter name="_bottomRightLC" type="CM_LocationsController" usage="output"/>
        <Parameter name="_taViewPos" type="CM_TerminalAreaViewPosition"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="fixupForDecking" id="f119aa09-2a86-406a-8b7d-34a4f6a00d54">
        <source>fixupForDecking(_pxyDeckingOptions: CM_YADeckingOptions input; _passport: CM_Passport input);
//----------------------------------------------------------------
//	Created:	07 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	locnCell		: CM_YALocationCell;
begin

	if _pxyDeckingOptions.allYALocationCellsIn.isEmpty
	and (not _pxyDeckingOptions.allYALocationCellsOut.isEmpty) then
		foreach locnCell in _pxyDeckingOptions.allYALocationCellsOut reversed do
			_pxyDeckingOptions.allYALocationCellsIn.add(locnCell);
		endforeach;
	endif;

	if (not _pxyDeckingOptions.allYALocationCellsIn.isEmpty)
	and _pxyDeckingOptions.allYALocationCellsOut.isEmpty then
		foreach locnCell in _pxyDeckingOptions.allYALocationCellsIn reversed do
			_pxyDeckingOptions.allYALocationCellsOut.add(locnCell);
		endforeach;
	endif;

	if _pxyDeckingOptions.allYALocationCellsIn.size &lt;&gt; _pxyDeckingOptions.allYALocationCellsOut.size then
		//what can we do here?
		foreach locnCell in _pxyDeckingOptions.allYALocationCellsIn do
			if not _pxyDeckingOptions.allYALocationCellsOut.includes(locnCell) then
				_pxyDeckingOptions.allYALocationCellsOut.add(locnCell);
			endif;
		endforeach;
	
		foreach locnCell in _pxyDeckingOptions.allYALocationCellsOut do
			if not _pxyDeckingOptions.allYALocationCellsIn.includes(locnCell) then
				_pxyDeckingOptions.allYALocationCellsIn.add(locnCell);
			endif;
		endforeach;

		//app.raiseUnexpectedProgramError(class.name, method.name, 'area location cells need fixing');
		//return;
	endif;

	

end;</source>
        <Parameter name="_pxyDeckingOptions" type="CM_YADeckingOptions" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="fixupYALocationCells" id="b27863c8-4d6b-41dc-beca-454be4ddecbe">
        <source>fixupYALocationCells();

/*

Purpose:			Need to make sure that there are enough YALocationCells on all the Yard Locations

Parameters:			None

Return Value:		None


Date		Who		Reason
20 Mar 2009	cnwkpd1	PAR #18994 - factored out from applyAdvancedDeckingRules

*/

vars
	location		: CM_LocationsController;
	yardLocation	: CM_YardController;
	yaLocnCell		: CM_YALocationCell;
	height			: Integer;
	
begin
	// Make sure all the Location Controllers have the correct number of YALocationCells
	// This can happen when the height of a gridded area is increased
	foreach location in self.allLocationsControllers do
		if location.isKindOf(CM_YardController) then
			yardLocation := location.CM_YardController;
			while yardLocation.allYAYardLocationCells.size &lt; self.heightOfStack do
				create yaLocnCell persistent;
				yardLocation.allYAYardLocationCells.add(yaLocnCell);
				yaLocnCell.setForCreate(yardLocation.allYAYardLocationCells.size);
			endwhile;
		endif;
	endforeach;
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getAvailUse" id="bfe2bcbd-9c09-4ca5-90a7-a7acf87aa0bf">
