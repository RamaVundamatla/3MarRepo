	self.allLabelsArray.add( self.lblH );
	self.allLabelsArray.add( self.lblI );
	self.allLabelsArray.add( self.lblJ );
	self.allLabelsArray.add( self.lblK );
	self.allLabelsArray.add( self.lblL );
	self.allLabelsArray.add( self.lblM );
	self.allLabelsArray.add( self.lblN );
	self.allLabelsArray.add( self.lblO );
	self.allLabelsArray.add( self.lblP );
	self.allLabelsArray.add( self.lblQ );
	self.allLabelsArray.add( self.lblR );
	self.allLabelsArray.add( self.lblS );
	self.allLabelsArray.add( self.lblT );
	self.allLabelsArray.add( self.lblU );
	self.allLabelsArray.add( self.lblV );
	self.allLabelsArray.add( self.lblW );
	self.allLabelsArray.add( self.lblX );
	self.allLabelsArray.add( self.lblY );
	self.allLabelsArray.add( self.lblZ ); */

