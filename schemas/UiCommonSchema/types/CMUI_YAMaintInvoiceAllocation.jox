		saveOk := self.saveDataCargoAllocation(false);  // ### TFS 51219 25MAY2021 NAVAB1 renamed method
	elseif self.myTranMapInvent &lt;&gt; null then
		saveOk := self.saveDataInventAllocation(false);  // ### TFS 51219 25MAY2021 NAVAB1 
	endif;
	
