    <JadeMethod name="getCandHCode" id="afc5fa63-a551-42ff-85b3-e9aab60234dc">
        <source>getCandHCode(_strArray: StringArray input): String;
//----------------------------------------------------------------
//	Created:	05 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	strCandHCode		: String;
	tmpStrArray			: StringArray;
begin
	create tmpStrArray transient;

	if self.shipPortGroup.shippingLine &lt;&gt; null then
		tmpStrArray.add(self.shipPortGroup.shippingLine.code.trimBlanks);
	else
		tmpStrArray.add(null);
	endif;
	
	tmpStrArray.add(self.shipPortGroup.code.trimBlanks);
	
	if self.debtor &lt;&gt; null then
		tmpStrArray.add(debtor.name.trimBlanks);
	else
		tmpStrArray.add(null);
	endif;

	strCandHCode := tmpStrArray[1] &amp; " " &amp; tmpStrArray[3] &amp; " " &amp; tmpStrArray[2];

	if _strArray = null then
		return strCandHCode;
	endif;
	
	_strArray.clear;
	_strArray.add(tmpStrArray[1]);
	_strArray.add(tmpStrArray[3]);
	_strArray.add(tmpStrArray[2]);
	
	return strCandHCode;
epilog
	delete tmpStrArray;	
end;</source>
        <Parameter name="_strArray" type="StringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
