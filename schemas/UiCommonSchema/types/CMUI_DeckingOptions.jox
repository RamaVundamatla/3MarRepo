    <JadeMethod name="doAddInRuleToTable" id="a949a664-5df8-43cd-95cd-16ed1d6197da">
        <source>doAddInRuleToTable();
//----------------------------------------------------------------
//	Created:	25 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	tbl			: CM_Table;
	pxyRule,
	conflRule	: CM_YADeckingRule;
	intRow,
	option,
	intFrom,
	intTo,
	maxHeight,
	idx			: Integer;
	pxyOpts		: CM_YADeckingOptions;
	rulesDelete	: CM_DeckingRuleByHeightFromAsc;
begin

	on Exception do self.addToTableExHandler(exception);

	tbl := self.tblInOptions;
		
	option := self.getOptionFromCombo(self.cmbInOptions);
	if option &lt; 0 then
		//app.raiseUnexpectedProgramError(class.name, method.name, 'invalid decking option');
		app.msgBox('The option selected is invalid.', app.getErrorString(Warning), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	intFrom := self.txtFromIn.text.Integer;
	intTo := self.txtToIn.text.Integer;
	
	if intFrom &gt; intTo 
	or intFrom = null
	or intTo = null then
		app.msgBox('The heights entered are invalid.' &amp; CrLf &amp; 'Please check the heights and try again.', app.getErrorString(Warning), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	maxHeight := self.getHeightForBlockObject();
	if intTo &gt; maxHeight then
		app.msgBox('The heights entered exceed the maximum for the selected area (' &amp; maxHeight.String &amp; ').' &amp; CrLf &amp; 'Please check the heights and try again.', app.getErrorString(Warning), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;	
	endif;
	
	pxyOpts := self.myProxyDeckingOptions;
	
	create pxyRule transient;
	//set the proxy
	if option = DeckingRule_Default then
		option := pxyOpts.getDefaultRuleIn(intFrom);	
	endif;
	pxyRule.setProxyBasic(option, intFrom, intTo, true);

	create rulesDelete transient;
	//remove conflicting (overlapping) rules
	foreach intRow in (tbl.fixedRows) to tbl.rows do
		conflRule := tbl.accessRow(intRow).itemObject.CM_YADeckingRule;
		if conflRule = null then
			continue;
		endif;
		if (conflRule.heightFrom &gt;= intFrom and conflRule.heightFrom &lt;= intTo)
		or (conflRule.heightTo &gt;= intFrom and conflRule.heightTo &lt;= intTo) then
			//conflicts
			rulesDelete.add(conflRule);
		endif;
	endforeach;
	
	foreach conflRule in rulesDelete do
		pxyOpts.allDeckingRulesIn.remove(conflRule);
		self.removeItemFromTable(conflRule, tbl);
		delete conflRule;
	endforeach;
	/*
	if tbl.row &gt; tbl.fixedRows then
		conflRule := tbl.accessRow(tbl.row).itemObject.CM_YADeckingRule;
	else
		conflRule := pxyOpts.allDeckingRulesIn[pxyRule.heightFrom];
	endif;
	
	if conflRule &lt;&gt; null then
		//if conflRule.heightFrom = pxyRule.heightFrom and
		if conflRule.heightTo &gt;= pxyRule.heightTo then
			//replace
			pxyOpts.allDeckingRulesIn.remove(conflRule);
			self.removeItemFromTable(conflRule, tbl);
			delete conflRule;
		else
			//clear the decks
			pxyOpts.allDeckingRulesIn.purge;
			tbl.rows := tbl.fixedRows;
		endif;
	endif;
	*/
	//add to proxy
	pxyOpts.allDeckingRulesIn.add(pxyRule);
	
	//add to table
	idx := tbl.addItem(pxyRule.getTableDisplay);
	tbl.accessRow(idx).itemObject := pxyRule;
	
	self.updateFromToInTxt(pxyRule.heightTo+1, maxHeight);
epilog
	delete rulesDelete;
end;</source>
    </JadeMethod>
    <JadeMethod name="doAddOutRuleToTable" id="d0a49e84-a44e-43af-9326-ec2890325464">
        <source>doAddOutRuleToTable();
//----------------------------------------------------------------
//	Created:	25 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	tbl			: CM_Table;
	pxyRule,
	conflRule	: CM_YADeckingRule;
	intRow,
	option,
	intFrom,
	intTo,
	maxHeight,
	idx			: Integer;
	pxyOpts		: CM_YADeckingOptions;
	rules,
	rulesDelete	: CM_DeckingRuleByHeightFromAsc;
begin

	on Exception do self.addToTableExHandler(exception);

	tbl := self.tblOutOptions;
	
	option := self.getOptionFromCombo(self.cmbOutOptions);
	if option &lt; 0 then
		//app.raiseUnexpectedProgramError(class.name, method.name, 'invalid decking option');
		app.msgBox('The option selected is invalid.', app.getErrorString(Warning), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	intFrom := self.txtFromOut.text.Integer;
	intTo := self.txtToOut.text.Integer;
	
	if intFrom &gt; intTo 
	or intFrom = null
	or intTo = null then
		app.msgBox('The heights entered are invalid.' &amp; CrLf &amp; 'Please check the heights and try again.', app.getErrorString(Warning), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	maxHeight := self.getHeightForBlockObject();
	if intTo &gt; maxHeight then
		app.msgBox('The heights entered exceed the maximum for the selected area (' &amp; maxHeight.String &amp; ').' &amp; CrLf &amp; 'Please check the heights and try again.', app.getErrorString(Warning), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;	
	endif;
	
	pxyOpts := self.myProxyDeckingOptions;
	
	create pxyRule transient;
	//set the proxy
	if option = DeckingRule_Default then
		option := pxyOpts.getDefaultRuleOut(intFrom);	
	endif;
	pxyRule.setProxyBasic(option, intFrom, intTo, false);

	create rulesDelete transient;
	//remove conflicting (overlapping) rules
	foreach intRow in (tbl.fixedRows) to tbl.rows do
		conflRule := tbl.accessRow(intRow).itemObject.CM_YADeckingRule;
		if conflRule = null then
			continue;
		endif;
		if (conflRule.heightFrom &gt;= intFrom and conflRule.heightFrom &lt;= intTo)
		or (conflRule.heightTo &gt;= intFrom and conflRule.heightTo &lt;= intTo) then
			//conflicts
			rulesDelete.add(conflRule);
		endif;
	endforeach;
	
	foreach conflRule in rulesDelete do
		pxyOpts.allDeckingRulesOut.remove(conflRule);
		self.removeItemFromTable(conflRule, tbl);
		delete conflRule;
	endforeach;
	
	/*
	create rules transient;
	pxyOpts.allDeckingRulesOut.copy(rules);
	
	conflRule := rules[pxyRule.heightFrom];
	
	if conflRule &lt;&gt; null then
		if conflRule.heightTo &gt;= pxyRule.heightTo then
			//replace
			pxyOpts.allDeckingRulesOut.remove(conflRule);
			self.removeItemFromTable(conflRule, tbl);
			delete conflRule;
		else
			//clear the decks
			pxyOpts.allDeckingRulesOut.purge;
			tbl.rows := tbl.fixedRows;
		endif;
	endif;
	*/
	//add to proxy
	pxyOpts.allDeckingRulesOut.add(pxyRule);
	
	//add to table
	idx := tbl.addItem(pxyRule.getTableDisplay);
	tbl.accessRow(idx).itemObject := pxyRule;
	
	self.updateFromToOutTxt(pxyRule.heightTo+1, maxHeight);
epilog
	delete rules;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBaseFormCancel" id="94a850e5-2861-442b-bea7-30b7bf4e07cb">
        <updating/>
        <source>doBaseFormCancel() updating, protected;
//----------------------------------------------------------------
//	Created:	21 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	
	if app.msgBox(app.getErrorString(UnsavedChangesWillBeLost) &amp; CrLf &amp; app.getErrorString(AreYouSure), app.getErrorString(Warning), MsgBox_Yes_No + MsgBox_Exclamation_Mark_Icon) = MsgBox_Return_No then
		return;
	endif;

	inheritMethod();
	
	self.returnValue := IDCANCEL; 
	self.unloadForm;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBaseFormSave" id="24b1480f-b778-4013-a5aa-197658502ecc">
        <updating/>
        <source>doBaseFormSave() updating, protected;
//----------------------------------------------------------------
//	Created:	21 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	
begin

	//critical validation - also done in transaction
	
	if self.myProxyDeckingOptions.inOptionType = DeckingRule_Custom then
		self.myProxyDeckingOptions.validateCustomIn();
	else
		//validate the rules don't overlap or miss out cells
		self.myProxyDeckingOptions.validateInRules();
	endif;
	
	if self.myProxyDeckingOptions.outOptionType = DeckingRule_Custom then
		self.myProxyDeckingOptions.validateCustomOut();
	else
		//validate the rules don't overlap or miss out cells
		self.myProxyDeckingOptions.validateOutRules();
	endif;
	
	inheritMethod();
	
	self.doSave();
	
	self.returnValue := IDOK; 
	self.unloadForm;


end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doDeleteFromTable" id="f115803b-38b5-4144-9fa2-b1ab15edf357">
        <source>doDeleteFromTable(_tbl: CM_Table input);
//----------------------------------------------------------------
//	Created:	25 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	row	: Integer;
	pxy	: Object;
begin
	row := _tbl.row;
	
	if row &lt;= _tbl.fixedRows then
		return;
	endif;
	
	//delete the proxy and remove the row
	pxy := _tbl.accessRow(row).itemObject;
	delete pxy;
	_tbl.removeItem(row);

end;</source>
        <Parameter name="_tbl" type="CM_Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doDragDropLstLocations" id="2dc37ab5-bcf1-48d6-a0d4-50f8f41ee651">
        <updating/>
        <source>doDragDropLstLocations(listbox: ListBox input; win: Window input; x: Real; y: Real) updating;
//----------------------------------------------------------------
//	Created:	22 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------

vars
	idx					: Integer;
	yaLocnCellTarget 	: CM_YALocationCell;
	tmpArray			: CM_YALocationCellArray;
	targetIndex			: Integer;
begin
	targetIndex := listbox.dragListIndex;
	
	if targetIndex &lt; 1 then
		return;
	endif;

	yaLocnCellTarget := listbox.itemObject[targetIndex].CM_YALocationCell;

	if yaLocnCellTarget = null then
		return;
	endif;

	if self.allSelectedLocnCells.includes(yaLocnCellTarget) then
		//user is backing out of the drag
		return;
	endif;

	create tmpArray transient;
	foreach yaLocnCellTarget in self.allSelectedLocnCells do
		idx := listbox.findObject(yaLocnCellTarget);
		tmpArray.atPut(idx, yaLocnCellTarget);
	endforeach;

	foreach yaLocnCellTarget in tmpArray reversed do
		if yaLocnCellTarget = null then
			//there'll be heaps of these for big lists
			continue;
		endif;
		idx := listbox.findObject(yaLocnCellTarget);
		listbox.removeItem(idx);
		if idx &lt; targetIndex then
			//keep adjusting for the removal
			targetIndex := targetIndex - 1;
		endif;
		
		self.addItemToListAt(targetIndex, yaLocnCellTarget);
		
		if not self.customOrderHasChanged then
			self.setCustomOrderHasChanged(true);
		endif;
		
	endforeach;

epilog
	delete tmpArray;
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doDragOverLstLocations" id="d1e5a63b-2b0c-4a77-8d14-21e3f90aa984">
        <updating/>
        <source>doDragOverLstLocations(listbox: ListBox input; win: Window input; x: Real; y: Real; state: Integer) updating;
//----------------------------------------------------------------
//	Created:	22 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	indexOver,
	indexBefore : Integer;
begin
	
	indexBefore := self.selectedIndex;
	
	
	//if self.selectedIndex &gt; 0 and self.selectedIndex &lt;= self.lstDeckingLocns.listCount then
	//	self.selectedIndex := ;
	//endif;
	
	indexOver := self.lstDeckingLocns.dragListIndex();

	if indexOver = indexBefore 
	or indexOver &lt; 1 then
		return;
	endif;

	self.lstDeckingLocns.clearAllSelected();

	if indexOver &lt; 1 then
		indexOver := indexBefore;
	endif;
	
	if indexOver &gt; 0 then
		self.selectedIndex := indexOver;
		self.lstDeckingLocns.itemSelected[indexOver] := true;
	endif;
					
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="state" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doDragOverScrollArea" id="17ab157d-0096-4028-befb-10b70f1d13e9">
        <updating/>
        <source>doDragOverScrollArea(_top: Boolean) updating;
//----------------------------------------------------------------
//	Created:	24 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	now		: Integer;
begin
	now := app.clock();

	if _top then
		//scroll up
		if self.lstDeckingLocns.topIndex = 1 then
			//stop scrolling
			return;
		endif;
		if (now - self.lastScrollClock) &gt; 10 then	
			self.lstDeckingLocns.topIndex := self.lstDeckingLocns.topIndex - 5;
			self.lastScrollClock := now;
		endif;
	else
		//scroll down
		if (self.lstDeckingLocns.topIndex + self.lstDeckingLocns.lines) &gt; self.lstDeckingLocns.listCount then
			//stop scrolling
			return;
		endif;
		if (now - self.lastScrollClock) &gt; 10 then	
			self.lstDeckingLocns.topIndex := self.lstDeckingLocns.topIndex + 5;
			self.lastScrollClock := now;
		endif;
	endif;
	
end;</source>
        <Parameter name="_top" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doInitControlsForObject" id="8d1b6b78-e070-467c-b1a0-ada1b34ba16e">
        <updating/>
        <source>doInitControlsForObject() updating;
//----------------------------------------------------------------
//	Created:	21 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	yaDeckingOptions	: CM_YADeckingOptions;
	pxyDeckingRule,
	deckingRule			: CM_YADeckingRule;
	idx					: Integer;
	gridArea			: CM_GridArea;
begin

	yaDeckingOptions := self.myProxyDeckingOptions;
	
	if yaDeckingOptions = null then
		return;
	endif;

	if yaDeckingOptions.myDeckingLevel = DeckingLevel_TA then
		gridArea := yaDeckingOptions.getGridArea;
		self.buildCombosForDeckingOpts(gridArea, DeckingLevel_TA, yaDeckingOptions);
	elseif yaDeckingOptions.myDeckingLevel = DeckingLevel_Row then
		self.buildCombosForGridRow(yaDeckingOptions);
	elseif yaDeckingOptions.myDeckingLevel = DeckingLevel_YA then
		self.buildCombosForYABlock(yaDeckingOptions);
	endif;

	self.chkOutUseRevOfIn.value := yaDeckingOptions.useReverseOfIn;
	self.chkShowHeights.value := yaDeckingOptions.showHeightsForCustom;
	
	//In
	foreach pxyDeckingRule in yaDeckingOptions.allDeckingRulesIn do
		idx := self.tblInOptions.addItem(pxyDeckingRule.getTableDisplay);
		self.tblInOptions.accessRow(idx).itemObject := pxyDeckingRule;
	endforeach;

	//Out
	foreach pxyDeckingRule in yaDeckingOptions.allDeckingRulesOut reversed do
		idx := self.tblOutOptions.addItem(pxyDeckingRule.getTableDisplay);
		self.tblOutOptions.accessRow(idx).itemObject := pxyDeckingRule;
	endforeach;

	//and the heights - show min and max
	self.txtFromIn.text := "1";
	self.txtToIn.text := yaDeckingOptions.getStackHeight.String;
	self.txtFromOut.text := "1";
	self.txtToOut.text := yaDeckingOptions.getStackHeight.String;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doMouseDownLstLocations" id="393a21de-b94f-4672-a94b-d2beb24b4a04">
        <updating/>
        <source>doMouseDownLstLocations(listbox: ListBox input; button: Integer; shift: Integer; x: Real; y: Real) updating;
//----------------------------------------------------------------
//	Created:	22 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	yaLocnCell : CM_YALocationCell;
begin

	if button = Window.MouseButton_Left then
		yaLocnCell := listbox.listObject.CM_YALocationCell;
		self.updateSelectedLocns(yaLocnCell, shift);						
	endif;

	self.dragMode := DragMode_None;	

	self.myCurrentListObject := yaLocnCell;

//	if button = 1 then
//		self.origXPos := x;
//		self.origYPos := y;
//	endif;

end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doMouseMoveLstLocations" id="f4c848cb-c155-4054-8858-e599a4fe818d">
        <updating/>
        <source>doMouseMoveLstLocations(listbox: ListBox input; button: Integer; shift: Integer; x: Real; y: Real) updating;
//----------------------------------------------------------------
//	Created:	22 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	blnSelected	: Boolean;
	numSelected	: Integer;
begin

	if button = 0 then
		return;
	endif; 
	foreach blnSelected in self.lstDeckingLocns.itemSelected do
		if blnSelected then
			numSelected := numSelected + 1;
		endif;
		if numSelected &gt; 2 then
			break;
		endif;
	endforeach;

	if numSelected &lt; 1 then
		return;
	endif;

	self.dragMode := DragMode_Drag;
	if numSelected = 1 then	
		self.dragCursor := self.lstDeckingLocns.dragCursor;
	else
		self.dragCursor := self.frmCustomSetting.dragCursor;
	endif;

end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doResize" id="7fae14a7-382b-4a1d-8ccd-010a3cbdef5f">
        <updating/>
        <source>doResize() updating;
//----------------------------------------------------------------
//	Created:	24 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	topPosition	: Real;
	
begin
	inheritMethod();
	
	topPosition				:=	frmToolbar.top + frmToolbar.height + 5;
	frmInOptions.top		:=	topPosition;
	frmOutOptions.top		:=	frmInOptions.top + frmInOptions.height + 5;
	self.height				:=	frmOutOptions.top + frmOutOptions.height + 38;
	self.lblScrollArea.top	:=	self.lstDeckingLocns.top + self.lstDeckingLocns.height;
end;</source>
    </JadeMethod>
    <JadeMethod name="doReverseOrderSelection" id="a1722688-98e4-4163-8386-fd9bdc3e8679">
        <updating/>
        <source>doReverseOrderSelection() updating;
//----------------------------------------------------------------
//	Created:	22 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	prevItemSelected,
	outSelection,
	inSelection,
	blnSelected		: Boolean;
	tmpArray		: CM_YALocationCellArray;
	idx,targetIndex	: Integer;
	yaLocnCell		: CM_YALocationCell;
begin
	//rule: selection must be contiguous

	create tmpArray transient;
	idx := 0;
	foreach blnSelected in self.lstDeckingLocns.itemSelected do
		idx := idx + 1;
		if blnSelected then
			if outSelection then
				//non-contiguous selection detected
				app.msgBox("To reverse a selection it must be contiguous.", "Error", MsgBox_OK_Only + MsgBox_Information_Icon);
				return;
			else
				yaLocnCell := self.lstDeckingLocns.itemObject[idx].CM_YALocationCell;
				tmpArray.add(yaLocnCell);
			endif;
		endif;
		if prevItemSelected
		and not blnSelected then
			outSelection := true;
		endif;
		prevItemSelected := blnSelected;
	endforeach;
	
	if tmpArray.isEmpty then
		return;
	endif;
	//must be OK to reverse
	
	targetIndex := self.lstDeckingLocns.findObject(tmpArray[1]);
	foreach yaLocnCell in tmpArray do
		if yaLocnCell = tmpArray[1] then
			//we're going to insert the others above it
			continue;
		endif;	
		idx := self.lstDeckingLocns.findObject(yaLocnCell);
		self.lstDeckingLocns.removeItem(idx);
	
		self.addItemToListAt(targetIndex, yaLocnCell);
		
		if not self.customOrderHasChanged then
			self.setCustomOrderHasChanged(true);
		endif;
	endforeach;
	
	
epilog
	tmpArray.clear;
	delete tmpArray;	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="8f9610b0-a91a-4a35-96b5-189eac228eb6">
