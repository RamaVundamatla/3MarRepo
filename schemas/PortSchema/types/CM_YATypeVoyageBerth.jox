    <JadeMethod name="isCMIFDataMatch" id="b6e8ad96-c851-437e-ab91-2139fd8fa6e6">
        <source>isCMIFDataMatch(_cmifAutoPlan: CMIF_YAAutoPlan; _yaData: CM_YADataObjects): Boolean;
// -------------------------------------------
// Created 27 May 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	
	return _cmifAutoPlan.isVoyageBerth_Match(_yaData);


end;</source>
        <Parameter name="_cmifAutoPlan" type="CMIF_YAAutoPlan"/>
