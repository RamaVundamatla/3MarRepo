    <JadeMethod name="addText" id="a6982598-6f74-4a49-a3f2-8cf61ac71ecd">
        <updating/>
        <source>addText(_locale : CM_Locale; text, shortText : String; _category : XLAT_Category) updating;

vars

begin
	myCategory := _category;
	allLocales.add(_locale);
	allText.add(text);
	if myCategory.usesShortText then
		allShortText.add(shortText);
	endif;
	if _locale.localeId = StandardTextLocaleStr then
		defaultLocaleIndex := allLocales.size;
	endif;

end;</source>
        <Parameter name="_locale" type="CM_Locale"/>
        <Parameter name="text" type="String"/>
        <Parameter name="shortText" type="String"/>
        <Parameter name="_category" type="XLAT_Category"/>
    </JadeMethod>
    <JadeMethod name="buildXml" id="90126e13-b35a-4842-9a53-769842b361e6">
        <source>buildXml():String;

vars

begin
	if self.myCategory.myConstantCategory.name = XLAT_FormCaptions then
		return self.zBuildXmlForFormControlConstan;
	elseif self.myCategory.myConstantCategory.name = XLAT_Exceptions then
		return self.zBuildXmlForTextMessageConstan(true);
	elseif self.myCategory.myConstantCategory.name = EntTableRows then
		return self.zBuildXmlForEntTableRow;
	elseif self.myCategory.myConstantCategory.name = XLAT_ReportNames then
		return self.zBuildXmlForReportNames;
	elseif self.myCategory.myConstantCategory.name = XLAT_Permissions then
		return self.zBuildXmlForPermissions;
	endif;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNumUniqueSubstitutionParams" id="d7683829-49a6-47b9-9849-2148be58ddb1">
        <source>getNumUniqueSubstitutionParams( _text : String ) : Integer protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 Nov 2008	cnwjk3	PAR 18461 - Need to be able to exclude parameters from the translation

*/

vars
	theArray			: BooleanArray;
	substitutionNumber	: Integer;
	numUniqueParams		: Integer;
	i,j					: Integer;
	strNum				: String;
	bTest				: Boolean;

begin
	create theArray transient;

	numUniqueParams := 0;
	i := _text.pos("%", 1);
	while i &lt;&gt; 0 do
		strNum := "";
		i := i + 1;
		while i &lt;= _text.length and (_text[i] &gt;= '0' and _text[i] &lt;= '9')  do
			strNum := strNum &amp; _text[i];
			i := i + 1;
		endwhile;		
			
		if strNum &lt;&gt; ""  then
			substitutionNumber := strNum.Integer;
			// Ignore any out of range as these will be picked up by range validation methods
			if substitutionNumber &gt; 0 and substitutionNumber &lt;= MAX_SUBSTITUTION_NUM  then
				theArray[substitutionNumber] := true;
			endif;
		endif;	
		if i &lt;&gt; 0 and i &lt;= _text.length then 
			i := _text.pos("%", i);
		else
			break;
		endif;
	endwhile;	
	
	// Count the unique number of params.  I really wanted to use a Set here, but it is overkill for
	// such a small amount of possible entries.
	foreach bTest in theArray do
		if bTest = true then
			numUniqueParams := numUniqueParams + 1;
		endif;
	endforeach;
	
	return numUniqueParams;
epilog
	delete theArray;
end;</source>
        <access>protected</access>
        <Parameter name="_text" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initialiseForXlatableStringScm" id="d8e6e6f9-e7e0-435a-b04b-f71bcebce732">
        <updating/>
        <source>initialiseForXlatableStringScm(text, shortText : String; _root : CM_Root; _category : XLAT_Category) updating;

// use this method when when creating scm file source to create a global constant for a new XLAT_TranslatableString object

vars

begin
	myRoot := _root;
	myCategory := _category;
	
	// clear arrays in case the proxy is being reused
	allLocales.clear;
	allText.clear;
	allShortText.clear; 
	
	// don't need any references	

	// copy across the default locale text
	allLocales.add(myRoot.getLocale(StandardTextLocaleStr, false));
	allText.add(text);
	allShortText.add(shortText);
end;</source>
        <Parameter name="text" type="String"/>
        <Parameter name="shortText" type="String"/>
        <Parameter name="_root" type="CM_Root"/>
        <Parameter name="_category" type="XLAT_Category"/>
    </JadeMethod>
    <JadeMethod name="initialiseFromConstant" id="1d7da4cf-df6b-4676-8ac1-81a0f580c14a">
        <updating/>
        <source>initialiseFromConstant(root : CM_Root; _constant : GlobalConstant):Boolean updating;

// use this method when reading the the global constant XML - the idea is that the the xml text is parsed ONCE, 
// then pass around the details as required
// 17/03/2015	cnwmh5	Transient Leaks

vars
	schemaName	: String;
	className	: String;
	localeName	: String;
	xmlDoc		: CM_XMLDocument;
	xmlElement	: JadeXMLElement;
	xmlArray	: JadeXMLElementArray;
	xmlElem		: JadeXMLElement;
	locale		: CM_Locale;
	text		: String;
	shortText	: String;
begin
	if _constant.text = null then
		return false;
	endif;

	myRoot := root;

	create xmlDoc transient;
	create xmlArray transient;

	xmlDoc.parseString(_constant.text);
	xmlDoc.getElementsByTagName( XMLTag_Header, xmlArray);
	xmlElement := xmlArray[1];

	schemaName := xmlElement.getAttributeByName(XML_Tag_SchemaName).value;
	className := xmlElement.getAttributeByName(XML_Tag_FormClass).value;

	mySchema := rootSchema.getSchema(schemaName);
	myClass := mySchema.getClass(className);
	setConstant(_constant);
	
	xmlDoc.getElementsByTagName(XMLTag_LocaleMsg, xmlArray);

	foreach xmlElem in xmlArray where xmlElem.attributes.size &gt; 0 do
		localeName := xmlElem.getAttributeByName(XMLTag_LocaleName).value;
		if localeName = null then
			app.raiseCMException2(MethodWithNullParam, method.name, 'localeName', null, null);
		endif;
		if localeName &lt;&gt; StandardTextLocaleStr then
			// Only update Standard Locale from Global Constant
			continue;
		endif;

		locale 	  := myRoot.getLocale(localeName, true);
		text 	  := xmlElem.getTagValueOfName(XMLTag_Msg);
		shortText := xmlElem.getTagValueOfName(XMLTag_ShortMsg);

		allLocales.add(locale);
		allText.add(text);
		allShortText.add(shortText);

		// record the default locale index
		if localeName = StandardTextLocaleStr then
			defaultLocaleIndex := allText.size;
		endif;

	endforeach;

	return true;
epilog
	delete xmlArray;
	delete xmlDoc;
end;</source>
        <Parameter name="root" type="CM_Root"/>
        <Parameter name="_constant" type="GlobalConstant"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initialiseFromNewFormControl" id="9427b64b-f8e5-4680-b60a-2232ae10130a">
        <updating/>
        <source>initialiseFromNewFormControl(_root : CM_Root; _schema : Schema; _class : Class; _constant : GlobalConstant; _newDefaultLocaleText : String) updating;

// use this method when when creating scm file source to create a global constant from a new form control, i.e there is no existing
// global constant or associated XLAT_FormCaption instance (so only interested in text for default locale in this circumstance)

vars

begin
	// clear arrays in case the proxy is being reused
	allLocales.clear;
	allText.clear;
	allShortText.clear; 
	
	// set references	
	myRoot := _root;
	mySchema := _schema;
	myClass := _class;
	setConstant(_constant);

	// copy across the default locale text
	allLocales.add(myRoot.getLocale(StandardTextLocaleStr, false));
	allText.add(_newDefaultLocaleText);

end;</source>
        <Parameter name="_root" type="CM_Root"/>
        <Parameter name="_schema" type="Schema"/>
        <Parameter name="_class" type="Class"/>
        <Parameter name="_constant" type="GlobalConstant"/>
        <Parameter name="_newDefaultLocaleText" type="String"/>
    </JadeMethod>
    <JadeMethod name="setConstant" id="c8caed29-bdf4-4edf-8992-94255fe47106">
        <updating/>
        <source>setConstant(constant : GlobalConstant) updating;

vars

begin
	myConstant := constant;
end;
</source>
        <Parameter name="constant" type="GlobalConstant"/>
    </JadeMethod>
    <JadeMethod name="updateExistingFormCaptionText" id="b3301b9e-274b-4b8c-9e61-d6494c4ca04f">
        <updating/>
        <source>updateExistingFormCaptionText(_newDefaultLocaleText : String; _existingTranslations : XLAT_FormCaption) updating;

// use this method when creating scm file source to update a global constant from an existing form control, i.e there is an existing
// global constant and associated XLAT_FormCaption instance
// Watch out for multiple locales in this circumstance - don't overwrite user translations

vars
	translation : XLAT_Translation;
begin
	// clear arrays in case the proxy is being reused
	allLocales.clear;
	allText.clear;
	allShortText.clear; 
	
	// references already set by initialise... method
	
	// copy across translated text
	foreach translation in _existingTranslations.allTextByLocale do
		allLocales.add(translation.myLocale);

		if translation.myLocale.localeId = StandardTextLocaleStr then

			// default locale - overwrite with (maybe) updated value from the control caption
			allText.add(_newDefaultLocaleText);	
			defaultLocaleIndex := allText.size;
			
		else
			// preserve any existing translation for other locales
			allText.add(translation.text);	
		endif;
	endforeach;
	
end;</source>
        <Parameter name="_newDefaultLocaleText" type="String"/>
        <Parameter name="_existingTranslations" type="XLAT_FormCaption"/>
    </JadeMethod>
    <JadeMethod name="vDefaultShortText" id="19bc1eab-e5fd-4141-a0e8-b4075e4294ae">
        <methodInvocation>mapping</methodInvocation>
        <source>vDefaultShortText(set: Boolean; _value: String io) mapping;

vars

begin
	if set then
		// read-only
	else
		_value := allShortText[defaultLocaleIndex];
	endif;


end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="vDefaultText" id="35d43aff-71c7-4400-b6a8-6572688dcc2e">
