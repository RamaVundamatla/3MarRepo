    <JadeMethod name="showHeightExceededForm" id="77ae2e2f-00b0-423a-bc03-ac740e620219">
        <source>showHeightExceededForm(_hghtExceedObj : CMIF_YardHeightExceeded; _viewMode : Integer; _menuAction : CMUI_MenuAction);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 November 2009	cnwphb1	Initial creation (PAR 21532 CCMS SFW 1025)

*/
	
vars
	objs		: ObjectArray;
	gc			: CM_GridController;
begin
	gc := _hghtExceedObj.myLocationsController.CM_GridController;
	create objs transient;
	
	objs.add(gc.myGridRow.allControllersByColumn.first);
	objs.add(gc.myGridRow.allControllersByColumn.last);

	self.showYardGridAreasForm(objs, _viewMode, _menuAction, _hghtExceedObj.extraStackHeight);
epilog
	delete objs;
end;
</source>
        <Parameter name="_hghtExceedObj" type="CMIF_YardHeightExceeded"/>
        <Parameter name="_viewMode" type="Integer"/>
        <Parameter name="_menuAction" type="CMUI_MenuAction"/>
    </JadeMethod>
    <JadeMethod name="showHideDriverPieceCount" id="8c2fddac-3757-48bf-b418-70e3c4024d82">
        <source>showHideDriverPieceCount(pTable : CM_EntryTable input; pShow : Boolean);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 January 2010	cnwas3	Initial creation

*/

vars
	r	: Integer;	
begin

	if pTable &lt;&gt; null then
		r := pTable.getRow(ETRow_PieceCountError);
		if r &gt; 0 then
			pTable.setValue(r, pShow);		
		endif;
		if pShow then
			pTable.showRowByName(ETRow_DriversPieceCount, false);				
		else
			pTable.hideRowByName(ETRow_DriversPieceCount, false);			
		endif;
	endif;
	
end;</source>
        <Parameter name="pTable" type="CM_EntryTable" usage="input"/>
        <Parameter name="pShow" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showHideGenCargoRows" id="9dcaa2ca-c865-4425-b21a-fbd940aeee7b">
        <source>showHideGenCargoRows(_cargoType: CM_CargoType; _table: CM_EntryTable input);
//----------------------------------------------------------------
//	Created:	24 April 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	entDef			: EntTableDef;
	entRow			: EntTableRow;
	tmpCargoType	: CM_CargoType;
begin

	tmpCargoType := _cargoType;
	
	if tmpCargoType = null then
		return;
	endif;
	
	//show/hide GC rows
	entDef := app.myController.getEntTableDef(ETDef_AllAttributes);
	foreach entRow in entDef.allEntTableRows do
		if tmpCargoType.allAttributesOnProduct.includes(entRow.name) then
		// This is the new one for after 7.4.1 release	
		//if _cargoType.getAttributeValue(entRow.name).Boolean then
			_table.showRowByName(entRow.name, false);
		else
			_table.hideRowByName(entRow.name, false);
		endif;
	endforeach;	
epilog
end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_table" type="CM_EntryTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="showIdMaskWindow" id="9b4b3726-8212-4ec7-b516-4ccb16c59ce9">
        <updating/>
        <source>showIdMaskWindow(pTable : CM_EntryTable input; pRow : Integer; pCaption : String; pHint : String) updating;

vars
	form : CMUI_IDFilterEntry;
	parent : CM_BaseForm;
begin
	
	parent := pTable.form.CM_BaseForm;

	create form transient;  //+ dh 9/11/2007 for par 14360

	//- dh 9/11/2007 for par 14360 
	//form := app.loadForm(CMUI_IDFilterEntry, CMUI_Assistant, false, false, true, self.myTerminal, parent.myMasterMenuAction).CMUI_IDFilterEntry;

	if form = null then
		return;
	endif;

	form.label1.caption := pHint;
	form.caption := pCaption;
	form.idString := pTable.getValue(pRow).String.splitToMultiLine;
	form.showModal;

	pTable.setValue(pRow,form.idString.splitToSingleLine);
	
epilog
	delete form;
end;</source>
        <Parameter name="pTable" type="CM_EntryTable" usage="input"/>
        <Parameter name="pRow" type="Integer"/>
        <Parameter name="pCaption" type="String"/>
        <Parameter name="pHint" type="String"/>
    </JadeMethod>
    <JadeMethod name="showIdMaskWindowFlexi" id="08a21934-f408-4190-90c7-037ee152d205">
        <updating/>
        <source>// cnwjk3 - sfw1035
showIdMaskWindowFlexi(_caption, _hint, _idMask : String): String updating;

vars
	form 	: CMUI_IDFilterEntry;
	line	: String;
begin
	
	create form transient; 

	form.label1.caption := _hint;
	form.caption := _caption;
	form.idString := _idMask.splitToMultiLine();
	form.showModal;

	line := form.idString.splitToSingleLine();
	line := line.replaceString(",", ", ");
	return line;
epilog
	delete form;
end;</source>
        <Parameter name="_caption" type="String"/>
        <Parameter name="_hint" type="String"/>
        <Parameter name="_idMask" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
