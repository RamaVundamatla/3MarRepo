    <JadeMethod name="getWeightQuantityForRelease" id="ed147106-69e7-47f9-9e0c-d40f33aceafa">
        <source>getWeightQuantityForRelease(_release : CM_BulkRelease; 
							_tiSet 	: CM_TISet input;
							_weightLoaded : Decimal output) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 September 2021	jlier1	Initial creation

*/

vars
	ti : CM_TrackedItem;
	count: Integer;
	isWagon : Boolean;
begin
	if self.isKindOf(CM_WagonController) then
		isWagon :=true;
	endif;

	foreach ti in self.allTrackedItems discreteLock  do
		if _tiSet.includes( ti ) then
			continue;
		endif;
		_tiSet.add(ti);
		if not isWagon and ti.isROB then
			continue;
		endif;
		//13 Jun 2016	NDL	TFS 2133 - Count should be relative to the Release 
		if _release &lt;&gt; null and not ti.allBulkReleasesAssigned.includes( _release) then
			continue;
		endif;

		count := count + ( ti.totalQuantity.max(1) );
		_weightLoaded := _weightLoaded + ti.totalWeight;
	endforeach;
	
	return count;

epilog

end;</source>
        <Parameter name="_release" type="CM_BulkRelease"/>
        <Parameter name="_tiSet" type="CM_TISet" usage="input"/>
        <Parameter name="_weightLoaded" type="Decimal" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
