    <JadeMethod name="cloneAreaFrame" id="4a3cc3de-e54d-4c4f-accd-572df391e056">
        <updating/>
        <source>cloneAreaFrame( _areaViewPosition : CM_TerminalAreaViewPosition ) : Frame updating;

/*

Purpose:		Create Area frame for display.

Parameters:			

Return Value:		


Date				Who		Reason
01 September 2008	consw1	Initial creation

*/

vars
	clonedFrame : Frame;
	
begin
	if (self.isEditMode or self.isAddMode) then
		clonedFrame := self.frmArea.loadControl(self.allAreaFrames.size + 1).Frame;
	else
		clonedFrame := self.frmAreaFixed.loadControl(self.allAreaFrames.size + 1).Frame;
	endif;
		
	clonedFrame.userObject := _areaViewPosition;

	if clonedFrame.isKindOf(CMUI_ResizableRectFrame) and  _areaViewPosition.myTerminalArea.canBeDesigned then
		clonedFrame.CMUI_ResizableRectFrame.canResizeHeight:=false;
		clonedFrame.CMUI_ResizableRectFrame.canResizeWidth:=false;
		
		//clonedFrame.CMUI_ResizableRectFrame.
	endif;
	self.allAreaFrames.add(clonedFrame);
	
	return clonedFrame;
	
epilog

end;</source>
        <Parameter name="_areaViewPosition" type="CM_TerminalAreaViewPosition"/>
        <ReturnType type="Frame"/>
    </JadeMethod>
