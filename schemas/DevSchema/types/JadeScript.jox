    <JadeMethod name="eprTestMachineBestPick" id="f588a599-9891-4cae-a57f-1462268504a6">
        <source>eprTestMachineBestPick();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 February 2022	jlier1	Initial creation

*/

vars
	agent: CM_YAAutoplanAgent;
	rtQueueTask : CM_RTQueueTask;
	ti : CM_TrackedItem;
begin

	app.initialize;
	app.myPassport.setMyUserFromCode("JLGER1");
	rtQueueTask:="2832.6610103".asOid.CM_RTQueueTask;
	app.myPassport.setMyTerminal(rtQueueTask.getMyTerminal);
	agent := app.myYAAgent;
	if agent = null then
		app.initialiseForStartAutoPlan(app.myPassport);
		agent := app.myYAAgent;
	endif;
	
	if agent = null then
		return;
	endif;
	
	
	ti := agent.sourceTIForBestPickDirector(rtQueueTask);
	
	app.finalize;
epilog

end;</source>
