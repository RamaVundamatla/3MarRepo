TMD+3++2'
LOC+9+ITSAL:139:6+SALERN:BER:ZZZ:SALERNO CONTAINER TERMINAL SPA'
LOC+11+MTMLA:139:6+:TER:ZZZ:MALTA FREEPORT TERMINAL LIMITED'
LOC+8+YEADE:139:6'
LOC+7+YEADE:139:6'
MEA+AAE+T+KGM:3890'
MEA+AAE+G+KGM:24000'
TDT+10++9'
LOC+5+ITSAL:139:6'
DTM+133:201902081516:203'
DTM+132:201902192200:203'
NAD+CF+HLC:160:166'
NAD+CU+763631:ZZZ++U. DEL CORONA &amp; SCARDIGLI SRL++LIVORNO (LEGHORN)++57123'
CNT+16:1'
UNT+31+CANITSAL169534'
UNZ+2+65541'
";
	
	//===============================
	// Load File, and confim success
	//===============================
	ediFile := self.ediLoadFileName(strData, EDIFileType_Unknown, "COPARN", "COPARN-1"&amp;method.name);
	self.assertNotNull(ediFile);
	self.ediVerify(ediFile);	
	tempStr	:= 'Verify failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS, CM_EDIFile.EDI_STATUS_VERIFIED );
	self.ediDBLoad(ediFile);
	tempStr	:= 'DBLoad failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_DBLOADED);
	beginTransaction;
		delete ediFile; //Don't need the file anymore, so may as well delete it
	commitTransaction;
	
	//===============================
	// Confirm expected objects are created
	//===============================
	booking := self.getBooking(BookingNo);
	self.assertNotNull(booking);
	ti := self.getTrackedItem(ContainerId1);
	self.assertNotNullMsg(ti, "Prenote");
	ti := self.getTrackedItem(ContainerId2);
	self.assertNotNullMsg(ti, "Prenote");
		
	//===============================
	// Test Created booking lines are correct
	//===============================
	//should have 2 booking items of quantity 1
	self.assertEqualMsg(booking.allBookingRefItems.size(), 1, "Number of Booking Items");
	bookingItem := booking.allBookingRefItems.first();
	self.assertEqualMsg(bookingItem.quantity, 1, "Booking Item Quanity");
	
	// COMPLETED TEST FOUR
	
	
	
	//###########################
	//## Clean Up After Yourself
	//###########################
	beginTransaction;
	operator.setPropertyValue(CM_Operator::bookingsUniqueByNumber.name, opBookUnique);
	terminal.setConfig(EdiUseOldCoparn, ediUseOldCoparn);
	commitTransaction;
	
	// clear out previous test
	self.deleteEDIParty(PARTY);
	self.deleteBooking(BookingNo);			
	contId := ContainerId1;
	self.deleteTrackedItem(contId, false);
	contId2 := ContainerId2;
	self.deleteTrackedItem(contId2, false);
	
	self.deleteVoyage(VoyageName);
	self.deleteVessel(ShipName);
	
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	if pxyCollection &lt;&gt; null then
		pxyCollection.purge();
		delete pxyCollection;
	endif;
	delete proxyEDIParty;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCoparnBookingVent" id="07597337-d7f5-4a52-8a99-ae238ac36eb3">
        <source>tCoparnBookingVent();
// cnwrs1
/*
Date		Who		Reason
09 Jul 2013	cnwcs5	Initial Creation - par 31942 CCMS POL 2220 - FTX segment processing for Coparn/IFTMCS bookings
*/
constants
	MEASURE = 'UTDisplace';
vars
	result	:Decimal[14,4];
begin
	self.deleteMeasurementType (MEASURE);
	
	self.createMeasurementType (10, 14.4, true, false, false, false, MEASURE, Type_Displacement, MEASURE);
	
	result := self.zCoparnBookingVent ('OSI++21+CBM/H', 'OSI++%VENT+%UNITS');
	
	self.assertEqual (result, 21.Decimal);
	
	result := self.zCoparnBookingVent ('OSI++22+CBM/H', 'OSI++%VENT+CBM/H');
	
	self.assertEqual (result, 22.Decimal);
	
	result := self.zCoparnBookingVent ('OSI++CBM/H+23', 'OSI++%UNITS+%VENT');
	
	self.assertEqual (result, 23.Decimal);
	
	result := self.zCoparnBookingVent ('OSI++CBM/H+24', 'OSI++%UNITS+%VENT');
	
	self.assertEqual (result, 24.Decimal);
	
	result := self.zCoparnBookingVent ('OSI+++MTQ 25', 'OSI+++MTQ %VENT');
	
	self.assertEqual (result, 25.Decimal);
	
	result := self.zCoparnBookingVent ('OSI+++26 MTQ', 'OSI+++%VENT %UNITS');
	
	self.assertEqual (result, 26.Decimal);
	
	result := self.zCoparnBookingVent ('OSI+++MTQ 27', 'OSI+++%UNITS %VENT');
	
	self.assertEqual (result, 27.Decimal);
	
	result := self.zCoparnBookingVent ('OSI+++ABC~MTQ~CDE~28~FGH', 'OSI+++ABC~%UNITS~CDE~%VENT~FGH');
	
	self.assertEqual (result, 28.Decimal);
	
	result := self.zCoparnBookingVent ('OSI+++ABCMTQCDE29FGH', 'OSI+++ABC%UNITSCDE%VENTFGH');
	
	self.assertEqual (result, 29.Decimal);
	
	result := self.zCoparnBookingVent ('OSI+++ABC' &amp; MEASURE.toLower &amp; 'CDE30FGH', 'OSI+++ABC%unitsCDE%ventFGH');
	
	self.assertEqual (result, 300.Decimal);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tCoparnBookings" id="9479e3d4-f0ac-4204-9554-b658dfe70e2a">
        <source>tCoparnBookings();
// jlgmd1
/*

Purpose:			
Changes to allow more efficient processing of Coparn bookings in JMT. #01-868
Parameters:			

Return Value:		

Date									Who								Reason
12 July 2016					cnwrh7							Initial creation
// 21 Aug 2017	jlgrs1	TFS 6564 add Coparn and Coreor RFF and NAD translation
// 10 Sep 2019	cnwrs1	TFS 46030
*/
constants
	ShipName  			=	"MAERSK DUFFIELD";
	VoyageName1	= "MSK001";
	VoyageName2   = "MSK002";
	VoyageName3	= "MSK003";
	BookingNo			= "2523500001";
	PARTY 					= "HLL";
	SENDER1				= "MAEU";
	SENDER2 			= "HLL";
	TruckId					= "UTRHT1";
	ContainerId1 		= "UTMHXZ00011"; 
	TestOperator	= "HLL";
vars
	vessel			: CM_Vessel;
	voyage 		: CM_Voyage;
	ediParty		: CM_EDIParty;
	operator 		: CM_Operator;
	booking 		: CM_BookingRef;
	rules				: CM_EDIPartyCoparnRules;
	ediFile 			: CM_EDIFile;
	vvr 					: CM_VehicleVisitRecord;
	gate				: CM_Gate;
	
	terminalCode 									: String;
	strData 												: String;
	tempStr												: String;
	bookingsUniqueByNumber			: Boolean;
	bookingsUniqueByNumberSet		: Boolean;
	opBookUnique					: Boolean;
	contId							: String;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	self.deleteVoyageCutoff("PRENOTES");
	self.deleteVoyageCutoff("RELEASES");
	terminalCode := self.getTerminal.code;		//get TerminalCode
	operator :=  app.myRoot.allOperators ['HLL']; 
	
	opBookUnique := operator.bookingsUniqueByNumber;			//Remember what has been set in order to reset after running unit test
	beginTransaction;
	operator.setPropertyValue(CM_Operator::bookingsUniqueByNumber.name, false);
	commitTransaction;
	
	
	self.deleteVoyage(VoyageName1);		//delete Voyage
	self.deleteVessel(ShipName);					//delete Vessel
	self.deleteBooking(BookingNo);			//delete Booking
	contId := ContainerId1;
	self.deleteTrackedItem(contId, false);
	
	//Now set up cleanly
	//Add Vessel
	vessel := self.addVesselCellular(ShipName, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.assertNotNullMsg(vessel, "Add vessel failed");
	
	//Add Voyage
	voyage := self.addVoyageWithContainerStructur(VoyageName1, ShipName, 'HLL', self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	
	
	ediParty	:= self.createEDIPartyAndRules ('UT_HOLD' &amp; terminalCode, 'UT_HOLD' &amp; terminalCode, PARTY, PARTY, SENDER1, SENDER2, operator, true);
	rules		:= ediParty.getRulesForFileType (EDIFileType_Coparn).CM_EDIPartyCoparnRules;
	self.setTerminalConfig(EdiBookingCommodity, false);
	
	strData := "
UNB+UNOA:1+" &amp; SENDER1 &amp; " +NZPOE+090209:2000+25235'
UNH+" &amp; BookingNo &amp; "+COPARN:D:95B:UN:ITG14'
BGM+11+20090209200047+9'
RFF+BOOK:DP28524_1'
TDT+20+" &amp; VoyageName1&amp;"+1++MAE:172:20+++9227340:146:11:MAERSK DUFFIELD'
LOC+88+NZPOE:139:6'
LOC+9+NZPOE:139:6'
DTM+133:200903132200:203'
NAD+CZZ+CCS+NEW ZEALAND APPLE LIMITED'
NAD+CA+MAE:172:20'
GID+1'
FTX+AAA+++CONFECTIONARY'
EQD+CN++22G1:102:5+2+2+5'
RFF+BOOK:" &amp; BookingNo &amp; "'
EQN+2'
TMD+3++2'
LOC+8+GBFXT:139:6'
LOC+98+NZPOE:139:6'
LOC+11+GRAEF:139:6'
MEA+AAE+G+KGM:22000'
MEA+AAE+T+KGM:4840'
MEA+AAE+EGW+KGM:17242'
FTX+HAN++COA'
TDT+30+0904+1++MAE:172:20+++9166792:146:11:SKAGEN MAERSK'
LOC+11+GBFXT:139:6'
CNT+16:1'
UNT+29+"&amp;BookingNo&amp;"'
UNZ+1+25235'
";
	//Check the text
	ediFile := self.ediLoadFileName(strData, EDIFileType_Unknown, "COPARN", "COPARN-1"&amp;method.name);
	self.assertNotNull(ediFile);
	self.ediVerify(ediFile);	

	tempStr	:= 'Verify failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg( ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS, tempStr );
	self.ediDBLoad(ediFile);
	tempStr	:= 'DBLoad failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_DBLOADED);
	booking := self.getBooking(BookingNo);
	self.assertNotNull(booking);
	
	//Step2 Bring in a cargo item for the booking
	self.deleteVehicle(TruckId);
	self.opts.purge();
	self.opts.addAssoc("BookingItem", booking.allBookingRefItems.first);
	vvr := self.gateInContainer(TruckId, ContainerId1, "2200", operator.code, "GENL", self.getProfileSetting(UT_Profile.P_SGATE).asString());	//Bring in a cargo item for the booking
	self.assertNotNull(vvr);
	
	//self.setTerminalConfig(AutoBookingCargoUpdates, true);
	
	//return;
	
	//Step3 Set up operator for the booking created above has "Bookings are Unique by Number" set to false.
	//operator := self.getOperator(TestOperator);
	//self.assertNotNullMsg(operator, 'Operator HLL does not exist');
	bookingsUniqueByNumber := operator.bookingsUniqueByNumber;				
	////bookingsUniqueByNumberSet := true;
	beginTransaction;
	operator.setPropertyValue(CM_Operator::bookingsUniqueByNumber.name, false);
	commitTransaction;
	
	//Step4 Edit the EDI File and Change the voyage to create a new booking with new voyage
	
	strData := "
UNB+UNOA:1+" &amp; SENDER1 &amp; " +NZPOE+090209:2000+25235'
UNH+" &amp; BookingNo &amp; "+COPARN:D:95B:UN:ITG14'
BGM+11+20090209200047+9'
RFF+BOOK:DP28524_1'
TDT+20+" &amp; VoyageName2&amp;"+1++MAE:172:20+++9227340:146:11:MAERSK DUFFIELD'
LOC+88+NZPOE:139:6'
LOC+9+NZPOE:139:6'
DTM+133:200903132200:203'
NAD+CZZ+CCS+NEW ZEALAND APPLE LIMITED'
NAD+CA+MAE:172:20'
GID+1'
FTX+AAA+++CONFECTIONARY'
EQD+CN++22G1:102:5+2+2+5'
RFF+BOOK:" &amp; BookingNo &amp; "'
EQN+2'
TMD+3++2'
LOC+8+GBFXT:139:6'
LOC+98+NZPOE:139:6'
LOC+11+GRAEF:139:6'
MEA+AAE+G+KGM:22000'
MEA+AAE+T+KGM:4840'
MEA+AAE+EGW+KGM:17242'
FTX+HAN++COA'
TDT+30+0904+1++MAE:172:20+++9166792:146:11:SKAGEN MAERSK'
LOC+11+GBFXT:139:6'
CNT+16:1'
UNT+29+"&amp;BookingNo&amp;"'
UNZ+1+25235'
";
	self.deleteVoyage(VoyageName2);		//delete the Second Voyage to make it is clean
	
	voyage := self.addVoyageWithContainerStructur(VoyageName2, ShipName, 'HLL', self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);			//add the second Voyage
	
	ediFile := self.ediLoadFileName(strData, EDIFileType_Unknown, "COPARN", "COPARN-2"&amp;method.name);
	self.assertNotNull(ediFile);
	self.ediVerify(ediFile);	

	tempStr	:= 'Verify failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg( ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS, tempStr );
	self.ediDBLoad(ediFile);
	tempStr	:= 'DBLoad failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_DBLOADED);
	booking := self.getBooking(BookingNo);
	self.assertNotNull(booking);
	
	///return;
	
	//Step5 Delete the latest Booking
	self.deleteBooking(booking.bookingReference);
	
	//Step6 Make the Operator fo rthe booking has "Bookings are Unique by Number" set to true
	beginTransaction;
	operator.setPropertyValue(CM_Operator::bookingsUniqueByNumber.name, true);
	commitTransaction;
	
	//Step7 Edit the file (Voyage) again to reload
	
	strData := "
UNB+UNOA:1+" &amp; SENDER1 &amp; " +NZPOE+090209:2000+25235'
UNH+" &amp; BookingNo &amp; "+COPARN:D:95B:UN:ITG14'
BGM+11+20090209200047+9'
RFF+BOOK:DP28524_1'
TDT+20+" &amp; VoyageName3&amp;"+1++MAE:172:20+++9227340:146:11:MAERSK DUFFIELD'
LOC+88+NZPOE:139:6'
LOC+9+NZPOE:139:6'
DTM+133:200903132200:203'
NAD+CZZ+CCS+NEW ZEALAND APPLE LIMITED'
NAD+CA+MAE:172:20'
GID+1'
FTX+AAA+++CONFECTIONARY'
EQD+CN++22G1:102:5+2+2+5'
RFF+BOOK:" &amp; BookingNo &amp; "'
EQN+2'
TMD+3++2'
LOC+8+GBFXT:139:6'
LOC+98+NZPOE:139:6'
LOC+11+GRAEF:139:6'
MEA+AAE+G+KGM:22000'
MEA+AAE+T+KGM:4840'
MEA+AAE+EGW+KGM:17242'
FTX+HAN++COA'
TDT+30+0904+1++MAE:172:20+++9166792:146:11:SKAGEN MAERSK'
LOC+11+GBFXT:139:6'
CNT+16:1'
UNT+29+"&amp;BookingNo&amp;"'
UNZ+1+25235'
";
	self.deleteVoyage(VoyageName3);		//delete the Third Voyage to make it is clean
	
	voyage := self.addVoyageWithContainerStructur(VoyageName3, ShipName, 'HLL', self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);			//add the thid Voyage
	
	
	ediFile := self.ediLoadFileName(strData, EDIFileType_Unknown, "COPARN", "COPARN-3"&amp;method.name);
	self.assertNotNull(ediFile);
	self.ediVerify(ediFile);	

	tempStr	:= 'Verify failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg( ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS, tempStr );
	self.ediDBLoad(ediFile);
	tempStr	:= 'DBLoad failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_DBLOADED);
	booking := self.getBooking(BookingNo);
	self.assertNotNull(booking);
	self.assertEqualMsg(booking.consignorCode, "CCS", "wrong consignor");
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	beginTransaction;
	operator.setPropertyValue(CM_Operator::bookingsUniqueByNumber.name, opBookUnique);
	commitTransaction;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCoparnHLLFTX" id="d8e11183-d7d1-45fc-961e-074d7a0429e3">
        <source>tCoparnHLLFTX();
// cnwrs1
// cnwcs5 par 31942
// CCMS 2220
constants
	ShipName 	= "CCMS2220";
	VoyageName 	= "CCMS2220VOY";
	BookingNo 	= "CCMS2220";	
	PARTY		= 'HLL';
	SENDER1		= 'HAPAG-LLOYD';
	SENDER2		= 'HLL';
	REMARKS		= 'Some remarks';
	REMARKS2	= '** HEAVY RATED CTR RQD THKS **';
	REMARKS3_1	= 'TEMP  0.5 DEGREES CELSIUS';
	REMARKS3_2	= 'VENT 5M/H CONT RUNNING';
	REMARKS3_3	= 'HUM 85% DRAINS OPEN';
	REMARKS3	= REMARKS3_1 &amp; ' ' &amp; REMARKS3_2 &amp; ' ' &amp; REMARKS3_3;
vars
	vessel			: CM_Vessel;
	voyage			: CM_Voyage;
	ediFile 		: CM_EDIFile;
	booking 		: CM_BookingRef;
	bookingItem		: CM_BookingRefItem;
	text 			: String;
	tempStr 		: String;
	bookingItems 	: Integer;
	ediParty		: CM_EDIParty;
	rules			: CM_EDIPartyCoparnRules;
	code			: String;
	operator		: CM_Operator;
begin
	code 		:= self.getTerminal.code;
	operator	:= app.myRoot.allOperators ['HLL']; 
	
	self.assertNotNull (operator);
	
	self.deleteVoyage(VoyageName);
	self.deleteVessel(ShipName);
	self.deleteBooking(BookingNo);
	
	vessel := self.addVesselCellular(ShipName, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.assertNotNullMsg(vessel, "Add vessel failed");
	
	voyage := self.addVoyageWithContainerStructur(VoyageName, ShipName, 'HLL', self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);

	ediParty	:= self.createEDIPartyAndRules ('UT_HOLD' &amp; code, 'UT_HOLD' &amp; code, PARTY, PARTY, SENDER1, SENDER2, operator, true);
	rules		:= ediParty.getRulesForFileType (EDIFileType_Coparn).CM_EDIPartyCoparnRules;
	self.setTerminalConfig(EdiBookingCommodity, false);


	text := "
UNB+UNOA:2+" &amp; SENDER1 &amp; "+NZPOE+090826:0003+2885'
UNH+"&amp;BookingNo&amp;"+COPARN:D:95B:UN'
BGM+11:::GATE IN ORDER+"&amp;BookingNo&amp;"+9'
RFF+BN:"&amp;BookingNo&amp;"'
TDT+20+"&amp;VoyageName&amp;"+1++HLC:172:166+++DDBZ2:103::PATRICIA SCHULTE'
RFF+VON:033616'
LOC+9+NZPOE:139:6:PORT CHALMERS++:BER:ZZZ:PORT OTAGO LIMITED'
LOC+11+USPHL:139:6:PHILADELPHIA, PA'
DTM+133:200909092200:203'
DTM+132:200910051300:203'
NAD+CF+HLC:160:166'
GID+1'
FTX+AAA+++FZBF -22C'
EQD+CN++22R1:102:5++2+5'
EQN+1'
TMD+3++1'
LOC+9+NZPOE:139:6:PORT CHALMERS++:BER:ZZZ:PORT OTAGO LIMITED'
LOC+11+USPHL:139:6:PHILADELPHIA, PA'
LOC+7+USBED:139:6:BEDFORD, PA'
MEA+WT+G+KGM:21200'
MEA+WT+T+KGM:3200'
TMP+2+-21.0:CEL'
FTX+ABC+++" &amp; REMARKS &amp; "'
FTX+ABC+++THIS BOOKING CONFIRMATION IS SUBJECT TO RECEIVING OF ALL RELEVANT:BILL OF LADING / SEA WAYBILL DATA FROM THE SHIPPER IN DUE TIME:RESPECTIVELY ACCORDING TO LOCAL DOCUMENTATION CLOSING DATES/TIMES.:THE HAPAG-LLOYD AG SHALL NOT BE RESPONSIBLE FOR ANY COSTS/DELAYS OCCUR:DUE TO INTERVENTION OF CUSTOMS.'
FTX+ABC+++" &amp; REMARKS2 &amp; ":** SUBJECT TO EQUIPMENT AVAILABILITY **:HAPAG-LLOYD AG SHALL NOT BE RESPONSIBLE FOR ANY COSTS/DELAYS OCCUR:DUE TO INTERVENTION OF CUSTOMS.'
FTX+ABC+++" &amp; REMARKS3_1 &amp; ":" &amp; REMARKS3_2 &amp; ":" &amp; REMARKS3_3 &amp;":CHECKING OF REQUIRED TEMPERATURE AND AIRFLOW SETTINGS ON REFRIGERATED:CONTAINERS IS THE RESPONSIBILITY OF THE SHIPPER AT TIME OF PACKING.'
TDT+10'
NAD+CU++ALLIANCE GROUP LIMITED:51 DON STREET:INVERCARGILL'
CNT+16:1'
UNT+27+"&amp;BookingNo&amp;"'";

	ediFile := self.ediLoadFileName(text, EDIFileType_Unknown, "COPARN", "COPARN-1"&amp;method.name);
	
	self.assertNotNull(ediFile);
	self.ediVerify(ediFile);
	
	tempStr	:= 'Verify failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg( ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS, tempStr );
	
	self.ediDBLoad(ediFile);
	
	tempStr	:= 'DBLoad failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_DBLOADED);
	
	booking := self.getBooking(BookingNo);
	self.assertNotNull(booking);
	
	bookingItems := booking.allBookingRefItems.size;
	self.assertEqual(bookingItems, 1);
	
	bookingItem := booking.allBookingRefItems.first;
	
	self.assertEqualMsg (bookingItem.remarks[1:(REMARKS.length + REMARKS2.length + REMARKS3.length) + 2], 
		REMARKS &amp; ' ' &amp; REMARKS2 &amp; ' ' &amp; REMARKS3, 'Remarks not set');							// 14/07/2015 cnwmh5
		
epilog
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="tCoparnMOLFTX" id="3527b02b-9d33-4cd3-928d-199b053f0eb1">
        <source>tCoparnMOLFTX();
// cnwrs1
// cnwcs5 par 31942
// CCMS 2220
//16 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
constants
	ShipName 	= "MOL2220a";
	VoyageName 	= "MOL2220VOY";
	BookingNo1 	= "MOL2220a";	
	BookingNo2 	= "MOL2220b";
	PARTY		= 'MOL';
	SENDER1		= 'MOLNZ';
	SENDER2		= 'MOL';

vars
	vessel			: CM_Vessel;
	voyage			: CM_Voyage;
	ediFile 		: CM_EDIFile;
	booking 		: CM_BookingRef;
	bookingItem		: CM_BookingRefItem;
	text 			: String;
	tempStr 		: String;
	bookingItems 	: Integer;
	ediParty		: CM_EDIParty;
	rules			: CM_EDIPartyCoparnRules;
	code			: String;
	operator		: CM_Operator;
begin
	code 		:= self.getTerminal.code;
	operator	:= app.myRoot.allOperators ['MOL']; 
	
	self.assertNotNull (operator);
	
	self.deleteVoyage(VoyageName);
	self.deleteVessel(ShipName);
	
	self.deleteBooking(BookingNo1);
	self.deleteBooking(BookingNo2);
	
	vessel := self.addVesselCellular(ShipName, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.assertNotNullMsg(vessel, "Add vessel failed");
	
	voyage := self.addVoyageWithContainerStructur(VoyageName, ShipName, 'MOL', self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg (voyage, "Add voyage failed");

	ediParty	:= self.createEDIPartyAndRules ('UT_HOLD' &amp; code, 'UT_HOLD' &amp; code, PARTY, PARTY, SENDER1, SENDER2, operator, true);
	rules		:= ediParty.getRulesForFileType (EDIFileType_Coparn).CM_EDIPartyCoparnRules;



	text := "
UNA:+,? '
UNB+UNOA:1+" &amp; SENDER1 &amp; "+POWLG+130415:1049+5296'
UNH+8491+COPARN:D:95B:UN'
BGM+11+8491+9'
RFF+BN:"&amp;BookingNo1&amp;"'
TDT+20+"&amp;VoyageName&amp;"+1++MOL:172:166+++9323041:146::MOL WINTER'
RFF+VON:"&amp;VoyageName&amp;"'
LOC+8+INNSA:139:6'
LOC+9+NZWLG:139:6'
LOC+10+NZWLG:139:6'
LOC+11+SGSIN:139:6'
DTM+133:201304190530:203'
NAD+CA+MOL:172:20'
NAD+CZ++INTEGROW MARKETING LTD'
GID+1'
FTX+AAA+++APLA APPLES, FRESH/CHILLED'
SGP+17101073061L1'
EQD+CN++4532:102:5++2+5'
EQN+1'
MEA+WT+G+KGM:31600.000'
TMP+2+0.000:CEL'
FTX+OSI++21+CBM/H'
CNT+16:1'
UNT+22+8491'
UNH+8492+COPARN:D:95B:UN'
BGM+11+8492+9'
RFF+BN:"&amp;BookingNo2&amp;"'
TDT+20+"&amp;VoyageName&amp;"+1++MOL:172:166+++9323041:146::MOL WINTER'
RFF+VON:"&amp;VoyageName&amp;"'
LOC+8+THLKR:139:6'
LOC+9+NZWLG:139:6'
LOC+10+NZWLG:139:6'
LOC+11+SGSIN:139:6'
DTM+133:201304190530:203'
NAD+CA+MOL:172:20'
NAD+CZ++INTEGROW MARKETING LTD'
GID+1'
FTX+AAA+++APLA APPLES, FRESH/CHILLED'
SGP+17101073077L1'
EQD+CN++4532:102:5++2+5'
EQN+1'
MEA+WT+G+KGM:31600.000'
TMP+2+0.000:CEL'
FTX+OSI++22+MTQ'
CNT+16:1'
UNT+22+8492'
UNZ+2+5296'";

	ediFile := self.ediLoadFileName(text, EDIFileType_Unknown, "COPARN", "COPARN-1"&amp;method.name);
	
	self.assertNotNull(ediFile);
	self.ediVerify(ediFile);
	
	tempStr	:= 'Verified failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg( ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, tempStr );
	
	self.ediDBLoad(ediFile);
	
	tempStr	:= 'DB Load failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_DBLOADED);
	
	booking := self.getBooking(BookingNo1);
	self.assertNotNull(booking);
	
	bookingItems := booking.allBookingRefItems.size;
	self.assertEqual(bookingItems, 1);
	
	bookingItem := booking.allBookingRefItems.first;
	
	self.assertEqualMsg (bookingItem.getVentilation, '21'.Decimal, 'booking 1 - ventilation not set');
	
	booking := self.getBooking(BookingNo2);
	self.assertNotNull(booking);
	
	bookingItems := booking.allBookingRefItems.size;
	self.assertEqual(bookingItems, 1);
	
	bookingItem := booking.allBookingRefItems.first;
	
	self.assertEqualMsg (bookingItem.getVentilation, '22'.Decimal, 'booking 2 - ventilation not set');
epilog
	
end;
</source>
