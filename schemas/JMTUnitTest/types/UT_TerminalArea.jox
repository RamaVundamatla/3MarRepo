    <JadeMethod name="tUserDefinedDeliveryReason" id="a9c92c4a-44b2-40e6-8c1f-cd3c79ef724a">
        <source>tUserDefinedDeliveryReason();
/*

Purpose:			

Date		Who		Reason
02 February 2016	cnwmk3	Initial creation	PAR 37445

*/
vars

	releaseArea						: CM_BlockStack;
	consignee						: CM_ConsigneeConsignor;
	objSet							: ObjectSet;
	tiSet							: CM_TISet;	
	ti1								: CM_TrackedItem;
	deliveryReason					: CM_DeliveryReleaseReason;
	index							: Integer;
	dr								: Integer;
begin
	create tiSet transient;
	
	// create a release area
	releaseArea := self.addReleaseTransArea("UT_REL01", 50, null);
	self.assertNotNull(releaseArea);
	
	// add container to release area
	ti1 := self.addContainerAtLocation("CONTR00001", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), "2200", "APPL", TI_IMEX_STATUS_EXPORT, releaseArea.myLocationsController);
	tiSet.add(ti1);
	
	// check container is added to release area
	create objSet transient;
	releaseArea.getAllLocationsTrackedItems(objSet);
	self.assertEqual(objSet.size, 1);
	
	// release cargo adding a delivery release reason
	consignee := self.addConsigneeConsignor("MDH2", "UT MDH Consignee", true, false, false);
	self.assertNotNull(consignee);
	
	self.addDeliveryReleaseReason(100, "UserDefinedReason");
	deliveryReason := app.myRoot.allDeliveryReasonselReasons[100];
	app.myTrxDA.trxReleaseFromTransArea(tiSet, 0, consignee.code, deliveryReason.id.asStringJMT(), 100 , app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	// check released cargo item delivery Release Reason
	self.assertEqual(self.getTrackedItem("CONTR00001").deliveryReleaseReason, deliveryReason.id);
	
	// check cargo is released from the area
	objSet.clear();
	releaseArea.getAllLocationsTrackedItems(objSet);
	self.assertEqual(objSet.size, 0);
	
epilog
	delete objSet;
	delete tiSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="uPAR28048" id="5b7b3223-ea21-4aac-9fa3-057629d5ada8">
        <source>uPAR28048();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 August 2011	cnwmh5	Initial creation

*/
constants

	RTGAreaId				: String = "UTMHRTG1";
	BlockStackId			: String = "UTMHBS1";
	AllocationId			: String = "UTMDHPAR28048";
	ContainerId				: String = "UTMHQQ00001";

vars

	rtg						: CM_RTGArea;
	ya						: CM_YardAllocation;
	container				: CM_TrackedItem;
	location				: CM_LocationsController;
	blockStack				: CM_BlockStack;
	
	locations				: CM_LCArray;

begin

	// initial setup 
	self.disableAllYA(true);

	// create a block stack to put the container in 
	self.deleteTerminalArea(BlockStackId);
	blockStack := self.addBlockStack(BlockStackId, 10, null);
	self.assertNotNull(blockStack);
	
	
	// create rtg area with use 40ft id's set
	self.opts.purge();
	self.opts.addAssoc("use40ftIds", true);
	self.deleteTerminalArea(RTGAreaId);
	rtg := self.addRTGArea(RTGAreaId, 3, 5, 4);
	self.assertNotNull(rtg);
	
	// create ya
	create locations transient;
	locations.add(rtg.allGridControllersByRowColumn[1, 1]);
	locations.add(rtg.allGridControllersByRowColumn[1, 2]);
	locations.add(rtg.allGridControllersByRowColumn[2, 1]);
	locations.add(rtg.allGridControllersByRowColumn[2, 2]);
	
	self.deleteYA(AllocationId);
	ya := self.addYA1(AllocationId, YACriteriaType_ISO, "4310", locations);
	self.assertNotNull(ya);
	
	// create a container
	self.deleteContainer(ContainerId);
	container := self.addContainerAtLocation(ContainerId, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), "4310", "GENL", 3, blockStack.allLocationsControllers.first);
	self.assertNotNull(container);
	location := app.autoPlanTiYA(self.getTerminal(), rtg, container);
	//self.move(container, location);
	

epilog

	self.disableAllYA(false);
	
	//self.deleteYA(AllocationId);

	delete locations;
	
end;</source>
    </JadeMethod>
</Class>
