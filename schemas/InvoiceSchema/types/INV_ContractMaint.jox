    <JadeMethod name="btnCopy_click" id="d2a778fe-2b4a-4180-b8b9-6eec66a97302">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCopy_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Mar 2023 navtnr20 Bug 56906: EUP - Minor UX issues when adding contract/contract information
10/03/2023	navkc1	CR #55652 Task 56286: UI - Contract Detail Copy TRX
31/01/2023	navkc1 Bug 61578: EUP | FR 54089 - Invoice Contracts - Copy function extended
*/

vars
	form 		: INV_ContractRateMaint;
	clonedDtl,
	contractDtl	: CM_InvoiceContractDetails;
	today		: Date;
begin
	
	/* //31/01/2023	navkc1 Bug 61578 
	self.doBtnCopyClick(); // 13/03/2023	navkc1	CR 55652 Task 56286
	*/
	
	//31/01/2023	navkc1 Bug 61578 - We want to bring up a form and allow use to change the details
	contractDtl := self.tblData.accessRow(self.tblData.row).itemObject.CM_InvoiceContractDetails;
	
	if contractDtl = null then
		app.msgBox(app.getErrorString(Record_selected), app.getErrorString(Warning),MsgBox_OK_Only);
		return;
	endif;
	
	form := self.myContractRateMaint;
	
	if form &lt;&gt; null then
		form.unloadForm();
	endif;
	
	form := app.loadForm(INV_ContractRateMaint, INV_Assistant, false, false,false, self.myTerminal,null).INV_ContractRateMaint;
	self.myContractRateMaint := form;
	form.myParentForm := self;
	
	if form &lt;&gt; null then
		form.mode := INV_ContractRateMaint.MODE_COPY;
		form.setInvContract(self.myInvoiceContract);
		form.setMyCurrentBank(self.myCurrentBank);
		clonedDtl := contractDtl.cloneForCopy(true, false, today, true);
		form.setInvContractDetail(clonedDtl);
		form.centreWindow();
		form.show;
	endif;
	
epilog
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
