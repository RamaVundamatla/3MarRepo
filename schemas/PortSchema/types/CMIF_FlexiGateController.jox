    <JadeMethod name="setSealNumberValueDirect" id="d1f8675b-0e78-44b4-8f42-e8f163d0a766">
        <source>setSealNumberValueDirect( _sealType : CM_SealType; _sealNumValue : String; pDateTime : TimeStamp );

/*

Purpose:			

Parameters:			

Return Value:		
/* Changes

Date		Name	TFS#		Description
============================================================================
20/09/2010	cnwndl1	Initial creation	
			NDL	Par 25608 		Use/update new seals data structure
29 Mar 2019 jlgka1	TFS 44020	Change StringArray to HugeStringArray.
============================================================================*/

vars
	theCargoType 	  : CM_CargoType;
	pxySealTI 		  : CM_SealTI;
	sealTI 			  : CM_SealTI;
	previousValue 	  : String;
	sealNumArray 	  : HugeStringArray; //jlgka1 TFS 44020
	now 			  : TimeStamp;
	existingSealValue : String;

begin
	if _sealType = null then
		app.raiseCMException(NO_Seal_type_selected, null, null);
		return;
	endif;
	
	// don't continue if the value is already the same.
	sealTI := self.getSealTI( _sealType );
	if sealTI &lt;&gt; null then
		existingSealValue := sealTI.getSealValueAsString;
	endif;
	if existingSealValue = _sealNumValue then
		return;
	endif;
	
	theCargoType := app.myRoot.allCargoTypesById[self.cargoType];
	if theCargoType = null then
		app.raiseCMException2(Seal_type_not_valid_cargo_type, _sealType.description, null, null, null);
		return;
	endif;
	
	if not _sealType.allCargoTypes.includes( theCargoType ) then
		app.raiseCMException2(Seal_type_not_valid_cargo_type, _sealType.description, theCargoType.description, null, null);
		return;
	endif;
	
	if _sealType.notAvailableForEntry then
		app.raiseCMException1(NotAvailableForEntry, _sealType.description, null, null);
		return;
	endif;

	sealTI := self.getSealTI( _sealType );
	
	if pDateTime &lt;&gt; null then
		now := pDateTime;
	else
		now := app.actualTimeServer();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
	endif;
	
	if sealTI &lt;&gt; null  then
		// we have found an existing sealTi of this type already on the CMIF,
		// update its value if its changed.
		// This will be OK for a real object update or a proxy update.
		
		if _sealNumValue &lt;&gt; sealTI.getSealValueAsString then
		
			
			if not sealTI.allSealNums.isEmpty and _sealType.savePreviousSeal then
				previousValue := sealTI.getSealValueAsString;
			else
				previousValue := null;
			endif;
			sealTI.setPreviousSeal(previousValue);
			sealTI.allSealNums.clear();
			if _sealType.allowMultipleSealNums and _sealNumValue.pos(",",1) &gt; 0 then
				create sealNumArray transient;
				_sealNumValue.getTokensForDelimiterHuge(",",sealNumArray); //jlgka1 TFS 44020
				sealNumArray.copy( sealTI.allSealNums );
			else
				if _sealNumValue.trimBlanks &lt;&gt; null then
					sealTI.allSealNums.add( _sealNumValue.trimBlanks);
				endif;
			endif;
			sealTI.setSealedDT(now);
			
		endif;
		
	else
		
		if sealTI = null and _sealNumValue.trimBlanks &lt;&gt; null then
			// so create it.
			
			if _sealType.allowMultipleSealNums and  _sealNumValue.pos(",",1) &gt; 0 then
				create sealNumArray transient;
				_sealNumValue.getTokensForDelimiterHuge(",",sealNumArray); //jlgka1 TFS 44020
			endif;
			
			//create a proxy to do the updating from, don't link it to the tracked item yet
			create pxySealTI transient;
			pxySealTI.setProxy(	_sealNumValue.trimBlanks,		//_sealNum : String;
								sealNumArray,					//_sealNumArray : StringArray;
								null,							//_prevSeal : String;
								_sealType.sealType,				//_sealType : String;
								now,							//_sealedDT : TimeStamp;
								null							//_myTrackedItem : CM_TrackedItem
								);
			
			if self.isTransient then
				//The container is a proxy, just link the transient to me, all will be sorted in the transaction.
				self.allSeals.add( pxySealTI );
			
			else
				// this is a direct update to a real object, i.e. some lazy B#$%^ didn't follow the standard of
				// doing the updates via a proxy, so, create the real seal data from the transient and get rid of the transient
				create sealTI persistent;
				sealTI.setForCreate(pxySealTI);
				self.allSeals.add( sealTI );
				
				delete pxySealTI;
			
			endif;
			
		endif;
		
	endif;
	
epilog

	delete sealNumArray;
	
end;</source>
        <Parameter name="_sealType" type="CM_SealType"/>
        <Parameter name="_sealNumValue" type="String"/>
        <Parameter name="pDateTime" type="TimeStamp"/>
    </JadeMethod>
</Class>
