    <JadeMethod name="validateForUpdate" id="219d6838-0440-40de-bbc8-4a6a482c0a11">
        <source>validateForUpdate();
// 09 August 2011	cnwjre1	CCMS 1776 Cargo Enquiry User Definable Layout
begin
	if self.myUser = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "User", null, null);
		app.raiseCMException(Input_required_field_Usr, null, null); // cnwdb2	PAR 35364


	endif;
	if self.myCargoBOLType = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "Cargo Type", null, null);
		app.raiseCMException(Input_required_field_cargoType, null, null); // cnwdb2	PAR 35364
	endif;

end;
</source>
    </JadeMethod>
