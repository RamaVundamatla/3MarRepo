    <JadeMethod name="getDensity" id="188903df-05d9-4674-836e-daea3136ed14">
        <source>getDensity() : Decimal;
/*

Date		Who		Reason
16 June 2014	cnwer1	Initial creation PAR 34406
// ### TFS BUG 60216 04SEP2023 NAVAB1 return 1 if the density is zero

*/

vars
	density : Decimal [23,4];
begin
		
	if self.myProduct &lt;&gt; null and self.myProduct.myDensityDec &lt;&gt; null then		// ### TFS 52193 22Nov2021 NAVPW1
		density :=  self.myProduct.getDensityValue;
	endif;
	if self.myCargoType &lt;&gt; null then
		if self.myCargoType.mySystemProductType &lt;&gt; null  then
			density :=  self.myCargoType.mySystemProductType.getDensityValue;
		else
			density := self.myCargoType.defaultDensity;
		endif;
	endif;
	
	if density = 0 then
		return 1;
	endif;
	
	return density;
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
