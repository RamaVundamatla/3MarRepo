    <JadeMethod name="caption" id="39738503-0b0a-4ba0-8c41-dee2febdab17">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>caption(set: Boolean; value: String io) mapping, updating;

vars
	int : Integer;

begin
	if set then
		// Find all '&amp;' and replace them with '&amp;&amp;'
		int := 1;
		while int &gt; 0 and int &lt;= value.length do
			int := value.pos("&amp;", int);
			if int &gt; 0 then
				value := value[1 : int] &amp; value[int : end];
				int := int + 2;
			endif;
		endwhile;
	else
		// Find all '&amp;&amp;' and replace them with '&amp;'
		int := 1;
		while int &gt; 0 and int &lt;= value.length do
			int := value.pos("&amp;&amp;", int);
			if int &gt; 0 then
				if int + 2 &lt;= value.length then
					value := value[1 : int] &amp; value[int + 2 : end];
				else
					value := value[1 : int];
				endif;
				int := int + 1;			
			endif;
		endwhile;
	endif;
	inheritMethod(set, value);
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="click" id="e79cffaa-4979-4c16-9309-0b25c5a9317b">
        <updating/>
        <source>click(label: CnEcAppGridAppLabel input) updating;

vars

begin
	// If in print preview mode ...
	if app.printer.printPreview then
		// ...disable event handling
		return;
	endif;
	inheritMethod(label);
	appGrid.click(appGrid);	
end;</source>
        <Parameter name="label" type="CnEcAppGridAppLabel" usage="input"/>
    </JadeMethod>
