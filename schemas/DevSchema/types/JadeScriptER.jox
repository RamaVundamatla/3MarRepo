    <JadeMethod name="testEWSActivityHistoryGetAPIEndpoint" id="2c403f00-bc7b-4e9c-bf02-0045b71dc35b">
        <source>testEWSActivityHistoryGetAPIEndpoint();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 September 2024	jlier1	Initial creation

*/

vars
	invoice : CM_Invoice;
	secondLast : CM_EWSActivityInvoiceAPI;
	lastPart  : CM_EWSActivityInvoiceAPIParts;
	endpoint : CM_Endpoint;
	pos : Integer;
	epName : String;
	iter : Iterator;
begin
	invoice:= "2216.1183047".asOid.CM_Invoice;
	write invoice.allEWSInvoiceAPIActivities.last.CM_EWSActivityInvoiceAPI.attemptNumber;
	lastPart:= invoice.allEWSInvoiceAPIActivities.last.CM_EWSActivityInvoiceAPI.allEWSMessageParts.last;
	//secondLast:=invoice.allEWSInvoiceAPIActivities.getAtKeyLss(lastPart.myTerminal,lastPart.interfaceName,lastPart.createdTime).CM_EWSActivityInvoiceAPI;
//	write secondLast.attemptNumber;
	secondLast:=invoice.allEWSInvoiceAPIActivities.last.CM_EWSActivityInvoiceAPI;
	iter := invoice.allEWSInvoiceAPIActivities.createIterator;
	iter.back(secondLast);
	iter.back(secondLast);
	iter.current(secondLast);
	write secondLast.attemptNumber;
	//endwhile;
	//write epName;
	endpoint:= lastPart.getAPIEndpoint;
	if endpoint &lt;&gt; null then
		write endpoint.endpoint;
	endif;
epilog	
	delete iter;
end;</source>
    </JadeMethod>
