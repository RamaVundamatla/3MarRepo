    <JadeMethod name="translateForm" id="0572d831-d2af-462a-80fe-29710deadae4">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 12 December 2024 13:41:41.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0025831, locale);
	btnClear.translateCaption(Xlat_0025832, locale);
	btnClose.translateCaption(Xlat_0025833, locale);
	btnFindTi.translateCaption(Xlat_0025834, locale);
	btnRemove.translateCaption(Xlat_0025835, locale);
	btnSave.translateCaption(Xlat_0025836, locale);
	btnSaveNext.translateCaption(Xlat_0026273, locale);
	chkQuantity.translateBubbleHelp(Xlat_0026115, locale);
	chkQuantity.translateCaption(Xlat_0026116, locale);
	lblDebtor.translateCaption(Xlat_0025837, locale);
	lblInvoiceNum.translateCaption(Xlat_0025838, locale);
	lblLineType.translateCaption(Xlat_0026274, locale);
	lblQuantity.translateCaption(Xlat_0025840, locale);
	lblRemarks.translateCaption(Xlat_0027008, locale);
	lblStartDate.translateCaption(Xlat_0025841, locale);
	mnuColumnOrganizer.translateCaption(Xlat_0025842, locale);
	mnuContextMenu.translateCaption(Xlat_0025843, locale);
	msgInvLineType.translateCaption(Xlat_0025844, locale);
	shtDetail.translateCaption(Xlat_0025845, locale);
	shtItems.translateCaption(Xlat_0025846, locale);
	shtLineTypes.translateCaption(Xlat_0025847, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="unload" id="47cbe240-abfc-40b7-a757-c17368b7409b">
        <controlMethod name="CM_BaseForm::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>unload() updating, clientExecution;
/*

Purpose:			

Parameters:			

