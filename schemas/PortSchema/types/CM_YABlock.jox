    <JadeMethod name="updateProxyDeckingOptions" id="fed030ec-5e16-4e56-ab06-283cc4ad2cd2">
        <source>updateProxyDeckingOptions();
//----------------------------------------------------------------
//	Created:	12 August 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	locn				: CM_YardController;
begin
	self.raiseExceptionIfNotTransient(method);
	
	self.myDeckingOptions.allYALocationCellsIn.clear;
	
	//do this before setting default rules (will need to know what location cells are relevant)
	foreach locn in self.allYardControllers do
		locn.allYAYardLocationCells.copy(self.myDeckingOptions.allYALocationCellsIn);
	endforeach;

	self.myDeckingOptions.setOutDeckingReverseOfIn();
	
end;</source>
