    <JadeMethod name="setForCreate" id="054d9ac7-1dd0-4352-9107-dd40303ce936">
        <updating/>
        <source>setForCreate(_proxy : CM_RemoteDataHdr) updating;

vars

	pxyRemoteDetail,
	newRemoteDetail	: CM_RemoteDataDtl;
//	CM_RemoteDataHdrArray Use this to connect internal transactions to user.

begin

	self.messageId 					:= _proxy.messageId;
	self.messageType				:= _proxy.messageType;
	self.deviceId					:= _proxy.deviceId;
	self.msgInfo					:= _proxy.msgInfo;
	self.myRemoteDataRoot			:= _proxy.myRemoteDataRoot;
	self.myRadioTelemetryDevice		:= _proxy.myRadioTelemetryDevice;
	self.time						:= _proxy.time;
	self.userId						:= _proxy.userId;
	self.myUser						:= _proxy.myUser;
	self.myGUIUser					:= _proxy.myGUIUser;
	self.terminal					:= _proxy.terminal;
	self.theVersion					:= _proxy.theVersion;
	self.error						:= _proxy.error;
	self.errorText					:= _proxy.errorText;
	
	foreach pxyRemoteDetail in _proxy.allRemoteDataDtl do
		create newRemoteDetail as pxyRemoteDetail.class persistent;
		newRemoteDetail.setForCreate(pxyRemoteDetail, self);
	endforeach;

end;</source>
        <Parameter name="_proxy" type="CM_RemoteDataHdr"/>
    </JadeMethod>
    <JadeMethod name="setPassportTerminal" id="477f18bf-8525-45b9-87f0-fde4b92e5d24">
        <source>setPassportTerminal() protected;

// Created by cnwdvb1 on 06 August 2007

vars

	theTerminal	: CM_Terminal;

begin

	theTerminal := app.myRoot.allTerminals[self.terminal];
	if theTerminal = null then
		app.raiseCMException1(Err_InvalidTerminal, self.terminal, null, null);
	endif;
	app.myPassport.setMyTerminal(theTerminal);

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setProxy" id="3d014ca9-2f5e-4767-8296-497d8ccd938d">
        <updating/>
        <source>setProxy(_root : CM_RemoteDataRoot; _data : String; _session : CM_XMLSession) updating;

vars

	device	: CM_RadioTelemetryDevice;

begin

	self.raiseExceptionIfNotTransient(method);
	self.msgInfo := _data;
	if _session &lt;&gt; null then
		self.myUser 				:= _session.myUser;
		self.theVersion				:= _session.theVersion;
		self.deviceId				:= _session.deviceID;
		self.userId					:= _session.userCode;
		self.myRadioTelemetryDevice :=  _session.myDevice;
	endif;
	self.myRemoteDataRoot := _root;
	

end;</source>
        <Parameter name="_root" type="CM_RemoteDataRoot"/>
        <Parameter name="_data" type="String"/>
        <Parameter name="_session" type="CM_XMLSession"/>
    </JadeMethod>
