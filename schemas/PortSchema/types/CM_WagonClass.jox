    <JadeMethod name="cnEcGetDuplicate" id="52b3887a-88a0-4adf-a834-10320975ce41">
        <source>cnEcGetDuplicate(pFormat: CnEcXmlFormat; pInput: CnEcXmlStructureInstance): Object;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 September 2014	cnwndl1	Initial creation	Par 34893

*/

vars

	code : String;
	wagon : CM_WagonClass;

begin

	code := self.cnEcXMLGetTheAttributeValue( pFormat, pInput, self.class.name, "code" ).String; 
	
	if code &lt;&gt; null then
		wagon := app.myRoot.allWagonClasses.getAtKey( code );
	endif;

epilog

	return wagon;

end;</source>
        <Parameter name="pFormat" type="CnEcXmlFormat"/>
        <Parameter name="pInput" type="CnEcXmlStructureInstance"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="convertToWellcar" id="5b9d000f-1e78-4ca0-bd68-034f2dc92b1c">
        <updating/>
        <source>convertToWellcar( _errorMess : String output ):Boolean updating;
/*

Purpose:			

Parameters:		Use only for 8.3.2 Wellcar conversion to 8.4.1 Wellcar...
				This method and the fix up handler method should be deleted 
				after CICE have finished with it.
				I.e. Probably by the release of 8.4.2

Return Value:		

Date		Who		Reason
22 December 2014	cnwndl1	Initial creation	Par 35346

*/

vars

	oldCode : String;
	newCode : String;
	success : Boolean;
	pxyWc : CM_WagonClass;
	newWc : CM_WagonClass;
	wc : CM_WagonClass;
	wellCount : Integer;
	wellIds : StringArray;
	tiersArray : StringArray;
	wellOLength : Decimal [16,4];
	wellOWidth : Decimal [16,4];
	wellDeckHeight : Decimal [16,4];
	wellCargoHeight : Decimal [16,4];
	wellCargoWeight : Decimal [16,4];
	wellTareWeight : Decimal [16,4];
	allConsigneeRestrictions : CM_ConsignCodeArray;
	err : CM_Error;
	well : CM_WagonWellDefinition;
	load : Boolean;
	pxy : CM_WagonWellDefinition;
	wellLocations : StringArray;

begin

	success := false;

	oldCode := self.code;
	newCode := ( "832" &amp; self.code ).String[1:10];
	
	if self.myRoot.allWagonClasses.getAtKey( newCode ) &lt;&gt; null then
		_errorMess := newCode &amp; " code value already used!!";
		return success;
	endif;

	_errorMess := " failed to set is not available and new code value";
	beginTransaction;
	self.isNotAvailableForEntry := true;
	self.code := newCode;
	commitTransaction;
	
	_errorMess := null;
	
	create allConsigneeRestrictions transient;
	if not self.allConsigneeCodesRestricted.isEmpty then
		self.allConsigneeCodesRestricted.copy( allConsigneeRestrictions );
	endif;
	create wellIds transient;
	wellCount := (self.locationIds.size / 4).Integer;
	
	create wellLocations transient;
	wellLocations.add("1");
	wellLocations.add("2");
	wellLocations.add("3");
	wellLocations.add("4");
	
	if wellCount &gt; 0 then
		wellOLength := 0;
		wellOWidth := 0;
		wellDeckHeight := self.deckHeight;
		wellCargoHeight := self.maxCargoHeight - self.deckHeight;
		wellCargoWeight := self.maxLoadWeight / wellCount;
		wellTareWeight := self.tareWeight / wellCount;
	endif;
	
	
	if wellCount = 1 then
		wellIds.add("A");
	elseif wellCount = 2 then
		wellIds.add("A");
		wellIds.add("B");
	elseif wellCount = 3 then
		wellIds.add("A");
		wellIds.add("C");
		wellIds.add("B");
	elseif wellCount = 4 then
		wellIds.add("A");
		wellIds.add("C");
		wellIds.add("D");
		wellIds.add("B");
	elseif wellCount = 5 then
		wellIds.add("A");
		wellIds.add("C");
		wellIds.add("D");
		wellIds.add("E");
		wellIds.add("B");
	else
		_errorMess := newCode &amp; " invalid well count!!";
		return success;
	endif;
	
	create pxyWc transient;
	pxyWc.setProxy(	oldCode,	//pCode : String;
					false,	//pAcceptsGenerator : Boolean; 
					false,	//pDoorsAccessible : Boolean; 
					false,	//_isNotAvailableForEntry : Boolean; 
					self.maxLoadWeight,	//pMaxLoadWeight : Decimal;														// PAR #31155
					self.maxNumInStack,	//pMaxNumInStack : Integer;
					0,	//pLenInUnits : Integer;
					wellIds,	//pLocationIds : StringArray;
					allConsigneeRestrictions,	//pConsigneeRestrictions : CM_ConsignCodeArray;
					0,	//pDeckHeight : Decimal;														// PAR #31155
					0,	//pMaxCargoHeight : Decimal;												// PAR #31155
					0,	//pTareWeight : Decimal;														// PAR #31155
					self.myCarrier,	//pMyCarrier : CM_Carrier
					0,	//pInternalHeight : Decimal;	//18 Mar 2013	NDL	Par 31278
					0,	//pInternalLength : Decimal;	//18 Mar 2013	NDL	Par 31278
					0,	//pInternalWidth : Decimal;	//18 Mar 2013	NDL	Par 31278
					0,	//pOverallHeight : Decimal;	//18 Mar 2013	NDL	Par 31278
					0,	//pOverallLength : Decimal;	//18 Mar 2013	NDL	Par 31278
					0,	//pOverallWidth : Decimal;	//18 Mar 2013	NDL	Par 31278
					CM_WagonClass.Wagon_Wellcar,	//pWagonType : Integer;
					self.tierIds,	//pTierIds : StringArray;
					null,	//pSealTypes : CM_SealTypeDict	//10 Mar 2015	NDL	Par 35828
					CM_BoxcarVisit.BoxcarGraphicBreakBulk // TFS 49523
					);
					
	while true do
		app.myTrxCA.trxCreateWagonClass(pxyWc, newWc, app.myPassport);
		
		if app.myPassport.hasErrors() then
			foreach err in app.myPassport.allErrors do
				_errorMess := _errorMess &amp; ' : ' &amp; pxyWc.code &amp; '  ' &amp; err.text &amp; ",  ";
			endforeach;
			
			foreach err in app.myPassport.allErrors do
				err.removeFromPassport();
			endforeach;
			return success;
		elseif app.myPassport.noErrors then
			app.myPassport.clearErrorsWarnings();
			break;
		else
			app.myPassport.warningsAcknowledged	:= true;
			continue;
		endif;
		
		break;
	
	endwhile;
	
	foreach well in newWc.allWagonWellDefArray do
		app.cmsBeginLoad(load);
		pxy := well.pxyCreateUpdateProxy();
		app.cmsEndLoad(load);
		
		pxy.setProxy(	wellDeckHeight,	//_deckHeight : Decimal;			
						wellLocations.size,	//_lenInUnits : Integer;
						wellCargoHeight,	//maxCargoHeight : Decimal;
						wellCargoWeight,	//_maxLoadWeight : Decimal;
						overallLength,	//_overallLength : Decimal;
						overallWidth,	//_overallWidth : Decimal;
						wellTareWeight,	//_tareWeight : Decimal;
						pxy.wellId,	//_wellId : String;
						wellLocations	//_wellLocations : StringArray
						);
						
		while true do
	
			app.myTrxUA.trxUpdateWagonWellDef(pxy, app.myPassport);
			
			if app.myPassport.trxCompletedOK then
				app.myPassport.clearErrorsWarnings();
				delete pxy;
				break;
				
			elseif app.myPassport.hasErrors() then
				foreach err in app.myPassport.allErrors do
					_errorMess := _errorMess &amp; ' : ' &amp; newWc.code &amp; " ( Well " &amp; pxy.wellId &amp; ")  " &amp; err.text &amp; ",  ";
				endforeach;
				
				foreach err in app.myPassport.allErrors do
					err.removeFromPassport();
				endforeach;
				return success;	
				
			else
				app.myPassport.warningsAcknowledged	:= true;
				continue;
				
			endif;
			
			break;
		
		endwhile;
					
	endforeach;
	
	_errorMess := null;
	success := true;

epilog

	abortTransaction;
	
	delete pxyWc;
	delete wellIds;
	delete allConsigneeRestrictions;
	delete pxy;
	delete wellLocations;

	return success;

end;</source>
        <Parameter name="_errorMess" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="delete" id="d79b90bb-db8b-43b3-835d-2591947de7e9">
