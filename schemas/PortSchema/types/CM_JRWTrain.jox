    </PrimAttribute>
    <JadeMethod name="noOutputReturned" id="0f99dbc3-dae9-44a0-bd6a-a978fb66526a">
        <source>noOutputReturned(): Boolean;
// -----------------------------------------------------------------------------
// Created:		13 July 2009 by consw1
//
// Purpose:		
//
