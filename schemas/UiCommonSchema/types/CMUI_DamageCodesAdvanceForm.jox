    <JadeMethod name="tblDataDisplayRow" id="d31affa7-affd-4822-97f4-32d8f1a0e55e">
        <source>tblDataDisplayRow(table : Table input; obj : Object): String;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		31 July 2009
//
// Implemented version: JMT 7.7.3
