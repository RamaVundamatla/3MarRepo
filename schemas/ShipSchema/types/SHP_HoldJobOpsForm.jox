    <JadeMethod name="mnuColumnOrg_click" id="01e468f2-e605-4f54-adbe-19c1eb59f1d4">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuColumnOrg_click(menuItem: MenuItem input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
