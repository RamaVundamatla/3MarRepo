    <JadeMethod name="getReleasesTotalOutstanding" id="e330ad26-d808-4b53-ba18-304bf3d2b5f6">
        <source>getReleasesTotalOutstanding() : Integer;
//----------------------------------------------------------------------
// Created by 	cnwsh3 - 18 August 2010
//
// Implemented version: JMT 7.8.3
// Date  		User  		Change
// 18/08/2010  	cnwsh3		CCMS1063 - Need total number of cargo still to be released for Booking.
//							This is derived from the info on the releases requests
//----------------------------------------------------------------------
vars
		
begin
	return self.getReleasesTotalRequested() - self.getReleasedCount();
		
epilog
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getReleasesTotalRequested" id="5ce3952b-ba0b-47a9-8dfb-32c81a9d28bc">
        <source>getReleasesTotalRequested() : Integer;
//----------------------------------------------------------------------
// Created by 	cnwsh3 - 18 August 2010
//
// Implemented version: JMT 7.8.3
// Date  		User  		Change
//----------------------------------------------------------------------
vars
	release : CM_BulkRelease;
	totalToRelease : Integer;
begin
	//Get the total number of requests for release for the booking reference from it's release requests.
	foreach release in self.allReleaseRequests do
		totalToRelease := totalToRelease + release.getTotalRequested();
	endforeach;
	
	return totalToRelease;
epilog
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getReservedCount" id="25df6cd6-f7a6-42cf-ba37-d1e03bf0a1a7">
        <source>getReservedCount():Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 November 2009	cnwndl1	Initial creation	1028
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items

*/

vars
	brItem 	: CM_BookingRefItem;
	count : Integer;
	
begin
	
	foreach brItem in self.allBookingRefItems do
		if brItem.myReserveDetail &lt;&gt; null then
			//count := count + brItem.myReserveDetail.allTrackedItems.size;
			count := count + brItem.myReserveDetail.getAllTrackedItemsSize(false); //23/06/2023	navkc1	CR 58406 Task 58408
		endif;
	endforeach;
	return count;
epilog
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
