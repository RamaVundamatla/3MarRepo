    <JadeMethod name="doBtnNew" id="789dcecd-bd78-4149-b6c0-47af5ad65ceb">
        <updating/>
        <source>doBtnNew()updating;
//--------------------------------------------------
// Created:	06 April 2005 By: cnwgd1
//--------------------------------------------------
vars

