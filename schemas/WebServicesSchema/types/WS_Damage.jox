    <PrimAttribute name="isRepaired" id="00e3b9a0-d4e5-4f22-9d4d-adb567228202">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <ImplicitInverseRef name="myDamageCode" id="19b4072a-a11e-4fda-87f1-4da335450ab2">
        <embedded/>
        <type name="WS_DamageCode"/>
