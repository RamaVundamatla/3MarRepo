    <JadeMethod name="deleteVoyageJobs" id="590ccdf3-4e34-4079-9848-57aee63f57fa">
        <updating/>
        <source>deleteVoyageJobs(_setTime : TimeStamp) updating;

constants
	MaxTransactionTime = 20000;	// 20 seconds
vars
	lastCommit : Decimal[20];
	now : Decimal[20];
	count : Integer;
	voyageJob : CM_VoyageJob;
	iter : Iterator;
	size : String;
    dict, objArray : ObjectArray;
    obj: Object;
begin
	lastCommit := app.relativeMachineTime();
	app.myPassport.clearErrorsWarnings();
	self.monitor(method.name&amp;' '&amp;"Getting VoyageJob..."); 
	if self.abortStatus = true then
		return;
	endif;

	create dict transient;
    create objArray transient;

	CM_VoyageJob.allInstances(objArray,0,true); 
	size := objArray.size.userNumberFormat($CNEC_NO_DECIMALS);
	count := 0;
	self.monitor("Checking " &amp; size &amp; " VoyageJob for items to delete...");
	if self.abortStatus = true then
		return;
	endif;

	foreach obj in objArray do
		voyageJob := obj.CM_VoyageJob;
		count := count + 1;
//		if count mod 100000  = 0 then
		now := app.relativeMachineTime();
		if now - lastCommit &gt; MaxTransactionTime then
			lastCommit := app.relativeMachineTime();
			self.monitor("VoyageJob checked: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; size
				&amp; ". VoyageJob to erase: " &amp; dict.size.userNumberFormat($CNEC_NO_DECIMALS));
			if self.abortStatus = true then
				return;							//Exits here can just go straight back
			endif;
		endif;

		if voyageJob.createdTime = null then
			dict.add(voyageJob);
		elseif voyageJob.createdTime &lt; _setTime then			//No point in checking further
			dict.add(voyageJob);
		elseif voyageJob.myVoyage = null then
			dict.add(voyageJob);
		elseif voyageJob.myVoyage.archived then
			dict.add(voyageJob);
		endif;
	endforeach;

	self.monitor("There are " &amp; dict.size.userNumberFormat($CNEC_NO_DECIMALS) &amp; " items to delete"); 
	if self.abortStatus = true then
		return;
	endif;

	size := dict.size.userNumberFormat($CNEC_NO_DECIMALS);
	iter := dict.createIterator;
	count :=  0;

	lastCommit := app.relativeMachineTime();
	beginTransaction;
	on Exception do self.tiEraseExceptionHandler(exception);
	while iter.next(voyageJob) do
//		if count mod 10000 = 0 then
		now := app.relativeMachineTime();
		if now - lastCommit &gt; MaxTransactionTime then
			lastCommit := app.relativeMachineTime();
			commitTransaction;		//commit every 1000 items
			self.monitor("Erased VoyageJob: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; size);
			if self.abortStatus = true then
				return;
			endif;
			beginTransaction;
		endif;
//		app.writeLog("Deleting "&amp;voyageJob.String&amp;" "&amp;voyageJob.String,0); 
		if voyageJob.myTerminal &lt;&gt; null then	
			voyageJob.causeTerminalEvent(CM_VoyageJob.Event_Mode_Delete);
		endif;
		if not process.isInTransactionState then
			beginTransaction;
		endif;
		voyageJob.erase(NORMAL_ERASE);
		if process.isInTransactionState then
			count := count + 1;
		endif;
	endwhile;
	commitTransaction;
	//abortTransaction;
	self.monitor("Task Complete: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " VoyageJob erased ");
	if self.abortStatus = true then
		return;
	endif;
epilog
	delete dict;
	on Exception do null;
	delete objArray;
	delete iter;			// PAR #26678
end;</source>
        <Parameter name="_setTime" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="doStart" id="e5c231ee-183f-4168-adca-ddbf8082e8be">
        <updating/>
        <source>doStart() updating;
//Does the garbage collection
vars
    now : TimeStamp;
    i : Integer;
    str : String;
    setTime : TimeStamp;
    flags : Integer;
begin

	self.statusLine1.caption := "";
	self.statusLine1.refreshNow;
//	lbResult.clear;

//	if dTPicker1.getDate &gt; now.Date - PRIOR_DAYS then
	if self.dateMask.getDate() &gt; now.Date - PRIOR_DAYS then
		str := "The date for garbage collection must be at least " &amp; PRIOR_DAYS.String &amp; " days prior to today." 
		&amp; CrLf &amp; "Otherwise you may delete objects still in active use by the system";
		if app.msgBox(str, "Date Error", MsgBox_OK_Only+MsgBox_Exclamation_Mark_Icon) &lt;&gt; MB_OK then
			return;
		endif;
	endif;

	str := "Garbage collection is a permanent process to remove data objects." 
	&amp; CrLf &amp; "It can take a long time to delete certain objects such as voyages"
	&amp; CrLf &amp; "which have a lot of other objects associated with them"
	&amp; CrLf &amp; "You can use the 'Stop Collection' button to halt the process"
	&amp; CrLf &amp; "at any stage, but items already erased cannot subsequently be recovered"
	&amp; CrLf &amp; "Press OK to continue or Cancel to quit ";
	i := app.msgBox(str,"You have been warned !",MsgBox_OK_Cancel+MsgBox_Exclamation_Mark_Icon);
	if i = MsgBox_Return_Cancel then
       	return;
    endif;

	app.mousePointer := MousePointer_HourGlass;

	self.abortStatus := false;	//This gets set when the stop button is pressed
	self.bStart.enabled := false;
	self.btnStop.enabled := true;
    self.bExit.enabled := false;
    self.bStart.refreshNow;
    self.btnStop.refreshNow;
    self.bExit.refreshNow;

//	setTime := dTPicker1.getTimeStamp;
	setTime.setDate(self.dateMask.getDate()); // := dTPicker1.getTimeStamp;
	self.monitor(method.name&amp;' '&amp;"Starting Garbage collection from "&amp;setTime.String&amp;'.'); 

 	if self.cbOffsite.value = true then
    	flags := flags.bitOr(ERASE_OFFSITE);
	endif;

	if self.cbErased.value = true then
		flags := flags.bitOr(ERASE_DELETED);
	endif;

	if self.cbArchivedVoys.value = true then
    	flags := flags.bitOr(ERASE_ONSHIP);
	endif;
	
 	if self.cbOffsite.value = true and abortStatus = false then
		self.monitor(method.name&amp;' '&amp;"Processing Offsite..."); 
		self.deleteOffsiteItems(setTime);
		if self.abortStatus = true then
			return;
		endif;
	endif;

	if self.cbDiscrep.value = true and abortStatus = false then
		self.monitor(method.name&amp;' '&amp;"Processing Discrepancies..."); 
		self.deleteDiscrepancies(setTime);
		if self.abortStatus = true then
			return;
		endif;
	endif;

	if self.cbArchivedVoysDo.value = true and abortStatus = false then
		self.monitor(method.name&amp;' '&amp;"Processing Archive Voyages..."); 
		self.archiveVoyages(setTime);
		if self.abortStatus = true then
			return;
		endif;
	endif;

	if self.cbArchivedVoys.value = true and abortStatus = false then
		self.monitor(method.name&amp;' '&amp;"Processing Delete Archived Voyages..."); 
		self.deleteArchivedVoyages(setTime);
		if self.abortStatus = true then
			return;
		endif;
		self.deleteVoyageJobs(setTime);
		if self.abortStatus = true then
			return;
		endif;
	endif;

	if flags &lt;&gt; 0 and self.abortStatus = false then
		self.monitor(method.name&amp;' '&amp;"Processing flags..."); 
		self.deleteGarbageTIs(setTime, flags);
		if self.abortStatus = true then
			return;
		endif;
		self.deleteTISnapShots(setTime);
		if self.abortStatus = true then
			return;
		endif;
		self.deleteBulkRelease();
		if self.abortStatus = true then
			return;
		endif;
		self.deleteInformation(setTime);
		if self.abortStatus = true then
			return;
		endif;
		self.deleteInfoEDISent(setTime);
		if self.abortStatus = true then
			return;
		endif;
	endif;

	if self.cbMisc.value = true and self.abortStatus = false then
		self.monitor(method.name&amp;' '&amp;"Processing Misc..."); 
		self.deleteActivityHistory();
		if self.abortStatus = true then
			return;
		endif;
		self.deleteAuditObjects(setTime);
		if self.abortStatus = true then
			return;
		endif;
		self.deleteDataDumpExtractHistory();
		if self.abortStatus = true then
			return;
		endif;
		self.deleteCamTaskHistory();
		if self.abortStatus = true then
			return;
		endif;
	endif;

	if self.cbReeferTrans.value = true and self.abortStatus = false then
		self.monitor(method.name&amp;' '&amp;"Processing reffer Trans..."); 
		self.deleteTowerTransactions(setTime);
		if self.abortStatus = true then
			return;
		endif;
		self.deleteTemperatureReadings(setTime);
		if self.abortStatus = true then
			return;
		endif;
		self.deleteTempReadings(setTime);
		if self.abortStatus = true then
			return;
		endif;
	endif;

	if self.cbPrenoteItems.value = true and self.abortStatus = false then
		self.monitor(method.name&amp;' '&amp;"Processing Prenote..."); 
		self.deletePrenoteItems(setTime);
		if self.abortStatus = true then
			return;
		endif;
		self.deleteBookingRef(setTime);
		if self.abortStatus = true then
			return;
		endif;
	endif;
	
	if self.cbAuditItems.value = true and self.abortStatus = false then
		self.monitor(method.name&amp;' '&amp;"Processing Audit..."); 
		self.deleteInvoiceItems(setTime);
		if self.abortStatus = true then
			return;
		endif;
	endif;

	if self.cbMachineHistory.value = true and self.abortStatus = false then
		self.monitor(method.name&amp;' '&amp;"Processing Machine History..."); 
		self.deleteMachineHistory(setTime);
		if self.abortStatus = true then
			return;
		endif;
		self.deleteVehicleVisitRecord(setTime);
		if self.abortStatus = true then
			return;
		endif;
		self.deleteEventTransactions(setTime);
		if self.abortStatus = true then
			return;
		endif;
	endif;

	if self.cbOldJMT6.value = true and self.abortStatus = false then
		self.monitor(method.name&amp;' '&amp;"Processing Old JMT6..."); 
		self.deleteJMTV6Objects;
		if self.abortStatus = true then
			return;
		endif;
		self.deleteOldSlotControllers;
		if self.abortStatus = true then
			return;
		endif;
		self.deleteOldSlotRequests;
		if self.abortStatus = true then
			return;
		endif;
	endif;

	if self.cbEDIData.value = true and self.abortStatus = false then
		self.monitor(method.name&amp;' '&amp;"Processing EDI Data..."); 
		self.deleteAllEDI;
		if self.abortStatus = true then
			return;
		endif;
	endif;
	
epilog
	self.statusLine1.caption := "";
	if self.abortStatus then
		self.monitor("Garbage Collection Aborted.");
	endif;
	self.statusLine1.refreshNow;
	self.setEnableObjects;
	app.mousePointer := MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="load" id="a6c68959-deef-4e1c-8ea0-e3003062d9ab">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

vars
	logon : CMS_Logon;
	str : String;
	now : TimeStamp;
	date : Date;
begin
	app.initialize;
	app.isGarbageCollectionProcess := true;
	app.mainForm := self;
	app.niceName := "Garbage Collection";
	app.handleIt();

	self.centreWindow;

	self.show;
	bStart.enabled := false;
 	btnStop.enabled := false;
 	date := (now.Date - (PRIOR_DAYS+1));	
 	self.dateMask.setDate(date);

	//Users need to login. They must have write access to the garbage collection window
	create logon;

	logon.chbSetupMode.visible := false;

	logon.userObject := self;   // My ID in case of trouble
	logon.showModal;            // Will not return here unless satisfied
								// but may unload me if unhappy.
	if logon.modalResult &lt;&gt; IDOK then          // user canned out withot login
		bExit_click(bExit);               // Bye bye
		return;
	endif;

	app.myPassport.setMyTerminal(CM_Terminal.firstInstance);

	if app.myCurrentUserCan(app.getMyTerminalDO_NOT_USE(), PmAdmGarbagecollectMaint) = false then
		str := "You do not have sufficient access rights to use Garbage Collection" 
			&amp; CrLf &amp; "To acquire access rights, please contact your System Administrator"
			&amp; CrLf &amp; "The Garbage Collection application will now exit";
		if app.msgBox(str ,"Garbage Collect", MsgBox_OK_Cancel + MsgBox_Exclamation_Mark_Icon) &lt;&gt; MB_OK then
			bExit_click(bExit);
		endif;
	endif;

	self.cbArchivedVoys.value := true;
	self.cbArchivedVoysDo.value := true;
	self.cbAuditItems.value := true;
	self.cbDiscrep.value := true;
	self.cbEDIData.value := true;
	self.cbErased.value := true;
	self.cbMachineHistory.value := true;
	self.cbOffsite.value := true;
	self.cbOldJMT6.value := true;
	self.cbPrenoteItems.value := true;
	self.cbReeferTrans.value := true;
	self.cbMisc.value := true;
 	self.setEnableObjects();
epilog
	delete logon;
end;</source>
    </JadeMethod>
    <JadeMethod name="monitor" id="3f855b6c-ba3c-4b97-ba05-87a0560f0585">
        <source>monitor(_msg:String);

vars

begin 
	self.statusLine1.caption := _msg;
	app.writeLog(_msg,0);
	self.statusLine1.refreshNow;
	self.doWindowEvents(0);			//Check the cancel button
end;</source>
        <Parameter name="_msg" type="String"/>
    </JadeMethod>
    <JadeMethod name="queryUnload" id="3befb987-5710-4299-bef2-fadd6fa080f8">
        <controlMethod name="Form::queryUnload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>queryUnload(cancel: Integer io; reason: Integer) updating;
//User can only exit if garbage collection is not in process
vars
  str : String;
  closeIt : Integer;
begin
 if bExit.visible = false then
 	if reason = QueryUnload_User then
 		str := "Garbage Collection is in progress, do you want to halt the operation ?";
 		closeIt := app.msgBox(str, "Garbage Collection", MsgBox_Yes_No + MsgBox_Stop_Icon);

		if closeIt = MsgBox_Return_Yes	then
			btnStop_click(btnStop);
			btnStop.doWindowEvents(0);
		else
 			cancel := 1;
 		endif;
 	else		//Windows is trying to shut us down !!!
		btnStop_click(btnStop);
		btnStop.doWindowEvents(0);
 	endif;
 endif;
end;</source>
        <Parameter name="cancel" type="Integer" usage="io"/>
        <Parameter name="reason" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setEnableObjects" id="2cb60a36-6bef-4af6-8316-221c57dd3a4c">
        <source>setEnableObjects();

vars
	now : TimeStamp;
begin
//	if dTPicker1.getDate &lt; now.Date - PRIOR_DAYS then
	if self.dateMask.getDate() &lt; now.Date then
   		self.bStart.enabled := true;
	else
   		self.bStart.enabled := true;
	endif;
	self.btnStop.enabled := false;
    self.bExit.enabled := true;
end;</source>
    </JadeMethod>
    <JadeMethod name="tiEraseExceptionHandler" id="de8b13d8-82b4-4df4-8d8b-de4f23cb6e58">
        <source>tiEraseExceptionHandler(_ex : Exception) : Integer;
//If we can't erase a given TI, we shouldn't come to a sudden stop, just carry on
vars
    msg : String;
	stackDump: CnStackDump;
begin

	msg := "Error: " &amp; app.getErrorString(_ex.errorCode) &amp; ". Continuing with next object";

	if msg &lt;&gt; "" then
		app.writeLog(msg,0); 
//		lbResult.refreshNow;
	endif;
	create stackDump transient;
	stackDump.dumpStack(_ex);
	app.myPassport.clearErrorsWarnings();
	return Ex_Resume_Next;
end;</source>
        <Parameter name="_ex" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</GUIClass>
