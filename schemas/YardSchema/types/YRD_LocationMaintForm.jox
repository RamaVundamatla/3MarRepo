    <JadeMethod name="tblPackGroups_lostFocus" id="0bf898e3-3df2-4f19-b0f0-38146d038051">
        <controlMethod name="Table::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblPackGroups_lostFocus(table: Table input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 19/12/2016	cnwdap1		Initial creation TFS 2844 STWR Hazardous Details Enhancements
//
vars
	row : Integer;
	checked, str : String;

begin
	foreach row in table.fixedRows + 1 to table.rows do
		checked := table.accessCell(row, 1).text;
		if checked = "1" then
			if str = null then
				str := table.accessCell(row, 2).text;
			else
				str := str &amp; Comma &amp; Space &amp; table.accessCell(row, 2).text;
			endif;
		endif;
	endforeach;
	self.tblOther.setValueByName(ETRow_PackingGroup, str);
	row := self.tblOther.getRowByControlName(self.tblPackGroups.name);
	if row &gt; self.tblOther.fixedRows and row &lt;= self.tblOther.rows then
		self.tblOther.accessRow(row).height := self.tblOther.accessRow(1).height;
	endif;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="1e368581-cefa-4c1a-a923-e072a2ac0bff">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0008736, locale);
	btnLegend.translateCaption(Xlat_0004514, locale);
	btnPenAvail.translateBubbleHelp(Xlat_0004505, locale);
	btnPenAvail.translateCaption(Xlat_0004509, locale);
