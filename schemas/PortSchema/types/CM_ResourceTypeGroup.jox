    <JadeMethod name="pxyCreateUpdateProxy" id="89e273b6-eecd-40ae-b691-dabb29c9b391">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 November 2023	navpw1	Initial creation TFS: 58761 (60739)

*/

vars
	pxy			: SelfType;
	completedOK	: Boolean;
	
begin
	pxy := inheritMethod();
	self.allResourceTypes.copyNoDups(pxy.allResourceTypes);
	
	completedOK := true;
	
	return pxy;
	
epilog
	if not completedOK then
		delete pxy;
	endif;
	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="6cbf3399-c8f5-4934-a35b-c3d84931d252">
        <updating/>
        <source>setForCreate(_pxyResourceTypeGroup : CM_ResourceTypeGroup) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 November 2023	navpw1	Initial creation TFS: 58761 (60739)

*/

begin
	self.setForUpdate(_pxyResourceTypeGroup);
	self.myRoot := app.myRoot;
	
end;</source>
        <Parameter name="_pxyResourceTypeGroup" type="CM_ResourceTypeGroup"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="ac45f19b-4dce-4216-8f60-010a87669d05">
        <updating/>
        <source>setForUpdate(_pxyResourceTypeGroup : CM_ResourceTypeGroup) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 November 2023	navpw1	Initial creation TFS: 58761 (60739)

*/

vars

begin
	self.code					:= _pxyResourceTypeGroup.code;
	self.description			:= _pxyResourceTypeGroup.description;
	self.isNotAvailableForEntry	:= _pxyResourceTypeGroup.isNotAvailableForEntry;
	self.allResourceTypes.clear();
	_pxyResourceTypeGroup.allResourceTypes.copyNoDups(self.allResourceTypes);
	
end;</source>
        <Parameter name="_pxyResourceTypeGroup" type="CM_ResourceTypeGroup"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="d8564974-42eb-41c0-bda0-8131b9c62514">
        <updating/>
        <source>setProxy(_code, _description : String; _isNotAvailableForEntry : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 November 2023	navpw1	Initial creation TFS: 58761 (60739)

*/

begin
	self.code					:= _code;
	self.description			:= _description;
	self.isNotAvailableForEntry	:= _isNotAvailableForEntry;
	
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_isNotAvailableForEntry" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="921438f7-bf30-4835-85c8-f1983dbdc1df">
        <source>validateForCreate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 November 2023	navpw1	Initial creation TFS: 58761 (60739)

*/

vars
	existingResourceTypeGroup	: CM_ResourceTypeGroup;
	
begin
	if self.code = null then
		app.raiseCMException(Resource_Type_Group_CodeReq, null, null);
	endif;
	
	existingResourceTypeGroup := app.myRoot.allResourceTypeGroups[self.code];
	
	if existingResourceTypeGroup &lt;&gt; null then
		app.raiseCMException1(Resource_type_group_dup, self.code, null, null);
	endif;
	
	self.validateMe();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="b908a464-5252-480e-81b8-6652d02b8732">
        <source>validateForDelete();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
13 November 2023	navpw1	Initial creation TFS: 58761 (60739)

*/

vars
	colAvailableTaskCriteria,
	colMandatoryTaskCriteria : CM_TaskCriteriaDict;
	taskCriteria : CM_TaskCriteria;
	toDoTask : CM_ToDoTaskDesc;
	iter : Iterator;
	csvString : String;
	
begin
	colAvailableTaskCriteria := self.allAvailableTaskCriteria;
	
	if colAvailableTaskCriteria.isNotEmpty then
		iter := colAvailableTaskCriteria.createIterator;
		while iter.next(taskCriteria) do
			toDoTask := taskCriteria.myToDoTaskDesc;
			if toDoTask = null then
				continue;
			endif;
			
			csvString := csvString &amp; toDoTask.shortDescription &amp; Comma;
			
		endwhile;
		delete iter;
		app.raiseCMException1(Resource_type_grp_del_ava_Task, csvString, null, null);
		
	endif;
	
	csvString := null;
	
	colMandatoryTaskCriteria := self.allMandatoryTaskCriteria;
	if colMandatoryTaskCriteria.isNotEmpty then
		iter := colMandatoryTaskCriteria.createIterator;
		while iter.next(taskCriteria) do
			toDoTask := taskCriteria.myToDoTaskDesc;
			if toDoTask = null then
				continue;
			endif;
			
			csvString := csvString &amp; toDoTask.shortDescription &amp; Comma;
			
		endwhile;
		delete iter;
		app.raiseCMException1(Resource_type_grp_del_man_Task, csvString, null, null);
		
	endif;
	
epilog
	delete iter;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="63504e48-a878-477b-b353-39dcd7a51c19">
        <source>validateForUpdate(_realResourceTypeGroup : CM_ResourceTypeGroup);
/*

Purpose:			

Parameters:			_realResourceTypeGroup	CM_ResourceTypeGroup	The non-updated ResourceTypeGroup related to our proxy we are validating for update

Return Value:		NONE

Date		Who		Reason
13 November 2023	navpw1	Initial creation TFS: 58761 (60739)

*/

vars
	existingResourceTypeGroup : CM_ResourceTypeGroup;
	
begin
	if self.code = null then
		app.raiseCMException(Resource_Type_Group_CodeReq, null, null);
	endif;
	
	existingResourceTypeGroup := app.myRoot.allResourceTypeGroups[self.code];
	
	if existingResourceTypeGroup &lt;&gt; null and 		//If we have an existing resource type group for the new code (self.code)
		self.code &lt;&gt; _realResourceTypeGroup.code  	//and the new code (self.code) is different to the saved code (The one originally set before we did an update).
	then											//Then raise a duplicate resource type group exception
		app.raiseCMException1(Resource_type_group_dup, self.code, null, null);
	endif;
	
	self.validateMe();
	
end;</source>
        <Parameter name="_realResourceTypeGroup" type="CM_ResourceTypeGroup"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="4731e5ca-e80b-466a-b2e6-7bd1468f229d">
        <source>validateMe();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 November 2023	navpw1	Initial creation TFS: 58761 (60739)

*/

vars
	currentResourceTypeGroup	: CM_ResourceTypeGroup;
	resourceType				: CM_ResourceType;
	iter						: Iterator;
	
begin
	if self.allResourceTypes.isEmpty then
		return;
	endif;
	
	iter := self.allResourceTypes.createIterator;
	while iter.next(resourceType) do
		currentResourceTypeGroup := resourceType.myResourceTypeGroup;
		if currentResourceTypeGroup = null or 
			currentResourceTypeGroup.code = self.code
		then
			continue;
		endif;
		
		app.raiseCMException2(Resource_type_assign_diff_grp, resourceType.code, currentResourceTypeGroup.code, null, null);
		
	endwhile;
	
epilog
	delete iter;
	
end;</source>
    </JadeMethod>
</Class>
