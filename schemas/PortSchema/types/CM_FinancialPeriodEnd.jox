    <JadeMethod name="setForCreate" id="e2c64c64-aaff-41d5-9507-1fe8abb811c8">
        <updating/>
        <source>setForCreate(_pxy : SelfType) updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.myBank := app.myRoot.myRootCompany;
