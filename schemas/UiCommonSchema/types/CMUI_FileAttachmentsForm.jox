        <updating/>
        <source>tblFiles_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
24 September 2021	jlizm1	Initial creation TFS 51963 SAL Voyage Request Changes

*/

vars

	x1, 
	y1					: Real;
	
begin
	
	x1 := x;
	y1 := y;
		
	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   
	
	self.mnuColumnOrganiser.userObject := table;
	self.popupMenu(self.mnuContext, x1.Integer, y1.Integer);
	return true;
	
end;</source>
