    </JadeMethod>
    <JadeMethod name="updateStopTableTemplate" id="8a6ac170-4c80-4d6f-a7de-441ad52ded27">
        <updating/>
        <source>updateStopTableTemplate() updating;
//ccms1824 cnwrs1 may 2009
// 21/7/17 MAP TFS4916
vars
	intArraySet	: IntegerArray;
	intArrayPrevent	: IntegerArray;
	intArrayProcess : IntegerArray;
	holdVoyages : CM_ObjectArray; //ccms1824 cnwrs1 May 2009
begin
	create intArraySet transient;
	create intArrayPrevent transient;
	create intArrayProcess transient;
	create holdVoyages transient;
	self.mulHoldVoyages.getSelected(holdVoyages);
	self.copyColToArray(self.lstStopSet.allSelectedObjects, intArraySet);
	self.copyColToArray(self.lstStopPrevent.allSelectedObjects, intArrayPrevent);
	self.copyColToArray(self.lstStopProcess.allSelectedObjects, intArrayProcess);
	myProxyStopTableTemplate.setProxy(intArrayPrevent, intArraySet, intArrayProcess, 
									holdVoyages,
	                                self.chkChildOnly.value,
	                                self.chkChildIgnore.value,
	                                self.chkCoastalOnly.value,
	                                self.chkCoastalIgnore.value,
	                                self.chkTranshipOnly.value,
	                                self.chkTranshipIgnr.value,
	                                self.chkMTsOnly.value,
	                                self.chkFullsOnly.value);
epilog
	delete holdVoyages;
	delete intArraySet;
	delete intArrayPrevent;
	delete intArrayProcess;
end;
</source>
    </JadeMethod>
</GUIClass>
