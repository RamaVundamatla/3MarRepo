    <JadeMethod name="btnVehicleBook_click" id="a128c928-6477-45b2-a1f7-8d5867784797">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnVehicleBook_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Apr 2013	cnwndl1	Initial creation
05 Jul 2022 navma1	ChangeRequest 53899: EUP - VBS MTN - [3] - Maintaining VBS Slot
20 Sep 2022 navma1	ChangeRequest 53900: EUP - VBS MTN - [4] - Search Screen
23 Dec 2022	navak20 Task 55979: EUP - VBS MTN - [3] - Maintaining VBS Slot - Review Changes
*/

vars
	vssForm 		: CMUI_VehicleBookingDayView;
	vssAdvanced 	: CMUI_VehicleBookingAdvSearch;
	vbsEnqForm  	: CMUI_VehicleBookingEnqForm;
	showAdvanced	: Boolean;
	vbsProcess		: CM_VBSProcess;	// 23.12.2022 navak20 TFS 55979
	
begin
	vbsProcess := self.myTerminal.getMyVBSProcess;		// 23.12.2022 navak20 TFS 55979
	
	if not self.myTerminal.isVehicleBookingEnabled then
		return;
	endif;
	
	vssForm := app.getForm(CMUI_VehicleBookingDayView.name).CMUI_VehicleBookingDayView;
	
	//05.07.2022 navma1 #53899
	//if self.myTerminal.getMyVBSProcess &lt;&gt; null and self.myTerminal.getMyVBSProcess.isVbsSlotValidation then	// 23.12.2022 navak20 TFS 55979
	if vbsProcess &lt;&gt; null and vbsProcess.isVbsSlotValidation then		// 23.12.2022 navak20 TFS 55979
		showAdvanced := true;
	endif;
	
	if showAdvanced then
		vbsEnqForm := app.getForm(CMUI_VehicleBookingEnqForm.name).CMUI_VehicleBookingEnqForm;
		if vbsEnqForm &lt;&gt; null and vbsEnqForm.myTerminal = self.myTerminal then
			vbsEnqForm.windowState := vbsEnqForm.WindowState_Normal;
			vbsEnqForm.zOrder(1);
			return;
		endif;
		
		if vbsEnqForm = null or vbsEnqForm.myTerminal &lt;&gt; self.myTerminal then
			vbsEnqForm := app.loadForm(CMUI_VehicleBookingEnqForm, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_VehicleBookingEnqForm;
		endif;
		
		if vbsEnqForm &lt;&gt; null then
			vbsEnqForm.show;
		endif;
		
		/*
		//20.09.2022 navma1 #53900
		else
			vssAdvanced := app.getForm(CMUI_VehicleBookingAdvSearch.name).CMUI_VehicleBookingAdvSearch;
			if vssAdvanced &lt;&gt; null and vssAdvanced.myTerminal = self.myTerminal then
				vssAdvanced.windowState := vssAdvanced.WindowState_Normal;
				vssAdvanced.zOrder(1);
				return;
			endif;
			if vssAdvanced = null or vssAdvanced.myTerminal &lt;&gt; self.myTerminal then
				vssAdvanced := app.loadForm(CMUI_VehicleBookingAdvSearch, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_VehicleBookingAdvSearch;
			endif;
			if vssAdvanced &lt;&gt; null then
				vssAdvanced.show;
			endif;
			
		endif;
		*/
	else
		if vssForm &lt;&gt; null and vssForm.myTerminal = self.myTerminal then
			vssForm.windowState := vssForm.WindowState_Normal;
			vssForm.zOrder(1);
			return;
		endif;
		
		if vssForm = null or vssForm.myTerminal &lt;&gt; self.myTerminal then
			vssForm := app.loadForm(CMUI_VehicleBookingDayView, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_VehicleBookingDayView;
		endif;
		
		if vssForm &lt;&gt; null then
			vssForm.show;
		endif;
		
	endif;
	
end;</source>
