    <JadeMethod name="cmbCommodity_displayEntry" id="ba21cd6c-1546-4195-a3ba-1309ff2d0eea">
        <controlMethod name="CMUI_FieldComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbCommodity_displayEntry(_combobox: CMUI_FieldComboBoxControl input; _commodity: CM_Commodity; _index: Integer):String updating;
/*
Date		Who		Reason
24/07/2009	cnwdap1	Initial creation
19/02/2010	cnwdap1	PAR #21707 Exclude commodities that are marked as not available for entry
*/
vars

begin
	if _commodity.isNotAvailableForEntry then
		return null;
	endif;
	
	return _commodity.code &amp; " " &amp; _commodity.description;
