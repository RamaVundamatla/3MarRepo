        <Parameter name="_item" type="String"/>
        <Parameter name="_value" type="String"/>
        <Parameter name="_function" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validate" id="a1feedae-9e53-447d-8146-dd4df66ce6ae">
        <source>validate(_passport :CM_Passport input);
/****Changes

Date		Name	TFS#			Description
============================================================================
21 Nov 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
14 Dec 2012 cnwgb1  Heavy Rated Rule CCMS 2216/ PAR 30902 
25/03/2013	cnwcs5	CCMS POL 2097 / par 31259
03/07/2013	cnwcs5	par 31942 - 	FTX segment processing for Coparn/IFTMCS bookings
11 Sep 2014	cnwma1	PAR#34855 CCMS 2351: Hapag-Lloyd Release Request Enhancements
14 Jun 2016 cnwma1	TFS #2048 		POL - HSD EDI Empty Release Request
21 Aug 2017	jlgrs1	TFS 6564 		add Coparn and Coreor RFF and NAD translation
31 Aug 2017	jlgrs1	TFS 6797 		SNO SpecialStow
23 May 2018	jlgrs1	TFS 38357		SNO Fix Xlations from TFS 6797
03 Jun 2018	jlgrs1	TFS 39018 		SNO Cargo Operator in COPRAR
06 Nov 2018	jlgka1	39185, 39187	Add FTX21.1 for IFCSUM FTX+AAA rules.
14 Aug 2023	jlirs1	TFS 59845 (57770) Port of Origin BOP
============================================================================*/
vars
	ruleItem		:String;
	ruleFunction, 
	type			:Integer;
begin
	self.raiseExceptionIfNotTransient (method);
	
	ruleItem 	:= self.item;
	type 		:= self.myEDIPartyRules.getType;
	
	if ruleItem = null then
		app.raiseCMException (EDI_Party_Error6, null, null);
	
	elseif type = EDIFileType_Coparn and
			(ruleItem = self.Item_BGM_1_1 or
			 ruleItem = self.Item_UNH_1_1 or    //cnwma1 TFS #2048 14/06/2016 
			 ruleItem = self.Item_DTM_1_1 or
			 ruleItem = self.Item_FTX_1_1 or
			 ruleItem = self.Item_FTX_3_1 or	//07 Jun 2017	NDL	TFS 4454
			 ruleItem = self.Item_FTX_4_1 or
			 ruleItem = self.Item_MEA_3_2 or
			 ruleItem = self.Item_TMP_1_1 or
			 ruleItem = self.Item_NAD_1_1 or
			 ruleItem = self.Item_NAD_2_1 or
			 ruleItem = self.Item_NAD_3_1 or
			 ruleItem = self.Item_RFF_1_1) then  //11/09/2014 cnwma1 PAR#34855  CCMS POL 2351
		// all OK
	elseif type = EDIFileType_Coprar and
			(ruleItem = self.Item_FTX_3_1 or	//07 Jun 2017	NDL	TFS 4454
			 ruleItem = self.Item_NAD_1_1 or
			 ruleItem = self.Item_NAD_2_1 or
			 ruleItem = self.Item_NAD_3_1) then
	elseif type = EDIFileType_Coreor and
			(ruleItem = self.Item_NAD_1_1 or
			 ruleItem = self.Item_RFF_1_1) then  
		
	elseif  type = EDIFileType_IFTMCS03A and
			(ruleItem = self.Item_FTX_1_1 or
			 ruleItem = self.Item_FTX_4_1 ) then
	elseif  (type = EDIFileType_IFCSUM94B or
			 type= EDIFileType_IFCSUMAUBNE94B) and		//14 Aug 2023	jlirs1	TFS 59845 (57770) Port of Origin BOP
			(ruleItem = self.Item_FTX_3_1 or
			 ruleItem = self.Item_FTX_4_1 or 
			 ruleItem = self.Item_FTX_21_1) then		 //jlgka1 TFS 39185, 39187
		// all OK	
	else
		// we expect GUI to take care of this (including not passing in null values)
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Item is not supported');
	endif;
		
	ruleFunction := self.function;
	
	if ruleFunction = null then
		app.raiseCMException (EDI_Party_Error8, null, null);
	endif;
	
	if ruleItem = self.Item_BGM_1_1 then
		if ruleFunction &lt;&gt; null then 
			// we expect the GUI to only present valid options
			if ruleFunction &lt;&gt; self.Function_BGM_1_1_Booking and ruleFunction &lt;&gt; self.Function_BGM_1_1_Release and ruleFunction &lt;&gt; self.Function_BGM_1_1_Prenote then
				app.raiseUnexpectedProgramError (self.class.name, method.name, 'Function is not supported');
			endif;
		endif;
	
	elseif ruleItem = self.Item_UNH_1_1 then													//cnwma1 TFS #2048 14/06/2016 
		if ruleFunction &lt;&gt; null then 
			// we expect the GUI to only present valid options
			if ruleFunction &lt;&gt; self.Function_UNH_1_1_Booking and ruleFunction &lt;&gt; self.Function_UNH_1_1_Release then
				app.raiseUnexpectedProgramError (self.class.name, method.name, 'Function is not supported');
			endif;
		endif;
		
	elseif ruleItem = self.Item_DTM_1_1 then
		if ruleFunction &lt;&gt; null then 
			// we expect the GUI to only present valid options
			if ruleFunction &lt;&gt; self.Function_DTM_1_1_EstReqDT and ruleFunction &lt;&gt; self.Function_DTM_1_1_ReqDT then
				app.raiseUnexpectedProgramError (self.class.name, method.name, 'Function is not supported');
			endif;
		endif;
		
	elseif ruleItem = self.Item_FTX_1_1 then
		if ruleFunction &lt;&gt; null then
			if ruleFunction &lt;&gt; self.Function_FTX_1_1_BookingRemark then
				app.raiseUnexpectedProgramError (self.class.name, method.name, 'Function is not supported');
			endif;
		endif;
		
	elseif ruleItem = self.Item_RFF_1_1 then  //11/09/2014 cnwma1 PAR#34855  CCMS POL 2351
		if ruleFunction &lt;&gt; null then
			if ruleFunction &lt;&gt; self.Function_RFF_1_1_RelNo and
			   ruleFunction &lt;&gt; self.Function_RFF_1_1_ACW and
			   ruleFunction &lt;&gt; self.Function_RFF_1_1_ANN and
			   ruleFunction &lt;&gt; self.Function_RFF_1_1_BN and
			   ruleFunction &lt;&gt; self.Function_RFF_1_1_RE and
			   ruleFunction &lt;&gt; self.Function_RFF_1_1_REO and
			   ruleFunction &lt;&gt; self.Function_RFF_1_1_SQ and
			   ruleFunction &lt;&gt; self.Function_RFF_1_1_VON and
			   ruleFunction &lt;&gt; self.Fnct_RFF_1_1_Booking and
			   ruleFunction &lt;&gt; self.Fnct_RFF_1_1_EntryNumber and
			   ruleFunction &lt;&gt; self.Fnct_RFF_1_1_BOL and
			   ruleFunction &lt;&gt; self.Fnct_RFF_1_1_CarrierRef and
			   ruleFunction &lt;&gt; self.Fnct_RFF_1_1_CustomerRef and
			   ruleFunction &lt;&gt; self.Fnct_RFF_1_1_Release and
			   ruleFunction &lt;&gt; self.Fnct_RFF_1_1_Sequence then
				app.raiseUnexpectedProgramError (self.class.name, method.name, 'Function is not supported');
			endif;
		endif;
	elseif ruleItem = self.Item_NAD_1_1 then  
		if ruleFunction &lt;&gt; null then
			if ruleFunction &lt;&gt; self.Function_NAD_1_1_AM and
			   ruleFunction &lt;&gt; self.Function_NAD_1_1_CA and
			   ruleFunction &lt;&gt; self.Function_NAD_1_1_CC and
			   ruleFunction &lt;&gt; self.Function_NAD_1_1_CN and
			   ruleFunction &lt;&gt; self.Function_NAD_1_1_CU and
			   ruleFunction &lt;&gt; self.Function_NAD_1_1_CZ and
			   ruleFunction &lt;&gt; self.Function_NAD_1_1_FW and
			   ruleFunction &lt;&gt; self.Function_NAD_1_1_SH and
			   ruleFunction &lt;&gt; self.Function_NAD_1_1_SPC and
			   ruleFunction &lt;&gt; self.Fnct_NAD_n_1_CargoOper and
			   ruleFunction &lt;&gt; self.Fnct_NAD_n_1_Consignee and
			   ruleFunction &lt;&gt; self.Fnct_NAD_n_1_Consignor and
			   ruleFunction &lt;&gt; self.Fnct_NAD_n_1_CustomAgent and
			   ruleFunction &lt;&gt; self.Fnct_NAD_n_1_FreightForwd and
			   ruleFunction &lt;&gt; self.Fnct_NAD_n_1_RecCarrier and
			   ruleFunction &lt;&gt; self.Fnct_NAD_n_1_RelCarrier and
			   ruleFunction &lt;&gt; self.Fnct_NAD_n_1_WghtCertNam and
			   ruleFunction &lt;&gt; self.Fnct_NAD_n_1_WghtCertRef then
				app.raiseUnexpectedProgramError (self.class.name, method.name, 'Function is not supported');
			endif;
		endif;
	elseif ruleItem = self.Item_NAD_2_1 then  
		if ruleFunction &lt;&gt; null then
			if ruleFunction &lt;&gt; self.Fnct_NAD_n_1_CargoOper and
			   ruleFunction &lt;&gt; self.Fnct_NAD_n_1_Consignee and
			   ruleFunction &lt;&gt; self.Fnct_NAD_n_1_Consignor and
			   ruleFunction &lt;&gt; self.Fnct_NAD_n_1_CustomAgent and
			   ruleFunction &lt;&gt; self.Fnct_NAD_n_1_FreightForwd and
			   ruleFunction &lt;&gt; self.Fnct_NAD_n_1_RecCarrier and
			   ruleFunction &lt;&gt; self.Fnct_NAD_n_1_RelCarrier and
			   ruleFunction &lt;&gt; self.Fnct_NAD_n_1_WghtCertNam and
			   ruleFunction &lt;&gt; self.Fnct_NAD_n_1_WghtCertRef then
				app.raiseUnexpectedProgramError (self.class.name, method.name, 'Function is not supported');
			endif;
		endif;
	elseif ruleItem = self.Item_NAD_3_1 then  
		if ruleFunction &lt;&gt; null then
			if ruleFunction &lt;&gt; self.Fnct_NAD_n_1_CargoOper and
			   ruleFunction &lt;&gt; self.Fnct_NAD_n_1_Consignee and
			   ruleFunction &lt;&gt; self.Fnct_NAD_n_1_Consignor and
			   ruleFunction &lt;&gt; self.Fnct_NAD_n_1_CustomAgent and
			   ruleFunction &lt;&gt; self.Fnct_NAD_n_1_FreightForwd and
			   ruleFunction &lt;&gt; self.Fnct_NAD_n_1_RecCarrier and
			   ruleFunction &lt;&gt; self.Fnct_NAD_n_1_RelCarrier and
			   ruleFunction &lt;&gt; self.Fnct_NAD_n_1_WghtCertNam and
			   ruleFunction &lt;&gt; self.Fnct_NAD_n_1_WghtCertRef then
				app.raiseUnexpectedProgramError (self.class.name, method.name, 'Function is not supported');
			endif;
		endif;
		
	elseif ruleItem = self.Item_FTX_3_1 then	//07 Jun 2017	NDL	TFS 4454
		if ruleFunction &lt;&gt; null then
			if ruleFunction &lt;&gt; self.Function_FTX_3_1_Stowage then	
				app.raiseUnexpectedProgramError (self.class.name, method.name, 'Function is not supported');
			endif;
		endif;	
	elseif ruleItem = self.Item_FTX_4_1 then
		if ruleFunction &lt;&gt; null then 
			// we expect the GUI to only present valid options
			if ruleFunction &lt;&gt; self.Function_FTX_4_1_BookingIgnore and
				ruleFunction &lt;&gt; self.Function_FTX_4_1_BookingVent and
				ruleFunction &lt;&gt; self.Function_FTX_4_1_Heavy and
				ruleFunction &lt;&gt; self.Function_FTX_4_1_EstReqDT and       //cnwma1 TFS #2048 14/06/2016 
				ruleFunction &lt;&gt; self.Function_FTX_4_1_MTGradeText then
				app.raiseUnexpectedProgramError (self.class.name, method.name, 'Function is not supported');
			endif;
		endif;
		
	elseif ruleItem = self.Item_MEA_3_2 then
		if ruleFunction &lt;&gt; null then 
			// we expect the GUI to only present valid options
			if ruleFunction &lt;&gt; self.Function_MEA_3_2_Heavy then
				app.raiseUnexpectedProgramError (self.class.name, method.name, 'Function is not supported');
			endif;
		endif;
		
	elseif ruleItem = self.Item_TMP_1_1 then
		if ruleFunction &lt;&gt; null then 
			// we expect the GUI to only present valid options
			if ruleFunction &lt;&gt; self.Function_TMP_1_1_MTGradeTemp then
				app.raiseUnexpectedProgramError (self.class.name, method.name, 'Function is not supported');
			endif;
		endif;
	elseif ruleItem = self.Item_FTX_21_1 then	// jlgka1 TFS 39187, 39185 --&gt;
		if ruleFunction &lt;&gt; self.Function_FTX_21_1_Mafis and
		   ruleFunction &lt;&gt; self.Function_FTX_21_1_IgnoreSeg then	
				app.raiseUnexpectedProgramError (self.class.name, method.name, 'Function is not supported');
		endif; // jlgka1 TFS 39187, 39185	&lt;--
	endif;
	
	if self.value = null then
		app.raiseCMException (EDI_Party_Error7, null, null);
	endif;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateCreate" id="b024b8d1-a3d6-4972-8d6c-164edceba535">
        <source>validateCreate(_passport: CM_Passport input);
/*
Date		Who		Reason
16 November 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
*/
vars
	
begin
	self.raiseExceptionIfNotTransient (method);
	
	self.validate (_passport);
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateUpdate" id="f8076b04-a236-4ec4-93b7-e6a840ae4ce1">
        <source>validateUpdate(_passport: CM_Passport input);
/*
Date		Who		Reason
16/11/2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
*/
vars
	
begin
	self.raiseExceptionIfNotProxy (method);
	
	self.validate (_passport);
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
