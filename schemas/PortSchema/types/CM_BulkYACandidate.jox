<Class name="CM_BulkYACandidate" id="5b0cebcd-37ed-4912-b242-5f04c45cdd14">
    <superclass name="CM_Object"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="yardAllocations"/>
    <ImplicitInverseRef name="allMatchingTIs" id="237226d0-a383-4e6d-a1ae-e3cbee893e69">
        <memberTypeInverse/>
        <type name="CM_TISet"/>
    </ImplicitInverseRef>
    <PrimAttribute name="criteriaType" id="5e59f32a-4a89-4991-9457-ee02c56853ff">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="criteriaValue" id="0c406225-f2e2-45bd-b21b-8da9836872c5">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="imexStatus" id="003b7357-cca1-469c-90b8-e0f5b8363e26">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <ImplicitInverseRef name="myExistingYardAllocation" id="011be5ee-8f36-45e7-b9cb-e0b87b745750">
        <embedded/>
        <type name="CM_YardAllocation"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myTerminal" id="98d6a9fb-a809-427d-8b43-0bf514085c7b">
        <embedded/>
