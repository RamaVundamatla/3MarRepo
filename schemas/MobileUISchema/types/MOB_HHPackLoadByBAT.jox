    <JadeMethod name="txtBatNo_lostFocus" id="28da9701-802c-4efb-bd4a-515c7dde34a0">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtBatNo_lostFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 August 2015	cnwndl1	Initial creation	Par 36782

*/

vars

begin

	if txtBatNo.text.trimBlanks = null then
		txtBatNo.text := lblBatNo.caption.toUpper;
	endif;
	
	txtBatNo.selStart := 0;
	txtBatNo.selLength := 0;
	
	if self.myBulkRelease = null or self.myBulkRelease.code &lt;&gt; txtBatNo.text then
		self.findBatAndRequest();
	endif;
	
	self.setBtnsState();

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
