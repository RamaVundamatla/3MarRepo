    </JadeMethod>
    <JadeMethod name="doPurgeNavisSmartActivity" id="5a832d2c-2375-47ba-ba58-c4c8420259a1">
        <updating/>
        <source>doPurgeNavisSmartActivity()  :  Boolean protected, updating;
/*
Purpose:			

Date		Who		Reason
06 August 2021	navab1	TFS 50669
*/

vars

	errCode	: Integer;
	errTxt	: String;
	count, count2, completed, theSize   : Integer;
	iter,
	iter1   : Iterator;
	setAll,
    setErrors			: CM_ObjectSetActual;
	ewsAct : CM_ExternalWebServiceActivity;
	ewsActivities : CM_EWSActivityByDateTime;
begin
	on Exception do app.alertExceptionHandler(exception, null, app.getErrorString(Garbage_Collection), errCode, errTxt, true, false);
	
	self.doInitiateProcess;
	self.createActivityHistory(app.getErrorString(Database_Purging) &amp; ' ' &amp; app.getErrorString(Archive_navis_smart_activit), false, false);
 
	create setAll transient;
    create setErrors transient;
	create ewsActivities transient;
	
	iter := app.myRoot.allEWSOpsviewActivities.createIterator();
	while iter.next(ewsAct) do
		if ewsAct.status &lt;&gt; BGP_OpsViewWSRequest.EWS_STATUS_DELETED 
		and ewsAct.status &lt;&gt; BGP_OpsViewWSRequest.EWS_STATUS_BGP_SENT_SUCCESS  then
			continue;
		endif;

		if ewsAct.myTerminal &lt;&gt; null 
		and ewsAct.myTerminal &lt;&gt; self.myTerminal then
			continue;
		endif;

		if ewsAct.created.date &gt; self.date then
			continue;
		endif;
		ewsActivities.add(ewsAct);
	endwhile;	

	
	iter1 := ewsActivities.createIterator();
	theSize:= ewsActivities.size;

//		self.createActivityHistory("Identified " &amp; theSize.String &amp; " " &amp; app.getErrorString(Archive_navis_smart_activit),false,false);

	while iter1.next(ewsAct) do
		count := count + 1; 
		
		setAll.add(ewsAct);
		
		if count = self.Commit_Block_Size_Medium then
			self.addNumCompleted(setAll.size);
			if not self.doEraseBlockOfObjects(setAll, setErrors) then
				return false;
			endif;
			setAll.clear();
			count := 0;
			if self.abort() then
				return false;
			endif;
			if self.numCompleted mod self.Activity_Progress_Count_Small = 0 then
				self.createActivityHistory(app.getErrorString2(Progress, app.getErrorString(Purged) &amp; ' ' &amp; self.numCompleted.String, theSize.String &amp; ' ' &amp; app.getErrorString(Archive_navis_smart_activit) &amp; ' ' &amp; app.getErrorString(Available)), false, false);
			endif;
		endif;
	endwhile;	
	
	if not setAll.isEmpty() then
			self.addNumCompleted(setAll.size);
		if not self.doEraseBlockOfObjects(setAll, setErrors) then
			return false;
		endif;
	endif;
	
	self.setStats("END " &amp; app.getErrorString(Purged) &amp; ' ' &amp; self.numCompleted.String &amp; ' ' &amp; app.getErrorString(Archive_navis_smart_activit) &amp; ' ' &amp; setErrors.size.String &amp; ' ' &amp; app.getErrorString(Errors));

	
	self.createActivityHistory("Purged "&amp; self.numCompleted.asStringJMT() &amp; ' ' &amp; app.getErrorString(Archive_navis_smart_activit), false, false);
	
	return true;
epilog
	delete iter;
	delete iter1;
	
	delete ewsActivities;

	delete setAll;
	delete setErrors;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
