    <JadeMethod name="hideShowExtraInfo" id="c4145f87-7b36-4159-b179-3c8380ce0042">
        <updating/>
        <source>hideShowExtraInfo(_splitter : CMUI_SplitContainer input) protected, updating;
//-----------------------------------------
// Created: 12 November 2003 By: cnwgd1
//-----------------------------------------
begin
	if self.hideExtraInfo = true then
		self.mnuToggleExtraInfo.caption := app.getErrorString(Hide_Additional_Info);
	else
		self.mnuToggleExtraInfo.caption := app.getErrorString(Show_Additional_Info);
	endif;
	
	self.doToggleExtraInfo(_splitter);
end;</source>
        <access>protected</access>
        <Parameter name="_splitter" type="CMUI_SplitContainer" usage="input"/>
    </JadeMethod>
    <JadeMethod name="initClonedControls" id="b5054741-746d-41c6-88f2-2b4b0cb7abb7">
        <source>initClonedControls();
//--------------------------------------------------
// Created:	02 October 2003 By: cnwgd1
//--------------------------------------------------
vars
	idx,
	ratio,
	count,
	numCntrls	: Integer;
	obj 		: Object;
	tmpCntrl,
	cntrl		: CMUI_SplitContainer;
begin

	numCntrls := self.allClonedSplitters.size;

	if numCntrls &lt; 1 then
		return;
	endif;

	count := numCntrls + 1;
	foreach obj in self.allClonedSplitters do
		idx := idx+1;
		cntrl := obj.CMUI_SplitContainer;
		ratio := (100/count).Integer;
		if idx = numCntrls then
			if numCntrls = 1 then
				if cntrl.getMyRightControl() = null then
					cntrl.setLeftToRightRatioAndResize(100);
					tmpCntrl := cntrl.getControlByName('splTables').CMUI_SplitContainer;
					tmpCntrl.parent := self;
				endif;
			endif;
			break;
		endif;			
		cntrl.setLeftToRightRatioAndResize(ratio);
		count := count-1;
	endforeach;
	
	if tmpCntrl &lt;&gt; null then
		self.allClonedSplitters.remove(cntrl);
		delete cntrl;
		self.allClonedSplitters.add(tmpCntrl);
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="initFromUserWindow" id="c9eca015-008c-46b2-a422-effc49ad37c7">
        <updating/>
        <source>initFromUserWindow(_userWindow : CM_UserWindow) updating;
//--------------------------------------------------------------
//Created: 15 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	pos,
	startPos		: Integer;
	splitterName	: String;
begin
	inheritMethod(_userWindow);
	if _userWindow = null then
		self.splTablesRatio := 80;
		return;
	endif;
	
	startPos := 1;
	pos := 1;
	splitterName := _userWindow.xmlInfo.cnEcGetNextTagValueOfName(XMLTag_Splitter &amp; ' ' &amp; self.name &amp; ' ' &amp; splTables.name, startPos);

	if splitterName &lt;&gt; null then
		self.splTablesRatio := splitterName.cnEcGetNextTagValueOfName(XMLTag_Ratio, pos).Integer;
		self.hideExtraInfo := splitterName.cnEcGetNextTagValueOfName(XMLTag_HideExtraInfo, pos).Boolean;
	endif;
	if self.splTablesRatio &lt; 1 or self.splTablesRatio &gt; 99 then
		self.splTablesRatio := 80;
	endif;
	if self.hideExtraInfo then
		self.mnuToggleExtraInfo.caption := app.getErrorString(Show_Additional_Info);
	else
		self.mnuToggleExtraInfo.caption := app.getErrorString(Hide_Additional_Info);	
	endif;

	self.xmlStrDischarge := _userWindow.xmlInfo.cnEcGetTagValueOfName(XMLTag_DischargeView);	
	self.xmlStrLoad := _userWindow.xmlInfo.cnEcGetTagValueOfName(XMLTag_LoadView);		

end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="initTblWorkEntries" id="ff448003-10ab-40b2-8a1a-7fc971b24b78">
        <updating/>
        <source>initTblWorkEntries(_table : CM_DataTable input)updating;
//-----------------------------------------
//Created: March 2003 By: cnwgd1
//-----------------------------------------
vars
begin

	if _table = null then
		return;
	endif;
	
	self.setTableHeadings(_table);
	// dont want to 
	_table.disallowColumnSorter := true;
	_table.userInputEnabled := false;
	_table.multiSelect := CM_DataTable.MultiSelect_None; // PAR 7686
	self.toggleMultiSelect(_table);
	_table.selectMode := Table.SelectMode_CurrentRow;
	_table.selectionType := CM_DataTable.SelectionType_Row;
	self.setColorsForTable(_table);

end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="initialiseWithObject" id="5d77fd2c-3a5f-4ca7-a2b2-0b3ff1643a17">
        <updating/>
        <source>initialiseWithObject(_voyage : CM_Voyage; _crane : CM_Crane ; _job : CM_VoyageJob) updating;
// ---------------------------------------------------------------------------
// Created:     23 January 2008 by cnwaer1
//
// Purpose:     my
// ---------------------------------------------------------------------------
vars

begin
//	PAR 36296 self.myInitVoyage :=_voyage.CM_Voyage;
	self.myInitCrane := _crane.CM_Crane;
	self.myInitJob := _job.CM_VoyageJob;
	self.show();	
	
	// PAR 36296 self.myCurrentVoyage := _voyage.CM_Voyage; // PAR 36296
	self.setMyCurrentVoyage(_voyage.CM_Voyage);
	
	if self.myInitJob &lt;&gt; null then
		 // PAAR 36296 self.myCurrentVoyage := _voyage.CM_Voyage;
		self.doJobSelection();
	endif;
	
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_crane" type="CM_Crane"/>
        <Parameter name="_job" type="CM_VoyageJob"/>
    </JadeMethod>
    <JadeMethod name="keyDown" id="feb43496-630f-434e-a664-b6d9b7a289ce">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
//--------------------------------------------------
// Created:	15 October 2003 By: cnwgd1
//--------------------------------------------------
vars

begin
	app.mousePointer := MousePointer_HourGlass;
	
	if keyCode = CMUI_Key_F3 then
		self.showHideSelector();
		return;
		
	elseif keyCode = J_key_A then 
		if app.isAltKeyDown()
		and not app.isControlKeyDown()
		and not app.isShiftKeyDown()
		then
			if myCurrentTableWLE &lt;&gt; null then
				if self.myCurrentTableWLE.areAllSelected() then
					self.myCurrentTableWLE.deselectAll();
				else
					self.myCurrentTableWLE.selectAll();
				endif;
			endif;
			return;
		endif;
		
	elseif keyCode = J_key_E then 
		if app.isAltKeyDown()
		and not app.isControlKeyDown()
		and not app.isShiftKeyDown()
		then
			self.doEdit();
			return;
		endif;
		
	elseif keyCode = J_key_L then 
		if app.isAltKeyDown()
		and not app.isControlKeyDown()
		and not app.isShiftKeyDown()
		then
			self.doJobSelection();
			return;
		endif;
		
	elseif keyCode = J_key_M then 
		if app.isAltKeyDown()
		and not app.isControlKeyDown()
		and not app.isShiftKeyDown()
		then
			self.doBtnMoveIt();
			return;
		endif;
		
	elseif keyCode = J_key_P then 
		if app.isAltKeyDown()
		and not app.isControlKeyDown()
		and not app.isShiftKeyDown()
		then
			self.doBtnPrint();
			return;
		endif;
		
	elseif keyCode = J_key_R then 
		if app.isAltKeyDown()
		and not app.isControlKeyDown()
		and not app.isShiftKeyDown()
		then
			self.doRefreshTable(self.myCurrentTableWLE);
			return;
		endif;
		
	elseif keyCode = J_key_S then 
		if app.isAltKeyDown()
		and not app.isControlKeyDown()
		and not app.isShiftKeyDown()
		then
			self.showHideSelector();
			return;
		endif;
		
	elseif keyCode = J_key_Return then
		if self.frmSelector.visible then
			self.doJobSelection();
		endif;
		
	endif;

	inheritMethod(keyCode, shift);
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadControlsForSelectedJobs" id="5996b079-c523-49d0-874b-10ceba17bfe4">
        <updating/>
        <source>loadControlsForSelectedJobs()updating;
//--------------------------------------------------
// Created:	01 October 2003 By: cnwgd1
//--------------------------------------------------
vars
	numJobs,
	count,
	idx	 		: Integer;
	job			: CM_VoyageJob;
	firstTime,
	last, invalidObj		: Boolean;
	str			: String;
	cntrl		: CMUI_SplitContainer;	
begin
	on Exception do app.handleDeletedObject(exception, job, invalidObj);

	self.allClonedSplitters.purge();	
	self.allClonedWLETables.purge();
	self.allTablesByWle.clear();
	self.myCurrentSplitter := null;	
	self.myCurrentTableWLE := null;	
	self.myCurrentTableInfo := null;
	self.myCurrentWLE := null;		
	self.myCurrentTrackedItem := null;				
	self.doNotableClear();
			
	idx := 1;	
	numJobs := self.allSelectedVoyageJobsArray.size;
	firstTime := true;
	if self.myInitJob &lt;&gt; null then
			self.allSelectedVoyageJobsArray.clear();
			self.allSelectedVoyageJobsArray.add(self.myInitJob);
	endif;
	foreach job in self.allSelectedVoyageJobsArray do
		count := count +1;
		last := count = numJobs;
		idx := idx+1;
		self.cloneControls(job, idx, last);
		if firstTime then
			str := job.jobNum;
			firstTime := false;						
		else
			str := str &amp; ', ' &amp; job.jobNum;				
		endif;
	  endforeach;
	
	self.initClonedControls();
	
	if self.myCurrentVoyage &lt;&gt; null then
		self.setCaption(str &amp; ' ' &amp; self.myCurrentVoyage.code &amp; " - " &amp; self.myCurrentVoyage.description.trimBlanks &amp; ' ' &amp; app.getErrorString(JobOperations));
	else
		self.setCaption(app.getErrorString(JobOperations));
	endif;
	self.doResize();
end;</source>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="f6fac20b-ac77-4a0e-a93a-83a92e9a0196">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
// ---------------------------------------------------------------------------
// Created:      29 May 2003 by cnwsgp1
// ---------------------------------------------------------------------------
vars
	regKeys : IntegerArray;

begin
	self.doRefresh; 
	self.mnuTableInspectObject.visible := app.isAllowedToInspect();
	// All key strokes are turned off by default. This turns them back on and includes the H key. H for Help.
	create regKeys transient;
	regKeys.add(J_key_L); // look
	regKeys.add(J_key_A); // all
	regKeys.add(J_key_M); // move
	regKeys.add(J_key_S); // selector
	regKeys.add(J_key_P); // print
	regKeys.add(J_key_E); // enquiry
	regKeys.add(J_key_R); // refresh
	self.addRegisteredKeys(regKeys);

	self.chkQInOrder.bubbleHelp := "Queue all or none. Only Applies when using 'Queue All'." &amp; Cr &amp; Cr
								&amp; "If checked this means that if there are any errors or" &amp; Cr &amp; "warnings during 'Queue All' then none will be queued." &amp; Cr &amp; Cr
								&amp; "If unchecked, then during 'Queue All' only those" &amp; Cr &amp; "with no errors or warnings will be queued.";
epilog
	delete regKeys;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadListJobs" id="cc0b01d6-db69-4c36-94e5-998c1ef0709e">
        <source>loadListJobs(	_voyage : CM_Voyage;
				_crane	: CM_Crane;
				_job	: CM_VoyageJob);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Oct 2012	cnwpjs1	Initial creation  PAR #30438 - Voyage Rationalisation
29/04/2013	cnwcs5	par 30652 - remove resynch/resynchObject method calls
24/02/2024 	navcs2 	MTN-29368 EUP | Transaction Instrumentation - Voyage Discharge
14 Jan 2026 navhl20 Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
*/

vars
	str					: String;
	lvl,
	idx,
	jobSheetIdx,
	voyageIdx			: Integer;
	jobArray			: CM_JobArray;
	jobSheet			: CM_VoyageJobSheet;
	voyageJobSheetArray	: CM_VoyageJobSheetArray;
begin
	lstJobs.backColor := White;
	lstJobs.clear();
	lstJobs.hasTreeLines := true;
	lstJobs.hasPlusMinus := true;
	lstJobs.defaultLineHeight := 13;
	lstJobs.hasPictures := false; // this will put the windows pictures, folder etc. onto the tree

	self.tblInfo.clear();
	self.tblInfo.rows := 0;
	
	if _voyage = null then
		return;
	endif;
		

	self.tblWorkEntries.rows := self.tblWorkEntries.fixedRows;
	lvl := 1;
//	idx := self.lstJobs.addItem("Voyage Operations");
	idx := self.lstJobs.addItem(app.getErrorString(Voyage_Operations));	//30468
	lstJobs.itemLevel[idx] := lvl;
	lstJobs.itemObject[idx] := null;
	lstJobs.itemPicture[idx] := app.myRoot.getConfig(PicShipOps).Binary;
	
	create voyageJobSheetArray transient;
	create jobArray transient;
		
	lvl := 2;
	str := _voyage.code;
	
	idx := lstJobs.addItem(str);
	lstJobs.itemObject[idx] := _voyage;
	lstJobs.itemLevel[idx] := lvl;
	lstJobs.itemPicture[idx] := self.picVoyage.picture;
	lstJobs.itemExpanded[idx] := true;
	voyageIdx := idx;
	
	if _crane &lt;&gt; null then
		jobSheet :=  _voyage.allJobSheets[_crane.id];
		voyageJobSheetArray.add(jobSheet);
	else
		_voyage.allJobSheets.copy(voyageJobSheetArray);
	endif;
		
	foreach jobSheet in voyageJobSheetArray do
		
		lvl := 3;
		idx := lstJobs.addItem(jobSheet.crane);
		jobSheetIdx := idx;
		lstJobs.itemObject[idx] := jobSheet;
		lstJobs.itemLevel[idx] := lvl;
		
		//  PAR # 30438 
		if jobSheet.isVoyageROROJobSheet then
			lstJobs.itemPicture[idx] := self.picVoyage.picture;
		else
			lstJobs.itemPicture[idx] := self.picCrane.picture;
		endif;
		
		lvl := lvl+1;
		jobArray.clear();
		
		if _job &lt;&gt; null then
			jobArray.add(_job);
		else		
			jobSheet.allJobsByOrder.copy(jobArray);
		endif;
		
		self.lstJobsSetBelowLevelAllJobs(jobArray, idx, lvl, (_job &lt;&gt; null));
		lstJobs.itemExpanded[jobSheetIdx] := true;
		
	endforeach;
	
	
	if _job = null then
		self.lstJobsSetBelowVoyUnallocated(_voyage);
	endif;
	
	
	lstJobs.itemExpanded[voyageIdx] := true;
		
	
epilog
	delete jobArray;
	delete voyageJobSheetArray;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_crane" type="CM_Crane"/>
        <Parameter name="_job" type="CM_VoyageJob"/>
    </JadeMethod>
    <JadeMethod name="lstJobsChange" id="4a41ccb3-7ec5-46d0-9696-4b47718a209b">
        <updating/>
        <source>lstJobsChange(_listObject : CM_Object)updating;
//--------------------------------------------------------------
//Created: 18 March 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	rowIdx,
	lstCnt		: Integer;
	obj			: Object;
	job			: CM_VoyageJob;
	tmpVoyage,
	saveVoyage 	: CM_Voyage;
begin

	saveVoyage := self.myCurrentVoyage;
	self.setMyCurrentListObjects(_listObject);
	
	if _listObject = null then
		self.setNavigator(_listObject);
	endif;
	
	if saveVoyage &lt;&gt; self.myCurrentVoyage then
		//Voyage has changed, we only display jobs from same voyage
		lstCnt := self.lstJobs.listCount;
		foreach rowIdx in 1 to lstCnt do
			if (not lstJobs.itemSelected[rowIdx]) then
				continue;
			endif;		
			obj := lstJobs.itemObject[rowIdx];
			if obj = null then
				continue;
			endif;
			job := null;
			tmpVoyage := null;			
			if obj.isKindOf(CM_VoyageJob) then
				job := obj.CM_VoyageJob;
				tmpVoyage := job.myVoyage;
			elseif obj.isKindOf(CM_Voyage) then
				tmpVoyage := obj.CM_Voyage;
			elseif obj.isKindOf(CM_VoyageJobSheet) then
				tmpVoyage := obj.CM_VoyageJobSheet.myVoyage;
			endif;
			if tmpVoyage &lt;&gt; self.myCurrentVoyage then
				lstJobs.itemSelected[rowIdx] := false;
				if job &lt;&gt; null then
					if self.allSelectedVoyageJobsArray.includes(job) then
						self.allSelectedVoyageJobsArray.remove(job);
					endif;
				endif;
			endif;
		endforeach;
	endif;
end;</source>
        <Parameter name="_listObject" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="lstJobsContextMenu" id="cc60bf7e-7bc6-4c1a-9204-3f2c738f9bb3">
        <source>lstJobsContextMenu(_left, _top : Integer);
//--------------------------------------------------------------
//Created: 18 March 2003 By: cnwgd1
//--------------------------------------------------------------
// Changed On	By			Reason
// ----------	----------	------------------------------------
// 18/12/2019	jlgdap1		TFS 47144 JMT Refactor OOW Job Split Transfer
// 23/06/2020   cnwma1      Bug 49384: PEN - Problem with splitting jobs
vars

	obj : Object;
	voyage : CM_Voyage;
	job : CM_VoyageJob;			// TFS 47144

begin

	if self.myCurrentJob &lt;&gt; null then
		self.mnuLstJobRebuildStatus.visible := true;
		self.mnuLstJobRebuildStatus.userObject := self.myCurrentJob;
	else
		self.mnuLstJobRebuildStatus.visible := false;
		self.mnuLstJobRebuildStatus.userObject := null;
	endif;
	
	// PAR 36296 if self.myInitVoyage &lt;&gt; null or self.myInitJob &lt;&gt; null then
	if self.myCurrentVoyage &lt;&gt; null or self.myInitJob &lt;&gt; null then
		self.mnuLstJobHideCompleted.visible := false;
	else
		self.mnuLstJobHideCompleted.visible := true;
	endif;
	

	//cnwjo3 CCMS 1178 par 23366
	if app.getMyUser.canDo(self.myTerminal,PmAdmMoveCargoFromJob) then
		self.mnuMoveCargoFromJob2.visible := true;
	endif;
	
	//cnwjo3 ccms 1178 par 23366
	//self.mnuSplitOrTransferWrk2.visible := true;
	self.mnuSplitWork2.visible := false;	//18 Oct 2012	NDL	Par 30544
	self.mnuTransferWork2.visible := false;						// TFS 47144
	self.mnuMoveCargoFromJob2.enabled := false;
	if self.lstJobs.listObject &lt;&gt; null then
		if self.lstJobs.listObject.isKindOf(CM_VoyageJob) then
			job := self.lstJobs.listObject.CM_VoyageJob;		// TFS 47144
			if self.lstJobs.listObject.CM_VoyageJob.isDischarge then
				self.mnuMoveCargoFromJob2.enabled := true;
			endif;
			self.mnuSplitWork2.visible := true;	//18 Oct 2012	NDL	Par 30544
			self.mnuTransferWork2.visible := true;				// TFS 47144
			if job &lt;&gt; null then									// TFS 47144
				if job.status = JOB_UNACTIONED then				// TFS 47144
					//self.mnuSplitWork2.enabled := false;		// TFS 47144  //23.06.2020 cnwma1 #49384
					self.mnuTransferWork2.enabled := true;		// TFS 47144
				else											// TFS 47144
					self.mnuSplitWork2.enabled := true;			// TFS 47144
					self.mnuTransferWork2.enabled := false;		// TFS 47144
				endif;											// TFS 47144
			endif;												// TFS 47144
		endif;
	endif;
	
	//02 Apr 2012	NDL	Par 29369
	obj := self.lstJobs.listObject;
	self.mnuWPOpHrs2.visible := false;
	self.mnuWPOpHrs2.userObject := null;
	if obj &lt;&gt; null then
		if obj.isKindOf(CM_VoyageJob) then
			voyage := obj.CM_VoyageJob.myVoyage;
		elseif obj.isKindOf(CM_VoyageJobSheet) then
			voyage := obj.CM_VoyageJobSheet.myVoyage;
		endif;
		if voyage &lt;&gt; null then
			self.mnuWPOpHrs2.visible := true;
			self.mnuWPOpHrs2.userObject := voyage;
		endif;
	endif;
	
	popupMenu(mnuLstJobContext, _left, _top);
end;</source>
        <Parameter name="_left" type="Integer"/>
        <Parameter name="_top" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="lstJobsDblClick" id="2a5b6399-42c8-45c1-aeab-21f8b1157c90">
        <updating/>
        <source>lstJobsDblClick() updating;
//--------------------------------------------------------------
//Created: 03 April 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	self.lstJobsChange(self.lstJobs.listObject.CM_Object);
	self.doJobSelection();

end;</source>
    </JadeMethod>
    <JadeMethod name="lstJobsMouseMoveEvent" id="c5982b68-6d61-4213-99a3-b428907e0e64">
        <updating/>
        <source>lstJobsMouseMoveEvent(button: Integer; shift: Integer; x: Real; y: Real) updating;
//--------------------------------------------------------------
//Created: 16 April 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	if self.myCurrentListObject = null then
		return;
	endif;
	
	// #### WE ARE DRAGGING A JOB, but where from?
	if self.myCurrentListObject &lt;&gt; self.myCurrentJob then
		return;
	endif;

	if self.myCurrentJob.status = JOB_COMPLETE then
		self.lstJobs.dragCursor := self.picJobCompCur.picture;//self.curJobComp.picture;
	elseif self.myCurrentJob.status = JOB_PART_COMPLETE then
		self.lstJobs.dragCursor := self.picJobPartComCur.picture;//self.curJobPartComp.picture;
	else //Unactioned
		self.lstJobs.dragCursor := self.picJobUnactCur.picture;//self.curJobWLEs.picture;	
	endif;
	
	self.dragMode := DragMode_Drag;	
	self.dragCursor := self.lstJobs.dragCursor;

end;</source>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="lstJobsSaveSelected" id="68e7e122-2277-4834-a56b-4397556841d5">
        <updating/>
        <source>lstJobsSaveSelected() protected, updating;
// ---------------------------------------------------------------------------
// Created:      16 July 2003 by cnwsgp1
// ---------------------------------------------------------------------------
begin

	self.selectedListObject := self.myCurrentListObject;
	
	if self.lstJobs.listIndex &lt; 1 then
		self.selectedExpanded := null;
		self.topIndex := null;
		self.topObject := null;
		return;
	endif;
	
	self.selectedExpanded := self.lstJobs.itemExpanded[self.lstJobs.listIndex];
	self.topIndex := self.lstJobs.topIndex;
	self.topObject := self.lstJobs.itemObject[self.topIndex].CM_Object;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="lstJobsSetBelowLevelAllJobs" id="08b2b4c0-fb10-4f02-9622-579a61c6e595">
        <source>lstJobsSetBelowLevelAllJobs(_allJobs : CM_JobArray; _jobIndex,_level : Integer; _specificJob : Boolean);
//--------------------------------------------------------------
//Created: 19 March 2003 By: cnwgd1
// 09 Oct 12		PJS		PAR #30438 - Voyage Rationalisation
//--------------------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	job		: CM_Job;
	str  	: String;
	wle		: CM_WorkListEntry;
	jobIndex: Integer;
	request : CM_Request;
	vJob : CM_VoyageJob;
begin

	if _allJobs.isEmpty then
		return;
	endif;

	jobIndex := (_jobIndex + 1);
	
	//foreach job in _allJobs reversed do
	foreach job in _allJobs do
		vJob :=  job.CM_VoyageJob;
		
		// if its not a specific job then there may be reasons not to show it
		//
		if not _specificJob then
			if (not vJob.isLoadedToOperations) then
				continue;
			endif;
			if hideCompletedJobs and job.status = JOB_COMPLETE then
				continue;
			endif;
		endif;
		str := vJob.getTreeDescription();		

		self.lstJobs.addItemAt(str, jobIndex);
		self.lstJobs.itemObject[jobIndex] := job;
		self.lstJobs.itemLevel[jobIndex] := _level;
		
		if _specificJob then
			lstJobs.itemExpanded[jobIndex] := true;
			lstJobs.itemSelected[jobIndex] := true;
		endif;
		
		
		// Par 13968
		self.lstJobs.itemData[jobIndex] := job.status;

		if job.status = JOB_COMPLETE then
			self.lstJobs.itemPicture[jobIndex] := self.picJobComp.picture;
		elseif job.status = JOB_PART_COMPLETE then
			self.lstJobs.itemPicture[jobIndex] := self.picJobPartComp.picture;		
		else //Unactioned
			self.lstJobs.itemPicture[jobIndex] := self.picJobWLEs.picture;
		endif;	
		
		jobIndex := jobIndex + 1;

	endforeach;

end;</source>
        <Parameter name="_allJobs" type="CM_JobArray"/>
        <Parameter name="_jobIndex" type="Integer"/>
        <Parameter name="_level" type="Integer"/>
        <Parameter name="_specificJob" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="lstJobsSetBelowVoyUnallocated" id="9e186e76-db32-4d8f-a962-1c4a3d57eae0">
        <source>lstJobsSetBelowVoyUnallocated(_voyage : CM_Voyage);
//--------------------------------------------------------------
//Created: 05 June 2003 By: cnwgd1
//12 Oct 2012	PJS		PAR #30438
//--------------------------------------------------------------
vars
	lvl,
	idx : Integer;
	jobArray : CM_JobArray;
	hadException,
	expand : Boolean;
	thisForm	: SHP_VoyageOperationsForm;
begin
	on Exception do self.handleUiException(exception, hadException);			

	if _voyage = null then
		return;
	endif;
	
	lvl := 3;
	idx := self.lstJobs.findString(1, _voyage.code &amp; ' ' &amp; UnassignedJobs);
	if idx &gt; 0 then
		expand := self.lstJobs.itemExpanded[idx];
		self.lstJobs.clearBelowLevel(idx);
	else		
		idx := lstJobs.addItem(_voyage.code &amp; ' ' &amp; UnassignedJobs);
		lstJobs.itemObject[idx] := _voyage;
		lstJobs.itemLevel[idx] := lvl;
		lstJobs.itemPicture[idx] := self.picJobs.picture;	
	endif;	
		
	create jobArray transient;
	_voyage.getUnassignedVoyageJobs(jobArray);

	if (not jobArray.isEmpty) then
		self.lstJobsSetBelowLevelAllJobs(jobArray, idx, lvl+1,false);
	endif;	

	self.lstJobs.itemExpanded[idx] := expand;
		
epilog
	// 36236 detect 14022 level error and set otherwise-unused showSelectorOnStartup to pass back to notify code
	// thisForm is used to avoid having to make this and all callers 'updating'
	if hadException then
		thisForm := self;	
		thisForm.showSelectorOnStartup := true;
	endif;

	delete jobArray;						
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="lstJobsSetSelectedJobs" id="d7d5a563-4d9c-4162-9a48-37f04c192b61">
        <updating/>
        <source>lstJobsSetSelectedJobs()updating;
//--------------------------------------------------------------
//Created: June 2004 By: cnwgd1
//--------------------------------------------------------------
vars
	job : CM_VoyageJob;
	idx : Integer;
begin

	self.lstJobsChange(self.selectedListObject);
		
	on Exception do self.handleExceptionJob(exception, job);
	
	foreach job in self.allSelectedVoyageJobsArray do
		job.fetchLatest();
		if job = null then
			// job is set to null by the ex handler if it is not found / deleted
			continue;
		endif;		
		idx := self.lstJobs.findObject(job);
		if idx &lt; 1 then
			continue;
		endif;
		self.lstJobs.itemSelected[idx] := true;			
		self.lstJobs.itemExpanded[idx] := true;
		if not self.selectedExpanded then
			self.lstJobs.itemExpanded[idx] := false;
		endif;		
	endforeach;
	
	if self.topObject &lt;&gt; null then
		self.lstJobs.topIndex := self.lstJobs.findObject(self.topObject);
	elseif self.topIndex &gt; 0 then
		self.lstJobs.topIndex := self.topIndex;
	elseif self.selectedListObject &lt;&gt; null then
		self.lstJobs.topIndex := self.lstJobs.findObject(self.selectedListObject);
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="lstJobsSetSelectedObject" id="659597ff-3a60-4623-8cdd-e6c4c94fbc88">
        <updating/>
        <source>lstJobsSetSelectedObject()updating;
//--------------------------------------------------------------
//Created: 03 April 2003 By: cnwgd1
//15 Oct 2012	PJS		Par #30438
//--------------------------------------------------------------
vars
	idx : Integer;
begin
	if (not self.allSelectedVoyageJobsArray.isEmpty) then
		self.lstJobsSetSelectedJobs();
	elseif global.isValidObject(self.selectedListObject) then
		idx := self.lstJobs.findObject(self.selectedListObject);
		if idx &lt; 0 then
			idx := 1;
			self.lstJobs.listIndex := idx;
			self.lstJobs.listObject := lstJobs.itemObject[idx];
		else
			self.lstJobs.listObject := self.selectedListObject;		
		endif;
		self.lstJobs.itemSelected[idx] := true;	
		// unconditionally expand so that the parent items are expanded
		// and then contract if selected item is not expanded
		self.lstJobs.itemExpanded[idx] := true;
		if not self.selectedExpanded then
			self.lstJobs.itemExpanded[idx] := false;
		endif;
		self.lstJobsChange(self.selectedListObject);
		if self.topObject &lt;&gt; null then
			self.lstJobs.topIndex := self.lstJobs.findObject(self.topObject);
		elseif self.topIndex &gt; 0 then
			self.lstJobs.topIndex := self.topIndex;
		else
			self.lstJobs.topIndex := self.lstJobs.findObject(self.selectedListObject);
		endif;
	else
		self.selectedListObject := null;
	//	self.loadListJobsAll();
	//	if self.lstJobs.itemExpanded[1] &lt;&gt; true then
	//		self.lstJobs.expandItem(1);
	//	endif;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="lstJobsUpdateBelowJobSheet" id="3cfbd110-658f-426a-91fb-4daf7b6520f3">
        <updating/>
        <source>lstJobsUpdateBelowJobSheet(_voyageJobSheet : CM_VoyageJobSheet) updating;
//--------------------------------------------------------------
//Created: 26 May 2003 By: cnwgd1
//12 Oct 2012	PJS		PAR #30438
//--------------------------------------------------------------
vars
	jobArray : CM_JobArray;
	lvl,
	idx : Integer;
	tmpJob : CM_Job;
begin
	if _voyageJobSheet = null then
		return;
	endif;
	
	idx := self.lstJobs.findObject(_voyageJobSheet);
	if idx &lt; 1 then
		return;
	endif;
	lvl := self.lstJobs.itemLevel[idx];
	
	create jobArray transient;
	_voyageJobSheet.allJobsByOrder.copy(jobArray);
	
	self.lstJobs.clearBelowLevel(idx);
	
	self.lstJobsSetBelowLevelAllJobs(jobArray, idx, lvl+1,false);
	self.lstJobs.itemExpanded[idx] := true;	
	
	if not self.allSelectedVoyageJobsArray.isEmpty() then
		self.lstJobsSetSelectedJobs();
	endif;

epilog
	delete jobArray;
end;</source>
        <Parameter name="_voyageJobSheet" type="CM_VoyageJobSheet"/>
    </JadeMethod>
    <JadeMethod name="lstJobsUpdateJob" id="4c1fd010-8bc1-43bb-8f8a-11f5673051ec">
        <updating/>
        <source>lstJobsUpdateJob(_job : CM_Job; _mode, _jobIdx, _level : Integer; pExpanded : Boolean)updating;
//--------------------------------------------------------------
//Created: April By: cnwgd1
//--------------------------------------------------------------
vars
	idx			: Integer;
	str			: String;
	wle			: CM_WorkListEntry;
begin

	if _mode = self.Mode_Delete then
		return;
	endif;

	if _jobIdx &lt; 1 then //or _jobIdx &gt;= self.lstTransport.listCount then
		return;
	endif;

	if self.selectedListObject = null then
		self.selectedListObject := _job;
	endif;
	
	idx := _jobIdx;
	str := _job.getTreeDescription();
			
	if _mode = self.Mode_Update then
		self.lstJobs.removeItem(self.lstJobs.findObject(_job));
		if self.lstJobs.listCount &lt; idx then
			idx := self.lstJobs.addItem(str);
		else
			self.lstJobs.addItemAt(str, idx);
		endif;
	elseif _mode = self.Mode_Add then
		//cnwjo3 par 23366
		if self.lstJobs.findObject(_job) &gt; 0 then
			return;	//for some reason we are trying to add an item but it already
					//exists in the table.  abort here
		endif;
		
		if self.lstJobs.listCount &lt; idx then
			idx := self.lstJobs.addItem(str);
		else
			self.lstJobs.addItemAt(str, idx);
		endif;
	endif;
	
	self.lstJobs.itemObject[idx] := _job;
	self.lstJobs.itemLevel[idx] := _level;
	
	// Par 13968
	self.lstJobs.itemData[idx] := _job.status;

	if _job.status = JOB_COMPLETE then
		self.lstJobs.itemPicture[idx] := self.picJobComp.picture;
	elseif _job.status = JOB_PART_COMPLETE then
		self.lstJobs.itemPicture[idx] := self.picJobPartComp.picture;		
	else //Unactioned
		self.lstJobs.itemPicture[idx] := self.picJobWLEs.picture;
	endif;	

	self.lstJobsSetSelectedObject;
		
end;</source>
        <Parameter name="_job" type="CM_Job"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_jobIdx" type="Integer"/>
        <Parameter name="_level" type="Integer"/>
        <Parameter name="pExpanded" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="lstJobsUpdateObj" id="440d8e8e-6b25-456a-b494-b1ccc6e1bb0f">
        <updating/>
        <source>lstJobsUpdateObj(_obj : CM_Object; _event : Integer)updating;
//--------------------------------------------------------------
//Created: 31 January 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	str			: String;
	shtIdx,
	jobIdx,
	idx,
	craneLvl,
	jobLvl		: Integer;
	expanded 	: Boolean;
	selectedObj	: Object;
	voyageJob	: CM_VoyageJob;
	voyage		: CM_Voyage;
	now			: TimeStamp;		
begin
	now := app.actualTimeServer();	// 9/5/16 cnwmp6 TFS 488 - Multi timezone support
	
	self.lstJobsSaveSelected();

	if _event = VoyageJob_Delete_Event then
		idx := self.lstJobs.findObject(_obj);
		if idx &gt; 0 then
			self.lstJobs.clearBelowLevel(idx);
			self.lstJobs.removeItem(idx);
		endif;
		if _obj.String = self.selectedListObject.String then
			self.selectedListObject := null;
			self.lstJobsSetSelectedObject;	
		endif;
		self.tblWLEUpdateJob(_obj, self.Mode_Delete);		
		return;
	endif;
	
	if _obj = null then
		return;
	elseif (not global.isValidObject(_obj)) then
	//	self.tblWLEUpdateJob(_obj, self.Mode_Delete);			
		return;
	endif;
	
	if _event = JobSheet_Update_Event then
		if _obj.isKindOf(CM_VoyageJobSheet) then
			self.lstJobsUpdateBelowJobSheet(_obj.CM_VoyageJobSheet);
		elseif _obj.isKindOf(CM_VoyageJob) then
			idx := self.lstJobs.findObject(_obj);
			if idx &gt; 0 then
				self.lstJobs.clearBelowLevel(idx);
				self.lstJobs.removeItem(idx);
			endif;
			self.lstJobsUpdateBelowJobSheet(_obj.CM_VoyageJob.myVoyageJobSheet);
			self.tblWLEUpdateJob(_obj, self.Mode_Update);
		endif;
		return;		
	endif;	
	
	if CM_VoyageJob.hasInstance(_obj) then
		// PAR 21891
		// The refreshTable variable has been changed from true to false
		// The true was implemented by PAR 14066 to fix a duplicate table entry problem
		// It appears that the initial problem has been fixed 
		//
		//self.updateVoyageJob(_obj.CM_VoyageJob, _event, true);
		self.updateVoyageJob(_obj.CM_VoyageJob, _event, _obj.isKindOf(CM_VoyageHoldJob)); // TFS 3190
		return;
	endif;
	
	if _event = Voyage_Delete_Event then
		self.doRefresh();
		return;
	endif;

	if (not CM_Voyage.hasInstance(_obj)) then
		return;	
	endif;	
	
	voyage := _obj.CM_Voyage;
	
	if voyage.departedDT.isValid and voyage.departedDT &lt; now then
		return;
	endif;
	
	if self.myCurrentVoyage = voyage then
	// PAR 36296 if self.allCurrentVoyages.includes(voyage) then
		self.doRefresh();
	endif;
	
end;</source>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_event" type="Integer"/>
    </JadeMethod>
