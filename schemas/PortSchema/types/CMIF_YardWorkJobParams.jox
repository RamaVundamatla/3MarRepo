<Class name="CMIF_YardWorkJobParams" id="1de59a26-6fa3-4e7c-bb8d-c9877a383cf3">
    <superclass name="CMIF_Object"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="terminal"/>
    <PrimAttribute name="addToQueue" id="0e20331f-3bbf-4e31-ae3e-265d79613fea">
        <embedded/>
        <type name="Boolean"/>
        <text>If set, will automatically add to nominated queue</text>
    </PrimAttribute>
    <ImplicitInverseRef name="allSelectedTIs" id="89d1877d-a1c6-4408-b642-a28add1a2d0b">
        <memberTypeInverse/>
        <type name="CM_TIArray"/>
    </ImplicitInverseRef>
    <PrimAttribute name="defaultQueueToHeld" id="3820f618-4ae6-4879-bb56-7cadfab6e742">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="isBestPick" id="c684a767-1e41-4422-bb1d-f3952248f7e0">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="jobId" id="6b766843-d4b2-455e-9edf-42ca92906260">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <ImplicitInverseRef name="myQueueToAddTo" id="05aadba6-c137-4772-b009-7e5cc7746029">
        <embedded/>
        <type name="CM_RadioTelemetryQueue"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="mySourceLocation" id="90b0b444-86df-410e-a4b8-8ba0a986109d">
        <embedded/>
        <type name="CM_LocationsController"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="mySourceTA" id="5a5f45e7-7e9a-445a-babf-ab61ca083ce9">
        <embedded/>
        <type name="CM_TerminalArea"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="mySubTerminalSource" id="fe6790aa-f6ae-4f8b-951d-7b5dfe2d0827">
        <embedded/>
        <type name="CM_SubTerminal"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myTargetLocation" id="c363c426-29d4-4c12-b628-98d6f43c1305">
        <embedded/>
        <type name="CM_LocationsController"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myTargetTA" id="b696fe99-0034-4e0c-809f-f98bc7e43794">
        <embedded/>
        <type name="CM_TerminalArea"/>
    </ImplicitInverseRef>
    <PrimAttribute name="numToMove" id="4c5ae01a-8bd2-4098-bbbf-a0c55d1acc58">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="overridePlacementRestrictions" id="1e56f8c9-9285-4f97-87cb-acf47336a271">
        <embedded/>
        <type name="Boolean"/>
        <text>If there are restrictions on the target area, setting this flag
will allow the save if they are not compatible.
Call terminal's createYardWorkJob method with this set
OFF 1st, if error is of a restriction type (Labour restrictions will
ALWAYS FAIL), then set this flag if the users want to continue, the system will
create the task, restrictions will be ignored.</text>
    </PrimAttribute>
    <PrimAttribute name="priority" id="1f94f172-6307-4198-8ac9-9080c825637f">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="remarks" id="1d0273f4-d9d0-43ae-8781-3688046f6450">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="requredByDT" id="976a0c21-7b27-4285-b8af-3d8590b56709">
        <embedded/>
        <type name="TimeStamp"/>
    </PrimAttribute>
    <PrimAttribute name="typeToCreate" id="431ac26f-65b1-47cf-8ef6-6ca338a227f9">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <JadeMethod name="validateForCreate" id="67331f4a-c0ad-4839-bb46-2e72c0a7033a">
        <source>validateForCreate();
/*
 ------------------------------------------------------------------------
Created:			22 August 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
begin
	//We dont care about numToMove
	// 23098 allow gridded areas as well as block stacks
	if self.mySourceLocation = null and
	   self.mySourceTA = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "Source Location", null, null);
		app.raiseCMException(Input_required_field_sourLocn, null, null); // cnwdb2	PAR 35364	
		return;
	endif;	
	if self.myTargetLocation = null then
		// CMIF 1309 DVB changed 15/02/2005
//		app.raiseCMException1(REQUIRED_FIELD, "Target Location", null, null);
//		return;
	endif;	
	if self.typeToCreate &lt; Controller_Strip or self.typeToCreate &gt; Plan_On_Pickup then //cnwrd1 par 26734 CCMS 2014 plan on pickup
		app.raiseUnexpectedProgramError(class.name, method.name, 'TypeToCreate invalid');
		return;
	endif;
end;</source>
    </JadeMethod>
</Class>
