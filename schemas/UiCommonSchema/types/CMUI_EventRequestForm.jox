    <JadeMethod name="doSearch" id="4dbfe54f-5d02-4d5f-a463-86b422a7b88e">
        <updating/>
        <source>doSearch()updating;
//--------------------------------------------------
// Created:	13 April 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	if self.myCMIFSearchEventRequest = null then
		create self.myCMIFSearchEventRequest transient;
	else
		self.myCMIFSearchEventRequest.allTransactionTypes.clear();
		self.myCMIFSearchEventRequest.allStopTables.clear();
		self.myCMIFSearchEventRequest.allUpdateFields.clear;
	endif;
	
	self.tblSearch.setObjectFromTable(self.myCMIFSearchEventRequest, CMUI_EventRequestForm::setCMIFSearchEventRequest.name, false);
	
	//self.myCMIFSearchEventRequest.type := app.eventRequestStatusStringToENum(self.eventRequestType);
	self.myCMIFSearchEventRequest.myPassport := app.myPassport;

	self.displayEventRequests();
	
	self.frmSearch.visible := (self.tblData.rows = self.tblData.fixedRows);
	
end;</source>
