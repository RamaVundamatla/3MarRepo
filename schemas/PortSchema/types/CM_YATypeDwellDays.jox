    <JadeMethod name="isCMIFDataMatch" id="f01c866c-9730-4466-aa4b-32ac9acd03b1">
        <source>isCMIFDataMatch(_cmifAutoPlan: CMIF_YAAutoPlan; _yaData: CM_YADataObjects): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 October 2015	cnwmc5	Initial creation

*/

vars

begin
	return _cmifAutoPlan.isDwellDays_Match(_yaData);
epilog

end;</source>
        <Parameter name="_cmifAutoPlan" type="CMIF_YAAutoPlan"/>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
