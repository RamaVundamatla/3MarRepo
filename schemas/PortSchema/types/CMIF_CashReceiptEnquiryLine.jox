    <JadeMethod name="setFromObject" id="c09a01a5-7bad-4518-8a12-631bb308e92d">
        <updating/>
        <source>setFromObject( _cash : CM_Cash ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 Dec 2019	jlgndl1	Initial creation	TFS 47284
09 Sep 2020 cnwma1  Bug 50002: MTN - Cash transaction enquiry shows proforma charges as invoice
// ### JIRA 35803 21AUG2025 NAVAB1 refactored payment and receipt into local vars
*/

vars

	drTerm 		 : CM_DebtorTerminal;
	taxDec ,
	amountDec,
	totalDec 	 : Decimal [23,6];
	creditDetail : CM_CashCreditDetail;
	invLine		 : CM_InvoiceLine;
	proforma     : CM_ProformaDetails;

	cashPay : CM_CashPayment;
	cashRec : CM_CashReceipt;
begin

	self.myCashObject := _cash;
	self.date 		  := _cash.systemToLocalTime( _cash.dateTime ).asStringJMT;
	drTerm 			  := _cash.getDebtorTerminal();
	
	if drTerm &lt;&gt; null then
		self.debtor := drTerm.myDebtor.name;
		self.terminal := drTerm.myTerminal.code;
		self.type := _cash.getTypeString(drTerm).replaceString(Tab, " ");
	endif;
	
	//default values
	self.cargoId   := null;
	self.detail    := null;
	self.narration := null;
	
	if _cash.isReceipt then
		cashRec := _cash.CM_CashReceipt;
		
		//amountDec 		   := cashRec.cashValue;
// ### JIRA 33421 18NOV2024 NAVAB1				amountDec 		   := cashRec.totalCargoCharges; //07/10/2024	navkc1	JIRA 33025 - Include invoice line items to the total
		amountDec 		   := cashRec.totalCargoCharges + cashRec.roundingDifference; // ### JIRA 33421 18NOV2024 NAVAB1
		
		self.bank  		   := cashRec.myBank.code;	
		self.exported 	   := app.getYesBlank( cashRec.exportedCount &lt;&gt; 0 );
		self.myCashReceipt := cashRec;	
		taxDec 			   :=  cashRec.taxValue1 + cashRec.taxValue2 + cashRec.taxValue3;
		
		//06/08/2024	navkc1 CR 64842 Task 64844 starts --&gt;
		self.externalFinancialId := cashRec.externalFinancialId;
		self.externalReceiptNumber := cashRec.externalReceiptNumber;
		self.externalRef1 := cashRec.externalRef1;
		self.externalTransaction := cashRec.externalTransaction;
		self.paymentStatus := app.paymentStatusCashEnumToString(cashRec.paymentStatus);
		self.remarks := cashRec.remarks;
		self.externalInvoiceNumber := cashRec.externalInvoiceNumber;
		//06/08/2024	navkc1 CR 64842 Task 64844 end &lt;--
		
	elseif _cash.isPayment then
		cashPay := _cash.CM_CashPayment;
		
		//08/10/2024	navkc1	CR 33025
		if cashPay.isTaxPaymentForReceipt() then // ### JIRA 33421 18NOV2024 NAVAB1 - changed to use CM_CashPayment.isTaxPaymentForReceipt() instead of CM_CashPayment.isTaxPayment()
			taxDec := cashPay.cashValue;
		else
			amountDec 	:= _cash.cashValue * -1;
		endif;
		
		invLine 	:= cashPay.myInvoiceLine;
		if invLine &lt;&gt; null then
			self.narration := invLine.getLineDescNarration();
			if invLine.trackedItem &lt;&gt; null then
				self.cargoId := invLine.trackedItem.id;
			endif;
			if invLine.manual then
				self.detail := "Extra";
			else
				self.detail := "Invoiced";
			endif;
		endif;
		if cashPay.myProformaDetail &lt;&gt; null then
			self.detail 	:= "Estimation";
			proforma 		:= cashPay.myProformaDetail;
			if proforma.myInvoiceLineType &lt;&gt; null then
				self.narration	:= proforma.myInvoiceLineType.narration;
			endif;
			
			if proforma.myTrackedItem &lt;&gt; null then
				self.cargoId := proforma.myTrackedItem.id;
			endif;
		endif;
		self.myCashReceipt := cashPay.myCashReceipt;
		if self.myCashReceipt &lt;&gt; null then
			self.bank := self.myCashReceipt.myBank.code;
		endif;	
		if cashPay.myCashPaymentForTax &lt;&gt; null then
			taxDec := cashPay.myCashPaymentForTax.cashValue * -1;
		endif;
		// ### JIRA 35803 21AUG2025 NAVAB1
		if app.isSpecial then
			if cashPay.voided then
				self.paymentStatus := app.getErrorString(PaymentStatus_Void);
			elseif cashPay.status = CM_CashPayment.Status_Normal then
				self.paymentStatus := app.getErrorString(PaymentStatus_Normal);
			elseif cashPay.status = CM_CashPayment.Status_NormalOffsite then
				self.paymentStatus := app.getErrorString(PaymentStatus_NormalOffsite);
			endif;
		endif;
	elseif _cash.isCredit then
		foreach creditDetail in _cash.CM_CashCredit.allDerivedFromCreditDetails discreteLock do
			if creditDetail.myCashPayment &lt;&gt; null then
				if creditDetail.myCashPayment.isTaxPayment then
					taxDec := taxDec + creditDetail.cashValue;
				else
					amountDec := amountDec + creditDetail.cashValue;
				endif;
			endif;
		endforeach;
	
		self.bank 		   := _cash.CM_CashCredit.myBank.code;
		self.detail 	   := "Credit";
		self.exported	   := app.getYesBlank( _cash.CM_CashCredit.exportedCount &lt;&gt; 0 );
		self.myCashReceipt := _cash.CM_CashCredit.myDerivedFromCashReceipt;
	
	else
		//Not coded for
	endif;
	
	
	
	if self.myCashReceipt &lt;&gt; null then
		self.receipt := self.myCashReceipt.getExternalInvoiceNumber();
		self.sequenceNumber := self.myCashReceipt.sequenceNum; //06/08/2024	navkc1 CR 64842 Task 64844
	endif;
	
	self.amount := amountDec.asCurrencyJMT;
	self.tax 	:= taxDec.asCurrencyJMT;
	totalDec 	:= amountDec + taxDec;
	self.total  := totalDec.asCurrencyJMT;
	

epilog

end;</source>
        <Parameter name="_cash" type="CM_Cash"/>
    </JadeMethod>
</Class>
