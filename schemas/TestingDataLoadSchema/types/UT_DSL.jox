    <JadeMethod name="moveDirector" id="429f9143-d1fd-45cb-b4b1-0790575af65d">
        <source>moveDirector(	_id: String;
				_totalRequested: Integer;
				_operatorCode: String; 
				_isoTypeCode: String;
				_sourceTA: Any;
				_sourceBays: CM_GridObjectArray;
				_targetTA: CM_TerminalArea
				) : CM_YardDeliveryRequest;
				
/****Changes

Date		Name	TFS#			Description
============================================================================
02/02/2001	cnwdw1					Create a queued director task
03/10/2018	jlgka1	40698			Add "heavyRated" in method call 
									setProxyYardDelivery as a result of changes
									in that method.
3 Nov 2022 	navsks20 ChangeRequest 52721: PNL - Delivery Requests - Assign Cargo to Specified Release Request
============================================================================*/

vars
	proxyJob 		: CM_YardInternalJob;
	proxyRequest 	: CM_YardDeliveryRequest;
	allAvGrades 	: IntegerArray;
	sourceTA		: CM_TerminalArea;
	job 			: CM_Job;
	request 		: CM_YardDeliveryRequest;
	release 		: CM_BulkRelease;
	reserveDetail 	: CM_ReserveDetail;
	heavyRated 		: Boolean; // jlgka1 TFS # 40698
begin

	self.deleteYardJob(_id);
	
	if _sourceTA.isKindOf(CM_TerminalArea) then
		sourceTA := _sourceTA.CM_TerminalArea;
	endif;
	
	if self.opts.includesKey("Release") then
		release := self.opts.obj("Release").CM_BulkRelease;
		heavyRated := release.getHeavyDuty().asBooleanJMT();
	endif;
	if self.opts.includesKey("ReserveDetail") then
		reserveDetail := self.opts.obj("ReserveDetail").CM_ReserveDetail;
		if not heavyRated then
			heavyRated := reserveDetail.getHeavyRated();
		endif;
	endif;
	
	create proxyJob transient;
	proxyJob.setProxyYardDelivery(_id, self.getTerminal);
	proxyJob.setPriority(3);
	create allAvGrades transient;

	create proxyRequest transient;
	proxyRequest.setProxyYardDelivery(	_isoTypeCode,
										_operatorCode,
										"",
										_targetTA.id,
										app.getMyUserCode(),
										false,
										false,
										null,
										proxyJob,
										allAvGrades,
										_totalRequested,
										null,
										null,
										sourceTA,
										null, //source grid object ccms 2098
										null,
										self.getTerminal.getDefaultSubTerminalForRel(BR_TYPE_ROAD),
										release,
										reserveDetail,
										null,
										null,
										heavyRated,
										null,	//3.11.2022	navsks20 TFS 52721
										null);	//3.11.2022	navsks20 TFS 52721
	proxyRequest.setMTCommodity();
	if _sourceTA.isKindOf(CM_TerminalAreaArray) then
		proxyRequest.setNominatedTAs(_sourceTA.CM_TerminalAreaArray, _sourceBays);
	endif;
	
	app.myTrxCA.trxCreateYardInternalDeliveryR(proxyJob, job, proxyRequest, request, true, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	return request;
	
epilog
	delete allAvGrades;
	delete proxyRequest;
	delete proxyJob;
end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_totalRequested" type="Integer"/>
        <Parameter name="_operatorCode" type="String"/>
        <Parameter name="_isoTypeCode" type="String"/>
        <Parameter name="_sourceTA" type="Any"/>
        <Parameter name="_sourceBays" type="CM_GridObjectArray"/>
        <Parameter name="_targetTA" type="CM_TerminalArea"/>
        <ReturnType type="CM_YardDeliveryRequest"/>
    </JadeMethod>
    <JadeMethod name="moveIT" id="2c9c344b-b9f7-4302-95c1-ed34fdd9b725">
        <source>moveIT(_ti : CM_TrackedItem; _mode : Integer);
/*
Purpose:			
Date		Who		Reason
26 March 2014	cnwab1	Initial creation
*/

vars
	wle : CM_WorkListEntry;
	wles : CM_WLEArray;
	warnings : CM_WLEArray;
	fm : CM_FutureMove;
	idx : Integer;
begin

	if _ti = null then
		return;
	endif;

	if _mode = 0 then
		fm := _ti.getFutureMoveOfType(QUEUE_MODE, TI_FutureMoveQueued);
		if fm = null then
			fm := _ti.getFutureMoveOfType(PLANNING_MODE, TI_FutureMovePlanned);
		endif;
	elseif _mode = QUEUE_MODE then
		fm := _ti.getFutureMoveOfType(QUEUE_MODE, TI_FutureMoveQueued);
	elseif _mode = PLANNING_MODE then
			fm := _ti.getFutureMoveOfType(PLANNING_MODE, TI_FutureMovePlanned);
	endif;
	
	self.assertTrueMsg(fm &lt;&gt; null, "FM is null.");

	wle := fm.myWorkListEntry;
	self.assertTrueMsg(wle &lt;&gt; null, "WLE is null.");
	
	create wles transient;
	create warnings transient;
	wles.add(wle);
	
	
	while true do
		app.myPassport.setWarningsIgnored(true);
		app.myPassport.setWarningsAcknowledged(true);
		app.myTrxUA.trxUpdateWLEsDoMove(wles, warnings, REAL_MODE, true,  null, app.myPassport);
		
		idx := idx + 1;
		if warnings.isEmpty()
		or idx &gt; 5 then
			break;
		endif;
	endwhile;
epilog
	delete warnings;
	delete wles;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="moveOffsite" id="3b130619-2d7d-4638-8f08-3913c7c1d090">
        <source>moveOffsite(_ti: CM_TrackedItem);
//02 September 2008	cnwdw1	
// 02/08/2011	cnwmh5	Change so isForced can be passed via opts, change to use assertNoTrxErrorsOrWarnings
vars
	moveController	: CMIF_MoveController;
begin
	create moveController transient;
	moveController.setMyTrackedItem(_ti);
	moveController.setMyToPrimaryLocation(null);
	moveController.setMoveMode(REAL_MODE);
	if self.opts.includesKey("IsForcedMove") then					// 02/08/2011 cnwmh5
		moveController.isForcedMove := self.opts.bool("IsForcedMove");
	endif;
		
	app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();								// 02/08/2011 cnwmh5
	
epilog
	delete moveController;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="moveOpsviewCargo" id="16967916-fbb0-4290-9157-adb41c99cc0e">
        <source>moveOpsviewCargo(_voyage: CM_Voyage);

vars
	ya : CM_YardAllocation;
	bs : CM_TerminalArea;
	jobSheet : CM_JobSheet;
	job:CM_Job;
	req : CM_Request;
	wle : CM_WorkListEntry;
	location : CM_LocationsController;
	wlesToMove, wlesWithWarnings : CM_WLEArray;
	completedDate : TimeStamp;
	sleep: Integer;
	doWPOpHrs : Integer;	// create CM_WorkPointHrs every 'n' jobs.
	jobCount : Integer;
	forklift	: CM_Machine;
	queueEntry	: CM_RTQueueEntry;
	crnQueue	: CM_RadioTelemetryQueue;
	terminalArea	: CM_TerminalArea;
begin
	create wlesToMove transient;
	create wlesWithWarnings transient;
	
	sleep := self.opts.int("Sleep");
	doWPOpHrs := self.opts.int("WPOpHrs");
	
	forklift := self.getMachine("FK1");
	
	terminalArea := self.getTerminalArea("OVBS1");
	beginTransaction;
	forklift.addTAMaster(terminalArea);
	commitTransaction;
	
	terminalArea := self.getTerminalArea("COV11");
	beginTransaction;
	forklift.addTAMaster(terminalArea);
	commitTransaction;
	
	terminalArea := self.getTerminalArea("COV21");
	beginTransaction;
	forklift.addTAMaster(terminalArea);
	commitTransaction;
	
	foreach job in _voyage.allVoyageJobs  discreteLock do
		if job.CM_VoyageJob.isHatchLidJob() then
			continue;
		endif;
		
		if job.CM_VoyageJob.status = JOB_COMPLETE then					// 14/05/2013 cnwmh5
			continue;
		endif;
		
		
		self.moveCargoForVoyageJobExtra(job);
	endforeach;
	
	crnQueue := self.getQueue(UT_KPIVoyage.VoyageId);
	self.assertNotNull(crnQueue);
	beginTransaction;
	crnQueue.allSubQueuesById[UT_KPIVoyage.VoyageId &amp; " COV1"].setPropertyValue("loadMachinesMode", CM_VoyageCraneQueue.ActAsShipLander);
	crnQueue.allSubQueuesById[UT_KPIVoyage.VoyageId &amp; " COV1"].setPropertyValue("dischargeMachinesMode", CM_VoyageCraneQueue.ActAsShipLander);
	crnQueue.allSubQueuesById[UT_KPIVoyage.VoyageId &amp; " COV2"].setPropertyValue("loadMachinesMode", CM_VoyageCraneQueue.ActAsShipLander);
	crnQueue.allSubQueuesById[UT_KPIVoyage.VoyageId &amp; " COV2"].setPropertyValue("dischargeMachinesMode", CM_VoyageCraneQueue.ActAsShipLander);
	forklift.addToQueue(crnQueue, false, 0);
	commitTransaction;
		
		//self.moveCargoForVoyageJob(job, _mode);
	
	self.machineLogon(forklift);
	foreach job in _voyage.allVoyageJobs  discreteLock do
		if job.CM_VoyageJob.isHatchLidJob() then
			continue;
		endif;
		
		if job.CM_VoyageJob.status = JOB_COMPLETE then					// 14/05/2013 cnwmh5
			continue;
		endif;
		if job.CM_VoyageJob.jobType = 2 then
			self.moveCargoForVoyageJob(job, REAL_MODE);
			continue;
		endif;
	foreach wle in job.workListEntries discreteLock do
		
		if wle.allRTQueueEntries.size() = 0 then
			continue;
		endif;
		queueEntry := wle.allRTQueueEntries[1];
		self.machineAcceptSpecifiedTask(forklift, queueEntry);
		
		app.myPassport.setWarningsIgnored(true);
		app.myPassport.setWarningsAcknowledged(true);
		app.myTrxUA.trxMachinePickupTask(forklift,null,null,app.myPassport);

		
		app.myPassport.setWarningsIgnored(true);
		app.myPassport.setWarningsAcknowledged(true);
		self.machineSetdown(forklift, wle.myTrackedItem, forklift.currentQueueTask.targetLocationId);
		
	endforeach;
	
		
		if doWPOpHrs &lt;&gt; 0 then
			jobCount := jobCount + 1;
			if jobCount mod doWPOpHrs = 0 then
				self.addWPOpHrs( _voyage, job.CM_VoyageJob, 50000 );
			endif;
		endif;
		
		if sleep &lt;&gt; 0 then
			process.sleep(sleep);
		endif;
	endforeach;
	self.machineLogOff(forklift);

epilog
	delete wlesToMove;
	delete wlesWithWarnings;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="movePlanned" id="133d4ab8-1c80-470a-a6ce-81f8b51befa2">
