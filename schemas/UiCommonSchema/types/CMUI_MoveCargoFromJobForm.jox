    <JadeMethod name="translateForm" id="31defce6-cb04-4d36-9de5-c0684ad836ff">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0017434, locale);
	lblInstructions.translateCaption(Xlat_0016089, locale);
	lblJob.translateCaption(Xlat_0016090, locale);
	lblSelectCrane.translateCaption(Xlat_0016091, locale);
	mnuCargoEdit.translateCaption(Xlat_0016092, locale);
	mnuCargoEnquiry.translateCaption(Xlat_0016093, locale);
	mnuColumnOrganiser.translateCaption(Xlat_0016094, locale);
	mnuContextMenu.translateCaption(Xlat_0016095, locale);
	mnuInspectObject.translateCaption(Xlat_0016096, locale);
end;</source>
    </JadeMethod>
</GUIClass>
