    <JadeMethod name="alwaysDisplayRTQueueEntry" id="04e15dd0-9549-41b0-8ad7-fed8c239f3f6">
        <source>alwaysDisplayRTQueueEntry(_rtQueueEntry : CM_RTQueueEntry) : Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 Apr 2010	cnwer1	Initial creation
23 May 2012 cnwer1	PAR 29625 - Error 4
*/

vars
	rtQTask , workingTask: CM_RTQueueTask;
	sourceLC	: CM_LocationsController;
	rtQueueEntry : CM_RTQueueEntry;
	invalidObj	: Boolean;
begin

	on Exception do app.handleDeletedObject(exception,rtQueueEntry,invalidObj);
	rtQueueEntry:=_rtQueueEntry;
	rtQTask:=rtQueueEntry.getFirstUncompletedTask;
	if invalidObj then
		return false;
	endif;
	if rtQTask = null then
		return false;
	endif;
	
	if rtQTask.status = TASK_WORKING then
		if	rtQTask.machine = self.myMachine then
			return true;
		else
			return false;
		endif;
	endif;
	
	if rtQTask = null then
		return false;
	endif;
	
	if	(rtQTask.intendedMachine &lt;&gt; null and 
			rtQTask.intendedMachine = self.myMachine) then
		return true;
	endif;
	
	sourceLC:=rtQTask.getSourceLocation();
	if  sourceLC &lt;&gt; null and 
		sourceLC.isKindOf(CM_MachineController)  then //or rtQTask.sourceLocation.isKindOf(CM_VehicleController)
		return true;
	endif;
	
	return false;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rtQueueEntry" type="CM_RTQueueEntry"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkMaxDisplayedQueueEntries" id="c9812159-3997-4b67-bc9e-2bd181f82434">
        <updating/>
        <source>checkMaxDisplayedQueueEntries() : Integer protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 Apr 2010	cnwer1	Initial creation
14 OCt 2011 cnwer1 	PAR 28458 
*/

vars
	lastQIndex,
	startOffset,
	row,origRTQueueSize	: Integer;
	startQEntry	,
	rtQueueEntry : CM_RTQueueEntry;
	dtoQueueEntry : DTO_RTQueueEntry;
	dtoQueueAndEntries : DTO_QueueAndRTEntries;
	queue 		 : CM_RadioTelemetryQueue;
	mach		: CM_Machine;
	
begin
	
	if self.maxDisplayEntries= 0 then
		return 0;
	endif;
	
	dtoQueueAndEntries:=self.allOrderedQueueAndEntries[self.myMachine.myPrimaryQueue];
	
	if self.myMachine.myPrimaryQueue = null then
		return 0;
	endif;
	if dtoQueueAndEntries = null then
		create dtoQueueAndEntries transient;
		dtoQueueAndEntries.setMyQueue(self.myMachine.myPrimaryQueue);
		self.allOrderedQueueAndEntries.add(dtoQueueAndEntries);
	endif;
	
	mach:=self.myMachine;
	
	origRTQueueSize:=self.getNumberOfEntries;  // +  numRemovedAndUpdated;
	if origRTQueueSize &lt;  maxDisplayEntries then
		
		lastQIndex:=1;
	
		if dtoQueueAndEntries.allDTORTQueueEntries.size &gt; 0 then
			lastQIndex:=self.myMachine.myPrimaryQueue.allEntries.indexOf(dtoQueueAndEntries.allDTORTQueueEntries.last.myRealQueueEntry.CM_RTQueueEntry);
			if lastQIndex &gt; 0  then
				lastQIndex:=lastQIndex + 1;
			else
				lastQIndex:=1;
			endif;
		endif;
		// can't just return will need to check any queues after this one in the machines primary queues
		if self.myMachine.myPrimaryQueue.allEntries.size &gt;= lastQIndex then
			startQEntry:=self.myMachine.myPrimaryQueue.allEntries[lastQIndex];
			self.loadQueueEntries(self.myMachine.myPrimaryQueue,0,startQEntry);
			
			if self.getNumberOfEntries = maxDisplayEntries or not self.showSecondaryQueues then
				return origRTQueueSize;
			endif;
		endif;
		
		if self.getNumberOfEntries &lt; maxDisplayEntries and self.showSecondaryQueues then
			//have to check secondary queues
			startOffset:=dtoQueueAndEntries.allDTORTQueueEntries.size;
			foreach queue in mach.allQueues do
				if queue = self.myMachine.myPrimaryQueue then
					continue;
				endif;
				lastQIndex:=1;
				dtoQueueAndEntries:=self.allOrderedQueueAndEntries[queue];
				
				//epr PAR 28458 14/10/11
				if dtoQueueAndEntries = null then
					continue;
				endif;
				if dtoQueueAndEntries.allDTORTQueueEntries.size &gt; 0 then
					lastQIndex:=queue.allEntries.indexOf(dtoQueueAndEntries.allDTORTQueueEntries.last.myRealQueueEntry.CM_RTQueueEntry);
					//epr PAR 28458 14/10/11
					if lastQIndex = 0 then
						lastQIndex:=1;
					endif;
				endif;
				if queue.allEntries.size &gt;= lastQIndex then
					startQEntry:=queue.allEntries[lastQIndex];
					self.loadQueueEntries(queue,startOffset,startQEntry);
				endif;
				
				if self.getNumberOfEntries = maxDisplayEntries then
					return origRTQueueSize;
				endif;
				startOffset:=startOffset + dtoQueueAndEntries.allDTORTQueueEntries.size;
			endforeach;
				
			return origRTQueueSize;	
		endif;
		
	elseif origRTQueueSize  &gt; self.maxDisplayEntries then
		//delete from end
		row:=origRTQueueSize;
		while row &gt; self.maxDisplayEntries do
			
			dtoQueueEntry:=self.getDTOEntryAtPosition(row,dtoQueueAndEntries);
			if dtoQueueEntry = null then
				continue;
			endif;
			//dtoQueueEntry:=dtoQueueAndEntries.allDTORTQueueEntries[row];
			rtQueueEntry:=dtoQueueEntry.myRealQueueEntry.CM_RTQueueEntry;
			if not self.alwaysDisplayRTQueueEntry(rtQueueEntry) then
				dtoQueueAndEntries.allDTORTQueueEntries.remove(dtoQueueEntry);// removeAt(row);
				
				if self.allNewDTOEntries.includes(dtoQueueEntry) then
					self.allNewDTOEntries.remove(dtoQueueEntry);
				endif;
				//17 Jan 2014	NDL	Par 33022
			//	if dtoQueueEntry.oldRow &lt;&gt; 0 then
			//		self.allRowsToRemove[dtoQueueEntry.oldRow -1 ]:=dtoQueueEntry.oldRow -1 ;
			//	else
					self.allRowsToRemove[row]:=row;
			//	endif;
		
				delete dtoQueueEntry;
			endif;
			row:=row - 1;
		endwhile;
	
	endif;

	return 0;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="createDTO_RTQueueEntry" id="d03ea93a-1368-4967-b073-269766f605b5">
        <source>createDTO_RTQueueEntry(_rtEntry: CM_RTQueueEntry): DTO_RTQueueEntry protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 April 2010	cnwer1	Initial creation

*/

vars
	
	dto_RTQueueEntry : DTO_RTQueueEntry;
	
begin
	create dto_RTQueueEntry transient;
	dto_RTQueueEntry.setFromPersistent(_rtEntry);
	//epr TFS 37584 7/5/18
	dto_RTQueueEntry.setOverstowForMachine(self.myMachine);
	return dto_RTQueueEntry;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rtEntry" type="CM_RTQueueEntry"/>
        <ReturnType type="DTO_RTQueueEntry"/>
    </JadeMethod>
    <JadeMethod name="delete" id="5a97c99f-850b-4137-a46e-6703860b9bb2">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 August 2010	cnwer1	Initial creation

*/

vars

begin
	self.purgeEntries();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doFindDTOEntryByEntry" id="3b42143f-17f6-48bc-8f60-80b7a4e0b7fa">
        <source>doFindDTOEntryByEntry(_rtQueueEntry : CM_RTQueueEntry) : DTO_RTQueueEntry;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 August 2010	cnwer1	Initial creation

*/

vars
	dtoQueueEntries : DTO_QueueAndRTEntries;	
	dtoEntry	    : DTO_RTQueueEntry;
begin

	foreach dtoQueueEntries in self.allOrderedQueueAndEntries do
		dtoEntry:=self.findDTOEntryByQueueAndEntry(dtoQueueEntries,_rtQueueEntry);
		if dtoEntry &lt;&gt; null then
			return dtoEntry;
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_rtQueueEntry" type="CM_RTQueueEntry"/>
        <ReturnType type="DTO_RTQueueEntry"/>
    </JadeMethod>
    <JadeMethod name="doFindWorkingDTOEntries" id="c1a119a4-90f6-49b7-8637-4416b2dbe516">
        <updating/>
        <source>doFindWorkingDTOEntries(_dtoRTQueueEntryArray : DTO_RTQueueEntryArray input;
						_isOnlyWorkingTasks : Boolean;
						_table : Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 Aug 2010	cnwer1	Initial creation
07 Dec 2010 cnwer1	PAR 26511 
*/

vars
	mach : CM_Machine;
	allDTOEntries 	: DTO_RTQueueEntryByEntry;
	dtoRTQueueEntry : DTO_RTQueueEntry;
	rtQueueEntry 	: CM_RTQueueEntry;
	rtQueueTask 	: CM_RTQueueTask;
	invalidEntry,
	invalidTask 	: Boolean;
	dtoQueueEntries : DTO_QueueAndRTEntries;
	sortedTasks		: DynaDictionary;
	iter			: Iterator;
	localArray		: CM_RTQueueTaskArray; //03 May 2019	NDL	TFS 44600 - 1308 UHE, update during iteration error
begin
	mach := self.myMachine;
	if _isOnlyWorkingTasks and not mach.hasWorkingTasks then
		return; 
	endif;

	
	create allDTOEntries transient;
	foreach dtoQueueEntries in self.allOrderedQueueAndEntries do
		//epr par 32975 2/12/13
		foreach dtoRTQueueEntry in dtoQueueEntries.allDTORTQueueEntries do
			if  allDTOEntries[dtoRTQueueEntry.myRealQueueEntry] = null then
				allDTOEntries.add(dtoRTQueueEntry);
			endif;
		endforeach;
		//dtoQueueEntries.allDTORTQueueEntries.copy(allDTOEntries);
	endforeach;
	
	if mach.isMultiLift then
		create sortedTasks transient;
		sortedTasks.setMembership(CM_RTQueueTask);
		sortedTasks.addMemberKey(CM_RTQueueTask::tiId.name,false,false);
		sortedTasks.endKeys(true);
		mach.allCurrentQueueTasks.copy(sortedTasks);
		iter:=sortedTasks.createIterator;
	else
	//	iter:=mach.allCurrentQueueTasks.createIterator;
		//03 May 2019	NDL	TFS 44600
		create localArray transient;
		mach.allCurrentQueueTasks.copy(localArray);
		iter:=localArray.createIterator;
	endif;
	
	dtoRTQueueEntry:=null;
	
	on Exception do app.handleDeletedObject(exception, rtQueueTask, invalidTask);
	on Exception do app.handleDeletedObject(exception, rtQueueEntry, invalidEntry);		// PAR #24763
	
	while iter.next(rtQueueTask) do
		invalidTask := false;		// PAR #24763
		invalidEntry := false;
		
		if _isOnlyWorkingTasks and not rtQueueTask.isWorkingOrAccepted then
			continue;
		endif;
		
		rtQueueEntry := rtQueueTask.myEntry;
		if invalidTask then
			continue;
		endif;

		dtoRTQueueEntry := allDTOEntries.getAtKey(rtQueueEntry);

		if dtoRTQueueEntry = null then
			dtoRTQueueEntry := self.createDTO_RTQueueEntry(rtQueueEntry);
			//epr 7/11/10 par 25611 if an imv is just assigned we need this added 
			dtoQueueEntries:=self.allOrderedQueueAndEntries[rtQueueEntry.myQueue];
			if dtoQueueEntries = null then
				create dtoQueueEntries transient;
				dtoQueueEntries.setMyQueue(rtQueueEntry.myQueue);
				self.allOrderedQueueAndEntries.add(dtoQueueEntries);
			endif;
			
			dtoQueueEntries.allDTORTQueueEntries.add(dtoRTQueueEntry);
			
		endif;
		
		if dtoRTQueueEntry &lt;&gt; null then
			dtoRTQueueEntry.setFromPersistent(dtoRTQueueEntry.myRealQueueEntry.CM_RTQueueEntry);
			//epr TFS 37584 7/5/18
			dtoRTQueueEntry.setOverstowForMachine(self.myMachine);
			self.allNewDTOEntries.add(dtoRTQueueEntry);
		endif;
		
		
		if dtoRTQueueEntry &lt;&gt; null and not _dtoRTQueueEntryArray.includes(dtoRTQueueEntry) then
			_dtoRTQueueEntryArray.add(dtoRTQueueEntry);		
		endif;
	endwhile;
	
	if _table = null then
		return;
	endif;
	self.loadNewDTOEntriesToTable(_table,self.allNewDTOEntries,true);
	self.showingFilteredResults:=false;
epilog
	delete allDTOEntries;
	delete iter;
	delete sortedTasks;
	delete localArray;	//03 May 2019	NDL	TFS 44600
end;</source>
        <Parameter name="_dtoRTQueueEntryArray" type="DTO_RTQueueEntryArray" usage="input"/>
        <Parameter name="_isOnlyWorkingTasks" type="Boolean"/>
        <Parameter name="_table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doLoadAllQueueEntries" id="576de3a4-e958-4809-9d64-dc38d451cd5c">
        <updating/>
        <source>doLoadAllQueueEntries( _table : Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 August 2010	cnwer1	Initial creation

*/

vars
	startOrder : Integer;
	queue 		: CM_RadioTelemetryQueue;
	dtoQueueAndEntries : DTO_QueueAndRTEntries;
begin

	dtoQueueAndEntries:=self.loadQueueEntries(self.myMachine.myPrimaryQueue,0,null);
	
	
	dtoQueueAndEntries.loadToTable(self.myMachine, _table,self.myEntTableView,self.headerIsTopRow,0);
//process.debug;	
	startOrder:= dtoQueueAndEntries.allDTORTQueueEntries.size;
	if self.showSecondaryQueues then
		foreach queue in self.myMachine.allQueues do
			if queue = self.myMachine.myPrimaryQueue then
				continue;
			endif;
		
			dtoQueueAndEntries:=self.loadQueueEntries(queue,startOrder,null);
			dtoQueueAndEntries.loadToTable(self.myMachine, _table,self.myEntTableView,self.headerIsTopRow,startOrder);
			startOrder:=startOrder + dtoQueueAndEntries.allDTORTQueueEntries.size;
			
		endforeach;
	endif;
	
	_table.resort;
	self.showingFilteredResults:=false;
epilog
	
end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doLoadFromRTQueueEntries" id="f9aa630b-a973-4add-9178-47baabab3f02">
        <updating/>
        <source>doLoadFromRTQueueEntries(_table: Table input; _allRTQueueEntries : CM_RTQueueEntryArray) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 August 2010	cnwer1	Initial creation

*/

vars
	rtQueue		 : CM_RadioTelemetryQueue;
	rtQueueEntry : CM_RTQueueEntry;
	invalidObject : Boolean;
	dtoRTQueueEntry : DTO_RTQueueEntry;
	iter			: Iterator;
	objectEdition	: Integer;
begin
	
	on Exception do app.handleDeletedObject(exception,rtQueueEntry,invalidObject);
	
	iter:=_allRTQueueEntries.createIterator;
	while iter.next(rtQueueEntry) do
		invalidObject:=false;
		objectEdition:=rtQueueEntry.edition;
		if invalidObject then
			continue;
		endif; 
		
		dtoRTQueueEntry := null;
		dtoRTQueueEntry:=self.createDTO_RTQueueEntry(rtQueueEntry);
		// PAR #24763 - it's possible for null to be returned when the entry 
		// is deleted out from under us, so handle this
		if dtoRTQueueEntry &lt;&gt; null then
			self.allNewDTOEntries.add(dtoRTQueueEntry);
		endif;
		
	endwhile;	
		
	self.loadNewDTOEntriesToTable(_table,self.allNewDTOEntries,false);
	self.showingFilteredResults:=true;
epilog
	delete iter;

end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_allRTQueueEntries" type="CM_RTQueueEntryArray"/>
    </JadeMethod>
    <JadeMethod name="doRefreshQueueEntries" id="57dc9b72-92c8-4e73-b847-eea33d3d6729">
        <updating/>
        <source>doRefreshQueueEntries(_table : Table input;
						  _allRTQueueEntries : CM_RTQueueEntryArray ) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 August 2010	cnwer1	Initial creation

*/

vars
	newInsert,
	numOfEntries,
	row,
	removeRow,
	checkRowsFrom : Integer;
	rtQueueEntry : CM_RTQueueEntry;
begin


	
	numOfEntries:=self.getNumberOfEntries();
	
	if not (_table.rows - _table.fixedRows) = numOfEntries  then
		// epr par 26048 14/10/10
		if self.headerIsTopRow then
			_table.rows:=1;
		else
			_table.columns:=1;
		endif;
		self.doLoadAllQueueEntries(_table);
		return;
	endif;
	
	self.getAllRowsToRemove(_allRTQueueEntries);
	
	foreach rtQueueEntry in _allRTQueueEntries do
		newInsert:=self.refreshQueueEntry(rtQueueEntry);
		if newInsert &gt; 0 then
			if checkRowsFrom = 0 then
				checkRowsFrom:=newInsert;
			else
				checkRowsFrom:=checkRowsFrom.min(newInsert);
			endif;
		endif;
	endforeach;
	
	
	// don't have enough entries check if there are more to get because
	newInsert:=self.checkMaxDisplayedQueueEntries();
	if newInsert &gt; 0 then
		checkRowsFrom:=checkRowsFrom.min(newInsert);
	endif;
	
	if self.allNewDTOEntries.size = 0 and self.allRowsToRemove.size = 0 then
		return;
	endif;

	foreach row in self.allRowsToRemove reversed do
		if row = 0 then
			continue;
		endif;
		removeRow:=_table.fixedRows + row;
		if removeRow &lt;= _table.rows and
			removeRow &gt; _table.fixedRows then
			_table.removeItem(removeRow);
		endif;
		
	endforeach;
	
	self.loadNewDTOEntriesToTable(_table,self.allNewDTOEntries,true);
		
	if checkRowsFrom = 0 then
		return;
	endif;
	
	self.doUpdateTableWithRTOrder(checkRowsFrom,_table);
	
	self.showingFilteredResults:=false;
epilog
	_table.resort;
end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_allRTQueueEntries" type="CM_RTQueueEntryArray"/>
    </JadeMethod>
    <JadeMethod name="doReloadAllQueueEntries" id="8a4c8ee4-35db-464b-b136-7ba8f4224574">
        <updating/>
        <source>doReloadAllQueueEntries(_table : Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 August 2010	cnwer1	Initial creation

*/

vars
	
	dtoQueueAndEntry : DTO_QueueAndRTEntries;
	sortedQueueEntries : DynaDictionary;
	iter			 : Iterator;
	isPrimary		: Boolean;
	index			: Integer;
	mach			: CM_Machine;
begin
	
	
	mach:=self.myMachine;
	
	create sortedQueueEntries transient;
	self.getSortedQueueAndEntries(sortedQueueEntries);
	iter:=sortedQueueEntries.createIterator;
	while iter.next(dtoQueueAndEntry) do
		iter.getCurrentKeys(isPrimary,index);
		
		if not isPrimary and not mach.allQueues.includes(dtoQueueAndEntry.myQueue) then
			dtoQueueAndEntry.allDTORTQueueEntries.purge;
			continue;
		endif;
		
		self.loadNewDTOEntriesToTable(_table,dtoQueueAndEntry.allDTORTQueueEntries,true);
	endwhile;
	
	self.checkMaxDisplayedQueueEntries();
	self.showingFilteredResults:=false;
epilog
	delete sortedQueueEntries;
	delete iter;
end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doSetAllocatedTasks" id="c40139c3-5a63-4df0-89f1-f605a9d1f76b">
        <updating/>
        <source>doSetAllocatedTasks(_table : Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 August 2010	cnwer1	Initial creation

*/

vars
	row,
	numberOfRows : Integer;
	tableRow : JadeTableRow;
	dtoRTQueueEntry : DTO_RTQueueEntry;
begin
	self.showingAllocatedTask:=self.myMachine.hasAllocatedQueueTasks();
	//numberOfRows:=self.getNumberOfEntries+_table.fixedRows;
	
	row:=2;
	while row &lt;= _table.rows do
		tableRow:=_table.accessRow(row);
		dtoRTQueueEntry:=tableRow.itemObject.DTO_RTQueueEntry;
		row:=row + 1;	//04 Apr 2014	NDL	Par 33852
		if dtoRTQueueEntry = null then
			continue;
		endif;
		if self.showingAllocatedTask then
			tableRow.visible:=self.myMachine.isQueueEntryAllocated( dtoRTQueueEntry.myRealQueueEntry.CM_RTQueueEntry);
		else
			tableRow.visible:=true;
		endif;
	endwhile;
	
epilog

end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doUpdateTableWithRTOrder" id="08bc2ffa-8cf4-4d23-89b1-688474372db1">
        <updating/>
        <source>doUpdateTableWithRTOrder(_checkRowsFrom : Integer;
						_table : Table input) updating;

vars
	pos,
	rowNo: Integer;
	dtoRTQueueEntry : DTO_RTQueueEntry;
	cell 	: JadeTableCell;
	numOfEntries 	: Integer;
	sortColumn : Integer;
	dtoQueueAndEntry :	DTO_QueueAndRTEntries;
begin

	numOfEntries:=self.getNumberOfEntries;
	if self.myEntTableView &lt;&gt; null then
		sortColumn:= self.myEntTableView.allEntTableRows.size  + 1;
	else
		sortColumn:=_table.columns;
	endif;
	
	foreach pos in _checkRowsFrom to numOfEntries do
		
		
		dtoRTQueueEntry:=self.getDTOEntryAtPosition(pos,dtoQueueAndEntry);
		
		if dtoRTQueueEntry = null then
			continue;
		endif;
		
		rowNo:=pos + _table.fixedRows; 
		if  (rowNo &gt;_table.rows or rowNo &lt; 1) or  (_table.accessRow(rowNo).itemObject &lt;&gt; dtoRTQueueEntry) then
			rowNo:=_table.cnEcFindObjectRowNo(dtoRTQueueEntry);
		endif;
	
		
		if rowNo = 0 then
			continue;
		endif;
		if sortColumn &lt;&gt; null then
			cell:=_table.accessCell(rowNo,sortColumn);
			if cell.text.Integer &lt;&gt; pos then
				cell.text:=pos.String;
			endif;
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="_checkRowsFrom" type="Integer"/>
        <Parameter name="_table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="findDTOEntryByQueueAndEntry" id="c4d77f4e-47b7-46ae-abed-937837e4c12d">
        <source>findDTOEntryByQueueAndEntry(	_queueAndEntries : DTO_QueueAndRTEntries ;
							_rtQueueEntry : CM_RTQueueEntry) : DTO_RTQueueEntry protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21/04/2010	cnwer1	Initial creation
13/12/2013	cnwdap1	PAR #33191 Avoid 1310 errors on array-to-dictionary copy
*/
vars
	dtoEntriesByRTQEntryDict : DTO_RTQueueEntryByEntry;
	dtoEntry				 : DTO_RTQueueEntry;									// PAR #33191
begin
	if _rtQueueEntry = null then
		return null;
	endif;
	create dtoEntriesByRTQEntryDict transient;
	//_queueAndEntries.allDTORTQueueEntries.copy(dtoEntriesByRTQEntryDict);			// PAR #33191
	foreach dtoEntry in _queueAndEntries.allDTORTQueueEntries do					// PAR #33191
		//epr par 36288 22/6/15
		if dtoEntry = null then
			continue;
		endif;
		dtoEntriesByRTQEntryDict.addNoDuplicates(dtoEntry, false);					// PAR #33191
	endforeach;																		// PAR #33191
	
	return dtoEntriesByRTQEntryDict[_rtQueueEntry];
epilog
	delete dtoEntriesByRTQEntryDict;

end;</source>
        <access>protected</access>
        <Parameter name="_queueAndEntries" type="DTO_QueueAndRTEntries"/>
        <Parameter name="_rtQueueEntry" type="CM_RTQueueEntry"/>
        <ReturnType type="DTO_RTQueueEntry"/>
    </JadeMethod>
    <JadeMethod name="findQueueByQEntry" id="741530ab-c0c4-4f36-9c62-c5f1f609ee8f">
        <source>findQueueByQEntry(_rtQueueEntry : CM_RTQueueEntry ) : CM_RadioTelemetryQueue protected;
/*

Purpose:	expecting 	_rtQueueEntry to be invalid lets see what queue it was in	

Parameters:			

Return Value:		


Date		Who		Reason
27 August 2010	cnwer1	Initial creation

*/

vars
	dtoQueue : DTO_QueueAndRTEntries;
	dtoEntry : DTO_RTQueueEntry;
begin

	foreach dtoQueue in self.allOrderedQueueAndEntries do
		foreach dtoEntry in dtoQueue.allDTORTQueueEntries do
			if dtoEntry.myRealQueueEntry = _rtQueueEntry then
				return dtoQueue.myQueue;
			endif;
		endforeach;
	endforeach;
	
	return null;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rtQueueEntry" type="CM_RTQueueEntry"/>
        <ReturnType type="CM_RadioTelemetryQueue"/>
    </JadeMethod>
    <JadeMethod name="getAllRowsToRemove" id="8aeca498-8a59-43a7-a7eb-a35c7a9ae403">
        <source>getAllRowsToRemove( _allRTQueueEntries : CM_RTQueueEntryArray) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 February 2011	cnwer1	Initial creation

*/

vars
	dtoQueueAndEntries : DTO_QueueAndRTEntries;
	dtoRTQueueEntry : DTO_RTQueueEntry;
	rtQueueEntry : CM_RTQueueEntry;
	removeRow : Integer;
begin
	foreach rtQueueEntry in _allRTQueueEntries do
		removeRow:=1;
		//epr PAR 28458 14/10/11
		dtoRTQueueEntry:=null;
		self.getDTOEntryAndRow(rtQueueEntry,dtoRTQueueEntry,dtoQueueAndEntries,removeRow);	
		if dtoRTQueueEntry &lt;&gt; null then
			self.allRowsToRemove[removeRow]:=removeRow;
		endif;
	endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_allRTQueueEntries" type="CM_RTQueueEntryArray"/>
    </JadeMethod>
    <JadeMethod name="getDTOEntryAndRow" id="5226666a-e1d7-4385-a0e5-9a6cd0c814ba">
        <source>getDTOEntryAndRow(_rtQueueEntry : CM_RTQueueEntry;
					_dtoRTQueueEntry :DTO_RTQueueEntry io;
					_dtoQueueAndEntries : DTO_QueueAndRTEntries io;
					_row : Integer io) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 February 2011	cnwer1	Initial creation par 26860

*/

vars
	queue : CM_RadioTelemetryQueue;
	
begin
	_row:=1;
	self.getDTOEntryForQueue(self.myMachine.myPrimaryQueue,_rtQueueEntry,_dtoRTQueueEntry,_dtoQueueAndEntries,_row);
	
	if self.showSecondaryQueues and  _dtoRTQueueEntry = null  then
		foreach queue in self.myMachine.allQueues do
			if queue = self.myMachine.myPrimaryQueue then
				continue;
			endif;
			self.getDTOEntryForQueue(queue,_rtQueueEntry,_dtoRTQueueEntry,_dtoQueueAndEntries,_row);
			if _dtoRTQueueEntry &lt;&gt; null then
				break;
			endif;
		endforeach;
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rtQueueEntry" type="CM_RTQueueEntry"/>
        <Parameter name="_dtoRTQueueEntry" type="DTO_RTQueueEntry" usage="io"/>
        <Parameter name="_dtoQueueAndEntries" type="DTO_QueueAndRTEntries" usage="io"/>
        <Parameter name="_row" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getDTOEntryAtPosition" id="09cf2a6b-0e18-4ff9-875b-50b03136a304">
        <source>getDTOEntryAtPosition(_order : Integer; _dtoQueueAndEntry :  DTO_QueueAndRTEntries output) : DTO_RTQueueEntry protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 August 2010	cnwer1	Initial creation

*/

vars

	queue 	: CM_RadioTelemetryQueue;
	mach 	: CM_Machine;
	queueOffset,index : Integer;
	sortedQueueEntries : DynaDictionary;
	dtoQueueAndEntries : DTO_QueueAndRTEntries;
	iter				: Iterator;
	isPrimary			: Boolean;
begin
	mach:=self.myMachine;
	create sortedQueueEntries transient;
	self.getSortedQueueAndEntries(sortedQueueEntries);
	
	iter:=sortedQueueEntries.createIterator;
	while iter.next(_dtoQueueAndEntry) do
		if _order-queueOffset &lt;=  _dtoQueueAndEntry.allDTORTQueueEntries.size  then
			return _dtoQueueAndEntry.allDTORTQueueEntries[_order-queueOffset];
		endif;
		queueOffset:=queueOffset + _dtoQueueAndEntry.allDTORTQueueEntries.size;
	endwhile;
	
	return null;
epilog
	delete sortedQueueEntries;
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_order" type="Integer"/>
        <Parameter name="_dtoQueueAndEntry" type="DTO_QueueAndRTEntries" usage="output"/>
        <ReturnType type="DTO_RTQueueEntry"/>
    </JadeMethod>
    <JadeMethod name="getDTOEntryForQueue" id="291a52b7-0229-43da-a74c-4310495f14f8">
        <source>getDTOEntryForQueue(	_queue : CM_RadioTelemetryQueue;
						_rtQueueEntry : CM_RTQueueEntry;
						_dtoRTQueueEntry :DTO_RTQueueEntry io;
						_dtoQueueAndEntries : DTO_QueueAndRTEntries io;
						_row : Integer io)  protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 August 2010	cnwer1	Initial creation

*/

vars
	
begin
	
	
	_dtoQueueAndEntries:=self.allOrderedQueueAndEntries[_queue];
	
	//14/04/2011 cnwdz2 par27379
	if _dtoQueueAndEntries = null then
		return;
	endif;
	
	foreach _dtoRTQueueEntry in _dtoQueueAndEntries.allDTORTQueueEntries do
		if _dtoRTQueueEntry.myRealQueueEntry = _rtQueueEntry then
			break;
		endif;
		_row:=_row+1;
		_dtoRTQueueEntry:=null;		
	endforeach;
	
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_queue" type="CM_RadioTelemetryQueue"/>
        <Parameter name="_rtQueueEntry" type="CM_RTQueueEntry"/>
        <Parameter name="_dtoRTQueueEntry" type="DTO_RTQueueEntry" usage="io"/>
        <Parameter name="_dtoQueueAndEntries" type="DTO_QueueAndRTEntries" usage="io"/>
        <Parameter name="_row" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getIndexForRTQueueEntry" id="fffeb328-9641-4c4e-a2e3-bef2780aa3f9">
        <source>getIndexForRTQueueEntry( _dtoQueueAndEntries : DTO_QueueAndRTEntries;
						_rtQueueEntry : CM_RTQueueEntry;
						_oldRow : Integer;
						_reloadTable : Boolean output) : Integer protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 Dec 2009	cnwer1	Initial creation
16 Dec 2009 cnwer1	Par 21996
*/

vars
	newIndex,
	iterations,
	queueSize, 
	row : Integer;
	prevRTQueueEntry,
	nextRTQueueEntry: CM_RTQueueEntry;
	lookForward : Boolean;
	queue 	: CM_RadioTelemetryQueue;
begin
	//we are displaying nothing add
	if _oldRow = 0 then
		return 1;
	endif;
	
	queue:=_dtoQueueAndEntries.myQueue;
	lookForward:=true;
	newIndex:=queue.allEntries.indexOf(_rtQueueEntry);
	queueSize:=queue.allEntries.size;
	if queueSize = 1 then
		return 1;
	endif;
	iterations:=0;
	row:=_oldRow-1;
	while true do
		iterations:=iterations+1;
		//initalise vars
		prevRTQueueEntry:=null;
		nextRTQueueEntry:=null;
		// 16 Dec 2009 cnwer1	Par 21996 
		if iterations &gt; queueSize then
			//something has gone wrong we should of already found the index by now
			//break reload table
			_reloadTable:=true;
			break;
		endif;
		if lookForward then
			row:=row+1;
		else
			row:=row-1;
		endif;
		
		if row &gt; 1 then
			//check row belows index
			if row-1 &gt; _dtoQueueAndEntries.allDTORTQueueEntries.size then
				row:=_dtoQueueAndEntries.allDTORTQueueEntries.size;
				break;
			endif;
			prevRTQueueEntry:=_dtoQueueAndEntries.allDTORTQueueEntries[row-1].myRealQueueEntry.CM_RTQueueEntry;		
		endif;
		if row &lt;= _dtoQueueAndEntries.allDTORTQueueEntries.size then
			nextRTQueueEntry:=_dtoQueueAndEntries.allDTORTQueueEntries[row].myRealQueueEntry.CM_RTQueueEntry;
		endif;
	
		if prevRTQueueEntry &lt;&gt; null then
			if newIndex &gt; queue.allEntries.indexOf(prevRTQueueEntry) then
				if nextRTQueueEntry = null then
					break;
				endif;
				//+1 if needed
				if newIndex &lt; queue.allEntries.indexOf(nextRTQueueEntry) then
					break;
				else	
					lookForward:=true;
					
					continue;
				endif;
			else	
				lookForward:=false;
				continue;
			endif;
		else
		
			if newIndex &lt; queue.allEntries.indexOf(nextRTQueueEntry) then
				break;
			else
				lookForward:=true;
				continue;
			endif; 
		endif;	
		
	
	endwhile;
	
	return row;


epilog

end;</source>
        <access>protected</access>
        <Parameter name="_dtoQueueAndEntries" type="DTO_QueueAndRTEntries"/>
        <Parameter name="_rtQueueEntry" type="CM_RTQueueEntry"/>
        <Parameter name="_oldRow" type="Integer"/>
        <Parameter name="_reloadTable" type="Boolean" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getNumberOfEntries" id="0c30b139-bc6e-4441-ba53-b4d47060c02f">
        <source>getNumberOfEntries() : Integer;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 August 2010	cnwer1	Initial creation

*/

vars
	numOfEntries : Integer;
	dtoQueueAndEntries : DTO_QueueAndRTEntries;
begin
	
	numOfEntries:=0;
	
	foreach dtoQueueAndEntries in self.allOrderedQueueAndEntries do
		numOfEntries:=numOfEntries + dtoQueueAndEntries.allDTORTQueueEntries.size;
	endforeach;
	
	return numOfEntries;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getOrderOfDTOEntry" id="1ae8c398-8e17-4be2-9370-1763f3707a4f">
        <source>getOrderOfDTOEntry(_dtoEntry : DTO_RTQueueEntry) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 August 2010	cnwer1	Initial creation

*/

vars
	queueOffset,
 	order			: Integer;
	dtoQueueAndEntry : DTO_QueueAndRTEntries;
	queue			: CM_RadioTelemetryQueue;
	mach			: CM_Machine;
	queueEntry 		:  CM_RTQueueEntry;
	invalidObject : Boolean;
begin

	on Exception do app.handleDeletedObject(exception,queueEntry,  invalidObject);
	mach:=self.myMachine;
	queueEntry:=_dtoEntry.myRealQueueEntry.CM_RTQueueEntry;
	if queueEntry &lt;&gt; null then
		dtoQueueAndEntry:=self.allOrderedQueueAndEntries[queueEntry.myQueue];
	endif;
	if dtoQueueAndEntry = null or invalidObject  then
		return null;
	endif;
	
	//need to determine queue offset
	queueOffset:=0;
	if dtoQueueAndEntry.myQueue &lt;&gt; self.myMachine.myPrimaryQueue  then
		foreach queue in mach.allQueues do
			if queue = dtoQueueAndEntry.myQueue then
				break;
			endif;
			queueOffset:=queueOffset + self.allOrderedQueueAndEntries[queue].allDTORTQueueEntries.size;
		endforeach;
	endif;
	order:=dtoQueueAndEntry.allDTORTQueueEntries.indexOf(_dtoEntry);
	order:=order+ queueOffset;
	
	return order;
epilog

end;</source>
        <Parameter name="_dtoEntry" type="DTO_RTQueueEntry"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getQueueOffset" id="429d3a0e-09e6-4dec-8028-b74e72917244">
        <source>getQueueOffset(_queue : CM_RadioTelemetryQueue) : Integer protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 August 2010	cnwer1	Initial creation

*/

vars
	queue : CM_RadioTelemetryQueue;
	startOffset : Integer;
	queueAndEntries :  DTO_QueueAndRTEntries;
	machQueueAndEntries :  DTO_QueueAndRTEntries;
begin
	if _queue = self.myMachine.myPrimaryQueue or not self.showSecondaryQueues then
		startOffset:=0;
	else
	//	startOffset:=self.allOrderedQueueAndEntries[self.myMachine.myPrimaryQueue].allDTORTQueueEntries.size;
		
		//26 Jul 2013	NDL	Par 31515
		machQueueAndEntries := self.allOrderedQueueAndEntries[self.myMachine.myPrimaryQueue];
		if machQueueAndEntries = null then
			return 0;
		endif;
		startOffset := machQueueAndEntries.allDTORTQueueEntries.size;
		
		foreach queue in self.myMachine.allQueues do
			if queue = self.myMachine.myPrimaryQueue then
				continue;
			endif;
			if queue = _queue then
				break;
			endif;
			//epr par 29667 27/6/12
			queueAndEntries:=self.allOrderedQueueAndEntries[queue];
			if queueAndEntries &lt;&gt; null then
				startOffset:=startOffset + queueAndEntries.allDTORTQueueEntries.size;
			endif;
		endforeach;
	endif;
	
	return startOffset;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_queue" type="CM_RadioTelemetryQueue"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getSortedQueueAndEntries" id="c7702999-3843-4bde-a6bd-15397c9508f7">
        <source>getSortedQueueAndEntries(_sortedQueueEntries : DynaDictionary input) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 August 2010	cnwer1	Initial creation

*/

vars
	mach 	: CM_Machine;
	index,nonMachQueues : Integer;
	
	dtoQueueAndEntries : DTO_QueueAndRTEntries;

begin
	mach:=self.myMachine;
	_sortedQueueEntries.setMembership(DTO_QueueAndRTEntries);
	_sortedQueueEntries.addExternalKey(Boolean,1,true,false);  //type i.e. primary / secondary
	_sortedQueueEntries.addExternalKey(Integer,4,false,false);  // machine secondary queue order
	_sortedQueueEntries.endKeys(false);
	nonMachQueues:=mach.allQueues.size + 1;
	foreach dtoQueueAndEntries in self.allOrderedQueueAndEntries do
		index:=mach.allQueues.indexOf(dtoQueueAndEntries.myQueue); 
		if index = 0 then
			index:=nonMachQueues;
			nonMachQueues:=nonMachQueues + 1;
		endif;
		_sortedQueueEntries.putAtKey(dtoQueueAndEntries.myQueue = self.myMachine.myPrimaryQueue,index ,dtoQueueAndEntries);
	endforeach;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_sortedQueueEntries" type="DynaDictionary" usage="input"/>
    </JadeMethod>
    <JadeMethod name="initDetails" id="30264873-f1c4-42ba-a7b9-3f6806fe3756">
        <updating/>
        <source>initDetails(	_vmAgent : VehicleMountedAgent;
			_machine	: CM_Machine;
			_maxDisplayedQueueEntries : Integer;
			_showSecondaryQueues : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 August 2010	cnwer1	Initial creation

*/

vars

begin
	self.myMachine:=_machine;
	self.myVMAgent:=_vmAgent;
	self.maxDisplayEntries:=_maxDisplayedQueueEntries;
	self.showSecondaryQueues:=_showSecondaryQueues;
	self.purgeEntries;
epilog

end;</source>
        <Parameter name="_vmAgent" type="VehicleMountedAgent"/>
        <Parameter name="_machine" type="CM_Machine"/>
        <Parameter name="_maxDisplayedQueueEntries" type="Integer"/>
        <Parameter name="_showSecondaryQueues" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isShowingFilterResultsWithTask" id="064ee127-782b-4d3f-ab9a-43551b55ae0a">
        <source>isShowingFilterResultsWithTask(_rtQueueEntry : CM_RTQueueEntry;_allRTQueueEntriesShown : CM_RTQueueEntryArray io) :Boolean;
/*

Purpose:	check if showing filter results if so check if the entry is one of the ones that
			is being shown.
			
			Should of named this isShowingFilterResultsWithEntry but was 1 character to long

Parameters:			

Return Value:		


Date		Who		Reason
03 February 2011	cnwer1	Initial creation

*/

vars
	dtoRTEntry : DTO_RTQueueEntry;
	foundEntry : Boolean;
begin
	if not self.showingFilteredResults then
		return false;
	endif;
	foundEntry:=false;
	foreach dtoRTEntry in self.allNewDTOEntries do
		if dtoRTEntry.myRealQueueEntry = null then
			continue;
		endif;
		_allRTQueueEntriesShown.add(dtoRTEntry.myRealQueueEntry.CM_RTQueueEntry);
		if dtoRTEntry.myRealQueueEntry = _rtQueueEntry then
			foundEntry:= true;
		endif;	
	endforeach;
	
	return foundEntry;
epilog

end;</source>
        <Parameter name="_rtQueueEntry" type="CM_RTQueueEntry"/>
        <Parameter name="_allRTQueueEntriesShown" type="CM_RTQueueEntryArray" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadNewDTOEntriesToTable" id="a87fd8ae-4d92-4fe4-bc4e-4aa37e6407d3">
        <updating/>
        <source>loadNewDTOEntriesToTable(	_table : Table input;
							_allDTOEntries : DTO_RTQueueEntryArray input;
							_checkOrder : Boolean)  updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 August 2010	cnwer1	Initial creation

*/

vars
	order,
	newPosition 	: Integer;
	isVisible		: Boolean;
	dtoEntry 	: DTO_RTQueueEntry;
	vmInterface		: IF_VehicleMountedDetails;
	mach			: CM_Machine;
	iter 			: Iterator;
	allInvalidQueueEntries : CM_RTQueueEntryArray;
	rtQueueEntry		: CM_RTQueueEntry;
begin
	
	mach:=self.myMachine;

	iter:=_allDTOEntries.createIterator;
	
	create allInvalidQueueEntries transient;
	
	while iter.next(dtoEntry) do
		isVisible:=true;
		if headerIsTopRow then
			//epr par 26048 14/10/10
			if _checkOrder then
				order:=self.getOrderOfDTOEntry(dtoEntry);
				//epr par 25917 1/10/10
				if order = null then
					allInvalidQueueEntries.add(dtoEntry.myRealQueueEntry.CM_RTQueueEntry);
					continue;
				endif;
			endif;
			_table.rows:=_table.rows + 1;
			newPosition:=_table.rows;
			//epr 19/9/14 CCMS 1395
			if  mach.hasAllocatedQueueTasks() then
				if not mach.isQueueEntryAllocated(dtoEntry.myRealQueueEntry.CM_RTQueueEntry) then
					isVisible:=false;
				endif;
			endif;
		else
			_table.columns:=_table.columns + 1;
			newPosition:=_table.columns;
		endif;
		
		
		dtoEntry.loadToTable(_table,self.myEntTableView,self.headerIsTopRow,newPosition,order,isVisible);
	endwhile;
	
	self.getAllRowsToRemove(allInvalidQueueEntries);
	
	foreach rtQueueEntry in allInvalidQueueEntries do
		self.refreshQueueEntry(rtQueueEntry);
	endforeach;
	
	// don't have enough entries check if there are more to get because
	self.checkMaxDisplayedQueueEntries();
	
	
epilog
	delete iter;

	delete allInvalidQueueEntries;
end;</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_allDTOEntries" type="DTO_RTQueueEntryArray" usage="input"/>
        <Parameter name="_checkOrder" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadQueueEntries" id="7dd3c149-88d9-4edc-9051-8750804b3080">
        <updating/>
        <source>loadQueueEntries(	_queue : CM_RadioTelemetryQueue input;
					_startOffset 		: Integer;
					_startRTQueueEntry :  CM_RTQueueEntry input) :DTO_QueueAndRTEntries  updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 August 2010	cnwer1	Initial creation

*/

vars
	rtQueueEntry : CM_RTQueueEntry;
	allEntries : CM_RTQueueEntryArray;
	order : Integer;
	invalidObject : Boolean;
	objectEdition 	: Integer;
	dtoRTQueueEntry : DTO_RTQueueEntry;
	iter			: Iterator;
	dtoQueueAndEntries : DTO_QueueAndRTEntries;
begin
	on Exception do app.handleDeletedObject(exception,rtQueueEntry,invalidObject);
// just incase all entries changes copy to a collection
//	create allEntries transient;
	allEntries := _queue.allEntries.cloneSelf(true);
	iter:=allEntries.createIterator;
	
	
	dtoQueueAndEntries:=self.allOrderedQueueAndEntries[_queue];
	if dtoQueueAndEntries = null then
		create dtoQueueAndEntries transient;
		dtoQueueAndEntries.setMyQueue(_queue);
		self.allOrderedQueueAndEntries.add(dtoQueueAndEntries);
	endif;
	
	
	//need to purge all queued note infor self.allQueuedNoteInfo.purge; if is a reload
	if _startRTQueueEntry = null then
		dtoQueueAndEntries.allDTORTQueueEntries.purge;
		order:=_startOffset + 1;
	else
		order:=_startOffset + dtoQueueAndEntries.allDTORTQueueEntries.size+1;
		iter.startAtObject(_startRTQueueEntry);
	endif;
	
	while iter.next(rtQueueEntry) do
		invalidObject := false;
		objectEdition:=rtQueueEntry.edition;
		if invalidObject then
			continue;
		endif; 
		
		if not self.myVMAgent.queryDisplayRTEntry(rtQueueEntry) then
			continue;
		endif;
		
		if self.findDTOEntryByQueueAndEntry(dtoQueueAndEntries,rtQueueEntry) &lt;&gt; null then
			continue;
		endif;
		if (maxDisplayEntries &lt;&gt; 0 and order  &gt; maxDisplayEntries) and
			(not self.alwaysDisplayRTQueueEntry(rtQueueEntry)) then
			continue;
		endif;	
		
		dtoRTQueueEntry := null;
		dtoRTQueueEntry:=self.createDTO_RTQueueEntry(rtQueueEntry);
		// PAR #24763 - it's possible for null to be returned when the entry 
		// is deleted out from under us, so handle this
		if dtoRTQueueEntry &lt;&gt; null then
			dtoQueueAndEntries.allDTORTQueueEntries.add(dtoRTQueueEntry);
			self.allNewDTOEntries.add(dtoRTQueueEntry);
		endif;
		
		order:=order+1;
	endwhile;
		
epilog
	delete allEntries;
	delete iter;
	return dtoQueueAndEntries;


end;</source>
        <access>protected</access>
        <Parameter name="_queue" type="CM_RadioTelemetryQueue" usage="input"/>
        <Parameter name="_startOffset" type="Integer"/>
        <Parameter name="_startRTQueueEntry" type="CM_RTQueueEntry" usage="input"/>
        <ReturnType type="DTO_QueueAndRTEntries"/>
    </JadeMethod>
    <JadeMethod name="numberOfRowsToRemove" id="8bce92e4-54b7-4714-bf92-e0991ac99dad">
        <source>numberOfRowsToRemove() : Integer protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 February 2011	cnwer1	Initial creation

*/

vars
	
	count,
	i : Integer;
begin
	foreach i in self.allRowsToRemove  where i &lt;&gt; 0 do
		count:=count+1;
	endforeach;
	
	return count;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="purgeEntries" id="f3442915-9502-4ccc-affa-aa895d50491a">
        <source>purgeEntries();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 August 2010	cnwer1	Initial creation

*/

vars

begin
	self.allOrderedQueueAndEntries.purge;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="refreshQueueEntry" id="e8ffa08e-596e-4c67-9e9c-e410b7d3c706">
        <updating/>
        <source>refreshQueueEntry(_rtQueueEntry : CM_RTQueueEntry) : Integer updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 August 2010	cnwer1	Initial creation

*/

vars
	newInsert,
	checkRowsFrom : Integer;
	reloadTable : Boolean;
begin

	
	
	//epr par 26860 9/2/2011
	newInsert:=self.updateQueueEntry(_rtQueueEntry,reloadTable);
	if newInsert &gt; 0 then
		checkRowsFrom:=newInsert;
	endif;
	

	return checkRowsFrom;
	
epilog

end;</source>
