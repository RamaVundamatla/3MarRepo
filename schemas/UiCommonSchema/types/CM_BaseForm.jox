    <JadeMethod name="disableControlsByType" id="fe6a6ba5-3b57-4078-9503-e47e07d590ce">
        <source>disableControlsByType(_getChildren : Boolean; _class : Class; _enable : Boolean);
/*
Purpose:			
Date		Who		Reason
16 June 2016	cnwab1	Initial creation TFS 2101
*/

vars

	contl : Control;
	idx : Integer;
	contrls : CnEcControlArray;
begin

	create contrls transient;

	self.cnEcGetAllChildControls(contrls, _getChildren);
	

	foreach contl in contrls do
		if contl.isKindOf(_class) then
			contl.enabled := _enable;
		endif;
			
	endforeach;
		
	


epilog
	delete contrls;
end;</source>
        <Parameter name="_getChildren" type="Boolean"/>
        <Parameter name="_class" type="Class"/>
        <Parameter name="_enable" type="Boolean"/>
    </JadeMethod>
