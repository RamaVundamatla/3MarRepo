//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.commodityCode := pxyCommodityMap.commodityCode;
	self.contentsMap := pxyCommodityMap.contentsMap;
	self.initialise(self.contentsMap.imexMap.myProductMap.myProductGroupMap.myCargoTypeMap.transactionMap.bank);
end;</source>
