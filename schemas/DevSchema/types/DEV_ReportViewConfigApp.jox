    <JadeMethod name="initMsg" id="366de6d4-8e50-40d1-90b6-3326f6291026">
        <source>initMsg();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 August 2022	navkc1	Initial creation

*/

vars
	theGroupBox		: CMUI_MultiSelectGroupBox;
	
begin
	
	self.getAllViews();
	
	// =============================
	// MSG in Add Type Sheet
	// =============================
	
	theGroupBox 							:= self.msgViewsAddType;
	theGroupBox.caption 					:= null;
	theGroupBox.lockBottom 					:= false;
	theGroupBox.lockRight					:= false;
	theGroupBox.stretchHeight 				:= true;
	theGroupBox.stretchWidth 				:= true;
	theGroupBox.multiSelect 				:= ListBox.MultiSelect_Extended;
	theGroupBox.formDisplayEntryMethodName 	:= "displayView";
	theGroupBox.availableHeading 			:= "Available Views";
	theGroupBox.selectedHeading 			:= "Selected Views";
	theGroupBox.mySelectedListBox.sorted	:= false;
	theGroupBox.readOnly 					:= false;
	theGroupBox.relativeHeight				:= true;
	theGroupBox.relativeWidth 				:= true;
	theGroupBox.relativeLeft				:= true;
	theGroupBox.parentAspect				:= #4;	// Anchor Right
	
	theGroupBox.setAvailable(self.allViews, true);
	theGroupBox.cnEcResizeContents();
	
	// =============================
	// MSG in Check Duplicate Sheet
	// =============================
	
	theGroupBox 							:= self.msgViewsChkDup;
	theGroupBox.caption 					:= null;
	theGroupBox.lockBottom 					:= false;
	theGroupBox.lockRight					:= false;
	theGroupBox.stretchHeight 				:= true;
	theGroupBox.stretchWidth 				:= true;
	theGroupBox.multiSelect 				:= ListBox.MultiSelect_Extended;
	theGroupBox.formDisplayEntryMethodName 	:= "displayView";
	theGroupBox.availableHeading 			:= "Available Views";
	theGroupBox.selectedHeading 			:= "Selected Views";
	theGroupBox.mySelectedListBox.sorted	:= false;
	theGroupBox.readOnly 					:= false;
	theGroupBox.relativeHeight				:= true;
	theGroupBox.relativeWidth 				:= true;
	theGroupBox.relativeLeft				:= true;
	theGroupBox.parentAspect				:= #2;	// Scretch Bottom
	
	theGroupBox.setAvailable(self.allViews, true);
	theGroupBox.cnEcResizeContents();
	
	// =============================
	// MSG in Find Potential Error sheet
	// =============================
	
	theGroupBox 							:= self.msgViewPotentialErr;
	theGroupBox.caption 					:= null;
	theGroupBox.lockBottom 					:= false;
	theGroupBox.lockRight					:= false;
	theGroupBox.stretchHeight 				:= true;
	theGroupBox.stretchWidth 				:= true;
	theGroupBox.multiSelect 				:= ListBox.MultiSelect_Extended;
	theGroupBox.formDisplayEntryMethodName 	:= "displayView";
	theGroupBox.availableHeading 			:= "Available Views";
	theGroupBox.selectedHeading 			:= "Selected Views";
	theGroupBox.mySelectedListBox.sorted	:= false;
	theGroupBox.readOnly 					:= false;
	theGroupBox.relativeHeight				:= true;
	theGroupBox.relativeWidth 				:= true;
	theGroupBox.relativeLeft				:= true;
	theGroupBox.parentAspect				:= #2;	// Scretch Bottom
	
	theGroupBox.setAvailable(self.allViews, true);
	theGroupBox.cnEcResizeContents();
	
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="initTblAttributes" id="66d139ee-5af5-445f-b17d-81f215f8e202">
        <source>initTblAttributes();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 May 2023	navkc1	Initial creation

*/

vars

begin

	self.tblAttributesData.selectMode 			:= CM_EntryTable.SelectMode_FixedRow;
	self.tblAttributesData.selectionType 		:= CM_EntryTable.SelectionType_Row;
	self.tblAttributesData.multiSelect 			:= CM_BaseTable.MultiSelect_Simple;
	self.tblAttributesData.userInputEnabled 	:= true;
	self.tblAttributesData.setCellText(1, 1, "Name");
	self.tblAttributesData.setCellText(1, 2, "Type");
	
	// Alias column so we can give it a nice name.
	// Only this column can accept user input
	self.tblAttributesData.setCellText(1, 3, "Alias");
	self.tblAttributesData.accessColumn(3).inputType := Table.InputType_TextBox;
	self.tblAttributesData.accessColumn(3).maxLength := 30;
	
	self.tblAttributesData.sortAscending := false;
	self.tblAttributesData.resortTableByColumn(1);

epilog

end;</source>
    </JadeMethod>
