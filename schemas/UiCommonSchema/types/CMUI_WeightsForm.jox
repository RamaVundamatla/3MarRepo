Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 March 2014	cnwndl1	Initial creation

*/

vars

	weightType : CM_MeasurementType;

begin

	weightType := app.getDefaultMeasurementForType(Type_Weight);
	self.setChassisWeightFromSelection( weightType );

	self.calculate( false, cmbChassis );

epilog

end;</source>
