    <JadeMethod name="getWorkOrderForManifest" id="e61198d1-50c1-4439-8312-30231c1f75dc">
        <source>getWorkOrderForManifest(_wo : CM_WorkOrder output);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 November 2024	navsp1	Initial creation JIRA 33407 EUP | FR 53824 - Unable to update Manifest/VBS Appointment after WO Approved

*/

vars

begin
	_wo := self.getMyTerminal.allWorkOrders[self.manifestNumber];
	if self.myShipManifest &lt;&gt; null then
		_wo := null;
		_wo := self.getMyTerminal.allWorkOrders[self.myShipManifest.getVoyageCode];
	elseif self.myTrainConsist &lt;&gt; null then
		_wo := null;
		_wo := self.getMyTerminal.allWorkOrders[self.myTrainConsist.currentWagonCode];
	elseif self.myGateDocument &lt;&gt; null then
		_wo := null;
		_wo := self.getMyTerminal.allWorkOrders[self.transportReferenceCustomer];
	endif;
epilog

end;</source>
        <Parameter name="_wo" type="CM_WorkOrder" usage="output"/>
    </JadeMethod>
    <JadeMethod name="hasItems" id="d4339e68-05de-4602-93a5-214cd09edba1">
        <source>hasItems(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
01 November 2024	navcs2	MTN-33047

*/

vars
	ti	: Object;
	objSet	: CM_ObjectArray;
begin
	create objSet transient;
	
	self.getAllEDITrackedItems(objSet);
	
	foreach ti in objSet do
		if (ti.CM_EDITrackedItem.isEDICargo and ti.CM_EDICargoTI.itemised) 
			or (ti.CM_EDITrackedItem.isEDIPrenote and ti.CM_EDIPrenoteTI.itemised) then
			return true;
		endif;
	endforeach;
	
	return false;
epilog
	delete objSet;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
