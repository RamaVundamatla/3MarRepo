    <JadeMethod name="isFromBarge" id="7b01d256-dfe2-467f-80e5-505ad1766089">
        <source>isFromBarge(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 June 2021	navndl1	Initial creation	TFS 51245

*/

vars

begin
	return self.myLocationActivity.mySourceVoyage &lt;&gt; null and self.myLocationActivity.mySourceVoyage.isBarge;

epilog

end;</source>
