    <JadeMethod name="getMyVoyage" id="94fb93c5-bc3c-4afb-ab2b-793efe86a4e8">
        <source>getMyVoyage(): CM_Voyage;
//----------------------------------------------------------------
//	Created:	08 November 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	voyCode : String;
begin
	//CNWSH3 - 1/10/2008 - MOVED TO CM_EDIDATA::getVOyageFromCode 
	//AS OTHER EDI DATA CLASSES USE A VOYAGE CODE.
	//DEIMPLEMENTED 
	voyCode := self.voyageCode.trimBlanks;
	
	if voyCode = "" then
		return null;
	endif;
	
	return self.getMyTerminal.lookupVoyage(voyCode, null, false);

epilog

end;</source>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
