<Class name="DataObjects" id="de799e4d-3ac1-4571-9782-5120bfe5366d">
    <superclass name="Object"/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <text>
This abstract class holds multiple persistent subclasses. Most applications will
subscribe to notifications on this class (via CacheSyncer), so add new classes 
under here if they are likely to need cache synchronisation.</text>
    <DbClassMap file="JetPlusMap"/>
</Class>
