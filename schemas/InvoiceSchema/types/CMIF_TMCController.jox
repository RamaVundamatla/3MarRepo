    <JadeMethod name="getFullHeadings" id="474c2207-00bc-4cb3-8ce8-b6f0c5e725d3">
        <updating/>
        <source>getFullHeadings() updating;
// April 2010, cnwjre1, par 23659, invoice transaction map extract enhancements for Tranship IMEX status
vars
	maxOrderEle, allXMLMethods,allXMLCargoTypes,allXMLQuestions	: JadeXMLElementArray;
	xmlCargoType,xmlQuestion,xmlMethod	: JadeXMLElement;

	order	: Integer;
	strLabel, strMethod : String;
begin

	self.fullMethodHeadings.clear;
	self.fullMethodNames.clear;
	
	create maxOrderEle transient;
	create allXMLMethods transient;
	create allXMLCargoTypes transient;
	create allXMLQuestions transient;
	
	self.xmlDocument.getElementsByTagName(InvoiceMappingTag_ALL, allXMLMethods);	

	foreach xmlMethod in allXMLMethods do

		xmlMethod.getElementsByTagName("MAXORDER", maxOrderEle);	
		foreach xmlCargoType in maxOrderEle do
			self.maxMethods := xmlCargoType.textData.Integer;
		endforeach;

		xmlMethod.getElementsByTagName(InvoiceMappingTag_CARGOTYPE, allXMLCargoTypes);
		foreach xmlCargoType in allXMLCargoTypes do
		
			xmlCargoType.getElementsByTagName(InvoiceMappingTag_QUESTION,allXMLQuestions);
			foreach xmlQuestion in allXMLQuestions do
					
				strLabel := xmlQuestion.getTagValueOfName(InvoiceMappingTag_LABEL);
				strMethod := xmlQuestion.getTagValueOfName(InvoiceMappingTag_METHOD);
				order :=  xmlQuestion.getTagValueOfName(InvoiceMappingTag_ORDER).Integer;
				self.fullMethodHeadings[order] := strLabel;
				self.fullMethodNames[order] := strMethod;
	
			endforeach;

		endforeach;
	endforeach;

epilog
	delete maxOrderEle;
	delete allXMLMethods;
	delete allXMLCargoTypes;
	delete allXMLQuestions;

end;
</source>
    </JadeMethod>
    <JadeMethod name="getMappingHeaders" id="753ca1e9-5e84-4208-9645-5673596df174">
        <updating/>
        <source>getMappingHeaders() updating;
// April 2010, cnwjre1, par 23659, invoice transaction map extract enhancements for Tranship IMEX status
vars
	maxOrderEle, allXMLMethods,allXMLCargoTypes,allXMLQuestions	: JadeXMLElementArray;
	xmlCargoType,xmlQuestion,xmlMethod	: JadeXMLElement;

	order, maxOrder : Integer;
	strLabel, strMethod, strClass : String;
begin

	self.allHeadings.clear;
	self.allMethods.clear;
	
	if self.myCurrentMapTM = null then
		return;
	endif;
	
	create allXMLMethods transient;
	create allXMLCargoTypes transient;
	create allXMLQuestions transient;
	create maxOrderEle transient;
	
	self.xmlDocument.getElementsByTagName(InvoiceMappingTag_ALL, allXMLMethods);	

	foreach xmlMethod in allXMLMethods do

		// INITIALISE
		xmlMethod.getElementsByTagName("MAXORDER", maxOrderEle);	
		foreach xmlCargoType in maxOrderEle do
			maxOrder := xmlCargoType.textData.Integer;
			self.allHeadings[maxOrder] := "";
			self.allMethods[maxOrder] := "";
		endforeach;

		 xmlMethod.getElementsByTagName(InvoiceMappingTag_CARGOTYPE, allXMLCargoTypes);
		foreach xmlCargoType in allXMLCargoTypes do
			strClass := xmlCargoType.getAttributeByName(InvoiceMappingAttr_CLASS).value;
			
			if strClass = CM_TrackedItem.name 
			or strClass = self.myCurrentMapTIService.className then
			
				xmlCargoType.getElementsByTagName(InvoiceMappingTag_QUESTION,allXMLQuestions);
				foreach xmlQuestion in allXMLQuestions do
					
					strLabel := xmlQuestion.getTagValueOfName(InvoiceMappingTag_LABEL);
					
					// only show isRORO for ship release and receive
					if strLabel = InvoiceMappingLabelIsRORO then
						if self.myCurrentMapServiceBroker.isKindOf(CM_TransServiceBroker) then
							if not (self.myCurrentMapServiceBroker.CM_TransServiceBroker.className = CM_ReceiveShip.name
								or self.myCurrentMapServiceBroker.CM_TransServiceBroker.className = CM_ReleaseShip.name) then
								continue;
							endif;
						else
							continue;
						endif;
					endif;
					strMethod := xmlQuestion.getTagValueOfName(InvoiceMappingTag_METHOD);
					order :=  xmlQuestion.getTagValueOfName(InvoiceMappingTag_ORDER).Integer;
					self.allHeadings[order] := strLabel;
					self.allMethods[order] := strMethod;
		
				endforeach;
			endif;
		endforeach;
	endforeach;

epilog
	delete allXMLMethods;
	delete allXMLCargoTypes;
	delete allXMLQuestions;
	delete maxOrderEle;

end;
</source>
    </JadeMethod>
    <JadeMethod name="loadXMLDocument" id="e038ee51-9b11-4902-a97f-86aa697aed8b">
        <updating/>
        <source>loadXMLDocument() updating;
// April 2010, cnwjre1, par 23659, invoice transaction map extract enhancements for Tranship IMEX status
vars

begin

	if self.xmlDocument = null then
		create self.xmlDocument transient;
		xmlDocument.parseString(InvoiceMappingMethods);
		if self.myBank.voidInvoiceLineDesc = null then
			self.voidInvoiceLineDesc := "VOID";
		else
			self.voidInvoiceLineDesc := self.myBank.voidInvoiceLineDesc.narration;
		endif;
	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="transhipTranMapUpgrade" id="bb6baee1-13a8-41e3-a9de-0719bbe191ad">
        <source>transhipTranMapUpgrade();
//----------------------------------------------------------------------
//  Created by cnwjre1 May 2010 for 23659
// 	extract, convert and re-load invoicing cargo transaction map details relating to transhipment
//  Does this for all maps for all terminals
//  Uses the log directory for file location, as available in both managed and un-managed environments
//----------------------------------------------------------------------
vars
	fileStart,
	filePath,
	fileName,
	fileOutName,
	fileSuffix	: String;
	name	: String;
	nameList	: StringArray;
	term	: CM_Terminal;
	bank	: CM_Bank;
	tmcRoot	: CMIF_TMCRoot;
	tranGroup	: CMIF_TMCTranGroup;
	loadAgent	: CM_InvoiceTranMapFileLoadAgent;
begin
	fileStart := app.myCnLog.filePath;
	create nameList transient;
	
	foreach term in CM_Terminal.instances do
		app.myPassport.setMyTerminal(term);
		
		bank := term.getDefaultCompanyBank();	// 35872
	
		create tmcRoot transient;
		tmcRoot.itemName := bank.code;
		tmcRoot.extractName := tmcRoot.itemName;
		tmcRoot.initialise(tmcRoot.groupCount);			// this creates the rest of the transients
	
		filePath := fileStart &amp; "TranshipMap" &amp; term.code;
		fileSuffix := ".csv";
		create loadAgent;
		loadAgent.myTerminal := term;
	
		tmcRoot.getCargoMapNames(nameList);
		foreach name in nameList do
			tranGroup := tmcRoot.getCargoMap(name);
			fileName := filePath &amp; name &amp; fileSuffix;
			fileOutName := filePath &amp; name &amp; "Out" &amp; fileSuffix;
			tranGroup.transhipOutputOnly := true;
			tranGroup.outputAsCSV(fileName, true);
			loadAgent.doConvertCSVFile(fileName, fileOutName);
			loadAgent.doLoadCSVFile(bank, fileOutName, false);	// files are on server
		endforeach;
		delete tmcRoot;
		delete loadAgent;
	endforeach;
epilog
	delete tmcRoot;
	delete loadAgent;
	delete nameList;
end;</source>
    </JadeMethod>
</Class>
