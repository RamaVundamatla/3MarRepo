    <JadeMethod name="trxCreateVehicleBookingAdv" id="baf29dab-a46a-4356-bb80-0f88e6aeba84">
        <updating/>
        <source>trxCreateVehicleBookingAdv(_proxy : CM_VehicleBookingTimeSlot; _newVehicleBookingTimeSlot : CM_VehicleBookingTimeSlot output; _isCopy : Boolean;  _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
12 July 2022	navcs2	53899 EUP - SD - VBS MTN - [3] - Maintaining VBS Slot
24 May 2023 	navhl20 Defect 58041: MTN - Unable to copy the slots with the status "Booked - Current"
*/

vars
	vbsTimeSlotItems : CM_VehicleBookingTSItemSet; 
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	
	create vbsTimeSlotItems transient;
	
	_proxy.allVehicleBookingItems.copy(vbsTimeSlotItems);
	
	// Start the transaction
	beginTransaction;

	// Perform the operation
	app.myUtilityCA.utlCreateVehicleBookingAdv(_proxy, _newVehicleBookingTimeSlot, vbsTimeSlotItems,_isCopy, _passport);			//24.5.2023 navhl20 #58041
	
epilog
	delete vbsTimeSlotItems;
	self.finaliseActivityWithPassport(_passport);
end;
</source>
