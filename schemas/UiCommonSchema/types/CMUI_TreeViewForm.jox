    <JadeMethod name="doResize" id="f7d634b1-231b-44ad-bdc9-6ee24c36b313">
        <updating/>
        <source>doResize() updating;
/*
----------   ----------  --------------------------------------------------
Created:	02 May 2007 By cnwth2

Purpose:	

*/

/*

Date		Who		Reason
02 Jul 2008	cnwkpd1	PAR #17284 - Correct placement of main frame when toolbar captions
					are shown

*/

vars
	newTop			: Real;
	
begin
	inheritMethod();
	
	newTop := self.frmToolbar.top + self.frmToolbar.height;		// PAR #17284
	if self.frmMain.top &lt;&gt; newTop then
		self.frmMain.top := newTop;
		self.frmMain.repositionAfterResize;
	endif;
	
end;


</source>
