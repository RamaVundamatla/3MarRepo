    <JadeMethod name="chkIncludeLoad_change" id="84dc1084-eea2-4e7a-87b3-c79ba763a1dc">
        <controlMethod name="CheckBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>chkIncludeLoad_change(checkbox: CheckBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
04 December 2024	navlw1	Jira-14844: MTN - Refinement of EDI Issue Save

*/

vars

begin
	if self.myCurrentEDIIssue = null then
		return;
	endif;
	if self.myCurrentEDIIssue.includeLoadIssue &lt;&gt; self.chkIncludeLoad.value then
		self.ediChanged := true;
	endif;
epilog

end;</source>
