        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="initialise" id="555ad8d5-a299-4be4-986b-26ff5643e5ae">
        <updating/>
        <source>initialise(_groupCount : Integer io) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 January 2010	cnwndl1	Initial creation

*/

vars

	tmcDebtor : CMIF_TMCDebtorGroup;
	aDM : CM_DebtorMap;
	
begin

	self.myTMCController := self.myGroup.myTMCController;	// April 2010, cnwjre1, par 23659, invoice transaction map extract enhancements for Tranship IMEX status
	self.hidePictures := true;
	create tmcDebtor as CMIF_TMCDebtorGroupDefault;
	tmcDebtor.myDebtor := null;
	tmcDebtor.myDebtorMap := null;
	tmcDebtor.myServiceBroker := self.myTransResourceServiceBroker;
	tmcDebtor.itemName := tmcDebtor.getItemName();
	tmcDebtor.extractName := tmcDebtor.getItemCode();	// 23659
	tmcDebtor.myGroup := self;
	tmcDebtor.initialise(_groupCount);

	foreach aDM in self.myTransResourceServiceBroker.allDebtorMapsByDebtor do
		create tmcDebtor;

		tmcDebtor.myDebtor := aDM.myDebtorNode;
		tmcDebtor.myDebtorMap := aDM;
		tmcDebtor.itemName := tmcDebtor.getItemName();
		tmcDebtor.extractName := tmcDebtor.getItemCode();	// 23659
		tmcDebtor.myGroup := self;
		tmcDebtor.initialise(_groupCount);
	endforeach;
	
	_groupCount := _groupCount + 1;
				
end;</source>
        <Parameter name="_groupCount" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setControllerCurrent" id="bc07d464-ee32-47c1-bd91-db9d0c8e202e">
        <source>setControllerCurrent() ;
// April 2010, cnwjre1, par 23659, invoice transaction map extract enhancements for Tranship IMEX status
vars

	aCommMap : CM_CommodityMap;
	
begin

	inheritMethod();
	
	myTMCController.myCurrentMapServiceBroker := self.myTransResourceServiceBroker;
	myTMCController.myCurrentMapResourceType := self.myTransResourceServiceBroker; // 15/05/2023	navkc1	CR 57927 Task 54268;
	
	// 24/05/2023	navkc1	CR 57927 Task 57923
	if self.myTransResourceServiceBroker = null then
		return;
	endif;
	
	// 24/05/2023	navkc1	CR 57927 Task 57923
	if self.myTransResourceServiceBroker.isKindOf(CM_TransResourceServiceBroker) then
	
		aCommMap := self.myTransResourceServiceBroker.CM_TransResourceServiceBroker.commodityMap; // 15/05/2023	navkc1	CR 57927 Task 54268
	
		myTMCController.myCurrentMapCommodity := aCommMap;
		myTMCController.myCurrentMapContents := aCommMap.contentsMap;
		myTMCController.myCurrentMapIMEX := myTMCController.myCurrentMapContents.imexMap;
		myTMCController.myCurrentMapProduct := myTMCController.myCurrentMapIMEX.myProductMap;
		myTMCController.myCurrentMapProdGrp := 	myTMCController.myCurrentMapProduct.myProductGroupMap;
		myTMCController.myCurrentMapTIService := myTMCController.myCurrentMapProdGrp.myCargoTypeMap;
		myTMCController.myCurrentMapTM := myTMCController.myCurrentMapTIService.transactionMap;
	
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setEnableObjects" id="53ad7ffe-e371-4e94-8118-85e37ad57f1d">
        <source>setEnableObjects(form: INV_TransactionMap io);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 January 2010	cnwndl1	Initial creation	MES CCMS 1006

*/

vars

begin

	inheritMethod(form);
	
	form.menuSItemNew.visible := true;  // MAIN CARGO NEW MENU	
	form.mnuTMExport.visible := false;
	form.menuMappingSetActive.visible := false;
	form.modePropertyNew := INV_TransactionMap.ModeProperty_Debtor;
	form.modePropertyDelete := INV_TransactionMap.ModeProperty_ResourceType;

	form.menuSItemDelete.visible := true;
	form.menuSItemNew.enabled := true;
	form.menuSINewDebtor.enabled := true;
	form.mnuCopy.visible := app.myCurrentUserCan(form.myTerminal, form.permissionMaint); // TFS 2198 CNWAB1;
	form.btnCopy.enabled := app.myCurrentUserCan(form.myTerminal, form.permissionMaint); // TFS 2198 CNWAB1;
	form.mnuReplace.visible := app.myCurrentUserCan(form.myTerminal, form.permissionMaint); // TFS 2198 CNWAB1;
	form.btnReplace.enabled := app.myCurrentUserCan(form.myTerminal, form.permissionMaint); // TFS 2198 CNWAB1;
	form.menuSINewDebtor.visible := true;
	form.mnuResourceType.visible := true;
	
	form.btnDelete.enabled := true;
	form.btnNew.enabled := true;

epilog

end;</source>
        <Parameter name="form" type="INV_TransactionMap" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setMyCurrent" id="0c9b8f96-1a10-4dee-8a9b-b9854962d8be">
        <updating/>
        <source>setMyCurrent(form: INV_TransactionMap io) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 January 2010	cnwndl1	Initial creation	CCMS MES 1006
15/05/2023	navkc1	CR 57927 Task 54268 - Transaction Map
*/

vars

	aCommMap 		: CM_CommodityMap;
	serviceBroker 	: CM_ServiceBroker; // 15/05/2023	navkc1	CR 57927 Task 54268
	
begin

	inheritMethod(form);
	
	form.myCurrentMapServiceBroker := self.myTransResourceServiceBroker;
	form.myCurrentMapResourceType := self.myTransResourceServiceBroker;
	
	if self.myTransResourceServiceBroker &lt;&gt; null then
		// 15/05/2023	navkc1	CR 57927 Task 54268
		if self.myTransResourceServiceBroker.isKindOf(CM_TransResourceServiceBroker) then
			aCommMap := self.myTransResourceServiceBroker.CM_TransResourceServiceBroker.commodityMap;
		
			form.myCurrentMapCommodity := aCommMap;
			form.myCurrentMapContents := aCommMap.contentsMap;
			form.myCurrentMapIMEX := form.myCurrentMapContents.imexMap;
			form.myCurrentMapProduct := form.myCurrentMapIMEX.myProductMap;
			form.myCurrentMapProdGrp := 	form.myCurrentMapProduct.myProductGroupMap;
			form.myCurrentMapTIService := form.myCurrentMapProdGrp.myCargoTypeMap;
			form.myCurrentMapTM := form.myCurrentMapTIService.transactionMap;
		elseif self.myTransResourceServiceBroker.isToDoRsrcServiceBroker() then // 15/05/2023	navkc1	CR 57927 Task 54268
			
			serviceBroker := self.myTransResourceServiceBroker.CM_ToDoResourceServiceBroker.myServiceBroker;
			
			if serviceBroker.isEventServiceBroker() then
				form.myCurrentMapTMEvent := serviceBroker.CM_EventServiceBroker.myTranMap;
			elseif serviceBroker.isWOServiceBroker() then
				form.myCurrentMapTMWorkOrder := serviceBroker.CM_WorkOrderServiceBroker.myTransMap;
			endif;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="form" type="INV_TransactionMap" usage="io"/>
    </JadeMethod>
</Class>
