    <JadeMethod name="tfs50421FixAgentDebtorSYS" id="6a90b7ad-f41c-4ef5-8e28-151b769db131">
        <source>tfs50421FixAgentDebtorSYS();
/*
Purpose:			

Date		Who		Reason
28 October 2021	navab1	TFS 51853
*/

vars
	iter01 : Iterator;
	men : CM_MenuEntity;
	oArray : ObjectArray; 
	idx, count : Integer;
	xml : String;
	root : CM_Root;
	pic : Binary;
	
	linecolr : Integer;
	classs : Class;
begin
	root := CM_Root.firstInstance;
	
	app.mousePointer := Form.MousePointer_HourGlass;

	foreach men in CM_Root.firstInstance.allToolbarEntities do

		if men.getHeading() = "Agent Debtor Maintenance" then

			beginTransaction;
			men.setPictures("PicConsigneeUp","PicConsigneeDown","PicConsigneeUp");
			commitTransaction;

		endif;
	
	
	endforeach;

epilog
	delete oArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="tfs50421FixMenuEntityIcons" id="a462445d-f271-4d4e-86f4-916fc9312d3b">
        <source>tfs50421FixMenuEntityIcons();
/*
Purpose:			

Date		Who		Reason
28 October 2021	navab1	TFS 51853
*/

vars
	iter01 : Iterator;
	men : CM_MenuEntity;
	oArray : ObjectArray; 
	idx, count : Integer;
	xml : String;
	root : CM_Root;
	pic : Binary;
	
	linecolr : Integer;
	classs : Class;
begin
	root := CM_Root.firstInstance;
	
	app.mousePointer := Form.MousePointer_HourGlass;

	create oArray transient;
	CM_MenuEntity.allInstances(oArray,0,true);
	iter01 := oArray.createIterator;
	idx := 1;
	
	while iter01.next(men) do
		if men.isKindOf(CM_QryReportSystem) // NO ICON
		or  men.isKindOf(CM_QryReportUser) // NO ICON
//		or  men.isKindOf(CM_MenuRootForRoot) // Have Icons, but these are all 'SYSTEM ITEMS' 
//		or  men.isKindOf(CM_MenuRootForUser) // Have Icons, but these are all 'SYSTEM ITEMS' icon is either a light house or a PC
		or  men.isKindOf(CM_MenuRootQuery) // NO ICONS only 1 instance
		or  men.isKindOf(CM_MenuRootReportForRoot) // NO ICON
		or  men.isKindOf(CM_MenuRootReportUserTerminal) // NO ICON
		or  men.isKindOf(CM_MenuRootToolbar) // NO ICON
		or  men.isKindOf(CM_MenuRootUserBackgroundReps) // NO ICON
		or  men.isKindOf(CM_MenuRootUserTemplates) // NO ICON
		or  men.isKindOf(CM_MenuRootUserTerminal) // NO ICON
		or  men.isKindOf(CM_MenuUserToolbarRoot) // NO ICON
		or  men.isKindOf(CM_MenuUserReport) // NO ICON
//		or  men.isKindOf(CM_MenuUserDtl) // 30,000 plus, all with icons
//		or  men.isKindOf(CM_MenuUserHdr) // 20,000 plus, all with pictures, no icon
//		or  men.isKindOf(CM_MenuUserQuery) // all the same question mark icon , no pictures
		
		then
			continue;
		endif;
/*	
		if men.getHeading() = "EDI Data Translations" then
			beginTransaction;
			men.setPictures("p16Translations",men.pictureStringButtonDown,men.pictureStringIcon);
			commitTransaction;
			continue;
		endif;
	
		if men.getHeading() = "Snapshot Summary" then
			beginTransaction;
			men.setPictures("picSnapshotSumm","picSnapshotSumm","picSnapshotSumm");
			commitTransaction;
			continue;
		endif;
		
		if men.getHeading() = "Harbour" then
			beginTransaction;
			men.setPictures("picHarbourSys","picHarbourSys","picHarbourSys");
			commitTransaction;
			continue;
		endif;
		
		if men.getHeading() = "Currency Type Maintenance" then
			beginTransaction;
			men.setPictures("picCurrencyType","picCurrencyType","picCurrencyType");
			commitTransaction;
			continue;
		endif;
		
		if men.getHeading() = "Invoice Types" then
			beginTransaction;
			men.resetPictures();
			commitTransaction;
			continue;
		endif;

		
		if men.getHeading() = "Activity History" then
			beginTransaction;
			men.setPictures("picActivityHistory","picActivityHistory","picActivityHistory");
			commitTransaction;
			continue;
		endif;
		if men.getHeading() = "Load List" then
			beginTransaction;
			men.setPictures(men.pictureStringButton,men.pictureStringButtonDown,"picLoadListUp");
			commitTransaction;
			continue;
		endif;
		if men.getHeading() = "Cash Consolidation" then
			beginTransaction;
			men.setPictures("picTermTrade16","picTermTrade16","picTermTrade16");
			commitTransaction;
			continue;
		endif;
		if men.getHeading() = "Load Out Reconciliation" then
			beginTransaction;
			men.resetPictures();
			commitTransaction;
			continue;
		endif;
		if men.getHeading() = "Location Enquiry" then
			beginTransaction;
			men.resetPictures();
			commitTransaction;
			continue;
		endif;
		if men.getHeading() = "Location Inventory Enquiry" then
			beginTransaction;
			men.setPictures("picLocnInventoryEnq","picLocnInventoryEnq","picLocnInventoryEnq");
			commitTransaction;
			continue;
		endif;
		if men.getHeading() = "TBA List" then
			beginTransaction;
			men.resetPictures();
			commitTransaction;
			continue;
		endif;
		if men.getHeading() = "Text Translation" then
			beginTransaction;
			men.setPictures("picTranslationsUp","picTranslationsUp","picTranslationsUp");
			commitTransaction;
			continue;
		endif;
				*/
		if men.getHeading() = "Agent Debtor Maintenance" then
			beginTransaction;
			men.resetPictures();
			commitTransaction;
			continue;
		endif;
	
	
	endwhile;

epilog
	delete oArray;
end;</source>
    </JadeMethod>
