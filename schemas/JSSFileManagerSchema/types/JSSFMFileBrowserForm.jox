    <JadeMethod name="setState" id="027a7550-615c-4deb-ac6e-e0c4d28d45a3">
        <source>setState(pState:Integer) protected;
// --------------------------------------------------------------------------------
// Created:		26 June 2002 by cnwdad1
//
// Purpose:		Sets the state of the mouse pointer, and sets the status light to
//				red (busy) or green (idle).
//
// Parameters:	pState - Indicates the desired state.  Only send either the "Busy"
//					or "Idle" global constant values to this method.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pState = Idle then
		picState.picture	:=	picHolderIdle.picture;
		picState.refreshNow();
		app.mousePointer	:=	Idle;
		
	elseif pState = Busy then
		app.mousePointer	:=	Busy;
		picState.picture	:=	picHolderBusy.picture;
		picState.refreshNow();
		
	else
		// Ignore state setting.
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pState" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="statusResizeKeys" id="7d637925-075a-4999-8a6e-339d3d06b39f">
        <source>statusResizeKeys() protected;
// --------------------------------------------------------------------------------
// Created:		28 June 2002 by cnwdad1
//
// Purpose:		Resizes the lables on the status bar for the Close and Refresh
//				function keys.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	labelWidth	: Integer;
	
begin
	labelWidth	:=	lblKeyClose.getTextExtent(lblKeyClose.caption &amp; "w");
	lblKeyClose.move((lblTimestamp.left - lblKeyClose.width - 2), -2, labelWidth, lblKeyClose.height);
	
	labelWidth	:=	lblKeyRefresh.getTextExtent(lblKeyRefresh.caption &amp; "w");
	lblKeyRefresh.move((lblKeyClose.left - lblKeyRefresh.width - 2), -2, labelWidth, lblKeyRefresh.height);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="statusResizeObjectCounts" id="9d1dec32-d9a2-4cb5-a565-4f0e72b34e6c">
        <source>statusResizeObjectCounts() protected;
// --------------------------------------------------------------------------------
// Created:		26 June 2002 by cnwdad1
//
// Purpose:		Resizes the lables on the status bar for the Object Count and
//				Selected Count displays.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	labelWidth	: Integer;
	
begin
	labelWidth	:=	lblObjectCount.getTextExtent(lblObjectCount.caption &amp; "w");
	lblObjectCount.move(-1, -2, labelWidth, lblObjectCount.height);
	
	labelWidth	:=	lblSelectedCount.getTextExtent(lblSelectedCount.caption &amp; "w");
	lblSelectedCount.move((lblObjectCount.left + lblObjectCount.width + 2), -2, labelWidth, lblSelectedCount.height);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="statusResizeTimestamp" id="0b0e3bc3-9889-4126-9d8e-db078efd8dd8">
        <source>statusResizeTimestamp() protected;
// --------------------------------------------------------------------------------
// Created:		26 June 2002 by cnwdad1
//
// Purpose:		Resizes the lable on the status bar for the TimeStamp display.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	labelWidth	: Integer;
	
begin
	labelWidth	:=	lblTimestamp.getTextExtent(lblTimestamp.caption &amp; "w");
	
	lblTimestamp.move((picState.left - lblTimestamp.width - 3), -2, labelWidth, lblTimestamp.height);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="statusSetObjectCount" id="d40fb2cb-11d6-4764-ad2a-0d3dcd49e0d0">
        <source>statusSetObjectCount(pNodeCount:Integer; pTotalFileSize:Decimal) protected;
// --------------------------------------------------------------------------------
// Created:		26 June 2002 by cnwdad1
//
// Purpose:		Updates the values of the Object Count labels.
//
// Parameters:	pNodeCount - The number of objects.
//				pTotalFileSize - The total size of all of the objects.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 17/10/2002	cnwdad1		Changed to round the total file size to an integer
//							instead of a decimal to two places.
// --------------------------------------------------------------------------------
vars
	displayValue	: String;
	
begin
	displayValue	:=	" " &amp; pNodeCount.String &amp;
						" objects (" &amp;
//						(pTotalFileSize / 1048576).roundedTo(2).String &amp;
						(pTotalFileSize / 1048576).rounded.String &amp;
						" MB)";
	
	lblObjectCount.caption	:=	displayValue;
end;</source>
        <access>protected</access>
        <Parameter name="pNodeCount" type="Integer"/>
        <Parameter name="pTotalFileSize" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="statusSetSelectedCount" id="e19928c7-7db5-4f62-bcf0-90e22dc4e8f1">
        <source>statusSetSelectedCount(pTheTable:Table) protected;
// --------------------------------------------------------------------------------
// Created:		26 June 2002 by cnwdad1
//
// Purpose:		Updates the values of the Selected Objects labels.
//
// Parameters:	pTheTable - The table containing the selectd objects to count.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 17/10/2002	cnwdad1		Changed to round the selected file size to an integer
//							instead of a decimal to two places.
// --------------------------------------------------------------------------------
vars
	theTable		: Table;
	displayValue	: String;
	totalNodeCount	: Integer;
	totalFileSize	: Integer;
	rowPointer		: Integer;
	startRow		: Integer;
	rowCount		: Integer;
	
begin
	theTable	:=	pTheTable;
	
	if theTable = null then
		totalNodeCount	:=	0;
		totalFileSize	:=	0;
	else
		startRow	:=	theTable.fixedRows + 1;
		rowCount	:=	theTable.rows;
		
		foreach rowPointer in startRow to rowCount do
			if theTable.getCellSelected(rowPointer, 1) then
				totalNodeCount	:=	totalNodeCount + 1;
				totalFileSize	:=	totalFileSize + theTable.getCellText(rowPointer, 3).Integer;
			endif;
		endforeach;
	endif;
	
	displayValue	:=	" " &amp; totalNodeCount.String &amp;
						" objects selected (" &amp;
//						(totalFileSize / 1048576).roundedTo(2).String &amp;
//						(totalFileSize / 1024).roundedTo(2).String &amp;
						(totalFileSize / 1024).rounded.String &amp;
						" MB)";
	
	lblSelectedCount.caption	:=	displayValue;
end;</source>
        <access>protected</access>
        <Parameter name="pTheTable" type="Table"/>
    </JadeMethod>
    <JadeMethod name="statusSetTimestampFormat" id="4329cfb0-d2ea-4dbb-a730-4a4c395d8fb9">
        <source>statusSetTimestampFormat() protected;
// --------------------------------------------------------------------------------
// Created:		26 June 2002 by cnwdad1
//
// Purpose:		Sets the current timestamp, suitably formatted, for the status line.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	currentTimestamp	: TimeStamp;
	
begin
	lblTimestamp.caption	:=	" " &amp; currentTimestamp.date.shortFormat() &amp; " " &amp; currentTimestamp.time.format("HH:mm") &amp; "";
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="d1ee5790-a98c-48ba-a3ca-0e498cca5d0b">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;
// --------------------------------------------------------------------------------
// Created:		30 July 2002 by cnwdad1
//
// Purpose:		Passes this event on to the Form Interface class for processing.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.aMyFormInterface &lt;&gt; null then
		self.aMyFormInterface.sendMsgWithParams(method.name, eventType, theObject, eventTag);
	endif;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tableDragAndDrop" id="46f64e17-0658-41c1-ad35-2947160f780a">
        <updating/>
        <source>tableDragAndDrop(pTheTable: Table input; pXPos:Real; pYPos:Real) updating, protected;
// --------------------------------------------------------------------------------
// Created:		15 July 2002 by cnwdad1
//
// Purpose:		Processes the drag and drop event for the specified table control.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theListbox			: ListBox;
	listPointer			: Integer;
	targetPath			: String;
	nodeType			: Integer;
	targetNodeOption	: Integer;
	isTargetSet			: Boolean;
	isTargetUnix		: Boolean;
	
begin
	if (not self.aAllCutAndPasteObjects.isEmpty()) then
		// First, we must check that the user has selected a target directory in
		// the appropriate listbox.
		if pTheTable = tblFilesTop then
			theListbox	:=	lstDirTop;
		elseif pTheTable = tblFilesBottom then
			theListbox	:=	lstDirBottom;
		else
			return;
		endif;
		
		listPointer	:=	theListbox.listIndex;
		
		if listPointer = JSS_NULL_INDEX then
			isTargetSet	:=	false;
		else
			if self.aMyDragFromControl = pTheTable and self.aDragFromIndex &lt;&gt; 0 then
				if self.aDragFromIndex = listPointer then
					return;		// Can't do drag-drop onto the source of the drag-drop.
				endif;
			endif;
			
			isTargetSet	:=	true;
			targetPath	:=	self.listGetQualifiedName(theListbox, listPointer);
			nodeType	:=	theListbox.itemData[listPointer];
		endif;
		
		if isTargetSet then
			isTargetUnix	:=	false;
			
			if nodeType = self.LISTBOX_NODE_LOCAL_FOLDER or nodeType = self.LISTBOX_NODE_LOCAL_FILE then
				targetNodeOption	:=	JSSFMFileManagerService.NODE_TARGET_CLIENT;
			elseif nodeType = self.LISTBOX_NODE_APP_SERVER_FOLDER or nodeType = self.LISTBOX_NODE_APP_SERVER_FILE then
				targetNodeOption	:=	JSSFMFileManagerService.NODE_TARGET_APPSERVER;
				isTargetUnix		:=	self.aIsUnixAppServer;
			elseif nodeType = self.LISTBOX_NODE_DB_SERVER_FOLDER or nodeType = self.LISTBOX_NODE_DB_SERVER_FILE then
				targetNodeOption	:=	JSSFMFileManagerService.NODE_TARGET_DBSERVER;
				isTargetUnix		:=	self.aIsUnixDbServer;
			else
				return;
			endif;
			
			self.doPasteSelectedNodes(targetPath, targetNodeOption, isTargetUnix);
			self.aDragFromIndex		:=	0;
			self.aMyDragFromControl	:=	null;
		else
			app.msgBox(	"A target directory has not been selected.",
						"Copy Error",
						MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
			return;
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pTheTable" type="Table" usage="input"/>
        <Parameter name="pXPos" type="Real"/>
        <Parameter name="pYPos" type="Real"/>
    </JadeMethod>
    <JadeMethod name="tableIsAnyRowsSelected" id="7ac278a4-0307-4dc1-ae79-9c78f5e8bee2">
        <source>tableIsAnyRowsSelected(pTheTable:Table):Boolean protected;
// --------------------------------------------------------------------------------
// Created:		01 July 2002 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether any of the specified
//				table's rows is selected.
//
// Parameters:	pTheTable - The table control whose rows to check.
//
// Returns:		True if a row is selected, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theTable	: Table;
	rowPointer	: Integer;
	rowCount	: Integer;
	startRow	: Integer;
	
begin
	theTable	:=	pTheTable;
	rowCount	:=	theTable.rows;
	startRow	:=	theTable.fixedRows + 1;
	
	foreach rowPointer in startRow to rowCount do
		if self.tableIsRowSelected(theTable, rowPointer) then
			return true;
		endif;
	endforeach;
	
	return false;
end;</source>
        <access>protected</access>
        <Parameter name="pTheTable" type="Table"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tableIsRowSelected" id="568ca6d9-ccbf-4ba7-9224-26d8abcccd5d">
        <source>tableIsRowSelected(pTable:Table; pRow:Integer):Boolean protected;
// --------------------------------------------------------------------------------
// Created:		27 June 2002 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the specified row in the
//				specified table is selected.
//
// Parameters:	pTheTable - The table control whose rows to check.
//				pRow - The row to check for selection.
//
// Returns:		True if the row is selected, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	startColumn		: Integer;
	columnCount		: Integer;
	columnPointer	: Integer;
	
begin
	startColumn	:=	pTable.fixedColumns + 1;
	columnCount	:=	pTable.columns;
	
	foreach columnPointer in startColumn to columnCount do
		if pTable.getCellSelected(pRow, columnPointer) then
			return true;
		endif;
	endforeach;
	
	return false;
end;</source>
        <access>protected</access>
        <Parameter name="pTable" type="Table"/>
        <Parameter name="pRow" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tableLoadDirectoryContents" id="94a22565-f059-4045-8092-1ee3eb1e2eb5">
        <updating/>
        <source>tableLoadDirectoryContents(pTheTable:Table input; pTheListbox:ListBox) updating, protected;
// --------------------------------------------------------------------------------
// Created:		29 June 2002 by cnwdad1
//
// Purpose:		Populates the specified table with the contents of the currently
//				selected directory in the specified listbox.
//
// Parameters:	pTheTable - The table to populate with the directory's contents.
//				pTheListbox - The listbox with the selected directory.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theTable		: Table;
	theContainer	: JSSFMFolder;
	theNode			: JSSFMFileNode;
	rowPointer		: Integer;
	theTableCell	: JadeTableCell;
	totalFileCount	: Integer;
	totalFileSize	: Decimal[23];
	pathName		: String;
	listPointer		: Integer;
	nodeType		: Integer;
	isValidNode		: Boolean;
	isAppServer		: Boolean;
	isUnix			: Boolean;
	
begin
	theTable		:=	pTheTable;
	self.initializeTable(theTable);
	totalFileCount	:=	0;
	totalFileSize	:=	0;
	
	listPointer		:=	pTheListbox.listIndex;
	
	if listPointer = JSS_NULL_INDEX then
		self.aCurrentTablePath	:=	null;
		self.aCurrentTableNode	:=	0;
		
		isValidNode	:=	false;
	else
		isValidNode	:=	true;
	endif;
	
	if isValidNode then
		nodeType				:=	pTheListbox.itemData[listPointer];
		pathName				:=	self.listGetQualifiedName(pTheListbox, listPointer);
		self.aCurrentTablePath	:=	pathName;
		self.aCurrentTableNode	:=	nodeType;
		
		create theContainer transient;
		
		// Fetch the files and folder nodes from the relevant node.
		
		isUnix	:=	false;
		
		if nodeType = self.LISTBOX_NODE_DB_SERVER_FOLDER then
			isUnix		:=	self.aIsUnixDbServer;
			self.doFetchDirectoryContentsServer(pathName, isUnix, theContainer);
		elseif nodeType = self.LISTBOX_NODE_APP_SERVER_FOLDER then
			isAppServer	:=	true;
			isUnix		:=	self.aIsUnixAppServer;
			self.doFetchDirectoryContentsClient(pathName, theContainer, isAppServer, isUnix);
		elseif nodeType = self.LISTBOX_NODE_LOCAL_FOLDER then
			isAppServer	:=	false;
			self.doFetchDirectoryContentsClient(pathName, theContainer, isAppServer, isUnix);
		else
			isValidNode	:=	false;
		endif;
		
		// Now add the details of each node to the table control.
		
		if isValidNode
		and (not theContainer.allFileNodes.isEmpty())
		then
			foreach theNode in theContainer.allFileNodes do
				totalFileCount	:=	totalFileCount + 1;
				totalFileSize	:=	totalFileSize + theNode.fileSize;
				rowPointer		:=	theTable.addItem(theNode.getTableDisplay());
				theTableCell	:=	theTable.accessCell(rowPointer, 1);
				
				if theNode.fileNodeFlag = JSSFMFileNode.NODE_FLAG_FOLDER then
					theTableCell.picture	:=	picHolderClosed.picture;
					
				elseif theNode.fileNodeFlag = JSSFMFileNode.NODE_FLAG_FILE then
					theTableCell.picture	:=	picHolderFile.picture;
					
				else
					theTableCell.picture	:=	null;
				endif;
			endforeach;
		endif;
	endif;
	
	self.statusSetObjectCount(totalFileCount, totalFileSize);
	self.statusSetSelectedCount(theTable);
	self.statusResizeObjectCounts();
epilog
	delete theContainer;
end;</source>
        <access>protected</access>
        <Parameter name="pTheTable" type="Table" usage="input"/>
        <Parameter name="pTheListbox" type="ListBox"/>
    </JadeMethod>
    <JadeMethod name="tableMouseDown" id="2152c52d-898b-4437-a292-658d15528989">
        <updating/>
        <source>tableMouseDown(pTheTable: Table input; pButtonId: Integer; pShift:Integer; pXPos: Real; pYPos: Real) updating, protected;
// --------------------------------------------------------------------------------
// Created:		27 June 2002 by cnwdad1
//
// Purpose:		Processes the mouseDown event for the specified table control.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theTable		: Table;
	actualXPos		: Real;
	actualYPos		: Real;
	rowPointer		: Integer;
	columnPointer	: Integer;
	startRow		: Integer;
	rowCount		: Integer;
	
begin
	theTable	:=	pTheTable;
	theTable.click(theTable);
	theTable.setFocus();
	
	if pButtonId = Window.MouseButton_Left then
		if pShift.bitAnd(1) &lt;&gt; 0 then
			// By default, when doing a multi-select using the shift key, the rows
			// in the middle of the selection are not fully selected, only the cells
			// within the column that was clicked are selected.  The following is a
			// workaround to fully select all cells of every row within the selection
			// range.
			startRow	:=	theTable.fixedRows + 1;
			rowCount	:=	theTable.rows;
			
			foreach rowPointer in startRow to rowCount do
				if self.tableIsRowSelected(theTable, rowPointer) then
					self.tableSelectRow(theTable, rowPointer);
				endif;
			endforeach;
			
			return;
		endif;
		
		theTable.getCellFromPosition(pXPos, pYPos, rowPointer, columnPointer);
		
		if rowPointer &gt; theTable.fixedRows and rowPointer &lt;= theTable.rows then
			self.aIsLeftMouseDown	:=	true;
			self.aDragFromIndex		:=	0;
			self.aMyDragFromControl	:=	null;
			self.aMyMenuList		:=	null;
			self.aMyMenuTable		:=	theTable;
		endif;
		
		self.tableSelectRow(theTable, theTable.row);
		
	elseif pButtonId = Window.MouseButton_Right then
		self.menuEnableForTable(theTable);
		
		actualXPos	:=	pXPos;
		actualYPos	:=	pYPos;
		
		self.getRelativeWindowPosition(theTable, actualXPos, actualYPos);
		popupMenu(mnuFile, actualXPos.Integer, actualYPos.Integer);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pTheTable" type="Table" usage="input"/>
        <Parameter name="pButtonId" type="Integer"/>
        <Parameter name="pShift" type="Integer"/>
        <Parameter name="pXPos" type="Real"/>
        <Parameter name="pYPos" type="Real"/>
    </JadeMethod>
    <JadeMethod name="tableMouseMove" id="fda1c379-c6d1-4732-a32b-5ce110035d1f">
        <updating/>
        <source>tableMouseMove(pTheTable: Table input; pButtonId: Integer; pXPos: Real; pYPos: Real) updating, protected;
// --------------------------------------------------------------------------------
// Created:		15 July 2002 by cnwdad1
//
// Purpose:		Processes the mouseMove event for the specified table control.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	IS_CUT_AND_PASTE	: Boolean = false;
	
vars
	rowPointer		: Integer;
	columnPointer	: Integer;
	theListbox		: ListBox;
	listPointer		: Integer;
	
begin
	if pButtonId = Window.MouseButton_Left and self.aIsLeftMouseDown then
		pTheTable.getCellFromPosition(pXPos, pYPos, rowPointer, columnPointer);
		
		if rowPointer &gt; pTheTable.fixedRows
		and rowPointer &lt;= pTheTable.rows
		and self.dragMode &lt;&gt; Form.DragMode_Drag
		then
			if pTheTable = tblFilesTop then
				theListbox	:=	lstDirTop;
			elseif pTheTable = tblFilesBottom then
				theListbox	:=	lstDirBottom;
			else
				return;
			endif;
			
			listPointer	:=	theListbox.listIndex;
			
			if listPointer =JSS_NULL_INDEX then
				return;
			elseif self.aMyDragFromControl = pTheTable and self.aDragFromIndex &lt;&gt; 0 then
				if self.aDragFromIndex = rowPointer then
					return;		// Can't do drag-drop onto the source of the drag-drop.
				endif;
			endif;
			
			self.dragMode			:=	Form.DragMode_Drag;
			self.aDragFromIndex		:=	rowPointer;
			self.aMyDragFromControl	:=	pTheTable;
			self.menuCopyCut(IS_CUT_AND_PASTE);
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pTheTable" type="Table" usage="input"/>
        <Parameter name="pButtonId" type="Integer"/>
        <Parameter name="pXPos" type="Real"/>
        <Parameter name="pYPos" type="Real"/>
    </JadeMethod>
    <JadeMethod name="tableMouseUp" id="b71f249d-666d-4009-9080-29b5bcb18c53">
        <updating/>
        <source>tableMouseUp() updating, protected;
// --------------------------------------------------------------------------------
// Created:		15 July 2002 by cnwdad1
//
// Purpose:		Processes the mouseUp event for the specified table control.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.aIsLeftMouseDown then
		self.aIsLeftMouseDown	:=	false;
		self.aAllCutAndPasteObjects.purge();
		self.dragMode			:=	Form.DragMode_None;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="tableRemoveFileNode" id="9469fb1b-7392-4bed-94ef-99802e640caa">
        <source>tableRemoveFileNode(pTheTable:Table input; pFileNodeName:String) protected;
// --------------------------------------------------------------------------------
// Created:		17 July 2002 by cnwdad1
//
// Purpose:		Removes the row of a file/directory from the specified table, which
//				has the specified name.
//
// Parameters:	pTheTable - The table control to remove the row from.
//				pFileNodeName - The name of the file/directory to remove.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theTable		: Table;
	rowPointer		: Integer;
	startRow		: Integer;
	rowCount		: Integer;
	checkName		: String;
	nodeName		: String;
	
begin
	nodeName	:=	pFileNodeName.toUpper();
	theTable	:=	pTheTable;
	startRow	:=	theTable.fixedRows + 1;
	rowCount	:=	theTable.rows;
	
	foreach rowPointer in startRow to rowCount do
		checkName	:=	theTable.getCellText(rowPointer, 7).toUpper();
		
		if checkName = nodeName then
			theTable.removeItem(rowPointer);
			break;
		endif;
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="pTheTable" type="Table" usage="input"/>
        <Parameter name="pFileNodeName" type="String"/>
    </JadeMethod>
    <JadeMethod name="tableRenameFileNode" id="1123c34d-0bc7-4464-b90e-177d455ebea8">
        <source>tableRenameFileNode(pTheTable:Table input; pOldNodeName:String; pNewNodeName:String) protected;
// --------------------------------------------------------------------------------
// Created:		17 July 2002 by cnwdad1
//
// Purpose:		Changes the name of a file or directory in the specified table.
//
// Parameters:	pTheTable - The table containing the file/directory to rename.
//				pOldNodeName - The original file/directory name.
//				pNewNodeName - The new file/directory name.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theTable		: Table;
	rowPointer		: Integer;
	startRow		: Integer;
	rowCount		: Integer;
	checkName		: String;
	oldNodeName		: String;
	newNodeName		: String;
	fileNodeName	: String;
	namePosition	: Integer;
	
begin
	oldNodeName	:=	pOldNodeName.toUpper();
	newNodeName	:=	pNewNodeName;
	theTable	:=	pTheTable;
	startRow	:=	theTable.fixedRows + 1;
	rowCount	:=	theTable.rows;
	
	foreach rowPointer in startRow to rowCount do
		checkName	:=	theTable.getCellText(rowPointer, 7).toUpper();
		
		if checkName = oldNodeName then
			theTable.setCellText(rowPointer, 7, newNodeName);
			
			// Strip out the file node name from the whole path name.
			
			namePosition	:=	newNodeName.reversePos(JSS_SEPARATOR_WIN) + 1;
			
			if namePosition &gt; 1 and namePosition &lt;= newNodeName.length then
				fileNodeName	:=	newNodeName[namePosition:end];
				theTable.setCellText(rowPointer, 2, fileNodeName);
			endif;
			
			break;
		endif;
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="pTheTable" type="Table" usage="input"/>
        <Parameter name="pOldNodeName" type="String"/>
        <Parameter name="pNewNodeName" type="String"/>
    </JadeMethod>
    <JadeMethod name="tableSelectRow" id="93635b7e-96e1-4d05-92d2-312bcc9f7c44">
        <updating/>
        <source>tableSelectRow(pTheTable:Table input; pRow:Integer) updating, protected;
// --------------------------------------------------------------------------------
// Created:		27 June 2002 by cnwdad1
//
// Purpose:		Selects a row in the specified table, by selecting each cell in the
//				specified row.
//
// Parameters:	pTheTable - The table control to select the row in.
//				pRow - The row number to select.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	IS_CELL_SELECTED	: Boolean = true;
	
vars
	theTable		: Table;
	startColumn		: Integer;
	columnCount		: Integer;
	columnPointer	: Integer;
	
begin
	theTable	:=	pTheTable;
	
	if theTable.row &lt;= theTable.fixedRows then
		return;
	endif;
	
	startColumn	:=	theTable.fixedColumns + 1;
	columnCount	:=	theTable.columns;
	
	foreach columnPointer in startColumn to columnCount do
		theTable.setCellSelected(pRow, columnPointer, IS_CELL_SELECTED);	
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="pTheTable" type="Table" usage="input"/>
        <Parameter name="pRow" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tableSort" id="f600e3a6-340a-48b4-b672-68aa98959e71">
        <source>tableSort(pTheTable:Table) protected;
// --------------------------------------------------------------------------------
// Created:		29 June 2002 by cnwdad1
//
// Purpose:		Sorts the specified table by the currently selected column.
//
// Parameters:	pTheTable - The table control to sort.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//11 Nov 2013	cnwrs1	make date time sort work
// --------------------------------------------------------------------------------
vars
	theTable		: Table;
	columnPointer	: Integer;
	
begin
	theTable		:=	pTheTable;
	columnPointer	:=	theTable.column;
	
	if columnPointer = 1 then
		theTable.sortColumn[1]	:=	1;
		theTable.sortColumn[2]	:=	2;
		theTable.sortType[1]	:=	Table.SortType_Alpha;
		theTable.sortType[2]	:=	Table.SortType_Alpha;
	else
		theTable.sortColumn[1]	:=	columnPointer;
		
		if columnPointer = 2 then
			theTable.sortType[1]	:=	Table.SortType_Alpha;
			
		elseif columnPointer = 3 then
			theTable.sortType[1]	:=	Table.SortType_Numeric;
			
		elseif columnPointer = 4 then
			theTable.sortType[1]	:=	Table.SortType_Alpha;//Table.SortType_TimeStamp;
			
		elseif columnPointer = 5 then
			theTable.sortType[1]	:=	Table.SortType_Alpha;
			
		endif;
	endif;
	
	theTable.resort();
end;</source>
        <access>protected</access>
        <Parameter name="pTheTable" type="Table"/>
    </JadeMethod>
    <JadeMethod name="tblFilesBottom_click" id="b2857fe3-9a15-4626-8d89-58b754f73f80">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblFilesBottom_click(table: Table input) updating;
// --------------------------------------------------------------------------------
// Created:		27 June 2002 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.setState(Busy);
	
	if table.row &lt;= table.fixedRows then
		self.tableSort(table);
	else
		self.statusSetSelectedCount(table);
		self.statusResizeObjectCounts();
	endif;
epilog
	self.setState(Idle);
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblFilesBottom_dragDrop" id="ee789968-7e71-4b4a-9db6-930dc0819c3b">
        <controlMethod name="Table::dragDrop"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblFilesBottom_dragDrop(table: Table input; win: Window input; x: Real; y: Real) updating;
// --------------------------------------------------------------------------------
// Created:		15 July 2002 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.setState(Busy);
	self.tableDragAndDrop(table, x, y);
epilog
	self.setState(Idle);
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="tblFilesBottom_mouseDown" id="d78da6ac-4158-4b48-b9d2-91cdedeccf0c">
        <controlMethod name="Table::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblFilesBottom_mouseDown(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// --------------------------------------------------------------------------------
// Created:		27 June 2002 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if (not button = Window.MouseButton_Right) then
		self.setState(Busy);
	endif;
	
	self.getServiceInterfaceSettings();
	self.tableMouseDown(table, button, shift, x, y);
epilog
	self.setState(Idle);
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="tblFilesBottom_mouseMove" id="798a9761-98ba-4d5b-bd9e-a277ae14f638">
        <controlMethod name="Table::mouseMove"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblFilesBottom_mouseMove(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// --------------------------------------------------------------------------------
// Created:		15 July 2002 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.tableMouseMove(table, button, x, y);
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="tblFilesBottom_mouseUp" id="05bcaff2-8801-475a-a311-78d8bc21030f">
