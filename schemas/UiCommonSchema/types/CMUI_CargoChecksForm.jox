        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="buildCmbConfirmLocation" id="06e007d6-8472-43d8-b6dc-0aeea35884c1">
        <updating/>
        <source>buildCmbConfirmLocation(_ti : CM_TrackedItem) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
07 February 2024		jlizm1	Initial creation TFS 62142 Perform checks from voyage ops live
29 May 2024				jlika1	TFS 64049 CUX | UAT FLP - Retain previous location in Voyage Ops Live Checks
*/

vars	
	cmifComboFiller: CMIF_VoyLiveLcnCmbFiller;
	indx : Integer;	
begin

	if self.myVoyage = null then
		return;
	endif;
	
	create cmifComboFiller transient;
	cmifComboFiller.fillCmbWithPotentialLcns(self.cmbConfirmLocation, self.myVoyage, _ti);
	
	//Only set the combo box value if it is not yet set 
	if self.cmbConfirmLocation.listObject = null and self.myDefaultLocation &lt;&gt; null and self.cmbConfirmLocation.listCount &lt;&gt; 0 then
		foreach indx in 1 to self.cmbConfirmLocation.listCount do
			if self.cmbConfirmLocation.itemObject[indx] = self.myDefaultLocation then
				self.cmbConfirmLocation.listObject := self.myDefaultLocation;
				break;
			endif;
		endforeach;		
	endif;
epilog	
	delete cmifComboFiller;	
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="clickBack" id="3688e12f-5085-41c5-87b0-32e022123479">
        <source>clickBack( _ctl : Control input );
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06/05/2014	cnwndl1	Initial creation	Par 34076
15/07/2014	cnwdap1	PAR #34568 CCMS SFW 1389 Alternative Id Cargo Check
30/04/2015	cnwdap1	PAR #36094 CCMS SFW 1413 TFS 313 Cold Store Enhancements
30/01/2018	jlgdap1	TFS 36611 PEN Cannot check hazard
31/01/2024	jlika1	TFS 62154 62155 CUX | Photo Checks for Foreman Live
07/02/2024	jlizm1	TFS 62142 Perform checks from voyage ops live
*/
vars

begin

	self.shtCargoChecks.visible := true;
	self.fldMain.topSheet := self.shtCargoChecks;
	self.btnComplete.visible :=  true;
	
	self.shtAlternativeId.visible := false;				// PAR #34568
	self.shtDamage.visible := false;
	self.shtSeals.visible := false;
	self.shtDimensions.visible := false;
	self.shtWeight.visible := false;
	self.shtSpecialLifts.visible := false;
	self.shtTemperature.visible := false;				// PAR #36094
	self.shtHazards.visible := false;					// TFS 36611
	self.shtPhoto.visible := false;
	
	if self.shouldShowLocationCheck then
		self.lblConfirmLocation.visible := true;
		self.cmbConfirmLocation.visible := true;
	endif;
				
epilog

end;</source>
        <Parameter name="_ctl" type="Control" usage="input"/>
    </JadeMethod>
    <JadeMethod name="clickSave" id="5a06e96f-67d0-4bd0-b188-d483bb387888">
        <updating/>
        <source>clickSave( _ctl : Control input ) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06/05/2014	cnwndl1	Initial creation	Par 34076
22/04/2015	cnwdap1	PAR #36094 CCMS SFW 1413 TFS 313 Cold Store Enhancements
09/10/2017	jlgdap1	TFS 7204 STWR Correct real handling for non-standard locales
30/01/2018	jlgdap1	TFS 36611 PEN Cannot check hazard
06/04/2023	jlizm1	TFS 57098 EUP Seal numbers on trucks
17/01/2024	jlika1	TFS 62070 MTN - Road Gate - Cargo Checks does not save damage.
31/01/2024	jlika1	TFS 62154 62155 CUX | Photo Checks for Foreman Live
18 Dec 2024	navhl20 Bug MTN-33659: MTN - Unable to load cargo items using the complete job form if the checks are configured
*/
vars

	mess : String;
	startPos : Integer;
	endPos : Integer;
	toDoTaskCode : Integer;
	toDoTaskDesc : CM_ToDoTaskDesc;
	addingToDo : Boolean;
	doBack : Boolean;
	
begin

	app.mousePointer := self.MousePointer_HourGlass;
	
	if self.chkToDo.visible and self.chkToDo.parent = _ctl then
		addingToDo := self.chkToDo.value;
	endif;
	
	if addingToDo then
		toDoTaskDesc := self.myCurrentCheckItem.myToDoTaskDesc;
		if toDoTaskDesc &lt;&gt; null then
			toDoTaskCode := toDoTaskDesc.code;
		endif;
	endif;

	if _ctl = self.shtSeals then
		doBack := self.updateSeals();
		
		if doBack and self.myVehicleVisit &lt;&gt; null and self.myCargoChecks = null then	//18.12.2024 navhl20 #33659
			self.unloadForm();
		endif;
	
	elseif _ctl = self.shtDamage then
		doBack := self.updateDamages( toDoTaskDesc, toDoTaskCode, addingToDo, self.myTerminal );
		
	elseif _ctl = self.shtDimensions then
		doBack := self.updateDimensions( toDoTaskCode, addingToDo );
		
	elseif _ctl = self.shtWeight then
		doBack := self.updateWeight( toDoTaskCode, addingToDo );
	
	elseif _ctl = self.shtSpecialLifts then
		doBack := self.updateSpecialLifts( toDoTaskCode, addingToDo );
	
	elseif _ctl = self.shtAlternativeId then																	// PAR #34568
		doBack := self.updateAlternativeId(self.txtAlternativeId.text.trimBlanks, toDoTaskCode, addingToDo );	// PAR #34568
		
	elseif _ctl = self.shtTemperature then																							// PAR #36094
		//doBack := self.updateTemperature(self.txtTemperature.text.trimBlanks.Real, self.optCelcius.value, toDoTaskCode, addingToDo);// PAR #36094	// TFS 7204
		doBack := self.updateTemperature(self.txtTemperature.text.trimBlanks.asRealJMT, self.optCelcius.value, toDoTaskCode, addingToDo);			// TFS 7204
		
	elseif _ctl = self.shtHazards then 										// TFS 36611
		doBack := self.updateHazardToDo(toDoTaskCode, addingToDo);			// TFS 36611
	elseif _ctl = self.shtPhoto then 										
		doBack := self.updatePhoto();		
	endif;
	
	if doBack then
		app.myPassport.clearErrorsWarnings();
		self.clickBack( _ctl );
		
	endif;

epilog

	app.mousePointer :=	Idle;

end;</source>
        <Parameter name="_ctl" type="Control" usage="input"/>
    </JadeMethod>
    <JadeMethod name="confirmLocation" id="e95dc7e5-1594-46bf-aa87-8bc29122fc79">
        <updating/>
        <source>confirmLocation(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
07 February 2024		jlizm1	Initial creation TFS 62142 Perform checks from voyage ops live
29 May 2024				jlika1	TFS 64049 CUX | UAT FLP - Retain previous location in Voyage Ops Live Checks
*/

vars
	stowageController 	: CMIF_StowageConfirmController;
	newTITxn 			: CM_TITransaction;
	confirmationLocn 	: CM_LocationsController;
	theReturn			: Integer;
begin
	
	if self.myVoyage = null then
		return false;
	endif;

	if self.myTrackedItem = null then
		return false;
	endif;

	confirmationLocn := self.cmbConfirmLocation.listObject.CM_LocationsController;
	
	if confirmationLocn = null then
		global.beep;
		app.msgBox(app.getErrorString(Please_select_locati_confir_ca),app.getErrorString(Problem), MsgBox_OK_Only);
		return false;
	endif;	
	
	theReturn :=  app.msgBox(app.getErrorString1(Confirm_cargo_location, confirmationLocn.getFullId()),app.getErrorString(Confirm_location),MsgBox_Yes_No);
	
	if theReturn = MsgBox_Return_No then
		return false;
	endif;
	
	self.setDefaultLocation(confirmationLocn);
	
	create stowageController transient;
	
	stowageController.type := TRANS_TYPE_STOWAGE_CONFIRM;
	stowageController.dateTime := app.actualTimeAppServer;
	stowageController.noCharge := true;
	stowageController.userId := app.getMyUserCode;
	stowageController.myConfirmationLocation := confirmationLocn;
	stowageController.myVoyage	:= self.myVoyage;
	stowageController.myTerminal := self.myTerminal;
	stowageController.myTrackedItem := self.myTrackedItem;
	stowageController.isLoad := true;
	stowageController.myTargetLocation := confirmationLocn;
	stowageController.isForVoyage := true;
	stowageController.transferType := self.myTransferType;

	app.myPassport.warningsAcknowledged := true; 
	app.myPassport.setWarningsIgnored(true);
	
	while true do
		app.myTrxCA.trxCreateStowageConfirmNoJob(stowageController, newTITxn, app.myPassport);
		if app.myPassport.trxCompletedOK then
			return true;
		endif;
		theReturn := app.showErrorWarningDialog(app.getErrorString(Confirm_location), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
		if app.myPassport.noErrors and
		   theReturn = IDOK then
			// there must have just been warnings that the user has acknoledged so ..
			app.myPassport.warningsAcknowledged	:= true;
			continue;
		endif;
		break;
	endwhile;

	return false;
	
epilog
	delete stowageController;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createPxySealCheckDetail" id="30822df0-c479-4c25-a3ee-bde6aa4207b3">
        <source>createPxySealCheckDetail( 	_sealCheck : CM_SealCheck;
							_sealAfter : String;
							_sealBefore : String;
							_sealCheckType : Integer;
							_sealType : String;
							_viewed : Integer
							) : CM_SealCheckDetail;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 May 2014	cnwndl1	Initial creation	Par 34076

*/

vars

	sealCheckDetail : CM_SealCheckDetail;

begin

	create sealCheckDetail transient;
	sealCheckDetail.setProxy(	_sealCheck,	//_sealCheck : CM_SealCheck;
								_sealAfter,	//_sealAfter : String;
								_sealBefore,	//_sealBefore : String;
								_sealCheckType,	//_sealCheckType : Integer;
								_sealType,	//_sealType : String;
								_viewed	//_viewed : Integer;
								);
								
	return sealCheckDetail;

epilog

end;</source>
        <Parameter name="_sealCheck" type="CM_SealCheck"/>
        <Parameter name="_sealAfter" type="String"/>
        <Parameter name="_sealBefore" type="String"/>
        <Parameter name="_sealCheckType" type="Integer"/>
        <Parameter name="_sealType" type="String"/>
        <Parameter name="_viewed" type="Integer"/>
        <ReturnType type="CM_SealCheckDetail"/>
    </JadeMethod>
    <JadeMethod name="createSealCheckTransaction" id="08fa8bda-e97b-4bba-b972-d17663865f89">
        <source>createSealCheckTransaction( _proxySealCheckTrx 	: CM_SealCheck io;
							_updateSealsArray  	: CM_ObjectArray;
							_passport 			: CM_Passport input
							):CM_SealCheck;

/*

Purpose:			

Parameters:			

Return Value:		

/* Changes

Date		Name	TFS#		Description
============================================================================
06 May 2014	cnwndl1	Par 34076	Initial creation	
29 Mar 2019 jlgka1	TFS 44020	Change StringArray to HugeStringArray.
============================================================================*/

vars
	trackedItem			: CM_TrackedItem;
	theTIProxy 			: CM_TrackedItem;
	gte					: CMGTE_Receival;
	mess 				: String;
	txnController 		: CMIF_TITransactionController;
	newTITxn 			: CM_TITransaction;
	toDoTaskDescToAdd 	: CM_ToDoTaskDesc;
	tiUpdateRequired 	: Boolean;
	sealCheckTrxProxy 	: CM_SealCheck;
	obj 				: Object;
	updateSealType 		: CM_SealType;
	pxySealCheckDetail 	: CM_SealCheckDetail;
	sealAfter 			: String;
	sealBefore 			: String;
	pxySealTi 			: CM_SealTI;
	sealedDT 			: TimeStamp;
	loadState 			: Boolean;
	sealNumArray 		: HugeStringArray; // jlgka1 TFS 44020
	editFieldsValues 	: HugeStringArray; // jlgka1 TFS 44020
	gteUpdateRequired 	: Boolean;	
	receiveForm 		: CMUI_ReceiveCargoForm;
	allSealsToUpdate 	: CM_SealTIBySealTypeDict;
	sealTITrans 		: CM_SealTI;	
begin

	app.mousePointer :=	Busy;

	trackedItem := self.myTrackedItem;
	gte := self.myGTEReceival;
	if trackedItem = null and gte = null then
		mess := app.getErrorString(NO_Cargo_found);
		app.mousePointer :=	Idle;
		app.msgBox( mess, app.getErrorString(Error) , MsgBox_OK_Only);
		return null;
	endif;
	
	_proxySealCheckTrx.setMyTrackedItem(trackedItem, null);

	if trackedItem &lt;&gt; null then
		theTIProxy := trackedItem.pxyGetProxyObject;
	endif;
	if theTIProxy = null and trackedItem &lt;&gt; null then
		app.cmsBeginLoad(loadState);
		theTIProxy := trackedItem.pxyCreateUpdateProxy();
		app.cmsEndLoad(loadState);
	endif;

	create txnController transient;
	txnController.type := TRANS_TYPE_SEAL_CHECK;
	txnController.noCharge := false; // TFS 3844 changed to false
	txnController.myTrackedItem := trackedItem;
	txnController.myTITransaction := _proxySealCheckTrx;

	
	//Add the to do task to the TI proxy if required.
	toDoTaskDescToAdd := self.getToDoTaskDescToAdd( trackedItem );
	if toDoTaskDescToAdd &lt;&gt; null then
		if theTIProxy &lt;&gt; null then
			tiUpdateRequired := true;
			theTIProxy.addToDoTask( toDoTaskDescToAdd.description, _passport );
		endif;
	endif;
	
	//Update the seal values on the proxy TI, for the ones that the user said they wanted updated. (Can only happen in 'Full' mode) 
	if _updateSealsArray &lt;&gt; null and not _updateSealsArray.isEmpty then
	
		if trackedItem = null then
			//14 Jun 2017	NDL	TFS 4656
			// Doesn't make sense to record the seal data on the main form when entering a brand new unknown cargo item,
			// and then do cargo checks and record different data in the seals checks.... BUT what would I know.
			//So just update the data they entered in the Cargo checks for seals onto the main form.
			if self.myParentForm &lt;&gt; null and self.myParentForm.isKindOf( CMUI_ReceiveCargoForm ) then
				receiveForm := self.myParentForm.CMUI_ReceiveCargoForm;
				create allSealsToUpdate transient;
				foreach obj in _updateSealsArray do
					updateSealType := obj.CM_SealType;
					pxySealCheckDetail := _proxySealCheckTrx.getSealCheckDetailForSealType( updateSealType.sealType );
					if pxySealCheckDetail = null then
						// we had an object that we were supposed to make changes from and now its gone ???
						mess := app.getErrorString3(UNEXPECTED_PROGRAM_ERROR,self.class.name,method.name,"pxySealCheckDetail = null");
						app.mousePointer :=	Idle;
						app.msgBox( mess, app.getErrorString(Error) , MsgBox_OK_Only);
						return null;
					endif;
					sealAfter := pxySealCheckDetail.sealAfter;
					create sealTITrans transient;
					sealTITrans.setProxy(	sealAfter,	//_sealNum : String;
											null,	//_sealNumArray : StringArray;
											null,	//_prevSeal : String;
											updateSealType.sealType,	//_sealType : String;
											null,	//_sealedDT : TimeStamp;
											null	//_myTrackedItem : CM_TrackedItem
											);
					allSealsToUpdate.add(sealTITrans);
				endforeach;
				receiveForm.updateSealsDirectFromChecks( allSealsToUpdate );
			endif;
		else
			app.cmsBeginLoad(loadState);
			tiUpdateRequired := true;
			create editFieldsValues transient;
	
			foreach obj in _updateSealsArray do
	
				updateSealType := obj.CM_SealType;
				pxySealCheckDetail := _proxySealCheckTrx.getSealCheckDetailForSealType( updateSealType.sealType );
				if pxySealCheckDetail = null then
					// we had an object that we were supposed to make changes from and now its gone ???
					mess := app.getErrorString3(UNEXPECTED_PROGRAM_ERROR,self.class.name,method.name,"pxySealCheckDetail = null");
					app.mousePointer :=	Idle;
					app.msgBox( mess, app.getErrorString(Error) , MsgBox_OK_Only);
					return null;
				endif;
				sealAfter := pxySealCheckDetail.sealAfter;
				sealBefore := pxySealCheckDetail.sealBefore;
				// find the existing seal data on the proxy ti. If its there, update it, otherwise create it.
				pxySealTi := theTIProxy.getSealTI(updateSealType);
			
				if pxySealTi = null then
					//create it.
					create pxySealTi transient;
					sealedDT := app.actualTimeServer();
				else
					sealedDT := pxySealTi.sealedDT;
				endif;
				
				if updateSealType.allowMultipleSealNums then
					if sealAfter.pos(",",1) &gt; 0 then
						create sealNumArray transient;
						sealAfter.getTokensForDelimiterHuge(",",sealNumArray); // jlgka1 TFS 44020
					endif; 
				endif;
			
				pxySealTi.setProxy(	sealAfter,	//_sealNum : String;
									sealNumArray,	//_sealNumArray : StringArray;
									sealBefore,	//_prevSeal : String;
									updateSealType.sealType,	//_sealType : String;
									sealedDT,	//_sealedDT : TimeStamp;
									theTIProxy	//_myTrackedItem : CM_TrackedItem
									);
									
				if sealNumArray &lt;&gt; null then
					delete sealNumArray;
				endif;
				
				//gather up the edit details for the CM_Edit transaction
				self.getSealUpdateEditTransDetails( pxySealTi, editFieldsValues );
				
			endforeach;
			app.cmsEndLoad(loadState);
			
		endif;
		
	endif;
	
	app.myPassport.clearErrorsWarnings();
	app.myPassport.setWarningsIgnored(true);
	
	if theTIProxy &lt;&gt; null then
	
		app.myTrxCA.trxCreateSealsCheckTransaction( txnController, theTIProxy, tiUpdateRequired, gte, newTITxn, editFieldsValues, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			app.myPassport.clearErrorsWarnings();
			return newTITxn.CM_SealCheck;
			
		else
			mess := app.myPassport.getAllErrorsWarningsAsString;
			app.myPassport.clearErrorsWarnings();
			app.mousePointer :=	Idle;
			app.msgBox( mess, app.getErrorString(Error) , MsgBox_OK_Only);
			return null;
			
		endif;
	
	elseif gte &lt;&gt; null then
	
		//Don't create the transactions, just add a copy of the proxy seal checks details ontto the GTE
		//proxy Seal Check on the transaction has a collection of these.
		app.myTrxCA.trxCreateSealsCheckOnGTE( _proxySealCheckTrx, gte, toDoTaskDescToAdd, allSealsToUpdate, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			app.myPassport.clearErrorsWarnings();
			return null;
			
		else
			mess := app.myPassport.getAllErrorsWarningsAsString;
			app.myPassport.clearErrorsWarnings();
			app.mousePointer :=	Idle;
			app.msgBox( mess, app.getErrorString(Error) , MsgBox_OK_Only);
			return null;
			
		endif;
		
	endif;
	
epilog

	delete txnController;
	delete sealNumArray;
	delete editFieldsValues;
	delete theTIProxy;
	if allSealsToUpdate &lt;&gt; null then
		if not allSealsToUpdate.isEmpty then
			allSealsToUpdate.purge();
		endif;
		delete allSealsToUpdate;
	endif;
	app.cmsEndLoad(loadState);
	app.mousePointer :=	Idle;

end;</source>
        <Parameter name="_proxySealCheckTrx" type="CM_SealCheck" usage="io"/>
        <Parameter name="_updateSealsArray" type="CM_ObjectArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_SealCheck"/>
    </JadeMethod>
    <JadeMethod name="createSealChecksForTruck" id="f3f0b6e1-c8cc-4967-85ff-ed430c8bf57e">
        <source>createSealChecksForTruck(_pxySealCheckDetails : CM_SealCheckDetailSet; _updateSealsArray : CM_ObjectArray) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
06 April 2023		jlizm1	Initial creation TFS 57098 EUP Seal numbers on trucks

*/

vars
	vvr 				: CM_VehicleVisitRecord;
	sealsToUpdate 		: CM_SealObjectBySealTypeDict;
	obj 				: Object;
	updateSealType 		: CM_SealType;
	pxySealCheckDetail 	: CM_SealCheckDetail;
	mess 				: String;
	truckSeal			: CM_TruckSeal;
	pxyTruckSeal		: CM_TruckSeal;
	sealAfter 			: String;
	sealBefore 			: String;
	sealedDT 			: TimeStamp;
	
begin
	app.mousePointer :=	Busy;
	vvr := self.myVehicleVisit;
	
	if vvr = null then
		app.mousePointer :=	Idle;
		app.msgBox( app.getErrorString(Err_No_Vehicle_visit_selected), app.getErrorString(Error) , MsgBox_OK_Only);
		return false;
	endif;
	
	if _updateSealsArray &lt;&gt; null and not _updateSealsArray.isEmpty then
		create sealsToUpdate transient;
		foreach obj in _updateSealsArray do
			if not obj.isKindOf(CM_SealType) then
				continue;
			endif;
			updateSealType := obj.CM_SealType;
			pxySealCheckDetail := _pxySealCheckDetails.getFirstOfSealType( updateSealType.sealType );
			if pxySealCheckDetail = null then
				// we had an object that we were supposed to make changes from and now its gone ???
				mess := app.getErrorString3(UNEXPECTED_PROGRAM_ERROR,self.class.name,method.name,"pxySealCheckDetail = null");
				app.mousePointer :=	Idle;
				app.msgBox( mess, app.getErrorString(Error) , MsgBox_OK_Only);
				return null;
			endif;
			
			sealAfter := pxySealCheckDetail.sealAfter;
			sealBefore := pxySealCheckDetail.sealBefore;
			truckSeal := vvr.allTruckSeals.getTruckSeal(updateSealType);
			
			if truckSeal = null then
				sealedDT := app.actualTimeServer;
			else	
				sealedDT := truckSeal.sealedDT;
			endif;

			create pxyTruckSeal transient;
			pxyTruckSeal.setProxy(	pxySealCheckDetail.sealAfter,
									pxySealCheckDetail.sealBefore,
									updateSealType.sealType,
									sealedDT,
									vvr
									);
			sealsToUpdate.add(pxyTruckSeal);
		endforeach;
		
	endif;
	
	app.myTrxCA.trxCreateTruckSealCheckTrans(_pxySealCheckDetails, vvr, sealsToUpdate, app.myPassport);
	
	return true;
	
epilog
	app.mousePointer :=	Idle;
	delete sealsToUpdate;
	
end;</source>
        <Parameter name="_pxySealCheckDetails" type="CM_SealCheckDetailSet"/>
        <Parameter name="_updateSealsArray" type="CM_ObjectArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="displayAlternativeId" id="7bee8521-5791-4a7a-9902-28e052d0cc36">
        <source>displayAlternativeId();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 15/07/2014	cnwdap1		Initial creation PAR #34568 CCMS SFW 1389 Alternative Id Cargo Check
//
vars

begin
	if self.myTrackedItem &lt;&gt; null then
		self.txtAlternativeId.text := self.myTrackedItem.alternativeId;
	elseif self.myGTEReceival &lt;&gt; null then
		self.txtAlternativeId.text := self.myGTEReceival.alternativeId;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="displayChecksForCargo" id="bed1dea7-2267-4aef-9946-71b9bfd5d150">
        <updating/>
        <source>displayChecksForCargo() updating;
/*

Purpose:			Display checks page for selected cargo. Used when doing cargo select when in voyage ops context

Parameters:			

Return Value:		

Date				Who		Reason
01 February 2024	jlizm1	Initial creation TFS 62142 Perform checks from voyage ops live
14 February 2024	jlizm1	TFS 62437 Create edit transaction for check complete
20 Feb 2024 navhl20 ChangeRequest 62525: EUP | Retrospective Operations - [54177.060] - Cargo &amp; Truck Checks
10 Jun 2024	jlika1	TFS 64158 CUX | Configurability of Foreman checks for onboard cargo
*/

vars

	cargoCheck 		: CM_CargoCheck;
	item			: CM_CargoCheckItem;
	idx				: Integer;
	jadeCol			: JadeTableColumn;
	jadeCell		: JadeTableCell;
	str				: String;
	setting			: CM_TICargoChecks;
	cmifAutoPlan	: CMIF_YAAutoPlan;
	change			: Real;
	dummyTI			: CM_TrackedItem;
	cargoType 		: CM_CargoType;
	desc1 			: String;
	desc2 			: String;

begin
	if self.myTrackedItem = null then
		return;
	endif;
	
	self.grpCargoSelect.visible := false;
	self.grpMain.visible := true;
	self.tblCargoChecks.clear();
	self.tblCargoChecks.rows := 0;
	
	self.txtCargoId.text := self.myTrackedItem.id;	
	self.myTrackedItem.getShortDescriptions(desc1, desc2 );
	self.lblDesc1.caption := desc1;
	self.lblDesc2.caption := desc2;
	self.lblConfirmLocation.visible := false;
	self.cmbConfirmLocation.visible := false;
	
	// create an auto plan for checking criteria
	create cmifAutoPlan as CMIF_YAAutoPlanNormal transient;
	cmifAutoPlan.attachTI(self.myTrackedItem);
	
	if self.myCargoChecks = null then
		// Just go back, it's broke
		self.setupChildSelectTable();
		return;
	endif;
	
	if self.myCargoChecks.allCargoCheckItems.isEmpty then
		// No checks to do, mark as complete and return to cargo select
		app.myTrxUA.trxUpdateTICheckCompleted(self.myCargoChecks.context, true, self.myTrackedItem, self.effectiveDT, app.myPassport);			//20.02.2024 navhl20 #62525
		self.setupChildSelectTable();
		return;
	endif;
	
	// load table with current context Cargo Check Items
	foreach item in self.myCargoChecks.allCargoCheckItems discreteLock do
	
		if item.requiredExtraInfo &lt;&gt; null 
		and not item.requiredExtraInfo.isOneOf(	EXTRA_INFO_SEALS, 
												EXTRA_INFO_DAMAGE, 
												EXTRA_INFO_DIMENSION, 
												EXTRA_INFO_WEIGHT, 
												EXTRA_INFO_SPECIAL_LIFT, 
												EXTRA_INFO_ALTERNATIVE_ID,
												EXTRA_INFO_TEMPERATURE,
												EXTRA_INFO_HAZARD_SYMBOLS,
												EXTRA_INFO_PHOTO) then
			continue;
		endif;
		
		// does this tracked item match the cargo check criteria?
		if cmifAutoPlan &lt;&gt; null and not item.doesTIMatchMe(cmifAutoPlan) then
			continue;
		endif;

		idx := self.tblCargoChecks.addItem(item.name);
		self.tblCargoChecks.accessRow(idx).itemObject := item;
		
		// set cell control according to item's required extra info
		// if item is required, add two buttons Yes/No
		if item.required then
		
			self.setupCargoCheckTableYesNoBtns( self.tblCargoChecks, idx );
			
		else	
			//jlier1 TFS 62168 29/1/24
			// add a button
			self.tblCargoChecks.accessCell(idx, self.ColumnValue).picture := self.btnTick.createPicture(false, false, 32);
			// merge the second and third columns
			self.setupCargoCheckTableMergeCells( idx );	
		endif;
		
	endforeach;
	
	if self.shouldShowLocationCheck() then
		self.lblConfirmLocation.visible := true;
		self.cmbConfirmLocation.visible := true;
	endif;
	
	if not self.shouldShowLocationCheck() and self.tblCargoChecks.rows = self.tblCargoChecks.fixedRows then
		// If we hav no cargo checks in the table (because they've been filtered out by criteria on the check)
		// just mark as complete and return to cargo select
		app.myTrxUA.trxUpdateTICheckCompleted(self.myCargoChecks.context, true, self.myTrackedItem, self.effectiveDT, app.myPassport);		//20.02.2024 navhl20 #62525
		self.setupChildSelectTable();
		return;
	endif;
	
	self.tblCargoChecks.tabKey := J_key_Tab;

epilog

	delete cmifAutoPlan;
	delete dummyTI;

end;</source>
    </JadeMethod>
    <JadeMethod name="displayDamages" id="d4a04141-a238-498c-86c4-069c081dfeeb">
        <updating/>
        <source>displayDamages() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 May 2014	cnwndl1	Initial creation	Par 34076

*/

vars

	size : Integer;
	
begin

	if self.myGTEReceival &lt;&gt; null then
		self.tblDamages.initCombos(self.myGTEReceival.IF_DamageDetails);
		self.tblDamages.setTableFromDamageInterface(self.myGTEReceival.IF_DamageDetails);
		size := self.myGTEReceival.allDamageInstancesByPos.size;
	elseif self.myTrackedItem &lt;&gt; null then
		self.tblDamages.initCombos(self.myTrackedItem.IF_DamageDetails);
		self.tblDamages.setTableFromDamageInterface(self.myTrackedItem.IF_DamageDetails);
		size := self.myTrackedItem.allDamageInstancesByPos.size;
	endif;
	
	if size = self.tblDamages.rows then
		self.tblDamages.addNewRow();
	endif;
																							

epilog

end;</source>
