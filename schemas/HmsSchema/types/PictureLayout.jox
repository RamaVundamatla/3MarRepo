    <JadeMethod name="windowCreated" id="ab1cb036-cfa5-449e-a50a-d1fb7acf6136">
        <updating/>
        <source>windowCreated(cntrl : Control input; persistCntrl : Control) updating;

vars
	pl : PictureLayout;
	f  : Form;
	int: Integer;
begin
	inheritMethod(cntrl,persistCntrl);
	if not isInPainter then
		if self.hotspotBinary &lt;&gt; null then
			self.setPicture(1,self.picture);
			self.picture:=hotspotBinary;
			self.pictureIndex := 0;//
//			and canShowHotspot then
/*		self.borderStyle := 0;

		if hotspotBinary &lt;&gt; null and isChild &lt;&gt; true and mode = Draw_RunTime then
			app.currentIndex := app.currentIndex + 1;	
			pl := self.loadControl(app.currentIndex).PictureLayout;
			pl.parent 			:= self;
			pl.isChild			:= true;
			pl.myParent			:= self;
			pl.name     		:= 'pic' &amp; app.currentIndex.String;
			pl.borderStyle 		:= 0;
			pl.top				:= 0;
			pl.left				:= 0;
			pl.picture			:= self.hotspotBinary;
			pl.pictureDown 		:= null;
			pl.pictureDisabled 	:= null;
			pl.visible			:= true;
			self.myChild:= pl;*/
		endif;
	endif;

	// if the item is being extracted, switch the control mode back so that it can show the cloned items (above) at run time...
	if mode = Draw_Extract then
		mode := Draw_RunTime;
	endif;	
end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
