    <JadeMethod name="getWorkPointFirst" id="ad73d6c9-dfe6-4f4a-935d-0c9b45ee3bd4">
        <source>getWorkPointFirst():CM_WorkPoint;
/*
Purpose:			

Date		Who		Reason
13OCT2021	NAVAB1	TFS 51988
*/


vars
	queueObj : CM_RadioTelemetryQueue;
	queueItem	: CM_RadioTelemetryQueue;
	term : CM_Terminal;
begin

	queueObj := self.myQueue;

	if queueObj = null then
		return null;
	endif;
	
	foreach queueItem in queueObj.allSubQueuesById where queueItem.isWorkPointQueue do	
		return queueItem.CM_VoyageWorkPointQueue.myWorkPoint;
 	endforeach;
	
	return null;
end;</source>
        <ReturnType type="CM_WorkPoint"/>
    </JadeMethod>
    <JadeMethod name="getWorkPointWithNoJS" id="2f49d369-bf59-42d2-be1e-c582d05686cb">
        <source>getWorkPointWithNoJS():CM_WorkPoint;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 June 2012	cnwndl1	Initial creation	Par 29621

*/

vars
	queueObj : CM_RadioTelemetryQueue;
	queueItem	: CM_RadioTelemetryQueue;
	term : CM_Terminal;
begin

	queueObj := self.myQueue;

	if queueObj = null then
		return null;
	endif;
	
	foreach queueItem in queueObj.allSubQueuesById where queueItem.isWorkPointQueue do	
		if not self.hasWorkPointGotJS(queueItem.CM_VoyageWorkPointQueue.myWorkPoint) then
			return queueItem.CM_VoyageWorkPointQueue.myWorkPoint;
		endif;
 	endforeach;
	
	return null;
end;</source>
        <ReturnType type="CM_WorkPoint"/>
    </JadeMethod>
    <JadeMethod name="getWorkStartedAtTS" id="60396320-e5f1-4036-9da6-d3718fcf4b22">
        <source>getWorkStartedAtTS() : TimeStamp;
/*
Purpose:			

Date		Who		Reason
30 June 2022	navab1	TFS 53105
*/

vars
	workedStartedAt: TimeStamp;
begin
	
	workedStartedAt := self.shipExchangeDate;
	if not workedStartedAt.isValid() then
		
		workedStartedAt := self.labourOnBoard;
		if not workedStartedAt.isValid() then
			workedStartedAt := self.arrivedDT;
			if not workedStartedAt.isValid() then
				workedStartedAt := self.estimatedArrivalDT;
				if not workedStartedAt.isValid() then
					workedStartedAt := app.actualTimeServer;
				endif;
			endif;
		endif;
	endif;


	return workedStartedAt;
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getWorkTotalMovesCompleted" id="f55914e2-b449-488b-9560-e292c26bd422">
        <source>getWorkTotalMovesCompleted() : Integer;
// ---------------------------------------------------------------------------
// Created:		January 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
