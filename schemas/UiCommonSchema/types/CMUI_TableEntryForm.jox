    <JadeMethod name="doCancel" id="62ea5034-adbc-4dd4-9f35-e0f10af9b59b">
        <updating/>
        <source>doCancel() updating;
// ---------------------------------------------------------------------------
// Created:     05 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars

begin
	self.myCurrentView := null;
	self.modalResult := MsgBox_Return_Cancel;
	unloadForm();

end;</source>
