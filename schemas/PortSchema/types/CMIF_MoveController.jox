    <JadeMethod name="setMyOriginatingLocation" id="4fd9d19f-1674-43a8-a5a3-432c37d0f191">
        <updating/>
        <source>setMyOriginatingLocation(value: CM_LocationsController) updating;
/*
 ------------------------------------------------------------------------
Created:			24 September 2001 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	obj : Object;
	invalidObj : Boolean;
	edition : Integer;
	locid	: String;
begin
	obj:=value;
	//epr 5/3/12 par 29208 
	on Exception do app.handleDeletedObject(exception,obj, invalidObj);

	if self.myOriginatingLocation &lt;&gt; value then 
		if obj &lt;&gt; null then
			edition:=obj.edition;
		endif;
		
		if invalidObj then
			self.myOriginatingLocation := null;
		else
			self.myOriginatingLocation := value;
		endif;
		//par#12662 cnwmo1 13/10/2006
		if value &lt;&gt; null then
			locid := value.getFullIdAndLevel(self.myTrackedItem, self.moveMode, false); // 08/1/2015 cnwma1 PAR #35491 
			if locid &lt;&gt; null then
				self.myOriginatingLocationString := locid[1:30];
			endif;
		endif;
		
	endif;
end;</source>
        <Parameter name="value" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="setMyPackRelease" id="1acbc89a-ccb2-45ff-b2f5-df21824ac527">
        <updating/>
        <source>setMyPackRelease( _packRelease : CM_BulkRelease input) updating;
/*

Date		Who		Reason
05 December 2016	cnwer1	Initial creation TFS 2897

*/

vars

begin
	if _packRelease = null then
		return;
	endif;
	
	if not _packRelease.isPackingType() then
		return;
	endif;
	
	self.myPackRelease :=_packRelease;
epilog

end;</source>
