	if form = null then
		form := app.loadForm(YRD_TrainArrivalForm, CMUI_Assistant, false, false, false, self.myTerminal, null).YRD_TrainArrivalForm;
	endif;
	
	form.setParentForm(self);
	form.myCurrentTrain := self.myCurrentTrain;
	form.showModal();
	/*
	now := app.actualTimeServer();
	
	self.lblTrainArrival.caption := "Train Arrival For " &amp; self.myCurrentTrain.code;
	
	if self.myCurrentTrain.arrivalDT.isValid() then
		self.mskTrainArrDT.setDate(self.myCurrentTrain.arrivalDT.date);
		self.mskTrainArrTM.setTime(self.myCurrentTrain.arrivalDT.time);
	else
		self.mskTrainArrDT.setDate(now.date);
		self.mskTrainArrTM.setTime(now.time);
	
	endif;
	
	self.btnTrainArrSave.setFocus();
	*/
epilog

end;</source>
