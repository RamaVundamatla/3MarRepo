    <JadeMethod name="setFromLocActRepThroughPutSum" id="c7bc814c-a8ab-4b38-9668-bf0b6b33723b">
        <updating/>
        <source>setFromLocActRepThroughPutSum( _tPutSum : CMIF_LocActRepThroughPutSum; _selectedMonth : Integer )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 June 2021	navndl1	Initial creation	TFS 51245

*/

vars

begin

	self.count := 0;
	self.modeString := _tPutSum.modeString;
	self.modeInt := _tPutSum.modeInt;
	self.myCargoType := _tPutSum.myCargoType;
	self.myOperator := _tPutSum.myOperator;
	self.yearMonth := _selectedMonth;
	self.typeString := _tPutSum.typeString;
	self.weight := 0;

epilog

end;</source>
        <Parameter name="_tPutSum" type="CMIF_LocActRepThroughPutSum"/>
        <Parameter name="_selectedMonth" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setFromLocationActivity" id="c48ff4a0-6f70-4385-b52d-b730d0743662">
        <updating/>
        <source>setFromLocationActivity( _locAct : CMEVT_LocationActivity; _yearMonth : Integer; _count : Integer ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 June 2021	navndl1	Initial creation	TFS 51245

*/

vars

	

begin

	self.count := _count;
	self.modeString := _locAct.directionMode;
	self.modeInt := _locAct.movementDirection;
	self.myCargoType := _locAct.getCargoType;
	self.myOperator := _locAct.getOperator;
	self.yearMonth := _yearMonth;
	self.typeString := _locAct.directionType;
	self.weight := _locAct.weight;

epilog

end;</source>
        <Parameter name="_locAct" type="CMEVT_LocationActivity"/>
        <Parameter name="_yearMonth" type="Integer"/>
        <Parameter name="_count" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="writeDebugLine" id="ea4446af-c537-4799-99c6-36d851a05662">
        <source>writeDebugLine():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 June 2021	navndl1	Initial creation	TFS 51245

*/

vars

	str : String;

begin

	str :=	self.yearMonth.String &amp; ", " &amp; Tab &amp;
			self.myOperator.code &amp; ", " &amp; Tab &amp;
			self.myCargoType.abbreviation &amp; ", " &amp; Tab &amp;
			self.typeString[1:3] &amp; ", " &amp; Tab &amp;
			self.modeString &amp; ", " &amp; Tab &amp;
			self.getWeightAsST &amp; ", " &amp; Tab &amp;
			self.getWeightYTDAsST &amp; ", " &amp; Tab &amp;
			self.count.asStringJMT &amp; ", " &amp; Tab &amp;
			self.countYTD.asStringJMT;
			
	return str;


epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
