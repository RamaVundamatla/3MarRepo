    <JadeMethod name="getObjects" id="5bd41e07-1d07-435c-bb64-1c98a9d54602">
        <source>getObjects(objects: ObjectLongNameDict input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/08/2023	navkc1	CR 59594  Task 59584: Jade - CustDocs New YA Criteria
18/08/2023	navkc1	CR 59603 Task 59604: UI - CustDocs More Stop Criteria
*/

vars
	shipLineStatus : CM_ShippingLineStatus;
	terminal		: CM_Terminal;
	userTerm	: CM_UserTerminal;
	user		: CM_User;
begin
	
	user := app.getMyUser();
	
	foreach userTerm in user.allUserTerminals do
		terminal := userTerm.getMyTerminal();
		
		foreach shipLineStatus in terminal.allShippingLineStatus do
			objects[shipLineStatus.getYAIdentifier()] := shipLineStatus;
		endforeach;
		
	endforeach;
	
epilog

end;</source>
        <Parameter name="objects" type="ObjectLongNameDict" usage="input"/>
    </JadeMethod>
