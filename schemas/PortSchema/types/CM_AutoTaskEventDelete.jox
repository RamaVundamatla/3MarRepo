    <JadeMethod name="getEventTypesStr" id="54d2c8ec-20bd-4455-871e-4f58c31fdf10">
        <source>getEventTypesStr() : String protected;
/*
----------   ----------  --------------------------------------------------
Created:	27 July 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	eventTypeInt	: Integer;
	eventType		: CM_EventType;
	str			: String;
begin
	foreach eventTypeInt in self.allEventTypes do
		eventType := app.myRoot.allEventTypesByType [eventTypeInt];
		if eventType &lt;&gt; null then
			str := str &amp; eventType.name &amp; ',';
		endif;
	endforeach;

	return str;
end;


</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getValueForRow" id="b8a5e5fc-282d-48fe-985a-1be42fa1914b">
        <source>getValueForRow(_rowName: String; _obj: Object output): Any;
/*
----------   ----------  --------------------------------------------------
Created:	26 July 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if _rowName = ETRow_BgpAutoNoDaysOldEvent then
		return self.daysOld.String;
	elseif _rowName = ETRow_BgpAutoEventTypes then
		//return self.getEventTypesStr();
		return self.allEventTypes;
	endif;
	return inheritMethod(_rowName, _obj);
	

end;


</source>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_obj" type="Object" usage="output"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="530902a3-9bc0-424c-a26d-c472d6a2e9c4">
        <source>pxyCreateUpdateProxy(): SelfType;
/*
----------   ----------  --------------------------------------------------
Created:	30 July 2007 By cnwth2

Purpose:	

Changed On   	Changed By  Reason
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy	
----------   ----------  --------------------------------------------------
*/
vars
	pxySelf			: SelfType;
	completedOK		: Boolean;
begin
	pxySelf := inheritMethod();
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxySelf;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxySelf;
	endif;	
end;


</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="52b25be0-fe2c-426b-925a-3bb125054fb9">
        <updating/>
        <source>setForCreate(_pxyAutoTask: CM_AutoTaskEventDelete) updating;
/*
----------   ----------  --------------------------------------------------
Created:	26 July 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	inheritMethod(_pxyAutoTask);
	self.allEventTypes.clear();
	_pxyAutoTask.allEventTypes.copy(self.allEventTypes);
	self.daysOld := _pxyAutoTask.daysOld;
	
	self.requestClassName := BGP_EventDeleteRequest.name;

end;


</source>
        <Parameter name="_pxyAutoTask" type="CM_AutoTaskEventDelete"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="53174b1f-4442-4939-a8cd-bac77d4910ca">
        <updating/>
        <source>setForUpdate(_pxyAutoTask: CM_AutoTaskEventDelete) updating;
/*
----------   ----------  --------------------------------------------------
Created:	26 July 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	inheritMethod(_pxyAutoTask);
	self.allEventTypes.clear();
	_pxyAutoTask.allEventTypes.copy(self.allEventTypes);
	self.daysOld := _pxyAutoTask.daysOld;

end;


</source>
        <Parameter name="_pxyAutoTask" type="CM_AutoTaskEventDelete"/>
    </JadeMethod>
    <JadeMethod name="setValueForRow" id="1d645162-5533-4b88-bad8-7747d48e1616">
        <updating/>
        <source>setValueForRow(_rowName: String; _value: Any) updating;
/*
----------   ----------  --------------------------------------------------
Created:	26 July 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	obj			: Object;
	objArray			: ObjectArray;
begin
	if _rowName = ETRow_BgpAutoNoDaysOldEvent then
		self.daysOld := _value.Integer;
	elseif _rowName = ETRow_BgpAutoEventTypes then
		objArray := _value.ObjectArray;
		self.allEventTypes.clear();
		foreach obj in objArray do
			self.allEventTypes.add(obj.CM_EventType.type);
		endforeach;
	
	endif;
	
	inheritMethod(_rowName, _value);


end;


</source>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="validate" id="10cf7bf6-6597-4f9b-ba22-3373ec34eb7f">
        <source>validate();
/*
----------   ----------  --------------------------------------------------
Created:	26 July 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	inheritMethod();
	if self.allEventTypes.isEmpty then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Event Types', ETRow_BgpAutoEventTypes, null);
		app.raiseCMException(Input_required_field_EvtTypes, ETRow_BgpAutoEventTypes, null); // cnwdb2	PAR 35364


	endif;

end;


</source>
    </JadeMethod>
</Class>
