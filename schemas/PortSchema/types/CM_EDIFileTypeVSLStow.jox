    <DbClassMap file="edi"/>
    <JadeMethod name="create" id="30ea0abf-a3fc-4ee6-8074-47ef16ef6be4">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     10 September 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.name	:= "Navis VSLStow";
	self.type	:= EDIFileType_VSLStow;
end;</source>
    </JadeMethod>
    <JadeMethod name="createSummary" id="9ce58773-4041-437f-b69a-5852348563a8">
        <updating/>
        <source>createSummary(_voyage : CM_Voyage; _dict : CMIF_ExportStiffByISODischLoad input) updating;
// ---------------------------------------------------------------------------
// Created:     cnwyl1  Yi Liu
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	filter			: CMQF_ExportStiff;
	passport		: CM_Passport;
begin
	create filter transient;
	passport := app.myPassport;
	
	filter.allTerminals.add(app.myPassport.myTerminal);
	filter.setMyVoyage( _voyage );

	filter.filterObjects(_dict, passport);
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_dict" type="CMIF_ExportStiffByISODischLoad" usage="input"/>
    </JadeMethod>
    <JadeMethod name="extractFile" id="26a71f92-5d83-4b22-bfbb-494c9b674a2d">
        <updating/>
        <source>extractFile(_ediFile: CM_EDIFile io; _number: Integer; _recipient: CM_Operator) updating;
//
//12 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
//
//15 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
vars
	ediDataStowAdvice	: CM_EDIDataStowAdvice;
	ediTI				: CM_EDITrackedItem;
	operatorOid			: CM_Operator;
	voyageOid			: CM_Voyage;
	now					: TimeStamp;
	terminal			: CM_Terminal;
	ediData				: CM_EDIData;
	fromPort,
	toPort				: String;
	dict	: CMIF_ExportStiffByISODischLoad;
	str : String;
begin
	ediData := _ediFile.ediData;
	if (not CM_EDIDataStowAdvice.hasInstance(ediData)) then
		app.raiseCMException2(ERR_INVALID_EDI_FORMAT, self.name, ediData.class.name, null, null);
		return;
	endif;

	ediDataStowAdvice := ediData.CM_EDIDataStowAdvice;
	terminal := app.myPassport.myTerminal;
	
	voyageOid := terminal.lookupVoyage(ediDataStowAdvice.voyageCode, null, false);
	fromPort := ediDataStowAdvice.fromPort;
	toPort := ediDataStowAdvice.toPort;
	
	// Header
	str := str &amp; "*VSLSTOW" &amp; Tab &amp; "1" &amp; Tab &amp; "1" &amp; Tab &amp; now.date.format("dd/MM/yy") &amp;  now.time.format(" hh:mm") &amp; Tab &amp; "STANDARD" &amp; Tab &amp; "NAVIS SPARCS 2.9o60" &amp; CrLf;
	str := str &amp; "*MKT" &amp; Tab &amp; voyageOid.vesselName &amp; Tab &amp; voyageOid.code &amp; Tab &amp; fromPort &amp; CrLf;
	str := str &amp; "* PROJECTION KEYS" &amp; CrLf;
	
	//column
	str := str &amp; "PROJPOOLID" &amp; Tab &amp; 
							"PROJCOUNT" &amp; Tab &amp; 
							"EQUIPTYPEISO" &amp; Tab &amp; 
							"CMHEIGHT" &amp; Tab &amp; 
							"KGWEIGHT" &amp; Tab &amp; 
							"OWNER" &amp; Tab &amp; 
							"LIVEREEFER" &amp; Tab &amp; 
							"LOADPORT" &amp; Tab &amp; 
							"DISCHPORT" &amp; Tab &amp;
							"DESTINATION" &amp; Tab &amp; 
							"FULLSTATUS" &amp; Tab &amp; 
							"IMOCODE" &amp; Tab &amp; 
							"REEFERTEMP" &amp; Tab &amp; 
							"OVRHEIGHT" &amp; Tab &amp; 
							"OVRWIDERIGHT" &amp; Tab &amp; 
							"OVRWIDELEFT" &amp; Tab &amp; 
							"BOOKING" &amp; Tab &amp; 
							"DG1" &amp; Tab &amp; 
							"DG2" &amp; Tab &amp; 
							"DG3" &amp; Tab &amp; 
							"DG4" &amp; Tab &amp; 
							"DG5" &amp; Tab &amp; 
							"DG6" &amp; Tab &amp; 
							"DG7" &amp; Tab &amp; 
							"DG8" &amp; Tab &amp; 
							"DG9" &amp; Tab &amp; 
							"UPPERTEMP" &amp; Tab &amp; 
							"LOWERTEMP" &amp; CrLf;
	str := str &amp; "* POOLS" &amp; CrLf;
	
	create dict transient;
	
	self.createSummary(voyageOid,dict);
	//body
	str := str &amp; self.extractPools(_ediFile, dict);
	str := str &amp; "* PROJECTIONS" &amp; CrLf;
	str := str &amp; "* END OF FILE" &amp; CrLf;
	_ediFile.setRawDataString(str);
	_ediFile.writeFile();
end;
</source>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="io"/>
        <Parameter name="_number" type="Integer"/>
        <Parameter name="_recipient" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="extractPools" id="2162c984-4a75-4ae2-b221-f19a86c2b351">
        <updating/>
        <source>extractPools(_ediFile: CM_EDIFile io; _dict	: CMIF_ExportStiffByISODischLoad) : String updating;
//
//15 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
//
vars
	cmif : CMIF_ExportStiffSum;
	id : Integer;
	count : Integer;
	isoType : String;
	height : Decimal[14,4];
	weight : Decimal[14,4];
	owner  : String;
	liveReefer : String;
	loadPort : String;
	dischPort : String;
	destination : String;
	fullStatus : String;
	reeferTemp : Real;
	msg : String;
	//the following fields are reserved.
	imoCode : String;
	
	ovrHeight : Integer;
	ovrWideRight : Integer;
	ovrWideLeft : Integer;
	booking : String;
	dg1, dg2, dg3, dg4, dg5, dg6, dg7, dg8, dg9 : String;
	upperTemp : Integer;
	lowerTemp : Integer;
	str : String;
begin
	id := 1;
	imoCode := null;
	//reeferTemp := null;
	ovrHeight := 0;
	ovrWideRight := 0;
	ovrWideLeft := 0;
	booking := null; 
	dg1 := null;
	dg2 := null;
	dg3 := null;
	dg4 := null;
	dg5 := null;
	dg6 := null;
	dg7 := null;
	dg8 := null;
	dg9 := null;
	upperTemp := 0;
	lowerTemp := 0;
	owner := null;
	
	foreach cmif in _dict do
		count := cmif.totalQuantity;
		isoType := cmif.isoType;
		height := cmif.height;
		weight := cmif.weight;
		liveReefer := cmif.liveReefer;
		loadPort := cmif.loadPort;
		dischPort := cmif.dischPort;
		fullStatus := cmif.fullStatus;
		reeferTemp := cmif.reeferTemp;
		
		msg := id.String &amp; Tab &amp; 
				count.String &amp; Tab &amp; 
				isoType &amp; Tab &amp; 
				height.String &amp; Tab &amp; 
				weight.asStringWeightJMT() &amp; Tab &amp; 
				owner &amp; Tab &amp; 
				liveReefer &amp; Tab &amp; 
				loadPort &amp; Tab &amp; 
				dischPort &amp; Tab &amp; 
				destination &amp; Tab &amp;
				fullStatus &amp; Tab &amp;
				imoCode &amp; Tab &amp;
				reeferTemp.String &amp; Tab &amp;
				ovrHeight.String &amp; Tab &amp;
				ovrWideRight.String &amp; Tab &amp;
				ovrWideLeft.String &amp; Tab &amp;
				booking &amp; Tab &amp;
				dg1 &amp; Tab &amp; dg2 &amp; Tab &amp; dg3 &amp; Tab &amp; dg4 &amp; Tab &amp; dg5 &amp; Tab &amp; dg6 &amp; Tab &amp; dg7 &amp; Tab &amp; dg8 &amp; Tab &amp; dg9 &amp; Tab &amp;
				upperTemp.String &amp; Tab &amp;
				lowerTemp.String;
			
		id := id + 1;
		str := str &amp; msg &amp; CrLf;
	endforeach;
	return str;
end;
</source>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="io"/>
        <Parameter name="_dict" type="CMIF_ExportStiffByISODischLoad"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="findEDIDataType" id="8cf477c5-5d4d-4bbf-a519-2b75c7007887">
        <source>findEDIDataType(_ediDataClass: Class io; _dataType, _fileTypeCode: Integer io); // cnwrs1 Par 24207 ccms 1117 11 May 2010
//----------------------------------------------------------------
//	Created:	27 August 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	_ediDataClass := CM_EDIDataStowAdvice;
	_dataType := EDIDataType_StowAdvice;
	_fileTypeCode := self.type;

end;</source>
        <Parameter name="_ediDataClass" type="Class" usage="io"/>
        <Parameter name="_dataType" type="Integer" usage="io"/>
        <Parameter name="_fileTypeCode" type="Integer" usage="io"/>
    </JadeMethod>
