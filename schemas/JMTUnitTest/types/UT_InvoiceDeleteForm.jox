    <JadeMethod name="btnProcess_click" id="413a97cb-3b09-42fd-92a5-a1c5e372409a">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnProcess_click(btn: Button input) updating;

/*

Purpose:		

Date			Who		Reason
14 February 2014	cnwmh5	Initial creation

*/

vars

	index						: Integer;

begin

	if self.txtStartDate.text.Date &gt; self.txtEndDate.text.Date then
		app.msgBox("Start Date &gt; End Date", "Date Error", MsgBox_Information_Icon + MsgBox_OK_Only);
		self.txtStartDate.setFocus();
		return;
	endif;
	
	if self.txtStartDate.text &lt;&gt; null and self.txtEndDate.text = null then
		app.msgBox("End Date cannot be Blank", "Date Error", MsgBox_Information_Icon + MsgBox_OK_Only);
		self.txtEndDate.setFocus();
		return;
	endif;
	
	if self.txtEndDate.text &lt;&gt; null and self.txtStartDate.text = null then
		app.msgBox("Start Date cannot be Blank", "Date Error", MsgBox_Information_Icon + MsgBox_OK_Only);
		self.txtStartDate.setFocus();
		return;
	endif;

	// get the selected terminals
	foreach index in 1 to self.lstTerminals.listCount step 1 do
		if self.lstTerminals.itemSelected[index] then
			self.utdsl.UT_Scripts.terminalArray.add(self.lstTerminals.itemObject[index].CM_Terminal);
		endif;	
	endforeach;
	
	if self.utdsl.UT_Scripts.terminalArray.isEmpty() then
		app.msgBox("Please selected a terminal for Post Invoices for.", "Terminal Error", MsgBox_Information_Icon + MsgBox_OK_Only);
		self.lstTerminals.setFocus();
		return;
	endif;
	
	self.unloadForm();
	
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
