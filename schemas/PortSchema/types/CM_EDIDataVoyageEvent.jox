    <JadeMethod name="verifyEDIDataTIs" id="305506b6-4349-4386-83d6-8129a11b9559">
        <updating/>
        <source>verifyEDIDataTIs(_passport: CM_Passport input): Integer updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
29 July 2022		jlizm1	Initial creation TFS 54165 EDI Voyage Events
22 july 2025 navsaa30 MTN -35271 - Fix tVoyageEvent Unit Test
*/

vars

	ediTI : CM_EDITrackedItem;
	errorSet : CM_ErrorSet;
	status : Integer;
	exceptionStatus	: Boolean;
	
begin
	exceptionStatus := app.continueCMExceptions;		//navsaa30 #35271 22/7/2025
	app.setContinueCMExceptions(true);
	on Exception do validationExceptionHandler(exception, _passport);
	create errorSet transient;
	_passport.moveErrorsToSet(errorSet);
	
	foreach ediTI in self.allEDITrackedItems do
		ediTI.verifySelf();
		if _passport.hasErrors then
			status := CM_EDITrackedItem.EDI_STATUS_VERIFIED_ERRORS;
		else
			status := CM_EDITrackedItem.EDI_STATUS_VERIFIED;
		endif;
		
		app.myTrxUA.trxUpdateEDITIStatus(ediTI, status, _passport);
		_passport.moveErrorsToSet(errorSet);
	endforeach;
	
	_passport.addErrorsFromSet(errorSet);
	return _passport.allErrorWarnings.size;
	
epilog
	app.setContinueCMExceptions(exceptionStatus);	//navsaa30 #35271 22/7/2025
	delete errorSet;
	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
