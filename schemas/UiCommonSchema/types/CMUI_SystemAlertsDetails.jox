    <JadeMethod name="displayActivity" id="d5a65be6-288d-4ec1-af82-128db7d1a694">
        <updating/>
        <source>displayActivity() protected, updating;
// -------------------------------------------
// Created 29 March 2004 by cnwdvb1
// -------------------------------------------
vars
	idx 		: Integer;
	lColour		: Integer;
	ls			: Boolean;
	array		: HugeStringArray;
	str			: String;
	activity	: CM_ActivityHistory;
	
begin
	app.cmsBeginLoad(ls);
	
//	if self.myActivityHistory = null then
	if self.myObject = null then
		self.unloadForm();
		return;
	endif;
	
	activity := self.myObject.CM_ActivityHistory;
	
	if not global.isValidObject(activity) then  // cnwrd1 par #16737 28.7.2008
		return;
		endif;
		
	create array transient;	
	if not activity.getDetailForDisplay(array) then
		self.unloadForm();
		return;
	endif;

	foreach str in array do
		idx := self.tblAlerts.addItem(str);
		if idx mod 2 = 0 then
			lColour := self.clrOne.backColor;
		else
			lColour := self.clrTwo.backColor;
		endif;
		self.tblAlerts.accessRow(idx).backColor := lColour;
	endforeach;

epilog
	delete array;
	app.cmsEndLoad(ls);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="displayAlerts" id="ee7c8b50-6ac9-4295-8546-4394a92e28a6">
        <updating/>
        <source>displayAlerts() updating, protected;
// ---------------------------------------------------------------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	tmpHeight,
	idx 		: Integer;
	lColour 	: Integer;
	ls 			: Boolean;
	strs 		: CM_Strings;
	array 		: HugeStringArray;
	str 		: String;
	alert		: CM_SystemAlert;
	rowObj		: JadeTableRow;
	colObj		: JadeTableColumn;
	
begin
	app.cmsBeginLoad(ls);
	
	create array transient;
	
	//if self.mySystemAlert = null then
	if self.myObject = null then
		self.unloadForm();
		return;
	endif;
	
	alert := self.myObject.CM_SystemAlert;
	
	if alert.hasDetails  = false then
		return;
	endif;
	
	strs := alert.logDetails;
	strs.getStrings(array);
	colObj := self.tblAlerts.accessColumn(1);
	
	foreach str in array do
		idx := self.tblAlerts.addItem(str);
		
		if idx mod 2 = 0 then
			lColour := self.clrOne.backColor;
		else
			lColour := self.clrTwo.backColor;
		endif;
		
		self.tblAlerts.accessRow(idx).backColor := lColour;
		//self.tblAlerts.accessRow(idx).backColor := lColour;
		rowObj	:= self.tblAlerts.accessedRow;
		tmpHeight := rowObj.height;
		tmpHeight := tmpHeight.max(self.tblAlerts.getTextHeightForWidth(str, colObj.width) + 4);
		rowObj.height := tmpHeight;
		rowObj.wordWrap := true;
	endforeach;

	self.setCaption("Alerts Details (" &amp; (self.tblAlerts.rows - 1).String &amp; " Items)");
epilog
	delete array;
	app.cmsEndLoad(ls);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="displayEmailRequest" id="2ae24b9a-0d49-4cdc-9aee-b239c906cc42">
        <updating/>
        <source>displayEmailRequest() updating, protected;
/* ---------------------------------------------------------------------------
Created:     16 September 2008 by cnwrs2

Purpose:     
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars
	idx 		: Integer;
	lColour		: Integer;
	ls			: Boolean;
	array		: HugeStringArray;
	str			: String;
	emailRequest	: BGP_EmailSendRequest;
	
begin
	if self.myObject = null then
		self.unloadForm();
		return;
	endif;
	
	emailRequest := self.myObject.BGP_EmailSendRequest;
	
	create array transient;	
	if not emailRequest.getDetailForDisplay(array) then
		self.unloadForm();
		return;
	endif;

	foreach str in array do
		idx := self.tblAlerts.addItem(str);
		if idx mod 2 = 0 then
			lColour := self.clrOne.backColor;
		else
			lColour := self.clrTwo.backColor;
		endif;
		self.tblAlerts.accessRow(idx).backColor := lColour;
	endforeach;
epilog
	delete array;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="displayInformation" id="c6a978d4-f0ec-4206-91a1-6e9261f177c4">
        <updating/>
        <source>displayInformation() protected, updating;
// -------------------------------------------
// Created 21 September 2005 by cnwdvb1
// -------------------------------------------
/*

Date		Who		Reason
28 Feb 2012	cnwkpd1	PAR #29165 - CCMS SFW 1272 - Reduce physical database size
	
*/

vars
	tmpHeight,
	idx 		: Integer;
	lColour		: Integer;
	ls			: Boolean;
	str			: String;
	information	: CM_Information;
	rowObj		: JadeTableRow;
	colObj		: JadeTableColumn;
	infoLines	: StringArray512;
	
begin
	app.cmsBeginLoad(ls);
	
//	if self.myActivityHistory = null then
	if self.myObject = null then
		self.unloadForm();
		return;
	endif;
	
	self.tblAlerts.wordWrap		:=	true;
	self.tblAlerts.alignment	:=	Table.Alignment_Left_Top;
	
	information := self.myObject.CM_Information;
	
	colObj := self.tblAlerts.accessColumn(1);
	
	// PAR #29165 - Change to use method to handle possible XML storage option
	create infoLines transient;
	information.getInformationLines(infoLines);
	
	foreach str in infoLines do
		idx	:=	self.tblAlerts.addItem(str);
		
		if idx mod 2 = 0 then
			lColour := self.clrOne.backColor;
		else
			lColour := self.clrTwo.backColor;
		endif;
		
		self.tblAlerts.accessRow(idx).backColor := lColour;
		rowObj	:= self.tblAlerts.accessedRow;
		tmpHeight := rowObj.height;
		tmpHeight := tmpHeight.max(self.tblAlerts.getTextHeightForWidth(str, colObj.width) + 4);
		rowObj.height := tmpHeight;
		rowObj.wordWrap := true;
	endforeach;
	
epilog
	delete infoLines;
	app.cmsEndLoad(ls);
	
end;</source>
        <access>protected</access>
    </JadeMethod>
