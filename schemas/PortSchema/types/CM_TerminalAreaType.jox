    <JadeMethod name="findTransferAreaForTerminal" id="bb72ed33-cea7-40f7-8b2c-30324f8ba3ef">
        <source>findTransferAreaForTerminal(_terminal : CM_Terminal) : CM_InterTerminalTransferArea;
// -------------------------------------------
// Created 22 July 2004 by cnwdvb1
// -------------------------------------------
vars

	iter		: Iterator;
	area		: CM_InterTerminalTransferArea;

begin

	if self.type &lt;&gt; TA_TYPE_INTERTERM_TRANS_AREA then
		app.raiseCMException1(ERR_INVALID_TA_ID, self.description, null, null);
		return null;
	endif;
	
	iter := self.allTerminalAreasByTerminal.createIterator();
	while iter.next(area) do
		if area.myOtherTerminalTransferArea.myTerminal = _terminal then
			return area;
		endif;
	endwhile;
	return null;

epilog
	delete iter;
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="CM_InterTerminalTransferArea"/>
    </JadeMethod>
    <JadeMethod name="getAllTAsForGantryLaneAreaType" id="6009f25e-9c03-46ef-a1cb-b54e7601b9f8">
        <source>getAllTAsForGantryLaneAreaType(_terminal: CM_Terminal; _coll : Collection input);
/*

Purpose:		returns all valid terminal areas for a type of gantry lane i.e. either rtg or rmg	

Parameters:			

Return Value:		


Date		Who		Reason
23 September 2009	cnwer1	Initial creation

*/

vars
	iter : Iterator;
	typeToFind : Integer;
	ta		: CM_TerminalArea;
begin
	if _coll = null or _terminal = null then
		return;
	endif;
	
	if self.type = TA_TYPE_RTG_LANE then
		typeToFind:=TA_TYPE_RTG;
	elseif self.type = TA_TYPE_RMG_LANE then
		typeToFind:=TA_TYPE_RMG;
	else
		//only 2 options
		return;
	endif;
	
	iter:=_terminal.allTerminalAreasByTypeId.createIterator;
	_terminal.allTerminalAreasByTypeId.startKeyGeq(typeToFind,null,iter);
	while iter.next(ta) do
		if ta.type &lt;&gt; typeToFind then
			return;
		endif;
		_coll.add(ta);
	endwhile;
epilog
	delete iter;

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_coll" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAreasForTerminal" id="95b039a3-50dc-45ed-a851-f83c5bcc8278">
        <source>getAreasForTerminal(_areas: Collection input; _terminal: CM_Terminal);
//----------------------------------------------------------------
//	Created:	30 March 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	iter		: Iterator;
	area		: CM_TerminalAreaMaster;
begin
	if _areas = null
	or _terminal = null then
		return;
	endif;
	
	iter := self.allTerminalAreasByTerminal.createIterator();
	self.allTerminalAreasByTerminal.startKeyGeq(_terminal, null, iter);
	
	while iter.next(area) do
		if area.myTerminal &lt;&gt; _terminal then
			break;
		endif;
		_areas.add(area);
	endwhile;
	
epilog
	delete iter;	
end;</source>
        <Parameter name="_areas" type="Collection" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="a48e1839-b648-45de-b41e-fea653f15716">
        <source>getAuditText(): String;
// ---------------------------------------------------------------------------
// Created:     15 March 2007 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------

vars
	txt		: String;
	tmpStr	: String;
	port    : CM_Port;
begin
	txt[10000] := '*';
	txt := null;
	txt := inheritMethod();
	return txt;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCMIFTAClassToCreate" id="48f1816b-3b4a-4c93-bac5-144e59327538">
        <source>getCMIFTAClassToCreate(): Class;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 July 2009	cnwer1	Initial creation
15 Jul 2013  cnwer1		removed trailer area references 
*/

vars

begin
	if self.isGantryAreaType then
		return CMIF_RTGArea;
	elseif self.type = TA_TYPE_FORK_LIFT_STACK or self.type = TA_TYPE_STRADDLE_STACK  then
		return CMIF_GridArea;
	else
		return CMIF_TerminalArea;
	endif;

epilog

end;</source>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="getFirstAreaForTerminal" id="b3edeb45-553b-4eba-92d5-e0b36542179b">
        <source>getFirstAreaForTerminal(_terminal : CM_Terminal) : CM_TerminalArea;

// Created by cnwdvb1 on 18 January 2007

vars

	iter		: Iterator;
	area		: CM_TerminalArea;
begin

	if _terminal = null then
		return null;
	endif;
	
	iter := self.allTerminalAreasByTerminal.createIterator();
	self.allTerminalAreasByTerminal.startKeyGeq(_terminal, null, iter);
	
	while iter.next(area) do
		if area.myTerminal &lt;&gt; _terminal then
			break;
		endif;
		
		return area;
	endwhile;
	
epilog
	delete iter;	

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="CM_TerminalArea"/>
    </JadeMethod>
