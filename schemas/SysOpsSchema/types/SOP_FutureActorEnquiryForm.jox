    <JadeMethod name="cmbCargoType_lostFocus" id="f5ee5552-cd58-48a5-ad2f-8833bfec5223">
        <controlMethod name="CMUI_ComboBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbCargoType_lostFocus(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 June 2024	navra1	Initial creation for //navra1 - TFS 60149/Task 64397 - 13th June 2024

*/

vars
	cargoType : CM_CargoType;
begin		
	
	if cmbCargoType.listObject.CM_CargoType &lt;&gt; null then
		self.searchCargoTypeId := cmbCargoType.listObject.CM_CargoType.description;
	else
		self.searchCargoTypeId := null;
	endif;
	if process.isRam() then
		cargoType := app.myRoot.allCargoTypesByDescription[self.searchCargoTypeId];
		if cargoType = null then
			write "All CargoTypes" &amp; " with self.searchCargoTypeId = " &amp; self.searchCargoTypeId.String &amp; " value";
		else
			write  '(' &amp; cargoType.description &amp; ')' &amp; ' - ' &amp; cargoType.abbreviation.display;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbRequestType_lostFocus" id="9867ab93-5c92-4895-a70e-4e89c43251f7">
        <controlMethod name="CMUI_ComboBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbRequestType_lostFocus(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 June 2024	navra1	Initial creation for //navra1 - TFS 60149/Task 64397 - 12th June 2024

*/

vars

begin
	self.searchRequestType := cmbRequestType.text;
	if self.searchRequestType = "&lt;&lt;ALL FUTURE ACTORS&gt;&gt;" then
		self.searchRequestType := "";
	endif;
	if process.isRam() then
		if self.searchRequestType = "" then
			write "All Future actors";
		else	
			write self.searchRequestType;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbTerminal_lostFocus" id="236b56f5-9ccd-45bb-adde-df88e395995e">
        <controlMethod name="CMUI_ComboBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbTerminal_lostFocus(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 June 2024	navra1	Initial creation for //navra1 - TFS 60149/Task 64397 - 12th June 2024

*/

vars
	terminal : CM_Terminal;
begin
	if cmbTerminal.listObject.CM_Terminal &lt;&gt; null then
		self.searchTerminalCode := cmbTerminal.listObject.CM_Terminal.code;
	else
		self.searchTerminalCode := '';
	endif;
	
	if process.isRam() then
		terminal := app.myRoot.allTerminals[self.searchTerminalCode];
		if terminal = null then
			write "All Terminals";
		else
			write terminal.code;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
