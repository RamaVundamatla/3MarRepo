    <JadeMethod name="setInverseReferences" id="fc6a4316-df2c-46ee-a01c-8c7fc25280c2">
        <updating/>
        <source>setInverseReferences() updating;
// -------------------------------------------
// Created 29 March 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	self.myRoot 				:= self.myRootNoInverse;
	self.myTerminal				:= self.myTerminalNoInverse;
	self.myRootNoInverse		:= null;
	self.myTerminalNoInverse	:= null;
	if self.myTerminal &lt;&gt; null then
		self.myTerminal.causeEvent(self.myTerminal.getTerminalEvent(EventTerminalActivityAdd), false, self);	
	elseif self.myRoot &lt;&gt; null then
		self.myRoot.causeEvent(EventSystemActivityAdd, false, self);
	endif;


end;</source>
    </JadeMethod>
    <JadeMethod name="setProxy" id="4ed231b7-9364-4323-84b3-87130ed60db7">
        <updating/>
        <source>setProxy(_type : Integer; _terminal : CM_Terminal; _temp: Boolean) updating;
// -------------------------------------------
// Created 29 March 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	self.activityType			:= _type;
	self.dateTime				:= self.createdTime;
	if _terminal &lt;&gt; null then
		self.myTerminalNoInverse	:= _terminal;
	else
		self.myRootNoInverse 		:= app.myRoot;
	endif;
	self.temp := _temp;
end;</source>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_temp" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validate" id="46ceded8-28f0-4a63-8c7f-8c4f5b8ea2e4">
        <source>validate();
// -------------------------------------------
// Created 29 March 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	if self.myRootNoInverse = null and self.myTerminalNoInverse = null then	
	//	app.raiseCMException1(REQUIRED_FIELD, 'CM_Root/CM_Terminal', null, null);
		app.raiseCMException(Input_required_field_cmRotCmTr, null, null); // cnwdb2	PAR 35364
		return;
	endif;

	if not self.dateTime.isValid then
		app.raiseCMException1(ERR_INVALID_TIMESTAMP, null,  null, null);
		return;
	endif;
	
	if self.description = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Description), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Description), null, null); // cnwdb2	PAR 35364
		return;
	endif;


end;</source>
    </JadeMethod>
</Class>
