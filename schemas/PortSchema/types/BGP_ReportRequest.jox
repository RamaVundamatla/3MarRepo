    <JadeMethod name="postReportRunProcessing" id="59d7069b-33c9-4ee0-9159-cd9e70724385">
        <updating/>
        <source>postReportRunProcessing(_pxyJadeReport : JadeReport; _blob : Binary io; _pxyFilter : CMQF_FilterReports) protected, updating;
/*

Purpose:			
		This is where the output from the reports gets dealt with.
		Reports that are in file format e.g csv, html etc arrive as a blob
		The jade report object carries anything that isn't a file
		If the report is pdf it arrives as a jadereport but is turned into
		a pdf blob by the pdf generator. It is then attached to the menu user report object.
		Any report that has been turned into a blob can now be emailed at the bottom of the method. 
Parameters:			

Return Value:		

Date		Who		Reason
26 Aug 2003 cnwdvb1
24 Apr 2013	cnwcs5	par 30652 - remove resynch/resynchObject method calls
03 Jan 2013	cnwrs1	32983 crash after user deleted.
03 Mar 2020 cnwma1	Bug 48769: PNL - FW: Report Standard (1048). (Update outside transaction)
14 Mar 2025	jlizm1	MTN 34050 BGP Reports not being received by customer
13 Jan 2026 navah1	MTN-36669: PEN | Report Generation - SFTP Reports
*/

vars
	email 				: CM_EmailTemplate;
	sender,
	heading,
	ext,
	msg,
	physicalPrinter,
	extraFilterInfo		: String;
	printer				: CM_PrinterDef;
	isPDF				: Boolean;
	ftpEntity			: CM_FTPEntity;
begin	

	ext		 := app.getExtension(self.outputDestination);
	printer  := self.getPrinter(self.printerName);
	
	if printer = null then
		msg := 'Cannot determine printer type';
		app.writeLog(msg, LogINFO);							//25 Nov 2019	NDL	TFS 47053
		
	else
		isPDF		    := printer.printerIsPDF;			// and app.getMyUser.canDo(app.getMyTerminalDO_NOT_USE, PmPDFBackground);
		physicalPrinter := printer.physicalPrinterName;
		msg   		    := 'Is PDF ' &amp; isPDF.String;
		app.writeLog(msg, LogINFO);							//25 Nov 2019	NDL	TFS 47053		
	endif;
	
	if (self.outputDestination = JadeReportWriterReport.PRINTER or self.outputDestination = CM_QryReport.PDF_Format) and _pxyJadeReport &lt;&gt; null then
		if _pxyJadeReport.printArray.size &lt; 1 then 			//there were probably extra criteria in the design itself that caused there to be no output
			msg := 'Bailing because no pages generated';
			app.writeLog(msg, LogINFO);						//25 Nov 2019	NDL	TFS 47053
			
			app.myTrxUA.trxUpdateMenuUserReportErrMsg(self.myReportTemplate, CM_MenuUserReport.MSG_NO_ITEMS_FOUND, app.myPassport);
			if (not app.myPassport.trxCompletedOK) then
				app.raiseCMException1(BackgroundErrorGeneral, 'trxUpdateMenuUserReport failed', null, null);
				//????
			endif;
		else
			if isPDF then
				_blob := self.doPrintPDF(printer, _pxyJadeReport, self.myReportTemplate, false);
				ext   := BGP_EmailSendRequest.PDF;
				if _blob = null then
					app.writeLog("No binary received from pdf printer", LogINFO);
				endif;
			else

				if self.outputType = Save or self.outputType 	= SaveAndPrint or self.outputType = 0 then
					msg := 'Saving report output to menu object';
					app.writeLog(msg, LogINFO);								//25 Nov 2019	NDL	TFS 47053
					
					beginTransaction; 										//03.03.2020  cnwma1 #48769
					self.myReportTemplate.cloneJadeReport(_pxyJadeReport);
					commitTransaction;
				endif;	
				if self.outputType = Print or self.outputType = SaveAndPrint then
					// We want to print to a specific printer. Not just preview.
					msg := 'Attempting to print report to printer (' &amp; self.printerName &amp; ')';
					app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
					
					//	if self.setPrinter(physicalPrinter) then
					if self.setPrinter(self.printerName) then	//11 Mar 2016	NDL	TFS 1593
						app.printer.printPreview := false;
						app.printerFixPAR34782(_pxyJadeReport);
						app.printer.printReport(_pxyJadeReport);
					endif;
				endif;
			endif;
		endif;
	endif;	
	
	if (self.outputDestination &lt;&gt; JadeReportWriterReport.PRINTER or isPDF) and
		(_blob &lt;&gt; null) then
		
		if self.myReportTemplate.name &lt;&gt; null then
			heading := self.myReportTemplate.name &amp; ext;			
		elseif self.myReportDef.heading &lt;&gt; null then
			heading := self.myReportDef.heading &amp; ext;
		endif;
				
		// CCMS 1292.
		self.saveReportOutputToNetworkPath(heading);
		
		if self.myReportTemplate.myEmailTemplate &lt;&gt; null then
			// CCMS 1325
			if app.myQAFilter.isNoDataReport and self.myReportTemplate.stopEmailWhenNoDataRpt then
				// Don't send email.
			else
				email := self.myReportTemplate.myEmailTemplate;
				if email.useExtraInfoInSubjectLine then
					// CCMS 1327
					extraFilterInfo := _pxyFilter.getExtraInfoString();
					if extraFilterInfo &lt;&gt; null then
						extraFilterInfo := '/' &amp; extraFilterInfo;
					endif;
				endif;
				msg := 'Emailing report';
				app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
				
				
				sender := app.myRoot.getConfig(AutoSendersEmailAddress).String;
				// We want to do some CSV emailing.
				app.myTrxCA.trxCreateEmailSendRequest(app.getErrorString1(Background_Report, heading) &amp; ' ' &amp; app.getErrorString(User) &amp; ' ' &amp; self.getUserCode(), 
													email.getAllToAddressesOrNames(false), 
													sender, 
													email.getAllCCAddressesOrNames(false), 
													email.getAllBCCAddressesOrNames(false), 
													email.subject &amp; extraFilterInfo,
													email.body, 
													null,
													null,
													_blob, 
													heading, 
													EmailSource_Reports, 
													self.myReportTemplate, 
													app.myPassport);
				if not app.myPassport.trxCompletedOK then
					app.remoteErrorWarningToAlert('Could not send email', 
												  null,
												  app.myPassport.allErrors,
												  null,
												  false,
												  true);
				endif;
			endif;
		endif;
	endif;
	
	if self.outputType = self.FTP_SFTP then //13.01.2026 navah1 #MTN-36669
		ftpEntity := self.myReportTemplate.myFTPEntity;
		if ftpEntity &lt;&gt; null then
			if ftpEntity.isSFTP() then
				self.sendSFTP(_blob);
			endif;
		endif;
	endif;
	
	if self.outputType &lt;&gt; self.Print then
		self.myReportTemplate.sendCreatedEvent(true);
	endif;
	
	self.removeMenuItems();

end;</source>
        <access>protected</access>
        <Parameter name="_pxyJadeReport" type="JadeReport"/>
        <Parameter name="_blob" type="Binary" usage="io"/>
        <Parameter name="_pxyFilter" type="CMQF_FilterReports"/>
    </JadeMethod>
    <JadeMethod name="removeMenuItems" id="f76ab6dd-c7b1-4b0d-ad5e-f426980c168b">
        <updating/>
        <source>removeMenuItems() updating, protected;
//
// cnwdvb1 05 May 2003 
//
//03 Jan 2013	cnwrs1	32983 crash after user deleted.
vars
	menuItem	: CM_MenuUserItem;
	set			: CM_MenuUserItemSet;
	msg : String;
begin	

	if self.outputType = Print and self.outputDestination = JadeReportWriterReport.PRINTER then
		create set transient;
		self.myReportTemplate.allMenuUserReports.copy(set);
		beginTransaction;
		msg := 'Removing output from user report menu';
		app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
		
		foreach menuItem in set do
			menuItem.CM_MenuUserReport.sendEvent(CM_User.BGP_REPORT_DELETED, false);
			// Menu item is not inversed up as a parent to request because we can removed menu
			// item before we delete request. Most times though it is in charge and the delete trx
			// keeps track of the clean up.
			delete menuItem;
		endforeach;
		commitTransaction;
	endif;
		
epilog
	delete set;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="runReport" id="f893c53b-9624-4ae0-820e-f215690f79e0">
        <updating/>
        <source>runReport() : CM_User protected, updating;
// ---------------------------------------------------------------------------
// Created:     18 October 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//03 Jan 2013	cnwrs1	32983 crash after user deleted.
//29 Jun 2015   cnwma1  PAR #36541  Locale not picked up by BGP report template
//12 Jan 2018	jlgmd1	TFS #36427 - DQM - Vessel Schedule Report
// ---------------------------------------------------------------------------
vars
	error,
	profName			: String;
	pxyJadeReport		: JadeReport;
	thePrinterName		: String;
	file				: File;
	user				: CM_User;
	defaultPrinter		: String;
	blob				: Binary;
	userInfo			: String;
	startTime			: TimeStamp;
	endNoteSent,
	rtnValue			: Boolean;
	pxyFilter			: CMQF_FilterReports;
	docType 			: Integer;
	msg : String;
begin
	
	on Exception do self.xPrinterHandler(exception);
	msg := 'Starting background printer request';
	app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
	
	// Clear out any screwed up output and reset printer.
	app.printer.abort();
	// We need something to print with.
	// TFS 978 for HH label
	if self.printerName &lt;&gt; null then
		defaultPrinter := self.printerName;
	endif;
	self.setPrinter(defaultPrinter);
	
	//Set this once we know what printer we are using.
	docType := app.printer.documentType;
	
	user := self.myReportTemplate.getUserToRunAgainst();
	msg := 'Terminal ' &amp; app.myPassport.myTerminal.String;
	app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
	
	if user = null then
		app.raiseUnexpectedProgramError(class.name, method.name, app.getErrorString(Could_Not_Find_User) &amp; self.myReportTemplate.name);
	endif;

	app.myPassport.setMyUser(user);
	app.setLocale(app.getMyUser().getLocale()); // 29/01/2015  cnwma1 PAR #36541 
	// Par 10931
	beginTransaction;
	process.changeUserCode(user.code);
	commitTransaction;

	app.myTrxUA.trxUpdateMenuUserReportErrMsg(self.myReportTemplate, app.getErrorString(Report_Not_Yet_Processed), app.myPassport);
	if (not app.myPassport.trxCompletedOK) then
		app.raiseCMException1(BackgroundErrorGeneral,'trxUpdateMenuUserReport failed', null, null);
		//????
	endif;
	
	//	notify the LockKeeper that a transaction is starting
	startTime := app.actualTimeServer();
	app.lockKeeperNotifyStartActivity(startTime, method, null, self.myReportDef.getNameForLockKeeper(0), app.myPassport);
	//userInfo := app.userInfoStringStartTrxEncode(process, startTime, method, null, self.getReportDescription);
	//system.causeEvent(LockKeeper_StartTrx_Event, true, userInfo);
	
	create pxyJadeReport transient;
	rtnValue := self.doFiltering(pxyFilter);
//	self.profileName := pxyFilter.jrwProfileName;	//filter holds the saved profile name

	endNoteSent := app.lockKeeperNotifyEndActivity(startTime, true, app.myPassport);
	
	if (not rtnValue) or self.doCallBackAbortCheck() then
		return user;
	endif;

	if not self.createReports(pxyJadeReport, pxyFilter, blob) then
		return user;
	endif;

	if self.doCallBackAbortCheck() then
		return user;
	endif;
	
	self.postReportRunProcessing(pxyJadeReport, blob, pxyFilter);
	msg := 'Report request completed';
	app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
	
epilog
	abortTransaction;		// Problem in report writer left locks
	delete pxyJadeReport;
	// CCMS 1327
	delete pxyFilter;
	
	//In case the report was a different document type to the print setting prior to the report run.
	app.printer.documentType := docType;
	if (not endNoteSent) then
		app.lockKeeperNotifyEndActivity(startTime, true, app.myPassport);
	endif;
	return user;
	//userInfo := app.userInfoStringEndTrxEncode(process, startTime, app.actualTimeServer);
	//system.causeEvent(LockKeeper_EndTrx_Event, true, userInfo);

end;</source>
        <access>protected</access>
        <ReturnType type="CM_User"/>
    </JadeMethod>
    <JadeMethod name="saveReportOutputToNetworkPath" id="1ddb5991-dedd-4be2-8f55-8abcfc378d5e">
        <source>saveReportOutputToNetworkPath(_fileName : String) protected;
// -------------------------------------------
// Created 21 October 2004 by cnwdvb1
// 13 Jan 2026 navah1	MTN-36669: PEN | Report Generation - SFTP Reports
// -------------------------------------------
vars

	reportTemplate	: CM_ReportTemplate;
	fileName,
	filePath		: String;
	length			: Integer;
	

begin
	if self.outputType = self.FTP_SFTP then //13.01.2026 navah1 #MTN-36669
		return;
	endif;
	
	fileName := _fileName.cnEcRemoveSubstring('&amp;');  //28 Jan 2020 NDL TFS 48390 Embedded ampersand causes issues with pdf file name.
	fileName := fileName.doInvalidCharacterSweep();
	
	reportTemplate := self.myReportTemplate;
	if reportTemplate.networkFilepath &lt;&gt; null then
		filePath := reportTemplate.networkFilepath;
		length := filePath.length();
		if filePath[length] = '\' or filePath[length] = '/' then
			filePath := filePath &amp; fileName;
		else
			filePath := reportTemplate.networkFilepath &amp; '\' &amp; fileName;
		endif;
		if not reportTemplate.writeCSVBlobToFile(filePath) then
			app.remoteErrorWarningToAlert('Unable to save ' &amp; reportTemplate.name &amp; ' for user ' &amp; app.myPassport.getUserCode &amp; 
			' to network path ' &amp;  filePath, null, null, null, false, true);
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_fileName" type="String"/>
    </JadeMethod>
    <JadeMethod name="sendSFTP" id="c3b6822f-3ea0-4649-8541-5a8067fe4c4e">
        <source>sendSFTP(_blob : Binary io);
/*
Date        Who     Reason
13 Jan 2026 navah1  Initial creation
13 Jan 2026 navah1	MTN-36669: PEN | Report Generation - SFTP Reports
*/

vars
    header          : CM_FileDataStorageHeader;
    file            : File;
    sftpEntity		: CM_SFTPEntity;
    sftp            : CMIF_SFTPRequest;
    hadError        : Boolean;
	sftpEntDest,
    outFileName,
    result,
    fileName,
    msg,
    heading,
    ext             : String;

begin
    ext := app.getExtension(self.outputDestination);

    if self.myReportTemplate.name &lt;&gt; null then
        heading := self.myReportTemplate.name &amp; ext;
    elseif self.myReportDef.heading &lt;&gt; null then
        heading := self.myReportDef.heading &amp; ext;
    endif;

    beginTransaction;
        header := app.convertBlobForRequest(_blob, heading, false, 0);
        if header &lt;&gt; null then
            fileName := app.writeBinaryToFile(header, null);
        endif;
		if self.myReportTemplate.networkFilepath &lt;&gt; null then
			fileName := app.writeBinaryToFile(header, self.myReportTemplate.networkFilepath);
		else
			fileName := app.writeBinaryToFile(header, null); 
		endif;
    commitTransaction;

    if fileName &lt;&gt; null then
        create file transient;
        file.kind := File.Kind_Unknown_Text;
        file.mode := File.Mode_Input;
        file.fileName := fileName;
        file.usePresentationFileSystem := false;
		sftpEntity := self.myReportTemplate.myFTPEntity.CM_SFTPEntity;
		
        if file.isAvailable and sftpEntity &lt;&gt; null then
            create sftp transient;
			sftpEntDest := sftpEntity.destinationDirectory;

            if sftpEntDest &lt;&gt; null then
                sftpEntDest.replaceChar('\', '/');

                if not sftpEntDest.startsWith("/") then
                    outFileName := '/';
                endif;

                if sftpEntDest.endsWith('/') then
                    outFileName &amp;= sftpEntDest &amp; heading;
                else
                    outFileName &amp;= sftpEntDest &amp; '/' &amp; heading;
                endif;
            else
                outFileName := '/' &amp; heading;
            endif;

            app.writeLog("SFTP WriteFile " &amp; fileName &amp; " to " &amp; outFileName, LogINFO);

            msg := "emSFTP_WriteFileSync host=" &amp; sftpEntity.getServerNameForConnect()
                &amp; " userId=" &amp; sftpEntity.userId
                &amp; " password length=" &amp; sftpEntity.getPwForUse(null).length.String
                &amp; " port=" &amp; sftpEntity.port.String
                &amp; " sourceFile=" &amp; fileName
                &amp; " destFile=" &amp; outFileName
                &amp; " publicKey=null"
                &amp; " privateKey length=" &amp; sftpEntity.privateKey.length.String
                &amp; " passPhrase length=" &amp; sftpEntity.getPwForUse('passPhrase').length.String
                &amp; " subscriberOid=" &amp; self.getInstanceIdForObjectXX(self).String
                &amp; " timeout=" &amp; sftpEntity.timeOut.String;
            app.writeLog(class.name &amp; "::" &amp; method.name &amp; " " &amp; msg, LogDEBUG);

            hadError := sftp.emSFTP_WriteFileSync(
                self,
                sftpEntity.getServerNameForConnect(),
                sftpEntity.userId,
                sftpEntity.getPwForUse(null),
                sftpEntity.port,
                fileName,
                outFileName,
                sftpEntity.publicKey,
                sftpEntity.privateKey,
                sftpEntity.getPwForUse('passPhrase'),
                self.getInstanceIdForObjectXX(self),
                sftpEntity.timeOut,
                result
            );

            if hadError then
                app.writeLog(app.getErrorString1(Error_Display, result), LogINFO);
                app.raiseCMException1(Error_Display, result, null, null);
            endif;
        else
            app.writeLog("SFTP failed. File " &amp; file.fileName &amp; " not found.", LogINFO);
            if app.isJMTUnitTest then
                app.raiseCMException1(Error_Display, "SFTP failed. File " &amp; file.fileName &amp; " not found.", null, null);
            endif;
        endif;
    endif;
epilog

end;</source>
        <Parameter name="_blob" type="Binary" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setExtraActivityHistory" id="ceb2bd40-b820-4417-aa85-56ebaa3a0b98">
        <source>setExtraActivityHistory(_activityHistory: CM_ActivityHistoryGeneral input);
// -------------------------------------------
// Created 28 February 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	_activityHistory.setExtraDetail('Request Deleted' &amp; Tab &amp; self.getDisplay().removeTabCrLfs);


end;</source>
        <Parameter name="_activityHistory" type="CM_ActivityHistoryGeneral" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setParameters" id="d84a5451-8615-4e08-bdd9-8b16b519495e">
        <source>setParameters(_jadeReportWriterReport : JadeReportWriterReport; _pxyFilter : CMQF_FilterReports input) protected;
// ---------------------------------------------------------------------------
// Created:     15 October 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// 12 Jan 2018	jlgmd1		TFS #36427 - DQM - Vessel Schedule Report
vars
	qryParam			: CM_QueryReportParam;
	filterObject		: CMQF_FilterReports;
	edition 			: Integer;	//18 July 2016	NDL	TFS 2329
	invalid				: Boolean;	//18 July 2016	NDL	TFS 2329
begin
	//filterObject := self.myFilter;		//TFS 36427
	filterObject := _pxyFilter;				//TFS 36427
	if filterObject = null then
		return;
	endif;
	
	on Exception do app.handleDeletedObject( exception, qryParam, invalid );	//18 July 2016	NDL	TFS 2329
	
	
	foreach qryParam in filterObject.allQueryReportParams do
	
		//18 July 2016	NDL	TFS 2329
		invalid := false;
		edition := qryParam.edition;
		if invalid then
			continue;
		endif;
		
		_jadeReportWriterReport.setParameter(qryParam.paramName, qryParam.getParamValue());
		
	endforeach;
	
end;</source>
        <access>protected</access>
        <Parameter name="_jadeReportWriterReport" type="JadeReportWriterReport"/>
        <Parameter name="_pxyFilter" type="CMQF_FilterReports" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setPrinter" id="b9919865-da72-44e8-9318-cc84051848fd">
        <source>setPrinter(_printer : String) : Boolean protected;

// cnwdvb1 17 June 2003 
//03 Jan 2013	cnwrs1	32983 crash after user deleted.
//30/03/2017    cnwma1 TFS # 3745*:POL - JMT Reports not working?
//24/04/2025	jlizm1	MTN 34729 STWO Implement Handling for Intermittent PDF Print Failures in BGP Reports
constants

	Printer_Ok				= 0;
	DefaultPrinterError		= 15014;

vars

	findPrinterValue	: Integer;
//	strErr,
	tempStr,
	thePrinterName		: String;
	stringArray1		: CnStringArray;		// from 31581 May 2013, allow for long printer names
	stringArray2		: StringArray;
	msg : String;
begin

	thePrinterName := _printer;
	// If printer name is null then Jade uses default printer.
	findPrinterValue :=  app.printer.setPrinter(thePrinterName);
	msg := 'Set Printer Return Value = ' &amp; findPrinterValue.String;
	app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
	
	if findPrinterValue = Printer_Ok then
		return true;
	endif;
	msg := '(' &amp; thePrinterName &amp; ') was not located. Trying for default printer';
	app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
	
	create stringArray1 transient;
	create stringArray2 transient;
	app.printer.getAllPrinters(stringArray1);
	
	stringArray2.add('Available Printers are:');
	foreach tempStr in stringArray1 do
		msg := 'Available Printer (' &amp; tempStr &amp; ')';
		app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
		
		stringArray2.add(tempStr[1:30]);
	endforeach;
	
	if self.myReportDef &lt;&gt; null then   //30/03/2017 cnwma1 TFS # 3745
		stringArray2.add('Report Name:'&amp; self.myReportDef.reportName);
	endif;
	app.remoteErrorWarningToAlert('Unable To Locate Printer ' &amp; thePrinterName, null, null, stringArray2, false, false);

	// If we have failed we try to set to default printer.
	if thePrinterName &lt;&gt; null then
		thePrinterName := null;
		findPrinterValue := app.printer.setPrinter(thePrinterName);
	endif;
	// Have we succeed on our second try?
	if findPrinterValue = Printer_Ok then
		msg := 'Defaulted to Printer: ' &amp; app.printer.getPrinterName;
		app.writeLog(msg, LogINFO);
		return true;
	endif;
	msg := 'Set printer call for ' &amp; thePrinterName &amp; ' failed with error ' &amp; findPrinterValue.String;
	app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
	
	app.raiseCMException(findPrinterValue, null, null);
	return false;
epilog	
	delete stringArray1;
	delete stringArray2;
end;</source>
        <access>protected</access>
        <Parameter name="_printer" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setPrinterName" id="4a3eaf03-06c7-441b-8395-2f41a4ef934f">
        <updating/>
        <source>setPrinterName(_printerName: String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 November 2017	jlgmd1	Initial creation TFS 7140 DPH - message box in bgp process

*/

vars

begin
	self.printerName := _printerName;
epilog

end;</source>
        <Parameter name="_printerName" type="String"/>
    </JadeMethod>
    <JadeMethod name="validate" id="705e2a34-39c6-4901-8520-3c7f4d3cf6a7">
        <source>validate();
// -------------------------------------------
// Created 15 December 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	if self.myFilter = null then
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, self.class.name, method.name, 'myFilter is null', null, null);
	endif;

	if not self.isTemplate and self.myReportDef = null then
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, self.class.name, method.name, 'myReportDef is null', null, null);
	endif;	


end;</source>
    </JadeMethod>
    <JadeMethod name="xPrinterHandler" id="2f5a7d2c-bb41-4a32-abb5-60d736695115">
        <source>xPrinterHandler(_exp : Exception) : Integer protected;

vars

	error 	: Integer;
	errStr	: String;
	array	: StringArray;

begin

	error := _exp.errorCode;

	// Par 8001 Cannot update menu because already in transaction state sometimes.	
//	if self.myMenuUserReport &lt;&gt; null then
//		app.myTrxUA.trxUpdateMenuUserReport(self.myMenuUserReport, CM_MenuUserReport.MSG_ERR_PROCESSING, app.myPassport);
//	endif;
	
	if error = 15005 then
		errStr := 'Unable to communicate with printer';
	elseif error = 15006 then
		errStr := 'Header and footer larger than page';
	elseif error = 15007 then
		errStr := 'Frame larger than page depth';  
	elseif error = 15013 then
		errStr := 'Printer is currently open';
	elseif error =15015 then
		errStr := 'Printing cancelled';
	elseif error = 15016 then
		errStr := 'Printing stopped';
	elseif error = 15017 then
		errStr := 'Supplied printer does not match local and favorite printers';
	elseif error = 15014 then
		errStr := 'Default printer not assigned';
	elseif error &gt;= 15001 and error &lt;= 15099 then	// MTN 34050 jlizm1 13/03/2025 log any other expections
		app.writeLog('Printer Error (' &amp; error.String &amp; '). ' &amp; _exp.text, LogINFO);
	endif;
	
	if errStr &lt;&gt; null then
		abortTransaction;
		create array transient;
		errStr := 'Background Error (' &amp; error.String &amp; ') ' &amp; errStr;
		array.add(self.myReportDef.reportName &amp; ' user ' &amp; self.myReportTemplate.userCodeToRunAs);
		app.remoteErrorWarningToAlert(errStr, null, null, array, true, true);
	endif;
	return Ex_Pass_Back;
epilog
	delete array;
end;</source>
        <access>protected</access>
        <Parameter name="_exp" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
