    <JadeMethod name="showMoveFrame" id="7826cab9-1bda-4fff-8d7a-4ed0fc4bf7fb">
        <updating/>
        <source>showMoveFrame() updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theFrame : CMUI_MoveableFrame;
begin
	self.loadMoveMappings(); //epr TFS 4135 1/5/17 only load this on showing the frame not every form refersh
	theFrame := self.frmListMoves;
