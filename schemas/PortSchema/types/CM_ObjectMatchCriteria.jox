    <JadeMethod name="delete" id="d0d153ef-7aa0-43e2-9d84-3c7720bae031">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 December 2013	cnwndl1	Initial creation	Par 33184

*/

vars

begin

	if not self.allCriteria.isEmpty then
		self.allCriteria.purge();
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getCriteriaFor" id="e201ac15-3681-41b9-a8d4-e283e2fa52d7">
        <source>getCriteriaFor( _yaCriteriaType : Integer ) : CM_YACriteria;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 March 2016	cnwndl1	Initial creation	TFS 1684

*/

vars

	iter : Iterator;
	criteria : CM_YACriteria;

begin

	if self.allCriteria = null or self.allCriteria.isEmpty then
		return null;
	endif;
	
	iter := self.allCriteria.createIterator;
	while iter.next( criteria ) do
		if criteria.myYACriteriaType = null  then
			continue;
		endif;
		if criteria.myYACriteriaType.type = _yaCriteriaType then
			return criteria;
		endif;
	endwhile;
	
	return null;

epilog

	delete iter;

end;</source>
        <Parameter name="_yaCriteriaType" type="Integer"/>
        <ReturnType type="CM_YACriteria"/>
    </JadeMethod>
    <JadeMethod name="getCriteriaSummary" id="994fb31d-80a1-4582-8b81-d7a8878ad202">
        <source>getCriteriaSummary( _delim : String ): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 December 2013	cnwndl1	Initial creation	Par 33184
*/

vars

	criteria : CM_YACriteria;
	invalidObj : Boolean;
	attrStr : String;
	valueStr : String;
	retString : String;

begin

	on Exception do app.handleDeletedObject(exception, criteria, invalidObj);

	foreach criteria in self.allCriteria do
		attrStr := null;

		attrStr := criteria.myYACriteriaType.description;
		valueStr := criteria.getDisplayForYAMTableColumn;

		if attrStr &lt;&gt; null and valueStr &lt;&gt; null then
			if retString &lt;&gt; null then
				retString := retString &amp; _delim;
			endif;
			retString := retString &amp; attrStr &amp; "=" &amp; valueStr;
		endif;
	endforeach;
	
	return retString;

epilog

end;</source>
        <Parameter name="_delim" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="eda62e12-46ab-4bc4-85d5-6a510b4d2592">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 September 2020	jlgndl1	Initial creation	TFS 49984

*/

vars

begin

	if _attrName = ETRow_CriteriaSummary then
		return self.getCriteriaSummary(", ");
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
