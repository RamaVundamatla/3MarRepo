    <JadeMethod name="translateForm" id="9da2d426-5dc4-4466-b8b7-d4a45d40fa23">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 10 June 2021 14:50:54.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0024238, locale);
	btnAddManual.translateCaption(Xlat_0024239, locale);
	btnCancel.translateCaption(Xlat_0024240, locale);
	btnCargoId.translateCaption(Xlat_0024241, locale);
	btnFindOutTi.translateCaption(Xlat_0024242, locale);
	btnOk.translateCaption(Xlat_0024243, locale);
	grpComponents.translateCaption(Xlat_0024244, locale);
	grpManualAmountOut.translateCaption(Xlat_0024245, locale);
	grpManualSel.translateCaption(Xlat_0024246, locale);
	grpMethodology.translateCaption(Xlat_0024247, locale);
	grpOutput.translateCaption(Xlat_0024248, locale);
	grpRecipe.translateCaption(Xlat_0024249, locale);
	lblAmountReqd.translateCaption(Xlat_0024250, locale);
	lblCargoId.translateCaption(Xlat_0024251, locale);
	lblCargoTypIn.translateCaption(Xlat_0024252, locale);
	lblCargoType.translateCaption(Xlat_0024253, locale);
	lblLocation.translateCaption(Xlat_0024254, locale);
	lblMultipleBy.translateCaption(Xlat_0024255, locale);
	lblOperator.translateCaption(Xlat_0024256, locale);
	lblQuantiyOut.translateCaption(Xlat_0024257, locale);
	lblResultsIn.translateCaption(Xlat_0024258, locale);
	lblSubCargoType.translateCaption(Xlat_0024259, locale);
	lblSubCargoTypeIn.translateCaption(Xlat_0024260, locale);
	lblTerminalArea.translateCaption(Xlat_0024261, locale);
	lblVolumeOut.translateCaption(Xlat_0024262, locale);
	lblWeightOut.translateCaption(Xlat_0024263, locale);
	mnuContext.translateCaption(Xlat_0024264, locale);
	mnuFindComp.translateCaption(Xlat_0024265, locale);
	mnuRemoveComp.translateCaption(Xlat_0024266, locale);
	optCreateTI.translateCaption(Xlat_0024267, locale);
	optExistingTI.translateCaption(Xlat_0024268, locale);
	optManual.translateCaption(Xlat_0024269, locale);
	optRecipe.translateCaption(Xlat_0024270, locale);
end;</source>
