    <JadeMethod name="getPicture" id="3d46154d-f38f-47a8-943c-2703c6d2e9ca">
        <source>getPicture(form: INV_TransactionMap): Picture;

vars

begin
	if self.hidePictures then
		return null;
	endif;
	return form.picContainer;

end;</source>
        <Parameter name="form" type="INV_TransactionMap"/>
        <ReturnType type="Picture"/>
    </JadeMethod>
    <JadeMethod name="getRealMapObject" id="7186231f-71c7-4fee-b9ac-b04ca7040fe1">
        <source>getRealMapObject(): Object;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	return self.myTIServiceMap;

end;</source>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="initialise" id="18449dec-cf4f-4537-ad98-944992bd7e25">
        <updating/>
        <source>initialise(_groupCount : Integer io) updating;

vars
	pgm : CM_ProductGroupMap;
	tmcPG : CMIF_TMCProductGroupGroup;
	
	root : CM_Root;
begin
	root := app.myRoot;
	
	self.myTMCController := self.myGroup.myTMCController;	// April 2010, cnwjre1, par 23659, invoice transaction map extract enhancements for Tranship IMEX status
	self.hidePictures := self.myTMCController.hidePictures;
	foreach pgm in self.myTIServiceMap.allProductGroupMaps do
		if pgm.myProductGroup = null then
			create tmcPG as CMIF_TMCProductGroupDefault;
		else
			create tmcPG;
		endif;
		
		tmcPG.itemName := pgm.itemName;
		tmcPG.extractName := pgm.getItemCode();	// 23659
		tmcPG.myProductGroupMap := pgm;
		tmcPG.myGroup := self;
		tmcPG.initialise(_groupCount);
	endforeach;
	
	_groupCount := _groupCount + 1;

end;</source>
        <Parameter name="_groupCount" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setControllerCurrent" id="81ac7b4e-66db-4b13-800f-4ab6316bc931">
        <source>setControllerCurrent() ;
// April 2010, cnwjre1, par 23659, invoice transaction map extract enhancements for Tranship IMEX status
vars

begin

	inheritMethod();
	
	myTMCController.myCurrentMapTIService := self.myTIServiceMap;
	myTMCController.myCurrentMapTM := self.myTIServiceMap.transactionMap;
end;</source>
    </JadeMethod>
    <JadeMethod name="setEnableObjects" id="3077b92d-0fc6-4626-89f1-b3b98b7536ec">
        <source>setEnableObjects(form: INV_TransactionMap io);

vars

begin

	inheritMethod(form);

	form.menuSItemNew.visible := true;  // MAIN CARGO NEW MENU
	form.menuTMVnew.visible := false;  // MAIN VTMIS NEW MENU	
	form.mnuTMExport.visible := false;
	form.menuMappingSetActive.visible := false;
	form.modePropertyUpdate := INV_TransactionMap.ModeProperty_CargoType;
	form.modePropertyDelete := INV_TransactionMap.ModeProperty_CargoType;
	form.modePropertyNew := INV_TransactionMap.ModeProperty_ProductGroup;
	form.menuSItemNew.enabled := true;
	form.btnNew.enabled := true;

	form.menuSINewProductGroup.visible := true;
	form.mnuCopy.visible := app.myCurrentUserCan(form.myTerminal, form.permissionMaint); // TFS 2198 CNWAB1;
	form.btnCopy.enabled := app.myCurrentUserCan(form.myTerminal, form.permissionMaint); // TFS 2198 CNWAB1;
	form.mnuReplace.visible := app.myCurrentUserCan(form.myTerminal, form.permissionMaint); // TFS 2198 CNWAB1;
	form.btnReplace.enabled := app.myCurrentUserCan(form.myTerminal, form.permissionMaint); // TFS 2198 CNWAB1;

	form.menuSItemDelete.visible := true;
	form.btnDelete.enabled := true;
	
end;</source>
        <Parameter name="form" type="INV_TransactionMap" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setMyCurrent" id="6328a24f-40ac-4e54-9321-1a232a5277f1">
        <updating/>
        <source>setMyCurrent(form: INV_TransactionMap io) updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin

	inheritMethod(form);
	
	form.myCurrentMapTIService := self.myTIServiceMap;
	form.myCurrentMapTM := self.myTIServiceMap.transactionMap;
	form.myTMCCargoType := self;
end;</source>
        <Parameter name="form" type="INV_TransactionMap" usage="io"/>
    </JadeMethod>
</Class>
