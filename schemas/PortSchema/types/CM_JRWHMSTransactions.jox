    <JadeMethod name="noOutputReturned" id="d44a8927-aeae-4eab-be59-524130bf653d">
        <source>noOutputReturned(): Boolean;
//----------------------------------------------------------------
//	Created:	26 May 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	if self.allHMSTransactions.isEmpty
	and self.allReportMovements.isEmpty then
		return true;
	endif;
	
	return false;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
