    <JadeMethod name="getResponses" id="a45320f2-9685-43c8-9e83-b2003daacfa8">
        <source>getResponses();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
04 July 2024	navcs2	ChangeRequest 63797: EUP | CAMS Search for outgoing messages - CAMS Message Enquiry

*/

vars
	rowIndex		: Integer;
	include			: Boolean;
	code 			: String;
begin
	
	foreach rowIndex in 1 to self.tblResponseCodes.rows do
		include := self.tblResponseCodes.accessCell(rowIndex, 1).text = "1";
		if include then
			code := self.tblResponseCodes.accessCell(rowIndex, 2).text;
			if code = self.HttpStringAll then
				self.allFilterResponseCodes.add(0);
			elseif code = self.HttpStringClientError then
				self.allFilterResponseCodes.add(HttpResponseClientError);
			elseif code = self.HttpStringForbidden then
				self.allFilterResponseCodes.add(HttpResponseForbidden);
			elseif code = self.HttpStringNoContent then
				self.allFilterResponseCodes.add(HttpResponseNoContent);
			elseif code = self.HttpStringNoFound then
				self.allFilterResponseCodes.add(HttpResponseNotFound);
			elseif code = self.HttpStringOK then
				self.allFilterResponseCodes.add(HttpResponseOK);
			elseif code = self.HttpStringUnauth then
				self.allFilterResponseCodes.add(HttpResponseUnauthorized);
			elseif code = self.HttpStringSystemError then
				self.allFilterResponseCodes.add(HttpResponseSystemError);
			endif;
		endif;
	endforeach;
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="getStatuses" id="33c1b847-1586-4af8-b524-924cdc83fb5f">
        <source>getStatuses();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
04 July 2024	navcs2	ChangeRequest 63797: EUP | CAMS Search for outgoing messages - CAMS Message Enquiry

*/

vars
	rowIndex		: Integer;
	include			: Boolean;
	code 			: String;
begin
	
	foreach rowIndex in 1 to self.tblStatuses.rows do
		include := self.tblStatuses.accessCell(rowIndex, 1).text = "1";
		if include then
			code := self.tblStatuses.accessCell(rowIndex, 2).text;
			
			if not self.allFilterStatuses.includes(code) then
				self.allFilterStatuses.add(code);
			endif;
		endif;
	endforeach;
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="handleRegexException" id="e80a0492-04c1-4514-acda-939e9e50ca08">
        <source>handleRegexException(_exc : JadeRegexException; _hadException : Boolean io; _nativeError : String output ) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
22 August 2024		navcs2	ChangeRequest 63797: EUP | CAMS Search for outgoing messages - CAMS Message Enquiry

*/

vars
	returnVal : Integer;
begin
	returnVal := Ex_Pass_Back;
	if _exc.resumable then
			returnVal := Ex_Resume_Next;
	endif;
	_nativeError:=_exc.nativeErrorMessage;
	_hadException:=true;
	
	return returnVal;
epilog

end;</source>
        <Parameter name="_exc" type="JadeRegexException"/>
        <Parameter name="_hadException" type="Boolean" usage="io"/>
        <Parameter name="_nativeError" type="String" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="includeObjectCams" id="d42e52f3-499a-4753-8fd6-383697c9a558">
        <source>includeObjectCams(camHist : CM_CamTaskHistory) : Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
04 July 2024	navcs2	ChangeRequest 63797: EUP | CAMS Search for outgoing messages - CAMS Message Enquiry

*/

vars

begin
	if self.allFilterCamProtocols &lt;&gt; null and not self.allFilterCamProtocols.includes(camHist.camProtocol) then	
		return false;
	endif;
	
	if self.filterDateFrom.isValid() and camHist.runDateTime &lt; self.filterDateFrom then
		return false;
	endif;
	if self.filterDateTo.isValid() and camHist.runDateTime &gt; self.filterDateTo then
		return false;
	endif;
	
	if self.myFilterStatusCams = self.AllStatuses then
		
	elseif self.myFilterStatusCams &lt;&gt; null and not self.myFilterStatusCams = camHist.status then
		return false;
	endif;
	
	return true;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="camHist" type="CM_CamTaskHistory"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initQueryFrame" id="a956c54b-53d0-437f-b372-2ae91f7d9a7d">
        <updating/>
        <source>initQueryFrame() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
04 July 2024	navcs2	ChangeRequest 63797: EUP | CAMS Search for outgoing messages - CAMS Message Enquiry

*/

constants
	GAP = 10;
	SMALLGAP	= 5;
vars
	sht			: CMUI_Sheet;
begin
	self.frmQuery.height	:= 370;
	self.frmQuery.width		:= self.frmQuery.width;

	sht 						:= self.shtQuery1;
	sht.caption 				:= app.getErrorString(CAMS_Protocol);
	sht.visible 				:= true;
	
	/*
	sht 						:= self.shtQuery2;
	sht.caption 				:= app.getErrorString(Status);
	sht.visible 				:= true;
	
	sht 						:= self.shtQuery3;
	sht.caption 				:= self.ResponseCodeCaption;
	sht.visible 				:= true;
	*/
	
	self.setupStatusTbl();
	self.setupResponseCodeTbl();
	self.setupCamsProtocolsTbl();
	self.buildCmbStatus();
	
	self.doResetSearch;
	self.fldQuery.topSheet 		:= self.shtQuery1;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initTableData" id="051ec1c5-c180-4ccc-bfe5-aaee805ef2f3">
        <updating/>
        <source>initTableData(_theEntDef: String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
04 July 2024	navcs2	ChangeRequest 63797: EUP | CAMS Search for outgoing messages - CAMS Message Enquiry

*/
vars

begin
	inheritMethod(_theEntDef);
    
	self.tblData.multiSelect	:= CM_DataTable.MultiSelect_Simple;	
epilog

