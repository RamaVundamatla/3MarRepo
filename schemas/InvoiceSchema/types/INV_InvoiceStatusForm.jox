    <JadeMethod name="addObjectsToTable" id="4e4a5990-ea3f-4264-9fdc-7c8fef6b40be">
        <updating/>
        <source>addObjectsToTable(_numItems: Integer io) updating;
/*
Purpose:	TFS 39618		
Date				Who			Reason
JANUARY 2019		CNWAB1		Initial creation
*/

vars
	invStatus : CM_InvoiceStatus;
	tmpPassport	: CM_Passport;
	breakOut	: Boolean;
begin

	self.setMyDataClass();
	beginClassNotification(CM_InvoiceStatus, false, Object_Create_Event, Response_Continuous, 0); 

	tmpPassport := app.myPassport;
	
	foreach invStatus in app.myRoot.allInvoiceStatuses  do
		if self.includeObject(invStatus, tmpPassport) then
			self.addObjectToTable(invStatus, _numItems, breakOut);
		endif;
		if breakOut then
			break;
		endif;
	endforeach;

end;</source>
        <Parameter name="_numItems" type="Integer" usage="io"/>
    </JadeMethod>
