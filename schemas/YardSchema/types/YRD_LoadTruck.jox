    <JadeMethod name="doCheckForInterTermJob" id="70dbccf2-999e-49d8-a14c-317855b17867">
        <updating/>
        <source>doCheckForInterTermJob(_createOneIfNone : Boolean) : CM_InterTermVehicleJob updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
22 February 2010	conkc1	Initial creation

*/
vars

	interTermJob : CM_InterTermVehicleJob;
	proxy        : CM_InterTermVehicleJob;
	result       : Boolean;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin

	interTermJob := self.myVehicle.getInterTerminalJob();
	if interTermJob &lt;&gt; null then
		return interTermJob;
	endif;

	if _createOneIfNone = false then
		return interTermJob;
	endif;
	//if the truck doesn't have an inter terminal transfer job, then create one here.
	create proxy transient;
	proxy.setProxy(self.myVehicle, myDriver);
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxCA.trxCreateInterTermVehicleJob(proxy, interTermJob, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog(app.getString(Inter_Terminal_Transfer), app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return null;
		
	endwhile;
	
	return interTermJob;
	
epilog

	delete proxy;

end;</source>
        <Parameter name="_createOneIfNone" type="Boolean"/>
        <ReturnType type="CM_InterTermVehicleJob"/>
    </JadeMethod>
    <JadeMethod name="doCreateLoad" id="fcf57c82-a849-4825-9632-c44e62de1dab">
        <updating/>
        <source>doCreateLoad() : Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
22 February 2010	conkc1	Initial creation

*/
vars
	pProxyInterTermMove : CM_InterTerminalMove;
	pNewInterTermMove   : CM_InterTerminalMove;
	result              : Integer;
begin

	create pProxyInterTermMove transient;
	pProxyInterTermMove.setProxy(	self.myCargo.id,	        // cargoID : String;
									self.myCargo.myOperator,	// operator : CM_Operator;
									self.myCargo,	            // sourceTI : CM_TrackedItem;
									self.mySourceTerminal,	    // sourceTerminal : CM_Terminal;
									self.myTargetTerminal,	    // targetTerminal : CM_Terminal;
									self.myVehicle,	            // sourceVehicle : CM_Vehicle;
									self.myVehicle.regNumber,	// vehicleId : String;
									ITT_LOADING,	            // status : Integer;
									self.myInterTermVehicleJob  // myInterTermVehicleJob : CM_InterTermVehicleJob
									);
									
	
	
	while true do
		app.myTrxCA.trxCreateInterTerminalMove(pProxyInterTermMove, pNewInterTermMove, app.myPassport); 
		if app.myPassport.trxCompletedOK then
			app.myPassport.clearErrorsWarnings();
			break;
		else
			//If there were warnings, give the user a chance to see them. If there are no errors they may decide to acknowledge
			//them and update anyway.
			result := app.showErrorWarningDialog(app.getErrorString(Load), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		return false;
	endwhile;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doInterTerminalCheck" id="e6ba21e5-f905-4f43-af15-68cda53060bf">
        <source>doInterTerminalCheck( ti : CM_TrackedItem ) : Boolean;
/*
Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
21 February 2010	conkc1	Initial creation

*/
vars
	errorMess : String;
begin
	
	if ti &lt;&gt; null then
		if not ti.allBulkReleasesAssigned.includesInterTerminalRelease then
			// not valid container to be released by inter terminal 
			errorMess := app.getErrorString1(Not_Part_inter_term_release, ti.id);
			app.msgBox(errorMess ,app.getErrorString(Error), MsgBox_OK_Only);
			return false;
		endif;
	endif;
	
	return true;
	

epilog

end;</source>
        <Parameter name="ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doLoadSourceTerminal" id="574616dd-77ad-4b8f-9f85-b6d11e9ed23b">
        <updating/>
        <source>doLoadSourceTerminal() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
22 February 2010	conkc1	Initial creation

*/
vars

	index    : Integer;
	userTerm : CM_UserTerminal;
	
begin

	foreach userTerm in app.getMyUser.allUserTerminals do
		index := self.cmbSourceTerm.addItem(userTerm.myTerminal.code);
		self.cmbSourceTerm.itemObject[index] := userTerm.myTerminal;
	endforeach;

	self.cmbSourceTerm.listObject := self.myTerminal;
	self.mySourceTerminal         := self.myTerminal;
epilog

end;</source>
    </JadeMethod>
