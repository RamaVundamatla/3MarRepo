    <JadeMethod name="create" id="02c21b3f-039b-4303-ad57-960198c4ef06">
        <updating/>
        <source>create() updating;
//--------------------------------------------------------------
//Created: 04 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
begin
	self.name := SOP_TableMaintForm.Table_Harbour;
	self.permissionView	 := PmHMSHarbourTblView;
	self.permissionMaint := PmHMSHarbourTblMaint;
	self.myDataClass := HMS_Harbour;

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="34a74ee3-ab30-4d5d-b145-8b6272d5628e">
        <updating/>
        <source>doSave(): Boolean updating;
//--------------------------------------------------------------
//Created: 04 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	pxyHarbour	: HMS_Harbour;
	code,
	description	: String;
	theForm 	: SOP_TableMaintForm;

begin

  	theForm := self.myForm; 
	code := theForm.tblInput1.getValueByName(ETRow_Code).String;
	description := theForm.tblInput1.getValueByName(ETRow_Description).String;

	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as HMS_Harbour transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy is null for update');
			return false;
		endif;
	endif;

	pxyHarbour := theForm.myProxyObject.HMS_Harbour;
	pxyHarbour.defaultOrderTimesArrive.clear();
	pxyHarbour.defaultOrderTimesDepart.clear();
	pxyHarbour.defaultOrderTimesShift.clear();			
	theForm.tblInput1.setObjectFromTable(pxyHarbour, 'setObjectFromTableSpecial', false);
	theForm.tblInput2.setObjectFromTable(pxyHarbour, 'setObjectFromTableSpecial', false);
	theForm.tblInput3.setObjectFromTable(pxyHarbour, 'setObjectFromTableSpecial', false);

	pxyHarbour.setEmailGroup(theForm.SOP_HMS_TableMaintForm.cmbEmailGroup.listObject.CM_EmailGroup);
	pxyHarbour.setProxy(app.myRoot);
	pxyHarbour.allTerminalsByCode.clear();
	pxyHarbour.setDefaultTerminal (theForm.SOP_HMS_TableMaintForm.cmbDefTerminal.listObject.CM_Terminal);
	theForm.mulSelect1.getSelected(pxyHarbour.allTerminalsByCode);	
	pxyHarbour.allWharfDisplayOrderArray.clear();
	theForm.mulSelect2.getSelected(pxyHarbour.allWharfDisplayOrderArray);
		
	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateHMSObject(pxyHarbour, theForm.myCurrentObject, app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateHMSObject(pxyHarbour, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	return app.myPassport.trxCompletedOK;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
