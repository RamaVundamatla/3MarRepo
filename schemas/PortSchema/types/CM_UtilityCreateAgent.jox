    <JadeMethod name="utlCreateBank" id="f9b14b2e-6f97-4b75-9cb6-277d0853416d">
        <source>utlCreateBank(_theController : CMIF_BankDetails input; _newBank:CM_Bank output; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	
begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valBank(_theController.myProxyBank);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	app.setContinueCMExceptions(false);

	create _newBank persistent;
	_newBank.setForCreate(_theController);
	
	if _passport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(_newBank);
	endif;
	if _passport.noErrors then
		_passport.myTerminal.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_COMPANY_CREATE),false,_newBank);
	endif;

end;</source>
        <Parameter name="_theController" type="CMIF_BankDetails" usage="input"/>
        <Parameter name="_newBank" type="CM_Bank" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateBargeCopies" id="912a89c0-6a82-4406-9398-41fe99cad8ad">
        <updating/>
        <source>utlCreateBargeCopies(	_allPxyVoyages : CM_VoyageArray input; 
						_sourceBargeVoyage : CM_Voyage; 
						_allTIs : CM_TIArray input;							// TFS 50878
						_copying : Boolean;									// TFS 50878
						_passport : CM_Passport input	) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 May 2020	jlgndl1	Initial creation	TFS 49417
24 May 2021	navdap1	TFS 50878 ASPA Bulk Barge Cargo Creation
*/

vars

	pxyVoyage : CM_Voyage;
	newVoyage : CM_Voyage;
	realVessel : CM_Vessel;
	realVoyGlobal : CM_VoyageGlobal;
	createSPS : Boolean;
	eventTrans : CM_EventTransaction;
	proxyEvent : CM_EventTransaction;
	newEventTrans : CM_EventTransaction;
	pxyTI, newTI : CM_TrackedItem;					// TFS 50878

begin
	// TFS 50878 create a cargo item for first voyage (on barge copy only, not barge create)
	if _copying then
		if _allTIs &lt;&gt; null then
			pxyTI := _allTIs.first;
			if pxyTI &lt;&gt; null then
				pxyTI.zSetPxyVoyage(_sourceBargeVoyage, _sourceBargeVoyage.code);
				pxyTI.zSetPxyLocationId(_sourceBargeVoyage.myShipBlockStack.ident);
				app.myUtilityCA.utlCreateTrackedItem(pxyTI, newTI, _passport);
				if _passport.hasErrors then
					return;
				endif;
				// if successful, move the new TI to the voyage, remove the first TI from the array, and add to deferred updates
				newTI.moveToLocation(_sourceBargeVoyage.myShipBlockStack, null, null, null, REAL_MODE, false, true, false, false, false, true, null, null, null, app.actualTimeServer, null, app.myPassport);
				_passport.addTrackedItemForDeferUpd(newTI);
			endif;
			if not _allTIs.isEmpty then
				_allTIs.remove(_allTIs.first);
			endif;
		endif;
	endif;
	// TFS 50878 end of this bit
	
	foreach pxyVoyage in _allPxyVoyages do
	
		realVessel := pxyVoyage.myVessel;
		createSPS := pxyVoyage.structureIncludesLOLO;
		newVoyage := null;

		app.myUtilityCA.utlCreateVoyage( pxyVoyage, newVoyage, realVessel, realVoyGlobal, createSPS, _passport );
		
		if _passport.hasErrors then
			break;
		endif;
		
		if newVoyage &lt;&gt; null then
		
		
			foreach eventTrans in _sourceBargeVoyage.allEventTransactionsByDateTime do
				if eventTrans.isKindOf( CMEVT_VoyageEvent ) then
					proxyEvent := eventTrans.myEventType.createEvent( eventTrans.dateTime, eventTrans.myTerminal, app.myPassport.myUser.code, true, eventTrans.noCharge, eventTrans.amount);
					proxyEvent.CMEVT_VoyageEvent.setMyVoyage( newVoyage );
					proxyEvent.CMEVT_VoyageEvent.setEndDataTime( eventTrans.myEventType.isFromToDateTimeRequired ,eventTrans.CMEVT_VoyageEvent.dateTimeEnd );
					proxyEvent.CMEVT_VoyageEvent.setUnitDescription( eventTrans.myEventType.unitDescription );					
					proxyEvent.CMEVT_VoyageEvent.setRemarks( eventTrans.CMEVT_VoyageEvent.remarks );								
					proxyEvent.CMEVT_VoyageEvent.setShiftFromProxy( eventTrans.CMEVT_VoyageEvent );
					proxyEvent.CMEVT_VoyageEvent.setJobDetails( eventTrans.CMEVT_VoyageEvent.myJob, eventTrans.CMEVT_VoyageEvent.myJobSheet);
					
					app.myUtilityCA. utlCreateEventTransaction( proxyEvent, newEventTrans,  _passport );
					
					delete proxyEvent;
					
					if _passport.hasErrors then
						break;
					endif;
				endif;
			endforeach;
		
			if _passport.hasErrors then
				break;
			endif;
			
			// TFS 50878 start of TI update
			if _allTIs &lt;&gt; null then
				pxyTI := _allTIs.first.CM_TrackedItem;
				if pxyTI &lt;&gt; null then
					pxyTI.zSetPxyVoyage(newVoyage, newVoyage.code);
					pxyTI.zSetPxyLocationId(newVoyage.myShipBlockStack.ident);
					app.myUtilityCA.utlCreateTrackedItem(pxyTI, newTI, _passport);
					if _passport.hasErrors then
						break;
					endif;
					// if successful, move ti to voyage and add TI to deferred updates
					newTI.moveToLocation(newVoyage.myShipBlockStack, null, null, null, REAL_MODE, false, true, false, false, false, true, null, null, null, app.actualTimeServer, null, app.myPassport);
					_passport.addTrackedItemForDeferUpd(newTI);
				endif;
				if not _allTIs.isEmpty then
					_allTIs.remove(_allTIs.first);
				endif;
			endif;
			// TFS 50878 end of TI update
		
		endif;
	
	endforeach;

epilog

	delete proxyEvent;

end;</source>
        <Parameter name="_allPxyVoyages" type="CM_VoyageArray" usage="input"/>
        <Parameter name="_sourceBargeVoyage" type="CM_Voyage"/>
        <Parameter name="_allTIs" type="CM_TIArray" usage="input"/>
