    <JadeMethod name="setDetails" id="3e2d3ce2-339c-42f9-b343-45b8236a2d4f">
        <updating/>
        <source>setDetails(_voyageJob : CM_VoyageJob; _selectedWLEs : CM_WLESet; _allVoyageJobs : CM_JobArray) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 February 2012	cnwer1	Initial creation CCMS MES 1033

*/

vars

begin
	
	if _selectedWLEs &lt;&gt; null then
		_selectedWLEs.copy(self.allSelectedWLEs);
	endif;
	if _allVoyageJobs &lt;&gt; null then
		_allVoyageJobs.copy(self.allVoyageJobs);
	endif;
	self.setMyVoyageJob(_voyageJob);
	
epilog

end;</source>
        <Parameter name="_voyageJob" type="CM_VoyageJob"/>
        <Parameter name="_selectedWLEs" type="CM_WLESet"/>
        <Parameter name="_allVoyageJobs" type="CM_JobArray"/>
    </JadeMethod>
    <JadeMethod name="setMyVoyageJob" id="36bdb5e1-a847-4f84-8ddf-1e4ebce3cee7">
        <updating/>
        <source>setMyVoyageJob(_voyageJob : CM_VoyageJob) updating, protected;
// --------------------------------------------------------------------------------
// Created:		31 August 2010 by cnwjo3
//
// Purpose:		
//
vars
	isUnactioned : Boolean;
begin
	self.myVoyageJob := _voyageJob;
	
	if self.allVoyageJobs.size &gt; 1 then
		self.chkMoveJob.enabled := false;
		self.chkMoveJob.value := true;
		self.txtNewJobID.enabled := false;
		self.txtNewJobID.text := null;
	else
		if self.myVoyageJob &lt;&gt; null then		
			isUnactioned := (self.myVoyageJob.status = JOB_UNACTIONED);
			self.chkMoveJob.enabled := isUnactioned;
			self.chkMoveJob.value := false; // PAR 30416 isUnactioned;
			
			if isUnactioned then
				self.txtNewJobID.enabled := not isUnactioned;
				self.txtNewJobID.text := null;
			endif;
			self.chkMoveJob.click(self.chkMoveJob);// PAR 30416	//20 Apr 2012	NDL	Par	29411 
		endif;
	endif;
	
// PAR 30416	self.chkMoveJob.click(self.chkMoveJob);	//20 Apr 2012	NDL	Par	29411 
	
	 // PAR 25968
	if self.myVoyageJob &lt;&gt; null then
		self.myVoyage:=self.myVoyageJob.myVoyage;
		self.myWorkPoint:=self.myVoyageJob.getWorkPointObject;
		self.currentVoyageJobSheet:=self.myVoyageJob.myJobSheet.CM_VoyageJobSheet;
		
		
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_voyageJob" type="CM_VoyageJob"/>
    </JadeMethod>
    <JadeMethod name="setNewJobIDtxtValue" id="ac491296-210b-4c8c-9238-27a58764c556">
        <updating/>
        <source>setNewJobIDtxtValue(_workPoint : CM_Object input) updating;
/* --------------------------------------------------------------------------------
// Created:		31 August 2010 by cnwjo3
//
// Purpose:		"If it is to the same crane (myCrane) the job id will be the same number with letter appended i.e. 101A.
//				If it is a transfer to a different crane then the new number will be the next available number for the job"
//				CCMS 1178 PAR 23366

16 Oct 2012	cnwer1	PAR 30574
*/
vars
	holdJobSheet : CM_VoyageHoldJobSheet;
	jobSheet : CM_VoyageJobSheet;
	notok : Boolean;
	wpid : String;
begin
	self.txtNewJobID.text :=null;
	
	if self.myVoyageJob = null then
		return;
	endif;
	
	if _workPoint = null then
		return;
	endif;
		
	
	wpid := _workPoint.IF_VoyageWorkPoint.getID;
		
	self.currentVoyageJobSheet:=self.myVoyageJob.myVoyage.allJobSheets[wpid];
	
	
	// ### TFS 3646
	if _workPoint.IF_VoyageWorkPoint.getWorkPoint &lt;&gt; null then // JOB SHEET is for a WORKPOINT
		// WP can be for roro decks or voyage holds. Do not mix the job types on the different job sheets.
		if self.myVoyageJob.isVoyageHoldJob &lt;&gt; self.currentVoyageJobSheet.isVoyageHoldJobSheet() then
			if self.myVoyageJob.isVoyageHoldJob() then
				app.msgBox(app.getErrorString1(Alloc_deck_sheet_this_voyag_ca,  wpid),app.getErrorString(Job_Sheet),MsgBox_OK_Only);
			else
				app.msgBox(app.getErrorString1(Alloc_hold_sheet_this_voyag_ca,  wpid),app.getErrorString(Job_Sheet),MsgBox_OK_Only);
			endif;
			
			self.cmbCrane.listIndex := -1;
			self.currentVoyageJobSheet:= null;
			
			return;
		
		endif;
	endif;
	
	 // PAR 25968
	if self.myVoyageJob.status = JOB_UNACTIONED and self.chkMoveJob.value then
		self.txtNewJobID.text := self.myVoyageJob.jobNum;
		return;
	endif;
	
	if self.currentVoyageJobSheet = null then
		return;
	endif;

	if self.currentVoyageJobSheet.allJobsByJobNum.isEmpty then
		self.txtNewJobID.text := self.myVoyage.getNextJobNumber(self.currentVoyageJobSheet, _workPoint.IF_VoyageWorkPoint).asStringJMT;
	elseif self.myWorkPoint = _workPoint  then	
		self.txtNewJobID.text := self.currentVoyageJobSheet.allJobsByJobNum.getNextJobSuffix(self.myVoyageJob.id);	
	else
		self.txtNewJobID.text := self.currentVoyageJobSheet.allJobsByJobNum.getNextJobID();
	endif;
	
end;</source>
        <Parameter name="_workPoint" type="CM_Object" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setTableDataFromOrganiser" id="c9a858b7-452e-43dd-a69b-7aaa9f872373">
        <updating/>
        <source>setTableDataFromOrganiser(_theTable: CM_DataTable input) updating;
// --------------------------------------------------------------------------------
