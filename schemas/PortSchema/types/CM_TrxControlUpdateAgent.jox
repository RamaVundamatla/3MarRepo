        <source>trxUpdateTIUnassignPack(_pxyTI : CM_TrackedItem; _passport : CM_Passport input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/07/2015	cnwdap1		Initial creation PAR #36484 Remove TI from booking and booking item,
//							unassign from release request
//
vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

