    <JadeMethod name="isChassisWorkEntryPresent" id="f479eeef-26d9-41aa-bf9c-44adbc4446a7">
        <updating/>
        <source>isChassisWorkEntryPresent(_chassis : CM_TILC) : Boolean updating, protected;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 29 June 2007
//
//----------------------------------------------------------------------

vars
	wle : CM_WorkListEntry;
begin
	foreach wle in self.myJob.workListEntries discreteLock where wle.myTrackedItem &lt;&gt; null and wle.myTrackedItem.isKindOf(CM_TILC) do
		if wle.myTrackedItem.id = _chassis.id then
			return true;
		endif;
	endforeach;
	
	return false;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_chassis" type="CM_TILC"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadWorkEntries" id="eb1218ed-9238-4a06-8d86-e2f00f57ea79">
        <updating/>
        <source>loadWorkEntries() updating, protected;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 31 May 2007
//
//----------------------------------------------------------------------

vars
	wle : CM_WorkListEntry;
	job : CM_RoadJob;
begin
	job := self.myJob.CM_RoadJob;
	
	if job = null then
		return;
	endif;
	
	self.tblReceivals.allSelectedObjects.clear();
	self.tblReleases.allSelectedObjects.clear();
	self.tblReceivals.rows := self.tblReceivals.fixedRows;
	self.tblReleases.rows := self.tblReleases.fixedRows;
	
	foreach wle in self.myJob.workListEntries do
		self.addWorkEntry(wle);
	endforeach;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
