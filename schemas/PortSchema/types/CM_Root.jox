    <JadeMethod name="setLicenseName" id="8e046710-e1b1-424e-b469-6ca93a22bc2f">
        <updating/>
        <source>setLicenseName(_name, _productCode : String) updating;
// ---------------------------------------------------------------------------
// Created:     01 April 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	
	if _productCode = ProductCode_JMT
	or _productCode = ProductCode_Subs	//19 Jun 2020	NDL	TFS 49569
	then
		self.licenseName := _name;
		if self.licenseName = null then
			//no longer licensed
			self.setPropertyValue('extraInfo', null);
			self.setConfig("SUBS",null, true);	//19 Jun 2020	NDL	TFS 49569
		endif;
	// ### JIRA 33541 12DEC2024 NAVAB1
	elseif _productCode = ProductCode_EWS then
		self.licenseEWS := _name;
	elseif _productCode = ProductCode_JMT_EDI then
		self.licenseNameEDI := _name;
	else
		app.raiseCMException1(ErrInvalidLicenseProductCode, _productCode, '_productCode', null);
	endif;

end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_productCode" type="String"/>
    </JadeMethod>
