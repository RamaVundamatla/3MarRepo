    <JadeMethod name="isSealed" id="cf373ddc-a385-496c-917e-e1e008d3b492">
        <source>isSealed():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 March 2015	cnwndl1	Initial creation

*/

vars

	seal : CM_WagonSeal;
	sealValue : String;

begin

	if self.allWagonSeals.isEmpty then
		return false;
	endif;
	
	foreach seal in self.allWagonSeals do
		sealValue := seal.getSealValueAsString.trimBlanks;
		if sealValue &lt;&gt; null then
			//could be just history showing 'previous seal' value
			return true;
		endif;
	endforeach;
	
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
