    <JadeMethod name="trxUpdateTrain" id="89b016c7-13a4-42e8-bedc-04289148d4df">
        <updating/>
        <source>trxUpdateTrain(_pxyTrain : CM_Train input; _isValidate : Boolean; _passport : CM_Passport input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	06 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
25 Oct 2024  navma1		 MTN-33231 MTN - Enable Deferred Updates For Train and Wagon Events 
----------   ----------  --------------------------------------------------
*/
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);

	_passport.useEventDeferUpdate := true;			//25.10.2024 navma1 #MTN-33231
	
	beginTransaction;
	
	app.myUtilityUA.utlUpdateTrain(_pxyTrain, _isValidate, true, _passport);
	
	if _passport.noErrors then					   //25.10.2024 navma1 #MTN-33231
		_passport.doDeferredUpdates();
	endif;

epilog
	self.finaliseActivityWithPassport(_passport);
end;
</source>
