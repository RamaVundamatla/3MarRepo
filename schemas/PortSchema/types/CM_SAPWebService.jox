    <JadeMethod name="getDisplayStringForAttribute" id="da456879-dc5c-4640-9206-22bb020d37db">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//
// 11 Jun 2018	jlgrs1	TFS 39013 (37190) Pelindo BGP Web Service
// 13 Mar 2019	jlgsl4	TFS 40360 - NXL - KiwiRail EDI message
// 09 APr 2020	jlgdap1	TFS 49003 API Inline Agent
// 13 Jul 2020  cnwma1  Bug 49243: MTN - Cargo Chain Web Service Callback INI value
// 21 Sep 2020 cnwma1 ChangeRequest 49906: MTN - Ops View External Webservice

vars

begin
	if _attrName = ETRow_WebServiceType then
		return ExternalWebServiceSAP;
	endif;

	return inheritMethod(_attrName, _short);
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="f436656c-7535-4474-a75c-ef5d1cd842e1">
        <source>validateMe() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 November 2018	jlgmp6	Initial creation	TFS41999

*/

vars

begin
	inheritMethod();

	if self.userCode = null then
		app.raiseCMException1(Input_required_field_Required, app.getString(User), self.userCode, null);
	endif;
	if self.password = null then
		app.raiseCMException1(Input_required_field_Required, app.getString(Password), null, null);
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
