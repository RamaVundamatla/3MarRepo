    <JadeMethod name="getDisplayStringForAttribute" id="f9af99cb-4c1e-4988-b2ff-6bb97857d2c3">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

// Created by cnwdvb1 on 23 November 2006

// 10/09/2008	concms1	par17903/ccms 1741 Welcome screen - interim solution
//03 May 2024   navbs1  Bug 63983: GPHA - Error when creating or editing user: Invalid property value 'dataAccessCustomsAgent', does not exist for class CM_User/2412.5

vars
	dac	: CM_DataAccessController;
begin

	if _attrName = ETRow_DataAccessCarrier then
		dac := self.allDataAccessControllers[CM_Carrier.name];
		if dac = null then
			return null;
		endif;
		return dac.name;

	elseif _attrName = ETRow_DataAccessOrganisation then
		dac := self.allDataAccessControllers[CM_Organisation.name];
		if dac = null then
			return null;
		endif;
		return dac.name;
		
	elseif _attrName = ETRow_DataAccessOperator then
		dac := self.allDataAccessControllers[CM_Operator.name];
		if dac = null then
			return null;
		endif;
		return dac.name;
		
	elseif _attrName = ETRow_DataAccessConsignee then
		dac := self.allDataAccessControllers[CM_ConsigneeConsignor.name];
		if dac = null then
			return null;
		endif;
		return dac.name;
		
	elseif _attrName = ETRow_SystemSecurityRole then
		if self.mySystemSecurityRole = null then
			return null;
		else
			return self.mySystemSecurityRole.name;
		endif;
		
	elseif _attrName = ETRow_NotAvailableForEntry then
		return self.isNotAvailableForEntry.String; 
		
	elseif _attrName = ETRow_Status then 	// *************************
		return app.userStatusEnumToString(self.status); 

	elseif _attrName = ETRow_MyOrganisation then // 'myOrganisation' then // *********************
		if self.myOrganisation = null then
			return null;
		else
			return self.myOrganisation.name; 
		endif;
	elseif _attrName = ETRow_MyLocale then 
		if self.myLocale = null then
			return null;
		else
			return self.myLocale.localeDescription; 
		endif;
	elseif _attrName = ETRow_EmailAddress then
		return self.getEmailAddress();
		
	elseif _attrName = ETRow_RadioTelemetryOnly then
		if self.radioTelemetryDevice = null then
			return null;
		else
			return self.radioTelemetryDevice.model.String;
		endif;
	elseif _attrName = ETRow_ShowWelcomeScreen then	// par 17903
		return self.getShowWelcomeScreen.String;	// par 17903
		
	elseif _attrName = ETRow_DataAccessSubTerminal then				// par 19803
		dac := self.allDataAccessControllers[CM_SubTerminal.name];	// par 19803
		
		if dac = null then											// par 19803
			return null;											// par 19803
		endif;														// par 19803
		return dac.name;											// par 19803
	elseif _attrName = ETRow_SingleSignOnOnly then //+ cnwmd1 Par 22287
		return self.getUserSingleSignOnOnly.String;
		
	elseif _attrName = ETRow_SingleSignOnOverride then				// TFS 51226
		return self.getUserSingleSignAllowOverride.String;			// TFS 51226
		
	elseif _attrName = ETRow_TerminalSecurityRole then	//06 Aug 2019	NDl	TFS 45057
		return self.getTerminalSecRoles();
	elseif _attrName = ETRow_SsoMatchingId then		//20.07.2022 navam1 #52824
		return self.getSSOMatchingId();
	elseif _attrName = ETRow_SsoLinkedIdentifier then		//20.07.2022 navam1 #52824
		return self.getSSOUniqueId();
	elseif _attrName = ETRow_DataAccessCustomsAgent then		//03.05.2024 navbs1 #63983
		dac := self.allDataAccessControllers[CM_CustomsAgent.name];
		if dac = null then
			return null;
		endif;
		return dac.name;
	endif;
	
	return inheritMethod(_attrName, _short);

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
