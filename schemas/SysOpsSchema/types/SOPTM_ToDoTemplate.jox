    <JadeMethod name="doResize" id="eddbce2b-1711-4298-9f5c-58283e8126a6">
        <source>doResize();
//----------------------------------------------------------------
//	Created:	15 June 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------

vars

	mulSelect	: CMUI_MultiSelectGroupBox;
begin
	
	inheritMethod();

	mulSelect := self.myForm.mulSelect41;
	mulSelect.height := mulSelect.parent.height/2.5;
	self.myForm.mulSelect42.top := mulSelect.top + mulSelect.height + 5;
end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="2f233d1d-c5e2-445e-b4ff-53ddee083b51">
        <updating/>
        <source>doSave(): Boolean updating;

vars
	errObj				: CM_Error;
	idx					: Integer;
	ignoreWarnings,
	rtnValue			: Boolean;
	proxyToDoTemplate	: CM_ToDoTemplate;
	lId					: String; 
	lEmpties,lExports,
	lImports,lFull,
	lStorage,
	lTranships			: Boolean;					// 21/09/2010 cnwmh5 #25602
	lAvailabilityGrades	: CM_MTGradeByCodeDict;
	lIsoGroups			: CM_ISOTypeGroupByCodeDict;
	lIsoTypes			: CM_ISOTypeByCodeDict; 
	lOperators			: CM_OperatorByCodeDict;
	lToDoTasks			: CM_ToDoTaskDescByCode;
	lMTGrade			: CM_MTGrade;
	theForm				: SOP_TableMaintForm;
	msg 				: String;

begin
    theForm := self.myForm; 

	lId := theForm.tblInput1.getValueByName(ETRow_Id).String;
	lEmpties := theForm.tblInput1.getValueByName(ETRow_Empties).Boolean;
	lExports :=theForm.tblInput1.getValueByName(ETRow_Exports).Boolean;
	lImports := theForm.tblInput1.getValueByName(ETRow_Imports).Boolean;
	lFull := theForm.tblInput1.getValueByName(ETRow_Full).Boolean;
	lStorage := theForm.tblInput1.getValueByName(ETRow_Storage).Boolean;
	lTranships := theForm.tblInput1.getValueByName(ETRow_Tranships).Boolean;		// 21/09/2010 cnwmh5 #25602
	lMTGrade := theForm.cmbAvaGrades.listObject.CM_MTGrade;

	create lAvailabilityGrades transient;
	create lIsoGroups transient;
	create lIsoTypes transient; 
	create lOperators transient; 
	create lToDoTasks transient;

    theForm.mulSelect1.getSelected(lAvailabilityGrades); 
    theForm.mulSelect2.getSelected(lOperators);
    theForm.mulSelect3.getSelected(lToDoTasks);   
    theForm.mulSelect41.getSelected(lIsoTypes);    
    theForm.mulSelect42.getSelected(lIsoGroups);
	
	if theForm.optTypes.value then
		if not lIsoGroups.isEmpty then
			app.raiseCMException2(ISOGroups_or_ISOTypes, app.getErrorString(ISOTypes), app.getErrorString(ISOGroups), null, null);
			return false;
		endif;
	elseif theForm.optGroups.value then
		if not lIsoTypes.isEmpty then
			app.raiseCMException2(ISOGroups_or_ISOTypes, app.getErrorString(ISOGroups), app.getErrorString(ISOTypes), null, null);
			return false;
		endif;
	endif;
   
  	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_ToDoTemplate transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;
	proxyToDoTemplate := theForm.myProxyObject.CM_ToDoTemplate;
	proxyToDoTemplate.setProxy(lId,lEmpties,lExports,lImports,lFull,lStorage, lTranships,
	                           lAvailabilityGrades,lIsoGroups,lIsoTypes,lOperators,lToDoTasks,lMTGrade) ;
	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateToDoTemplate(proxyToDoTemplate, theForm.myCurrentObject, app.myPassport);
		rtnValue := app.myPassport.trxCompletedOK;
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateToDoTemplate(proxyToDoTemplate, app.myPassport );
		rtnValue := app.myPassport.trxCompletedOK;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;

	// 27/09/2010 cnwmh5 #25602 - Start
	///if theForm.myCurrentObject &lt;&gt; null and theForm.myCurrentObject.isKindOf(CM_ToDoTemplate) then
	///	beginTransaction;
	///	theForm.myCurrentObject.CM_ToDoTemplate.setExtraDataValueForTranships(lTranships);
	///	commitTransaction;
	///endif;
	// 27/09/2010 cnwmh5 #25602 - End
	
	return rtnValue;
epilog
	delete lAvailabilityGrades ;
	delete lIsoGroups ;
	delete lIsoTypes ; 
	delete lOperators ; 
	delete lToDoTasks ;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCollection" id="cbe7322c-e095-48f2-b64b-844ae59cbc63">
        <source>getCollection(): Collection;

vars

begin
	return self.myForm.myTerminal.allToDoTaskTemplates;
end;</source>
        <ReturnType type="Collection"/>
    </JadeMethod>
