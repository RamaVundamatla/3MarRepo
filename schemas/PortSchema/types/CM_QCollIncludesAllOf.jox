    <JadeMethod name="doMatch" id="a5cc1d16-6509-460d-87c5-be387b743cc3">
        <source>doMatch(_value: Any): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Apr 2013	cnwpjs1	Initial creation  PAR # 31237

*/

vars

obj	: Object;

begin
	if self.allSelectionValues.isEmpty then //Haven't selected any items so assume it's ok.  
		return true;
	endif;
	
	if _value = null then
		return false;
	endif;
	

	foreach obj in allSelectionValues do
		if not _value.Collection.includes(obj) then
			return false;
		endif;
	endforeach;
													
	return true;

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
