    <JadeMethod name="getDisplayStringForAttribute" id="a342a04c-4338-4358-b99a-f2dade7999ed">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 14/02/2022	navdap1		Initial creation TFS 52268 AAT 1-Stop VBS Integration
// 19/12/2022	navmk20		Bug 55820: AAT - External Web Service Monitor Column Organiser
vars

begin
	if _attrName = ETRow_Sequence then
		return null;
	elseif _attrName = ETRow_IsSnapshot then // 19.12.2022 navmk20 TFS 55820
		return null;						 // 19.12.2022 navmk20 TFS 55820
	endif;
	
	return inheritMethod(_attrName, _short);
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initialiseActivity" id="fbe9c3fd-8cb7-4499-b6a8-d39aa1fac926">
        <updating/>
        <source>initialiseActivity(_description: String; _interface: String; _terminal: CM_Terminal; _opsViewObject: CM_Object; _dataAction: Character; _dataType: String; _snapshot: Boolean; _oid: String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 December 2021	navpw1	Initial creation TFS: 52268

*/

begin
	inheritMethod(_description, _interface, _terminal, _opsViewObject, _dataAction, _dataType, _snapshot, _oid);
	
	self.myReleaseRequestObject := _opsViewObject;
	self.dataAction := _dataAction;
	self.dataType := _dataType;
	self.objectOid := _oid;

end;</source>
        <Parameter name="_description" type="String"/>
        <Parameter name="_interface" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_opsViewObject" type="CM_Object"/>
        <Parameter name="_dataAction" type="Character"/>
        <Parameter name="_dataType" type="String"/>
        <Parameter name="_snapshot" type="Boolean"/>
        <Parameter name="_oid" type="String"/>
    </JadeMethod>
