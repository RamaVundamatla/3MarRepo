    <JadeMethod name="dragSelectEnd" id="20f8593e-5488-4a37-a6c7-8318d43412ce">
        <updating/>
        <source>dragSelectEnd(_dragSelectFrame : CMUI_GridAreaDrawingFrame input; _x, _y : Real) updating;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:		End of selection with dragged rectangle
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 22/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------
vars
	frame			: CMUI_GridAreaFrame;
	gridArea		: CMUI_GridArea;
	railDockBar 	: YRD_RailDockBar;
	x1, y1, x2, y2 	: Real;
	
begin
	x1 := _x.min(self.origXPos);
	x2 := _x.max(self.origXPos);
	y1 := _y.min(self.origYPos);
	y2 := _y.max(self.origYPos);

	railDockBar := _dragSelectFrame.parent.CMUI_ScrollableDrawingFrame.parent.YRD_RailDockBar;

	_dragSelectFrame.windowToScreen(x1, y1);
	railDockBar.mySDF.myDrawingFrame.screenToWindow(x1, y1);
	_dragSelectFrame.windowToScreen(x2, y2);
	railDockBar.mySDF.myDrawingFrame.screenToWindow(x2, y2);
	
	_dragSelectFrame.clearGraphics;
	_dragSelectFrame.dragMode := DragMode_None;
	_dragSelectFrame.visible := false;

	//  Select wagons

	railDockBar.mySDF.clearAllSelectedPoints();
	
	foreach gridArea in railDockBar.mySDF.allGridAreasByRowColumn do
		frame := gridArea.myGridAreaFrame;
		if frame &lt;&gt; null
		and frame.left &lt; x2
		and frame.top &lt; y2
		and frame.left + frame.width &gt; x1
		and frame.top + frame.height &gt; y1 then
			gridArea.YRD_WagonArea.selectWagon();
		endif;
	endforeach;
	
epilog

end;</source>
        <Parameter name="_dragSelectFrame" type="CMUI_GridAreaDrawingFrame" usage="input"/>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="dragSelectStart" id="c045111b-d041-427c-b393-d68efce992a6">
        <updating/>
        <source>dragSelectStart(frame: CMUI_GridAreaFrame input; _x, _y : Real) updating;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:		Start selection with dragged rectangle
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 22/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------
vars
	dragSelectFrame : CMUI_GridAreaDrawingFrame;
	railDockBar : YRD_RailDockBar;
	x1, y1 : Real;

begin
	railDockBar := frame.parent.CMUI_DrawingFrame.parent.CMUI_ScrollableDrawingFrame.parent.YRD_RailDockBar;
	dragSelectFrame := railDockBar.myDragSelectFrame;
	
	dragSelectFrame.move(0, 0, railDockBar.mySDF.width, railDockBar.mySDF.height);
	dragSelectFrame.visible := true;
	dragSelectFrame.zOrder(1);
	
	dragSelectFrame.isDrawDeskTopRectangle := true;
	dragSelectFrame.dragMode := DragMode_Drag;
	dragSelectFrame.dragCursor := self.picYAAreaCur.picture;
	
	x1 := self.origXPos;
	y1 := self.origYPos;

	if frame &lt;&gt; null then
		frame.windowToScreen(x1, y1);
		dragSelectFrame.screenToWindow(x1, y1);
	endif;

	self.origXPos := x1;
	self.origYPos := y1;

epilog

end;</source>
        <Parameter name="frame" type="CMUI_GridAreaFrame" usage="input"/>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="dragTrackedItem" id="23fc4fe9-130b-49eb-84c5-b29555677dd1">
        <updating/>
        <source>dragTrackedItem(_ti : CM_TrackedItem; _wle : CM_WorkListEntry; _control : Control input) updating;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:		
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	picture			: Picture;
	wleObj			: CM_WorkListEntry;
	obj				: Object;
	tmpTi			: CM_TrackedItem;
	origLocn		: CM_LocationsController;
	moveController	: CMIF_MoveController;
	invalidWLE		: Boolean;
	
begin
	on Exception do app.handleDeletedObject(exception, wleObj, invalidWLE);		 // PAR 17940

	// Par 14454 Jade doesn't seem to cope with invalid objects in delete
	if global.isValidObject(app.myMoveController) then
		delete app.myMoveController;
	endif;

	create moveController transient;	
	app.myMoveController := moveController;
	moveController.setMoveMode(self.moveModeForm);			
	moveController.setMyTrackedItem(_ti);
	origLocn := _ti.getPrimaryLocation(REAL_MODE);	
	if origLocn &lt;&gt; null then
		moveController.setEffectiveTimeStampOverride(origLocn.getEffectiveTimeStamp());
	endif;

	//WLE could be null if drag from grid area.
	
	wleObj	:=	_wle;
	
	if wleObj &lt;&gt; null then
		wleObj.setMoveControllerAllOtherTIs(moveController);
		
		if invalidWLE then // PAR 17940
			self.myCurrentTrackedItem := null; // PAR 17940
			return; // PAR 17940
		endif; // PAR 17940
	endif;
	
	if _wle &lt;&gt; null then
		if moveController.allOtherTrackedItems.isEmpty then
			if moveController.moveMode = REAL_MODE and		// 22/04/2009 cnwar2 #19464
			_ti.myPrimaryQueuedLocation &lt;&gt; null then		// wle should not be updated if the move is instant and the item is queued
				moveController.setMyWorkListEntry(null);	// (unless the move is to the queued location, this is handled later)
			else
				moveController.setMyWorkListEntry(_wle);
			endif;
		else
			moveController.setJobForMove(_wle.job);		
		endif;
	endif;
	
	_control.dragMode := DragMode_Drag;
	
	create picture transient;
	self.setPictureDragCursor(picture);
	if picture &lt;&gt; null then
		_control.dragCursor := picture.picture;
	endif;
epilog
	if picture &lt;&gt; null then
		delete picture;
	endif;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_control" type="Control" usage="input"/>
    </JadeMethod>
    <JadeMethod name="dragWagon" id="ff77c5a2-ef1b-47ad-bf97-02848a355d3c">
        <updating/>
        <source>dragWagon(_wagon : CM_Wagon; _control : Control input) updating;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:     
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 22/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// 19/08/2022 	navsj20		ChangeRequest 54281: EUP - Wagon Track Planning

// ---------------------------------------------------------------------------
vars
	moveController	: CMIF_WagonMoveController;
	picture			: Picture;

begin
	if global.isValidObject(app.myMoveController) then
		delete app.myMoveController;
	endif;

	app.myMoveController := null;
	
	if global.isValidObject(app.myWagonMoveController) then
		delete app.myWagonMoveController;
	endif;

	create moveController transient;	
	app.myWagonMoveController := moveController;
	
	moveController.isFromTrain := self.isDisplayedTrains;
	moveController.setMoveMode(self.getMoveMode); 		//19 Aug 2022	navsj20	TFS 54281

	self.getSelectedWagons( moveController.allWagons, _wagon );

	if moveController.allWagons.isEmpty then
		delete app.myWagonMoveController;
		return;
	endif;
	
	moveController.autoSetEffectiveTimeStamp();	//26 Feb 2021	NDL	TFS 50837
	
	_control.dragMode := DragMode_Drag;
	
	create picture transient;
	self.setPictureDragCursor(picture);
	if picture &lt;&gt; null then
		_control.dragCursor := picture.picture;
	endif;
	
	_control.dragCursor := self.picMvWagon.picture;
	// START 19 Aug 2022	navsj20	TFS 54281
	if self.moveModeForm = PLANNING_MODE then
		_control.dragCursor := self.picMvPlannedWagon.picture;
	endif;
	// END 19 Aug 2022	navsj20	TFS 54281
epilog
	if picture &lt;&gt; null then
		delete picture;
	endif;
end;</source>
        <Parameter name="_wagon" type="CM_Wagon"/>
        <Parameter name="_control" type="Control" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawDragSelectFrame" id="a1763219-56ee-452f-b2a9-c9f8c47f8c00">
        <updating/>
        <source>drawDragSelectFrame(_dragSelectFrame : CMUI_GridAreaDrawingFrame input; _x, _y : Real) updating;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:		End of selection with dragged rectangle
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 22/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------
vars

begin
	_dragSelectFrame.clearGraphics;

	_dragSelectFrame.drawStyle := Frame.DrawFillStyle_Transparent;
	_dragSelectFrame.drawWidth := 1;

	_dragSelectFrame.drawFillStyle := Frame.DrawFillStyle_Transparent;
	_dragSelectFrame.drawFillColor := Black;

	_dragSelectFrame.drawFilledRectangle(self.origXPos.Integer, self.origYPos.Integer, _x, _y, Black);

epilog
	
end;</source>
        <Parameter name="_dragSelectFrame" type="CMUI_GridAreaDrawingFrame" usage="input"/>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawingFrameMouseDownEvent" id="4ae1cf84-326c-42e3-9a1b-65987b07d4ce">
        <updating/>
        <source>drawingFrameMouseDownEvent(_button : Integer; _x, _y : Real)updating;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:		
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 23/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------
vars
	lX, lY 		: Real;

begin
	lX := _x;
	lY := _y;
	self.myCurrentGridAreaFrame.windowToScreen(lX, lY);
	self.screenToWindow(lX, lY);

	if _button = Window.MouseButton_Right then
		self.setGridAreaContextMenu(null, lX.Integer, lY.Integer);
	endif;
end;</source>
