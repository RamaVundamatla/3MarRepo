        <updating/>
        <source>tblWagons_dblClick(table: CM_DataTable input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	09 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	mode : Integer;
begin
	if table.row &gt; table.fixedRows then
		mode := YRD_TrainWagonForm.Mode_View;
		self.doEditViewWagon(mode); //+ cnwmd1, CCMS 1067, Par 19913
	else
		table.resortTableByColumn(table.column);
	endif;
	
end;


</source>
