    <JadeMethod name="canTakePhoto" id="4cf4af22-fa0b-4c11-a485-2956ae535599">
        <source>canTakePhoto():Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 December 2010	cnwndl1	Initial creation	Par 23831

*/

vars

	rtDevice : CM_RadioTelemetryDevice;
	
begin
	if app.isDevelopmentSystem() then
		return true;
	endif;
	
	rtDevice := app.myLogonAgent.myRTDevice;
	if rtDevice = null then
		return false;
	endif;
	
	return rtDevice.canTakePhoto();

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="convertCargoIdForSearch" id="a6bfc8e6-164c-4eac-8071-234b6a74fe2c">
        <source>convertCargoIdForSearch(	_rawId: String;
							_cargoType : Integer;
							_imex : Integer;
							_voyage : CM_Voyage;
							_convertedCargoId: String output;
							_convertedAltId: String output
							);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 July 2016	cnwndl1	Initial creation	TFS 2275 / 2216

*/

vars

	cmifID : CMIF_IDConversion;

begin
	
	create cmifID transient;
	cmifID.scannedValue := _rawId;
	cmifID.myTerminal := self.myTerminal;
	cmifID.cargoType := _cargoType;
	cmifID.imexStatus := _imex;
	cmifID.myVoyage := _voyage;
	cmifID.isAlternateId := false;
	cmifID.callerName := self.class.name;	//18 Aug 2016	NDL	TFS 2567
	
	_convertedCargoId := app.convertScannedCargoId( null, null, false, cmifID );
	
	cmifID.isAlternateId := true;
	_convertedAltId := app.convertScannedCargoId( null, null, false, cmifID );
		
epilog

	delete cmifID;

end;</source>
        <Parameter name="_rawId" type="String"/>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_imex" type="Integer"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_convertedCargoId" type="String" usage="output"/>
        <Parameter name="_convertedAltId" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="create" id="c2f0e45b-781c-42f7-93d7-e02e9f7abcf0">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>create() updating, clientExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 March 2016	cnwndl1	Initial creation

*/

vars

begin

	if app.myHandHeldCheckerAgent &lt;&gt; null then
		self.myMobileGenericAgent := app.myHandHeldCheckerAgent.myMobileGenericAgent;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="b4ace705-407e-46dc-bcca-0b71e85ed557">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>delete() updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:	01 September 2009 By Graeme Black cnwgb1
// Status: 	Unfinished
// Purpose:	
// ---------------------------------------------------------------------------
vars
begin
	if  app.myLogonAgent &lt;&gt; null and app.myLogonAgent.isKindOf(VehicleMountedLogonAgent) then
		return;
	endif;
	
	if not app.isOnDevice() and not self.modal then
		self.getSessionAgent().setLastScreenPosition(self.left.Integer, self.top.Integer, self.width.Integer, self.height.Integer );
	endif;
epilog
end;</source>
    </JadeMethod>
