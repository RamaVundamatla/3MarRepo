        <source>setForCreate(prxyRestriction : CM_LocationRestriction) updating;
// ---------------------------------------------------------------------------
// Created:     05 February 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

//	self.setId(prxyRestriction.myTerminalArea);
	self.setForUpdate(prxyRestriction);
	self.myTerminalArea := prxyRestriction.myTerminalArea;

end;</source>
        <Parameter name="prxyRestriction" type="CM_LocationRestriction"/>
