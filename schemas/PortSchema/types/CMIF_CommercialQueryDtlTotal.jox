<Class name="CMIF_CommercialQueryDtlTotal" id="48c2cbec-be5c-48b2-82eb-af9f84ec6871">
    <superclass name="CMIF_CommercialQueryEntity"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="transact"/>
    <ImplicitInverseRef name="allTotalDtlTIs" id="e0b9af05-5135-44bc-8ed2-39159692c4a7">
        <memberTypeInverse/>
        <type name="CM_TISet"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <PrimAttribute name="cargoType" id="b08ae0a6-7140-4658-9777-4e6181aba066">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="cargoTypeDescr" id="48e1be29-15be-460a-8ae5-6ed3183c4085">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="columnType" id="c8d5531b-3d4a-48bd-a634-426a6321a986">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <ExplicitInverseRef name="myHdr" id="12d017cb-3153-43c3-9e11-7897e4f0542e">
        <kind>child</kind>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CMIF_CommercialQueryHeader"/>
        <access>readonly</access>
        <Inverse name="CMIF_CommercialQueryHeader::allTotalDlts"/>
    </ExplicitInverseRef>
    <PrimAttribute name="num" id="50da002f-4b72-4177-a78a-393b1e862400">
        <precision>16</precision>
        <scaleFactor>4</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="type" id="81523ea7-eb5c-43cd-9df6-21533426ef80">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="addTI" id="6bf4b0e4-86cf-4eaa-b8bb-d44134e20b4d">
        <updating/>
        <source>addTI(_ti : CM_TrackedItem; _num : Decimal) updating;
// ---------------------------------------------------------------------------
// Created:     23 November 2007 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	
begin
	self.allTotalDtlTIs.add(_ti);
	self.num := self.num + _num;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_num" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getTISet" id="8eac91f8-35bc-489d-96fc-fbeed5e20e30">
        <source>getTISet(): CM_TISet;
// ---------------------------------------------------------------------------
// Created:     18 February 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	return self.allTotalDtlTIs;
end;</source>
        <ReturnType type="CM_TISet"/>
    </JadeMethod>
    <JadeMethod name="init" id="4c1b335c-8357-404b-888f-2b73d978c332">
        <updating/>
        <source>init(_cargoTypeDescr : String; _cargoType, _type, _columnType : Integer; _hdr : CMIF_CommercialQueryHeader) updating;
// ---------------------------------------------------------------------------
// Created:     26 November 2007 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.allTotalDtlTIs.clear;
	self.cargoTypeDescr := _cargoTypeDescr;
	self.cargoType	:= _cargoType;
	self.columnType := _columnType;
	self.type := _type;
	self.myHdr := _hdr;
end;</source>
        <Parameter name="_cargoTypeDescr" type="String"/>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_columnType" type="Integer"/>
        <Parameter name="_hdr" type="CMIF_CommercialQueryHeader"/>
    </JadeMethod>
</Class>
