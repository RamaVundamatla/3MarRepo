    <JadeMethod name="maintainAddress" id="74a4d2e6-72b7-4ab6-9707-9529d83405d5">
        <source>maintainAddress() protected;

vars
	formObj			: CnEcEmailAddressMaintForm;
	emailAddressObj	: CnEcEmailAddress;
	
begin
	emailAddressObj	:=	lstAddressPerson.listObject.CnEcEmailAddress;
	
	create formObj;
	formObj.aMyEmailAddress		:=	emailAddressObj;
	formObj.aMyEmailSendForm	:=	self.aMyEmailSendForm;
	formObj.showModal();
	
	self.populateAddressPersonList();
epilog
	if app.isValidObject(emailAddressObj) then
		lstAddressPerson.listIndex := lstAddressPerson.findObject(emailAddressObj);
		
		if lstAddressPerson.listIndex &gt; 0 then
			btnAddressMaint.enabled := true;
		else
			btnAddressMaint.enabled := false;			
		endif;		
	else
		btnAddressMaint.enabled := false;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateAddressPersonList" id="0a00d297-ac23-4eb5-bac8-04e652b8fe97">
        <source>populateAddressPersonList() protected;

vars
	baseDataObj	: CnEcEmailBaseData;
	
begin
	baseDataObj	:=	self.aMyEmailSendForm.aMyEmailBaseData;

	lstAddressPerson.listCollection(baseDataObj.allEmailAddresses, true, 0);
	btnAddressMaint.enabled	:=	false;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="select" id="abdc4163-1208-47fe-b5b5-919af9eac4b7">
        <updating/>
        <source>select() updating, protected;

begin
	if lstAddressPerson.listIndex &gt; 0 then
		aMyEmailSendForm.aSelectedPersonAddress := lstAddressPerson.listObject.CnEcEmailAddress.emailAddress;
	elseif lstLdapPerson.listIndex &gt; 0 then
		aMyEmailSendForm.aSelectedPersonAddress := lstLdapPerson.text;
	endif;
	
	unloadForm();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="updateAddressBook" id="111c2777-f540-457a-9ea7-1ecb61e608a4">
        <source>updateAddressBook() protected;

vars
	baseDataObj		: CnEcEmailBaseData;
	emailAddObj		: CnEcEmailAddress;
	errorMsg		: String;
	addresseeName	: String;
	
begin
	baseDataObj		:=	aMyEmailSendForm.aMyEmailBaseData;
	addresseeName := aAllNamesArray[lstLdapPerson.listIndex];
	lstAddressPerson.listIndex := lstAddressPerson.findStringExact(1,addresseeName);
	
	if lstAddressPerson.listIndex &gt; 0 then
	
		app.msgBox("'" &amp; addresseeName &amp; "' already in your Address Book. Not added" ,"Error",MsgBox_OK_Only);
		lstLdapPerson.listIndex := CNEC_NULL_INDEX; 
	else
	
		errorMsg := aMyEmailSendForm.aMyTA.trxCnEcEmailAddressCreate(baseDataObj,	//pCnEcEmailBaseDataParent : CnEcEmailBaseData io;
																	lstLdapPerson.text,	//pEmailAddress:String;
																	baseDataObj,	//pMyBaseData:CnEcEmailBaseData;
																	addresseeName,	//pName:String;
																	emailAddObj	//pCnEcEmailAddressNew : CnEcEmailAddress output
																	);
		if errorMsg &lt;&gt; null then
			app.msgBox(errorMsg,"Error",MsgBox_OK_Only);
		else
			self.populateAddressPersonList();
			lstAddressPerson.listIndex := lstAddressPerson.findStringExact(1,addresseeName);
			btnAddressMaint.enabled := true;
			lstLdapPerson.listIndex := CNEC_NULL_INDEX;
		endif;
	
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
</GUIClass>
