    <JadeMethod name="validateModeAndFlip" id="f6d03199-4988-4538-afe5-fb637890dcab">
        <source>validateModeAndFlip(_mode : Integer; _flipH, _flipV : Boolean) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2010	cnwjk3	Initial creation

*/

vars

begin
	if _mode = CMIF_RDTDrawElement.MODE_TOPDOWN then
		if not self.canDisplayTopDown() then
			app.raiseUnexpectedProgramError(class.name, method.name, "display mode MODE_TOPDOWN unsupported for this class type");
		endif;
	elseif _mode = CMIF_RDTDrawElement.MODE_FACE then
		if not self.canDisplayFace() then 
			app.raiseUnexpectedProgramError(class.name, method.name, "display mode MODE_SIDE unsupported for this class type");		
		endif;
	elseif _mode = CMIF_RDTDrawElement.MODE_END then
		if not self.canDisplayEnd() then 
			app.raiseUnexpectedProgramError(class.name, method.name, "display mode MODE_END unsupported for this class type");		
		endif;	
	else
		app.raiseUnexpectedProgramError(class.name, method.name, "Unsupported display mode specified");
	endif;

	if _flipH then	
		if not self.canFlipH(_mode) then 
			app.raiseUnexpectedProgramError(class.name, method.name, "Horizontal flip not supported for specified display mode");		
		endif;	
	endif;
	
	if _flipV then	
		if not self.canFlipV(_mode) then 
			app.raiseUnexpectedProgramError(class.name, method.name, "Vertical flip not supported for specified display mode");		
		endif;	
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_flipH" type="Boolean"/>
        <Parameter name="_flipV" type="Boolean"/>
    </JadeMethod>
</Class>
