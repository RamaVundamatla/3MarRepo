    <JadeMethod name="setDefaults" id="db213756-6a56-469b-859a-77829e78956b">
        <source>setDefaults();
//--------------------------------------------------
// Created:	17 October 2005 By: cnwgd1
//--------------------------------------------------
vars
	validationType : Integer;
	
begin
	if self.myConflictManager = null then
		self.txtDateFrom.setDate(app.actualTimeServer().date);
		self.txtDateTo.setDate(app.actualTimeServer().cnEcAddMonths(3).date);
		return;
	endif;
	
	self.txtDateFrom.setDate(self.myConflictManager.fromDT.date());
	self.txtDateTo.setDate(self.myConflictManager.endDT.date());
	
	if self.myConflictManager.allValidationTypes.size &gt; 0 then
		self.chkBerthDepths.value	:=	false;
		self.chkClearances.value	:=	false;
		self.chkLockouts.value		:=	false;
		self.chkTidalWindow.value	:=	false;			
		self.chkWharfOverhang.value	:=	false;
		self.chkSteamTime.value		:=	false;
		self.chkStockpile.value		:=	false;
		self.chkVesselUnavail.value	:=	false;
		
		foreach validationType in self.myConflictManager.allValidationTypes do
			if validationType = ValidateClearances then
				self.chkClearances.value := true;
			elseif validationType = ValidateBerthDepths then
				self.chkBerthDepths.value := true;
			elseif validationType = ValidateWharfLockout then
				self.chkLockouts.value := true;
			elseif validationType = ValidateTidalWindow then
				self.chkTidalWindow.value := true;	
			elseif validationType = ValidateWharfOverhang then		
				self.chkWharfOverhang.value := true;
			elseif validationType = ValidateShipDraft then
				self.chkBerthDepths.value := true;
				self.chkTidalWindow.value := true;												
			elseif validationType = ValidateShipPosn then
				self.chkClearances.value := true;
				self.chkWharfOverhang.value := true;
			elseif validationType = ValidatePilotMaster then
				self.chkPilotMaster.value := true;															
			elseif validationType = ValidateSteamTime then
				self.chkSteamTime.value := true;															
			elseif validationType = ValidateStockpile then
				self.chkStockpile.value := true;															
			elseif validationType = ValidateVesselUnavail then
				self.chkVesselUnavail.value := true;															
			endif;
		endforeach;
		
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setMyConflictManager" id="78007480-9466-4a4a-abef-c55dfe7495b4">
        <updating/>
