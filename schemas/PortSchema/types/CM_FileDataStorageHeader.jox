    <JadeMethod name="cloneDetail" id="da5d0ce9-311d-495d-a37f-6bf00ea5275f">
        <updating/>
        <source>cloneDetail(_allDetail : CM_FileStorageArray) updating;

// Created by cnwdvb1 on 27 June 2006

// J Harliwich 3/9/09 MES1011 Create as transient or persistent depending on self

vars

	newDetail,
	detail : CM_FileDataStorageDetail;

begin

	foreach detail in _allDetail do
		if  self.isTransient then 
			create newDetail transient;
		else
			create newDetail persistent;
		endif;
		newDetail.set(self.fileName, detail.csvBlob, null, self);
	endforeach;

end;</source>
        <Parameter name="_allDetail" type="CM_FileStorageArray"/>
    </JadeMethod>
    <JadeMethod name="cloneHdr" id="f8f1607a-07de-4d8b-96d3-1d965f3680c1">
        <source>cloneHdr() : CM_FileDataStorageHeader;

// Created by cnwdvb1 on 27 June 2006

vars

	hdr : CM_FileDataStorageHeader;

begin

	create hdr persistent;
	
	hdr.set(self.fileName, self.type);
	hdr.cloneDetail(self.allFileDataStorageDetail);
	
	return hdr;	

end;</source>
        <ReturnType type="CM_FileDataStorageHeader"/>
    </JadeMethod>
    <JadeMethod name="isEmpty" id="35c09bb7-a65f-4314-a01c-2bbe330ee8c5">
        <source>isEmpty() : Boolean;

// Created by cnwdvb1 on 17 July 2006

vars

begin

	return self.allFileDataStorageDetail.isEmpty();

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="set" id="87dfe2dc-4f63-4a26-b96f-b6ef83f6e6bd">
        <updating/>
        <source>set(_fileName : String; _type : Integer) updating;

vars

begin

	self.fileName	:= _fileName;
	self.type		:= _type;

end;</source>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
