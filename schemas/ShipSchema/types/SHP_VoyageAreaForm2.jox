    <JadeMethod name="btnBaySelectOpt2_mouseDown" id="fcd21a9e-fc7e-4455-880b-df36ff57f123">
        <controlMethod name="Button::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnBaySelectOpt2_mouseDown(btn: Button input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		15 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	x1 : Real;
	y1 : Real;
begin
	x1 := x;
	y1 := y;

	x1 := x1 + self.frmSelectVoyage.left;
	y1 := y1 + self.frmSelectVoyage.top;

	self.popupMenu(self.mnuBaySelOptions, x1.Integer, y1.Integer);

end;</source>
