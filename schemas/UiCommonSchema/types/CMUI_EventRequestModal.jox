    <JadeMethod name="doSaveNotify" id="1775d1f9-708c-485f-9efd-d286a93ee645">
        <updating/>
        <source>doSaveNotify() : Boolean updating;
//--------------------------------------------------
// Created:	19 April 2005 By: cnwgd1
//--------------------------------------------------
vars
	tmpTimeArray : TimeArray;
	tmpUser : CM_User;
	cmifEventReq : CMIF_EventRequestController;
	pxyEmail,
	realEmail : CM_EventRequestEmail;
	pxyRequestNotify : CM_EventRequestNotification;
	result : Integer;
	rtnValue : Boolean;
begin
	
	if self.mode = self.Mode_Update then
		if CM_EventRequestNotification.hasInstance(self.myEventRequest) then
			beginLoad;
			pxyRequestNotify := self.myEventRequest.pxyCreateUpdateProxy().CM_EventRequestNotification;
			tmpUser := self.myEventRequest.myUser;			
			endLoad;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'myEventRequest is null for update');	
			return false;	
		endif;		
	elseif self.mode = self.Mode_Add then
		create pxyRequestNotify transient;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid mode for update');		
		return false;
	endif;
	
	self.setProxyEventRequest(pxyRequestNotify, tmpUser);	
	if tmpUser = null then
		tmpUser := app.getMyUser();
	endif;

	beginLoad;
	
	create tmpTimeArray transient;
	self.getRunTimes(tmpTimeArray);
	
	if not tmpTimeArray.isEmpty() then
		realEmail := tmpUser.allEventRequestEmail[pxyRequestNotify.type];
		if realEmail &lt;&gt; null then
			pxyEmail := realEmail.pxyCreateUpdateProxy();
	
		elseif (not tmpTimeArray.isEmpty) then //&lt;-- only create if they have added time(s)
			create pxyEmail transient;
		endif;
		endLoad;
		
		if pxyEmail &lt;&gt; null then
			pxyEmail.setProxy(app.myRoot, tmpUser, pxyRequestNotify.type, tmpTimeArray);
		endif;
	endif;
	
	create cmifEventReq transient;
	cmifEventReq.myPxyEventRequestEmail := pxyEmail;		
	cmifEventReq.myPxyEventRequestNotify := pxyRequestNotify;
	cmifEventReq.cargoIds := self.txtCargoId.text;
	self.lstTableRequest.getSelectedStrings(cmifEventReq.allEventNames);		
	//self.lstTableRequest.allSelectedObjects.copy(cmifEventReq.allSelectedObjects);		
	self.lstTableRequest.getSelectedObjectsWithDupes(cmifEventReq.allSelectedObjects);		
		
	while true do
		app.myTrxUA.trxUpdateEventRequest(cmifEventReq, app.myPassport);					
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			rtnValue := true;
			break;
		else
			result := app.showErrorWarningDialog('Event Notification Request', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;	

	if rtnValue then	
		app.msgBox(app.getErrorString4(EventRequestResult, self.eventRequestType, cmifEventReq.numPending.String, cmifEventReq.numActioned.String, cmifEventReq.numMatchFailed.String), self.eventRequestType, MsgBox_OK_Only+ MsgBox_Information_Icon);
	endif;
								
epilog
	endLoad;
	delete tmpTimeArray;
	delete pxyEmail;
	delete pxyRequestNotify;
	delete cmifEventReq;
	return rtnValue;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSelectRecipients" id="246cef45-132e-49ab-9f89-077b9a7d3907">
        <source>doSelectRecipients();
//--------------------------------------------------
// Created:	18 April 2005 By: cnwgd1
//--------------------------------------------------
vars
	email : CM_EmailEntity;
	origAddresses,
	address,
	str : String;
	result : Integer;
	selected : CM_EmailEntityByTypeNameDict;
	emailController	: CMIF_EmailTemplateController;
	form			: CMUI_RecipientSelector;
	toA,
	ccA,
	bccA	: String;
	
begin

	
	create form transient;
	create emailController transient;
	
	self.setNavigatorHeading(form.caption);
	form.setMyTerminal( self.myTerminal );	//29 Aug 2017	NDL	TFS 5845
	form.myEmailController := emailController;
	form.mode := CMUI_RecipientSelector.Mode_To;
	form.centreWindow;
	form.showModal;

	origAddresses := self.txtRecipients.text;
	
	if form.modalResult = IDOK then
		toA 	:= emailController.allToAddresses.getAddresses();
		ccA 	:= emailController.allCcAddresses.getAddresses();
		bccA	:= emailController.allBccAddresses.getAddresses();
		
		if toA &lt;&gt; null then
			str := toA &amp; ';';
		endif;
		
		if ccA &lt;&gt; null then
			str := str &amp; ccA &amp; ';';
		endif;
		
		if bccA &lt;&gt; null then
			str := str &amp; bccA &amp; ';';
		endif;
	endif;

	if str.length &gt; 1 then
		if origAddresses &lt;&gt; null then
			if app.msgBox(app.getErrorString(ConcatenateEmailAddresses), 'Email Recipients', MsgBox_Yes_No+MsgBox_Question_Mark_Icon) = MsgBox_Return_Yes then
				self.txtRecipients.text := origAddresses &amp; '; ' &amp; str;
			endif;
		else
			self.txtRecipients.text := str;
		endif;
	endif;	
epilog
	delete selected;
	delete emailController;
end;</source>
    </JadeMethod>
    <JadeMethod name="getEmailAddresses" id="f104b130-ca81-4d55-8fc7-427ef1963e45">
        <source>getEmailAddresses( _addressArray : CM_StringArray input );
//--------------------------------------------------
// Created:	20 May 2005 By: cnwgd1
//--------------------------------------------------
vars
	delimiters		: String;
	address			: String;
	addresses		: String;
	cnStringArray	: CnStringArray;
	/*
	cnt,
	len : Integer;
	delmiter,
	address,
	addresses : String;
//	*/
	
begin
	// cnwrl1 10/03/2010 PAR 22853 - start of coding
	// Break up the supplied text of potential email addresses into none-null single email addresses.
	// The potential delimiters are semicolons and comma and strip all spaces out of the addresses.
	create cnStringArray transient;
	delimiters	:= SemiColon &amp; CNEC_COMMA;
	addresses	:= self.txtRecipients.text;
	addresses.cnUnbust( delimiters, cnStringArray, true );
	foreach address in cnStringArray where address &lt;&gt; null do
		address.cnEcRemoveCrLf;
		_addressArray.add( address );
	endforeach;
	// cnwrl1 10/03/2010 PAR 22853 - end of coding
	
	/* cnwrl1 10/03/2010 PAR 22853 - what it was
	addresses := self.txtRecipients.text.splitToMultiLine();
	addresses.replaceChar(";", Lf);
	len := addresses.length;
	cnt := cnt+1;	
	while true do
		address := null;
		address := addresses.getDelimitedToken(cnt, CrLf, delmiter);
		if address = null then
			break;
		endif;
		address.replaceChar(';', ' ');
		_addressArray.add(address.trimBlanks);
	endwhile;
//	cnwrl1 10/03/2010 PAR 22853 - end of what it was */
	
epilog
	delete cnStringArray;
	
end;
</source>
        <Parameter name="_addressArray" type="CM_StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getRunTimes" id="ec157e71-45cd-4ede-8a21-deaa15192821">
        <source>getRunTimes(_timeArray : TimeArray input);
//--------------------------------------------------
// Created:	19 May 2005 By: cnwgd1
//--------------------------------------------------
vars
	lstCnt,
	cnt : Integer;
	str : String;
	localTime: TimeStamp;
begin

	//List box is sorted ascending
	//time will be added in the correct order
	lstCnt := self.lstTime.listCount();
	while cnt &lt; lstCnt do
		cnt := cnt + 1;
		str := self.lstTime.itemText[cnt];
		localTime.setTime(str.Time);
		_timeArray.add(self.localToSystemTime(localTime).Time);	// 17/6/16 cnwmp6 TFS 488 - Multi timezone support
	endwhile;
	
end;</source>
        <Parameter name="_timeArray" type="TimeArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="keyDown" id="06e9602e-e07c-4a10-b67d-7fe5aa7999b6">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
//--------------------------------------------------
// Created:	19 May 2005 By: cnwgd1
//--------------------------------------------------
vars
begin

	if keyCode = J_key_Delete then
		self.addRemoveTime(false);
	else
		inheritMethod(keyCode, shift);
	endif;

end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="lstTableRequest_displayRow" id="ade3bc9f-a139-488c-a087-ba3c6d7de621">
        <controlMethod name="Table::displayRow"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstTableRequest_displayRow(table: Table input; theSheet: Integer; obj: Object; theRow: Integer; bcontinue: Boolean io):String updating;
//--------------------------------------------------
// Created:	18 April 2005 By: cnwgd1
//--------------------------------------------------
vars
	selected : Boolean;
begin

	if CM_StopsTable.hasInstance(obj) then
		selected := table.CMUI_ListTable.allSelectedObjects.includes(obj);
		return self.myAssistant.displayEntryStopsTableList(obj.CM_StopsTable, selected, true);
	else
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="theSheet" type="Integer"/>
        <Parameter name="obj" type="Object"/>
        <Parameter name="theRow" type="Integer"/>
        <Parameter name="bcontinue" type="Boolean" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="optClear_change" id="6902e2ef-9236-41c0-a6fd-31745a11b8e3">
        <controlMethod name="OptionButton::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>optClear_change( optionbutton : OptionButton input ) updating;

/*
Date				Who		Reason
18 September 2009	cnwrl1	Initial creation as part of PAR 20230 - New Messina Messages
*/
	
vars
	
begin
	self.doOptClearChange( optionbutton );
	
epilog
	
end;
</source>
        <Parameter name="optionbutton" type="OptionButton" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setEnableObjects" id="427f0950-3d76-449a-8e20-b20ef333097a">
        <source>setEnableObjects();
//--------------------------------------------------
// Created:	17 May 2005 By: cnwgd1
//--------------------------------------------------
// 14/12/2010 	cnwcs5	ccms mes 1112 / par 24464
vars
	str : String;
begin
	if self.myEventRequest = null then
		// 'Enter the cargo ids and select the requests you would like actioned. '
		str := app.getErrorString( LblEventrequest_NewRequest );
	else
		self.txtCargoId.enabled := false;
		self.lstTableRequest.userInputEnabled := false;
		self.cmbCargoType.enabled := false;
		self.cmbOrganisation.enabled := false;
		self.optAdd.enabled := false;
		self.optClear.enabled := false;
		self.txtReqInfo.enabled	:= false;		// cnwrl1 18/09/2009 PAR 20320 - MES 1011 New Messina Messages
		self.txtExpiryDate.enabled := false;	// cnwrl1 12/01/2010 PAR 21889
		
		if self.myEventRequest.status = EventRequestEmailed then
			// 'This request cannot be updated because it has already been processed and the notification has been sent.'
			str := app.getErrorString( LblEventRequest_Emailed );
		elseif self.myEventRequest.status = EventRequestActioned or
			self.myEventRequest.status = EventRequestCargoDeleted then		// 14/12/2010 	cnwcs5	ccms mes 1112 / par 24464
			// 'This request has already been actioned. Only the email recipients and remarks can be updated.'
			str := app.getErrorString( LblEventRequest_Actioned );
		elseif self.myEventRequest.status = EventRequestMatched then
			// what title string ends up for these ones - if any exist?
			self.cmbOrganisation.enabled := true;
			self.optAdd.enabled := true;
			self.optClear.enabled := true;
		else
			self.txtCargoId.enabled := true;
			self.lstTableRequest.userInputEnabled := true;
			self.cmbCargoType.enabled := true;
			self.cmbOrganisation.enabled := true;
			self.optAdd.enabled := true;
			self.optClear.enabled := true;
			self.txtReqInfo.enabled	:= self.optClear.value;		// cnwrl1 18/09/2009 PAR 20320 - MES 1011 New Messina Messages
			self.txtExpiryDate.enabled := self.optClear.value;	// cnwrl1 12/01/2010 PAR 21889
			// 'The enabled fields can be updated for this request.'
			str :=  app.getErrorString( LblEventrequest_Enabled );
		endif;
	endif;
	self.lblEventRequest.caption := str;
end;
</source>
    </JadeMethod>
    <JadeMethod name="setProxyEventRequest" id="d5a2272a-6b9c-4ab5-ab03-ba8f13e4a388">
        <source>setProxyEventRequest(_pxyRequest : CM_EventRequest input; _user : CM_User);
//--------------------------------------------------
// Created:	19 April 2005 By: cnwgd1
//--------------------------------------------------
vars
	cargoType			: CM_CargoType;
	organisation		: CM_Organisation;
	terminalObj			: CM_Terminal;
	remarks				: String;
	ref					: String;
	user				: CM_User;
	clearStops			: Boolean;
	notify				: Boolean;
	pxyRequestNotify	: CM_EventRequestNotification;
	pxyRequestStops		: CM_EventRequestStops;	
	addresses			: CM_StringArray;
	
begin
	if _pxyRequest = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null Event Request');	
		return;
	endif;
	user := _user;
	if user = null then
		user := app.getMyUser();
	endif;
	remarks := self.txtRemarks.text;	
	ref := self.txtReference.text;
	
	cargoType := self.cmbCargoType.listObject.CM_CargoType;
	organisation := self.cmbOrganisation.listObject.CM_Organisation;
	terminalObj := self.myTerminal;				//+cnwml2 PAR25743
	notify := self.ckbNotify.value;
	clearStops := self.optClear.value;
	
	create addresses transient;
	self.getEmailAddresses(addresses);			
							
	if CM_EventRequestNotification.hasInstance(_pxyRequest) then
		pxyRequestNotify := _pxyRequest.CM_EventRequestNotification;
		pxyRequestNotify.setProxyRequestNotify(	addresses,
												remarks,
												pxyRequestNotify.cargoId,
												user,
												cargoType,
												pxyRequestNotify.myTrackedItem,
												organisation,
												terminalObj,
												_pxyRequest.status,
												pxyRequestNotify.eventType,
												pxyRequestNotify.eventName,
												null,
												null,
												ref,
												self.ckbCleanup.value,
												false );		// isEDI	// cnwrl1 21/09/2009 PAR 20320 - MES 1011 New Messina Messages
	elseif CM_EventRequestStops.hasInstance(_pxyRequest) then
		pxyRequestStops := _pxyRequest.CM_EventRequestStops;
		pxyRequestStops.setProxyRequestStops(	EventRequestTypeStops,
												addresses,
												remarks,
												pxyRequestStops.cargoId,
												user,
												cargoType,
												organisation,
												terminalObj,
												_pxyRequest.status,
												clearStops,
												notify,									
												ref,
												self.ckbCleanup.value,
												pxyRequestStops.myStopsTable,
												self.txtReqInfo.text.trimBlanks,	// cnwrl1 18/09/2009 PAR 20320 - MES 1011 New Messina Messages
												self.txtExpiryDate.getDate,	// cnwrl1 12/01/2010 PAR 21889
												false,
												null,
												null,
												null,
												null,	//_custAgent : CM_CustomsAgent 30 Jun 2015	NDL	Par 36543
												null,	//_toDoRemarks		: String	//06 Oct 2015	NDL	Par 37011
												null,	//_tiBOL		//cnwmc5 - 11 Jan 2016 - PAR 37275
												null,	//_clearCustAgent		//cnwmc5 - 11 Jan 2016 - PAR 37275
												null,  // 16/01/2017 cnwma1 TFS #2885
												null,  // 16/01/2017 cnwma1 TFS #2885
												null  // 16/01/2017 cnwma1 TFS #2885
												);		// isEDI	// cnwrl1 21/09/2009 PAR 20320 - MES 1011 New Messina Messages
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Request class not handled');
		return;
	endif;
	
epilog
	delete addresses;
	
end;
</source>
        <Parameter name="_pxyRequest" type="CM_EventRequest" usage="input"/>
        <Parameter name="_user" type="CM_User"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="2769be18-37e4-444b-bcf2-2ba1794e7916">
        <updating/>
        <source>setupForm() updating;
//--------------------------------------------------
// Created:	18 April 2005 By: cnwgd1
//--------------------------------------------------
vars
	//translation : XLAT_Translation;

begin
	inheritMethod();
	
	self.myAssistant.comboBoxCargoTypes(self.cmbCargoType, app.myPassport.getDefaultCargoType());
	self.eventRequestType := EventRequestTypeNotifyStr;	
	self.myAssistant.listTableEventActivities(self.lstTableRequest);
	//this form only handles event notifications now
	self.lblRequestsAdd.caption := app.getErrorString(LblEventRequestText);
	self.lblRequestsClear.visible := false;
	self.optAdd.visible := false;
	self.optClear.visible := false;
	self.ckbNotify.visible := false;
	self.ckbCleanup.visible := false;
	self.txtReference.visible := false;
	self.lblReference.visible := false;
	// cnwrl1 18/09/2009 PAR 20320 - MES 1011 New Messina Messages - start of coding
	self.lblReqInfo.visible	:= false;
	self.txtReqInfo.visible	:= false;
	// cnwrl1 18/09/2009 PAR 20320 - MES 1011 New Messina Messages - end of coding
	// cnwrl1 12/01/2010 PAR 21889 - start of coding
	self.lblExpiryDate.visible	:= false;
	self.txtExpiryDate.visible	:= false;
		
	self.timeMask.insertMode := false;	
	self.timeMask.setTime(self.systemToLocalTime(app.actualTimeServer).time());	// 18/4/16 cnwmp6 TFS 488 - Multi timezone support
	self.displayEventRequest();
	self.txtCargoId.setFocus();	
	self.btnOk.default := false;
	if (not app.myCurrentUserCan(self.myTerminal, PmGenRecipientSelector)) then
		self.btnRecipients.visible := false;
	endif;
	self.setEnableObjects();
end;
</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="0fc69a98-be43-427e-8f80-7f533e3f0805">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0007435, locale);
	btnRecipients.translateBubbleHelp(Xlat_0000414, locale);
	btnRecipients.translateCaption(Xlat_0000416, locale);
	btnTimeAdd.translateCaption(Xlat_0000405, locale);
	btnTimeRemove.translateCaption(Xlat_0000418, locale);
	ckbCleanup.translateBubbleHelp(Xlat_0005068, locale);
	ckbCleanup.translateCaption(Xlat_0005069, locale);
	ckbNotify.translateBubbleHelp(Xlat_0000408, locale);
	ckbNotify.translateCaption(Xlat_0000409, locale);
	cmbCargoType.translateBubbleHelp(Xlat_0000399, locale);
	cmbOrganisation.translateBubbleHelp(Xlat_0000386, locale);
	grpEmail.translateCaption(Xlat_0000410, locale);
	lblCargoID.translateCaption(Xlat_0000406, locale);
	lblCargoType.translateCaption(Xlat_0000400, locale);
	lblEventRequest.translateCaption(Xlat_0000388, locale);
	lblExpiryDate.translateCaption(Xlat_0013442, locale);
	lblOrganisation.translateCaption(Xlat_0000389, locale);
	lblRecipients.translateCaption(Xlat_0000419, locale);
	lblReference.translateCaption(Xlat_0005071, locale);
	lblRemarks.translateCaption(Xlat_0000407, locale);
	lblReqInfo.translateCaption(Xlat_0011972, locale);
	lblRequestsAdd.translateCaption(Xlat_0013443, locale);
	lblRequestsClear.translateCaption(Xlat_0013444, locale);
	lblTimes.translateCaption(Xlat_0000411, locale);
	lstTableRequest.translateBubbleHelp(Xlat_0000387, locale);
	optAdd.translateCaption(Xlat_0000412, locale);
	optClear.translateCaption(Xlat_0000413, locale);
	txtCargoId.translateBubbleHelp(Xlat_0000403, locale);
	txtExpiryDate.translateBubbleHelp(Xlat_0018766, locale);
	txtRecipients.translateBubbleHelp(Xlat_0000415, locale);
	txtRemarks.translateBubbleHelp(Xlat_0000404, locale);
	txtReqInfo.translateBubbleHelp(Xlat_0018767, locale);
end;</source>
    </JadeMethod>
</GUIClass>
