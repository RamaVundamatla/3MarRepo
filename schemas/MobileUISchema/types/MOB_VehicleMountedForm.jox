    <JadeMethod name="isDirectorTask" id="91787378-99e1-4eab-906d-771d50633d50">
        <source>isDirectorTask() : Boolean protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 May 2010	cnwjk3	Initial creation

*/

vars
	dto,
	dtoTwin : DTO_RTQueueEntry;
	dtoEntryArray 	: DTO_RTQueueEntryArray;
begin
	//epr par 33495 noticed I was getting error 4s here
	create dtoEntryArray transient;
	app.myVMAgent.myMachQEntryTableSynchAgent.doFindWorkingDTOEntries(dtoEntryArray,false,null);
	if dtoEntryArray.size &gt; 0 then
			dto:=dtoEntryArray[1];
	endif;
	if dtoEntryArray.size &gt; 1 then
			dtoTwin:=dtoEntryArray[2];
	endif;
/*	
	dto := self.getWorkingDTOEntry();
	//cnwrd1 par 32293 
	
	dtoTwin := self.getWorkingTwinDTOEntry(); 
	
	*/
	if dto &lt;&gt; null and dto.isForDirectorTask() then
		return true;
	endif;

	if dtoTwin &lt;&gt; null and dtoTwin.isForDirectorTask() then
		return true;
	endif;

	return false;

epilog
	delete dtoEntryArray;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
