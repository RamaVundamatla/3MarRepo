<JadeWebServiceConsumerClass name="JadeWebServiceConsumer">
    <Constant name="SessionIdPropertyName" id="ddf1c98e-1c7d-4e77-87cb-0fc32a39bd42">
        <source>"sessionId"</source>
        <type name="String"/>
    </Constant>
    <JadeMethod name="getSessionId" id="b5d4b060-65cb-41ce-a8c1-38626e20d3ab">
        <source>getSessionId() : String;

/*

Purpose:			Get the current server side JADE sessionId (if there is one)

Parameters:			None

Return Value:		Current sessionId, or null if there is no current session, or if the receiver
					is not a session-based service.


Date		Who		Reason
22 Jul 2008	cnwkpd1	PAR #17554 - Development of new RIA Web Service application

*/

vars
	session			: JadeSessionHeader;
	sessionError	: Boolean;
	
begin
	on Exception do self.metadataErrorHandler(exception, sessionError);
	
	session := self.getPropertyValue(SessionIdPropertyName).JadeSessionHeader;
	if sessionError or session = null then
		return null;
	endif;
		
	return session.getPropertyValue(JadeSessionHeader::sessionId.name).String;
	

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="metadataErrorHandler" id="c958e405-09c6-49e7-a710-46a659721f0f">
        <source>metadataErrorHandler(_exc : Exception; _metadataError : Boolean io) : Integer protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 July 2008	cnwkpd1	PAR #17554 - Development of new RIA Web Service application

*/

vars

begin
	if _exc.errorCode = 1010 or				// method not defined
	   _exc.errorCode = 1011 or				// property not defined
	   _exc.errorCode = 1086 then			// invalid class
		
		_metadataError := true;
		return Ex_Resume_Next;
	endif;
	
	return Ex_Pass_Back;
	
	   
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_exc" type="Exception"/>
        <Parameter name="_metadataError" type="Boolean" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setSessionId" id="c2a354f3-d279-4bb5-8368-3287630003a0">
        <updating/>
        <source>setSessionId(_value : String) : Boolean updating;

/*

Purpose:			Set the current server side JADE sessionId (if there is one)

Parameters:			_value to set the sessionId to

Return Value:		True if the set was successful, false if the receiver is not for a session-based service.

Date		Who		Reason
22 Jul 2008	cnwkpd1	PAR #17554 - Development of new RIA Web Service application

*/

vars
	session			: JadeSessionHeader;
	sessionError	: Boolean;
	
begin
	if _value = self.getSessionId then			// already set, do nothing
		return true;
	endif;
	
	on Exception do self.metadataErrorHandler(exception, sessionError);
	
	session := self.getPropertyValue(SessionIdPropertyName).JadeSessionHeader;
	if sessionError then
		return false;
	endif;
	
	if session = null then
		create session transient;
		self.setPropertyValue(SessionIdPropertyName, session);
	endif;
	
	session.setPropertyValue(JadeSessionHeader::sessionId.name, _value);
	
	return true;
	

epilog

end;</source>
        <Parameter name="_value" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</JadeWebServiceConsumerClass>
