        <source>tblCalendar_dblClick(table: Table input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 October 2010	cnwndl1	Initial creation

*/
vars

	jadeTableCell : JadeTableCell;
	listbox : CMUI_ListBox;
	date : Date;
	
begin

	jadeTableCell := table.accessCell( table.row, table.column );
	
	if jadeTableCell &lt;&gt; null then
		listbox := jadeTableCell.cellControl.CMUI_ListBox;
		if listbox &lt;&gt; null and listbox.listCount &gt; 0 then
			date := listbox.itemText[1].asDateJMT;
			if date.isValid then
				self.cmbPeriod.listIndex := self.cmbPeriod.findStringExact( 1, ByDay );
				self.txtDate.setDate(date);
				self.doChangeDate( true );
				return;
			endif;
		endif; 
	endif;
	
epilog

end;</source>
