		userId := 'UNITTEST';
	endif;
		
	terminalCode	:= self.getTerminal().code;
	fellingDate		:= app.actualTimeServer().Date;
	
	if _fellDate = null then
		fellDate := fellingDate.formatAsYYYYMMDD();
	endif;
	
	create remoteManager transient;
	create xmlSession transient;

