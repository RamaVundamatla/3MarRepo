    <JadeMethod name="stretchHeight" id="8a152fb7-3a87-469f-936c-f7e1de0ca89e">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>stretchHeight(set: Boolean; _value: Boolean io) updating, mapping;
// ---------------------------------------------------------------------------
// Created:     22 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

    if set and _value then
    	if self.lockBottom then
    		self.lockBottom := false;
    	endif;
   	endif;
  
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="stretchWidth" id="63b38c03-ff80-4b57-a4c2-4c20c29811e1">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>stretchWidth(set: Boolean; _value: Boolean io) updating, mapping;
// ---------------------------------------------------------------------------
// Created:     22 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
    if set and _value then
    	if self.lockRight then
    		self.lockRight := false;
    	endif;
   	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
