    <JadeMethod name="setStrictBOLNumberRule" id="868547e3-134e-4a65-9a8f-85a000b16773">
        <source>setStrictBOLNumberRule( _value : Boolean);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 March 2013	cnwrd1	Initial creation

*/

vars
	aConfig : CMIF_ConfigRoot;
	expectedEdition : Integer;
begin
	
	create aConfig transient;
	aConfig.setFromPersistentData(app.myRoot);
	expectedEdition := app.myRoot.edition;

	aConfig.strictBOLNumberCheck := _value;
	
	app.myTrxUA.trxUpdateConfig(aConfig, app.myRoot,expectedEdition,app.myPassport);
