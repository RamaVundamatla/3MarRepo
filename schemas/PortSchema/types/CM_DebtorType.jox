    <JadeMethod name="getDisplayStringForAttribute" id="cd630159-3c13-41d6-b110-7c1d0c95a027">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:	3 April 2008 By Graeme Black cnwgb1 par 16666
// Used in the maintenance table for CM_DebtorType (INV_DebtorType)
// ---------------------------------------------------------------------------
begin
	if _attrName = ETRow_DefDebtor then
		if self.myDefaultDebtor = null then
			return null;
		else
			return self.myDefaultDebtor.name;
		endif;
	elseif _attrName = ETRow_IsNotAvailableForEntryCk then
		return self.isNotAvailableForEntry.getYesNo();
	else
		return inheritMethod(_attrName, _short);
	endif;
end;
</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isBolDrType" id="c47f884f-32b4-49a7-8c09-6adc99929f87">
        <source>isBolDrType():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 November 2019	jlgndl1	Initial creation	TFS 47100

*/

vars

begin

	if self.code.isOneOf( 	DT_BOL_ITEM_FIRST_CONSEE,
							DT_BOL_ITEM_FIRST_CONSOR,
							DT_BOL_OPERATOR,
							DT_BOL_VOY_OPERATOR ) then
		return true;
	endif;
	
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
