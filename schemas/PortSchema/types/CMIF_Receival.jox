    <JadeMethod name="actionForAutoPlan" id="f986612a-2769-4edc-afdb-6b5c45fbc2dd">
        <source>actionForAutoPlan(_theJob : CM_RoadJob; _passport : CM_Passport input): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 June 2009	cnwer1	Initial creation 19912

*/

vars
	
begin
	
	if not inheritMethod(_theJob, _passport) then
		return false;
	endif;
	
	if self.myPersistentTrackedItem = null then
		return false;
	endif;
	self.myPersistentTrackedItem.autoPlan(QUEUE_MODE, _theJob, null, null, _passport);
epilog

end;</source>
        <Parameter name="_theJob" type="CM_RoadJob"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="actionForCreate" id="4eeeb410-3592-45b6-bfbd-79bf29954663">
        <updating/>
        <source>actionForCreate(pProxy: CM_Object io; _passport : CM_Passport input): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     14 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	request 			: CM_Request;
	job					: CM_RoadJob;
	plannedLocn			: CM_LocationsController;
	subItem				: CMIF_TIObject;
	nullObject			: CM_Object;
	txnParams			: CMIF_TITransactionController;
	expectedEdition		: Integer;
	transferTI,
	preNoteTI, realTI	: CM_TrackedItem;
	tiUpdateCntrlr 		: CMIF_TIUpdateController;
	tmpConsignorVoyageCode, tmpEirNumber, tmpConsignee : String;
	intArray			: IntegerArray;
begin

	job := self.getInOutJob();
	if job = null then
		return false;
	endif;

	// Create children &amp; COUs, attach them to us.
	foreach subItem in allSubItems do
		if not subItem.actionForCreate(nullObject, _passport) then
			break;
		endif;		
	endforeach;
	
	//tiUpdateCntrlr := app.createTIUpdateControl(TI_UPDMODE_NORMAL, _passport.userCode, null);
	// as we are receiving, should use TI_UPDMODE_RECEIPT
	tiUpdateCntrlr := app.createTIUpdateControl(TI_UPDMODE_RECEIPT, _passport.userCode, null);
	
	if self.myProxyTrackedItem &lt;&gt; null then
	
		//check for transfer TI
		transferTI := self.myTerminal.lookupTrackedItem(self.myProxyTrackedItem.id, self.myProxyTrackedItem.cargoType, TI_STATE_TRANSFER, null, false);
		
		if transferTI = null then
			//Check if this container has been preadvised into the system.
			preNoteTI := self.myTerminal.lookupTrackedItem(self.myProxyTrackedItem.id, self.myProxyTrackedItem.cargoType, TI_STATE_NOTIFIED, null, false);
		
			if preNoteTI = null then
				if self.isFromPrenote then
					//no warning at this stage - they may just be filling the receival from a dummy prenote
					app.writeStatement('CNWJC2 ' &amp; class.name &amp; " " &amp; method.name &amp;  " was a prenote on the form - but no prenote found" );
				endif;
				
				//New: Create the persistent TI, using the proxy TI we already validated
				self.myPersistentTrackedItem := _passport.myTerminal.createTrackedItem(self.myProxyTrackedItem, _passport);
			else
				//Pre-Advised: Match with the prenoted object and update
				self.myPersistentTrackedItem := preNoteTI;
				self.myPersistentTrackedItem.validateVoyOperatorStopPrenote(self, self.myProxyTrackedItem, _passport);
				self.myPersistentTrackedItem.setForUpdate(self.myProxyTrackedItem, tiUpdateCntrlr, null, true, _passport); //cnwrd1 28.8.09 par 20545
			endif;
		else
			//transfered from other terminal Create the persistent TI, using the proxy TI we already validated
			transferTI.setForTransitReceival(self.myProxyTrackedItem, _passport.myTerminal);
			self.myPersistentTrackedItem := _passport.myTerminal.createTrackedItem(self.myProxyTrackedItem, _passport);
		endif;
		
		if _passport.noErrors() and self.damaged then
			// Create damaged transaction.
			create txnParams transient;
			txnParams.type		:= TRANS_TYPE_DAMAGED;
			txnParams.noCharge	:= true;
			
			self.myPersistentTrackedItem.createTransaction(txnParams, _passport);
		endif;
		
		// 29/05/2009 cnwar2 CCMS1040/#19796
		if self.myPersistentTrackedItem.myVoyage &lt;&gt; null then
			if (self.myPersistentTrackedItem.cutoffTS.isValid and self.myPersistentTrackedItem.cutoffTS &lt; app.actualTimeServer)
			or (self.myPersistentTrackedItem.earliestReceivalTS.isValid and self.myPersistentTrackedItem.earliestReceivalTS &gt; app.actualTimeServer) then
				// create receival outside restriction transaction
				if txnParams = null then
					create txnParams transient;
				endif;
				txnParams.type := TRANS_TYPE_Rec_Outside_Restric;
				txnParams.myTrackedItem := self.myPersistentTrackedItem;
				self.myPersistentTrackedItem.createTransaction(txnParams, app.myPassport);
			endif;
		endif;
	
		if _passport.noErrors() then 
			//Receive the TI onto the vehicle, DO NOT pass in the job or wle else the job gets set to complete and a visit is recorded
			//changed back to original  job.myVehicle.myPrimaryActualLocation
	
			create intArray transient;
			
			// PAR 16338 self.myPersistentTrackedItem.moveToLocation( job.myVehicle.locationsController, null, null, null,REAL_MODE, true, true, false, false, false,  0, _passport);
			//self.myPersistentTrackedItem.moveToLocation( job.myVehicle.locationsController, null, null, null,REAL_MODE, false, true, false, false, false,   false,null,null, _passport);// PAR 16338 changed to not be forced so that validation is applied	
			self.myPersistentTrackedItem.moveToLocation( job.myVehicle.locationsController, null, null, null,REAL_MODE, false, true, false, false, false,   false,null,null,null,null,job.myVehicleVisit, _passport);	// TFS 2651
			//self.myPersistentTrackedItem.setHazardLocations(); PAR 16097
			self.myPersistentTrackedItem.setHazardLocationsForMode(REAL_MODE, false);
		endif;
	endif;
	

	if _passport.noErrors then
		// create the request

		create self.myProxyTIRequest transient;
		if self.myProxyTrackedItem &lt;&gt; null then
			tmpConsignorVoyageCode := self.myProxyTrackedItem.consignorVoyageCode;
			tmpEirNumber := self.myProxyTrackedItem.eirNumber;
			tmpConsignee := self.myProxyTrackedItem.consignee;
		endif;
		
		self.myProxyTIRequest.setProxy(false, tmpConsignorVoyageCode, tmpEirNumber, // lClean, lconsignorVoyageCode, leirNumber
								tmpConsignee, self.doorsDirection, 
								null, self.freightForwarderCode, null, true, 			//pDeliveryNumber,lFreightForwarderCode, lFreightPayer, lisReceipt
								null,null, 0,null, false, null, false, 				// lISOType, lOperator, lNumRequested, lreasonCode, lHeavy, lMask, lneedCOU,
								false, null, null, false, null, null, null,				// lneedGenerator, lDate, lvoyageCode, lCheckISO, pJob, pinNo, pAVG
								false, null, self.remarks, self.myPersistentTrackedItem, // pRemoveStops, pReasonCodeDescr,pRemarks,pTI
								_passport.userCode, null);
								
	endif;
	
	if _passport.noErrors() then	
		//Validate the request (TI is already validated)
		self.myProxyTIRequest.validate(self.myUserObject);
	endif;
	
	if (not _passport.noErrors()) then
		return false;
	endif;

	//Add the request to the job	
	request := job.addRequest(self.myProxyTIRequest, _passport);
	if request = null 
	or _passport.hasErrors then
		return false;
	endif;
	

	//Add the TI to the job
	job.addTI(self.myPersistentTrackedItem, self.myProxyTIRequest);

	if _passport.noErrors then		
		// Autoplan the TI to suitable yard location
		if job.autoComplete then
			plannedLocn := self.getPlannedLocation();
			if plannedLocn &lt;&gt; null then
				self.myPersistentTrackedItem.moveToLocation(plannedLocn,
															job,
															null,
															null,
															PLANNING_MODE,
															false,
															true,
															false,
															false,
															false,
															false,
															null,
															null,
															null,				// TFS 2651
															null,
															job.myVehicleVisit,
															_passport);
			endif;
		endif;
	endif;	

epilog
	delete tiUpdateCntrlr;
	if intArray &lt;&gt; null then
		delete intArray;
	endif;
	return _passport.noErrors;

end;</source>
        <Parameter name="pProxy" type="CM_Object" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="actionForCreatePost" id="2cc54a36-21c9-4682-9edd-22887301049e">
        <updating/>
        <source>actionForCreatePost(_obj : Object; _passport : CM_Passport input) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     August 2008 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	
	if self.myRequest &lt;&gt; null then
		self.myRequest.setItemDetails(self);
	endif;
	
	return true;
epilog
	
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canBeAutoPlanned" id="047f05dd-15b4-4a6d-8e60-434fce78f1fd">
        <source>canBeAutoPlanned(_job: CM_RoadJob): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 June 2009	cnwer1	Initial creation par 19912

*/

vars

begin
	
	
	if _job.autoComplete then
		return false;
	endif;
	
	return true;

epilog

end;</source>
        <Parameter name="_job" type="CM_RoadJob"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canBeTwinAutoPlanned" id="9aad9c14-74b8-4e4a-a996-5a91eca2e818">
        <source>canBeTwinAutoPlanned(_job: CM_RoadJob): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 June 2009	cnwer1	Initial creation par 19912

*/

vars
	isoTypeObject		: CM_ISOType;
begin
	/*
				try to twin plan if config option set (planTwinAtGate) and isoType is twin lift capable and they haven't already entered a planned yard location 
				on the road entry			
			*/

	if not self.canBeAutoPlanned(_job) then
		return false;
	endif;

	isoTypeObject:=app.myRoot.allISOTypes[self.isoType];
	
	return isoTypeObject &lt;&gt; null and (not isoTypeObject.isNotTwinLiftCapable) and (self.yardLocationTxt = null);
epilog

end;</source>
        <Parameter name="_job" type="CM_RoadJob"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkIsDuplicate" id="41981e75-daf1-4d67-aefc-0400b2e9ec14">
        <source>checkIsDuplicate(_item: CMIF_TIObject) : Boolean;
//--------------------------------------------------
// Created:	18 March 2004 By: cnwgd1
//--------------------------------------------------
vars

	cargoType	: CM_CargoType;

begin

	if _item = self then
		return false;
	endif;
	if _item.class &lt;&gt; self.class then
		return false;
	endif;
	
	if _item.CMIF_Receival.id = self.id 
	and _item.CMIF_Receival.cargoType = self.cargoType then
		// CCMS 1533
		
		cargoType := app.myRoot.allCargoTypesById[self.cargoType];
		if cargoType = null or not cargoType.allowDuplicates then
			app.raiseCMException1(VB_DUPLICATED_ITEM, self.id, null, null);
			return true;
		endif;
		
	/*	//no duplicates allowed
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.id, null, null);
		return true;*/
	endif;

	return false;
end;</source>
        <Parameter name="_item" type="CMIF_TIObject"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkTIsExistOnship" id="746272d3-7532-4cb4-a12f-9beae870f880">
        <source>checkTIsExistOnship(_passport : CM_Passport input);

vars
	terminal 	: CM_Terminal;
	theVoyages	: CM_VoyageSet;
	voyage 		: CM_Voyage;
	ti			: CM_TrackedItem;
	locationString : String;
begin

	create theVoyages transient;
	// PAR 22396
	if _passport.allCurrentCellularVoyages = null then
		self.myTerminal.getAllCurrentCellularVoyagesNC(theVoyages, false,false);
	else
		_passport.allCurrentCellularVoyages.copy(theVoyages);
	endif;

	foreach voyage in theVoyages discreteLock do
		ti:= voyage.allOnshipTIsByIdCargoType[self.id, self.cargoType];
		if ti &lt;&gt; null then
			locationString:= "Onship " &amp; voyage.code &amp; " " &amp; ti.locationId;
			app.raiseCMWarning2(ERR_PRENOTE_ID_EXISTS, self.id, locationString,"", null, ti);
		endif;
	endforeach; 
epilog
	if theVoyages &lt;&gt; null then
		delete theVoyages;
	endif;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cloneForTest" id="c0ab33eb-9710-4101-a456-8b7565b2ecbf">
        <source>cloneForTest(): SelfType;
// ---------------------------------------------------------------------------
// Created:     17 June 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	rtnObj	: SelfType;
begin
	rtnObj := inheritMethod();
	
	self.allTIHazards.copy(rtnObj.allTIHazards);
	
	rtnObj.imExStatus		:= self.imExStatus;
	rtnObj.myBusinessUnit	:= self.myBusinessUnit;
	
	return rtnObj;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
