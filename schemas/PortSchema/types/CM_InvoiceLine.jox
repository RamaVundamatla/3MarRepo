    <JadeMethod name="lineTotal" id="ff895542-2463-4d8f-ab85-ce09cdd164a0">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>lineTotal(set: Boolean; _value: Decimal io) mapping, updating;

vars
//	tot: Decimal[16,6];		//change from real - charges can have 6 dp
	charge: CM_Charge;
	// TFS 42431 tot: Decimal[23,6];	//11 May 2018	NDL	TFS 38528
	// TFS 43253 tot: Decimal[23,2];	// TFS 42431 
	tot: Decimal[23,6]; // TFS 43253
begin

	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	else

		foreach charge in self.charges discreteLock do
			tot := tot + charge.total;
		endforeach;

		_value := tot;
	endif;
	
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Decimal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="lineTotalUsedMinMax" id="75c13db4-ae6a-42a8-9d54-c530ee3c6f09">
        <source>lineTotalUsedMinMax() : String;
// ---------------------------------------------------------------------------
// Created:		March 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
begin
	
	if self.hasMinMaxTotal and self.displayMinMaxApplied then
		return "(Min/Max Charged)";
	else
		return null;
	endif;


end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="loadProperties" id="2f1644b2-f183-4a3a-8978-73731cd712e1">
        <updating/>
        <source>loadProperties(t : Table io) updating;
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	mapDIL : CM_InvoiceLineDesc;
	str : String;
	transportMode : String;
begin

	str := sequenceNum.String.padLeftBlanks(10) &amp; '  ' &amp; Tab;
	str := str &amp; quantity.String &amp; '  ' &amp; Tab;
	str := str &amp; invoiceLineDesc.narration &amp; Tab;
	if status = STATUS_VOIDED then
		str := str &amp; "Void" &amp; Tab;
	else
		str := str &amp; "Normal" &amp; Tab;
	endif;
	if not manual then
		str := str &amp; trackedItemId &amp; Tab;
		if myTransactionTI = null then
			str := str &amp; "**UNKNOWN**" &amp; Tab;
		else
			str := str &amp; myTransactionTI.class.name[4:end] &amp; Tab;
		endif;
	else
		str := str &amp; "Manual" &amp; Tab;
		str := str &amp; Tab;
	endif;
	str := str &amp; debtor.name &amp; Tab;

	str := str &amp; chargeTime.date.userFormat($CM_YearFormat) &amp; chargeTime.time.userFormat($CM_SortTime) &amp; Tab;
	str := str &amp; chargeTime.String &amp; Tab;

	str := str &amp; overriddenChargeCount.String &amp; '  ' &amp; Tab;

	if invoice &lt;&gt; null then //par8562 rs july2004
		str := str &amp; invoice.sequenceNum.String &amp; '  ' &amp;Tab;
	endif;
	//FD For ccms 1107 : Add one more column for transport mode
	if self.trackedItem &lt;&gt; null then
		transportMode := app.transModeToString(self.trackedItem.receiptTransportMode);
		str := str &amp; transportMode &amp; '  '&amp; Tab;
	else
		str := str &amp; Tab;
	endif;
	
	
	if not self.invoiceLineDesc.allConsolidatedDebtorInvLineD.isEmpty then
		mapDIL := self.invoiceLineDesc.allConsolidatedDebtorInvLineD.first;
		if mapDIL &lt;&gt; null then
			str := str &amp;  mapDIL.narration &amp; Tab;
		else
			str := str &amp; Tab;
		endif;
	else
		str := str &amp; Tab;
	endif;	




	t.column := 1;
	t.text := str;

end;</source>
        <Parameter name="t" type="Table" usage="io"/>
    </JadeMethod>
    <JadeMethod name="mergeLineToInvoice" id="e6d77c47-8371-4c7a-81bf-c694d4449933">
        <updating/>
        <source>mergeLineToInvoice(_target: CM_Invoice) updating;
/*
Purpose - 	
Who - NAVAB1
Date - 08JAN2024
ADO -  CR 58085 TASK 61342
*/

vars
	auditOfLineMovement:  CM_AuditLineMerged;
	tiEditAudit:          CM_AuditTIEdit;
	statusAudit:          CM_AuditLineStatusChanged;
	descChangeAudit:      CM_AuditLineDescChanged;
	now:                  TimeStamp;
	line:                 CM_InvoiceLine;
	keepOldInvoiceAudit:  Boolean;
	trans:                CM_TITransaction;
	oldInvoice:           CM_Invoice;
begin
 
	oldInvoice := self.invoice;
	 
	create auditOfLineMovement;
	auditOfLineMovement.sequenceNum := app.getNextInvoiceSeqNumOnRootBank(SN_AUDIT);
	 
	auditOfLineMovement.fromInvoiceSeqNum := oldInvoice.sequenceNum;
	auditOfLineMovement.toInvoiceSeqNum := _target.sequenceNum;
	auditOfLineMovement.invoiceLineSeqNum := self.sequenceNum;
	auditOfLineMovement.mergeUser := app.getMyUserCode;
	auditOfLineMovement.mergeTS := app.actualTimeAppServer;
	auditOfLineMovement.setRemarks();
	 
	app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(self, true);
	 
 
	auditOfLineMovement.unauditedFOs.clear;
	auditOfLineMovement.auditedFOs.clear;
	 
	auditOfLineMovement.auditedFOs.add(self);
	auditOfLineMovement.auditedFOs.add(_target);
	auditOfLineMovement.auditedFOs.add(self.invoice);
	
	self.invoice := _target;
	self.debtor := _target.debtor;
		 
	if self.myInvoiceLineAdditional &lt;&gt; null then
		self.myInvoiceLineAdditional.mergeLineToInvoice(_target);
	endif;
	 
	app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(self, false);
epilog
 
end;

</source>
        <Parameter name="_target" type="CM_Invoice"/>
    </JadeMethod>
    <JadeMethod name="moveLineToInvoice" id="d34f83aa-178b-4245-89fa-738ff26bc58f">
        <updating/>
        <source>moveLineToInvoice(newInvoice: CM_Invoice) updating;
//
// Changed On	By			Reason
// ----------	--------	----------------------------------------------------
// 23/11/2015	cnwdap1		PAR #36909 Minimum Charges - move associated minimum charge line with parent line
vars
	auditOfLineMovement:  CM_AuditLineMoved;
	tiEditAudit:          CM_AuditTIEdit;
	statusAudit:          CM_AuditLineStatusChanged;
	descChangeAudit:      CM_AuditLineDescChanged;
	now:                  TimeStamp;
	line:                 CM_InvoiceLine;
	keepOldInvoiceAudit:  Boolean;
	trans:                CM_TITransaction;
	oldInvoice:           CM_Invoice;
begin

	oldInvoice := invoice;

	// reuse old line move audits
	auditOfLineMovement := getAuditOfClass(CM_AuditLineMoved).CM_AuditLineMoved;

	if auditOfLineMovement = null then
		// create line moved audit
		create auditOfLineMovement;
		auditOfLineMovement.sequenceNum := app.getNextInvoiceSeqNumOnRootBank(SN_AUDIT); // PAR 15036
	endif;

	auditOfLineMovement.fromInvoiceSeqNum := invoice.sequenceNum;
	auditOfLineMovement.movedBy := app.getMyUserCode;
	auditOfLineMovement.movedDT := now;
	auditOfLineMovement.setRemarks;

	app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(self, true);		// 10/5/18 MAP TFS37718

	self.invoice := newInvoice;
	self.debtor := newInvoice.debtor;

	auditOfLineMovement.unauditedFOs.clear;
	auditOfLineMovement.auditedFOs.clear;

	auditOfLineMovement.auditedFOs.add(self);

	// tidy up TI Edit audits for the TI corresponding to this line;
	if self.trackedItem &lt;&gt; null then
		foreach line in trackedItem.invoiceLines do
			if line.invoice = oldInvoice then
				keepOldInvoiceAudit := true;
				break;
			endif;
		endforeach;

		foreach trans in trackedItem.allTransactions do
			if trans.isKindOf(CM_Edit) then

				tiEditAudit := trans.CM_Edit.audit;
				if tiEditAudit = null then
					continue;
				endif;

				// take care of newInvoice
				tiEditAudit.addUnauditedFO(newInvoice);

				// take care of old invoice
				if not keepOldInvoiceAudit then
					tiEditAudit.removeFO(oldInvoice);
				endif;

			endif;
		endforeach;
	endif;

	// tidy up status change audits for this line
	statusAudit := getAuditOfClass(CM_AuditLineStatusChanged).CM_AuditLineStatusChanged;
	if statusAudit &lt;&gt; null then
		// take care of new Invoice
		statusAudit.addUnauditedFO(newInvoice);

		// take care of old Invoice
		statusAudit.removeFO(oldInvoice);
	endif;

	// tidy up description change audits for this line
	descChangeAudit := getAuditOfClass(CM_AuditLineDescChanged).CM_AuditLineDescChanged;
	if descChangeAudit &lt;&gt; null then
		// take care of new Invoice
		descChangeAudit.addUnauditedFO(newInvoice);

		// take care of old Invoice
		descChangeAudit.removeFO(oldInvoice);
	endif;

	if self.myInvoiceLineAdditional &lt;&gt; null then							// PAR #36909
		self.myInvoiceLineAdditional.moveLineToInvoice(newInvoice);			// PAR #36909
	endif;																	// PAR #36909

	app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(self, false);		// 10/5/18 MAP TFS37718
epilog

end;</source>
        <Parameter name="newInvoice" type="CM_Invoice"/>
    </JadeMethod>
