    <JadeMethod name="pxyCreateUpdateProxy" id="c03a5d96-08a2-4d5d-8fc2-9957c6fec427">
        <source>pxyCreateUpdateProxy(): SelfType;
//--------------------------------------------------
// Created:	31 January 2006 By: cnwgd1
//--------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	proxyVessel 	: CM_VesselStructure;
	completedOK		: Boolean;
begin
	proxyVessel := inheritMethod();
	proxyVessel.myRoot := self.myRoot;
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyVessel;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyVessel;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
