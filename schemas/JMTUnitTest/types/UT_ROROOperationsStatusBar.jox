    <JadeMethod name="xPAR31367StatusBarStep2" id="09584c45-983e-4c4a-97fd-d3ab180f8851">
        <updating/>
        <source>xPAR31367StatusBarStep2() updating;

/*

Purpose:		Colour code and check that the status bar is correct

Date			Who		Reason
10/03/2013		cnwmh5	Initial creation

*/

constants

	ContainerPartialId					: String = 'UT31367';

vars

	theSlot								: CM_LocationsController;
	voyageJob							: CM_VoyageJob;
	
	strs								: StringArray;
	dischargeLocn						: StringArray;
	roroLCs								: CM_LCArray;
	
	locnDefn							: String;
	idx									: Integer;
	
begin

	app.writeLog("STEP 2", LogINFO);
	app.writeLog("Colour coding discharge jobs.  Creating dischargeJobs.  Please wait...", LogINFO);
	
	create strs transient;
	create roroLCs transient;
	
	// locations to discharge colour code
	create dischargeLocn transient;
	dischargeLocn.clear;
	dischargeLocn.add("D40131");
	dischargeLocn.add("D40132");
	dischargeLocn.add("D40133");
	dischargeLocn.add("D40134");
	dischargeLocn.add("D40181");
	dischargeLocn.add("D40182");
	dischargeLocn.add("D40183");
	dischargeLocn.add("D40184");
	
	beginTransaction;
	foreach locnDefn in dischargeLocn do
		strs.clear();
		strs.add(locnDefn);
		self.myVoyage.findLocation(strs, false, theSlot, idx);
		theSlot.CM_ROROSlotController.createDefaultDischargeCC(app.myPassport, true);
	endforeach;
	commitTransaction;
	self.assertNoTrxErrorsOrWarnings();
	
	roroLCs.clear();
	foreach locnDefn in dischargeLocn do
		self.getJobROROControllerByID(self.myVoyage.code, self.myDeck.code, null, locnDefn, roroLCs, false, 1); 
	endforeach;
	voyageJob := self.addVoyageROROJob(self.myVoyage, self.myDeck, "UT_MHQ", roroLCs, true);
	self.assertTrue(voyageJob &lt;&gt; null);
	
	// locations to discharge colour code
	dischargeLocn.clear;
	dischargeLocn.add("D40033");
	dischargeLocn.add("D40034");
	
	beginTransaction;
	foreach locnDefn in dischargeLocn do
		strs.clear();
		strs.add(locnDefn);
		self.myVoyage.findLocation(strs, false, theSlot, idx);
		theSlot.CM_ROROSlotController.createDefaultDischargeCC(app.myPassport, true);
	endforeach;
	commitTransaction;
	self.assertNoTrxErrorsOrWarnings();
	
	roroLCs.clear();
	foreach locnDefn in dischargeLocn do
		self.getJobROROControllerByID(self.myVoyage.code, self.myDeck.code, null, locnDefn, roroLCs, false, 1); 
	endforeach;
	voyageJob := self.addVoyageROROJob(self.myVoyage, self.myDeck, "UT_MHQ", roroLCs, true);
	self.assertTrue(voyageJob &lt;&gt; null);
	

	app.writeLog("Checking Status Bar (HIDE) details are correct.  Please wait...", LogINFO);
	
	// check that the details of the status bar is correct - Hide Exports
	self.locationArray.clear();
	self.statusArray.clear();
	self.locationArray.add("D4013");
	self.statusArray.add("D4013 D4013 |  Fwd: D4018 | 3 x CONT NZLYT  U20G| 1 x CONT NZAKA  U20G | UT313670001, UT313670002, UT313670003, UT313670004 Job: 200");
	self.locationArray.add("D4018");
	self.statusArray.add("D4018 D4018 | Aft: D4013 | 3 x CONT NZLYT  U20G| 1 x CONT NZAKA  U20G | UT313670005, UT313670006, UT313670007, UT313670008 Job: 200");
	self.locationArray.add("D4003");
	self.statusArray.add("D4003 D4003 |  Fwd: D4008 | 3 x CONT NZLYT  U20G| 1 x CONT NZAKA  U20G | UT313670009, UT313670010, UT313670011, UT313670012 Job: 201");
	self.locationArray.add("D4005");
	self.statusArray.add("D4005 D4005 |  Fwd: D4010 | 1 x CONT NZLYT  U20G | UT313670019");
	self.locationArray.add("D4006");
	self.statusArray.add("D4006 D4006 |  Fwd: D4011 | 3 x CONT NZLYT  U20G | UT313670013, UT313670014, UT313670015");
	self.locationArray.add("D4033");
	self.statusArray.add("D4033 D4033 | Aft: D4028 | 3 x CONT NZLYT  U20G | UT313670016, UT313670017, UT313670018");
	
	
	self.xCheckStatusBarCorrect(ShpDisplayMode_Actual, ShpDisplayMode_ColCodeDisch, ShpDisplayModeSub_ExportsHide, method.qualifiedName, 1);

	app.writeLog("Checking Status Bar (SHOW) details are correct.  Please wait...", LogINFO);
	
	// check that the details of the status bar is correct - SHOW EXPORTS
	self.locationArray.clear();
	self.statusArray.clear();
	self.locationArray.add("D4013");
	self.statusArray.add("D4013 D4013 |  Fwd: D4018 | 3 x CONT NZLYT  U20G| 1 x CONT NZAKA  U20G | UT313670001, UT313670002, UT313670003, UT313670004");
	self.locationArray.add("D4018");
	self.statusArray.add("D4018 D4018 | Aft: D4013 | 3 x CONT NZLYT  U20G| 1 x CONT NZAKA  U20G | UT313670005, UT313670006, UT313670007, UT313670008");
	self.locationArray.add("D4003");
	self.statusArray.add("D4003 D4003 |  Fwd: D4008 | 3 x CONT NZLYT  U20G| 1 x CONT NZAKA  U20G | UT313670009, UT313670010, UT313670011, UT313670012");
	self.locationArray.add("D4005");
	self.statusArray.add("D4005 D4005 |  Fwd: D4010 | 1 x CONT NZLYT  U20G | UT313670019");
	self.locationArray.add("D4006");
	self.statusArray.add("D4006 D4006 |  Fwd: D4011 | 3 x CONT NZLYT  U20G | UT313670013, UT313670014, UT313670015");
	self.locationArray.add("D4033");
	self.statusArray.add("D4033 D4033 | Aft: D4028 | 3 x CONT NZLYT  U20G | UT313670016, UT313670017, UT313670018");
	
	
	self.xCheckStatusBarCorrect(ShpDisplayMode_Actual, ShpDisplayMode_ColCodeDisch, ShpDisplayModeSub_ExportsShow, method.qualifiedName, 2);
	
epilog

	delete strs;
	delete roroLCs;
	delete dischargeLocn;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="xPAR31367StatusBarStep3" id="405676fa-f41c-4eb1-a8e4-04aa0da43a65">
        <source>xPAR31367StatusBarStep3();

/*

Purpose:		Plan discharge job and check that the status bar is correct	

Date			Who		Reason
10/05/2013		cnwmh5	Initial creation

*/

constants

	
	VoyageId							: String = "VOY31367MDH";
	
vars

	location							: CM_LocationsController;
	job									: CM_Job;
	req 								: CM_Request;
	wle 								: CM_WorkListEntry;
	
begin

	app.writeLog("STEP 3", LogINFO);
	app.writeLog("Discharging containers.  Please wait...", LogINFO);
	
	location := self.myBlockStack.allLocationsControllers.first;
	
	foreach job in self.myVoyage.allVoyageJobs do
		if not job.CM_VoyageJob.isDischarge then			// Discharge only
			continue;
		endif;
		
		foreach req in job.allRequests discreteLock do
			foreach wle in req.allWorkListEntries discreteLock do
				if wle.myTrackedItem &lt;&gt; null then
					self.movePlannedWLE(wle.myTrackedItem, location, wle);
				endif;
			endforeach;
		endforeach;
	endforeach;
	
	// check that the details of the status bar is correct - SHOW EXPORTS
	app.writeLog("Checking Status Bar (SHOW) details are correct.  Please wait...", LogINFO);
	self.locationArray.clear();
	self.statusArray.clear();
	self.locationArray.add("D4013");
	self.statusArray.add("D4013 D4013 |  Fwd: D4018 | 3 x CONT NZLYT  U20G| 1 x CONT NZAKA  U20G | UT313670001, UT313670002, UT313670003, UT313670004");
