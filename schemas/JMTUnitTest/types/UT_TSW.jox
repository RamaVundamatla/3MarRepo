            &lt;Seal&gt;
              &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
              &lt;ID&gt;CN3474193&lt;/ID&gt;
            &lt;/Seal&gt;
          &lt;/TransportEquipment&gt;
          &lt;UnloadingLocation&gt;
          
            &lt;ID&gt;NZTRG&lt;/ID&gt;
          &lt;/UnloadingLocation&gt;
        &lt;/Consignment&gt;
        &lt;ResponsibleGovernmentAgency&gt;
        
          &lt;ID&gt;MPIBIO&lt;/ID&gt;
        &lt;/ResponsibleGovernmentAgency&gt;
      &lt;/Declaration&gt;
    &lt;/OverallDeclaration&gt;
    &lt;Status&gt;
      &lt;EffectiveDateTime formatCode="204"&gt;20200120091629&lt;/EffectiveDateTime&gt;
      &lt;NameCode&gt;' &amp; DECLARATION_PROCESSING_STATUS &amp; '&lt;/NameCode&gt;
      &lt;Pointer&gt;
      
        &lt;DocumentSectionCode&gt;07B&lt;/DocumentSectionCode&gt;
      &lt;/Pointer&gt;
      &lt;Pointer&gt;
      
        &lt;DocumentSectionCode&gt;42A&lt;/DocumentSectionCode&gt;
      &lt;/Pointer&gt;
      &lt;Pointer&gt;
        &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
        &lt;DocumentSectionCode&gt;08B&lt;/DocumentSectionCode&gt;
        &lt;TagID&gt;G007&lt;/TagID&gt;
      &lt;/Pointer&gt;
    &lt;/Status&gt;
  &lt;/Response&gt;
&lt;/DocumentMetaData&gt;';
	
	/*
	** Run
	*/
	ediFile := self.ediLoadFileName(ediText, EDIFileType_XML, USER_DEF_NAME, USER_DEF_NAME &amp; method.name);
	self.assertNotNull(ediFile);
	
	// should be 1 edi tracked item
	self.assertEqualMsg(ediFile.ediData.allEDITrackedItems.size, 2, "Test 3 - EDI Data has incorrect number of EDI tracked items");
	
	// Both EDI tracked items should have pack count of 1 (pack count is set to 1 by the plugin for container cargo)
	foreach ediTI in ediFile.ediData.allEDITrackedItems do
		ediStop := ediTI.CM_EDICustomStopTI;
		if ediStop.billOfLading = BOL1 then
			found1 := true;
			self.assertEqualMsg(ediStop.packCount, 1, "Test 3 - BOL 1 has incorrect pack count");
		endif;
	endforeach;
	self.assertTrueMsg(found1, "Test 3 - BOL 1 not found");
	
	self.ediVerify(ediFile);
	tempStr	:= 'Test 3 - Verify Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_VERIFIED, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	//return;
	self.ediDBLoad(ediFile);
	tempStr	:= 'Test 3 - DBLoad Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	self.assertNoTrxErrorsOrWarnings();
	
	/*
	** Assert
	*/
	
	// Check the cargo for import stop
	foreach ti1 in tiSet do
		// stop should have been cleared
		tempStr	:= 'Test 3 - Stop ' &amp; STOP_ID_TT.display &amp; Space &amp; realStopsTableTT.heading.display &amp; ' still exists for cargo ' &amp; ti1.id;
		self.assertEqualMsg(ti1.isStopSet(STOP_ID_TT), false, tempStr);
		
	endforeach;
	
	/*
	**	Test 3 End - Test Role Code that is TT. Should remove the TSW TT HOLD stop with stopId as 874
	*/
	
	beginTransaction;
	realStopsTableTT.setPropertyValue(CM_StopsTable::isNotAvailableForEntry.name, true);
	realStopsTableGC.setPropertyValue(CM_StopsTable::isNotAvailableForEntry.name, true);
	commitTransaction;
	
	completedOk := true;
	
epilog
	if not completedOk and realStopsTableTT &lt;&gt; null and realStopsTableGC &lt;&gt; null then
		abortTransaction;
		beginTransaction;
		realStopsTableTT.setPropertyValue(CM_StopsTable::isNotAvailableForEntry.name, true);
		realStopsTableGC.setPropertyValue(CM_StopsTable::isNotAvailableForEntry.name, true);
		commitTransaction;
	endif;
	delete pxyStopsTableTT;
	delete pxyStopsTableGC;
	delete pxyCustomsActionTT;
	delete pxyCustomsActionGC;
	delete intArray;
	delete setArray;
	delete tiSet;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tTSWDTRTTB08" id="98a26274-45c9-42cb-9278-e5b1e98bc931">
        <source>tTSWDTRTTB08();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
26 June 2023	navpw1	Initial creation TFS: 58831

*/

constants
	ROLE_CODE_TT					: String	= 'TT';
	ROLE_CODE_GC					: String	= 'GC';
	DECLARATION_PROCESSING_STATUS	: String	= 'B08';
	BLOCKSTACK						: String	= 'UTB' &amp; DECLARATION_PROCESSING_STATUS;
	MASTERBOL						: String	= "PMWLQ6952";		// Master BOL
	HOUSEBOL						: String	= "TLL014121";		// House BOL
	VESSEL							: String	= 'UTBOL' &amp; DECLARATION_PROCESSING_STATUS;
	VOYAGE							: String	= 'UT' &amp; self.TFS58831 &amp; "_" &amp; DECLARATION_PROCESSING_STATUS;
	OPERATOR						: String	= 'UTOP';
	USER_DEF_NAME					: String	= 'TSW';
	
	CONTAINERTEST1					: String	= self.TFS58831 &amp; "-" &amp; DECLARATION_PROCESSING_STATUS &amp; "-1";
	CONTAINERTEST2					: String	= self.TFS58831 &amp; "-" &amp; DECLARATION_PROCESSING_STATUS &amp; "-2";
	CONTAINERTEST3					: String	= self.TFS58831 &amp; "-" &amp; DECLARATION_PROCESSING_STATUS &amp; "-3";
	CONTAINERTEST4					: String	= self.TFS58831 &amp; "-" &amp; DECLARATION_PROCESSING_STATUS &amp; "-4";
	CONTAINER1						: String	= self.TFS58831 &amp; "-" &amp; DECLARATION_PROCESSING_STATUS &amp; "-5";
	CONTAINER2						: String	= self.TFS58831 &amp; "-" &amp; DECLARATION_PROCESSING_STATUS &amp; "-6";
	BOL1							: String	= "BOL120N28100-2";
	
	STOP_CODE_TT					: String	= "TSWTT";
	STOP_ID_TT						: Integer	= 877;
	STOP_HEADING_TT					: String	= "TSW TT HOLD " &amp; DECLARATION_PROCESSING_STATUS;
	CUSTOMS_ACTION_NAME_TT			: String	= "TSW TT " &amp; DECLARATION_PROCESSING_STATUS;
	CUSTOMS_ACTION_KEYWORD_TT		: String	= DECLARATION_PROCESSING_STATUS;
	
	STOP_CODE_GC					: String	= "TSWGC";
	STOP_ID_GC						: Integer	= 878;
	STOP_HEADING_GC					: String	= "TSW GC HOLD " &amp; DECLARATION_PROCESSING_STATUS;
	CUSTOMS_ACTION_NAME_GC			: String	= "TSW GC " &amp; DECLARATION_PROCESSING_STATUS;
	CUSTOMS_ACTION_KEYWORD_GC		: String	= DECLARATION_PROCESSING_STATUS;
	
vars
	blockStack						: CM_BlockStack;
	pxyStopsTableTT,
	realStopsTableTT,
	pxyStopsTableGC,
	realStopsTableGC,
	stopsTableMAF,
	stopsTableTT,
	stopsTableGC					: CM_StopsTable;
	vessel							: CM_Vessel;
	voyage							: CM_Voyage;
	operator						: CM_Operator;
	tiSet							: CM_TISet;
	ti1,
	ti2								: CM_TrackedItem;
	ediText, tempStr				: String;
	ediFile							: CM_EDIFile;
	ediTI							: CM_EDITrackedItem;
	ediStop							: CM_EDICustomStopTI;
	found1							: Boolean;
	pxyCustomsActionTT,
	realCustomsActionTT,
	pxyCustomsActionGC,
	realCustomsActionGC				: CM_EDIAction;
	
	pxyStopsTableTemplateTT,
	pxyStopsTableTemplateGC			: CM_StopTableTemplate;
	intArray						: IntegerArray;
	setArray						: IntegerArray;
	noImportStops,
	completedOk						: Boolean;
	
begin
	noImportStops := self.getTerminalConfig(NoImportStops).Boolean;
	self.setTerminalConfig(NoImportStops, true);
	self.assertTrueMsg(self.getTerminalConfig(NoImportStops).Boolean, "Terminal Config -&gt; Settings Tab -&gt; 'No Import Stops' should be set to true");
	
	// get rid of stuff - block stack, bols, voyage, vessel
	self.deleteTerminalArea(BLOCKSTACK);
	self.deleteVoyage(VOYAGE);
	self.deleteVessel(VESSEL);
	
	// setup stuff 
	blockStack := self.addBlockStack(BLOCKSTACK, 10, null);
	
	//Get Operator
	operator := self.getOperator(OPERATOR);
	self.assertNotNull(operator);
	
	vessel := self.addVesselGeneralCargo(VESSEL, operator, 5);
	self.assertNotNull(vessel);
	
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL, OPERATOR, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 2);
	self.assertNotNull(voyage);
	
	//Delete TSW TT STOP
	stopsTableTT := self.getRoot.getStopTableForId(STOP_ID_TT);
	if stopsTableTT &lt;&gt; null then
		self.deleteStopsTable(STOP_ID_TT);
		self.assertIsDeletedMsg(stopsTableTT, "stopsTableTT");
	endif;
	
	//Delete TSW GC STOP
	stopsTableGC := self.getRoot.getStopTableForId(STOP_ID_GC);
	if stopsTableGC &lt;&gt; null then
		self.deleteStopsTable(STOP_ID_GC);
		self.assertIsDeletedMsg(stopsTableGC, "stopsTableGC");
	endif;
	
	//Get Stops Table MAF
	stopsTableMAF := self.getRoot.getStopTableForId(TI_Stop_MAF);
	
	//Create TSW TT STOP
	create pxyStopsTableTT transient;
	pxyStopsTableTT.setProxy(false, STOP_CODE_TT, STOP_HEADING_TT, STOP_CODE_TT, null, STOP_ID_TT, null, false, false, app.myRoot, null, app.myPassport.myUser.code, null);
	
	create pxyStopsTableTemplateTT transient;
	pxyStopsTableTemplateTT.setKeys( app.getMyTerminalDO_NOT_USE, pxyStopsTableTT );
	
	create intArray transient;
	create setArray transient;
	setArray.add(StopApplyExport);
	
	pxyStopsTableTemplateTT.setProxy(	intArray,
									setArray,
									intArray,
									null,									// Hold Voyages
									false,
									false,
									false,
									false,
									false,
									false,
									false,
									true);
	
	app.myTrxCA.trxCreateStopsTable(pxyStopsTableTT, realStopsTableTT, app.myPassport);
	self.assertNotNullMsg(realStopsTableTT, "realStopsTableTT");
	
	//Create TSW GC STOP
	create pxyStopsTableGC transient;
	pxyStopsTableGC.setProxy(false, STOP_CODE_GC, STOP_HEADING_GC, STOP_CODE_GC, null, STOP_ID_GC, null, false, false, app.myRoot, null, app.myPassport.myUser.code, null);
	
	create pxyStopsTableTemplateGC transient;
	pxyStopsTableTemplateGC.setKeys( app.getMyTerminalDO_NOT_USE, pxyStopsTableGC );
	
	delete intArray;
	delete setArray;
	
	create intArray transient;
	create setArray transient;
	setArray.add(StopApplyExport);
	
	pxyStopsTableTemplateGC.setProxy(	intArray,
									setArray,
									intArray,
									null,									// Hold Voyages
									false,
									false,
									false,
									false,
									false,
									false,
									false,
									true);
	
	app.myTrxCA.trxCreateStopsTable(pxyStopsTableGC, realStopsTableGC, app.myPassport);
	self.assertNotNullMsg(realStopsTableGC, "realStopsTableGC");
	
	//Delete Customs Action TT
	realCustomsActionTT := app.myRoot.allEDIActions[CUSTOMS_ACTION_NAME_TT];
	if realCustomsActionTT &lt;&gt; null then
		self.deleteEDIAction(CUSTOMS_ACTION_NAME_TT, null, EDIKeyField_Clearance);
		self.assertIsDeleted(realCustomsActionTT);
	endif;
	
	realCustomsActionTT := null;
	
	//Delete Customs Action GC
	realCustomsActionGC := app.myRoot.allEDIActions[CUSTOMS_ACTION_NAME_GC];
	if realCustomsActionGC &lt;&gt; null then
		self.deleteEDIAction(CUSTOMS_ACTION_NAME_GC, null, EDIKeyField_Clearance);
		self.assertIsDeleted(realCustomsActionGC);
	endif;
	
	realCustomsActionGC := null;
	
	//Create Customs Action TT
	create pxyCustomsActionTT transient;
	pxyCustomsActionTT.setProxy(CUSTOMS_ACTION_NAME_TT, CUSTOMS_ACTION_KEYWORD_TT, EDIKeyField_Clearance, EDIAction_Add, realStopsTableTT, CM_EDIFileTypeXMLJMTInternal.firstInstance, null, null, null, "TT");
	app.myTrxCA.trxCreateEDIAction(pxyCustomsActionTT, realCustomsActionTT, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(realCustomsActionTT, "realCustomsActionTT");
	
	//Create Customs Action GC
	create pxyCustomsActionGC transient;
	pxyCustomsActionGC.setProxy(CUSTOMS_ACTION_NAME_GC, CUSTOMS_ACTION_KEYWORD_GC, EDIKeyField_Clearance, EDIAction_Remove, realStopsTableTT, CM_EDIFileTypeXMLJMTInternal.firstInstance, null, null, null, null);
	app.myTrxCA.trxCreateEDIAction(pxyCustomsActionGC, realCustomsActionGC, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(realCustomsActionGC, "realCustomsActionGC");
	
	/*
	**	Test 1 Start - Test Role Code that is TT. Should add the TSW TT HOLD stop with stopId as 874
	*/
	
	/*
	** Setup
	*/
	create tiSet transient;
	
	// create cargo - two containers
	ti1 := self.addContainerAtLocation(CONTAINERTEST1, operator, "22G1", "GENL", TI_IMEX_STATUS_IMPORT, blockStack.myLocationsController);
	ti2 := self.addContainerAtLocation(CONTAINERTEST2, operator, "22G1", "GENL", TI_IMEX_STATUS_IMPORT, blockStack.myLocationsController);
	
	tiSet.add(ti1);
	tiSet.add(ti2);
	
	// assign house bol number and voyage
	beginTransaction;
	foreach ti1 in tiSet do
		ti1.setPropertyValue(CM_TrackedItem::houseBillOfLading.name, BOL1);
		ti1.setMyVoyage(voyage, app.myPassport);
	endforeach;
	commitTransaction;
	
	self.assertEqualMsg(voyage.allTisByHouseBol.size, 2, "Test 1 - Voyage has incorrect number of House BOL TIs");
	
	// edi text - one master BOL (which JMT ignores) and 1 house BOl (but 2 house BOL segments with the same BOL number)
	ediText := 
'&lt;DocumentMetaData xmlns="urn:wco:datamodel:WCO:DM:1"&gt;
  &lt;WCODataModelVersion&gt;3.2&lt;/WCODataModelVersion&gt;
  &lt;WCODocumentName&gt;RES&lt;/WCODocumentName&gt;
  &lt;CountryCode&gt;NZ&lt;/CountryCode&gt;
  &lt;AgencyAssignedCustomizedDocumentName&gt;RESICR&lt;/AgencyAssignedCustomizedDocumentName&gt;
  &lt;AgencyAssignedCustomizedDocumentVersion&gt;V1.0&lt;/AgencyAssignedCustomizedDocumentVersion&gt;
  &lt;CommunicationMetaData&gt;
  
    &lt;Recipient&gt;
      &lt;ID&gt;40513451K&lt;/ID&gt;
      &lt;RoleCode&gt;' &amp; ROLE_CODE_TT &amp; '&lt;/RoleCode&gt;
    &lt;/Recipient&gt;
  &lt;/CommunicationMetaData&gt;
  &lt;Response xmlns="urn:wco:datamodel:WCO:ResponseModel:1"&gt;
    &lt;IssueDateTime formatCode="204"&gt;20200120091629&lt;/IssueDateTime&gt;
    &lt;FunctionalReferenceID&gt;20414&lt;/FunctionalReferenceID&gt;
    &lt;FunctionCode&gt;24&lt;/FunctionCode&gt;
    &lt;AdditionalDocument&gt;
      &lt;CategoryCode&gt;BAC&lt;/CategoryCode&gt;
      &lt;ImageBinaryObject mimeCode="application/pdf" uri="idd_E41D6A50-4381-4388-B61B-445801BE6537" filename="PDF7-49861192-2020-01-20-0901194016.pdf"&gt;Attached&lt;/ImageBinaryObject&gt;
    &lt;/AdditionalDocument&gt;
    &lt;OverallDeclaration&gt;
    
      &lt;Declaration&gt;
        &lt;ID&gt;49861192&lt;/ID&gt;
        &lt;AcceptanceDateTime formatCode="204"&gt;20200120091629&lt;/AcceptanceDateTime&gt;
        &lt;FunctionalReferenceID&gt;468&lt;/FunctionalReferenceID&gt;
        &lt;VersionID&gt;1&lt;/VersionID&gt;
        &lt;Submitter&gt;
        
          &lt;Name&gt;Maersk A S&lt;/Name&gt;
        &lt;/Submitter&gt;
        &lt;BorderTransportMeans&gt;
          &lt;Name&gt;' &amp; VESSEL &amp; '&lt;/Name&gt;
          &lt;ID&gt;9297852&lt;/ID&gt;
          &lt;TypeCode&gt;1&lt;/TypeCode&gt;
          &lt;ArrivalDateTime formatCode="102"&gt;20200122&lt;/ArrivalDateTime&gt;
          &lt;FirstArrivalLocationID&gt;NZTRG&lt;/FirstArrivalLocationID&gt;
          &lt;JourneyID&gt;' &amp; VOYAGE &amp; '&lt;/JourneyID&gt;
        &lt;/BorderTransportMeans&gt;
        &lt;Consignment&gt;
          &lt;GoodsStatusCode StatusType="CLEARANCE"&gt;IDR&lt;/GoodsStatusCode&gt;
          &lt;GoodsStatusCode StatusType="MOVEMENT"&gt;DTA&lt;/GoodsStatusCode&gt;
          &lt;SequenceNumeric&gt;181&lt;/SequenceNumeric&gt;
          &lt;AdditionalInformation&gt;
            &lt;StatementCode&gt;1C&lt;/StatementCode&gt;
            &lt;StatementTypeCode&gt;MTT&lt;/StatementTypeCode&gt;
          &lt;/AdditionalInformation&gt;
          &lt;Consignee&gt;
          
            &lt;Name&gt;ROHLIG NEW ZEALAND LTD&lt;/Name&gt;
          &lt;/Consignee&gt;
          &lt;ConsignmentItem&gt;
            &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
            &lt;GoodsMeasure&gt;
            
              &lt;GrossMassMeasure unitCode="KGM"&gt;1953.3&lt;/GrossMassMeasure&gt;
            &lt;/GoodsMeasure&gt;
            &lt;Packaging&gt;
              &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
              &lt;QuantityQuantity&gt;79&lt;/QuantityQuantity&gt;
              &lt;TypeCode&gt;PK&lt;/TypeCode&gt;
            &lt;/Packaging&gt;
          &lt;/ConsignmentItem&gt;
          &lt;ConsignmentItem&gt;
            &lt;SequenceNumeric&gt;2&lt;/SequenceNumeric&gt;
            &lt;GoodsMeasure&gt;
            
              &lt;GrossMassMeasure unitCode="KGM"&gt;2737.3&lt;/GrossMassMeasure&gt;
            &lt;/GoodsMeasure&gt;
            &lt;Packaging&gt;
              &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
              &lt;QuantityQuantity&gt;137&lt;/QuantityQuantity&gt;
              &lt;TypeCode&gt;PK&lt;/TypeCode&gt;
            &lt;/Packaging&gt;
          &lt;/ConsignmentItem&gt;
          &lt;Consignor&gt;
          
            &lt;Name&gt;ROHLIG CHINA LIMITED NINGBO BRANCH&lt;/Name&gt;
          &lt;/Consignor&gt;
          &lt;TransitDestination&gt;
          
            &lt;Name&gt;PORTNZNSN&lt;/Name&gt;
          &lt;/TransitDestination&gt;
          &lt;TransportContractDocument&gt;
            &lt;ID&gt;' &amp; BOL1 &amp; '&lt;/ID&gt;
            &lt;TypeCode&gt;BM&lt;/TypeCode&gt;
          &lt;/TransportContractDocument&gt;
          &lt;TransportEquipment&gt;
            &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
            &lt;FullnessCode&gt;5&lt;/FullnessCode&gt;
            &lt;ID&gt;' &amp; CONTAINERTEST1 &amp; '&lt;/ID&gt;
            &lt;Seal&gt;
              &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
              &lt;ID&gt;CN3474138&lt;/ID&gt;
            &lt;/Seal&gt;
          &lt;/TransportEquipment&gt;
          &lt;TransportEquipment&gt;
            &lt;SequenceNumeric&gt;2&lt;/SequenceNumeric&gt;
            &lt;FullnessCode&gt;5&lt;/FullnessCode&gt;
            &lt;ID&gt;' &amp; CONTAINERTEST2 &amp; '&lt;/ID&gt;
            &lt;Seal&gt;
              &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
              &lt;ID&gt;CN3474193&lt;/ID&gt;
            &lt;/Seal&gt;
          &lt;/TransportEquipment&gt;
          &lt;UnloadingLocation&gt;
          
            &lt;ID&gt;NZTRG&lt;/ID&gt;
          &lt;/UnloadingLocation&gt;
        &lt;/Consignment&gt;
        &lt;ResponsibleGovernmentAgency&gt;
        
          &lt;ID&gt;MPIBIO&lt;/ID&gt;
        &lt;/ResponsibleGovernmentAgency&gt;
      &lt;/Declaration&gt;
    &lt;/OverallDeclaration&gt;
    &lt;Status&gt;
      &lt;EffectiveDateTime formatCode="204"&gt;20200120091629&lt;/EffectiveDateTime&gt;
      &lt;NameCode&gt;' &amp; DECLARATION_PROCESSING_STATUS &amp; '&lt;/NameCode&gt;
      &lt;Pointer&gt;
      
        &lt;DocumentSectionCode&gt;07B&lt;/DocumentSectionCode&gt;
      &lt;/Pointer&gt;
      &lt;Pointer&gt;
      
        &lt;DocumentSectionCode&gt;42A&lt;/DocumentSectionCode&gt;
      &lt;/Pointer&gt;
      &lt;Pointer&gt;
        &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
        &lt;DocumentSectionCode&gt;08B&lt;/DocumentSectionCode&gt;
        &lt;TagID&gt;G007&lt;/TagID&gt;
      &lt;/Pointer&gt;
    &lt;/Status&gt;
  &lt;/Response&gt;
&lt;/DocumentMetaData&gt;';
	
	/*
	** Run
	*/
	ediFile := self.ediLoadFileName(ediText, EDIFileType_XML, USER_DEF_NAME, USER_DEF_NAME &amp; method.name);
	self.assertNotNull(ediFile);
	
	// should be 1 edi tracked item
	self.assertEqualMsg(ediFile.ediData.allEDITrackedItems.size, 2, "Test 1 - EDI Data has incorrect number of EDI tracked items");
	
	// Both EDI tracked items should have pack count of 1 (pack count is set to 1 by the plugin for container cargo)
	foreach ediTI in ediFile.ediData.allEDITrackedItems do
		ediStop := ediTI.CM_EDICustomStopTI;
		if ediStop.billOfLading = BOL1 then
			found1 := true;
			self.assertEqualMsg(ediStop.packCount, 1, "Test 1 - BOL 1 has incorrect pack count");
		endif;
	endforeach;
	self.assertTrueMsg(found1, "Test 1 - BOL 1 not found");
	
	self.ediVerify(ediFile);
	tempStr	:= 'Test 1 - Verify Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_VERIFIED, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	//return;
	self.ediDBLoad(ediFile);
	tempStr	:= 'Test 1 - DBLoad Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	self.assertNoTrxErrorsOrWarnings();
	
	/*
	** Assert
	*/
	// Check the cargo for import stop
	foreach ti1 in tiSet do
		// stop should have been added
		tempStr	:= 'Test 1 - Stop ' &amp; STOP_ID_TT.display &amp; Space &amp; realStopsTableTT.heading.display &amp; ' does not exist for cargo ' &amp; ti1.id;
		self.assertEqualMsg(ti1.isStopSet(STOP_ID_TT), true, tempStr);
		
	endforeach;
	
	/*
	** Cleanup
	*/
	delete tiSet;
	
	/*
	**	Test 1 End - Test Role Code that is TT. Should add the TSW TT HOLD stop with stopId as 874
	*/
	
	/*
	**	Test 2 Start - Test Role Code that is GC. Should not add the TSW TT HOLD stop with stopId as 874
	*/
	
	/*
	** Setup
	*/
	create tiSet transient;
	
	// create cargo - two containers
	ti1 := self.addContainerAtLocation(CONTAINERTEST3, operator, "22G1", "GENL", TI_IMEX_STATUS_IMPORT, blockStack.myLocationsController);
	ti2 := self.addContainerAtLocation(CONTAINERTEST4, operator, "22G1", "GENL", TI_IMEX_STATUS_IMPORT, blockStack.myLocationsController);
	
	tiSet.add(ti1);
	tiSet.add(ti2);
	
	// assign house bol number and voyage
	beginTransaction;
	foreach ti1 in tiSet do
		ti1.setPropertyValue(CM_TrackedItem::houseBillOfLading.name, BOL1);
		ti1.setMyVoyage(voyage, app.myPassport);
	endforeach;
	commitTransaction;
	
	self.assertEqualMsg(voyage.allTisByHouseBol.size, 4, "Test 2 - Voyage has incorrect number of House BOL TIs");
	
	// edi text - one master BOL (which JMT ignores) and 1 house BOl (but 2 house BOL segments with the same BOL number)
	ediText := 
'&lt;DocumentMetaData xmlns="urn:wco:datamodel:WCO:DM:1"&gt;
  &lt;WCODataModelVersion&gt;3.2&lt;/WCODataModelVersion&gt;
  &lt;WCODocumentName&gt;RES&lt;/WCODocumentName&gt;
  &lt;CountryCode&gt;NZ&lt;/CountryCode&gt;
  &lt;AgencyAssignedCustomizedDocumentName&gt;RESICR&lt;/AgencyAssignedCustomizedDocumentName&gt;
  &lt;AgencyAssignedCustomizedDocumentVersion&gt;V1.0&lt;/AgencyAssignedCustomizedDocumentVersion&gt;
  &lt;CommunicationMetaData&gt;
  
    &lt;Recipient&gt;
      &lt;ID&gt;40513451K&lt;/ID&gt;
      &lt;RoleCode&gt;' &amp; ROLE_CODE_GC &amp; '&lt;/RoleCode&gt;
    &lt;/Recipient&gt;
  &lt;/CommunicationMetaData&gt;
  &lt;Response xmlns="urn:wco:datamodel:WCO:ResponseModel:1"&gt;
    &lt;IssueDateTime formatCode="204"&gt;20200120091629&lt;/IssueDateTime&gt;
    &lt;FunctionalReferenceID&gt;20414&lt;/FunctionalReferenceID&gt;
    &lt;FunctionCode&gt;24&lt;/FunctionCode&gt;
    &lt;AdditionalDocument&gt;
      &lt;CategoryCode&gt;BAC&lt;/CategoryCode&gt;
      &lt;ImageBinaryObject mimeCode="application/pdf" uri="idd_E41D6A50-4381-4388-B61B-445801BE6537" filename="PDF7-49861192-2020-01-20-0901194016.pdf"&gt;Attached&lt;/ImageBinaryObject&gt;
    &lt;/AdditionalDocument&gt;
    &lt;OverallDeclaration&gt;
    
      &lt;Declaration&gt;
        &lt;ID&gt;49861192&lt;/ID&gt;
        &lt;AcceptanceDateTime formatCode="204"&gt;20200120091629&lt;/AcceptanceDateTime&gt;
        &lt;FunctionalReferenceID&gt;468&lt;/FunctionalReferenceID&gt;
        &lt;VersionID&gt;1&lt;/VersionID&gt;
        &lt;Submitter&gt;
        
          &lt;Name&gt;Maersk A S&lt;/Name&gt;
        &lt;/Submitter&gt;
        &lt;BorderTransportMeans&gt;
          &lt;Name&gt;' &amp; VESSEL &amp; '&lt;/Name&gt;
          &lt;ID&gt;9297852&lt;/ID&gt;
          &lt;TypeCode&gt;1&lt;/TypeCode&gt;
          &lt;ArrivalDateTime formatCode="102"&gt;20200122&lt;/ArrivalDateTime&gt;
          &lt;FirstArrivalLocationID&gt;NZTRG&lt;/FirstArrivalLocationID&gt;
          &lt;JourneyID&gt;' &amp; VOYAGE &amp; '&lt;/JourneyID&gt;
        &lt;/BorderTransportMeans&gt;
        &lt;Consignment&gt;
          &lt;GoodsStatusCode StatusType="CLEARANCE"&gt;IDR&lt;/GoodsStatusCode&gt;
          &lt;GoodsStatusCode StatusType="MOVEMENT"&gt;DTA&lt;/GoodsStatusCode&gt;
          &lt;SequenceNumeric&gt;181&lt;/SequenceNumeric&gt;
          &lt;AdditionalInformation&gt;
            &lt;StatementCode&gt;1C&lt;/StatementCode&gt;
            &lt;StatementTypeCode&gt;MTT&lt;/StatementTypeCode&gt;
          &lt;/AdditionalInformation&gt;
          &lt;Consignee&gt;
          
            &lt;Name&gt;ROHLIG NEW ZEALAND LTD&lt;/Name&gt;
          &lt;/Consignee&gt;
          &lt;ConsignmentItem&gt;
            &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
            &lt;GoodsMeasure&gt;
            
              &lt;GrossMassMeasure unitCode="KGM"&gt;1953.3&lt;/GrossMassMeasure&gt;
            &lt;/GoodsMeasure&gt;
            &lt;Packaging&gt;
              &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
              &lt;QuantityQuantity&gt;79&lt;/QuantityQuantity&gt;
              &lt;TypeCode&gt;PK&lt;/TypeCode&gt;
            &lt;/Packaging&gt;
          &lt;/ConsignmentItem&gt;
          &lt;ConsignmentItem&gt;
            &lt;SequenceNumeric&gt;2&lt;/SequenceNumeric&gt;
            &lt;GoodsMeasure&gt;
            
              &lt;GrossMassMeasure unitCode="KGM"&gt;2737.3&lt;/GrossMassMeasure&gt;
            &lt;/GoodsMeasure&gt;
            &lt;Packaging&gt;
              &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
              &lt;QuantityQuantity&gt;137&lt;/QuantityQuantity&gt;
              &lt;TypeCode&gt;PK&lt;/TypeCode&gt;
            &lt;/Packaging&gt;
          &lt;/ConsignmentItem&gt;
          &lt;Consignor&gt;
          
            &lt;Name&gt;ROHLIG CHINA LIMITED NINGBO BRANCH&lt;/Name&gt;
          &lt;/Consignor&gt;
          &lt;TransitDestination&gt;
          
            &lt;Name&gt;PORTNZNSN&lt;/Name&gt;
          &lt;/TransitDestination&gt;
          &lt;TransportContractDocument&gt;
            &lt;ID&gt;' &amp; BOL1 &amp; '&lt;/ID&gt;
            &lt;TypeCode&gt;BM&lt;/TypeCode&gt;
          &lt;/TransportContractDocument&gt;
          &lt;TransportEquipment&gt;
            &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
            &lt;FullnessCode&gt;5&lt;/FullnessCode&gt;
            &lt;ID&gt;' &amp; CONTAINERTEST3 &amp; '&lt;/ID&gt;
            &lt;Seal&gt;
              &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
              &lt;ID&gt;CN3474138&lt;/ID&gt;
            &lt;/Seal&gt;
          &lt;/TransportEquipment&gt;
          &lt;TransportEquipment&gt;
            &lt;SequenceNumeric&gt;2&lt;/SequenceNumeric&gt;
            &lt;FullnessCode&gt;5&lt;/FullnessCode&gt;
            &lt;ID&gt;' &amp; CONTAINERTEST4 &amp; '&lt;/ID&gt;
            &lt;Seal&gt;
              &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
              &lt;ID&gt;CN3474193&lt;/ID&gt;
            &lt;/Seal&gt;
          &lt;/TransportEquipment&gt;
          &lt;UnloadingLocation&gt;
          
            &lt;ID&gt;NZTRG&lt;/ID&gt;
          &lt;/UnloadingLocation&gt;
        &lt;/Consignment&gt;
        &lt;ResponsibleGovernmentAgency&gt;
        
          &lt;ID&gt;MPIBIO&lt;/ID&gt;
        &lt;/ResponsibleGovernmentAgency&gt;
      &lt;/Declaration&gt;
    &lt;/OverallDeclaration&gt;
    &lt;Status&gt;
      &lt;EffectiveDateTime formatCode="204"&gt;20200120091629&lt;/EffectiveDateTime&gt;
      &lt;NameCode&gt;' &amp; DECLARATION_PROCESSING_STATUS &amp; '&lt;/NameCode&gt;
      &lt;Pointer&gt;
      
        &lt;DocumentSectionCode&gt;07B&lt;/DocumentSectionCode&gt;
      &lt;/Pointer&gt;
      &lt;Pointer&gt;
      
        &lt;DocumentSectionCode&gt;42A&lt;/DocumentSectionCode&gt;
      &lt;/Pointer&gt;
      &lt;Pointer&gt;
        &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
        &lt;DocumentSectionCode&gt;08B&lt;/DocumentSectionCode&gt;
        &lt;TagID&gt;G007&lt;/TagID&gt;
      &lt;/Pointer&gt;
    &lt;/Status&gt;
  &lt;/Response&gt;
&lt;/DocumentMetaData&gt;';
	
	/*
	** Run
	*/
	ediFile := self.ediLoadFileName(ediText, EDIFileType_XML, USER_DEF_NAME, USER_DEF_NAME &amp; method.name);
	self.assertNotNull(ediFile);
	
	// should be 1 edi tracked item
	self.assertEqualMsg(ediFile.ediData.allEDITrackedItems.size, 2, "Test 2 - EDI Data has incorrect number of EDI tracked items");
	
	// Both EDI tracked items should have pack count of 1 (pack count is set to 1 by the plugin for container cargo)
	foreach ediTI in ediFile.ediData.allEDITrackedItems do
		ediStop := ediTI.CM_EDICustomStopTI;
		if ediStop.billOfLading = BOL1 then
			found1 := true;
			self.assertEqualMsg(ediStop.packCount, 1, "Test 2 - BOL 1 has incorrect pack count");
		endif;
	endforeach;
	self.assertTrueMsg(found1, "Test 2 - BOL 1 not found");
	
	self.ediVerify(ediFile);
	tempStr	:= 'Test 2 - Verify Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_VERIFIED, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	//return;
	self.ediDBLoad(ediFile);
	tempStr	:= 'Test 2 - DBLoad Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	self.assertNoTrxErrorsOrWarnings();
	
	/*
	** Assert
	*/
	// Check the cargo for import stop
	foreach ti1 in tiSet do
		// stop should have been added
		tempStr	:= 'Test 2 - Stop ' &amp; STOP_ID_TT.display &amp; Space &amp; realStopsTableTT.heading.display &amp; ' exists for cargo ' &amp; ti1.id &amp; '. It should not';
		self.assertEqualMsg(ti1.isStopSet(STOP_ID_TT), false, tempStr);
		
	endforeach;
	
	/*
	** Cleanup
	*/
	delete tiSet;
	
	/*
	**	Test 2 End - Test Role Code that is GC. Should not add the TSW TT HOLD stop with stopId as 874
	*/
	
	/*
	**	Test 3 Start - Test Role Code that is GC. Should remove the TSW TT HOLD stop with stopId as 874
	*/
	
	/*
	** Setup
	*/
	create tiSet transient;
	
	// create cargo - two containers
	ti1 := self.addContainerAtLocation(CONTAINER1, operator, "22G1", "GENL", TI_IMEX_STATUS_IMPORT, blockStack.myLocationsController);
	ti2 := self.addContainerAtLocation(CONTAINER2, operator, "22G1", "GENL", TI_IMEX_STATUS_IMPORT, blockStack.myLocationsController);
	
	tiSet.add(ti1);
	tiSet.add(ti2);
	
	// assign house bol number and voyage
	beginTransaction;
	foreach ti1 in tiSet do
		ti1.setPropertyValue(CM_TrackedItem::houseBillOfLading.name, BOL1);
		ti1.setMyVoyage(voyage, app.myPassport);
	endforeach;
	commitTransaction;
	
	// add an import stop
	foreach ti1 in tiSet do
		self.addStopById(ti1, STOP_ID_TT);
	endforeach;
	
	foreach ti1 in tiSet do
		// check - cargo should have the TT stop
		tempStr	:= 'Test 3 - Stop ' &amp; STOP_ID_TT.display &amp; Space &amp; realStopsTableTT.heading.display &amp; ' does not exist for cargo ' &amp; ti1.id;
		self.assertEqualMsg(ti1.isStopSet(STOP_ID_TT), true, tempStr);
		
	endforeach;
	
	self.assertEqualMsg(voyage.allTisByHouseBol.size, 6, "Test 3 - Voyage has incorrect number of House BOL TIs");
	
	// edi text - one master BOL (which JMT ignores) and 1 house BOl (but 2 house BOL segments with the same BOL number)
	ediText := 
'&lt;DocumentMetaData xmlns="urn:wco:datamodel:WCO:DM:1"&gt;
  &lt;WCODataModelVersion&gt;3.2&lt;/WCODataModelVersion&gt;
  &lt;WCODocumentName&gt;RES&lt;/WCODocumentName&gt;
  &lt;CountryCode&gt;NZ&lt;/CountryCode&gt;
  &lt;AgencyAssignedCustomizedDocumentName&gt;RESICR&lt;/AgencyAssignedCustomizedDocumentName&gt;
  &lt;AgencyAssignedCustomizedDocumentVersion&gt;V1.0&lt;/AgencyAssignedCustomizedDocumentVersion&gt;
  &lt;CommunicationMetaData&gt;
  
    &lt;Recipient&gt;
      &lt;ID&gt;40513451K&lt;/ID&gt;
      &lt;RoleCode&gt;' &amp; ROLE_CODE_GC &amp; '&lt;/RoleCode&gt;
    &lt;/Recipient&gt;
  &lt;/CommunicationMetaData&gt;
  &lt;Response xmlns="urn:wco:datamodel:WCO:ResponseModel:1"&gt;
    &lt;IssueDateTime formatCode="204"&gt;20200120091629&lt;/IssueDateTime&gt;
    &lt;FunctionalReferenceID&gt;20414&lt;/FunctionalReferenceID&gt;
    &lt;FunctionCode&gt;24&lt;/FunctionCode&gt;
    &lt;AdditionalDocument&gt;
      &lt;CategoryCode&gt;BAC&lt;/CategoryCode&gt;
      &lt;ImageBinaryObject mimeCode="application/pdf" uri="idd_E41D6A50-4381-4388-B61B-445801BE6537" filename="PDF7-49861192-2020-01-20-0901194016.pdf"&gt;Attached&lt;/ImageBinaryObject&gt;
    &lt;/AdditionalDocument&gt;
    &lt;OverallDeclaration&gt;
    
      &lt;Declaration&gt;
        &lt;ID&gt;49861192&lt;/ID&gt;
        &lt;AcceptanceDateTime formatCode="204"&gt;20200120091629&lt;/AcceptanceDateTime&gt;
        &lt;FunctionalReferenceID&gt;468&lt;/FunctionalReferenceID&gt;
        &lt;VersionID&gt;1&lt;/VersionID&gt;
        &lt;Submitter&gt;
        
          &lt;Name&gt;Maersk A S&lt;/Name&gt;
        &lt;/Submitter&gt;
        &lt;BorderTransportMeans&gt;
          &lt;Name&gt;' &amp; VESSEL &amp; '&lt;/Name&gt;
          &lt;ID&gt;9297852&lt;/ID&gt;
          &lt;TypeCode&gt;1&lt;/TypeCode&gt;
          &lt;ArrivalDateTime formatCode="102"&gt;20200122&lt;/ArrivalDateTime&gt;
          &lt;FirstArrivalLocationID&gt;NZTRG&lt;/FirstArrivalLocationID&gt;
          &lt;JourneyID&gt;' &amp; VOYAGE &amp; '&lt;/JourneyID&gt;
        &lt;/BorderTransportMeans&gt;
        &lt;Consignment&gt;
          &lt;GoodsStatusCode StatusType="CLEARANCE"&gt;IDR&lt;/GoodsStatusCode&gt;
          &lt;GoodsStatusCode StatusType="MOVEMENT"&gt;DTA&lt;/GoodsStatusCode&gt;
          &lt;SequenceNumeric&gt;181&lt;/SequenceNumeric&gt;
          &lt;AdditionalInformation&gt;
            &lt;StatementCode&gt;1C&lt;/StatementCode&gt;
            &lt;StatementTypeCode&gt;MTT&lt;/StatementTypeCode&gt;
          &lt;/AdditionalInformation&gt;
          &lt;Consignee&gt;
          
            &lt;Name&gt;ROHLIG NEW ZEALAND LTD&lt;/Name&gt;
          &lt;/Consignee&gt;
          &lt;ConsignmentItem&gt;
            &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
            &lt;GoodsMeasure&gt;
            
              &lt;GrossMassMeasure unitCode="KGM"&gt;1953.3&lt;/GrossMassMeasure&gt;
            &lt;/GoodsMeasure&gt;
            &lt;Packaging&gt;
              &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
              &lt;QuantityQuantity&gt;79&lt;/QuantityQuantity&gt;
              &lt;TypeCode&gt;PK&lt;/TypeCode&gt;
            &lt;/Packaging&gt;
          &lt;/ConsignmentItem&gt;
          &lt;ConsignmentItem&gt;
            &lt;SequenceNumeric&gt;2&lt;/SequenceNumeric&gt;
            &lt;GoodsMeasure&gt;
            
              &lt;GrossMassMeasure unitCode="KGM"&gt;2737.3&lt;/GrossMassMeasure&gt;
            &lt;/GoodsMeasure&gt;
            &lt;Packaging&gt;
              &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
              &lt;QuantityQuantity&gt;137&lt;/QuantityQuantity&gt;
              &lt;TypeCode&gt;PK&lt;/TypeCode&gt;
            &lt;/Packaging&gt;
          &lt;/ConsignmentItem&gt;
          &lt;Consignor&gt;
          
            &lt;Name&gt;ROHLIG CHINA LIMITED NINGBO BRANCH&lt;/Name&gt;
          &lt;/Consignor&gt;
          &lt;TransitDestination&gt;
          
            &lt;Name&gt;PORTNZNSN&lt;/Name&gt;
          &lt;/TransitDestination&gt;
          &lt;TransportContractDocument&gt;
            &lt;ID&gt;' &amp; BOL1 &amp; '&lt;/ID&gt;
            &lt;TypeCode&gt;BM&lt;/TypeCode&gt;
          &lt;/TransportContractDocument&gt;
          &lt;TransportEquipment&gt;
            &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
            &lt;FullnessCode&gt;5&lt;/FullnessCode&gt;
            &lt;ID&gt;' &amp; CONTAINER1 &amp; '&lt;/ID&gt;
            &lt;Seal&gt;
              &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
              &lt;ID&gt;CN3474138&lt;/ID&gt;
            &lt;/Seal&gt;
          &lt;/TransportEquipment&gt;
          &lt;TransportEquipment&gt;
            &lt;SequenceNumeric&gt;2&lt;/SequenceNumeric&gt;
            &lt;FullnessCode&gt;5&lt;/FullnessCode&gt;
            &lt;ID&gt;' &amp; CONTAINER2 &amp; '&lt;/ID&gt;
            &lt;Seal&gt;
              &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
              &lt;ID&gt;CN3474193&lt;/ID&gt;
            &lt;/Seal&gt;
          &lt;/TransportEquipment&gt;
          &lt;UnloadingLocation&gt;
          
            &lt;ID&gt;NZTRG&lt;/ID&gt;
          &lt;/UnloadingLocation&gt;
        &lt;/Consignment&gt;
        &lt;ResponsibleGovernmentAgency&gt;
        
          &lt;ID&gt;MPIBIO&lt;/ID&gt;
        &lt;/ResponsibleGovernmentAgency&gt;
      &lt;/Declaration&gt;
    &lt;/OverallDeclaration&gt;
    &lt;Status&gt;
      &lt;EffectiveDateTime formatCode="204"&gt;20200120091629&lt;/EffectiveDateTime&gt;
      &lt;NameCode&gt;' &amp; DECLARATION_PROCESSING_STATUS &amp; '&lt;/NameCode&gt;
      &lt;Pointer&gt;
      
        &lt;DocumentSectionCode&gt;07B&lt;/DocumentSectionCode&gt;
      &lt;/Pointer&gt;
      &lt;Pointer&gt;
      
        &lt;DocumentSectionCode&gt;42A&lt;/DocumentSectionCode&gt;
      &lt;/Pointer&gt;
      &lt;Pointer&gt;
        &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
        &lt;DocumentSectionCode&gt;08B&lt;/DocumentSectionCode&gt;
        &lt;TagID&gt;G007&lt;/TagID&gt;
      &lt;/Pointer&gt;
    &lt;/Status&gt;
  &lt;/Response&gt;
&lt;/DocumentMetaData&gt;';
	
	/*
	** Run
	*/
	ediFile := self.ediLoadFileName(ediText, EDIFileType_XML, USER_DEF_NAME, USER_DEF_NAME &amp; method.name);
	self.assertNotNull(ediFile);
	
	// should be 1 edi tracked item
	self.assertEqualMsg(ediFile.ediData.allEDITrackedItems.size, 2, "Test 3 - EDI Data has incorrect number of EDI tracked items");
	
	// Both EDI tracked items should have pack count of 1 (pack count is set to 1 by the plugin for container cargo)
	foreach ediTI in ediFile.ediData.allEDITrackedItems do
		ediStop := ediTI.CM_EDICustomStopTI;
		if ediStop.billOfLading = BOL1 then
			found1 := true;
			self.assertEqualMsg(ediStop.packCount, 1, "Test 3 - BOL 1 has incorrect pack count");
		endif;
	endforeach;
	self.assertTrueMsg(found1, "Test 3 - BOL 1 not found");
	
	self.ediVerify(ediFile);
	tempStr	:= 'Test 3 - Verify Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_VERIFIED, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	//return;
	self.ediDBLoad(ediFile);
	tempStr	:= 'Test 3 - DBLoad Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	self.assertNoTrxErrorsOrWarnings();
	
	/*
	** Assert
	*/
	
	// Check the cargo for import stop
	foreach ti1 in tiSet do
		// stop should have been cleared
		tempStr	:= 'Test 3 - Stop ' &amp; STOP_ID_TT.display &amp; Space &amp; realStopsTableTT.heading.display &amp; ' still exists for cargo ' &amp; ti1.id;
		self.assertEqualMsg(ti1.isStopSet(STOP_ID_TT), false, tempStr);
		
	endforeach;
	
	/*
	**	Test 3 End - Test Role Code that is TT. Should remove the TSW TT HOLD stop with stopId as 874
	*/
	
	beginTransaction;
	realStopsTableTT.setPropertyValue(CM_StopsTable::isNotAvailableForEntry.name, true);
	realStopsTableGC.setPropertyValue(CM_StopsTable::isNotAvailableForEntry.name, true);
	commitTransaction;
	
	completedOk := true;
	
epilog
	if not completedOk and realStopsTableTT &lt;&gt; null and realStopsTableGC &lt;&gt; null then
		abortTransaction;
		beginTransaction;
		realStopsTableTT.setPropertyValue(CM_StopsTable::isNotAvailableForEntry.name, true);
		realStopsTableGC.setPropertyValue(CM_StopsTable::isNotAvailableForEntry.name, true);
		commitTransaction;
	endif;
	delete pxyStopsTableTT;
	delete pxyStopsTableGC;
	delete pxyCustomsActionTT;
	delete pxyCustomsActionGC;
	delete intArray;
	delete setArray;
	delete tiSet;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tTSWDTRTTC06" id="932472f1-17ba-4fe5-aa2c-21a9be82bbd3">
        <source>tTSWDTRTTC06();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
26 June 2023	navpw1	Initial creation TFS: 58831

*/

constants
	ROLE_CODE_TT					: String	= 'TT';
	ROLE_CODE_GC					: String	= 'GC';
	DECLARATION_PROCESSING_STATUS	: String	= 'C06';
	BLOCKSTACK						: String	= 'UTB' &amp; DECLARATION_PROCESSING_STATUS;
	MASTERBOL						: String	= "PMWLQ6952";		// Master BOL
	HOUSEBOL						: String	= "TLL014121";		// House BOL
	VESSEL							: String	= 'UTBOL' &amp; DECLARATION_PROCESSING_STATUS;
	VOYAGE							: String	= 'UT' &amp; self.TFS58831 &amp; "_" &amp; DECLARATION_PROCESSING_STATUS;
	OPERATOR						: String	= 'UTOP';
	USER_DEF_NAME					: String	= 'TSW';
	
	CONTAINERTEST1					: String	= self.TFS58831 &amp; "-" &amp; DECLARATION_PROCESSING_STATUS &amp; "-1";
	CONTAINERTEST2					: String	= self.TFS58831 &amp; "-" &amp; DECLARATION_PROCESSING_STATUS &amp; "-2";
	CONTAINERTEST3					: String	= self.TFS58831 &amp; "-" &amp; DECLARATION_PROCESSING_STATUS &amp; "-3";
	CONTAINERTEST4					: String	= self.TFS58831 &amp; "-" &amp; DECLARATION_PROCESSING_STATUS &amp; "-4";
	CONTAINER1						: String	= self.TFS58831 &amp; "-" &amp; DECLARATION_PROCESSING_STATUS &amp; "-5";
	CONTAINER2						: String	= self.TFS58831 &amp; "-" &amp; DECLARATION_PROCESSING_STATUS &amp; "-6";
	BOL1							: String	= "BOL120N28100-2";
	
	STOP_CODE_TT					: String	= "TSWTT";
	STOP_ID_TT						: Integer	= 879;
	STOP_HEADING_TT					: String	= "TSW TT HOLD " &amp; DECLARATION_PROCESSING_STATUS;
	CUSTOMS_ACTION_NAME_TT			: String	= "TSW TT " &amp; DECLARATION_PROCESSING_STATUS;
	CUSTOMS_ACTION_KEYWORD_TT		: String	= DECLARATION_PROCESSING_STATUS;
	
	STOP_CODE_GC					: String	= "TSWGC";
	STOP_ID_GC						: Integer	= 880;
	STOP_HEADING_GC					: String	= "TSW GC HOLD " &amp; DECLARATION_PROCESSING_STATUS;
	CUSTOMS_ACTION_NAME_GC			: String	= "TSW GC " &amp; DECLARATION_PROCESSING_STATUS;
	CUSTOMS_ACTION_KEYWORD_GC		: String	= DECLARATION_PROCESSING_STATUS;
	
vars
	blockStack						: CM_BlockStack;
	pxyStopsTableTT,
	realStopsTableTT,
	pxyStopsTableGC,
	realStopsTableGC,
	stopsTableMAF,
	stopsTableTT,
	stopsTableGC					: CM_StopsTable;
	vessel							: CM_Vessel;
	voyage							: CM_Voyage;
	operator						: CM_Operator;
	tiSet							: CM_TISet;
	ti1,
	ti2								: CM_TrackedItem;
	ediText, tempStr				: String;
	ediFile							: CM_EDIFile;
	ediTI							: CM_EDITrackedItem;
	ediStop							: CM_EDICustomStopTI;
	found1							: Boolean;
	pxyCustomsActionTT,
	realCustomsActionTT,
	pxyCustomsActionGC,
	realCustomsActionGC				: CM_EDIAction;
	
	pxyStopsTableTemplateTT,
	pxyStopsTableTemplateGC			: CM_StopTableTemplate;
	intArray						: IntegerArray;
	setArray						: IntegerArray;
	importStops						: Boolean;
	completedOk						: Boolean;
	
begin
	importStops := self.getTerminalConfig(NoImportStops).Boolean;
	self.setTerminalConfig(NoImportStops, false);
	// get rid of stuff - block stack, bols, voyage, vessel
	self.deleteTerminalArea(BLOCKSTACK);
	self.deleteVoyage(VOYAGE);
	self.deleteVessel(VESSEL);
	
	// setup stuff 
	blockStack := self.addBlockStack(BLOCKSTACK, 10, null);
	
	//Get Operator
	operator := self.getOperator(OPERATOR);
	self.assertNotNull(operator);
	
	vessel := self.addVesselGeneralCargo(VESSEL, operator, 5);
	self.assertNotNull(vessel);
	
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL, OPERATOR, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 2);
	self.assertNotNull(voyage);
	
	//Delete TSW TT STOP
	stopsTableTT := self.getRoot.getStopTableForId(STOP_ID_TT);
	if stopsTableTT &lt;&gt; null then
		self.deleteStopsTable(STOP_ID_TT);
		self.assertIsDeletedMsg(stopsTableTT, "stopsTableTT");
	endif;
	
	//Delete TSW GC STOP
	stopsTableGC := self.getRoot.getStopTableForId(STOP_ID_GC);
	if stopsTableGC &lt;&gt; null then
		self.deleteStopsTable(STOP_ID_GC);
		self.assertIsDeletedMsg(stopsTableGC, "stopsTableGC");
	endif;
	
	//Get Stops Table MAF
	stopsTableMAF := self.getRoot.getStopTableForId(TI_Stop_MAF);
	
	//Create TSW TT STOP
	create pxyStopsTableTT transient;
	pxyStopsTableTT.setProxy(false, STOP_CODE_TT, STOP_HEADING_TT, STOP_CODE_TT, null, STOP_ID_TT, null, false, false, app.myRoot, null, app.myPassport.myUser.code, null);
	
	create pxyStopsTableTemplateTT transient;
	pxyStopsTableTemplateTT.setKeys( app.getMyTerminalDO_NOT_USE, pxyStopsTableTT );
	
	create intArray transient;
	create setArray transient;
	setArray.add(StopApplyExport);
	
	pxyStopsTableTemplateTT.setProxy(	intArray,
									setArray,
									intArray,
									null,									// Hold Voyages
									false,
									false,
									false,
									false,
									false,
									false,
									false,
									true);
	
	app.myTrxCA.trxCreateStopsTable(pxyStopsTableTT, realStopsTableTT, app.myPassport);
	self.assertNotNullMsg(realStopsTableTT, "realStopsTableTT");
	
	//Create TSW GC STOP
	create pxyStopsTableGC transient;
	pxyStopsTableGC.setProxy(false, STOP_CODE_GC, STOP_HEADING_GC, STOP_CODE_GC, null, STOP_ID_GC, null, false, false, app.myRoot, null, app.myPassport.myUser.code, null);
	
	create pxyStopsTableTemplateGC transient;
	pxyStopsTableTemplateGC.setKeys( app.getMyTerminalDO_NOT_USE, pxyStopsTableGC );
	
	delete intArray;
	delete setArray;
	
	create intArray transient;
	create setArray transient;
	setArray.add(StopApplyExport);
	
	pxyStopsTableTemplateGC.setProxy(	intArray,
									setArray,
									intArray,
									null,									// Hold Voyages
									false,
									false,
									false,
									false,
									false,
									false,
									false,
									true);
	
	app.myTrxCA.trxCreateStopsTable(pxyStopsTableGC, realStopsTableGC, app.myPassport);
	self.assertNotNullMsg(realStopsTableGC, "realStopsTableGC");
	
	//Delete Customs Action TT
	realCustomsActionTT := app.myRoot.allEDIActions[CUSTOMS_ACTION_NAME_TT];
	if realCustomsActionTT &lt;&gt; null then
		self.deleteEDIAction(CUSTOMS_ACTION_NAME_TT, null, EDIKeyField_Clearance);
		self.assertIsDeleted(realCustomsActionTT);
	endif;
	
	realCustomsActionTT := null;
	
	//Delete Customs Action GC
	realCustomsActionGC := app.myRoot.allEDIActions[CUSTOMS_ACTION_NAME_GC];
	if realCustomsActionGC &lt;&gt; null then
		self.deleteEDIAction(CUSTOMS_ACTION_NAME_GC, null, EDIKeyField_Clearance);
		self.assertIsDeleted(realCustomsActionGC);
	endif;
	
	realCustomsActionGC := null;
	
	//Create Customs Action TT
	create pxyCustomsActionTT transient;
	pxyCustomsActionTT.setProxy(CUSTOMS_ACTION_NAME_TT, CUSTOMS_ACTION_KEYWORD_TT, EDIKeyField_Clearance, EDIAction_Add, realStopsTableTT, CM_EDIFileTypeXMLJMTInternal.firstInstance, null, null, null, "TT");
	app.myTrxCA.trxCreateEDIAction(pxyCustomsActionTT, realCustomsActionTT, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(realCustomsActionTT, "realCustomsActionTT");
	
	//Create Customs Action GC
	create pxyCustomsActionGC transient;
	pxyCustomsActionGC.setProxy(CUSTOMS_ACTION_NAME_GC, CUSTOMS_ACTION_KEYWORD_GC, EDIKeyField_Clearance, EDIAction_Remove, realStopsTableTT, CM_EDIFileTypeXMLJMTInternal.firstInstance, null, null, null, null);
	app.myTrxCA.trxCreateEDIAction(pxyCustomsActionGC, realCustomsActionGC, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(realCustomsActionGC, "realCustomsActionGC");
	
	/*
	**	Test 1 Start - Test Role Code that is TT. Should add the TSW TT HOLD stop with stopId as 874
	*/
	
	/*
	** Setup
	*/
	create tiSet transient;
	
	// create cargo - two containers
	ti1 := self.addContainerAtLocation(CONTAINERTEST1, operator, "22G1", "GENL", TI_IMEX_STATUS_IMPORT, blockStack.myLocationsController);
	ti2 := self.addContainerAtLocation(CONTAINERTEST2, operator, "22G1", "GENL", TI_IMEX_STATUS_IMPORT, blockStack.myLocationsController);
	
	tiSet.add(ti1);
	tiSet.add(ti2);
	
	// assign house bol number and voyage
	beginTransaction;
	foreach ti1 in tiSet do
		ti1.setPropertyValue(CM_TrackedItem::houseBillOfLading.name, BOL1);
		ti1.setMyVoyage(voyage, app.myPassport);
	endforeach;
	commitTransaction;
	
	self.assertEqualMsg(voyage.allTisByHouseBol.size, 2, "Test 1 - Voyage has incorrect number of House BOL TIs");
	
	// edi text - one master BOL (which JMT ignores) and 1 house BOl (but 2 house BOL segments with the same BOL number)
	ediText := 
'&lt;DocumentMetaData xmlns="urn:wco:datamodel:WCO:DM:1"&gt;
  &lt;WCODataModelVersion&gt;3.2&lt;/WCODataModelVersion&gt;
  &lt;WCODocumentName&gt;RES&lt;/WCODocumentName&gt;
  &lt;CountryCode&gt;NZ&lt;/CountryCode&gt;
  &lt;AgencyAssignedCustomizedDocumentName&gt;RESICR&lt;/AgencyAssignedCustomizedDocumentName&gt;
  &lt;AgencyAssignedCustomizedDocumentVersion&gt;V1.0&lt;/AgencyAssignedCustomizedDocumentVersion&gt;
  &lt;CommunicationMetaData&gt;
  
    &lt;Recipient&gt;
      &lt;ID&gt;40513451K&lt;/ID&gt;
      &lt;RoleCode&gt;' &amp; ROLE_CODE_TT &amp; '&lt;/RoleCode&gt;
    &lt;/Recipient&gt;
  &lt;/CommunicationMetaData&gt;
  &lt;Response xmlns="urn:wco:datamodel:WCO:ResponseModel:1"&gt;
    &lt;IssueDateTime formatCode="204"&gt;20200120091629&lt;/IssueDateTime&gt;
    &lt;FunctionalReferenceID&gt;20414&lt;/FunctionalReferenceID&gt;
    &lt;FunctionCode&gt;24&lt;/FunctionCode&gt;
    &lt;AdditionalDocument&gt;
      &lt;CategoryCode&gt;BAC&lt;/CategoryCode&gt;
      &lt;ImageBinaryObject mimeCode="application/pdf" uri="idd_E41D6A50-4381-4388-B61B-445801BE6537" filename="PDF7-49861192-2020-01-20-0901194016.pdf"&gt;Attached&lt;/ImageBinaryObject&gt;
    &lt;/AdditionalDocument&gt;
    &lt;OverallDeclaration&gt;
    
      &lt;Declaration&gt;
        &lt;ID&gt;49861192&lt;/ID&gt;
        &lt;AcceptanceDateTime formatCode="204"&gt;20200120091629&lt;/AcceptanceDateTime&gt;
        &lt;FunctionalReferenceID&gt;468&lt;/FunctionalReferenceID&gt;
        &lt;VersionID&gt;1&lt;/VersionID&gt;
        &lt;Submitter&gt;
        
          &lt;Name&gt;Maersk A S&lt;/Name&gt;
        &lt;/Submitter&gt;
        &lt;BorderTransportMeans&gt;
          &lt;Name&gt;' &amp; VESSEL &amp; '&lt;/Name&gt;
          &lt;ID&gt;9297852&lt;/ID&gt;
          &lt;TypeCode&gt;1&lt;/TypeCode&gt;
          &lt;ArrivalDateTime formatCode="102"&gt;20200122&lt;/ArrivalDateTime&gt;
          &lt;FirstArrivalLocationID&gt;NZTRG&lt;/FirstArrivalLocationID&gt;
          &lt;JourneyID&gt;' &amp; VOYAGE &amp; '&lt;/JourneyID&gt;
        &lt;/BorderTransportMeans&gt;
        &lt;Consignment&gt;
          &lt;GoodsStatusCode StatusType="CLEARANCE"&gt;IDR&lt;/GoodsStatusCode&gt;
          &lt;GoodsStatusCode StatusType="MOVEMENT"&gt;DTA&lt;/GoodsStatusCode&gt;
          &lt;SequenceNumeric&gt;181&lt;/SequenceNumeric&gt;
          &lt;AdditionalInformation&gt;
            &lt;StatementCode&gt;1C&lt;/StatementCode&gt;
            &lt;StatementTypeCode&gt;MTT&lt;/StatementTypeCode&gt;
          &lt;/AdditionalInformation&gt;
          &lt;Consignee&gt;
          
            &lt;Name&gt;ROHLIG NEW ZEALAND LTD&lt;/Name&gt;
          &lt;/Consignee&gt;
          &lt;ConsignmentItem&gt;
            &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
            &lt;GoodsMeasure&gt;
            
              &lt;GrossMassMeasure unitCode="KGM"&gt;1953.3&lt;/GrossMassMeasure&gt;
            &lt;/GoodsMeasure&gt;
            &lt;Packaging&gt;
              &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
              &lt;QuantityQuantity&gt;79&lt;/QuantityQuantity&gt;
              &lt;TypeCode&gt;PK&lt;/TypeCode&gt;
            &lt;/Packaging&gt;
          &lt;/ConsignmentItem&gt;
          &lt;ConsignmentItem&gt;
            &lt;SequenceNumeric&gt;2&lt;/SequenceNumeric&gt;
            &lt;GoodsMeasure&gt;
            
              &lt;GrossMassMeasure unitCode="KGM"&gt;2737.3&lt;/GrossMassMeasure&gt;
            &lt;/GoodsMeasure&gt;
            &lt;Packaging&gt;
              &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
              &lt;QuantityQuantity&gt;137&lt;/QuantityQuantity&gt;
              &lt;TypeCode&gt;PK&lt;/TypeCode&gt;
            &lt;/Packaging&gt;
          &lt;/ConsignmentItem&gt;
          &lt;Consignor&gt;
          
            &lt;Name&gt;ROHLIG CHINA LIMITED NINGBO BRANCH&lt;/Name&gt;
          &lt;/Consignor&gt;
          &lt;TransitDestination&gt;
          
            &lt;Name&gt;PORTNZNSN&lt;/Name&gt;
          &lt;/TransitDestination&gt;
          &lt;TransportContractDocument&gt;
            &lt;ID&gt;' &amp; BOL1 &amp; '&lt;/ID&gt;
            &lt;TypeCode&gt;BM&lt;/TypeCode&gt;
          &lt;/TransportContractDocument&gt;
          &lt;TransportEquipment&gt;
            &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
            &lt;FullnessCode&gt;5&lt;/FullnessCode&gt;
            &lt;ID&gt;' &amp; CONTAINERTEST1 &amp; '&lt;/ID&gt;
            &lt;Seal&gt;
              &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
              &lt;ID&gt;CN3474138&lt;/ID&gt;
            &lt;/Seal&gt;
          &lt;/TransportEquipment&gt;
          &lt;TransportEquipment&gt;
            &lt;SequenceNumeric&gt;2&lt;/SequenceNumeric&gt;
            &lt;FullnessCode&gt;5&lt;/FullnessCode&gt;
            &lt;ID&gt;' &amp; CONTAINERTEST2 &amp; '&lt;/ID&gt;
            &lt;Seal&gt;
              &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
              &lt;ID&gt;CN3474193&lt;/ID&gt;
            &lt;/Seal&gt;
          &lt;/TransportEquipment&gt;
          &lt;UnloadingLocation&gt;
          
            &lt;ID&gt;NZTRG&lt;/ID&gt;
          &lt;/UnloadingLocation&gt;
        &lt;/Consignment&gt;
        &lt;ResponsibleGovernmentAgency&gt;
        
          &lt;ID&gt;MPIBIO&lt;/ID&gt;
        &lt;/ResponsibleGovernmentAgency&gt;
      &lt;/Declaration&gt;
    &lt;/OverallDeclaration&gt;
    &lt;Status&gt;
      &lt;EffectiveDateTime formatCode="204"&gt;20200120091629&lt;/EffectiveDateTime&gt;
      &lt;NameCode&gt;' &amp; DECLARATION_PROCESSING_STATUS &amp; '&lt;/NameCode&gt;
      &lt;Pointer&gt;
      
        &lt;DocumentSectionCode&gt;07B&lt;/DocumentSectionCode&gt;
      &lt;/Pointer&gt;
      &lt;Pointer&gt;
      
        &lt;DocumentSectionCode&gt;42A&lt;/DocumentSectionCode&gt;
      &lt;/Pointer&gt;
      &lt;Pointer&gt;
        &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
        &lt;DocumentSectionCode&gt;08B&lt;/DocumentSectionCode&gt;
        &lt;TagID&gt;G007&lt;/TagID&gt;
      &lt;/Pointer&gt;
    &lt;/Status&gt;
  &lt;/Response&gt;
&lt;/DocumentMetaData&gt;';
	
	/*
	** Run
	*/
	ediFile := self.ediLoadFileName(ediText, EDIFileType_XML, USER_DEF_NAME, USER_DEF_NAME &amp; method.name);
	self.assertNotNull(ediFile);
	
	// should be 1 edi tracked item
	self.assertEqualMsg(ediFile.ediData.allEDITrackedItems.size, 2, "Test 1 - EDI Data has incorrect number of EDI tracked items");
	
	// Both EDI tracked items should have pack count of 1 (pack count is set to 1 by the plugin for container cargo)
	foreach ediTI in ediFile.ediData.allEDITrackedItems do
		ediStop := ediTI.CM_EDICustomStopTI;
		if ediStop.billOfLading = BOL1 then
			found1 := true;
			self.assertEqualMsg(ediStop.packCount, 1, "Test 1 - BOL 1 has incorrect pack count");
		endif;
	endforeach;
	self.assertTrueMsg(found1, "Test 1 - BOL 1 not found");
	
	self.ediVerify(ediFile);
	tempStr	:= 'Test 1 - Verify Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_VERIFIED, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	
	self.ediDBLoad(ediFile);
	tempStr	:= 'Test 1 - DBLoad Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	self.assertNoTrxErrorsOrWarnings();
	
	/*
	** Assert
	*/
	// Check the cargo for import stop
	foreach ti1 in tiSet do
		// stop should have been added
		tempStr	:= 'Test 1 - Stop ' &amp; STOP_ID_TT.display &amp; Space &amp; realStopsTableTT.heading.display &amp; ' does not exist for cargo ' &amp; ti1.id;
		self.assertEqualMsg(ti1.isStopSet(STOP_ID_TT), true, tempStr);
		
	endforeach;
	
	/*
	** Cleanup
	*/
	delete tiSet;
	
	/*
	**	Test 1 End - Test Role Code that is TT. Should add the TSW TT HOLD stop with stopId as 874
	*/
	
	/*
	**	Test 2 Start - Test Role Code that is GC. Should not add the TSW TT HOLD stop with stopId as 874
	*/
	
	/*
	** Setup
	*/
	create tiSet transient;
	
	// create cargo - two containers
	ti1 := self.addContainerAtLocation(CONTAINERTEST3, operator, "22G1", "GENL", TI_IMEX_STATUS_IMPORT, blockStack.myLocationsController);
	ti2 := self.addContainerAtLocation(CONTAINERTEST4, operator, "22G1", "GENL", TI_IMEX_STATUS_IMPORT, blockStack.myLocationsController);
	
	tiSet.add(ti1);
	tiSet.add(ti2);
	
	// assign house bol number and voyage
	beginTransaction;
	foreach ti1 in tiSet do
		ti1.setPropertyValue(CM_TrackedItem::houseBillOfLading.name, BOL1);
		ti1.setMyVoyage(voyage, app.myPassport);
	endforeach;
	commitTransaction;
	
	self.assertEqualMsg(voyage.allTisByHouseBol.size, 4, "Test 2 - Voyage has incorrect number of House BOL TIs");
	
	// edi text - one master BOL (which JMT ignores) and 1 house BOl (but 2 house BOL segments with the same BOL number)
	ediText := 
'&lt;DocumentMetaData xmlns="urn:wco:datamodel:WCO:DM:1"&gt;
  &lt;WCODataModelVersion&gt;3.2&lt;/WCODataModelVersion&gt;
  &lt;WCODocumentName&gt;RES&lt;/WCODocumentName&gt;
  &lt;CountryCode&gt;NZ&lt;/CountryCode&gt;
  &lt;AgencyAssignedCustomizedDocumentName&gt;RESICR&lt;/AgencyAssignedCustomizedDocumentName&gt;
  &lt;AgencyAssignedCustomizedDocumentVersion&gt;V1.0&lt;/AgencyAssignedCustomizedDocumentVersion&gt;
  &lt;CommunicationMetaData&gt;
  
    &lt;Recipient&gt;
      &lt;ID&gt;40513451K&lt;/ID&gt;
      &lt;RoleCode&gt;' &amp; ROLE_CODE_GC &amp; '&lt;/RoleCode&gt;
    &lt;/Recipient&gt;
  &lt;/CommunicationMetaData&gt;
  &lt;Response xmlns="urn:wco:datamodel:WCO:ResponseModel:1"&gt;
    &lt;IssueDateTime formatCode="204"&gt;20200120091629&lt;/IssueDateTime&gt;
    &lt;FunctionalReferenceID&gt;20414&lt;/FunctionalReferenceID&gt;
    &lt;FunctionCode&gt;24&lt;/FunctionCode&gt;
    &lt;AdditionalDocument&gt;
      &lt;CategoryCode&gt;BAC&lt;/CategoryCode&gt;
      &lt;ImageBinaryObject mimeCode="application/pdf" uri="idd_E41D6A50-4381-4388-B61B-445801BE6537" filename="PDF7-49861192-2020-01-20-0901194016.pdf"&gt;Attached&lt;/ImageBinaryObject&gt;
    &lt;/AdditionalDocument&gt;
    &lt;OverallDeclaration&gt;
    
      &lt;Declaration&gt;
        &lt;ID&gt;49861192&lt;/ID&gt;
        &lt;AcceptanceDateTime formatCode="204"&gt;20200120091629&lt;/AcceptanceDateTime&gt;
        &lt;FunctionalReferenceID&gt;468&lt;/FunctionalReferenceID&gt;
        &lt;VersionID&gt;1&lt;/VersionID&gt;
        &lt;Submitter&gt;
        
          &lt;Name&gt;Maersk A S&lt;/Name&gt;
        &lt;/Submitter&gt;
        &lt;BorderTransportMeans&gt;
          &lt;Name&gt;' &amp; VESSEL &amp; '&lt;/Name&gt;
          &lt;ID&gt;9297852&lt;/ID&gt;
          &lt;TypeCode&gt;1&lt;/TypeCode&gt;
          &lt;ArrivalDateTime formatCode="102"&gt;20200122&lt;/ArrivalDateTime&gt;
          &lt;FirstArrivalLocationID&gt;NZTRG&lt;/FirstArrivalLocationID&gt;
          &lt;JourneyID&gt;' &amp; VOYAGE &amp; '&lt;/JourneyID&gt;
        &lt;/BorderTransportMeans&gt;
        &lt;Consignment&gt;
          &lt;GoodsStatusCode StatusType="CLEARANCE"&gt;IDR&lt;/GoodsStatusCode&gt;
          &lt;GoodsStatusCode StatusType="MOVEMENT"&gt;DTA&lt;/GoodsStatusCode&gt;
          &lt;SequenceNumeric&gt;181&lt;/SequenceNumeric&gt;
          &lt;AdditionalInformation&gt;
            &lt;StatementCode&gt;1C&lt;/StatementCode&gt;
            &lt;StatementTypeCode&gt;MTT&lt;/StatementTypeCode&gt;
          &lt;/AdditionalInformation&gt;
          &lt;Consignee&gt;
          
            &lt;Name&gt;ROHLIG NEW ZEALAND LTD&lt;/Name&gt;
          &lt;/Consignee&gt;
          &lt;ConsignmentItem&gt;
            &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
            &lt;GoodsMeasure&gt;
            
              &lt;GrossMassMeasure unitCode="KGM"&gt;1953.3&lt;/GrossMassMeasure&gt;
            &lt;/GoodsMeasure&gt;
            &lt;Packaging&gt;
              &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
              &lt;QuantityQuantity&gt;79&lt;/QuantityQuantity&gt;
              &lt;TypeCode&gt;PK&lt;/TypeCode&gt;
            &lt;/Packaging&gt;
          &lt;/ConsignmentItem&gt;
          &lt;ConsignmentItem&gt;
            &lt;SequenceNumeric&gt;2&lt;/SequenceNumeric&gt;
