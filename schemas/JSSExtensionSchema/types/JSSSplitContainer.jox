    <JadeMethod name="jssMouseUp" id="81b1f120-a90f-4813-9fe3-b69081977603">
        <updating/>
        <source>jssMouseUp(wndw: Window input; button: Integer; shift: Integer; x: Real; y: Real) updating, protected;
// --------------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad1
//
// Purpose:		Called by the splitter bar when the user mouse action is complete.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	// Calculate and set the new ratio, and resize the child controls
	
	if isSplitHorizontal then
		self.leftToRightRatio := (self.myHorizontalSplitter.top / self.clientHeight * 100).Integer;
	else
		self.leftToRightRatio := (self.myVerticalSplitter.left / self.clientWidth * 100).Integer;
	endif;
	
	self.resizeChildrenAndSplitter(false);

	// Invoke any form logic required after the move
	
	self.splitterMove(self);

	inheritMethod(wndw, button, shift, x, y);
end;</source>
        <access>protected</access>
        <Parameter name="wndw" type="Window" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="leftToRightRatio" id="fac644ae-772c-4605-aa79-d19fe2a3395c">
        <methodInvocation>mapping</methodInvocation>
        <source>leftToRightRatio(set: Boolean; _value: Integer io) mapping, protected;
// --------------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if set then
		if _value &lt; 0 or _value &gt; 100 then
			_value	:=	50;
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="repositionAfterResize" id="bb76a471-1275-4f62-859a-186e7f8922bd">
        <updating/>
        <source>repositionAfterResize() updating;
// --------------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	newLeft		: Real;
	newTop		: Real;
	newWidth	: Real;
	newHeight	: Real;
	
begin
	//inheritMethod();

	newLeft		:=	self.left;
	newTop		:=	self.top;
	newWidth	:=	self.width;
	newHeight	:=	self.height;

	if self.isLockRight then
		newLeft	:=	(parent.width - newWidth - self.distanceFromRight).max(0);
	endif;
	
	if self.isLockBottom then
		newTop	:=	(parent.height - newHeight - self.distanceFromBottom).max(0);
	endif;
	
	if self.isStretchWidth then
		newWidth	:=	(parent.width - newLeft - self.distanceFromRight).max(0);
	endif;
	
	if self.isStretchHeight then
		newHeight	:=	(parent.height - newTop - self.distanceFromBottom).max(0);
	endif;
	
	if newLeft &lt;&gt; self.left
	or newTop &lt;&gt; self.top
	or newWidth &lt;&gt; self.width
	or newHeight &lt;&gt; self.height
	then
		self.move(newLeft, newTop, newWidth, newHeight);
		self.jssResizeContents();
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="resizeChildren" id="0486344f-187b-4743-915e-d654db0206b0">
        <source>resizeChildren(pParent:Window) protected;
// --------------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad1
//
// Purpose:     Resizes the receiver's child controls, typically after the
//				receiver itself has been resized.
//
// Parameters:  pParent - The receiver's parent window.
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	controlIndex	: Integer;
	theControl		: Control;
	
begin
	foreach controlIndex in 1 to self.form.controlCount() do
		theControl	:=	self.form.controls(controlIndex);
		
		if theControl.parent = pParent then
			theControl.jssResizeContents();
		endif;
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="pParent" type="Window"/>
    </JadeMethod>
    <JadeMethod name="resizeChildrenAndSplitter" id="976ec285-e3aa-4141-b0b2-ccaa1919e43a">
        <updating/>
        <source>resizeChildrenAndSplitter(pIsFormResize:Boolean) updating, protected;
// --------------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad1
//
// Purpose:		Positions and sizes the left and right controls, and the vertical
//				splitter on the control.
//
// Parameters:	pIsFormResize - True if the parent form is being resized.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	separation	: Integer;
	leftSize	: Real;
	rightSize	: Real;

begin
	self.resizeSplitterGetNewSizes(pIsFormResize, leftSize, rightSize, separation);
	
	if self.isSplitHorizontal then
	 	// Handle horizontal split

		if self.myLeftControl &lt;&gt; null then
			self.myLeftControl.move(0, 0, self.clientWidth, leftSize);
			self.myLeftControl.jssResizeContents();
			
			if self.myLeftControl.isKindOf(Frame) then
				self.resizeChildren(self.myLeftControl);
			endif;
		endif;

		if self.myRightControl &lt;&gt; null then
			self.myRightControl.move(0, leftSize + separation, self.clientWidth, rightSize);
			self.myRightControl.jssResizeContents();
			
			if self.myRightControl.isKindOf(Frame) then
				self.resizeChildren(self.myRightControl);
			endif;
		endif;

		if self.myHorizontalSplitter &lt;&gt; null then
			self.myHorizontalSplitter.move(0, leftSize, self.clientWidth, self.myHorizontalSplitter.height);
			self.myHorizontalSplitter.zOrder(1);
		endif;
	else
		// Handle vertical split

		if self.myLeftControl &lt;&gt; null then
			self.myLeftControl.move(0, 0, leftSize, self.clientHeight);
			self.myLeftControl.jssResizeContents();
			
			if self.myLeftControl.isKindOf(Frame) then
				self.resizeChildren(self.myLeftControl);
			endif;
		endif;

		if self.myRightControl &lt;&gt; null then
			self.myRightControl.move(	leftSize + separation,
										0,
										rightSize,
										self.clientHeight);

			self.myRightControl.jssResizeContents();
			
			if self.myRightControl.isKindOf(Frame) then
				self.resizeChildren(self.myRightControl);
			endif;
		endif;

		if self.myVerticalSplitter &lt;&gt; null then
			self.myVerticalSplitter.move(leftSize, 0, self.myVerticalSplitter.width, self.clientHeight);
			self.myVerticalSplitter.zOrder(1);
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pIsFormResize" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="resizeContents" id="e66faae6-5649-4831-bc5c-cc09e5fe5b2f">
        <updating/>
        <source>resizeContents() updating;
// --------------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.resizeChildrenAndSplitter(true);
end;</source>
    </JadeMethod>
    <JadeMethod name="resizeSplitterGetNewSizes" id="14f69014-b250-44f3-bfd1-ce77005476da">
        <updating/>
        <source>resizeSplitterGetNewSizes(	pFromResize : Boolean;
							pLeftSize: Real output;
							pRightSize : Real output;
							pSeparation : Integer output) updating, protected;
// --------------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad1
//
// Purpose:		Positions and sizes the left and right controls, and the vertical
//				splitter on the control.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	MIN_SIZE	: Integer = 20;
	
vars
	ratio				: Decimal[4,2];
	leftControlSize		: Real;
	rightControlSize	: Real;
	clientSize			: Real;

begin
	ratio	:=	self.leftToRightRatio / 100;
	
	if self.isSplitHorizontal then
	 	// Handle horizontal split

		if self.myHorizontalSplitter = null or (not self.myHorizontalSplitter.visible) then
			pSeparation	:=	0;
		else
			pSeparation	:=	self.myHorizontalSplitter.height.Integer;
		endif;
		
		clientSize 			:= self.clientHeight;
		
		if self.myLeftControl &lt;&gt; null then
			leftControlSize		:= self.myLeftControl.height;
		else
			// possibly need to do some calculations here
			leftControlSize		:= 0;
		endif;

		if self.myRightControl &lt;&gt; null then
			rightControlSize	:= self.myRightControl.height;
		else
			rightControlSize	:= 0;
		endif;
	else
		if self.myVerticalSplitter = null or (not self.myVerticalSplitter.visible) then
			pSeparation	:=	0;
		else
			pSeparation	:=	self.myVerticalSplitter.width.Integer;
		endif;

		clientSize := self.clientWidth;

		if self.myLeftControl &lt;&gt; null then
			leftControlSize		:= self.myLeftControl.width;
		else
			// possibly need to do some calculations here
			leftControlSize		:= 0;
		endif;

		if self.myRightControl &lt;&gt; null then
			rightControlSize	:= self.myRightControl.width;
		else
			rightControlSize	:= 0;
		endif;
	endif;

	// Calculate new sizes for left and right controls;
	
	if pFromResize and self.splitType = self.SPLITTYPE_LOCKLEFT then
		if self.pinnedPosition &lt;&gt; 0 then
			// Always attempt to reset control to pinned size
			leftControlSize		:=	self.pinnedPosition;
			self.pinnedPosition	:=	0;
		endif;
		
		if leftControlSize + MIN_SIZE &gt; clientSize then
			if self.pinnedPosition = 0 then
				self.pinnedPosition	:=	leftControlSize;
			endif;
			
			pLeftSize	:=	(clientSize - MIN_SIZE) - (pSeparation div 2);
		else
			pLeftSize	:=	leftControlSize;
		endif;
		
		pRightSize	:=	clientSize - pLeftSize - pSeparation;

	elseif pFromResize and self.splitType = self.SPLITTYPE_LOCKRIGHT then
		if self.pinnedPosition &lt;&gt; 0 then
			// Always attempt to reset control to pinned size
			rightControlSize	:=	self.pinnedPosition;
			self.pinnedPosition	:=	0;
		endif;
		
		if rightControlSize + MIN_SIZE &gt; clientSize then
			if self.pinnedPosition = 0 then
				self.pinnedPosition := rightControlSize;
			endif;
			
			pRightSize	:=	(clientSize - MIN_SIZE) - (pSeparation div 2);
		else
			pRightSize	:=	rightControlSize;
		endif;
		
		pLeftSize	:=	clientSize - pRightSize - pSeparation;

	else
		pLeftSize	:=	(clientSize * ratio) - (pSeparation div 2);
		pRightSize	:=	clientSize - pLeftSize - pSeparation;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pFromResize" type="Boolean"/>
        <Parameter name="pLeftSize" type="Real" usage="output"/>
        <Parameter name="pRightSize" type="Real" usage="output"/>
        <Parameter name="pSeparation" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="setDistanceFromBottom" id="5a7cc22a-e521-4af1-867b-4dca5eee7706">
        <updating/>
        <source>setDistanceFromBottom(pValue:Real) updating;
// --------------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.distanceFromBottom &lt;&gt; pValue then 
		self.distanceFromBottom	:=	pValue;
	endif;
end;</source>
        <Parameter name="pValue" type="Real"/>
    </JadeMethod>
    <JadeMethod name="setDistanceFromRight" id="1f510c2a-ab53-4f77-9ec9-31ca0e2e82ec">
        <updating/>
        <source>setDistanceFromRight(pValue:Real) updating;
// --------------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.distanceFromRight &lt;&gt; pValue then
		self.distanceFromRight	:=	pValue;
	endif;
end;</source>
        <Parameter name="pValue" type="Real"/>
    </JadeMethod>
    <JadeMethod name="setLeftToRightRatio" id="6339014d-2f7f-4871-84ea-dae6e0006be0">
        <updating/>
        <source>setLeftToRightRatio(pValue:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad1
//
// Purpose:		Update the ratio (in percent) that the left control uses of the parent
//				control width.
//
// Parameters:	pValue - The percent of the left-to-right placement.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pValue &lt;&gt; self.leftToRightRatio then
		self.leftToRightRatio	:=	pValue;
		self.resizeChildrenAndSplitter(false);
	endif;
end;</source>
        <Parameter name="pValue" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setupChildControls" id="57aaf238-5167-419f-aa7c-4f5d13621b29">
        <updating/>
        <source>setupChildControls() updating;
// --------------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad1
//
// Purpose:		Setup the left and right child controls the children of the receiver,
//				and setup the starting ratio to reflect the painted ratios of the
//				visible child controls.
//
//				Note: The container control only supports two child controls.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theControl		: Control;
	controlIndex	: Integer;
	totalSize		: Real;
	errorMessage	: String;

begin
	// First delete any existing splitter bars
	if self.myVerticalSplitter &lt;&gt; null then
		delete self.myVerticalSplitter;
	endif;

	if self.myHorizontalSplitter &lt;&gt; null then
		delete self.myHorizontalSplitter;
	endif;

	// Forget existing controls
	self.myLeftControl	:=	null;
	self.myRightControl	:=	null;

	// Look through the controls of the form for children of self
	foreach controlIndex in 1 to self.form.controlCount do
		theControl := self.form.controls(controlIndex);
		
		if theControl.isKindOf(ScrollBar) or
		   theControl.isKindOf(JSSVerticalSplitter) or
		   theControl.isKindOf(JSSHorizontalSplitter) then
		   	continue;
		endif;

		if (not theControl.isKindOf(ScrollBar)) then		// ignore JASTablePlus scroll bars
			if theControl.parent = self then
				if self.myLeftControl = null then
		    		self.myLeftControl := theControl;
		    	else
		    		if self.myRightControl = null then
			    		if (not self.isSplitHorizontal)
			    		and (theControl.left &gt; self.myLeftControl.left)
			    		or self.isSplitHorizontal
			    		and (theControl.top &gt; myLeftControl.top)
			    		then
			    			self.myRightControl	:=	theControl;
			    		else
			    			self.myRightControl	:=	self.myLeftControl;
			    			self.myLeftControl	:=	theControl;
			    		endif;
					else
						errorMessage	:=	self.class().name &amp; '::' &amp; method.name &amp;
											"  Error&gt;&gt; you can only have 2 child controls.";
						app.msgBox(errorMessage, $JSSError, MsgBox_OK_Only);
					endif;
				endif;
			endif;
	 	endif;
	endforeach;

	if self.myRightControl = null then
		//JASFormException.raise_(6, "JASSplitContainer must have 2 child controls");
		// write self.class().name &amp; '::' &amp; method.name &amp; '  Error&gt;&gt; you must have 2 child controls';
		// return added to avoid null object ref if cloning at run time (RJS 7Feb01)
		return;
	endif;

	if self.myLeftControl.visible and self.myRightControl.visible then
		// Setup the ratios of the children based on their current widths/heights if not
		//  defined in Painter
	 	if self.leftToRightRatio = 0 then
	 		if self.isSplitHorizontal then
	 			totalSize				:=	self.myLeftControl.height + self.myRightControl.height;
				self.leftToRightRatio	:=	(self.myLeftControl.height / totalSize * 100).Integer;
 			else
				totalSize				:=	self.myLeftControl.width + self.myRightControl.width;
				self.leftToRightRatio	:=	(self.myLeftControl.width / totalSize * 100).Integer;
			endif;
 		endif;
 	else
 		if self.myLeftControl.visible then
 			self.leftToRightRatio	:=	100;
 		else
			self.leftToRightRatio	:=	0;
		endif;
	endif;
	
	// Following was moved from windowCreated to allow for control to be cloned at runtime (RJS 7Feb01).
	if (self.myLeftControl &lt;&gt; null)
	and self.myLeftControl.visible
	and (self.myRightControl &lt;&gt; null)
	and self.myRightControl.visible
	then
		self.initializeSplitter();
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="showLeftControl" id="95988ab7-08b9-4b59-9e3a-c3b6fa49c867">
        <updating/>
        <source>showLeftControl(pRatio:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad1
//
// Purpose:     Make visible the reciever's left-hand control and spliter bar.
//
// Parameters:  pRatio - The ratio (in percent) that the left control uses of
//					the parent control's width.
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	if self.isSplitHorizontal then
		self.myHorizontalSplitter.visible	:=	true;
	else
		self.myVerticalSplitter.visible		:=	true;
	endif;

	self.myLeftControl.visible	:=	true;

	self.setLeftToRightRatio(pRatio);
end;</source>
        <Parameter name="pRatio" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showRightControl" id="0f3ecc03-050d-452c-bff6-4bdaee037252">
        <updating/>
        <source>showRightControl(pRatio:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad1
//
// Purpose:     Make visible the reciever's right-hand control and spliter bar.
//
// Parameters:  pRatio - The ratio (in percent) that the right control uses of
//					the parent control's width.
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	if self.isSplitHorizontal then
		self.myHorizontalSplitter.visible	:=	true;
	else
		self.myVerticalSplitter.visible		:=	true;
	endif;

	self.myRightControl.visible	:=	true;
	self.setLeftToRightRatio(100 - pRatio);
end;</source>
        <Parameter name="pRatio" type="Integer"/>
    </JadeMethod>
    <ExternalMethod name="splitterMove" id="3d781d09-4109-4ec1-a4df-8690c5df4dae">
        <updating/>
        <entrypoint>CallControlEvent</entrypoint>
        <library name="jadpmap"/>
        <source>splitterMove(pSplitContainer:JSSSplitContainer input) is CallControlEvent in jadpmap updating;</source>
        <Parameter name="pSplitContainer" type="JSSSplitContainer" usage="input"/>
    </ExternalMethod>
    <JadeMethod name="windowCreated" id="b10a3dd3-cfca-4c04-b358-431d78fb27f7">
        <updating/>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating;
// --------------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(cntrl, persistCntrl);

	if self.isInPainter then
		self.borderStyle	:=	Window.BorderStyle_Single;
	else	
		self.borderStyle	:=	Window.BorderStyle_None;
		self.setupChildControls();
		self.resizeChildrenAndSplitter(false);
	endif;

	self.transparent	:=	false;
	self.backColor		:=	Window.Color_3DFace;

	if self.isLockRight or self.isStretchWidth then
 		self.distanceFromRight := persistCntrl.parent.width - persistCntrl.width - persistCntrl.left;
 	endif;

	if self.isLockBottom or self.isStretchHeight then
		self.distanceFromBottom := persistCntrl.parent.height - persistCntrl.height - persistCntrl.top;
	endif;
end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
