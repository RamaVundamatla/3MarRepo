    <JadeMethod name="xPAR31367StatusBarStepB1" id="0e7fd0bb-300b-45c6-acde-d1ee28932c21">
        <updating/>
        <source>xPAR31367StatusBarStepB1() updating;

/*

Purpose:		Create the cargo on the voyage and check that the status bar is correct

Date			Who		Reason
23/03/2013		cnwmh5	Initial creation

*/

constants

	ContainerPartialId					: String = 'UT31367';

vars

	port								: CM_Port;
	cargo								: CM_TrackedItem;
	locnDefnVoyage 						: CM_ROROLocnDefnVoyage;
	slotDefn 							: CM_ROROSlotDefn;
	slotLC 								: CM_ROROSlotController;
	cargoType							: CM_CargoType;
	layout								: CM_DeckItemLayout;
	locnGCDefnVoyage					: CM_ROROGCDefnVoyage;
	tempTI								: CM_TrackedItem;
	location							: CM_ROROLocnDefn;
	
	newPointsArray						: DecimalArray;
	tiArray								: CM_TIArray;
	
	locn								: String;
	isoTypeStr							: String;
	
begin

	app.writeLog("STEP B1", LogINFO);
	app.writeLog("Creating containers on ship.  Please wait...", LogINFO);
	
	port := app.myRoot.allPorts["AUSYD"];
	
	// setup some containers
	self.opts.purge;
	self.opts.addAssoc("CENum", "123");
	
	// Discharge 20'
	self.locationArray.clear();
	self.locationArray.add("D4069");
	self.locationArray.add("D4074");
	self.locationArray.add("D4070");
	self.locationArray.add("D4075");
	self.locationArray.add("D4082");
	self.locationArray.add("D4088");
	self.locationArray.add("D4083");
	self.locationArray.add("D4087");
	self.locationArray.add("D4198");
	self.locationArray.add("D4199");
	self.locationArray.add("D4065");
	self.locationArray.add("D4066");
	
	foreach locn in self.locationArray do
	
		locnDefnVoyage := self.myDeck.allROROLocnDefnByCode[locn].CM_ROROLocnDefnVoyage;
		self.assertNotEqual(locnDefnVoyage, null);
		
		foreach slotDefn in locnDefnVoyage.allROROSlotDefnByOrdinal discreteLock do
			slotLC := slotDefn.CM_ROROSlotDefnVoyage.mySlotController;
			if not slotLC.mySlotDefn.isAvailable then
				continue;
			endif;
			self.cargoCountId := self.cargoCountId + 1;
			cargo := self.addContainerAtLocnDisch(ContainerPartialId &amp; self.cargoCountId.padLeadingWith("0", 4), "U20G", "GENL", TI_IMEX_STATUS_REMAINONBOARD, slotLC, port, self.myVoyage);
			self.assertNotNull(cargo);
			self.deleteStops(cargo);
		endforeach;
	
	endforeach;
	
	// Discharge 40'
	self.locationArray.clear();
	self.locationArray.add("D4076");
	self.locationArray.add("D4077");
	self.locationArray.add("D4078");
	self.locationArray.add("D4086");
	self.locationArray.add("D4085");
	self.locationArray.add("D4084");
	self.locationArray.add("D4040");
	self.locationArray.add("D4064");
	
	foreach locn in self.locationArray do
	
		locnDefnVoyage := self.myDeck.allROROLocnDefnByCode[locn].CM_ROROLocnDefnVoyage;
		self.assertNotEqual(locnDefnVoyage, null);
		
		foreach slotDefn in locnDefnVoyage.allROROSlotDefnByOrdinal discreteLock do
			slotLC := slotDefn.CM_ROROSlotDefnVoyage.mySlotController;
			if not slotLC.mySlotDefn.isAvailable then
				continue;
			endif;
			self.cargoCountId := self.cargoCountId + 1;
			cargo := self.addContainerAtLocnDisch(ContainerPartialId &amp; self.cargoCountId.padLeadingWith("0", 4), "U40G", "GENL", TI_IMEX_STATUS_REMAINONBOARD, slotLC, port, self.myVoyage);
			self.assertNotNull(cargo);
			self.deleteStops(cargo);
		endforeach;
	
	endforeach;
	
	// Discharge GC area
	cargoType := self.getCargoType("CANNONBALL");
	self.assertNotNull(cargoType);
	
	//self.myVoyage.myROROStructure.createQuickCargoGC(null, cargoType, 155.0, -9.50, self.myDeck, 15); 
	self.createQuickCargoGC(self.myVoyage.myROROStructure, locnGCDefnVoyage, cargoType, 155.0, -9.50, self.myDeck, 15); 	// 27/08/2015 cnwmh5
	self.assertNoTrxErrorsOrWarnings();
	
	locnGCDefnVoyage := self.myDeck.allROROGCDefnByCode.first.CM_ROROGCDefnVoyage;
	self.assertNotNull(locnGCDefnVoyage);
	layout := locnGCDefnVoyage.myLayout;
	create newPointsArray transient;
	newPointsArray.add(156.00);
	newPointsArray.add(-9.50);
	newPointsArray.add(165.00);
	newPointsArray.add(-9.50);
	newPointsArray.add(165.00);
	newPointsArray.add(-1.50);
	newPointsArray.add(156.00);
	newPointsArray.add(-1.50);
	newPointsArray.add(156.00);
	newPointsArray.add(-9.50);
	beginTransaction;
	layout.setPointsPolygonCMs(newPointsArray);
	commitTransaction;
	
	location := null;
	
	// OOTL - Non Rotated
	//self.myVoyage.myROROStructure.createQuickCargoOOTL(null, false, 113.00, -9.50, self.myDeck, 5); 	
	self.createQuickCargoOOTL(self.myVoyage.myROROStructure, location, false, 113.00, -9.50, self.myDeck, 5); 	
	self.assertNoTrxErrorsOrWarnings();
	//self.myVoyage.myROROStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(self.myVoyage.myROROStructure, location, false, 119.50, -9.50, self.myDeck, 5); 	
	self.assertNoTrxErrorsOrWarnings();
	//self.myVoyage.myROROStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(self.myVoyage.myROROStructure, location, false, 113.00, -6.20, self.myDeck, 5); 	
	self.assertNoTrxErrorsOrWarnings();
	//self.myVoyage.myROROStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(self.myVoyage.myROROStructure, location, false, 119.50, -6.20, self.myDeck, 5); 	
	self.assertNoTrxErrorsOrWarnings();
	
	//self.myVoyage.myROROStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(self.myVoyage.myROROStructure, location, true, 128.00, -12.50, self.myDeck, 5); 	
	self.assertNoTrxErrorsOrWarnings();
	//self.myVoyage.myROROStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(self.myVoyage.myROROStructure, location, true, 128.00, -9.40, self.myDeck, 5); 	
	self.assertNoTrxErrorsOrWarnings();
	//self.myVoyage.myROROStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(self.myVoyage.myROROStructure, location, true, 128.00, -6.40, self.myDeck, 5); 	
	self.assertNoTrxErrorsOrWarnings();
	
	// OOTL - Rotated
	//self.myVoyage.myROROStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(self.myVoyage.myROROStructure, location, false, 113.00, 10.50, self.myDeck, 1); 	
	self.assertNoTrxErrorsOrWarnings();
	//self.myVoyage.myROROStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(self.myVoyage.myROROStructure, location, false, 113.00, 3.50, self.myDeck, 1); 	
	self.assertNoTrxErrorsOrWarnings();
	//self.myVoyage.myROROStructure.createQuickCargoOOTL(
