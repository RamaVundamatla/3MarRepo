    <JadeMethod name="tAutoRolloverBulkReleases" id="a2ac5d34-4c75-4823-ae35-95776a6a6e72">
        <source>tAutoRolloverBulkReleases();
// cnwndl1
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 December 2010	cnwndl1	Initial creation	Par 26650 and then 26983

*/

vars

	term : CM_Terminal;
	bulkRelease : CM_BulkRelease;
	today : TimeStamp;
	yesterday : TimeStamp;
	thirtyDaysOld : TimeStamp;
	tomorrow : TimeStamp;
	testNo : String;

begin

	tomorrow.setDate(today.date + 1 );
	yesterday.setDate(today.date - 1 );
	thirtyDaysOld.setDate(today.date - 30 );
	term := self.getTerminal;
	
	// create bulk release
	self.tReleaseWithAssignedCargo();
	
	// find it.
	testNo := "Pre-test";
	bulkRelease := term.getBulkReleaseFromCode("UTRRRoad");
	self.assertTrueMsg(bulkRelease &lt;&gt; null, "Active Bulk release not found!" &amp; "( test " &amp; testNo &amp; " )");
	self.assertTrueMsg(bulkRelease.status = BR_ACTIVE, "Bulk release status not Active!" &amp; "( test " &amp; testNo &amp; " )");
	
	// set the estimated date required to 30 days ago.
	testNo := "1";
	beginTransaction;
	bulkRelease.setEstDate( thirtyDaysOld );
	commitTransaction;
	self.assertTrueMsg(bulkRelease.dateEstimatedRequired = thirtyDaysOld, "Active Bulk release 'dateEstimatedRequired' not 30 days ago!" &amp; "( test " &amp; testNo &amp; " )" );
	self.assertTrueMsg(bulkRelease.status = BR_ACTIVE, "Bulk release status not Active!" &amp; "( test " &amp; testNo &amp; " )");
	
	// Call the updating trx used by the BGP
	app.myTrxUA.trxRelReqEstDateRollover(term, app.myPassport);
	// date should have been updated
	self.assertTrueMsg(bulkRelease.dateEstimatedRequired.Date = today.Date, "Active Bulk release 'dateEstimatedRequired' not updated!" &amp; "( test " &amp; testNo &amp; " )");

	//-----------------------------------------------------
	// Ok so try a pending one.
	testNo := "2";
	beginTransaction;
	bulkRelease.setEstDate( thirtyDaysOld );
	bulkRelease.setPropertyValue("status", BR_PENDING );
	commitTransaction;
	self.assertTrueMsg(bulkRelease.dateEstimatedRequired = thirtyDaysOld, "Pending Bulk release 'dateEstimatedRequired' not 30 days ago!" &amp; "( test " &amp; testNo &amp; " )");
	self.assertTrueMsg(bulkRelease.status = BR_PENDING, "Bulk release status not Pending!" &amp; "( test " &amp; testNo &amp; " )");
	
	// Call the updating trx used by the BGP
	app.myTrxUA.trxRelReqEstDateRollover(term, app.myPassport);
	// date should have been updated
	self.assertTrueMsg(bulkRelease.dateEstimatedRequired.Date = today.Date, "Pending Bulk release 'dateEstimatedRequired' not updated!" &amp; "( test " &amp; testNo &amp; " )");

	//-----------------------------------------------------
	// set the estimated date required to yesterday.
	testNo := "3";
	beginTransaction;
	bulkRelease.setEstDate( yesterday );
	bulkRelease.setPropertyValue("status", BR_ACTIVE );
	commitTransaction;
	self.assertTrueMsg(bulkRelease.dateEstimatedRequired = yesterday, "Active Bulk release 'dateEstimatedRequired' not yesterday!" &amp; "( test " &amp; testNo &amp; " )");
	self.assertTrueMsg(bulkRelease.status = BR_ACTIVE, "Bulk release status not Active!" &amp; "( test " &amp; testNo &amp; " )");
	
	// Call the updating trx used by the BGP
	app.myTrxUA.trxRelReqEstDateRollover(term, app.myPassport);
	// date should have been updated
	self.assertTrueMsg(bulkRelease.dateEstimatedRequired.Date = today.Date, "Active Bulk release 'dateEstimatedRequired' not updated!" &amp; "( test " &amp; testNo &amp; " )");

	//-----------------------------------------------------
	// Ok so try a pending one.
	testNo := "4";
	beginTransaction;
	bulkRelease.setEstDate( yesterday );
	bulkRelease.setPropertyValue("status", BR_PENDING );
	commitTransaction;
	self.assertTrueMsg(bulkRelease.dateEstimatedRequired = yesterday, "Pending Bulk release 'dateEstimatedRequired' not yesterday!" &amp; "( test " &amp; testNo &amp; " )");
	self.assertTrueMsg(bulkRelease.status = BR_PENDING, "Bulk release status not Pending!" &amp; "( test " &amp; testNo &amp; " )");
	
	// Call the updating trx used by the BGP
	app.myTrxUA.trxRelReqEstDateRollover(term, app.myPassport);
	// date should have been updated
	self.assertTrueMsg(bulkRelease.dateEstimatedRequired.Date = today.Date, "Pending Bulk release 'dateEstimatedRequired' not updated!" &amp; "( test " &amp; testNo &amp; " )");

	//-----------------------------------------------------
	// set the estimated date required to tomorrow.
	testNo := "5";
	beginTransaction;
	bulkRelease.setEstDate( tomorrow );
	bulkRelease.setPropertyValue("status", BR_ACTIVE );
	commitTransaction;
	self.assertTrueMsg(bulkRelease.dateEstimatedRequired = tomorrow, "Active Bulk release 'dateEstimatedRequired' not tomorrow!" &amp; "( test " &amp; testNo &amp; " )");
	self.assertTrueMsg(bulkRelease.status = BR_ACTIVE, "Bulk release status not Active!" &amp; "( test " &amp; testNo &amp; " )");
	
	// Call the updating trx used by the BGP
	app.myTrxUA.trxRelReqEstDateRollover(term, app.myPassport);
	// date should NOT have been updated
	self.assertTrueMsg(bulkRelease.dateEstimatedRequired.Date = tomorrow.Date, "Future dated Active Bulk release 'dateEstimatedRequired' was updated!" &amp; "( test " &amp; testNo &amp; " )");

	//-----------------------------------------------------
	// Ok so try a pending one.
	testNo := "6";
	beginTransaction;
	bulkRelease.setEstDate( tomorrow );
	bulkRelease.setPropertyValue("status", BR_PENDING );
	commitTransaction;
	self.assertTrueMsg(bulkRelease.dateEstimatedRequired = tomorrow, "Pending Bulk release 'dateEstimatedRequired' not tomorrow!" &amp; "( test " &amp; testNo &amp; " )");
	self.assertTrueMsg(bulkRelease.status = BR_PENDING, "Bulk release status not Pending!" &amp; "( test " &amp; testNo &amp; " )");
	
	// Call the updating trx used by the BGP
	app.myTrxUA.trxRelReqEstDateRollover(term, app.myPassport);
	// date should have been updated
	self.assertTrueMsg(bulkRelease.dateEstimatedRequired.Date = tomorrow.Date, "Future dated Pending Bulk release 'dateEstimatedRequired' was updated!" &amp; "( test " &amp; testNo &amp; " )");

	//-----------------------------------------------------
	// Ok so make sure no effect on a complete one.
	testNo := "7";
	beginTransaction;
	bulkRelease.setEstDate( yesterday );
	bulkRelease.setPropertyValue("status", BR_COMPLETE );
	commitTransaction;
	self.assertTrueMsg(bulkRelease.dateEstimatedRequired = yesterday, "Complete Bulk release 'dateEstimatedRequired' not yesterday!" &amp; "( test " &amp; testNo &amp; " )");
	self.assertTrueMsg(bulkRelease.status = BR_COMPLETE, "Bulk release status not Complete!" &amp; "( test " &amp; testNo &amp; " )");
	
	// Call the updating trx used by the BGP
	app.myTrxUA.trxRelReqEstDateRollover(term, app.myPassport);
	// date should NOT be updated for completed releases
	self.assertTrueMsg(bulkRelease.dateEstimatedRequired.Date = yesterday.Date, "Complete Bulk release 'dateEstimatedRequired' should NOT be updated!" &amp; "( test " &amp; testNo &amp; " )");

	// Set everything back to its original state...
	beginTransaction;
	bulkRelease.setEstDate( null );
	bulkRelease.setPropertyValue("status", BR_ACTIVE );
	commitTransaction;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckNumOfWLEFailedLoad" id="62412406-c46d-4c47-9979-6f1a00537db0">
        <source>tCheckNumOfWLEFailedLoad();
/*

Purpose:		This UT tests the number of WLE created for Any ID Ay Amount release request
				As we load cargo to the truck for any id any amount, it creates a WLE and attach the cargo to it, then move the cargo to the truck
				However, if the move failed, the WLE left hanging in the system.
				We want to make sure the WLE gets deleted if the move has failed.

Parameters:			

Return Value:		

Date		Who		Reason
30/01/2025	navkc1 JIRA Bug MTN-12256: MTN - Truck Loader Any Amt Any Id WLE Issue

*/

constants
	TerminalAreaID 		= "UT12256TA";
	VehicleID 			= "TRUCK12256";
	CargoID				= "12256-";
	ReleaseRequestID 	= "REL12256";
	NumOfCargoToCreate	= 3;
	StopsID				= 888;
	CargoTypID			= "CGT12256";
vars
	bs						: CM_BlockStack;
	operator 				: CM_Operator;
	firstTiToLoad,
	secondTiToLoad,
	lastTiToLoad,
	ti						: CM_TrackedItem;
	bulkRelease				: CM_BulkRelease;
	vehicle					: CM_Vehicle;
	vvr						: CM_VehicleVisitRecord;
	allTis					: CM_TISet;
	tiString				: String;
	idx						: Integer;
	cargoType				: CM_CargoType;
	stopCheckArray,
	stopProcessArray,
	stopsSetArray			: IntegerArray;
	pxyStopsTableTemplate	: CM_StopTableTemplate;
	pxyStopTable,
	realStop				: CM_StopsTable;
	terminal				: CM_Terminal;
	job						: CM_Job;
	wle 					: CM_WorkListEntry;
	reserveSelection		: CM_ReserveSelection;
begin
	
	create stopCheckArray transient;
	create pxyStopsTableTemplate transient;
	create pxyStopTable transient;
	create stopsSetArray transient;
	create stopProcessArray transient;
	// Create TI
	create allTis transient;
	
	// Clear data 
	self.deleteReleaseRequest(ReleaseRequestID);
	self.deleteVehicle(VehicleID);
	self.deleteTerminalArea(TerminalAreaID);
	self.deleteStopsTable(StopsID);
	
	// Get Terminal
	terminal := self.getMyTerminal();
	
	// Create a cargo type
	self.opts.purge();
	self.opts.addAssoc("AllowDuplicateId", true);
	self.opts.addAssoc("Description", CargoTypID  &amp; " Desc");

	cargoType := self.addCargoType(CargoTypID, false);
	self.assertTrueMsg(cargoType &lt;&gt; null, "Failed to get cargo type");
	
	// Get Operator
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	// Create Stops Table
	stopCheckArray.add(StopPreventTruckLoad);
	
	pxyStopsTableTemplate.setProxy(stopCheckArray, stopsSetArray, stopProcessArray, null, false, false, false, false, false, false,true, true);
	pxyStopsTableTemplate.setPropertyValue("myStopTable", pxyStopTable);
	pxyStopsTableTemplate.setPropertyValue("myTerminal", terminal);
	pxyStopTable.setProxy(false, "UTTL", "UT PREVENT TRUCK LOAD", "UTTL", 0, StopsID, null, false, true, app.myRoot, null, null, null);
	app.myTrxCA.trxCreateStopsTable(pxyStopTable, realStop, app.myPassport);
	self.assertTrueMsg(realStop &lt;&gt; null, "Failed to create stop");	
	
	// Create Block Stack Terminal Area
	bs := self.addBlockStack(TerminalAreaID, 200, null);
	self.assertTrueMsg(bs &lt;&gt; null, "Failed to create block stack");
	
	
	
	foreach idx in 1 to NumOfCargoToCreate do
		tiString := CargoID &amp; idx.String;
		ti := self.addCargoAtLocation(tiString, cargoType, operator, bs.allLocationsControllers.first());
		self.assertTrueMsg(ti &lt;&gt; null, "Failed to create cargo " &amp; tiString);
		allTis.add(ti);
		
		if idx = 1 then
			firstTiToLoad := ti;
		elseif idx = 2 then
			secondTiToLoad := ti;
		endif;
	endforeach;
	
	lastTiToLoad := ti;
	// Set stop to the last TI created
	self.addStop(ti, realStop);
	
	// Create a release request
	self.opts.purge();
	self.opts.addAssoc("TotalRequested", 20);
	self.opts.addAssoc("AnyAmtAnyIdAllowedAmount", 10);
	bulkRelease := self.addReleaseByTypeRequest(ReleaseRequestID, BR_TYPE_ROAD, cargoType.id, null);
	self.assertTrueMsg(bulkRelease &lt;&gt; null, "Failed to create " &amp; ReleaseRequestID &amp; " bulk release in set up");
	
	// Bring in a truck for gating out, using the 'release by id' with 'any id any amount' wle
	self.opts.purge();
	self.opts.addAssoc("ReleaseRequest", bulkRelease);
	self.opts.addAssoc("AnyId", true);
	self.opts.addAssoc("AnyAmt", true);
	vvr := self.gateOutGC(VehicleID, "", "UTDRIVER", null, self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString()), null);
	
	vehicle := self.getVehicle( VehicleID );
	self.assertTrueMsg(vvr &lt;&gt; null, "Failed to create VVR in set up");
	job := vvr.getMyJob;
	self.assertTrueMsg(vvr &lt;&gt; null, "Failed to find Job in set up");
	
	// Make sure we have the WLE created correctly
	wle := job.workListEntries.getFirstUnactionedWLE();
	self.assertTrueMsg(wle &lt;&gt; null, "Failed to find 1st WLE");
	self.assertTrueMsg(wle.isAnyAmount, "WLE is NOT 'Any Id Any Amout' wle");
	
	// Now we get the first TI and load it to the truck
	self.opts.purge();
	self.opts.addAssoc("quantity", 1.Integer);
	self.doSimulateWebTruckLoad( vehicle, wle, firstTiToLoad, false );
	
	// Now we get the second TI and load it to the truck
	self.opts.purge();
	self.opts.addAssoc("quantity", 1.Integer);
	self.doSimulateWebTruckLoad( vehicle, null, secondTiToLoad, false );
	
	// Check that we should have 
	self.assertTrueMsg(job.workListEntries.size() = 2, "We should have 2 actioned WLEs at this stage");
	
	// Now we get the last TI and load it to the truck, it should fail due to the stop preventing truck load
	self.opts.purge();
	self.opts.addAssoc("quantity", 1.Integer);
	self.doSimulateWebTruckLoad( vehicle, null, lastTiToLoad, false );
	
	// Check that we still have 2 WLEs
	self.assertTrueMsg(job.workListEntries.size() = 2, "We should have 2 actioned WLEs at this stage");
	// Check the last TI is not loaded to the truck
	self.assertTrueMsg(not lastTiToLoad.isOnTruck(), "Last TI should not be on the truck");
	// Check the last TI doesnt linked to the release request
	self.assertTrueMsg(lastTiToLoad.allBulkReleasesAssigned.isEmpty(), "Last TI should not be linked to the release request");
	// Road exit
	self.roadExit(vvr);
	
epilog
	
	foreach ti in allTis do
		self.deleteTrackedItem(ti, true);
	endforeach;

	delete allTis;
	delete stopCheckArray;
	delete pxyStopsTableTemplate;
	delete pxyStopTable;
	delete stopsSetArray;
	delete stopProcessArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="tConsigneeExtValidation" id="dfbc74ea-d20c-48c5-8dc5-149f5e165520">
        <source>tConsigneeExtValidation();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
07 November 2025	navpw1	Initial creation JIRA: MTN-36370

*/

constants
	REF : String = "36370";
	BLOCKSTACK	: String	= 'UTPW1';
	ConsignId1	: String = "UTPW1";
	ConsignId2	: String = "UTPW2";
	
	
vars
	originalConsigneeConfig : Integer;
	originalConsignorConfig : Integer;
	blockStack				: CM_BlockStack;
	terminal				: CM_Terminal;
	terminalUTHelper		: UT_HelperAdmTerm;
	consignee1 		: CM_ConsigneeConsignor;
	consignee2 		: CM_ConsigneeConsignor;
	operator : CM_Operator;
	
begin
	terminal := self.getTerminal;
	originalConsigneeConfig := terminal.getConfig(RelReqConsigneeValidate).Integer;
	originalConsignorConfig := terminal.getConfig(RelReqConsignorValidate).Integer;
	
	create terminalUTHelper transient;
	terminalUTHelper.setActiveProfile;
	terminalUTHelper.currentMethodBeingRun := UT_Release::tConsigneeExtValidation;
	
	//**********
	// CLEANUP
	//**********
	self.deleteTerminalArea(BLOCKSTACK);
	self.deleteConsigneeConsignor(ConsignId1);
	self.deleteConsigneeConsignor(ConsignId2);
	
	
	//***************************
	// Setup
	//***************************
	//Create BlockStack
	blockStack := self.addBlockStack(BLOCKSTACK, 10, null);
	self.assertNotNullMsg(blockStack, "Global Setup - blockStack");
	
	// create the consignees
	consignee1 := self.addConsigneeConsignor(ConsignId1, ConsignId1, true, true, false);
	self.assertNotNull(consignee1);
	consignee2 := self.addConsigneeConsignor(ConsignId2, ConsignId2, true, true, false);
	self.assertNotNull(consignee2);
	
	operator := self.getOperator("UTOP");
	
	//Run Test 1
	
	self.zConsigneeValidationMTN33613(terminalUTHelper, terminal, operator, consignee1, consignee2, blockStack); //ToDo Add machine moving cargo like in vehicle app
	
	//End Test 1
	
	
	//Run Test 2
	
	self.zConsigneeValidationMTN35801(terminalUTHelper, terminal, operator, consignee1, consignee2, blockStack);
	
	//End Test 2
	
	
	//Run Test 3
	
	self.zConsigneeValidationMTN36101(terminalUTHelper, terminal, operator, consignee1, consignee2, blockStack);
	
	//End Test 3
	
	
	
	//**********
	// CLEANUP
	//**********
	//self.deleteTerminalArea(BLOCKSTACK);
	self.deleteConsigneeConsignor(ConsignId1);
	self.deleteConsigneeConsignor(ConsignId2);
	
epilog
	delete terminalUTHelper;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tConsigneeValidation" id="ab755e9c-582e-46e6-abcd-5d04a08abcf2">
        <source>tConsigneeValidation();
/*

Purpose:			Tests new consignee validation for items MTN-34494 &amp; MTN-34950

Parameters:			

Return Value:		

Date				Who		Reason
17 June 2025		jlizm1	Initial creation MTN 34950 Add config to set if consignee must match release
07 November 2025	navpw1	JIRA: MTN-36370 - Added some more explanation
*/
constants
	REL_ID			: String = "UTZR250617";
	TIID1			: String = "ZJMU2506171";
	TIID2			: String = "ZJMU2506172";
	TIID3			: String = "ZJMU2506173";
	BSID			: String = "UTZBS1";
	ConsignId1		: String = "UTCE1";
	ConsignId2		: String = "UTCE2";
	RAIL_AREA_ID 	: String = "ZRA001";
	
vars
	originalConsigneeConfig : Integer;
	originalConsignorConfig : Integer;
	release			: CM_BulkRelease;
	operator 		: CM_Operator;
	consignee1 		: CM_ConsigneeConsignor;
	consignee2 		: CM_ConsigneeConsignor;
	blockStack 		: CM_BlockStack;
	ti1, ti2, ti3 	: CM_Container;
	wle, wle1, wle2, wle3 : CM_WorkListEntry;
	iter 			: Iterator;
	contCargoType 	: CM_CargoType;
	cmifObjects 	: ObjectArray;
	intFaceBP 		: CMIF_BuildPriority;
	cmifRequest 	: CMIF_Request;
	railIORake 		: CM_RailJSInOutRake;
	obj 			: Object;
	railArea 		: CM_Rail;
	railLine 		: CM_RailLine;
	resDet			: CM_ReserveDetail;
	request			: CM_Request;
	moveController	: CMIF_MoveController;
	
begin
	originalConsigneeConfig := self.getTerminalConfig(RelReqConsigneeValidate).Integer;
	originalConsignorConfig := self.getTerminalConfig(RelReqConsignorValidate).Integer;
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	contCargoType := self.getCargoType("CONT");
	
	//**********
	// CLEANUP
	//**********
	self.cleanUpRail(null, null, null, RAIL_AREA_ID); 
	self.deleteContainer(TIID1);
	self.deleteContainer(TIID2);
	self.deleteContainer(TIID3);
	self.deleteTerminalArea(BSID);
	self.deleteReleaseRequest(REL_ID);
	self.deleteConsigneeConsignor(ConsignId1);
	self.deleteConsigneeConsignor(ConsignId2);
	
	//***************************
	// Setup
	//***************************
	
	// create yard location
	blockStack := self.addBlockStack(BSID, 100, null);
	self.assertTrueMsg(blockStack &lt;&gt; null, "Failed to set up block stack");
	
	// create the consignees
	consignee1 := self.addConsigneeConsignor(ConsignId1, ConsignId1, true, true, false);
	self.assertNotNull(consignee1);
	consignee2 := self.addConsigneeConsignor(ConsignId2, ConsignId2, true, true, false);
	self.assertNotNull(consignee2);
	
	// create cargo
	ti1 := self.addContainerAtLocation(TIID1, operator, "2200", "MT", TI_IMEX_STATUS_IMPORT, blockStack);
	self.assertTrueMsg(ti1 &lt;&gt; null, "Failed to create container 1");
	ti2 := self.addContainerAtLocation(TIID2, operator, "2200", "MT", TI_IMEX_STATUS_IMPORT, blockStack);
	self.assertTrueMsg(ti2 &lt;&gt; null, "Failed to create container 2");
	ti3 := self.addContainerAtLocation(TIID3, operator, "2200", "MT", TI_IMEX_STATUS_IMPORT, blockStack);
	self.assertTrueMsg(ti3 &lt;&gt; null, "Failed to create container 3");
	
	// Create Release Request
	self.opts.purge();
	self.opts.addAssoc(UT_OPTS_Number, 3.Integer);
	self.opts.addAssoc(UT_OPTS_ISOType, "2200");
	self.opts.addAssoc(UTTI_Consignee, ConsignId1);
	self.opts.addAssoc(UTTI_Consignor, ConsignId1);
	//self.opts.addAssoc( "Voyage", voyage );
	release := self.addReleaseByTypeRequestOpts(REL_ID, BR_TYPE_RAIL, contCargoType.id);
	self.assertTrueMsg(release &lt;&gt; null, "Failed to set up Rail Release");
	
	//Create Rail area
	railArea :=	self.addRailArea(RAIL_AREA_ID, 4, 5);
	self.assertTrueMsg(railArea &lt;&gt; null,"Rail Area not created. ");
	
	railLine :=	railArea.allRailLinesByIndex[1];
	self.assertTrueMsg(railLine &lt;&gt; null,"Rail line not found. ");
	
	foreach obj in railArea.allRailJSInOut discreteLock do
		railIORake := obj.CM_RailJSInOutRake;
		if railIORake.getIoType() = Rail_JSIO_Type_Out then
			break;
		endif;
		railIORake := null;
	endforeach;
	self.assertTrueMsg(railIORake &lt;&gt; null, "Failed to set up Rail Rake");
	
	// Assign release request  to rail area
	create cmifObjects transient;
	create intFaceBP transient;
	cmifObjects.add(intFaceBP);
	intFaceBP.mode := 1;
	release.allReserveDetails.copy(intFaceBP.allReservesToProcess);
	release.setInterfaceBP(intFaceBP, railIORake);
	cmifRequest := intFaceBP.allCMIFRequests.first;
	self.assertNotNull(cmifRequest);
	cmifRequest.quantityTxt := 3;
	self.ignoreTrxWarnings(true);
	app.myTrxUA.trxUpdateAssignOutwardRail(cmifObjects, railIORake, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	foreach obj in cmifObjects do
		intFaceBP := obj.CMIF_BuildPriority;
		delete intFaceBP.myProxyRailJob;
		intFaceBP.allCMIFRequests.purge;
		delete intFaceBP;
	endforeach;
	cmifObjects.purge;
	delete cmifObjects;
	
	resDet := release.allReserveDetails.first();
	self.assertNotNullMsg(resDet, "Reserve Detail");
	request := resDet.allDeliveryRequests.first();
	self.assertEqualMsg(request.allWorkListEntries.size, 3, "unexpected number of wles");
	
	iter := request.allWorkListEntries.createIterator;
	while iter.next(wle) do
		if wle1 = null then
			wle1 := wle;
		elseif wle2 = null then
			wle2 := wle;
		else
			wle3 := wle;
		endif;
	endwhile;
	
	self.assertNotNullMsg(wle1, "wle1");
	self.assertNotNullMsg(wle2, "wle2");
	self.assertNotNullMsg(wle3, "wle3");

	self.ignoreTrxWarnings(true);
	
	//ti1 = no consignee no consignor
	
	//ti2 = matches consignee no consignor
	self.opts.purge;
	self.opts.addAssoc(UTTI_Consignee, ConsignId1);
	self.expectTrxError(ERR_CONTAINER_NO);
	self.updateTI(ti2);
	
	//ti3 = different consignee no consignor
	self.opts.purge;
	self.opts.addAssoc(UTTI_Consignee, ConsignId2);
	self.updateTI(ti3);
	
	self.ignoreTrxWarnings(false);
	
	self.setTerminalConfig(RelReqConsigneeValidate, ConsigneeStrictMatch);
	self.setTerminalConfig(RelReqConsignorValidate, ConsignorStrictMatch);
	
	create moveController transient;
	moveController.setMyWorkListEntry(wle1);
	moveController.setMyTrackedItem(ti1);
	
	self.ignoreTrxWarnings(true);
	app.myTrxUA.trxUpdateWLEAssignTI(moveController, app.myPassport);
	self.assertTrueMsg(app.myPassport.allErrors.includesErrorCode(TI_TestReqConsignee), "Should have raised an error " &amp; TI_TestReqConsignee.String );
	
	delete moveController;
	create moveController transient;
	moveController.setMyWorkListEntry(wle1);
	moveController.setMyTrackedItem(ti3);
	self.ignoreTrxWarnings(true);
	app.myTrxUA.trxUpdateWLEAssignTI(moveController, app.myPassport);
	self.assertTrueMsg(app.myPassport.allErrors.includesErrorCode(TI_TestReqConsignee), "Should have raised an error " &amp; TI_TestReqConsignee.String );
	
	delete moveController;
	create moveController transient;
	moveController.setMyWorkListEntry(wle1);
	moveController.setMyTrackedItem(ti2);
	self.ignoreTrxWarnings(true);
	app.myTrxUA.trxUpdateWLEAssignTI(moveController, app.myPassport);
	self.assertFalseMsg(app.myPassport.allErrors.includesErrorCode(TI_TestReqConsignee), "Should not have raised an error " &amp; TI_TestReqConsignee.String );
	self.assertTrueMsg(app.myPassport.allErrors.includesErrorCode(TI_TestReqConsignor), "Should have raised an error " &amp; TI_TestReqConsignor.String );
	
	self.ignoreTrxWarnings(true);
	//ti2 = matches consignee matches consignor
	self.opts.purge;
	self.opts.addAssoc(UTTI_Consignor, ConsignId1);
	self.expectTrxError(ERR_CONTAINER_NO);
	self.updateTI(ti2);

	delete moveController;
	create moveController transient;
	moveController.setMyWorkListEntry(wle1);
	moveController.setMyTrackedItem(ti2);
	self.ignoreTrxWarnings(true);
	app.myTrxUA.trxUpdateWLEAssignTI(moveController, app.myPassport);
	self.assertTrueMsg(app.myPassport.allErrors.isEmpty, "Should not have raised an error: " &amp; app.myPassport.getErrorsAsString() );
	
	
	self.setTerminalConfig(RelReqConsignorValidate, ConsignorEmptyOk);
	//ti3 = matches consignee no consignor
	self.opts.purge;
	self.opts.addAssoc(UTTI_Consignee, ConsignId1);
	self.expectTrxError(ERR_CONTAINER_NO);
	self.updateTI(ti3);
	
	delete moveController;
	create moveController transient;
	moveController.setMyWorkListEntry(wle2);
	moveController.setMyTrackedItem(ti3);
	self.ignoreTrxWarnings(true);
	app.myTrxUA.trxUpdateWLEAssignTI(moveController, app.myPassport);
	self.assertTrueMsg(app.myPassport.allErrors.isEmpty, "Should not have raised an error: " &amp; app.myPassport.getErrorsAsString() );
	
	self.setTerminalConfig(RelReqConsigneeValidate, ConsigneeNoMatch);
	//ti1 = different consignee no consignor
	self.opts.purge;
	self.opts.addAssoc(UTTI_Consignee, ConsignId2);
	self.expectTrxError(ERR_CONTAINER_NO);
	self.updateTI(ti1);
	
	delete moveController;
	create moveController transient;
	moveController.setMyWorkListEntry(wle3);
	moveController.setMyTrackedItem(ti1);
	self.ignoreTrxWarnings(true);
	app.myTrxUA.trxUpdateWLEAssignTI(moveController, app.myPassport);
	self.assertTrueMsg(app.myPassport.allErrors.isEmpty, "Should not have raised an error: " &amp; app.myPassport.getErrorsAsString() );
	
	
	//**********
	// CLEANUP
	//**********
	self.cleanUpRail(null, null, null, RAIL_AREA_ID); 
	self.deleteContainer(TIID1);
	self.deleteContainer(TIID2);
	self.deleteContainer(TIID3);
	self.deleteTerminalArea(BSID);
	self.deleteReleaseRequest(REL_ID);
	self.deleteConsigneeConsignor(ConsignId1);
	self.deleteConsigneeConsignor(ConsignId2);
	
	
epilog
	self.setTerminalConfig(RelReqConsigneeValidate, originalConsigneeConfig);
	self.setTerminalConfig(RelReqConsignorValidate, originalConsignorConfig);
	
	delete iter;
	if cmifObjects &lt;&gt; null then
		foreach obj in cmifObjects do
			intFaceBP := obj.CMIF_BuildPriority;
			delete intFaceBP.myProxyRailJob;
			intFaceBP.allCMIFRequests.purge;
			delete intFaceBP;
		endforeach;
		cmifObjects.purge;
	endif;
	delete cmifObjects;
	delete moveController;
	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tHiLoCubeMatchISOGroup" id="9fbda4e5-5d13-422e-a1f7-6d287364987c">
        <source>tHiLoCubeMatchISOGroup();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 August 2022	navkc1	Initial creation - Bug 54325: PNL-Can be Hi or Low Cube (in Releases) ignored when releasing a container to our packing Sub-Terminal

*/

/*

This is created for testing "Can be Hi or Low Cube" option in Release requests. System should match the substitute ISO Group configured when the option is checked.
If the ISO Group matches the Substitute ISO Group, the tracked item can be substituted and released.

*/

constants
	ReleaseReqCode 	: String = "UTHILOCUBEISOGRP";
	RelISOType		: String = "2100";
	RelISOTypeGroup	: String = "GEN2";
	TICargoType		: String = "CONT";
	TITrackedItemID	: String = "UTISOGRP01";
	TIISOType		: String = "2010";

vars
	terminal 		: CM_Terminal;
	releaseReq		: CM_BulkRelease;
	ti				: CM_TrackedItem;
	reserverSel		: CM_ReserveSelection;
	operator		: CM_Operator;
	
begin
	// Get terminal
	terminal := self.getTerminal();
	// Get Operator
	operator := self.getOperator("UTOP");
	// Delete existing objects 
	self.deleteReleaseRequest(ReleaseReqCode);
	self.deleteContainer(TITrackedItemID);
	
	// Create TrackedItem
	ti := self.addContainer(TITrackedItemID, operator, TIISOType, "MT", TI_IMEX_STATUS_STORAGE);
	
	// Set opts for Release Requests
	self.opts.addAssoc("CanBeHiLoCube", true);
	self.opts.addAssoc("ISOType", RelISOType);
	self.opts.addAssoc("ISOGroup", RelISOTypeGroup);
	self.opts.addAssoc("Operator", operator);
	// Create release request
	releaseReq := self.addReleaseByTypeRequestOpts(ReleaseReqCode, BR_TYPE_ROAD, TI_CargoType_Container);
	
	// Get Reserver Selection	
	reserverSel := releaseReq.allReserveDetails.first().CM_ReserveSelection;
	
	// Test
	reserverSel.testCandidateTI(ti);
	// Not expected any errors
	self.assertNoTrxErrorsPassport(app.myPassport.getAllErrorsWarningsAsString());
	
	// Cleaning up any objects created
	self.deleteReleaseRequest(ReleaseReqCode);
	self.deleteContainer(TITrackedItemID);
	self.opts.purge();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tMisMatchISOGroup" id="a108033f-59aa-44e1-a458-06791ab55d01">
        <source>tMisMatchISOGroup();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 July 2021	navndl1	Initial creation	TFS 51454
//19/07/2022	navtnr20	ChangeRequest 53974: EUP - OUT - Additional Fields on Release Line Level																	
*/

constants

	ReleaseCode : String = "UTISOGRP";
	BaseTiId : String = "UTISOGRP";
	BlockStack : String = "ISOG";
	CustomerReference : String = "UTCUSTOMERREFERENCE";//19-7-2022 navtnr20 53974
	LineNumber :Integer = 123;	//19-7-2022 navtnr20 53974
	
vars

	br : CM_BulkRelease;
	oper : CM_Operator;
	selectedResDetail : CM_ReserveSelection;
	bs : CM_BlockStack;
	index : Integer;
	ti : CM_TrackedItem;
	reason : String;
	firstReasonOnly : Boolean;
	skipCriteria : IntegerArray;
	isoGroup : CM_ISOTypeGroup;
	contIsoType : CM_ISOType;
		
begin

	oper := app.myRoot.allOperators.getAtKey("260");
	self.assertTrueMsg( oper &lt;&gt; null , " Operator not found pre-test");

	self.setTerminalConfig(AllowResDetIsoMisMatch, true);
	
	foreach index in 1 to 1 do
		self.deleteContainer( BaseTiId &amp; index.String );
	endforeach;
	
	self.deleteTerminalArea(BlockStack);
	bs := self.addBlockStack(BlockStack, 100, null);
	self.assertTrueMsg( bs &lt;&gt; null , " Block Stack not found pre-test");
	
	self.deleteReleaseRequest(ReleaseCode);
	
	isoGroup := app.myRoot.allISOTypeGroups.getAtKey( "40BX" ).CM_ISOTypeGroup;
	
	self.opts.purge();
	self.opts.addAssoc("ISOType", "2200");  //Deliberate mis match
	self.opts.addAssoc("ISOGroup", "40BX"); //Deliberate mis match
	self.opts.addAssoc("Number", 2.Integer );
	self.opts.addAssoc("Operator", oper );
	self.opts.addAssoc(UTTI_CustomsReference,CustomerReference);		//19-7-2022 navtnr20 53974 
	self.opts.addAssoc(UTTI_LineNumber,LineNumber);	//19-7-2022 navtnr20 53974
	br := self.addReleaseByTypeRequestOpts(ReleaseCode, BR_TYPE_ROAD, TI_CargoType_Container);
	self.assertTrueMsg( br &lt;&gt; null , " Bulk Release not created pre-test");
	self.assertTrueMsg( br.status = BR_ACTIVE , " Bulk Release not active pre-test");
	selectedResDetail := br.allReserveDetails.first.CM_ReserveSelection;
	self.assertTrueMsg( selectedResDetail &lt;&gt; null , " Reserve Detail not created pre-test");
	
	//add 1 containers
	contIsoType := isoGroup.allISOTypes.first;
	foreach index in 1 to 1 do
		ti := self.addContainer( BaseTiId &amp; index.String, oper, contIsoType.code, "MT", TI_IMEX_STATUS_STORAGE );
		self.assertTrueMsg( ti &lt;&gt; null , " Cargo '" &amp; BaseTiId &amp; index.String &amp; "' not created pre-test");
		self.move(ti, bs);
	endforeach;

	ti := self.getTrackedItemByCargoType( BaseTiId &amp; "1", TI_CargoType_Container );

	create skipCriteria transient;
	ti.testAgainstReserveSelection( selectedResDetail, reason, firstReasonOnly, skipCriteria );
	self.assertTrueMsg( reason.trimBlanks = null , " Should match because ISO Group OK ( even-though ISO Type doesn't) and mismatch config ON");	
	self.setTerminalConfig(AllowResDetIsoMisMatch, false);
	
	ti.testAgainstReserveSelection( selectedResDetail, reason, firstReasonOnly, skipCriteria );
	self.assertTrueMsg( reason.pos("ISO Type", 1) &gt; 0 , " Should NOT match because ISO Type doesn't match and mis match config OFF");	
	
	//If we got this far all is good get rid of the data.
	foreach index in 1 to 1 do
		self.deleteContainer( BaseTiId &amp; index.String );
	endforeach;
	self.deleteTerminalArea(BlockStack);
	self.deleteReleaseRequest(ReleaseCode);

epilog

	self.setTerminalConfig(AllowResDetIsoMisMatch, false);
	delete skipCriteria;
	

end;</source>
    </JadeMethod>
    <JadeMethod name="tMtShipRelease" id="17e5876b-ebaf-4c68-8d83-05721f694bf5">
        <source>tMtShipRelease();
// cnwndl1
//09 September 2010	cnwdw1	
// Test the rules around MT release to Ship - the mts are NOT assigned to the release
//19/07/2022	navtnr20	ChangeRequest 53974: EUP - OUT - Additional Fields on Release Line Level																	
constants
	CustomerReference : String = "UTCUSTOMERREFERENCE";//19-7-2022 navtnr20 53974
	LineNumber :Integer = 123;//19-7-2022 navtnr20 53974
vars
	voyage1: CM_Voyage;
	voyage2: CM_Voyage;
	vessel: CM_Vessel; 
	releaseRequest: CM_BulkRelease;
	truck: CM_Vehicle;
	ti, ti2: CM_TrackedItem;
	ya: CM_YardAllocation;
	bs1, bs2: CM_BlockStack;
	source: CM_LocationsController;
	dischargePort: CM_Port;
	icArea: CM_YardInterchangeArea;
	autoPlanMTReleaseStrategy : Integer;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	self.deleteContainer("TEST0000001");
	self.deleteContainer("TEST0000002");
	dischargePort := app.myRoot.allPorts["NZAKL"];
	self.deleteTerminalArea(self.getProfileSetting(UT_Profile.P_BLOCKSTACK).asString);
	bs1 := addBlockStack(self.getProfileSetting(UT_Profile.P_BLOCKSTACK).asString, 100, null);
	deleteTerminalArea("UT_YIC");
	icArea 	:= self.addYardInterchangeArea ("UT_YIC", null, 0, 0);
	
	// createVoyage
	deleteVoyage("UTVOYAGE1");
	deleteVoyage("UTVOYAGE2");
	deleteVessel("UTSHIP");
	vessel := addVesselCellular("UTSHIP", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	voyage1 := addVoyageWithContainerStructur("UTVOYAGE1", "UTSHIP", self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	voyage2 := addVoyageWithContainerStructur("UTVOYAGE2", "UTSHIP", self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);

	self.setTerminalConfig(AutoPlanMTReleaseStrategy, AutoPlanMTRelStrategyTerminal);
	
	// Create the Release
	deleteReleaseRequest("UTRRShip");
	self.opts.purge;
	self.opts.addAssoc("ISOGroup", "UT20");
	self.opts.addAssoc("Voyage", voyage1);
	self.opts.addAssoc("DischargePort", dischargePort);
	self.opts.addAssoc("CreateDeliveryRequest", true);
	self.opts.addAssoc("TerminalArea", bs1);   // Make sure only get cargo from bs1
	self.opts.addAssoc(UTTI_CustomsReference,CustomerReference);		//19-7-2022 navtnr20 53974 
	self.opts.addAssoc(UTTI_LineNumber,LineNumber);	//19-7-2022 navtnr20 53974
	releaseRequest := addReleaseByTypeRequestOpts("UTRRShip", BR_TYPE_SHIP, TI_CargoType_Container);
	assertNotNull(releaseRequest);
	assertTrue(releaseRequest.requests.first.isKindOf(CM_DeliveryRequest));
	assertEqual(releaseRequest.requests.first.CM_DeliveryRequest.voyageCode, voyage1.code);

	// Test 1: Make sure we find can find a EXPORT for the voyage
	self.deleteContainer("TEST0000001");
	ti := self.addContainerAtLocnDisch("TEST0000001", "UT20", "MT", TI_IMEX_STATUS_EXPORT, bs1.myLocationsController, dischargePort, voyage1);
	source := app.sourceTisForRequestYA(self.getTerminal(), releaseRequest.requests.first);
	assertNotNullMsg(source, getYAAutoPlanMessages);
	assertEqualMsg(source.getName(), bs1.myLocationsController.getName(), getYAAutoPlanMessages);

	// Test 2: Make sure we find can find a Storage with no voyage
	self.deleteContainer("TEST0000001");
	ti := self.addContainerAtLocnDisch("TEST0000001", "UT20", "MT", TI_IMEX_STATUS_STORAGE, bs1.myLocationsController, dischargePort, null);
	source := app.sourceTisForRequestYA(self.getTerminal(), releaseRequest.requests.first);
	assertNotNullMsg(source, getYAAutoPlanMessages);
	assertEqualMsg(source.getName(), bs1.myLocationsController.getName(), getYAAutoPlanMessages);

	// Test 3: Make sure we find can find a Storage with different voyage
	self.deleteContainer("TEST0000001");
	ti := self.addContainerAtLocnDisch("TEST0000001", "UT20", "MT", TI_IMEX_STATUS_STORAGE, bs1.myLocationsController, dischargePort, voyage2);
	source := app.sourceTisForRequestYA(self.getTerminal(), releaseRequest.requests.first);
	assertNotNullMsg(source, getYAAutoPlanMessages);
	assertEqualMsg(source.getName(), bs1.myLocationsController.getName(), getYAAutoPlanMessages);
	
	// Test 4: Make sure we do not find EXPORT with different voyage
	self.deleteContainer("TEST0000001");
	ti := self.addContainerAtLocnDisch("TEST0000001", "UT20", "MT", TI_IMEX_STATUS_EXPORT, bs1.myLocationsController, dischargePort, voyage2);
	source := app.sourceTisForRequestYA(self.getTerminal(), releaseRequest.requests.first);
	assertNullMsg(source, getYAAutoPlanMessages);

	// Test 4: Make sure we do not find EXPORT with null voyage
	self.deleteContainer("TEST0000001");
	ti := self.addContainerAtLocnDisch("TEST0000001", "UT20", "MT", TI_IMEX_STATUS_EXPORT, bs1.myLocationsController, dischargePort, null);
	source := app.sourceTisForRequestYA(self.getTerminal(), releaseRequest.requests.first);
	assertNullMsg(source, getYAAutoPlanMessages);
	
	// Test 5: Make sure we don't find cargo in interchange areas
	// Create the Release
	deleteReleaseRequest("UTRRShip");
	self.opts.purge;
	self.opts.addAssoc("ISOGroup", "20BX");
	self.opts.addAssoc("Voyage", voyage1);
	self.opts.addAssoc("CreateDeliveryRequest", true);
	self.opts.addAssoc("DischargePort", dischargePort);
	//self.opts.addAssoc("TerminalArea", bs1);   // Make sure only get cargo from bs1
	releaseRequest := addReleaseByTypeRequestOpts("UTRRShip", BR_TYPE_SHIP, TI_CargoType_Container);
	assertNotNull(releaseRequest);
	assertTrue(releaseRequest.requests.first.isKindOf(CM_DeliveryRequest));
	assertEqual(releaseRequest.requests.first.CM_DeliveryRequest.voyageCode, voyage1.code);

	// Should not find ti2 as it is in a transfer area
	self.deleteContainer("TEST0000002");
	ti2 := self.addContainerAtLocnDisch("TEST0000002", "UT20", "MT", TI_IMEX_STATUS_STORAGE, icArea.getDefaultLane, dischargePort, voyage1);
	self.deleteContainer("TEST0000001");
	ti := self.addContainerAtLocnDisch("TEST0000001", "UT20", "MT", TI_IMEX_STATUS_STORAGE, bs1.myLocationsController, dischargePort, voyage1);
	source := app.sourceTisForRequestYA(self.getTerminal(), releaseRequest.requests.first);
	assertNotNull(releaseRequest);
	assertTrue(releaseRequest.requests.first.isKindOf(CM_DeliveryRequest));
	assertEqual(releaseRequest.requests.first.CM_DeliveryRequest.voyageCode, voyage1.code);


epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
end;</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;Fails&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="tRailRelease49095" id="dee6716d-69f4-4467-873c-a9d309a719e3">
        <source>tRailRelease49095();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who			Reason
20 April 2020	jlgndl1		Initial creation	TFS 49095
//19/07/2022	navtnr20	ChangeRequest 53974: EUP - OUT - Additional Fields on Release Line Level															
22 Nov 2023		navlw1		ChangeRequest 60874 [Task:60878]: MTN | Jade Upgrade - Unit Test Review
*/

constants

	RailAreaId : String = "UT_RA45";
	RailReleaseRqId : String = "UTRAIL49095";
	ContainerIdPrefix : String = "UTRA49095";
	BlockStackId : String = "UTBS";
	ConsigneeId1 : String = "UTCE2";
	TrainCode : String = "UT49095";
	Wagonnn : String = "PK11";
	WagonClassCode : String = "PK";
	ForkLift1 = "UTF1";
	QueueName = "UT_QUEUE";
	CustomerReference : String = "UTCUSTOMERREFERENCE";//19-7-2022 navtnr20 53974
	LineNumber :Integer = 123;	//19-7-2022 navtnr20 53974
	
vars

	railArea : CM_Rail;
	railIORake : CM_RailJSInOutRake;
	releaseRequest : CM_BulkRelease;
	intFaceBP : CMIF_BuildPriority;
	cmifRequest : CMIF_Request;
	obj : Object;
	bs : CM_BlockStack;
	ti : CM_TrackedItem;
	consignee : CM_ConsigneeConsignor;
	terminal : CM_Terminal;
	cmifMoveController : CMIF_MoveController;
	cmifObjects : ObjectArray;
	index : Integer;
	contId : String;
	wagonMaster : CM_WagonMaster;
	wagonId : String;
	train: CM_Train;
	wagon : CM_Wagon;
	wagonClass : CM_WagonClass;
	wagMoveControl : CMIF_WagonMoveController;
	railLine : CM_RailLine;
	allWles : CM_WLEArray;
	wleArray : CM_WLEArray;
	wagonArray : CM_WagonArray;
	wle : CM_WorkListEntry;
	railJob : CM_RailJob;
	agent : CM_RailProcessingAgent;
	wlesWithWarnings : CM_WLEArray;
	forkLift : CM_Machine;
	tas : StringArray;
	queue : CM_RadioTelemetryQueue;
	task : CM_RTQueueTask;
	allTis : CM_TIArray;
	ya : CM_YardAllocation;
	locations : CM_LCArray;
	mtReleaseStrategy : Integer;
		
begin

	// get the default stuff
	terminal := self.getTerminal();
	self.setTerminalConfig(ShowRelReqOnRailLoadList, false);
	mtReleaseStrategy := self.setTerminalConfig(AutoPlanMTReleaseStrategy, AutoPlanMTRelStrategyYA).Integer; // #60874 Task#60878
	
	self.disableAllYA(true);
	
	//clean up old data
	
	self.deleteMachine(ForkLift1);
	foreach index in 1 to 10 do
		contId := ContainerIdPrefix &amp; index.padLeadingWith('0',2);
		self.deleteContainer(contId);
	endforeach;
	foreach index in 1 to 4 do
		wagonMaster	:=	self.getRoot.allWagonMasters[Wagonnn &amp; index.padLeadingWith('0',2)];
		if wagonMaster &lt;&gt; null then
			self.deleteWagonMasterAndWagons(wagonMaster);
		endif;
	endforeach;
	self.deleteTrain(TrainCode,null);
	self.deleteRailArea(RailAreaId);
	self.deleteReleaseRequest(RailReleaseRqId);
	self.deleteTerminalArea(BlockStackId);
	self.deleteConsigneeConsignor(ConsigneeId1);
	self.deleteQueue (QueueName);
	self.deleteYA("UT");

	// create the rail transfer area
	railArea := self.addRailArea(RailAreaId, 4, 4);
	self.assertTrueMsg(railArea &lt;&gt; null, "Failed to set up Rail Area");
	railLine	:=	railArea.allRailLinesByIndex[1];
	foreach obj in railArea.allRailJSInOut discreteLock do
		railIORake := obj.CM_RailJSInOutRake;
		if railIORake.getIoType() = Rail_JSIO_Type_Out then
			break;
		endif;
		railIORake := null;
	endforeach;
	self.assertTrueMsg(railIORake &lt;&gt; null, "Failed to set up Rail Rake");
	
	// create rail release request
	self.opts.purge();
	self.opts.addAssoc("ISOType", "2200");
	self.opts.addAssoc("Number", 6.Integer);
	releaseRequest := self.addReleaseByTypeRequestOpts(RailReleaseRqId, BR_TYPE_RAIL, TI_CargoType_Container);
	self.assertTrueMsg(releaseRequest &lt;&gt; null, "Failed to set up Rail Release");
	
	bs := self.addBlockStack(BlockStackId, 10, null);
	queue := self.addQueueToTA (QueueName, BlockStackId);
	
	create locations transient;
	locations.add( bs.myLocationsController );		
	ya := self.addYA1("UT", YACriteriaType_IsTwenty,  CM_YADataBoolean.VALUE_TRUE, locations);
	
	consignee := self.addConsigneeConsignor(ConsigneeId1, ConsigneeId1, true, false, false);
	self.assertTrueMsg(consignee &lt;&gt; null, "Failed to set up Consignee");
	
	
	
	// assign to outwards rail area
	create cmifObjects transient;
	create intFaceBP transient;
	cmifObjects.add(intFaceBP);
	intFaceBP.mode := 1;
	releaseRequest.allReserveDetails.copy(intFaceBP.allReservesToProcess);
	releaseRequest.setInterfaceBP(intFaceBP, railIORake);
	cmifRequest := intFaceBP.allCMIFRequests.first;
	self.assertNotNull(cmifRequest);
	cmifRequest.quantityTxt := releaseRequest.allReserveDetails.first.totalRequested;
	app.myTrxUA.trxUpdateAssignOutwardRail(cmifObjects, railIORake, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	//collect up the wles created
	create allWles transient;
	foreach railJob in railIORake.railJobs do
		foreach wle in railJob.workListEntries do
			allWles.add( wle );
		endforeach;
	endforeach;
	
	self.opts.purge;
	self.opts.addAssoc("Consignee", consignee.code);
	self.opts.addAssoc(UTTI_CustomsReference,CustomerReference);		//19-7-2022 navtnr20 53974 
	self.opts.addAssoc(UTTI_LineNumber,LineNumber);	//19-7-2022 navtnr20 53974
	//Add cargo
	create allTis transient;
	foreach index in 1 to 10 do
		contId := ContainerIdPrefix &amp; index.padLeadingWith('0',2);
		ti := self.addContainerAtLocation(contId, null, "2200", "MT", TI_IMEX_STATUS_STORAGE, bs);
		allTis.add( ti );
	endforeach;
	
	//Add train and wagons
	train := self.addTrain(TrainCode,null);
	wagonClass := app.myRoot.allWagonClasses.getAtKey(WagonClassCode);
	create wagonArray transient;
	foreach index in 1 to 4 do
		wagon := self.addWagonInRailArea(Wagonnn &amp; index.padLeadingWith('0',2), WagonClassCode, railArea, train);
		wagonArray.add( wagon );
	endforeach;
	
	//confirm wagons in
	create wagMoveControl transient;
	wagMoveControl.myTargetRailLine	:=	railLine;
	wagMoveControl.targetPosition := 1;
	wagonArray.copy(wagMoveControl.allWagons);
	wagMoveControl.doAutoPlanOfCargo :=	false;
	self.ignoreTrxWarnings(true);
	
	app.myTrxUA.trxUpdateWagonConfirmToRail( wagMoveControl, app.myPassport );
	self.assertTrueMsg( app.myPassport.trxCompletedOK(), "Train/Wagon confirm to Rail failed." );
	
	//Assign the wles to the wagons 
	create agent transient;
	agent.initialise( self.getTerminal );
	agent.doAssignReleasesToWagons( allWles, wagonArray, false, true );
	
	//queue the first two to make director tasks
	create wleArray transient;
	create wlesWithWarnings transient;
	wleArray.add( allWles[1] );
	wleArray.add( allWles[2] );
	app.myTrxUA.trxUpdateWLEsDoMove( wleArray, wlesWithWarnings, QUEUE_MODE, false, null, app.myPassport );
	
	task := allWles[1].allRTQueueEntries.first.allTasks.first;
	
	//add forklift
	create tas transient;
	tas.add( ti.myPrimaryActualLocation.getFullId );
	tas.add( railArea.getLocationsController.getFullId );
	forkLift := self.addForkLift( ForkLift1, 93, tas, task.myEntry.myQueue.id );
	
	self.machineLogon (forkLift);
	self.machineAssignToQueue( forkLift, task.myEntry.myQueue );
	
	//select cargo and move the first queued items with the machine
	foreach index in 1 to 2 do
		task := allWles[index].allRTQueueEntries.first.allTasks.first;
		ti := allTis[index];
		// do accept director task
		self.machineAcceptSpecifiedTask( forkLift, task.myEntry );
		// Do Pick up
		self.machineDirector( forkLift, ti );
		// do the setdown
		self.machineSetdown( forkLift, ti, ti.myPrimaryQueuedLocation.getFullId );
	endforeach;
	
	//Queue the next two
	wleArray.clear();
	wlesWithWarnings.clear();
	wleArray.add( allWles[3] );
	wleArray.add( allWles[4] );
	app.myTrxUA.trxUpdateWLEsDoMove( wleArray, wlesWithWarnings, QUEUE_MODE, false, null, app.myPassport );
	
	//select cargo and move the first queued items with the machine
	foreach index in 3 to 4 do
		task := allWles[index].allRTQueueEntries.first.allTasks.first;
		ti := allTis[index];
		// do accept director task
		self.machineAcceptSpecifiedTask( forkLift, task.myEntry );
		// Do Pick up
		self.machineDirector( forkLift, ti );
		// do the setdown
		self.machineSetdown( forkLift, ti, ti.myPrimaryQueuedLocation.getFullId );
	endforeach;
	
	
	self.machineLogOff( forkLift );
	
	//all done, clean up
	
	self.deleteMachine(ForkLift1);
	foreach index in 1 to 10 do
		contId := ContainerIdPrefix &amp; index.padLeadingWith('0',2);
		self.deleteContainer(contId);
	endforeach;
	foreach index in 1 to 4 do
		wagonMaster	:=	self.getRoot.allWagonMasters[Wagonnn &amp; index.padLeadingWith('0',2)];
		if wagonMaster &lt;&gt; null then
			self.deleteWagonMasterAndWagons(wagonMaster);
		endif;
	endforeach;
	self.deleteTrain(TrainCode,null);
	self.deleteRailArea(RailAreaId);
	self.deleteReleaseRequest(RailReleaseRqId);
	self.deleteTerminalArea(BlockStackId);
	self.deleteConsigneeConsignor(ConsigneeId1);
	self.deleteQueue (QueueName);
	self.deleteYA("UT");

epilog

	app.isRTApp := false;
	self.setTerminalConfig(AutoPlanMTReleaseStrategy, mtReleaseStrategy); // #60874 Task#60878
	self.disableAllYA(false);
	if cmifObjects &lt;&gt; null then
		foreach obj in cmifObjects do
			intFaceBP := obj.CMIF_BuildPriority;
			
			delete intFaceBP.myProxyRailJob;
			intFaceBP.allCMIFRequests.purge;
			delete intFaceBP;
	
		endforeach;
		cmifObjects.purge;
	endif;
	delete cmifObjects;
	delete wagMoveControl;
	delete allWles;
	delete wleArray;
	delete wagonArray;
	delete agent;
	delete wlesWithWarnings;
	delete tas;
	delete allTis;
	delete locations;

end;</source>
    </JadeMethod>
    <JadeMethod name="tRailReleaseBBBulk" id="20df8103-3f91-47be-b27a-d73e6cd220bf">
        <source>tRailReleaseBBBulk();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 September 2020	jlgndl1	Initial creation	TFS 49865
//19/07/2022	navtnr20	ChangeRequest 53974: EUP - OUT - Additional Fields on Release Line Level																	
*/

constants

	RailAreaId : String = "UT_RA45";
	RailReleaseRqId1 : String = "UTRAIL49865A";
	RailReleaseRqId2 : String = "UTRAIL49865B";
	CargoIdPrefix : String = "UTRA49865";
	BlockStackId : String = "UTBS";
	ConsigneeId1 : String = "UTCE2";
	TrainCode : String = "UT49095";
	Wagonnn : String = "BX49865";
	WagonClassCode : String = "BX";
	ForkLift1 = "UTF1";
	QueueName = "UT_QUEUE";
	CustomerReference : String = "UTCUSTOMERREFERENCE";//19-7-2022 navtnr20 53974
	LineNumber :Integer = 123;//19-7-2022 navtnr20 53974
	
vars

	railArea : CM_Rail;
	railIORake : CM_RailJSInOutRake;
	releaseRequest1 : CM_BulkRelease;
	intFaceBP : CMIF_BuildPriority;
	cmifRequest : CMIF_Request;
	releaseRequest2 : CM_BulkRelease;
	obj : Object;
	bs : CM_BlockStack;
	ti : CM_TrackedItem;
	consignee : CM_ConsigneeConsignor;
	terminal : CM_Terminal;
	cmifMoveController : CMIF_MoveController;
	cmifObjects : ObjectArray;
	index : Integer;
	cargoId : String;
	wagonMaster : CM_WagonMaster;
	wagonId : String;
	train: CM_Train;
	wagon : CM_Wagon;
	wagonClass : CM_WagonClass;
	wagMoveControl : CMIF_WagonMoveController;
	railLine : CM_RailLine;
	allWles : CM_WLEArray;
	wleArray : CM_WLEArray;
	wagonArray : CM_WagonArray;
	wle : CM_WorkListEntry;
	railJob : CM_RailJob;
	agent : CM_RailProcessingAgent;
	wlesWithWarnings : CM_WLEArray;
	forkLift : CM_Machine;
	tas : StringArray;
	queue : CM_RadioTelemetryQueue;
	task : CM_RTQueueTask;
	allTis : CM_TIArray;
	ya : CM_YardAllocation;
	locations : CM_LCArray;
	bbCargoType : CM_CargoType;
	bulkCargoType : CM_CargoType;
	oper : CM_Operator;
	cargo : CM_Cargo;

begin

	// get the default stuff
	terminal := self.getTerminal();
	self.setTerminalConfig(ShowRelReqOnRailLoadList, false);
	self.disableAllYA(true);
	oper := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	bbCargoType :=  app.myRoot.getCargoTypeFromAbbrev('UTBYQ');
	self.assertTrueMsg( bbCargoType &lt;&gt; null, "Cargo Type 'UTBYQ' Not created during setup");
	bulkCargoType := app.myRoot.getCargoTypeFromAbbrev('UTBYW');
	self.assertTrueMsg( bulkCargoType &lt;&gt; null, "Cargo Type 'UTBYW' Not created during setup");
	
	//clean up old data	
	self.deleteMachine(ForkLift1);
	foreach index in 1 to 5 do
		cargoId := CargoIdPrefix &amp; index.padLeadingWith('0',2);
		self.deleteCargo( cargoId, bbCargoType );
	endforeach;
	foreach index in 6 to 10 do
		cargoId := CargoIdPrefix &amp; index.padLeadingWith('0',2);
		self.deleteCargo( cargoId, bulkCargoType );
	endforeach;
	foreach index in 1 to 4 do
		wagonMaster	:=	self.getRoot.allWagonMasters[Wagonnn &amp; index.padLeadingWith('0',2)];
		if wagonMaster &lt;&gt; null then
			self.deleteWagonMasterAndWagons(wagonMaster);
		endif;
	endforeach;
	self.deleteTrain(TrainCode,null);
	self.deleteRailArea(RailAreaId);
	self.deleteReleaseRequest(RailReleaseRqId1);
	self.deleteReleaseRequest(RailReleaseRqId2);
	self.deleteTerminalArea(BlockStackId);
	self.deleteConsigneeConsignor(ConsigneeId1);
	self.deleteQueue (QueueName);
	self.deleteYA("UTBYQ");
	self.deleteYA("UTBYW");

	
	create wleArray transient;
	
	// create the rail transfer area
	railArea := self.addRailArea(RailAreaId, 4, 4);
	self.assertTrueMsg(railArea &lt;&gt; null, "Failed to set up Rail Area");
	railLine	:=	railArea.allRailLinesByIndex[1];
	foreach obj in railArea.allRailJSInOut discreteLock do
		railIORake := obj.CM_RailJSInOutRake;
		if railIORake.getIoType() = Rail_JSIO_Type_Out then
			break;
		endif;
		railIORake := null;
	endforeach;
	self.assertTrueMsg(railIORake &lt;&gt; null, "Failed to set up Rail Rake");
	
	//Add train and wagons
	train := self.addTrain(TrainCode,null);
	wagonClass := app.myRoot.allWagonClasses.getAtKey(WagonClassCode);
	create wagonArray transient;
	foreach index in 1 to 4 do
		wagon := self.addWagonInRailArea(Wagonnn &amp; index.padLeadingWith('0',2), WagonClassCode, railArea, train);
		wagonArray.add(wagon);
	endforeach;
	
	// create rail release requests
	self.opts.purge();
	self.opts.addAssoc( "weightRequested", "10000".Decimal);
	self.opts.addAssoc( "FullRelease", true );  // otherwise it defaults to empties only
	self.opts.addAssoc( "Train", train );
	releaseRequest1 := self.addReleaseByTypeRequestOpts(RailReleaseRqId1, BR_TYPE_RAIL, bulkCargoType.id);
	self.assertTrueMsg(releaseRequest1 &lt;&gt; null, "Failed to set up Rail Release 1");
	
	self.opts.purge();
	self.opts.addAssoc( "number", "10".Integer);
	self.opts.addAssoc( "FullRelease", true );  // otherwise it defaults to empties only
	self.opts.addAssoc(UTTI_CustomsReference,CustomerReference);		//19-7-2022 navtnr20 53974 
	self.opts.addAssoc(UTTI_LineNumber,LineNumber);	//19-7-2022 navtnr20 53974
	releaseRequest2 := self.addReleaseByTypeRequestOpts(RailReleaseRqId2, BR_TYPE_RAIL, bbCargoType.id);
	self.assertTrueMsg(releaseRequest2 &lt;&gt; null, "Failed to set up Rail Release 2");
	
	//create the locations and Yard Allocations
	bs := self.addBlockStack(BlockStackId, 10, null);
	queue := self.addQueueToTA (QueueName, BlockStackId);
	
	create locations transient;
	locations.add( bs.myLocationsController );		
	ya := self.addYA1("UTBYQ", YACriteriaType_CargoType, bbCargoType, locations);
	ya := self.addYA1("UTBYW", YACriteriaType_CargoType, bulkCargoType, locations);
	
	//add a consignee
	consignee := self.addConsigneeConsignor(ConsigneeId1, ConsigneeId1, true, false, false);
	self.assertTrueMsg(consignee &lt;&gt; null, "Failed to set up Consignee");
	
	// assign first 5000 kg bulk to outwards rail area
	create cmifObjects transient;
	create intFaceBP transient;
	cmifObjects.add(intFaceBP);
	intFaceBP.mode := 1;
	releaseRequest1.allReserveDetails.copy(intFaceBP.allReservesToProcess);
	releaseRequest1.setInterfaceBP(intFaceBP, railIORake);
	cmifRequest := intFaceBP.allCMIFRequests.first;
	self.assertNotNull(cmifRequest);
	cmifRequest.weight := 5000;
	app.myTrxUA.trxUpdateAssignOutwardRail(cmifObjects, railIORake, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	foreach obj in cmifObjects do
		intFaceBP := obj.CMIF_BuildPriority;
		delete intFaceBP.myProxyRailJob;
		intFaceBP.allCMIFRequests.purge;
		delete intFaceBP;
	endforeach;
	cmifObjects.purge;
	delete cmifObjects;
	
	// assign the second 5000 kg bulk to outwards rail area
	create cmifObjects transient;
	create intFaceBP transient;
	cmifObjects.add(intFaceBP);
	intFaceBP.mode := 1;
	releaseRequest1.allReserveDetails.copy(intFaceBP.allReservesToProcess);
	releaseRequest1.setInterfaceBP(intFaceBP, railIORake);
	cmifRequest := intFaceBP.allCMIFRequests.first;
	self.assertNotNull(cmifRequest);
	cmifRequest.weight := 5000;
	app.myTrxUA.trxUpdateAssignOutwardRail(cmifObjects, railIORake, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	foreach obj in cmifObjects do
		intFaceBP := obj.CMIF_BuildPriority;
		delete intFaceBP.myProxyRailJob;
		intFaceBP.allCMIFRequests.purge;
		delete intFaceBP;
	endforeach;
	cmifObjects.purge;
	delete cmifObjects;
	
	//assign the first 5 break bulk items to outwards rail
	create cmifObjects transient;
	create intFaceBP transient;
	cmifObjects.add(intFaceBP);
	intFaceBP.mode := 1;
	releaseRequest2.allReserveDetails.copy(intFaceBP.allReservesToProcess);
	releaseRequest2.setInterfaceBP(intFaceBP, railIORake);
	cmifRequest := intFaceBP.allCMIFRequests.first;
	self.assertNotNull(cmifRequest);
	cmifRequest.quantityTxt := 5;
	app.myTrxUA.trxUpdateAssignOutwardRail(cmifObjects, railIORake, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	foreach obj in cmifObjects do
		intFaceBP := obj.CMIF_BuildPriority;
		delete intFaceBP.myProxyRailJob;
		intFaceBP.allCMIFRequests.purge;
		delete intFaceBP;
	endforeach;
	cmifObjects.purge;
	delete cmifObjects;
	
	//assign the second 5 break bulk items to outwards rail
	create cmifObjects transient;
	create intFaceBP transient;
	cmifObjects.add(intFaceBP);
	intFaceBP.mode := 1;
	releaseRequest2.allReserveDetails.copy(intFaceBP.allReservesToProcess);
	releaseRequest2.setInterfaceBP(intFaceBP, railIORake);
	cmifRequest := intFaceBP.allCMIFRequests.first;
	self.assertNotNull(cmifRequest);
	cmifRequest.quantityTxt := 5;
	app.myTrxUA.trxUpdateAssignOutwardRail(cmifObjects, railIORake, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	foreach obj in cmifObjects do
		intFaceBP := obj.CMIF_BuildPriority;
		delete intFaceBP.myProxyRailJob;
		intFaceBP.allCMIFRequests.purge;
		delete intFaceBP;
	endforeach;
	cmifObjects.purge;
	delete cmifObjects;
	
	//collect up the 4 wles created for the 2 bulk and 3 break bulk director tasks.
	create allWles transient;
	foreach railJob in railIORake.railJobs do
		foreach wle in railJob.workListEntries do
			allWles.add( wle );
		endforeach;
	endforeach;
	
	//Add cargo
	self.opts.purge;
	self.opts.addAssoc("Consignee", consignee.code);
	create allTis transient;
	foreach index in 1 to 5 do
		cargoId := CargoIdPrefix &amp; index.padLeadingWith('0',2);
		cargo := self.addCargoAtLocation(cargoId, bbCargoType, oper, bs.myLocationsController).CM_Cargo;
		self.assertTrueMsg( cargo &lt;&gt; null, cargoId &amp; " not created - setup phase : (test 13) - " &amp; app.myPassport.getErrorsAndWarningsAsString );
		beginTransaction;
		cargo.setTotalQuantity(5);
		cargo.setTotalWeightWithoutTrans(5000);
		cargo.setImExStatus(TI_IMEX_STATUS_STORAGE);
		commitTransaction;
		allTis.add( cargo );
	endforeach;
	foreach index in 6 to 10 do
		cargoId := CargoIdPrefix &amp; index.padLeadingWith('0',2);
		cargo := self.addCargoAtLocation( cargoId, bulkCargoType, oper, bs.myLocationsController).CM_Cargo;
		self.assertTrueMsg( cargo &lt;&gt; null, cargoId &amp; " not created - setup phase : " &amp; app.myPassport.getErrorsAndWarningsAsString );
		beginTransaction;
		cargo.setTotalWeightWithoutTrans(5000);
		cargo.setImExStatus(TI_IMEX_STATUS_STORAGE);
		commitTransaction;
		allTis.add( cargo );
	endforeach;

	
	//confirm wagons in
	create wagMoveControl transient;
	wagMoveControl.myTargetRailLine	:=	railLine;
	wagMoveControl.targetPosition := 1;
	wagonArray.copy(wagMoveControl.allWagons);
	wagMoveControl.doAutoPlanOfCargo :=	false;
	self.ignoreTrxWarnings(true);
	
	app.myTrxUA.trxUpdateWagonConfirmToRail( wagMoveControl, app.myPassport );
	self.assertTrueMsg( app.myPassport.trxCompletedOK(), "Train/Wagon confirm to Rail failed. - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	
	//Assign the four wles to the wagons one at a time 
	create agent transient;
	wagonArray.clear();
	wleArray.clear();
	wagonArray.add( train.allWagonsByOrderInward[1]);
	wleArray.add( allWles[1] );
	agent.initialise( self.getTerminal );
	agent.doAssignReleasesToWagons( wleArray, wagonArray, false, true );
	delete agent;
	
	create agent transient;
	wagonArray.clear();
	wleArray.clear();
	wagonArray.add( train.allWagonsByOrderInward[2]);
	wleArray.add( allWles[2] );
	agent.initialise( self.getTerminal );
	agent.doAssignReleasesToWagons( wleArray, wagonArray, false, true );
	delete agent;
	
	create agent transient;
	wagonArray.clear();
	wleArray.clear();
	wagonArray.add( train.allWagonsByOrderInward[3]);
	wleArray.add( allWles[3] );
	agent.initialise( self.getTerminal );
	agent.doAssignReleasesToWagons( wleArray, wagonArray, false, true );
	delete agent;
	
	create agent transient;
	wagonArray.clear();
	wleArray.clear();
	wagonArray.add( train.allWagonsByOrderInward[4]);
	wleArray.add( allWles[4] );
	agent.initialise( self.getTerminal );
	agent.doAssignReleasesToWagons( wleArray, wagonArray, false, true );
	delete agent;
	
	//queue the wles to make director tasks
	wleArray.clear();
	create wlesWithWarnings transient;
	wleArray.add( allWles[1] );
	wleArray.add( allWles[2] );
	wleArray.add( allWles[3] );
	wleArray.add( allWles[4] );
	app.myTrxUA.trxUpdateWLEsDoMove( wleArray, wlesWithWarnings, QUEUE_MODE, false, null, app.myPassport );
	
	task := allWles[1].allRTQueueEntries.first.allTasks.first;
	
	//add forklift
	create tas transient;
	tas.add( allTis[1].myPrimaryActualLocation.getFullId );
	if allTis[1].myPrimaryActualLocation &lt;&gt; allTis[6].myPrimaryActualLocation then
		tas.add( allTis[6].myPrimaryActualLocation.getFullId );
	endif;
	tas.add( railArea.getLocationsController.getFullId );
	forkLift := self.addForkLift( ForkLift1, 93, tas, task.myEntry.myQueue.id );
	
	self.machineLogon (forkLift);
	self.machineAssignToQueue( forkLift, task.myEntry.myQueue );
	
	//select director task and cargo and move the item with the machine	 5000 kgs bulk
	task := allWles[1].allRTQueueEntries.first.allTasks.first;
	ti := allTis[6];
	// do accept director task
	self.machineAcceptSpecifiedTask( forkLift, task.myEntry );
	// Do Pick up
	self.machineDirector( forkLift, ti );
	// do the setdown
	self.machineSetdown( forkLift, ti, task.targetLocationId );
	
	//second one 5000kgs bulk
	task := allWles[2].allRTQueueEntries.first.allTasks.first;
	ti := allTis[7];
	// do accept director task
	self.machineAcceptSpecifiedTask( forkLift, task.myEntry );
	// Do Pick up
	self.machineDirector( forkLift, ti );
	// do the setdown
	self.machineSetdown( forkLift, ti, task.targetLocationId );
	

	//first break bulk move of a quantity of 5
	task := allWles[3].allRTQueueEntries.first.allTasks.first;
	ti := allTis[1];
	// do accept director task
	self.machineAcceptSpecifiedTask( forkLift, task.myEntry );
	// Do Pick up
	self.machineDirector( forkLift, ti );
	// do the setdown
	self.machineSetdown( forkLift, ti, task.targetLocationId );
	
	//first break bulk move of a quantity of 5
	task := allWles[4].allRTQueueEntries.first.allTasks.first;
	ti := allTis[2];
	// do accept director task
	self.machineAcceptSpecifiedTask( forkLift, task.myEntry );
	// Do Pick up
	self.machineDirector( forkLift, ti );
	// do the setdown
	self.machineSetdown( forkLift, ti, task.targetLocationId );
	
	
	self.machineLogOff( forkLift );
	
	//all done, clean up
	
	self.deleteMachine(ForkLift1);
	foreach index in 1 to 5 do
		cargoId := CargoIdPrefix &amp; index.padLeadingWith('0',2);
		self.deleteCargo( cargoId, bbCargoType );
	endforeach;
	foreach index in 6 to 10 do
		cargoId := CargoIdPrefix &amp; index.padLeadingWith('0',2);
		self.deleteCargo( cargoId, bulkCargoType );
	endforeach;
	foreach index in 1 to 4 do
		wagonMaster	:=	self.getRoot.allWagonMasters[Wagonnn &amp; index.padLeadingWith('0',2)];
		if wagonMaster &lt;&gt; null then
			self.deleteWagonMasterAndWagons(wagonMaster);
		endif;
	endforeach;
	self.deleteTrain(TrainCode,null);
	self.deleteRailArea(RailAreaId);
	self.deleteReleaseRequest(RailReleaseRqId1);
	self.deleteReleaseRequest(RailReleaseRqId2);
	self.deleteTerminalArea(BlockStackId);
	self.deleteConsigneeConsignor(ConsigneeId1);
	self.deleteQueue (QueueName);
	self.deleteYA("UTBYQ");
	self.deleteYA("UTBYW");

epilog

	app.isRTApp := false;
	self.disableAllYA(false);
	if cmifObjects &lt;&gt; null then
		foreach obj in cmifObjects do
			intFaceBP := obj.CMIF_BuildPriority;
			
			delete intFaceBP.myProxyRailJob;
			intFaceBP.allCMIFRequests.purge;
			delete intFaceBP;
	
		endforeach;
		cmifObjects.purge;
	endif;
	delete cmifObjects;
	delete wagMoveControl;
	delete allWles;
	delete wleArray;
	delete wagonArray;
	delete agent;
	delete wlesWithWarnings;
	delete tas;
	delete allTis;
	delete locations;

end;</source>
    </JadeMethod>
    <JadeMethod name="tRailReleaseTIMoveToWLE1" id="8250251c-0b8b-4332-92e8-6c8bfca3263e">
        <source>tRailReleaseTIMoveToWLE1();

/*

Purpose:			Rail Release and move TI to WLE with Terminal Config ShowRelReqOnRailLoadList set to true 
					(TBA in Rail Ops when Release Request moved to rail area)

Date				Who		Reason
16/12/2011			cnwmh5	Initial creation

*/
constants

	RailAreaId			: String = "UTMCLR1";
	RailReleaseRqId		: String = "UTMHRailR01234567890123456781";
	ContainerId1		: String = "UTMH3333301";
	BlockStackId		: String = "UTMHBS1";
	ConsigneeId1		: String = "UTCE1";
	
vars

	railArea			: CM_Rail;
	railIORake 			: CM_RailJSInOutRake;
	releaseRequest		: CM_BulkRelease;
	intFaceBP			: CMIF_BuildPriority;
	cmifRequest			: CMIF_Request;
	obj					: Object;
	bs					: CM_BlockStack;
	ti					: CM_TrackedItem;
	consignee			: CM_ConsigneeConsignor;
	terminal			: CM_Terminal;
	cmifMoveController	: CMIF_MoveController;
	
	cmifObjects 		: ObjectArray;

begin
	
	// get the default stuff
	terminal := self.getTerminal();

	// create the rail transfer area
	self.deleteRailArea(RailAreaId);
	railArea := self.addRailArea(RailAreaId, 4, 4);
	self.assertNotNull(railArea);
	foreach obj in railArea.allRailJSInOut discreteLock do
		railIORake := obj.CM_RailJSInOutRake;
		if railIORake.getIoType() = Rail_JSIO_Type_Out then
			break;
		endif;
		railIORake := null;
	endforeach;
	self.assertNotNull(railIORake);
	
	// create rail release request
	self.opts.purge();
	self.opts.addAssoc("ISOType", "2200");
	self.deleteReleaseRequest(RailReleaseRqId);
	releaseRequest := self.addReleaseByTypeRequestOpts(RailReleaseRqId, BR_TYPE_RAIL, TI_CargoType_Container);
	self.assertNotNull(releaseRequest);

	// assign to outwards rail area
	create cmifObjects transient;
	create intFaceBP transient;
	cmifObjects.add(intFaceBP);
	intFaceBP.mode := 1;
	releaseRequest.allReserveDetails.copy(intFaceBP.allReservesToProcess);
	releaseRequest.setInterfaceBP(intFaceBP, railIORake);
	cmifRequest := intFaceBP.allCMIFRequests.first;
	self.assertNotNull(cmifRequest);
	cmifRequest.quantityTxt := releaseRequest.allReserveDetails.first.totalRequested;
	app.myTrxUA.trxUpdateAssignOutwardRail(cmifObjects, railIORake, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	// create terminal area to put containers in
	self.deleteTerminalArea(BlockStackId);
	bs := self.addBlockStack(BlockStackId, 10, null);
	self.assertNotNull(bs);
	
	// create the consignee
	self.deleteConsigneeConsignor(ConsigneeId1);
	consignee := self.addConsigneeConsignor(ConsigneeId1, ConsigneeId1, true, false, false);
	self.assertNotNull(consignee);	
	
	// create the containers to for the first move
	self.opts.purge;
	self.opts.addAssoc("Consignee", consignee.code);
	self.deleteContainer(ContainerId1);
	ti := self.addContainerAtLocation(ContainerId1, null, "2200", "MT", TI_IMEX_STATUS_STORAGE, bs);
	self.updateTI(ti);
	
	//  move the jobs to the WLE - with Terminal Config ShowRelReqOnRailLoadList set
	self.setTerminalConfig(ShowRelReqOnRailLoadList, true);
	
	// move first container to rail opts
	create cmifMoveController transient;
	cmifMoveController.setMyOriginatingLocation(bs.allLocationsControllers.first);
	cmifMoveController.setMyTrackedItem(ti);
	cmifMoveController.setMyWorkListEntry(railIORake.railJobs.first.CM_RailJob.workListEntries.first);
	self.assertNotNullMsg(cmifMoveController.myOriginatingLocation, "Move Controller's myOriginatingLocation");
	self.assertNotNullMsg(cmifMoveController.myTrackedItem, "Move Controller's myTrackedItem");
	self.assertNotNullMsg(cmifMoveController.myWorkListEntry, "Move Controller's myWorkListEntry");
	app.myTrxUA.trxUpdateWLEAssignTI(cmifMoveController, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqualMsg(ti.consignee, consignee.code, "Tracked Item (" &amp; ti.id &amp; ") consisngee code not equal");
	
	
	//Complete so clean up
	self.deleteRailArea(RailAreaId);
	self.deleteReleaseRequest(RailReleaseRqId);
	self.deleteTerminalArea(BlockStackId);
	self.deleteContainer(ContainerId1);
		
epilog

	delete cmifMoveController;

	if cmifObjects &lt;&gt; null then
		foreach obj in cmifObjects do
			intFaceBP := obj.CMIF_BuildPriority;
			
			delete intFaceBP.myProxyRailJob;
			intFaceBP.allCMIFRequests.purge;
			delete intFaceBP;
	
		endforeach;
		cmifObjects.purge;
	endif;
	delete cmifObjects;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tRailReleaseTIMoveToWLE2" id="72f97174-bbff-4797-9b58-5d776325614e">
        <source>tRailReleaseTIMoveToWLE2();

/*

Purpose:			Rail Release and move TI to WLE with Terminal Config ShowRelReqOnRailLoadList set to false 

Date				Who		Reason
16/12/2011			cnwmh5	Initial creation #28804

*/
constants

	RailAreaId			: String = "UTMCLR2";
	RailReleaseRqId		: String = "UTMHRailR01234567890123456782";
	ContainerId1		: String = "UTMH3333302";
	BlockStackId		: String = "UTMHBS2";
	ConsigneeId1		: String = "UTCE2";
	
vars

	railArea			: CM_Rail;
	railIORake 			: CM_RailJSInOutRake;
	releaseRequest		: CM_BulkRelease;
	intFaceBP			: CMIF_BuildPriority;
	cmifRequest			: CMIF_Request;
	obj					: Object;
	bs					: CM_BlockStack;
	ti					: CM_TrackedItem;
	consignee			: CM_ConsigneeConsignor;
	terminal			: CM_Terminal;
	cmifMoveController	: CMIF_MoveController;
	
	cmifObjects 		: ObjectArray;
	
begin
	
	// get the default stuff
	terminal := self.getTerminal();

	// create the rail transfer area
	self.deleteRailArea(RailAreaId);
	railArea := self.addRailArea(RailAreaId, 4, 4);
	self.assertNotNull(railArea);
	foreach obj in railArea.allRailJSInOut discreteLock do
		railIORake := obj.CM_RailJSInOutRake;
		if railIORake.getIoType() = Rail_JSIO_Type_Out then
			break;
		endif;
		railIORake := null;
	endforeach;
	self.assertNotNull(railIORake);
	
	// create rail release request
	self.opts.purge();
	self.opts.addAssoc("ISOType", "2200");
	self.deleteReleaseRequest(RailReleaseRqId);
	releaseRequest := self.addReleaseByTypeRequestOpts(RailReleaseRqId, BR_TYPE_RAIL, TI_CargoType_Container);
	self.assertNotNull(releaseRequest);

	// assign to outwards rail area
	create cmifObjects transient;
	create intFaceBP transient;
	cmifObjects.add(intFaceBP);
	intFaceBP.mode := 1;
	releaseRequest.allReserveDetails.copy(intFaceBP.allReservesToProcess);
	releaseRequest.setInterfaceBP(intFaceBP, railIORake);
	cmifRequest := intFaceBP.allCMIFRequests.first;
	self.assertNotNull(cmifRequest);
	cmifRequest.quantityTxt := releaseRequest.allReserveDetails.first.totalRequested;
	app.myTrxUA.trxUpdateAssignOutwardRail(cmifObjects, railIORake, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	// create terminal area to put containers in
	self.deleteTerminalArea(BlockStackId);
	bs := self.addBlockStack(BlockStackId, 10, null);
	self.assertNotNull(bs);
	
	// create the consignee
	self.deleteConsigneeConsignor(ConsigneeId1);
	consignee := self.addConsigneeConsignor(ConsigneeId1, ConsigneeId1, true, false, false);
	self.assertNotNull(consignee);	
	
	// create the containers to for the first move
	self.opts.purge;
	self.opts.addAssoc("Consignee", consignee.code);
	self.deleteContainer(ContainerId1);
	ti := self.addContainerAtLocation(ContainerId1, null, "2200", "MT", TI_IMEX_STATUS_STORAGE, bs);
	self.updateTI(ti);
	
	//  move the jobs to the WLE - with Terminal Config ShowRelReqOnRailLoadList set
	self.setTerminalConfig(ShowRelReqOnRailLoadList, false);
	
	// move first container to rail opts
	create cmifMoveController transient;
	cmifMoveController.setMyOriginatingLocation(bs.allLocationsControllers.first);
	cmifMoveController.setMyTrackedItem(ti);
	cmifMoveController.setMyWorkListEntry(railIORake.railJobs.first.CM_RailJob.workListEntries.first);
	self.assertNotNullMsg(cmifMoveController.myOriginatingLocation, "Move Controller's myOriginatingLocation");
	self.assertNotNullMsg(cmifMoveController.myTrackedItem, "Move Controller's myTrackedItem");
	self.assertNotNullMsg(cmifMoveController.myWorkListEntry, "Move Controller's myWorkListEntry");
	app.myTrxUA.trxUpdateWLEAssignTI(cmifMoveController, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqualMsg(ti.consignee, consignee.code, "Tracked Item (" &amp; ti.id &amp; ") consisngee code not equal");
	
	//Complete so clean up
	self.deleteRailArea(RailAreaId);
	self.deleteReleaseRequest(RailReleaseRqId);
	self.deleteTerminalArea(BlockStackId);
	self.deleteContainer(ContainerId1);
		
epilog

	delete cmifMoveController;

	if cmifObjects &lt;&gt; null then
		foreach obj in cmifObjects do
			intFaceBP := obj.CMIF_BuildPriority;
			
			delete intFaceBP.myProxyRailJob;
			intFaceBP.allCMIFRequests.purge;
			delete intFaceBP;
	
		endforeach;
		cmifObjects.purge;
	endif;
	delete cmifObjects;
	
end;</source>
    </JadeMethod>
