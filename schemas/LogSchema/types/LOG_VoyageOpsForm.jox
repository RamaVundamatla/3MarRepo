    <JadeMethod name="getAvailableGLBTerminals" id="cf157d9c-f2f0-4599-8935-3ec31e571c94">
        <source>getAvailableGLBTerminals() : String;

/*

Purpose:		Get the terminals available	

Parameters:			

Return Value:		


Date		Who		Reason
09 November 2009	cnwmh5	Initial creation

*/

vars
	terminal : CM_Terminal;
	terminalName 	: String;
	obj				: Object;
begin

	// Mohammad par#13527 17/4/2007
	obj := self.lstPorts.listObject;
	if obj.isKindOf(CM_Voyage) or obj.isKindOf(CM_VoyageOperator) then
		if self.myCurrentVoyage &lt;&gt; null then
			terminal := self.myCurrentVoyage.myTerminal;
			if terminal &lt;&gt; null then
				terminalName := terminal.name;
			endif;
		endif;
	endif;

	self.myAssistant.LOG_Assistant.comboBoxTerminalForGlbVoyage(self.cmbPort,self.myCurrentVoyageGlobal,self.permissionMaint, terminal); // Mohammad par#13524 20/4/2007

	return terminalName;
	
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="e40a004f-5e98-4d4b-9b96-9d0941c65c80">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
//--------------------------------------------------
// Created:	13 August 2004 By: cnwgd1
//--------------------------------------------------
vars
	xmlStr	: String;
	entRow	: EntTableRow;	
begin
	xmlStr := inheritMethod() 
	&amp; self.tblOrderData.getXmlStrForColumns(true)
	&amp; self.tblAllocatedRows.getXmlStrForColumns(true)
	&amp; self.tblSupplierDtl.getXmlStrForColumns(true)
	&amp; self.tblSSSDockets.getXmlStrForColumns(true)
	&amp; self.tblSSSEDIData.getXmlStrForColumns(true)		
	&amp; self.tblSrchResults.getXmlStrForColumns(true)			
	&amp; self.tblVoyTermDtl.getXmlStrForColumns(true);					
	
	// listbox splitter ratio
	xmlStr := xmlStr &amp; 
			global.formatAsXMLPrefix(XMLTag_Splitter &amp; ' ' &amp; self.name &amp; ' ' &amp; self.splOperations.name) &amp;
			global.formatAsXML(XMLTag_Ratio, self.splOperations.leftToRightRatio.String) &amp;
			global.formatAsXMLSuffix(XMLTag_Splitter &amp; ' ' &amp; self.name &amp; ' ' &amp; self.splOperations.name);

	// Main splitter ratio
	xmlStr := xmlStr &amp; 
			global.formatAsXMLPrefix(XMLTag_Splitter &amp; ' ' &amp; self.name &amp; ' ' &amp; self.splMain.name) &amp;
			global.formatAsXML(XMLTag_Ratio, self.splMain.leftToRightRatio.String) &amp;
			global.formatAsXMLSuffix(XMLTag_Splitter &amp; ' ' &amp; self.name &amp; ' ' &amp; self.splMain.name);			

	// Allocation splitter ratio
	xmlStr := xmlStr &amp; 
			global.formatAsXMLPrefix(XMLTag_Splitter &amp; ' ' &amp; self.name &amp; ' ' &amp; self.splAllocateRows.name) &amp;
			global.formatAsXML(XMLTag_Ratio, self.splAllocateRows.leftToRightRatio.String) &amp;
			global.formatAsXMLSuffix(XMLTag_Splitter &amp; ' ' &amp; self.name &amp; ' ' &amp; self.splAllocateRows.name);						

	return xmlStr;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleSystemNotification" id="71129604-ba3d-44e4-bf9b-ea4bc3748346">
        <updating/>
        <source>handleSystemNotification(eventType: Integer; theObject: Object; eventTag: Integer) updating;
//--------------------------------------------------
// Created:	19 January 2004 By: cnwgd1
//--------------------------------------------------
vars
	str : String;
	rowIdx : Integer;
	tmpObj : CM_Object;
	tmpSOHLocn : CM_SOHLocation;
	tmpAllocation : CM_StockOrderAllocation;
begin
	
	if CM_SOHLocation.hasInstance(theObject) then
		self.showTableDataForCurrentObject();
		self.allocateRowClearNotes();
		self.showSOHSearchResults();
		
		// PAR11719
		tmpSOHLocn := theObject.CM_SOHLocation;
		foreach tmpAllocation in tmpSOHLocn.allStockOrderAllocations do
			if CM_StockOrderLineAlloc.hasInstance(tmpAllocation) then
				tmpObj := tmpAllocation.CM_StockOrderLineAlloc.myStockOrderLine;
			elseif CM_StockOrderSummaryAlloc.hasInstance(tmpAllocation) then
				tmpObj := tmpAllocation.CM_StockOrderSummaryAlloc.myStockOrderSummary;
			endif;
			if tmpObj &lt;&gt; null then
				rowIdx := self.tblOrderData.fixedRows+1;
				if self.tblOrderData.findObjectInRow(tmpObj, rowIdx) then
					str := self.dataTableDisplayRow(self.tblOrderData, tmpObj);
					self.tblOrderData.accessCell(rowIdx, 1).text := str;
				endif;
			endif;
			tmpObj := null;
		endforeach;	
	endif;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleUserNotification" id="aa88f4d8-15c5-497e-af89-007b8ec2e176">
        <updating/>
        <source>handleUserNotification(_obj : Object; _event : Integer) updating;
//--------------------------------------------------------------
//Created: 07 November 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	idx,
	termEvent,
	topRow		: Integer;
	saveTblObj	: CM_StockOrderObject;
	selectedObj : Object;
	topList		: CM_QueueListBox;
	voyOper 	: CM_VoyageOperator;
	term		: CM_Terminal;
	changeSelected : Boolean;	
	failedDAC  :CM_DataAccessController;
begin
	
	if _obj = null then
		return;
	endif;
		
	if self.fldTreeView.topSheet = self.shtListSuppliers then
		topList := self.lstSuppliers;
	else
		topList := self.lstPorts;	
	endif;

	if topList.listIndex &gt; 0 then
		selectedObj	:= topList.itemObject[topList.listIndex];
	endif;
	
	topRow := self.tblOrderData.topRow;
	saveTblObj := self.myCurrentStockOrderObject;	
	
	if _event = LogVoyageOps_Delete_Event
	or (not global.isValidObject(_obj)) then
	
		if  _obj = saveTblObj then  //if the stock order object we've selected is deleted  //cnwrd1 par #19172,  9.4.09
			changeSelected := true; //refresh the display.
		endif;
		
	   	self.removeDeletedObject(_obj);		
		
	   	if _obj = selectedObj then
	   		selectedObj := null;
	   		idx := topList.listIndex - 1;
	   		if idx &gt; topList.listCount then
	   			idx := topList.listCount;
	   			if idx &gt; 0 then
	   				// select the object above the one just deleted
			   		selectedObj := topList.itemObject[idx];
			   		changeSelected := true;
	   			endif;
	   		endif;			
		   endif;


	elseif CM_VoyageOperator.hasInstance(_obj) then
		voyOper := _obj.CM_VoyageOperator;
		if voyOper.myVoyage &lt;&gt; null then
			term := voyOper.myVoyage.myTerminal;
		endif;
		if term = null then
			return;
		endif;
		
		if (not term.canUserAccessSelf(app.getMyUser(), failedDAC, app.myPassport)) then
			return;
		endif;

		termEvent := term.getEventFromTerminalEvent(_event);		
		
		if termEvent = VoyageOperator_Create_Event then
			self.listsAddItem(_obj);
		
		elseif termEvent = VoyageOperator_Update_Event then
			self.listsUpdateItem(_obj);
			changeSelected := selectedObj = _obj; // selected object updated refresh the data					
		
		else
			return;
		endif;
		
	elseif _event = LogVoyageOps_Create_Event then
		self.listsAddItem(_obj);
		// select the newly created object
		if CM_VoyageGlobal.hasInstance(_obj) then
			if self.tblVoyageAdmin.userScript = _obj.CM_VoyageGlobal.code then
				selectedObj := _obj;
				changeSelected := true;
				self.tblVoyageAdmin.userScript := null;
			endif;
		endif;

	elseif _event = LogVoyageOps_Update_Event then
		if CM_StockOrderObject.hasInstance(_obj) then
			self.tblOrderDataUpdateObject(_obj.CM_StockOrderObject, _event);
			return;		
		else
			self.listsUpdateItem(_obj);
		endif;
		changeSelected := selectedObj = _obj; // selected object updated refresh the data
//		if CM_LogVoyage.hasInstance(selectedObj) then
		if CM_Voyage.hasInstance(selectedObj) then		
			if selectedObj.CM_Voyage.myLogVoyageStructure &lt;&gt; null and selectedObj.CM_Voyage.myVoyageGlobalArrival = _obj then
				changeSelected := true;
			endif;
		endif;		
		self.tblVoyageAdmin.userScript := null;		
		
		// 17/08/2010 cnwar2 #25468 code removed
		
	endif;

	if changeSelected then
	
		self.listsSetSelected(lstSuppliers, selectedObj);		
		self.listsSetSelected(lstPorts, selectedObj);			
		
		self.listTreeViewChange(topList);	

		if self.myCurrentVoyageOperator &lt;&gt; null then	
			self.loadAllOrdersByVoyageOperator(self.myCurrentVoyageOperator);
		elseif self.myCurrentVoyage &lt;&gt; null then
			self.loadAllOrdersByVoyageTerminal(self.myCurrentVoyage, null);							
		elseif self.myCurrentVoyageGlobal &lt;&gt; null then
			self.loadAllOrdersByVoyageGlobal(self.myCurrentVoyageGlobal);		
		endif;
		
		self.setSelectedTblOrderData(saveTblObj, topRow); //cnwrd1 par #19172,  9.4.09 moved from outsite changeSelected
	endif;

	

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_event" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="hideCannotAccessSheetMsg" id="1726b709-1a7a-439a-91c8-787cf8a5bc70">
        <source>hideCannotAccessSheetMsg(_sheet : Sheet);
// ---------------------------------------------------------------------------
// Created:     31 July 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	enable : Boolean;
begin
	
	if self.modeView = self.Mode_View_Only or
	   self.modeView = self.Mode_ArchiveView or
	   self.modeView = self.Mode_LimitedEdit then
		enable := false;
	else
		enable := true;
	endif;
	
	if _sheet &lt;&gt; null then
		self.setControlsForSheet(_sheet, enable);
	endif;	
	frmMessage.visible := false;
end;</source>
        <Parameter name="_sheet" type="Sheet"/>
    </JadeMethod>
    <JadeMethod name="includeGlobalVoyage" id="59717900-b83a-4280-8e71-f9ee5f5d4799">
        <source>includeGlobalVoyage(_voyGlobal : CM_VoyageGlobal; _passport : CM_Passport) : Boolean;
// ---------------------------------------------------------------------------
// Created:     10 March 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	terminal : CM_Terminal;
	tmpStartDate,
	tmpEndDate	: Date;
	voyCode : String;
begin

	if (not _voyGlobal.canUserAccess(_passport, self.permissionView)) then
		return false;
	endif;

	if (not _voyGlobal.hasStructureOfType(LogStructure)) then
		return false;
	endif;
	
	if self.modeView = Mode_ArchiveView then
	
		terminal := self.cmbTerminal.listObject.CM_Terminal;
		voyCode := self.tblArchiveSearch.getValueByName(ETRow_VoyageCode).String;				
		tmpStartDate := self.tblArchiveSearch.getValueAsDate(ETRow_FilterStartDate);
		tmpEndDate := self.tblArchiveSearch.getValueAsDate(ETRow_FilterEndDate);
		
		if (not _voyGlobal.hasArchivedVoyages(terminal, tmpStartDate, tmpEndDate, _passport, self.permissionView)) then
			return false;
		elseif voyCode &lt;&gt; null then
			if (not _voyGlobal.code.startsWith(voyCode)) then
				return false;
			endif;			
		endif;
		
	elseif _voyGlobal.checkAllArchived() then
		return false;
		
	elseif not _voyGlobal.checkCanViewUnArchived(_passport, self.permissionView) then
		return false; // added as global voyages still viewable when user has acess to archived terminal (but no others)
					// and there are other voyages user does not have access to. 
	endif;
			
	return true;

end;</source>
        <Parameter name="_voyGlobal" type="CM_VoyageGlobal"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includeOperator" id="2395c983-9964-4a47-9fa5-3b1e5990e7b5">
        <source>includeOperator(_operator : CM_Operator) : Boolean;
//-----------------------------------------
//Created: March 2003 By: cnwgd1
//-----------------------------------------
vars

	failedDAC  :CM_DataAccessController;

begin

	if _operator &lt;&gt; null then
	   	if (not _operator.canUserAccessSelf(null, failedDAC, app.myPassport)) then
			return false;
		endif;
	endif;	

	return true;

end;</source>
        <Parameter name="_operator" type="CM_Operator"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includeStockOrder" id="fb94b64e-8749-4c98-a6eb-3a5de3360913">
        <source>includeStockOrder(_order : CM_StockOrderObject; _user : CM_User) : Boolean;
//-----------------------------------------
//Created: March 2003 By: cnwgd1
//-----------------------------------------
vars
	term : CM_Terminal;
	oper : CM_Operator;
	cons : CM_ConsigneeConsignor;
	failedDAC  :CM_DataAccessController;
begin

	term := _order.getMyTerminal();

	if term &lt;&gt; self.myTerminal and
	   (not _user.canDo(term, self.permissionView)) then
		return false;
	endif;

	oper := _order.getMyOperator();
	if oper &lt;&gt; null then
	   	if (not oper.canUserAccessSelf(null, failedDAC, app.myPassport)) then
			return false;
		endif;
	endif;
	
	if CM_LogStockOrderLine.hasInstance(_order) then
		cons := _order.CM_LogStockOrderLine.myConsignee;
		if cons &lt;&gt; null then
		   	if (not cons.canUserAccessSelf(null, failedDAC, app.myPassport)) then
				return false;
			endif;
		endif;
	endif;		
					

	return true;

end;</source>
        <Parameter name="_order" type="CM_StockOrderObject"/>
        <Parameter name="_user" type="CM_User"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includeVoyage" id="767015d2-1feb-4da0-b8b0-325d911c91bf">
        <source>includeVoyage(_voy : CM_Voyage; _user : CM_User) : Boolean;
// ---------------------------------------------------------------------------
// Created:     10 March 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	term : CM_Terminal;
	failedDAC  :CM_DataAccessController;
begin

	if _voy.archived then
		term := _voy.myTerminalArchived;
	else
		term := _voy.myTerminal;
	endif;
	
	if term &lt;&gt; self.myTerminal and
	   (not _user.canDo(term, self.permissionView)) then
		return false;
	endif;

	if self.modeView = Mode_ArchiveView then
		if (not self.allArchivedVoySearchResults.includes(_voy)) then
			return false;
		endif;
	elseif _voy.archived then
		return false;
	endif;
	
	if _voy.myLogVoyageStructure = null then
		return false;
	endif;
	
	if (not _voy.canUserAccessSelf(null, failedDAC,app.myPassport)) then
		return false;
	endif;

	return true;

end;</source>
        <Parameter name="_voy" type="CM_Voyage"/>
        <Parameter name="_user" type="CM_User"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initAllocateRowsTables" id="ba1cc84d-a21c-468e-aa58-c2125c7caaee">
        <updating/>
        <source>initAllocateRowsTables(_table : CM_DataTable input; _entTableDef : EntTableDef) updating;
//--------------------------------------------------------------
//Created: July 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	_table.selectMode := Table.SelectMode_CurrentRow;
	_table.autoSize := Table.AutoSize_Column;
	_table.clearAllData();
	_table.readOnly := false;
	_table.userInputEnabled := true;	
	_table.cnEcResizeContents();
	_table.setTblDataEntRowsFromDef(_entTableDef);
	_table.accessColumn(_table.getColumnByRowName(ETRow_AverageSED)).alignment := Table.Alignment_Right_Middle;	
	_table.accessColumn(_table.getColumnByRowName(ETRow_CurrentVolume)).alignment := Table.Alignment_Right_Middle;	
	_table.accessColumn(_table.getColumnByRowName(ETRow_AllocVolume)).alignment := Table.Alignment_Right_Middle;	
	_table.accessColumn(_table.getColumnByRowName(ETRow_AvailableVolume)).alignment := Table.Alignment_Right_Middle;	
	_table.accessColumn(_table.getColumnByRowName(ETRow_Date)).visible := false;

end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_entTableDef" type="EntTableDef"/>
    </JadeMethod>
    <JadeMethod name="initFldTreeView" id="810ccb41-237d-44b5-8254-9601372327f4">
        <updating/>
        <source>initFldTreeView()updating;
//--------------------------------------------------------------
//Created: 16 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	self.viewList := self.VIEW_PORTS;
	lstPorts.enabled := true;
	lstPorts.visible := true;
	lstPorts.backColor := White;
	lstPorts.hasTreeLines := true;
	lstPorts.hasPlusMinus := true;
	lstPorts.defaultLineHeight := 13;
	lstPorts.hasPictures := false; // this will put the windows pictures, folder etc. onto the tree
	
	lstSuppliers.enabled := true;
	lstSuppliers.visible := true;
	lstSuppliers.backColor := White;
	lstSuppliers.hasTreeLines := true;
	lstSuppliers.hasPlusMinus := true;
	lstSuppliers.defaultLineHeight := 13;
	lstSuppliers.hasPictures := false; // this will put the windows pictures, folder etc. onto the tree
		
end;</source>
    </JadeMethod>
    <JadeMethod name="initFromUserWindow" id="71f63eee-ae6b-49d4-8d92-72083582171d">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;
//--------------------------------------------------
// Created:	13 August 2004 By: cnwgd1
//--------------------------------------------------
vars
	startPos,
	pos : Integer;
	splitterName : String;
begin
	inheritMethod(_userWindow);

	//Set Operations splitter ratio
	startPos := 1;
	pos := 1;
	splitterName := _userWindow.xmlInfo.cnEcGetNextTagValueOfName(XMLTag_Splitter &amp; ' ' &amp; self.name &amp; ' ' &amp; self.splOperations.name, startPos);

	if splitterName &lt;&gt; null then
		self.splOperationsRatioSaved := splitterName.cnEcGetNextTagValueOfName(XMLTag_Ratio, pos).Integer;
	else
		self.splOperationsRatioSaved := self.splOperations.leftToRightRatio;
	endif;
	self.splOperations.setLeftToRightRatioAndResize(self.splOperationsRatioSaved);

	//Set Main splitter ratio
	startPos := 1;
	pos := 1;
	splitterName := _userWindow.xmlInfo.cnEcGetNextTagValueOfName(XMLTag_Splitter &amp; ' ' &amp; self.name &amp; ' ' &amp; self.splMain.name, startPos);

	if splitterName &lt;&gt; null then
		self.splMainRatioSaved := splitterName.cnEcGetNextTagValueOfName(XMLTag_Ratio, pos).Integer;
	else
		self.splMainRatioSaved := self.splMain.leftToRightRatio;
	endif;
	self.splMain.setLeftToRightRatioAndResize(self.splMainRatioSaved);

	//Set Allocate Rows splitter ratio
	startPos := 1;
	pos := 1;
	splitterName := _userWindow.xmlInfo.cnEcGetNextTagValueOfName(XMLTag_Splitter &amp; ' ' &amp; self.name &amp; ' ' &amp; self.splAllocateRows.name, startPos);

	if splitterName &lt;&gt; null then
		self.splAllocateRowsRatioSaved := splitterName.cnEcGetNextTagValueOfName(XMLTag_Ratio, pos).Integer;
	else
		self.splAllocateRowsRatioSaved := self.splAllocateRows.leftToRightRatio;
	endif;
	self.splAllocateRows.setLeftToRightRatioAndResize(self.splAllocateRowsRatioSaved);		
end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
