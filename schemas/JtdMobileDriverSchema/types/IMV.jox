    <JadeMethod name="handleDeletedObjects" id="d8e5b59e-65af-46f4-9f3a-74510a189e89">
        <source>handleDeletedObjects(exc:Exception):Integer;

begin
	//app.logMessage(method.qualifiedName&amp;" exc.errorCode="&amp;exc.errorCode.String);
	if  exc.errorCode = 4 or exc.errorCode = 1090  // object not found
	or exc.errorCode = 1086 then  // Class of object is invalid in this context (if array is empty, can't type guard null to Object)
		return(Ex_Resume_Next);
	else
		return(Ex_Pass_Back);
	endif;
end;
</source>
        <Parameter name="exc" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="imv001_VMIF_btnGetTask_click" id="2b4bc717-013f-4d9c-aa13-dab411176a23">
        <updating/>
        <source>imv001_VMIF_btnGetTask_click():Integer updating;

vars
	i,j,row:Integer;
	table:Table;
	
begin
	app.logMessage(method.qualifiedName&amp;" "&amp;app.jmtComputerName&amp;" is looking for a move to make");
	table:=myVehicleMounted_IMVForm.tblJobs;
	while true do :outer  // loop until we have something to do, then exit to bump the count on the JtdController form
		if qIsInLoadMode then  // only Get Task in load mode - in discharge mode IMV operator just reads screen and does not push buttons
			if table.rows &lt; 2 then  // we are empty - go to RTG and get another container
			
				myVehicleMounted_IMVForm.txtWrongData.text:=null;
				myVehicleMounted_IMVForm.btnGetTask.click(myVehicleMounted_IMVForm.btnGetTask);
				foreach i in 1 to 20 do
					if table.rows &gt;= 2 then  // got a container
						app.logMessage(method.qualifiedName&amp;" i="&amp;i.String&amp;" "&amp;app.jmtComputerName&amp;" got "&amp;table.getCellText(2, 1)&amp;" "&amp;table.getCellText(2, 2)&amp;" "&amp;table.getCellText(2, 4)&amp;" "&amp;table.getCellText(2, 6));
						myRTQueue.causeEvent(1208, true, app.jmtComputerName[1:4]&amp;table.getCellText(2, 4));
						if pauseAndStop(30000) then return 0; endif;  // IMV travel time
						break;
					elseif myVehicleMounted_IMVForm.txtWrongData.text &lt;&gt; null then
						app.logMessage(method.qualifiedName&amp;" i="&amp;i.String&amp;" "&amp;app.jmtComputerName&amp;" got error: "&amp;myVehicleMounted_IMVForm.txtWrongData.text);
						if pauseAndStop(20000) then return 0; endif;  // "safe" way to add a delay
						break;
					endif;
					if pauseAndStop(1000) then return 0; endif;  // "safe" way to add a delay
				endforeach;
				if table.rows &lt; 2 and myVehicleMounted_IMVForm.txtWrongData.text = null then
					app.logMessage(method.qualifiedName&amp;" "&amp;app.jmtComputerName&amp;" clicked the button but got no response");
					if pauseAndStop(2000) then return 0; endif;  // "safe" way to add a delay
					return 1;
				endif;
			endif;
		endif;
		if table.rows &gt;= 2 then  // got a container on board
			app.logMessage(method.qualifiedName&amp;" "&amp;app.jmtComputerName&amp;" is moving "&amp;table.getCellText(2, 1)&amp;" "&amp;table.getCellText(2, 2)&amp;" "&amp;table.getCellText(2, 4)&amp;" "&amp;table.getCellText(2, 6));  //&amp;" myRTQueue="&amp;myRTQueue.String
			if table.getCellText(2, 1) = "EXPORT" then
				myRTQueue.causeEvent(1208, true, app.jmtComputerName[1:4]&amp;table.getCellText(2, 4));  // if these are duplicated, they will be filtered at the other end
			endif;
			// wait until the container is gone, timeout periodically to repeat the logMessage above
			foreach i in 1 to 20 do
				if table.rows &lt; 2 then
					break outer;
				endif;
				if pauseAndStop(3000) then return 0; endif;  // "safe" way to add a delay
			endforeach;
		endif;
		if pauseAndStop(1000) then return 0; endif;  // "safe" way to add a delay
		/*if      app.jmtComputerName = "IM21" then myVehicleMounted_IMVForm.top:=300;
		elseif app.jmtComputerName = "IM35" then myVehicleMounted_IMVForm.top:=500;
		endif;/**/
	endwhile;
	
	return 0;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="qIsInLoadMode" id="ea2c3dff-aaaa-4a89-a49c-e0bfd53bc428">
        <source>qIsInLoadMode():Boolean;

vars
	myRTQueueEntry:Object;
	jobType:Integer;
begin
	on Exception do handleDeletedObjects(exception);  // other apps are deleting these objects
	jobType:=1;  // return false if there is an exception
	
	myRTQueueEntry:=myRTQueue.getPropertyValue("allEntries").Array.first.Object;
	jobType:=myRTQueueEntry.getPropertyValue("myJob").Object.getPropertyValue("jobType").Integer;
	//app.logMessage(method.qualifiedName&amp;" myRTQueue job type="&amp;jobType.String);
	return jobType = 0;  // aka VOYAGEJOB_TYPE_LOAD
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="runTest" id="eac41c46-7433-43ba-b2e9-326221b8ee8d">
        <updating/>
        <source>runTest():Integer updating;

vars
	sa:StringArray;
	meth:String;
begin
	create sa transient;
	sa.add('imv001_VMIF_btnGetTask_click');

	foreach meth in sa do
		if meth[6:2] &lt;&gt; "v_" then
			app.doWindowEvents(longPause);
		endif;
		userPreTransaction(meth);
		retCode:=self.sendMsg(meth).Integer;
		userPostTransaction(meth);
		if app.atcgReplayFailure then
			app.atcgReplayFailure:=false;
			break;
		elseif retCode = 0 then
			app.logMessage("Test "&amp;self.class.name&amp;"::"&amp;meth&amp;" succeeded");
		else
			app.logMessage("Test "&amp;self.class.name&amp;"::"&amp;meth&amp;" failed with error code "&amp;retCode.String);
			break;
		endif;
	endforeach;
	app.atcgDetectMissedMsgBoxes;
	app.logMessage("Finished");
	return 0;
epilog
	delete sa;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="startup" id="dfc98e89-c5f6-4569-8246-9543c2bcca1b">
        <updating/>
        <source>startup() updating;

begin
	app.atcgRecordingVersion:='1.1.14.0';
	inheritMethod();
end;</source>
    </JadeMethod>
    <JadeMethod name="startup2" id="77666686-f5b7-42ae-ba72-55446d053557">
        <updating/>
        <source>startup2() updating;

vars
	primaryQ,
	nextPrimaryQ	: Object;
	
begin
	myVehicleMounted_IMVForm:=app.getForm('VehicleMounted_IMVForm').VehicleMounted_IMVForm;
	myMachine:=app.myVehicleMountedIMVGuiAgent.myVehicleMountedIMVAgent.myMachine;
	myRTQueue:=app.myVehicleMountedIMVGuiAgent.myVehicleMountedIMVAgent.myRTQueue;
	myVehicleMounted_IMVForm.caption:=myVehicleMounted_IMVForm.caption&amp;" "&amp;app.jmtComputerName;
	
	app.logMessage(method.qualifiedName&amp;" myMachine="&amp;myMachine.getPropertyValue("id").String);
	app.logMessage(method.qualifiedName&amp;" myRTQueue="&amp;myRTQueue.String&amp;", myRTQueue.id="&amp;myRTQueue.getPropertyValue("id").String);

	primaryQ := myMachine.getPropertyValue("myPrimaryQueue").Object;
	if primaryQ &lt;&gt; null then
		app.logMessage(method.qualifiedName&amp;" machine.myPrimaryQueue="&amp;primaryQ.String&amp;", machine.myPrimaryQueue.id="&amp;primaryQ.getPropertyValue("id").String);
	else
		app.logMessage(method.qualifiedName&amp;" machine.myPrimaryQueue=&lt;null&gt;");
	endif;

	nextPrimaryQ := myMachine.getPropertyValue("myNextPrimaryQueue").Object;
	if nextPrimaryQ &lt;&gt; null then
		app.logMessage(method.qualifiedName&amp;" machine.myNextPrimaryQueue="&amp;nextPrimaryQ.String&amp;", machine.myNextPrimaryQueue.id="&amp;nextPrimaryQ.getPropertyValue("id").String);
	else
		app.logMessage(method.qualifiedName&amp;" machine.myNextPrimaryQueue=&lt;null&gt;");
	endif;
end;

</source>
    </JadeMethod>
    <JadeMethod name="stop" id="1e57cfc2-0409-4b1b-ae62-a39d41b6825f">
        <updating/>
        <source>stop() updating;

begin
	inheritMethod;
end;
</source>
    </JadeMethod>
    <JadeMethod name="stop2" id="8ed1dccf-a16a-4e74-9499-8885ee4725f2">
        <updating/>
        <source>stop2() updating;

begin
	myVehicleMounted_IMVForm.btnLogoff.click(myVehicleMounted_IMVForm.btnLogoff);
	app.doWindowEvents(shortPause);

	myHandHeldLogonForm:=app.getForm('HandHeldLogonForm').HandHeldLogonForm;
	myHandHeldLogonForm.btnExit.click(myHandHeldLogonForm.btnExit);
	app.doWindowEvents(shortPause);
	
	if app.isValidObject(myVehicleMounted_IMVForm) then
		myVehicleMounted_IMVForm.unloadForm;
	endif;
	myVehicleMounted_IMVForm:=null;
	if app.isValidObject(myHandHeldLogonForm) then
		myHandHeldLogonForm.unloadForm;
	endif;
	myHandHeldLogonForm:=null;
end;
</source>
    </JadeMethod>
</Class>
