    <JadeMethod name="canfactorBy" id="9db437f4-e127-40c7-9af8-de693f3351ca">
        <source>canfactorBy( _factor : Decimal; _raiseExc : Boolean ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	component : CM_RecipeComponent;
	factored : Decimal[14,4];
	msg : String;

begin

	if not self.canFactor then
		return false;
	endif;

	foreach component in self.allComponentsByOrder do
		if component.quantity &lt;&gt; 0 then
			factored := component.quantity * _factor;
			if factored.Integer &lt;&gt; factored then
				if _raiseExc then
					app.raiseCMException3(Quant_compo_not_facto_resul_no, component.quantity.asStringJMT, component.code, _factor.asStringJMT, null, null );
				else
					msg := app.getErrorString3(Quant_compo_not_facto_resul_no, component.quantity.asStringJMT, component.code, _factor.asStringJMT );
					app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
				endif;
				return false;
			endif;
		endif;
	endforeach;
	
	return true;

epilog

end;</source>
        <Parameter name="_factor" type="Decimal"/>
        <Parameter name="_raiseExc" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAmountString" id="089823cc-5157-4ea7-a021-85128e21a3af">
        <source>getAmountString( _multiplier : Decimal ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	returnVal : String;
	measureType : CM_MeasurementType;
	type : String;
	multiplier : Decimal[14,4];

begin

	if _multiplier = 0 then
		multiplier := 1;
	else
		multiplier := _multiplier;
	endif;

	if self.myCargoType = null then
		if self.defaultQuantity &lt;&gt; 0 then
			returnVal := "x" &amp; (self.defaultQuantity * multiplier).Integer.asStringJMT;
		elseif self.defaultWeight &lt;&gt; 0 then
			returnVal := (self.defaultWeight * multiplier).asStringWeightJMT &amp; " kg";
		elseif self.defaultVolume &lt;&gt; 0 then
			returnVal := (self.defaultVolume * multiplier).asStringWeightJMT &amp; " m3";
		endif;
	
	else
		if self.myCargoType.isTrackByVolume then
			if self.myProduct &lt;&gt; null then
				measureType := self.myProduct.getDefaultMeasurementForType(Type_Volume);
			else
				measureType := self.myCargoType.getDefaultMeasurementForType(Type_Volume);
			endif;
			type := measureType.shortName;
			if self.defaultVolume &lt;&gt; 0 then
				returnVal := app.convertMeasurementForDisplay(type, (self.defaultVolume * multiplier) ) &amp; " " &amp; type;
			endif;
		elseif self.myCargoType.isTrackByWeight then
			if self.myProduct &lt;&gt; null then
				measureType := self.myProduct.getDefaultMeasurementForType(Type_Weight);
			else
				measureType := self.myCargoType.getDefaultMeasurementForType(Type_Weight);
			endif;
			type := measureType.shortName;
			if self.defaultWeight &lt;&gt; 0 then
				returnVal := app.convertMeasurementForDisplay(type, (self.defaultWeight * multiplier) ) &amp; " " &amp; type;
			endif;
		else
			if self.defaultQuantity &lt;&gt; 0 then
				returnVal := "x" &amp; (self.defaultQuantity * multiplier).Integer.asStringJMT;
			endif;
		endif;

	endif;
	
	return returnVal;

epilog

end;</source>
        <Parameter name="_multiplier" type="Decimal"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="720413f4-4f8b-4913-8156-12f5ab558e5a">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

begin

	if _attrName = ETRow_RecipeAmount then
		return self.getAmountString(1);
	elseif _attrName = ETRow_RecipeCode then
		return self.code;
	elseif _attrName = ETRow_RecipeCompCount then
		return self.allComponentsByCode.size.asStringJMT;
	elseif _attrName = ETRow_RecipeDescription then
		return self.description;
	elseif _attrName = ETRow_RecipeProduct then
		return self.getRecipeCTProductString();
	elseif _attrName = ETRow_RecipeInstructions then
		return self.instructions;
	else
		return inheritMethod(_attrName, _short);
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOtherAmountsString" id="7f29b0a7-139a-48f7-a2dd-4771fc7b8509">
        <source>getOtherAmountsString( _multiplier : Decimal ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	returnVal : String;
	measureType : CM_MeasurementType;
	type : String;
	multiplier : Decimal[14,4];

begin

	if _multiplier = 0 then
		multiplier := 1;
	else
		multiplier := _multiplier;
	endif;
	
	if self.myCargoType = null then
		if self.defaultWeight &lt;&gt; 0 then
			returnVal := (self.defaultWeight * multiplier).asStringWeightJMT &amp; " kg";
		endif;
		if self.defaultVolume &lt;&gt; 0 then
			if returnVal &lt;&gt; null then
				returnVal := returnVal &amp; ", ";
			endif;
			returnVal := returnVal &amp; (self.defaultVolume * multiplier).asStringWeightJMT &amp; " m3";
		endif;
	
	else
		if self.myCargoType.isTrackByVolume or self.myCargoType.isTrackByWeight then
			if self.defaultQuantity &lt;&gt; 0 then
				returnVal := "x" &amp; (self.defaultQuantity * multiplier).Integer.asStringJMT;
			endif;
		endif;
	
		if not self.myCargoType.isTrackByWeight then
			if self.myProduct &lt;&gt; null then
				measureType := self.myProduct.getDefaultMeasurementForType(Type_Weight);
			else
				measureType := self.myCargoType.getDefaultMeasurementForType(Type_Weight);
			endif;
			type := measureType.shortName;
			if self.defaultWeight &lt;&gt; 0 then
				if returnVal &lt;&gt; null then
					returnVal := returnVal &amp; ", ";
				endif;
				returnVal := returnVal &amp; app.convertMeasurementForDisplay(type, (self.defaultWeight * multiplier) ) &amp; " " &amp; type;
			endif;
		endif;
	
		if not self.myCargoType.isTrackByVolume then
			if self.myProduct &lt;&gt; null then
				measureType := self.myProduct.getDefaultMeasurementForType(Type_Volume);
			else
				measureType := self.myCargoType.getDefaultMeasurementForType(Type_Volume);
			endif;
			type := measureType.shortName;
			if self.defaultVolume &lt;&gt; 0 then
				if returnVal &lt;&gt; null then
					returnVal := returnVal &amp; ", ";
				endif;
				returnVal := returnVal &amp; app.convertMeasurementForDisplay(type, (self.defaultVolume * multiplier) ) &amp; " " &amp; type;
			endif;
		endif;
		
	endif;
	
	return returnVal;

epilog

end;</source>
        <Parameter name="_multiplier" type="Decimal"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRecipeCTProductString" id="a4b57416-5373-4d54-90da-2b79c149ab78">
        <source>getRecipeCTProductString():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	retStr : String;

begin

	if self.myProduct &lt;&gt; null then
		retStr := self.myProduct.description;
	endif;
	
	if self.myCargoType &lt;&gt; null then
		if retStr = null then
			retStr := self.myCargoType.abbreviation;
			if not self.myCargoType.allProducts.isEmpty then
				retStr := retStr &amp; ", " &amp; app.getErrorString( AnyString );
			endif;
		else
			retStr := self.myCargoType.abbreviation &amp; ", " &amp; retStr;
		endif;
	endif;
	
	if retStr = null then
		retStr := app.getErrorString( Unknown );
	endif;
	
	return retStr;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTextForAuditStrOnCargoType" id="9bf13cb6-e695-446a-9ed6-24a6b8dcc9ab">
        <source>getTextForAuditStrOnCargoType():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	txt : String;
	recipeComp : CM_RecipeComponent;

begin
	txt := "Recipe " &amp; self.code &amp; "/" &amp; self.description &amp; Cr;
	
	if self.myProduct &lt;&gt; null then
		txt := txt &amp;  '[' &amp; self.myProduct.code &amp; "] " &amp; Cr;
	endif;
	txt := txt &amp;  'Components:' &amp; Cr;
	txt := txt &amp;  'Output ' &amp; self.getAmountString(1) &amp; Cr;
	foreach recipeComp in self.allComponentsByCode do
		txt := txt &amp; recipeComp.getTextForAuditStringOnRecipe &amp; Cr;
	endforeach;
	
	return txt;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="dbcb006d-6fb8-4300-8c4d-1fdc8b3229c2">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	pxyRecipe : CM_Recipe;
	recipeComp : CM_RecipeComponent;
	pxyRecipeComp : CM_RecipeComponent;
	completedOK : Boolean;

begin

	pxyRecipe := inheritMethod();
	
	pxyRecipe.myProduct := self.myProduct;
	
	foreach recipeComp in self.allComponentsByCode do
		pxyRecipeComp := recipeComp.pxyCreateUpdateProxy();
		if pxyRecipeComp &lt;&gt; null then
			pxyRecipeComp.setMyRecipe( pxyRecipe );
		endif;
	endforeach;
	
	
	completedOK := true;
	return pxyRecipe;

epilog

	if not completedOK then
		delete pxyRecipe;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="9bea0ffa-95bc-47b4-b760-f9b96e745ae9">
        <updating/>
        <source>setForCreate( _pxyRecipe : CM_Recipe; _cargoType : CM_CargoType ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 May 2021	navndl1	Initial creation	TFS 

*/

vars

begin

	self.setForUpdate( _pxyRecipe, _cargoType );
	self.myRoot := app.myRoot;

epilog

end;</source>
        <Parameter name="_pxyRecipe" type="CM_Recipe"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="320a50fd-9685-4ecb-90af-7e7923eec85c">
        <updating/>
        <source>setForUpdate( _pxyRecipe : CM_Recipe; _cargoType : CM_CargoType ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	updatedComponents : CM_RecipeComponentByCodeDict;
	pxyComponent : CM_RecipeComponent;
	existingComponent : CM_RecipeComponent;
	newComponent : CM_RecipeComponent;

begin
	
	self.code := _pxyRecipe.code;
	self.description := _pxyRecipe.description;
	self.canFactor := _pxyRecipe.canFactor;
	
	self.myProduct := _pxyRecipe.myProduct;
	self.myCargoType := _cargoType;
	
	self.defaultQuantity := _pxyRecipe.defaultQuantity;
	self.defaultVolume := _pxyRecipe.defaultVolume;
	self.defaultWeight := _pxyRecipe.defaultWeight;
	self.instructions := _pxyRecipe.instructions;
	
	create updatedComponents transient;
	foreach pxyComponent in _pxyRecipe.allComponentsByCode do
		existingComponent := pxyComponent.pxyGetRealObject;
		
		if existingComponent = null then
			// a new one, make it belong to me.
			create newComponent persistent;
			newComponent.setForCreate( pxyComponent, self );
			updatedComponents.add( newComponent );
		else
			//its pre existing, just update it
			existingComponent.setForUpdate( pxyComponent, self );
			updatedComponents.add( existingComponent );
		endif;	
	endforeach;
	
	foreach existingComponent in self.allComponentsByCode do
		if not updatedComponents.includes( existingComponent ) then
			//its been deleted
			delete existingComponent;
		endif;
	endforeach;

epilog

	delete updatedComponents;

end;</source>
        <Parameter name="_pxyRecipe" type="CM_Recipe"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="setMyCargoType" id="c171dc3e-bc30-402c-81f3-149a2cb27e87">
