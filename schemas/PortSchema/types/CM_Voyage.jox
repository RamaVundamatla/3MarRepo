    <JadeMethod name="getFirstImportOperator" id="686b7cd5-be89-47bf-9463-85eb0414850c">
        <source>getFirstImportOperator(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 Sep 2022	navak20	TFS ChangeRequest 54863: PIBT - Vessel Departure Report Extraction error

*/

vars
	firstImport : CM_TrackedItem;
begin
	firstImport := self.allImportTIs.first;
	if firstImport &lt;&gt; null then
