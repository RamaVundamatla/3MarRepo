    <JadeMethod name="matchesCriteria" id="e1989c43-1674-4bc8-bcf2-1001850ef354">
        <source>matchesCriteria( yaRequest : CMIF_YARequest input ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 October 2019	jlgndl1	Initial creation	TFS 46911

*/

vars

	criteria : CM_YACriteria;

begin

	foreach criteria in self.allCriteria discreteLock do
		if not criteria.isCMIFAutoPlanDataMatch( yaRequest ) then
			return false;
		endif;
	endforeach;
	
	return true;

epilog

end;</source>
        <Parameter name="yaRequest" type="CMIF_YARequest" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
