    <JadeMethod name="doDelete" id="7632c34a-202c-4ceb-b291-9224fd2b8432">
        <updating/>
        <source>doDelete()updating;
//--------------------------------------------------
// Created:	13 April 2005 By: cnwgd1
//--------------------------------------------------
vars

	result			: Integer;
	msgStr			: String;
	selectedObj 	: CM_Object;
	objectArray		: CM_ObjectArrayActual;
	
begin

	if self.tblData.allSelectedObjects.size &gt; 1 then
	   	msgStr := app.getErrorString2(ConfirmDelete, 'selected', 'Master Items');
	elseif self.myCurrentTiLCType &lt;&gt; null then
		selectedObj := self.myCurrentTiLCType;
		msgStr := app.getErrorString2(ConfirmDelete, 'the selected', 'Master Item ' &amp; self.myCurrentTiLCType.code);
	else
		app.msgBox(app.getErrorString(Please_Select_An_Item_Fiirst), self.caption, MsgBox_OK_Only+MsgBox_Stop_Icon);
		return;	
	endif;

	if app.msgBox(msgStr, self.caption, MsgBox_Yes_No + MsgBox_Question_Mark_Icon + MsgBox_Default_Second) = MsgBox_Return_No then
		return;
	endif;
	
	
	while true do
		if selectedObj &lt;&gt; null then
		  	app.myTrxDA.trxDeleteCMObject(selectedObj, app.myPassport);
		else
			create objectArray transient;
			self.tblData.allSelectedObjects.copy(objectArray);
		  	app.myTrxDA.trxDeleteCMObjects(objectArray, app.myPassport);	
		endif;		  	  
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			self.doRefresh();
			break;
		else
			result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Delete + ErrWarnMode_CanAckWarnings);
			if result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
	
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;	

epilog
	delete objectArray;
end;</source>
    </JadeMethod>
