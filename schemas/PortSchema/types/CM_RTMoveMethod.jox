    <JadeMethod name="buildQueueEntries" id="f0e3fc32-8bab-4790-b581-6c1397760017">
        <source>buildQueueEntries(_arbiter : CM_RTQueueArbiter input);

// Created by cnwdvb1 on 29 August 2006
//
// Changed On	By			Reason
// ----------	--------	----------------------------------------------------------
// 30/08/2011	cnwdap1		PAR #25693 CCMS POL 2008 Clear the override queue for Full Move Queueing
vars

	group			: CM_MachineTypeGroup;
	preferSource	: Boolean;
	entry			: CM_RTQueueEntry;
	orginalTI 		: CM_TrackedItem;
begin

	_arbiter.isTargetMove := false;
	preferSource := _arbiter.preferSource;
	
	_arbiter.currentMachineTypeGrpIndex:=0;
	foreach group in self.allMachineTypeGroups discreteLock do
		// The count here makes sure that if there are three parts to the move then
		// the final move is the opposite to the first when it comes to prefer source.
		// This forces the correct queue to be selected.
		_arbiter.currentMachineTypeGrpIndex:=_arbiter.currentMachineTypeGrpIndex+1;
		if _arbiter.currentMachineTypeGrpIndex = self.allMachineTypeGroups.size  and group.type &lt;&gt; MACHINETYPEGRP_IMV then
			_arbiter.preferSource := not _arbiter.preferSource;
		endif;
		if group.type = MACHINETYPEGRP_SOURCEIC or
			group.type = MACHINETYPEGRP_TARGETIC or 
			group.type = MACHINETYPEGRP_MAFI then //jlier1 TFS 54701 19/9/22
				continue;
		endif;
		_arbiter.myCurrentMachineTypeGroup := group;
		// PAR #25693 CCMS POL 2008 Need to remove the override queue if this is a full move queuing method
		if _arbiter.myRTMoveMethodRule &lt;&gt; null and _arbiter.myRTMoveMethodRule.queuingRule = FullMoveQueuing then
			_arbiter.queue := null;  
		endif;
		//jlier1 TFS 54701 19/9/22
		if _arbiter.currentMachineTypeGrpIndex = 1 and group.type = MACHINETYPEGRP_TRACTOR and self.allMachineTypeGroups.last.type = MACHINETYPEGRP_LIFTER  then
			//this is a special case where if the cargo is on a MAFI the tractor moves the MAFI to target location and then the reach stacker moves the cargo to the target location
			if _arbiter.ti &lt;&gt; null and _arbiter.ti.isOnTrailer then
				orginalTI:=_arbiter.ti;
				_arbiter.ti:=orginalTI.getCurrentTrailer;	
			endif;
		endif;
		
		// PAR #25693 end
		_arbiter.buildQueueEntryMaster();
		//jlier1 TFS 54701 19/9/22
		if orginalTI &lt;&gt; null then
			_arbiter.ti:=orginalTI;
			orginalTI:=null;
		endif;
	endforeach;
	
	//epr ccms 1100 because queue is added after the entry is created need to now check this here
	foreach entry in _arbiter.allRTQueueEntries do
		entry.checkTasksHaveMachineCoverage();
	endforeach;

epilog	
	_arbiter.preferSource := preferSource;
end;</source>
        <Parameter name="_arbiter" type="CM_RTQueueArbiter" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getInvalidWLEEntriesToDelete" id="1b4d2f79-d811-4d79-a91a-c69c2d61ed3d">
        <source>getInvalidWLEEntriesToDelete(_wle : CM_WorkListEntry;
						_machine : CM_Machine; 
						_lastGroundedLocation :CM_LocationsController;
						_allWLEEntriesToDelete : CM_RTQueueEntrySet input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 March 2011	cnwer1	Initial creation

*/

vars
	allMachineTypeGroups : CM_MachineTypeGroupArray;
	currentRTQueueEntry, rtQueueEntry : CM_RTQueueEntry;
	machineTypeGrp : CM_MachineTypeGroup;
	iter 			: Iterator;
begin

	_allWLEEntriesToDelete.clear;
	
	if _wle = null then
		return;
	endif;
	
	_wle.allRTQueueEntries.copy(_allWLEEntriesToDelete);
	if _machine = null then
		return;
	endif;
	
	create allMachineTypeGroups transient;
	currentRTQueueEntry:=null;
	iter:=_wle.allRTQueueEntries.createIterator;
	while iter.next(rtQueueEntry) do
		allMachineTypeGroups.add(rtQueueEntry.getMyMachineTypeGroup);
		if rtQueueEntry.status &lt;&gt; ENTRY_COMPLETE then
			currentRTQueueEntry:=rtQueueEntry;
			break;
		endif;
	endwhile;
	
	machineTypeGrp:=_machine.getMachineTypeGroup;
	//its the first entry and been picked up by a machine
	if currentRTQueueEntry.getPreviousRelatedEntry() = null then //epr par 35702 17/2/15
		if self.allMachineTypeGroups.first = machineTypeGrp then
			_allWLEEntriesToDelete.remove(currentRTQueueEntry);
		endif;
	else
		// has a previous entry
		// if the area is an  differnt to the and it has moved to an interchange area then will be a new rule and
		// but has to start with machine type
		if _machine.getMachineTypeGroup.type = MACHINETYPEGRP_IMV then
			//has to include the first machine group and the next one has to be this machine type group
			// if true have to retain up to the current rt queue entry
			if  self.includesMachineTypeGroups(allMachineTypeGroups) then
				delete iter;
				iter:=_wle.allRTQueueEntries.createIterator;
				iter.startAtObject(currentRTQueueEntry);
				while iter.back(rtQueueEntry) do
					_allWLEEntriesToDelete.remove(rtQueueEntry);
				endwhile;
					
			endif;
		else
			if self.allMachineTypeGroups.first = machineTypeGrp then
				_allWLEEntriesToDelete.remove(currentRTQueueEntry);
			endif;
		endif;
	endif;	
	
epilog
	delete allMachineTypeGroups;
	delete iter;
end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_machine" type="CM_Machine"/>
        <Parameter name="_lastGroundedLocation" type="CM_LocationsController"/>
        <Parameter name="_allWLEEntriesToDelete" type="CM_RTQueueEntrySet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getName" id="928e7315-6bc2-49a1-9236-146a856fb315">
