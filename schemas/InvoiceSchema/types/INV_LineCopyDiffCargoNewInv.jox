    <JadeMethod name="removeTIs" id="f913c7c9-b9c5-4caf-8c4e-44160d624bd5">
        <source>removeTIs();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 April 2023  navmv20 TFS 55304 Task 55545: UI - Invoice Line List Changes

*/

vars
	allSelectedItems : CM_TIArray;
	ti : CM_TrackedItem;
	iter : Iterator;
	idx : Integer;
begin
	create allSelectedItems transient;
	
	self.tblResults.allSelectedObjects.copy(allSelectedItems);
	if allSelectedItems.size = 0  then
		app.msgBox(app.getErrorString2(CMUI_Please_Select, "cargo item(s)", "remove"),app.getErrorString(NOTHING_SELECTED), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	foreach ti in allSelectedItems do
		self.allTIs.remove(ti);
	endforeach;
	
	iter := self.allTIs.createIterator(); 
	self.tblResults.clearAllData();
		
	while iter.next(ti) do	
		idx := self.tblResults.updateItemObject(ti, self.colorRow1, self.colorRow2, app.myPassport);
		self.tblResults.accessRow(idx).itemObject := ti;
	endwhile;
	
epilog
	delete allSelectedItems;
	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="saveSelectedTrackedItems" id="78ac4c0a-4d87-4e25-9c31-db7876a46124">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_CMUI_TrackedItems::saveSelectedTrackedItems"/>
        </interfaceImplements>
        <updating/>
        <source>saveSelectedTrackedItems(_allTIs : CM_TIArray) : Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 April 2023  navmv20 TFS 55304 Task 55545: UI - Invoice Line List Changes

*/

vars
	ti 		  : CM_TrackedItem;
	currentTA : CM_TerminalArea;
	iter      : Iterator;
	count,
	idx       : Integer;
begin

	if _allTIs = null then
		return true;
	endif;
	
	self.allTIs.clear();
	_allTIs.copy(self.allTIs);
	
	iter := self.allTIs.createIterator();
	self.tblResults.setMyDataClass(CM_TrackedItem);

	if self.allTIs.size &gt; 0 then
		while iter.next(ti) do
			count := count + 1;
			idx := self.tblResults.updateItemObject(ti, self.colorRow1, self.colorRow2, app.myPassport);
			self.tblResults.accessRow(idx).itemObject := ti;
		endwhile;
		self.shtCargoItems.caption := "Items (" &amp; allTIs.size().String &amp; ")";
		self.setCargoSpecific();
		return true;
	endif;
	self.shtCargoItems.caption := "Items (" &amp; allTIs.size().String &amp; ")";
	return false;

epilog

end;</source>
        <Parameter name="_allTIs" type="CM_TIArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setCargoSpecific" id="7ad31ac6-e633-4140-8351-2981ad04fdb3">
        <updating/>
        <source>setCargoSpecific() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 April 2023  navmv20 TFS 55304 Task 55545: UI - Invoice Line List Changes

*/

vars
	invoiceType : CM_InvoiceDesc;
	debSep      : CM_InvTypeDebtorSeparation;
	debtor      : CM_Debtor;
	trackedItem : CM_TrackedItem;
	cargoType   : CM_CargoType;
	opCode      : String;
	operator    : CM_Operator;
	iterator    : Iterator;
begin

	invoiceType := self.cmbInvTypeInv.listObject.CM_InvoiceDesc;
	debtor      := self.cmbDebtorInvProp.listObject.CM_Debtor;
	
	if invoiceType = null then
		return;
	else
		debSep := invoiceType.getDebtorSeparation(debtor);
	endif;
	
	if invoiceType.isCargoSpecificSeparation(debSep) and self.myCurrentTI = null then
		if self.allTIs.size() &gt; 0 then
			trackedItem := self.allTIs.first;
			self.tblCargo.setValueByName(ETRow_CargoId,trackedItem.id);
			cargoType := app.myRoot.allCargoTypesById[trackedItem.cargoType];
			
			self.cmbCargoTypeInvP.listIndex := self.cmbCargoTypeInvP.findStringExact(1,cargoType.description);
			
			if self.cmbCargoTypeInvP.listIndex &lt;&gt; -1 then
				self.tblCargo.setValueByName(ETRow_CargoType,cargoType.description);
			endif;
			opCode := trackedItem.operatorCode; 
			self.cmbCargoOper.listIndex := self.cmbCargoOper.findStringExact(1,opCode);
			if self.cmbCargoOper.listIndex &lt;&gt; -1 then
				self.tblCargo.setValueByName(ETRow_CargoOperator,opCode);
			endif;
			
			self.setMyCurrentTI();
		endif;
	endif;	
end;</source>
    </JadeMethod>
