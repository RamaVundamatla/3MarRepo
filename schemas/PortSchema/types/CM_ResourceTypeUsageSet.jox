<CollClass name="CM_ResourceTypeUsageSet" id="233e1e0a-b6df-4a4e-ad05-8155f726d93f">
    <loadFactor>98</loadFactor>
    <memberType name="CM_ResourceTypeUsage"/>
    <superclass name="ObjectSet"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="actTrans"/>
    <JadeMethod name="getAutoApplyResourceUsage" id="cf999798-375c-47aa-aa74-258cfe390f0f">
        <source>getAutoApplyResourceUsage(_resourceType : CM_ResourceType) : CM_ResourceTypeUsage;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 Dec 2023 navlc30 ChangeRequest 60748: EUP | VAS Mobile App - [53813.070] [BackEnd] Automatic VAS Resources

*/

vars
	resourceUsage : CM_ResourceTypeUsage;
begin
	foreach resourceUsage in self do 
		
		if resourceUsage.myResourceType = _resourceType then
			return resourceUsage;
		endif;
		
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_resourceType" type="CM_ResourceType"/>
        <ReturnType type="CM_ResourceTypeUsage"/>
    </JadeMethod>
    <JadeMethod name="hasResourceType" id="6ff95e35-d183-479b-9408-dcb0916c241d">
        <source>hasResourceType(_resourceType : CM_ResourceType):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 December 2023		navma1	Initial creation
19 Dec 2023 navlc30 ChangeRequest 60748: EUP | VAS Mobile App - [53813.070] [BackEnd] Automatic VAS Resources

*/

vars
	resourceUsage : CM_ResourceTypeUsage;
begin
	foreach resourceUsage in self do 
		
		if resourceUsage.myResourceType = _resourceType then
			return true;
		endif;
		
	endforeach;
	
	return false;
epilog

end;</source>
        <Parameter name="_resourceType" type="CM_ResourceType"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</CollClass>
