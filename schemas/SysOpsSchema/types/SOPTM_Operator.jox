    <JadeMethod name="initShtTblInput2" id="de78a8bf-3715-45ab-b613-429444d1dd8a">
        <updating/>
        <source>initShtTblInput2() updating;
// ---------------------------------------------------------------------------
// Created:     18 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	entTableDef	: EntTableDef;
	mainSheet,
	tmpSheet	: CMUI_Sheet;
	idx			: Integer;
	defName		: String;
	theForm		: SOP_TableMaintForm;
	
begin
	
	inheritMethod();
	
	theForm 	:= self.myForm;
	mainSheet	:= theForm.shtTblInput2;

	foreach defName in self.allEntTableDefs do

		entTableDef := app.myController.getEntTableDef(defName);
		if entTableDef = null then
			app.raiseUnexpectedProgramError(class.name, method.name, 'Unknown def (' &amp; defName &amp; ')');
			continue;
		endif;

		idx := idx + 1;
		tmpSheet := mainSheet.getControl(idx).CMUI_Sheet;
		if tmpSheet = null then
			tmpSheet := mainSheet.loadControl(idx).CMUI_Sheet;
		endif;
		tmpSheet.visible := true;
		
		tmpSheet.caption := entTableDef.description;
	endforeach;

//	self.showSheet(fldConfig.topSheet);
	
//	tblConfig.userInputEnabled := false;
	
end;</source>
    </JadeMethod>
