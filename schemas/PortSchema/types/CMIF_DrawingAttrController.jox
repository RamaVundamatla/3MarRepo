    <JadeMethod name="handleYardAllocation" id="b64bd1b8-f278-4505-a18e-778c7b190829">
        <source>handleYardAllocation(_voy  : CM_Voyage; _isExport : Boolean); //_terminalArea : CM_TerminalArea);
//17 June 2008	cnwdw1	
//
vars
	yalloc : CM_YardAllocation;
begin
	self.allYardAllocations.clear(); // PAR 26322 if the allocations are deleted invalid objects are in this collection.

	foreach yalloc in _voy.allVoyageAllocations discreteLock  do
		if (yalloc.isExportAllocation() &lt;&gt; _isExport) then
			continue;
		endif;
		if yalloc.isDisabled then
			continue;
		endif;
		
		self.allYardAllocations.addNoDuplicates(yalloc,false);
	endforeach;
end;</source>
        <Parameter name="_voy" type="CM_Voyage"/>
        <Parameter name="_isExport" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="saveAllUsedProducts" id="6864b9d9-5399-4eec-9154-6c589a7d3ef0">
        <source>saveAllUsedProducts(pAllProductsObj:CM_ProductByCodeDict);
// --------------------------------------------------------------------------------
// Created:		01 December 2005 by cnwdad1
//
// Purpose:		Updates a collection of Products that are currently "in use" within
//				a Grid Area.  This collection will be refreshed whenever a new area
//				is selected.
//
// Parameters:	pAllProductsObj - A reference to a collection of Products.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.allUsedProducts.clear();
	pAllProductsObj.copy(self.allUsedProducts);
end;</source>
        <Parameter name="pAllProductsObj" type="CM_ProductByCodeDict"/>
    </JadeMethod>
