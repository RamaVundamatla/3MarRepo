    <JadeMethod name="checkModifiedTimestamp" id="9c9fc102-e257-4843-a2c1-f1a257a355e1">
        <source>checkModifiedTimestamp(_line 				: String;
						_modifiedTimeStamp 	: LSModifiedTimeStamp io) : Boolean protected;
/*

Purpose:			For getting modified timestamp within schema files		

Parameters:			_line: 			String		Is an parameter used to hold the current line to check
					_modifiedTimestamp	String	Output variable to hold the resulting modified timestamp info

Return Value:		Boolean: Representing whether this line is a modified timestamp

Date		Who		Reason
30 November 2021	navpw1	Initial creation TFS: 52202

*/

constants
	ModifiedTimestampRegex = "[\s]*setModifiedTimeStamp[\s]*" &amp; '"' &amp; "(?'modifiedBy'.*)" &amp; '"' &amp; "[\s]*" &amp; '"' &amp; "(?'modifiedVersion'.*)" &amp; '"' &amp; "\s{0,1}(?'patchVersion'.*)\s{1}(?'modifiedTimestamp'.*);";
	
vars
	modifiedTimestamp 	: String;
	regexMatch 			: Boolean;
	matches				: JadeRegexMatch;
	
begin
	regexMatch := JadeRegex@match(_line, ModifiedTimestampRegex, true, true, matches);
	
	if not regexMatch then
		_modifiedTimeStamp.setProperties("", "", "", null);
		return regexMatch;
	endif;
	_modifiedTimeStamp.setProperties(matches.getCaptureByName("modifiedBy").value, matches.getCaptureByName("modifiedVersion").value, matches.getCaptureByName("patchVersion").value, matches.getCaptureByName("modifiedTimestamp").value.TimeStamp);
	return regexMatch;
	
epilog
	delete matches;
	
end;</source>
        <access>protected</access>
        <Parameter name="_line" type="String"/>
        <Parameter name="_modifiedTimeStamp" type="LSModifiedTimeStamp" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkSetModifiedTimestamp" id="71438d91-fdc9-41df-9e8b-5750bf7ea040">
        <source>checkSetModifiedTimestamp(_line 		: String;
						_objectToSet	: DEV_SchemaObjectEntity io) : Boolean protected;
/*

Purpose:			For getting modified timestamp within schema files		

Parameters:			_line: 			String						Is a parameter used to hold the current line to check
					_objectToSet	DEV_SchemaObjectEntities	Output variable to return the object we set the timestamp for

Return Value:		Boolean: Representing whether this line is a modified timestamp

Date		Who		Reason
06 December 2021	navpw1	Initial creation TFS: 52202

*/

constants
	ModifiedTimestampRegex = "[\s]*setModifiedTimeStamp[\s]*" &amp; '"' &amp; "(?'modifiedBy'.*)" &amp; '"' &amp; "[\s]*" &amp; '"' &amp; "(?'modifiedVersion'.*)" &amp; '"' &amp; "\s{0,1}(?'patchVersion'.*)\s{1}(?'modifiedTimestamp'.*);";
	
vars
	modifiedTimestamp	: String;
	regexMatch 			: Boolean;
	matches				: JadeRegexMatch;
	modifiedTimeStamp 	: LSModifiedTimeStamp;
begin
	regexMatch := JadeRegex@match(_line, ModifiedTimestampRegex, true, true, matches);
	
	if not regexMatch then
		return regexMatch;
	endif;
	
	create modifiedTimeStamp transient;
	
	modifiedTimeStamp.setProperties(matches.getCaptureByName("modifiedBy").value, matches.getCaptureByName("modifiedVersion").value, 
											matches.getCaptureByName("patchVersion").value, matches.getCaptureByName("modifiedTimestamp").value.TimeStamp);
	_objectToSet.setLastModifiedTimeStamp(modifiedTimeStamp);
	
	return regexMatch;
	
epilog
	delete matches;
	delete modifiedTimeStamp;
	
end;</source>
        <access>protected</access>
        <Parameter name="_line" type="String"/>
        <Parameter name="_objectToSet" type="DEV_SchemaObjectEntity" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="classIsIgnored" id="30ac0288-4325-4db5-8a90-0e34ad6bdc63">
        <source>classIsIgnored(_currentSchema : Schema; _className : String) : Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
22 April 2025	navpw1	Initial creation

*/

vars
	classesToIgnore : StringArray;
	classToIgnore	: String;
	isPrimitive,
	isJadeInterface : Boolean;
	schema : Schema;
	
begin
	schema := _currentSchema;
	create classesToIgnore transient;
	classesToIgnore.add("JadeScript");
	classesToIgnore.add("UT_Template");
	
	//In case we're dealing with JadeScript or a primitive or interface we want to exclude these
	foreach classToIgnore in classesToIgnore do
		//if _className &lt;&gt; classToIgnore then
		//	continue;
		//endif;
		
		if _className = classToIgnore then 
			return true;
		endif;
		
		if classToIgnore = "JadeScript" and 
			_className.startsWith("JadeScript")
		then
			return true;
		endif;
		
	endforeach;
	
	isPrimitive := schema.getPrimitive(_className) &lt;&gt; null;
	if isPrimitive then
		return true;
	endif;
	
	isJadeInterface := schema.getJadeInterface(_className) &lt;&gt; null;
	if isJadeInterface then
		return true;
	endif;
	
	return false;
	
epilog
	delete classesToIgnore;
	
end;</source>
        <access>protected</access>
        <Parameter name="_currentSchema" type="Schema"/>
        <Parameter name="_className" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cleanUpFiles" id="66eded97-1387-4b97-9eb5-c1d9e42458a6">
        <source>cleanUpFiles(_directory, _filename, _targetDir : String; _removeOrigFile, _removeFileReorg, _removeFileReorgCleaned : Boolean) protected;
/*

Purpose:			Cleans up temporary files on the server

Parameters:			_directory:					The directory that needs cleaning
					_filename:					Name of the file to be cleaned
					_targetDir:					The target directory (Folder &amp; Filename) that needs cleaning. (Look into getting the temp directory off of this variable)
					_removeOrigFile:			Should we remove the original file
					_removeFileReorg:			Should we remove the re-organised file
					_removeFileReorgCleaned:	Should we remove the re-organised cleaned file

Return Value:		

Date		Who		Reason
01 November 2021	navpw1	Initial creation TFS: 52202

*/

vars
	origFile			: File;
	ansiFile			: File;
	fileReorg			: File;
	fileReorgCleaned	: File;
	
begin
	if (_removeOrigFile) then
		create origFile transient;
		origFile.usePresentationFileSystem := false;
		origFile.fileName := _targetDir;
		origFile.purge();
		create ansiFile transient;
		ansiFile.usePresentationFileSystem := false;
		ansiFile.fileName := _targetDir &amp; "_ansi";
		ansiFile.purge();
	endif;
	
	if (_removeFileReorg) then
		create fileReorg transient;
		fileReorg.usePresentationFileSystem := false;
		fileReorg.fileName := _directory &amp; "\" &amp; _filename &amp; ".reorganised.scm";
		fileReorg.purge();
	endif;
	
	if (_removeFileReorgCleaned) then
		create fileReorgCleaned transient;
		fileReorgCleaned.usePresentationFileSystem := false;
		fileReorgCleaned.fileName := _directory &amp; "\" &amp; _filename &amp; ".reorganised.scm.cleaned";
		fileReorgCleaned.purge();
	endif;
	
epilog
	if (_removeOrigFile) then
		delete origFile;
		delete ansiFile;
	endif;
	if (_removeFileReorg) then
		delete fileReorg;
	endif;
	if (_removeFileReorgCleaned) then
		delete fileReorgCleaned;
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_directory" type="String"/>
        <Parameter name="_filename" type="String"/>
        <Parameter name="_targetDir" type="String"/>
        <Parameter name="_removeOrigFile" type="Boolean"/>
        <Parameter name="_removeFileReorg" type="Boolean"/>
        <Parameter name="_removeFileReorgCleaned" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cleanUpReports" id="c3819789-57fd-4a81-9153-a5ee4cd4e21e">
        <source>cleanUpReports();
/*

Purpose:			Cleans up Reports from the last x Months (This is defined in DEV_SourceCompareAgent.ReportRetentionPeriodInMonths)

Parameters:			NONE

Return Value:		NONE

Date			Who		Reason
22 July 2022	navpw1	Initial creation

*/

vars
	devSourceCompareRoot 	: DEV_SourceCompareRoot;
	allReports 				: DEV_SourceCompareReports;
	devReport 				: DEV_SourceCompareReport;
	days,
	hours 					: Integer;
	date 					: Date;
	ts 						: TimeStamp;
	dynaDict				: DynaDictionary;
	iter					: Iterator;
	completedOk				: Boolean;
	
begin
	devSourceCompareRoot := DEV_SourceCompareRoot.firstInstance;
	
	if devSourceCompareRoot = null then
		self.logMessage("Could not find Dev Source Compare Root Object: DEV_SourceCompareRoot", LogERROR);
		return;
	endif;
	
	allReports := devSourceCompareRoot.allSourceCompareReports;
	
	days := date.subtract(date.addMonths(DEV_SourceCompareAgent.ReportRetentionPeriodInMonths)).cnDays * -1; //Gets the amount of days for the amount of months we are retaining reports for exactly and multiplies it by -1 to get it as a positive
	
	hours := days * 24; // Gets the amount of hours for the days
	
	ts := ts.subtractHoursAndMinutes(hours);
	
	self.logMessage("Timestamp for report removal: " &amp; ts.String, LogDEBUG);
	
	create dynaDict transient;
	dynaDict.setMembership(DEV_SourceCompareReport);
	dynaDict.addMemberKey(DEV_SourceCompareReport::timeStamp.name, true, false);
	dynaDict.endKeys(false);
	
	iter := allReports.createIterator;
	
	while iter.next(devReport) do
		if devReport.timeStamp &gt; ts and devReport.isAvailable then
			continue;
		endif;
		
		dynaDict.add(devReport);
		
	endwhile;
	
	delete iter;
	
	iter := dynaDict.createIterator;
	
	while iter.next(devReport) do
		self.logMessage("Deleting Report: " &amp; devReport.timeStamp.String, LogDEBUG);
		beginTransaction;
		delete devReport;
		commitTransaction;
	endwhile;
	
	completedOk := true;
	
epilog
	delete dynaDict;
	delete iter;
	
	if not completedOk then
		abortTransaction;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="cleanUpReportsProgress" id="65d50b62-2310-476b-b6da-d46e4b9524e1">
        <source>cleanUpReportsProgress(_cmsProgress : CMS_Progress io);
/*

Purpose:			Cleans up Reports from the last x Months (This is defined in DEV_SourceCompareAgent.ReportRetentionPeriodInMonths)

Parameters:			NONE

Return Value:		NONE

Date			Who		Reason
22 July 2022	navpw1	Initial creation

*/

vars
	devSourceCompareRoot 	: DEV_SourceCompareRoot;
	allReports 				: DEV_SourceCompareReports;
	devReport 				: DEV_SourceCompareReport;
	days,
	hours 					: Integer;
	date 					: Date;
	ts 						: TimeStamp;
	dynaDict				: DynaDictionary;
	iter					: Iterator;
	completedOk				: Boolean;
	countDone				: Integer;
	
begin
	devSourceCompareRoot := DEV_SourceCompareRoot.firstInstance;
	
	if devSourceCompareRoot = null then
		self.logMessage("Could not find Dev Source Compare Root Object: DEV_SourceCompareRoot", LogERROR);
		return;
	endif;
	
	_cmsProgress.setAction("Getting old Source Compare Reports");
	_cmsProgress.progress.partsInJob := 1;
	_cmsProgress.raiseExceptionOnAbort := false;
	
	allReports := devSourceCompareRoot.allSourceCompareReports;
	
	days := date.subtract(date.addMonths(DEV_SourceCompareAgent.ReportRetentionPeriodInMonths)).cnDays * -1; //Gets the amount of days for the amount of months we are retaining reports for exactly and multiplies it by -1 to get it as a positive
	
	hours := days * 24; // Gets the amount of hours for the days
	
	ts := ts.subtractHoursAndMinutes(hours);
	
	self.logMessage("Timestamp for report removal: " &amp; ts.String, LogDEBUG);
	
	create dynaDict transient;
	dynaDict.setMembership(DEV_SourceCompareReport);
	dynaDict.addMemberKey(DEV_SourceCompareReport::timeStamp.name, true, false);
	dynaDict.endKeys(false);
	
	iter := allReports.createIterator;
	
	while iter.next(devReport) do
		if devReport.timeStamp &gt; ts and devReport.isAvailable then
			continue;
		endif;
		
		dynaDict.add(devReport);
		
	endwhile;
	
	delete iter;
	
	if dynaDict.isEmpty then
		self.logMessage("No Reports to delete", LogDEBUG);
		return;
	endif;
	
	_cmsProgress.setAction("Removing old Source Compare Reports");
	_cmsProgress.progress.partsInJob := dynaDict.size;
	_cmsProgress.raiseExceptionOnAbort := false;
	
	iter := dynaDict.createIterator;
	countDone := 0;
	while iter.next(devReport) do
		self.logMessage("Deleting Report: " &amp; devReport.timeStamp.String, LogDEBUG);
		beginTransaction;
		delete devReport;
		commitTransaction;
		countDone += 1;
		_cmsProgress.progress.partsDone := countDone;
	endwhile;
	
	completedOk := true;
	
epilog
	delete dynaDict;
	delete iter;
	
	if not completedOk then
		abortTransaction;
	endif;
	
end;</source>
        <Parameter name="_cmsProgress" type="CMS_Progress" usage="io"/>
    </JadeMethod>
    <JadeMethod name="create" id="8d3ad92a-25e5-4fb6-8b34-64adfb25272f">
        <updating/>
        <source>create() updating;
/*

Purpose:			Creates regex patterns for cleaning files so they can be reused. (Check if these can be removed and replaced with a better way)

Parameters:			

Return Value:		

Date		Who		Reason
20 December 2017	jlgkpd1	Initial creation

*/

vars
	devSourceCompareRoot : DEV_SourceCompareRoot;
	
begin
	//Cleanup Regex Patterns
	self.cleanupRegexPatterns.add(create LSRegexReplace("number", "number[\s]{0,1}=[\s]{0,1}[0-9]*", "number = ", "", true, false) transient);
	self.cleanupRegexPatterns.add(create LSRegexReplace("ordinal", "ordinal[\s]{0,1}=[\s]{0,1}[0-9]*", "ordinal = ", "", true, false) transient);
	self.cleanupRegexPatterns.add(create LSRegexReplace("subId", "subId[\s]{0,1}=[\s]{0,1}[0-9]*", "subId = ", "", true, false) transient);
	self.cleanupRegexPatterns.add(create LSRegexReplace("highestSubId", "highestSubId[\s]{0,1}=[\s]{0,1}[0-9]*", "highestSubId = ", "", true, false) transient);
	self.cleanupRegexPatterns.add(create LSRegexReplace("highestOrdinal", "highestOrdinal[\s]{0,1}=[\s]{0,1}[0-9]*", "highestOrdinal = ", "", true, false) transient);
	self.cleanupRegexPatterns.add(create LSRegexReplace("jadeVersionNumber", 'jadeVersionNumber[\s]{0,1}"[0-9.]*"', 'jadeVersionNumber "', '"', true, false) transient);
	self.cleanupRegexPatterns.add(create LSRegexReplace("patchVersioningEnabled", "patchVersioningEnabled[\s]{0,1}=[\s]{0,1}[a-zA-Z]*", "patchVersioningEnabled = ", "", true, false) transient);
	self.cleanupRegexPatterns.add(create LSRegexReplace("patchVersion", "patchVersion[\s]{0,1}=[\s]{0,1}[0-9]*", "patchVersion = ", "", true, false) transient);
	
	//Global Required Ones
	self.regexPatterns.add(create LSRegexReplace("DocumentationText", "documentationText", null, null, true, false) transient);
	self.regexPatterns.add(create LSRegexReplace("GraveAccentRegex", "`", null, null, false, false) transient);
	self.regexPatterns.add(create LSRegexReplace("ReplaceOneEndCrLfRegex", "[\r\n]{1}$", null, null, true, false) transient);
	self.regexPatterns.add(create LSRegexReplace("ReplaceGraveAccent", "^`{1}|`{1}$", null, null, true, false) transient);
	self.regexPatterns.add(create LSRegexReplace("ModifiedTimeStampRegex", "[\s]*setModifiedTimeStamp[\s]*" &amp; '"' &amp; "(?'modifiedBy'.*)" &amp; '"' &amp; "[\s]*" &amp; '"' &amp; "(?'modifiedVersion'.*)" &amp; '"' &amp; "\s{0,1}(?'patchVersion'.*)\s{1}(?'modifiedTimestamp'.*);", null, null, true, true) transient);
	
	//Schema
	self.regexPatterns.add(create LSRegexReplace("FirstSchemaLineRegex", "(?'schema'[A-Za-z0-9]*)\ssubschemaOf\s(?'subSchema'[A-Za-z]*)\s(?'otherData'[A-za-z0-9\s,=;]*)", null, null, true, true) transient);
	
	//Constant Categories
	self.regexPatterns.add(create LSRegexReplace("ConstantCategoryRegex", "\tcategoryDefinition\s(?'category'[A-Za-z0-9_.,;]*)", null, null, true, true) transient); //&lt;Tab&gt;categoryDefinition &lt;Category&gt;
	self.regexPatterns.add(create LSRegexReplace("CategoryDefinition", "categoryDefinition", null, null, false, false) transient); //&lt;Tab&gt;&lt;Constant&gt;:&lt;ConstantValue&gt;
	
	self.regexPatterns.add(create LSRegexReplace("ConstantRegex", "\s*(?'constantName'[A-Za-z0-9_]*):[\s]*(?'constantType'[Binary|Boolean|Byte|Character|Date|Decimal|Integer|Integer64|Point|Real|String|StringUtf8|Time|Timestamp|TimestampInterval|TimestampOffset]*)[\s]*=[\s]*(?'constantData'.*)", null, null, true, true) transient); //&lt;Tab&gt;&lt;Constant&gt;:&lt;ConstantValue&gt;
	
	create self.reportAgent transient; // ### TFS 52202 08Dec2021 NAVPW1
	
	devSourceCompareRoot := DEV_SourceCompareRoot.firstInstance;
	
	if devSourceCompareRoot = null then
		beginTransaction;
			create devSourceCompareRoot persistent;
		commitTransaction;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="createSections" id="1184c057-3ded-4a8a-8ade-2fe838691c82">
        <source>createSections() protected;
/*

Purpose:			Creates sections used for reading a file. These are removed while a file is processing.
					This Agent is also only created once, so for reuse this must be called

Parameters:			

Return Value:		

Date		Who		Reason
27 October 2021	navpw1	Initial creation TFS: 52202

*/

begin
	sections.clear();
	
	sections.add("schemaDefinition");				// 1.
	sections.add("importedPackageDefinitions");		// 2.
	sections.add("constantDefinitions");			// 3.
	sections.add("localeDefinitions");				// 4.
	sections.add("translatableStringDefinitions");	// 5.
	sections.add("localeFormatDefinitions");		// 6.
	sections.add("libraryDefinitions");				// 7.
	// sections.add("externalFunctionDefinitions");	// 8.
	// sections.add("typeHeaders");					// 9.
	// sections.add("interfaceDefs");				// 10.
	sections.add("membershipDefinitions");			// 11.
	sections.add("typeDefinitions");				// 12.
	sections.add("inverseDefinitions");				// 13.
	sections.add("databaseDefinitions");			// 14.
	sections.add("schemaViewDefinitions");			// 15.
	// sections.add("_exposedListDefinitions");		// 16.
	sections.add("exportedPackageDefinitions");		// 17.
	sections.add("externalFunctionSources");		// 18.
	sections.add("typeSources");					// 19.
	sections.add("memberKeyDefinitions");
	sections.add("externalKeyDefinitions");
	sections.add("interfaceDefs");

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="delete" id="3522676b-0a3f-49b7-92dd-7a4ee94e352f">
        <updating/>
        <source>delete() updating;
/*

Purpose:			Clean up Transients created

Parameters:			

Return Value:		

Date		Who		Reason
20 December 2017	jlgkpd1	Initial creation

*/

begin
	self.cleanupRegexPatterns.purge();
	self.regexPatterns.purge();
	delete self.mySchemaFile;
	delete self.reportAgent; // ### TFS 52202 08Dec2021 NAVPW1
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doGet5Months" id="82da9ea2-0bdb-4875-8261-c450edaef7da">
        <updating/>
        <source>doGet5Months(_fileAndDirectory,
					_schemaFileName 	: String; 
					_writeMethodsToFile : Boolean;
					_reportType			: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 December 2021	navpw1	Initial creation TFS: 52202

*/

vars
	devSchemaSection				: DEV_SchemaGenericSection;
	targetDir, 
	appLogTmpDir					: String;
	currentSchemaData				: Schema;
	currentConstantCategory 		: ConstantCategory;
	currentConstant					: Constant;
	currentClass 					: Class;
	currentAttribute				: Property;
	currentReference				: Reference;
	currentPrimitive				: PrimType;
	currentInterface				: JadeInterface;
	currentMethod 					: Method;
	loadedSchemaFile 				: DEV_Schema;
	loadedSchemaClassesSection 		: DEV_SchemaClassesSection;
	loadedSchemaMethodSection		: DEV_SchemaClassesSection;
	loadedSchemaConstantsSection 	: DEV_SchemaConstantsSection;
	loadedClass						: DEV_Class;
	loadedAttribute					: DEV_Attribute;
	loadedMethod					: DEV_Method;
	loadedConstantCategory			: DEV_GlobalConstantCategory;
	loadedGlobalConstant			: DEV_GlobalConstant;
	loadedConstant					: DEV_ClassConstant;
	loadedReference					: DEV_Reference;
	outputFile 						: File;
	requiredTimeStamp 				: TimeStamp;
	
begin
	if _schemaFileName.cnContains("JMMobileClientBaseSchema") or _schemaFileName.cnContains("TestingDataLoadSchema") then
		return;
	endif;
	
	requiredTimeStamp := requiredTimeStamp.subtractHoursAndMinutes(145 * 24);
	
	self.logMessage("Running Comparison for '" &amp; _fileAndDirectory &amp; "'", LogDEBUG);
	
	//Load the selected schema file
	appLogTmpDir := app.getAppServerLogDir() &amp; '\tmpFiles';
	
	targetDir := app.copyFileToAppServer(_fileAndDirectory);
	
	self.logMessage("File copied from '" &amp; _fileAndDirectory &amp; "' to '" &amp; targetDir &amp; "'", LogDEBUG);
	
	self.createSections();
	
	self.logMessage("Loading Schema File: '" &amp; _schemaFileName &amp; "'", LogDEBUG);
	self.doLoadSchemaFile(targetDir, _schemaFileName);
	self.logMessage("Finished Loading Schema", LogDEBUG);
	
	loadedSchemaFile := self.mySchemaFile.mySchema;
	
	/*
	**	Run class and method comparison between the 2
	*/
	
	//Get Loaded Schema Data
	//Not sure why this exists??????
	//Find the use of typeSources
	if(loadedSchemaFile.allSections.getAtKey("typeSources") &lt;&gt; null) then
		loadedSchemaClassesSection := loadedSchemaFile.allSections.getAtKey("typeSources").DEV_SchemaClassesSection;
	else
		//throw exception
	endif;
	
	//Get Loaded Schema Constant Data
	if(loadedSchemaFile.allSections.getAtKey("constantDefinitions") &lt;&gt; null) then
		loadedSchemaConstantsSection := loadedSchemaFile.allSections.getAtKey("constantDefinitions").DEV_SchemaConstantsSection;
	endif;
	
	if(loadedSchemaFile.allSections.getAtKey("typeDefinitions") &lt;&gt; null) then
		loadedSchemaMethodSection := loadedSchemaFile.allSections.getAtKey("typeDefinitions").DEV_SchemaClassesSection;
	else
		//throw exception
	endif;
	
	//Process each class in schema and check if current schema has the same class
	
	self.logMessage("Checking Schema '" &amp; loadedSchemaFile.name &amp; "'", LogDEBUG);
	
	currentSchemaData := rootSchema.getSchema(loadedSchemaFile.name);
	
	if currentSchemaData = null then
		self.logMessage("Schema not found | " &amp; loadedSchemaFile.name, LogFATAL);
		self.errorsOccurred := true;
		return;
	endif;
	
	/*
	* Global Constant Categories?
	* Global Constants
	*/
	if loadedSchemaConstantsSection &lt;&gt; null then
		foreach loadedConstantCategory in loadedSchemaConstantsSection.allConstantCategories do
			currentConstantCategory := currentSchemaData.getCategory(loadedConstantCategory.name);
			if currentConstantCategory &lt;&gt; null then
				if currentConstantCategory.text &lt;&gt; loadedConstantCategory.documentationTextData 
					and loadedConstantCategory.modifiedTimeStamp &gt; requiredTimeStamp 
				then
					self.reportAgent.createReport(loadedSchemaFile, _reportType);
					self.reportAgent.addGcCategory(loadedSchemaFile.name, loadedConstantCategory, self.reportAgent.Object_Different);
				endif;
				
				foreach loadedGlobalConstant in loadedConstantCategory.allConstants do
					if not loadedGlobalConstant.modifiedTimeStamp &gt; requiredTimeStamp then 		//Check if the last modified timestamp is greater than 7 days ago
						continue; 																//If not continue looping
					else
						currentConstant := currentSchemaData.getConstant(loadedGlobalConstant.name);
						if currentConstant &lt;&gt; null then 
							if currentConstant.text &lt;&gt; loadedGlobalConstant.documentationTextData 
								or currentConstant.getSource() &lt;&gt; loadedGlobalConstant.value
								//currentConstant.type.name &lt;&gt; loadedGlobalConstant.type - Needs implementing
							then
								self.reportAgent.createReport(loadedSchemaFile, _reportType);
								self.reportAgent.addGcCategory(loadedSchemaFile.name, loadedConstantCategory, reportAgent.Object_Link);
								self.reportAgent.addGlobalConstant(loadedSchemaFile.name, loadedGlobalConstant, reportAgent.Object_Different);
								
								self.errorsOccurred := true;
							endif;
			
						else
							self.reportAgent.createReport(loadedSchemaFile, _reportType);
							self.reportAgent.addGcCategory(loadedSchemaFile.name, loadedConstantCategory, reportAgent.Object_Link);
							self.reportAgent.addGlobalConstant(loadedSchemaFile.name, loadedGlobalConstant, reportAgent.Object_Missing);
							
							self.errorsOccurred := true;
						endif;
					endif;
				endforeach;
			else
				self.reportAgent.createReport(loadedSchemaFile, _reportType);
				self.reportAgent.addGcCategory(loadedSchemaFile.name, loadedConstantCategory, reportAgent.Object_Missing);
				
				self.errorsOccurred := true;
			endif;
			
		endforeach;
	endif;
	
	
	/*
	* Classes and Methods/Attributes/Constants check
	*/
	if loadedSchemaMethodSection &lt;&gt; null then
		foreach loadedClass in loadedSchemaMethodSection.allClasses do
			currentClass := currentSchemaData.getClass(loadedClass.name);
			
			if self.classIsIgnored(currentSchemaData, loadedClass.name) then
				continue;
			endif;
			
			if currentClass &lt;&gt; null then 											//If we can find the class then compare it
				if currentClass.text &lt;&gt; loadedClass.documentationTextData then 		//If the documentation text on the class doesn't match then add to differing classes array
					self.reportAgent.createReport(loadedSchemaFile, _reportType);
					self.reportAgent.addClass(loadedSchemaFile.name, loadedClass, self.reportAgent.Object_Different);
					
					self.errorsOccurred := true;
				endif;
				
				/*
				* Attributes
				*/
				foreach loadedAttribute in loadedClass.allAttributes do 					//Loop through attributes
					if not loadedAttribute.modifiedTimeStamp &gt; requiredTimeStamp then 		//Check if the last modified timestamp is greater than 7 days ago
						continue; 															//If not continue looping
					else
						currentAttribute := currentClass.getProperty(loadedAttribute.name); //Get the current attribute from the environment
						if(currentAttribute &lt;&gt; null) then 									//If we can find the attribute then compare it
							if currentAttribute.type.name &lt;&gt; loadedAttribute.type
								or currentAttribute.text &lt;&gt; loadedAttribute.documentationTextData
							then 															//If the documentation text and type on the attribute doesn't match then 
																							//add to differing attributes array
								self.reportAgent.createReport(loadedSchemaFile, _reportType);
								self.reportAgent.addClass(loadedSchemaFile.name, loadedClass, self.reportAgent.Object_Link);
								self.reportAgent.addAttribute(loadedSchemaFile.name, loadedAttribute, self.reportAgent.Object_Different);
								
								self.errorsOccurred := true;
							endif;
						else 																//Add it to the missing attributes array as it does not exist
							self.reportAgent.createReport(loadedSchemaFile, _reportType);
							self.reportAgent.addClass(loadedSchemaFile.name, loadedClass, self.reportAgent.Object_Link);
							self.reportAgent.addAttribute(loadedSchemaFile.name, loadedAttribute, self.reportAgent.Object_Missing);
							self.errorsOccurred := true;
						endif;
					endif;
				endforeach;
				
				/*
				* Constants
				*/
				foreach loadedConstant in loadedClass.allConstants do 						//Loop through constants
					if not loadedConstant.modifiedTimeStamp &gt; requiredTimeStamp then 		//Check if the last modified timestamp is greater than 7 days ago
						continue; 															//If not continue looping
					else
						currentConstant := currentClass.getConstant(loadedConstant.name); 	//Get the current constant from the environment
						if currentConstant &lt;&gt; null then 									//If we can find the constant then compare it
							if currentConstant.type.name &lt;&gt; loadedConstant.type 
								or currentConstant.text &lt;&gt; loadedConstant.documentationTextData 
								or currentConstant.getSource() &lt;&gt; loadedConstant.value
							then 															//If the documentation text, value and type on the constant doesn't match then 
																							//add to differing constants array
								self.reportAgent.createReport(loadedSchemaFile, _reportType);
								self.reportAgent.addClass(loadedSchemaFile.name, loadedClass, self.reportAgent.Object_Link);
								self.reportAgent.addConstant(loadedSchemaFile.name, loadedConstant, self.reportAgent.Object_Different);
								
								self.errorsOccurred := true;
							endif;
						else 																//Add it to the missing constants array as it does not exist
							self.reportAgent.createReport(loadedSchemaFile, _reportType);
							self.reportAgent.addClass(loadedSchemaFile.name, loadedClass, self.reportAgent.Object_Link);
							self.reportAgent.addConstant(loadedSchemaFile.name, loadedConstant, self.reportAgent.Object_Missing);
							self.errorsOccurred := true;
						endif;
					endif;
				endforeach;
				
				/*
				* References
				*/
				foreach loadedReference in loadedClass.allReferences do
					//Loop through references
					if not loadedReference.modifiedTimeStamp &gt; requiredTimeStamp then
						continue;
					endif;
					
					currentReference := currentClass.getProperty(loadedReference.name).Reference; //Get the current constant from the environment
					if currentReference &lt;&gt; null then 									//If we can find the constant then compare it
						if currentReference.type.name &lt;&gt; loadedReference.type 
							or currentReference.text &lt;&gt; loadedReference.documentationTextData 
							//or currentReference.getSource() &lt;&gt; loadedReference.value
						then 															//If the documentation text, value and type on the constant doesn't match then 
																						//add to differing constants array
							self.reportAgent.createReport(loadedSchemaFile, _reportType);
							self.reportAgent.addClass(loadedSchemaFile.name, loadedClass, self.reportAgent.Object_Link);
							self.reportAgent.addReference(loadedSchemaFile.name, loadedReference, self.reportAgent.Object_Different);
							
							self.errorsOccurred := true;
						endif;
					else 																//Add it to the missing constants array as it does not exist
						self.reportAgent.createReport(loadedSchemaFile, _reportType);
						self.reportAgent.addClass(loadedSchemaFile.name, loadedClass, self.reportAgent.Object_Link);
						self.reportAgent.addReference(loadedSchemaFile.name, loadedReference, self.reportAgent.Object_Missing);
						
						self.errorsOccurred := true;
					endif;
				endforeach;
				
				/*
				* Methods
				* Process method comparison for class
				*/
				foreach loadedMethod in loadedClass.allMethods do
					if loadedMethod.name = "translateForm" then
						continue;
					endif;
					
					if not loadedMethod.modifiedTimeStamp &gt; requiredTimeStamp then
						continue;
					else
						currentMethod := currentClass.getMethod(loadedMethod.name);
						if currentMethod &lt;&gt; null then
							//Method Exists in both classes
							if currentMethod.getSource() &lt;&gt; loadedMethod.desc
								or currentMethod.text &lt;&gt; loadedMethod.documentationTextData
							then
								self.reportAgent.createReport(loadedSchemaFile, _reportType);
								self.reportAgent.addClass(loadedSchemaFile.name, loadedClass, self.reportAgent.Object_Link);
								self.reportAgent.addMethod(loadedSchemaFile.name, loadedMethod, self.reportAgent.Object_Different);
								
								self.errorsOccurred := true;
							endif;
						else
							self.reportAgent.createReport(loadedSchemaFile, _reportType);
							self.reportAgent.addClass(loadedSchemaFile.name, loadedClass, self.reportAgent.Object_Link);
							self.reportAgent.addMethod(loadedSchemaFile.name, loadedMethod, self.reportAgent.Object_Missing);
							
							self.errorsOccurred := true;
						endif;
					endif;
				endforeach;
			endif;
		endforeach;
	endif;
	
end;</source>
        <Parameter name="_fileAndDirectory" type="String"/>
        <Parameter name="_schemaFileName" type="String"/>
        <Parameter name="_writeMethodsToFile" type="Boolean"/>
        <Parameter name="_reportType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doGetOldChanges" id="7e14cb3b-0ad3-4e23-82eb-ac2839eecb07">
        <updating/>
        <source>doGetOldChanges(_fileAndDirectory,
					_schemaFileName 	: String; 
					_writeMethodsToFile : Boolean;
					_reportType			: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 June 2022	navpw1	Initial creation

*/

vars
	devSchemaSection				: DEV_SchemaGenericSection;
	targetDir, 
	appLogTmpDir					: String;
	currentSchemaData				: Schema;
	currentConstantCategory 		: ConstantCategory;
	currentConstant					: Constant;
	currentClass 					: Class;
	currentAttribute				: Property;
	currentReference				: Reference;
	currentPrimitive				: PrimType;
	currentInterface				: JadeInterface;
	currentMethod 					: Method;
	loadedSchemaFile 				: DEV_Schema;
	loadedSchemaClassesSection 		: DEV_SchemaClassesSection;
	loadedSchemaMethodSection		: DEV_SchemaClassesSection;
	loadedSchemaConstantsSection 	: DEV_SchemaConstantsSection;
	loadedClass						: DEV_Class;
	loadedAttribute					: DEV_Attribute;
	loadedMethod					: DEV_Method;
	loadedConstantCategory			: DEV_GlobalConstantCategory;
	loadedGlobalConstant			: DEV_GlobalConstant;
	loadedConstant					: DEV_ClassConstant;
	loadedReference					: DEV_Reference;
	outputFile 						: File;
	requiredTimeStamp 				: TimeStamp;
	date : Date;
	time : Time;
begin
	if _schemaFileName.cnContains("JMMobileClientBaseSchema") or _schemaFileName.cnContains("TestingDataLoadSchema") then
		return;
	endif;
	
	//requiredTimeStamp := requiredTimeStamp.subtractHoursAndMinutes(self.DaysForComparison * 24);
	
	date.setDate(1, 1, 2022);
	time.setTime(0, 0, 0, 0);
	requiredTimeStamp.setDate(date);
	requiredTimeStamp.setTime(time);
	
	self.logMessage("Running Comparison for '" &amp; _fileAndDirectory &amp; "'", LogDEBUG);
	
	//Load the selected schema file
	appLogTmpDir := app.getAppServerLogDir() &amp; '\tmpFiles';
	
	targetDir := app.copyFileToAppServer(_fileAndDirectory);
	
	self.logMessage("File copied from '" &amp; _fileAndDirectory &amp; "' to '" &amp; targetDir &amp; "'", LogDEBUG);
	
	self.createSections();
	
	self.logMessage("Loading Schema File: '" &amp; _schemaFileName &amp; "'", LogDEBUG);
	self.doLoadSchemaFile(targetDir, _schemaFileName);
	self.logMessage("Finished Loading Schema", LogDEBUG);
	
	loadedSchemaFile := self.mySchemaFile.mySchema;
	
	/*
	**	Run class and method comparison between the 2
	*/
	
	//Get Loaded Schema Data
	//Not sure why this exists??????
	//Find the use of typeSources
	if(loadedSchemaFile.allSections.getAtKey("typeSources") &lt;&gt; null) then
		loadedSchemaClassesSection := loadedSchemaFile.allSections.getAtKey("typeSources").DEV_SchemaClassesSection;
	else
		//throw exception
	endif;
	
	//Get Loaded Schema Constant Data
	if(loadedSchemaFile.allSections.getAtKey("constantDefinitions") &lt;&gt; null) then
		loadedSchemaConstantsSection := loadedSchemaFile.allSections.getAtKey("constantDefinitions").DEV_SchemaConstantsSection;
	endif;
	
	if(loadedSchemaFile.allSections.getAtKey("typeDefinitions") &lt;&gt; null) then
		loadedSchemaMethodSection := loadedSchemaFile.allSections.getAtKey("typeDefinitions").DEV_SchemaClassesSection;
	else
		//throw exception
	endif;
	
	//Process each class in schema and check if current schema has the same class
	
	self.logMessage("Checking Schema '" &amp; loadedSchemaFile.name &amp; "'", LogDEBUG);
	
	currentSchemaData := rootSchema.getSchema(loadedSchemaFile.name);
	
	if currentSchemaData = null then
		self.logMessage("Schema not found | " &amp; loadedSchemaFile.name, LogFATAL);
		self.errorsOccurred := true;
		return;
	endif;
	
	/*
	* Global Constant Categories?
	* Global Constants
	*/
	if loadedSchemaConstantsSection &lt;&gt; null then
		foreach loadedConstantCategory in loadedSchemaConstantsSection.allConstantCategories do
			currentConstantCategory := currentSchemaData.getCategory(loadedConstantCategory.name);
			if currentConstantCategory &lt;&gt; null then
				if currentConstantCategory.text &lt;&gt; loadedConstantCategory.documentationTextData 
					and loadedConstantCategory.modifiedTimeStamp &lt; requiredTimeStamp 
				then
					self.reportAgent.createReport(loadedSchemaFile, _reportType);
					self.reportAgent.addGcCategory(loadedSchemaFile.name, loadedConstantCategory, self.reportAgent.Object_Different);
				endif;
				
				foreach loadedGlobalConstant in loadedConstantCategory.allConstants do
					if not loadedGlobalConstant.modifiedTimeStamp &lt; requiredTimeStamp then 		//Check if the last modified timestamp is greater than 7 days ago
						continue; 																//If not continue looping
					else
						currentConstant := currentSchemaData.getConstant(loadedGlobalConstant.name);
						if currentConstant &lt;&gt; null then 
							if currentConstant.text &lt;&gt; loadedGlobalConstant.documentationTextData 
								or currentConstant.getSource() &lt;&gt; loadedGlobalConstant.value
								//currentConstant.type.name &lt;&gt; loadedGlobalConstant.type - Needs implementing
							then
								self.reportAgent.createReport(loadedSchemaFile, _reportType);
								self.reportAgent.addGcCategory(loadedSchemaFile.name, loadedConstantCategory, reportAgent.Object_Link);
								self.reportAgent.addGlobalConstant(loadedSchemaFile.name, loadedGlobalConstant, reportAgent.Object_Different);
								
								self.errorsOccurred := true;
							endif;
			
						else
							self.reportAgent.createReport(loadedSchemaFile, _reportType);
							self.reportAgent.addGcCategory(loadedSchemaFile.name, loadedConstantCategory, reportAgent.Object_Link);
							self.reportAgent.addGlobalConstant(loadedSchemaFile.name, loadedGlobalConstant, reportAgent.Object_Missing);
							
							self.errorsOccurred := true;
						endif;
					endif;
				endforeach;
			else
				self.reportAgent.createReport(loadedSchemaFile, _reportType);
				self.reportAgent.addGcCategory(loadedSchemaFile.name, loadedConstantCategory, reportAgent.Object_Missing);
				
				self.errorsOccurred := true;
			endif;
			
		endforeach;
	endif;
	
	
	/*
	* Classes and Methods/Attributes/Constants check
	*/
	if loadedSchemaMethodSection &lt;&gt; null then
		foreach loadedClass in loadedSchemaMethodSection.allClasses do
			currentClass := currentSchemaData.getClass(loadedClass.name);
			
			if self.classIsIgnored(currentSchemaData, loadedClass.name) then
				continue;
			endif;
			
			if currentClass &lt;&gt; null then 											//If we can find the class then compare it
				if currentClass.text &lt;&gt; loadedClass.documentationTextData then 		//If the documentation text on the class doesn't match then add to differing classes array
					self.reportAgent.createReport(loadedSchemaFile, _reportType);
					self.reportAgent.addClass(loadedSchemaFile.name, loadedClass, self.reportAgent.Object_Different);
					
					self.errorsOccurred := true;
				endif;
				
				/*
				* Attributes
				*/
				foreach loadedAttribute in loadedClass.allAttributes do 					//Loop through attributes
					if not loadedAttribute.modifiedTimeStamp &lt; requiredTimeStamp then 		//Check if the last modified timestamp is greater than 7 days ago
						continue; 															//If not continue looping
					else
						currentAttribute := currentClass.getProperty(loadedAttribute.name); //Get the current attribute from the environment
						if(currentAttribute &lt;&gt; null) then 									//If we can find the attribute then compare it
							if currentAttribute.type.name &lt;&gt; loadedAttribute.type
								or currentAttribute.text &lt;&gt; loadedAttribute.documentationTextData
							then 															//If the documentation text and type on the attribute doesn't match then 
																							//add to differing attributes array
								self.reportAgent.createReport(loadedSchemaFile, _reportType);
								self.reportAgent.addClass(loadedSchemaFile.name, loadedClass, self.reportAgent.Object_Link);
								self.reportAgent.addAttribute(loadedSchemaFile.name, loadedAttribute, self.reportAgent.Object_Different);
								
								self.errorsOccurred := true;
							endif;
						else 																//Add it to the missing attributes array as it does not exist
							self.reportAgent.createReport(loadedSchemaFile, _reportType);
							self.reportAgent.addClass(loadedSchemaFile.name, loadedClass, self.reportAgent.Object_Link);
							self.reportAgent.addAttribute(loadedSchemaFile.name, loadedAttribute, self.reportAgent.Object_Missing);
							self.errorsOccurred := true;
						endif;
					endif;
				endforeach;
				
				/*
				* Constants
				*/
				foreach loadedConstant in loadedClass.allConstants do 						//Loop through constants
					if not loadedConstant.modifiedTimeStamp &lt; requiredTimeStamp then 		//Check if the last modified timestamp is greater than 7 days ago
						continue; 															//If not continue looping
					else
						currentConstant := currentClass.getConstant(loadedConstant.name); 	//Get the current constant from the environment
						if currentConstant &lt;&gt; null then 									//If we can find the constant then compare it
							if currentConstant.type.name &lt;&gt; loadedConstant.type 
								or currentConstant.text &lt;&gt; loadedConstant.documentationTextData 
								or currentConstant.getSource() &lt;&gt; loadedConstant.value
							then 															//If the documentation text, value and type on the constant doesn't match then 
																							//add to differing constants array
								self.reportAgent.createReport(loadedSchemaFile, _reportType);
								self.reportAgent.addClass(loadedSchemaFile.name, loadedClass, self.reportAgent.Object_Link);
								self.reportAgent.addConstant(loadedSchemaFile.name, loadedConstant, self.reportAgent.Object_Different);
								
								self.errorsOccurred := true;
							endif;
						else 																//Add it to the missing constants array as it does not exist
							self.reportAgent.createReport(loadedSchemaFile, _reportType);
							self.reportAgent.addClass(loadedSchemaFile.name, loadedClass, self.reportAgent.Object_Link);
							self.reportAgent.addConstant(loadedSchemaFile.name, loadedConstant, self.reportAgent.Object_Missing);
							self.errorsOccurred := true;
						endif;
					endif;
				endforeach;
				
				/*
				* References
				*/
				foreach loadedReference in loadedClass.allReferences do
					//Loop through references
					if not loadedReference.modifiedTimeStamp &lt; requiredTimeStamp then
						continue;
					endif;
					
					currentReference := currentClass.getProperty(loadedReference.name).Reference; //Get the current constant from the environment
					if currentReference &lt;&gt; null then 									//If we can find the constant then compare it
						if currentReference.type.name &lt;&gt; loadedReference.type 
							or currentReference.text &lt;&gt; loadedReference.documentationTextData 
							//or currentReference.getSource() &lt;&gt; loadedReference.value
						then 															//If the documentation text, value and type on the constant doesn't match then 
																						//add to differing constants array
							self.reportAgent.createReport(loadedSchemaFile, _reportType);
							self.reportAgent.addClass(loadedSchemaFile.name, loadedClass, self.reportAgent.Object_Link);
							self.reportAgent.addReference(loadedSchemaFile.name, loadedReference, self.reportAgent.Object_Different);
							
							self.errorsOccurred := true;
						endif;
					else 																//Add it to the missing constants array as it does not exist
						self.reportAgent.createReport(loadedSchemaFile, _reportType);
						self.reportAgent.addClass(loadedSchemaFile.name, loadedClass, self.reportAgent.Object_Link);
						self.reportAgent.addReference(loadedSchemaFile.name, loadedReference, self.reportAgent.Object_Missing);
						
						self.errorsOccurred := true;
					endif;
				endforeach;
				
				/*
				* Methods
				* Process method comparison for class
				*/
				foreach loadedMethod in loadedClass.allMethods do
					if loadedMethod.name = "translateForm" then
						continue;
					endif;
					
					if not loadedMethod.modifiedTimeStamp &lt; requiredTimeStamp then
						continue;
					else
						currentMethod := currentClass.getMethod(loadedMethod.name);
						if currentMethod &lt;&gt; null then
							//Method Exists in both classes
							if currentMethod.getSource() &lt;&gt; loadedMethod.desc
								or currentMethod.text &lt;&gt; loadedMethod.documentationTextData
							then
								self.reportAgent.createReport(loadedSchemaFile, _reportType);
								self.reportAgent.addClass(loadedSchemaFile.name, loadedClass, self.reportAgent.Object_Link);
								self.reportAgent.addMethod(loadedSchemaFile.name, loadedMethod, self.reportAgent.Object_Different);
								
								self.errorsOccurred := true;
							endif;
						else
							self.reportAgent.createReport(loadedSchemaFile, _reportType);
							self.reportAgent.addClass(loadedSchemaFile.name, loadedClass, self.reportAgent.Object_Link);
							self.reportAgent.addMethod(loadedSchemaFile.name, loadedMethod, self.reportAgent.Object_Missing);
							
							self.errorsOccurred := true;
						endif;
					endif;
				endforeach;
			endif;
		endforeach;
	endif;
	
end;</source>
        <Parameter name="_fileAndDirectory" type="String"/>
