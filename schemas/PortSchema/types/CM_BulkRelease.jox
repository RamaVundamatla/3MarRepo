    <JadeMethod name="canUserAccessSelf" id="6c84e467-4f64-4d83-a71c-1544aec7d117">
        <source>canUserAccessSelf(_user: CM_User; _failedDAC: CM_DataAccessController output; _passport: CM_Passport): Boolean;

/*

Purpose:		PAR 20059	

Parameters:			

Return Value:		


Date		Who		Reason
07 July 2009	cnwas3	Initial creation
23 July 2018		jlgrh7 TFS39309 Release Request Search based on data access group
*/

vars
	carrier 		: CM_Carrier;	
	tmpConsignee	: CM_ConsigneeConsignor;	
	tmpCustomAgent					: CM_CustomsAgent;				//+TFS39309
	tmpConsignor							: CM_ConsigneeConsignor;	//+TFS39309
	tmpFreiForwarder 					: CM_ConsigneeConsignor; 	//+TFS39309
	
begin
	tmpConsignee := self.getConsignee();
	if tmpConsignee &lt;&gt; null and (not tmpConsignee.canUserAccessSelf(_user, _failedDAC,  _passport)) then
		return false;
	endif;
			
	if self.myOperator &lt;&gt; null then
		if (not self.myOperator.canUserAccessSelf(_user, _failedDAC, _passport)) then
			return false;
		endif;
	elseif self.myOperatorGroup &lt;&gt; null then
		if (not self.myOperatorGroup.canUserAccessSelf(_user, _failedDAC, _passport)) then
			return false;
		endif;
	endif;

	if self.carrierId &lt;&gt; null then
		carrier := app.myRoot.allCarriers[self.carrierId];
		if carrier &lt;&gt; null then
			if (not carrier.canUserAccessSelf(_user, _failedDAC, _passport)) then
				return false;
			endif;
		endif;
	endif;
	
	//31 May 2016	NDL	TFS 2022
	if self.mySubTerminal &lt;&gt; null then
		if (not self.mySubTerminal.canUserAccessSelf(_user, _failedDAC, _passport)) then
			return false;
		endif;
	endif;
	
	tmpConsignor := self.getConsignor();			//+TFS39309 Starts
	if tmpConsignor &lt;&gt; null and (not tmpConsignor.canUserAccessSelf(_user, _failedDAC,  _passport)) then
		return false;
	endif;
	tmpCustomAgent :=self.getCustomAgent();
	if tmpCustomAgent &lt;&gt; null and (not tmpCustomAgent.canUserAccessSelf(_user, _failedDAC,  _passport)) then
		return false;
	endif;
	tmpFreiForwarder := self.getFreiForwarder();
	if tmpFreiForwarder &lt;&gt; null and (not tmpFreiForwarder.canUserAccessSelf(_user, _failedDAC,  _passport)) then
		return false;
	endif;																			//+TFS39309Ends
	
	
	return inheritMethod(_user, _failedDAC, _passport);

epilog

end;</source>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_failedDAC" type="CM_DataAccessController" usage="output"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="causeUpdateEvent" id="78e41e97-4aa3-455d-9822-96cfd1ce9196">
