// cnwdvb1 10 February 2003 

vars

begin
	return 'bgpAutoViewEmail';

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getValueForRow" id="ddfda205-a764-4ae5-8e4a-f66c2ce24ef3">
        <source>getValueForRow(_rowName: String; _obj : Object output): Any;
// -------------------------------------------
// Created 04 March 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	if _rowName = ETRow_BgpAlertFreq then
		return self.numFailMinutes.String;
	elseif _rowName = ETRow_BgpMinsBeforeAlrt then
		return self.numAlertMinutes;
	endif;
	return inheritMethod(_rowName, _obj);


end;</source>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_obj" type="Object" usage="output"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="6e7f7888-a9ed-4fc7-a6e9-a8283f245ed8">
        <updating/>
        <source>setForCreate(_pxyAutoTask: CM_AutoTaskEmail) updating;

// cnwdvb1 10 February 2003
// 
// 28 May 2013		cnwrs1	ccms 1336 Par 31389 separate BGP EmailRequest to seperate read and send
vars

begin
	inheritMethod(_pxyAutoTask);
	self.requestClassName 		:= BGP_EmailReadRequest.name;
	self.numAlertMinutes 		:= _pxyAutoTask.numAlertMinutes;
	self.numFailMinutes			:= _pxyAutoTask.numFailMinutes;

end;</source>
        <Parameter name="_pxyAutoTask" type="CM_AutoTaskEmail"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="774cd920-8227-434b-acc1-9dd9e06f08d6">
        <updating/>
        <source>setForUpdate(_pxyAutoTask: CM_AutoTaskEmail) updating;
// -------------------------------------------
// Created 04 March 2004 by cnwdvb1
// -------------------------------------------
vars

begin
	inheritMethod(_pxyAutoTask);
	self.numAlertMinutes 	:= _pxyAutoTask.numAlertMinutes;
	self.numFailMinutes		:= _pxyAutoTask.numFailMinutes;

end;</source>
        <Parameter name="_pxyAutoTask" type="CM_AutoTaskEmail"/>
    </JadeMethod>
    <JadeMethod name="setValueForRow" id="99777a45-e2ea-41f6-a90a-f6541473e5e1">
        <updating/>
        <source>setValueForRow(_rowName: String; _value: Any) updating;
// -------------------------------------------
// Created 04 March 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	if _rowName = ETRow_BgpAlertFreq then
		self.numFailMinutes := _value.Integer;
	elseif _rowName = ETRow_BgpMinsBeforeAlrt then
		self.numAlertMinutes := _value.Integer;
	else
		inheritMethod(_rowName, _value);
	endif;

end;</source>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="validate" id="b3993c15-0104-47ed-be79-0f6e9aa6c531">
        <source>validate();
// -------------------------------------------
// Created 15 March 2004 by cnwdvb1
// -------------------------------------------
vars

begin
	inheritMethod();
	if self.numAlertMinutes = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Number of Minutes Before Alert', ETRow_BgpMinsBeforeAlrt, null);
		app.raiseCMException(Input_required_field_mnsBfrAlt, ETRow_BgpMinsBeforeAlrt, null); // cnwdb2	PAR 35364

	endif;
	if self.numFailMinutes = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Number of Minutes Between Alerts', ETRow_BgpAlertFreq, null);
		app.raiseCMException(Input_required_field_minBtnAlt, ETRow_BgpAlertFreq, null);
	
		
	endif;


end;</source>
    </JadeMethod>
</Class>
