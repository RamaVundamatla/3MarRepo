    <JadeMethod name="getReleaseNumber" id="a24c10fd-ef5f-44bd-9610-f329a966a1e5">
        <source>getReleaseNumber() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Aug 2025	naviv1	Initial creation - MTN-35545: FR 35007.020 Display Release Request ID in Vehicle Visit Enquiry

*/

vars
	str : String;
	bulkRelease : CM_BulkRelease;
	gte : CMGTE_Entity;
	invalid  : Boolean;
begin
	on Exception do app.handleDeletedObject( exception, bulkRelease, invalid );
	
	foreach gte in self.allGateEntities where gte.isKindOf(CMGTE_Release) do
		bulkRelease := gte.CMGTE_Release.myBulkRelease;
		if bulkRelease &lt;&gt; null then
			bulkRelease.edition;
			if not invalid then
				str.addStringToList(bulkRelease.code,", ");
			endif;
		endif;
	endforeach;
	return str;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
