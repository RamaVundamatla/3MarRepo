        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_baseForm" type="CM_BaseForm" usage="input"/>
        <Parameter name="_locations" type="String"/>
        <Parameter name="_sheetIndex" type="Integer"/>
        <ReturnType type="CM_YardAllocation"/>
    </JadeMethod>
