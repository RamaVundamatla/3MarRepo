    <JadeMethod name="getCustomStatus" id="b9f9915e-2dd4-4513-b92e-e8e4751c84f5">
        <source>getCustomStatus() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27/09/2023	navkc1	CR 60428 Task 60701: UI - Customs Status on Transport UI

*/

vars
	ti		: CM_TrackedItem;
	str,
	messStr	: String;
begin
	foreach ti in self.allTrackedItems discreteLock do
		
		str := ti.getCustomsStatus();
		
		if str = null then
			continue;
		endif;
		
		/* //04/04/2025	navkc1 JIRA Story MTN-33940
		if messStr = null then
			messStr := str;
		elseif messStr.pos(str, 1) = 0 then
			messStr := messStr &amp; "," &amp; str;
		endif;
		*/ 
		
		messStr.addStringToList(str, ","); //04/04/2025	navkc1 JIRA Story MTN-33940
		
	endforeach;
	
	return messStr;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDateForCustomer" id="d314f531-d122-4deb-aba9-0d29d6ad40b3">
        <source>getDateForCustomer() : Date;
//--------------------------------------------------------------
// Created: 14 August 2002 By: cnwsb1
//--------------------------------------------------------------
vars

begin

	if self.referenceDate = null then
		return dateTime.date;
	else
		return self.referenceDate;
	endif;

end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="getDateShippingLineStopRemoved" id="dcf6d389-de66-4410-8272-fc13afa3153e">
        <source>getDateShippingLineStopRemoved():Date;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 October 2015	cnwndl1	Initial creation	Par 36777

*/

vars

	iter : Iterator;
	bolTrx : CM_BOLTransaction;
	retDate : Date;

begin

	retDate := null;

	iter := self.allBOLTransactions.createIterator;
	while iter.next( bolTrx ) do
		if bolTrx.isKindOf( CM_BOLStopCleared ) then
			retDate := bolTrx.dateTime.Date;
			return retDate;
		endif;
	endwhile;
	
	return retDate;

epilog

end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="getDateTimeLocalTZ" id="27c70f61-02e4-4bb1-aebf-924636b157bb">
        <source>getDateTimeLocalTZ():TimeStamp;
/*

Purpose:			Return the local timezone version of the receiver's dateTime (for JRW)

Parameters:			None

Return Value:		

Date		Who		Reason
19 May 2016	cnwns1	TFS 488 - Multi Timezone Support

*/

vars

begin
	return self.systemToLocalTime(self.dateTime);
	
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getDeliveryOrderNums" id="dfe2b0c4-d5dd-45c3-a0da-00f91cb33680">
        <source>getDeliveryOrderNums( _delOrderNumArray : StringArray input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 October 2015	cnwndl1	Initial creation	Par 36777

*/

vars

	iter : Iterator;
	ti : CM_TrackedItem;
	delOrderNum : String;

begin

	while iter.next( ti ) do
		delOrderNum := ti.customExportEntryNumber.trimBlanks;
		if delOrderNum &lt;&gt; null then
			if not _delOrderNumArray.includes( delOrderNum ) then
				_delOrderNumArray.add( delOrderNum );
			endif;
		endif;
	endwhile;

epilog

delete iter;

end;</source>
        <Parameter name="_delOrderNumArray" type="StringArray" usage="input"/>
    </JadeMethod>
