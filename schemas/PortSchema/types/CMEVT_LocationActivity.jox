    <JadeMethod name="getTypeAsString" id="e1ec3aef-00ae-464a-9972-fe7f23d30ca4">
        <source>getTypeAsString():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

begin

	if self.isLocationBalance then
		return app.getErrorString( LABalance );
	elseif self.isLocationDiscrepancyDecrease then
		return app.getErrorString( LADiscrepancy_decrease );
	elseif self.isLocationDiscrepancyIncrease then
		return app.getErrorString( LADiscrepancy_increase );
	elseif self.isLocationMove then
		return app.getErrorString( LACargo_move );
	endif;
	
	return self.getTypeString;
	
epilog

end;</source>
