    <JadeMethod name="addVoyStatsCancelled" id="fb676a40-a53b-4d53-8d02-ce08ec0531f8">
        <source>addVoyStatsCancelled(_controller: CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 August 2018	jlgndl1	Initial creation	TFS 39924
 11 Oct 2021	jlier1		TFS 51963
*/

vars

	pelindoProcess : CM_VoyageProcess;
	inaPortNetProcess : CM_VoyageProcess;
	inaportnetAction : Boolean;
	rootRole : CM_SecurityRoleTerminalRoot;
	pxyStatus, realStatus : CM_VoyageStatus;

begin

	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Adding 'Voyage Status Cancelled' ", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Adding 'Voyage Status Cancelled'") ;	
	endif;
	
	inaportnetAction := false;

	inaPortNetProcess := app.myRoot.allVoyageProcesses[VoyageProcessInaportnet];
	realStatus := inaPortNetProcess.allStatusesById[Voyage_Status_IVoyCancelled];
	//app.myUtilityUA.setupVoyageStatus(inaPortNetProcess, Voyage_Status_IVoyCancelled, 		520, 	"Voyage Cancelled");	
	if realStatus = null then
		create pxyStatus transient;
		pxyStatus.setProxy(Voyage_Status_IVoyCancelled, 520, "Voyage Cancelled", inaPortNetProcess, null, null,false);
		
		
		beginTransaction;
		app.myUtilityCA.utlCreateVoyageStatus(pxyStatus, realStatus, app.myPassport);
		
		if app.myPassport.noErrors then
			foreach rootRole in CM_SecurityRoleTerminalRoot.instances do
				rootRole.allVoyageStatusesMaint.addNoDuplicates(realStatus, false);
			endforeach;	
			commitTransaction;
		else
			abortTransaction;
			app.writeLog(method.qualifiedName &amp; " Failed to create CM_VoyageStatus Voyage Cancelled!!!", LogINFO);
			app.writeLog(method.qualifiedName &amp; " " &amp; app.myPassport.getErrorsAsString, LogINFO);
		endif;
		
	endif;
	
	pelindoProcess := app.myRoot.allVoyageProcesses[VoyageProcessPelindo1];
	realStatus := pelindoProcess.allStatusesById[Voyage_Status_VoyCancelled];
	//app.myUtilityUA.setupVoyageStatus(pelindoProcess, Voyage_Status_VoyCancelled, 		22, 	"Voyage Cancelled");
	if realStatus = null then
		create pxyStatus transient;
		pxyStatus.setProxy(Voyage_Status_VoyCancelled, 22, "Voyage Cancelled", pelindoProcess, null, null,false);
		
		beginTransaction;
		app.myUtilityCA.utlCreateVoyageStatus(pxyStatus, realStatus, app.myPassport);
		
		if app.myPassport.noErrors then
			foreach rootRole in CM_SecurityRoleTerminalRoot.instances do
				rootRole.allVoyageStatusesMaint.addNoDuplicates(realStatus, false);
			endforeach;	
			commitTransaction;
		else
			abortTransaction;
			app.writeLog(method.qualifiedName &amp; " Failed to create CM_VoyageStatus Voyage Cancelled!!!", LogINFO);
			app.writeLog(method.qualifiedName &amp; " " &amp; app.myPassport.getErrorsAsString, LogINFO);
		endif;
		
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Adding 'Voyage Status Cancelled' complete",LogINFO );
	if _controller &lt;&gt; null then
		_controller.logEntry(" Adding 'Voyage Status Cancelled' complete") ;	
	endif;
	
	self.addScriptRun(method.name);
	
epilog

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
