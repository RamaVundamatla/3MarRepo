    <JadeMethod name="accumulate" id="d6979b5a-d60d-4d40-8992-3dde407771f7">
        <updating/>
        <source>accumulate(kpi : CM_KPITruckByCarrierDay; includeDetail :Boolean) updating ;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 Nov 2025	navbs1	Initial creation	Story MTN-36661: MTN | KPI REST API - Truck Turn Around

*/

vars
	vvr 			: CM_VehicleVisitRecord;
	invalidObject 	: Boolean;
begin
	
	self.dwellTimeMax := self.dwellTimeMax.max(kpi.dwellTimeMax);
	if self.dwellTimeMin = 0 then 
		self.dwellTimeMin := kpi.dwellTimeMin;
	else
		self.dwellTimeMin := self.dwellTimeMin.min(kpi.dwellTimeMin);
	endif;
	self.dwellTimeTotal := self.dwellTimeTotal + kpi.dwellTimeTotal;
	self.numTrucks := self.numTrucks + kpi.numTrucks;
	self.dwellTimeAve := (self.dwellTimeTotal / self.numTrucks).rounded();
	
	if includeDetail then 
		on Exception do app.handleDeletedObject(exception, vvr, invalidObject);
		 foreach vvr in kpi.allVehicleVisitRecords do 
			vvr.edition;
			if invalidObject = true then 
				invalidObject := false;
				continue;
			endif;
			self.allVehicleVisitRecords.tryAdd(vvr);
		 endforeach;	
		 on Exception do null;
	endif;
	
	
epilog

end;</source>
        <Parameter name="kpi" type="CM_KPITruckByCarrierDay"/>
        <Parameter name="includeDetail" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setProxyKPI" id="3fe2c802-5ce2-4e87-b028-bc71a8367453">
        <updating/>
        <source>setProxyKPI(_term : CM_Terminal;_code : String; _ts : TimeStamp; _type : Integer; _user : String) updating;
// ---------------------------------------------------------------------------
// Created:		13 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	
	// PAR 16390 - changes for dwell to minutes and tidy up
	
	inheritMethod(_term, _code, _ts, _type, _user);
	
	self.dictYear := self.dateTime.date.year();
	self.dictMonth := self.dateTime.date.month();
	self.dictDay := self.dateTime.date.day();
end;</source>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_code" type="String"/>
        <Parameter name="_ts" type="TimeStamp"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_user" type="String"/>
    </JadeMethod>
    <JadeMethod name="updateCarrier" id="0773f2b5-5eb1-4055-a97c-3f958c0f6ac9">
        <updating/>
        <source>updateCarrier(_visit : CM_VehicleVisitRecord) updating;
// ---------------------------------------------------------------------------
// Created:		14 February 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin

	self.myCarrier := _visit.getMyCarrier();
	
end;</source>
        <Parameter name="_visit" type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="updateFromVisitRecord" id="2d403cd0-5fbc-4b97-ae02-1eb8c450ed1c">
        <updating/>
        <source>updateFromVisitRecord(_visit : CM_VehicleVisitRecord) updating;
// ---------------------------------------------------------------------------
// Created:		14 February 2008 By Andrew Bishop cnwab1
//
// Changes :	PAR 16390 - change to dwell from time to integer	
//
// ---------------------------------------------------------------------------
vars
	dwell : Integer;
begin

	// duplicates by timestamp are allowed, but not the same object. 
	//	This method is called by the cargo truck KPI as well so the 
	// object could well be passed in more than once.
	if not self.allVehicleVisitRecords.includes(_visit) then
		self.allVehicleVisitRecords.add(_visit);
	endif;
	
	self.numTrucks := self.numTrucks + 1;
		
	dwell := _visit.dwellTimeMinutes;
	
	if dwell &gt; 0 then
		// PAR 16390 - changes for dwell to minutes 
		// dwellTimeMin should never get set to 0 if we have some detail records
		if self.dwellTimeMin = 0 then
			self.dwellTimeMin := dwell;
		else
			self.dwellTimeMin := self.dwellTimeMin.min(dwell);
		endif;
	endif;
	
	self.dwellTimeMax := self.dwellTimeMax.max(dwell);
	self.dwellTimeTotal := self.dwellTimeTotal + dwell;
	self.dwellTimeAve := (self.dwellTimeTotal / self.numTrucks).rounded();
	
	
end;</source>
        <Parameter name="_visit" type="CM_VehicleVisitRecord"/>
    </JadeMethod>
</Class>
