<CollClass name="CM_ContentsStatbyCodeAbbColour" id="9e4826e0-e9f0-4923-8982-95d1b42a249d">
    <memberType name="CM_ContentsStatus"/>
    <superclass name="CM_MemberKeyDictionary"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <MemberKey>
        <property name="CM_CargoStatus::code"/>
    </MemberKey>
    <MemberKey>
        <property name="CM_CargoStatus::abbreviation"/>
    </MemberKey>
    <MemberKey>
        <property name="CM_CargoStatus::colour"/>
    </MemberKey>
    <JadeMethod name="removeObject" id="6845398f-f767-4c37-aae4-ad4762f94aff">
        <lockReceiver/>
        <updating/>
        <source>removeObject(_obj : MemberType) : Boolean updating, lockReceiver;
// ---------------------------------------------------------------------------
// Created:     27 May 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	iter	: Iterator;
	tmpObj	: MemberType;
	keyCode	: Integer;
	keyAbbr	: String;
	keyNum	: Integer;
begin
	iter := self.createIterator();
	
	while iter.next(tmpObj) do
		if tmpObj = _obj then
			self.getIteratorKeys(keyCode, keyAbbr, keyNum, iter);
			self.removeKey(keyCode, keyAbbr, keyNum);
			return true;
		endif;
	endwhile;

	return false;

epilog
	delete iter;
end;</source>
        <Parameter name="_obj" type="MemberType"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</CollClass>
