<PrimType name="Real">
    <JadeMethod name="jtdRoundedSeconds" id="3f1f0e9f-ac80-4b2e-9c90-f91245fb846b">
        <source>jtdRoundedSeconds() : Real;

begin
	if self &lt; 0 then
		return self.roundedTo(1);
	endif;
	
	if self &lt; 1000 then
		return self.roundedTo(2);
	endif;
	
	if self &lt; 10000 then
		return self.roundedTo(1);
	endif;
	
	return self.roundedTo(0);
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
</PrimType>
