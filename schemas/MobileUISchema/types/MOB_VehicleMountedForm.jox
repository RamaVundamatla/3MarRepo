    <JadeMethod name="setupTwinLiftLabels" id="f440c530-cca6-4796-8781-165c623392ba">
        <source>setupTwinLiftLabels(_firstEntry, _twinEntry : DTO_RTQueueEntry; _firstCargoId, _secondCargoId : String) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 June 2011	#cnwdz2	 27732

*/

vars
	firstEntryLc,
	secondEntryLc		: CM_LocationsController;
	firstEntryStackPos,
	secondEntryStackPos : Real;
	tmpTA				: CM_GridArea;
	firstCargoId,
	secondCargoId		: String;
begin

	//27/06/2011 cnwdz2 27732		
	if _firstCargoId &lt;&gt; null and _secondCargoId &lt;&gt; null then
		self.myMoveTableDetails.addDataForEntRowName(ETRow_CargoID, _firstCargoId);
		self.myMoveTableDetails.addDataForEntRowName(ETRow_TwinID, _secondCargoId);
	else	
		firstEntryLc := _firstEntry.getLocationSource;
	
		if firstEntryLc = null or (not firstEntryLc.isKindOf(CM_GridController)) then
			return;
		endif;
		
		secondEntryLc := _twinEntry.getLocationSource;
		
		if secondEntryLc = null then  //cnwrd1 par 32293
			return;
		endif;
		
		if self.myMachine.machineType = MACHINETYPE_STRADDLE then			
			if firstEntryLc.myTerminalArea = secondEntryLc.myTerminalArea and 
			   firstEntryLc.CM_GridController.row = secondEntryLc.CM_GridController.row then
				firstCargoId  := self.myMoveTableDetails.getDataForEntRowName(ETRow_CargoID).String;
				secondCargoId := self.myMoveTableDetails.getDataForEntRowName(ETRow_TwinID).String;
				self.myMoveTableDetails.addDataForEntRowName(ETRow_CargoID, firstCargoId &amp; " (" &amp; app.getErrorString(TwinLift_Front) &amp; ")");
				self.myMoveTableDetails.addDataForEntRowName(ETRow_TwinID, secondCargoId &amp; " (" &amp; app.getErrorString(TwinLift_Back) &amp; ")");						
			endif;
		elseif self.myMachine.machineType = MACHINETYPE_FORK_LIFT or 
		       self.myMachine.machineType = MACHINETYPE_SIDE_LOADER then			
			if firstEntryLc.myTerminalArea = secondEntryLc.myTerminalArea and 
			   firstEntryLc.CM_GridController.row = secondEntryLc.CM_GridController.row then
				firstCargoId  := self.myMoveTableDetails.getDataForEntRowName(ETRow_CargoID).String;
				secondCargoId := self.myMoveTableDetails.getDataForEntRowName(ETRow_TwinID).String;
				if firstEntryLc.CM_GridController.column &lt; secondEntryLc.CM_GridController.column then
					self.myMoveTableDetails.addDataForEntRowName(ETRow_CargoID, firstCargoId &amp; " (" &amp; app.getErrorString(TwinLift_Left) &amp; ")");
					self.myMoveTableDetails.addDataForEntRowName(ETRow_TwinID, secondCargoId &amp; " (" &amp; app.getErrorString(TwinLift_Right) &amp; ")");
				elseif secondEntryLc.CM_GridController.column &lt; firstEntryLc.CM_GridController.column then
					self.myMoveTableDetails.addDataForEntRowName(ETRow_CargoID, firstCargoId &amp; " (" &amp; app.getErrorString(TwinLift_Right) &amp; ")");
					self.myMoveTableDetails.addDataForEntRowName(ETRow_TwinID, secondCargoId &amp; " (" &amp; app.getErrorString(TwinLift_Left) &amp; ")");
				endif;				
			endif;
		endif;
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_firstEntry" type="DTO_RTQueueEntry"/>
        <Parameter name="_twinEntry" type="DTO_RTQueueEntry"/>
        <Parameter name="_firstCargoId" type="String"/>
        <Parameter name="_secondCargoId" type="String"/>
    </JadeMethod>
    <JadeMethod name="setupWeightInterface" id="e638e30a-a891-4832-a64d-6629e39ba2a8">
        <updating/>
        <source>setupWeightInterface() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 Jun 2010	cnwer1	Initial creation
13 Jul 2016	cnwkpd1	Create test Loadrite Weighing Interface

*/

constants

vars
	device 			: CM_RadioTelemetryDevice;
	profileString	: String;
	iniFileName		: String;
	
begin
	device:=app.myVMAgent.myRTDevice;
	
	if not device.canDoLoadriteWeighing then
		return;
	endif;
	// In development only, check ini file for dummy weighing interface
	executeWhen JMTDevelopmentEnvironment;
	iniFileName := app.getIniFileName();
	profileString := app.getProfileString(iniFileName, "VehicleMountedApp", "SimulateWeighingInterface", "&lt;not set&gt;");
	if profileString = "&lt;not set&gt;" then
		app.setProfileString(iniFileName, "VehicleMountedApp", "SimulateWeighingInterface", true.String);
		profileString := true.String;
	endif;
	if profileString.Boolean then
		create self.myWeightInterfaceController as CM_WeightInterfaceControllerXX transient;
	endif;
	app.msgBox("Dev only simulation is in use, run app DevSchema MachineWeighSimulator to activate", "Weighing Simulation", MsgBox_OK_Only);
	endExecuteWhen;
	
	if self.myWeightInterfaceController = null then
		create self.myWeightInterfaceController transient;
	endif;
	
	//create self.myWeightInterfaceController transient;
	self.myWeightInterfaceController.initializeWithSerialDetails(device.myWinCESerialDetails);
	self.myWeightInterfaceController.setWeightCallerInterface(self.IF_WeightCallerInterface);
	
	self.hasWeightInterfaceError:=false;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="shouldShowAccessForkLiftStack" id="715cd818-650d-4710-a608-bf8153835396">
        <source>shouldShowAccessForkLiftStack(_entry : DTO_RTQueueEntry) : String protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 Jun 2011	#cnwdz2	 27732
29 May 2012 cnwer1	PAR 29588
*/

vars
	lc 				: CM_LocationsController;
	tmpTA			: CM_GridArea;
	forkLiftStack   : CM_ForkLiftStack;
	ti              : CM_TrackedItem;
	access          : String;
	qEntry 			: CM_RTQueueEntry;
	overstowController : CMIF_OverstowController;
	accessDirection : Integer;
begin
	lc :=  _entry.getLocationSource;
	if lc &lt;&gt; null and lc.isKindOf(CM_GridController) then
		tmpTA := lc.getMyTerminalArea().CM_GridArea;
		if tmpTA &lt;&gt; null and tmpTA.isKindOf(CM_ForkLiftStack) then
			forkLiftStack := tmpTA.CM_ForkLiftStack;
			ti := _entry.getTI();
			qEntry := _entry.myRealQueueEntry.CM_RTQueueEntry;
			if qEntry &lt;&gt; null and ti &lt;&gt; null then	//07 Oct 2014	NDL	Par 35016
				if forkLiftStack.accessBack and forkLiftStack.accessFront then
					//epr TFS 37584 4/5/18
					create overstowController transient;
					overstowController.setParams(accessDirection,ti,true,qEntry,self.myMachine);
					overstowController.getAllOverstows;
					if overstowController.accessDirection =  CM_YABlock.SideAccess_Front then
						access := app.getErrorString1(Access_Side, forkLiftStack.bottomLabel);
					else
						access := app.getErrorString1(Access_Side, forkLiftStack.topLabel );
					endif;
				
				elseif forkLiftStack.accessBack then
					access := app.getErrorString1(Access_Side, forkLiftStack.topLabel );
				elseif forkLiftStack.accessFront then
					access := app.getErrorString1(Access_Side, forkLiftStack.bottomLabel);
				endif;
			endif;				
		endif;
	endif;
	return access;
epilog

	delete overstowController;
end;</source>
        <access>protected</access>
        <Parameter name="_entry" type="DTO_RTQueueEntry"/>
        <ReturnType type="String"/>
    </JadeMethod>
