    <JadeMethod name="drawTI" id="402bbef9-fedd-47b2-b14b-9006b79fb07a">
        <updating/>
        <source>drawTI(_theTI : CM_TrackedItem; _theGridAttributes : CMUI_GridAttributes input;
		_x1, _y1, _x2, _y2 : Real;
		_frame : YRD_ContainerDrawingFrame input;  _lc : CM_LocationsController) updating, protected;
// ---------------------------------------------------------------------------
// Created:		January  2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 11/11/2019	jlgdap1		TFS 46405 AT Flat Rack and OOG in LOLO Planning Screen
vars
	theFrame: YRD_ContainerDrawingFrame;
	lTIColour, theInverseColour : Integer;
	theTI : CM_TrackedItem ;
	fm : CM_FutureMove;
begin
	theTI := _theTI;
	
	if theTI = null then
		return;
	endif;

	if self.displayMode = DISPLAY_MODE_ACTUAL then
		if self.gridObjectsGetAtKeyForPut(_x1.Integer, _y1.Integer, _x2.Integer, _y2.Integer) = null then 
			self.gridObjectsPutAtKey(_x1.Integer, _y1.Integer, _x2.Integer, _y2.Integer, _theTI); 
		endif;
	elseif self.displayMode = DISPLAY_MODE_QUEUE then
		fm := _theTI.getFutureMoveForLC(QUEUE_MODE, self.myLocationsController); 
		if fm &lt;&gt; null then
			if self.gridObjectsGetAtKeyForPut(_x1.Integer, _y1.Integer, _x2.Integer, _y2.Integer) = null then		
				self.gridObjectsPutAtKey(_x1.Integer, _y1.Integer, _x2.Integer, _y2.Integer, fm); 
			endif;
		endif;
	elseif self.displayMode = DISPLAY_MODE_PLAN then
		fm := _theTI.getFutureMoveForLC(PLANNING_MODE, self.myLocationsController);
		if fm &lt;&gt; null then
			if self.gridObjectsGetAtKeyForPut(_x1.Integer, _y1.Integer, _x2.Integer, _y2.Integer) = null then		
				self.gridObjectsPutAtKey(_x1.Integer, _y1.Integer, _x2.Integer, _y2.Integer, fm); 
			endif;
		endif;
	endif;
	
	theFrame := _frame;
	theFrame.drawFontSize := 8;
	
	self.myTrackedItem := theTI;
	lTIColour := self.getFillColourForTI(theTI);
	if self.useSelectorObjects and not self.allSelectorTIs.includes(theTI) then
		lTIColour := White;
	endif;
	
	theInverseColour := lTIColour.getInverseColour();

	self.drawBackground(theFrame,_x1, _y1, _x2, _y2);
	
	if self.drawBackEnd then
		self.drawBackendAtt(theTI, theFrame,_x1, _y1, _x2, _y2, theInverseColour);
		return;
	endif;
	
	theFrame.drawFillColor := lTIColour;

	self.drawMainCode(theTI, _x1, _y1, _x2, _y2 , theFrame,theInverseColour);

	// #############
	if self.scaleFactor &lt; 2  then
		return;
	endif;
	if theTI &lt;&gt; null and theTI.isOverSizedContainer() then
		self.drawOverSizedMark(theFrame, theTI, lTIColour,  _x1, _y1, _x2,_y2); 
	endif;
		
	// Draw the attributes (if any)
	//self.drawIcons(theTI, theFrame,_x1,y1, theInverseColour);				// TFS 46405
	self.drawIcons(theTI, theFrame,_x1,y1, theInverseColour, false);		// TFS 46405
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_theGridAttributes" type="CMUI_GridAttributes" usage="input"/>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_y2" type="Real"/>
        <Parameter name="_frame" type="YRD_ContainerDrawingFrame" usage="input"/>
        <Parameter name="_lc" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="drawTIOverstow" id="db77a45c-89a1-4892-9da6-583eeacaece5">
        <updating/>
        <source>drawTIOverstow(_theTI : CM_TrackedItem; _theGridAttributes : CMUI_GridAttributes input;
		_x1, _y1, _x2, _y2 : Real;
		_frame : YRD_ContainerOStowDrawingFrame input) updating, protected;
// ---------------------------------------------------------------------------
// Created:		January  2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 11/11/2019	jlgdap1		TFS 46405 AAT Flat Rack and OOG in LOLO Planning Screen
vars
	theFrame			: YRD_ContainerOStowDrawingFrame;
	lTIColour, idx,
	theInverseColour	: Integer;
	lFactor				: Real;
	theTI				: CM_TrackedItem;
begin
	theTI := _theTI;
	
	if theTI = null then
		return;
	endif;
	
	if self.gridObjectsGetAtKeyForPut(_x1.Integer, _y1.Integer, _x2.Integer, _y2.Integer) = null then 
		self.gridObjectsPutAtKey(_x1.Integer, _y1.Integer, _x2.Integer, _y2.Integer, _theTI); 
	endif;

	theFrame := _frame;
	theFrame.drawFontSize := 8;
	
	self.myTrackedItem := theTI;
	lTIColour := self.getFillColourForTI(theTI);
	if self.useSelectorObjects and not self.allSelectorTIs.includes(theTI) then
		lTIColour := White;
	endif;
	
	theInverseColour := lTIColour.getInverseColour();

	self.drawBackground(theFrame,_x1, _y1, _x2, _y2);
	
	if self.drawBackEnd then
		self.drawBackendAtt(theTI, theFrame,_x1, _y1, _x2, _y2, theInverseColour);
		return;
	endif;
	
	lFactor := self.scaleFactor;

	theFrame.drawFillColor := lTIColour;

	self.drawMainCode(theTI, _x1, _y1, _x2, _y2 , theFrame,theInverseColour);

	if lFactor &lt; 2  then
		return;
	endif;
	
	// Draw the attributes (if any)
	//self.drawIcons(theTI, theFrame,_x1,y1, theInverseColour);				// TFS 46405
	self.drawIcons(theTI, theFrame,_x1,y1, theInverseColour, false);		// TFS 46405
end;</source>
        <access>protected</access>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_theGridAttributes" type="CMUI_GridAttributes" usage="input"/>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_y2" type="Real"/>
        <Parameter name="_frame" type="YRD_ContainerOStowDrawingFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawTransformer" id="097f7bc0-dea5-4de0-b25f-6cfa965517a9">
        <source>drawTransformer();
// ---------------------------------------------------------------------------
// Created:		17 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	self.myDrawingFrame.drawFillColor := White;
	self.myDrawingFrame.drawWidth := self.scaleFactor.Integer;
	self.myDrawingFrame.drawFilledRectangle(self.x1,self.y1,self.x2,self.y2,Blue);
epilog
	self.myDrawingFrame.drawWidth := 1;

end;</source>
    </JadeMethod>
    <JadeMethod name="drawYardAllocationLinesForRow" id="84473bfb-7370-4b15-8bb3-17c746d0e018">
        <source>drawYardAllocationLinesForRow(_column: CM_GridColumn; _yaTop: Integer; _oldHeight: Integer): Integer;

/*

Purpose:			Draw Yard Allocations for given Grid Column.
					Yard Allocations are also added to associated YAMTable.

Parameters:			_yaTop contains the position to commence drawing the Yard Allocation lines.
					_oldHeight contains the current height of the draw area for the given row's Yard Allocation lines.

Return Value:		The new height of the draw area for the given row's Yard Allocation lines.


Date				Who		Reason
11 December 2008	consw1	SWF1030 - Initial creation

*/

constants
	LineHeight 		= 3;

vars
	colDepthArray	: IntegerArray;
	controllers		: CM_GridControllersByRow;
	idx				: Integer;
	lc1, lc2 		: CM_GridController;
	newHeight		: Integer;
	tmpLC			: CM_GridController;
	ya				: CM_YardAllocation;
	yaDepth			: Integer;
	yaDepthArray	: IntegerArray;
	yaSet			: CM_YardAllocationSet;
	yaByPriority	: CM_YAByPriorityDict;


begin
	create controllers transient;
	create colDepthArray transient;
	create yaDepthArray transient;
	create yaSet transient;
	create yaByPriority transient;
	
	//  Get Yard Allocations for row

	foreach tmpLC in _column.allControllersByRow where tmpLC.row &gt;= self.minRow do
		if tmpLC.row &gt; self.maxRow then
			break;
		endif;
		controllers.add(tmpLC);
		foreach ya in tmpLC.allYardAllocations where ya.myTerminal &lt;&gt; null and not ya.isDisabled and not yaSet.includes(ya) do
			if self.allYardAllocationsFilter.isEmpty
			or self.allYardAllocationsFilter.includes(ya) then
				yaSet.add(ya);
			endif;
		endforeach;
		colDepthArray[tmpLC.row] := 0;
	endforeach;
	
	if yaSet.isEmpty then
		//  Old height retained when larger to avoid need to redraw whole frame
		newHeight := _oldHeight.max( LineHeight * 2 );
		self.allYARows.putAtKey(0, _yaTop, 0, _yaTop + newHeight, _column);
		return newHeight;
	endif;

	//  Update associated YAM table
	
	if self.myYAMTable &lt;&gt; null then
		foreach ya in yaSet where not self.myYAMTable.allYardAllocationsByPriority.includes(ya) do
			self.myYAMTable.addItemYardAllocation(ya);
		endforeach;
	endif;
	
	//  Yard Allocations are ordered in priority sequence when there are multiple occurrences for a location
	
	yaSet.copy(yaByPriority);

	foreach ya in yaByPriority do
		yaDepth := 1;
		foreach tmpLC in controllers where tmpLC.allYardAllocations.includes(ya) do
			yaDepth := yaDepth.max( colDepthArray[tmpLC.row] + 1 );
		endforeach;
		foreach tmpLC in controllers where tmpLC.allYardAllocations.includes(ya) do
			colDepthArray[tmpLC.row] := yaDepth;
		endforeach;
		yaDepthArray.add(yaDepth);
	endforeach;

	//  Display Yard Allocations
	
	idx := 0;
	newHeight := 0;
		
	foreach ya in yaByPriority do
		idx := idx + 1;
		lc1 := null;
		lc2 := null;
		foreach tmpLC in controllers where tmpLC.allYardAllocations.includes(ya) do
			if lc2 = null then
				lc1 := tmpLC;
			elseif tmpLC.row &lt;&gt; lc2.row + 1 then
				self.drawSelfYardAllocationLine( ya, lc1, lc2, _yaTop, yaDepthArray[idx], LineHeight, newHeight );
				lc1 := tmpLC;
			endif;
			lc2 := tmpLC;
		endforeach;
		if lc2 &lt;&gt; null then
			self.drawSelfYardAllocationLine( ya, lc1, lc2, _yaTop, yaDepthArray[idx], LineHeight, newHeight );
		endif;
	endforeach;

	//  Save off position details
	
	if newHeight &lt; _oldHeight then
		//  Old height retained when larger to avoid need to redraw whole frame
		newHeight := _oldHeight;
	elseif newHeight &gt; _oldHeight then
		//  Include an extra line to avoid need to redraw whole frame when next Yard Allocation created/extended
		newHeight := newHeight + LineHeight;
	endif;

	self.allYARows.putAtKey(0, _yaTop, 0, _yaTop + newHeight, _column);

	return newHeight;

epilog
	self.myDrawingFrame.drawWidth := 1; // PAR 18682
	
	delete controllers;
	delete colDepthArray;
	delete yaDepthArray;
	delete yaSet;
	delete yaByPriority;
end;</source>
        <Parameter name="_column" type="CM_GridColumn"/>
        <Parameter name="_yaTop" type="Integer"/>
        <Parameter name="_oldHeight" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
