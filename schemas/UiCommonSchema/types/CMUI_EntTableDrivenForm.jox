    <JadeMethod name="doOpenCloseSection" id="0fce1739-5ed4-49ae-b3ef-092153e296e6">
        <updating/>
        <source>doOpenCloseSection(_sectionFrame, _nextSectionFrame : CMUI_FieldFrame; _button : CMUI_Button input; _opening : Boolean io) updating, protected;
/*
Purpose:			Open and close sections of the form marked with CMUI_FieldFrame controls with open/close buttons
					Example code shows use of local attribute Boolean and label for each section - your
					form should do the same, then inheritMethod to pick up the automatic open/close function

Parameters:			_sectionFrame - frame that is being closed/opened
					_nextSectionFrame - next heading frame on the form (so we know when to stop the opening/closing)
					_picture - the picture control clicked by the user (the control that contains the open/close arrow)

Return Value:		None

Date		Who		Reason
21 July 2009	cnwdap1	Initial creation
*/
vars
	frame 						: CMUI_FieldFrame;
	ctrlCount, increase, rows	: Integer;
	counting, moving			: Boolean;
	parentWindow				: Window;
	lowestTop					: Real;
	diff						: Real;

begin
	// are we opening or closing
	// EXAMPLE - YOUR FORM SHOULD DO SIMILAR AND THEN inheritMethod
/*	if _sectionFrame = self.lblAddDetails then
		_opening := self.closedAdditional;
		self.closedAdditional := not _opening;
	elseif _sectionFrame = self.lblCargoDetails then
		_opening := self.closedCargo;
		self.closedCargo := not _opening;
	elseif _sectionFrame = self.lblDimensions then
		_opening := self.closedDimensions;
		self.closedDimensions := not _opening;
	elseif _sectionFrame = self.lblReeferDetails then
		_opening := self.closedReefer;
		self.closedReefer := not _opening;
	elseif _sectionFrame = self.lblVoyageDetails then
		_opening := self.closedVoyage;
		self.closedVoyage := not _opening;
	endif;	*/

	// read all field frame controls looking for the section we're closing/opening
	counting := false;
	foreach frame in self.allFieldFrames do
		// record the parent of the field frame - this could be a group, another frame or a form
		parentWindow := frame.parent;
		
		if counting then
			ctrlCount := ctrlCount + 1;
			
			// make visible or invisible depending on whether we're opening or closing
			if _opening then
				frame.visible := true;
			else
				frame.visible := false;
			endif;
		endif;
		
		if frame = _sectionFrame then
			counting := true;
		elseif frame = _nextSectionFrame then
			counting := false;
			frame.visible := true;		// section frames are always visible
			ctrlCount := ctrlCount - 1;
		endif;
	endforeach;
	
	// we know how many controls in this section - work out how many rows this is
	rows := (ctrlCount / self.numberOfColumns).Integer;
	if ctrlCount mod self.numberOfColumns &lt;&gt; 0 then
		rows := rows + 1;
	endif;
	
	if _opening then
		increase := rows * self.PADDING_PER_ROW;
	else
		increase := rows * self.PADDING_PER_ROW * -1;
	endif;
	
	// swap pictures around
	_button.pictureDown 		:= _button.picture;
	_button.picture 			:= _button.pictureDisabled;
	_button.pictureDisabled		:= _button.pictureDown;
	_button.pictureDown 		:= null;
	
	// adjust control positions and parent height
	// all controls after the "next control" need to move up or down by the "increase" value
	foreach frame in self.allFieldFrames where frame.visible and not frame.isHidden do
		if frame = _nextSectionFrame then
			moving := true;
			diff := (frame.top - (lowestTop + self.PADDING_PER_ROW));
			if not _opening or (_opening and diff &lt; 0) then
				diff := diff * -1;
			endif;
			frame.top := lowestTop + self.PADDING_PER_ROW;
		endif;
		
		if moving and frame &lt;&gt; _nextSectionFrame then
			frame.top := frame.top + diff;
		endif;
		
		if not moving and frame.top &gt; lowestTop then
			lowestTop := frame.top;
		endif;
	endforeach;
	
	if parentWindow &lt;&gt; null then
		parentWindow.height := parentWindow.height + diff;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_sectionFrame" type="CMUI_FieldFrame"/>
        <Parameter name="_nextSectionFrame" type="CMUI_FieldFrame"/>
        <Parameter name="_button" type="CMUI_Button" usage="input"/>
        <Parameter name="_opening" type="Boolean" usage="io"/>
    </JadeMethod>
