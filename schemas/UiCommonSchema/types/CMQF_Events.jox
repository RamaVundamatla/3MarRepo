<Class name="CMQF_Events">
    <JadeMethod name="setFromAgent" id="d0eece80-568d-4740-ba09-9b0f6b1516e0">
        <updating/>
        <source>setFromAgent(_agent: CMUI_ReportAgent input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	23 July 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
07 Jan 2020 NDL TFS 47780
*/
vars
	
	aTime			: Time;
	
	string : String;
	dateStr : String;
	tplType : Integer;
	tplFactor : Integer;
	
begin
	inheritMethod(_agent);
	
	aTime := null;
	
	if _agent.state = _agent.STATE_TEMPLATE_SAVE or  _agent.state = _agent.STATE_TEMPLATE_EDIT then
		
		if _agent.isRowIncluded(ETRow_StartDate) then
			self.setTemplateDateFields(_agent.getValueForTemplateDates(ETRow_StartDate), 
								self.startDateTplType, self.startDateTplFactor, ETRow_StartDate);
		elseif _agent.isRowIncluded(ETRow_DateFrom) then
			self.setTemplateDateFields(_agent.getValueForTemplateDates(ETRow_DateFrom), 
								self.startDateTplType, self.startDateTplFactor, ETRow_DateFrom);
		endif;
		
		if _agent.isRowIncluded(ETRow_EndDate) then
			self.setTemplateDateFields(_agent.getValueForTemplateDates(ETRow_EndDate), 
								self.endDateTplType, self.endDateTplFactor, ETRow_EndDate);
		elseif _agent.isRowIncluded(ETRow_DateTo) then
			self.setTemplateDateFields(_agent.getValueForTemplateDates(ETRow_DateTo), 
								self.endDateTplType, self.endDateTplFactor, ETRow_DateTo);
		endif;
	
	else
		
		if _agent.isRowIncluded(ETRow_StartDate) then
			self.startDate := _agent.getValueByNameForDateIfVisible(ETRow_StartDate);
		elseif _agent.isRowIncluded(ETRow_DateFrom) then
			self.startDate := _agent.getValueByNameForDateIfVisible(ETRow_DateFrom);
		endif;
		
		
		if _agent.isRowIncluded(ETRow_EndDate) then
			self.endDate := _agent.getValueByNameForDateIfVisible(ETRow_EndDate);
		elseif _agent.isRowIncluded(ETRow_DateTo) then
			self.endDate := _agent.getValueByNameForDateIfVisible(ETRow_DateTo);
		endif;
		
	
	endif;
	
	if _agent.isRowIncluded(ETRow_TimeFrom) then
		aTime := _agent.getValueByName(ETRow_TimeFrom).Time;	
	endif;
	
	if aTime.isValid then
		self.startTime.setTime(aTime.hour, aTime.minute, aTime.second, 0);
	else
		self.startTime.setTime(0, 0, 0, 0);
	endif;
	
	//to date time//////////////////////////////////
	aTime := null;
	if _agent.isRowIncluded(ETRow_TimeTo) then
		aTime := _agent.getValueByName(ETRow_TimeTo).Time;
	endif;
	
	if aTime.isValid then
		self.endTime.setTime(aTime.hour, aTime.minute, aTime.second, 0);
	else
		self.endTime.setTime(0, 0, 0, 0);
	endif;
	
	if _agent.isRowIncluded(ETRow_FiltNoUser) then
		self.includeNoUser := _agent.getValueByName(ETRow_FiltNoUser).Boolean;
	endif;
	
	if _agent.isRowIncluded(ETRow_FiltIncludeNoTerm) then
		self.includeNoTerminal :=  _agent.getValueByName(ETRow_FiltIncludeNoTerm).Boolean;
	endif;
	
	
	self.allEventTypes.clear;
	if _agent.isRowIncluded(ETRow_AllEventTypes) then
		_agent.getSelectedEventTypes(self.allEventTypes);
	endif;
	
	self.allUsers.clear;
	if _agent.isRowIncluded(ETRow_AllUsers) then
		_agent.getSelectedUsers(self.allUsers);
	endif;
	
end;


</source>
        <Parameter name="_agent" type="CMUI_ReportAgent" usage="input"/>
    </JadeMethod>
</Class>
