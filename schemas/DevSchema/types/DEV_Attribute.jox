    <JadeMethod name="create" id="cde9b84c-45f1-41c4-8f7d-4473bfb6f41a">
        <updating/>
        <source>create(_name, 
		_type, 
		_miscData,
		_documentationTextData	: String;
		_length,
		_precision,
		_reason					: Integer;
		_class 					: DEV_Class) ::super(_name) updating;
/*

Purpose:			Constructor for DEV_Attribute class

Parameters:			_name: 					Attribute Name
					_type: 					Attribute Type (String, Boolean etc.)
					_miscData: 				The data we are not interested in but needs to be written out
					_documentationTextData: The documentation text on the attribute
					_length:				The length of the attribute, only used if its a string
					_class:					The class object the attribute belongs to

Return Value:		

Date		Who		Reason
08 November 2021	navpw1	Initial creation TFS: 52202

*/

begin
	//Set Attributes
	self.name					:= _name;
	self.type					:= _type;
	self.miscData 				:= _miscData;
	self.documentationTextData	:= _documentationTextData;
	self.length					:= _length;
	self.precision				:= _precision;
	self.reason					:= _reason;
	
	//Set References
	self.myClass 				:= _class;
	
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_type" type="String"/>
        <Parameter name="_miscData" type="String"/>
        <Parameter name="_documentationTextData" type="String"/>
        <Parameter name="_length" type="Integer"/>
        <Parameter name="_precision" type="Integer"/>
        <Parameter name="_reason" type="Integer"/>
        <Parameter name="_class" type="DEV_Class"/>
    </JadeMethod>
    <JadeMethod name="getMyClass" id="c793d912-3226-43bc-abd9-ad41013ff243">
        <source>getMyClass(_scm : Schema) : Class;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 November 2023	navpw1	Initial creation

*/

begin
	return _scm.getClass(self.myClass.name);
	
end;</source>
        <Parameter name="_scm" type="Schema"/>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="getMySchema" id="c5756c15-7405-4568-98cc-1e78ea7c6003">
        <source>getMySchema(): Schema;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 November 2023	navpw1	Initial creation

*/

begin
	return rootSchema.getSchema(self.myClass.mySchema.name);
	
end;</source>
        <ReturnType type="Schema"/>
    </JadeMethod>
</Class>
