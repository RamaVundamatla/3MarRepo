    <JadeMethod name="copyPDF" id="9d045c6b-c36a-433c-a406-df9c2e16dce5">
        <source>copyPDF(_hotfix : String; _allDirs : FileNodeArray ): Boolean;
/* ---------------------------------------------------------------------------
Created:	11 April 2011	by cnwvu1

Change Date		Who		Reason
------------------------------------------------------------------------------*/
vars
	fileFld		: FileFolder;
	fileOne		: FileNode;
	sourceDir,
	destDir		: String;
	rt			: RootHotFixes;
	tmpFileName	: String;
	pErrTxt		: String;
	filePDF		: File;
	
begin

	create fileFld transient;
	create filePDF transient;
	
	rt := app.myRootHotFix;
	
	sourceDir	:= _hotfix &amp;'\'&amp; self.getNameHotFix(_hotfix) &amp;'\';
	destDir		:= self.getDirHotFixSuperClient(_allDirs);

	fileFld.fileName:= sourceDir;
	fileFld.mask	:= '*.' &amp; rt.FILE_TYPE_PDF;	// we are interested in PDFs only

	
	if not fileFld.isAvailable then
		app.writeLogMessage(' Cannot copy PDF files. Directory not found. ' &amp; sourceDir);
		return false;
	endif;
	
	if fileFld.files.size = 0 then	// no PDF file found. However, let it go - don't interrupt process.
		return true;
	endif;
	
	foreach fileOne in fileFld.files do

		if fileOne.isKindOf(File) then

			tmpFileName := fileOne.fileName[ sourceDir.length+1 : fileOne.fileName.length - sourceDir.length ];
		
			// if PDF file is Readme.pdf, then change it to ReadmeNNN.pdf, where NNN - hotfix number
			if tmpFileName.toUpper = rt.FILE_PDF_README_NAME.toUpper then
				tmpFileName := tmpFileName[ 1 : tmpFileName.length-4 ]  // removes ".pdf" from the tmpFileName
                    &amp; _hotfix[_hotfix.length-2 : 3]     // adds hotfix number
                    &amp; "." &amp; rt.FILE_TYPE_PDF;           //adds ".pdf"
			endif;
			
			//check for PDF duplicates
			filePDF.fileName := destDir &amp; tmpFileName;
			if filePDF.isAvailable() then
				app.writeLogMessage("Copying PDF (" &amp; fileOne.fileName &amp; ") failed. There are duplicates in " &amp; destDir); 
				return false;
			endif;

			if not rt.ZJade_Local_Mode_For_File_Copy then //don't use JMT writeToBinary method, because it removes spaces from the file name.
				if sourceDir &amp; tmpFileName &lt;&gt; fileOne.fileName then
					fileOne.File.rename(sourceDir &amp; tmpFileName);	// rename from Readme.pdf to ReadmeNNN.pdf, where NNN - hotfix number.
				endif;
				if not rt.copyFile(sourceDir &amp; tmpFileName, destDir, true) then
					app.writeLogMessage("Copying PDF (" &amp; fileOne.fileName &amp; ") failed.");
					return false;
				endif;
			else
				// Jade local variant of copying	- always use this for PDF
				if not fileOne.File.cnCopyFile( destDir &amp; tmpFileName, false, pErrTxt) then	// always use File.cnCopyFIle method
					app.writeLogMessage('pErrTxt = ' &amp; pErrTxt);
					return false;
				endif;
			endif;
			
		endif;
		
	endforeach;
	
	return true;

epilog
	delete fileFld;
	delete filePDF;
	
end;</source>
        <Parameter name="_hotfix" type="String"/>
        <Parameter name="_allDirs" type="FileNodeArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="copyWeb" id="f7ff23da-795f-4f3f-b8a4-1cec02323c03">
        <source>copyWeb(_allDirs: FileNodeArray; _rangeFrom, _rangeTo : Integer ) : Boolean;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 October 2012	cnwdw1	Initial creation
10 April 2014	cnwmc5	Changes to make it work correcly
*/
vars
	targetWebFolder: FileFolder;
	folder: FileNode;
	
	mainName : String;
begin

	create targetWebFolder transient;
	targetWebFolder.fileName := self.getDirHotFixSuper(_allDirs) &amp; RootHotFixes.DIR_WEB_NAME;
	if not targetWebFolder.isAvailable then
		targetWebFolder.make;
	endif;
	
	foreach folder in _allDirs do
		if self.isHotfixInRangeOfSuperHotfix( folder.fileName, _rangeFrom, _rangeTo ) then
			mainName := self.getNameHotFix( folder.fileName );
			if app.folderExists(folder.fileName &amp; "\" &amp; mainName &amp; "\" &amp; RootHotFixes.DIR_WEB_NAME, true) then
				if not app.copyAFolder(folder.fileName &amp; "\" &amp; mainName &amp; "\" &amp; RootHotFixes.DIR_WEB_NAME, true, targetWebFolder.fileName, true) then
					return false;
				endif;
			endif;
		endif;
	endforeach;
	
	return true;
	
epilog
	delete targetWebFolder;

end;</source>
        <Parameter name="_allDirs" type="FileNodeArray"/>
        <Parameter name="_rangeFrom" type="Integer"/>
        <Parameter name="_rangeTo" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="copy_files" id="c144313f-dae9-4b98-ac28-cad44601df92">
        <source>copy_files( _hotFix : String; allDirs : FileNodeArray ) : Boolean;
// Vytenis	11/2006
vars
	rt : RootHotFixes;

begin

	rt := app.myRootHotFix;

	// for JadeMast
	if not rt.copyDirectory( 	_hotFix &amp;'\'&amp; rt.DIR_JADE_NAME &amp;'\'&amp; rt.DIR_SCHEMAS_NAME &amp;'\',
								self.getDirHotFixSuperJadeMasterScm( allDirs ),
								false) then
		return false;
	endif;

	// for Client
	if not rt.copyDirectory( 	_hotFix &amp;'\'&amp; self.getNameHotFix( _hotFix ) &amp;'\'&amp; rt.DIR_SCHEMAS_NAME &amp;'\',
								self.getDirHotFixSuperClientScm( allDirs ),
								false) then
		return false;
	endif;
	
	//cnwmc5 - 10 April 2014 - copy bin dirs
	// for JadeMast
	if not rt.copyDirectory( 	_hotFix &amp;'\'&amp; self.getNameHotFix( _hotFix ) &amp;'\'&amp; 'bin' &amp;'\',
								self.getDirHotFixSuperJadeMasterBin( allDirs ),
								false) then
		return false;
	endif;
	// for Client
	if not rt.copyDirectory( 	_hotFix &amp;'\'&amp; self.getNameHotFix( _hotFix ) &amp;'\'&amp; 'bin' &amp;'\',
								self.getDirHotFixSuperClientBin( allDirs ),
								false) then
		return false;
	endif;

	return true;
	
end;
</source>
        <Parameter name="_hotFix" type="String"/>
        <Parameter name="allDirs" type="FileNodeArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="executeHotFix" id="c34c4528-3c32-4656-8aaa-5a2199a06d3c">
        <source>executeHotFix( _hotFix : String; allDirs: FileNodeArray ) : Boolean;
// Vytenis	11/2006
vars
	
begin

// create Readme and JMTInstall
	if not self.executeHotFix_filesReadmeInsta( _hotFix, false, allDirs ) then
		return false;
	endif;
	/*par 27368. Now, no need in the readme.txt file. All pdf documents from each hotfix are copied instead.
	if not self.executeHotFix_filesReadmeInsta( _hotFix, true, allDirs ) then
		return false;
	endif;
	*/
	//par 27368. Now, copying all pdf documents from each hotfix. cnwvu1
	if not self.copyPDF(_hotFix, allDirs) then
		return false;
	endif;

// copy all Schemas files
	if not self.copy_files( _hotFix, allDirs ) then
		return false;
	endif;
	
	app.writeLogMessage(_hotFix &amp; ' - ok.');
	return true;
	
end;

</source>
        <Parameter name="_hotFix" type="String"/>
        <Parameter name="allDirs" type="FileNodeArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="executeHotFix_filesReadmeInsta" id="09e5b11b-e5bc-4a70-af79-0856a511ec6c">
        <source>executeHotFix_filesReadmeInsta( _hotFix : String; createReadme: Boolean; allDirs: FileNodeArray ) : Boolean;
// Vytenis	11/2006
// createReadme =
//		true  - Readme.txt
//		false - JMTInstall.txt
vars
	f				: File;
	fSuper			: File;
	rt				: RootHotFixes;
	s				: String;
	pErrTxt			: String;
	pos				: Integer;
	hotfixStr,
	readmeFileStr	: String;
	
begin

	create f	transient;
	create fSuper		transient;

	rt := app.myRootHotFix;
	if rt = null then
		app.writeLogMessage( 'RootHotFixes empty...');
		return false;
	endif;
	f.kind := File.Kind_Unknown_Text; // 2/3/16  cnwns1 PAR 36286 unicode version
	f.mode := File.Mode_Input;
	
	hotfixStr := self.getNameHotFix(_hotFix);	// e.g. 782Hotfix_015
	if createReadme then
		f.fileName		:= _hotFix &amp;'\'&amp; hotfixStr &amp;'\'&amp; rt.FILE_README_NAME;
		if not f.isAvailable then
			// Readme file name changed from 'Readme.txt' to 'JMT X.X.X Hotfix XXX Readme.txt' in later hotfixes
			readmeFileStr	:= 'JMT '&amp; hotfixStr[1] &amp;'.'&amp; hotfixStr[2] &amp;'.'&amp; hotfixStr[3] &amp;' Hotfix '&amp; hotfixStr[11:3] &amp;' '&amp; rt.FILE_README_NAME;
			f.fileName		:= _hotFix &amp;'\'&amp; hotfixStr &amp;'\'&amp; readmeFileStr;
		endif;		
		
		fSuper.fileName	:= self.getDirHotFixSuperClient(allDirs) &amp; rt.FILE_README_NAME;
	else
		f.fileName		:= _hotFix &amp;'\'&amp; self.getNameHotFix(_hotFix) &amp;'\'&amp; rt.FILE_JMT_INSTALL_NAME;
		fSuper.fileName	:= self.getDirHotFixSuperClient(allDirs) &amp; rt.FILE_JMT_INSTALL_NAME;
	endif;

	if not f.isAvailable then
		app.writeLogMessage(' File not found - ' &amp;f.fileName);	
		return false;
	endif;
	f.open;

	if not fSuper.isAvailable then
		fSuper.mode := File.Mode_Output;
	else
		fSuper.kind := File.Kind_Unknown_Text; // 2/3/16  cnwns1 PAR 36286 unicode version
		fSuper.mode := File.Mode_Append;
	endif;
	fSuper.open;

	if createReadme then
		fSuper.writeLine('');
		fSuper.writeLine( rt.DIR_PART_HOTFIX &amp; _hotFix[_hotFix.length-2 : 3] );
		fSuper.writeLine( '=========' );
	else
		fSuper.writeLine( rt.JMT_INSTALL_STR_REM &amp; rt.DIR_PART_HOTFIX &amp; _hotFix[_hotFix.length-2 : 3] );
	endif;
	
	while not f.endOfFile() do
		
		s := f.readLine;
		
		if s[1:13].toUpper = rt.JMT_INSTALL_STR_LAST.toUpper then
			fSuper.writeLine( s &amp; ' ' &amp; _hotFix[_hotFix.length-2 : 3] );
			
		elseif s.trimBlanks = '' then
			fSuper.writeLine( s );
			
		else
			if not (s.trimBlanks() = '') then
			//and not (s = rt.README_STR_BEGIN) then
				pos := s.pos( rt.README_STR_BEGIN_HOTFIX2, 1 );
				if pos = 0 then
					fSuper.writeLine( s );
				endif;
				//fSuper.writeLine( s );
			endif;
			
		endif;
		
	endwhile;

	f.close;
	fSuper.commit;
	fSuper.close;

	return true;
	
epilog
	delete f;
	delete fSuper;	

end;
</source>
        <Parameter name="_hotFix" type="String"/>
        <Parameter name="createReadme" type="Boolean"/>
        <Parameter name="allDirs" type="FileNodeArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDirHotFixSuper" id="f1ad4be5-7eef-4f76-972b-3980b9d7ab2a">
