    <JadeMethod name="loadBOLExtensions" id="b6223c24-a2cf-46bd-99c5-35e7ab5c6e27">
        <updating/>
        <source>loadBOLExtensions()updating;
// ---------------------------------------------------------------------------
// Created:     26 August 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	bolOut		: CM_BOLOut;
	bolType		: Integer;
	obj			: Object;
	tmpBOLOutExt : CM_BOLExtLogOut;
	found		: Boolean;
	foundRow,
	numRows		: Integer;
	
begin
	//reset tables and docketDynaDict
	self.myBOLExtDynaDict.clear();
	tblBOLExt.rows 		:= tblBOLExt.fixedRows;
	tblLogError.rows 	:= tblLogError.fixedRows;
	//grab the voyage and populate the docketDynaDict and 
	//the table - this also an object ref 'behind' each row
	if self.myCurrentLogVoyage = null then
		staMain.caption := null;
		return;
	endif;
	
	if self.myCurrentLogVoyage.myLogVoyageStructure = null then 
		return;
	endif;
	
	self.myCurrentLogVoyage.myLogVoyageStructure.allLogBOLsInError.copy(self.myBOLExtDynaDict);	
	
	foreach obj in self.myBOLExtDynaDict do
		tmpBOLOutExt := obj.CM_BOLExtLogOut;
		self.addTblBOLExtRow(tmpBOLOutExt);
		numRows := numRows + 1;
		if tmpBOLOutExt = self.myCurrentBOLExt then
			found := true;
			foundRow := numRows;
		endif;
	endforeach;

	tblBOLExt.colourRows(self.colorRow1, self.colorRow2);

	if found then
		self.doTblBOLExtRowColumnChg(self.myCurrentBOLExt);
		self.tblBOLExt.topRow := foundRow;
	else
		self.myCurrentBOLExt := null;
		if tblBOLExt.rows &gt; tblBOLExt.fixedRows then
			self.myCurrentBOLExt := tblBOLExt.accessRow(tblBOLExt.fixedRows+1).itemObject.CM_BOLExtLogOut;
			tblBOLExt.accessRow(tblBOLExt.fixedRows+1).selected := true;
			self.loadLogErrors(Row_Unchecked);			
		endif;
	endif;
	
	self.setStatusCaption();
	self.btnSelectAll.caption := 'Select All';
		
end;</source>
    </JadeMethod>
    <JadeMethod name="loadCmbVoyages" id="27933ae2-c122-44f4-8d01-45b7be07087f">
        <updating/>
        <source>loadCmbVoyages()updating;
// ---------------------------------------------------------------------------
// Created:     26 August 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	found		: Boolean;
	tempVoyDict	: CM_VoyageSet;
	voy			: CM_Voyage;
	iter		: Iterator;
	obj			: Object;
begin
	//CNWTH2 - changed so no archived voyages are displayed - why not call assistant method?
	create tempVoyDict transient;
	iter := self.myTerminal.allVoyagesByCode.createIterator;
	
	while iter.next(voy) do
//		if voy.isKindOf(CM_LogVoyage) then
		if voy.myLogVoyageStructure &lt;&gt; null then
			if voy.myTerminalArchived &lt;&gt; null then
				continue;
			endif;
			tempVoyDict.add(voy);
		endif;	
	endwhile;
	
	if tempVoyDict.size &gt; 0 then
		self.cmbVoyage.listCollection(tempVoyDict, false, 0);
		// 28082 Sep 2011 find first non-closed entry
		delete iter;
		iter := tempVoyDict.createIterator();
		while iter.next(obj) do
			voy :=  obj.CM_Voyage;
			if voy.isClosedStatus() then
				continue;
			endif;
			found := true;
			break;
		endwhile;
		if found then
			self.cmbVoyage.listObject := voy;
			self.cmbVoyage.click(cmbVoyage);
		endif;
	endif;
	
epilog
	delete iter;
	delete tempVoyDict;
end;</source>
    </JadeMethod>
