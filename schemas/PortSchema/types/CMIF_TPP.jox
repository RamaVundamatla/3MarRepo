    <JadeMethod name="copyProduksi" id="c029d4db-eefb-4c71-92a1-b5dc74f2ba23">
        <updating/>
        <source>copyProduksi(invLine : CM_InvoiceLine)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 January 2019	jlgma1	Initial creation 42036

*/

vars
	
begin
	if invLine = null then
		return;
	endif;
	self.setMyInvoiceLine(invLine);
	
	self.productionQty  := invLine.quantity.String;
	self.cargoType      := self.tPPHelper(invLine, "cargoType");
	self.uOM			:= invLine.invoiceLineDesc.unitNarration;
	
epilog

end;</source>
        <Parameter name="invLine" type="CM_InvoiceLine"/>
    </JadeMethod>
    <JadeMethod name="copyRevenue" id="3631129b-b179-42d1-be3e-dcc0ef74fbfe">
        <updating/>
        <source>copyRevenue(invLine : CM_InvoiceLine)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 January 2019	jlgma1	Initial creation 42036

*/

vars
	
begin
	if invLine = null then
		return;
	endif;
	self.setMyInvoiceLine(invLine);
	
	self.productionCode := self.tPPHelper(invLine, "productionCode");
	//jlier1 TFS 51963 15/10/21
	if self.myInvoice.bank.code.toUpper.cnContains("DOM") then
		self.amount       :=  invLine.lineTotal.String;
	else
		self.amount       :=  invLine.getAmountForCurrencyCode("USD").String;
	endif;
	self.cargoType      := self.tPPHelper(invLine, "cargoType");
	self.uOM	:="IDR";
epilog

end;</source>
        <Parameter name="invLine" type="CM_InvoiceLine"/>
    </JadeMethod>
    <JadeMethod name="copyTrafficBarang" id="09b25d7a-b9eb-4650-b4ab-db6041d28a86">
        <updating/>
        <source>copyTrafficBarang(invLine : CM_InvoiceLine)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Jan 2019	cnwma1	ChangeRequest 42036: PEL1 - SAP TPP Report

*/

vars

begin
	if invLine = null then
		return;
	endif;
	self.setMyInvoiceLine(invLine);
	
	self.termCode  		:= self.tPPHelper(invLine, "termCode");
	self.month     		:= self.tPPHelper(invLine, "month");
	self.year      	    := self.tPPHelper(invLine, "year");
	self.wharfCode      := self.tPPHelper(invLine, "wharfCode");
	self.wharfName      := self.tPPHelper(invLine, "wharfName");
	self.berthCode      := self.tPPHelper(invLine, "berthCode");
	self.berthName      := self.tPPHelper(invLine, "berthName");
	self.imex          	:= self.tPPHelper(invLine, "imex");
	self.businessUnit  	:= self.tPPHelper(invLine, "businessUnit");
	self.transferType  	:= self.tPPHelper(invLine, "transferType");
	self.codeHewanMobil := self.tPPHelper(invLine, "codeHewanMobil");
	self.nameHewanMobil := self.tPPHelper(invLine, "nameHewanMobil");
	self.isoType        := self.tPPHelper(invLine, "isoType");
	self.contentStatus  := self.tPPHelper(invLine, "contentStatus");
	self.cargoType      := self.tPPHelper(invLine, "cargoType");
	self.commodity      := self.tPPHelper(invLine, "commodity");
	self.quantity   	:= self.tPPHelper(invLine, "quantityBarrang");
	self.uOM            := self.tPPHelper(invLine, "uOM");
	self.voyageCode   	:= self.tPPHelper(invLine, "voyageCode");
epilog

end;</source>
        <Parameter name="invLine" type="CM_InvoiceLine"/>
    </JadeMethod>
    <JadeMethod name="copyTrafficKapal" id="5ffd21a6-ca33-4a31-8601-bdf67962c113">
        <updating/>
        <source>copyTrafficKapal(inv : CM_Invoice)updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 Dec 2018	cnwma1	ChangeRequest 42036: PEL1 - SAP TPP Report

*/

vars
	
begin

	self.termCode     		:= self.tPPHelper(inv,"termCode");
	self.month        		:= self.tPPHelper(inv,"month");
	self.year      	  	   	:= self.tPPHelper(inv,"year");
	self.berthCode 	  	   	:= self.tPPHelper(inv,"berthCode");
	self.berthName    	   	:= self.tPPHelper(inv,"berthName");
	self.wharfCode   	   	:= self.tPPHelper(inv,"wharfCode");
	self.wharfName    	   	:= self.tPPHelper(inv,"wharfName");
	self.voyageCode   	   	:= self.tPPHelper(inv,"voyageCode");
	self.vesselName   	   	:= self.tPPHelper(inv,"vesselName");
	self.businessUnit 	   	:= self.tPPHelper(inv,"businessUnit");       
	self.routeType    	   	:= self.tPPHelper(inv,"routeType"); 
	self.countryID    	   	:= self.tPPHelper(inv,"countryID"); 
	self.quantity     	   	:= self.tPPHelper(inv,"quantityKappal"); 
	self.vesselType   	   	:= self.tPPHelper(inv,"vesselType"); 
	self.uNIT_GRT     	   	:= self.tPPHelper(inv,"unit_GRT");  	
	self.counter    	   	:= self.tPPHelper(inv,"counter"); 
	self.flag      		   	:= self.tPPHelper(inv,"flag"); 
	self.externalInvoiceNbr	:= self.tPPHelper(inv,"externalInvoiceNbr");       
epilog

end;</source>
        <Parameter name="inv" type="CM_Invoice"/>
    </JadeMethod>
    <JadeMethod name="getArrivalMovement" id="b1dfa25d-1985-498c-8d69-d76854e1a014">
        <source>getArrivalMovement():HMS_VoyageMovement;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 Dec 2018	cnwma1	ChangeRequest 42036: PEL1 - SAP TPP Report
*/

vars
	movement 		: HMS_VoyageMovement;
	hmsVoyageData   : HMS_VoyageData;
begin
	if self.myVoyage &lt;&gt; null then
		if self.myVoyage.myHMSVoyageData &lt;&gt; null then
			foreach movement in self.myVoyage.myHMSVoyageData.allVoyageMovements do
				if movement.getMyBerth &lt;&gt; null then
					if not  movement.getMyWharf.isLogicalWharf then
						return movement;
					endif;
				endif;
			endforeach;
		endif;
	endif;
	return null;
epilog

end;</source>
        <ReturnType type="HMS_VoyageMovement"/>
    </JadeMethod>
    <JadeMethod name="getBerth" id="9812c1cd-2e2b-45ce-8b00-141599e1955c">
        <source>getBerth():HMS_Berth;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 Dec 2018	cnwma1	ChangeRequest 42036: PEL1 - SAP TPP Report

*/

vars
	berth : HMS_Berth;
begin
	if self.getArrivalMovement &lt;&gt; null then
		berth := self.getArrivalMovement.getMyBerth;
	endif;
	
	return berth;
epilog

end;</source>
        <ReturnType type="HMS_Berth"/>
    </JadeMethod>
    <JadeMethod name="getRouteType" id="e38eb858-163c-4575-a2f1-4e59fa86c22d">
        <source>getRouteType():String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 Dec 2018	cnwma1	ChangeRequest 42036: PEL1 - SAP TPP Report

*/

vars
	route : String;
begin
	if self.myVoyage &lt;&gt; null then
		if self.myVoyage.myHMSVoyageData &lt;&gt; null then
			if self.myVoyage.myHMSVoyageData.getVesselIsTramper &lt;&gt; null then
				route := "TRAMPER";
			else
				route := "LINER";
			endif;
		endif;
	endif;
	return route;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getWharf" id="f1e16467-c28f-4184-865d-e2e323b07498">
        <source>getWharf(): HMS_Wharf;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 Dec 2018	cnwma1	ChangeRequest 42036: PEL1 - SAP TPP Report

*/

vars
	wharf : HMS_Wharf;
begin
	if self.getArrivalMovement() &lt;&gt; null then
