		endif;
		//self.myAssistant.showEventTransactions(self.myCurrentVoyage, shift);								// TFS 4174
		self.myAssistant.showEventTransactions(self.myCurrentVoyage, shift, jobSheet, self.myCurrentJob);	// TFS 4174
	endif;

epilog

end;</source>
