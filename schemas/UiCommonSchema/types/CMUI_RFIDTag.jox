    <JadeMethod name="setupForm" id="c9fcbb63-2d81-4c10-a4c6-6d2a5270a886">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
16 August 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	rfidTag : CM_RFIDTag;
begin

	inheritMethod();
	self.beginNotifications();
	
	self.btnOk.visible := false;
	self.btnCancel.visible := false;//caption:="Proceed";
	self.loadJobInfo();
	if myJob &lt;&gt; null then
		rfidTag:=myJob.myRFIDTag;
	endif;
	self.myAssistant.comboBoxRFIDTag(self.cmbRFID,self.myTerminal, rfidTag);
	self.lstInfo.parentAspect:=Control.ParentAspect_StretchBottom;
	
	self.setForMode();
	
epilog
	app.mousePointer	:=	Idle;
end;</source>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="52b2e743-1d9b-4ad8-9e6c-b55e5a62ebd0">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;
/*
----------   ----------  --------------------------------------------------
Created:	07 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if (not self.readTagSuccessful) then
		self.lblRFID.visible := not self.lblRFID.visible;
	else
		self.lblRFID.caption := 'Tag Read &gt;&gt;';
		self.lblRFID.visible := true;
		self.lblRFID.foreColor := Green;
	endif;
end;


</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="b0d84a27-121a-4f9d-a0ac-d20588806c19">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
//	self.translateCaption(Xlat_0017448, locale);
	btnProceed.translateCaption(Xlat_0004927, locale);
	btnSendControl.translateCaption(Xlat_0004928, locale);
	lblRFID.translateCaption(Xlat_0004929, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="userNotify" id="6a9af116-6c35-45ed-9d09-fad49979bb1c">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
/*
----------   ----------  --------------------------------------------------
Created:	05 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	self.doHandleNotification(eventType, theObject, eventTag, userInfo);
	

end;


</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</GUIClass>
