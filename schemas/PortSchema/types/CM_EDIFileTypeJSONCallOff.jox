    <JadeMethod name="findEDIDataType" id="0db6c465-9816-44c3-93c2-3da259a3451b">
        <source>findEDIDataType(_ediDataClass: Class io; _dataType: Integer io; _fileTypeCode: Integer io);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 29/06/2023	navdap1		Initial creation TFS 58923 EUP CallOff EDI Data Type / EDI Load
//
vars

begin
	_ediDataClass	:= CM_EDIDataCallOff;
	_dataType		:= EDIDataType_CallOff;
	_fileTypeCode	:= self.type;

epilog

end;</source>
        <Parameter name="_ediDataClass" type="Class" usage="io"/>
