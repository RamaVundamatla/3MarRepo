    <JadeMethod name="trxUpdateTIsForBulkEdit" id="96fc3b7b-54bb-4a74-bc7b-98dd421d7acc">
        <updating/>
        <source>trxUpdateTIsForBulkEdit(
	_pxySet             : CM_ObjectSet input; 
	_bulkEditController : CMIF_BulkEditController io;
	_updateMode 		: Integer;
	_allTasksToAdd 		: IntegerArray;
	_allTasksToComplete : IntegerArray;
	_allTasksToRemove 	: IntegerArray;
	_allStopsToAdd		: CM_StopsByIdDict;					// cnwrl1 11/01/2010 PAR 21889
	_allStopsToRemove	: CM_StopsByIdDict;					// cnwrl1 11/01/2010 PAR 21889
	_allStopsToUpdate	: CM_StopsByIdDict;					// cnwrl1 18/01/2010 PAR 21889
	_hasEditedToDoTasks	: Boolean;
	_extraParams		: CMIF_TIUpdateExtraParams; 		//cnwrd1 ccms 1804 29.5.09
	_passport 			: CM_Passport input ) updating;
// ---------------------------------------------------------------------------
// Created:     26 March 2003		cnwth2	
//
// Purpose: 
// ----------   ----------  --------------------------------------------------
// 8 Jun 2010	RJS			PAR 24336 - move setting of pxy's to calling method
// 11 Dec 2015  cnwma1      PAR #37301  Comparison Error
// 30 Mar 2016	cnwdap1		PAR #35843 Make monitor time based rather than object based
// 09 Apr 2024	navdap1		TFS 63307 EUP | Performance - Cargo Enquiry Bulk Updates
// 28 May 2024	navdap1		TFS 64312 EUP | Bulk Edit in Cargo Enquiry Progress Changes
// ----------   ----------  --------------------------------------------------
vars
	tiAuditCntrl		: CM_TIAuditController;
	updateController 	: CMIF_TIUpdateController;
	edition				: Integer;
	numUpdated			: Integer;
	tisToUnlock			: CM_ObjectSet;
	tisLocked			: CM_ObjectSet;
	unlockObj			: Object;
	pxyObj				: Object;
	taskObj				: Object;
	realTI				: CM_TrackedItem;
	pxyTI				: CM_TrackedItem;
	utlAgent			: CM_UtilityUpdateAgent;
	cmifMonitor			: CMIF_Monitor;
	prxyTasksToAdd		: IntegerArray;			// possible transient leaks ?
	prxyTasksToComplete	: IntegerArray;			// possible transient leaks ?
	prxyTasksToRemove	: IntegerArray;			// possible transient leaks ?
	lastUpdated			: Decimal [20];			// PAR #35843
	doProgressive		: Boolean;			// TFS 63307
	cargoGroups			: ObjectSet;		// TFS 63307
	obj 				: Object;			// TFS 63307
	cargoGroup			: CM_CargoGroup;	// TFS 63307
	allCargoGroups		: Boolean;				// TFS 64312
	
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	_passport.useTIDictDeferUpdate 		  := true;
	_passport.useTITransactionDeferUpdate := true;
	_passport.useOfflineFutureActorDeferUpd := true;

	create tisLocked transient;
	create tisToUnlock transient;
	create cargoGroups transient;						// TFS 63307

	doProgressive := _passport.allowProgressiveUpdates;	// TFS 63307

	beginTransaction;

	tiAuditCntrl := _passport.getTIAuditController();
	tiAuditCntrl.reset();	// 19 Oct 2012	NDL	Par 30594 - clear out any previous containers data.
	
	updateController := app.createTIUpdateControl(TI_UPDMODE_NORMAL, _passport.userCode, null);

	if _passport.hasErrorsOrWarnings then
		return;
	endif;

	app.setContinueCMExceptions(true);
	numUpdated  := 1;
	utlAgent    := app.myUtilityUA;
	cmifMonitor := app.myPassport.myCMIFMonitor;

	//session lock it up - unlocks in batches as we go further down
	foreach pxyObj in _pxySet do
		realTI := pxyObj.CM_Object.pxyGetRealObject().CM_TrackedItem;
		if not doProgressive then														// TFS 63307
			tisLocked.add(realTI);
			self.lock(realTI, Exclusive_Lock, Session_Duration, 0);
		endif;																			// TFS 63307
		
		// change to now do validate here rather than in utl below
		app.myValUA.valTrackedItem(pxyObj.CM_TrackedItem, updateController, _passport);
		
		// TFS 63307 feedback on validation progress
		numUpdated +=1;
		if cmifMonitor &lt;&gt; null then
			if (app.relativeMachineTime - lastUpdated) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then
				lastUpdated := app.relativeMachineTime;
				cmifMonitor.partsDone := numUpdated;
				cmifMonitor.updateProgressWithCaption('Bulk Edit - successfully validated:', cmifMonitor.partsInJob, cmifMonitor.partsDone, "Bulk edit validating...");
				if (cmifMonitor.monitorReturnValue = CMIF_Monitor.MonitorReturnValue_Cancel)  then
					break;
				endif;
			endif;
		endif;
		// TFS 63307 end of this bit
	endforeach;

	// check validation
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	// TFS 63307 start of this bit
	if doProgressive then
		_passport.setWarningsAcknowledged(true);
		_passport.setWarningsIgnored(true);
		global.bulkEditProcess:= process.getOidString;
		app.writeLog(method.qualifiedName &amp; Tab &amp; " Setting global bulkEditProcess to " &amp; process.getOidString, LogDEBUG);
		process.setPersistentDeadlockPriority(20);
	endif;
	numUpdated := 1;
	// TFS 63307 end of this bit
	
	allCargoGroups := true;				// TFS 64312
	foreach pxyObj in _pxySet do
		pxyTI := pxyObj.CM_TrackedItem;
		if (app.relativeMachineTime - lastUpdated) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then	// PAR #35843
			lastUpdated := app.relativeMachineTime;													// PAR #35843
			if (not _passport.noErrors) then
		    	return;
		    endif;
		    
		    _passport.doDeferredUpdates();
			// TFS 63307 take a break
			if doProgressive then
				process.sleep(100);
			endif;
			// TFS 63307 end of this bit
			app.cmsCommitTransaction(_passport);
			
			//all TIs to be updated were session locked at start of trx - so unlock them
			//outside of transaction state as we're done with them
			if not doProgressive then											// TFS 63307
				foreach unlockObj in tisToUnlock do
					self.unlock(unlockObj);
					tisLocked.remove(unlockObj);
				endforeach;
			endif;																// TFS 63307
			_passport.clearDeferUpdatesCollections();
			//if we've done one batch OK - no need to keep validating stops
			updateController.doValidateStops := false;
			tisToUnlock.clear();
			
			beginTransaction;
			_passport.useTIDictDeferUpdate 		  := true;						// TFS 63307
			_passport.useTITransactionDeferUpdate := true;						// TFS 63307
			_passport.useOfflineFutureActorDeferUpd := true;
			
			if cmifMonitor &lt;&gt; null then
				cmifMonitor.partsDone := numUpdated;
				cmifMonitor.updateProgressWithCaption('Bulk Edit - successfully commited:', cmifMonitor.partsInJob, cmifMonitor.partsDone, 'Bulk edit saving...');	// TFS 63307
				if (cmifMonitor.monitorReturnValue = CMIF_Monitor.MonitorReturnValue_Cancel)  then
					break;
				endif;
			endif;
			// TFS 63307 reset the "bulk updates are happening" flag
			if doProgressive then
				_passport.allowProgressiveUpdates := true;
				global.bulkEditProcess := process.getOidString;
				app.writeLog(method.qualifiedName &amp; Tab &amp; " Setting global bulkEditProcess to " &amp; process.getOidString, LogDEBUG);
				process.setPersistentDeadlockPriority(20);
			endif;
			// TFS 63307 end of this bit
		endif;
		
		if not pxyTI.isCargoGroupItem then				// TFS 64312
			allCargoGroups := false;					// TFS 64312
		endif;											// TFS 64312
		
		pxyTI.pxyGetRealObjectAndEdition(realTI, edition);
		if not doProgressive then												// TFS 63307
			tisToUnlock.add(realTI);
		endif;																	// TFS 63307

		prxyTasksToAdd 		:= _allTasksToAdd;
		prxyTasksToComplete	:= _allTasksToComplete;
		prxyTasksToRemove	:= _allTasksToRemove;
		
		prxyTasksToAdd.clear();
		prxyTasksToComplete.clear();
		prxyTasksToRemove.clear ();
		
		if _extraParams.useSelectedBookingItem then                        //11/12/2015 cnwma1 PAR #37301 Comparison Error
			updateController.useSelectedBookingItem :=true;
		endif;
		if doProgressive then										// TFS 63307
			updateController.dateTime := app.actualTimeServer;		// TFS 63307
		endif;														// TFS 63307
		
		if _hasEditedToDoTasks then
			//th2 PAR 12469 - Bulk Edit of To Do Tasks/Grades etc. (refer back to PAR 12381)
			//the code here previously (14th August) didn't really make any sense. It now compares the 
			//todo tasks on the proxy to the todo tasks on the real TI to work out whats been added
			//and what has been removed etc.
			foreach taskObj in pxyTI.allToDoTasksToDo do
				prxyTasksToAdd.add(taskObj.CM_ToDoTask.toDoTaskDescCode);
			endforeach;
	
			foreach taskObj in pxyTI.allToDoTasksCompleted do
				if realTI.allToDoTasksToDo.includes(taskObj.CM_TiToDoTask) then
					prxyTasksToComplete.add(taskObj.CM_ToDoTask.toDoTaskDescCode);
				endif;
			endforeach;
			
			foreach taskObj in realTI.allToDoTasksToDo do
//	PAR16074 this was comparing the ti to itself and removing all the remaining todos!!!!!!
//			if realTI.allToDoTasksToDo.includes(taskObj.CM_TiToDoTask) then
				if not pxyTI.allToDoTasksToDo.includes(taskObj.CM_TiToDoTask) then
					prxyTasksToRemove.add(taskObj.CM_ToDoTask.toDoTaskDescCode);
				endif;
			endforeach;
		endif;
		if _passport.hasErrors() then
		   	return;
		endif;
		
		utlAgent.utlUpdateTIForBulkEdit(pxyTI,
									realTI, 
									_updateMode, 
									updateController, 
									prxyTasksToAdd,
									prxyTasksToComplete,
									prxyTasksToRemove,
									_extraParams,  //cnwrd1 ccms 1804 29.5.09
									_passport);		//!!!CNWTH2 UNCOMMENT WHEN GUI EXISTS FOR HANDLING A RETURNED ERROR SET
	
		prxyTasksToAdd.clear();
		prxyTasksToComplete.clear();
		prxyTasksToRemove.clear ();
		
		// TFS 63307 start of this bit - store cargo groups for cargo group detail updates later
		if pxyTI.myCargoGroup &lt;&gt; null then
			cargoGroups.addNoDuplicates(pxyTI.myCargoGroup, false);
		endif;
		// TFS 63307 end of this bit
		
		numUpdated := numUpdated + 1;
	endforeach;	
	
	if _passport.noErrors then
		_passport.doDeferredUpdates();
		
		// TFS 64312 Don't need to do cargo group detail updates if all items changed were cargo groups
		if not allCargoGroups then
			// TFS 63307 start of cargo group detail processing
			foreach obj in cargoGroups do
				cargoGroup := obj.CM_CargoGroup;
				CMIF_TrxActionCargoGroup@createAction(null, cargoGroup, _passport);
			endforeach;
			// TFS 63307 end of this bit
		endif;
	endif;
	
epilog
	if tiAuditCntrl &lt;&gt; null then
		tiAuditCntrl.resetIsAudited(true);
	endif;
	
	delete updateController;
	self.finaliseActivityWithPassport(_passport);
	
	if not doProgressive then												// TFS 63307
		foreach unlockObj in tisLocked do
			self.unlock(unlockObj);
		endforeach;
	endif;																	// TFS 63307
	
	delete tisToUnlock;
	delete tisLocked;
	delete cargoGroups;														// TFS 63307
	process.setPersistentDeadlockPriority(0);								// TFS 63307
end;</source>
        <Parameter name="_pxySet" type="CM_ObjectSet" usage="input"/>
        <Parameter name="_bulkEditController" type="CMIF_BulkEditController" usage="io"/>
        <Parameter name="_updateMode" type="Integer"/>
        <Parameter name="_allTasksToAdd" type="IntegerArray"/>
        <Parameter name="_allTasksToComplete" type="IntegerArray"/>
        <Parameter name="_allTasksToRemove" type="IntegerArray"/>
        <Parameter name="_allStopsToAdd" type="CM_StopsByIdDict"/>
        <Parameter name="_allStopsToRemove" type="CM_StopsByIdDict"/>
        <Parameter name="_allStopsToUpdate" type="CM_StopsByIdDict"/>
        <Parameter name="_hasEditedToDoTasks" type="Boolean"/>
        <Parameter name="_extraParams" type="CMIF_TIUpdateExtraParams"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateTIsForBulkEditSimple" id="5e600d99-eee4-42e8-a289-5db79651fbfd">
        <updating/>
        <source>trxUpdateTIsForBulkEditSimple(_agent : CMIF_TIBulkUpdateAgent input; _passport : CM_Passport input) updating;
/*
Purpose:			

Date		Who		Reason
08 May 2024	navab1	CR 64033 TASK 64035
*/
vars

begin

	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	beginTransaction;

	app.myUtilityUA.utlUpdateTIsForBulkEditSimple(_agent, _passport);

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_agent" type="CMIF_TIBulkUpdateAgent" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateTIsReadyToShip" id="a93a1be5-a691-4683-bd8e-b4fc51a62f8d">
        <updating/>
        <source>trxUpdateTIsReadyToShip(_theTIs: CM_TIArray input; _readyToShip : Boolean; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		February  2004 By CNWJC2
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
//08 Oct 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
constants
	ProgressBarRefresh	: Integer = 2000;	
vars
	ti					: CM_TrackedItem;
	lPassport			: CM_Passport;
	utilUA				: CM_UtilityUpdateAgent;
	intCount,
	total				: Integer;
	updateProg			: Boolean;
	propArray			: StringArray;
	tiAuditCntrl		: CM_TIAuditController;
	tiUpdateCntrl		: CMIF_TIUpdateController;
	progressInt	: TimeStampInterval;
	progressTS : TimeStamp;
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportSilentExHandler(exception, _passport);
	on LockException do agtPassportSilentLockExHandler(exception, 10, _passport);

	progressTS := app.actualTimeServer();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	//only audit RTS property
	tiAuditCntrl := _passport.getTIAuditController();	
	create propArray transient;
	propArray.add(CM_TrackedItem::readyToShip.name);
	tiAuditCntrl.setAuditSpecific(CM_TrackedItem, propArray);
	
	lPassport 		:= app.myPassport;
	utilUA 			:= app.myUtilityUA;
	updateProg 		:= lPassport.hasMonitor;
	total 			:= _theTIs.size();
	tiUpdateCntrl 	:= app.createTIUpdateControl(TI_UPDMODE_NORMAL, _passport.userCode, null);
	
	beginTransaction;
	foreach ti in _theTIs do
		progressInt := app.actualTimeServer() - progressTS;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		if updateProg and (progressInt.getMilliseconds &gt;= ProgressBarRefresh)then
			lPassport.myCMIFMonitor.updateProgress("Updating RTS", total, intCount);
			progressTS := app.actualTimeServer();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		endif;
		if ti.readyToShip = _readyToShip or (ti.site = TI_SITE_ONSHIP and not (ti.isRehandle or ti.isTranshipItem)) then	// 30/9/19 MAP TFS 45590
			continue;
		endif;
		//update it
		utilUA.utlUpdateTIReadyToShip(ti, tiUpdateCntrl, _readyToShip, lPassport);
	endforeach;

epilog
	if tiAuditCntrl &lt;&gt; null then
		tiAuditCntrl.resetIsAudited(true);
	endif;
	
	delete propArray;
	delete tiUpdateCntrl;
	self.finaliseActivityWithPassport(_passport);
	if updateProg then
		lPassport.myCMIFMonitor.updateProgress("Updating RTS", total, intCount);
	endif;
end;</source>
        <Parameter name="_theTIs" type="CM_TIArray" usage="input"/>
        <Parameter name="_readyToShip" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
