<Class name="UT_HMS_Master" id="068d0fd2-057f-403c-8c6d-c640ebe8d881">
    <superclass name="UT_HMS"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="unitTest"/>
    <JadeMethod name="deleteHMSMaster" id="841c379c-42c1-47fa-bb98-919a417d9e39">
        <source>deleteHMSMaster( harbour : HMS_Harbour; masterCode : String );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 May 2012	cnwndl1	Initial creation

*/

vars

	master : HMS_Master;

begin

	if masterCode = null or harbour = null then
		return;
	endif;
	
	master := harbour.allMasters.getAtKey( masterCode );
	
	if master = null then
		return;
	endif;
	
	beginTransaction;
	delete master;
	commitTransaction;

epilog

end;</source>
        <Parameter name="harbour" type="HMS_Harbour"/>
        <Parameter name="masterCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="deleteHMSPilotExemptRule" id="78571a4a-aa55-4229-a077-35e9366d1047">
        <source>deleteHMSPilotExemptRule( harbour : HMS_Harbour; ruleName : String);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 May 2012	cnwndl1	Initial creation	Par 29496

*/

vars

	rule : HMS_PilotExemptionRule;

begin

	if ruleName = null or harbour = null then
		return;
	endif;
	
	rule := harbour.allPilotExemptionRules.getAtKey( harbour, ruleName );
	
	if rule = null then
		return;
	endif;
	
	beginTransaction;
	delete rule;
	commitTransaction;

epilog

end;</source>
        <Parameter name="harbour" type="HMS_Harbour"/>
        <Parameter name="ruleName" type="String"/>
    </JadeMethod>
    <JadeMethod name="tPilotExemptionRulesAndCerts" id="7bfbae6d-8be4-431b-8da8-d8f1fa36f1b0">
        <source>tPilotExemptionRulesAndCerts();
//cnwndl1
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 May 2012	cnwndl1	Initial creation	Par 29496
30 Apr 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement
*/

constants

	MasterCode : String = "PUG";
	MasterName : String = "Captain Pug Wash";
vars

	harbour : HMS_Harbour;
	pxyMaster : HMS_Master;
	hmsObject : HMS_Object;
	master : HMS_Master;
	
	pxyExemptRule : HMS_PilotExemptionRule;
	rule1, rule2, rule3 : HMS_PilotExemptionRule;
	criteria : Integer;
	operator : Integer;
	isActive : Boolean;
	value : Decimal [10,2];
	ruleName : String;
	
	voyage : CM_Voyage;
	vessel : CM_Vessel;
	selectedVoyage : CM_Voyage;
	
	today : Date;
	pxyPilotExemption : HMS_PilotExemptionCertificate;
	certifiedDate : Date;
	expiryDate : Date;
	revalidateDate : Date;
	pilotExemptionCertificate : HMS_PilotExemptionCertificate;
	validatingPilot : HMS_Pilot;
	loadStateSet : Boolean;
	
	pxyVoyage : CM_Voyage;
	pxyMovement : HMS_VoyageMovement;
	pxyVoyageData : HMS_VoyageData;
	errorInfo : String;
	
	rule2Voyage : CM_Voyage;
	//allPilots : HMS_PilotByCodeDict; // TFS 44438 after 040 cut/release
	allMovementPilotDetails : HMS_MovementPilotDetailsSet; // TFS 44438
begin

	// make sure we have an associated harbour
	harbour := self.getTerminal.myHarbour;
	assertTrueMsg( harbour &lt;&gt; null , "No Harbour declared for terminal " &amp; self.getTerminal.code);
	
	//clear out old data
	self.deleteHMSPilotExemptRule( harbour, "U" &amp; HMS_PilotExemptionRule.Criteria_Length_Str);
	self.deleteHMSPilotExemptRule( harbour, "U" &amp; HMS_PilotExemptionRule.Criteria_Draft_Str);
	self.deleteHMSPilotExemptRule( harbour, "U" &amp; HMS_PilotExemptionRule.Criteria_Weight_Str);
	self.deleteHMSMaster( harbour,  MasterCode );
	
	//create new Master
	create pxyMaster transient;
	pxyMaster.setPropertyValue("code", MasterCode);
	pxyMaster.setPropertyValue("description", MasterName);
	pxyMaster.setPropertyValue("notAvailForEntry", false);
	pxyMaster.setProxy( harbour );
	
	app.myTrxCA.trxCreateHMSObject(pxyMaster, hmsObject, app.myPassport);
	master := hmsObject.HMS_Master;
	assertTrueMsg( app.myPassport.trxCompletedOK, "Errors during Master create - " &amp; app.myPassport.getErrorsAndWarningsAsString );

	//create 3 Pilot Exemption Rules
	create pxyExemptRule transient;
	criteria := HMS_PilotExemptionRule.Criteria_Length;
	operator := HMS_PilotExemptionRule.Oper_GEQ;
	isActive := true;
	value := 110.00;
	ruleName := "U" &amp; HMS_PilotExemptionRule.Criteria_Length_Str;
	
	pxyExemptRule.setProxy(	criteria,	//_criteria : Integer;
							isActive,	//_isActive : Boolean;
							operator,	//_operator : Integer;
							value,	//_value : Decimal;
							ruleName,	//_ruleName : String;
							harbour	//_myHarbour : HMS_Harbour
							);
							
	app.myTrxCA.trxCreateHMSObject(pxyExemptRule, hmsObject, app.myPassport);
	rule1 := hmsObject.HMS_PilotExemptionRule;
	assertTrueMsg( app.myPassport.trxCompletedOK, "Errors during Rule [" &amp; ruleName &amp; "] create - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	delete pxyExemptRule;
	
	//find a voyage that needs a pilot based on rule 1.   Length GEQ 110m
	foreach voyage in self.getTerminal.allVoyagesByCode do
		if voyage = self.getTerminal.getNullVoyage then
			continue;
		endif;
		vessel := voyage.getMyVessel;
		if vessel = null then
			continue;
		endif;
		if rule1.vesselRequiresPilotForRule( vessel ) then
			selectedVoyage := voyage;
			break;
		endif;
	endforeach;
	assertTrueMsg( selectedVoyage &lt;&gt; null, "No voyage found that would require a pilot for rule 1." );
	
	selectedVoyage := null;
	create pxyExemptRule transient;
	criteria := HMS_PilotExemptionRule.Criteria_Draft;
	operator := HMS_PilotExemptionRule.Oper_GEQ;
	isActive := true;
	value := 15.00;
	ruleName := "U" &amp; HMS_PilotExemptionRule.Criteria_Draft_Str;
	
	pxyExemptRule.setProxy(	criteria,	//_criteria : Integer;
							isActive,	//_isActive : Boolean;
							operator,	//_operator : Integer;
							value,	//_value : Decimal;
							ruleName,	//_ruleName : String;
							harbour	//_myHarbour : HMS_Harbour
							);
							
	app.myTrxCA.trxCreateHMSObject(pxyExemptRule, hmsObject, app.myPassport);
	rule2 := hmsObject.HMS_PilotExemptionRule;
	assertTrueMsg( app.myPassport.trxCompletedOK, "Errors during Rule [" &amp; ruleName &amp; "] create - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	delete pxyExemptRule;
	
	//find a voyage that needs a pilot based on rule 2.   Draft GEQ 15m 
	foreach voyage in self.getTerminal.allVoyagesByCode do
		if voyage = self.getTerminal.getNullVoyage then
			continue;
		endif;
		vessel := voyage.getMyVessel;
		if vessel = null then
			continue;
		endif;
		if rule2.vesselRequiresPilotForRule( vessel ) then
			selectedVoyage := voyage;
			break;
		endif;
	endforeach;
	assertTrueMsg( selectedVoyage &lt;&gt; null, "No voyage found that would require a pilot for rule 2." );
	rule2Voyage := selectedVoyage;
	
	selectedVoyage := null;
	create pxyExemptRule transient;
	criteria := HMS_PilotExemptionRule.Criteria_Weight;
	operator := HMS_PilotExemptionRule.Oper_GEQ;
	isActive := true;
	value := 100.00;
	ruleName := "U" &amp; HMS_PilotExemptionRule.Criteria_Weight_Str;
	
	pxyExemptRule.setProxy(	criteria,	//_criteria : Integer;
							isActive,	//_isActive : Boolean;
							operator,	//_operator : Integer;
							value,	//_value : Decimal;
							ruleName,	//_ruleName : String;
							harbour	//_myHarbour : HMS_Harbour
							);
							
	app.myTrxCA.trxCreateHMSObject(pxyExemptRule, hmsObject, app.myPassport);
	rule3 := hmsObject.HMS_PilotExemptionRule;
	assertTrueMsg( app.myPassport.trxCompletedOK, "Errors during Rule [" &amp; ruleName &amp; "] create - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	delete pxyExemptRule;
	
	
	//find a voyage that needs a pilot based on rule 3.   Weight greater than or equal to 100 tonne 
	foreach voyage in self.getTerminal.allVoyagesByCode do
		if voyage = self.getTerminal.getNullVoyage then
			continue;
		endif;
		vessel := voyage.getMyVessel;
		if vessel = null then
			continue;
		endif;
		if rule3.vesselRequiresPilotForRule( vessel ) then
			selectedVoyage := voyage;
			break;
		endif;
	endforeach;
	
	assertTrueMsg( selectedVoyage &lt;&gt; null, "No voyage found that would require a pilot for rule 3." );
	
	vessel := selectedVoyage.getMyVessel;
	if not harbour.requiresPilotFor( vessel, selectedVoyage, null ) then
		assertTrueMsg( false, "Check of vessel/voyage from Harbour failed to identify, pilot needed." );
	endif;
	
	//create allPilots transient; // TFS 44438 after 040 cut/release

	create allMovementPilotDetails transient;// TFS 44438
	
	app.cmsBeginLoad( loadStateSet );
	pxyVoyage := selectedVoyage.pxyCreateUpdateProxy();
	app.cmsEndLoad( loadStateSet );
	create pxyVoyageData transient;
	pxyVoyage.setPropertyValue('myHMSVoyageData',pxyVoyageData);

	create pxyMovement transient;
	pxyMovement.setMyHMSVoyageData(pxyVoyageData);
	pxyMovement.setProxy(	0.0,	//_aftClearanceFrom : Decimal;
							0.0,	//_aftClearanceTo : Decimal;
							0.0,	//_bowMarkTo : Decimal;
							0.0,	//_sternMarkTo : Decimal;
							0.0,	//_foreClearanceFrom : Decimal;
							0.0,	//_foreClearanceTo : Decimal;
							0,	//_locationPilotLaunch : Integer;
							0,	//_locationTug : Integer;
							0,	//_numContractTugs : Integer;
							0,	//_moveStatus : Integer;
							0,	//_numLineCrewRequired : Integer;
							0,	//_relativeOrderTimeLines : Integer;
							0,	//_relativeOrderTimePlaunch : Integer;
							0,	//_relativeOrderTimeTugs : Integer;
							0,	//_sideTo : Integer;
							0,	//_draftFwd : Real;
							0,	//_draftAft : Real;
							null,	//_moveType : String;
							null,	//_remarks : String;
							null,	//_shipsMaster : String;
							app.actualTimeServer,	//_occursOnDT : TimeStamp;// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
							false,	//_chargeForMove : Boolean;
							false,	//_isAgentDefault : Boolean;
							false,	//_overlapsWharfSection : Boolean;
							false,	//_pilotExempt : Boolean;
							null,	//_myPilot : HMS_Pilot;
							master,	//_myMaster : HMS_Master;
							null,	//_myPilotLaunch : HMS_PilotLaunch;
							null,	//_myLineCompany : HMS_LineCompany;
							null,	//_myShippingAgent : CM_ShippingAgent;
							null,	//_myShippingLine : CM_ShippingLine;
							null,	//_myContact : CM_EmailAddress2;
							null,	//_myBerth : HMS_Berth;
							null,	//_myTidalClass : HMS_TidalClass;
							harbour,	//_myHarbour : HMS_Harbour
							//allPilots,	// _allPilots : HMS_PilotByCodeDict // TFS 44438 after 040 cut/release
							allMovementPilotDetails // TFS 44438
							);
							
	if pxyMovement.validate_ExemptMaster( false, errorInfo ) or errorInfo = null then
		assertTrueMsg( false, "Validation should have failed the Master moving the vessel with no Pilot." );
	endif;
	
	
	create pxyPilotExemption transient;
	today := app.actualTimeServer.Date;// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	certifiedDate := today;
	expiryDate := today.cnEcAddYears(5);
	revalidateDate := today.cnEcAddYears(1);
	validatingPilot := harbour.allPilots.first;
	
	pxyPilotExemption.setProxy(	certifiedDate,	//_certifiedDate : Date;
								expiryDate,	//_expiryDate : Date;
								revalidateDate,	//_revalidationDate : Date;
								vessel,	//_myVessel : CM_Vessel;
								validatingPilot,	//_myValidatedBy : HMS_Pilot;
								harbour,	//_myHarbour : HMS_Harbour;
								master	//_myMaster : HMS_Master
								);
	app.myTrxCA.trxCreatePilotExemptCert(pxyPilotExemption, pilotExemptionCertificate, app.myPassport);							
	assertTrueMsg( app.myPassport.trxCompletedOK, "Errors during Pilot Exemption Certificate create - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	assertTrueMsg( master.allPilotExemptionCertificates.size = 1, "Wrong number of Pilot Exemption Certificates.");
	assertTrueMsg( master.hasAnyCurrentPEC(), "Master not registering as having a current Pilot Exemption Certificate.");
	assertTrueMsg( master.hasCurrentPECforVessel( harbour, vessel, today ), "Master not registering as having a current Pilot Exemption Certificate for Vessel.");
	delete pxyPilotExemption;
	
	app.cmsBeginLoad( loadStateSet );
	pxyPilotExemption := pilotExemptionCertificate.pxyCreateUpdateProxy();
	app.cmsEndLoad( loadStateSet );
	
	revalidateDate := today.cnEcAddYears(2);
	pxyPilotExemption.setProxy(	certifiedDate,	//_certifiedDate : Date;
								expiryDate,	//_expiryDate : Date;
								revalidateDate,	//_revalidationDate : Date;
								vessel,	//_myVessel : CM_Vessel;
								validatingPilot,	//_myValidatedBy : HMS_Pilot;
								harbour,	//_myHarbour : HMS_Harbour;
								master	//_myMaster : HMS_Master
								);
								
	app.myTrxUA.trxUpdatePilotExemptCert(pxyPilotExemption, app.myPassport);
	assertTrueMsg( app.myPassport.trxCompletedOK, "Errors during Pilot Exemption Certificate update - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	assertTrueMsg( master.allPilotExemptionCertificates.first.hasAudits, "No Audits for Pilot Exemption Certificate after update.");
	
	if not pxyMovement.validate_ExemptMaster( false, errorInfo ) or errorInfo &lt;&gt; null then
		assertTrueMsg( false, "Validation should have Allowed the Master to the vessel with no Pilot, because he has the correct Exemption certificate." );
	endif;
	

	//16 Jan 2013	NDL	Par 30888 - Use Movement drafts if movement is available.
	assertTrueMsg( rule2.voyageRequiresPilotForRule( rule2Voyage, null ), "With NO movement in play should use voyage or vessel draft and require pilot." );
	
	pxyMovement.setPropertyValue("draftAft",(rule2.value - 0.01).Decimal);	// below the draft threshold declared on rule2 where a pilot is required
	assertTrueMsg( rule2.voyageRequiresPilotForRule( rule2Voyage, pxyMovement ) = false, "With movement in play should use draft value from movement which is below value and should NOT require a pilot." );
	
	pxyMovement.setPropertyValue("draftAft",rule2.value.Decimal);	// equal to the draft threshold declared on rule2, so a pilot is required					
	assertTrueMsg( rule2.voyageRequiresPilotForRule( rule2Voyage, pxyMovement ), "With movement in play should use draft value from movement, which EQUALS value and should require a pilot." );
	
	pxyMovement.setPropertyValue("draftAft",(rule2.value + 0.01).Decimal);	// above the draft threshold declared on rule2, so a pilot is required						
	assertTrueMsg( rule2.voyageRequiresPilotForRule( rule2Voyage, pxyMovement ), "With movement in play should use draft value from movement, which is ABOVE the value and should require a pilot." );
	
								
epilog

	delete pxyMovement;
	delete pxyMaster;
	delete pxyExemptRule;
	delete pxyPilotExemption;
	delete pxyVoyageData;
	delete pxyVoyage;
	//delete allPilots; // TFS 44438 after 040 cut/release
	delete allMovementPilotDetails; // TFS 44438
	
	self.deleteHMSPilotExemptRule( harbour, "U" &amp; HMS_PilotExemptionRule.Criteria_Length_Str);
	self.deleteHMSPilotExemptRule( harbour, "U" &amp; HMS_PilotExemptionRule.Criteria_Draft_Str);
	self.deleteHMSPilotExemptRule( harbour, "U" &amp; HMS_PilotExemptionRule.Criteria_Weight_Str);
	self.deleteHMSMaster( harbour,  MasterCode );

end;</source>
    </JadeMethod>
    <JadeMethod name="uListVoyageData" id="edde67dd-b830-4e9a-942d-5e7a29b57a54">
        <source>uListVoyageData();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 June 2012	cnwndl1	Initial creation

*/

vars

	voyage : CM_Voyage;
	vessel : CM_Vessel;
	tonnes : Decimal [8,2];
	length : Decimal [8,2];
	draft : Decimal [8,2];

begin

	foreach voyage in self.getTerminal.allVoyagesByCode do
		if voyage = self.getTerminal.getNullVoyage then
			continue;
		endif;
		vessel := voyage.getMyVessel;
		if vessel = null then
			continue;
		endif;
		if vessel.myHMSVesselData = null then
			continue;
		endif;
		tonnes := 0;
		length := 0;
		draft := 0;
		tonnes := vessel.myHMSVesselData.dim_GrossRegTonnes;
		length := vessel.myHMSVesselData.dim_LengthOverall;
		if vessel.myHMSVesselData.dim_DraftAft &gt; vessel.myHMSVesselData.dim_DraftFore then
			draft := vessel.myHMSVesselData.dim_DraftAft;	
		else
			draft := vessel.myHMSVesselData.dim_DraftFore;
		endif;
		
		write vessel.code &amp; " : " &amp; tonnes.String &amp;  " tonnes, " &amp; length.String &amp; " loa, " &amp; draft.String &amp; " draft";
		
	endforeach;

end;
</source>
    </JadeMethod>
</Class>
