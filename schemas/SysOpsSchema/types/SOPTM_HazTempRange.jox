    </JadeMethod>
    <JadeMethod name="doSave" id="8082fc4f-fe1c-4e08-b6ec-49d67776fc4e">
        <updating/>
        <source>doSave(): Boolean updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 04 November 2016	cnwdap1		Initial creation PAR #
//
vars
	errObj : CM_Error;
	idx : Integer;
	listBox : ListBox;
	ignoreWarnings, rtnValue : Boolean;
	pxyHazTempRange : CM_HazTempRange;
	colour : Integer;
	value, lower, upper : Real;
	form : SOP_TableMaintForm;
	
begin
	form := self.myForm; 

	value := form.tblInput1.getValueByName(ETRow_Value).String.asRealJMT;	//27 Apr 2017	NDL	TFS 4054
	colour := form.tblInput1.getValueByName(ETRow_Colour).Integer;
    upper := form.tblInput1.getValueByName(ETRow_Upper).String.asRealJMT;	//27 Apr 2017	NDL	TFS 4054
    lower := form.tblInput1.getValueByName(ETRow_Lower).String.asRealJMT;	//27 Apr 2017	NDL	TFS 4054
	if form.myProxyObject = null then
		if form.mode = form.Mode_Add then
			create form.myProxyObject as CM_HazTempRange transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	pxyHazTempRange := form.myProxyObject.CM_HazTempRange;
	pxyHazTempRange.setProxy(value, colour, upper, lower);

	if form.mode = form.Mode_Add then
		app.myTrxCA.trxCreateHazTempRange(pxyHazTempRange, form.myCurrentObject, app.myPassport);
		rtnValue := app.myPassport.trxCompletedOK;
	elseif form.mode = form.Mode_Update then
		app.myTrxUA.trxUpdateHazTempRange(pxyHazTempRange, app.myPassport);
		rtnValue := app.myPassport.trxCompletedOK;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; form.mode.String &amp; ')');
		return false;
	endif;
	
	return rtnValue;	

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
