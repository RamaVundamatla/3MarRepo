    <JadeMethod name="calculateVolForSplit" id="2642f6d1-4e8f-48f7-b56d-b2a3eaa08c4a">
        <source>calculateVolForSplit(_row : Integer; _col : Integer) : String;
// ---------------------------------------------------------------------------
// Created:     12 September 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	tmpValue,
	colOrdered, 
	rowAvail,
	volAllocated2,
	volAllocated	: Decimal[16,4];
	row,
	column,
	fixedColumns,
	fixedRows,
	idx2,
	idx 			: Integer;
	tmpStr2,
	tmpStr,
	tmpText			: String;
	table 			: CM_DataTable;
begin
	table := self.tblAllocDetail;

	fixedRows := table.fixedRows;
	fixedColumns := table.fixedColumns;
	row := _row;
	column := _col;

	//rowAvail := table.accessCell(row, 3).text.Decimal;
	rowAvail := table.accessCell(row, 3).text.asDecimalJMT();// 01 APR 2010	NDL	Par 23556

	tmpText := table.accessCell(row, column).text;
	tmpStr := tmpText[1:1].toUpper;

//	tmpText := tmpStr;
// 	only interested in calculating Remaining vaule as this one was not calculating in the transaction layer correctly. 
	if tmpStr = 'R' then 
	// 	work out value
		idx2 := table.columns;
		while idx2 &gt; fixedColumns do
			if idx2 &lt;&gt; column then
				// add rest of values and subtract off vol. 
				// should only be number values as can only have either 'remaining' and numbers 
				// in the table or 'all' and nothing else in table.
				tmpStr2 := table.accessCell(row, idx2).text;
				//volAllocated := (volAllocated + tmpStr2.Decimal);
				volAllocated := (volAllocated + tmpStr2.asDecimalJMT() );	// 01 APR 2010	NDL	Par 23556
			endif;
			idx2 := (idx2-1);	
		endwhile;
	tmpValue := rowAvail  - volAllocated;
	return tmpValue.String;
	endif;
// else return original cell text	
	return tmpText.String;
/*	
/	//Override value if row already allocated
	idx2 := table.columns;
	while idx2 &gt; fixedColumns do
		if idx2 &lt;&gt; column then
			tmpStr2 := table.accessCell(row, idx2).text;
			tmpStr2 := tmpStr2[1:1].toUpper;
			if 
				tmpText := '0';
				break;
			elseif tmpStr = 'A' and tmpStr2 &lt;&gt; null then
				if tmpStr2 &lt;&gt; '0' then
					tmpText := '0';
					break;			
				endif;
			endif;
		endif;
		idx2 := (idx2-1);
	endwhile;

// change text in table  if only 'a' or 'r' entered. 
/* if tmpText &lt;&gt; null then
		if tmpText[1].toUpper = 'A' then
			tmpText := 'All';
		elseif tmpText[1].toUpper = 'R' then
			tmpText := 'Remaining';
		endif;
	endif;
*/
/*	
	table.accessCell(row, column).text := tmpText;

	//Calculate remainder in row still to be allocated (each row)
	volAllocated := 0;
	idx := table.columns;				
	while idx &gt; fixedColumns do
		tmpText := table.accessCell(row, idx).text;
		tmpStr := tmpText[1:1].toUpper;
		if tmpStr = 'A' then
			//whole row allocated to this one lot
			volAllocated := rowAvail;
			break;
		elseif tmpStr = 'R' then
			//Balance remaining after other lots have been allowcated their share of the row
			volAllocated := rowAvail;
			break;		
		else
			//row split across multipule lots
		endif;
		idx := (idx-1);
	endwhile;
	
	//Row remainder still to be allocated to lot
	table.accessCell(row, 4).text := self.volumeDisplayString((rowAvail - volAllocated));

	//Calculate ramainder still to be allocated to lot (each column)
	idx := table.rows;
	volAllocated := 0;
	while idx &gt; fixedRows do
		tmpText := table.accessCell(idx, column).text;
		tmpStr := tmpText[1:1].toUpper;
		if tmpStr = 'A' then
			volAllocated := volAllocated + table.accessCell(idx, 3).text.Decimal;		
		elseif tmpStr = 'R' then
			idx2 := table.columns;
			volAllocated2 := null;				
			while idx2 &gt; fixedColumns do
				tmpStr2 := table.accessCell(idx, idx2).text;
				volAllocated2 := (volAllocated2 + tmpStr2.Decimal);
				idx2 := (idx2-1);
			endwhile;
			tmpValue := (table.accessCell(idx, 3).text.Decimal - volAllocated2);
			if tmpValue &lt; 0 then
				tmpValue := 0;
			endif;
			volAllocated := volAllocated + tmpValue;
		else			
			volAllocated := (volAllocated + tmpText.Decimal);
		endif;
		idx := (idx-1);
	endwhile;

	colOrdered := table.accessCell(2, column).text.Decimal;
	table.accessCell(3, column).text := self.volumeDisplayString((colOrdered - volAllocated));

	return;
*/
end;</source>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_col" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="clearAllTables" id="824c23a6-1384-400c-9398-9907a234af49">
        <updating/>
        <source>clearAllTables() updating;
//--------------------------------------------------------------
//Created: 24 July 2002 By: cnwgd1
//--------------------------------------------------------------
// 11/04/2011	cnwcs5	par 27367 - use clearAllData instead of setting rows to fixed rows
vars
	
begin

	self.myCurrentOperator			:= null;
	self.myCurrentStockOrderObject	:= null;
	self.myCurrentVoyage	 		:= null;
	self.myCurrentVoyageGlobal 		:= null;
	self.myCurrentVoyageOperator 	:= null;

	self.tblOrderData.clearAllData;	// par 27367
	
	self.detailsDisplaySelected();
	self.showSupplierDetails();
	self.showVoyageDetails();
end;</source>
