    <JadeMethod name="doLoadBulkReleases" id="99f863f3-6024-4f60-b0c9-66961f6f3c34">
        <source>doLoadBulkReleases() protected;
// ---------------------------------------------------------------------------
// Created:     22 March 2004	cnwth2
//
// Purpose:     
//	14/07/2025		naviv1	MTN-35226	MTN - Usage of Iterator.getCurrentKeys  			 
// ----------   ----------  --------------------------------------------------
vars
	cmb					: CMUI_ComboBox;
	terminal			: CM_Terminal;
	bulkReleaseDict		: CM_BulkReleaseByTypeStCodeDict; //CM_BulkReleaseByStatusByCode;
	bulkRelease			: CM_BulkRelease;
	iter				: Iterator;
	statusKey, typeKey			: Integer;
	codeKey				: String;
	keyDateRequested : TimeStamp;
begin
	terminal := self.cmbTerminal.listObject.CM_Terminal;
	if terminal = null then
		return;
	endif;
	cmb := self.cmbBulkRelease;
	cmb.clear();
	bulkReleaseDict := terminal.allBulkReleaseByTypeByStByCd; //allBulkReleaseByStatusByCode;
	
	if bulkReleaseDict.isEmpty then
		return;
	endif;
	
	iter := bulkReleaseDict.createIterator();
	
	// ROAD
	bulkReleaseDict.startKeyGeq(BR_TYPE_ROAD,BR_ACTIVE, null, null, iter);
	while iter.next(bulkRelease) do
		iter.getCurrentKeys(typeKey,statusKey, codeKey,keyDateRequested);  //MTN-35226
		if typeKey &lt;&gt; BR_TYPE_ROAD or statusKey &lt;&gt; BR_ACTIVE then
			break;
		endif;

		cmb.itemObject[cmb.addItem(bulkRelease.code)] := bulkRelease;			
	endwhile;

	// RAIL
	bulkReleaseDict.startKeyGeq(BR_TYPE_RAIL,BR_ACTIVE, null,null, iter);
	while iter.next(bulkRelease) do
		iter.getCurrentKeys(typeKey,statusKey, codeKey,keyDateRequested);  //MTN-35226
		if typeKey &lt;&gt; BR_TYPE_RAIL or statusKey &lt;&gt; BR_ACTIVE then
			break;
		endif;

		cmb.itemObject[cmb.addItem(bulkRelease.code)] := bulkRelease;			
	endwhile;
	
	// PACKING
	bulkReleaseDict.startKeyGeq(BR_TYPE_PACKING,BR_ACTIVE, null,null, iter);
	while iter.next(bulkRelease) do
		iter.getCurrentKeys(typeKey,statusKey, codeKey,keyDateRequested);  //MTN-35226
		if typeKey &lt;&gt; BR_TYPE_PACKING or statusKey &lt;&gt; BR_ACTIVE then
			break;
		endif;

		cmb.itemObject[cmb.addItem(bulkRelease.code)] := bulkRelease;			
	endwhile;
	
	if cmb.listCount() &gt; 0 then
		cmb.listIndex := 1;
	endif;
	self.doLoadReserveDetails();
	
epilog
	delete iter;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doLoadReserveDetails" id="42dad24d-7f55-4d2b-a339-bd45f16db621">
        <source>doLoadReserveDetails() protected;
// -----------------------------------------------------------------------------
// Created:		18 September 2009 by consw1
//
// Purpose:		Load Items for Release by Type
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	br 	: CM_BulkRelease;

begin
	br := self.cmbBulkRelease.listObject.CM_BulkRelease;

	self.cmbReserveDetail.clear();
	
	if br &lt;&gt; null then
		self.cmbReserveDetail.listCollection(br.allReserveDetails, true, 0);
	endif;
	
	self.cmbReserveDetail.enabled := (self.cmbReserveDetail.listCount() &gt; 0);
	
	if self.cmbReserveDetail.enabled then
		self.cmbReserveDetail.listIndex := 1;
	endif;
		
	self.lblReserveDetail.enabled := self.cmbReserveDetail.enabled;
		
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doLoadTerminals" id="95e28b0d-1f61-4b9a-b5d3-1a4bc9eec192">
        <source>doLoadTerminals() protected;
// ---------------------------------------------------------------------------
// Created:     22 March 2004	cnwth2
//
// Purpose:     Populates self.cmbTerminal for bulk release assignment function
//			 
// ----------   ----------  --------------------------------------------------
vars
	cmb					: CMUI_ComboBox;
	terminalDict		: CM_TerminalByCodeDict;
	terminal			: CM_Terminal;
begin
	terminalDict := app.myRoot.allTerminals;
	cmb := self.cmbTerminal;
	cmb.clear();
	foreach terminal in terminalDict do
		cmb.itemObject[cmb.addItem(terminal.code &amp; ' - ' &amp; terminal.name)] := terminal;	
	endforeach;
	
	cmb.listIndex := 1;
	terminal := terminalDict.first;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doMenuEnquire" id="4815f7c8-19db-492b-8e82-8e758b997868">
        <source>doMenuEnquire() protected;
// ---------------------------------------------------------------------------
// Created:     20 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
// Changed On	By			Reason
// ----------	----------	--------------------------------------------------
// 10/20/2011	cnwdap1		PAR #26830 CCMS POL 2013 don't set Selector terminal to null,
//								set it back to what it was before we went to cargo enquiry screen
//								(selector needs terminal so it can get security for Move it screen)
vars
	obj				: CM_Object;
	terminal		: CM_Terminal;		// PAR #26830
begin
	if self.isBaseFormModal then
		return;
	endif;
	
	obj := self.tblResults.accessRow(self.tblResults.row).itemObject.CM_Object;
	if obj = null or
	   not global.isValidObject(obj) then //par 15781 Jan 2008 cnwrs1
		return;
	endif;
	
	terminal := self.myAssistant.myTerminal;	// PAR #26830
	
	if obj.isKindOf(CM_TrackedItem) then
		// need to set the terminal so showCargoEnquiryForm can set permissions
		self.myAssistant.myTerminal := obj.CM_TrackedItem.myTerminal;
		self.myAssistant.showCargoEnquiryForm(obj, self.myMasterMenuAction, true, false);
	elseif obj.isKindOf(CM_BOL) then
		self.myAssistant.myTerminal := obj.CM_BOL.myTerminal;
		//th2 PAR 12235 - docket enquiry form not yet operational for anything except log dockets
		//so if it's not a log docket, open it in cargo enquiry
		if obj.CM_BOL.bolType = BOLType_Log then
			self.myAssistant.showDocketMaintForm(obj.CM_BOL, self.myMasterMenuAction, true, false);
		else
			self.myAssistant.showCargoEnquiryForm(obj, self.myMasterMenuAction, true, false);
		endif;
		
	endif;

	//self.myAssistant.myTerminal := null;		// PAR #26830
	self.myAssistant.myTerminal := terminal;	// PAR #26830

end;</source>
        <access>protected</access>
    </JadeMethod>
