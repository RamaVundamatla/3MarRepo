    <JadeMethod name="getMyTerminal" id="f72b9c7f-7bde-4c00-869e-3a75ce6467c8">
        <source>getMyTerminal(): CM_Terminal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 August 2018	jlgab1	Initial creation

*/

vars
	bank : CM_Bank;
begin

	bank := self.getBank();
	
