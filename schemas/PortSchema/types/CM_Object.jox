    <JadeMethod name="getDisplayStringForAttribute" id="74791c56-9629-49dc-a2fc-3704c4a1f5f2">
        <source>getDisplayStringForAttribute(_attrName : String; _short : Boolean) : String;
// ---------------------------------------------------------------------------
// Created:     09 April 2002 by cnwrs2
//
// Purpose:  
// 15 Nov 2023	navma	ChangeRequest 61117: MTN - Add JMTTestEnvironment Initialisation Flag    
// ---------------------------------------------------------------------------
vars 
	tmpValue	  : Any;
	tmpStr		  : String;
	invalidObject : Boolean;
	
begin

	on Exception do self.handleUnknownPropertyValue(exception, _attrName, self); // CNWAB1

	tmpValue := self.getPropertyValue(_attrName);
	
	if tmpValue.isKindOf(String) then
		tmpStr := tmpValue.String;
	elseif tmpValue.isKindOf(Time) then
		if tmpValue.Time.isValid then
			tmpStr := tmpValue.Time.shortFormatJMT();
		endif;
	elseif tmpValue.isKindOf(Date) then
		if tmpValue.Date.isValid then
			tmpStr := tmpValue.Date.shortFormatJMT();
		endif;
	elseif tmpValue.isKindOf(TimeStamp) then
		if tmpValue.TimeStamp.isValid then
			tmpStr := self.systemToLocalTime(tmpValue.TimeStamp).shortCurrentLocaleFormat();	// 19/04/2016 cnwmp6 TFS 488 - Multi timezone support
		endif;
	elseif tmpValue.isKindOf(Boolean) then
		tmpStr := app.getYesNo(tmpValue.Boolean);
	elseif tmpValue.isKindOf(CM_Object) then
		if tmpValue &lt;&gt; null then
			on Exception do app.handleDeletedObject( exception, tmpValue.CM_Object, invalidObject);
			tmpStr := tmpValue.CM_Object.getDisplayDetails(_short);
		endif;
	elseif tmpValue.isKindOf(Decimal) then  //27 Apr 2017	NDL	TFS 4054
		return tmpValue.asStringJMT;
	elseif tmpValue.isKindOf(Real) then 	//27 Apr 2017	NDL	TFS 4054
		return tmpValue.asStringJMT;
	else
		tmpStr := tmpValue.String;
	endif;

	return tmpStr;
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringTest" id="cead4b23-e86f-4ba6-9fb3-2b0483eae5e1">
        <source>getDisplayStringTest(_attrName : String; _short : Boolean) : String;
// ---------------------------------------------------------------------------
// Created:     09 April 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpValue	: Any;
	tmpStr		: String;
	propDict	: PropertyNDict;	
	prop		: Property;
begin
	
	tmpValue := self.getPropertyValue(_attrName);
	if tmpValue.isKindOf(String) then
		tmpStr := tmpValue.String;
	elseif tmpValue.isKindOf(Time) then
		if tmpValue.Time.isValid then
			tmpStr := tmpValue.Time.shortFormatJMT();
		endif;
	elseif tmpValue.isKindOf(Date) then
		if tmpValue.Date.isValid then
			tmpStr := tmpValue.Date.shortFormatJMT();
		endif;
	elseif tmpValue.isKindOf(TimeStamp) then
		if tmpValue.TimeStamp.isValid then
			tmpStr := tmpValue.Date.shortFormatJMT() &amp; ' ' &amp; tmpValue.Time.shortFormatJMT();
		endif;
	elseif tmpValue.isKindOf(Boolean) then
		tmpStr := app.getYesNo(tmpValue.Boolean);
	elseif tmpValue.isKindOf(CM_Object) then
		if tmpValue &lt;&gt; null then
			tmpStr := tmpValue.CM_Object.getDisplayDetails(_short);
		endif;
	else
		tmpStr := tmpValue.String;
	endif;
	
	return tmpStr;


end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
