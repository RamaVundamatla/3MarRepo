    <JadeMethod name="loadDB" id="d84e61f9-c8cb-417f-8bd3-261c2380fccf">
        <updating/>
        <source>loadDB(_mergeCargo : Boolean; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		23 January 2003  by Jason Chapman  (cnwjc2)ccms1063
// Rewritten 6.11.08 cnwgb1 PAR 18418 Maersk COREOR Processing DCT Gdansk
// Rewritten 9.4.2010 cnwdad1 PAR 22153. This is no longer a single data file,
//		and it now also supports partial DB load status.
// ---------------------------------------------------------------------------
/* Changes

Date		Name	TFS#		Description
============================================================================
15 Jul 2010	cnwdap1	PAR #25021 	review use of isImport/isExport for tranships
28 Mar 2011	cnwcs5	PAR 27150  	do not create alter or log an error if file fails to load completely
									  - only create an alert if tracked item cannot be updated, i.e. it is onsite
08 Oct 2015	cnwrs1	Par 36863  	make EDI consistant times when refreshing progress bar
13 May 2016	cnwns1	TFS 488  	Multi Timezone Support
03 Sep 2019 jlgka1 	TFS 45332 	STWR - Better Forms and Interfaces for EDI Module
20 Oct 2020	jlgmd1	TFS 50204	Refactor progress updates to superclass method
============================================================================*/

vars
	ediTI				: CM_EDITrackedItem;
	trackedItem			: CM_TrackedItem;
	terminalObj			: CM_Terminal;
	ediOperatorStopTi	: CM_EDIOperatorStopTI;
	partsTodo			: Integer;
	partsDone			: Integer;
	passport			: CM_Passport;
	voyageObj			: CM_Voyage;	// CCMS 1790 Gdansk cnwgb1 3.12.2008
	invalidVoyage		: Boolean;		// cnwgb1 PAR 20335 23.7.09
	isFullyProcessed	: Boolean;		// cnwdad1 09/04/2010 - PAR #22153.
	isFreeOfErrors		: Boolean;		// cnwdad1 09/04/2010 - PAR #22153.
	progressTS 			: TimeStamp;
	invalidTI 			: Boolean;	//09 Nov 2017	NDL	TFS 7580
	
begin
	on Exception do validationExceptionHandler(exception, _passport);
	on Exception do app.handleDeletedObject(exception, voyageObj, invalidVoyage); //cnwgb1 PAR 20335 23.7.09 Skip invalid voyages
	
	progressTS := app.actualTimeServer();// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	passport			:=	_passport;
	partsTodo			:=	self.allEDITrackedItems.size;
	terminalObj			:=	self.getMyTerminal();
	isFullyProcessed	:=	true;
	isFreeOfErrors		:=	true;
	
	self.updateProgress(progressTS, "Processing Operator Stop", partsTodo, partsDone, true, passport);
	
	foreach ediTI in self.allEDITrackedItems do
		partsDone	:=	partsDone + 1;
		
		self.updateProgress(progressTS, "Processing Operator Stop", partsTodo, partsDone, false, passport);

		ediOperatorStopTi	:=	ediTI.CM_EDIOperatorStopTI;
		
		if ediOperatorStopTi.status = CM_EDIFile.EDI_STATUS_DBLOADED then // Only unprocessed TIs
			continue;
		endif;
			
	/*	if ediOperatorStopTi.myTrackedItem &lt;&gt; null then	//04 Oct 2016	NDL	TFS 2718 / 2536
			trackedItem := ediOperatorStopTi.myTrackedItem;
		else
			trackedItem	:=	terminalObj.allOnsiteTIsByIdCargoType[ediOperatorStopTi.id, TI_CargoType_Container];
		endif; */
		
		//09 Nov 2017	NDL	TFS 7580
		trackedItem := null; 
		invalidTI := ediOperatorStopTi.getMyTrackedItem( trackedItem );
		if invalidTI then
			trackedItem := null;
		endif;
		if trackedItem = null then
			trackedItem	:=	terminalObj.allOnsiteTIsByIdCargoType[ediOperatorStopTi.id, TI_CargoType_Container];
		endif;
		
		//CCMS 1790 cnwgb1 3.12.2008
		if trackedItem = null  then // Tracked Item is not onsite yet, check incoming voyages released by planners
			foreach voyageObj in terminalObj.myEdiConfig.allVoyagesToProcess do
				if not voyageObj.hasDeparted() then //cnwgb1 PAR 20335 23.7.09
					trackedItem	:=	voyageObj.allOnshipTIsByIdCargoType[ediOperatorStopTi.id, TI_CargoType_Container];
					if trackedItem &lt;&gt; null then
						break;
					endif;
				endif;
			endforeach;
		endif;
		
		if trackedItem = null or  					// Tracked item isn't on any available voyages either
			(not trackedItem.isImport and			// Only Imports
			not trackedItem.isTranshipItem)	then	// PAR #25021
			isFullyProcessed	:=	false;
			continue;
		endif;
		
		app.myTrxUA.trxUpdateEDIOperatorStops(trackedItem, ediOperatorStopTi, passport);
		
		if passport.hasErrors() then
			isFreeOfErrors	:=	false;
			// 28/03/2011 par 27150 - log error and create an alert if the tracked item cannot be updated !!!
			app.writeLog('Database Load failed for ' &amp; trackedItem.id &amp; ' one or more items.', LogINFO);
			app.remoteErrorWarningToAlert('Database load failure - Customs EDI item(s) failed for ' &amp; trackedItem.id &amp; '.', null, passport.allErrors, null, false, true);
			app.myPassport.clearErrorsWarnings();
		endif;
	endforeach;
	
	self.updateProgress(progressTS, "Processing Operator Stop", partsTodo, partsDone, true, passport);
	
	if isFreeOfErrors then
		if isFullyProcessed then
			app.myTrxUA.trxSetEDIDataStatus(self, CM_EDIFile.EDI_STATUS_DBLOADED);
		else 
			app.myTrxUA.trxSetEDIDataStatus(self, CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
			//	28/03/2011 par 27150 -  it is OK to leave the file in a partially loaded state
		endif;
	else
		// If status is not set to partial load, this message will not get re-processed.
		app.myTrxUA.trxSetEDIDataStatus(self, CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	endif;
end;
</source>
        <Parameter name="_mergeCargo" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="processTIs" id="f1bc7d7c-bc7a-410c-9834-173fe42310cb">
        <updating/>
        <source>processTIs(_trackedItem : CM_TrackedItem; _type : Integer) updating;
// This method taks TI's from CMS and converts data to EDI TIs
// used to extract data from CMS
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
// 07 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	ediTrackedItem: CM_EDIOperatorStopTI;
	commodity: CM_Commodity;
begin
	if _trackedItem &lt;&gt; null then
		if _trackedItem.cargoType = TI_CargoType_Container then
			create ediTrackedItem persistent;
			ediTrackedItem.setForCreateNew(self);
			ediTrackedItem.setCargoType(_trackedItem.cargoType);
		else
			abortTransaction;
			return;
		endif;
		ediTrackedItem.setId(_trackedItem.id);
		if _trackedItem.isEmpty then
			ediTrackedItem.fullOrMT := "E";
		else
			ediTrackedItem.fullOrMT := "F";
		endif;
//		ediTrackedItem.voyageCode := _trackedItem.voyageCode;	// cnwrl1 09/06/2010 PAR 24299 - what it was
		// make sure the manual collection on CM_EDIConfig gets maintained
		ediTrackedItem.setVoyageCode( _trackedItem.voyageCode );
		if _trackedItem.myVoyage &lt;&gt; null then
			ediTrackedItem.vesselName := _trackedItem.myVoyage.vesselName;
		endif;
		ediTrackedItem.freightForwarder := _trackedItem.freightForwarderCode;	//31 May 2017	NDL TFS 4456
		ediTrackedItem.expiryDate := null;	//02 Jun 2017	NDL TFS 4455
	endif;
	//ediFile.errorStatus := CM_EDIFile.EDI_STATUS_LOADED;
end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
