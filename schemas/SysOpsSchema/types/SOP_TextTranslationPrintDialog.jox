    <JadeMethod name="btnPrint_click" id="3697743f-462f-45c0-b62a-1296ac71bff9">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnPrint_click(btn: Button input) updating;

vars

begin
