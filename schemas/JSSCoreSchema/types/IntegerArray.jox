<CollClass name="IntegerArray">
    <JadeMethod name="jssDoSort" id="873aaa14-3f9b-49e6-9b6c-888d63e69fe0">
        <lockReceiver/>
        <updating/>
        <source>jssDoSort(pSorterObj: JSSSorter) updating, protected, lockReceiver;
// --------------------------------------------------------------------------------
// Created:		08 February 2001 by cnwdad1
//
// Purpose:		Refer to method implementation on the Array class.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	integerValue	: Integer;
	sortKeyObj		: Object;

begin
	foreach integerValue in self do
		pSorterObj.addValue(integerValue);
	endforeach;
	
	self.purge();
	
	foreach sortKeyObj in pSorterObj.mySortColl do
		self.add(sortKeyObj.JSSSortKey.getValue.Integer);
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="pSorterObj" type="JSSSorter"/>
    </JadeMethod>
</CollClass>
