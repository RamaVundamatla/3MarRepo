    <JadeMethod name="doOK" id="09049efe-5cfc-488d-b361-7e6f467444f1">
        <updating/>
        <source>doOK() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 May 2010	#cnwdz2	 

*/

vars

begin
	app.mousePointer := Busy;
	self.currentDefname := self.txtNewDefName.text;
	inheritMethod();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="b6904f18-1f99-4d5e-8bff-38e2624e8fc5">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 May 2010	#cnwdz2	 

*/

vars

begin
	inheritMethod();
	app.mousePointer := Idle;
	self.txtNewDefName.maxLength := self.maxDefNameLength;
	self.txtNewDefName.text := self.currentDefname;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="c2396fab-b809-4173-b0f4-6efc56e3c752">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0014942, locale);
	lblInfo.translateCaption(Xlat_0014943, locale);
	lblInfo1.translateCaption(Xlat_0014944, locale);
	lblNewDefName.translateCaption(Xlat_0014945, locale);
end;</source>
    </JadeMethod>
</GUIClass>
