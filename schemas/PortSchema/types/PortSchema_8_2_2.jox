    <JadeMethod name="convertVoyageVesselStructures" id="9370cb51-9420-4ca9-b6ba-ffe8840d0829">
        <source>convertVoyageVesselStructures();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 August 2013	cnwrd1	Initial creation

*/


vars
	aVoyage : CM_Voyage;
	aVessel : CM_Vessel;
	aVoyageStructElements : CM_VoyageStructuralElements;
	aVesselStructElements : CM_VesselStructuralElements;	
	aSection : CM_VesselSection;
	aTank : CM_VesselTank;
	aRamp : CM_RORORampExternal ;
	aVesselSection : CM_VesselSectionVessel;
	aVesselTank : CM_VesselTankVessel;
	aVesselRORORamp : CM_RORORampExternalVessel;
	aVoyageSection : CM_VesselSectionVoyage;
	aVoyageTank : CM_VesselTankVoyage;
	aVoyageRORORamp : CM_RORORampExternalVoyage;	
	count : Integer;
begin

	app.writeLog( method.qualifiedName &amp; ' Converting  Vessel Structures 8.2.2', LogINFO);

	//need to step through every vessel and switch the structural elements over to the new class
	
	beginTransaction;
		
		
	foreach aVessel in CM_Vessel.instances do
	
		//first check if we've already done this one

		count := count +1;
		if count = 100 then
			count := 0;
			commitTransaction;
			beginTransaction;
		endif;
		if aVessel.myStructuralElements = null then
		
		//first we create us a structural element and set the voyage
		
			create aVesselStructElements;
			aVessel.setMyStructuralElements(aVesselStructElements);
			
			// now we go through the vessel cellular structure and move the sections and tanks
			
			if aVessel.myCellularVesselStructure &lt;&gt; null then
				foreach aTank in aVessel.myCellularVesselStructure.allTanks do
					aVesselTank := aTank.CM_VesselTankVessel;
					if aVesselTank.myVesselStructuralElement = null then
						aVesselTank.setMyVesselStructElements(aVesselStructElements);
						aVesselTank.setPropertyValue('myVesselStructure', null);
					endif;				
				endforeach;		
				
				
				foreach aSection in aVessel.myCellularVesselStructure.allSectionsByPosition do
					aVesselSection := aSection.CM_VesselSectionVessel;
					if aVesselSection.myVesselStructuralElement = null then
						aVesselSection.setMyVesselStructElements(aVesselStructElements);
						aVesselSection.setPropertyValue('myVesselStructure', null);
					endif;				
				endforeach;		
				
			endif;
		
			// and the ramps from the rorosrtucture
			
			if aVessel.myROROVesselStructure &lt;&gt; null then
				foreach aVesselRORORamp in aVessel.myROROVesselStructure.allRamps do
					//aVesselTank := aTank.CM_VesselTankVessel;
					if aVesselRORORamp.myVesselStructuralElement = null then
						aVesselRORORamp.setMyVesselStructElements(aVesselStructElements);
						aVesselRORORamp.setPropertyValue('myROROStructure', null);
					endif;				
				endforeach;		
			endif;
		
		endif;	
	endforeach;
	
	
	app.writeLog( method.qualifiedName &amp; ' Converting  Vessel Structures 8.2.2 Complete', LogINFO);

	
	app.writeLog( method.qualifiedName &amp; ' Converting  Voyage Structures 8.2.2', LogINFO);
	foreach aVoyage in CM_Voyage.instances do
		count := count +1;
		if count = 100 then
			count := 0;
			commitTransaction;
			beginTransaction;
		endif;

		//first check if we've already done this one
		
		if aVoyage.myStructuralElements = null then
		
		//first we create us a structural element and set the voyage
		
		create aVoyageStructElements;
		aVoyage.setMyStructuralElements(aVoyageStructElements);
		
		// now we go through the vessel cellular structure and move the sections and tanks
		
		if aVoyage.myCellularVoyageStructure &lt;&gt; null then
			foreach aTank in aVoyage.myCellularVoyageStructure.allTanks do
				aVoyageTank := aTank.CM_VesselTankVoyage;
				if aVoyageTank.myVoyageStructuralElement = null then
					aVoyageTank.setMyVoyageStructure(aVoyageStructElements);
					aVoyageTank.setPropertyValue('myVoyageStructure', null);
				endif;				
			endforeach;		
			
			
			foreach aSection in aVoyage.myCellularVoyageStructure.allSectionsByPosition do
				aVoyageSection := aSection.CM_VesselSectionVoyage;
				if aVoyageSection.myVoyageStructuralElement = null then
					aVoyageSection.setMyVoyageStructure(aVoyageStructElements);
					aVoyageSection.setPropertyValue('myVoyageStructure', null);
				endif;				
			endforeach;		
			
		endif;
		
		// and the ramps from the rorosrtucture
		
		if aVoyage.myROROStructure &lt;&gt; null then
			foreach aRamp in aVoyage.myROROStructure.allRamps do
				aVoyageRORORamp := aRamp.CM_RORORampExternalVoyage;
				if aVoyageRORORamp.myVoyageStructuralElement = null then
					aVoyageRORORamp.setMyVoyageStructure(aVoyageStructElements);
					aVoyageRORORamp.setPropertyValue('myVoyageStructure', null);
				endif;				
			endforeach;		
		endif;
		
		endif;	
	endforeach;	
	
	commitTransaction;
	
	app.writeLog( method.qualifiedName &amp; ' Converting  Voyage Structures 8.2.2 Complete', LogINFO);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="finishCAMSTimestampUpgrade" id="3e57cad7-a353-4ad7-bfda-b9794ceb2816">
        <source>finishCAMSTimestampUpgrade(_controller :CnEcReleaseController; _file :File) protected;
/*
Date		Who		Reason
24 Jun 2013	cnwcs5	Initial Creation - CCMS POL 1294/par 31505
*/
vars
	terminal	:CM_Terminal;
	upgrader	:CM_ObjectUpgraderCAMSTrx;
	str			:String;
	coll		:ObjectArray;
	obj			:Object;
begin		
	str	:= 'Finshing CAMS Timestamp Upgrade for 8.2.2';
			
	write str;
	self.logMessage(str, _controller, _file);
			
	create coll transient;
	
	CM_ObjectUpgraderCAMSTrx.allInstances (coll, null, false);
	
	foreach terminal in app.myRoot.allTerminals do	

		/// so we are re-runnable make sure we dont already have an upgrader for this terminal	
		upgrader := null;
		
		foreach obj in coll do
			upgrader := obj.CM_ObjectUpgraderCAMSTrx;
			
			if upgrader.myTerminal = terminal then
				break;
			endif;
			
			upgrader := null;
		endforeach;
		
		if upgrader = null then
			str	:= 'No CAMS Timestamp Upgrader object found - ignoring terminal ' &amp; terminal.code;
			
			write str;
			self.logMessage(str, _controller, _file);
			
			continue;
		endif;
		
		// perform final step of upgrade
		if upgrader.isComplete then
			
			str	:= 'CAMS Timestamp Upgrade already complete for ' &amp; terminal.code;
			
			write str;
			self.logMessage(str, _controller, _file);
		else
			str	:= 'CAMS Timestamp Upgrade not complete for ' &amp; terminal.code &amp; '. Finshing upgrade';
			
			write str;
			self.logMessage(str, _controller, _file);
			
			upgrader.runConversion (self, CM_ObjectUpgraderCAMSTrx.STYLE_NEXT_RELEASE_UPGRADE);
		endif;
		
		if upgrader.isComplete then
			// should always be the case
			beginTransaction;
			coll.remove (upgrader);
			delete upgrader;
			commitTransaction;
		endif;
	endforeach;

	str	:= 'Completed CAMS Timestamp Upgrade for 8.2.2';
			
	write str;
	self.logMessage(str, _controller, _file);

epilog
	delete coll;
end;</source>
        <access>protected</access>
        <Parameter name="_controller" type="CnEcReleaseController"/>
        <Parameter name="_file" type="File"/>
    </JadeMethod>
    <JadeMethod name="repairVoyageTEUSummaryReport" id="e934c4ad-8d96-4d4d-9e15-5aaf74268d3a">
        <source>repairVoyageTEUSummaryReport();
/*
Purpose:			
Date		Who		Reason
22 August 2013	cnwab1	Initial creation
*/

vars
	menuAgent			: CM_MenuAgent;
	menuRoot			: CM_MenuRootReportForRoot;
	report		: GlobalConstant;
begin
	app.writeLog( method.qualifiedName &amp; 'Repairing Voyage TEU Summary Report Object 8.2.2', LogINFO);
	
	create menuAgent transient;
		
	report 	 := currentSchema.getConstant('CM_RepVoyageTEUSummary');
	menuRoot := app.myRoot.myReportMenuRoot;
	
	beginTransaction;
	menuAgent.loadJMTMenuReportDetails(report, menuRoot);
	commitTransaction;
  
    write CM_RepVoyageTEUSummary;
epilog
 	delete menuAgent;

end;</source>
    </JadeMethod>
    <JadeMethod name="specificPostStandard" id="8cac49c5-3ee9-448b-b4d8-7089aaa3c629">
        <updating/>
        <source>specificPostStandard(_controller :CnEcReleaseController) updating;
/*
Purpose:			Specific Release upgrade for JMT 8.2.2

Parameters:			Release Controller

Date		Who		Reason
24 Jun 2013	cnwcs5	8.2.2 Release
*/
vars
	file	: File;
	str		: String;
begin
	create file transient;
	
	file.usePresentationFileSystem	:= false;
	//file.kind						:= File.Kind_ANSI;	// 29/2/16 cnwmp6 PAR 36286 unicode version
	file.mode						:= File.Mode_Output;
	file.fileName					:= app.myCnCntrl.logPath &amp; '\app_upgrade.log';
	
	if file.isAvailable then
		file.purge();
	endif;
	
	str	:= 'Performing Upgrade for JMT ' &amp; CM_Version.VERSION;
	self.logMessage( str, _controller, file );
	
	inheritMethod(_controller);
	
	self.finishCAMSTimestampUpgrade(_controller, file);	// cnwcs5 par 31505
	
	self.convertGCvesselVoyageStructs();	//10 July 2013	NDL	Par 31965
	
	self.convertTrailerAreasToBS();  //15/7/13 EPR par 31985
	
	self.convertCountryData(); //08 Aug 2013	NDL Par 32033
	
	self.convertLOLOTEUCapacity(); // 19 Aug CNWAB1 PAR 32286
	
	self.uppercaseVehicleColours();		// 21 Aug 2013 cnwdap1 PAR #32303
	
	self.repairVoyageTEUSummaryReport(); // 22 Aug CNWAB1 PAR 32179
	
	self.updateVehiclesUnknownChassis(); //23 Aug cnwer1 ccms 1338 
	
	self.convertVoyageVesselStructures(); //cnwrd1 par 31974
	
	//*************** this is the last thing that should happen
	str	:= 'Finished Upgrade for JMT ' &amp; CM_Version.VERSION;
	self.logMessage(str, _controller, file);
	
epilog
	delete file;
end;
</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
