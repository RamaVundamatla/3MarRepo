    <JadeMethod name="addMachineMovesByTypeAndShift" id="69408a95-f3a0-4975-9fef-1f7da5d46e47">
        <source>addMachineMovesByTypeAndShift( _machine : CM_Machine );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 Nov 2009	cnwndl1	Initial creation
11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/

vars

	iterShift : Iterator;
	shift : CM_Shift;
	startTime : TimeStamp;
	endTime : TimeStamp;
	allHistoryMoves : CM_MachineHistoryByDateTime;
	iterHistory : Iterator;
	firstHistory : CM_MachineHistory;
	history : CM_MachineHistory;
	move : CM_Move;
	ti : CM_TrackedItem;
	pickupSource : CM_LocationsController;
	sourceCont : CM_LocationsController;
	targetCont : CM_LocationsController;
//	is20 : Boolean;
//	is40 : Boolean;
//	source : String;
//	target : String;
	tmpFoundHeight : Integer;
	unmatchedPickups : CM_MachineHistoryByDateTime;
	movementsTotal : CMIF_ShiftMovementTotalsObject;
	
begin

	create allHistoryMoves transient;
	_machine.getMovesOnSelectedDate( self.selectedDate, allHistoryMoves );
	
	if allHistoryMoves.isEmpty then
		return;
	endif;
	
	create unmatchedPickups transient;
	iterHistory := allHistoryMoves.createIterator;
	
	// get all of the move details per (ship, road, yard) per shift from each machine
	iterShift := self.allShifts.createIterator;
	
	while iterShift.next( shift ) do
		iterHistory.reset();
		startTime := shift.startDateTime;
		endTime := shift.endDateTime;
		firstHistory := allHistoryMoves.getAtKeyGeq(startTime);
		if firstHistory = null or firstHistory.dateTime &gt;= endTime then
			// not in this shift
			continue;
		endif;
		
		movementsTotal := self.getShiftMovementsTotalsObj(shift);
		
		while iterHistory.next( history ) do
			if history.dateTime &gt;= endTime then
			// not in this shift
				break;	// will go to the next shift
			endif;
			
			if history.type = 5 or history.type = 6 or history.type = 7 then	// moved or pickup and set down
				
				move := history.CM_MachineMoveHistory.myMoveTransaction;
				if move = null or allMoves.includes(move) then
					//no associated move or move already processed...
					continue;
				endif;
				
				ti := move.myTrackedItem;
				if ti = null or not ti.isKindOf(CM_Container) then
					// only care about containers
					continue;
				endif;
				
			/*	Flip Flop Flip Flop
				is20 := ti.CM_Container.is20;
				is40 := ti.CM_Container.is40;
				if not is20 and not is40 then
					// only care about 20's and 40's
					continue;
				endif; */
				
				if history.CM_MachineMoveHistory.sourceLocation.trimBlanks = null then
					// can't be a real move!!
					continue;
				endif;
				if history.CM_MachineMoveHistory.targetLocation.trimBlanks = null then
					// can't be a real move!!
					continue;
				endif;
				
				//try to establish the move controller from the move
				sourceCont := null;
				targetCont := null;
				self.myTerminal.findLocationFromString(history.CM_MachineMoveHistory.sourceLocation, true, sourceCont, tmpFoundHeight);
				self.myTerminal.findLocationFromString(history.CM_MachineMoveHistory.targetLocation.trimBlanks, true, targetCont, tmpFoundHeight);
				
				if sourceCont = null or targetCont = null or sourceCont.isWagon or targetCont.isWagon then
					// couldn't work out the locations controller or was rail.
					continue;
				endif;
			
				if history.type = 6 then//	 This is a pickup, we only want to process each pickUp and set down only once.
					if not unmatchedPickups.includes(history) then	//24 Sep 2010	NDL Par 25579 - allow for users setting up overlapping shifts.
						unmatchedPickups.add(history);
					endif;
					continue;
				else
					if history.type = 7 then // this is a set down
						//the comparision needs to be done against the source of its previous pickup
						sourceCont := self.findPickUpSourceForSetDown(ti, unmatchedPickups);
						if sourceCont = null then
							// huh? - might have been on the machine over change of shift at change of day - too slow.
							continue;
						endif;
					endif;
				endif;
				
				movementsTotal.addNonRailMove( sourceCont, targetCont, ti );
				
			endif;
			
		endwhile;
		
	endwhile;
	
	
epilog
	delete iterHistory;			// PAR #26678
	delete iterShift;
	delete allHistoryMoves;
	delete unmatchedPickups;
	
end;</source>
        <Parameter name="_machine" type="CM_Machine"/>
    </JadeMethod>
    <JadeMethod name="addTrainStatTotalsObjects" id="b7773b65-2960-4c39-a0b5-e93c0d59c324">
        <updating/>
        <source>addTrainStatTotalsObjects( _train : CM_Train ) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 November 2009	cnwndl1	Initial creation

*/

vars

	iter : Iterator;
	shift : CM_Shift;
	startTime : TimeStamp;
	endTime : TimeStamp;
	inward : Boolean;
	totalsObject : CMIF_TrainStatTotalsObject;
	tis : CM_TIArray;
	ti : CM_TrackedItem;
	firstWorked : TimeStamp;
	lastWorked : TimeStamp;
	allTiRailMoves : CM_TITransactionByDateDict;
	trans : CM_TITransaction;
	
begin

	// create two 'CMIF_TrainStatTotalsObject' objects per train
	// per shift, one inward, and one outward.
	
	iter := self.allShifts.createIterator;
	while iter.next( shift ) do
		startTime := shift.startDateTime;
		endTime := shift.endDateTime;
		inward := true;
		create totalsObject transient;
		totalsObject.setBaseDataForMSLReport( inward, shift, _train, self );
	endwhile;
	delete iter;
	
	iter := self.allShifts.createIterator;
	while iter.next( shift ) do
		startTime := shift.startDateTime;
		endTime := shift.endDateTime;
		inward := false;
		create totalsObject transient;
		totalsObject.setBaseDataForMSLReport( inward, shift, _train, self );
	endwhile;
	delete iter;
	
	
	//now add the move data to the relevant 'CMIF_TrainStatTotalsObject' object
	create tis transient;
	create allTiRailMoves transient;
	
	_train.getAllTrackedItems(true, tis);	// inward cargo
	iter := tis.createIterator;
	while iter.next( ti ) do
		firstWorked := null;
		lastWorked := null;
		allTiRailMoves.clear();
		totalsObject := self.getTotalsObjectForTi( _train, true, ti, firstWorked, lastWorked, allTiRailMoves );
		if totalsObject &lt;&gt; null then
			totalsObject.addTiForMSLReport( ti, firstWorked, lastWorked );
			foreach trans in allTiRailMoves do
				if not allMoves.includes(trans) then	// Potential for a wagon to wagon move that has already been added from the other end
					self.allMoves.add(trans.CM_Move);
				endif;
			endforeach;
		endif;
	endwhile;
	tis.clear();
	
	_train.getAllTrackedItems(false, tis);	// outward cargo
	iter := tis.createIterator;
	while iter.next( ti ) do
		firstWorked := null;
		lastWorked := null;
		allTiRailMoves.clear();
		totalsObject := self.getTotalsObjectForTi( _train, false, ti, firstWorked, lastWorked, allTiRailMoves );
		if totalsObject &lt;&gt; null then
			totalsObject.addTiForMSLReport( ti, firstWorked, lastWorked );
			foreach trans in allTiRailMoves do
				if not allMoves.includes(trans) then
					self.allMoves.add(trans.CM_Move); 
				endif;
			endforeach;
		endif;
	endwhile;
	

epilog

	delete iter;
	delete tis;
	delete allTiRailMoves;
	
end;</source>
        <access>protected</access>
        <Parameter name="_train" type="CM_Train"/>
    </JadeMethod>
    <JadeMethod name="createEmptyShiftMovement" id="aeb87635-ed4f-4397-9118-e833d0613032">
