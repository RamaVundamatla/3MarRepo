    <JadeMethod name="doSave" id="9b637f19-261d-4c94-b5d0-831336f47982">
        <updating/>
        <source>doSave(): Boolean updating;
//------------------------------------------------
// Created: 06 April 2006 By: cnwgd1
//------------------------------------------------
vars
	notAvailable,
	rtnValue : Boolean;
	proxyLoader : CM_LoadingCompany;
	tmpCode, tmpDescription : String;
	theForm : SOP_TableMaintForm;
begin
	theForm := self.myForm; 

	tmpCode := theForm.tblInput1.getValueByName(ETRow_Code).String;
	tmpDescription := theForm.tblInput1.getValueByName(ETRow_Description).String;
	notAvailable := theForm.tblInput1.getValueByName(ETRow_IsNotAvailableForEntry).Boolean;
	
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_LoadingCompany transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	proxyLoader := theForm.myProxyObject.CM_LoadingCompany;
	proxyLoader.setProxy(tmpCode, tmpDescription, notAvailable, app.myRoot, app.myPassport);
	proxyLoader.allContacts.clear();
	theForm.mulSelect1.getSelected(proxyLoader.allContacts);
	
	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateLoadingCompany(proxyLoader, theForm.myCurrentObject,app.myPassport);
		rtnValue :=app.myPassport.trxCompletedOK;
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateLoadingCompany(proxyLoader,app.myPassport);
		rtnValue := app.myPassport.trxCompletedOK;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	return rtnValue;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
