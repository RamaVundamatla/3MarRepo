    <JadeMethod name="tblTaskCreation_dblClick" id="000fb39e-c944-4e24-b26c-64a6ef3be8f5">
        <controlMethod name="CM_EntryTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblTaskCreation_dblClick(table: CM_EntryTable input) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
07 March 2008	cnwer1	Initial creation - PAR#xxxx
17/03/2014		cnwmh5	Tranisent Leaks
*/
vars

	recipientMode : Integer;
	emailController : CMIF_EmailTemplateController;
	theFileFolder : FileFolder;
	directoryName : String;
	isMTPoolThreshold : Boolean;
	proxyThreshold : CM_AutoTaskMTPoolThreshold;
	
begin

	if self.state = State_View then	// #24990 15/07/2010
		return;
	endif;

	create emailController transient;
	recipientMode:=CMUI_RecipientSelector.Mode_To;
	if table.accessedRow &lt;&gt; null then
		
		if table.accessedRow.itemObject.EntTableRowTransient.name = ETRow_EmailRecipient then
		
			//27 Jun 2011	NDL	Par 27731
			isMTPoolThreshold := ( self.myProxyAutoTask &lt;&gt; null and self.myProxyAutoTask.isKindOf(CM_AutoTaskMTPoolThreshold) );
			if isMTPoolThreshold then
				proxyThreshold := self.myProxyAutoTask.CM_AutoTaskMTPoolThreshold;
				if not proxyThreshold.allSelectedEmailAddresses.isEmpty then
					proxyThreshold.allSelectedEmailAddresses.copy( emailController.allToAddresses );
				endif;
			endif;
			
			modalResult:=self.myAssistant.showRecipientSelector(emailController,recipientMode,true);
			if modalResult = IDOK then
				table.setValueByName(ETRow_EmailRecipient, emailController.allToAddresses.getAddresses);
				
				//27 Jun 2011	NDL	Par 27731
				if isMTPoolThreshold then
					proxyThreshold.allSelectedEmailAddresses.clear();
					if not emailController.allToAddresses.isEmpty then
						emailController.allToAddresses.copy(proxyThreshold.allSelectedEmailAddresses);
					endif;
				endif;
				
			endif;
		elseif table.accessedRow.itemObject.EntTableRowTransient.name = ETRow_BgpSnapShotDefinition then
			
			self.showSSDefinitionForm();
			
		elseif table.accessedRow.itemObject.EntTableRowTransient.name = ETRow_BgpAutoSelectorQuery then
			self.showSelector();
		elseif table.accessedRow.itemObject.EntTableRowTransient.name = ETRow_ServerFilePath then
			create theFileFolder transient;			
			directoryName	:=	theFileFolder.browseForFolder("", global.cnEcGetFileSeparator());			
			
			table.setValueByName(ETRow_ServerFilePath, directoryName);
			self.doCSVFilename(ETRow_CsvFileName,directoryName,self.tblTaskCreation.getValueByName(ETRow_BgpSnapShotDefinition).String);
		endif;
	endif;

epilog
	delete emailController;	
	delete theFileFolder;
end;</source>
        <Parameter name="table" type="CM_EntryTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblTaskDisplay_click" id="5438c0fb-d727-43c5-93ed-47229ec64b10">
