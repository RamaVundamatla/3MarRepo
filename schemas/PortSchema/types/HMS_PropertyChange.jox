<Class name="HMS_PropertyChange" id="86f3ece7-e039-49ea-9230-3a6b2e5a31ca">
    <superclass name="HMS_Object"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="hmsTrans"/>
    <ExplicitInverseRef name="myTransaction" id="e350f057-e045-498d-b016-9c6416a33fc0">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="HMS_Transaction"/>
        <access>readonly</access>
        <Inverse name="HMS_Transaction::allPropertyChanges"/>
    </ExplicitInverseRef>
    <PrimAttribute name="propertyDescription" id="447eca8b-eebc-4bbc-9941-d7be9b185381">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="propertyValueNew" id="313cff44-e2f8-4deb-af94-4616f06c632b">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="propertyValueOld" id="2832b315-156d-4d77-917b-6b7f5890bccc">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="set" id="6d05d841-6b1d-47cd-b263-5c855f16aa17">
        <updating/>
        <source>set(_trans : HMS_Transaction; _desc, _oldValue, _newValue : String) updating;
//--------------------------------------------------------------
//Created: 25 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	self.myTransaction := _trans;
	self.propertyDescription := _desc;
	self.propertyValueOld := _oldValue;
	self.propertyValueNew := _newValue;	
end;</source>
        <Parameter name="_trans" type="HMS_Transaction"/>
        <Parameter name="_desc" type="String"/>
        <Parameter name="_oldValue" type="String"/>
        <Parameter name="_newValue" type="String"/>
    </JadeMethod>
</Class>
