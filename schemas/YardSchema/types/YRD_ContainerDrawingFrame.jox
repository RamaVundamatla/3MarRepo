    <JadeMethod name="doDFContextMenu" id="850050b3-3000-43cb-aae8-d52f85d3fb9f">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>doDFContextMenu(frame: Frame input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		10 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	//CHECK WHAT TYPE OF DRAWING CONTROLLER WE ARE GOING TO BE USING
	//if not self.myDockBar.isForTrailers then															// cnwjk3 ccms 1018 4/12/09
	//	return self.myDockBar.myDrawingController.doDFContextMenu(frame, conwin, mouse, x, y);			// cnwjk3 ccms 1018 4/12/09
	if self.myDockBar.isForRoRoLanes then															// cnwjk3 ccms 1018 4/12/09
		if self.myDockBar.myRoRoLaneDrawingController &lt;&gt; null then
			return self.myDockBar.myRoRoLaneDrawingController.doDFContextMenu(frame, conwin, mouse, x, y);	// cnwjk3 ccms 1018 4/12/09
		else
			return false;
		endif;
	else
		return self.myDockBar.myDrawingController.doDFContextMenu(frame, conwin, mouse, x, y);
	endif;

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDFDblClick" id="2d6cfedd-2b07-4744-88df-a14f06744aca">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>doDFDblClick(frame: Frame input) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		10 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	//if self.myDockBar.isForRoRoLanes then							// cnwjk3	ccms 1018 4/12/09
	if self.myDockBar.isForRoRoLanes and self.myDockBar.myRoRoLaneDrawingController &lt;&gt; null then		// jlgmd1	TFS#36913 08/02/2018
		self.myDockBar.myRoRoLaneDrawingController.doDFDblClick(frame);	// cnwjk3	ccms 1018 4/12/09
	else
		self.myDockBar.myDrawingController.doDFDblClick(frame);
	endif;
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doDFDragDrop" id="0a5b2cb0-31fe-4e86-943e-d6a51fd68814">
