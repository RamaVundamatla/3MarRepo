        <updating/>
        <source>mnuAuditTI_click(menuItem: MenuItem input) updating;
//
// 04 May 2012	cnwrs1		Par 29531 - EDI Data/TI auditing
// 18/10/2012	cnwcs5		par 30501 - use correct clone of tblEDITI
//
vars
	table	:CM_DataTable;
	obj		:CM_Object;
begin
	// the actual table e are looking at will have been saved off in userObject
	table := menuItem.userObject.CM_DataTable;		
	
	if table &lt;&gt; null then
		obj := table.allSelectedObjects.first.CM_Object;
		
		if obj &lt;&gt; null then
			app.viewAuditForm(obj, self.myAssistant.class, self.myTerminal);
		endif;
	endif;
end;</source>
