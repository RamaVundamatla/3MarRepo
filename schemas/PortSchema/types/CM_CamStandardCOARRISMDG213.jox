    <JadeMethod name="outputHeader_UNH_BGM" id="bbb267f2-d443-4060-9a78-bc50e14a8e7a">
        <updating/>
        <source>outputHeader_UNH_BGM(_camFile: CM_CamFile input; _camTaskHistory: CM_CamTaskHistory input; _activity: Integer; _unhSeq: Integer io; _segmentCount: Integer io; _coll: HugeStringArray input): String updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 Jan 2018	cnwma1  ChangeRequest 36628: Create new CAMS file type for SMDG 2.13 COARRI
22 Dec 2020 cnwma1  Bug 50555: GPHA - BGM+98 and BGM+270 not working in COARRI SMDG 213
*/

vars
	strLine : String;
	docType : String;
begin

	//22.12.2020 cnwma1 #50555
	if _camTaskHistory.camProtocol.changeCOARRIBGM then
		if _activity = COARRI_SHIPLOAD then
			docType := CM_CamEDIFACTDesc.BGM_COARRI_162_LOAD ;
		elseif _activity = COARRI_SHIPDISCHARGE then 
			docType := CM_CamEDIFACTDesc.BGM_COARRI_162_DISCHARGE ;
		endif;
		
	//27Jan2023 navsp1 TFS 56282
	elseif _camTaskHistory.camProtocol.changeCOARRIBGM4446 then
		if _activity = COARRI_SHIPLOAD then
			docType := CM_CamEDIFACTDesc.BGM_COARRI_46_LOAD ;
		elseif _activity = COARRI_SHIPDISCHARGE then 
			docType := CM_CamEDIFACTDesc.BGM_COARRI_44_DISCHARGE ;
		endif;
	else
		if _activity = COARRI_SHIPLOAD then
			docType := CM_CamEDIFACTDesc.BGM_COARRI_213_LOAD ;
		elseif _activity = COARRI_SHIPDISCHARGE then 
			docType := CM_CamEDIFACTDesc.BGM_COARRI_213_DISCHARGE ;
		endif;
	endif;
	
	
	strLine := strLine &amp; self.makeMessageHeader(_camFile, _camTaskHistory, _unhSeq, docType, 'COARRI', _coll);
	_segmentCount := _segmentCount + 2;
	
	return strLine;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_activity" type="Integer"/>
        <Parameter name="_unhSeq" type="Integer" usage="io"/>
        <Parameter name="_segmentCount" type="Integer" usage="io"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="processTransaction" id="518bfb33-5155-4a82-87f7-74b868a2d25b">
        <updating/>
        <source>processTransaction(_transaction : CM_TITransaction; _camProtocol : CM_CamProtocol; _camAgent : CM_CamControllerAgent input; _camFile : CM_CamFile input) updating;
//31 Jan 2018	cnwma1  ChangeRequest 36628: Create new CAMS file type for SMDG 2.13 COARRI
//08 Apr 2022	jlika1	TFS 53181	GPHA - Voyage Code Translation for Multiple Terminals and Co-Loaders
vars
	camMessage : CM_CamMessage;
	xlVoyageId : String; 
	outOpVoyageCode : String;
	outVoyVoyageCode : String;
	code : String;
	vesselName : String;
	ti : CM_TrackedItem;
	voyage : CM_Voyage;
	pos3 : Integer;
	pos4 : Integer;
	pos5 : Integer;
begin
	_camAgent.writeDebugLog(class.name &amp; '::' &amp; method.name &amp; " process " &amp; _transaction.getCamsDisplayDetails);
	
	ti 	:= _transaction.myTrackedItem;
	
	if not self.includeRehandles(_camProtocol) then
		if ti.isRehandle or ti.isSOB then
			if _camAgent.logExcludedTransactions then
				_camAgent.logReasonForExclusion(_transaction, "Transaction is for a rehandle or SOB and they are not set to be included.");
			endif;
			return;
		endif;
	endif;
	
	voyage 	:= self.getVoyage (_transaction, ti);
	
	if voyage = null then
		if _camAgent.logExcludedTransactions then
			_camAgent.logReasonForExclusion(_transaction, "Transaction is for no voyage so is excluded.");
		endif;
		return;
	endif;
	
	//get the voyage code
	code := self.getCodeForVoyage(ti, voyage, _camProtocol);	
	vesselName := voyage.vesselName; 								
	
	//translate the voyage Code	
	self.getXlatedVoyageCodes(_camProtocol.operatorXlationCode.trimBlanks, code, outOpVoyageCode, outVoyVoyageCode, _camProtocol.terminal);
	if _camProtocol.getIsCustomsProtocol() and voyage.customsManifest &lt;&gt; null then		
		outVoyVoyageCode := voyage.customsManifest;
	endif;	

	if outOpVoyageCode.trimRight = "HOLD" or 
	   outOpVoyageCode.trimRight = "********" then
		app.writeLog("Error : Container " &amp; ti.id.trimRight &amp; " has an invalid voyage " &amp; outOpVoyageCode &amp; ".", LogINFO);
		if _camAgent.logExcludedTransactions then
			_camAgent.logReasonForExclusion(_transaction, "Transaction is for invalid voyages which are ignored.");
		endif;
		camMessage := null;
	elseif voyage.isHOLDSorSHIP() then
		app.writeLog("NonPlannedVoyages are ignored for this protocol.", LogWARN);
		if _camAgent.logExcludedTransactions then
			_camAgent.logReasonForExclusion(_transaction, "Transaction for NonPlannedVoyages which are ignored for this protocol.");
		endif;
		camMessage := null;
	else
		if _transaction.isCamsShipReleaseType() then
			camMessage := self.getCamMessageVoyage(_camFile, outOpVoyageCode, outVoyVoyageCode, vesselName, COARRI_SHIPLOAD, _camProtocol.singleContainerPerBGM);
		
		elseif _transaction.isCamsShipReceiveType() then
			camMessage := self.getCamMessageVoyage(_camFile, outOpVoyageCode, outVoyVoyageCode, vesselName, COARRI_SHIPDISCHARGE, _camProtocol.singleContainerPerBGM); 
		
		else
			//do nothing
			app.writeLog("No message. Not a ship receive/release.", LogWARN);
			if _camAgent.logExcludedTransactions then
				_camAgent.logReasonForExclusion(_transaction, "Transaction not a ship receive/release.");
			endif;
			camMessage := null;
		endif;
	endif;

	if camMessage = null then
		app.writeLog("CAM Message is null " &amp; _transaction.String &amp; ", " &amp; ti.id &amp; " for " &amp; outOpVoyageCode &amp; ".", LogERROR);
		if _camAgent.logExcludedTransactions then
			_camAgent.logReasonForExclusion(_transaction, "CAM Message is null " &amp; _transaction.String &amp; ", " &amp; ti.id &amp; " for " &amp; outOpVoyageCode &amp; ".");
		endif;
		return;
	endif;

	camMessage.camVoyage.voyageOid := voyage;
	
	//create all of the group 3 message now
	pos3 := camMessage.group3.size;
	
	self.makeMessages(null, _transaction, _camProtocol, camMessage, xlVoyageId, _camProtocol.terminal, null);

	camMessage.setupCAMSInfoDetails(_camProtocol, pos3, pos4, pos5, _transaction);
epilog
	
end;
</source>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent" usage="input"/>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
    </JadeMethod>
</Class>
