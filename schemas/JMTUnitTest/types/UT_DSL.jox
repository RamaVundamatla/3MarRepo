    <JadeMethod name="addMinMaxToTerminalArea" id="4b7c5a77-f4ff-4c04-83e1-286d35a29533">
        <source>addMinMaxToTerminalArea(	_tam : CM_TerminalAreaMaster input;
							_cargoType : CM_CargoType;
							_cargoSubType : CM_Product;
							_minVol	: Decimal;
							_minWeight : Integer; 
							_maxVol		: Decimal;
							_maxWeight : Integer;
							_maxQuantity : Integer
							);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 June 2016	cnwndl1	Initial creation	TFS 2172

*/

vars

	proxyTAM : CM_TerminalAreaMaster;
	proxyMinMax : CM_TerminalAreaProductMinMax;
	load : Boolean;

begin

	app.cmsBeginLoad(load);
	proxyTAM := _tam.pxyCreateUpdateProxy();
	app.cmsEndLoad(load);
	
	create proxyMinMax transient;
	proxyMinMax.setupProxy(	null,
							_cargoType,
							_cargoSubType,
							proxyTAM,
							_minVol,
							_minWeight,
							_maxVol,
							_maxWeight,
							_maxQuantity
							);

	app.myTrxUA.trxUpdateTerminalArea(proxyTAM, app.myPassport);

epilog

	app.cmsEndLoad(load);
	delete proxyMinMax;
	delete proxyTAM;

end;</source>
        <Parameter name="_tam" type="CM_TerminalAreaMaster" usage="input"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_cargoSubType" type="CM_Product"/>
        <Parameter name="_minVol" type="Decimal"/>
        <Parameter name="_minWeight" type="Integer"/>
        <Parameter name="_maxVol" type="Decimal"/>
        <Parameter name="_maxWeight" type="Integer"/>
        <Parameter name="_maxQuantity" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addOperator" id="32db778e-4d67-4bce-91e0-b02b9101758a">
        <source>addOperator(_code: String;
			_description: String;
			_notAvailableForEntry: Boolean;
			_colour: Integer;
			_reeferReadingsPerDay: Integer;
			_debtor: CM_Debtor;
			_displayTempFahrenheit: Boolean;
			_requiresBookingReference: Boolean;
			_requiresCVC: Boolean;
			_requiresConsigneeConsignor: Boolean;
			_requiresDeliveryRelease: Boolean;
			_requiresHumidity: Boolean;
			_requiresRequestNumber: Boolean;
			_requiresVentilation: Boolean;
			_requiresVoyage: Boolean;
			_cargoRelImpFFUpdAllowed: Boolean;	// adm 210708 CCMS 1738
			_notRoadIds,
			_notRailIds: CM_Strings;
			_allCodeGroups: CM_CodeGroupsByTypeDict;
			_reqExpOpNo: Boolean; //cnwrd1 4.11.08 CCMS JMT 1743/1764 
			_reqImpFF: Boolean; //cnwrd1 4.11.08 CCMS JMT 1743/1764 
			_reqImpOperatorPIN : Boolean; //cnwrd1 4.11.08 CCMS JMT 1743/1764 
			_cmifOpTermDict : CMIF_OpTerminalConfigDict;		// cnwar2 PAR 19796
			_emailAddresses : CM_EmailEntityByTypeNameDict; //25 Aug 2009	NDL	Par 20521
			_reeferWashExpiry : Integer; //cnwjo3 CCMS 1892, par 23587
			_configCMIF : CMIF_ConfigOperator input;
			_showOpExportReleaseWarning	:Boolean;	// 14/03/2011 cnwcs5 par 26909 
			_bookingsUniqueByNumber : Boolean		// 20/10/2011 cnwdap1 PAR #28524 CCMS POL 2096
			) : CM_Operator;
//02 September 2010	cnwvu1
// 	Additional values can be set in _configCMIF.

vars
	pxyOperator,
	operator:	 CM_Operator;

begin

	self.deleteOperator(_code);
	
	create pxyOperator transient;	
	
	pxyOperator.setProxy(	_code,
							_description,
							_notAvailableForEntry,
							_colour,
							_reeferReadingsPerDay,
							_debtor,
							_displayTempFahrenheit,
							_requiresBookingReference,
						    _requiresCVC,
						    _requiresConsigneeConsignor,
						    _requiresDeliveryRelease,
						    _requiresHumidity,
						    _requiresRequestNumber,
						    _requiresVentilation,
 						    _requiresVoyage,
							_cargoRelImpFFUpdAllowed, // adm 210708 CCMS 1738
 						    _notRoadIds,
 						    _notRailIds,
 						    _allCodeGroups,
							_reqExpOpNo,					//cnwrd1 4.11.08 CCMS JMT 1743/1764 
							_reqImpFF,						//cnwrd1 4.11.08 CCMS JMT 1743/1764 
							_reqImpOperatorPIN,				//cnwrd1 4.11.08 CCMS JMT 1743/1764 
							_cmifOpTermDict,				//cnwar2 - PAR 19796 
							_emailAddresses,				//_emailAddresses : CM_EmailEntityByTypeNameDict;
							_reeferWashExpiry, 				//cnwjo3 CCMS 1892, par 23587
							_showOpExportReleaseWarning,	// 14/03/2011 cnwcs5 par 26909 
							_bookingsUniqueByNumber			// 20/10/2011 cnwdap1 PAR #28524 CCMS POL 2096
							);

	
	app.myTrxCA.trxCreateOperator(pxyOperator, _configCMIF, operator, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	
	return operator;
	
epilog
	delete pxyOperator;

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_notAvailableForEntry" type="Boolean"/>
        <Parameter name="_colour" type="Integer"/>
        <Parameter name="_reeferReadingsPerDay" type="Integer"/>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <Parameter name="_displayTempFahrenheit" type="Boolean"/>
        <Parameter name="_requiresBookingReference" type="Boolean"/>
        <Parameter name="_requiresCVC" type="Boolean"/>
        <Parameter name="_requiresConsigneeConsignor" type="Boolean"/>
        <Parameter name="_requiresDeliveryRelease" type="Boolean"/>
        <Parameter name="_requiresHumidity" type="Boolean"/>
        <Parameter name="_requiresRequestNumber" type="Boolean"/>
        <Parameter name="_requiresVentilation" type="Boolean"/>
        <Parameter name="_requiresVoyage" type="Boolean"/>
        <Parameter name="_cargoRelImpFFUpdAllowed" type="Boolean"/>
        <Parameter name="_notRoadIds" type="CM_Strings"/>
        <Parameter name="_notRailIds" type="CM_Strings"/>
        <Parameter name="_allCodeGroups" type="CM_CodeGroupsByTypeDict"/>
        <Parameter name="_reqExpOpNo" type="Boolean"/>
        <Parameter name="_reqImpFF" type="Boolean"/>
        <Parameter name="_reqImpOperatorPIN" type="Boolean"/>
        <Parameter name="_cmifOpTermDict" type="CMIF_OpTerminalConfigDict"/>
        <Parameter name="_emailAddresses" type="CM_EmailEntityByTypeNameDict"/>
        <Parameter name="_reeferWashExpiry" type="Integer"/>
        <Parameter name="_configCMIF" type="CMIF_ConfigOperator" usage="input"/>
        <Parameter name="_showOpExportReleaseWarning" type="Boolean"/>
        <Parameter name="_bookingsUniqueByNumber" type="Boolean"/>
        <ReturnType type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="addOperatorGroup" id="88ad7677-c80f-4b0b-9259-6726f68f051d">
        <source>addOperatorGroup(_operatorGroupCode, _operatorGroupDesc : String) : CM_OperatorGroup;

/*

Purpose:		Create an operator group

Date			Who		Reason
06/03/2014		cnwmh5	Initial creation

*/

vars

	pxyOperatorGroup				: CM_OperatorGroup;
	operatorGroup					: CM_OperatorGroup;
	
	codeGroups						: CM_CodeGroupsByTypeDict;

begin

	self.deleteOperatorGroup(_operatorGroupCode);

	create codeGroups transient;
	
	create pxyOperatorGroup transient;
	pxyOperatorGroup.setProxy(_operatorGroupCode, _operatorGroupDesc, codeGroups, true);
	
	app.myTrxCA.trxCreateOperatorGroup(pxyOperatorGroup, operatorGroup, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

	return operatorGroup;

epilog

	delete codeGroups;
	delete pxyOperatorGroup;

end;</source>
        <Parameter name="_operatorGroupCode" type="String"/>
        <Parameter name="_operatorGroupDesc" type="String"/>
        <ReturnType type="CM_OperatorGroup"/>
    </JadeMethod>
    <JadeMethod name="addOperatorRequiresImpPin" id="e74836e4-4a67-4d89-b70b-b927b8efe926">
        <source>addOperatorRequiresImpPin(_code, _description : String): CM_Operator;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 December 2010	cnwrd1	Initial creation

*/

vars

	operator		: CM_Operator;
	logSpecs		: CM_CodeGroupLogSpecs;
