// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
begin
	self.selectObj(table.row, table.column, true);
epilog

end;
</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="e914d810-bc85-475e-8b24-81215229f14e">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0008164, locale);
	btnAdd.translateBubbleHelp(Xlat_0005298, locale);
	btnAdd.translateCaption(Xlat_0005299, locale);
	btnCancel.translateCaption(Xlat_0005300, locale);
	btnDelete.translateBubbleHelp(Xlat_0005301, locale);
	btnDelete.translateCaption(Xlat_0005302, locale);
	btnEdit.translateBubbleHelp(Xlat_0005303, locale);
	btnEdit.translateCaption(Xlat_0005304, locale);
	btnRefresh.translateBubbleHelp(Xlat_0005305, locale);
	btnRefresh.translateCaption(Xlat_0005306, locale);
	btnSave.translateCaption(Xlat_0005307, locale);
	btnShowDays.translateBubbleHelp(Xlat_0005308, locale);
	btnShowDays.translateCaption(Xlat_0005309, locale);
	frmReport.translateCaption(Xlat_0005310, locale);
	lblCopyDate.translateCaption(Xlat_0005311, locale);
	lblEndTime.translateCaption(Xlat_0005312, locale);
	lblMin.translateCaption(Xlat_0005313, locale);
	lblNumPerSlot.translateCaption(Xlat_0005314, locale);
	lblReport.translateCaption(Xlat_0005315, locale);
	lblStartTime.translateCaption(Xlat_0005316, locale);
	lblTimeInSlots.translateCaption(Xlat_0005317, locale);
	mnuCopyTimeSlot.translateCaption(Xlat_0008165, locale);
	mnuDelTimeSlot.translateCaption(Xlat_0008166, locale);
	mnuInsertTimeSlot.translateCaption(Xlat_0008167, locale);
	mnuInspect.translateCaption(Xlat_0008168, locale);
	mnuTS.translateCaption(Xlat_0008169, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="userNotify" id="b5752085-735c-44e6-9abd-3bc0e9455261">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:     01 May 2007 by cnwyl1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpEvent : Integer;
	tmpTerminal : CM_Terminal;
begin
	tmpTerminal := self.myTerminal;
	tmpEvent := tmpTerminal.getEventFromTerminalEvent(eventType);

	if tmpEvent = Event_TimeSlotStd_Add or 
			tmpEvent = Event_TimeSlotStd_Update or 
			tmpEvent = Event_TimeSlotStd_Delete then
		self.doTblUserNotify(theObject.CM_TimeSlotEntity);
	endif;
	
	inheritMethod(eventType, theObject, eventTag, userInfo);
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="valBulkCreateSlots" id="34ea2d8e-b181-4322-a06e-720de5e51122">
        <source>valBulkCreateSlots() : Boolean;
// ---------------------------------------------------------------------------
// Created:     01 May 2007 by cnwyl1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	timeStart,
	timeEnd,
	tmpTime,
	timeIS			: Time;
	timeInSlots,
	numOfSlot,
	day				: Integer;
	date			: Date;
begin
// cnwdad1 17/06/2009 - PAR #19942.
//	timeStart := self.txtTimeStart.text.Time;
//	timeEnd := self.txtTimeEnd.text.Time;
//	timeInSlots := self.txtTimeInSlots.text.Integer;
//	numOfSlot := self.txtNumOfSlots.text.Integer;
//	date := self.dateMask.text.Date;
	timeStart := self.txtTimeStart.getTime();
	timeEnd := self.txtTimeEnd.getTime();
	timeInSlots := self.txtTimeInSlots.text.Integer;
	numOfSlot := self.txtNumOfSlots.text.Integer;
	date := self.dateMask.getDate();
	
	if self.mode = MODE_CREATE then
		if timeInSlots = null then
		//	app.raiseCMException1(REQUIRED_FIELD, "Time Between Trucks", null, null);
			app.raiseCMException(Input_required_field_timBetTck, null, null); // cnwdb2	PAR 35364
			return false;
		endif;

		if not timeEnd.isValid() then
			app.raiseCMException1(ERR_INVALID_TIMESTAMP, 'End Time',null, null);
			return false;
		endif;		
	
		if timeEnd &lt;= timeStart then
			app.raiseCMException2(InvalidAttrForUpdate, 'End Time', 'End time must be after start time', null, null);
			return false;
		endif;
	endif;

	if self.mode = MODE_ADD then
		if numOfSlot = null then
		//	app.raiseCMException1(REQUIRED_FIELD, "NO. of Trucks", null, null);
			app.raiseCMException(Input_required_field_noOfTruck, null, null); // cnwdb2	PAR 35364
			return false;
		endif;
		
		if not timeStart.isValid() then
			app.raiseCMException1(ERR_INVALID_TIMESTAMP, 'Start Time',null, null);
			return false;
		endif;
	endif;
	
	if self.mode = MODE_COPY then
		if date.isValid() or date = null then
			app.raiseCMException1(ERR_INVALID_TIMESTAMP, 'The date copying from',null, null);
			return false;
		endif;
	endif;
	
	return true;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="valEditSlots" id="e4434cfd-c817-4707-8f2c-dbcbce032d0d">
        <source>valEditSlots(_startTime : Time; _row : Integer; _col : Integer) : Boolean;
// ---------------------------------------------------------------------------
// Created:     cnwyl1  Yi Liu
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	timeStart,
	timeEnd,
	tmpTime		: Time;
	idx			: Integer;
begin
	timeStart := self.tblTimeSlot.accessCell(_row, 1).text.Time;
	
	foreach idx in _row + 1 to self.tblTimeSlot.rows do
		tmpTime := self.tblTimeSlot.accessCell(idx, 1).text.Time;
		if timeStart = tmpTime then
			app.raiseCMException1(VB_DUPLICATED_ITEM, "Time Slot", null, null);
			return false;
		endif;
	endforeach;
	return true;
epilog

end;</source>
        <Parameter name="_startTime" type="Time"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_col" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
