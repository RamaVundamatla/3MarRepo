    <JadeMethod name="buildBookingComboBox" id="47332524-16f0-4e4c-a969-8a9b22392975">
        <source>buildBookingComboBox();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 May 2022	navcs2	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
11 Jul 2023 navma1	Defect 59095: EUP - Able to save the Receive Cargo Work Order without the Booking selected when the VAS Subscription is on/off

*/

vars
	bookingRef : CM_BookingRef;
begin
	
	if myBookingItem &lt;&gt; null then
		
		bookingRef := myBookingItem.myBookingReference;
		
		self.cmbBooking.addItemObject(bookingRef.bookingReference, bookingRef);
		self.cmbBooking.setIndexFromObject(bookingRef);	
		self.cmbBooking.enabled	  := false;
		self.cmbSite.setForText(app.siteEnumToString(SEL_QUERYSITE_NOTIFIED));
		self.cmbSite.enabled 	  := false;
		self.cmbReleases.isHidden := true;
		self.cmbVoyage.enabled	  := false;
	else
		self.cmbBookings.visible  := false;
		self.cmbBooking.visible   := false;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="buildReleaseRequestsCombo" id="eb5419d0-3063-4a0d-9d7e-52c03845899e">
        <source>buildReleaseRequestsCombo();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 May 2022	navcs2	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
16 Oct 2023 navlc30 ChangeRequest 58996: EUP | VBS changes MTN - Adding multiple items at once (From Ticket FR 53429)

*/

vars

begin
	if self.myReserveDetail &lt;&gt; null then
		self.cmbRelease.addItemObject(self.myReserveDetail.myReserveHeader.code, myReserveDetail.myReserveHeader);
		self.cmbRelease.setIndexFromObject(self.myReserveDetail.myReserveHeader);	
		self.cmbRelease.enabled := false;
		self.cmbSite.setForText(app.siteEnumToString(TI_SITE_ONSITE));
		self.cmbSite.enabled := false;
	elseif self.myContextSearchObject.isKindOf(CM_BulkRelease) then																				//16.10.2023 navlc30 #58996
		self.cmbRelease.addItemObject(self.myContextSearchObject.CM_BulkRelease.code, self.myContextSearchObject);
		self.cmbRelease.setIndexFromObject(self.myContextSearchObject);
		self.cmbReleases.visible := true;
		self.cmbReleases.enabled := false;
		self.cmbRelease.visible  := true;
		self.cmbRelease.enabled  := false;
	else
		self.cmbReleases.visible := false;
		self.cmbRelease.visible := false;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="chkShowAllOperator_change" id="f6a204f3-e15d-4926-aa1b-1a727719c95e">
        <controlMethod name="CheckBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>chkShowAllOperator_change(checkbox: CheckBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22/06/2023	navkc1	Bug 58784: EUP - Inv Maint Find Items use Debtor for Operators

*/

vars
	combo : CMUI_ComboOperator;
	
begin
	if checkbox.value then
		combo := self.cmbOperatorCode;
		combo.setInitialised(false);
		combo.initialise(true);
		self.isLimitingOperator := false;
	else
		self.doPopCmbOperatorFromDebtor(self.myDebtor);
	endif;
epilog

end;</source>
        <Parameter name="checkbox" type="CheckBox" usage="input"/>
    </JadeMethod>
