    <JadeMethod name="doMnuInvNewClick" id="222526cf-2489-4c31-9005-a28ca73d0b62">
        <updating/>
        <source>doMnuInvNewClick(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 10 March 2023  navmv20 TFS 56128 Task 56129: UI - Manual Invoice Lines - Multi TI Invoice Line Type

vars
	form : INV_InvoiceLineNew; //10 March 2023  navmv20 TFS 56128
begin
	//10 March 2023  navmv20 TFS 56128 Task 56129 - START
	//self.doBtnNewClick();
	if not self.getStatusGood() then
		app.msgBox("Cannot add new lines to VOID or POSTED invoices.","New Invoice Line Error",MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	form := app.loadForm(INV_InvoiceLineNew, 
					INV_Assistant, 
					false, 
					false,
					false, 
					self.myTerminal,
					null).INV_InvoiceLineNew;	
	
	if form = null then
		return;
	endif;
	form.createMyAssistant(INV_Assistant);
	form.setMyCurrentBank(self.myCurrentBank);
	form.setMyCurrentInvoice(self.myCurrentInvoice);
	form.myParentForm := self;
	form.showModal();
	//10 March 2023  navmv20 TFS 56128 Task 56129 - END
end;</source>
