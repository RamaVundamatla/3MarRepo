    <JadeMethod name="printReleaseWorksheet" id="7f1f5c95-10da-4aea-b3a3-85c27eeb1897">
        <source>printReleaseWorksheet(_jobsToPrint: CM_RailJobArray; _reportName: String);
//----------------------------------------------------------------
//	Created:	18 February 2005	by Jason Chapman  (cnwjc2)
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------
// 18 Mar 2010	consw1		PAR #22886 - Leaking report transients
//----------------------------------------------------------------
vars
	qryReport 			: CM_QryReport;
	jrwManager			: JadeReportWriterManager;
	jrwReport			: JadeReportWriterReport;
	jrwFileName			: String;
	jrwTransient		: CM_JRWWLE;
	reefer				: Object;
	jadeReport			: JadeReport;
	termDict			: CM_TerminalByCodeDict;
	job					: CM_RailJob;
	wle					: CM_WorkListEntry;
begin

	
	qryReport := app.myRoot.getQryReport(_reportName);//"Yard Worksheet - MT Rail Release");
	
	if qryReport = null then
		app.msgBox('Report ' &amp; _reportName &amp; ' not found.','Report',0);
		return;
	endif;
	
	jrwTransient := app.myQAFilter.createJRWTransient(CM_JRWWLE).CM_JRWWLE;
	
	if jrwTransient = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Failed to create JRW transient singleton');
		return;
	endif;
	
	jrwTransient.allWorkListEntries.clear();
	//populate the JRW transient singleton
	foreach job in _jobsToPrint do
		foreach wle in job.workListEntries do
			jrwTransient.allWorkListEntries.add(wle);
		endforeach;
	endforeach;
	
	create termDict transient;
	termDict.add(self.myTerminal);
//	jrwTransient.allTerminals.add(self.myTerminal);
	jrwTransient.setAllTerminals(termDict);
			
	jrwManager := app.createReportWriterManager();
	
	create jadeReport transient;

	app.printer.printPreview := false;

	jrwFileName := qryReport.jrwReportName.first;
	jrwReport := jrwManager.getReport(jrwFileName);
	jrwReport.setOutputDestination(JadeReportWriterReport.PRINTER);
	jadeReport.description := jrwReport.name;
	app.printer.setReport(jadeReport);
	jrwReport.run();

	if self.chkPrintPreview.value then
		app.printPreview(jadeReport, true);
	else
		app.printer.printReport(jadeReport);
	endif;

	abortTransaction;		// to clear any locks held by the report writer
	
epilog
	delete jrwManager;
	delete jrwReport;
	delete termDict;
end;</source>
        <Parameter name="_jobsToPrint" type="CM_RailJobArray"/>
        <Parameter name="_reportName" type="String"/>
    </JadeMethod>
    <JadeMethod name="rebuildWLEStatus" id="4038dc5a-f632-41f9-8146-9eaaaf5979a8">
        <updating/>
        <source>rebuildWLEStatus(_wle : CM_WorkListEntry input)updating;
//--------------------------------------------------------------
//Created: 28 February 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	obj : Object;
	rtnValue : Boolean;
	theResult : Integer;	//15 Jan 2020 NDL	TFS 46815
	
begin	

	if _wle = null then
		return;
	endif;
	
	app.mousePointer := MousePointer_HourGlass;
	
	//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateWLEStatus(_wle, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Rebuild Entry Status', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="input"/>
    </JadeMethod>
    <JadeMethod name="remarksUpdate" id="d9f19b95-177a-4a58-a0d3-0f5bc4115ea7">
        <source>remarksUpdate(_obj : CM_Object input);
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:		
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// ---------------------------------------------------------------------------

vars
	remarksFrm	: CMUI_Remarks;
begin
	
	if _obj = null then
		return;
	endif;
	
	// Update the navigator
	remarksFrm := app.loadForm(CMUI_Remarks, CMUI_Assistant, false, false, true, self.myTerminal, self.myMasterMenuAction).CMUI_Remarks;
	self.setNavigatorHeading(remarksFrm.caption); 
	remarksFrm.centreWindow;
	remarksFrm.myCurrentObject := _obj.CM_Object;
	remarksFrm.setMyTerminal(self.myTerminal);
	remarksFrm.showModal;
	
end;</source>
        <Parameter name="_obj" type="CM_Object" usage="input"/>
    </JadeMethod>
    <JadeMethod name="removeDynamicGridAreaFrames" id="243df707-2c76-4578-8387-3874ae9b6f02">
        <source>removeDynamicGridAreaFrames(_sdf : CMUI_ScrollableDrawingFrame) protected;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
// ---------------------------------------------------------------------------
// Purpose:		Remove all of the dynamically created grid area frames.
//				This should be done before mySDF.clearAll is done which
//				removes the transient objects representing the grid area frames.
//				Note this is done here instead of on mySDF so that we can
//				delete only the dynamic controls and not self.frmGridArea
//				which is the painted frame used to clone the controls.
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 17/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------
vars
	gridArea : CMUI_GridArea;
begin

	foreach gridArea in _sdf.allGridAreasByColumnRow do
		if gridArea.myGridAreaFrame &lt;&gt; self.frmGridArea then
			delete gridArea.myGridAreaFrame;
		endif;
	endforeach;
	
	_sdf.clearAll();
	
end;</source>
        <access>protected</access>
        <Parameter name="_sdf" type="CMUI_ScrollableDrawingFrame"/>
    </JadeMethod>
