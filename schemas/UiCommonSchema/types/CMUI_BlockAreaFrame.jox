    <JadeMethod name="getSelectedYardAllocation" id="712c6f7c-d085-4404-88e9-8028594c27a0">
        <source>getSelectedYardAllocation() : CM_YardAllocation;
//29 May 2008	cnwdw1	
//
vars
	yardAllocation : CM_YardAllocation;
begin
	yardAllocation := self.myDrawingController.getSelectedYardAllocation();
	if yardAllocation &lt;&gt; null and yardAllocation.isTransient() then
		yardAllocation := null;
	endif;
	return yardAllocation;
end;</source>
