    <JadeMethod name="displayForXlation" id="54eb58e3-5bc2-4690-b70c-cd1715ef9eba">
        <source>displayForXlation(_codeFirst: Boolean): String;
//
//15 Jul 2014	Par 34567	CCMS 2346 add EDI Xlation for Cargo Type and Cargo Sub Type
//
//16 Apr 2015	cnwrs1	Par 36065 Check cargotype and subtype
vars

begin
	if _codeFirst then
		return self.abbreviation.String.trimBlanks&amp;' ['&amp;self.description.trimBlanks&amp;']';
	else
		return self.description.trimBlanks&amp;' ['&amp;self.abbreviation.String.trimBlanks&amp;']';
	endif;
end;
</source>
        <Parameter name="_codeFirst" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
