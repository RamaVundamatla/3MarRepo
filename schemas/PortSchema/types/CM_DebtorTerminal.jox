    <JadeMethod name="setConsolidatedBalance" id="cc0b5f57-b242-4ad0-82eb-13d9b5a8f199">
        <updating/>
        <source>setConsolidatedBalance()updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 August 2012	cnwndl1	Initial creation
21 Oct 	  2019  cnwma1 Bug 47081: JMT - Decimal amount on Cash needs to be reviewed
*/

vars

	cash : CM_Cash;
	iter : Iterator;
	archiveBal : Decimal [23,6];	//21.10.2019 cnwma1 TFS #47081

begin

	iter := self.allConsolidatedCashTrx.createIterator;
	while iter.next( cash ) do
		archiveBal := archiveBal + cash.getAmountForBalanceTotal( self );
	endwhile;
	
	self.consolidatedBalance := archiveBal;

epilog

	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="setDefaultInvoiceJRW" id="4d4be203-8ba8-4fdd-9697-f89c455abb77">
