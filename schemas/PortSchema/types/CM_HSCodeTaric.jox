<Class name="CM_HSCodeTaric" id="5a96f282-f26a-43f7-a36f-bbbddcfe6927">
    <superclass name="CM_HarmonizedSystem"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="terminal"/>
    <ExplicitInverseRef name="myHSSubCode" id="00b04c6b-3154-43cf-bc42-a206034b5e75">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_HSCodeSubCode"/>
        <access>readonly</access>
        <Inverse name="CM_HSCodeSubCode::allHSTarics"/>
