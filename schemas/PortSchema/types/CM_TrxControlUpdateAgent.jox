    <JadeMethod name="trxUpdateSlotRequestSeqNum2" id="70060349-5668-4ec9-9c5c-565d4f2d0193">
        <updating/>
        <source>trxUpdateSlotRequestSeqNum2(	_customSeq 				: CMIF_CustomSeqObjectDictByReq;
								_isTwinMode,		
								_isStarboardBerthed		: Boolean; 
								_voyageJob				: CM_VoyageJob input;
								_passport				: CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
// ---------------------------------------------------------------------------
// 30 Aug 2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition 
vars
	lastTmpSeqObj,
	tmpSeqObj		: CMIF_CustomSequenceObject;
	tmpSlotRequest	: CM_SlotRequest;
	tmpSlotController	: CM_SlotController;
	termEvent		: Integer;		
	wle				: CM_WorkListEntry;
	wleUpdateEvent	: Integer;
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	
	if _customSeq = null then
		app.raiseCMException1(MethodWithNullParam, '_customSeq', null, null);
		return;
	endif;

	if _voyageJob = null then
		app.raiseCMException1(MethodWithNullParam, '_voyageJob', null, null);
		return;
	endif;
	
	sharedLock(_voyageJob);			

	foreach tmpSeqObj in _customSeq do
		tmpSlotController := tmpSeqObj.mySlotController;
		if tmpSlotController = null then
			app.raiseCMException1(MethodWithNullParam, 'seqObj.mySlotController', null, null);
			return;
		endif;
		tmpSlotRequest := tmpSeqObj.myRequest;
		if tmpSlotRequest = null then
			app.raiseCMException1(MethodWithNullParam, 'seqObj.myRequest', null, null);
			return;
		endif;

		if tmpSlotRequest.myJob &lt;&gt; _voyageJob then
			app.raiseUnexpectedProgramError(class.name, method.name, 'voyage job mismatch.');
			return;
		endif;
				
		exclusiveLock(tmpSlotController);
		if tmpSlotController.edition &lt;&gt; tmpSeqObj.expectedEdition then
			app.raiseCMException1(ObjectUpdatedByAnotherUserSave, app.getErrorString(Slot) &amp; ' ' &amp; tmpSlotController.ident, null, null);
			return;
		endif;
	endforeach;
		
	termEvent := _passport.myTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA);
	
	wleUpdateEvent := _passport.myTerminal.getTerminalEvent(WLE_Update_Event); 

	beginTransaction;
	
	foreach tmpSeqObj in _customSeq do
		tmpSlotRequest	:= tmpSeqObj.myRequest;
		tmpSlotController := tmpSeqObj.mySlotController;

		tmpSlotRequest.setCustomSeqNumber(tmpSeqObj.seqNum, _isStarboardBerthed);
	
		tmpSlotRequest.setSeqNumDefTwinCustom(tmpSeqObj, _isStarboardBerthed);

		if _passport.noErrors then
			// This will update the display on screen of this slot
			self.updateObjectEdition(tmpSlotController);	// par 30292
			
			tmpSlotController.myBayVoyage.myCellularVoyageStructure.myVoyage.causeEvent(termEvent, false, tmpSlotController);
			
			foreach wle in 	tmpSlotRequest.allWorkListEntries do
				wle.causeEvent(wleUpdateEvent, false, wle);
			endforeach;
		endif;
		lastTmpSeqObj := tmpSeqObj;
	endforeach;
	
	if _passport.hasErrors then
		return;
	endif;
	// Par 13644
	if _isTwinMode then
		_voyageJob.setTwinLift(_voyageJob.canBeTwinLiftVoyageJob());

	endif;

	//Par 8919 - re-calculate the flip side custom sequence number for this job				
	_voyageJob.calcCustomSequenceNumberOther(_isStarboardBerthed);
	_voyageJob.validateForTLSeqNums();	
	
	//31 Aug 2012	NDL	Par 30057
	if _passport.noErrors then
		//epr par 31205 3/4/13
		_voyageJob.setDefaultLoadLanes(null,null);
	endif;

epilog
	
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_customSeq" type="CMIF_CustomSeqObjectDictByReq"/>
        <Parameter name="_isTwinMode" type="Boolean"/>
        <Parameter name="_isStarboardBerthed" type="Boolean"/>
        <Parameter name="_voyageJob" type="CM_VoyageJob" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateSlotRequestVA" id="977d7d09-d129-4ff0-a552-b53b6bb3a077">
        <updating/>
        <source>trxUpdateSlotRequestVA(_theSlots, _theSlotsAlt : CM_SlotControllerArray; _isLoad : Boolean; _theEditions : CM_ObjectByOidEditionDict; _voyAlloc : CM_VoyageAllocation; _passport : CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 December 2009	cnwas3	Initial creation

*/

begin
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	self.doValidateSlotRequestVA(_theSlots, _theSlotsAlt, _isLoad, _theEditions, _voyAlloc, _passport);

	if (not self.checkValidationWithPassport(_passport)) then
		return;
	endif;

	beginTransaction;
	
	self.doUpdateSlotRequestVA(_theSlots, _theSlotsAlt, _isLoad, _voyAlloc, _passport);

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_theSlots" type="CM_SlotControllerArray"/>
        <Parameter name="_theSlotsAlt" type="CM_SlotControllerArray"/>
        <Parameter name="_isLoad" type="Boolean"/>
        <Parameter name="_theEditions" type="CM_ObjectByOidEditionDict"/>
        <Parameter name="_voyAlloc" type="CM_VoyageAllocation"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateSnapShot" id="c739a682-802d-4d29-b258-bbf6ff81d5d4">
        <updating/>
        <source>trxUpdateSnapShot(_pxySnapShot: CM_UserTISnapShot; _snapShots: CM_SnapShotSet; _changeReason: CM_MessageUser; _passport : CM_Passport input) updating;
//----------------------------------------------------------------
//	Created:	15 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	snapShot	: CM_SnapShot;
//	tiSnap		: CM_TISnapShot;
	userSnap	: CM_UserTISnapShot;
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);

	beginTransaction;
	foreach snapShot in _snapShots discreteLock do
		userSnap := snapShot.CM_TISnapShot.myUserTISnapShot;
		if userSnap = null then
			userSnap := app.myUtilityCA.utlCreateUserTISnapShot(snapShot.CM_TISnapShot, null, _passport);	
		endif;
		
		if _passport.hasErrorsOrWarnings() then
			return;
		endif;
		
		app.myUtilityUA.utlUpdateSnapShot(_pxySnapShot, userSnap, _changeReason, _passport);
	endforeach;
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_pxySnapShot" type="CM_UserTISnapShot"/>
        <Parameter name="_snapShots" type="CM_SnapShotSet"/>
        <Parameter name="_changeReason" type="CM_MessageUser"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateSnapShotFromCargo" id="da352dfe-9470-47d9-9a81-07b11acef082">
        <updating/>
        <source>trxUpdateSnapShotFromCargo(_entTableRow : EntTableRow; _realTISnapsShots : CM_SnapShotSet input; _passport : CM_Passport input) updating;
/*
Purpose:	TFS 40336		
Date				Who			Reason
SEPTEMBER 2018		CNWAB1		Initial creation
*/


vars
	snapShot	: CM_SnapShot;
	tiSnap :CM_TISnapShot;
	pxySnapShot, userSnap	: CM_UserTISnapShot;
	ti : CM_TrackedItem;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);

	beginTransaction;
	
	foreach snapShot in _realTISnapsShots do
		tiSnap := snapShot.CM_TISnapShot;
		userSnap := tiSnap.CM_TISnapShot.myUserTISnapShot;
		if userSnap = null then
			userSnap := app.myUtilityCA.utlCreateUserTISnapShot(tiSnap, null, _passport);	
		endif;
		pxySnapShot := app.createUpdateProxy(userSnap).CM_UserTISnapShot;
		
		ti := tiSnap.myTrackedItem;
		
		pxySnapShot.setProxyValueFromCargoProperty(_entTableRow, ti);
		
		app.myUtilityUA.utlUpdateSnapShot(pxySnapShot, userSnap, null, _passport);
		
		delete pxySnapShot;
		
		if _passport.hasErrorsOrWarnings() then
			break;
		endif;
		


	endforeach;
	
epilog
	delete pxySnapShot;
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_entTableRow" type="EntTableRow"/>
        <Parameter name="_realTISnapsShots" type="CM_SnapShotSet" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateSnapShotHide" id="27fd8add-e3d8-41b8-b854-7274716d4c82">
        <updating/>
        <source>trxUpdateSnapShotHide(_snapShots: CM_SnapShotSet; _changeReason: CM_MessageUser; _passport : CM_Passport input) updating;
//----------------------------------------------------------------
//	Created:	10 May 2006	by Jason Chapman  (cnwjc2)
//  RBarr 14/7/2006 Or show items currently hidden
//----------------------------------------------------------------
vars
	snapShot	: CM_SnapShot;
	tiSnap		: CM_TISnapShot;
	userSnap	: CM_UserTISnapShot;
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);

	beginTransaction;

	foreach snapShot in _snapShots do
		tiSnap := snapShot.CM_TISnapShot;
		if tiSnap.myUserTISnapShot = null then
			userSnap := app.myUtilityCA.utlCreateUserTISnapShot(tiSnap, _changeReason, _passport);
			app.myUtilityUA.utlUpdateSnapShotHide(userSnap, true, null, _passport);
		else
			userSnap :=  tiSnap.myUserTISnapShot;
			app.myUtilityUA.utlUpdateSnapShotHide(userSnap, not userSnap.ignore, _changeReason, _passport);
		endif;
	endforeach;
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_snapShots" type="CM_SnapShotSet"/>
        <Parameter name="_changeReason" type="CM_MessageUser"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
