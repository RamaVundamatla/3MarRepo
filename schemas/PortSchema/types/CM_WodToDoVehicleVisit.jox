    <JadeMethod name="prepareAuditDetail" id="1e9ef3a7-fe17-4dc7-9b77-0089bc253bfc">
        <source>prepareAuditDetail(_str : String io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 April 2023	navhl20	ChangeRequest 57301:[57303] EUP - [Framework] - Improve Audits on Work orders
21/04/2023	navcs2	Bug 57691: MTN - WO - Audits are missing for the totalActioned

*/

vars
	tmpStr	 	: String;
	vvr			: CM_VehicleVisitRecord;
begin
	inheritMethod(_str);
	tmpStr := null;
	if self.allVehicleVisits.isNotEmpty then
		foreach vvr in self.allVehicleVisits do
			if tmpStr = null then
				tmpStr := tmpStr &amp; vvr.visitNumber;
			else
				tmpStr :=tmpStr &amp; Comma &amp; vvr.visitNumber;
			endif;
		endforeach;
		_str := _str &amp; "Vehicle Visits" &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	// 21/04/2023	navcs2	Bug 57691 Start
	tmpStr := null;
	if self.allVehiclesActioned.isNotEmpty then
		tmpStr := self.allVehiclesActioned.size.String;
		_str := _str &amp; "Number Actioned" &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	else
		tmpStr := 0.String;
		_str := _str &amp; "Number Actioned" &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	// 21/04/2023	navcs2	Bug 57691 End
epilog

end;</source>
        <Parameter name="_str" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="e94becc2-227f-4ac2-87e6-ded706f2858c">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
19 December 2022	navcs2	ChangeRequest 56835:[56836] EUP - VAS Truck Work Order

*/

vars
	pxy 		: SelfType;
	completedOK : Boolean;
begin
	pxy := inheritMethod();
	
	self.allVehicleVisits.copy(pxy.allVehicleVisits);
	self.allVehiclesActioned.copy(pxy.allVehiclesActioned);
	self.allVehiclesCompleted.copy(pxy.allVehiclesCompleted);
	
	completedOK := true;
	return pxy;
epilog
	
	if not completedOK then
		delete pxy;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="325a8dc9-25bf-42da-a662-da0e8431ac11">
        <updating/>
        <source>setForUpdate(_pxyWoDDtl: CM_WodToDoVehicleVisit) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
03 October 2022	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs
20 Mar 2023  	navhl20 Defect 57233: MTN - Editing Vas Tasks is not working correctly
// ### TFS CR 56814 TASK 56813 07JUL2023 NAVAB1
*/

vars

begin
	inheritMethod(_pxyWoDDtl);
	self.allVehicleVisits.clear();																			//20.3.2023 navhl20	#57233
	_pxyWoDDtl.allVehicleVisits.copyNoDuplicates(self.allVehicleVisits, false);
epilog

end;</source>
        <Parameter name="_pxyWoDDtl" type="CM_WodToDoVehicleVisit"/>
    </JadeMethod>
    <JadeMethod name="setProxyToDo" id="f4f50b94-ddee-4d72-aa41-d40ae3c2f303">
