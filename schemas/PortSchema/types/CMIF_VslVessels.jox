    <JadeMethod name="initializeForActivity" id="c9b2d33a-9db6-4c92-b08e-a81e9acd784e">
        <updating/>
        <source>initializeForActivity(_any: Any; _ewsOpsView: CM_EWSActivityOpsview) updating;
/*
Purpose:			

Date		Who		Reason
27 August 2021	navab1	TFS 51853
*/

vars
	vessel : CM_Vessel;
	voyage : CM_Voyage;
begin
	inheritMethod(_any, _ewsOpsView);
	
	self.tableName		:= self.Vsl_vessels;
	
	if _any.isKindOf(CM_Voyage) then // ### TFS 53569 12MAY2022 NAVAB1
		voyage	:= _any.CM_Voyage;
		voyage.initializeForActivity(_ewsOpsView,self);
		/*
		self.gkey := self.generateFullGKey(_any.CM_Voyage.getMyVessel(), ""); // ### TFS 53569 12MAY2022 NAVAB1
		self.id	:= _any.CM_Voyage.vesselCode; // ### TFS 53569 12MAY2022 NAVAB1	
		self.name	:= _any.CM_Voyage.vesselName;  // ### TFS 53569 12MAY2022 NAVAB1 
		self.vesclass_gkey := self.generateFullGKey(_any.CM_Voyage.getMyVessel(), ""); // navra1 - 8th Sep 2022 - TFS53105
		*/
	elseif _any.isKindOf(CM_Vessel) then // ### TFS 53569 12MAY2022 NAVAB1
		vessel	:= _any.CM_Vessel;
		vessel.initializeForActivity(_ewsOpsView,self);
	/*
		self.gkey := self.generateFullGKey(_any, ""); // ### TFS 53569 12MAY2022 NAVAB1
		self.id	:= _any.CM_Vessel.code; // ### TFS 53569 12MAY2022 NAVAB1		:= self.mapper(_any,"id_vsl").String; // changed this from 'id' because it was getting the operator id. WAS CMIF_VslVessels::id.name).String;
		self.name	:= _any.CM_Vessel.name;  // ### TFS 53569 12MAY2022 NAVAB1  	:= self.mapper(_any,"name_vsl").String;		
		self.vesclass_gkey := self.generateFullGKey(_any, ""); // navra1 - 8th Sep 2022 - TFS53105
		*/
	endif;
	

epilog

end;</source>
        <Parameter name="_any" type="Any"/>
        <Parameter name="_ewsOpsView" type="CM_EWSActivityOpsview"/>
    </JadeMethod>
</Class>
