    <JadeMethod name="getMoveMode" id="9d4d8185-d944-40ab-a732-9f5f130a143a">
        <source>getMoveMode(): Integer;
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if self.modeView = ShpDisplayMode_Actual then
		return CMUI_GridAreaStatusLine.MENU_MOVE_INSTANT_ONLY ;
	elseif self.modeView = ShpDisplayMode_Proposed then
		return CMUI_GridAreaStatusLine.MENU_MOVE_PLAN_ONLY ;
	elseif self.modeView = WorkMode_Plan then
		return CMUI_GridAreaStatusLine.MENU_MOVE_PLAN_ONLY ;
	else
		return inheritMethod();
	endif;
end;</source>
