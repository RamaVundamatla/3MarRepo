    <JadeMethod name="doLogon" id="433eec15-ea16-402c-bf24-4d7422498528">
        <updating/>
        <source>doLogon() protected, updating;

/*

Date		Who		Reason
15 Oct 2009	cnwkpd1	Tidy up error message display
28 May 2010 cnwer1	reworked for CCMS 1099 Vehicle Mounted App
20 Oct 2011	cnwkpd1	PAR #28510 - Problems logging on in Windows Mobile 6.5 device
*/

vars
	username,
	password,
	errorStr		: String;
	modalResult 	: Integer;
	chgPass			: ChangePassword;

begin

	self.endTimeoutTimer(); //02 Mar 2011	NDL Par 26793	/ CCMS 2047

	app.setApplicationColors(0, 0, 0, 0);
	
	username	:=	self.txtUsername.text.trimBlanks();
	password	:=	self.txtPassword.getPasswordText().trimBlanks();			// PAR #28510
	
	app.myLogonAgent.doLogon(username, password, errorStr);
	if errorStr &lt;&gt; null then
		self.setupTimeout();	//02 Mar 2011	NDL	Par 26793 / CCMS 2047
		self.msgBox(errorStr,app.getErrorString(Logon_error), MsgBox_Exclamation_Mark_Icon, false);
		self.endTimeoutTimer(); //02 Mar 2011	NDL Par 26793	/ CCMS 2047
		
		//+cnwml2 PAR26208
		if errorStr = app.getErrorString(Err_Password_Expired) then
			create chgPass;
			modalResult := chgPass.showModal();
			if modalResult = 0 then
				//13 Sep 2011	NDL	Par 28102
				app.myLogonAgent.doLogon(username, chgPass.getPropertyValue(ChangePassword::repeatPass.name).String, errorStr);	
			else
				self.txtPassword.setFocus();
				self.setupTimeout();	//02 Mar 2011	NDL	Par 26793 / CCMS 2047
				return;
			endif;
		else
			self.txtPassword.setFocus();
			self.setupTimeout();	//02 Mar 2011	NDL	Par 26793 / CCMS 2047
			return;
		endif;
	endif;

	//  Get Locale here
	app.setLocale(app.getMyUser().getLocale());
	app.setTerminal();
	self.gotoHomeForm();
	
	
epilog
	
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="endTimeoutTimer" id="5e8b2832-5c11-4511-aacb-88527c164e4a">
        <source>endTimeoutTimer();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 March 2011	cnwndl1	Initial creation	Par 26793	/ CCMS 2047

*/

vars

	isActive : Boolean;
	option: Integer;
	timeRemaining: Integer;
	
begin

	isActive :=  self.getTimerStatus(	Mobile_App_Timeout,	//eventTag: Integer;
										option,	//option: Integer output;
										timeRemaining	//timeRemaining: Integer output
										);

	if isActive then
		self.endTimer(Mobile_App_Timeout);
	endif;

epilog

end;</source>
    </JadeMethod>
