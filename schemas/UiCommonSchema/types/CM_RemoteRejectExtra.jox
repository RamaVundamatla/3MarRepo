<Class name="CM_RemoteRejectExtra">
    <JadeMethod name="loadRemoteTable" id="a55858cd-163b-4952-8203-d8c2f5b0cf38">
        <updating/>
        <source>loadRemoteTable(_table : CM_EntryTable io) updating;

vars

begin

	inheritMethod(_table);
	self.addRemoteRow(_table, 'ID', self.id, null);
	self.addRemoteRow(_table, 'Reason code', self.reasonCode, null);
	self.addRemoteRow(_table, 'Recovery code', self.recoveryCode, null);

end;</source>
        <Parameter name="_table" type="CM_EntryTable" usage="io"/>
    </JadeMethod>
</Class>
