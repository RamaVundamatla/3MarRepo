        <updating/>
        <source>addTruncated(_value : String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 January 2021	jlgndl1	Initial creation	TFS 50581

*/

vars

begin

	if _value.length &gt; 200 then
   		self.add(_value[1:200]);
   	else
   		self.add(_value);
   	endif;

epilog

end;</source>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
