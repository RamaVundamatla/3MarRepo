    <JadeMethod name="getSelectedAvaGrades" id="326abbe5-4245-44bb-8b63-00005e7bed7d">
        <source>getSelectedAvaGrades(_avaGradesArray: IntegerArray input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 September 2008	cnwkao1	Initial creation - based on WebSchema implementation

*/

vars
	str			: String;
	strArray	: StringArray;
	grade		: Integer;
	reportParam	: WS_ReportParameter;
	
begin

	reportParam := self.allWSReportParams.getAtKey(ETRow_AvaGrade);
	if reportParam &lt;&gt; null then
		str := reportParam.value;
	endif;	
	
	_avaGradesArray.clear();
	
	if str.length &gt; 0 then
		create strArray transient;
		str.getTokensForDelimiter("|", strArray);
		foreach str in strArray do
			grade := str.Integer;
			_avaGradesArray.add(grade);
		endforeach;
	endif;

	
epilog
	delete strArray;
	
end;</source>
        <Parameter name="_avaGradesArray" type="IntegerArray" usage="input"/>
    </JadeMethod>
