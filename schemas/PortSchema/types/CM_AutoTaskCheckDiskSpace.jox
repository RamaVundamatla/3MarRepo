<Class name="CM_AutoTaskCheckDiskSpace" id="862f684b-3b9e-49bd-bad4-91b31661fb95">
    <superclass name="CM_AutoTask"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;Check Disk Space On Server&lt;/display&gt;</text>
    <DbClassMap file="backgroundprocess"/>
    <PrimAttribute name="freeDisk" id="a49920b3-d60c-4940-a178-8d63e75b123f">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="freeDiskServer" id="b5060018-f060-467a-8255-df6260d594e6">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getEntryTableViewName" id="f71d19fb-4f4d-47ad-a5f8-12867157a241">
        <source>getEntryTableViewName(): String;

// cnwdvb1 27 January 2003 

vars

begin
	return 'bgpAutoViewDiskSpace';

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getValueForRow" id="9ff35c5d-c3b2-40da-a9a0-18b2ae267ad2">
        <source>getValueForRow(_rowName: String; _obj : Object output): Any;

// cnwdvb1 27 January 2003 

vars

begin

	if _rowName = ETRow_BgpAutoDiskSpace then
		return self.freeDisk;
	elseif _rowName = ETRow_BgpAutoDiskSpaceServer then
		return self.freeDiskServer;
	endif;
	return inheritMethod(_rowName, _obj);

end;</source>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_obj" type="Object" usage="output"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="c080b404-32ce-4bc1-8d1d-98e7a49fe296">
        <updating/>
        <source>setForCreate(_pxyAutoTask: CM_AutoTaskCheckDiskSpace) updating;

// cnwdvb1 27 January 2003 

vars

begin
	inheritMethod(_pxyAutoTask);
	self.requestClassName	:= BGP_CheckDiskSpaceRequest.name;
	self.freeDisk			:= _pxyAutoTask.freeDisk;
	self.freeDiskServer		:= _pxyAutoTask.freeDiskServer;

end;</source>
        <Parameter name="_pxyAutoTask" type="CM_AutoTaskCheckDiskSpace"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="0cf3db3f-22eb-43b3-a79e-dd0a3f7a2fa5">
        <updating/>
        <source>setForUpdate(_pxyAutoTask: CM_AutoTaskCheckDiskSpace) updating;

// cnwdvb1 27 January 2003 

vars

begin
	inheritMethod(_pxyAutoTask);
	self.freeDisk		:= _pxyAutoTask.freeDisk;
	self.freeDiskServer	:= _pxyAutoTask.freeDiskServer;

end;</source>
        <Parameter name="_pxyAutoTask" type="CM_AutoTaskCheckDiskSpace"/>
    </JadeMethod>
    <JadeMethod name="setValueForRow" id="ad6571b8-8d54-433e-a1fd-d4ffd166bd70">
        <updating/>
        <source>setValueForRow(_rowName: String; _value: Any) updating;

// cnwdvb1 27 January 2003 

vars

begin

	if _rowName = ETRow_BgpAutoDiskSpace then
		self.freeDisk := _value.Integer;
	elseif _rowName = ETRow_BgpAutoDiskSpaceServer then
		self.freeDiskServer := _value.Integer;
	else
		inheritMethod(_rowName, _value);
	endif;

end;</source>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="validate" id="e85aae72-65b6-400b-bfd2-514ed5ae505a">
        <source>validate();

// cnwdvb1 27 January 2003 
// 12/12/2014  cnwdb2	PAR 35364

vars

begin
	inheritMethod();
	if self.freeDisk = 0 then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Number of MB on App Servers before Alert', ETRow_BgpAutoDiskSpace, null);
		app.raiseCMException(Input_required_field_NumMBApp, ETRow_BgpAutoDiskSpace, null);

	endif;
	
	if self.freeDiskServer = 0 then
//		app.raiseCMException1(REQUIRED_FIELD, 'Number of MB on DB Server before Alert', ETRow_BgpAutoDiskSpace, null);
		app.raiseCMException(Input_required_field_NumMbBfre, ETRow_BgpAutoDiskSpace, null); // cnwdb2	PAR 35364


	endif;

end;</source>
    </JadeMethod>
</Class>
