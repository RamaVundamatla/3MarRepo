    <JadeMethod name="validateBooking" id="56ac201d-2641-43fa-8245-5d002bfc28ed">
        <source>validateBooking( _fromBulkOutTrx : Boolean );
/*

Date		Who		Reason
24/09/2014	cnwer1	Initial creation PAR
09/10/2014	cnwdap1	PAR #34979 Check if gate entity in vehicle visit is a proxy of me, or is me
20/06/2015  cnwma1  PAR #37938 TFS #2160  MSL - Gate in MT container
*/

vars
	operator : CM_Operator;
	config	 : Integer;
	terminal : CM_Terminal;
	weight 		: Decimal[14,4];
	count			: Integer;
	ent				: CMGTE_Entity;
	isByWeight 		: Boolean;
begin	
	
	operator := self.getOperatorObject();
	
	if operator = null then
		return;
	endif;
	
	if not operator.requiresBookingReference then
		return;
	endif;
	
	config:=  self.myTerminal.getConfig(BookingRefRequired).Integer;
	
	if config = BookingRequired_None then
		return;
	endif;
	
	
	if self.bookingReference = null then
		//if self.imexStatus = TI_IMEX_STATUS_STORAGE and self.isMT() then			// 30/08/2010 +cnwmh5 #25562 MSL1078  // - 20/06/2016 cnwma1 PAR #37938 TFS #2160
	    if self.imexStatus = TI_IMEX_STATUS_STORAGE and  app.myRoot.isAnEmptyCommodity(self.commodity, true)then        // + 20/06/2016 cnwma1 PAR #37938 TFS #2160
			// don't need to check anything
		elseif config = BookingRequired_Partial then				//+cnwml2 PAR23763 MSL PAR1078
			app.raiseCMWarning2(ERR_INVALID_VALUE,"booking reference code", "You must enter a booking reference code.", null,self, null);
		elseif config = BookingRequired_Strict then
			app.raiseCMException2(ERR_INVALID_VALUE,"booking reference code", "You must enter a booking reference code.", null,self);
		endif;
	elseif self.myBookingRefItem = null then
		app.raiseCMException2(ERR_INVALID_VALUE,"booking reference item", "You must enter a booking reference item.", null,self);
	else
		terminal := self.getMyTerminal();
		if terminal.allBookingRefsByRef[self.bookingReference] = null then
			app.raiseCMException1(WARN_BOOKING_REF,self.bookingReference, null,self);
		else
			if self.myParent = null then					//no need to validate child cargo as it has no VVR +cnwml2 PAR26251
				//+cnwml2 PAR23763 MSL PAR1078
				//epr par 34935 29/9/14
				isByWeight:=self.myBookingRefItem.isBulkMulti;
				if  isByWeight then
					weight:=self.myBookingRefItem.getReceivedWeight;
					if _fromBulkOutTrx then	//21 Nov 2017	NDL	TFS 7820
						//during Outward Bulk Gate Trx, we will replace the temp '1 kg' with the real value. 
						weight := weight - 1;
					endif;
				else
					count :=self.myBookingRefItem.getRecievedCount;
				endif;
				//add on the ti we are working with now if we haven't already added it to the visit record
				if  isByWeight then
					weight:=weight + self.weightTotal;
				else	
					count := count + self.totalQuantity.max(1); 
				endif;
				//+cnwml2 PAR25885
				foreach ent in self.myVehicleVisitRecord.allGateEntities do					//only want to add receivals not releases for the current booking				
					//18 Feb 2011	NDL Par 27061 - do the checks first
					if not ent.isCMGTE_Receival then	
						continue;
					elseif ent.myBookingRefItem = null then
						continue;
					elseif ent.myBookingRefItem.myBookingReference &lt;&gt; self.myBookingRefItem.myBookingReference then
						continue;
					elseif ent.myBookingRefItem &lt;&gt; self.myBookingRefItem then	//13 Nov 2013	NDL	Par 32668
						continue;
					endif;				
					//continue if find self
					//if ent.pxyGetProxyObject = self then							// PAR #34979
					if ent.pxyGetProxyObject = self or ent = self then				// PAR #34979
						continue;
					endif;			
					if  isByWeight then
						weight:=weight + ent.CMGTE_Receival.weightTotal;
					else
						count := count + ent.totalQuantity.max(1);
					endif;			
				endforeach;
				
				if  isByWeight then
					if  self.myBookingRefItem.getWeight &lt; weight then
						if config = BookingRequired_Partial then
							app.raiseCMWarning3(ERR_Booking_Exceeded,self.jobTypeString,  self.myBookingRefItem.myBookingReference.bookingReference &amp;  " (" &amp;  self.myBookingRefItem.getShortDisplay() &amp; ")", null,null,self, null);
						elseif config = BookingRequired_Strict then
							app.raiseCMException3(ERR_Booking_Exceeded,self.jobTypeString,  self.myBookingRefItem.myBookingReference.bookingReference &amp;  " (" &amp;  self.myBookingRefItem.getShortDisplay() &amp; ")", null,null,self);
						endif;
					endif;
				else
					if  self.myBookingRefItem.getQuantity &lt; count then
						if config = BookingRequired_Partial then
							app.raiseCMWarning3(ERR_Booking_Exceeded,self.jobTypeString,  self.myBookingRefItem.myBookingReference.bookingReference &amp;  " (" &amp;  self.myBookingRefItem.getShortDisplay() &amp; ")", null,null,self, null);
						elseif config = BookingRequired_Strict then
							app.raiseCMException3(ERR_Booking_Exceeded,self.jobTypeString,  self.myBookingRefItem.myBookingReference.bookingReference &amp;  " (" &amp;  self.myBookingRefItem.getShortDisplay() &amp; ")", null,null,self);
						endif;
					endif;
				endif;
			endif;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_fromBulkOutTrx" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForAttachment" id="5934d727-83b2-4fb2-86e1-0b433382ab87">
        <updating/>
        <source>validateForAttachment(_passport : CM_Passport input) : Boolean updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 September 2009	cnwdap1	Initial creation
02/05/2018	jlgmd1	TFS #38259 C3 - Error on Road Gate
*/
vars
	theCargoType	: CM_CargoType;
	tmpTerm			: CM_Terminal;
	prenoteTI,
	pxyTI			: CM_TrackedItem;
	tiUpdCntrl		: CMIF_TIUpdateController;
	
begin
	// Should be called on a transient instance
	if not self.isTransient then
		app.raiseUnexpectedProgramError(class.name, method.name, 'transient method called for persistent object');
		return false;
	endif;	
	
	tmpTerm := self.getMyTerminal();
	
	theCargoType := app.myRoot.allCargoTypesById[self.cargoType];
	if theCargoType = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'cargo type', 'cargoType', self);
		if self.isTrailer then	//14 Oct 2020	NDL	TFS 49189
			app.raiseCMException(Must_select_type_trailer, 'trailer cargoType', self);
		else
			app.raiseCMException(Input_required_field_cargoType, 'cargoType', self); // cnwdb2	PAR 35364
		endif;
		return _passport.noErrors();
	endif;

	// Still need to do this check, if find a pre-note then need to do difference checks (as per edition change checks)
	if self.id &lt;&gt; null and self.cargoType &lt;&gt; null then
		// Child cargo should only be treated as pre-noted cargo, if the parent is also pre-noted!
		if self.myParent.CMGTE_Receival.isFromPrenote then	// 02/05/2018 jlgmd1 TFS #38259
			prenoteTI := self.myTerminal.lookupTrackedItem(self.id, self.cargoType, TI_STATE_NOTIFIED, null, false);
		endif;
	endif;
	if prenoteTI &lt;&gt; null then		

		self.myTrackedItem := prenoteTI;
		// 25/07/2008 cnwar2 #17525
		if self.tiEdition &lt;&gt; 0 and self.tiEdition &lt;&gt; prenoteTI.edition then
			if _passport.noErrors then
				
				// Since persisting the GTE_Entity and getting to this point, pre-note may have been updated.
				// Back in the GUI, we need to check for this exception being raised and then throw up a side by side comparison of the fields that have 
				// changed and allow the user to confirm/deny the changes???
				app.raiseCMWarning1(ObjectUpdatedByAnotherUserSave, 'Pre-Notified Item', null, null, self);
				//return false;
			endif;
		endif;
		self.isFromPrenote := true;
		pxyTI := app.createUpdateProxy(self.myTrackedItem).CM_TrackedItem;
	else
		//create the proxy from scratch
		self.isFromPrenote := false;
		pxyTI := self.myTerminal.createTI(theCargoType, true);	
		
		// Set here so that actionForCreateInternal() does not have to re-validate before creating the persistent instance from it
		//self.myTrackedItem := pxyTI;
	endif;

	pxyTI.setPxyFromCMGTE_Receival(self, _passport);	

	tiUpdCntrl := app.createTIUpdateControl(TI_UPDMODE_RECEIPT, null, null);
	tiUpdCntrl.isReceivalPrenote	:= self.isFromPrenote;
	tiUpdCntrl.isEDI				:= false;

	pxyTI.validateForAttachment(tiUpdCntrl, _passport);	//Sub items are recursively validated here

epilog
	delete pxyTI;
	if tiUpdCntrl &lt;&gt; null then
		delete tiUpdCntrl;
	endif;
	return _passport.noErrors();
	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="be443d3b-9aa9-4955-9a85-e9a55413706a">
        <updating/>
        <source>validateForCreate(_passport : CM_Passport input; _pxyTI : CM_TrackedItem io) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     14 December 2000 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 30/08/2010	cnwmh5	#25562 CCMS MES 1078 - Add additional check when checking booking reference so
//						that if receiving storage mt it doesn't check for a booking reference.
// 14/03/2011	cnwcs5	PAR 26909 - 7.8.2 hotfix - remove operator export release number warning message
//								  - 7.9.1 - display message based on operator configuration
// 18/01/2013	cnwdap1	PAR #31018 CCM POL 2223 validation of on power during transit details
// 31/03/2014	cnwdap1	PAR #33781 Validation from PAR #31018 moved to CM_TrackedItem validatePackDetails
//						method so it can be used by prenotes as well as receivals and normal updates
// 10/04/2014	cnwdap1	PAR #33606 CCMS SFW 1366 Bulk - check weight / volume cannot be greater than remaining weight / volume
// 19/06/2015	cnwdap1	PAR $36421 Hazardous Materials Handling - raise warning that commodity will be changed
// 28/09/2015   cnwma1  PAR #36924 Voyage cut-off early receival error message
// 12/10/2015   cnwma1  PAR #36519 Booking Calculations
// 17 Mar 2017	cnwrs1	TFS3778/TFS3801 dont lookup TIs that we already have
//23 May 2017	cnwma1	TFS #4450:C3 - 8.5.1.060_Testing - Unable to gate in FCL with attachments
// 02/05/2018	jlgmd1	TFS #38259 C3 - Error on Road Gate
// 28 Aug 2018	jlgrs1	TFS 39619 PEN - Approved Carriers For Operator 
//29/08/2018	JLGNS1	Bug 40008: PEN - Restrict Operator Issue - removed TFS2749
//23/06/2023	navpw1	TFS: 57812 (58798) - Added warning for setting itemised when the totalQuantity of break bulk is greater than 1
vars
	theCargoType	: CM_CargoType;
	theVoy 			: CM_Voyage;
	theOp 			: CM_Operator;
	tmpType 		: String;
	tmpTerm			: CM_Terminal;
	prenoteTI,
	pxyTI			: CM_TrackedItem;
	tiUpdCntrl		: CMIF_TIUpdateController;
	job				: CM_RoadJob;
	measure			: String;				// PAR #33606
	receivalValue	: String;				// PAR #33606
	prenoteValue	: String;				// PAR #33606
	hazCode			: String;				// PAR #36421
	bookCommodity	: CM_Commodity;			// PAR #36421
	receivalChild 	: CMGTE_Entity;
	carrier			: CM_Carrier;
	operator		: CM_Operator;
	tiId, 							//07/03/2025	navkc1 JIRA Story MTN-34225
	operatorStr		: String;
	dac				: CM_DataAccessController;
	cutoffPreNote	: Boolean; //07/03/2025	navkc1 JIRA Story MTN-34225
	cutoffTS,
	earliestTS		: TimeStamp; //07/03/2025	navkc1 JIRA Story MTN-34225
begin

	// Should be called on a transient instance
	if not self.isTransient then
		app.raiseUnexpectedProgramError(class.name, method.name, 'transient method called for persistent object');
		return false;
	endif;	
	tmpTerm := self.getMyTerminal();
	
	theCargoType := app.myRoot.allCargoTypesById[self.cargoType];
	if theCargoType = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'cargo type', 'cargoType', self);
		if self.isTrailer then	//14 Oct 2020	NDL	TFS 49189
			app.raiseCMException(Must_select_type_trailer, 'trailer cargoType', self);
		else
			app.raiseCMException(Input_required_field_cargoType, 'cargoType', self); // cnwdb2	PAR 35364
		endif;
		return false;
	endif;

	if self.id = null then
		tmpType := "Item";
		if theCargoType &lt;&gt; null then
			tmpType := theCargoType.description;
		endif;
		app.raiseCMException2(ERR_Cargo_Unknown,  tmpType, " ID was blank.", null, self);
		return false;
	endif;
	
	// 03/02/2012 cnwar2 #28799
	if self.carrier &lt;&gt; null 
	and self.myVehicleVisitRecord &lt;&gt; null                           // 12/10/2015 cnwma1 PAR #36519	
	and self.carrier &lt;&gt; self.myVehicleVisitRecord.carrierCode then 
		app.raiseCMWarning3(ReceivalCarrierMismatch, self.id, self.carrier, self.myVehicleVisitRecord.carrierCode, null, null, self);				// 18/09/2012 cnwmh5 #30233
		self.carrier := self.myVehicleVisitRecord.carrierCode;        								// 18/09/2012 cnwmh5 #30233
		
		// cnwmc5 - 4 Feb 2015 - PAR 35641
		// We don't want to return here if we are coming from the web service..
		// This is because the web service needs to do everything in one transaction,
		// by returning here, it causes the Pre-Note to not be used..
		if not app.isWebApp then
			return false;
		endif;
	endif;
	prenoteTI := self.myTrackedItem;
	if prenoteTI = null then
		// Child cargo should only be treated as pre-noted cargo, if the parent is also pre-noted!
		if self.myParent = null or (self.myParent &lt;&gt; null and self.myParent.CMGTE_Receival.isFromPrenote) then		// 02/05/2018 jlgmd1 TFS #38259
			prenoteTI := self.myTerminal.lookupTrackedItem(self.id, self.cargoType, TI_STATE_NOTIFIED, null, false);
		endif;
	endif;
	theVoy := tmpTerm.lookupVoyage (self.voyageCode, null, false);
	theOp := app.myRoot.allOperators[self.operatorCode];
	
	/*			28/09/2015 cnwma1 PAR #36924
	if theVoy &lt;&gt; null and theOp &lt;&gt; null then
		if  prenoteTI = null and theOp.hasReceivalCutOffForVoyage(theVoy)  then	// 12/03/2010 cnwar2 #22900 - allow receival for existing prenotes  //epr par 36705 2/9/15
			app.raiseCMException3(ERR_OP_CARGO_REL_HALT,self.operatorCode, self.voyageCode, app.getErrorString(Received).toLower, "operator",self); //+ cnwmd1 Par  25546
		endif;	
	endif;
	*/
		
	// PAR 18537 - give a warning if the operator release number not set
	// par 26909 - 7.8.2 hotfix - remove operator export release number warning
	// par 26909 - 7.9.1 - display operator export release number warning based on operator config setting
	if theOp &lt;&gt; null and 
		self.operatorExportReleaseNumber = null and // nothing entered
		theOp.getRequiresExportOperatorNo and		// release number required
		theOp.getShowOpExportReleaseWarning then	// they want a warning
		app.raiseCMWarning2(Operat_releas_number_requir_op, self.id, theOp.description, null, null, null);
	endif;
	
	//epr par 25/9/14 34935 refactored code block  into method
	self.validateBooking( false );
	
	if self.myVehicleVisitRecord &lt;&gt; null then
		job := self.myVehicleVisitRecord.myRoadJob;
		if job &lt;&gt; null then
			if job.autoComplete then	//12 Oct 2011 NDL	Par 28313
				self.validatePlannedLocation();
			endif;
		endif;
	endif;
	
	// RJS/JK - new validation added here:
	
	if prenoteTI &lt;&gt; null then		
		self.myTrackedItem := prenoteTI;
		//epr par 31726 12/6/13
		if prenoteTI.canSplitTotalQuantity then
			//epr TFS 1602 1/3/17 tiding up the errors
			if theCargoType.isBulkByQuantity and  self.totalQuantity &gt; prenoteTI.totalQuantity then
				app.raiseCMException2(Receival_quantity_gtr_prenote,self.totalQuantity.asStringJMT,prenoteTI.totalQuantity.asStringJMT,null,null);
			elseif theCargoType.isBulkByWeight and self.weightTotal &gt; prenoteTI.totalWeight then	// PAR #33606
				// get measurement type for error message																		// PAR #33606																// PAR #33606
				measure := theCargoType.myWeightMeasurementType.shortName;						// PAR #33606																														// PAR #33606
				receivalValue := app.convertMeasurementForDisplay(measure, self.weightTotal) &amp; Space &amp; measure;					// PAR #33606
				prenoteValue := app.convertMeasurementForDisplay(measure, prenoteTI.totalWeight) &amp; Space &amp; measure;				// PAR #33606
				app.raiseCMException2(Receival_weight_gtr_prenote, receivalValue, prenoteValue, null, null);					// PAR #33606
			elseif theCargoType.isBulkByVolume and self.volumeTotal &gt; prenoteTI.totalVolume then	// PAR #33606
				// get measurement type for error message																		// PAR #33606
				measure:= theCargoType.myVolumeMeasurementType.shortName;						// PAR #33606																										// PAR #33606
				receivalValue := app.convertMeasurementForDisplay(measure, self.volumeTotal) &amp; Space &amp; measure;					// PAR #33606
				prenoteValue := app.convertMeasurementForDisplay(measure, prenoteTI.totalVolume) &amp; Space &amp; measure;				// PAR #33606
				app.raiseCMException2(Receival_volume_gtr_prenote, receivalValue, prenoteValue, null, null);					// PAR #33606
			endif;
		endif;
		
		// 25/07/2008 cnwar2 #17525
		if self.tiEdition &lt;&gt; 0 and self.tiEdition &lt;&gt; prenoteTI.edition then
			if _passport.noErrors then
				
				// Since persisting the GTE_Entity and getting to this point, pre-note may have been updated.
				// Back in the GUI, we need to check for this exception being raised and then throw up a side by side comparison of the fields that have 
				// changed and allow the user to confirm/deny the changes???
				// For 7.7.3 we are just issuing a warning
				//app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Pre-Notified Item', null, null);
				app.raiseCMWarning1(ObjectUpdatedByAnotherUserSave, 'Pre-Notified Item', null, null, self);
				//return false;
			endif;
		endif;
		self.isFromPrenote := true;
		//23/05/2017 cnwma1 TFS #4450
		if not self.allChildren.isEmpty then
			foreach receivalChild in self.allChildren do
				if receivalChild.isKindOf(CMGTE_Receival) then
					receivalChild.CMGTE_Receival.isFromPrenote := true;
				endif;
			endforeach;
		endif;
		//pxyTI := app.createUpdateProxy(self.myTrackedItem).CM_TrackedItem;		// cnwjk3 PAR 22502 02/03/10
		if self.myTrackedItem.myParent = null then									// cnwjk3 PAR 22502 02/03/10
			//30 Nov 2016	NDL	TFS 2999
			if not self.myTerminal.getConfig(AllowDuplicatePreNotes).Boolean
			or not self.myTrackedItem.myCargoType.allowDuplicates then
				pxyTI := app.createUpdateProxy(self.myTrackedItem).CM_TrackedItem;		// cnwjk3 PAR 22502 02/03/10
			else
				pxyTI := self.myTrackedItem.pxyGetProxyObject();
				if pxyTI = null then
					pxyTI := app.createUpdateProxy(self.myTrackedItem).CM_TrackedItem;
				endif;
			endif;
		else 																		// cnwjk3 PAR 22502 02/03/10	
			pxyTI := self.myTrackedItem.pxyGetProxyObject();						// cnwjk3 PAR 22502 02/03/10
			if pxyTI = null then													// cnwjk3 PAR 22502 02/03/10
				pxyTI := app.createUpdateProxy(self.myTrackedItem).CM_TrackedItem;	// cnwjk3 PAR 22502 02/03/10
			endif;																	// cnwjk3 PAR 22502 02/03/10
		endif;																		// cnwjk3 PAR 22502 02/03/10		
	else
		//create the proxy from scratch
		self.isFromPrenote := false;
		pxyTI := self.myTerminal.createTI(theCargoType, true);			
	endif;

	pxyTI.setPxyFromCMGTE_Receival(self, _passport);	
	
	tiId := pxyTI.id; //07/03/2025	navkc1 JIRA Story MTN-34225
	
	cutoffPreNote := theVoy &lt;&gt; null and theVoy.shipCutoffsForPrenotes; //07/03/2025	navkc1 JIRA Story MTN-34225
	// 28/05/2009 cnwar2 CCMS1040/#19796
//	if theVoy &lt;&gt; null and not pxyTI.isPreNote then		// cnwmc5 - 16 Nov 2015 - PAR 37110
//		if (pxyTI.cutoffTS.isValid()
//		and pxyTI.cutoffTS &lt; app.actualTimeServer())
	if pxyTI.originallyCreatedAfterCutOff(cutoffTS) then	//20 Jan 2016	NDL	Par 37409
		if pxyTI.isPreNote() then //07/03/2025	navkc1 JIRA Story MTN-34225
			if cutoffPreNote then
				if tmpTerm.getConfig(ShipCutoffsShowError).Boolean = true then
					app.raiseCMException2(Receival_Outside_CutoffPN, tiId, cutoffTS.asStringJMT(), null, null);
				else
					app.raiseCMWarning2(Receival_Outside_CutoffPN, tiId, cutoffTS.asStringJMT(), null, null, null);
				endif;
			endif;
		else
			if tmpTerm.getConfig(ShipCutoffsShowError).Boolean = true then // PAR 35397
				app.raiseCMException1(Receival_Outside_Cutoff, tiId, null, null); // PAR 35397
			else
				app.raiseCMWarning1(Receival_Outside_Cutoff, tiId, null, null, null);
			endif;
		endif;
	else
		//25/03/2025	navkc1 JIRA Defect Sub-task MTN-34476 - This is a prenote created way before. Validate the cutoff time
		pxyTI.validateForPrenoteCutoff();
	endif;
	if theVoy &lt;&gt; null then
		earliestTS := pxyTI.earliestReceivalTS; //07/03/2025	navkc1 JIRA Story MTN-34225
		if (earliestTS.isValid()
		and earliestTS &gt; app.actualTimeServer())
		then
			if pxyTI.isPreNote() then //07/03/2025	navkc1 JIRA Story MTN-34225
				if cutoffPreNote then
					if  tmpTerm.getConfig(ShipCutoffsShowError).Boolean = true then
						app.raiseCMException2(Receival_Outside_EarliestPN, tiId, earliestTS.asStringJMT(), null, null);
					else
						app.raiseCMWarning2(Receival_Outside_EarliestPN, tiId, earliestTS.asStringJMT(), null, null, null);
					endif;
				endif;
			else
				if tmpTerm.getConfig(ShipCutoffsShowError).Boolean = true then // PAR 35397
					app.raiseCMException1(Receival_Outside_Earliest, tiId, null, null); // PAR 35397
				else
					app.raiseCMWarning1(Receival_Outside_Earliest, tiId, null, null, null);
				endif;
			endif;
		endif;
	endif;
	
	// PAR #36421 if terminal config option "Use Detailed Hazardous Entry Screen" is set,				// PAR #36421
	// warn user that commodity will be changed to the terminal's "No Info Hazardous" commodity			// PAR #36421
	if not self.allTIHazards.isEmpty and self.myTerminal.getConfig(UseDetailedHazEntry).Boolean then	// PAR #36421
		hazCode := self.myTerminal.getConfig(DefHazCommodity).String;									// PAR #36421
		if self.myBookingRefItem &lt;&gt; null and self.myBookingRefItem.getMyCommodity &lt;&gt; null then			// PAR #36421
			bookCommodity := self.myBookingRefItem.getMyCommodity;										// PAR #36421
			if bookCommodity.code &lt;&gt; hazCode then														// PAR #36421
				app.raiseCMWarning2(Commodity_Changed_Haz, self.id, hazCode, null, null, null);			// PAR #36421
			endif;																						// PAR #36421
		endif;																							// PAR #36421
		if bookCommodity = null then																	// PAR #36421
			if self.commodity &lt;&gt; hazCode then															// PAR #36421
				app.raiseCMWarning2(Commodity_Changed_Haz, self.id, hazCode, null, null, null);			// PAR #36421
			endif;																						// PAR #36421
		endif;																							// PAR #36421
	endif;																								// PAR #36421

	carrier := app.myRoot.allCarriers[self.carrier];		// 14/9/17 MAP TFS2749
	operator := app.myRoot.allOperators[self.operatorCode];
	if carrier &lt;&gt; null and not carrier.canCarrierAccessForOperator(operator, dac, false) then
		if operator &lt;&gt; null then
			operatorStr := operator.description;
		endif;
		app.raiseCMException2(Carri_does_not_have_acces_oper, carrier.description, operatorStr, null, null);
		return false;
	endif;
	// 16 Aug 2018	jlgrs1	TFS 39619 PEN - Approved Carriers For Operator 
//	if carrier &lt;&gt; null and
//	   operator &lt;&gt; null and
//	   theCargoType &lt;&gt; null and
//	   not operator.canOpAccessCarrierForCargoType(carrier, self.cargoType) then
//		app.raiseCMException3(Opera_denie_carri_acces_cargo_, operator.description, carrier.description, theCargoType.description, null, null);
//	endif;
	
	tiUpdCntrl := app.createTIUpdateControl(TI_UPDMODE_RECEIPT, null, null);
	tiUpdCntrl.isReceivalPrenote	:= self.isFromPrenote;
	tiUpdCntrl.isEDI				:= false;

	// ### TFS 57812 (58798) 22Jun2023 NAVPW1
	if self.itemised and self.totalQuantity &gt; 1 then
		app.raiseCMWarning(Itemi_been_track_item_quant_gr, null, null, null);
	endif;
	// ### TFS 57812 (58798) 22Jun2023 NAVPW1
	
	pxyTI.validateTrackedItem(tiUpdCntrl, _passport);	//Sub items are recursively validated here
	_pxyTI := pxyTI; // return this.  Caller must destroy!
epilog
	//delete pxyTI;  Caller will delete this.
	if tiUpdCntrl &lt;&gt; null then
		delete tiUpdCntrl;
	endif;
	return _passport.noErrors();
	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_pxyTI" type="CM_TrackedItem" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
