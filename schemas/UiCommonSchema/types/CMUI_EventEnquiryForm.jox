    <JadeMethod name="handleEventNotification" id="f1b66693-5353-41a6-87f2-252b459df1bc">
        <updating/>
        <source>handleEventNotification(eventType: Integer; _eventTrans : CM_EventTransaction; eventTag: Integer) updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	26 July 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	numItems			: Integer;
	breakOut			: Boolean;
begin
	if eventType = Object_Create_Event then
		if self.includesObject(_eventTrans) then
			self.addObjectToTable(_eventTrans, numItems, breakOut);
		endif;
	endif;
	
	
	

end;

</source>
        <access>protected</access>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="_eventTrans" type="CM_EventTransaction"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleTblDataDblClick" id="8f9b1b22-6e2e-4e50-b48d-ba282db1b930">
        <updating/>
        <source>handleTblDataDblClick(_row: Integer) updating;
/*
----------   ----------  --------------------------------------------------
Created:	25 July 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	ti					: CM_TrackedItem;
	releaseRequest		: CM_BulkRelease;
	event				: CM_EventTransaction;
begin
	event := tblData.accessRow(_row).itemObject.CM_EventTransaction;

	if CMEVT_OverriddenWarning.hasInstance(event) then
		if CM_TrackedItem.hasInstance(event.CMEVT_OverriddenWarning.mySubject) then
			ti :=event.CMEVT_OverriddenWarning.mySubject.CM_TrackedItem;
			app.myPassport.setMyTerminal(ti.myTerminal);
			self.myAssistant.showCargoEnquiryForm(ti, self.myMasterMenuAction, true, false);
		elseif CM_BulkRelease.hasInstance(event.CMEVT_OverriddenWarning.mySubject) then
			releaseRequest := event.CMEVT_OverriddenWarning.mySubject.CM_BulkRelease;
			self.myAssistant.setMyTerminal(releaseRequest.myTerminal);
			self.myAssistant.releaseRequestView(releaseRequest, self.myMasterMenuAction);
		
		endif;
		
	//25 Aug 2009	NDL	CCMS 1609 Par 20521
	elseif CMEVT_BookingRefDiscrep.hasInstance(event) then 
		self.doOpenBookingRefDiscrep( event.CMEVT_BookingRefDiscrep );
		
	endif;
end;

</source>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="931e7e81-3494-4fd0-8b5d-f9f9c325c2e3">
        <source>includesObject(_eventTrans : CM_EventTransaction) : Boolean protected;
/*
----------   ----------  --------------------------------------------------
Created:	11 July 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if self.allLoadedEvents.includes(_eventTrans) then
		return false;
	endif;
	
	if not self.filtIncludeNoUser then
		if _eventTrans.userCode = null then
			return false;
		endif;
	endif;
	
	if self.filtNeedFilterUsers then
		if self.filtAllUsers[_eventTrans.userCode] = null then
			return false;
		endif;
	endif;
	
	self.allLoadedEvents.add(_eventTrans);
	//app.writeStatement(class.name &amp; '::' &amp; method.name &amp; '-_eventTrans=' &amp; _eventTrans.String);
	return true;
end;

</source>
        <access>protected</access>
        <Parameter name="_eventTrans" type="CM_EventTransaction"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initDataTable" id="6f939823-cb32-4750-b079-c81bf4ae0f68">
