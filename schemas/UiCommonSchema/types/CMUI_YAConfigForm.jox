    <JadeMethod name="getRealYAConfig" id="3c4ac775-0632-406c-9c1f-40770025bcad">
        <source>getRealYAConfig() : CM_YAConfig;

/*

Purpose:			

Parameters:			Returns real CM_YAConfig from proxy

Return Value:		


