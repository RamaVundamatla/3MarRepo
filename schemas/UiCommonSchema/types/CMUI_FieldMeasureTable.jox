    <JadeMethod name="setWidths" id="95c76e99-72fd-46be-b171-68b7c8f96aa4">
        <updating/>
        <source>setWidths(_controlWidth: Integer; _labelWidth: Integer) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27/03/2013	cnwdap1	Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
*/
vars

begin
	inheritMethod(_controlWidth, _labelWidth);
	self.myMeasurementTable.width	:= _controlWidth *2 / 3;
	self.myMeasurementTable.left	:= self.width - _controlWidth;
	self.myMeasurementTable.setColumnWidths((self.myMeasurementTable.width / 2).Integer, (self.myMeasurementTable.width / 2).Integer - 7);
	self.myMeasurementTable.rowHeight[1] := self.height.Integer - 1;
epilog

end;</source>
        <Parameter name="_controlWidth" type="Integer"/>
        <Parameter name="_labelWidth" type="Integer"/>
    </JadeMethod>
