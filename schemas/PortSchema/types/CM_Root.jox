        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="createWorkOrderDetailTypes" id="2dbfaed6-827e-4759-987b-068d7290074d">
        <source>createWorkOrderDetailTypes();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Sep 2021 navma1  ChangeRequest 51925: SAL - Web Portal Cargo Work Orders
20 Feb 2023 navma1  ChangeRequest 56637: EUP - Add VAS WorkOrder Detail Types
*/

vars
	pxyWoDetailType,
	woDetailType	 : CM_WorkOrderDetailType;
	appScm		     : Schema;
	const 		     : Constant;
	type			 : String;
	constantCategory : ConstantCategory;
	taskId			 : Integer;
begin
	
	appScm := currentSchema; 
	
	if appScm.name &lt;&gt; PortSchemaName then
		appScm := rootSchema.getSchema(PortSchemaName);
	endif;
	
	if appScm = null then
		return;
	endif;
	
	constantCategory := appScm.getConstantCategory('WO_Task_Type_Cargo');
	
	if constantCategory = null then
		return;
	endif;
	
	foreach const in constantCategory.getConstants do
	
		taskId := const.getSource().Integer;
		
		if app.myRoot.allWorkOrderTaskTypes[WorkOrderMode_Cargo,taskId] &lt;&gt; null then
			continue;
		endif;
		
		create pxyWoDetailType transient;
		
		pxyWoDetailType.setProxy(app.workorderDetailTypeEnumToStr(WorkOrderMode_Cargo,taskId),
								taskId,
								false,
								WorkOrderMode_Cargo);
		
		app.myUtilityCA.utlCreateWorkOrderDetailType(pxyWoDetailType,woDetailType,app.myPassport);
		delete pxyWoDetailType;
	endforeach;
	
	constantCategory := appScm.getConstantCategory('WO_Task_Type_Voyage');
	
	if constantCategory = null then
		return;
	endif;
	
	foreach const in constantCategory.getConstants do
		
		taskId := const.getSource().Integer;
		
		//No Need for creating those types as they are sub types
		if taskId = WO_TASK_MARINE or taskId = WO_TASK_CARGOREQUEST then
			continue;
		endif;	
		
		if app.myRoot.allWorkOrderTaskTypes[WorkOrderMode_Voyage,taskId] &lt;&gt; null then
			continue;
		endif;
		
		create pxyWoDetailType transient;
		
		pxyWoDetailType.setProxy(app.workorderDetailTypeEnumToStr(WorkOrderMode_Voyage,taskId),
								taskId,
								false,
								WorkOrderMode_Voyage);
		
		app.myUtilityCA.utlCreateWorkOrderDetailType(pxyWoDetailType,woDetailType,app.myPassport);
		delete pxyWoDetailType;
	endforeach;
	
	//Start 22.12.2022 navhl20 #56637
	constantCategory := appScm.getConstantCategory('WO_Task_Type_ToDo');
	
	if constantCategory = null then
		return;
	endif;
	
	foreach const in constantCategory.getConstants do
	
		taskId := const.getSource().Integer;

		if app.myRoot.allWorkOrderTaskTypes[WorkOrderMode_ToDo,taskId] &lt;&gt; null then
			continue;
		endif;
		
		create pxyWoDetailType transient;
		
		pxyWoDetailType.setProxy(app.workorderDetailTypeEnumToStr(WorkOrderMode_ToDo,taskId),
								taskId,
								false,
								WorkOrderMode_ToDo);
		
		app.myUtilityCA.utlCreateWorkOrderDetailType(pxyWoDetailType,woDetailType,app.myPassport);
		delete pxyWoDetailType;
	
	endforeach;
	//End 22.12.2022 navhl20 #56637
epilog
	delete pxyWoDetailType;
end;</source>
    </JadeMethod>
    <JadeMethod name="debtorTypeQueryPropertyUpdate" id="be453ba2-2fac-409f-b8de-98852e6533a4">
        <source>debtorTypeQueryPropertyUpdate(_debtorType: CM_DebtorType; _oldCode: String; _oldDescription : String);
// ---------------------------------------------------------------------------
// Created:	24 April 2008 By Graeme Black cnwgb1
//
// Adds, updates or deletes the debtor type query property from all 
// Query Definitions for Tracked Items. It also updates any selected
// columns.
//
// Notes:
// We don't allow queries on debtor types that don't have debtors.
// This routine is complicated by CM_DebtorType allowing key (code) changes.
// Since Debtor Types are user defined, the Dr prefix is added so that the
// user doesn't cause a name conflict with an existing Query Property
// ---------------------------------------------------------------------------
vars
	qDef		: CM_QueryDefinition;
	qProp		: CM_QueryProperty;
	newKey		: String;
	newDesc		: String;
	oldKey      : String;
	dtProp		: CM_QRefDebtorType;
	shouldShow	: Boolean;
	columns		: StringArray;
	cargoBol	: CM_CargoBOLType;
	oldDesc     : String;
begin
	
	newKey :=  'DT - ' &amp; _debtorType.code;
	newDesc := 'DT - ' &amp; _debtorType.description;
	shouldShow := not _debtorType.allDebtors.isEmpty();
	
	if ( _oldCode &lt;&gt; null) then
		oldKey := "DT - " &amp; _oldCode;
	else
		oldKey := null;
	endif;
	if ( _oldDescription &lt;&gt; null) then
		oldDesc := "DT - " &amp; _oldDescription;
	else
		oldDesc := null;
	endif;
	
	foreach qDef in self.allQueryDefinitionObjects do
		if not qDef.isKindOf(CM_QDefTrackedItem) then
			continue;
		endif;
		
		// For the particular query find the correct collection of 
		// columns
		columns := null;
		dtProp := null;
		qProp := null;
		if qDef.mode = 0 then
			if self.myQueryMenuRoot &lt;&gt; null then
				columns := self.myQueryMenuRoot.allColumns;
			endif;
		else
			cargoBol := self.allCargoTypesById[qDef.mode];
			if cargoBol &lt;&gt; null then
				columns := cargoBol.allSelectorColumns;
			endif;
		endif;
		
		// oldKey only exists if CM_DebtorType is being updated
		if oldKey &lt;&gt; null and oldKey &lt;&gt; newKey then
			qProp := qDef.allQueryProperties[oldKey];
		endif;
		if qProp = null then
			qProp := qDef.allQueryProperties[newKey];
		endif;

		
		if qProp = null then
			// New property
			if shouldShow then
				create dtProp persistent;
				dtProp.set( newDesc, newKey, qDef.className );
				dtProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
				qDef.allQueryProperties.add(dtProp);
				
				if columns &lt;&gt; null	and (not columns.includes(newKey)) then 		
					columns.add(newKey);
				endif;

			endif;
		else
			// Existing Property
			dtProp := qProp.CM_QRefDebtorType;
			if shouldShow then
				// Update the property
				dtProp.set( newDesc, newKey, qDef.className );
				dtProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
				
				if oldKey &lt;&gt; newKey then
					if columns &lt;&gt; null	then 
						if columns.includes(oldKey) then 		
							columns.remove(oldKey);
						endif;
						if not columns.includes(newKey) then 		
							columns.add(newKey);
						endif;
					endif;
				endif;
				
			else
				// Existing property which should no longer be shown, delete it
				if columns &lt;&gt; null	and columns.includes(oldKey) then 		
					columns.remove(oldKey);
				endif;

				qDef.allQueryProperties.remove(dtProp);
				dtProp.erase(0);

			endif;
		endif;
		
	endforeach;
	
	// Send notification to update combo box on Item Selector screen if it is up
	if self.myQueryMenuRoot &lt;&gt; null then
		if oldDesc &lt;&gt; null and ( oldDesc &lt;&gt; newDesc or not shouldShow) then
			self.myQueryMenuRoot.causeEvent(SelectorProperty_Delete_Event, false, oldDesc); 
		endif;
		if shouldShow then
			self.myQueryMenuRoot.causeEvent(SelectorProperty_Create_Event, false, newKey); 
		endif;
	endif;

end;</source>
        <Parameter name="_debtorType" type="CM_DebtorType"/>
        <Parameter name="_oldCode" type="String"/>
        <Parameter name="_oldDescription" type="String"/>
    </JadeMethod>
    <JadeMethod name="delete" id="d38c6e57-e9f7-43ae-8786-311cac2dbd02">
        <updating/>
        <source>delete() updating;
// ---------------------------------------------------------------------------
// Created:		March 2004 By cnwrs1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/* Changes

Date		Name	TFS#		Description
============================================================================
24/09/2019 	jlgka1 	TFS 45614 	JMT - Refactoring remove Voyage Commodity Scenario mode
28/07/2020	jlgmd1				StarterDB - Prevent dialogs while the batch init app is (re)initialising the system
============================================================================*/
begin
	if (not self.isTransient) and (not app.isBackGroundApp) then
		if app.msgBox("You are about to DELETE CM_Root '" &amp; self.String &amp; "'. Are you sure that you want to do this?",
						"Delete ROOT Confirmation", MsgBox_Question_Mark_Icon + MsgBox_Yes_No) = MsgBox_Return_No then
			abortTransaction;
			return;
		endif;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="deleteFutureActor" id="9a31c3fb-6b7d-414e-b35c-e8865a1261b6">
        <source>deleteFutureActor(_parent : CM_Object; _class : Class);
/*

Purpose:			
	Typical usages:  remove future storage actor when releasing cargo, deleting all future actors when deleting cargo
	Road Release
	Rail Release
	Ship Release
	CCMS DPH 2278 delete any future actors (of the given class) for the given object
Parameters:			

Return Value:		

Date		Who		Reason
17 Mar 2025 navma1 MTN-34120 MTN | Dead Lock (1081) on CM_OfflineFutureActorParentDct
*/

vars
	actor	: CM_OfflineFutureActor;
	iter	: Iterator;
begin
	
	if _parent = null then
		return;
	endif;
	
	iter := self.allOfflineFutureActorParents.createIterator();
	self.allOfflineFutureActorParents.startKeyGeq(_parent, iter);
	
	while iter.next(actor) do
		
		if actor.myParentObject &lt;&gt; _parent then
			break;
		endif;
		
		if _class &lt;&gt; null and actor.class &lt;&gt; _class then
			continue;
		endif;
		
		//delete actor;										//17.03.2025 navma1 #MTN-34120
		app.myPassport.addFutureActorsForDeferDel(actor);	//17.03.2025 navma1 #MTN-34120
		
	endwhile;

epilog
	delete iter;
end;
</source>
        <Parameter name="_parent" type="CM_Object"/>
        <Parameter name="_class" type="Class"/>
    </JadeMethod>
    <JadeMethod name="deleteStateDataObject" id="dd0820ff-5c31-4bc7-8fc4-98dc6b18a0ce">
        <source>deleteStateDataObject(_key : String; _stateClass :Class): Boolean;
// ---------------------------------------------------------------------------
// Created:		01 April 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	stateObject		: CM_StateObject;
	stateData		: CM_StateData;
begin
	
	if _stateClass.getSuperclass() &lt;&gt; CM_StateData then
		return false;
	endif;
	
	foreach stateObject in self.allStateObjects do
		foreach stateData in stateObject.allStateData do
			if stateData.isKindOf(_stateClass) then
				if stateData.key = _key then
					delete stateData;
					return true;
				endif;
			endif;
		endforeach;
	endforeach;
	
	return false;
end;</source>
        <Parameter name="_key" type="String"/>
        <Parameter name="_stateClass" type="Class"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="deriveCompanyCode" id="84169e81-db2a-46f8-85ae-6b0044d8d3a1">
        <source>deriveCompanyCode() : String;
/*
Purpose: For OpsView MTN generates unique keys for all the objects sent to OpsView, this is called the GKEY. 
		In the OpsView database  there is also a PKEY value, which is the real unique key and is the COMPLEX ID and the GKEY concatinated.
		The COMPLEX ID sent to OpsView is the CM_Root.companyCode value.	
		
		In theory there could be multiple clients in one instance of OpsView so we need the company code (COMPLEX ID) to be set correctly (uniquely) in each customer environment.
		
		Note. Returning the client code used for clients in Azure Dev Ops as at 1st Feb 2022

Date		Who		Reason
01 February 2022	navab1	TFS 51855
*/

vars

begin
	if self.isClientAAT() then
		return "AAT";
	elseif self.isClientABS() then
		return "AST";
	elseif self.isClientADP() then
		return "ADP";
	elseif self.isClientASPA() then
		return "ASPA";
	elseif self.isClientC3() then
		return "C3L";
	elseif self.isClientCICE() then
		return "CIG";
	elseif self.isClientCentrePort() then
		return "CPL";
	elseif self.isClientConlinx() then
		return "NXL";
	elseif self.isClientDPHMOB() then
		return "PRP1";
	elseif self.isClientDPHPGSNO() then
		return "PRP2";
	elseif self.isClientDPHPJ() then
		return "PRP3";
	elseif self.isClientDPHPPEV() then
		return "PRP4";
	elseif self.isClientDPHSAV() then
		return "PRP5";
	elseif self.isClientDPHSJ() then
		return "PRP6";
	elseif self.isClientDUQM() then
		return "DQM";
	elseif self.isClientEuroPorts() then
		return "EUP";
	elseif self.isClientGTUQ1() then
		return "GUQ1";
	elseif self.isClientGTUQ2() then
		return "GUQ2";
	elseif self.isClientGhana() then
		return "GPHA";
	elseif self.isClientHAT() then
		return "HAT";
	elseif self.isClientJadeMaster() then
		return "MTN";
	elseif self.isClientLinx() then
		return "LNX";
	elseif self.isClientMessina() then
		return "MSL";
	elseif self.isClientMilaha() then
		return "QTS";
	elseif self.isClientPIBT() then
		return "PIBT";
	elseif self.isClientPOE() then
		return "POE";
	elseif self.isClientPenn() then
		return "PEN";
	elseif self.isClientPortNelson() then
		return "PNL";
	elseif self.isClientPortOtago() then
		return "POL";
	elseif self.isClientSAL() then
		return "SAL";
	elseif self.isClientSNO() then
		return "SNO";
	elseif self.isClientSSL() then
		return "SSL";
	elseif self.isClientSTWOman() then
		return "STWO";
	elseif self.isClientSTWR() then
		return "STWR";
	elseif self.isClientSouthPort() then
		return "SPT";
	elseif self.isClientTML() then
		return "TML";
		
		
	// NEW CLIENTS 2202SEP21
	elseif self.isClientCuxport() then
		return "CUX";
	elseif self.isClientENT() then
		return "ENT";
	elseif self.isClientPortBrisbane() then
		return "POB";
	// NEW CLIENTS JAN2024 // ### TFS CR 58085 TASK 61342 08JAN2024 NAVAB1
	elseif self.isClientCallao() then
		return "CAO";
	elseif self.isClientDPHFDW() then
		return "FDW";
	elseif self.isClientNSWPorts() then
		return "NSWP";
		
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doConvertCargoId" id="ec1f5848-fd6b-4770-9303-3956b90ce81a">
        <source>doConvertCargoId( _cmif : CMIF_IDConversion ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 July 2016	cnwndl1	Initial creation TFS 2275 / 2216

*/

vars

	reference : Integer;

begin
	// default behaviour
//	return _cmif.convertedCargoId;
	return _cmif.scannedValue;	//18 Aug 2016	NDL	TFS 2567 - with no hook code should not truncate.
	
