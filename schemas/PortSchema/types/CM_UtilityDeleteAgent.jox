    <JadeMethod name="utlDeleteCashPayment" id="356b709e-0ebd-486e-a65a-79e72c9b1d1a">
        <source>utlDeleteCashPayment(_obj : CM_CashPayment input);
/*
Purpose: Initial creation is for delete audit trail

Parameters:			

Return Value:		

Date		Who		TFS		Reason
24 Jul 2019	jlgdi1	45301	Initial creation 
*/

begin
	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	
	// no validate delete method as of the time of writing (validationDeleteAgent)
	// add validation delete method here eg. (app.myValDA.valCashPayment(_obj))
	
	if not self.checkValidationWithPassport(app.myPassport) then
		return;
	endif;

	if app.myPassport.noErrors then
		// only requierd if class is audited
		self.myDeleteAuditAgent.audDeleteGeneric(_obj);
	endif;

	if app.myPassport.noErrors then
		_obj.erase(NORMAL_ERASE);
	endif;
end;</source>
        <Parameter name="_obj" type="CM_CashPayment" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteCashReceipt" id="fee6315c-f1b0-459b-81bd-db2ace6da4d0">
        <source>utlDeleteCashReceipt(_obj : CM_CashReceipt input);
/*
Purpose:	TFS 39721		
Date				Who			Reason
JULY 2018		CNWAB1		Initial creation
*/

vars
	root : CM_Root;
begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	// note that validation agent locks object
	app.myValDA.valCashReceipt(_obj);
	
	if not self.checkValidationWithPassport(app.myPassport) then
		return;
	endif;
	
	//11/07/2024	navkc1 CR 64837 Task 64851
	if _obj.isDraftReceipt() then
		root := app.myRoot;
		root.deleteFutureActor(_obj, CM_CashStatusAdvanceProcess);
	endif;

	if app.myPassport.noErrors then
		// only requierd if class is audited
		if not _obj.isDraftReceipt() and not _obj.isHoldReceipt() and not _obj.isCancelled() then //20/08/2025	navkc1 JIRA MTN 35791
			self.myDeleteAuditAgent.audDeleteGeneric(_obj);
		endif;
	endif;

	if app.myPassport.noErrors then
		_obj.erase(NORMAL_ERASE);
	endif;

end;</source>
        <Parameter name="_obj" type="CM_CashReceipt" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteCheckScalingBatch" id="5e1b2758-d03e-4d5f-a0ea-ad7edc8f4fc5">
        <updating/>
        <source>utlDeleteCheckScalingBatch(_chkScaleHdr : CM_LogCheckScaleHdr io; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     14 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	cancelSave 		: Boolean;
	batchNo			: Integer;
	terminal		: CM_Terminal;
begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	app.myValDA.valCheckScalingHdr(_chkScaleHdr);
	
	if (not self.checkValidationWithPassport(_passport)) then // Show any Errors and Warnings in a list
		return;
	endif;


	app.setContinueCMExceptions(false);
	batchNo := _chkScaleHdr.batchNo;
	terminal := _chkScaleHdr.myTerminal;
	
	if _passport.noErrors then
		_chkScaleHdr.erase(NORMAL_ERASE);
	endif;
	
	if not _passport.noErrors then
		return;
	endif;
	
	if terminal &lt;&gt; null then
		terminal.causeEvent(EVENT_CHECKSCALE_DELETE, false, batchNo);
	endif;
end;</source>
        <Parameter name="_chkScaleHdr" type="CM_LogCheckScaleHdr" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
