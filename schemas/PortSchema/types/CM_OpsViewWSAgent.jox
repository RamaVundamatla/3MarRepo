    <JadeMethod name="doSendHTTPRequest" id="28a9cad7-1028-4795-b5cb-2c23d9308cfc">
        <updating/>
        <source>doSendHTTPRequest(_url : String;
				  _verb : String;
				  _additionalHeaders : String;
				  _putPostData : String;
				  _resultCode: Integer output) : String updating;
/*

Purpose:			Wrapper method for sending a single http request, handling any exceptions.  Sends the 
					request as defined, and returns the read response as a String

Parameters:			URL to send the request to
					HTTP Verb (GET, POST, etc)
					Any additional headers required
					Optional data for a PUT/POST request

Return Value:		String value returned if successful, or null if unsuccessful


Date		Who		Reason
26 JUL 2021	NAVAB1	TFS 50669
21 Oct 2024	navmd1	TFS 59895 / MTN-14636 Change JSON sanitisation from XML to Regex so value types are not lost


*/

vars
	httpConn			: JadeHTTPConnection;
	returnVal			: String;
	sendSuccess			: Boolean;
	postDataLogging		: String;
	jsonHelper			: CMIF_JsonHelper;
	timeoutMS			: Integer;
	formattedReturnVal	: String;
	pxyActivity,
	realActivity 		: CM_ExternalWebServiceActivity;
begin
	// Get a sanitised version of the put data for logging
	if _putPostData &lt;&gt; null then
		postDataLogging := JMTJadeJson@sanitiseSensitiveFields4Loging(_putPostData);
	else
		postDataLogging := null;
	endif;

	app.writeLog(method.qualifiedName &amp; 
				   " _url=" &amp; _url &amp;
				   ", _verb=" &amp; _verb &amp;
				   ", _additionalHeaders=" &amp; _additionalHeaders &amp;
				   ", _putPostData=" &amp; postDataLogging, LogDEBUG);	

	create httpConn transient;
	
	// Set timeouts of required
	if self.timeoutSeconds &lt;&gt; 0 then
		timeoutMS := self.timeoutSeconds * 1000;
		httpConn.connectTimeout := timeoutMS;
		httpConn.sendTimeout := timeoutMS;
		httpConn.receiveTimeout := timeoutMS;
	endif;
	
	httpConn.url := _url;

	// ### EWS Activity SENT_PENDING
	if self.myLastEWSActivity &lt;&gt; null then
		realActivity := self.myLastEWSActivity;
		pxyActivity := app.createUpdateProxy(realActivity).CM_ExternalWebServiceActivity;
		if pxyActivity &lt;&gt; null then
			if self.myLastEWSActivity.changed.isValid() then
				pxyActivity.setProxyStatus(BGP_OpsViewWSRequest.EWS_STATUS_BGP_SENT_RESEND); // has been sent before
			else
				pxyActivity.setProxyStatus(BGP_OpsViewWSRequest.EWS_STATUS_BGP_SENT_PENDING);
			endif;
			
			app.myTrxUA.trxUpdateEWSActivity(pxyActivity, app.myPassport);
			delete pxyActivity;
		endif;
	endif;
	
	sendSuccess := httpConn.sendRequest(_verb, _additionalHeaders, _putPostData);
	_resultCode := httpConn.queryStatusCode();	
	
	 // ### TFS 50669 25AUG2021 NAVAB1 JADE sends a success if it was able to communicate with the endpoint, whatever the response code
	if sendSuccess then
		if _resultCode &lt;&gt; HttpResponseOK then
			sendSuccess := false;
		endif;
	endif;
	
	if sendSuccess then
		httpConn.readBody(0);
		returnVal := httpConn.responseBody.StringUtf8.String;
		app.writeLog(method.qualifiedName &amp; "SUCCESS returnVal=" &amp; returnVal, LogDEBUG);
		app.writeLog(method.qualifiedName &amp; "SUCCESS _resultCode=" &amp; _resultCode.String, LogDEBUG);
		
		create jsonHelper transient;
		
		if (returnVal &lt;&gt; "") then
			formattedReturnVal := jsonHelper.formatJsonString(returnVal);
		elseif (sendSuccess) then
			formattedReturnVal := "EMPTY";
		else
			formattedReturnVal := "";
		endif;

		// ### EWS Activity SUCCESS
		app.writeLog(method.qualifiedName &amp; " sendRequest success", LogINFO);
		pxyActivity := app.createUpdateProxy(realActivity).CM_ExternalWebServiceActivity;
		if pxyActivity &lt;&gt; null then
			pxyActivity.setProxyStatus(BGP_OpsViewWSRequest.EWS_STATUS_BGP_SENT_SUCCESS);
			pxyActivity.setProxyRequestDetails(_putPostData, formattedReturnVal, _resultCode); 
			app.myTrxUA.trxUpdateEWSActivity(pxyActivity, app.myPassport);
			delete pxyActivity;
		endif;
		
	else
		httpConn.readBody(0);
		returnVal := httpConn.responseBody.StringUtf8.String;
		app.writeLog(method.qualifiedName &amp; "FAILED returnVal=" &amp; returnVal, LogDEBUG);
		app.writeLog(method.qualifiedName &amp; "FAILED _resultCode=" &amp; _resultCode.String, LogDEBUG);

		// ### EWS Activity FAILURE
		app.writeLog(method.qualifiedName &amp; " sendRequest failed. Check firewall or timeout settings.", LogERROR);	// TFS 52461 navmd1 26/11/2021
		pxyActivity := app.createUpdateProxy(realActivity).CM_ExternalWebServiceActivity;
		if pxyActivity &lt;&gt; null then
			pxyActivity.setProxyStatus(BGP_OpsViewWSRequest.EWS_STATUS_BGP_SENT_FAILURE);
			pxyActivity.setProxyRequestDetails(_putPostData, formattedReturnVal, _resultCode); 
			app.myTrxUA.trxUpdateEWSActivity(pxyActivity, app.myPassport);
			delete pxyActivity;
		endif;
	endif;

	return returnVal;
	
epilog
	delete httpConn;
	delete jsonHelper;
	delete  pxyActivity;
end;</source>
        <Parameter name="_url" type="String"/>
        <Parameter name="_verb" type="String"/>
        <Parameter name="_additionalHeaders" type="String"/>
        <Parameter name="_putPostData" type="String"/>
        <Parameter name="_resultCode" type="Integer" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
