    <JadeMethod name="btnClose_click" id="5f27ce23-54a5-472c-b6b4-591b11917747">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnClose_click(jadeMask: JadeMask input) updating;
// --------------------------------------------------------------------------------
// Created:		12 December 2005 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.unloadForm();
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doFormLoad" id="adc554d9-c6a6-4ce2-bfe5-b2484b8ab3ea">
        <updating/>
        <source>doFormLoad() updating, protected;
// --------------------------------------------------------------------------------
// Created:		01 March 2007 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod();
	self.centreWindow();
	
	if self.aMyForm = null then
		app.msgBox(	"You need to call the " &amp; self.class.name &amp; "::" &amp; CnEcGuiContents::setForm.name &amp; " method before showing the form.",
					"Error",
					MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		self.unloadForm();
		return;
	endif;
	
	barListBox.ignoreSkin	:=	true;
	barTable.ignoreSkin		:=	true;
	btnClose.ignoreSkin		:=	true;
	fraControls.ignoreSkin	:=	true;
	lstControls.ignoreSkin	:=	true;
	tblControls.ignoreSkin	:=	true;
	
	self.tableInitialize();
	self.showFormContents();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getClassIcon" id="4f227835-da72-44f6-81c6-60e096e73370">
        <source>getClassIcon(pClassObj:Class):Binary protected;
// --------------------------------------------------------------------------------
// Created:		17 December 2005 by cnwdad1
//
// Purpose:		Returns a binary icon which corresponds to the specified control
//				class.
//
// Parameters:	pClassObj - A reference to the control class.
//
// Returns:		The control icon.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 28/02/2007	cnwdad1		Added an icon for a MenuItem.
// --------------------------------------------------------------------------------
vars
	systemTypeObj	: Class;
	
begin
	systemTypeObj	:=	pClassObj.cnEcGetSystemType();
	
	if systemTypeObj.name = BaseControl.name then
		return picBaseControl.picture;
	elseif systemTypeObj.name = BrowseButtons.name then
		return picBrowseButtons.picture;
	elseif systemTypeObj.name = Button.name then
		return picButton.picture;
	elseif systemTypeObj.name = CheckBox.name then
		return picCheckBox.picture;
	elseif systemTypeObj.name = ComboBox.name then
		return picComboBox.picture;
	elseif systemTypeObj.name = Folder.name then
		return picFolder.picture;
	elseif systemTypeObj.name = Frame.name then
		return picFrame.picture;
	elseif systemTypeObj.name = GroupBox.name then
		return picGroupBox.picture;
	elseif systemTypeObj.name = HScroll.name then
		return picHScroll.picture;
	elseif systemTypeObj.name = JadeDockBar.name then
		return picJadeDockBar.picture;
	elseif systemTypeObj.name = JadeDockContainer.name then
		return picJadeDockCont.picture;
	elseif systemTypeObj.name = JadeEditMask.name then
		return picJadeEditMask.picture;
	elseif systemTypeObj.name = JadeEditor.name then
		return picJadeEditor.picture;
	elseif systemTypeObj.name = JadeMask.name then
		return picJadeMask.picture;
	elseif systemTypeObj.name = JadeRichText.name then
		return picJadeRichText.picture;
	elseif systemTypeObj.name = JadeTextEdit.name then
		return picJadeTextEdit.picture;
	elseif systemTypeObj.name = Label.name then
		return picLabel.picture;
	elseif systemTypeObj.name = MenuItem.name then
		return picMenu.picture;
	elseif systemTypeObj.name = ListBox.name then
		return picListBox.picture;
	elseif systemTypeObj.name = MultiMedia.name then
		return picMultiMedia.picture;
	elseif systemTypeObj.name = OleControl.name then
		return picOLEControl.picture;
	elseif systemTypeObj.name = OptionButton.name then
		return picOptionButton.picture;
	elseif systemTypeObj.name = Picture.name then
		return picPicture.picture;
	elseif systemTypeObj.name = ProgressBar.name then
		return picProgressBar.picture;
	elseif systemTypeObj.name = Sheet.name then
		return picSheet.picture;
	elseif systemTypeObj.name = StatusLine.name then
		return picStatusLine.picture;
	elseif systemTypeObj.name = Table.name then
		return picTable.picture;
	elseif systemTypeObj.name = TextBox.name then
		return picTextBox.picture;
	elseif systemTypeObj.name = VScroll.name then
		return picVScroll.picture;
	elseif systemTypeObj.name = WebHTML.name then
		return picWebHTML.picture;
	elseif systemTypeObj.name = WebHotSpot.name then
		return picWebHotSpot.picture;
	elseif systemTypeObj.name = WebInsert.name then
		return picWebInsert.picture;
	elseif systemTypeObj.name = WebJavaApplet.name then
		return picWebJavaApplet.picture;
	elseif systemTypeObj.name = "JadeXamlControl" then
		return picXaml.picture;
	else
		return picUnknown.picture;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pClassObj" type="Class"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="getPropertyOwner" id="652fd89d-53dd-45d5-80ae-8a7b6e5f590f">
        <source>getPropertyOwner(pPropertyObj:Property):Window protected;
// --------------------------------------------------------------------------------
// Created:		05 March 2006 by cnwdad1
//
// Purpose:		Returns the "owner" on which the specified property is implemented.
//
// Parameters:	pPropertyObj - A reference to the property who's owner we want.
//
// Returns:		A reference to the Window (or Control) on which the property is
//				implemented.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	listboxObj	: ListBox;
	rowPointer	: Integer;
	parentIndex	: Integer;
	
begin
	listboxObj	:=	lstControls;
	rowPointer	:=	listboxObj.findObject(pPropertyObj);
	
	if rowPointer = CNEC_NULL_INDEX then
		return null;
	endif;
	
	parentIndex	:=	listboxObj.cnEcFindParent(rowPointer);
	
	if parentIndex = 0 or parentIndex = CNEC_NULL_INDEX then
		return self.aMyForm;
	else
		return listboxObj.itemObject[parentIndex].Window;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pPropertyObj" type="Property"/>
        <ReturnType type="Window"/>
    </JadeMethod>
    <JadeMethod name="listAddChildControl" id="22e60b92-0242-4b5f-b66b-b901ae08e783">
        <source>listAddChildControl(pControlObj:Control; pListLevel:Integer) protected;
// --------------------------------------------------------------------------------
// Created:		12 December 2005 by cnwdad1
//
// Purpose:		Adds the specified control into the listbox hierarchy, at the
//				specified level.
//
// Parameters:	pControlObj - A reference to the control to add to the hierarchy.
//				pListLevel - The hierarchy level of the control.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	listboxObj			: ListBox;
	listPointer			: Integer;
	displayValue		: String;
	childControlObj		: Control;
	allChildControls	: CnEcControlArray;
	
begin
	listboxObj		:=	lstControls;
	displayValue	:=	pControlObj.name &amp; " (" &amp; pControlObj.tabIndex.cnEcNumberFormat() &amp; ")";
	listPointer		:=	listboxObj.addItem(displayValue);
	listboxObj.itemLevel[listPointer]	:=	pListLevel;
	listboxObj.itemObject[listPointer]	:=	pControlObj;
	listboxObj.itemPicture[listPointer]	:=	self.getClassIcon(pControlObj.class);
	
	if mnuFuncShowProperties.checked then
		self.listAddWindowProperties(pControlObj, pListLevel + 1);
	endif;
	
	create allChildControls transient;
	pControlObj.cnEcGetAllChildControls(allChildControls, false);
	
	if allChildControls.cnEcIsNotEmpty() then
		foreach childControlObj in allChildControls do
			if not childControlObj.visible and mnuFuncHideInvisible.checked then
				continue;
			endif;
			
			if not childControlObj.enabled and mnuFuncHideDisabled.checked then
				continue;
			endif;
		
			self.listAddChildControl(childControlObj, (pListLevel + 1));
		endforeach;
	endif;
epilog
	delete allChildControls;
end;</source>
        <access>protected</access>
        <Parameter name="pControlObj" type="Control"/>
        <Parameter name="pListLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="listAddMenu" id="2eee6f4e-7638-4c5f-b07b-3cd7efd8ab52">
        <source>listAddMenu(pMenuObj:MenuItem; pListLevel:Integer) protected;
// --------------------------------------------------------------------------------
// Created:		28 February 2007 by cnwdad1
//
// Purpose:		Adds the specified menu to the listbox, at level 1 of the hierarchy.
//
// Parameters:	pMenuObj - A reference to the menu to add to the hierarchy.
//				pListLevel - The hierarchy level of the menu.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	listboxObj			: ListBox;
	listPointer			: Integer;
	displayValue		: String;
	
begin
	listboxObj		:=	lstControls;
	displayValue	:=	pMenuObj.name;
	
	if displayValue = null then
		return;
	endif;
	
	listPointer		:=	listboxObj.addItem(displayValue);
	listboxObj.itemLevel[listPointer]	:=	pListLevel;
	listboxObj.itemObject[listPointer]	:=	pMenuObj;
	listboxObj.itemPicture[listPointer]	:=	self.getClassIcon(pMenuObj.class);
	
	if mnuFuncShowProperties.checked then
		self.listAddWindowProperties(pMenuObj, 1);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pMenuObj" type="MenuItem"/>
        <Parameter name="pListLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="listAddWindowProperties" id="3be3c20a-bda5-4de0-aa27-90c48ced9115">
        <source>listAddWindowProperties(pWindowObj:Object; pListLevel:Integer) protected;
// --------------------------------------------------------------------------------
// Created:		12 December 2005 by cnwdad1
//
// Purpose:		Adds the specified Window properties into the listbox hierarchy,
//				at the specified level.
//
// Parameters:	pWindowObj - A reference to the Window to add to the hierarchy.
//				pListLevel - The hierarchy level of the property.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	propertyObj		: Property;
	allProperties	: PropertyColl;
	listPointer		: Integer;
	listboxObj		: ListBox;
	
begin
	allProperties	:=	pWindowObj.class.allProperties();	// This method creates a new instance of the property collection.
	listboxObj		:=	lstControls;
	
	foreach propertyObj in allProperties do
		if propertyObj.hasControlInstance
		or propertyObj.name[1] = "_"
		or propertyObj.isSystemObject()
		then
			continue;
		endif;
		
		listPointer	:=	listboxObj.addItem(propertyObj.name &amp; " (" &amp; propertyObj.getType().name &amp; ")");
		listboxObj.itemLevel[listPointer]	:=	pListLevel;
		listboxObj.itemObject[listPointer]	:=	propertyObj;
	endforeach;
epilog
	delete allProperties;
end;</source>
        <access>protected</access>
        <Parameter name="pWindowObj" type="Object"/>
        <Parameter name="pListLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="listInspectObject" id="f39b5238-14c5-492d-94b0-7c6c6f41805f">
        <source>listInspectObject(pIsJade:Boolean) protected;
// --------------------------------------------------------------------------------
// Created:		13 December 2005 by cnwdad1
//
// Purpose:		Inspect the currently selected list item object.
//
// Parameters:	pIsJade - If true, then inspect with Jade's native inspector,
//					otherwise use the BaseSchema inspector.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	itemObj		: Object;
	
begin
	itemObj	:=	lstControls.listObject;
	
	if itemObj = null then
			return;
	endif;
	
	if pIsJade then
		itemObj.inspect();
	else
		itemObj.cnEcInspect();
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pIsJade" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="lstControls_click" id="0c27c9a2-6d35-4b85-aea0-6918fba8db0c">
        <controlMethod name="ListBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstControls_click(listbox: ListBox input) updating;
// --------------------------------------------------------------------------------
// Created:		17 December 2005 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	self.tableShowDetails(listbox.listObject);
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lstControls_contextMenu" id="18d31917-e6e9-4138-8d32-ec32954c8535">
        <controlMethod name="ListBox::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstControls_contextMenu(listbox: ListBox input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		13 December 2005 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	actualXPos	: Real;
	actualYPos	: Real;
	
begin
	actualXPos	:=	x;
	actualYPos	:=	y;
	
	if listbox.listIndex = CNEC_NULL_INDEX then
		mnuFuncInspectBase.enabled	:=	false;
		mnuFuncInspectJade.enabled	:=	false;
	else
		mnuFuncInspectBase.enabled	:=	true;
		mnuFuncInspectJade.enabled	:=	true;
	endif;
	
	self.cnEcGetRelativePosition(listbox, actualXPos, actualYPos);
	popupMenu(mnuFunc, actualXPos.Integer, actualYPos.Integer);
	
	return false;
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="lstControls_pictureClick" id="fc638764-c507-4060-9bce-d581df2705e2">
        <controlMethod name="ListBox::pictureClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstControls_pictureClick(listbox: ListBox input; picIndex: Integer; whatClicked: Integer) updating;
// --------------------------------------------------------------------------------
// Created:		12 December 2005 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	lstControls.itemExpanded[picIndex]	:=	(not lstControls.itemExpanded[picIndex]);
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
