    <Constant name="ABORT_INTERVAL" id="d1da5fdf-edd2-406b-b920-9175a114510b">
        <source>3</source>
        <type name="Integer"/>
    </Constant>
    <Constant name="CHECK_INTERVAL" id="776cf9d5-5331-431e-b1ce-16132b5eed50">
        <source>1</source>
        <type name="Integer"/>
    </Constant>
    <Constant name="RECHECK_INTERVAL" id="6ed90a52-e5ad-443c-87d8-9c2599d97bee">
        <source>60</source>
        <type name="Integer"/>
    </Constant>
