/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 November 2009	cnwndl1	Initial creation	Par 21519

*/

vars

begin
	
	if doMnuContextBuildTblTrans(table, conwin, mouse, x, y) then
		return self.showContextMenu(mnuContext, table, conwin, mouse, x, y);
	else
		return false;
	endif;
	
epilog

end;</source>
