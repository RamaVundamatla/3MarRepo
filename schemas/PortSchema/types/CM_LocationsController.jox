    <JadeMethod name="getFIFOTimeStampYA" id="5381807f-cad6-49ce-b269-5440257a0886">
        <source>getFIFOTimeStampYA(_isIn : Boolean; _sortedByDate : CM_TIByReceiveDT input) : TimeStamp;
// -------------------------------------------
// Created 05 April 2005 by cnwdvb1
// -------------------------------------------
/* Decided to pass dict in because faster than creating it all the time. */ 
// 21 Jun 25	jlier1 JIRA-13860 - if we don't have a valid date return null 
vars

	ti				:	CM_TrackedItem;
	dt				:	TimeStamp;

begin

	_sortedByDate.clear();
	
	if self.allTrackedItems.isEmpty then
		return null;
	endif;

	//----------------
	//Painful, but no other way!
	//----------------
	foreach ti in self.allTrackedItems do
		_sortedByDate.add(ti);		
	endforeach;

	if _sortedByDate.isEmpty() then
		return null;
	endif;
	//----------------
	//Return the received DT of the 1st TI
	//----------------
	if _isIn then
		//jlier1 - in want most recent receival date/time
		dt := _sortedByDate.last.receivedDT;
	else
		//jlier1  -out want oldest reveical date/time
		dt := _sortedByDate.first.receivedDT;
	endif;

	return dt;
end;</source>
        <Parameter name="_isIn" type="Boolean"/>
        <Parameter name="_sortedByDate" type="CM_TIByReceiveDT" usage="input"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
