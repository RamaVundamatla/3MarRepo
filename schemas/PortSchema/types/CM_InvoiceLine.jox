    <JadeMethod name="getMeasurementStringForAttrib" id="1ce2a6cd-5a23-4cbe-8efe-ef9e06b4a942">
        <source>getMeasurementStringForAttrib(_attrName: String; _measureType: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08/06/2020 cnwma1 ChangeRequest 49400: ASPA - Invoice Enhancements for Barges

*/

vars

begin
	if _attrName = ETRow_TotalWeight then
		return app.convertMeasurementForDisplay(_measureType, self.trackedItemWeight);
	elseif 	_attrName = ETRow_Volume then
		return app.convertMeasurementForDisplay(_measureType, self.trackedItemVolume);
	endif;
	
	return inheritMethod(_attrName, _measureType, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_measureType" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMinMaxDisplayed" id="605e41a3-be8b-45b7-ad86-424f693c3bb1">
        <source>getMinMaxDisplayed(_minMaxUsed : Boolean output; _minMaxDisplayed : Boolean output);
/* cnwjre1 Nov 2011 28304 the GRT quantity is showing instead of the original quantity value for some marine invoices - in particular
    when voiding an invoice line (which doesn't particularly matter but doesn't look good), plus at least one Port Nelson active invoice.
	Called from the end of CM_InvoiceLine lineTotal the CM_Charge getMinMaxDetails is the min/max code from evaluateRate but also handling a VOID line
*/
vars
	minMaxDisplayed	: Boolean;
	isMinMaxSet,
	minMaxUsed	: Boolean;
	charge	: CM_Charge;
	
begin
	_minMaxUsed := false;
	_minMaxDisplayed := false;
	foreach charge in self.charges discreteLock do
		isMinMaxSet := false;
		charge.getMinMaxDetails(isMinMaxSet, minMaxUsed, minMaxDisplayed);
		if isMinMaxSet then
			_minMaxUsed := minMaxUsed;
			_minMaxDisplayed := minMaxDisplayed;
		endif;
	endforeach;

end;
</source>
        <Parameter name="_minMaxUsed" type="Boolean" usage="output"/>
        <Parameter name="_minMaxDisplayed" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getMyBerthObject" id="c7779818-3ab9-43e0-b7f3-a7d6a1e447f7">
        <source>getMyBerthObject():HMS_Berth;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 June 2018	jlgma1	Initial creation

*/

vars
	voyage : CM_Voyage;
	tmpMove : HMS_VoyageMovement;
	tmpBerth : HMS_Berth;
	titran : CM_WorkOrderExtraTI;
begin
	voyage := self.getMyVoyageObject();
	if voyage&lt;&gt; null then
	
		// TFS 42161 use berth on work order for cash estiamtes.
		if self.myTransactionWO &lt;&gt; null then
			if app.isInProformaMode then
				if self.myTransactionWO.myWorkOrder &lt;&gt; null then
					tmpBerth := self.myTransactionWO.myWorkOrder.getMyBerth(); // TFS 42221
					
					if tmpBerth &lt;&gt; null then
						return tmpBerth;
					endif;
				endif;
			endif;
		endif;
	
		if voyage.myHMSVoyageData &lt;&gt; null then
			if not voyage.myHMSVoyageData.allVoyageMovements.isEmpty then
				tmpMove := voyage.myHMSVoyageData.allVoyageMovements.getAtKeyGtr(self.chargeTime).HMS_VoyageMovement;
				if tmpMove = null then // TFS 42221
					tmpMove := voyage.getMovementDeparture();
					if tmpMove &lt;&gt; null then
						tmpMove := tmpMove.myPreviousMovement.HMS_VoyageMovement;
					endif;
				endif;
				if tmpMove &lt;&gt; null then
					return tmpMove.getMyBerth;
				endif;
			endif;
		endif;
	endif;
epilog

end;</source>
        <ReturnType type="HMS_Berth"/>
    </JadeMethod>
    <JadeMethod name="getMyHarbourResourceType" id="e320dc4d-fe51-42d1-898e-d09346b52549">
        <source>getMyHarbourResourceType():String;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 19 December 2018
TFS#		: 40200
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	trans 	: HMS_VTMISTransaction;
	resType : HMS_ResourceType;
begin
	trans := self.myTransactionHMS;
	if trans = null or trans.myResourceUsed = null then
		return null;
	endif;
	
	resType := trans.myResourceUsed.myResourceType;
	if resType = null then
		return null;
	endif;
	
	return resType.code;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyHarbourResourceUsed" id="b17f29a0-303c-4928-b5dc-73cb94f52a5c">
