    <JadeMethod name="showThumbnail" id="8d3e6448-60fc-410f-9e46-cad261ce1a23">
        <updating/>
        <source>showThumbnail(_obj: CM_SourceSubLocation) updating;
// -----------------------------------------------------------------------------
// Created:		12 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	tbl			: CM_EntryTable;
	
begin
	//self.showThumbnail_Code(_obj);`commented by CCMS JML 1105,  par 21535. Added new attribute isFSC. New ETDef_CodeMaintSourceLoc definition.

	//CCMS JML 1105, par 21535. Nov 2009
	
	self.myForm.shtTblInput1.caption := 'Details';
	self.myForm.shtTblInput1.visible := true;
	self.myForm.shtMultiSelect1.visible := false;
	self.myForm.shtMultiSelect2.visible := false;
	self.myForm.shtMultiSelect3.visible := false;

	tbl := myForm.tblInput1;
	self.myForm.initTblInput(tbl, ETDef_CodeMaintSourceLoc);
	
	tbl.enabled := true;
	
	tbl.clearValues;
	tbl.setValueByName(ETRow_Code, _obj.code);
	tbl.setValueByName(ETRow_Description, _obj.description);
	self.myForm.tblInput1.setValueByName(ETRow_NotAvailableForEntry, _obj.notAvailableForEntry);
	
	// FSC asttribute is visible for Source Location
	tbl.showRowByName(ETRow_IsFSC, false);
	tbl.setValueByName(ETRow_IsFSC, _obj.isFSC);
	
	tbl.cnEcResizeContents();
	
end;</source>
        <Parameter name="_obj" type="CM_SourceSubLocation"/>
    </JadeMethod>
</Class>
