    <JadeMethod name="dummyUpLaunch" id="d305fcdd-fb07-4964-a547-c76d0a58ca7a">
        <updating/>
        <source>dummyUpLaunch(_move : HMS_VoyageMovement input) updating;
// ---------------------------------------------------------------------------
// Created:		27 September 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 24 May 2019	jlgsl4	TFS 44438 - PEL1 - remove most myPilotLaunch references

vars
	tmpRes : HMS_Resource;
	pxyResUsed : HMS_ResourceUsed;
	theVoyage : CM_Voyage;
	aHarbour : HMS_Harbour;
begin
	/*if _move.myPilotLaunch = null then // --&gt; TFS 44438 after 040 cut/release
		return;
	endif;*/

	if _move.allMovementPilotDetails.isEmpty then // no pilots or pilot launches
		return;
	elseif _move.allMovementPilotDetails.first.myPilotLaunch = null then // at least 1 pilot, but no pilot launch
		return;
	endif; // &lt;-- TFS 44438 after 040 cut/release
	
	theVoyage := _move.myHMSVoyageData.myVoyage;
	aHarbour := _move.myHarbour;

	tmpRes := _move.allMovementPilotDetails.first.myPilotLaunch.getResourceForHarbourMovement(aHarbour,_move.moveType); // TFS 44438 after 040 cut/release
	if tmpRes &lt;&gt; null then
		if _move.getDefaultResourceUsed(tmpRes) = null then
			create pxyResUsed transient;
			self.allResUsed.add(pxyResUsed);	
			pxyResUsed.setProxy(aHarbour,tmpRes.myResourceType,tmpRes,null,_move.occursOnDTNEW,theVoyage.departedDT,1,false,null,null);
		endif;
	endif;
end;</source>
        <Parameter name="_move" type="HMS_VoyageMovement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="dummyUpPilot" id="019b3aba-51ef-4b51-a929-950941701669">
        <updating/>
        <source>dummyUpPilot(_move : HMS_VoyageMovement input) updating;
// ---------------------------------------------------------------------------
// Created:		27 September 2005  By Andrew Bishop cnwab1
//
// Purpose:		
// 23 Apr 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement
// ---------------------------------------------------------------------------

vars

	tmpRes : HMS_Resource;
	pxyResUsed : HMS_ResourceUsed;
	theVoyage : CM_Voyage;
	aHarbour : HMS_Harbour;
	movementPilotDetails : HMS_MovementPilotDetails; // TFS 44438	
	pilot : HMS_Pilot;
	
begin
	if _move.getUnConvertedMyPilotRef = null and _move./*allPilots*/allMovementPilotDetails.isEmpty then // TFS 44438
		return;
	endif;
	
	
	theVoyage := _move.myHMSVoyageData.myVoyage;
	aHarbour := _move.myHarbour;

	if _move.allMovementPilotDetails.isEmpty then //allPilots.isEmpty then // TFS 44438
		pilot := _move.getUnConvertedMyPilotRef;
		
		tmpRes := pilot.getResourceForHarbourMovement(aHarbour,_move.moveType);
		if tmpRes &lt;&gt; null then 
			// Check that it has not already been created and has noresource currently i.e. is a default from the vessel
			if _move.getDefaultResourceUsed(tmpRes) = null then
				create pxyResUsed transient;
				self.allResUsed.add(pxyResUsed);
				pxyResUsed.setProxy(aHarbour,tmpRes.myResourceType,tmpRes,null,_move.occursOnDTNEW,theVoyage.departedDT,1,false,null,null);
			endif;	
		endif;
	
	else	//31 Oct 2018	NDL	TFS 41662	
		foreach movementPilotDetails in _move.allMovementPilotDetails do //pilot in _move.allPilots do // TFS 44438
		
			tmpRes := /*pilot*/movementPilotDetails.myPilot.getResourceForHarbourMovement(aHarbour,_move.moveType); // TFS 44438
			if tmpRes &lt;&gt; null then 
				// Check that it has not already been created and has noresource currently i.e. is a default from the vessel
				if _move.getDefaultResourceUsed(tmpRes) = null then				
					create pxyResUsed transient;
					self.allResUsed.add(pxyResUsed);
					pxyResUsed.setProxy(aHarbour,tmpRes.myResourceType,tmpRes,null,_move.occursOnDTNEW,theVoyage.departedDT,1,false,null,null);
				endif;	
			endif;
		
		endforeach;
		
	endif;


end;</source>
        <Parameter name="_move" type="HMS_VoyageMovement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="dummyUpShipLines" id="31855611-c17c-4074-901c-08ebd33fd132">
        <updating/>
        <source>dummyUpShipLines(_move : HMS_VoyageMovement input) updating;
// ---------------------------------------------------------------------------
// Created:		27 September 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	tmpRes : HMS_Resource;
	pxyResUsed : HMS_ResourceUsed;
	theVoyage : CM_Voyage;
	aHarbour : HMS_Harbour;
begin
	if _move.myLineCompany = null then
		return;
	endif;
	
	theVoyage := _move.myHMSVoyageData.myVoyage;
	aHarbour := _move.myHarbour;

	tmpRes := _move.myLineCompany.getResourceForHarbourMovement(aHarbour,_move.moveType);
	if tmpRes &lt;&gt; null then
		// Check that it has not already been created and has noresource currently i.e. is a default from the vessel
		if _move.getDefaultResourceUsed(tmpRes) = null then
			create pxyResUsed transient;
			self.allResUsed.add(pxyResUsed);
	
			pxyResUsed.setProxy(aHarbour,tmpRes.myResourceType,tmpRes,null,_move.occursOnDTNEW,theVoyage.departedDT,_move.numLineCrewRequired,false,null,null);
		endif;
	endif;


end;</source>
        <Parameter name="_move" type="HMS_VoyageMovement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="dummyUpTugs" id="45bf75f5-049e-4312-9ce3-001a599c86e5">
        <updating/>
        <source>dummyUpTugs(_move : HMS_VoyageMovement input) updating;
// ---------------------------------------------------------------------------
// Created:		09 September 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	tmpRes : HMS_Resource;
	pxyResUsed : HMS_ResourceUsed;
	theVoyage : CM_Voyage;
	aHarbour : HMS_Harbour;
	numTugs, idx,qty : Integer;
	aTug : HMS_Tug;
	poc,contractTugCharged : Boolean;
begin
	theVoyage := _move.myHMSVoyageData.myVoyage;
	aHarbour := _move.myHarbour;
	numTugs := theVoyage.getVesselDefaultTugsForMovemnt(_move);

	if _move.allTugsUsed.size = 0 then
		if numTugs &gt; 0 then
			// ### need a resource so use first tug on harbour with a resource
			foreach aTug in _move.myHarbour.allTugs do : tugLoop
				tmpRes := aTug.getResourceForHarbourMovement(aHarbour,_move.moveType);
				if tmpRes &lt;&gt; null then
					break tugLoop;
				endif;
				
				tmpRes := null;
			endforeach;
			if tmpRes &lt;&gt; null then
				create pxyResUsed transient;
				self.allResUsed.add(pxyResUsed);

				pxyResUsed.setProxy(aHarbour,tmpRes.myResourceType,tmpRes,null,_move.occursOnDTNEW,theVoyage.departedDT,numTugs,true,null,null);

			endif;
		endif;
	else
		contractTugCharged := false;
		idx := 0;
		foreach aTug in _move.allTugsUsed do
			idx := idx + 1;
			poc := (numTugs &gt;= idx);
			
			if poc and contractTugCharged then
				continue;
			endif;
			
			if poc then
				qty := numTugs;
			else
				qty := _move.allTugsUsed.size - numTugs;
			endif;
			tmpRes := aTug.getResourceForHarbourMovement(aHarbour, _move.moveType);
			// ## No Resource = NO Charge
			if tmpRes = null then
				continue;
			endif;
			create pxyResUsed transient;
			self.allResUsed.add(pxyResUsed);
			pxyResUsed.setProxy(aHarbour,tmpRes.myResourceType,tmpRes,null,_move.occursOnDTNEW,theVoyage.departedDT,qty,poc,null,null);
			
			if poc then
				contractTugCharged := true;
			else 
				break;
			endif;
		endforeach;

	endif;		

end;</source>
        <Parameter name="_move" type="HMS_VoyageMovement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="dummyUpWharf" id="95ed683f-81f7-41e7-bd00-230151b81265">
        <updating/>
        <source>dummyUpWharf(_move : HMS_VoyageMovement input) updating;
// ---------------------------------------------------------------------------
// Created:		27 September 2005  By Andrew Bishop cnwab1
//
// Purpose:		This is only for non berthage type resources, typically that have been out on to the Arrival movement.
//
// ---------------------------------------------------------------------------

vars
	diff, diffMin : Integer;
	timeTill2ndResource : Real;

	tmpRes : HMS_Resource;
	pxyResUsed : HMS_ResourceUsed;
	theVoyage : CM_Voyage;
	aHarbour : HMS_Harbour;
	theCalcType : CM_CalculationType;
	berthPOC : Boolean;
begin
	if _move.getMyBerth.myWharf = null then
		return;
	endif;
	
	if _move.moveType =  HMSMovementTypeArrival then
		self.dummyUpWharfArrival(_move);
	else
		self.dummyUpWharfDeparture(_move);
	endif;
end;</source>
        <Parameter name="_move" type="HMS_VoyageMovement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="dummyUpWharfArrival" id="aa6f7c82-fe5a-489a-95b9-28ee3c703987">
        <updating/>
        <source>dummyUpWharfArrival(_move : HMS_VoyageMovement input) updating;
// ---------------------------------------------------------------------------
// Created:		27 September 2005  By Andrew Bishop cnwab1
//
// Purpose:		This is only for non berthage type resources, typically that have been out on to the Arrival movement.
//
// ---------------------------------------------------------------------------

vars
	diff, diffMin : Integer;
	timeTill2ndResource : Real;

	tmpRes : HMS_Resource;
	pxyResUsed,realResUsed : HMS_ResourceUsed;
	theVoyage : CM_Voyage;
	aHarbour : HMS_Harbour;
	theCalcType : CM_CalculationType;
	berthPOC : Boolean;
	isDefaultJMTProcess : Boolean;	//17 Oct 2018	NDL	TFS 41411
begin
	if _move.getMyBerth.myWharf = null then
		return;
	endif;
	
	if _move.moveType &lt;&gt; HMSMovementTypeArrival then
		return;
	endif;
	
	theVoyage := _move.myHMSVoyageData.myVoyage;
	aHarbour := _move.myHarbour;
	berthPOC := theVoyage.isBerthageOnContract();
	
	//17 Oct 2018	NDL	TFS 41411 - don't create dummy lines for non default voyage processes.
	/* TFS 41411 Removed during testing as incorrect
	isDefaultJMTProcess := theVoyage.myVoyageProcess = null or theVoyage.myVoyageProcess.isDefaultProcessJMT;
	if not isDefaultJMTProcess then
		return;
	endif;
	*/
	
	tmpRes := _move.getMyBerth.myWharf.getResourceForHarbourMovement(_move.moveType,HMS_Wharf.First_Resource);
	if tmpRes &lt;&gt; null then




		// Check that it has not already been created and has noresource currently i.e. is a default from the vessel
//		if _move.getDefaultResourceUsed(tmpRes) = null then
		realResUsed := _move.getDefaultResourceUsed(tmpRes);// try to find a real matching resource
		if realResUsed = null then // there may be a persistent ResUsed without a resource set. Check the proxy copy as this will have already been set a ResUsed.
			realResUsed := self.getResourceFromLocalProxies(tmpRes);
		endif;
		if realResUsed = null then
				create pxyResUsed transient;
				self.allResUsed.add(pxyResUsed);
		
				pxyResUsed.setProxy(aHarbour,tmpRes.myResourceType,tmpRes,null,theVoyage.arrivedDT,theVoyage.departedDT,1,berthPOC,null,null);
		endif;
	endif;
	tmpRes := _move.getMyBerth.myWharf.getResourceForHarbourMovement(_move.moveType,HMS_Wharf.Second_Resource);
	if tmpRes &lt;&gt; null then
		// Check that it has not already been created and has noresource currently i.e. is a default from the vessel
		if _move.getDefaultResourceUsed(tmpRes) = null then

			theCalcType := tmpRes.getMappedInvoiceCalcType(theVoyage,berthPOC);
			// if the resource is for not a 'chop it up into hourly blocks' type of calculation then charge as normal
			if theCalcType &lt;&gt; null then
				create pxyResUsed transient;
				self.allResUsed.add(pxyResUsed);
		
				pxyResUsed.setProxy(aHarbour,tmpRes.myResourceType,tmpRes,null,theVoyage.arrivedDT,theVoyage.departedDT,1,berthPOC,null,null);
			endif;
		endif;	
	endif;


end;</source>
        <Parameter name="_move" type="HMS_VoyageMovement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="dummyUpWharfDeparture" id="4031823a-1af7-4dad-9647-d4f876d440aa">
        <updating/>
        <source>dummyUpWharfDeparture(_move : HMS_VoyageMovement input) updating;
// ---------------------------------------------------------------------------
// Created:		27 September 2005  By Andrew Bishop cnwab1
//
// Purpose:		This is only for non berthage type resources, typically that have been out on to the Arrival movement.
//
// ---------------------------------------------------------------------------
//23 May 2015	cnwrs1	Par 36315 - 1090
//10 Dec 2015	cnwdap1	PAR #37295 - Check for Calculation type on resource for setting hour blocks
//31 Mar 2020	jlgdap1	TFS 48975 ASPA HMS Charging for Shifts

vars
	diff, diffMin : Integer;
	timeTill2ndResource : Real;
	thePrevMove : HMS_VoyageMovement;
	prevWharf : HMS_Wharf;
	tmpRes : HMS_Resource;
	realResUsed, pxyResUsed : HMS_ResourceUsed;
	theVoyage : CM_Voyage;
	aHarbour : HMS_Harbour;
	theCalcType, res1CalcType, res2CalcType : CM_CalculationType;
	berthPOC : Boolean;
	numHourBlocks, minutes4Block, firstBlockMinutes : Integer;
	stTS, endTS : TimeStamp;
	hmsBerthBlock1, hmsBerthBlock2 : Integer; 
	isDefaultJMTProcess : Boolean;	//17 Oct 2018	NDL	TFS 41411
	isPelindo : Boolean;	//12 Dec 2018	NDL	TFS 42526
	clearUnitsUsed : Boolean;	//12 Dec 2018	NDL	TFS 42526
begin
	if _move.getMyBerth.myWharf = null then
		return;
	endif;
	
	if _move.moveType = HMSMovementTypeArrival then
		return;
	endif;
	
	self.berthageNoShift := _move.getMyTerminal.getConfig(InvoiceHMSNoShiftCharge).Boolean;
	if self.berthageNoShift 
	and _move.moveType = HMSMovementTypeShift  then
		return;
	endif;
	
	theVoyage := _move.myHMSVoyageData.myVoyage;
	aHarbour := _move.myHarbour;
	berthPOC := theVoyage.isBerthageOnContract();

	//17 Oct 2018	NDL	TFS 41411 - don't create dummy lines for non default voyage processes.
	/* TFS 41411 Removed during testing as incorrect
	isDefaultJMTProcess := theVoyage.myVoyageProcess = null or theVoyage.myVoyageProcess.isDefaultProcessJMT;
	if not isDefaultJMTProcess then
		return;
	endif;
	*/
	
	//12 Dec 2018	NDL	TFS 42526
	if theVoyage.myVoyageProcess &lt;&gt; null and not theVoyage.myVoyageProcess.isDefaultProcessJMT then
		isPelindo := true;
	endif;
	
	if self.berthageNoShift then
		thePrevMove := _move.myHMSVoyageData.getMovementFirstChargeable(_move.moveType); 
	else
		thePrevMove := _move.getVoyageMovementPrevious(); 
		stTS := thePrevMove.occursOnDTNEW;
		endTS := _move.occursOnDTNEW;
		
		diffMin := (stTS.cnEcDiff(endTS) / MillisecondsPerMinute).Integer; 

		if _move.moveType = HMSMovementTypeShift then
	//		thePrevMove := _move;	//11 Sep 2018	NDL	TFS 
		else // Departure
			thePrevMove := _move.getMovementPreviousChargeable(); 
		endif;

	endif;
	if thePrevMove &lt;&gt; null then
		prevWharf := thePrevMove.getMyBerth.myWharf;
	else
		prevWharf := _move.getMyBerth.myWharf;
	endif;


	
	tmpRes := prevWharf.getResourceForHarbourMovement(_move.moveType,HMS_Wharf.First_Resource);
	
	if tmpRes &lt;&gt; null then
		hmsBerthBlock1 := tmpRes.getTimeBlockFromResource(_move,berthPOC).Integer;// PAR 35469
		// PAR #37295 If the resource has a "Calculation Type for Quantity", then use this to get hours				// PAR #37295
		
		res1CalcType := tmpRes.myCalculationTypeQuantity; // TFS 39721
/* TFS 39721 was
		if tmpRes.myCalculationTypeQuantity &lt;&gt; null and tmpRes.myCalculationTypeQuantity.hoursBlock &lt;&gt; null then	// PAR #37295
			hmsBerthBlock1 := tmpRes.myCalculationTypeQuantity.hoursBlock.Integer;									// PAR #37295
		endif;																										// PAR #37295
NOW */
		if res1CalcType &lt;&gt; null and res1CalcType.hoursBlock &lt;&gt; null then
			hmsBerthBlock1 := res1CalcType.hoursBlock.Integer;
		endif;



		// Check that it has not already been created and has noresource currently i.e. is a default from the vessel
		if self.berthageNoShift then
			numHourBlocks := _move.myHMSVoyageData.getNumberOfBlocksVisit(hmsBerthBlock1, diff, firstBlockMinutes, false, hmsBerthBlock1, tmpRes); // PAR 35469
			diffMin := diff; // PAR 12884
			endTS := theVoyage.departedDT;
			stTS := endTS.addMinutes(diff * -1);
		else
		
			if res1CalcType &lt;&gt; null then // TFS 39721
				numHourBlocks := res1CalcType.getNumHourBlocks(diffMin,true,prevWharf); // TFS 39721
				if numHourBlocks &lt; 1 then // TFS 39721
					numHourBlocks := 1; // TFS 39721
				endif; // TFS 39721
				
			else // TFS 39721
			
				numHourBlocks := _move.myHMSVoyageData.getNumberOfBlocksMovement(diffMin,hmsBerthBlock1, prevWharf, true);		// 36605 extra param
			endif;
		endif;

		//12 Dec 2018	NDL	TFS 42526 - set the 'units used' to zero if it uses dates and not quantity.
		if isPelindo then
			if tmpRes.myResourceType &lt;&gt; null
			and tmpRes.myResourceType.isFromToDateTimeRequired
			and not tmpRes.myResourceType.isQuantityRequired
			then
				numHourBlocks := 0;
			endif;
		endif;

		realResUsed := _move.getDefaultResourceUsed(tmpRes);// try to find a real matching resource
		if realResUsed = null then // there may be a persistent ResUsed without a resource set. Check the proxy copy as this will have already been set a ResUsed.
			realResUsed := self.getResourceFromLocalProxies(tmpRes);
		endif;
		if realResUsed = null then
			create pxyResUsed transient;
			self.allResUsed.add(pxyResUsed);

			pxyResUsed.setProxy(aHarbour,tmpRes.myResourceType,tmpRes,null,stTS, endTS,numHourBlocks,berthPOC,null,null);
			pxyResUsed.setMyVoyageMovement(_move);						// TFS 48975
		endif;
	endif;
	
	
	tmpRes := prevWharf.getResourceForHarbourMovement(_move.moveType,HMS_Wharf.Second_Resource);
	
	if tmpRes &lt;&gt; null then
		hmsBerthBlock2 := tmpRes.getTimeBlockFromResource(_move,berthPOC).Integer;// PAR 35469
		// PAR #37295 If the resource has a "Calculation Type for Quantity", then use this to get hours				// PAR #37295
		
		
		res2CalcType := tmpRes.myCalculationTypeQuantity; // TFS 39721
/* TFS 39721 was
		
		if tmpRes.myCalculationTypeQuantity &lt;&gt; null and tmpRes.myCalculationTypeQuantity.hoursBlock &lt;&gt; null then	// PAR #37295
			hmsBerthBlock2 := tmpRes.myCalculationTypeQuantity.hoursBlock.Integer;									// PAR #37295
		endif;	
NOW */
		if res2CalcType &lt;&gt; null and res2CalcType.hoursBlock &lt;&gt; null then
			hmsBerthBlock2 := res2CalcType.hoursBlock.Integer;
		endif;
		
		
		// PAR #37295
		if theVoyage.arrivedDT.isValid and theVoyage.departedDT.isValid then// ### PAR 10966
	
			// PAR 35469 minutes4Block := ((HMSBerthBlock1 * MillisecondsPerHour) / MillisecondsPerMinute).Integer; // basically 24 hours as minutes = 1440
			minutes4Block := ((hmsBerthBlock1 * MillisecondsPerHour) / MillisecondsPerMinute).Integer; // basically 24 hours as minutes = 1440
			if firstBlockMinutes &lt; minutes4Block then // first block is less than 24 hours
				diffMin := diffMin - firstBlockMinutes; // PAR 12319 - only take away the minutes for the first block of berthage.
			else // first block is greater than 24 hours
				diffMin := diffMin - minutes4Block; // PAR 12319 - take away 24 hours
			endif;
		
			timeTill2ndResource := (prevWharf.timeTill2ndResource * MillisecondsPerHour) / MillisecondsPerMinute; // PAR 10972 AKB2005DEC
			// ### charge for 2nd berthage resource
			if diffMin &gt;= timeTill2ndResource then// ### PAR 10972
				// Check that it has not already been created and has noresource currently i.e. is a default from the vessel
				realResUsed := _move.getDefaultResourceUsed(tmpRes); // try to find a real matching resource
				if realResUsed = null then // there may be a persistent ResUsed without a resource set. Check the proxy copy as this will have already been set a ResUsed.
					realResUsed := self.getResourceFromLocalProxies(tmpRes);
				endif;
				if realResUsed = null then
//					// if the resource is for not a 'chop it up into hourly blocks' type of calculation then charge as normal
						if self.berthageNoShift then
							numHourBlocks := _move.myHMSVoyageData.getNumberOfBlocksVisit(hmsBerthBlock2, diff, firstBlockMinutes, true, hmsBerthBlock1, tmpRes); // PAR 35469
							endTS := theVoyage.departedDT;
							stTS := endTS.addMinutes(diff * -1);
						else
							if res2CalcType &lt;&gt; null then // TFS 39721
								numHourBlocks := res2CalcType.getNumHourBlocks(diffMin,true,prevWharf); // TFS 39721
								// NOTE numHourBlocks = 0 is valid, do not set to 1 
							else // TFS 39721
								numHourBlocks := _move.myHMSVoyageData.getNumberOfBlocksMovement(diffMin,hmsBerthBlock2, prevWharf, false);		// 36605 extra param
							endif;
						endif;

						if numHourBlocks &gt; 0 then		// 36605
							create pxyResUsed transient;
							self.allResUsed.add(pxyResUsed);
							
							//12 Dec 2018	NDL	TFS 42526 - set the 'units used' to zero if it uses dates and not quantity.
							if isPelindo then
								if tmpRes.myResourceType &lt;&gt; null
								and tmpRes.myResourceType.isFromToDateTimeRequired
								and not tmpRes.myResourceType.isQuantityRequired
								then
									numHourBlocks := 0;
								endif;
							endif;
				
							pxyResUsed.setProxy(aHarbour,tmpRes.myResourceType,tmpRes,null,stTS, endTS,numHourBlocks,berthPOC,null,null);
							pxyResUsed.setMyVoyageMovement(_move);		// TFS 48975
						endif;	
				endif;
			endif;
		endif;
	endif;


end;</source>
        <Parameter name="_move" type="HMS_VoyageMovement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getResourceFromLocalProxies" id="7277aa4f-485d-4553-addb-1dca7c4062da">
        <source>getResourceFromLocalProxies(_resource : HMS_Resource) : HMS_ResourceUsed;
// ---------------------------------------------------------------------------
// Created:		12 September 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	tmpResourceUsed : HMS_ResourceUsed;
	anObj : Object;
begin
	if _resource = null then
		return null;
	endif;
	foreach anObj in self.allResUsed do
		tmpResourceUsed := anObj.HMS_ResourceUsed;
		
		if tmpResourceUsed.myResource = _resource then
			return tmpResourceUsed;
		endif;
	endforeach;
	return null;


end;</source>
        <Parameter name="_resource" type="HMS_Resource"/>
        <ReturnType type="HMS_ResourceUsed"/>
    </JadeMethod>
    <JadeMethod name="initialise" id="ce3f030a-94b5-4a86-9946-b93ecf6b795b">
        <updating/>
