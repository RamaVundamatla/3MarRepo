    <JadeMethod name="changeByXXHours" id="64980ed0-9c65-4026-83b5-e159b9359279">
        <source>changeByXXHours(_changeByHours : Integer):TimeStamp;
//--------------------------------------------------------------
//Created: 27 June 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	currentDate:	Date;
	currentTime:	Time;
	currentHour,
	newHour,
	hoursToChange,
	daysToChange:	Integer;
	newDate:		Date;
	newTime			: Time;
	newTS			: TimeStamp;
begin
	// This method will return a timestamp that is changed by the number
	// of hours that are passed in the hoursToChange parameter
	// NOTE: hoursToChange change be a positive or a negative change


	if _changeByHours = 0 then
		return self;
	endif;

	currentTime := self.time;
	currentHour := currentTime.hour;
	currentDate := self.Date;
	
	daysToChange := (_changeByHours / 24).abs.Integer;
	hoursToChange := (_changeByHours mod 24).abs.Integer;

	if _changeByHours &lt; 0 then
		if currentHour &lt; hoursToChange then
			daysToChange := daysToChange + 1;
			newHour := 24 - hoursToChange + currentHour;
		else
			newHour := currentHour - hoursToChange;
		endif;
		newTS.setDate(currentDate - daysToChange);
	else
		newHour := currentHour + hoursToChange;
		if newHour &gt;= 24 then
			newHour := newHour - 24;
			daysToChange := daysToChange + 1;
		endif;
		newTS.setDate(currentDate + daysToChange);
	endif;
	
	newTime.setTime(newHour, currentTime.minute, currentTime.second, currentTime.milliSecond);
	newTS.setTime(newTime);
	
	if (not newTS.isValid) then
		app.raiseUnexpectedProgramError('TimeStamp', method.name, 'Invalid timestamp for ' &amp; self.String &amp; ' changeBy ' &amp; _changeByHours.String);
	endif;
	
	return newTS;

/*
	currentDate := self.Date;
	currentTime := self.Time;

	if hoursToChange &lt; 0 then

		// Subtract time
		daysToChange:=((currentHour - hoursToChange.abs)/24).Integer.abs;

		if hoursToChange.abs &gt; currentHour then

// BUG HERE WHICH CAN RESULT IN TRYING TO DO '24:0:0' WHICH IS INVALID
			newTime := ((24 - ((currentHour - hoursToChange.abs).abs-(daysToChange*24))).String.padLeadingZeros(2) &amp; ":" &amp; self.Time.minute.String &amp; ":" &amp; self.Time.second.String).Time;
			daysToChange := daysToChange + 1;
			newDate := (currentDate-daysToChange).Date;
		else
			newTime := (((currentHour - hoursToChange.abs).abs-(daysToChange*24)).String.padLeadingZeros(2) &amp; ":" &amp; self.Time.minute.String &amp; ":" &amp; self.Time.second.String).Time;
			newDate := (currentDate-daysToChange).Date;
		endif;

		return (newDate.String &amp; "," &amp; newTime.String).TimeStamp;
	else
		// Add time
		daysToChange := ((currentHour + hoursToChange)/24).Integer;
		newTime := (((currentHour + hoursToChange)-(daysToChange*24)).String.padLeadingZeros(2) &amp; ":" &amp; self.Time.minute.String &amp; ":" &amp; self.Time.second.String).Time;
		newDate := (currentDate+daysToChange).Date;
		return (newDate.String &amp; "," &amp; newTime.String).TimeStamp;
	endif;	
*/
end;</source>
        <Parameter name="_changeByHours" type="Integer"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="changeByXXMinutes" id="fe52c799-2083-4b72-adc8-6979101ad10a">
        <source>changeByXXMinutes(minutes:Integer):TimeStamp;

vars
	ts: 		TimeStamp;
	ti: 		Time;
	min: 		Integer;
	rem: 		Integer;
	remTime:	Time;
begin
	ti := self.time;
	min := ti.minute;
	ts := self.changeByXXHours((minutes/60).Integer);
	rem := minutes - (((minutes/60).Integer) * 60).Integer; 
	if rem &lt; 0 then
		remTime.setTime(0,rem.abs,0,0);
		ts := ts - remTime;
	else
		remTime.setTime(0,rem,0,0);
		ts := ts + remTime;
	endif;
	//ti.setTime(ts.time.hour,min,0,0);
	//ts.setTime(ti + rem);
	return ts;	
end;</source>
        <Parameter name="minutes" type="Integer"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="checkIfDaylightSaving" id="1b7e478e-5c3c-4bef-bce9-7ebda2d01f24">
        <source>checkIfDaylightSaving(_dstChangesToday : Boolean output; _zone : String)  : Boolean;
//Tests if the passed in time is during a daylight savings period. Also tests if the clocks
//will change within 12 hours of the passed in time. Hoped to able to replace the rules for
//each locale with a system call in a later version of jade
constants
	SUNDAY = 7;
vars
	dstCutoff : TimeStamp;		//Time when daylight savings starts or ends
	tmpDate : Date;
	tmpTime : Time;
	tmpMonth, 
	tmpYear, 
	i		: Integer;
	daylightSaving : Boolean;
begin

	tmpMonth := self.date.month;
	tmpYear := self.date.year;

	if _zone = "New Zealand" then

		if tmpYear &gt; 2007 or (tmpYear &gt;= 2007 and tmpMonth &gt;= 9) then
			// from Sept 2007 
			// NZDT starts the last Sunday in September(9), finished first Sunday in April(4)
			
			if tmpMonth &gt;= 10 or tmpMonth &lt;= 3 then			//October(10) - March(3) always NZDT
				daylightSaving := true;
	
			elseif tmpMonth &gt;= 5 and tmpMonth &lt;= 8 then		//May(5) - August(8) always NZST
				daylightSaving := false;
	
			elseif tmpMonth = 9 then			//September(9) could be either
				tmpTime.setTime(2,0,0,0);		//DST starts and ends at 0200
				tmpDate := self.date;
				foreach i in 30 to 1 step-1 do		//Find last Sunday in September
					tmpDate.setDate(i, 9, tmpYear);
					if tmpDate.dayOfWeek = SUNDAY then
						break;
					endif;
				endforeach;
				dstCutoff.setDate(tmpDate);
				dstCutoff.setTime(tmpTime);
				daylightSaving := (self &gt; dstCutoff);
				i := self.differenceInHours(dstCutoff);
				if i &gt;= -12 and i &lt;= 12 then
					_dstChangesToday := true;
				endif;
				
			elseif tmpMonth = 4 then				//April(4) could be either 
				tmpTime.setTime(2,0,0,0);			//DST starts and ends at 0200
				tmpDate := self.date;				
				foreach i in 1 to 30 do			//Will be 1st Sunday in April(4)
					tmpDate.setDate(i, 4, tmpYear);
					if tmpDate.dayOfWeek = SUNDAY then
						break;
					endif;
				endforeach;
				dstCutoff.setDate(tmpDate);
				dstCutoff.setTime(tmpTime);
				daylightSaving := (self &lt; dstCutoff);
				i := self.differenceInHours(dstCutoff);
				if i &gt;= -12 and i &lt;= 12 then
					_dstChangesToday := true;
				endif;
			else
				daylightSaving := false;		//Should never get here !
			endif;
		
		else
			//These are the New Zealand rules for daylight saving periods	
			//NZDT starts 1st Sunday in October and finishes 3rd Sunday in March
			
			if tmpMonth &gt; 10 or tmpMonth &lt; 3 then			//November - February always NZDT
				daylightSaving := true;
	
			elseif tmpMonth &gt; 3 and tmpMonth &lt; 10 then	//April - September always NZST
				daylightSaving := false;
	
			elseif tmpMonth = 10 then			//October could be either
				tmpTime.setTime(2,0,0,0);		//DST starts and ends at 0200
				tmpDate := self.date;
				foreach i in 1 to 31 do		//Find 1st Sunday in October
					tmpDate.setDate(i, 10, tmpYear);
					if tmpDate.dayOfWeek = SUNDAY then
						break;
					endif;
				endforeach;
				dstCutoff.setDate(tmpDate);
				dstCutoff.setTime(tmpTime);
				daylightSaving := (self &gt; dstCutoff);
				i := self.differenceInHours(dstCutoff);
				if i &gt;= -12 and i &lt;= 12 then
					_dstChangesToday := true;
				endif;
			elseif tmpMonth = 3 then		//March could be either 
				tmpTime.setTime(2,0,0,0);		//DST starts and ends at 0200
				tmpDate := self.date;			//Find 3rd Sunday in March
				foreach i in 15 to 31 do		//Will be 1st Sunday on or after 15th
					tmpDate.setDate(i, 3, tmpYear);
					if tmpDate.dayOfWeek = SUNDAY then
						break;
					endif;
				endforeach;
				dstCutoff.setDate(tmpDate);
				dstCutoff.setTime(tmpTime);
				daylightSaving := (self &lt; dstCutoff);
				i := self.differenceInHours(dstCutoff);
				if i &gt;= -12 and i &lt;= 12 then
					_dstChangesToday := true;
				endif;
			else
				daylightSaving := false;		//Should never get here !
			endif;
		endif;
    endif;
epilog
	return daylightSaving;
end;</source>
        <Parameter name="_dstChangesToday" type="Boolean" usage="output"/>
        <Parameter name="_zone" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="dataDumpFormat" id="6211c93a-1f8c-4df8-adc4-a86b9aaefbe7">
        <source>dataDumpFormat() : String;
// ---------------------------------------------------------------------------
// Created:     26 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin
	if self.isValid then
		return self.date.dataDumpFormat &amp; " " &amp;
				self.time.dataDumpFormat;
