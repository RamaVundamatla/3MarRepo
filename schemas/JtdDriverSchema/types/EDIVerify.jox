<Class name="EDIVerify" id="644b83fa-b87b-4cdd-a6b9-1ae6fb001884">
    <superclass name="JmtTransactionGenerator"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="Port"/>
    <JadeMethod name="ev03_getEDIFilesDialog" id="c90ba7f0-00a7-498b-ba0f-72204150b746">
        <updating/>
        <source>ev03_getEDIFilesDialog():Integer updating;

begin
	app.logMessage(method.qualifiedName);
	self.myEDIForm := self.loadForm(PmAdmEdiopersView, false).CMUI_EDIForm;
	
	return (myEDIForm = null).Integer;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="ev04_doEDIVerify" id="0e51d3bc-efdc-47d3-a45c-16c92e4ca0da">
        <source>ev04_doEDIVerify(): Integer;

vars
	rslt	: Integer;
	row		: Integer;
	obj		: Object;
begin
	app.logMessage(method.qualifiedName);
	if myEDIForm = null then
		app.logMessage('No EDIForm');
		return 1;
	endif;
	rslt := 1;	// unsuccessful
	obj := null;
	myEDIForm.tblData.clearAllSelected;
	myEDIForm.tblData.selectMode := Table.SelectMode_Row;
	foreach row in myEDIForm.tblData.fixedRows+1 to myEDIForm.tblData.rows do
		myEDIForm.tblData.accessRow(row);
		obj := myEDIForm.tblData.accessedRow.itemObject;
		if obj &lt;&gt; null and CM_EDIData.hasInstance(obj) then
			myEDIForm.tblData.selectTheCurrentRow(row);
			break;
		endif;
	endforeach;
	if obj = null then
		return 1;	// no suitable row entry
	endif;
//	myEDIForm.doMnuFormContextMenu(myEDIForm.tblData, false, 0, 0);

//	How do I unload the contextMenu (mnuTblViewContext)?
//	myEDIForm.setFocus;
	myEDIForm.doVerifyEDITIs;
	return 0;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="ev06_loadGateForm" id="74677236-3da7-4b0e-bd62-8fb9c7d37a43">
        <updating/>
        <source>ev06_loadGateForm():Integer updating;

vars

begin
	app.logMessage(method.qualifiedName);
	//myGateInOutForm:=self.loadForm(GateSchemaName, "GTE_InOutForm", true);
	self.myGateInOutForm := self.loadForm(PmGteInOutEntry, false);
	
	return 0;
end;
</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="ev99_closeForm" id="52ceaef9-aa9f-4302-a375-8fb74a87fd7d">
        <updating/>
        <source>ev99_closeForm() updating;

begin
	myEDIForm.unloadForm;
	myEDIForm := null;
	doEndOfLoop;
end;</source>
    </JadeMethod>
    <JadeMethod name="listForms" id="8a765432-9d22-4ad0-977e-8a1d9914b9f3">
        <source>listForms(num:Integer);

vars
	idx		: Integer;
	form	: Form;

begin

	idx := app.formsCount;
	while idx &gt; 0 do
		form := app.forms(idx);
		if form &lt;&gt; null then
			// the error warning form is unloaded in the app.logout method.
write form.name;
		endif;
		idx := idx - 1;
	endwhile;
write '--endlist-- ' &amp; num.String;	
end;</source>
        <Parameter name="num" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="startup" id="e13caddc-b04e-468b-97b3-08b46a25c795">
        <updating/>
        <source>startup() updating;

begin
	inheritMethod();
end;</source>
    </JadeMethod>
</Class>
