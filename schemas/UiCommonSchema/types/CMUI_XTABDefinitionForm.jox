    <JadeMethod name="loadCellSheet" id="15905b5c-4242-438e-85de-179705304c7f">
        <source>loadCellSheet(_field :CM_XTABField)protected;
// ---------------------------------------------------------------------------
// Created:     27 November 2008 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.loadFunctionsForField (_field);
	
	if _field &lt;&gt; null then
		txtProperty.text		:= _field.getQueryPropertyTerminology;
		txtCaption_Cell.text	:= _field.heading;
		
		self.setFunction (_field.function);
		
		txtDecimals.text		:= _field.decimals.String;
		chkSeperator.value		:= _field.useSeperator;
		chkHideDetails.value	:= _field.hideDetail;
		chkHideSubTotal.value	:= _field.hideSubtotals;
		chkHideGrandTot.value	:= _field.hideGrandTotals;
		
		self.loadGroupingSheet (null);
	else
		txtProperty.text		:= null;
		txtCaption_Cell.text	:= null;
		txtDecimals.text		:= null;
		chkSeperator.value		:= false;
		chkHideDetails.value	:= false;
		chkHideSubTotal.value	:= false;
		chkHideGrandTot.value	:= false;
	endif;
	
	lblUseParentWarn.visible :=  self.isPropertyDerivedFromParent(_field);
	
	// save off field we are displaying
	shtProperties.userObject	:= _field;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_field" type="CM_XTABField"/>
    </JadeMethod>
    <JadeMethod name="loadFunctionsForField" id="e2d52585-9cd3-44a1-b36f-f75434a041ea">
        <source>loadFunctionsForField( _field : CM_XTABField ) protected;

// ---------------------------------------------------------------------------
// Created:     27 November 2008 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 12/02/2010	cnwcs5	par 22140 - New functions
// 04/06/2015   cnwma1  PAR 36369 - Unable to use the Sum function in a summary definition
// ---------------------------------------------------------------------------

vars
	index		: Integer;
	property	: CM_QueryProperty;
	
begin
	cmbFunction.clear;
	
	if _field = null then
		return;
	endif;
		
	property := _field.getQueryProperty;
	
	// Only allow decimal places if have a decimal.
	self.txtDecimals.enabled	:= property &lt;&gt; null and ( property.isKindOf( CM_QDecimalProperty ) or   property.isKindOf( CM_QRefMeasurementProperty ) or property.isKindOf(CM_QDecimalMethod)) ; // 04/06/2015 cnwma1 PAR #36369 //epr TFS 2438 27/7/16
	
	// code previously in this method has been refactored into CMUIAssistant method
	self.myAssistant.loadXTABFunctionsForQueryProp (property, cmbFunction);	// 12/02/2010 cnwcs5 par 22140
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_field" type="CM_XTABField"/>
    </JadeMethod>
    <JadeMethod name="loadGroupingSheet" id="662677ab-e24f-4b22-bdbf-d0e19b609878">
        <source>loadGroupingSheet(_element :CM_XTABGrouping)protected;
// ---------------------------------------------------------------------------
// Created:     27 November 2008 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 23/11/2009	cnwcs5		ccms 1028 - summary mappings
// ---------------------------------------------------------------------------
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars

begin
	if _element &lt;&gt; null then
		if _element.isTab then
			self.shtGroupings.caption :=  app.getErrorString (CMUI_XTABDefinitionForm_Tab); 
		elseif _element.isRow then
			self.shtGroupings.caption := app.getErrorString (CMUI_XTABDefinitionForm_Row);
		else
			self.shtGroupings.caption := app.getErrorString (CMUI_XTABDefinitionForm_Col);
		endif;
		
		txtElement.text		:= _element.getQueryPropertyTerminology;
		txtCaption.text		:= _element.heading;
		
		if _element.descending then
			cmbOrder.listIndex	:= self.ListIndex_Descending;
		else
			cmbOrder.listIndex	:= self.ListIndex_Ascending;
		endif;
		
		chkSubTotals.value		:= _element.includeSubtotals;
		txtSubTotHeading.text	:= _element.heading_SubTotal;
		
		if _element.isRow or _element.isTab then
			chkSummary.value	:= _element.includeSummary;
			txtSummHeading.text	:= _element.summaryHeading;
		else
			chkSummary.value	:= null;
			txtSummHeading.text	:= null;
		endif;
		
		// 23/11/2009 - load the mappings combo
		self.loadMappingsForElement (_element, null);
	
		self.loadCellSheet (null);
	else
		self.shtGroupings.translateCaption( Xlat_0009318, self.getLocale );
		txtElement.text		:= null;
		txtCaption.text		:= null;
		
		cmbOrder.listIndex	:= self.ListIndex_Ascending;
		
		chkSubTotals.value		:= null;
		txtSubTotHeading.text	:= null;
		chkSummary.value		:= false;
		txtSummHeading.text		:= null;
		
		self.loadMappingsForElement (null,null);	// 23/09/2009 - clear mappings combo
	endif;
	
	txtSubTotHeading.enabled	:= chkSubTotals.value;
	
	// save off element we are displaying
	shtGroupings.userObject	:= _element;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_element" type="CM_XTABGrouping"/>
    </JadeMethod>
    <JadeMethod name="loadMappingsForElement" id="5a89e5d1-51f2-4871-a1d1-f965bbd7c900">
        <source>loadMappingsForElement(_element :CM_XTABGrouping; _mapping :CM_XTABMapping) protected;
// ---------------------------------------------------------------------------
// Created:     23 November 2009 by cnwcs5
// Purpose:     CCMS 1028 - implement mappings
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	cmb			:CMUI_ComboBox;
	mapping		:CM_XTABMapping;
	idx, lstIdx	:Integer;
	prop		:String;
	selectedMapping : CM_XTABMapping;

begin
	cmb	:= self.cmbMapping;
	
	cmb.clear;
	
	if _element = null then
		return;	// nothing to load
	endif;
	
	//01 Dec 2009	NDL	CCMS 1028
	if _mapping &lt;&gt; null then
		selectedMapping := _mapping;
	else
		selectedMapping := _element.myXTABMapping;
	endif;
	
	cmb.addItem("");	// no mapping selected
	
	cmb.addItem(app.getErrorString(NewMapping));
	
	foreach mapping in CM_XTABMapping.instances do
		if mapping.propertyName &lt;&gt; _element.propertyName then
			continue;
		endif;
		idx := cmb.addItemObject(mapping.name, mapping);
		//if mapping = _element.myXTABMapping then
		if mapping = selectedMapping then	//01 Dec 2009	NDL	CCMS 1028
			lstIdx := idx;
		endif;
	endforeach;
	
	if lstIdx &lt;&gt; 0 then
		cmb.listIndex := lstIdx;
	endif;
	
	btnMapping.enabled := (cmb.listIndex &gt; 0 and cmb.itemText [cmb.listIndex] &lt;&gt; null);	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_element" type="CM_XTABGrouping"/>
        <Parameter name="_mapping" type="CM_XTABMapping"/>
    </JadeMethod>
    <JadeMethod name="loadModeCombo" id="1882ebda-31e5-4326-bfdc-41ffd18ad4a0">
        <updating/>
        <source>loadModeCombo()updating, protected;
// ---------------------------------------------------------------------------
// Created:     26 November 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 12/02/2010	cnwcs5		ccms 1925 / par 22295 - Release Summaries
//							change the way we check mode compatability (isCompatibleTypeAndMode)	
// ---------------------------------------------------------------------------
vars
	cmb			: CMUI_ComboBox;
	coll		: CM_QueryDefinitionByModeDict;
	qDef		: CM_QueryDefinition;
	idx			: Integer;
begin

	cmb := self.cmbMode;

	cmb.clear();
	cmb.sorted	:= true;				// cnwrl1 22/01/2009
	
	coll := app.myRoot.allQueryDefinitionObjects;
		
	foreach qDef in coll do 
		if not self.isCompatibleTypeAndMode (qDef.type, qDef.mode) then // 12/02/2010 cnwcs5 ccms 1925/par 22295
			continue;													// 12/02/2010 cnwcs5 ccms 1925/par 22295
		endif;															// 12/02/2010 cnwcs5 ccms 1925/par 22295
		
		idx := cmb.addItem(qDef.modeDescription);
		cmb.itemObject[idx] := qDef;
	endforeach;
	
	if self.myQueryDefinition &lt;&gt; null then
		cmb.listObject  := self.myQueryDefinition;	
	endif;
epilog
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadOrderCombo" id="7c50bd22-70e4-4b91-9e44-ce10fbded332">
        <source>loadOrderCombo()protected;
// ---------------------------------------------------------------------------
// Created:     27 November 2008 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	cmbOrder.addItem (app.getErrorString(CMUI_XTABDefinitionForm_Asc));
	cmbOrder.addItem (app.getErrorString(CMUI_XTABDefinitionForm_Desc));
	
	cmbOrder.listIndex := 1;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadProperties" id="bbcace92-c910-4da1-9b9a-f94f840f8641">
        <source>loadProperties()protected;
// ---------------------------------------------------------------------------
// Created:     26 November 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tbl		: Table;
	prop	: CM_QueryProperty;
	str 	: String;	
	bolType : CM_CargoBOLType;
begin
	tbl					:= self.tblProperties;
	tbl.clear;
	tbl.rows 			:= 0;
	tbl.columns			:= 1;
	tbl.sortColumn[ 1 ]	:= 0;			// no sorting ?
	tbl.gridLines		:= false;
	
	bolType				:= app.myRoot.getCargoBOLTypeForId( self.myQueryDefinition.mode ); 

	foreach prop in self.myQueryDefinition.allQueryProperties do
		if not prop.canBeViewed( app.myPassport ) then
			continue;
		endif;
		
		str := app.getTerminologyAlternate( bolType, null, prop.niceName, CM_TermExpressionSingular, prop.niceName );
		
		tbl.addItem( str ); 
		tbl.accessCell( tbl.rows, 1 ).itemObject	:= prop; 
		tbl.accessRow( tbl.rows ).itemObject		:= prop;
	endforeach;

	tbl.sortColumn[ 1 ]	:= 1;			// now sorting on column 1
	tbl.resort;
	
epilog
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadSavedDisplays" id="cf633fa4-4a0f-4e58-ad72-cf226eb780ff">
        <source>loadSavedDisplays()protected;
// ---------------------------------------------------------------------------
// Created:     08 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 13/01/2009	cnwrl1		Add user notifications (CCMS SFW 1047 - Totals Only Lists)
// 24 Nov 2009	NDL			CCMS 1028
// 12/02/2010	cnwcs5		ccms 1925 / par 22295 - Release summaries
//							Change way we check compatible modes (isCompatiblTypeAndMode)
// ---------------------------------------------------------------------------
vars
	xtab	: CM_OutputFormat_XTAB;
begin
	lstSavedDisplays.clear;
	
	foreach xtab in app.myRoot.allOutputFormats_XTAB do
		if not self.isCompatibleTypeAndMode (xtab.type,xtab.mode) then // 12/02/2010 cnwcs5 ccms 1925/par 22295
			continue;													// 12/02/2010 cnwcs5 ccms 1925/par 22295
		endif;															// 12/02/2010 cnwcs5 ccms 1925/par 22295

		lstSavedDisplays.itemObject[ lstSavedDisplays.addItem( xtab.name ) ]	:= xtab;
		self.beginNotification( xtab, EVENT_SummaryTable_Update, Response_Continuous, null );
		self.beginNotification( xtab, EVENT_SummaryTable_Delete, Response_Continuous, null );
	endforeach;
	
epilog

		
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadTableSheet" id="3f311cda-2859-488a-b62a-e4e0369d5a9d">
        <source>loadTableSheet(_format :CM_OutputFormat_XTAB)protected;
// ---------------------------------------------------------------------------
// Created:     27 November 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 18/08/2010	cnwcs5		par 23706 - new property
// ---------------------------------------------------------------------------
vars

begin
	if _format &lt;&gt; null then
		txtName.text			:= _format.name;
		txtDescription.text		:= _format.description;
		chkTotalColumn.value	:= _format.displayTotalColumn;
		txtTotColHeading.text	:= _format.grandTotalColumnHeading;
		chkTotalRow.value		:= _format.displayTotalRow;
		txtTotRowHeading.text	:= _format.grandTotalRowHeading;
		chkShowRepeatRow.value	:= _format.showRepeatedRowValues;	// 18/08/2010 cnwcs5 par 23706
	else
		txtName.text			:= null;
		txtDescription.text		:= null;
		chkTotalColumn.value	:= false;
		txtTotColHeading.text	:= null;
		chkTotalRow.value		:= false;
		txtTotRowHeading.text	:= null;
		chkShowRepeatRow.value	:= false;								// 18/08/2010 cnwcs5 par 23706
	endif;
	
	txtTotColHeading.enabled	:= chkTotalColumn.value;
	txtTotRowHeading.enabled	:= chkTotalRow.value;
	
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_format" type="CM_OutputFormat_XTAB"/>
    </JadeMethod>
