    <JadeMethod name="getAllDrawingIconsXML" id="66d6b2ce-978a-4552-b47b-3afee36ccfec">
        <source>getAllDrawingIconsXML(): String;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aWLE 		: CM_WorkListEntry;
	aSlotRequest : CM_SlotRequest;
	waterCooled : Boolean;
	theXMLString : String;
begin
	waterCooled := self.getHasCoolingWaterConnection;
	theXMLString :=  inheritMethod();
	if self.height &gt; 0 then
		if self.length &gt; 0 then
			if self.width &gt; 0 then
				theXMLString := theXMLString &amp; "&lt;at&gt;" &amp; PicTI_OD_HLW &amp; "&lt;/at&gt;";
			else
				theXMLString := theXMLString &amp; "&lt;at&gt;" &amp; PicTI_OD_HL &amp; "&lt;/at&gt;";
			endif;
		else
			if self.width &gt; 0 then
				theXMLString := theXMLString &amp; "&lt;at&gt;" &amp; PicTI_OD_HW &amp; "&lt;/at&gt;";
			else
				theXMLString := theXMLString &amp; "&lt;at&gt;" &amp; PicTI_OD_H &amp; "&lt;/at&gt;";
			endif;
		endif;
	elseif self.length &gt; 0 then
		if self.width &gt; 0 then
			theXMLString := theXMLString &amp; "&lt;at&gt;" &amp; PicTI_OD_WL &amp; "&lt;/at&gt;";
		else
			theXMLString := theXMLString &amp; "&lt;at&gt;" &amp; PicTI_OD_L &amp; "&lt;/at&gt;";
		endif;
	elseif self.width &gt; 0 then
		theXMLString := theXMLString &amp; "&lt;at&gt;" &amp; PicTI_OD_W &amp; "&lt;/at&gt;";
	endif;

	if self.is40 then
		theXMLString := theXMLString &amp; "&lt;at&gt;" &amp; PicTI40Footer &amp; "&lt;/at&gt;";
	endif;
 // PAR 16415 CCMS 1029
	if self.is30 then
		theXMLString := theXMLString &amp; "&lt;at&gt;" &amp; PicTI40Footer &amp; "&lt;/at&gt;";
	endif;

	if self.is53 then
		theXMLString := theXMLString &amp; "&lt;at&gt;" &amp; PicTI40Footer &amp; "&lt;/at&gt;";
	endif;
	if waterCooled then
		theXMLString := theXMLString &amp; "&lt;at&gt;" &amp; PicTIWaterCooled &amp; "&lt;/at&gt;";
	endif;
	// the only things that get connected are reefers so do not show the power icon and the reefer icon. at the same time
	if self.isConnected then
		theXMLString := theXMLString &amp; "&lt;at&gt;" &amp; PicTIConnected &amp; "&lt;/at&gt;";
	else
		if self.isReefer and not waterCooled then
			theXMLString := theXMLString &amp; "&lt;at&gt;" &amp; PicTIReefer &amp; "&lt;/at&gt;";
		endif;
	endif;
	if self.hasCOU then
		theXMLString := theXMLString &amp; "&lt;at&gt;" &amp; PicTICOU &amp; "&lt;/at&gt;";
	endif;

	if self.contentsStatus = TI_CONTENTS_STATUS_EMPTY then
		theXMLString := theXMLString &amp; "&lt;at&gt;" &amp; PicTIEmpty &amp; "&lt;/at&gt;";
	endif;

	if self.isFlat then
		theXMLString := theXMLString &amp; "&lt;at&gt;" &amp; PicTIFlat &amp; "&lt;/at&gt;";
	endif;

	if self.isHighCube() then
		theXMLString := theXMLString &amp; "&lt;at&gt;" &amp; PicTIHiCube &amp; "&lt;/at&gt;";
	endif;
//	if self.isNonStandardHeight then
//		theXMLString := theXMLString &amp; "&lt;at&gt;" &amp; PicTIOversized &amp; "&lt;/at&gt;";
//	endif;

	

	foreach aWLE in self.allWorklistEntries reversed do
		if CM_SlotRequest.hasInstance(aWLE.myRequest) then
			aSlotRequest := aWLE.myRequest.CM_SlotRequest;
			break;
		endif;
	endforeach;
	if aSlotRequest &lt;&gt; null then
		theXMLString := theXMLString &amp; aSlotRequest.getAllDrawingIconsXML();
	endif;
	return theXMLString;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAllSealNumCustoms" id="64b893d3-1096-4f74-b4c4-0dc623e2ecd1">
        <source>getAllSealNumCustoms(): String;
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 20 November 2008
//
// Implemented version: 7.7.1
// CCMS1765 GDANSK - Maersk reporting requirements. 
// Do not delete - used for reports.
//----------------------------------------------------------------------
/* Changes

Date		Name	TFS#		Description
============================================================================
29 Mar 2019 jlgka1	TFS 44020	Change StringArray to HugeStringArray.
============================================================================*/
vars
	int 	 : Integer;
	tmpStr,
	str 	 : String;	
	strArray : HugeStringArray;	//jlgka1 TFS 44020
begin

	//16 Sep 2010	NDL	Par 25608	remove ref to 'allCustomsSealNumbers'
	create strArray transient;
	self.getSealNumCustomsStringArray(strArray);
	
//	foreach tmpStr in self.allCustomsSealNumbers do
	foreach tmpStr in strArray do
		if str = null then
			str := tmpStr;
		else 
			str := tmpStr &amp; CrLf &amp; str;
		endif;
		
	endforeach;
	return str;

epilog
	delete strArray;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAllSeals" id="37d47e30-5f05-44e7-aa67-142b09815a65">
        <source>getAllSeals() : String;
// ---------------------------------------------------------------------------
// Created:     26 August 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tmpStr : String;
begin
	//15 Sep 2010	NDL	Par 25608 - change from direct ref to using method 'getSealNum'
	if self.getSealNum &lt;&gt; null then
		tmpStr :=  self.getSealNum;
	endif;
	//15 Sep 2010	NDL	Par 25608 - change to using method 'getSealNumCustoms' or 'getSealNumCustomsFirst'
	if  self.getSealNumCustomsFirst &lt;&gt; null then
		if tmpStr &lt;&gt; null then
			tmpStr := tmpStr &amp; ", ";
		endif;
		tmpStr := tmpStr &amp;  self.getSealNumCustomsFirst;
	endif;
	//15 Sep 2010	NDL	Par 25608 - change from direct ref to using method 'getSealNumShipper'
	if  self.getSealNumShipper &lt;&gt; null then
		if tmpStr &lt;&gt; null then
			tmpStr := tmpStr &amp; ", ";
		endif;
		tmpStr := tmpStr &amp;  self.getSealNumShipper;
	endif;
	return tmpStr;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
