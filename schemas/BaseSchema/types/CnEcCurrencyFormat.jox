    <JadeMethod name="getCurrencyFormat" id="df63daf0-996f-4243-baec-4ad5053ea7b2">
        <source>getCurrencyFormat(pCurrencyFormatObj:CurrencyFormat io);
// -----------------------------------------------------------------------------
// Created:		24 December 2001 by cnwdad1
//
// Purpose:		Copies the property values from the receiver to the specified
//				CurrencyFormat.
//
// Parameters:	pCurrencyFormatObj - The CurrencyFormat to update.
//
// Returns:		The CurrencyFormat as an IO parameter.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	// Get the number format properties.
	
	pCurrencyFormatObj.decimalPlaces			:=	self.decimalPlaces;
	pCurrencyFormatObj.decimalSeparator			:=	self.decimalSeparator;
	pCurrencyFormatObj.groupings				:=	self.groupings;
	pCurrencyFormatObj.negativeFormat			:=	self.negativeFormat;
	pCurrencyFormatObj.negativeSign				:=	self.negativeSign;
	pCurrencyFormatObj.positiveSign				:=	self.positiveSign;
	pCurrencyFormatObj.showLeadingZeros			:=	self.showLeadingZeros;
	pCurrencyFormatObj.thousandSeparator		:=	self.thousandSeparator;
	
	// Get the currency format properties.
	
	pCurrencyFormatObj.intlCurrencySymbol		:=	self.intlCurrencySymbol;
	pCurrencyFormatObj.intlDecimalPlaces		:=	self.intlDecimalPlaces;
	pCurrencyFormatObj.negSymbolPrecedesAmount	:=	self.negSymbolPrecedesAmount;
	pCurrencyFormatObj.negSymbolSeparated		:=	self.negSymbolSeparated;
	pCurrencyFormatObj.negativeSignPosition		:=	self.negativeSignPosition;
	pCurrencyFormatObj.posSymbolPrecedesAmount	:=	self.posSymbolPrecedesAmount;
	pCurrencyFormatObj.posSymbolSeparated		:=	self.posSymbolSeparated;
	pCurrencyFormatObj.positiveFormat			:=	self.positiveFormat;
	pCurrencyFormatObj.symbol					:=	self.symbol;
end;</source>
        <Parameter name="pCurrencyFormatObj" type="CurrencyFormat" usage="io"/>
    </JadeMethod>
    <JadeMethod name="updateMe" id="27e31401-e0ff-409f-ad19-5865c823b605">
        <updating/>
        <source>updateMe(pCurrencyFormatObj: CurrencyFormat) updating;
// -----------------------------------------------------------------------------
// Created:		24 December 2001 by cnwdad1
//
// Purpose:		Copies the property values from the specified CurrencyFormat to
//				the receiver.
//
// Parameters:	pCurrencyFormatObj - The CurrencyFormat, who's property values to
//					copy.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	inheritMethod(pCurrencyFormatObj);
	
	self.intlCurrencySymbol			:=	pCurrencyFormatObj.intlCurrencySymbol;
	self.intlDecimalPlaces			:=	pCurrencyFormatObj.intlDecimalPlaces;
	self.negSymbolPrecedesAmount	:=	pCurrencyFormatObj.negSymbolPrecedesAmount;
	self.negSymbolSeparated			:=	pCurrencyFormatObj.negSymbolSeparated;
	self.negativeSignPosition		:=	pCurrencyFormatObj.negativeSignPosition;
	self.posSymbolPrecedesAmount	:=	pCurrencyFormatObj.posSymbolPrecedesAmount;
	self.posSymbolSeparated			:=	pCurrencyFormatObj.posSymbolSeparated;
	self.positiveFormat				:=	pCurrencyFormatObj.positiveFormat;
	self.symbol						:=	pCurrencyFormatObj.symbol;
end;</source>
        <Parameter name="pCurrencyFormatObj" type="CurrencyFormat"/>
    </JadeMethod>
</Class>
