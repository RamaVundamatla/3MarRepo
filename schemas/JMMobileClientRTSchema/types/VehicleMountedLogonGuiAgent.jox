    <JadeMethod name="doLogon" id="edb87dab-b947-423c-a1fa-3c50520ac822">
        <source>doLogon(_userName: String; _password: String; _errorStr: String output);
/*

Purpose:			


Return Value:		


Date		Who		Reason
25 October 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	agentClass : Class;
begin
	inheritMethod(_userName, _password,  _errorStr);

	if _errorStr &lt;&gt; null then
		return;
	endif;
	self.setClientConnectionDetails(myVehicleMountedLogonAgent.myRTDevice.id,myVehicleMountedLogonAgent.myTerminal.code,_userName);
	app.createVehicleMountedGUIAgent();

epilog

end;</source>
        <Parameter name="_userName" type="String"/>
        <Parameter name="_password" type="String"/>
        <Parameter name="_errorStr" type="String" usage="output"/>
    </JadeMethod>
