    <JadeMethod name="xPAR31367StatusBarStepA2" id="c75bca6b-903e-4308-8d9e-f66b5f28328e">
        <updating/>
        <source>xPAR31367StatusBarStepA2() updating;

/*

Purpose:		Colour code and check that the status bar is correct

Date			Who		Reason
10/03/2013		cnwmh5	Initial creation

*/
vars

	theSlot								: CM_LocationsController;
	voyageJob							: CM_VoyageJob;
	
	strs								: StringArray;
	dischargeLocn						: StringArray;
