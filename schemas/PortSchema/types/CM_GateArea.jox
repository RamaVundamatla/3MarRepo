    <JadeMethod name="ccms1061_setFromVTA" id="514288e7-fe24-4846-88e7-0b24fc6cf75e">
        <updating/>
        <source>ccms1061_setFromVTA(_vta :CM_VehicleTransferArea input)updating;
// ---------------------------------------------------------------------------
// Created:     18 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 19/10/2009	cnwcs5		par 21404 - update locationId on tracked items at pre-gate LC
// ---------------------------------------------------------------------------
vars
	lc		:CM_BlockController;
	glc		:CM_GateLaneController;
	lane	:CM_LaneController;
	array	:CM_ObjectArray;
	obj		:Object;
	ld		:CM_LaneDevice;
	boom	:CM_Boom;
	vm		:CM_VehicleMachine;
	count	:Integer;
	ti		:CM_TrackedItem;
	move	:CM_FutureMove;
begin
	if _vta.isDualGate and self.areaType = CM_GateArea.AreaType_P then
		delete self.myInTransitToLocation;	// created in setForCreate
		
		// vta pre-gate lc means - in transit to the p-gate for dual gate
		lc := _vta.allPreGateControllers.first.CM_BlockController;
		
		lc.setMyPreGateVTA (null);
		lc.setMyPostGateVTA (null);
		lc.setPropertyValue (CM_LocationsController::myTerminalArea.name, self);
		
		self.myInTransitToLocation := lc;
		// need to do this after setting the above reference
		lc.setPropertyValue (CM_LocationsController::ident.name, lc.getID);
		
// *** par 21404 - start
		// any cargo at this location will need to have its location ids updated
		// the gate area id is different from the ic area id
		foreach ti in lc.allTrackedItems do				// par 21404
			if ti.myPrimaryActualLocation = lc then		// par 21404
				ti.setLocationId (lc.getFullId);		// par 21404
			endif;
		endforeach;										// par 21404
		
		foreach move in lc.allPlannedFutureMoves do
			if not move.isKindOf (CM_FutureMovePlanned) then
				continue;
			endif;
			
			ti := move.CM_FutureMovePlanned.myTrackedItem;
			
			if ti.myPrimaryPlannedLocation = lc then
				// update CM_TrackedItem::plannedLocnId
				ti.setPlannedLocnId (lc.getFullId);
			endif;
		endforeach;	
// *** par 21404 - end

		// now move devices from old gate lanes over to the new p-gate lanes
		create array transient;
		_vta.allGateLaneControllers.copy (array);	// can't update array during iteration
		
		foreach obj in array do
			glc := obj.CM_GateLaneController;
			
			count 	:= count + 1;
			lane 	:= self.getLaneByNumber (count);
			
			//detach from the vta
			glc.setMyPreGateVTA (null);
			glc.setMyPostGateVTA (null);
			glc.setMyLaneVTA (null);
						
			/// set properties for in/out/closed
			lane.setLaneDirection (glc.laneDirection);
			lane.setVehicleDirection (glc.vehicleDirection);
			lane.setIsUnavailable (glc.isUnavailable);
			
			// create boom
			if glc.boomMachineName &lt;&gt; null or glc.boomPortNo &lt;&gt; null then 
					
				create ld as CM_LDBoom;
				create boom;
				// we need a unique value for the code
				boom.setPropertyValue (CM_Boom::code.name, self.id &amp; count.String [1:10]);
				boom.setPropertyValue (CM_Boom::description.name, boom.code);
				boom.setPropertyValue (CM_Boom::portNumber.name, glc.boomPortNo);
				boom.setPropertyValue (CM_Boom::ipAddress.name, glc.boomMachineName);
				boom.setPropertyValue (CM_Boom::myTerminal.name, glc.myTerminal);
				ld.setPropertyValue (CM_LDBoom::myBoom.name, boom);
				ld.setPropertyValue (CM_LaneDevice::type.name, CM_LaneDevice.Type_BoomIn);
				ld.setPropertyValue (CM_LaneDevice::myLaneController.name, lane);
			endif;
			// create printer association
			if glc.myPrinter &lt;&gt; null then
				create ld as CM_LDPrinterDef;
				ld.setPropertyValue (CM_LDPrinterDef::myPrinter.name, glc.myPrinter);
				ld.setPropertyValue (CM_LaneDevice::myLaneController.name, lane);				
			endif;
			// create rfid tag reader association
			if glc.myRFIDTagReader &lt;&gt; null then
				create ld as CM_LDRFIDTagReader;
				ld.setPropertyValue (CM_LDRFIDTagReader::myRFIDTagReader.name, glc.myRFIDTagReader);
				glc.myRFIDTagReader.setPropertyValue (CM_RFIDTagReader::context.name, TagReaderContext_LaneDevice); 
				ld.setPropertyValue (CM_LaneDevice::type.name, CM_LaneDevice.Type_RFIDTagReaderRead);
				ld.setPropertyValue (CM_LaneDevice::myLaneController.name, lane);				
			endif;
			
			// move over any vehicles
			foreach vm in glc.allVehicleMachines do
				vm.setMyPrimaryActualLocation (lane,false);
			endforeach;
			
			// now move any TIs from the gate lane controller
			_vta.ccms1061_conversion_moveTIs (glc, lane); // par 21404		
			
			delete glc;	// don't need it any more
		endforeach;		
	endif;
epilog
	delete array;
end;</source>
        <Parameter name="_vta" type="CM_VehicleTransferArea" usage="input"/>
    </JadeMethod>
    <JadeMethod name="ccms1061_setProxy" id="7f460694-7751-4fe0-9d3f-6eca6ff8eb92">
        <updating/>
        <source>ccms1061_setProxy(_vta :CM_VehicleTransferArea input; _areaType :Integer;_in, _out :Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     16 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//	
// ---------------------------------------------------------------------------
vars
	id, suffix	:String;
	lanes		:Integer;
begin
	self.raiseExceptionIfNotTransient(method);
	
	id := _vta.id[2:end];	// expect 1st character to be '~'
	
	if _areaType = CM_GateArea.AreaType_A then
		suffix := '_A';
		
		// add default lanes
		self.pxyCreateNewLane (true);
		self.pxyCreateNewLane (false);
	else
		suffix  := '_P';
		lanes 	:= _vta.numGateLanes; 
		
		self.pxyUpdateLaneCount (lanes);	// will create lanes
	endif;
	
	if id.length &lt; (CM_TerminalAreaMaster::id.length - 1) then
		id := id &amp; suffix;
	else
		id := id [1:CM_TerminalAreaMaster::id.length - 2] &amp; suffix;
	endif;
	
	self.setProxy (id, _vta.comment, _vta.myTerminal, _areaType, _in, _out, lanes); 
epilog

end;</source>
        <Parameter name="_vta" type="CM_VehicleTransferArea" usage="input"/>
        <Parameter name="_areaType" type="Integer"/>
        <Parameter name="_in" type="Boolean"/>
        <Parameter name="_out" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="erase" id="1bdeec96-8e43-48c6-9292-6463cadcf5a6">
        <updating/>
        <source>erase(_level: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     10 August 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	subQueue	:CM_RadioTelemetryQueue;
begin
	if self.hasUsages then
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Gate area has usages - cannot be deleted');
	endif;

	foreach subQueue in self.allSubQueues do
			subQueue.erase(NORMAL_ERASE);
	endforeach;
	
	inheritMethod(_level);
epilog

end;</source>
        <Parameter name="_level" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="findLocation" id="1721ae47-4c3c-484a-bff0-377f5033c0cb">
        <source>findLocation(_strs: StringArray; _noException: Boolean; _foundLC: CM_LocationsController io; _foundHeight: Integer io);
// ---------------------------------------------------------------------------
// Created:     01 March 2010 by cnwcs5
// Purpose:     par 22580
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	lane	: String;
begin
	_foundLC := null;
	_foundHeight := NULLINDEX;

	if not _strs.isEmpty() then
		lane := _strs[1].trimBlanks();
	endif;
	
	if lane = null then
		if self.laneCount = 0 then
			_foundLC := self.getDefaultLane_IN;
			return;
		endif;
		return;
	endif;
	
	if lane.isInteger() then
		_foundLC := self.getLaneByNumber(lane.Integer);
	endif;
epilog

end;</source>
        <Parameter name="_strs" type="StringArray"/>
        <Parameter name="_noException" type="Boolean"/>
        <Parameter name="_foundLC" type="CM_LocationsController" usage="io"/>
        <Parameter name="_foundHeight" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="7b195a8d-16dc-4b27-b494-84e5b707ec41">
        <source>getAuditText(): String;
// ---------------------------------------------------------------------------
// Created:     15 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	txt, tmpStr	: String;
	row			: CM_GridRow;
	lane		: CM_LaneController;
	
begin
	//txt := inheritMethod();
	
	tmpStr := "GateArea " &amp; self.id &amp; " ";
	
	txt := txt &amp; tmpStr &amp; self.formatAuditText(CM_GateArea::comment.name, self.comment);
	txt := txt &amp; tmpStr &amp; self.formatAuditText(CM_GateArea::laneCount.name, self.laneCount.asStringJMT);
	
	foreach row in self.allGridRows do
		lane 	:= row.allControllersByColumn.first.CM_LaneController;
		
		if lane = null then
			continue;	// get around bug in development
		endif;
		txt 	:= txt &amp; lane.getAuditText();
	endforeach;

	return txt;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAuditTextForGate" id="5ef807ef-e993-4e1e-85bc-759d97a71f15">
        <source>getAuditTextForGate(_cnt : Integer): String;

/*
Date			Who		Reason
17 August 2009	cnwar2	Initial creation

*/
vars
	txt, tmpStr : String;
	row			: CM_GridRow;
	lane		: CM_LaneController;
	laneCnt		: Integer;
	ld			: CM_LaneDevice;
	
begin
	tmpStr 	:= self.getTypeAsString;	// A, P, T etc.
	if self.isInGate then
		if self.isOutGate then
			tmpStr := tmpStr &amp; '(IN-OUT) ';
		else
			tmpStr := tmpStr &amp; '(IN) ';
		endif;
	elseif self.isOutGate then
		tmpStr := tmpStr &amp; '(OUT) ';
	endif;
	tmpStr := tmpStr &amp; self.id;
	
	txt := 'GateArea ' &amp; _cnt.String &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	txt := txt &amp; 'GateArea ' &amp; _cnt.String &amp; ' comment' &amp; AuditStringSeparator &amp; self.comment.length.String &amp; AuditStringSeparator &amp; self.comment &amp; AuditStringSeparator;
	txt := txt &amp; 'GateArea ' &amp; _cnt.String &amp; ' laneCount' &amp; AuditStringSeparator &amp; self.laneCount.String.length.String &amp; AuditStringSeparator &amp; self.laneCount.String &amp; AuditStringSeparator;

	foreach row in self.allGridRows do
		lane 	:= row.allControllersByColumn.first.CM_LaneController;
		laneCnt	:= laneCnt + 1;
		
		if lane.isIn then
			if lane.isOut then
				tmpStr := 'IN-OUT';
			else
				tmpStr := 'IN';
			endif;
		elseif lane.isOut then
			tmpStr := 'OUT';
		endif;
		if lane.isUnavailable then
			tmpStr := tmpStr &amp; '-CLOSED';
		endif;
		txt := txt &amp; 'GateArea ' &amp; _cnt.String &amp; ' Lane ' &amp; laneCnt.String &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
		
		/*foreach ld in lane.allLaneDevices do
			txt := txt &amp; 'GateArea ' &amp; cnt.String &amp; ' Lane ' &amp; laneCnt.String;
			if ld.isBoom then
				tmpStr := ld.CM_LDBoom.myBoom.code;
				txt := txt &amp; ' Boom' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
			elseif ld.isKiosk then
				tmpStr := ld.CM_LDKiosk.myKiosk.code;
				txt := txt &amp; ' Kiosk' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
			elseif ld.isPrinter then
				tmpStr := ld.CM_LDPrinterDef.myPrinter.logicalPrinterName;
				txt := txt &amp; ' Printer' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
			elseif ld.isRFIDTagReader then
				tmpStr := ld.CM_LDPrinterDef.myPrinter.logicalPrinterName;
		endforeach;	*/
	endforeach;
	
	return txt;
end;</source>
        <Parameter name="_cnt" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
