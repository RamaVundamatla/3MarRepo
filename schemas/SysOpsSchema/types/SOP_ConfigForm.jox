    <JadeMethod name="getSsoProviderListIndex" id="460d4de2-95a8-4f02-a089-2b61efb47c26">
        <source>getSsoProviderListIndex(_itemData : Integer) : Integer protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 July 2022 navam1 ChangeRequest 52824: EUP - Azure Active Directory Single Sign On - MTN
25 Aug  2025 navec1	MTN-35151: Single Sign On via Okta for MTN Thin Client
*/

vars

begin
	if _itemData = null or _itemData = app.mySSOAgent.SSO_Provider_Default  then
		return 1;
	elseif _itemData = app.mySSOAgent.SSO_Provider_Microsoft then
		return 2;
	elseif _itemData = app.mySSOAgent.SSO_Provider_Okta then  // MTN-35151 - navec1 - Okta SSO
		return 3;
	else
		return -1;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_itemData" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getSsoProviderListItem" id="e303df9d-3642-48a1-8e93-e962f33a0e73">
        <source>getSsoProviderListItem(_itemData : Integer) : String protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 July 2022 navam1 ChangeRequest 52824: EUP - Azure Active Directory Single Sign On - MTN
25 Aug  2025 navec1	MTN-35151: Single Sign On via Okta for MTN Thin Client
*/

vars

begin
	if _itemData = null or _itemData = app.mySSOAgent.SSO_Provider_Default  then
		return app.mySSOAgent.SSO_Provider_DefaultDescr;
	elseif _itemData = app.mySSOAgent.SSO_Provider_Microsoft then
		return app.mySSOAgent.SSO_Provider_MicrosoftDescr;
	elseif _itemData = app.mySSOAgent.SSO_Provider_Okta then  // MTN-35151 - navec1 - Okta SSO
		return app.mySSOAgent.SSO_Provider_OktaDescr;
	else
		return app.mySSOAgent.SSO_Provider_DefaultDescr;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_itemData" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initEmailLicenseTypeCombo" id="370e57f3-9d87-4336-9ef6-3425bbfce427">
