<Class name="CM_QDefInvoiceLine" id="86b02ae1-1c32-43f9-ad06-a202ef0ebfff">
    <superclass name="CM_QueryDefinition"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <PrimAttribute name="useStaticInvoiceValues" id="77e0ac83-fcac-4c1d-bb1e-0838cda38224">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="create" id="30975612-ec94-4ae8-8692-0dc79d6a8d42">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2014	cnwndl1	Initial creation	CCMS QNS 2348

*/

vars

begin

	self.className := CM_InvoiceLine.name;
	
	//12/06/2024	navkc1 CR 64563 Task 64599
	if app.myRoot &lt;&gt; null and app.myRoot.isClientEuroPorts() then
		self.useStaticInvoiceValues := true;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="createProperties" id="542d1608-d26d-434e-973d-ca1b6befe4f6">
        <source>createProperties();
/*

Purpose:			

Parameters:			

Return Value:		

/****Changes

Date		Name	TFS#			Description
==========================================================================
14 May 2014	cnwndl1	CCMS QNS 2348	Initial creation	
16/06/2014	cnwjre1	34364 			Rename some of the attributes
09/09/2015	cnwdap1	PAR #36388 		Add Charge Date attribute
11/10/2017  cnwma1  TFS #7139 JMT - Adding Invoice End Date to Selector Query
28/09/2018	jlgka1	40200			Add CM_QStrResourceMethod for
									Harbour Resource Use List.
06/06/2019	jlgdap1	TFS 44554		AAT Stevedore Data Access
24/08/2022	navkc1	CR #54570		EUP - Inv Config - Selector Query - Include Service Type
13/12/2022  navmv20 Defect 55746: MTN - New tax fields not in selectors or summaries as per BRD
08/02/2023	navvt20 TFS 56132 Task 56137: Jade - Invoice Line Selector - UOM
27/02/2023	navmk20	Bug 56090: EUP - Remedial 54831 - Invoice Line Mode Selector Query
24/04/2023	navkc1	CR 55654 Task 55670: Jade - Contract reporting
//----------------------------------------------------------------------*/

vars
	tmpProp		: CM_QueryProperty;
begin

	//terminal  
	create tmpProp as CM_QRefTerminalMethod persistent;
	tmpProp.set('Terminal', CM_InvoiceLine::getTerminal.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.CollKey );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	//business unit
	create tmpProp as CM_QRefBankProperty persistent;
	tmpProp.set('Business Unit', CM_InvoiceLine::bank.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.CollKey );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	//invoice status
	create tmpProp as CM_QInvoiceStatusLookupMethod persistent;
	tmpProp.set('Invoice Status', CM_InvoiceLine::getInvoiceStatus.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	//line status
	create tmpProp as CM_QInvLineStatusLookupMethod persistent;
	tmpProp.set('Invoice Line Status', CM_InvoiceLine::getStatus.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	//cargo site
