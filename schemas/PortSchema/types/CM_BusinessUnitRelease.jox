    <JadeMethod name="getChargeableBusinessUnit" id="55758ca8-b6fe-453b-a775-2fe441b931f4">
        <source>getChargeableBusinessUnit() : CM_Bank;

vars
	term				: CM_Terminal;
	termDict			: CM_TerminalByCodeDict;
	bank				: CM_Bank;	
begin
	termDict := app.myRoot.allTerminals;
	foreach term in termDict do
		bank := term.companies[receivingCompanyCode];
		if bank &lt;&gt; null then
			break;
		endif;
	endforeach;
	
	return bank;

end;</source>
        <ReturnType type="CM_Bank"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="b40dadcd-e32f-44f3-8c21-9fb7e521a01b">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 June 2010	cnwndl1	Initial creation	Par 23498

*/

vars
	lDetail : String;
begin

	if _attrName = ETRow_Details  then
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
		else
			lDetail := "Receiving Business Unit: " &amp; self.receivingCompanyCode.trimBlanks;

			if lDetail &lt;&gt; "" then
				lDetail := lDetail &amp; " " &amp; self.urNumber.String;
			else
				lDetail := self.urNumber.String;
			endif;			
			
			return lDetail;
			
		endif;
	
	elseif _attrName = ETRow_ReceiveBusinessUnit then
		return receivingCompanyCode;
	
	else
		return inheritMethod(_attrName, _short);
	
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEnquiryRow" id="06a8e322-fe48-4711-b662-826a51ca3200">
        <source>getEnquiryRow(): String;
// ---------------------------------------------------------------------------
// Created:  May  2001 By Andrew Bishop cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lDetail : String;
begin
	lDetail := inheritMethod();
	lDetail := lDetail &amp; "Receiving Business Unit: " &amp; self.receivingCompanyCode.trimBlanks;

	if lDetail &lt;&gt; "" then
		lDetail := lDetail &amp; " " &amp; self.urNumber.String;
	else
		lDetail := self.urNumber.String;
	endif;			
	
	return lDetail;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
