    <JadeMethod name="createTerminalArea" id="a239484f-8bf1-41be-9245-7c103c7e88f1">
        <updating/>
        <source>createTerminalArea() updating;
/*
----------   ----------  --------------------------------------------------
Created:	28 July 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if self.labelLengthRow = 0 then
		self.labelLengthRow := self.numRows.String.length;
	endif;
	
	if self.labelLengthCol = 0 then
		self.labelLengthCol := self.numColumns.String.length;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="hasGridAreaIncreased" id="85e142bc-6ea1-4ad3-90f4-4dca96cc927f">
        <source>hasGridAreaIncreased() : Boolean;
// ---------------------------------------------------------------------------
// Created:     03 July 2008 by cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if not self.myTerminalArea.isGridArea() then
		return false;
	endif;
	
	if self.myTerminalArea.CM_GridArea.allGridRows.size &lt; self.myPxyTerminalArea.CM_GridArea.allGridRows.size then
		return true;
	endif;
	
	if self.myTerminalArea.CM_GridArea.allGridColumns.size &lt; self.myPxyTerminalArea.CM_GridArea.allGridColumns.size then
		return true;
	endif;
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="myPxyTerminalArea" id="f0e1a36e-89fc-41e6-85bd-9948ebe5a650">
        <methodInvocation>mapping</methodInvocation>
        <source>myPxyTerminalArea(set : Boolean; _value : CM_TerminalArea io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 August 2009	cnwer1	Initial creation

*/

vars

begin
	if not set then
		if self.myPxyTerminalArea &lt;&gt; null then
			_value:= self.myPxyTerminalArea;
			return;
		endif;
		if self.myPxyTerminalAreaMaster &lt;&gt; null and self.myPxyTerminalAreaMaster.isKindOf(CM_TerminalArea) then
			_value:= self.myPxyTerminalAreaMaster.CM_TerminalArea;
			return;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_TerminalArea" usage="io"/>
    </JadeMethod>
    <JadeMethod name="myTerminalArea" id="4ca3143d-c9c1-4908-8eef-6eb0f04cb995">
        <methodInvocation>mapping</methodInvocation>
        <source>myTerminalArea(set : Boolean; _value : CM_TerminalArea io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 August 2009	cnwer1	Initial creation

*/

vars

begin
	if not set then
		if self.myTerminalArea &lt;&gt; null then
			_value:= self.myTerminalArea;
			return;
		endif;
		if self.myTerminalAreaMaster &lt;&gt; null and self.myTerminalAreaMaster.isKindOf(CM_TerminalArea) then
			_value:= self.myTerminalAreaMaster.CM_TerminalArea;
			return;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_TerminalArea" usage="io"/>
    </JadeMethod>
    <JadeMethod name="validate" id="87314fdc-e523-4d3b-b445-62efb015327c">
        <source>validate(_errStr: String io);
/*
----------   ----------  --------------------------------------------------
Created:	28 July 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if self.myTerminal = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'null terminal');
		return;
	endif;
	
	if self.myPxyTerminalArea = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'null proxy Terminal Area');
		return;
	endif;

end;</source>
        <Parameter name="_errStr" type="String" usage="io"/>
    </JadeMethod>
</Class>
