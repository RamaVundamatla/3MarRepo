    <JadeMethod name="resetData_51979" id="ba2ae042-7b05-4776-a15f-a0b6725cf175">
        <source>resetData_51979();
/*

Purpose:	Reset 53848

Date		Who		Reason
29/07/2022	navmh5	Initial creation

*/

constants

	USER_DEF_NAME : String = "JMTInternalCargoOnSite";

vars
	
	terminal					: CM_Terminal;
	passportTerm 				: CM_Terminal;
	ti							: CM_TrackedItem;
	ediFileObj 					: CM_EDIFile;
	ediDataObj 					: CM_EDIData;
	passportObj					: CM_Passport;
	lc							: CM_GapController;
	obj							: Object;
	reeferJob 					: CM_YardActivity;	
	interchangeArea				: CM_TerminalArea;
	reeferBlock					: CM_ReeferBlock;
	
	
	tiSet						: CM_TISet;
	tiConnectArray				: ObjectArray;
	tiMonitorArray				: ObjectArray;
	tiDisconnectArray			: ObjectArray;
	tiAlarmArray				: ObjectArray;
	lcConnectArray				: ObjectArray;
	connectedArray				: ObjectArray;
	trackedItems				: CM_TIArray;
	taStringArray				: StringArray;
	
	taArray						: ObjectArray;
	
	count						: Integer;
	errorMsg 					: String;
	ediText						: String;
	now							: TimeStamp;
	str							: String;
	
begin
	
	app.initialize();
	 
	 terminal := app.myRoot.allTerminals["RAP1"];
	 if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	passportTerm := app.myPassport.myTerminal;
	app.myPassport.setMyTerminal(terminal);
	
	// Delete Terminal Areas
	/*
	write "Deleting Terminal Areas......";
	app.writeLog("Deleting Temrinal Areas......", LogINFO);
	deleteTerminalAreas_ReeferApp_54899();
	
	interchangeArea := self.getTerminalArea("ICA");
	self.assertNotNull(interchangeArea);
	
	create taArray transient;
	
	write "Creating Terminal Area - RA1 (GBS)......";
	app.writeLog("Creating Terminal Area - RA1 (GBS)......", LogINFO);
	obj := self.addForkLiftStack("RA1", 8, 8, 8);
	self.assertNotNull(obj);
	taArray.add(obj);
	
	write "Creating Terminal Area - RA2 (GBS)......";
	app.writeLog("Creating Terminal Area - RA2 (GBS)......", LogINFO);
	obj := self.addForkLiftStack("RA2", 8, 8, 8);
	self.assertNotNull(obj);
	taArray.add(obj);
	
	write "Creating Terminal Area - RA3 (GBS)......";
	app.writeLog("Creating Terminal Area - RA3 (GBS)......", LogINFO);
	obj := self.addForkLiftStack("RA3", 8, 8, 8);
	self.assertNotNull(obj);
	taArray.add(obj);
	
	write "Creating Terminal Area - RA4 (BS)......";
	app.writeLog("Creating Terminal Area - RA4 (BS)......", LogINFO);
	obj := self.addBlockStack("RA4", 9999, interchangeArea);
	self.assertNotNull(obj);
	taArray.add(obj);
	
	write "Creating Terminal Area - RA5 (BS)......";
	app.writeLog("Creating Terminal Area - RA5 (BS)......", LogINFO);
	obj := self.addBlockStack("RA5", 9999, interchangeArea);
	self.assertNotNull(obj);
	taArray.add(obj);
	*/
	
	// Delete Walk Paths
	write "Deleting all Walk Paths......";
	app.writeLog("Deleting all walk paths......", LogINFO);
	create taArray transient;
	create taStringArray transient;
	taStringArray.add("RA1");
	taStringArray.add("RA2");
	taStringArray.add("RA3");
	taStringArray.add("RA4");
	taStringArray.add("RA5");
	
	foreach str in taStringArray do
		obj := self.getTerminalArea(str);
		if obj &lt;&gt; null then
			taArray.add(obj);
		else
			write "Unable to find terminal (" &amp; str &amp; ")......";
			app.writeLog("Unable to find terminal (" &amp; str &amp; ")......", LogINFO);
		endif;
		
	endforeach;
	
	
	foreach count in 1 to 3 do
		foreach reeferBlock in taArray[count].CM_ForkLiftStack.allReeferBlocks do
			if reeferBlock.name = "RA1" or reeferBlock.name = "RA2" or reeferBlock.name = "RA3" then
				app.myTrxDA.trxDeleteReeferBlock( reeferBlock, app.myPassport );	
			endif;
		endforeach;
	endforeach;
	
	
	// Create walk paths
	createWalkPath_54899(taArray[1].CM_ForkLiftStack, "W1");	// has jobs with a mixture on connect / disconnect / monitor / alarm
	createWalkPath_54899(taArray[1].CM_ForkLiftStack, "W2");	// no Jobs but connected / disconnected reefers
	createWalkPath_54899(taArray[1].CM_ForkLiftStack, "W3");	// has jobs with a mixture on connect / disconnect / monitor /
	createWalkPath_54899(taArray[3].CM_ForkLiftStack, "W10");	// has jobs with a mixture on connect / disconnect / monitor / alarm
	
		
	// load the data
	write "Creating Tracked Items......";
	app.writeLog("Creating Tracked Items......", LogINFO);
	passportObj	:=	app.myPassport;
	ediText := dataSetup_51979();
	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME &amp; method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS, errorMsg);
	ediDataObj := ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	
	create tiConnectArray transient;
	create tiMonitorArray transient;
	create tiDisconnectArray transient;
	create tiAlarmArray transient;
	
	
	// Alarm Reefers
	ti := self.getTrackedItem("RAPP0000027");
	self.assertNotNull(ti);
	tiAlarmArray.add(ti);
	ti := self.getTrackedItem("RAPP0000028");
	self.assertNotNull(ti);
	tiAlarmArray.add(ti);
	ti := self.getTrackedItem("RAPP0000029");
	self.assertNotNull(ti);
	tiAlarmArray.add(ti);
	
	// Connect reefers
	write "Getting Reefers for Connect Job(s)......";
	app.writeLog("Getting Reefers for Connect Job(s)......", LogINFO);
	create trackedItems transient;
	taArray[1].CM_ForkLiftStack.getTIs(trackedItems, null);
	taArray[2].CM_ForkLiftStack.getTIs(trackedItems, null);
	taArray[3].CM_ForkLiftStack.getTIs(trackedItems, null);
	//taArray[5].CM_BlockStack.getTIs(trackedItems, null);
	
	foreach ti in trackedItems do
		
		if ti.id[5:end].Integer mod 3 = 0 then
			write 'id (Connect - GBS): ' &amp; ti.id &amp; Tab &amp; ti.locationId;
			tiConnectArray.add(ti);
			tiMonitorArray.add(ti);
		endif;
	
	endforeach;
	
	trackedItems.clear();
	taArray[5].CM_BlockStack.getTIs(trackedItems, null);
	
	foreach ti in trackedItems do
		
		if ti.id[5:end].Integer mod 3 = 0 then
			write 'id (Connect - BS): ' &amp; ti.id &amp; Tab &amp; ti.locationId;
			tiConnectArray.add(ti);
			tiMonitorArray.add(ti);
		endif;
	
	endforeach;
	
	
	
	
	// Connect reefers
	/*write "Connecting Reefers......";
	app.writeLog("Connecting Reefers......", LogINFO);
	
	
	
	foreach count in 1 to 16 do
		
		str := "S";
		if count &gt;= 15 then
			str := "O";
		endif;
				
		ti := self.getTrackedItem("PNL" &amp; str &amp; "00000" &amp; count.String.padLeadingZeros(2));
		if ti = null then
			continue;
		endif;
		
		tiMonitorArray.add(ti);
	
		if count = 15 then
			lc := ti.getMyGapPower();
			self.updateTIConnection(ti, true, true, app.actualTimeAppServer, lc);
			tiDisconnectArray.add(ti);
	    elseif count &lt; 5 or count &gt; 8 then
			lc := ti.getMyGapPower();
			self.updateTIConnection(ti, true, true, app.actualTimeAppServer, lc);
		else	
			tiConnectArray.add(ti);
		endif;
	endforeach;
	*/
	
	// Create connect walk path jobs
	write "Creating Connect Jobs......";
	app.writeLog("Creating Connect Jobs......", LogINFO);
	now := now.addHours(-3);
	foreach obj in tiConnectArray do
		reeferJob := self.addReeferJob( obj.CM_TrackedItem, CM_YardActivity.ReeferConnect, now );
	endforeach;
	
	// Create monitor walk path jobs
	write "Creating Monitor Jobs......";
	app.writeLog("Creating Monitor Jobs......", LogINFO);
	foreach obj in tiMonitorArray do
		reeferJob := self.addReeferJob( obj.CM_TrackedItem, CM_YardActivity.ReeferMonitor, now );
	endforeach;
	
	// Create disconnect walk path jobs
	write "Creating Disconnect Jobs......";
	app.writeLog("Creating Disconnect Jobs......", LogINFO);
	foreach obj in tiDisconnectArray do
		reeferJob := self.addReeferJob( obj.CM_TrackedItem, CM_YardActivity.ReeferDisconnect, now );
	endforeach;
	
	// Create alarm walk path jobs
	write "Creating Alarm Jobs......";
	app.writeLog("Creating Alarm Jobs......", LogINFO);
	foreach obj in tiAlarmArray do
		reeferJob := self.addReeferJob( obj.CM_TrackedItem, CM_YardActivity.ReeferAlarm, now );
	endforeach;
	
	
	
epilog

	app.myPassport.setMyTerminal(passportTerm);
	
	delete taArray;
	
	
	delete tiSet;
	delete tiConnectArray;
	delete tiMonitorArray;
	delete tiDisconnectArray;
	delete tiAlarmArray;
	delete taStringArray;
	
	delete trackedItems;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="resetData_52613" id="1c8861e5-4439-492c-a02b-88c45266663b">
        <source>resetData_52613();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08/08/2022	navmk3	Initial creation

*/
constants
	ReleaseNumber			= "RELROAD52613A01";
vars
	terminal, passportTerm			: CM_Terminal;
	release, pxyBulkRelease			: CM_BulkRelease;
	vvr, pxyVVR 					: CM_VehicleVisitRecord;
	pxyGateEntity, gateEntity		: CMGTE_Entity;
	controller						: CMIF_FlexiGateController;
	subTerm							: CM_SubTerminal;
	reserveDetail					: CM_ReserveDetail;
begin
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	/*****************************************************
	 * Terminal - TT1
	 *****************************************************/
	 
	 terminal := app.myRoot.allTerminals["TT1"];
	 if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	passportTerm := app.myPassport.myTerminal;
	app.myPassport.setMyTerminal(terminal);
	
	self.deleteReleaseRequest(ReleaseNumber);
	// add release requests
	self.opts.addAssoc("Number", 2);
	self.opts.addAssoc("ISOType", "2200");
	self.opts.addAssoc("Voyage", self.getVoyage("MSCK000010").CM_Voyage);
	self.opts.addAssoc("Operator", app.myRoot.allOperators["MSL"].CM_Operator);
	self.opts.addAssoc("FullRelease", true);
	self.opts.addAssoc("Carrier", self.getCarrier("AAUTO"));
	
	release := self.addReleaseByTypeRequestOpts(ReleaseNumber, 1, 1);

	// add Bag of Sand request line
	pxyBulkRelease	:=	app.createUpdateProxy(release).CM_BulkRelease;
	self.opts.addAssoc("NoDelete", true);
	self.opts.addAssoc("ProductStr", "BIGSAND");
	self.addReleaseRequestByTypeLine(ReleaseNumber, app.myRoot.allCargoTypesById[10016].id, null, null, 10, pxyBulkRelease);
	
	// add CAR request line
	self.opts.purge();
	delete pxyBulkRelease;
	release := self.getReleaseRequest(ReleaseNumber);
	pxyBulkRelease	:=	app.createUpdateProxy(release).CM_BulkRelease;
	self.opts.addAssoc("NoDelete", true);
	self.addReleaseRequestByTypeLine(ReleaseNumber, app.myRoot.allCargoTypesById[7].id, null, null, 10, pxyBulkRelease);
	
	// add truck to load cargo for release
	self.opts.addAssoc("Carrier", "AAUTO");
	
	self.deleteVehicle("TRK52613");
	// Gate in a truck for the release and make sure the Release Cargo screen has the correct weight - 42,700lbs.
	//self.opts.addAssoc("ReleaseRequest", release);
	//self.opts.addAssoc('release', release);
	vvr := addVehicleVisitRecord("TRK52613", "", "", "GATE");
	self.assertNotNull(vvr);
	
	// Create the GTE Entity and add to VVR
	create controller transient;
	create pxyGateEntity as CMGTE_Release transient;
	controller.myTerminal := terminal;
	controller.jobType := CMGTE_Entity.JobType_GeneralOUT;
	controller.numItems := 10;
	controller.operatorCode := "MSL";
	controller.cargoType := 10016;
	controller.myProduct := app.myRoot.allCargoTypesById[10016].getProductFromCode("BIGSAND");
	controller.myVehicleVisitRecord := vvr;
	if app.isSubTerminalsOn(terminal) then
		subTerm := terminal.getDefaultSubTerminal(	CM_SubTerminal.Type_BulkRelease,
												null,	// cnwdad1 27/01/2010 - PAR #22205.
												0,
												null,
												false);
		if subTerm &lt;&gt; null then
			controller.subTerminalCode := subTerm.code;
		endif;
	endif;
	
	controller.myBulkRelease := release;
	foreach reserveDetail in release.allReserveDetails where reserveDetail.getCargoType().id = 10016 do
		controller.myReserveDetail := reserveDetail;	
	endforeach;
	
	if release.myVoyage &lt;&gt; null then
		controller.voyageCode := release.myVoyage.code;
	endif;
	
	pxyGateEntity.setPXYFromController(controller); 
	pxyGateEntity.CMGTE_Release.setIsReleaseById(false);
	
	self.ignoreTrxWarnings(true);
	app.myTrxCA.trxCreateInOutFlexiGateEntity(vvr, pxyGateEntity, gateEntity, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	// Complete the Gate In - Road job is created
	pxyVVR := app.createUpdateProxy(vvr).CM_VehicleVisitRecord;
	self.ignoreTrxWarnings(true);
	app.myTrxCA.trxCreateInOutFlexiJob(pxyVVR, vvr, null,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
epilog
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="resetData_52705" id="6c7d3a1d-69ea-40f4-9d6a-a342655a70b3">
        <source>resetData_52705();
/*

Purpose:	Reset 52705		

Date		Who		Reason
28/01/2022	navmh5	Initial creation

*/

vars

	terminal				: CM_Terminal;
	user					: CM_User;
	ti						: CM_TrackedItem;
	vvr						: CM_VehicleVisitRecord;

begin

	
	app.initialize();
	
	/*****************************************************
	 * Terminal - TT1
	 *****************************************************/
	 
	 terminal := app.myRoot.allTerminals["PNL"];
	 if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	// Set passport user
	user := app.myRoot.allUsers["SUPERUSER"];
	app.myPassport.setMyUser(user);
	
	foreach vvr in CM_VehicleVisitRecord.instances discreteLock do
		if vvr.regNumber = "AUTOHUB" and vvr.timeOut = null then
			self.ignoreTrxWarnings(true); 
			app.myTrxUA.trxUpdateVVRCancel(vvr, "Last Test Run Failed", app.myPassport);
			self.assertNoTrxErrorsOrWarnings();
			//break;
		endif;
	endforeach;
	
	/*if vvr &lt;&gt; null then
		self.ignoreTrxWarnings(true); 
		app.myTrxUA.trxUpdateVVRCancel(vvr, "Last Test Run Failed", app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;*/
	
	//self.deleteBOL("TESTBOL", null);
		
	ti := self.getTrackedItem("TESTCARID");
	self.deleteTrackedItem(ti, false);	
	
	ti := self.getTrackedItem("TESTCARID2");
	self.deleteTrackedItem(ti, false);
	
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="resetData_52716" id="f7355190-db7c-4f72-8bcc-7a7def7a1d7f">
        <source>resetData_52716();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27/01/2022	navmk3	Initial creation

*/
constants

	VoyageId					: String = "TRIAC164C";
vars
	terminal, passportTerm		: CM_Terminal;
	tisToDelete					: CM_TISet;
	voyage 						: CM_Voyage;
begin
	app.initialize();
	
	/*****************************************************
	 * Terminal - PNL
	 *****************************************************/
	 
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	terminal := app.myRoot.allTerminals["PNL"];
	if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	passportTerm := app.myPassport.myTerminal;
	app.myPassport.setMyTerminal(terminal);
	
	create tisToDelete transient;
	
	voyage := self.getVoyage(VoyageId);
	voyage.allOnshipTIsByCargoTypeId.copyNoDups(tisToDelete);
	
	self.deleteTrackedItems(tisToDelete, null);

epilog
delete tisToDelete;
end;
</source>
    </JadeMethod>
    <JadeMethod name="resetData_52837" id="6a65ab1d-3397-4139-ae83-2463989faeea">
        <source>resetData_52837();
/*

Purpose:	Reset 52837		

Date		Who		Reason
28/10/2022	navmh5	Initial creation

*/
vars
	
	terminal				: CM_Terminal;
	passportTerm 			: CM_Terminal;
	invoice					: CM_Invoice;
	invoiceNote				: CM_InvoiceNote;
	
begin
	
	app.initialize();
	 
	 terminal := app.myRoot.allTerminals["TT1"];
	 if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	passportTerm := app.myPassport.myTerminal;
	app.myPassport.setMyTerminal(terminal);
	
	foreach invoiceNote in CM_InvoiceNote.instances discreteLock do
	
		if invoiceNote.myInvoice = null then
			continue;
		endif;
		
		if invoiceNote.myInvoice.sequenceNum &lt;&gt; 1 then
			continue;
		endif;
		
		beginTransaction;
		delete invoiceNote;
		commitTransaction;
	
	
	endforeach;

	
epilog

	app.myPassport.setMyTerminal(passportTerm);

end;</source>
    </JadeMethod>
    <JadeMethod name="resetData_52876" id="0dbafbe4-25b8-4c85-8f77-8c7c4f7b2def">
        <source>resetData_52876();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17/02/2022	navmk3	Initial creation

*/
constants

	ContId1						: String = "JLG52876A01";
	ContId2						: String = "JLG52876A02";
vars
	terminal, passportTerm		: CM_Terminal;
	ti							: CM_TrackedItem;
	voyage 						: CM_Voyage;
	terminalArea				: CM_TerminalArea;
	user						: CM_User;
	forklift					: CM_Machine;
begin
	app.initialize();
	
	/*****************************************************
	 * Terminal - PNL
	 *****************************************************/
	 
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("PNLDEFAULT");
	
	terminal := app.myRoot.allTerminals["PNL"];
	if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	passportTerm := app.myPassport.myTerminal;
	app.myPassport.setMyTerminal(terminal);
	
	ti := self.getTrackedItem(ContId1);
	terminalArea := self.getTerminalArea("A1");
	if ti &lt;&gt; null and terminalArea &lt;&gt; null then
		self.moveQueued(ti, terminalArea.CM_ForkLiftStack.allGridControllersByRowColumn[1,4]);
	endif;

	ti := self.getTrackedItem(ContId2);
	terminalArea := self.getTerminalArea("Q10_14");
	if ti &lt;&gt; null and terminalArea &lt;&gt; null then
		self.moveQueued(ti, terminalArea);
	endif;
	
	forklift := self.getMachine("TRE");
	self.machineLogon(forklift);
	self.machineAcceptSpecifiedTask(forklift, ti.allWorklistEntries.first.allRTQueueEntries.first);		
	
	self.machinePickup(forklift);
	self.machineSetdown(forklift, ti , "Q10DROP");
	self.machineLogOff(forklift);
	
	user := app.myRoot.allUsers["PNLDEFAULT"];
	self.assertNotNull(user);
	beginTransaction;
	user.setStateData(ConfigGrp_Web, "isGraphicalView", "False");
	commitTransaction;
end;
</source>
    </JadeMethod>
