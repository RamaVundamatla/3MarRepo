        <source>create() updating;
//
// 06 Jun 20	cnwrs1	Par34344 - Create ICL Codeco message
//
vars

begin
	self.name := "ICL Codeco";
	self.type := EDIFileTypeCams_ICLCodeco; // note can only use constant in dmast 
epilog

end;
</source>
