    <JadeMethod name="isDensity_Match" id="8a5690c6-123a-4854-b2d4-a15ac2467f3b">
        <source>isDensity_Match(_yaData: CM_YADataString): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11/05/2023	navkc1	Bug 57912: EUP - YA Density Error

*/

vars
	yaData 			: CM_YAData;
	yaDataString 	: CM_YADataString;
	del 			: CM_DeliveryRequest;
	density 		: String;
	
begin
	yaData := self.getExtraCriteriaMatchData( YACriteriaType_Density );

	if yaData &lt;&gt; null and yaData.isKindOf(CM_YADataString) then
		yaDataString := yaData.CM_YADataString;
		
		if yaDataString &lt;&gt; null then
			return _yaData.doesValueMatch( yaDataString.value );
		endif;
	endif;

	del := self.myDeliveryRequest;

	if del &lt;&gt; null then
		density := del.density.asStringJMT();
		
		return _yaData.doesValueMatch(density);
	endif;

	return true;
	
epilog

end;</source>
