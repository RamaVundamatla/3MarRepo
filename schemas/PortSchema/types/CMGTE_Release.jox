        <source>setImportReleasePIN( _value : String ) updating;

/*
Date			Who		Reason
07 October 2010	cnwrl1	Initial creation as part of PAR 25958 - Check all required information is supplied.
*/
	
vars
	
begin
	if self.importReleasePIN &lt;&gt; _value then
		self.importReleasePIN	:= _value;
	endif;
	
epilog
	
end;
</source>
