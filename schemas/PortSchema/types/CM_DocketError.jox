    <JadeMethod name="auditId" id="18bde585-fc25-41dc-a37b-6a0408e14aff">
        <source>auditId(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 February 2010	cnwas3	Initial creation

*/

vars

begin
	return self.docketErrorCode &amp; ' ' &amp; self.docketErrorDesc.trimBlanks();

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
