    <JadeMethod name="getExtraInfo" id="c6edd83a-fae7-4f75-9244-8e4b6e50541f">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
/*

Purpose:		TFS 39718	

Parameters:			

Return Value:		

Date		Who		Reason
11 July 2018	jlgab1	Initial creation

*/

vars
	block : CM_DataContainerBlock;

begin
	inheritMethod(_dataContainer);
	
	if self.myWorkOrderToCancel &lt;&gt; null then 
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Work_order_cancel), DC_Label, 1, null);
		block.addNewItem(self.myWorkOrderToCancel.getDisplayString() , DC_Data, 1, null);
	endif;
epilog

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
