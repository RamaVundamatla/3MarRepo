    <JadeMethod name="translateToSearchValueForWeb" id="d143a850-9cdd-4ce4-a868-902b2ad3e446">
        <source>translateToSearchValueForWeb(_value: Any; _sending : Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 27/09/2019	jlgzm1		Initial creation TFS 46703 Direct Release Selector Query
//
vars
	int : Integer;
	rtnVal, collStr, str : String;	
	strArray : StringArray;
	intArray : IntegerArray;

begin
	if _value.isKindOf(Integer) then
		return app.transportModeENumToString(_value.Integer);
		
	elseif _value.isKindOf(String) then
		if _value.String.cnContains("|") then
			collStr := _value.String;
			create strArray transient;
			create intArray transient;
			collStr.getTokensForDelimiter("|", strArray);
			foreach str in strArray do
				intArray.add(app.transportModeStringToENum(str));
			endforeach;
			return intArray;
		endif;
		
		if not _sending then
			return app.transportModeStringToENum(_value.String);
		endif;
		
		return _value.String;
		
	elseif _value.isKindOf(IntegerArray) then
		foreach int in _value.IntegerArray do
			rtnVal := rtnVal &amp; app.transportModeENumToString(int) &amp; CNEC_COMMA &amp; Space;
		endforeach;
		rtnVal := rtnVal[1:rtnVal.length-2];
		return rtnVal;
		
	endif;
	
	return inheritMethod(_value, _sending);

epilog
	delete strArray;
end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
