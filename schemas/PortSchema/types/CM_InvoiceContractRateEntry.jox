    <JadeMethod name="getDisplayStringForAttribute" id="bdd99903-5e2d-42c4-a81d-4995dcaa1664">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Feb 2023 navtnr20	TFS CR 55646 Task 55665: UI - Contract Details
09 Mar 2023	navmk20		Bug 57006: 4013 error when trying to edit a rate
27 March 2023  navmv20 TFS 55651 Task 57072: UI - Contract Bulk Edit UI
*/

vars
	criteria 	: CM_InvoiceContractCriteria; //27/03/2023 navmv20 TFS 55651 Task 57072
	invLineType : CM_InvoiceLineDesc; 		  //27/03/2023 navmv20 TFS 55651 Task 57072
	service     : CM_Service; 				  //27/03/2023 navmv20 TFS 55651 Task 57072
begin
	if _attrName = ETRow_FromTS then
		return self.systemToLocalTime(self.fromTS).asStringJMT();
	elseif _attrName = ETRow_ToTS then
		return self.systemToLocalTime(self.toTS).asStringJMT();
	elseif _attrName = ETRow_From then
		//9.3.2023 navmk20 TFS - 57006 return self.fromAmount.asStringJMT;
			return self.fromAmount.asStringJMTWithPrecision(2, true);//9.3.2023 navmk20 TFS - 57006
	elseif _attrName = ETRow_To then
		//9.3.2023 navmk20 TFS - 57006 return self.toAmount.asStringJMT;
			return self.toAmount.asStringJMTWithPrecision(2, true);//9.3.2023 navmk20 TFS - 57006
	elseif _attrName = ETRow_Rate then
		//9.3.2023 navmk20 TFS - 57006return self.costPerUnit.asStringJMT();
		return self.costPerUnit.asStringJMTWithPrecision(4,true);//9.3.2023 navmk20 TFS - 57006
		
	//27/03/2023 navmv20 TFS 55651 Task 57072 - START
	elseif _attrName = ETRow_ContractId then
		return self.myInvoiceContractRate.myInvoiceContractDetail.myInvoiceContract.contractId;
	elseif _attrName = ETRow_Criteria then
		criteria := self.myInvoiceContractRate.myInvoiceContractDetail.myInvoiceContractCriteria;
		if criteria &lt;&gt; null then
			return criteria.getCriteriaSummary(", ");
		else 
			return null;
		endif;
	elseif _attrName = ETRow_InvoiceLine then
		invLineType := self.myInvoiceContractRate.myInvoiceContractDetail.myInvoiceLineType;
		if invLineType &lt;&gt; null then
			return invLineType.narration;
		else
			return null;
		endif;
	elseif _attrName = ETRow_Service then
		service := self.myInvoiceContractRate.myService;
		if service &lt;&gt; null then
			return service.name;
		else
			return null;
		endif;
	endif;
	//27/03/2023 navmv20 TFS 55651 Task 57072 - END
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
