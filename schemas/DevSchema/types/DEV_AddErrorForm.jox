    <JadeMethod name="doLoad" id="e2c1b941-99ef-4523-96e2-96d59da65fad">
        <updating/>
        <source>doLoad() updating;

vars
	xmlDoc		: CM_XMLDocument;
	xmlElement	: JadeXMLElement;
	xmlArray	: JadeXMLElementArray;
	xmlElem		: JadeXMLElement;
	row			: Integer;
begin

//app.msgBox(self.name, '', 0);

	modalResult := MsgBox_Return_Cancel;

	if myConstant = null or myConstant.text = null then
		return;
	endif;

	txtHeading.text := myConstant.name;
	txtConstantValue.text := myConstant.getSource;
	
	table.setCellText(1,1,"Locale	Message	Short Message");
	table.columnWidth[1] := 100;
	table.columnWidth[2] := (table.clientWidth - 100) div 4 * 3;	// 3/4 of remainder
	table.columnWidth[3] := (table.clientWidth - 100) div 4;		// 1/4 of remainder
	table.columnWidth[1] := 100;
	table.accessColumn(2).partialTextIndication := true;
	table.accessColumn(3).partialTextIndication := true;
	table.accessColumn(2).inputType := Table.InputType_TextBox;
	table.accessColumn(3).inputType := Table.InputType_TextBox;
	
	create xmlDoc transient;
	create xmlArray transient;

	xmlDoc.parseString(myConstant.text);
	xmlDoc.getElementsByTagName(XMLTag_LocaleMsg, xmlArray);

	foreach xmlElem in xmlArray where xmlElem.attributes.size &gt; 0 do
		row := table.addItem(xmlElem.attributes[1].value &amp; Tab &amp;								// locale
							 xmlElem.getTagValueOfName(XMLTag_Msg) &amp; Tab &amp;		// msg
							 xmlElem.getTagValueOfName(XMLTag_ShortMsg));		// shortMsg
	endforeach;



epilog
	delete xmlDoc;
	delete xmlArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="89ef94ea-1f20-4f50-b4cf-523c95fa5593">
        <updating/>
        <source>doSave() updating;
// ---------------------------------------------------------------------------
// Created:     17 March 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
constants
	XML_Header = '&lt;?xml version="1.0"?&gt;';
vars
	xml			: String;
	localeStr	: String;
	row			: Integer;
	locale		: String;
	msg			: String;
	shortMsg	: String;
begin

	if self.myConstant = null then
		app.msgBox('Constant us null - cannot action', 'Error', MsgBox_OK_Only);
		return;
	endif;

	// accumulate messages for each locale
	foreach row in table.fixedRows + 1 to table.rows do
		locale	 := table.getCellText(row, 1);
		msg		 := table.getCellText(row, 2);
		shortMsg := table.getCellText(row, 3);
		
		if locale = null or msg = null then	// skip rubbish
			continue;
		endif;
		
		if locale &lt;&gt; StandardTextLocaleStr then
			continue;
		endif;
		
		localeStr := localeStr &amp;
						'&lt;' &amp; XMLTag_LocaleMsg &amp; ' ' &amp; XMLTag_LocaleName &amp; '="' &amp; locale &amp; '"&gt;' &amp; CrLf &amp;
						global.formatAsXML(XMLTag_Msg, msg) &amp;
						global.formatAsXML(XMLTag_ShortMsg, shortMsg) &amp;
						global.formatAsXMLSuffix(XMLTag_LocaleMsg);
					
	endforeach;
	
	xml := XML_Header &amp; CrLf &amp;
		   global.formatAsXMLPrefix(XMLTag_Header) &amp;
		   localeStr &amp;
		   global.formatAsXMLSuffix(XMLTag_Header);

	beginTransaction;		  
	self.myConstant.setText(xml);
	commitTransaction;
	
	self.modalResult := MsgBox_Return_OK;
	
	self.unloadForm();

end;</source>
    </JadeMethod>
