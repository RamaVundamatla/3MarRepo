    <JadeMethod name="numPlannedTIs" id="342bad4a-b2ef-4388-b67d-cd8472604930">
        <methodInvocation>mapping</methodInvocation>
        <source>numPlannedTIs(set: Boolean; _value: Integer io) mapping;
// ---------------------------------------------------------------------------
// Created:     19 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	_value := self.allPlannedFutureMoves.size;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="numPlannedTIsOut" id="0fb39071-3ec1-4b3c-8ce6-04d456c4a504">
        <source>numPlannedTIsOut():Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 January 2019	jlgndl1	Initial creation	TFS 42292

*/

vars

	iter : Iterator;
	count : Integer;
	ti : CM_TrackedItem;

begin

	iter := self.allTrackedItems.createIterator;
	while iter.next( ti ) do
		if ti.myPrimaryPlannedLocation &lt;&gt; null then
			count := count + 1;
		endif;
	endwhile;
	
	return count;

epilog

	delete iter;

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="numQueuedTIs" id="1fee6cdb-7218-465a-9da0-556a4594080b">
        <methodInvocation>mapping</methodInvocation>
        <source>numQueuedTIs(set: Boolean; _value: Integer io) mapping;
// ---------------------------------------------------------------------------
// Created:     19 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	_value := self.allQueuedFutureMoves.size;	//As there is a 1-to-1 relationship between a future move and a TI

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
