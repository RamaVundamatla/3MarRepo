    <JadeMethod name="hasTIsToDischarge" id="252b4766-e17e-4b07-bf43-0a1cfafb63e8">
        <source>hasTIsToDischarge(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 August 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars

begin
			
	if self.mySlotController &lt;&gt; null then
		if not self.mySlotController.allTrackedItems.isEmpty and self.mySlotController.mySlotRequestDischarge &lt;&gt; null then
