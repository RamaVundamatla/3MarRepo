<Class name="CM_CashCreditDetail" id="8128c00c-7d11-49a7-9cf6-9e607a24a374">
    <superclass name="CM_Cash"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>The detail of each credit, either derived (from the original cash receipt) or applied (to a subsequent receipt)</text>
    <DbClassMap file="cashPayment"/>
    <ExplicitInverseRef name="myAppliedToCashCredit" id="7e82b7bb-aec6-469c-b141-522d33b82655">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_CashCredit"/>
        <access>readonly</access>
        <text>The parent cash credit, when this is an applied credit detail (to a subsequent cash receipt)</text>
        <Inverse name="CM_CashCredit::allAppliedToCreditDetails"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="myCashPayment" id="b5a7092b-039a-45e2-95d1-01039dbd6411">
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_CashPayment"/>
        <access>readonly</access>
        <text>For a derived detail this is the matching payment from the original cash receipt.
For an applied detail this is the matching payment from the applied-to cash receipt.

In either case there can be more than one credit detail per payment.</text>
        <Inverse name="CM_CashPayment::allCashCreditDetails"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="myDerivedFromCashCredit" id="2a93df65-3dcb-492b-984b-bb6f05eec830">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_CashCredit"/>
        <access>readonly</access>
        <text>The parent cash credit, when this is a derived credit detail (from the original cash receipt)</text>
        <Inverse name="CM_CashCredit::allDerivedFromCreditDetails"/>
    </ExplicitInverseRef>
    <ImplicitInverseRef name="myTrackedItem" id="a9ddaf47-b114-45d0-a0e1-c3b0d0e29737">
        <embedded/>
        <type name="CM_TrackedItem"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="delete" id="15ae45aa-fa48-4e9e-9eda-08ce75de6d46">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 January 2021	jlgndl1	Initial creation

*/

vars

begin

	self.resetAuditsDuringDelete();	//25 Jan 2021	NDL	TFS 50152

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getDebtorTerminal" id="41784db9-58d7-40ed-a372-2348c8238919">
        <source>getDebtorTerminal(): CM_DebtorTerminal;

vars

begin
	if self.myAppliedToCashCredit &lt;&gt; null then
		return self.myAppliedToCashCredit.getDebtorTerminal();
	else
		return self.myDerivedFromCashCredit.getDebtorTerminal();
	endif;
end;
</source>
        <ReturnType type="CM_DebtorTerminal"/>
    </JadeMethod>
    <JadeMethod name="getDescription" id="da4d5be9-b8ea-4911-afd4-dd40848e0b5f">
        <source>getDescription(): String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 Oct 2019 cnwma1	ChangeRequest 46984: JMT - Refactor Cash Credit UI and Tax
*/
vars

	typeString : String;

begin
	if self.myAppliedToCashCredit &lt;&gt; null then
		typeString := "Applied Credit detail to";
	else
		typeString := "Derived Credit Detail from";
	endif;
	
	if self.myCashPayment &lt;&gt; null then
		typeString := typeString &amp; " " &amp; self.myCashPayment.getDescription(); 
	endif;

	return typeString;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getGLRateSummaryStats" id="3f4f75c4-54d4-40bf-bd72-e7a5cd320575">
        <source>getGLRateSummaryStats(_glSumm : CM_GLSummaryByGLCodeRateDict input);
/*

Purpose:			

Parameters:			

Return Value:	

	
Date		Who		Reason
   Feb 2016 TFS 985 Milaha credit/receipt export, copy of CM_Charge method
17 Oct 2019 cnwma1 ChangeRequest 46984: JMT - Refactor Cash Credit UI and Tax
*/

vars

begin
	
	if self.myCashPayment &lt;&gt; null then
		self.myCashPayment.getGLRateSummaryStats(_glSumm);
	endif;
end;</source>
        <Parameter name="_glSumm" type="CM_GLSummaryByGLCodeRateDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTypeString" id="c361dc9d-f6c7-4a4e-8a96-cbafcd2ca97c">
        <source>getTypeString(_drTerm: CM_DebtorTerminal): String;

vars

begin
	return self.getDescription();
end;
</source>
        <Parameter name="_drTerm" type="CM_DebtorTerminal"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="3772430a-a2bc-4de8-8314-345666c29a70">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:		TFS 44275	

Parameters:			

Return Value:		

Date		Who		Reason
19 Jun 2019	jlgab1	Initial creation
17 Oct 2019 cnwma1 ChangeRequest 46984: JMT - Refactor Cash Credit UI and Tax
*/

vars
	pxy : CM_CashCreditDetail;
begin
	pxy :=  inheritMethod();
	pxy.myAppliedToCashCredit   := self.myAppliedToCashCredit;
	pxy.myDerivedFromCashCredit := self.myDerivedFromCashCredit;
	
	return pxy;
epilog

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="pxyGetBank" id="f68151e0-e787-43a7-b8b8-830219f711dd">
        <source>pxyGetBank() : CM_Bank;

/*

Purpose:			// TFS 38732

Parameters:			

Return Value:		


Date		Who		Reason
16 May 2018	jlgab1	Initial creation

*/

vars
	bank : CM_Bank;
begin
	if self.myTrackedItem &lt;&gt; null then
		bank := self.myTrackedItem.companyOid;
	endif;
	if bank = null then
		if self.myCashPayment &lt;&gt; null 
		and self.myCashPayment.myCashReceipt &lt;&gt; null then
			bank := self.myCashPayment.myCashReceipt.myBank;
		endif;
	endif;
	if bank = null then
		if self.myDerivedFromCashCredit &lt;&gt; null then
			bank := self.myDerivedFromCashCredit.myBank;
		endif;
	endif;
		
	return bank;
epilog

end;</source>
        <ReturnType type="CM_Bank"/>
    </JadeMethod>
    <JadeMethod name="setAppliedProxy" id="5a14927c-712e-41fe-9db7-4dfcb5d79430">
        <updating/>
        <source>setAppliedProxy(_cashCredit 	: CM_CashCredit;
				_payment 		: CM_CashPayment;
				_trackedItem 	: CM_TrackedItem;
				_value 			: Decimal;
				_dateTime 		: TimeStamp) updating;
/*

Purpose:			

Parameters:			

Return Value:		


17 Oct 2019 cnwma1 ChangeRequest 46984: JMT - Refactor Cash Credit UI and Tax
*/
vars

begin

	self.myAppliedToCashCredit  := _cashCredit;
	self.myCashPayment 			:= _payment;
	self.myTrackedItem		    := _trackedItem;
	self.cashValue 				:= _value;
	self.dateTime 				:= _dateTime;
end;
</source>
        <Parameter name="_cashCredit" type="CM_CashCredit"/>
        <Parameter name="_payment" type="CM_CashPayment"/>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_value" type="Decimal"/>
        <Parameter name="_dateTime" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="setCashPayment" id="5f1ed359-7b2e-4da6-a21b-20c46bc371cd">
        <updating/>
        <source>setCashPayment(_value : CM_CashPayment) updating;

vars

begin
	self.myCashPayment := _value;
end;
</source>
        <Parameter name="_value" type="CM_CashPayment"/>
    </JadeMethod>
    <JadeMethod name="setDerivedFromCredit" id="7c192505-942b-4064-bade-d86d4ee94b0d">
        <updating/>
        <source>setDerivedFromCredit(_value : CM_CashCredit) updating;

vars

begin
	self.myDerivedFromCashCredit := _value;
end;
</source>
        <Parameter name="_value" type="CM_CashCredit"/>
    </JadeMethod>
    <JadeMethod name="setDerivedProxy" id="67171ad9-06b0-440d-ad4a-d65cc25f2e74">
        <updating/>
        <source>setDerivedProxy(_cashCredit 		: CM_CashCredit;
				_payment 		    : CM_CashPayment;
				_trackedItem        : CM_TrackedItem;
				_value 			    : Decimal; 
				_dateTime 			: TimeStamp) updating;
/*

Purpose:			

Parameters:			

Return Value:		


17 Oct 2019 cnwma1 ChangeRequest 46984: JMT - Refactor Cash Credit UI and Tax
*/
vars

begin
	self.myDerivedFromCashCredit := _cashCredit;
	self.myCashPayment 			 := _payment;
	self.myTrackedItem 			 := _trackedItem;
	self.cashValue 				 := _value;
	self.dateTime 				 := _dateTime;
end;
</source>
        <Parameter name="_cashCredit" type="CM_CashCredit"/>
        <Parameter name="_payment" type="CM_CashPayment"/>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_value" type="Decimal"/>
        <Parameter name="_dateTime" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="8d35c678-589c-4af0-8a4b-f33f9230522a">
        <updating/>
        <source>setForCreate(_proxy: CM_CashCreditDetail) updating;
/*

Purpose:			

Parameters:			

Return Value:		


17 Oct 2019 cnwma1 ChangeRequest 46984: JMT - Refactor Cash Credit UI and Tax
*/
vars

begin
	
	self.cashValue 	  			 := _proxy.cashValue;
	self.dateTime 	  		 	 := _proxy.dateTime;
	if self.dateTime = null then
		self.dateTime 			 := app.actualTimeServer;
	endif;
	self.myCashPayment 			 := _proxy.myCashPayment;
	self.myAppliedToCashCredit 	 := _proxy.myAppliedToCashCredit;
	self.myDerivedFromCashCredit := _proxy.myDerivedFromCashCredit;
end;
</source>
        <Parameter name="_proxy" type="CM_CashCreditDetail"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="7dcd0429-f172-4a96-b206-dcd64e125713">
        <updating/>
        <source>setForUpdate(_proxy: CM_CashCreditDetail) updating;
/*

Purpose:			

Parameters:			

Return Value:		


17 Oct 2019 cnwma1 ChangeRequest 46984: JMT - Refactor Cash Credit UI and Tax
*/
vars

begin
	inheritMethod(_proxy);
	
	self.myCashPayment 			 := _proxy.myCashPayment;
	self.myAppliedToCashCredit   := _proxy.myAppliedToCashCredit;
	self.myDerivedFromCashCredit := _proxy.myDerivedFromCashCredit;
	if self.dateTime = null then
		self.dateTime := app.actualTimeServer;
	endif;
end;
</source>
        <Parameter name="_proxy" type="CM_CashCreditDetail"/>
    </JadeMethod>
</Class>
