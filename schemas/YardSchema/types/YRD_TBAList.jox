    <JadeMethod name="setupForm" id="7fb2802b-09f7-4e78-ae9d-bd41a393a282">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.usesQueryFrame := true;

	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.showToolbar := true;
	self.useTableSorting := true;
	self.useTableInfo := true;
	inheritMethod();

	self.setCaption(app.getErrorString(TBAList));
	self.setNavigatorHeading(self.caption);
	
	self.initTableData(ETDef_LlHeadings); //epr TFS 378 22/6/15
	self.tblData.accessColumn(1).width := 130;

	self.tblInfo.rows := 0;
	//self.btnNew.enabled := app.myCurrentVoyage &lt;&gt; null;
	//cnwjo3 par 23105
	self.btnNew.enabled := app.getMyCurrentVoyage() &lt;&gt; null;

	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnEditItem.enabled := false;
		self.btnDelete.enabled := false;
		self.btnRemarks.enabled := false;
		self.btnNew.enabled:= false;
		self.mnuManualTBA.enabled := false; // TFS 45590

	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="d94b7692-f1c9-45ab-bcbb-0e6d818a5bc1">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0008927, locale);
	btnEnquiry.translateBubbleHelp(Xlat_0004659, locale);
	btnEnquiry.translateCaption(Xlat_0004663, locale);
	btnNew.translateBubbleHelp(Xlat_0004660, locale);
	btnNew.translateCaption(Xlat_0004664, locale);
	btnRefresh.translateBubbleHelp(Xlat_0004661, locale);
	btnRefresh.translateCaption(Xlat_0004665, locale);
	btnRemarks.translateBubbleHelp(Xlat_0004662, locale);
	btnRemarks.translateCaption(Xlat_0004666, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="userNotificationUpdate" id="a98aee26-161a-4df1-8fa6-44f786f54354">
        <updating/>
        <source>userNotificationUpdate(_event: Integer; _noteobj : CM_Object; _obj: CM_Object) updating;
// ---------------------------------------------------------------------------
// Created:		July 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	idx : Integer;
	theDataLine : String;
	theTI : CM_TrackedItem;
begin
	if _obj = null or (not global.isValidObject(_obj)) then
		return;
	endif;

	if _obj.isKindOf(CM_TrackedItem) and _event = Event_TBA_Create then
		self.doQuery();
	//endif;// PAR 20122
	elseif _obj.isKindOf(CM_TrackedItem) and _event = Object_Update_Event then
		theTI :=  _obj.CM_TrackedItem;
		if self.tblData.findObjectInRow(_obj,idx) then
			theDataLine := theTI.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
			self.tblData.accessCell(idx,1).text := theDataLine;
			if theTI.myMatchedTBA &lt;&gt; null then // PAR 35574
				self.tblData.accessRow(idx).backColor := LightGreen;
			else
				self.tblData.accessRow(idx).backColor := White;
			endif;
		endif;
	else
		inheritMethod(_event, _noteobj,_obj);
	endif;
epilog
	endLoad;
end;</source>
        <Parameter name="_event" type="Integer"/>
        <Parameter name="_noteobj" type="CM_Object"/>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
</GUIClass>
