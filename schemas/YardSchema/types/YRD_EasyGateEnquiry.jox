    <JadeMethod name="addRowToTable" id="263b8066-7e4f-43ed-a09f-cf8bdf02ebe2">
        <source>addRowToTable(_interTermMove : CM_InterTerminalMove; _tbl : CM_DataTable io) protected;


/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 February 2010	cnwrd1	Initial creation

*/

vars
	theDataLine : String;
begin

	theDataLine := _interTermMove.getAttributeStringForDefArray(_tbl.allTblDataEntRows);
	_tbl.accessRow(_tbl.addItem(theDataLine)).itemObject := _interTermMove;
	self.doNotableAdd(_interTermMove);

epilog

end;

</source>
        <access>protected</access>
        <Parameter name="_interTermMove" type="CM_InterTerminalMove"/>
        <Parameter name="_tbl" type="CM_DataTable" usage="io"/>
    </JadeMethod>
