    <JadeMethod name="getExportData" id="d6fe6f63-5418-4544-bf22-e3cdd24c1152">
        <updating/>
        <source>getExportData(_dataEntity: String): WS_ExportDataResponse updating;
/**
 * Exports JADE class instances as Base64-encoded XML
 * 
 * REST Endpoint: GET /exportData/{dataEntity}?internalAPI=true&amp;businessKey={key}&amp;maxRecords={max}
 * Security: Requires valid JWT access token + appropriate export permission
 * 
 * Query Parameters:
 * - internalAPI: true (required)
 * - businessKey: Optional filter for single record
 * - maxRecords: Maximum records to export (default 1000, max 10000)
 * 
 * Permissions:
 * - System classes: PmAdmSystemExport
 * - Terminal classes: PmAdmTerminalExport
 * 
 * Date        Who                      Reason
 * 6 Jan 2026 naviv1     Initial creation - MTN-36582 - Create Export API
 */
constants
    MAX_RECORDS_PARAM = "maxRecords";
    BUSINESS_KEY_PARAM = "businessKey";
    DEFAULT_MAX_RECORDS = 1000;
    ABSOLUTE_MAX_RECORDS = 10000;
vars
    response: WS_ExportDataResponse;
    passport: CM_Passport;
    term: CM_Terminal;
    exportClass: CM_ExportImportClass;
    wsAgent: CM_DataExportAgent;
    xmlResult: String;
    base64Result: String;
    businessKey: String;
    maxRecords: Integer;
    recordCount: Integer;
	requiredPermission : Integer;
	dataEntity : String;
begin
    // Arm exception handlers
    on CM_Exception do self.handleCMException(exception);
    on LockException do self.handleLockExceptions(exception);
    
    create response transient;
    
    // Initialize passport and validate session
    self.initialisePassport();
    passport := app.myPassport;
    
    if self.httpStatusCode &lt;&gt; HttpResponseOK then
        app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);
        return response;
    endif;
    
    if passport.hasErrors then
        self.httpStatusCode := HttpResponseUnauthorized;
        return response;
    endif;
    
    term := passport.myTerminal;
    if term = null then
        self.httpStatusCode := HttpResponseSystemError;
        return response;
    endif;
    
    // Validate data entity
	dataEntity := _dataEntity.replace(Space,'');
    exportClass := app.myRoot.allExportImportClasses.getByDisplayName(dataEntity);
    if exportClass = null then
        self.httpStatusCode := HttpResponseClientError;
        return response;
    endif;
    
    if not exportClass.isExportable then
        self.httpStatusCode := HttpResponseClientError;
        return response;
    endif;
    
    // Check permissions
    requiredPermission := self.getRequiredExportPermission(exportClass.category);
	
    if not passport.myUser.canDo(term,requiredPermission) then
        self.httpStatusCode := HttpResponseForbidden;
        return response;
    endif;
    
    // Get query parameters
    businessKey := self.qsData.getValue(BUSINESS_KEY_PARAM).asStringJMT();
    maxRecords := self.qsData.getValue(MAX_RECORDS_PARAM).asIntegerJMT();
    
    // Validate maxRecords
    if maxRecords &lt;= 0 then
        maxRecords := DEFAULT_MAX_RECORDS;
    elseif maxRecords &gt; ABSOLUTE_MAX_RECORDS then
        maxRecords := ABSOLUTE_MAX_RECORDS;
    endif;
    
    // Perform export
    create wsAgent transient;
    
    xmlResult := wsAgent.exportToXml(
        dataEntity,
		maxRecords,
        businessKey        
    );
    
    if xmlResult = "" or xmlResult = null then
		self.httpStatusCode := HttpResponseNotFound;
		 return response;
	endif;
    // Encode to Base64
    base64Result := xmlResult.Binary.base64EncodeNoCrLf;
    
    // Build response
    response.dataEntity := dataEntity;
    response.recordCount := recordCount;
    response.exportDataBase64 := base64Result;
    
    self.httpStatusCode := HttpResponseOK;
    
    return response;
    
epilog
    self.finaliseResponse(response);
    delete wsAgent;
end;</source>
        <Parameter name="_dataEntity" type="String"/>
        <ReturnType type="WS_ExportDataResponse"/>
    </JadeMethod>
    <JadeMethod name="getFaultQuestions" id="0fe3e6ae-4f95-4a3d-95f4-be09c1b4318d">
        <updating/>
        <source>getFaultQuestions(): WS_FaultQuestionsResponse updating;
/*

Purpose: This is the REST version of machineGetFaultQuestions

Parameters:

			
Return Value: 


Date		Name	TFS#		Description
============================================================================
22 Feb 2021	jlika1	49429		Initial creation
============================================================================*/

vars
	machine 		: CM_Machine;
	response		: WS_FaultQuestionsResponse;			
	faultQuestion 	: CM_FaultQuestion;
	wsFaultQuestion : WS_FaultQuestion;	
begin	
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	self.initialisePassportMachine();
	
	// Create the response
	create response transient;
	
	app.writeLog(method.qualifiedName, LogTRACE);	
	
	// Initialises user and checks request has valid headers deletes and recreates the passport
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	machine := app.myPassport.myMachine;
	machine.validateForVehicleApp(false);
	if app.myPassport.hasErrors then	
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;	
	
	foreach faultQuestion in machine.allCurrentFaultQuestions discreteLock do
		create wsFaultQuestion transient;
		wsFaultQuestion.setProxyFromObject(faultQuestion);
		response.allFaultQuesions.add(wsFaultQuestion);
		
	endforeach;
		
	return response;
epilog
	
	finaliseResponse(response);	
	return response;
end;
	
</source>
        <ReturnType type="WS_FaultQuestionsResponse"/>
    </JadeMethod>
    <JadeMethod name="getGrades" id="b3e0a5ad-c7a2-4bea-a9c8-6fa4e261f40c">
        <updating/>
        <source>getGrades(): WS_AvailabilityGradeResponse updating;
/*

Purpose:			

Parameters:			

