// 05/03/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
vars

begin
	//self.doTableCellInputReady(inputControl, table, cheight);						// PAR #31155
	self.doTableCellInputReady(table, inputControl, cleft, ctop, cwidth, cheight);	// PAR #31155
end;</source>
