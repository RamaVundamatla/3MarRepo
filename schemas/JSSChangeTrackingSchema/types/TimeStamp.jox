<PrimType name="TimeStamp">
    <JadeMethod name="formatAsYYYYMMDDHHMMSSMMM" id="b4a5a6b0-e7a4-4b2e-bf42-33c90fd7cdf3">
        <source>formatAsYYYYMMDDHHMMSSMMM() : String;
// ---------------------------------------------------------------------------
//27 Jul 2016	cnwrs1	Par 38030 C3 Data Extract loosing updates
// ---------------------------------------------------------------------------
vars

begin
	return self.date.format('yyyy-MM-dd') &amp; " " &amp; self.time.format('HH:mm:ss') &amp; "." &amp; self.time.milliSecond.String.padZeros(3);
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="truncateToSecond" id="4fea885a-d0d5-4daf-b061-70dcb5bab743">
        <source>truncateToSecond() : TimeStamp;
// ---------------------------------------------------------------------------
//27 Jul 2016	cnwrs1	Par 38030 C3 Data Extract loosing updates
// ---------------------------------------------------------------------------
vars
	timeToSecond: Time;
	timeStampToSecond : TimeStamp;
begin
	timeToSecond := self.time.truncateToSecond;
	timeStampToSecond.setDate(self.date);
	timeStampToSecond.setTime(timeToSecond);
	return timeStampToSecond;
end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
</PrimType>
