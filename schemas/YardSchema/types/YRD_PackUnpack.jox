    <JadeMethod name="addPackComplete" id="5b9c4f72-b738-41dc-a2f7-56428eaa33e6">
        <updating/>
        <source>addPackComplete(_packTIs : CM_TIArray)updating;
//29 April 2010	cnwml2


vars
	transPack 					: CM_TITransaction;
	transPackComplete 			: CM_TITransaction;
begin
	if self.myTerminal.getConfig(PromptForPackComplete).Boolean then
		//prompt for PackComplete transaction
		self.promptForPackComplete();
	else
		transPack := self.myTI.getLastTransOfType(TRANS_TYPE_PACK);
		if transPack &lt;&gt; null then
			transPackComplete := self.myTI.getLastTransOfType(TRANS_TYPE_PackComplete);
		endif;
		if transPack &lt;&gt; null and // we have a pack transaction
		   transPackComplete = null and // we dont have a pack complete trans
		   self.myTerminal.getConfig(PromptForPackComplete).Boolean then
			//prompt for PackComplete transaction
			self.promptForPackComplete();
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_packTIs" type="CM_TIArray"/>
    </JadeMethod>
    <JadeMethod name="addTblDataRow" id="fc9b6f11-5e32-4725-be81-6794098dcb3c">
        <source>addTblDataRow(_idx : Integer; _ti : CM_TrackedItem; _tbl : CM_DataTable input) : Integer protected;
// ---------------------------------------------------------------------------
// Created:     18 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
/*

Date		Who		Reason
06 Jul 2010	cnwkpd1	PAR #24795 - Tidy up notifications and performance of Pack/Unpack
29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
*/

vars
	theDataLine			: String;
	idx					: Integer;
begin
	if _tbl = null then
		return null;
	endif;
	
	theDataLine := _ti.getAttributeStringForDefArray(_tbl.allTblDataEntRows);
	
	if _idx &gt; 1 then
		_tbl.addItemAt(theDataLine, _idx);
		_tbl.accessRow(_idx).itemObject := _ti;
		idx := _idx;
	else
		idx := _tbl.addItem(theDataLine);
		_tbl.accessRow(idx).itemObject := _ti;
	endif;
	
//	self.endNotificationForSubscriber(_ti);		// PAR #24795 - removed, as TI is not registered to receive notes
	if not _ti.isTransient then
		self.armNotesForObject(_ti);
	endif;
	
	return idx;
	
end;</source>
        <access>protected</access>
        <Parameter name="_idx" type="Integer"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_tbl" type="CM_DataTable" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="97fde4fe-0af8-4b40-bc31-e4b00c99953b">
        <updating/>
        <source>addToolbarControls() updating, protected;
// ---------------------------------------------------------------------------
// Created:     16 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// 26/08/2010	cnwdap1		PAR #23925 CCMS MES 1076 Add new "Filter Bookings" button
// 20/06/2015	cnwdap1		PAR #36421 Hazardous Materials Handling
// 04 Oct 2022 navtnr20 ChangeRequest 54967: EUP - INB/OUT - Operational Instructions
vars
	queryToolbar,
	frm			: CMUI_Toolbar;
begin
	frm := self.frmToolbar;
	frm.addFrame(self.frmOptions, CMUI_Toolbar.Control_Alignment_Right);
	inheritMethod();
	queryToolbar := self.frmQueryToolbar;
	
	frm.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
		
	frm.addButton(self.btnShowSearcher, CMUI_Toolbar.Control_Alignment_Left);
	if app.getMyUser().canDo(self.myTerminal, PmAdmSelectorView) then
		frm.addButton(self.btnSelector, CMUI_Toolbar.Control_Alignment_Left);
	endif;
	
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnCreateLCL, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnMakeLCL, CMUI_Toolbar.Control_Alignment_Left);
	if self.myTerminal.getConfig(UseDetailedHazEntry).Boolean then					// PAR #36421
		frm.addButton(self.btnMakeHaz, CMUI_Toolbar.Control_Alignment_Left);		// PAR #36421
	endif;																			// PAR #36421
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnPack, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnUnpack, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnRepack, CMUI_Toolbar.Control_Alignment_Left);
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);	
	
	// PAR #23925 CCMS MES 1076
	frm.addButton(self.btnFilterExport, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnInstruction, CMUI_Toolbar.Control_Alignment_Left);	//04.10.2022 navtnr20 TFS 54967
	queryToolbar.showCaptions := false;
	queryToolbar.addButton(self.btnSearch, CMUI_Toolbar.Control_Alignment_Left);
	queryToolbar.addButton(self.btnReset, CMUI_Toolbar.Control_Alignment_Left);
	queryToolbar.addButton(self.btnSelectorQuery, CMUI_Toolbar.Control_Alignment_Left);
	queryToolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	queryToolbar.addButton(self.btnHideSearcher, CMUI_Toolbar.Control_Alignment_Left);
	
	queryToolbar.positionToolbarControls();
	queryToolbar.visible := true;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="addUnpackComplete" id="a30df79d-13c0-4d4b-a6c4-590e41900885">
        <updating/>
        <source>addUnpackComplete(_unpackTIs : CM_TIArray)updating;
//29 April 2010	cnwml2


vars
	transPack 					: CM_TITransaction;
	transPackComplete 			: CM_TITransaction;
begin
	if self.myTerminal.getConfig(PromptForPackComplete).Boolean then
		//prompt for Unpack Complete transaction
		self.promptForUnpackComplete();
	else
		// cnwrs1 Feb 2007 Par 13397
		transPack := self.myTI.getLastTransOfType(TRANS_TYPE_UNPACK);
		if transPack &lt;&gt; null then
			transPackComplete := self.myTI.getLastTransOfType(TRANS_TYPE_UnpackComplete);
		endif;
		if transPack &lt;&gt; null and // we have a unpack transaction
		   transPackComplete = null and // we dont have a unpack complete trans
		   self.myTerminal.getConfig(PromptForPackComplete).Boolean then
			//prompt for PackComplete transaction
			self.promptForUnpackComplete();
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_unpackTIs" type="CM_TIArray"/>
    </JadeMethod>
    <JadeMethod name="areChangesSaved" id="227495e3-e83c-4bd5-9d54-a63c5f9c3eb1">
        <source>areChangesSaved(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who			Reason
06 Apr 2024 navnk30 	Bug 63247: EUP Testing | Container Weights not updated when Making New LCL

*/

vars
	updatedWeight	: Decimal[14,4];
	ti				: CM_TrackedItem;
	savedChildren	: CM_TISet;
begin
	if self.myTI = null then
		return true;
	endif;
	savedChildren := self.myTI.allChildren;
	if self.allPackedItems.size() &lt;&gt; savedChildren.size() then
		return false;
	endif;
	updatedWeight := self.tblContainer.getMeasurementValueByName(ETRow_WeightTotal).Decimal;
	if self.myTI.totalWeight &lt;&gt; updatedWeight then
		return false;
	endif;
	foreach ti in self.allPackedItems do
		if not savedChildren.includes(ti) then
			return false;
		endif;
	endforeach;
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="armNotesForObject" id="f8f60fba-4f32-446e-bff6-7c6f34dd7491">
        <source>armNotesForObject(_obj : Object);
//********************************************************************
//
// Created by: cnwsh3
//
// Date: 29 January 2004
//
//********************************************************************
/*

Date		Who		Reason
06 Jul 2010	cnwkpd1	PAR #24795 - Tidy up notifications and performance of Pack/Unpack

*/

vars
		
begin
	self.beginNotification(_obj, Any_System_Event, Response_Continuous, 0);
	if _obj.isKindOf(CM_TrackedItem) then
		self.allNotifiedTIs.addNoDuplicates(_obj.CM_TrackedItem, false);
	endif;
	
end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="assignContainerDetails" id="30ec9c54-1ae1-4ba6-a62a-a6ec79d43354">
        <updating/>
        <source>assignContainerDetails(_ti : CM_TrackedItem; _contRange : CM_ContRange) : Boolean protected, updating;
// ---------------------------------------------------------------------------
// Created:     02 December 2003	cnwth2
//
// Purpose:     TI passed in is the TI we are getting the details FROM
//			 
// Changed On	By      	Reason
// ----------   -------- 	--------------------------------------------------
// 09/04/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
// 06/09/2013	cnwdap1		PAR #31196 Don't change parent container to MT just because child may be
//							Don't change voyage of parent container if child's voyage is the null voyage
// 09/04/2015	cnwdap1		PAR #35951 Change the form's imex status to Export if packing an Export item into a Storage container
//							Changed this method to updating to accomplish this
// 12/06/2025	navcs2		MTN-34953 MSL -- Incorrect cargo and total weight when a cargo item is pre-notified, gated in and then packed on a flat rack container
// 20 Nov 2025	navah1		MTN-36555: STWO - Incorrect Total Weight Calculation for MAFI When Packing Multiple Cargo Items
vars
	cargoVolume,
	totalVolume,
	maxVolume		: Decimal[16,4];
	contWeight 		: Decimal[14,4];
	cargoWeight		: Decimal[14,4];
	voy				: CM_Voyage;
	tmpConsign		: CM_ConsigneeConsignor;
	tmpPort			: CM_Port;
	tiParent		: CM_TrackedItem;
	tmpExpBooking	: CM_BookingRef;
	rowName			: String;						// PAR #31155
	weightDefault	: String;						// PAR #31155
	volumeDefault	: String;						// PAR #31155
	row				: Integer;						// PAR #31155
	value			: String;						// PAR #31155
	volumeSuffix	: String;
	commodityCode	: String;						// cnwmc5 - 6 August 2014 - PAR 34412
	
begin
	weightDefault := app.getDefaultMeasurementForType(Type_Weight).shortName;						// PAR #31155
	volumeDefault := app.getDefaultMeasurementForType(Type_Volume).shortName;						// PAR #31155
	
	if (not self.isUsedForRepack) and self.myTI &lt;&gt; null then
		//20.11.2025 navah1 #MTN-36555  - Start
		/*
		//contWeight := self.tblContainer.getValueByName(ETRow_WeightTotal).Decimal;				// PAR #31155
		contWeight := self.myTI.totalWeight;														// PAR #31155	// 12/06/2025 navcs2	MTN-34953
		//contWeight := contWeight + _ti.totalWeight;			//+cnwml2 MSL CCMS 1017
		//cargoWeight := self.tblContainer.getValueByName(ETRow_CargoWeight).Decimal;				// PAR #31155
		cargoWeight := self.myTI.weightCargo;														// PAR #31155	// 12/06/2025 navcs2	MTN-34953
		cargoWeight := cargoWeight + _ti.totalWeight;
		*/ 
		cargoWeight := self.tblContainer.getMeasurementValueByName(ETRow_CargoWeight).Decimal;
		cargoWeight := cargoWeight + _ti.totalWeight;
		contWeight := self.tblContainer.getMeasurementValueByName(ETRow_WeightTotal).Decimal;
		contWeight := contWeight + _ti.totalWeight;
		//20.11.2025 navah1 #MTN-36555 - End
		
		//cargoVolume := self.tblContainer.getValueByName(ETRow_Volume).String.asDecimalJMT();	// ** to manage ITALIAN locale #25592 17/11/2010
		cargoVolume := self.tblContainer.getMeasurementValueByName(ETRow_Volume).Decimal;			// PAR #31155
		cargoVolume := cargoVolume + _ti.getMyTotalVolume;
		//totalVolume	:= self.tblContainer.getValueByName(ETRow_ContainerVolume).String.asDecimalJMT();	// ** #25592 17/11/2010, this is container volume, i.e. actual volume of iron box.
		totalVolume	:= self.tblContainer.getMeasurementValueByName(ETRow_ContainerVolume).Decimal;	// PAR #31155
	else
		contWeight	:= _ti.totalWeight;						//+cnwml2 MSL CCMS 1017
		cargoVolume := _ti.getMyCargoVolume;	// #25592 18/11/2010 for containers totalVoluem reflects cargo volume (for general cargo volume = total Volume) **
		totalVolume		:= _ti.getMyTotalVolume;		// #25592 18/11/2010 for containers it is container volume. We need thisa for validation. **
	endif;
	
	tiParent := self.myTI;	// ** #25592 18/11/2010
	
	if _contRange &lt;&gt; null then
		// PAR 20310 - make sure maxKilos is valid 
		if _contRange.maxKilos &gt; 0 and contWeight &gt; _contRange.maxKilos then
			if not self.generateWarning(WARNING_OVER_WEIGHT, _ti) then
				return false;
			endif;
		endif;
	
		/*  ** commented by #25592 17/11/2010
		// PAR 20310 - make sure cubicMetres is valid 
		if _contRange.cubicMetres &gt; 0 and cargoVolume &gt; _contRange.cubicMetres then
			if not self.generateWarning(WARNING_OVER_VOLUME, _ti) then
				return false;
			endif;
		endif;	*/
	endif;
	
	// ** 25592 17/11/2010. Generating over volume warnings for a user.
	if	tiParent.isKindOf(CM_Container) then
		
	//	if cargoVolume &gt; totalVolume then	// for containers, if cargo volume &gt; container volume, raise a warning for a user.
		if totalVolume &gt; 0 and cargoVolume &gt; totalVolume then	//18 Oct 2012	NDL Par 30520
			if not self.generateWarning(WARNING_OVER_VOLUME, _ti) then
				return false;
			endif;
		endif;

		maxVolume := tiParent.CM_Container.getMaxVolume();
		if (maxVolume &gt; 0) and (totalVolume &gt; maxVolume) then	//for containers, if container volume &gt; max container volume, raise a warning for a user.
			//if not self.generateWarning(WARNING_OVER_VOLUME &amp; 'MAX', _ti) then this is for 7.8.2 hotfix
			if not self.generateWarning(WARNING_OVER_VOLUMEMAX, _ti) then
				return false;
			endif;
		endif;
		
	endif;

	
	if _ti.operatorCode.trimBlanks &lt;&gt; self.myTI.operatorCode.trimBlanks then
		if not self.generateWarning(WARNING_DIFFERENT_OPERATOR, _ti) then
			return false;
		endif;
	endif;
	
	//+cnwml2 PAR24740
	if _ti.destinationPort &lt;&gt; self.myTI.destinationPort then
		if _ti.destinationPort &lt;&gt; null then
			if not self.generateWarning(WARNING_DIFFERENT_DESTINATION, _ti) then
				return false;
			endif;
		endif;
	endif;
	
	if self.myTI.isKindOf(CM_Container) then
		if self.isUsedForRepack and (_ti.CM_Container.isoType &lt;&gt; self.myTI.CM_Container.isoType) then
			if not self.generateWarning(WARNING_DIFFERENT_ISOTYPE, _ti) then
				return false;
			endif;
		endif;
	endif;
	
	if contWeight &lt; 0 then
		contWeight := 0;
	endif;
	//self.tblContainer.setValueByName(ETRow_WeightTotal,contWeight.asStringWeightJMT());			// PAR #31155
	rowName := Prefix_Weight &amp; ETRow_WeightTotal &amp; "_" &amp; weightDefault;								// PAR #31155
	value := app.convertMeasurementForDisplay(weightDefault, contWeight) &amp; Space &amp; weightDefault;	// PAR #31155
	row := self.tblContainer.getRow(rowName);														// PAR #31155
	self.tblContainer.setValueByName(rowName, value);												// PAR #31155
	self.tblContainer.accessCell(row, self.tblContainer.ColumnValue).cellControl.CMUI_MeasurementTable.setValues(value);	// PAR #31155
	
	if cargoWeight &lt; 0 then
		cargoWeight := 0;
	endif;
	//self.tblContainer.setValueByName(ETRow_CargoWeight,cargoWeight.asStringWeightJMT());			// PAR #31155
	rowName := Prefix_Weight &amp; ETRow_CargoWeight &amp; "_" &amp; weightDefault;								// PAR #31155
	value := app.convertMeasurementForDisplay(weightDefault, cargoWeight) &amp; Space &amp; weightDefault;	// PAR #31155
	row := self.tblContainer.getRow(rowName);														// PAR #31155
	self.tblContainer.setValueByName(rowName, value);												// PAR #31155
	self.tblContainer.accessCell(row, self.tblContainer.ColumnValue).cellControl.CMUI_MeasurementTable.setValues(value);	// PAR #31155
	
	if cargoVolume &lt; 0 then
		cargoVolume := 0;
	endif;
	// 33768 get the measurement type the same way as the table setup in CM_BaseForm::loadMeasurementTypes
	//volumeSuffix := _ti.getMeasurementSuffixForRow(ETRow_Volume);
	volumeSuffix := tiParent.getMeasurementSuffixForRow(ETRow_Volume); // 33768 
	if volumeSuffix = null then
		volumeSuffix := volumeDefault;
	endif;
	//self.tblContainer.setValueByName(ETRow_Volume, cargoVolume);  // PAR 27868					// PAR #31155
	rowName := Prefix_Volume &amp; ETRow_Volume &amp; "_" &amp; volumeSuffix;									// PAR #31155/33768
	value := app.convertMeasurementForDisplay(volumeDefault, cargoVolume) &amp; Space &amp; volumeDefault;	// PAR #31155
	row := self.tblContainer.getRow(rowName);														// PAR #31155
	self.tblContainer.setValueByName(rowName, value);												// PAR #31155
	self.tblContainer.accessCell(row, self.tblContainer.ColumnValue).cellControl.CMUI_MeasurementTable.setValues(value);	// PAR #31155
	
	if totalVolume &lt; 0 then
		totalVolume := 0;
	endif;
	//if self.tblContainer.getValueByName(ETRow_VolumeTotal).String.asDecimalJMT() = 0 then
	//	self.tblContainer.setValueByName(ETRow_VolumeTotal, totalVolume);  // PAR 27868				// PAR #31155
	//endif;
	rowName := Prefix_Volume &amp; ETRow_VolumeTotal &amp; "_" &amp; volumeDefault;								// PAR #31155
	value := app.convertMeasurementForDisplay(volumeDefault, totalVolume) &amp; Space &amp; volumeDefault;	// PAR #31155
	row := self.tblContainer.getRow(rowName);														// PAR #31155
	self.tblContainer.setValueByName(rowName, value);												// PAR #31155
	self.tblContainer.accessCell(row, self.tblContainer.ColumnValue).cellControl.CMUI_MeasurementTable.setValues(value);	// PAR #31155

	//+cnwml2 PAR26046
	tmpConsign := app.myRoot.allConsigneeConsignors[_ti.consignee];
	if tmpConsign &lt;&gt; null then
		self.cmbConsignee.setObject(tmpConsign);
		self.tblContainer.setValueByName(ETRow_Consignee, tmpConsign.code);
	endif;

	//+cnwml2 PAR26046
	tmpConsign := app.myRoot.allConsigneeConsignors[_ti.consignor];
	if tmpConsign &lt;&gt; null then
		self.cmbConsignor.setObject(tmpConsign);
		self.tblContainer.setValueByName(ETRow_Consignor, tmpConsign.code);
	endif;
	
	if not self.myTerminal.getConfig(OnPackConfirmOpOverride).Boolean then					//+cnwml2 PAR22531
		if _ti.myOperator &lt;&gt; null then
			self.cmbOperatorRight.setIndexFromObject(_ti.myOperator);
			self.tblContainer.setValueByName(ETRow_OperatorRight, _ti.myOperator.code);
		endif;
			
		voy := self.myTerminal.lookupVoyage (_ti.voyageCode, null, false);
		//if voy &lt;&gt; null then																						// PAR #31196
		if voy &lt;&gt; null and voy &lt;&gt; self.myTerminal.getNullVoyage then												// PAR #31196
			self.cmbVoyageRight.listObject := voy;
			self.tblContainer.setValueByName(ETRow_VoyageRight, voy.code);
		endif;
		
		tmpPort := app.myRoot.allPorts[_ti.dischargePort];		//+cnwml2 PAR22531
		if tmpPort &lt;&gt; null then
			self.cmbDisPortRight.setIndexFromObject(tmpPort);
			//cnwjo3 par 24163
			//self.cmbDisPortRight.setObject(tmpPort);
			self.tblContainer.setValueByName(ETRow_DisPortRight, tmpPort.code);//Par 12953
		endif;
		
		//+cnwml2 PAR24740
		tmpPort := app.myRoot.allPorts[_ti.destinationPort];		
		if tmpPort &lt;&gt; null then
			self.cmbDestPortRight.setIndexFromObject(tmpPort);
			self.tblContainer.setValueByName(ETRow_DestinationPortRight, tmpPort.code);
		endif;
		
		//self.tblContainer.setValueByName(ETRow_Consignor, self.cmbConsignor.text);			//this should be unneccesary
	endif;

	// 05 May 2015	NDL	Par 36160 - remove "SuppressImexUpdateOnPack" check
//	if not self.myTerminal.getConfig(SuppressImexUpdateOnPack).Boolean then		// 02/03/2009 cnwar2 #18775 - new config to prevent auto updating of imex or commodity
		// PAR #31196 Don't change the parent container's commodity to MT if that's what the child cargo is			// PAR #31196
		if _ti.commodity &lt;&gt; null and _ti.commodity &lt;&gt; self.myTerminal.getDefaultEmptyCommodity then					// PAR #31196
			commodityCode := _ti.commodity;
		elseif _ti.commodity = null																					// cnwmc5 - 6 August 2014 - PAR 34412
		and (self.cmbCommodity.listObject = null 																	// cnwmc5 - 6 August 2014 - PAR 34412
		or self.cmbCommodity.listObject = app.myRoot.allCommodities[self.myTerminal.getDefaultEmptyCommodity]) then	// cnwmc5 - 6 August 2014 - PAR 34412
			commodityCode := self.myTerminal.getConfig(DefCommodity).String;										// cnwmc5 - 6 August 2014 - PAR 34412
		endif;																										// cnwmc5 - 6 August 2014 - PAR 34412
	
		if commodityCode &lt;&gt; null then																				// cnwmc5 - 6 August 2014 - PAR 34412
			self.cmbCommodity.setObject(app.myRoot.allCommodities[commodityCode]);									// cnwmc5 - 6 August 2014 - PAR 34412
			self.tblContainer.setValueByName(ETRow_Commodity, self.cmbCommodity.text);								// cnwmc5 - 6 August 2014 - PAR 34412
		endif;																										// cnwmc5 - 6 August 2014 - PAR 34412
		
		// PAR #31196 If packing a Tranship item in to a Storage container, change Storage container to Tranship	// PAR #31196
		if _ti.isTranshipItem and tiParent.isStorage then															// PAR #31196
			self.cmbImEx.setIndexFromObject(app.myRoot.allImexStatuses[TI_IMEX_STATUS_TRANSHIP]);					// PAR #31196
			self.tblContainer.setValueByName(ETRow_ImexStatus, self.cmbImEx.text);									// PAR #31196	
		endif;																										// PAR #31196
		
		// PAR #35951 if packing an Export item into a Storage container, set the current imex status to Export		// PAR #35951
		if _ti.isExport and self.myTI.isStorage then																// PAR #35951
			self.theTIimexStatus := TI_IMEX_STATUS_EXPORT;															// PAR #35951
		endif;																										// PAR #35951
//	endif;

	// #26726 14/01/2011. If stock booking has linked export booking but container has no export booking selected, then raise a warning for a user.
	if ( _ti.myBookingRefItem &lt;&gt; null ) and ( not _ti.myBookingRefItem.allLinkedExportBookings.isEmpty() ) then
		tmpExpBooking := self.cmbBooking.listObject.CM_BookingRef;
		if (tmpExpBooking = null) or (not _ti.myBookingRefItem.allLinkedExportBookings.includes(tmpExpBooking)) then
			if not self.generateWarning(WARNING_NO_EXPORT_BOOKING, _ti) then
				return false;
			endif;
		endif;
	endif;
	
	return true;
	
end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_contRange" type="CM_ContRange"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
