    <JadeMethod name="getAuditText" id="08a1c036-3d38-4c66-8900-33f5c77ad4ab">
        <source>getAuditText(): String;
// ---------------------------------------------------------------------------
// Created:     11 June 2007 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
// 03/11/2009	cnwmh5		PAR18267 - Remove test for tmpStr = null as wasn't 
//									   putting the objects value in the string
//									   used for comparision in before and after
// 02/06/2023	navra1		TFS 58278 - EUP - Prevent Automatic EDI DB Load
// ---------------------------------------------------------------------------
vars
	
	status,
	mtnStatus,
	inUse,
	txt		 : String;
	tmpStr	 : String;
	cBOLType : CM_CargoBOLType;
	stData   : CM_StateData;
	stObj    : CM_StateObject;
	voyage : CM_Voyage;
	calendar : CM_Calendar;
	stateValue : CM_Object;
	invalidObject : Boolean;
	idx,
	edition : Integer;
	ioClass : CM_ExtFinanceIO;	//10 Mar 2020	NDL	TFS 48407
	nameValuePair	:	CM_NameValuePair;	//navra1 - TFS 58278 - 2nd June 2023
	
begin
	txt[10000] := '*';
	txt := null;
	txt := inheritMethod();
	
	foreach cBOLType in self.allCargoBOLTypes do
		if tmpStr = null then
			tmpStr := cBOLType.description;
		else
			tmpStr := tmpStr &amp; ', ' &amp; cBOLType.description;
		endif;
	endforeach;

	txt := txt &amp; "Cargo BOL Types Selected " &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	
	on Exception do app.handleDeletedObject(exception,stateValue,invalidObject);
	
    tmpStr := null ;
	foreach stObj in self.allStateObjects do
		foreach stData in stObj.allStateData do
			///if tmpStr = null then								// 03/11/2009 cnwmh5 PAR18267
				if stData.isKindOf(CM_StateBinary) then
					tmpStr := stData.CM_StateBinary.value.String;
				elseif stData.isKindOf(CM_StateDecimal) then 
					tmpStr := stData.CM_StateDecimal.value.String;
				elseif stData.isKindOf(CM_StateInteger) then
					tmpStr := stData.CM_StateInteger.value.String;
				elseif stData.isKindOf(CM_StateReal) then
					tmpStr := stData.CM_StateReal.value.String;
				elseif stData.isKindOf(CM_StateString) then
					tmpStr := stData.CM_StateString.value;
				elseif stData.isKindOf(CM_StateReference) then
					if stData.CM_StateReference.myValue &lt;&gt; null then
						stateValue:=stData.CM_StateReference.myValue;
						edition:=stateValue.edition;
						if invalidObject then
							invalidObject:=false;
							continue;
						endif;
						if stData.CM_StateReference.myValue.isKindOf(CM_Bank) then 
							tmpStr := stData.CM_StateReference.myValue.CM_Bank.code;
						elseif stData.CM_StateReference.myValue.isKindOf(CM_VoidDebtor) then
							tmpStr := stData.CM_StateReference.myValue.CM_VoidDebtor.name;
						elseif stData.CM_StateReference.myValue.isKindOf(CM_ISOType) then
							tmpStr := stData.CM_StateReference.myValue.CM_ISOType.code;
						elseif stData.CM_StateReference.myValue.isKindOf(CM_Operator) then
							tmpStr := stData.CM_StateReference.myValue.CM_Operator.code;
						elseif stData.CM_StateReference.myValue.isKindOf(CM_Stevedore) then
							tmpStr := stData.CM_StateReference.myValue.CM_Stevedore.code;
						elseif stData.CM_StateReference.myValue.isKindOf(CM_Voyage) then
							tmpStr := stData.CM_StateReference.myValue.CM_Voyage.code;
						elseif stData.CM_StateReference.myValue.isKindOf(CM_DefaultFinanceIO)then
							tmpStr := stData.CM_StateReference.myValue.CM_DefaultFinanceIO.getNiceName; // PAR 33572
						elseif stData.CM_StateReference.myValue.isKindOf(CM_ToDoTaskDesc)then
							tmpStr := stData.CM_StateReference.myValue.CM_ToDoTaskDesc.shortDescription;
						endif;	
					endif;
				elseif stData.isKindOf(CM_StateStringArray) then
		//			tmpStr := stData.CM_StateStringArray.valueArray.asCSV(false);
				else
					tmpStr := tmpStr &amp; ', ' &amp; stData.getValue().String;
				endif;
			///endif;											// 03/11/2009 cnwmh5 PAR18267
		    txt := txt &amp; stData.key &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
		endforeach;
	endforeach;
	
	calendar := self.getMyHolidayCalendar;	//29 Oct 2010 NDL	Par 25530
	if calendar &lt;&gt; null then
		txt := txt &amp; 'Calendar for Invoicing ' &amp; AuditStringSeparator &amp; calendar.code.length.String &amp; AuditStringSeparator &amp; calendar.code &amp; AuditStringSeparator;
	endif;
//	foreach voyage in self.allVoyagesSet do
//		txt := txt &amp; 'Voyage ' &amp; AuditStringSeparator &amp; voyage.code.length.String &amp; AuditStringSeparator &amp; voyage.code &amp; AuditStringSeparator;
//	endforeach;
	
	//10 Mar 2020	NDL	TFS 48407
	ioClass := self.getConfig(FinancialIOClass).CM_ExtFinanceIO;
	if ioClass &lt;&gt; null then
		txt := txt &amp; ioClass.getTerminalAuditText();
	endif;
	
	//17/11/2025	navkc1 JIRA 36176
	tmpStr := null;
	foreach nameValuePair in self.allOnePortStatuses do
		status := nameValuePair.name;
		idx := 1;
		mtnStatus := app.movementStatusNumToString(nameValuePair.value.scanUntil("|", idx).Integer);
		
		inUse := "Not Used";
		if nameValuePair.value.endsWith("|1") then
			inUse := "Used";
		endif;
		
		tmpStr := tmpStr &amp; status &amp; " - " &amp; mtnStatus &amp; ' - ' &amp; inUse &amp; CrLf;
	endforeach;
	txt := txt &amp; "OnePort Statuses " &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	
	//navra1 - TFS 58278 - 2nd June 2023 - begin
	tmpStr := null;
	
	foreach nameValuePair in self.allDBLoadOptions do
		tmpStr := tmpStr &amp; nameValuePair.name &amp; ',' &amp; nameValuePair.value &amp; ',' &amp; CrLf;
	endforeach;
	
	//update in text to be returned
	txt := txt &amp; 'Edi Processing Configuration' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;	
	//navra1 - TFS 58278 - 2nd June 2023 - end
	
	return txt;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
