    <JadeMethod name="getCode" id="a173de5d-8e70-4643-8fdd-0afd8ccdcd8a">
        <source>getCode(): String;
/*
Purpose:	

Date		Who		Reason
10 March 2025	navab1	JIRA 34233
*/

vars

begin
	if self.myReceivalCutoffTermDef= null then
		return null;
	endif;
	
	return self.myReceivalCutoffTermDef.code;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOperatorCode" id="8dc4a666-e172-4540-984c-ba44202e11c5">
        <source>getOperatorCode() : String;
/*
Purpose:	

Date		Who		Reason
10 March 2025	navab1	JIRA 34233
*/

vars

begin
	if self.myOperatorTerminal&lt;&gt; null then
		return self.myOperatorTerminal.myOperator.code;
	endif;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
