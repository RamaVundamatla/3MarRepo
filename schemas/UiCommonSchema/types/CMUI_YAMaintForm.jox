    <JadeMethod name="doEditCriteria" id="4d3efd1f-85a6-4b27-be9c-ad6e8ebf4fa2">
        <updating/>
        <source>doEditCriteria() updating;

/*

Purpose:		Display form for editing criteria ex template

Parameters:			

Return Value:		


Date			Who		Reason
18 August 2008	consw1	Initial creation

*/

vars
	theForm 		: CMUI_YACriteriaMaintForm;
begin

	theForm := app.loadForm(CMUI_YACriteriaMaintForm, CMUI_Assistant, false, false, true, self.myTerminal, null).CMUI_YACriteriaMaintForm;
	if theForm = null then
		return;
	endif;

	theForm.setTemplateCriteria( self.allTemplateCriteria );
	
	// have to refresh the operational criteria here before showing the  maint form as the main form could have new values.
	self.doRefreshOperationalCriteria();// cnwrd1 par 19091 17.3.09
	
	theForm.setOperationalCriteria(self.allOperationalCriteria);
	theForm.setVoyages(self.allVoyages);

	theForm.setParentForm(self);
	theForm.showModal();
	
	if theForm.modalResult = IDOK and theForm.isModified then
		self.allTemplateCriteria.purge();
		theForm.getTemplateCriteria( self.allTemplateCriteria );
		self.allOperationalCriteria.purge();
		theForm.getOperationalCriteria( self.allOperationalCriteria );
		self.populateCriteriaFrames(true);
		self.isTemplateModified := true;
		self.displayCriteriaDesc();
	endif;
	
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="doFindImex" id="597d2206-6d29-45cc-a003-2f17b782ddeb">
        <updating/>
        <source>doFindImex() updating;
//26 February 2009	cnwdw1	
//
vars
	theForm 		: CMUI_YACriteriaSelectForm;
	imexStatus: CM_IMEXStatus;
	value: String;
begin
	theForm := app.loadForm(CMUI_YACriteriaSelectForm, CMUI_Assistant, false, false, true, self.myTerminal, null).CMUI_YACriteriaSelectForm;
	if theForm = null then
		return;
	endif;

	imexStatus := self.cmbIMEX.listObject.CM_IMEXStatus;
	
	if self.cmbIMEX.visible then  //cmbImex is visible, there is only one IMEX selected
		value := imexStatus.abbreviation;
	else
		value := self.txtImex.text;   //cmbImex is invisible, there are multiple IMEX selected							//+cnwml2 PAR22042
	endif;
	theForm.set(app.myRoot.allYACriteriaTypes[YACriteriaType_ImexStatus], value, null, 0,  self.frmCriteria);	//cnwmc5 - PAR 32155
	theForm.setParentForm(self);
	theForm.showModal();
	
	if theForm.modalResult = IDOK then
		if theForm.criteriaValue.pos(",", 1) &gt; 0 then
			// Multiple Imex status selected
			self.txtImex.visible := true;
			self.txtImex.text := theForm.criteriaValue;
			self.cmbIMEX.visible := false;
			//self.cmbIMEX.setIndexFromObject(app.myRoot.allImexStatuses[TI_IMEX_STATUS_NULL]);					//-cnwml2 PAR22042
		else
			foreach imexStatus in app.myRoot.allImexStatuses do
				if theForm.criteriaValue = imexStatus.abbreviation then
					self.cmbIMEX.setIndexFromObject(imexStatus);
					self.cmbIMEX.visible := true;
					self.txtImex.visible := false;
				endif;
			endforeach;
		endif;
		self.doIMEXSelected();
	endif;

epilog
	delete theForm;
end;</source>
    </JadeMethod>
    <JadeMethod name="doIMEXSelected" id="4d5e7657-f067-4eaf-9e76-06e609e9812e">
        <updating/>
        <source>doIMEXSelected() updating;
//04 August 2008	cnwdw1	
//20 May 2010		cnwdap1		CCMS 1116 Tranship changes
vars
	imex : CM_IMEXStatus;
	yaIMEXConfig	: CM_YAIMEXConfig;
	criteriaType: CM_YACriteriaType;
	opCriteria: CM_YACriteriaArray;
	criteria, proxyCriteria: CM_YACriteria;
	allCriteria				: CMIF_Array;
	tmpObjectSet			: ObjectSet;
	transientObj			: CMIF_YACriteriaPriority;

	strArray				: StringArray;
	str						: String;
begin
	self.allOperationalCriteria.purge();
	self.allTemplateCriteria.purge();
	imex := self.cmbIMEX.listObject.CM_IMEXStatus;
	
	//epr par 19/3/09 19078,
	if self.myYardAllocation = null and self.myTrackedItem &lt;&gt; null then
		//have to get all the possible criteria for the failed ti
		create allCriteria transient;
		create tmpObjectSet transient;
		
		self.myTrackedItem.setYardAllocationCriteriaAll(allCriteria, tmpObjectSet);
	endif;
	
	if not self.cmbIMEX.visible then
		if self.txtImex.text &lt;&gt; null then			//need an imex status, just get first one
			create strArray transient;
			strArray := self.txtImex.text.cnGetTokens(", ");
			foreach str in strArray do
				if str = "EXP" then
					imex := app.myRoot.allImexStatuses[TI_IMEX_STATUS_EXPORT];
					break;
				elseif str = "IMP" then
					imex := app.myRoot.allImexStatuses[TI_IMEX_STATUS_IMPORT];
					break;
				elseif str = "STO" then
					imex := app.myRoot.allImexStatuses[TI_IMEX_STATUS_STORAGE];
					break;
				//elseif str = "TRA" then											// PAR #23645 CCMS 1116
				elseif str = "ROB" then												// PAR #23645 CCMS 1116
					imex := app.myRoot.allImexStatuses[TI_IMEX_STATUS_REMAINONBOARD];
					break;
				elseif str = "TSH" then												// PAR #23645 CCMS 1116
					imex := app.myRoot.allImexStatuses[TI_IMEX_STATUS_TRANSHIP];	// PAR #23645 CCMS 1116
					break;															// PAR #23645 CCMS 1116
				endif;
			endforeach;
		endif;
	endif;
	

	if imex &lt;&gt; null and self.myTerminal.myYAConfig &lt;&gt; null then
		yaIMEXConfig := self.myTerminal.myYAConfig.allYAIMEXConfigs[imex.code];
		create opCriteria transient;
		if yaIMEXConfig &lt;&gt; null then
			foreach criteriaType in yaIMEXConfig.allOpCriteria do
				if self.myYardAllocation &lt;&gt; null then
					criteria := self.myYardAllocation.getCriteriaOfTypeValue(criteriaType.type);
				else
					//epr par 19078 19/3/09
					if allCriteria &lt;&gt; null and allCriteria.size &gt; 0 then
						criteria:=self.getCriteriaOfTypeFromTI(allCriteria,criteriaType.type);
					endif;
				endif;
				create proxyCriteria transient;
				if criteria = null then
					proxyCriteria.setProxy(criteriaType, "", "");			
				else
					proxyCriteria.setProxy(criteria.myYACriteriaType, criteria.myYAData.getDataValue(), criteria.code);
					opCriteria.add(criteria);
				endif;
				self.allOperationalCriteria.add( proxyCriteria.getTransient());
			endforeach;
			
			self.myDefaultConfigColourType := yaIMEXConfig.myDefaultColourType; //cnwrd1 ccms 2115 par 28185 12.9.2011
		else
			self.myDefaultConfigColourType := null; //cnwrd1 ccms 2115 par 28185 12.9.2011
		endif;
		
		
		
		if self.myYardAllocation &lt;&gt; null then
			foreach criteria in self.myYardAllocation.allCriteria do
				if not opCriteria.includes(criteria) and criteria.myYACriteriaType.type &lt;&gt; YACriteriaType_ImexStatus then
				//if criteria.myYACriteriaType.type &lt;&gt; YACriteriaType_ImexStatus then
					create proxyCriteria transient;
					proxyCriteria.setProxy(criteria.myYACriteriaType, criteria.myYAData.getDataValue(), criteria.code);
					self.allTemplateCriteria.add( proxyCriteria.getTransient() );
				endif;
			endforeach; 
		else
			// PAR 19421 no extra template criteria are defaulted
		endif;
		self.populateCriteriaFrames(true);
		self.setIMEXDefaultColour();
	endif;
	
	self.formatName(false);

epilog
	if allCriteria &lt;&gt; null then
		allCriteria.purge();
		delete allCriteria;
	endif;
	if tmpObjectSet &lt;&gt; null then
		delete tmpObjectSet;
	endif;
	delete opCriteria;
	delete strArray;
end;</source>
    </JadeMethod>
