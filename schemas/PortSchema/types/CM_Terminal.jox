    <JadeMethod name="getConfig" id="2cecead8-5de7-4f02-b3fd-5be333fda2d6">
        <source>getConfig( pCode : String ) : Any;
// ---------------------------------------------------------------------------
// Created:     11 July 2001 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

	logStr : String;
	any	: Any;

begin
	// Note: If you are getting CamsFileDirectory or EDIFileDirectory then use getConfig_FileDirectory method instead
	
	//19 Dec 2016	NDL	TFS 3129 - automatic conversion from Boolean to Integer;
	if pCode = HhTruckLoadScan then
		any := self.getStateData(ConfigGrp_System, pCode);
		if any.String = "true" then
			if app.myLoggingForm &lt;&gt; null then
				logStr := self.getConfigCodeNiceName(pCode, false);
				logStr := logStr &amp; " returned '1'";
				app.doFormLogging(method, logStr, null);
			endif;
			return 1;
		endif;
	endif;
	
	if app.myLoggingForm &lt;&gt; null then
		if pCode = null then
			logStr := "null";
		else
			logStr := self.getConfigCodeNiceName(pCode, false);
		endif;
		logStr := logStr &amp; " returned '" &amp; self.getStateData(ConfigGrp_System, pCode).String &amp; "'";
		app.doFormLogging(method, logStr, null);
	endif;
	
	return self.getStateData(ConfigGrp_System, pCode);
	
end;</source>
        <Parameter name="pCode" type="String"/>
        <ReturnType type="Any"/>
    </JadeMethod>
