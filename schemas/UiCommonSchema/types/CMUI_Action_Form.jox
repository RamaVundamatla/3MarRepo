    <JadeMethod name="doOptTicketClick" id="f92a2927-b123-4876-a634-b013450e13df">
        <updating/>
        <source>doOptTicketClick() updating;
// ---------------------------------------------------------------------------
// Created:     27 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars

begin
	self.allTrackedItems.clear();
	self.allDocketLocationHelpers.purge;
	
	self.selection := ITEMID;
	self.tblSelection.visible 	:= true;
	self.txtDetails.visible 	:= true;
	self.txtDetails.text := null;
	zClearSelectionDataTable();
	
	self.tblSelection.showHideRowsByViewName("SingleItemView", CM_EntryTable.ShowHideRows, false); 
	self.tblSelection.optimiseHeadingColumn();
	self.tblSelection.adjustHeight(1000);
	setDistances();
	self.resize();
	if cmbCargoType.listObject &lt;&gt; null then
		self.tblSelection.setValueByName(ETRow_CargoType, cmbCargoType.listObject.CM_CargoType.description);
	endif;
	if cmbOperator.listObject &lt;&gt; null then
		self.tblSelection.setValueByName(ETRow_MyOperator, cmbOperator.listObject.CM_Operator.code);
	endif;
	self.tblSelection.setValueByName(ETRow_Id, null);
	self.cmbTI.listObject := null;
	self.tblSelection.goToRowByName(ETRow_Id);
	self.tblSelection.setFocus;

end;</source>
