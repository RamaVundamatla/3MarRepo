    <JadeMethod name="setupForm" id="d857d7de-dc11-4a83-9005-25051f92797f">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			Sets up the form

Parameters:			NONE

Return Value:		NONE

Date			Who		Reason
07 October 2022	navpw1	Initial creation TFS: 54566

*/

begin
	self.useCtrlScroll					:= true;
	self.usesQueryFrame					:= true;
	self.useTableInfo					:= false;
	self.mnuContextColourLegend.visible	:= false;
	self.mnuColumnOrganiser.visible		:= false;
	
	self.frmToolbar.alignContainer		:= Frame.AlignContainer_Top; // this will make the dkcMain line up its top	
	self.toolbarStyle					:= self.ToolbarStyle_ShowNoHide;
	self.frmToolbar.priorityRight		:= true;
	self.showToolbar					:= true;
	self.setControlsForView();
	self.doCmbBankBuild();
	
	inheritMethod();
	
	self.frmProperties.zOrder(1);
	self.frmProperties.visible := false;
	
	if not app.defaultMdi then
		self.centreWindow;
	endif;
	
	self.fldQuery.topSheet := self.shtQuery1;
	
	self.positionQueryFrame();
	
	self.initTableData(ETDef_InvLineTypeMapping);
	self.doQuery();
	
	self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(EVENT_MAPPING_CREATE), Response_Continuous, null);
	self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(EVENT_MAPPING_DELETEOID), Response_Continuous, null);
	self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(EVENT_MAPPING_UPDATE), Response_Continuous, null);
	
	// cnwrl1 PAR 19324 default the navigation entry now.
	self.setNavigatorHeading( self.caption );
	
	// TFS 2734 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnEditItem.enabled:= false;
	endif;
	
	self.setMyCaption();
	
	self.tblData.multiSelect := CM_DataTable.MultiSelect_None;
	self.tblData.selectMode := Table.SelectMode_WholeRows;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="0f7c16c5-c9b0-4cc6-a6f4-b94a498c59d8">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 October 2022 08:06:56.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0025124, locale);
	btnAddItem.translateCaption(Xlat_0025125, locale);
	btnExportCSVMap.translateBubbleHelp(Xlat_0025126, locale);
	btnExportCSVMap.translateCaption(Xlat_0025127, locale);
	btnImportCSVMap.translateBubbleHelp(Xlat_0025128, locale);
	btnImportCSVMap.translateCaption(Xlat_0025129, locale);
	btnRefresh.translateBubbleHelp(Xlat_0025130, locale);
	btnRefresh.translateCaption(Xlat_0025131, locale);
	lblBank.translateCaption(Xlat_0025132, locale);
	lblBankProp.translateCaption(Xlat_0025133, locale);
	lblDebtor.translateCaption(Xlat_0025134, locale);
	lblInvoiceLineType.translateCaption(Xlat_0025135, locale);
	lblInvoiceType.translateCaption(Xlat_0025136, locale);
end;</source>
    </JadeMethod>
