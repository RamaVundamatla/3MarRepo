    <JadeMethod name="updateTranslations" id="3d1ca995-9273-4de2-9079-d68ecb441d18">
        <source>updateTranslations(_realTranslations: CM_KioskTranslationByLocale input;  _proxyTranslations : CM_KioskTranslationByLocale);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 August 2023	jlier1	Initial creation 58511

*/

vars
	pxyTranslation,
	realTranslation : CM_KioskTranslation;
	translationsToDelete :  ObjectSet;
begin
	create translationsToDelete transient;
	_realTranslations.copy(translationsToDelete);
	
	foreach pxyTranslation in _proxyTranslations do
		realTranslation := pxyTranslation.pxyGetRealObject.CM_KioskTranslation;
		if realTranslation = null then
			create realTranslation persistent;
			realTranslation.setForCreate(pxyTranslation.CM_KioskTranslation);
			_realTranslations.add(realTranslation);
		else
			realTranslation.setForUpdate(pxyTranslation.CM_KioskTranslation);
			translationsToDelete.remove(realTranslation);
		endif;
		
	endforeach;
	
	translationsToDelete.purge;
epilog
	delete translationsToDelete;
end;</source>
        <Parameter name="_realTranslations" type="CM_KioskTranslationByLocale" usage="input"/>
        <Parameter name="_proxyTranslations" type="CM_KioskTranslationByLocale"/>
    </JadeMethod>
</Class>
