    <JadeMethod name="updateToDoTasksForTI" id="f45130dd-41db-4ca7-a4d8-320ab437cc95">
        <source>updateToDoTasksForTI(	_form 			: JMMobileClient_BaseForm input;
						_toDoTaskSet	: ObjectSet input;
						_errorString	: String output;
						_state			: Integer output;
						_warnings		: Boolean io): Boolean;
// -------------------------------------------
// Created 30 January 2006 by cnwdvb1
// -------------------------------------------
vars

	packageDTO 		: MobileServerRTThin::DTO_EnquiryGradingTasks;
	rtnValue		: Boolean;
	mbToDoTask		: Object;
	dtoTask			: MobileServerRTThin::DTO_ToDoTask;

begin
	
	create packageDTO transient;

	self.clearStateObject();
	
	self.myStateObj.warningsAcknowledged := _warnings;
	
	foreach mbToDoTask in _toDoTaskSet do
		create dtoTask transient;
		mbToDoTask.MB_ToDoTask.translateToPackage(dtoTask);
		packageDTO.allToDoTasks.add(dtoTask);
	endforeach;
	
	rtnValue := self.myRTThinClientAgent.updateToDoTasksForTI(packageDTO, self.myStateObj);

	_errorString	:= self.myStateObj.errorString;
	_state			:= self.myStateObj.guiState;
	_warnings		:= self.myStateObj.hasWarningsOnly;
	
	if rtnValue then
		_form.loadFormFromThinClientObj(packageDTO);
	endif;

	return rtnValue;

epilog
	delete packageDTO;
end;</source>
        <Parameter name="_form" type="JMMobileClient_BaseForm" usage="input"/>
        <Parameter name="_toDoTaskSet" type="ObjectSet" usage="input"/>
        <Parameter name="_errorString" type="String" usage="output"/>
        <Parameter name="_state" type="Integer" usage="output"/>
        <Parameter name="_warnings" type="Boolean" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="userNotification" id="9902b8bb-090b-4b2e-81d9-965bcd7c30fa">
        <updating/>
        <source>userNotification(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// -------------------------------------------
// Created 24 January 2006 by cnwdvb1
// -------------------------------------------
vars

	dto	: MobileServerRTThin::DTO_StateInfo;

begin

	if eventType = MobileServerRTThin::RadioTelemetryThinClientAgent.Event_Server_Note and theObject = self.myRTThinClientAgent then
		dto := userInfo.MobileServerRTThin::DTO_StateInfo;
		self.myNotesObj.causeEvent(dto.guiState, true, dto.errorString);
	endif;

epilog
	delete dto;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</Class>
