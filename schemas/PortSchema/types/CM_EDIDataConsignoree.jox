    <JadeMethod name="getTIProperties" id="677cdf01-8db7-4b94-b5e1-40bba621e1f7">
        <source>getTIProperties( _propArray : ObjectArray io );

/*
Date				Who		Reason
19 February 2010	cnwrl1	Initial creation as part of PAR 21735 = CCMS 1068 (CR005) - EDI file load of Consignor/Consignee
*/
	
vars
	popColl		: PropertyNDict;
	property	: Property;
	
begin
	inheritMethod(_propArray);
	
	// now the sub-class properties
	popColl	:= CM_EDIConsignoreeTI.getProperties;
	
	foreach property in popColl do
		_propArray.add(property);
	endforeach;
end;
</source>
        <Parameter name="_propArray" type="ObjectArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="loadDB" id="d8c6048d-9bc3-41b3-8242-7e2d716c5c10">
        <updating/>
        <source>loadDB( _mergeCargo : Boolean; _passport : CM_Passport input ) updating;

/*
NOTE:		_mergeCargo - Only relevant when loading a Bay Plan.

Purpose:	To verify and database load the the EDI Data loaded for consignor and/or Consignee data.

Changes

Date		Name	TFS#		Description
============================================================================
19 Feb 2010	cnwrl1	Initial creation as part of PAR 21735 = CCMS 1068 (CR005) - EDI file load of Consignor/Consignee
21 Feb 2013	cnwrs1	Par 31143 	EDI TRX not handling dbLoadErrors after no verify errors take 3
13 May 2016	cnwns1	TFS 488  	Multi Timezone Support
03 Sep 2019 jlgka1 	TFS 45332 	STWR - Better Forms and Interfaces for EDI Module
20 Oct 2020	jlgmd1	TFS 50204	Refactor progress updates to superclass method
============================================================================*/
vars
	partsDone			: Integer;
	partsInJob			: Integer;
	progressStr			: String;
	progressTS			: TimeStamp;
	ediTI 				: CM_EDITrackedItem;
	passport			: CM_Passport;
	terminal			: CM_Terminal;
	allAddConsignorees	: CM_ConsignArray;
	allUpdConsignorees	: CM_ConsignArray;
	allDelConsignorees	: CM_ConsignArray;
	pxyConsignObj		: CM_ConsigneeConsignor;
	realConsignObj		: CM_ConsigneeConsignor;
	ediConsignTI		: CM_EDIConsignoreeTI;
	
begin
	// Arm our base exception handlers
	on Exception do validationExceptionHandler(exception, app.myPassport);
	app.setContinueCMExceptions(true);	// get as many error messages in 1 go as possible
	
	passport	:= _passport;
	partsInJob	:= self.allEDITrackedItems.size();
	partsDone	:= null;
	terminal	:= self.getMyTerminal();
	
	if terminal = null then
		// should never happen but just in case!
		app.raiseCMException1(Err_InvalidTerminal, null, null, null);
		return;
	endif;
	
	progressStr	:= app.getString(Loading_EDI_Data_Total, partsInJob.display);
	progressTS	:= app.actualTimeServer();// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	self.updateProgress(progressTS, progressStr, partsInJob, partsDone, true, passport);
	
	create allAddConsignorees transient;
	create allUpdConsignorees transient;
	create allDelConsignorees transient;
	
	foreach ediTI in self.allEDITrackedItems do
		partsDone			:= partsDone + 1;
		self.updateProgress(progressTS, progressStr, partsInJob, partsDone, false, passport);
		
		//self.zLoadDB(ediTI.CM_EDIConsignoreeTI, passport);
		
		ediConsignTI	:=	ediTI.CM_EDIConsignoreeTI;
		realConsignObj	:=	app.myRoot.allConsigneeConsignors[ediConsignTI.code];
		
		if realConsignObj = null then
			if ediTI.messageMode = CM_EDITrackedItem.EDI_ACTION_DELETE then
				continue;
			endif;
			
			create pxyConsignObj transient;
			ediConsignTI.setProxyFromEDI(pxyConsignObj);
			allAddConsignorees.add(pxyConsignObj);
		else
			if ediTI.messageMode = CM_EDITrackedItem.EDI_ACTION_DELETE then
				allDelConsignorees.add(realConsignObj);
			else
				pxyConsignObj	:=	app.createUpdateProxy(realConsignObj).CM_ConsigneeConsignor;
				ediConsignTI.setProxyFromEDI(pxyConsignObj);
				allUpdConsignorees.add(pxyConsignObj);
			endif;
		endif;
	endforeach;
	
	app.myTrxUA.trxProcessEDIConsignoreeAll(self, allAddConsignorees,
												allUpdConsignorees,
												allDelConsignorees,
												false, _passport);
	
	self.updateProgress(progressTS, progressStr, partsInJob, partsDone, true, passport);
	
epilog
	allAddConsignorees.purge();
	allUpdConsignorees.purge();
	
	delete allAddConsignorees;
	delete allUpdConsignorees;
	delete allDelConsignorees;
end;</source>
        <Parameter name="_mergeCargo" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateConsigns" id="a484dff7-2e87-407c-9385-81edd5aa01a3">
        <source>validateConsigns(	_allAddConsignorees	: CM_ConsignArray;
					_allUpdConsignorees	: CM_ConsignArray;
					_allDelConsignorees	: CM_ConsignArray) protected;
// --------------------------------------------------------------------------------
// Created:		08 March 2010 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	pxyConsignObj	: CM_ConsigneeConsignor;
	realConsignObj	: CM_ConsigneeConsignor;
	
begin
	foreach pxyConsignObj in _allAddConsignorees do
		app.myValCA.valConsigneeConsignor(pxyConsignObj);
	endforeach;
	
	foreach pxyConsignObj in _allUpdConsignorees do
		realConsignObj	:=	pxyConsignObj.pxyGetRealObject();
		app.myValUA.valConsigneeConsignor(realConsignObj, pxyConsignObj);
	endforeach;
	
	foreach realConsignObj in _allDelConsignorees do
		app.myValDA.valConsigneeConsignor(realConsignObj);
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="_allAddConsignorees" type="CM_ConsignArray"/>
        <Parameter name="_allUpdConsignorees" type="CM_ConsignArray"/>
        <Parameter name="_allDelConsignorees" type="CM_ConsignArray"/>
    </JadeMethod>
