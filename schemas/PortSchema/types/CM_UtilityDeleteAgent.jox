    <JadeMethod name="utlDeleteAvailabilityGrade" id="15fc1fc4-3562-4102-b78c-1857eed4fd61">
        <source>utlDeleteAvailabilityGrade(pAvailabilityGrade:CM_MTGrade io; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	yaType	: CM_YATypeAvGrade;

begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	app.myValDA.valAvailabilityGrade(pAvailabilityGrade);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	if _passport.noErrors then
		self.myDeleteAuditAgent.audDeleteGeneric(pAvailabilityGrade);
	endif;

	if _passport.noErrors then
		yaType := CM_YATypeAvGrade.firstInstance;
		if yaType &lt;&gt; null then
			yaType.removeMyDataObject(pAvailabilityGrade);
		endif;
		pAvailabilityGrade.erase(NORMAL_ERASE);
	endif;
	
end;</source>
        <Parameter name="pAvailabilityGrade" type="CM_MTGrade" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteAvailabilityGradeCode" id="67d31690-e405-4226-9d3b-a7ce9f7aaf50">
        <source>utlDeleteAvailabilityGradeCode(_mtGradeCode : CM_MTGradeCode io; _passport : CM_Passport);
// -------------------------------------------
// Created 27 October 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	self.initialiseActivity();
	if self.tryLock(_mtGradeCode, Exclusive_Lock, Transaction_Duration, LockTimeout_Immediate) then
		delete _mtGradeCode;
	else
		app.raiseCMException2(ObjectLockedByAnotherUser, 'Availability Code', 'Codes Maint', null, null);
	endif;


end;</source>
        <Parameter name="_mtGradeCode" type="CM_MTGradeCode" usage="io"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteBGPManager" id="d299dd89-f879-4a08-a845-234e48e69e32">
        <updating/>
        <source>utlDeleteBGPManager(_manager : BGP_Manager io; _passport : CM_Passport input) updating;

// cnwdvb1 25 October 2002 

vars
	cancelSave : Boolean;
	ti : CM_TrackedItem;
begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	_manager.validateForDelete();
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	if _passport.noErrors then	
		delete _manager;
	endif;

end;</source>
        <Parameter name="_manager" type="BGP_Manager" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteBGPRequest" id="be3ef019-af52-4f2e-811d-4af31b9290a8">
        <source>utlDeleteBGPRequest(_manager : BGP_Manager; _request : BGP_Request io; _sendCompletedNote : Boolean; _passport : CM_Passport input);
//
//18 Apr 2012	cnwrs1	Par 29441 - getting code 4's when trying to stop and clear the system
//
vars
	isInvalid : Boolean;
	requestCashReceipt,
	cashReceipt : CM_CashReceipt;
	workOrder  : CM_WorkOrder;
	invalidCashReceipt : Boolean;
	createCashReceipt  : Boolean;
	voyageProformaTrxAction  : CMIF_TrxActionWOProforma;
begin
	on Exception do app.handleDeletedObject(exception, _request, isInvalid);	 //18 Apr 2012 29441
	self.initialiseActivity();
	
	//epr TFS 43260 8/2/19
	if _request.isKindOf(BGP_SAPWSRequest) then
		on Exception do app.handleDeletedObject(exception, requestCashReceipt, invalidCashReceipt);	 //18 Apr 2012 29441
		//if it is a cancel estimate then
		if _request.BGP_SAPWSRequest.isSAPCancelEstimate  and not _request.BGP_SAPWSRequest.isManual then //epr TFS 44045 25/3/19
			requestCashReceipt:=_request.BGP_SAPWSRequest.myCashReceipt;
			if requestCashReceipt &lt;&gt; null then
				workOrder:=requestCashReceipt.myWorkOrder;
				
				if workOrder &lt;&gt; null and not invalidCashReceipt then
					//if this is the only cancel bgp request for the work order and then 
					//create post action to create new work order cash receipt and sap request
					createCashReceipt:=true;
					foreach cashReceipt in workOrder.allCashReceipts  where  cashReceipt &lt;&gt; requestCashReceipt  do 
						createCashReceipt:=false;
						break;
					endforeach;
					
					if createCashReceipt then
					//	app.writeLog("creating action to create cash receipt",LogAlways) ;
						create voyageProformaTrxAction transient;
						voyageProformaTrxAction.setMyWorkOrder(workOrder,CM_TrxControlAgent.Trx_Delete);
						_passport.addTrxPostAction(voyageProformaTrxAction);
					endif;
				endif;
			endif;
		endif;	
	endif;
	
	if self.tryLock(_request, Exclusive_Lock, Transaction_Duration, LockTimeout_Immediate) then
		if _manager &lt;&gt; null then
			_manager.createActivityForReqDelete(_request);
		endif;
		
		if _sendCompletedNote then		
			// We have finished. CCMS 1342
			_request.causeEvent(BGP_Object.BGP_RequestCompleted, false, _request.class.name);
		endif;
		
		delete _request;
	endif;

end;</source>
        <Parameter name="_manager" type="BGP_Manager"/>
        <Parameter name="_request" type="BGP_Request" usage="io"/>
        <Parameter name="_sendCompletedNote" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteBOL" id="be70155d-e2a7-436d-a7e1-88fe2486024b">
        <source>utlDeleteBOL(_bol : CM_BOL io; _passport : CM_Passport input);
//--------------------------------------------------------------
//Created: 06 May 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	ti : CM_TrackedItem;
begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	app.myValDA.valLogBOL(_bol);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
		
	exclusiveLock(_bol);
	
	app.setContinueCMExceptions(false);

	if _passport.noErrors then
		self.myDeleteAuditAgent.audDeleteGeneric(_bol);
	endif;

	if _passport.noErrors then	
		if _bol.myYardJob &lt;&gt; null then
			exclusiveLock(_bol.myYardJob);
			//this will remove the associated work list entry and erase the job if this is it's only work entry
			_bol.removeJobEntry();
		endif;
		if _bol.bolType = BOLType_Log then
			// if there are trackeditems involved then they must be unscaled logs.
			// Validation will not allow delete otherwise.
			_bol.removeTIs(_passport);
		elseif _bol.bolType = BOLType_GeneralDocket or _bol.bolType = BOLType_GeneralBillOfLading then
			if _bol.transportMode = TI_TRANSMODE_SHIP and CM_BOLIn.hasInstance(_bol) then
				// this is a receival bol being delivered by ship (import cargo) ok to delete cargo
				_bol.removeTIs(_passport);				
			endif;
						
		else
			// cnwsb1 22 Jul 2002: Belts and Braces check.  If you are getting
			// this error then consider adding your BOL type to the
			// BOLType_General clause above.  Otherwise consider removing
			// this exception.
			if _bol.numTIs &gt; 0 then
				app.raiseCMException1(DeletingBOLWithTIs, _bol.number, null, null);
				return;
			endif;	
		endif;
		
		_bol.handleOpsView(BGP_OpsViewWSRequest.OPS_ACTION_DELETE); // ### TFS 53105 31MAY2022 NAVAB1
		
		_bol.erase(NORMAL_ERASE);
	endif;

end;</source>
        <Parameter name="_bol" type="CM_BOL" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteBOLOutHeader" id="b267c06b-a2de-4c49-a855-336fbc10d3b5">
        <source>utlDeleteBOLOutHeader(_bolOutHdr : CM_BOLOutHeader io; _passport : CM_Passport input);
//--------------------------------------------------------------
//Created: November 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	cancelSave	: Boolean;
	terminal	: CM_Terminal;
begin

	self.initialiseActivity();
	app.setContinueCMExceptions(true);

	app.myValDA.valBOLOutHdr(_bolOutHdr);
	
	if (not self.checkValidationWithPassport(_passport)) then // Show any Errors and Warnings in a list
		return;
	endif;
	
	exclusiveLock(_bolOutHdr);
	

	app.setContinueCMExceptions(false);
	
	if _passport.noErrors then
		self.myDeleteAuditAgent.audDeleteGeneric(_bolOutHdr);
	endif;
	terminal := _passport.myTerminal;
	if _passport.noErrors then
		terminal.causeEvent(terminal.getTerminalEvent(BOLRecon_Delete_Event), false, _bolOutHdr);	
		_bolOutHdr.erase(NORMAL_ERASE);
	endif;
	
epilog
	return;
end;</source>
        <Parameter name="_bolOutHdr" type="CM_BOLOutHeader" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteBOLStop" id="77286213-22a2-41bc-a117-d3a7b0b65145">
        <source>utlDeleteBOLStop(_bol : CM_BOLIn input; _stopsTable : CM_StopsTable; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:	07 October 2008 By Graeme Black cnwgb1
// Purpose:	
// ---------------------------------------------------------------------------
vars
begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	

	app.setContinueCMExceptions(false);

	_bol.removeAStop( _stopsTable, true, _passport );
epilog
end;</source>
        <Parameter name="_bol" type="CM_BOLIn" usage="input"/>
        <Parameter name="_stopsTable" type="CM_StopsTable"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteBackup" id="4e02a7ab-769f-4d11-8ff3-f58bb6112693">
        <source>utlDeleteBackup(_backup:CM_Backup io; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     Aug 2004 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	app.myValDA.valBackup(_backup);
	
	if (not self.checkValidationWithPassport(_passport)) then // Show any Errors and Warnings in a list
		return;
	endif;


	app.setContinueCMExceptions(false);

	if _passport.noErrors then
		self.myDeleteAuditAgent.audDeleteGeneric(_backup);
	endif;

	if _passport.noErrors then
		_backup.erase(NORMAL_ERASE);
	endif;

epilog
	return;

end;</source>
        <Parameter name="_backup" type="CM_Backup" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteBank" id="ae56afe5-5eb1-4b84-9513-78400ddbbce0">
        <source>utlDeleteBank(pBank:CM_Bank io; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	app.myValDA.valBank(pBank);


	if (not self.checkValidationWithPassport(_passport)) then // Show any Errors and Warnings in a list
		return;
	endif;


	app.setContinueCMExceptions(false);

	if _passport.noErrors then
		self.myDeleteAuditAgent.audDeleteGeneric(pBank);
	endif;

	if _passport.noErrors then
		_passport.myTerminal.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_COMPANY_DELETE),false,pBank);
		pBank.erase(NORMAL_ERASE);
	endif;
epilog
	return;

end;</source>
        <Parameter name="pBank" type="CM_Bank" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
