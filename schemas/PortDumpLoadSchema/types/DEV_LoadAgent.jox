    <JadeMethod name="loadYardAllocation" id="54a93e5d-8439-48f3-9fa5-70618fd9b6a2">
        <source>loadYardAllocation(_proxyObject:CM_Object io):Boolean protected;

vars
	realObject, proxyObject: CM_YardAllocation;
	error: CM_Error;
	theUser: CM_User;
	result: Boolean;
	terminal: CM_Terminal;
	allTransientCriteriaObj:CMIF_Array;
begin
	result := false;
	proxyObject := _proxyObject.CM_YardAllocation;
	create allTransientCriteriaObj transient;
	proxyObject.allYABlocksIn.copy(proxyObject.allYABlocksOut);
	app.myTrxCA.trxCreateYardAllocation(proxyObject, allTransientCriteriaObj, realObject, app.myPassport);
	if app.myPassport.trxCompletedOK and
	   app.myPassport.allErrorWarnings.size = 0 then
//		write class.name&amp;'::'&amp;method.name&amp;' '&amp;proxyObject.code&amp;" OK";
		result := true;
	else
		foreach error in app.myPassport.allWarnings do
			write class.name&amp;'::'&amp;method.name&amp;' '&amp;proxyObject.code&amp;" WARNING: "&amp;error.text;
		endforeach;
		foreach error in app.myPassport.allErrors do
			write class.name&amp;'::'&amp;method.name&amp;' '&amp;proxyObject.code&amp;" ERROR: "&amp;error.text;
		endforeach;
	endif;
epilog
	return result;
end;</source>
