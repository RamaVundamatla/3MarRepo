    <JadeMethod name="getAmountString" id="38617e16-2f18-46a3-97dc-3a8f824f31cd">
        <source>getAmountString( _multiplier : Decimal ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	returnVal : String;
	measureType : CM_MeasurementType;
	type : String;
	multiplier : Decimal[14,4];

begin

	if _multiplier = 0 then
		multiplier := 1;
	else
		multiplier := _multiplier;
	endif;

	if self.myCargoType = null then
		if self.volume &lt;&gt; 0 then
			returnVal := (self.volume * multiplier).asStringWeightJMT &amp; " m3";
		elseif self.weight &lt;&gt; 0 then
			returnVal := (self.weight * multiplier).asStringWeightJMT &amp; " kg";
		elseif self.quantity &lt;&gt; 0 then
			returnVal := "x" &amp; (self.quantity * multiplier).Integer.asStringJMT;
		endif;
	
	else
		if self.myCargoType.isTrackByVolume then
			if self.myProduct &lt;&gt; null then
				measureType := self.myProduct.getDefaultMeasurementForType(Type_Volume);
			else
				measureType := self.myCargoType.getDefaultMeasurementForType(Type_Volume);
			endif;
			type := measureType.shortName;
			if self.volume &lt;&gt; 0 then
				returnVal := app.convertMeasurementForDisplay(type, (self.volume * multiplier) ) &amp; " " &amp; type;
			endif;
		elseif self.myCargoType.isTrackByWeight then
			if self.myProduct &lt;&gt; null then
				measureType := self.myProduct.getDefaultMeasurementForType(Type_Weight);
			else
				measureType := self.myCargoType.getDefaultMeasurementForType(Type_Weight);
			endif;
			type := measureType.shortName;
			if self.weight &lt;&gt; 0 then
				returnVal := app.convertMeasurementForDisplay(type, (self.weight * multiplier) ) &amp; " " &amp; type;
			endif;
		else
			if self.quantity &lt;&gt; 0 then
				returnVal := "x" &amp; (self.quantity * multiplier).Integer.asStringJMT;
			endif;
		endif;

	endif;
	
	return returnVal;

epilog

end;</source>
        <Parameter name="_multiplier" type="Decimal"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="e05ab0d6-a3a3-44a8-aa49-0a08738c2830">
        <source>getAuditText(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	txt : String;
	strText : String;

begin
	txt[10000] := '*';
	txt := null;

	strText := self.myCargoType.abbreviation;
	if self.myProduct &lt;&gt; null then
		strText := strText &amp; "/" &amp; self.myProduct.code;
	endif;
	
	strText := strText &amp; self.getAmountString(1);
	
	return strText;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="ef1a8f93-13d5-4e9b-ba3c-66b7ba58fb75">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 May 2021	navndl1	Initial creation	TFS 

*/

vars

begin

	




	if _attrName = ETRow_RecipeCompAmount then
		return self.getAmountString(1);
	elseif _attrName = ETRow_RecipeCompType then
		if self.myCargoType &lt;&gt; null then
			return self.myCargoType.description;
		endif;
		return null;
	elseif _attrName = ETRow_RecipeCompSubType then
		if self.myProduct &lt;&gt; null then
			return self.myProduct.description;
		endif;
		return null;
	elseif _attrName = ETRow_RecipeCompOrder then
		return self.order.asStringJMT;
	else
		return inheritMethod(_attrName, _short);
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTextForAuditStringOnRecipe" id="64c25ba2-2914-495e-9547-f9df75bb5ed6">
        <source>getTextForAuditStringOnRecipe():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	strText : String;

begin

	if self.myCargoType &lt;&gt; null then
		strText := self.myCargoType.abbreviation;
		if self.myProduct &lt;&gt; null then
			strText := strText &amp; "/" &amp; self.myProduct.code;
		endif;
	endif;
	
	strText := strText &amp; " - " &amp; self.getAmountString(1);
	
	return strText;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="29204923-ce80-4338-93d5-8500a96be35a">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	pxyRecipeComp : CM_RecipeComponent;
	completedOK : Boolean;

begin

	pxyRecipeComp := inheritMethod();
	
	pxyRecipeComp.myProduct := self.myProduct;
	pxyRecipeComp.myCargoType := self.myCargoType;
	
	
	completedOK := true;
	return pxyRecipeComp;

epilog

	if not completedOK then
		delete pxyRecipeComp;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="2cdff165-5fc8-4819-82c4-133ba60a2b66">
        <updating/>
        <source>setForCreate( _proxy : CM_RecipeComponent; _recipe : CM_Recipe ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

begin

	self.setForUpdate( _proxy, _recipe );

epilog

end;</source>
        <Parameter name="_proxy" type="CM_RecipeComponent"/>
