<CollClass name="CM_StopSet" id="f53cd145-ac38-4e96-bcb2-af8220c8fe6a">
    <memberType name="CM_Stops"/>
    <superclass name="CM_ObjectSet"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="stops"/>
    <JadeMethod name="auditIdDisplay" id="b8d6b3e3-a57c-49ec-93cd-da78ad500f1a">
        <source>auditIdDisplay() : String;
/*
Purpose - 	
Who - NAVAB1
Date - 30AUG2023
ADO - CR 59942 TASK 59943 
*/

vars
	stop	: CM_Stops;
	rtnStr	: String;
begin

	foreach stop in self do
		if rtnStr = null then
			rtnStr := stop.auditId();
		else
			rtnStr := rtnStr &amp; ', ' &amp; stop.auditId();
		endif;
	endforeach;

	return rtnStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</CollClass>
