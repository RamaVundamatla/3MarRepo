    <JadeMethod name="createInTransitFromLocation" id="bbca5b13-da76-4273-af7a-fe68f3464c4c">
        <updating/>
        <source>createInTransitFromLocation() updating,protected;
// ---------------------------------------------------------------------------
// Created:     18 June 2009 by concms1
// Purpose:     Par 
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	proxy, location	:CM_BlockController;
begin
	if self.myInTransitFromLocation &lt;&gt; null then
		return;
	endif;
	
	create proxy transient;	
	proxy.setProxy (self);
	
	create location;
	self.myInTransitFromLocation := location;

	location.setForCreate (proxy, self);
epilog
	delete proxy;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="erase" id="ab7a1ad1-ea30-4438-bc58-f5b425350cf1">
        <updating/>
        <source>erase(_level: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     17 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	// delete the IN-TRANSIT-FROM LC for this gate area
	if not self.isTransient then
		self.myInTransitFromLocation.erase (_level);
	endif;
	
	inheritMethod(_level);
epilog

end;</source>
        <Parameter name="_level" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="findLocation" id="d2065e03-91e1-4dba-adc8-780ac78770ef">
        <source>findLocation(_strs: StringArray; _noException: Boolean; _foundLC: CM_LocationsController io; _foundHeight: Integer io);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 August 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars

	lane	: String;

begin
	_foundLC := null;
	_foundHeight := NULLINDEX;

	if not _strs.isEmpty() then
		lane := _strs[1].trimBlanks();
	endif;
	
	if lane = null then
		if self.laneCount = 0 then
			_foundLC := self.getDefaultLane();
			return;
		endif;
		return;
	endif;
	
	if lane.isInteger() then
		_foundLC := self.getLaneByNumber(lane.Integer);
	endif;

epilog

end;</source>
        <Parameter name="_strs" type="StringArray"/>
        <Parameter name="_noException" type="Boolean"/>
        <Parameter name="_foundLC" type="CM_LocationsController" usage="io"/>
        <Parameter name="_foundHeight" type="Integer" usage="io"/>
    </JadeMethod>
