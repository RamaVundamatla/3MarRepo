    <JadeMethod name="setFromRealWSObject" id="0533e22b-7c6c-4e3a-9f79-bf355dafc3b0">
        <updating/>
        <source>setFromRealWSObject(_realResponse: ImportedWebServiceProxy) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 June 2019	jlger1	Initial creation 45207
 
*/

vars
	properties : PropertyNDict;
	prop : Property;
	value : Any;
begin

	foreach prop in self.class.allProperties do
		if _realResponse.class.getProperty(prop.name) &lt;&gt; null then
			value:=_realResponse.getPropertyValue(prop.name);		
			self.setPropertyValue(prop.name,value);
		endif;
	endforeach;


epilog

end;</source>
        <Parameter name="_realResponse" type="ImportedWebServiceProxy"/>
    </JadeMethod>
