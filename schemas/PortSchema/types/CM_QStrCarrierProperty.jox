    <JadeMethod name="setComboValues" id="d189aa1a-3058-45d6-8f5a-a8d8d1ee6e43">
        <source>setComboValues(_combo : ComboBox input; _params : CM_QueryCriteriaLineHolder; _queryOperator : CM_QueryOperator; _passport : CM_Passport);
// ---------------------------------------------------------------------------
// Created:     18 March 2003		cnwth2	
//
// Purpose:     		 
//
// Changed On	Changed By	Reason
// ----------   ----------  --------------------------------------------------
// 23/06/2022	navdap1		TFS 53362 EUP Master Data Interface Customers Between TOS and ERP
vars
	carrier			: CM_Carrier;
	carrierDict		: CM_CarrierByCodeDict;
	byName			: Boolean;				// TFS 53362

begin
	
	_combo.clear();
	carrierDict := app.myRoot.allCarriers;
	byName := app.myRoot.getConfig(CarrierCmbOrdDescr).Boolean;		// TFS 53362

	foreach carrier in carrierDict do
		if byName then																					// TFS 53362
			_combo.itemObject[_combo.addItem(carrier.description &amp; Tab &amp; carrier.code)] := carrier;		// TFS 53362
		else																							// TFS 53362
			_combo.itemObject[_combo.addItem(carrier.code &amp; Tab &amp; carrier.description)] := carrier;
		endif;																							// TFS 53362
	endforeach;

	if CM_QStringLookup.hasInstance(_queryOperator) then
		_combo.listObject := carrierDict[_queryOperator.CM_QStringLookup.selectionValue];
	elseif CM_QStringLookupNotEqual.hasInstance(_queryOperator) then
		_combo.listObject := carrierDict[_queryOperator.CM_QStringLookupNotEqual.selectionValue];
	endif;
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="4215f693-cdf1-4651-b141-52587c82c092">
        <source>translateToDisplayValue(_value: Any): String;
// ---------------------------------------------------------------------------
// Created:     18 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
/*

Date		Who		Reason
22 Oct 2008	cnwkpd1	PAR #18099 - Handle null objects in selector queries

*/

vars

begin
	if _value &lt;&gt; null then
		return _value.CM_Carrier.code;
	endif;
	
	return null;


end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="c603a97f-aaf9-4f30-8387-74dad04a55e8">
        <source>translateToSearchValue(_value: Any): Any;
// ---------------------------------------------------------------------------
// Created:     18 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
/*

Date		Who		Reason
06 Oct 2008	cnwkpd1	PAR #18099 - Correct Selector query processing
22 Oct 2008	cnwkpd1	PAR #18348 - Prevent 1002 exceptions in Selector query processing with isOneOf

*/

vars
	invalidObj 		: Boolean;
	object			: CM_Carrier;
	returnVal		: String;
	
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then			// PAR #18348
			return _value;
		endif;

		if _value.isKindOf(CM_Carrier) then
			object := _value.CM_Carrier;
		endif;
	endif;
	
	if object &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, object, invalidObj);
		
		returnVal := object.code;
	endif;
	
	return returnVal;
	
end;
</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="feaca338-8623-4afd-aef1-4266934e9ab8">
        <source>translateToSearchValueForWeb(_value: Any; _sending : Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 24/09/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal slector query parameters
//
vars

begin
	if _value.isKindOf(String) then
		return _value.String;
	endif;
	
	return inheritMethod(_value, _sending);

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
