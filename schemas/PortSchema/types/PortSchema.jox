    <JadeMethod name="cargoCheckContextENumToString" id="fb1ebfb1-57ed-4007-a940-1307382bcbcd">
        <source>cargoCheckContextENumToString(_cargoCheck : Integer) : String;
/*
Purpose:			Convert Cargo Check context integer to astring value

Parameters:			

Return Value:		

Date		Who		Reason
28/01/2010	cnwdap1	Initial creation CCMS 1071 General Cargo
20/04/2015	cnwdap1	PAR #36094 CCMS 1413 Cold Store Enhancements - added ROAD_REL context
24/01/2023	jlika1	TFS 62138 62139 CUX | Add Voyage Live Ops Check types
*/
vars

begin

	if _cargoCheck = CARGO_CHECK_CONTEXT_GATE_REC then
		return CARGO_CHECK_GATE_REC_STRING;
	elseif _cargoCheck = CARGO_CHECK_CONTEXT_GATE_REL then
		return CARGO_CHECK_GATE_REL_STRING;
	elseif _cargoCheck = CARGO_CHECK_CONTEXT_RAIL_REC then
		return CARGO_CHECK_RAIL_REC_STRING;
	elseif _cargoCheck = CARGO_CHECK_CONTEXT_RAIL_REL then
		return CARGO_CHECK_RAIL_REL_STRING;
	elseif _cargoCheck = CARGO_CHECK_CONTEXT_SHIP_DISC then
		return CARGO_CHECK_SHIP_DISC_STRING;
	elseif _cargoCheck = CARGO_CHECK_CONTEXT_SHIP_LOAD then
		return CARGO_CHECK_SHIP_LOAD_STRING;
	elseif _cargoCheck = CARGO_CHECK_CONTEXT_YARD then
		return CARGO_CHECK_YARD_STRING;
	elseif _cargoCheck = CARGO_CHECK_CONTEXT_TRUKLOAD then	//28 May 2010	NDL Par 23698
		return CARGO_CHECK_TRUCK_LOAD_STR;
	elseif _cargoCheck = CARGO_CHECK_CONTEXT_TRUKUNLOAD then	//28 May 2010	NDL Par 23698
		return CARGO_CHECK_TRUCK_UNLOAD_STR;
	elseif _cargoCheck = CARGO_CHECK_CONTEXT_PACK then	//04 Jul 2011	NDL Par 26476
		return CARGO_CHECK_PACK_STRING;
	elseif _cargoCheck = CARGO_CHECK_CONTEXT_UNPACK then	//04 Jul 2011	NDL Par 26476
		return CARGO_CHECK_UNPACK_STRING;
	elseif _cargoCheck = CARGO_CHECK_CONTEXT_TMANLOAD then	//CCMS MSL 1026
		return CARGO_CHECK_TMANLOAD_STR;
	elseif _cargoCheck = CARGO_CHECK_CONTEXT_TMANDISC then	//CCMS MSL 1026
		return CARGO_CHECK_TMANDISC_STR;
	elseif _cargoCheck = CARGO_CHECK_CONTEXT_ROAD_REC then	//07 May 2014	NDL	Par 34076
		return CARGO_CHECK_ROADGATE_IN_STRING;
	elseif _cargoCheck = TRUCK_CHECK_LOAD_COMPLETE then		//13 Sep 2023 jlizm1 TFS59985
		return TRUCK_CHECK_LOAD_COMPLETE_STR;
	elseif _cargoCheck = WAGON_CHECK_CONTEXT_PLACE_IN then	//07 May 2014	NDL	Par 34076
		return WAGON_CHECK_PLACEMENT_OUT_STR;
	elseif _cargoCheck = WAGON_CHECK_CONTEXT_PLACE_OUT then	//07 May 2014	NDL	Par 34076
		return WAGON_CHECK_PLACEMENT_IN_STR;
	elseif _cargoCheck = WAGON_CHECK_LOAD_COMPLETE then		//04 Nov 2022 jlizm1 TFS 54118
		return WAGON_CHECK_LOAD_COMPLETE_STR;
	elseif _cargoCheck = CARGO_CHECK_CONTEXT_ROAD_REL then		// PAR #36094
		return CARGO_CHECK_ROADGATE_OUT_STRNG;					// PAR #36094
	elseif _cargoCheck = CONT_CHECK_CONTEXT_PACK then		//08 Mar 2017	NDL	TFS 3635
		return CONT_CHECK_PACK_STR;
	elseif _cargoCheck = CONT_CHECK_CONTEXT_UNPACK then		//08 Mar 2017	NDL	TFS 3635
		return CONT_CHECK_UNPACK_STR;
	elseif _cargoCheck = CARGO_CHECK_CONTEXT_VOYOP_LOAD then
		return CARGO_CHECK_VOYOP_LOAD_STR;
	elseif _cargoCheck = CARGO_CHECK_CONTEXT_VOYOP_DISC then
		return CARGO_CHECK_VOYOP_DISC_STR;	
	endif;
	
epilog

end;</source>
        <Parameter name="_cargoCheck" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
