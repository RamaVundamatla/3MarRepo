31 Jan 2024	jlika1	TFS 62154 62155 CUX | Photo Checks for Foreman Live
*/

vars
	table : CM_DataTable;
begin
	table := self.getTableForSheet(self.fldMain.topSheet.CMUI_Sheet);
	
	self.doCargoChecks(table);
end;</source>
