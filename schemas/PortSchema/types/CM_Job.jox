    <JadeMethod name="shift" id="938c9144-faac-44d4-a018-029d391428b2">
        <updating/>
        <source>shift(numToShift : Integer) updating;
/*
------------------------------------------------------------------------
Created:			31 March 2003 by cnwdwq1
// Description : This method is used to shift a job up or down the order of work
//               A parameter indicates how many positions to move the job +ve values
//               shift it down, -ve value up, zero does nothing. If a value is
//               given that is larger than the possible number of shifts the job
//               will go to the beginning or end of the list depending on the sign of
//               the parameter.   
Parameters:		
Returns:			
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														
------------------------------------------------------------------------
*/
vars
	jobSheet : 	CM_JobSheet ;
	event,
	oldPos	:	Integer;
	newPos	:	Integer;
	numJobs	:	Integer;
	terminal:  CM_Terminal;
begin

	// If the same do not bother doing anything else.
	if numToShift = 0 then
		return;
	endif;

	exclusiveLock(self);

	jobSheet := self.myJobSheet;

	if jobSheet = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException(ERR_INVALID_CRANE, null, null);
		return;	
	endif;

	exclusiveLock(jobSheet);

	oldPos := jobSheet.allJobsByOrder.indexOf(self);
	//----------------------------------------------
	// Calculate the new position in the collection
	//----------------------------------------------
	newPos := oldPos + numToShift;

	numJobs := jobSheet.allJobsByOrder.size;

	if newPos &lt; 1 then        // Make sure we have not exceeded the ends
		newPos := 1;
	elseif newPos &gt; numJobs then
		newPos := numJobs;
	elseif newPos = oldPos then
	  	return;
	endif;
	jobSheet.allJobsByOrder.remove( self );
	jobSheet.allJobsByOrder.insert( newPos, self );
	
	terminal := self.getMyTerminal();
	
	if terminal &lt;&gt; null then
		event := terminal.getTerminalEvent(JobSheet_Update_Event);
		jobSheet.CM_VoyageJobSheet.myVoyage.causeEvent(event, false, jobSheet);
		
		self.causeTerminalEvent(CM_VoyageJob.Event_Mode_Update); //cause correct note
	endif;
end;</source>
        <Parameter name="numToShift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="splitUnactionedRequests" id="d7bd3e18-ac66-4355-88eb-f84aada9a6bd">
        <updating/>
        <source>splitUnactionedRequests(_newJob : CM_Job output; 
						_selectedRequests : CM_RequestSet;
						_newJobNum : String;
						_jobSheetTransTo :CM_VoyageJobSheet;  //+TFS40668
						_newCrane : String;
						_targetJob : CM_Job )updating;
//--------------------------------------------------------------
//Created: 05 May 2003 By: cnwgd1
// 10/10/2018	jlgrh7 TFS #40668  POL - Transferring Work Between Cranes (changed signature only for the superclass)
//--------------------------------------------------------------
vars
	request : CM_Request;
begin
		
	if self.status &lt;&gt; JOB_PART_COMPLETE then
		app.setContinueCMExceptions(false);
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid status for split');
		return;
	endif;
	
	// new job is only created if there are requests to split off
	foreach request in self.allRequests do
		if _newJob = null then
			 // Only create the one new job 
			 // for all unactioned requests to be attached to
			_newJob := self.cloneSelf(false);
			_newJob.status := JOB_UNACTIONED;
			self.cloneReferences(_newJob);
		endif;
		request.splitUnactionedWLEs(_newJob);
	endforeach;

	self.rebuildStatus();
			
end;</source>
        <Parameter name="_newJob" type="CM_Job" usage="output"/>
        <Parameter name="_selectedRequests" type="CM_RequestSet"/>
        <Parameter name="_newJobNum" type="String"/>
        <Parameter name="_jobSheetTransTo" type="CM_VoyageJobSheet"/>
        <Parameter name="_newCrane" type="String"/>
        <Parameter name="_targetJob" type="CM_Job"/>
    </JadeMethod>
    <JadeMethod name="statusString" id="58fe7309-803c-4390-b440-d1568802e25e">
        <methodInvocation>mapping</methodInvocation>
        <source>statusString(set: Boolean; value: String io) mapping;
vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;

	value := app.jobStatusEnumToString(self.status);
		
/*	if self.status = JOB_UNACTIONED then
		value := "Job Unactioned";
	elseif	self.status = JOB_COMPLETE then
		value := "Job Completed";
	elseif	self.status = JOB_PART_COMPLETE then
		value := "Job Part Complete";
	else
		value := "Unknown - " &amp; self.status.String;
	endif;*/

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="testForCompatibleMachine" id="d38ba400-f639-40df-97a4-9900d6ba29c2">
        <source>testForCompatibleMachine(_isRelease : Boolean; _terminal : CM_Terminal) : Boolean;
// ---------------------------------------------------------------------------
// Created:		November 2002 By Andrew Bishop cnwab1
//
// 				PAR 4321 - AKB2002NOV check whether a compatible machine exists for this job - checks cargo type
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aWLE	: CM_WorkListEntry;
	aRequest : CM_Request;
	anISOType : CM_ISOType;
	aTIType : CM_CargoType;
	aMachine : CM_Machine;
	didCheck,foundMachine : Boolean;
	alert	:	CM_SystemAlert;
	isoType: String;
	isoGroup: CM_ISOTypeGroup;
begin
	// Check whether there is machinary that can handle this job before queueing it
	if _isRelease then
		foundMachine := false;
		didCheck := false;
		foreach aRequest in self.allRequests do : outerXLoop
			if aRequest.isKindOf(CM_DeliveryRequest) then
				isoType := aRequest.CM_DeliveryRequest.isoType;
				if isoType = null then
					if aRequest.CM_DeliveryRequest.isoGroup = null then
						continue;
					endif;
					// Allow for release by ISOGroup
					isoGroup := app.myRoot.allISOTypeGroups[aRequest.CM_DeliveryRequest.isoGroup];
					if isoGroup &lt;&gt; null then
						anISOType := isoGroup.allISOTypes.first;
					endif;
				else
					anISOType := app.myRoot.allISOTypes[isoType];
				endif;
				if anISOType = null then
					continue;
				endif;
				aTIType := anISOType.myCargoType;
			endif;			
			if aRequest.isKindOf(CM_TIRequest) then
				aTIType := aRequest.CM_TIRequest.trackedItem.myCargoType;
			endif;			

			didCheck := true;
			// DVB Changed 6/09/04 for not available for entry
			foreach aMachine in _terminal.machines where not aMachine.isNotAvailableForEntry do
				if aMachine.allAllowedCargoTypes.includes(aTIType) then

	
					foundMachine := true;
					break outerXLoop;
				endif;
			endforeach;
		endforeach;
		// if not ti get checked, because of nulls, do not return
		if foundMachine = false and didCheck then
			create alert;
			alert.details := "Job id " &amp; self.jobId &amp; " Not Queued. No suitable machine with correct cargo type capabilities";
			alert.setSeverity(SEVERE_INFO);
			//-----------
			//Tell alert to add itself to system
			//-----------
			alert.add;
			return false;
		endif;

	else
		foundMachine := false;
		didCheck := false;
		foreach aWLE in self.workListEntries do : outerLoop
			if aWLE.myTrackedItem = null then
				continue;
			endif;
			didCheck := true;
			// DVB Changed 6/09/04 for not available for entry
			foreach aMachine in _terminal.machines where not aMachine.isNotAvailableForEntry do
				if aMachine.allAllowedCargoTypes.includes(aWLE.myTrackedItem.myCargoType) then
	
					foundMachine := true;
					break outerLoop;
				endif;
			endforeach;
		endforeach;
		// if not ti get checked, because of nulls, do not return
		if foundMachine = false and didCheck then
			create alert;
			alert.details := "Job id " &amp; self.jobId &amp; " Not Queued. No suitable machine with correct cargo type capabilities";
			alert.setSeverity(SEVERE_INFO);
			//-----------
			//Tell alert to add itself to system
			//-----------
			alert.add;
			return false;
		endif;
	endif;
	return foundMachine;
end;</source>
        <Parameter name="_isRelease" type="Boolean"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="transportMode" id="5e38dc2c-18ac-4ac2-9b4f-d1836d895729">
