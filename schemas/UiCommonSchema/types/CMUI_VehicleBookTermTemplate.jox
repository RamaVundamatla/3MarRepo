    <JadeMethod name="btnDelDay_click" id="9cc02879-e297-47b2-8be0-2fc5fc1db2eb">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnDelDay_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 April 2013	cnwndl1	Initial creation	Par 31393

*/

vars
	
	dayTemp : CM_VehicleBookingDayTemplate;
	
begin

	if self.tblDays.row &gt; self.tblDays.fixedRows and self.tblDays.row &lt;= self.tblDays.rows then
		dayTemp := self.tblDays.accessRow( self.tblDays.row ).itemObject.CM_VehicleBookingDayTemplate;
	endif;
	
	if dayTemp = null then
		return;
	endif;
	
	if app.msgBox( app.getErrorString1(Lit_Confirm_Delete, dayTemp.getDisplayForError()), app.getErrorString(Continue), MsgBox_Yes_No) &lt;&gt; MsgBox_Return_Yes then
		return;
	endif;
	
	app.myTrxDA.trxDeleteVehicleDayTemp(dayTemp, app.myPassport);
	self.initTblDays();

	
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnUpdDay_click" id="e534f6f6-49c7-45f7-b7da-954de7cb2251">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnUpdDay_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 April 2013	cnwndl1	Initial creation	Par 31393

*/

vars
	vssTemplate : CMUI_VehicleBookDayTemplate;
	dayTemp : CM_VehicleBookingDayTemplate;
	
begin

	if self.tblDays.row &gt; self.tblDays.fixedRows and self.tblDays.row &lt;= self.tblDays.rows then
		dayTemp := self.tblDays.accessRow( self.tblDays.row ).itemObject.CM_VehicleBookingDayTemplate;
	endif;
	
	if dayTemp = null then
		return;
	endif;

	vssTemplate := app.loadForm(CMUI_VehicleBookDayTemplate, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_VehicleBookDayTemplate;
	if vssTemplate &lt;&gt; null then
		vssTemplate.CMUI_VehicleBookDayTemplate.setMyTemplates( dayTemp, self.myVehicleBookingTerminal );
		vssTemplate.setParentForm(self);
		vssTemplate.showModal;
		self.initTblDays();
	endif;

epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
