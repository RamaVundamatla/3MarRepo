    <JadeMethod name="getLoadOrderForTI" id="95bd8443-fd7e-4f38-a81d-5ba1f81dec32">
        <source>getLoadOrderForTI(_ti: CM_TrackedItem): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 September 2019	jlgndl1	Initial creation	TFS 46611

*/

vars
	num,
	idx : Integer;
begin
	if _ti = null then
		return null;
	endif;
	idx := self.allTrackedItems.indexOf(_ti);
	num := self.allTrackedItems.size+1;
	if idx = 0 then
		return null;
	endif;
	return num - idx;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
