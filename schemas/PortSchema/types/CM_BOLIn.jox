    <JadeMethod name="cargoMatchesAndNeedsUpdate" id="7f7c8c18-c28a-42cf-ae72-573b2335657f">
        <source>cargoMatchesAndNeedsUpdate( _ti : CM_TrackedItem;
							_bolNumber : String;
							_operator : CM_Operator;
							_destPort : String;
							_dischPort : String
							):Boolean protected;
/*
	05 May 2014	NDL	Par 34034
	Find tis that have the BOL number set to my number, but the reference unset
*/
vars

	imexStatus : Integer;

begin

	
	
	if _ti.myReceivalBOL &lt;&gt; null then
		//reference is already set, NOT interested
		return false;
	endif;
	if _ti.billOfLading.toUpper &lt;&gt; _bolNumber then
		//not my bol number
		return false;
	endif;
	if _ti.myOperator &lt;&gt; _operator then
		//not my operator
		return false;
	endif;
	if _destPort &lt;&gt; null then
		if _ti.destinationPort.toUpper &lt;&gt; _destPort then
			//not my destination port
			return false;
		endif;
	endif;
	if _dischPort &lt;&gt; null then
		if _ti.dischargePort.toUpper &lt;&gt; _dischPort then
			//not my discharge port
			return false;
		endif;
	endif;
	imexStatus := _ti.getImExStatus;
	if imexStatus &lt;&gt; TI_IMEX_STATUS_IMPORT then
		//Only interested in imports, and tranship imports for the voyage
		if imexStatus = TI_IMEX_STATUS_TRANSHIP and _ti.myImportVoyage = self.myVoyage then
			//we are interested in this
		else
			//not an import
			return false;
		endif;
	endif;
	
	return true;

epilog

end;
</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_bolNumber" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_destPort" type="String"/>
        <Parameter name="_dischPort" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkForCargoWithBolNumOnly" id="5d5b55f2-5ebf-4067-b54a-af81ec08448a">
        <updating/>
        <source>checkForCargoWithBolNumOnly( _passport : CM_Passport input) protected, updating;
/*
	05 May 2014	NDL	Par 34034
	Find tis that have the BOL number set to my number, but the reference unset
*/
/*

Date		Who		Reason
27 Feb 2015	cnwkpd1	PAR #35773 - leaking iterators
	
*/

vars

	tiSet : CM_TISet;
	iter : Iterator;
	ti : CM_TrackedItem;
	bolNumber : String;
	operator : CM_Operator;
	imexStatus : Integer;
	destPort : String;
	dischPort : String;

begin

	if self.isTransient then
		return;
	endif;

	if self.myVoyage = null then
		return;
	endif;
	
	if not _passport.noErrors then
		return;
	endif;
	
	bolNumber := self.number.toUpper;
	operator := self.myOperator;
	destPort := self.destinationPort.toUpper;
	dischPort := self.dischargePort.toUpper;
	
	create tiSet transient;
	
	//Check on site collection
	iter := self.myVoyage.allOnsiteTIsByIdCargoType.createIterator;
	while iter.next( ti ) do
		if not cargoMatchesAndNeedsUpdate( ti, bolNumber, operator, destPort, dischPort ) then
			continue;
		endif;
		//BOL ref needs setting to me
		tiSet.addNoDuplicates( ti, false );
	endwhile;
	delete iter;
	
	//Check on ship collection
	iter := self.myVoyage.allOnshipTIsByIdCargoType.createIterator;
	while iter.next( ti ) do
		if not cargoMatchesAndNeedsUpdate( ti, bolNumber, operator, destPort, dischPort ) then
			continue;
		endif;
		//BOL ref needs setting to me
		tiSet.addNoDuplicates( ti, false );
	endwhile;
	delete iter;
	
	//Check on import tranship collection
	iter := self.myVoyage.allTranshipTIsImport.createIterator;
	while iter.next( ti ) do
		if not cargoMatchesAndNeedsUpdate( ti, bolNumber, operator, destPort, dischPort ) then
			continue;
		endif;
		//BOL ref needs setting to me
		tiSet.addNoDuplicates( ti, false );
	endwhile;
	delete iter;
	
	if tiSet.isEmpty then
		return;
	endif;
	
	iter := tiSet.createIterator;
	while iter.next( ti ) do
		if not _passport.noErrors then
			return;
		endif;
		ti.attachToBOL( self );
	endwhile;
	
epilog
	delete iter;
	delete tiSet;

end;
</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createScalerTransactions" id="fc8b925e-0a06-4fb0-a5da-af8ea7da8acb">
        <source>createScalerTransactions(_logScaleHdr : CM_LogScalingHdr);

// cnwdvb1 12 June 2003 

vars

	txn 			: CM_BOLInScalerTransaction;
	logScaleExtra	: CM_LogScalingExtra;

begin

	foreach logScaleExtra in _logScaleHdr.allLogScalingExtra do
		create txn persistent;
		txn.setScalerDetails(self, logScaleExtra);
		if (not app.myPassport.noErrors) then
			delete txn;
		endif;
	endforeach;	
	
	if not self.isTransient then	//20 Jan 2014	NDL	Par 33264
		//15 Jan 2104	NDL	Par 33264
		self.updateObjectEdition(self);
	endif;

end;</source>
        <Parameter name="_logScaleHdr" type="CM_LogScalingHdr"/>
    </JadeMethod>
    <JadeMethod name="createWLEs" id="5ac77d9a-07b8-4fa3-b079-4c3bfc50f36e">
        <source>createWLEs(_request : CM_Request);
// ---------------------------------------------------------------------------
// Created:     25 October 2002		cnwth2	
//
// Purpose:     Creates WLEs per cargoType/location - only used in warehousing
//				currently - 
//			 
// ----------   ----------  --------------------------------------------------
vars
	wle			: CM_YardWLE;
	tiDict		: CM_TIByCargoTypeLocationDict;
	ti			: CM_TrackedItem;
	lc			: CM_LocationsController;
	cargoType	: Integer;
	
begin
	if self.bolType &lt;&gt; BOLType_GeneralDocket and bolType &lt;&gt; BOLType_GeneralBillOfLading then
		return;
	endif;
	
	if _request.myTerminal &lt;&gt; self.myTerminal then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Attempt to update unscaled logs when not in original terminal for BOL');
		return;
	endif;
	
	create tiDict transient;
	self.getTICollectionForTerminal(self.myTerminal).copy(tiDict);
	
	if not tiDict.isEmpty then 	//Nothing to update // cnwrd1 1.7.08 par #17236
		ti := tiDict.first;
		cargoType := ti.cargoType;
		lc := ti.getPrimaryLocation(PLANNING_MODE);
	endif;
	

	create wle persistent;
	wle.setForCreate(_request.myJob, _request);
	
	foreach ti in tiDict do
		if (ti.cargoType &lt;&gt; cargoType) or ti.getPrimaryLocation(PLANNING_MODE) &lt;&gt; lc then			
			create wle persistent;
			wle.setForCreate(_request.myJob, _request);
			
		endif;
		wle.assignTIandBOL(ti, self);
		
		cargoType := ti.cargoType;
		lc := ti.getPrimaryLocation(PLANNING_MODE);
		
	endforeach;	

epilog
	delete tiDict;
end;</source>
        <Parameter name="_request" type="CM_Request"/>
    </JadeMethod>
    <JadeMethod name="doBOLTerminalUpgrade" id="8f2c2f74-b19c-475a-9b52-de68af76beb1">
        <updating/>
        <source>doBOLTerminalUpgrade() updating;
// ---------------------------------------------------------------------------
// Created:     07 May 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	bolTerminal	: CM_BOLTerminal;
	ti			: CM_TrackedItem;

begin

	exclusiveLock(self);

	bolTerminal := self.getBOLTerminal(self.myTerminal, true);
	
	exclusiveLock(bolTerminal);
	
	if bolTerminal.allTrackedItems.isEmpty then
		self.allTrackedItems.copy(bolTerminal.allTrackedItems);
	endif;

	if self.allTrackedItemsOrig.isEmpty then
		self.allTrackedItems.copy(self.allTrackedItemsOrig);
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="doUpdateLocation" id="8da723a2-d24a-4cc3-8245-4d572f7e3942">
        <updating/>
        <source>doUpdateLocation(_mode		: Integer; 
				_newLocn	: CM_LocationsController;
				_passport 	: CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 03 July 2002 By: cnwgd1
// 21.05.2024 navma1 Bug 64201: MTN - Stop Creating Alerts When Loading Ship manifest
//--------------------------------------------------------------
vars

begin
	
	if self.myPlannedLocation = null and self.origTerminalAreaId &lt;&gt; null then
		return;	
	elseif self.bolType = BOLType_GeneralDocket or self.bolType = BOLType_GeneralBillOfLading then
		if _newLocn &lt;&gt; null then									//21.05.2024 navma1 #64201
			self.doUpdateTILocations(_mode,_newLocn, _passport);
		endif;
	elseif _mode = PLANNING_MODE and self.bolType = BOLType_Log then
		// we no longer set the TI planned location as we use self.myPlannedLocation when moving LOG BOLs
		return;	
	else	
		if _newLocn = null then
			app.raiseUnexpectedProgramError(class.name, method.name, 'Null Location Controller, contact developer');
			return;
		endif;
		
		inheritMethod(_mode, _newLocn, _passport);
	endif;

end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_newLocn" type="CM_LocationsController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doUpdateTILocations" id="908e6d9b-807d-4f67-8e25-03c89c5f900f">
        <updating/>
        <source>doUpdateTILocations(_mode: Integer; _newLocn: CM_LocationsController; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     23 October 2002		cnwth2	
// ----------   ----------  --------------------------------------------------
// 09/04/2013	cnwcs5	par 31521 - don't move the child cargo
vars
	ti			: CM_TrackedItem;
	controller	: CMIF_MoveController;
	coll		: Collection;
	obj			: Any;
	
begin
	coll := self.getTICollectionForTerminal(self.myTerminal);

	if coll.isEmpty then 	//Nothing to update
		return;
	endif;

	create controller transient;
	
	controller.setMoveMode(_mode);
	controller.setJobForMove(self.myYardJob);	
	
	controller.isSystemMove := true;

	foreach obj in coll do
		ti := obj.CM_TrackedItem;
		
		// par 31521 - don't try and move child cargo
		if ti.isChild then
			continue;
		endif;
		if ti.hasBeenMerged then	//31 Dec 2018	NDL	TFS 42430 - don't want zombies either
			continue;
		endif;
		
		controller.setMyToPrimaryLocation(ti.getPrimaryLocation(_mode));
		controller.setMyTrackedItem(ti);		
		
		app.myUtilityUA.utlUpdateMoveTrackedItem(controller, _passport);
	endforeach;

epilog
	delete controller;
end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_newLocn" type="CM_LocationsController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="erase" id="675f47ad-c6b0-4548-9e41-e054de2a73f7">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
//--------------------------------------------------------------
//Created: 01 November 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	
	if (not self.isTransient) and self.myExtension &lt;&gt; null then
		exclusiveLock(self.myExtension);	
		if (not self.isMatched) then
			self.myTerminal.causeEvent(self.myTerminal.getTerminalEvent(BOLRecon_Delete_Event), false, self);	
		endif;
	endif;
	
	inheritMethod(_eraseLevel);

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
