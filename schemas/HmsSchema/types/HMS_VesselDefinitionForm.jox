    <JadeMethod name="doResizeTopSheet" id="c9809462-e770-4921-b83a-be8868c9879f">
        <source>doResizeTopSheet()protected;
//--------------------------------------------------
// Created:	20 June 2005 By: cnwgd1
//--------------------------------------------------
vars
	topSheet : Sheet;
begin
	topSheet := self.fldShipDetails.topSheet;
	if topSheet = self.shtBerthDetails then							
		self.doResizeShtBerthDetails(topSheet);
	elseif topSheet = self.shtDimensions then
		self.doResizeShtDimensions(topSheet);
	elseif topSheet = self.shtGeneral then
		self.doResizeShtGeneral(topSheet);
	elseif topSheet = self.shtOwner then
		self.doResizeShtOwner(topSheet);
	elseif topSheet = self.shtPilotDetail then		
		self.doResizeShtPilotDetail(topSheet);
	elseif topSheet = self.shtStdResources then		
		self.doResizeShtResources(topSheet);
	elseif topSheet = self.shtSummary then		
		self.doResizeShtSummary(topSheet);
	elseif topSheet = self.shtTidalDetails then		
		self.doResizeShtTidalDetails(topSheet);						
	endif;	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSave" id="2cce1948-3fc4-4c7e-a719-c7269cde6ac4">
        <updating/>
        <source>doSave() : Boolean updating;
//--------------------------------------------------
// Created:	06 April 2005 By: cnwgd1
//--------------------------------------------------
vars
	result : Integer;
	hasFutureVoyage,
	rtnValue : Boolean;
	newHMSVessel : HMS_Object;
	newVessel,
	pxyVessel : CM_Vessel;
	pxyVesselData : HMS_VesselData;
	pxyVesselDataHarbour : HMS_VesselDataHarbour;
	conflictManager : CMIF_HMS_ConflictsManager;	
begin

	if (not self.checkSecurity(PmHMSShipMaint, "HMS Vessel Definition")) then
		return false;
	endif;

	if self.myHarbour = null then
		app.raiseCMException1(HMSNoHarbourForTerminal, self.myTerminal.name, null, null);
	endif;	

	app.mousePointer := Window.MousePointer_HourGlass;		
	
	rtnValue := self.checkTblBasicDimension();
	if (not rtnValue) then
		return rtnValue;
	endif;
	
	rtnValue := self.checkTblKeyDistances();
	if (not rtnValue) then
		return rtnValue;
	endif;
	
	if self.mode = self.Mode_Add and self.myCurrentVessel = null then
		// create new CM_Vessel object if user is Adding a new ship
		create pxyVessel transient;
	elseif self.mode = self.Mode_Update then
		beginLoad;
		pxyVessel := self.myCurrentVessel.pxyCreateUpdateProxy().CM_Vessel;
		endLoad;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid mode');
		return false;
	endif;	

	pxyVesselData := pxyVessel.myHMSVesselData;
	if 	pxyVesselData = null then
		create pxyVesselData transient;
		pxyVessel.setHMSVesselData(pxyVesselData);
	endif;

	pxyVesselData.setPxyMyRoot(app.myRoot);
		
	pxyVesselDataHarbour := pxyVesselData.allVesselDataForHarbour[self.myHarbour];
	if pxyVesselDataHarbour = null then
		create pxyVesselDataHarbour transient;
		pxyVesselData.allVesselDataForHarbour.add(pxyVesselDataHarbour);
	endif;		

	self.setPxyVessel(pxyVessel);
	self.setPxyVesselData(pxyVesselData);
	self.setPxyVesselDataHarbour(pxyVesselDataHarbour);

	if self.mode = self.Mode_Add then	
		app.myTrxCA.trxCreateVessel(pxyVessel, newVessel, conflictManager, app.myPassport);
		if newVessel &lt;&gt; null then
			// select the new one created
			self.setMyCurrentVessel(newVessel);
		endif;
		if (not app.myPassport.trxCompletedOK) then
			app.showErrorWarningDialog('HMS Vessel Definition', app.myPassport, ErrWarnMode_AddUpdate);
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			rtnValue := false;
			return false;
		else
			self.clearErrorWarnings();
		endif;
						
	elseif self.mode = self.Mode_Update then
		if pxyVessel.myHMSVesselData &lt;&gt; null then
			//checked planned voyages for update
			hasFutureVoyage := app.myRoot.checkVesselHasHMSVoyage(pxyVessel.code.trimBlanks, app.actualTimeServer());
			if hasFutureVoyage then
				if app.msgBox(app.getErrorString1(VesselHasPlannedVoyages, pxyVessel.code), 'Update Voyage', MsgBox_Information_Icon + MsgBox_Yes_No) = MsgBox_Return_No then
					hasFutureVoyage := false;								
				endif;
			endif;										
		endif;
		while true do
			app.myTrxUA.trxUpdateVessel(pxyVessel, hasFutureVoyage, false, conflictManager, app.myPassport);			
			if app.myPassport.trxCompletedOK then
				// Clear errors/warnings from form and err/warnings window
				self.clearErrorWarnings();
				break;
			else
				result := app.showErrorWarningDialog('HMS Vessel Definition', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   result = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			endif;
			rtnValue := false;				
			return false;
		endwhile;		
					
		rtnValue := true;			
	endif;	

	if conflictManager &lt;&gt; null then
		if (not conflictManager.allCMIFConflicts.isEmpty) then
			if app.msgBox('There are Voyages with conflicts in the system. Do you want to view the "Conflict Report" now?', 'View Conflict Report', MsgBox_Exclamation_Mark_Icon + MsgBox_Yes_No + MsgBox_Default_Second) = MsgBox_Return_Yes then
				self.myAssistant.showConflictsReport(conflictManager, self.myTerminal, self.myTerminal.myHarbour);
			else
				delete conflictManager;			
			endif;
		else
			delete conflictManager;
		endif;
	endif;

epilog
	app.mousePointer := Window.MousePointer_Default;
	endLoad;
	delete pxyVessel;
	return rtnValue;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doVesselChange" id="d238d234-3281-45f0-9d80-cda0d2662914">
