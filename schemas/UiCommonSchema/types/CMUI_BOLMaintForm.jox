    <JadeMethod name="doDelete" id="0d06d0d4-4bcb-496d-8ed6-0a8073742e5f">
        <source>doDelete();
//19 January 2010	cnwml2


vars
	pxyBOLItem : CM_BOLDtl;
	obj 	: Object;
begin
	if self.tblItems.row &gt; 1 and self.tblItems.allSelectedObjects.size &gt; 0 then					
		if app.msgBox(app.getErrorString1(Lit_Confirm_Delete, "Item(s)"), app.getErrorString(Confirm_Delete), MsgBox_Yes_No) = MsgBox_Return_Yes then		
			foreach obj in self.tblItems.allSelectedObjects do																		
				pxyBOLItem := obj.CM_BOLDtl;																
				if pxyBOLItem &lt;&gt; null and self.myProxyBOL.allBOLDtls.includes(pxyBOLItem) then
					delete pxyBOLItem;
				endif;
			endforeach;
			self.loadItemTable();
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
