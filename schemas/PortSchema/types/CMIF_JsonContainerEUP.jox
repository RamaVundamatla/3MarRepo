<Class name="CMIF_JsonContainerEUP" id="a326502d-9bf7-47a0-9eac-524f9028e171">
    <superclass name="CMIF_JsonTransform"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="edi"/>
    <PrimAttribute name="containerNumber" id="29513557-b397-4a24-9f2c-3e7551598313">
        <length>21</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <ImplicitInverseRef name="containerOperator" id="b4474181-6567-49fa-99bc-b3679cf571ef">
        <embedded/>
        <type name="CMIF_JsonContainerOperatorEUP"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <PrimAttribute name="containerSeal1" id="5a922f41-38a9-4f95-a601-b2cf60afd4dc">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="containerSizeType" id="4a25e80b-5647-4e88-9bf1-007c8bbefad8">
        <length>5</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="tareWeight" id="db634296-1356-47c1-a070-f6eb20b9661f">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <JadeMethod name="delete" id="709e1839-89cb-4e71-946f-74e0b74f011b">
        <updating/>
        <source>delete() updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 30 June 2023
TFS#		: 58505
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

begin
	if self.containerOperator &lt;&gt; null then
		delete self.containerOperator;
	endif;				
end;</source>
    </JadeMethod>
    <JadeMethod name="setFromTI" id="5c3cd882-2ecc-4af9-a9af-668231025aaf">
        <updating/>
        <source>setFromTI(_trackedItem : CM_TrackedItem input; _translationOperator : CM_Operator; _isForLoadConfirmation  : Boolean) updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 23 June 2023
TFS#		: 58506
Function	:

*** Changes ***
Date			Name		TFS#		Description
24/07/2023		jlika1		55938		EUP | Load Confirmation Protocol
6/10/2023		navra1		60396		EUP | FR 54085 - Load Confirmation - Field Mapping
****************************************************/

vars
	operatorTI : CM_Operator;
	operator : CMIF_JsonContainerOperatorEUP;
begin
	if _trackedItem &lt;&gt; null then
		self.containerNumber := _trackedItem.id;
		self.containerSizeType := _trackedItem.getISOType();
		operatorTI :=  _trackedItem.myOperator;
		
		if operatorTI &lt;&gt; null then			
			create operator transient;
			operator.setFromOperator(operatorTI,_translationOperator);
			
			self.containerOperator := operator;			
		endif;
		if _isForLoadConfirmation then			//navra1 - TFS 60396 - 6th Oct 2023
			self.containerSeal1 := _trackedItem.getSealNum();
			self.tareWeight := _trackedItem.weightTare.Integer;
		endif;
	endif;	
end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_translationOperator" type="CM_Operator"/>
        <Parameter name="_isForLoadConfirmation" type="Boolean"/>
    </JadeMethod>
</Class>
