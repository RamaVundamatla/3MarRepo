    <JadeMethod name="testInvConsByExtRef4" id="e335b541-9947-4bc0-a136-d25d98ef005f">
        <source>testInvConsByExtRef4();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 September 2024	jlier1	Initial creation

*/

vars
	invoice , transientInvoice: CM_Invoice;
	invLine : CM_InvoiceLine;
	q,q1 : Real;
		dynaDict : DynaDictionary;
		iter : Iterator;
