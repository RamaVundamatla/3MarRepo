    <JadeMethod name="createInvoiceCalcTypes" id="92d995db-8e2f-426e-8f9b-a2500d5fac95">
        <source>createInvoiceCalcTypes();
// in fact only creates new CM_CalculationType from newly-added InvoiceCalculationTypes global constants
//02/10/2025	navkc1 JIRA 36149 AAT | RotaBox ISO Type and New Attributes - Calculation Type
vars
	labels : StringArray;
	values : IntegerArray;
	tot, idx : Integer;
	theCode : String;
	aCT, pxyCalculationType : CM_CalculationType;

begin

	//app.initialize();				// removed call to initialize as it breaks initializeRoot if no default printer is set		// jlgmd1 10/01/2020
	create labels transient;
	create values transient;
	
	app.getAllInvoiceCalcTypes(true,true,labels,values,"CARGO");
	// set an internal flag to allow creation of internal 'CCT'-prefixed calculation type instances
	app.myPassport.setPropertyValue("useBGPCreateCharge", true);
	
	tot := 	values.size;
	create pxyCalculationType transient;
	foreach idx in 1 to tot do
		theCode := "CCT" &amp; values[idx].padLeadingWith("0",2);
		
		if app.myRoot.allCalculationTypesByCode[theCode] = null then
			
			pxyCalculationType.setProxy(null, //_booleans
										values[idx], //_calculationType
										theCode, //_code
										labels[idx],// _description
										null,null,null,null,null,false,null,null,null,null,null,
										null, null, null, null, true, false, false, false, // TFS 39198
										null, null, null, 0, false, false, 0); // ### TFS 51219 25MAY2021 NAVAB1
	
			if pxyCalculationType.createAsSystemType() then
				app.myUtilityCA.utlCreateCalculationType(pxyCalculationType, aCT, app.myPassport);
			endif;
		endif;
	endforeach;
	
	app.getAllInvoiceCalcTypes(true,true,labels,values,"EVENT");
	// set an internal flag to allow creation of internal 'ECT'-prefixed calculation type instances
	app.myPassport.setPropertyValue("useBGPCreateCharge", true);
	
	tot := 	values.size;
	create pxyCalculationType transient;
	foreach idx in 1 to tot do
		theCode := "ECT" &amp; values[idx].padLeadingWith("0",2);
		
		if app.myRoot.allCalculationTypesByCode[theCode] = null then
			pxyCalculationType.setProxy(null, //_booleans
										values[idx], //_calculationType
										theCode, //_code
										labels[idx],// _description
										null,null,null,null,null,false,null,null,null,null,null,
										null, null, null, null, false, false, true,false, // TFS 39198
										null, null, null, 0, false, false, 0); // ### TFS 51219 25MAY2021 NAVAB1
	
			app.myUtilityCA.utlCreateCalculationType(pxyCalculationType, aCT, app.myPassport);
		endif;
	endforeach;
	
	
	// TFS 39198
	app.getAllInvoiceCalcTypes(true,true,labels,values,"WORKORDER");
	// set an internal flag to allow creation of internal 'WO'-prefixed calculation type instances
	app.myPassport.setPropertyValue("useBGPCreateCharge", true);
	
	tot := 	values.size;
	create pxyCalculationType transient;
	foreach idx in 1 to tot do
		theCode := "WO" &amp; values[idx].padLeadingWith("0",2);
		
		if app.myRoot.allCalculationTypesByCode[theCode] = null then
			pxyCalculationType.setProxy(null, //_booleans
										values[idx], //_calculationType
										theCode, //_code
										labels[idx],// _description
										null,null,null,null,null,false,null,null,null,null,
										INV_CALC_TYPE_WO_UNITS,
										null, null, null, null, false, false, false, true, // TFS 39198
										null, null, null, 0, false, false, 0); // ### TFS 51219 25MAY2021 NAVAB1
	
			app.myUtilityCA.utlCreateCalculationType(pxyCalculationType, aCT, app.myPassport);
		endif;
	endforeach;

	//30 Oct 2019	NDL	TFS 47100
	app.getAllInvoiceCalcTypes(true,true,labels,values,"BOL");
	// set an internal flag to allow creation of internal 'WO'-prefixed calculation type instances
	app.myPassport.setPropertyValue("useBGPCreateCharge", true);
	
	tot := 	values.size;
	create pxyCalculationType transient;
	foreach idx in 1 to tot do
		theCode := "BOL" &amp; values[idx].padLeadingWith("0",2);
		
		if app.myRoot.allCalculationTypesByCode[theCode] = null then
			pxyCalculationType.setProxy(null, //_booleans
										values[idx], //_calculationType
										theCode, //_code
										labels[idx],// _description
										null,null,null,null,null,false,null,null,null,null,null,
										null, null, null, null, false, false, false, false, // TFS 39198
										null, null, null, 0, true, false, 0); // ### TFS 51219 25MAY2021 NAVAB1
	
			app.myUtilityCA.utlCreateCalculationType(pxyCalculationType, aCT, app.myPassport);
		endif;
	endforeach; 
	
	

	 // ### TFS 51219 25MAY2021 NAVAB1
	app.getAllInvoiceCalcTypes(true,true,labels,values,"INVENTORY");
	// set an internal flag to allow creation of internal 'WO'-prefixed calculation type instances
	app.myPassport.setPropertyValue("useBGPCreateCharge", true);
	
	tot := 	values.size;
	create pxyCalculationType transient;
	foreach idx in 1 to tot do
		theCode := "INV" &amp; values[idx].padLeadingWith("0",2);
		
		if app.myRoot.allCalculationTypesByCode[theCode] = null then
			pxyCalculationType.setProxy(null, //_booleans
										values[idx], //_calculationType
										theCode, //_code
										labels[idx],// _description
										null,null,null,null,null,false,null,null,null,null,null,
										null, null, null, null, false, false, false, false, // TFS 39198
										null, null, null, 0, false, true, 0); // ### TFS 51219 25MAY2021 NAVAB1
	
			app.myUtilityCA.utlCreateCalculationType(pxyCalculationType, aCT, app.myPassport);
		endif;
	endforeach; 
	
epilog
	app.myPassport.setPropertyValue("useBGPCreateCharge", false);
	delete labels;
	delete values;
end;</source>
    </JadeMethod>
    <JadeMethod name="createJMTSupportUser" id="3c19088f-2ec3-48d3-af36-716ac8ede01b">
        <updating/>
        <source>createJMTSupportUser() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		TFS		Reason
29 Aug 2019	jlgdi1	45802	Initial creation

*/

vars
	daSet : CM_DataAccessControllerSet;
	proxyUser : CM_User;	
	user : CM_User;
	terminal:CM_Terminal;
	pxyUserTerm: CM_UserTerminal;
	
begin
	create proxyUser transient;
	
	proxyUser.setProxy(JMTSUPPORT_Str, "Master Terminal Support", 0, CM_InternalOrganisation.firstInstance, app.myRoot, true, false, false, false, null, 
					  daSet, CM_SecurityRoleSystemRoot.firstInstance, null, app.myRoot.allEmailEntities, 
					  null, null, self.getDefaultLocale(true), false, false);
	
	foreach terminal in app.myRoot.allTerminals do
		pxyUserTerm := proxyUser.allUserTerminals[terminal];
		if pxyUserTerm = null then
			create pxyUserTerm transient;
		endif;
		pxyUserTerm.setForProxy(terminal, proxyUser, CM_SecurityRoleTerminalRoot.firstInstance, null, null, null);
	endforeach;
	
	if app.myPassport.allErrors.size &gt; 0 then
		app.writeStatement("set proxy for user failed");
		app.myPassport.inspect;
	endif;

	app.myUtilityCA.utlCreateUser(proxyUser, "password", user, app.myPassport);
	if app.myPassport.allErrors.size &gt; 0 then
		app.writeStatement( "create user failed");
		app.myPassport.inspect;
	endif;
	
	app.setJMTSupportPW();
	
epilog
	delete proxyUser;
end;</source>
    </JadeMethod>
    <JadeMethod name="createLocale" id="2f0e97d9-5379-49ad-b228-ee2386b12367">
        <source>createLocale(_localeName : String) : CM_Locale;
// ---------------------------------------------------------------------------
// Created:     01 April 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	jmtLocale	: CM_Locale;
	localTrx	: Boolean;
begin

	localTrx := (not process.isInTransactionState);
	exclusiveLock(self);
	
	jmtLocale := self.allLocales[_localeName];
	if jmtLocale = null then
		if localTrx then
			beginTransaction;
		endif;
		create jmtLocale persistent;
		jmtLocale.setForCreate(_localeName, null, false, self);
		if localTrx then
			commitTransaction;
		endif;
	endif;
	
	return jmtLocale;

epilog
	if localTrx then
		// do this regardless to clear any locks
		abortTransaction;
	endif;
end;</source>
        <Parameter name="_localeName" type="String"/>
        <ReturnType type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="createMachineTypes" id="9385584c-4f7a-4d14-bb0d-d55444a06d4c">
        <source>createMachineTypes() protected;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose: Only called from root contructor to create all the valid machine types.    
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	poxyMachineType, machineType : CM_MachineType;
	index : Integer;
	description : String;
begin
	foreach index in 0 to (MACHINETYPE_MAX) do
		// cnwrs1 aug 2006 only create for non null descriptions
		description := self.machineTypeDescription(index);
		if description &lt;&gt; null then
			// 06/08/2009 cnwsh3 CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
			if index = MACHINETYPE_WAGONRAIL then
				create poxyMachineType as CM_WagonMachineType transient;
			else
				create poxyMachineType as CM_MachineType transient;
			endif;
			poxyMachineType.setProxy(index, description, null, null, null, null);
			app.myUtilityCA.utlCreateMachineType(poxyMachineType, machineType, app.myPassport);
		endif;
	endforeach;	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="createMeasurementTypes" id="ecb083ab-0263-49db-ae80-0fa09f7f2ac2">
        <updating/>
        <source>createMeasurementTypes() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Changed On	By			Reason
----------	--------	-----------------------------------------------------
30/04/2013	cnwdap1		Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
23/06/2014	cnwdap1		PAR #34449 Remove trx methods and replace with utl methods
14 Nov 2022	navma1		ChangeRequest 55381: MTN - Store format's decimal precision on Measurement Type
*/
vars
	realMeasure, pxyMeasure	: CM_MeasurementType;

begin
	realMeasure := app.myRoot.allMeasurementTypesByShortName["kg"];
	if realMeasure = null then
		create pxyMeasure transient;
		pxyMeasure.setProxy(1, 13.0, true, true, true, true, "kg", Type_Weight, "Kilograms",0);					//14.11.2022 navma1 #55381
		app.myUtilityCA.utlCreateMeasurementType(pxyMeasure, realMeasure, app.myPassport);
	endif;
	
	realMeasure := app.myRoot.allMeasurementTypesByShortName["lbs"];
	if realMeasure = null then
		create pxyMeasure transient;
		pxyMeasure.setProxy(0.453592, 13.0, false, false, false, true, "lbs", Type_Weight, "Pounds",0);			//14.11.2022 navma1 #55381
		app.myUtilityCA.utlCreateMeasurementType(pxyMeasure, realMeasure, app.myPassport);
	endif;
	
	realMeasure := app.myRoot.allMeasurementTypesByShortName["ST"];
	if realMeasure = null then
		create pxyMeasure transient;
		pxyMeasure.setProxy(907.18474, 10.3, false, false, false, true, "ST", Type_Weight, "Short Ton",3);		//14.11.2022 navma1 #55381
		app.myUtilityCA.utlCreateMeasurementType(pxyMeasure, realMeasure, app.myPassport);
	endif;
	
	realMeasure := app.myRoot.allMeasurementTypesByShortName["MT"];
	if realMeasure = null then
		create pxyMeasure transient;
		pxyMeasure.setProxy(1000, 10.3, false, false, false, true, "MT", Type_Weight, "Metric Tonne",3);	 	 //14.11.2022 navma1 #55381
		app.myUtilityCA.utlCreateMeasurementType(pxyMeasure, realMeasure, app.myPassport);
	endif;
	
	realMeasure := app.myRoot.allMeasurementTypesByShortName["LT"];
	if realMeasure = null then
		create pxyMeasure transient;
		pxyMeasure.setProxy(1016.04691, 10.3, false, false, false, true, "LT", Type_Weight, "Long Ton",3);		//14.11.2022 navma1 #55381
		app.myUtilityCA.utlCreateMeasurementType(pxyMeasure, realMeasure, app.myPassport);
	endif;
	
	// LINEAR MEASUREMENTS
	realMeasure := app.myRoot.allMeasurementTypesByShortName["cm"];
	if realMeasure = null then
		create pxyMeasure transient;
		pxyMeasure.setProxy(1, 13.0, true, true, true, true, "cm", Type_Linear, "Centimetre",0);				//14.11.2022 navma1 #55381
		app.myUtilityCA.utlCreateMeasurementType(pxyMeasure, realMeasure, app.myPassport);
	endif;
	
	realMeasure := app.myRoot.allMeasurementTypesByShortName["ft"];
	if realMeasure = null then
		create pxyMeasure transient;
		pxyMeasure.setProxy(30.48, 9.2, false, false, false, true, "ft", Type_Linear, "Foot",2);				//14.11.2022 navma1 #55381
		app.myUtilityCA.utlCreateMeasurementType(pxyMeasure, realMeasure, app.myPassport);
	endif;
	
	
	// VOLUME
	realMeasure := app.myRoot.allMeasurementTypesByShortName["m3"];
	if realMeasure = null then
		create pxyMeasure transient;
		pxyMeasure.setProxy(1, 13.4, true, true, true, true, "m3", Type_Volume, "Cubic Metre",4);				//14.11.2022 navma1 #55381
		app.myUtilityCA.utlCreateMeasurementType(pxyMeasure, realMeasure, app.myPassport);
	endif;
	
	realMeasure := app.myRoot.allMeasurementTypesByShortName["ft3"];
	if realMeasure = null then
		create pxyMeasure transient;
		pxyMeasure.setProxy(0.028316847, 9.2, false, false, false, true, "ft3", Type_Volume, "Cubic Foot",2);	//14.11.2022 navma1 #55381
		app.myUtilityCA.utlCreateMeasurementType(pxyMeasure, realMeasure, app.myPassport);
	endif;
	
	// DENSITY
	realMeasure := app.myRoot.allMeasurementTypesByShortName["kg/m3"];
	if realMeasure = null then
		create pxyMeasure transient;
		pxyMeasure.setProxy(1, 13.4, true, true, true, true, "kg/m3", Type_Density, "KG per Cubic Metre",4);	//14.11.2022 navma1 #55381
		app.myUtilityCA.utlCreateMeasurementType(pxyMeasure, realMeasure, app.myPassport);
	endif;
	
	// DISPLACEMENT
	realMeasure := app.myRoot.allMeasurementTypesByShortName["m3/hr"];
	if realMeasure = null then
		create pxyMeasure transient;
		pxyMeasure.setProxy(1, 5.2, true, true, true, true, "m3/hr", Type_Displacement, "Cubic Metre per Hour",2); //14.11.2022 navma1 #55381
		app.myUtilityCA.utlCreateMeasurementType(pxyMeasure, realMeasure, app.myPassport);
	endif;
	
	// STOWAGE FACTOR
	realMeasure := app.myRoot.allMeasurementTypesByShortName["m3/MT"];
	if realMeasure = null then
		create pxyMeasure transient;
		pxyMeasure.setProxy(1, 10.0, true, true, true, true, "m3/MT", Type_StowageFactor, "Cubic metres per tonne",0);	//14.11.2022 navma1 #55381
		app.myUtilityCA.utlCreateMeasurementType(pxyMeasure, realMeasure, app.myPassport);		// PAR #34449
	endif;
	
	realMeasure := app.myRoot.allMeasurementTypesByShortName["ft3/LT"];
	if realMeasure = null then
		create pxyMeasure transient;
		pxyMeasure.setProxy(0.0278696253, 13.4, true, false, true, true, "ft3/LT", Type_StowageFactor, "Cubic feet per long ton",4);	//14.11.2022 navma1 #55381

		app.myUtilityCA.utlCreateMeasurementType(pxyMeasure, realMeasure, app.myPassport);		// PAR #34449
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="createNavOpsViewUser" id="c9329070-60c4-4aed-9d5c-31e872f9ccc3">
        <updating/>
        <source>createNavOpsViewUser()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Sep 2020 cnwma1 ChangeRequest 49758: MTN - Navis Smart Data API - Snapshot Data

*/

vars
	dac			: CM_DataAccessControllerSet;
	proxyUser 	: CM_User;	
	user 		: CM_User;
	terminal	: CM_Terminal;
	pxyUserTerm : CM_UserTerminal;
	
begin
	create proxyUser transient;
	
	proxyUser.setProxy(OPSVIEWUSER_Str, 
					"Navis Ops View User",
					0,
					CM_InternalOrganisation.firstInstance,
					app.myRoot,
					true,
					false,
					false,
					false,
					null, 
					dac, 
					CM_SecurityRoleSystemRoot.firstInstance, 
					null, 
					app.myRoot.allEmailEntities, 
					null,
					null,
					self.getDefaultLocale(true),
					false,
					false);
	
	foreach terminal in app.myRoot.allTerminals do
		pxyUserTerm := proxyUser.allUserTerminals[terminal];
		if pxyUserTerm = null then
			create pxyUserTerm transient;
		endif;
		pxyUserTerm.setForProxy(terminal, proxyUser, CM_SecurityRoleTerminalRoot.firstInstance, null, null, null);
	endforeach;
	
	if app.myPassport.allErrors.size &gt; 0 then
		app.writeStatement("set proxy for user failed");
		app.myPassport.inspect;
	endif;

	app.myUtilityCA.utlCreateUser(proxyUser, "password", user, app.myPassport);
	
	if app.myPassport.allErrors.size &gt; 0 then
		app.writeStatement( "create user failed");
		app.myPassport.inspect;
	endif;
	
	app.setNavOpsViewPW();
	
epilog
	delete proxyUser;
end;</source>
    </JadeMethod>
    <JadeMethod name="createNullCarrier" id="843df17f-c8da-4a8e-bbc6-c0262dd94ad6">
        <source>createNullCarrier();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 30/01/2015	cnwdap1		Initial creation PAR #35610 
// 12/05/2022 	navhl20 	TFS 53430  EUP - Sub Carrier registration in MTN
//
vars
	carrier			: CM_Carrier;
	pxyCarrier		: CM_Carrier;
	pinAddresses	: CM_EmailEntityByTypeNameDict;

begin
	carrier := self.allCarriers[NULL_CARRIER_CODE];
	if carrier = null then
		create pinAddresses transient;
		create pxyCarrier transient;
		//pxyCarrier.setProxy(NULL_CARRIER_CODE, "Null Carrier", pinAddresses, false, false, true, null, null, null, null);				//12/05/2022 navhl20 TFS 53430
		pxyCarrier.setProxy(NULL_CARRIER_CODE, "Null Carrier", pinAddresses, false, false, true, false, null, null, null, null);		//12/05/2022 navhl20 TFS 53430
		app.myUtilityCA.utlCreateCarrier(pxyCarrier, carrier, app.myPassport);
	endif;
epilog
	delete pinAddresses;
	delete pxyCarrier;
end;</source>
    </JadeMethod>
