    <JadeMethod name="getMyTerminal" id="b121f373-425c-42e6-8c37-67d6dc56218c">
        <source>getMyTerminal(): CM_Terminal;
/*
Purpose:		TFS 2682	
Date		Who		Reason
15 September 2016	cnwab1	Initial creation
*/

vars
	bu : CM_Bank;
begin
	bu := self.getBank();
	
	if bu = null then
		return null;
	endif;
	
	return bu.getMyTerminal();

epilog

end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getServiceBroker" id="b9b87967-dd94-4c9b-85f6-db7f196af048">
        <source>getServiceBroker(_theTransaction: CM_EventTransaction) : CM_EventServiceBroker;
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance
09 May 219	jlgzm1	TFS 42038 1099 error, changing collection's keys
23 Oct 2024 navlw1  JIRA-33107: Invoice Logging Use Levels
25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/

vars
	theBroker : CM_EventServiceBroker;
	theEvent : CM_EventType;
	invalid 		: Boolean;
	canLogExtra	: Boolean;	//28.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//28.02.2025 navah1	#34141
	if _theTransaction = null then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject(exception, _theTransaction, invalid);
	theEvent := _theTransaction.myEventType;

	if invalid or theEvent = null then
		return null;
	endif;
	
	theBroker := self.allEventServiceBrokers[theEvent];
	if theBroker &lt;&gt; null then
		if canLogExtra then	//28.02.2025 navah1	#34141
			app.invLog("Event map found for " &amp; theEvent.name, LogTRACE.String);
		endif;
	endif;
	
	if theBroker = null then
		//theBroker := self.allEventServiceBrokers[null]; // DEFAULT
		//tfs42038 start
		foreach theBroker in self.allEventServiceBrokers do
			// would expect null/default event to be first in the collection, but may not be
			if theBroker.myEventType = null then
				break;
			endif;
		endforeach;
		//tfs42038 end
		if canLogExtra then	//28.02.2025 navah1	#34141
			app.invLog("Event map DEFAULT used", LogTRACE.String);
		endif;
	endif;
	return theBroker;
end;</source>
        <Parameter name="_theTransaction" type="CM_EventTransaction"/>
        <ReturnType type="CM_EventServiceBroker"/>
    </JadeMethod>
