    <JadeMethod name="uCreateVoyageLoadJobs" id="9fc667ca-c19d-4cee-a2d2-1734a69355ad">
        <source>uCreateVoyageLoadJobs();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 December 2008	cnwer1	Initial creation

*/

vars
	voyage : CM_Voyage;
	voyageJob : CM_VoyageJob;
	slots : CM_SlotControllerArray;
	tmpLoadCC	: CMIF_LoadColorCode;
begin
	//create a voyage job for bay 
	
	voyage := self.getTerminal.allVoyagesByCode.getAtKeyGeq(self.getVoyageName, null);
	create slots transient;
	self.getJobSlotControllers(self.getVoyageName,"09",DeckOnDeck,1,1,20,slots);
	
	create tmpLoadCC transient;
	tmpLoadCC.overrideMoveType :=true;
	tmpLoadCC.myDischargePort:=app.myRoot.allPorts["AUBNE"];
	// i think if we just create it it will mark them as a load job 
	//can then specify cargo. commodity and discharge port
	self.markSlotsAsLoadJob(slots,tmpLoadCC);
	
	voyageJob:=self.addVoyageJob(voyage,"J10",slots, false);
	
	assertTrue(voyageJob &lt;&gt; null);

epilog
	delete slots;
	delete tmpLoadCC;

end;</source>
    </JadeMethod>
    <JadeMethod name="uDeleteContainers" id="333beaaa-b88b-4c35-972f-5a63be981f8f">
        <source>uDeleteContainers();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 December 2008	cnwer1	Initial creation

*/

vars
ti : CM_TrackedItem;
	ids : StringArray;
	id : String;
	stradStack : CM_StraddleStack;
	allAssocs: ObjectArray;
	obj		: Object;
	assoc : CM_AssociationDict;
begin
	//self.deleteContainer("TEST0000001");
	create allAssocs transient;
	stradStack:=self.getTerminal.allTerminalAreas["UTSTRDA"].CM_StraddleStack;
	self.getAllContainerDetails(0,0,stradStack,null,null,null,null,null,null,allAssocs);
	//self.getAllContainerDetails(stradStack,0,ids,null,null);
	stradStack:=self.getTerminal.allTerminalAreas["UTSTRDB"].CM_StraddleStack;
	self.getAllContainerDetails(allAssocs.size,0,stradStack,null,null,null,null,null,null,allAssocs);
	//self.getAllContainerDetails(stradStack,ids.size,ids,null,null);
	stradStack:=self.getTerminal.allTerminalAreas["UTSTRDC"].CM_StraddleStack;
	self.getAllContainerDetails(allAssocs.size,0,stradStack,null,null,null,null,null,null,allAssocs);
	//self.getAllContainerDetails(stradStack,ids.size,ids,null,null);
	
	foreach 	obj in allAssocs do
		assoc:=obj.CM_AssociationDict;
		id:=assoc.str("ID");
		
		ti := self.getTerminal.lookupTrackedItem(id, TI_CargoType_Container, TI_STATE_NORMAL, null, false);
		if ti = null then
			continue;
		endif;
		self.assertTrue(ti &lt;&gt; null);
		
		beginTransaction;
		ti.invoiceLines.purge;
		commitTransaction;
		
		self.deleteTrackedItem(ti, false); // AKB added false
		ti := self.getTerminal.lookupTrackedItem(id, TI_CargoType_Container, TI_STATE_NORMAL, null, false);
		self.assertTrue(ti = null);
	endforeach;
	
	app.myPassport.clearErrorsWarnings();	// to prevent reporting of leaking transients when running in suite.

epilog
	
	allAssocs.purge;
	delete allAssocs;

end;</source>
    </JadeMethod>
