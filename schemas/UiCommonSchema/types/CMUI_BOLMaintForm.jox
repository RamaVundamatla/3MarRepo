    <JadeMethod name="btnClear_click" id="d638406b-83eb-4021-b4d2-89f9fbd9ddf9">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnClear_click(btn: Button input) updating;
//06 January 2010	cnwml2


vars

begin
	self.txtBOL.text := null;
	self.cmbOperator.setIndexFromObject(null);
	self.cmbVoyage.setIndexFromObject(null);
	self.cmbNofiyParty.setIndexFromObject(null);
	
	if self.myProxyBOL &lt;&gt; null then
		delete self.myProxyBOL;
	endif;
	self.tblItems.rows:=1;
	self.tblItems.allSelectedObjects.clear;
	
	self.setMyCurrentBOL(null);
	self.setMode(Mode_Add);
	
	
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
