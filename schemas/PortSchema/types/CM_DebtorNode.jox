    <JadeMethod name="setForCreate" id="f41f7f4f-835a-44b6-ba3e-22acefef6ddd">
        <updating/>
        <source>setForCreate(_debtorNodeController: CMIF_DebtorNode) updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
//13/09/17 jlgns1 TFS 6921 1201 : ADP Kernel stack overflow

vars
	parentNode	: CM_DebtorNode;
begin
	self.setFPE(app.myRoot.myRootCompany.getDefaultFPE()); // CCMS 1125 added
	self.bank := app.myRoot.myRootCompany;
	
	parentNode := _debtorNodeController.myParentDebtorNode;												//TFS 6921
																										//TFS 6921
	if self.isRootDebtorGroup() and parentNode &lt;&gt; null then												//TFS 6921
		app.raiseCMException(Root_debtor_cannot_have_parent,parentNode.name,self);						//TFS 6921
	endif;																								//TFS 6921
																										//TFS 6921
	if parentNode &lt;&gt; null and parentNode.checkParentage(self) then										//TFS 6921
		app.raiseCMException2(Already_incompat_relat_between ,self.name,parentNode.name, null, null);	//TFS 6921
	endif;
end;</source>
        <Parameter name="_debtorNodeController" type="CMIF_DebtorNode"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="acf10c4e-3aeb-456b-98e7-78e88e7f258a">
        <updating/>
        <source>setForUpdate(_debtorNodeController : CMIF_DebtorNode) updating;
//----------------------------------------------------------------
//	Created:	23 January 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//13/09/17 jlgns1 TFS 6921 1201 : ADP Kernel stack overflow
//02/05/2023 navra1 TFS 57086 - EUP - Customer Update - New Fields incl Debtor Details incl Financial ID
vars
	parentNode	: CM_DebtorNode;
begin
	// Apr 2012 load from file where parent is loaded with (and before) this
	parentNode := _debtorNodeController.myParentDebtorNode;
	if parentNode = null and
	   _debtorNodeController.parentNodeName &lt;&gt; null then
		parentNode := app.myRoot.myRootCompany.debtorNodes[_debtorNodeController.parentNodeName];
	endif;
	
	if self.isRootDebtorGroup() and parentNode &lt;&gt; null then												//TFS 6921
		app.raiseCMException(Root_debtor_cannot_have_parent,parentNode.name,self);						//TFS 6921
	endif;																								//TFS 6921
	if parentNode &lt;&gt; null and parentNode.checkParentage(self) then										//TFS 6921
		app.raiseCMException2(Already_incompat_relat_between ,self.name,parentNode.name, null, null);	//TFS 6921
	endif;																								//TFS 6921
	
	self.setGroup(parentNode);
	self.isSuspended    		  := _debtorNodeController.isSuspended;
	self.isZeroRatedTax 		  := _debtorNodeController.isZeroRated;
	self.badDebtor     		  	  := _debtorNodeController.badDebtor;
	self.name 		    		  := _debtorNodeController.name;
	self.remarks 				  := _debtorNodeController.remarks;
	self.isPurchaseOrderMandatory := _debtorNodeController.isPurchaseOrderMandatory;
	self.taxNumber				  := _debtorNodeController.taxNumber;								//navra1 - TFS 57086 - 2nd May 2023
	self.myTaxCountry			  := _debtorNodeController.taxCountry;								//navra1 - TFS 57086 - 2nd May 2023
end;
</source>
        <Parameter name="_debtorNodeController" type="CMIF_DebtorNode"/>
    </JadeMethod>
