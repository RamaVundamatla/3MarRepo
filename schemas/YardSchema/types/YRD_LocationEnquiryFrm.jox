    <JadeMethod name="filterTblInitWithLC" id="c414d939-f295-4920-8f6f-b99e38749ca2">
        <updating/>
        <source>filterTblInitWithLC() updating;
//--------------------------------------------------
// Created:	20 August 2003 By: cnwgd1
//--------------------------------------------------
vars
	voyage : CM_Voyage;
begin

	
	
	inheritMethod();
	//epr TFS 47132 30/12/19
	if self.useSelectorTable then
		return;
	endif;
	
	if self.myCurrentObject &lt;&gt; null then
		if self.myCurrentObject.isKindOf(CM_VoyageController) then
			voyage := self.myCurrentObject.CM_VoyageController.myVoyage;
		endif;
	endif;
	if voyage &lt;&gt; null and voyage.archived then
		self.myAssistant.comboBoxVoyageCurrent(	self.cmbFiltVoyage,
												voyage,
												true,
												true,
												self.includeSailedVoyages,
												true,
												true,
												true,
												true,
												false,
												false);	//cnwrs1 par15258 nov 2007
	else
		self.myAssistant.comboBoxVoyageCurrent(	self.cmbFiltVoyage,
												voyage,
												true,
												self.includeArchivedVoyages,
												self.includeSailedVoyages,
												true,
												true,
												true,
												true,
												false,
												false);	
	endif;
	self.cmbFiltVoyage.lostFocus(self.cmbFiltVoyage);
end;</source>
    </JadeMethod>
