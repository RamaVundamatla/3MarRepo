<GUIClass name="CMUI_AddFutureStAnniversary" id="1d905f5d-e1e7-4652-81be-af259710445f">
    <superclass name="CMUI_AdditionalFreeStorage"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <JadeMethod name="doOK" id="7028e9f8-c55c-4c1b-8fe8-c2a2773c638c">
        <updating/>
        <source>doOK() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 June 2023 navmv20 CR 58373 Task 58381: Jade - Future Storage Additional Days
*/
	
vars
	result : Integer;
	ti     : CM_TrackedItem;
	
begin
	while true do
		app.myTrxUA.trxUpdateFutureStorageDays(self.allTrackedItems,self.txtAddDays.text.Integer, self.txtReason.text, app.myPassport);
		if app.myPassport.trxCompletedOK then
			if self.allTrackedItems.size() &gt; 1 then
				app.msgBox( app.getErrorString1(Cargos_updated,self.allTrackedItems.size.String), app.getErrorString(Information) , MsgBox_OK_Only + MsgBox_Information_Icon);
			elseif self.allTrackedItems.size() = 1 then
				app.msgBox( app.getErrorString(Future_storag_annive_cargo_upd), app.getErrorString(Information) , MsgBox_OK_Only + MsgBox_Information_Icon);
			endif;
			break;
		else
			result:= app.showErrorWarningDialog(app.getErrorString(Error), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
	endwhile; 
	self.modalResult := IDOK;
	self.unloadForm;
epilog

end;</source>
    </JadeMethod>
