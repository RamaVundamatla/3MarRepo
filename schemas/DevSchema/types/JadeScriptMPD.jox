	write "13 " &amp; (13).Decimal.amountInArabicWords;
	write "14 " &amp; (14).Decimal.amountInArabicWords;
	write "15 " &amp; (15).Decimal.amountInArabicWords;
	write "16 " &amp; (16).Decimal.amountInArabicWords;
	write "17 " &amp; (17).Decimal.amountInArabicWords;
	write "18 " &amp; (18).Decimal.amountInArabicWords;
	write "19 " &amp; (19).Decimal.amountInArabicWords;
	
	write "20 " &amp; (20).Decimal.amountInArabicWords;
	write "21 " &amp; (21).Decimal.amountInArabicWords;
	write "22 " &amp; (22).Decimal.amountInArabicWords;
	write "23 " &amp; (23).Decimal.amountInArabicWords;
	write "24 " &amp; (24).Decimal.amountInArabicWords;
	write "25 " &amp; (25).Decimal.amountInArabicWords;
	write "26 " &amp; (26).Decimal.amountInArabicWords;
	write "27 " &amp; (27).Decimal.amountInArabicWords;
	write "28 " &amp; (28).Decimal.amountInArabicWords;
	write "29 " &amp; (29).Decimal.amountInArabicWords;
	
	write "30 " &amp; (30).Decimal.amountInArabicWords;
	write "31 " &amp; (31).Decimal.amountInArabicWords;
	write "32 " &amp; (32).Decimal.amountInArabicWords;
	write "33 " &amp; (33).Decimal.amountInArabicWords;
	write "34 " &amp; (34).Decimal.amountInArabicWords;
