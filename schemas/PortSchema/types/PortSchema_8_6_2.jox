    <JadeMethod name="createBOLDebtorTypes" id="6e187660-de56-418f-9818-41109873ed89">
        <source>createBOLDebtorTypes(_updController : CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 October 2019	jlgndl1	Initial creation	TFS 47100

*/

vars
	debtorType : CM_DebtorType;

begin
	if self.hasScriptBeenRunAtAll(method.name, _updController) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Creating BOL Debtor Types", LogINFO);
	if _updController &lt;&gt; null then
		_updController.logEntry(" Creating BOL Debtor Types") ;	
	endif;
	
	beginTransaction;
	if app.myRoot.allDebtorTypes["SDT11"] = null then
		create debtorType;
		debtorType.setForCreateParam("SDT11", "BOL Operator");
	endif;
	if app.myRoot.allDebtorTypes["SDT12"] = null then
		create debtorType;
		debtorType.setForCreateParam("SDT12", "BOL Item First Consignee");
	endif;
	if app.myRoot.allDebtorTypes["SDT13"] = null then
		create debtorType;
		debtorType.setForCreateParam("SDT13", "BOL Item First Consignor");
	endif;
	if app.myRoot.allDebtorTypes["SDT14"] = null then
		create debtorType;
		debtorType.setForCreateParam("SDT14", "BOL Voyage Operator");
	endif;
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Creating BOL Debtor Types complete", LogINFO);
	if _updController &lt;&gt; null then
		_updController.logEntry(" Creating BOL Debtor Types complete") ;	
	endif;
	
	self.addScriptRun(method.name);
epilog

end;</source>
