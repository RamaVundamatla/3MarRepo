    <JadeMethod name="getReserveSelectionCriteria" id="9ff1eb60-148a-4ebc-bf73-e2fb0dd7892a">
        <source>getReserveSelectionCriteria():CM_ReleaseByTypeCriteria;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 June 2015	cnwndl1	Initial creation	Par 36338

*/

vars

begin

	if self.myReserveSelection &lt;&gt; null then
		return self.myReserveSelection.myReleaseCriteria;
	elseif self.myDeliveryRequest &lt;&gt; null then
		return self.myDeliveryRequest.getReserveSelectionCriteria();
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="CM_ReleaseByTypeCriteria"/>
    </JadeMethod>
    <JadeMethod name="hasAllocation" id="6d04c599-7693-47d2-b33d-fbbe91c392a6">
