    <JadeMethod name="addString" id="a489e301-7059-4e0c-b0a6-6ba225951be9">
        <lockReceiver/>
        <updating/>
        <source>addString(pStringValue: String): Integer updating, lockReceiver;
// --------------------------------------------------------------------------------
// Created:		30 June 2001 by cnwdad1
//
// Purpose:		Adds a new element to the array with the specified string value.
//
// Parameters:	pStringValue (String) - The string value for the new array element.
//
// Returns:		Integer - The index of the new array element.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	substringObj	: CnEcSubstringObject;
	index			: Integer;

begin
	substringObj	:=	self.createEntry();
	substringObj.setStringValue(pStringValue);
	index			:=	self.size() + 1;
	self.atPut(index, substringObj);
epilog
	return index;
end;</source>
        <Parameter name="pStringValue" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addStringAt" id="e0f8287d-7c5c-42a3-998a-bce2e5e517aa">
        <lockReceiver/>
        <updating/>
        <source>addStringAt(pIndex: Integer; pStringValue: String) updating, lockReceiver;
// --------------------------------------------------------------------------------
// Created:		30 June 2001 by cnwdad1
//
// Purpose:		Inserts a new element into the array at the specified index position
//				and with the specified string value.
//
// Parameters:	pStringValue (String) - The string value for the new array element.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	substringObj	: CnEcSubstringObject;

begin
	substringObj	:=	self.createEntry();
	substringObj.setStringValue(pStringValue);
	self.atPut(pIndex, substringObj);
end;</source>
        <Parameter name="pIndex" type="Integer"/>
        <Parameter name="pStringValue" type="String"/>
    </JadeMethod>
    <JadeMethod name="createEntry" id="f03a86a6-8b28-4022-b2b5-60ce4b3ed214">
        <lockReceiver/>
        <updating/>
        <source>createEntry(): CnEcSubstringObject updating, protected, lockReceiver;
// --------------------------------------------------------------------------------
// Created:		30 June 2001 by cnwdad1
//
// Purpose:		Private method to create a new CnEcSubstringObject instance for a
//				new element in the array.
//
// Parameters:	None
//
// Returns:		CnEcSubstringObject - The newly created array member.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	substringObj	: CnEcSubstringObject;

begin
	if self.isTransient() then
		create substringObj transient;
	else
		create substringObj;
	endif;
epilog
	return substringObj;
end;</source>
        <access>protected</access>
        <ReturnType type="CnEcSubstringObject"/>
    </JadeMethod>
