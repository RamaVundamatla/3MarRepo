    <JadeMethod name="wsRESTPostSendEDI" id="7cd1eda3-f074-4970-b726-e056d892aaa7">
        <source>wsRESTPostSendEDI(_wsRequest: String; _testScenarioName: String): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 25 May 2023	navdap1		Initial creation TFS 
// 08 Jun 2023	navra1		TFS 58270 - Task - 57074 Load Rail Manifest Message
// 13 Jun 2024	navmd1		TFS 61725 Change to actually accept Euroports formatted messages
// 13 Nov 2025	navah1		MTN-34410: MTN | GET /ediStatus implementation
vars
	request				: WS_RestSendEDIRequest;
	requestLogin		: WS_RESTLoginAuthRequest;
	webService			: MasterTerminalAPIService;
	parser				: JadeJson;
	transientJSONObjs	: ObjectArray;
	response 			: WS_Response;
	responseLogin  		: WS_NAuthTokenResponse;
	ref 				: String;
	webRequestStr		: String;
	
begin	
	
	create webService transient;
	create parser transient;
	create transientJSONObjs transient;		
	
	webRequestStr := _wsRequest;
	
	if _testScenarioName = "EuroportsOperator" then
		self.loginRestWithOperator(webService, "Euroports");
		
		// Do 'processRequest' stuff
		webService.setPropertyValue(WS_RestWebServiceProvider::preTransformedRequest.name, webRequestStr);
		// transformRequest(_httpIn: String; _queryStr: String; _pathIn: String; _methodType: String) : String updating, protected;
		webRequestStr := webService.sendMsgWithParams(MasterTerminalAPIService::transformRequest.name, webRequestStr, null, "/sendedi", "POST").String;
	else
		self.loginREST(webService);	
	endif;

	request := parser.parse(webRequestStr, WS_RestSendEDIRequest, transientJSONObjs).WS_RestSendEDIRequest;
	
	//13.11.2025 navah1 #MTN-34410 Start
	//webService.setPropertyValue(WS_RestWebServiceProvider::requestPath.name, "/sendedi");
	//response := webService.postSendEDI(request);
	webService.setPropertyValue(WS_RestWebServiceProvider::requestPath.name, "/edi");
	response := webService.postEdi(request);
	//13.11.2025 navah1 #MTN-34410 End
	
	if _testScenarioName = "EuroportsOperator" then
		// do 'reply' stuff
		webService.reply(response.getErrorsAsStringForTesting());
	endif;
	
	return null;
	
	// Not used,just here to provide a reference from the super schema super class method 
	ref := CM_UnitTestAgent::wsRESTPostSendEDI.name; 
epilog
	delete webService;
	delete parser;
	delete requestLogin;
	delete request;
	transientJSONObjs.purge();
	delete transientJSONObjs;
	delete response;
	delete responseLogin;
end;</source>
        <Parameter name="_wsRequest" type="String"/>
        <Parameter name="_testScenarioName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
