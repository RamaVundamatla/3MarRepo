    <JadeMethod name="deleteWorkPoint" id="f1876137-ab45-450e-99ed-ff94cbaa96f8">
        <source>deleteWorkPoint(_code : String);
//
//27 November 2017	jlgrs1	Initial creation
//
vars
	realWorkPoint : CM_WorkPoint;
	obj : Object;
	objArray : ObjectArray;
	voyage		: CM_Voyage;
	
	jobSheetArray		: CM_VoyageJobSheetArray;

begin
	realWorkPoint := self.getTerminal.allWorkPointsByCode[_code];
	if realWorkPoint &lt;&gt; null then
		beginTransaction;
		foreach obj in realWorkPoint.allCraneOpHrsExchange do
			delete obj;
		endforeach;
		foreach obj in realWorkPoint.allCraneOpHrsLabour do
			delete obj;
		endforeach;
		foreach obj in realWorkPoint.allDelays do
			delete obj;
		endforeach;
		foreach obj in realWorkPoint.allKPIVoyageMoveDtls do
			delete obj;
		endforeach;
		///foreach obj in realWorkPoint.allVoyageWorkPointQueues do
		///	delete obj;
		///endforeach;
		commitTransaction;
				
		///foreach obj in realWorkPoint.allJobSheets do
		///	self.deleteVoyageJobSheet(obj.CM_VoyageJobSheet);
		///endforeach; 
		
		create objArray transient;
		realWorkPoint.allVoyageWorkPointQueues.copy(objArray);
		foreach obj in objArray do
			self.deleteQueue(obj.CM_VoyageWorkPointQueue);
		endforeach;
		
		voyage := self.opts.obj("Voyage").CM_Voyage;
		
		create jobSheetArray transient;
		realWorkPoint.allJobSheets.copy(jobSheetArray);
		foreach obj in jobSheetArray do
			self.deleteVoyageJobSheet(obj.CM_VoyageJobSheet);
		endforeach; 
		
		app.myTrxDA.trxDeleteWorkPoint(realWorkPoint, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;
	
epilog

	delete jobSheetArray;
	delete objArray;

end;</source>
        <Parameter name="_code" type="String"/>
    </JadeMethod>
    <JadeMethod name="deleteWorkPointJobSheet" id="4126650f-c803-4968-839f-4e02e0a8b51a">
        <source>deleteWorkPointJobSheet(_jobSheetId : String);
/*

Purpose:		Delete Work Point Job Sheet	

Parameters:			

Return Value:		

Date		Who		Reason
06/10/2023	navmh5	Initial Creation
*/
vars

	jobSheet 			: CM_WorkPointJobSheet;
	terminal			: CM_Terminal;
	
begin

	terminal := self.getTerminal();
	self.assertNotNullMsg(terminal, "Terminal not set");
	
	jobSheet := terminal.getWorkPointJobSheet(_jobSheetId);
	if jobSheet &lt;&gt; null then // only want to delete it if we find a job sheet
		app.myTrxDA.trxDeleteWorkPointJobSheet(jobSheet, app.myPassport);
	endif;

epilog

end;
</source>
        <Parameter name="_jobSheetId" type="String"/>
    </JadeMethod>
    <JadeMethod name="deleteYA" id="6e82de1a-01c5-4ec1-83c2-ddbc4b705443">
        <source>deleteYA(name: String);
//17 July 2008	cnwdw1	
//
vars
	ya : CM_YardAllocation;
	tempCode 				: String;
begin

	// 17/03/2018 jlgmh5
	tempCode := name;
	if tempCode.length &gt; 50 then
		tempCode := tempCode[1:50];
	endif;

	ya := self.getTerminal.allYardAllocatonsByCode[tempCode];
	if ya &lt;&gt; null then
		app.myTrxDA.trxDeleteYardAllocation(ya, app.myPassport);
		self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	endif;
end;</source>
