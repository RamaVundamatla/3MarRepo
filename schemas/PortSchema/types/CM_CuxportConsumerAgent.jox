begin
	//Each of these methods should first check for an active CM_CuxportServiceDef web service definition - if none found, just return.
	extWebService := app.myRoot.getFirstActiveEWSForEndpoint( ETRow_ShipReleaseEDBIC );		// TFS 58722
	if extWebService &lt;&gt; null and extWebService.isEDBIC then									// TFS 58722
		activeCuxPortInterface := extWebService.CM_CuxportServiceDef;						// TFS 58722
	endif;																					// TFS 58722
	
	if activeCuxPortInterface = null then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "No Ship Release Cuxport Interface defined", LogDEBUG);
		app.doRaiseAlert(method.qualifiedName &amp; Tab &amp; "No Ship Release Cuxport Interface defined");
		return false;																		// TFS 58722
	endif;
	
	create cargo transient;
	cargo.setFromTI(_trackedItem, false);
	
	cargo.deserializeJSON(jsonPostData);														// TFS 57362
	app.writeLog(method.qualifiedName &amp; Tab &amp; "jsoonPostData is " &amp; jsonPostData, LogDEBUG);	// TFS 57362
	
	// TFS 57207 start
	activeCuxPortInterface.getEndpointMethodAndValue(ETRow_ShipReleaseEDBIC, methodType, endpointPath);
	if methodType = null or endpointPath = null then
		app.writeLog(method.qualifiedName &amp; Tab &amp; activeCuxPortInterface.name &amp; " is not set up correctly for " &amp; activeCuxPortInterface.name &amp; Space &amp; ETRow_ShipReleaseEDBIC &amp; " messages", LogERROR);
		app.doRaiseAlert(activeCuxPortInterface.name &amp; " is not set up correctly for " &amp; activeCuxPortInterface.name &amp; Space &amp; ETRow_ShipReleaseEDBIC &amp; " messages");
		return true;
	endif;
	// TFS 57207 end
	self.sendToEDBIC(method.qualifiedName, activeCuxPortInterface.baseEndpoint &amp; "/" &amp; endpointPath, methodType, jsonPostData, _terminal, activeCuxPortInterface);
