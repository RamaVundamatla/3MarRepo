    <JadeMethod name="getAllKeyValues_XTAB" id="025497e4-f75b-46f3-8a6c-3c7a3100b4ab">
        <source>getAllKeyValues_XTAB(_keyArray :StringArray input; _iter :Iterator; _numTabs, _numCols, _numRows, _numKeys	:Integer; _clear :Boolean)protected;
// ---------------------------------------------------------------------------
// Created:     03 December 2009 by cnwcs5
// Purpose:     Get all key values for entry in collection 
// Parameters:  _keyArray	- coll to pur key values in
//				_iter		- 
//				_numTabs	- number of tab properties
//				_numKeys	- number of keys in the XTAB dynadictionary
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	int			:Integer;
begin
	if _clear then
		_keyArray.clear;
	endif;
	
	foreach int in 1 to _numKeys do
		_keyArray.add (_iter.getCurrentKey(int).String); 
				
	endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_keyArray" type="StringArray" usage="input"/>
        <Parameter name="_iter" type="Iterator"/>
        <Parameter name="_numTabs" type="Integer"/>
        <Parameter name="_numCols" type="Integer"/>
        <Parameter name="_numRows" type="Integer"/>
        <Parameter name="_numKeys" type="Integer"/>
        <Parameter name="_clear" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAllMatchingYACriteriaTypes" id="8c5d5e46-3cab-43ef-8196-0c67adedc6ab">
        <source>getAllMatchingYACriteriaTypes(_criteriaArray : IntegerArray io);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 February 2010	cnwas3	Initial creation

*/

vars
	qProperty : CM_QueryProperty;
	obj		  : CM_Object;
	index,noOfItems : Integer;
	criteriaType : Integer;
begin
	if self.allGroupingQueryProperties.isEmpty() then
		return;
	endif;
	
	_criteriaArray.clear();
	noOfItems := self.allGroupingQueryProperties.size();
	index := 1;
	
	while index &lt;= noOfItems do
		qProperty := self.allGroupingQueryProperties[index].CM_QueryProperty;
		criteriaType := self.getMatchingYACriteriaType(qProperty);		
		_criteriaArray.add(criteriaType);		
		index := index+1;
	endwhile;
	
	
epilog

end;</source>
        <Parameter name="_criteriaArray" type="IntegerArray" usage="io"/>
    </JadeMethod>
