    <JadeMethod name="translateForm" id="bb68508a-293e-4521-843d-e30d5bbfce5d">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0014437, locale);
	lblLoad.translateCaption(Xlat_0014438, locale);
	lblState.translateCaption(Xlat_0014439, locale);
	lblTerminal.translateCaption(Xlat_0014440, locale);
	lblUnload.translateCaption(Xlat_0014441, locale);
	lblUser.translateCaption(Xlat_0014442, locale);
	lblVehicle.translateCaption(Xlat_0014443, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
