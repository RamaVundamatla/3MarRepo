    <JadeMethod name="validateUpdate" id="97d7462e-e757-4ad3-92dd-015c8d27daf1">
        <source>validateUpdate(_passport: CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 May 2011	cnwer1	Initial creation CCMS 1031
26 Jan 2015 cnwma1  PAR #35537 4030 Exception in SHP_ROROPlanDrawingController::drawTIsInRectangle
*/

vars

begin
	if self.code = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Code),null,null );
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Code),null,null ); // cnwdb2	PAR 35364
	endif;
	
	if self.allSlotDefnByCode.size &gt; 0 then								//26/01/2015 cnwma1 PAR # 35537  
		if self.numTier &gt; 8 or self.numTier=0 then
			app.raiseCMException(Max_Tier_Range,null,null);
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
