        <Parameter name="_isSource" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPrimaryTaskRows" id="fb47d943-431e-4930-989a-117bd5f6289f">
        <source>getPrimaryTaskRows() : EntTableRowArray;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 March 2023	jlier1	Initial creation TFS 57064

*/

vars
	theEntDef : EntTableDef;	
	allEntTableRows : EntTableRowArray;
begin
	
	if self.myPrimaryTaskFields &lt;&gt; null and self.myPrimaryTaskFields.allEntTableRows.first &lt;&gt; null then
		return self.myPrimaryTaskFields.allEntTableRows;
	endif;

	create allEntTableRows transient;
	theEntDef:=app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_VehicleAppFields];	
	allEntTableRows.add(theEntDef.getEntTableRow(ETRow_Id));
	allEntTableRows.add(theEntDef.getEntTableRow(ETRow_Info));
	allEntTableRows.add(theEntDef.getEntTableRow(ETRow_SourceLocation));
	allEntTableRows.add(theEntDef.getEntTableRow(ETRow_TargetLocation));
	
	
	return allEntTableRows;
epilog

end;</source>
        <ReturnType type="EntTableRowArray"/>
    </JadeMethod>
    <JadeMethod name="getTerminal" id="0654232b-2f2e-404f-85f1-de49355640bf">
        <source>getTerminal() : CM_Terminal;
/*

Date		Who		Reason
10 January 2014	cnwer1	Initial creation PAR

*/

vars

begin
	if self.myTerminal &lt;&gt; null then
		return self.myTerminal;
	endif;
	
	if self.myTerminalMachineType &lt;&gt; null then
		return self.myTerminalMachineType.myTerminal;
	endif;
	
	if self.myMachine &lt;&gt; null then
		return self.myMachine.myTerminal;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getUniqueViewName" id="5d0d2c19-ee43-4d9b-aab8-3161094d0365">
        <source>getUniqueViewName(): String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 May 2010	cnwer1	Initial creation
30 Mar 2012	cnwkpd1	PAR #29099 - Allow for the same Machine Id in multiple Terminals
20 Feb 2023	navmd1	TFS 56666 SNO - 1310 when creating new Terminal level RT Config. Added Separator to ETView names.

*/
vars
	returnVal		: String;
	
begin
	if self.myMachine &lt;&gt; null then
		returnVal := self.myMachine.id;						// PAR #29099
		if self.myMachine.myTerminal &lt;&gt; null then
			returnVal := returnVal &amp; self.myMachine.myTerminal.code;
		endif;
		return returnVal;
	elseif self.myTerminal &lt;&gt; null then
		return self.myTerminal.code;
	elseif self.myTerminalMachineType &lt;&gt; null then
		return self.myTerminalMachineType.myTerminal.code &amp; CM_RTVehicleConfig.ETVIEW_SEPARATOR &amp; self.myTerminalMachineType.myMachineType.type.String;
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
