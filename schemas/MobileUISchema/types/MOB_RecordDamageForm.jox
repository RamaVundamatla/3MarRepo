    <JadeMethod name="checkForClose" id="648ae47d-3908-44d4-97f4-61bea5d98639">
        <source>checkForClose():Boolean;
/*
	Created on 09 May 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	return cmb_Damage.text = null
	and cmb_Position.text = null
	and cmb_Severity.text = null
	and txt_Notes.text = null;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="concatenateErrorMsg" id="fdd1cfbc-3fe6-4b3d-a144-b4a335155a2b">
        <source>concatenateErrorMsg(_message:String; _errorMsg:String):String protected;
// --------------------------------------------------------------------------------
// Created:		22 April 2008 by cnwdad1
//
// Purpose:		Concatenate a message to an existing error message, and return the result.
//
// Parameters:	_message - The message to concatenate.
//				_errorMsg - The existing errot message.
//
// Returns:		The concatenated error message.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	concatenatedMsg	: String;
	
begin
	if _message = null then
		return _errorMsg;
	endif;
	
	if _errorMsg = null then
		concatenatedMsg	:=	_message;
	else
		concatenatedMsg	:=	_errorMsg &amp; CrLf &amp; _message;
	endif;
	
	return concatenatedMsg;
end;</source>
        <access>protected</access>
        <Parameter name="_message" type="String"/>
        <Parameter name="_errorMsg" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="deleteTableObject" id="6c58b840-2864-4653-92ce-d86200e090e0">
        <updating/>
        <source>deleteTableObject() updating;
// --------------------------------------------------------------------------------
// Created:		18 June 2008 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	damageObj	: CM_DamageInstance;
	
begin
	damageObj	:=	self.getSelectedDamage();
	
	if damageObj = null then
		app.msgBox(app.getErrorString(Remove_Nothing_Selected), '', MsgBox_OK_Only);
		return;
	endif;
	
	app.myTrxDA.trxDeleteTIDamage(damageObj, app.myPassport);
	
	if app.myPassport.trxCompletedOK() then
		self.tablePopulate();
	else
		self.checkAndShowErrors();
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doCancel" id="e5429243-277f-4d0e-9339-464be40aad1c">
        <updating/>
        <source>doCancel()updating;
/*
	Created on 09 May 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	app.mousePointer	:=	Busy;
	self.doCloseForm();
epilog
	app.mousePointer	:=	Idle;
end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="06964416-98ce-4ea4-b928-1cba4cd653df">
        <source>doSave():Boolean;
// --------------------------------------------------------------------------------
// Created:		21 April 2008 by cnwdad1
//
// Purpose:		Standard method to perform an update.
//
// Parameters:	None
//
// Returns:		True if the update was successful, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
//							Change 2nd cmsBeginLoad to cmsEnd
// 01/07/2022  navak20 ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
// --------------------------------------------------------------------------------
vars
	damageObj		: CM_DamageInstance;
	tiObj			: CM_TrackedItem;
	proxyTIObj		: CM_TrackedItem;
	damageDefObj	: CM_DamageDefinitionCode;
	position		: Integer;
	damageCode		: String;
	//severity		: Integer;					// 11.07.2022 navak20 TFS 53862
	severity		: CM_DamageSeverity;		// 11.07.2022 navak20 TFS 53862
	damageNotes		: String;
	isLoadStateSet	: Boolean;
	// 04/08/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
	remarks 		: String;
	isNewDamage,
	isRepaired		: Boolean;	
	quantity		: Integer;
	damagePosition	: CM_DamagePosition;
	damagePosString	: String;
begin
	if not self.validateForm() then
		return false;
	endif;
	
	//position		:=	cmb_Position.cnEcGetItemData(cmb_Position.listIndex);
	damagePosString :=  cmb_Position.text;	
	damageCode		:=	cmb_Damage.text;
	//severity		:=	cmb_Severity.text.Integer;			// 11.07.2022 navak20 TFS 53862
	severity		:=	app.myRoot.getMyTerminal.allDamageSeverities[cmb_Severity.text.String];		// 11.07.2022 navak20 TFS 53862
	damageNotes		:=	txt_Notes.cnEcString();
	tiObj			:=	self.myTrackedItem;
	damageDefObj	:=	app.myRoot.allDamageDefinitionCodes[damageCode];
	damagePosition	:=  app.myRoot.allDamagePositionsByCode[damagePosString];
	isNewDamage		:=  self.chkNewDamage.value;
	isRepaired		:=  self.chkRepaired.value;
	
	app.cmsBeginLoad(isLoadStateSet);
	proxyTIObj		:=	tiObj.pxyCreateUpdateProxy();
	app.cmsEndLoad(isLoadStateSet);
	
	if damageNotes &lt;&gt; null then
		proxyTIObj.setRemarks(damageNotes, true);	// Add to existing remarks.
	endif;
	
	proxyTIObj.setDamaged(true);
	
	create damageObj transient;
	/*damageObj.setProxy(	proxyTIObj, 
						null,
						damageDefObj, 
						damagePosition,
						//position,
						remarks,
						isNewDamage,
						quantity,
						severity,
						isRepaired,
						null	//_locationStr 	: String	01 Mar 2016	NDL	TFS 1593
						); */
	damageObj.setProxy(	proxyTIObj, 
						null,
						damageDefObj, 
						damagePosition,
						//position,
						remarks,
						isNewDamage,
						quantity,
						severity,
						null,	//_locationStr 	: String	01 Mar 2016	NDL	TFS 1593
						null, null, null, null, null, null, null, null, null	//July 1, 2022 navak20 TFS 53862
						);
	app.myPassport.setWarningsIgnored(true);
	app.myTrxUA.trxUpdateTIDamage(proxyTIObj, app.myPassport);
	
	if app.myPassport.trxCompletedOK() then
		return true;
	else
		self.checkAndShowErrors();
		return false;
	endif;
epilog
	app.cmsEndLoad(isLoadStateSet);		// 08/04/2011 cnwmh5 #27347
	delete proxyTIObj;
	//delete damageObj;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getSelectedDamage" id="7f7c4423-e6c7-4ff7-af09-06900ae2dfbc">
        <source>getSelectedDamage():CM_DamageInstance protected;
// --------------------------------------------------------------------------------
// Created:		18 June 2008 by cnwdad1
//
// Purpose:		Returns a reference to the currently selected Damage Instance object.
//
// Parameters:	None
//
// Returns:		A reference to the selected Damage Instance object, or null.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	damageObj	: CM_DamageInstance;
	tableObj	: Table;
	
begin
	tableObj	:=	tbl_Packing;
	
	if tableObj.cnEcIsValidRow(tableObj.row) then
		damageObj	:=	tableObj.cnEcGetRowObject().CM_DamageInstance;
		
		if damageObj &lt;&gt; null then
			return damageObj;
		endif;
	endif;
	
	return null;
end;</source>
        <access>protected</access>
        <ReturnType type="CM_DamageInstance"/>
    </JadeMethod>
