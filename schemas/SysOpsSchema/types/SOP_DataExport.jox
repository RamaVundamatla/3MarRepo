    <JadeMethod name="copyToCreateDef" id="17da59ca-a0ef-4c10-b2eb-31fc40c6ad5f">
        <updating/>
        <source>copyToCreateDef() updating;
/*
Purpose:			
Parameters:			
Return Value:		
Date		Who		Reason
26 May 2010	#cnwdz2	 
29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
*/

vars
	newDef,
	proxyDef,
	proxyDefCopy,
	definition : CM_DataDumpExtractDef;
	
	extractClass,
	extractClassCopy : CM_DataDumpExtractClass;

	sqlColumn,
	proxySQLColumn : CM_DataDumpSQLColumn;
	copyDefInfoForm  : SOP_SQLNativeCopyDefInfoForm;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin
	if self.myCurrentObject = null then
		return;
	endif;
	
	copyDefInfoForm := app.loadForm(SOP_SQLNativeCopyDefInfoForm, 
									CMUI_Assistant, 
									false, 
									false,
									false, 
									self.myTerminal,
									self.myMasterMenuAction).SOP_SQLNativeCopyDefInfoForm;	
	if copyDefInfoForm = null then
		return;
	endif;
	copyDefInfoForm.maxDefNameLength := self.myCurrentObject.CM_DataDumpExtractDef.description.maxLength;
	copyDefInfoForm.showModal();
	if copyDefInfoForm.modalResult = IDCANCEL then 
		return;
	endif;

	self.createProxiesForEdit();
	proxyDef := self.myProxyObject.CM_DataDumpExtractDef;
	proxyDef.setDescription(copyDefInfoForm.defName);
	proxyDef.setDefinitionModified(true);
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxCA.trxCreateDataDumpExtractDef(proxyDef, newDef, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Extract Definition',
				app.myPassport, ErrWarnMode_AddUpdate);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		self.zClearProxyDetails();
		return;
		
	endwhile;
	
	self.myCurrentObject := newDef;
	self.createProxiesForEdit();
	proxyDefCopy := self.myProxyObject.CM_DataDumpExtractDef;
	proxyDefCopy.allDataDumpExtractClasses.clear();
	
	foreach extractClass in proxyDef.allDataDumpExtractClasses do
		create extractClassCopy transient;
		extractClassCopy.setProxy(extractClass.myDataDumpClass, extractClass.allDataDumpFeatures,extractClass.sqlTableName,
								  extractClass.deleteAction,    extractClass.deleteActionColumnName,  extractClass.deleteActionColumnPos,
								  extractClass.lastOperation,   extractClass.lastOperationColumnName, extractClass.lastOperationColumnPos,
								  extractClass.exportedTimestampColumnName, extractClass.exportedTimestampColumnPos,
								  extractClass.oidColumnPos, null);
		
		foreach sqlColumn in extractClass.allDataDumpSQLColumns do
			create proxySQLColumn transient;
			proxySQLColumn.setProxy(sqlColumn.isMaximumLength, sqlColumn.length.Integer, sqlColumn.decimalDigits, sqlColumn.name, extractClassCopy, sqlColumn.myDataDumpFeature, sqlColumn.myDataDumpSQLDataType, sqlColumn.sqlColumnOrdinalPosition);
			extractClassCopy.allDataDumpSQLColumns.add(proxySQLColumn);
		endforeach;

		proxyDefCopy.allDataDumpExtractClasses.add(extractClassCopy);
	endforeach;

	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateDataDumpExtractDef(proxyDefCopy, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Extract Definition', app.myPassport, ErrWarnMode_AddUpdate);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
	
	self.mySelectedClass := null;
	self.clearErrorWarnings();
	self.zClearProxyDetails();
	self.zHandleObjectAdd();
	self.tblData.selectObject(self.myCurrentObject, true);
	self.zDoTblDataRefresh();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="create" id="abb9ceb6-9225-499f-945c-14e3f730e33c">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     01 August 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin
	self.permissionView   := PmAdmDataExportView;
	self.permissionMaint  := PmAdmDataExportMaint;
	
	self.helpFileName := HelpFile_Admin;
end;</source>
    </JadeMethod>
    <JadeMethod name="createDefinitionFromFile" id="13199c2c-cd92-474b-83c0-168599594462">
        <updating/>
        <source>createDefinitionFromFile(file : File io) : CM_DataDumpExtractDef updating;
//20/04/2010 cnwdz2 24641
vars
	token               : String;
	line                : String;
	startPos            : Integer;
	delimiterString     : String;
	definition          : CM_DataDumpExtractDef;
	pdefinition         : CM_DataDumpExtractDef;

	createSQLStatements : Boolean;
	definitionModified  : Boolean;
	description         : String;
	edbConnectionString : String;
	edbMachineDSN       : String;
	edbPassword         : String;
	edbServerName       : String;
	edbUserName         : String;
	extractFormat       : Integer;
	fileFolderName      : String;
	isActive            : Boolean;
	lastOperationColumnName : String;
	myTerminal          : CM_Terminal;
	oidColumnName       : String;
	oidFormat           : Integer;
	sqlDatabaseName     : String;
	sqlServerVersion    : String;
	useSQLControlTable  : Boolean;
	alertLimit          : Integer;
	userCode : String;
	user : CM_User;
begin

	create pdefinition transient;
	while not file.endOfFile do 

		line     := file.readLine;
		startPos := 1;

		token := line.getDelimitedToken(startPos, Tab, delimiterString);

		if token [ 1 : 1 ] = "[" then
			break;
		endif;

		if token = "createSQLStatements" then
			createSQLStatements := line.getDelimitedToken(startPos, Tab, delimiterString).Boolean;
		elseif token = "definitionModified" then
			definitionModified := line.getDelimitedToken(startPos, Tab, delimiterString).Boolean;
		elseif token = "description" then
			description := line.getDelimitedToken(startPos, Tab, delimiterString);
		elseif token = "edbConnectionString" then
			edbConnectionString := line.getDelimitedToken(startPos, Tab, delimiterString);
		elseif token = "edbMachineDSN" then
			edbMachineDSN := line.getDelimitedToken(startPos, Tab, delimiterString);
		elseif token = "edbPassword" then
			edbPassword := line.getDelimitedToken(startPos, Tab, delimiterString);
		elseif token = "edbServerName" then
			edbServerName := line.getDelimitedToken(startPos, Tab, delimiterString);
		elseif token = "edbUserName" then
			edbUserName := line.getDelimitedToken(startPos, Tab, delimiterString);
		elseif token = "extractFormat" then
			extractFormat := line.getDelimitedToken(startPos, Tab, delimiterString).Integer;
		elseif token = "fileFolderName" then
			fileFolderName := line.getDelimitedToken(startPos, Tab, delimiterString);
		elseif token = "isActive" then
			isActive := line.getDelimitedToken(startPos, Tab, delimiterString).Boolean;
		elseif token = "lastOperationColumnName" then
			lastOperationColumnName  := line.getDelimitedToken(startPos, Tab, delimiterString);
		elseif token = "myTerminal" then
			//myTerminal := app.myPassport.myTerminal;
		elseif token = "oidColumnName" then
			oidColumnName := line.getDelimitedToken(startPos, Tab, delimiterString);
		elseif token = "oidFormat" then
			oidFormat := line.getDelimitedToken(startPos, Tab, delimiterString).Integer;
		elseif token = "sqlDatabaseName" then
			sqlDatabaseName := line.getDelimitedToken(startPos, Tab, delimiterString);
		elseif token = "sqlServerVersion" then
			sqlServerVersion := line.getDelimitedToken(startPos, Tab, delimiterString);
		elseif token = "useSQLControlTable" then
			useSQLControlTable := line.getDelimitedToken(startPos, Tab, delimiterString).Boolean;
		elseif token = "alertLimit" then
			alertLimit := line.getDelimitedToken(startPos, Tab, delimiterString).Integer;
		elseif token = "ignoreDeletesFromUser" then	//07 Jan 2014	NDL	Par 33264
			userCode := line.getDelimitedToken(startPos, Tab, delimiterString);
			if userCode &lt;&gt; null then
				user := app.myRoot.allUsers.getAtKey( userCode );
			endif;
		else
			return null;
		endif;
	endwhile;
	
	pdefinition.setProxy(description, extractFormat, isActive, createSQLStatements,
						 fileFolderName, edbConnectionString, edbPassword, edbServerName, edbUserName, edbMachineDSN,
						 oidColumnName, oidFormat, sqlDatabaseName, sqlServerVersion,
						 true, useSQLControlTable, myTerminal,alertLimit,
						 user	//_ignoreDeletesFromUser : CM_User	//07 Jan 2014	NDL	Par 33264
						 );
	
	return pdefinition;
epilog

end;</source>
        <Parameter name="file" type="File" usage="io"/>
        <ReturnType type="CM_DataDumpExtractDef"/>
    </JadeMethod>
    <JadeMethod name="createFeatureFromFile" id="156488e9-2577-4af3-b72f-762e793c6914">
        <updating/>
        <source>createFeatureFromFile(file : File io; dumpClass : CM_DataDumpClass; errorMessage : String output) : CM_DataDumpFeature updating;
//20/04/2010 cnwdz2 24641
// Changed On	By			reason
// ----------	--------	---------------------------------------------------------------------
// 23/11/2017	jlgdap1		TFS 7511 LNX Changes to allow attributes with the same name in different subclasses to be extracted
vars

	token               : String;
	line                : String;
	startPos            : Integer;
	delimiterString     : String;
	feature             : CM_DataDumpFeature;

	featureName         : String;
	featureNiceName     : String;
	isFeatureProtected  : Boolean;
	isProtected         : Boolean;
	myFeature           : String;
	mySubClassFeatureType : String;
	newLength           : Integer;
	newName             : String;
	newType             : String;
	returnValueIsAnObject : Boolean;
	subClassName        : String;  
begin

	while not file.endOfFile do 

		line     := file.readLine;
		startPos := 1;

		token := line.getDelimitedToken(startPos, Tab, delimiterString);

		if token [ 1 : 1 ] = "[" then
			break;
		endif;

		if token = "featureName" then
			featureName := line.getDelimitedToken(startPos, Tab, delimiterString);
		elseif token = "featureNiceName" then
			featureNiceName := line.getDelimitedToken(startPos, Tab, delimiterString);
		elseif token = "isFeatureProtected" then
			isFeatureProtected := line.getDelimitedToken(startPos, Tab, delimiterString).Boolean;
		elseif token = "isProtected" then
			isProtected := line.getDelimitedToken(startPos, Tab, delimiterString).Boolean;
		elseif token = "newLength" then
			newLength := line.getDelimitedToken(startPos, Tab, delimiterString).Integer;
		elseif token = "newName" then
			newName := line.getDelimitedToken(startPos, Tab, delimiterString);
		elseif token = "newType" then
			newType := line.getDelimitedToken(startPos, Tab, delimiterString);
		elseif token = "returnValueIsAnObject" then
			returnValueIsAnObject := line.getDelimitedToken(startPos, Tab, delimiterString).Boolean;
		elseif token = "subClassName" then
			subClassName := line.getDelimitedToken(startPos, Tab, delimiterString);
		elseif token = "myFeature" or token = "mySubClassFeatureType" then
		else
			//write method.qualifiedName &amp; " Error - " &amp; token;
			return null;
		endif;
	endwhile;
	
	//feature := dumpClass.allDataDumpFeatures[featureName];						// TFS 7511
	feature := dumpClass.allDataDumpFeatures[featureName, subClassName];			// TFS 7511
	if feature = null then
		//1/11/2010 cnwdz2 26191
		errorMessage := app.getErrorString2(ERR_CouldNotFindFeature, featureName, dumpClass.className);		
		return null;
	endif;
	return feature;
epilog

end;</source>
        <Parameter name="file" type="File" usage="io"/>
        <Parameter name="dumpClass" type="CM_DataDumpClass"/>
        <Parameter name="errorMessage" type="String" usage="output"/>
        <ReturnType type="CM_DataDumpFeature"/>
    </JadeMethod>
    <JadeMethod name="createSQLColumnFromFile" id="438d5398-d42f-4c16-94d0-981e90504a37">
        <updating/>
        <source>createSQLColumnFromFile(file : File io; 
					 _extractClass : CM_DataDumpExtractClass;
					 _dumpClass    : CM_DataDumpClass) : CM_DataDumpSQLColumn updating;
//20/04/2010 cnwdz2 24641
// Changed On	By			reason
// ----------	--------	---------------------------------------------------------------------
// 23/11/2017	jlgdap1		TFS 7511 LNX Changes to allow attributes with the same name in different subclasses to be extracted
vars

	token               : String;
	line                : String;
	startPos            : Integer;
	delimiterString     : String;
	sqlColumn           : CM_DataDumpSQLColumn;
	jadeFeature         : CM_DataDumpFeature;

	decimalDigits       : Integer;
	isMaximumLength     : Boolean;
	length              : Integer;
	name                : String;
	featureName         : String;
	sqlDataTypeName     : String;
	sqlDataType         : CM_DataDumpSQLDataType;
    sqlColumnOrdinalPosition : String;
	subClassName 		: String;				// TFS 7511
begin

	while not file.endOfFile do 

		line     := file.readLine;
		startPos := 1;

		token := line.getDelimitedToken(startPos, Tab, delimiterString);

		if token [ 1 : 1 ] = "[" then
			break;
		endif;

		if token = "decimalDigits" then
			decimalDigits := line.getDelimitedToken(startPos, Tab, delimiterString).Integer;
		elseif token = "isMaximumLength" then
			isMaximumLength := line.getDelimitedToken(startPos, Tab, delimiterString).Boolean;
		elseif token = "length" then
			length := line.getDelimitedToken(startPos, Tab, delimiterString).Integer;
		elseif token = "name" then
			name := line.getDelimitedToken(startPos, Tab, delimiterString).String;
		elseif token = "myDataDumpFeature" then
			featureName := line.getDelimitedToken(startPos, Tab, delimiterString).String;
		elseif token = "myDataDumpSQLDataType" then
			sqlDataTypeName := line.getDelimitedToken(startPos, Tab, delimiterString).String;
		elseif token = "sqlColumnOrdinalPosition" then
			sqlColumnOrdinalPosition := line.getDelimitedToken(startPos, Tab, delimiterString).String;
		elseif token = "subClassName" then																	// TFS 7511
			subClassName := line.getDelimitedToken(startPos, Tab, delimiterString).String;					// TFS 7511
		else
			//write method.qualifiedName &amp; " Error - " &amp; token;
			return null;
		endif;
	endwhile;
	
	//jadeFeature := _dumpClass.allDataDumpFeatures[featureName];											// TFS 7511
	jadeFeature := _dumpClass.allDataDumpFeatures[featureName, subClassName];								// TFS 7511
	sqlDataType := app.myRoot.allDataDumpSQLDataTypes[sqlDataTypeName];
	if sqlDataType = null then
		//write method.qualifiedName &amp; " Error - " &amp; "sqlDataType null - " &amp; sqlDataTypeName;
		return null;
	endif;

	create sqlColumn transient;
	sqlColumn.setProxy(isMaximumLength, length, decimalDigits, name, _extractClass, jadeFeature, sqlDataType, sqlColumnOrdinalPosition.asIntegerJMT());

	return sqlColumn;
epilog

end;</source>
        <Parameter name="file" type="File" usage="io"/>
        <Parameter name="_extractClass" type="CM_DataDumpExtractClass"/>
        <Parameter name="_dumpClass" type="CM_DataDumpClass"/>
        <ReturnType type="CM_DataDumpSQLColumn"/>
    </JadeMethod>
    <JadeMethod name="createSQLTableFromFile" id="eb1c67ed-4f92-4900-a57c-aa8d00222600">
        <updating/>
        <source>createSQLTableFromFile(file : File io; 
					   definition : CM_DataDumpExtractDef io; nextSQLTableFound:Boolean output; errorMessage : String output) : CM_DataDumpExtractClass updating;
//20/04/2010 cnwdz2 24641
vars
	today               : TimeStamp;
	token               : String;
	line                : String;
	startPos            : Integer;
	delimiterString     : String;
	psqlTable           : CM_DataDumpExtractClass;
	dumpClass           : CM_DataDumpClass;
	feature             : CM_DataDumpFeature;
	sqlColumn           : CM_DataDumpSQLColumn;
	featureArray        : CM_DataDumpFeatureArray;
	sqlColumnDict       : CM_DataDumpSQLColumnDict;

	className                 : String;
	deleteAction              : Integer;
	deleteActionColumnName    : String;
	deleteActionColumnPos     : Integer;
	exportedTimestampColumnName : String;
	exportedTimestampColumnPos: Integer;
	extractedUpToDateTime     : String;
	extractedUpToDateTimeTS   : TimeStamp;
	lastOperation             : Character;
	lastOperationColumnName   : String;
	lastOperationColumnPos    : Integer;
	oidColumnPos              : Integer;
	sqlTableName              : String;
	breakOut                  : Boolean;

begin

	create sqlColumnDict transient;
	create psqlTable transient;
	create featureArray transient;

	while not file.endOfFile do 
		line     := file.readLine;
		startPos := 1;

		token := line.getDelimitedToken(startPos, Tab, delimiterString);
		if token [ 1 : 1 ] = "[" then
			breakOut := true;
			break;
		endif;

		if token = "className" then
			className := line.getDelimitedToken(startPos, Tab, delimiterString);
		elseif token = "deleteAction" then
			deleteAction := line.getDelimitedToken(startPos, Tab, delimiterString).Integer;
		elseif token = "deleteActionColumnName" then
			deleteActionColumnName := line.getDelimitedToken(startPos, Tab, delimiterString);
		elseif token = "deleteActionColumnPos" then
			deleteActionColumnPos := line.getDelimitedToken(startPos, Tab, delimiterString).Integer;
		elseif token = "exportedTimestampColumnName" then
			exportedTimestampColumnName := line.getDelimitedToken(startPos, Tab, delimiterString);
		elseif token = "exportedTimestampColumnPos" then
			exportedTimestampColumnPos := line.getDelimitedToken(startPos, Tab, delimiterString).Integer;
		elseif token = "extractedUpToDateTime" then
			extractedUpToDateTime := line.getDelimitedToken(startPos, Tab, delimiterString);
			extractedUpToDateTimeTS := extractedUpToDateTime.TimeStamp;
			if extractedUpToDateTimeTS.isValid = false then
				extractedUpToDateTimeTS := null;
			endif;
		elseif token = "lastOperation" then
			lastOperation := line.getDelimitedToken(startPos, Tab, delimiterString).Character;
		elseif token = "lastOperationColumnName" then
			lastOperationColumnName := line.getDelimitedToken(startPos, Tab, delimiterString);
		elseif token = "lastOperationColumnPos" then
			lastOperationColumnPos := line.getDelimitedToken(startPos, Tab, delimiterString).Integer;
		elseif token = "oidColumnPos" then
			oidColumnPos := line.getDelimitedToken(startPos, Tab, delimiterString).Integer;
		elseif token = "sqlTableName" then
			sqlTableName := line.getDelimitedToken(startPos, Tab, delimiterString);
		elseif token = "myDataDumpClass" or token = "myDataDumpExtractDef" then
		else
			//write method.qualifiedName &amp; " Error - " &amp; token;
			return null;
		endif;
		
	endwhile;
	
	if breakOut = false then
		return null;
	endif;

	dumpClass := app.myRoot.allDataDumpClasses[className];
	if dumpClass = null then
		//1/11/2010 cnwdz2 26191
		errorMessage := app.getErrorString1(ERR_CouldNotFindClass, className);
		return null;
	endif;

	psqlTable.setProxy(dumpClass, featureArray, sqlTableName,
					   deleteAction,  deleteActionColumnName,  deleteActionColumnPos,
					   lastOperation, lastOperationColumnName, lastOperationColumnPos,
					   exportedTimestampColumnName, exportedTimestampColumnPos,
					   oidColumnPos, extractedUpToDateTimeTS);
	
	while not file.endOfFile do 

		line     := file.readLine;
		startPos := 1;

		token := line.getDelimitedToken(startPos, Tab, delimiterString);

		if token = "[Feature]" then
			feature := createFeatureFromFile(file, dumpClass, errorMessage);
			if errorMessage &lt;&gt; null then 	
				//21 Jan 2015	NDL	Par 35249
				if app.msgBox(errorMessage, app.getErrorString(ERR_ErrorBoxTitle), MsgBox_OK_Cancel + MsgBox_Exclamation_Mark_Icon) = MsgBox_Return_OK then
					continue;
				endif;
				return null;
			endif;
			featureArray.add(feature);
			continue; 
		endif;
		
		if token = "[SQLColumn]" then
			sqlColumn := createSQLColumnFromFile(file, psqlTable, dumpClass);
			sqlColumnDict.add(sqlColumn);
			continue; 
		endif;

		if token = "[SQLTable]" then
			nextSQLTableFound := true;
			break;
		endif;

	endwhile;

	featureArray.copy(psqlTable.allDataDumpFeatures);
	sqlColumnDict.copy(psqlTable.allDataDumpSQLColumns);

	return psqlTable;

epilog

	delete sqlColumnDict;
	delete featureArray;

end;</source>
        <Parameter name="file" type="File" usage="io"/>
        <Parameter name="definition" type="CM_DataDumpExtractDef" usage="io"/>
        <Parameter name="nextSQLTableFound" type="Boolean" usage="output"/>
        <Parameter name="errorMessage" type="String" usage="output"/>
        <ReturnType type="CM_DataDumpExtractClass"/>
    </JadeMethod>
    <JadeMethod name="displayEntryFeature" id="d2c910ea-4b11-43c2-9c6a-f885f849818f">
        <source>displayEntryFeature(_feature : CM_DataDumpFeature) : String;
// ---------------------------------------------------------------------------
// Created:     24 May 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if _feature &lt;&gt; null then
		return _feature.featureName;
	endif;

end;</source>
        <Parameter name="_feature" type="CM_DataDumpFeature"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="displayEntryObject" id="8530e561-b32c-4ca0-8ef6-021ee7946154">
        <source>displayEntryObject(_object : CM_Object) : String;
// ---------------------------------------------------------------------------
// Created:     Aug 2004	cnwrs1
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if _object &lt;&gt; null then
		if _object.class.name = "CM_MachineHistory" then
			return _object.CM_MachineHistory.dateTime.date.String;
		elseif _object.class.name = "CM_TempReading" then
			return _object.CM_TempReading.dateTime.date.String;
		elseif _object.class.name = "CM_TITransaction" then
			return _object.CM_TITransaction.dateTime.date.String;
		elseif _object.class.name = "CM_VehicleVisitRecord" then
			return _object.CM_VehicleVisitRecord.timeIn.date.String;
		else
			return _object.getDisplayDetails(false);
		endif;
	endif;

end;</source>
        <Parameter name="_object" type="CM_Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="displayExtracClassInTable" id="7a397acb-3c14-448b-b910-8c8fed3f3937">
        <updating/>
        <source>displayExtracClassInTable(_extractClasses:CM_DataDumpExtractClass; isInsert:Boolean)updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 May 2010	#cnwdz2	 

*/

vars
	extractedUpTo : String;
	lineStr : String;
	idx : Integer;
	rowPt : Integer;
begin
	self.mySelectedClass := _extractClasses;//pxyExtractClass;
	
	if _extractClasses.extractedUpToDateTime.isValid then
		extractedUpTo := _extractClasses.extractedUpToDateTime.String;
	else
		extractedUpTo := "";
	endif;
	
	lineStr := true.cnEcGetTableCheckBoxValue &amp; Tab &amp; 
				_extractClasses.myDataDumpClass.className &amp; Tab &amp; 
				_extractClasses.sqlTableName &amp; Tab &amp;
				extractedUpTo;
	if isInsert then
		idx := self.tblExtractClass.addItem(lineStr);	
	else
		idx := self.tblExtractClass.row;
		self.tblExtractClass.setCellText(2,1,lineStr);
	endif;

	self.tblExtractClass.accessRow(idx).itemObject := _extractClasses;
	self.tblExtractClass.colourRows(self.colorRow1, self.colorRow2);
epilog

end;</source>
        <Parameter name="_extractClasses" type="CM_DataDumpExtractClass"/>
        <Parameter name="isInsert" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="displaySelectorResults" id="94475a29-e2cf-42af-8845-d9fd8036cdbf">
        <updating/>
        <source>displaySelectorResults(_resultCollection : Collection; _mode : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     19 November 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	obj			: Any;
	listBox		: CMUI_ListBox;
begin

	if _resultCollection = null then
		return;
	endif;
	self.fldInput.topSheet := self.shtExtractObject;
	listBox := self.mulObjects.myAvailableListBox;
	listBox.clear();
	foreach obj in _resultCollection do
		if (not CM_Object.hasInstance(obj.Object)) then
			continue;
		endif;
		
		listBox.itemObject[listBox.addItem(self.displayEntryObject(obj.CM_Object))] := obj.CM_Object;
	endforeach;
	
end;</source>
        <Parameter name="_resultCollection" type="Collection"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doAddJadeSQLMapping" id="2b8a223f-092f-482f-bca0-fc1da0e75b93">
        <source>doAddJadeSQLMapping();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 April 2010	#cnwdz2	 24641

*/

vars
	mappingForm : SOP_JadeSQLMappingForm;
begin	
	
	mappingForm := app.loadForm(SOP_JadeSQLMappingForm, 
							CMUI_Assistant, 
							false, 
							false,
							false, 
							self.myTerminal,
							self.myMasterMenuAction).SOP_JadeSQLMappingForm;	
	if mappingForm = null then
		return;
	endif;
	
	mappingForm.mode := SOP_JadeSQLMappingForm.Mode_Add;
	mappingForm.sqlVersion := self.tblExtractDef.getValueByName(ETRow_SqlServerVersion).String;
	mappingForm.myDelegate := self;
	mappingForm.showModal();	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBGPExtract" id="09632cfc-edeb-443b-ae63-f42dfdde7302">
        <source>doBGPExtract(_def : CM_DataDumpExtractDef; _extractType : String; _objArray : ObjectArray) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 November 2024	navsp1	Initial creation JIRA-23326

*/

vars
	proxyBGPRequest, bgpRequest : BGP_ExternalDBRequest;
begin
	//Initiate for the extract request
	create proxyBGPRequest transient;
	proxyBGPRequest.setProxy(app.myPassport.myUser, _def.myTerminal, _extractType, _objArray, app.isSpecial());
	app.myTrxCA.trxCreateBGPExtDBRequest(proxyBGPRequest, bgpRequest, _def, app.myPassport);
	if not app.myPassport.hasErrors then
		app.msgBox("BGP request has been queued successfully", "BGP Extract!", MsgBox_OK_Only);
	else
		app.msgBox("BGP request has been failed", "BGP Extract!", MsgBox_OK_Only);
		app.writeLog(method.qualifiedName() &amp; " BGP extract request failed!", LogERROR);
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_def" type="CM_DataDumpExtractDef"/>
        <Parameter name="_extractType" type="String"/>
        <Parameter name="_objArray" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="doCancel" id="60fd5ec6-0102-4797-9648-ba83f1d02e72">
        <updating/>
        <source>doCancel(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     25 May 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.mySelectedClass := null;
	return inheritMethod();

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDataDumpClass" id="ff75795a-4f1b-46aa-b39a-244808f8b31e">
        <updating/>
        <source>doDataDumpClass(_changedDataOnly : Boolean) updating, protected;
// ---------------------------------------------------------------------------
// Created:     26 May 2004	cnwth2
//
// Purpose:     
//	
// Changed On	By			Reason		 
// ----------   ----------  --------------------------------------------------
// 18/02/2015	cnwdap1		PAR #35705 Check in epilog whether agent needs finalising before deleting
vars
	obj							: Object;
	agent 						: CM_DataDumpExtractionAgent;
	def							: CM_DataDumpExtractDef;
	dataDumpClassSet			: CM_DataDumpExtractClassSet;
	numRows,
	row							: Integer;
	tbl							: CM_DataTable;
	numberOfRecordsToExtract 	: Integer;
begin
	if self.mode &lt;&gt; self.Mode_View then
		return;
	endif;
	
	if (not CM_DataDumpExtractDef.hasInstance(self.myCurrentObject)) then
		app.msgBox('You must select a definition first', 'No definition selected', MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	if self.tblExtractClass.allSelectedObjects.isEmpty then
		app.msgBox('You must highlight classes to extract in the class table', 'No classes highlighted', MsgBox_Exclamation_Mark_Icon);
		return;
	endif;

	create agent transient;
	def := self.myCurrentObject.CM_DataDumpExtractDef;
	//verify classes selected are all included in the def - they have to be
	tbl := self.tblExtractClass;
	numRows := tbl.rows;
	foreach row in tbl.fixedRows + 1 to numRows do
		if (tbl.accessRow(row).selected = true) and
		   tbl.getCellText(row, 1) = '0' then
			if app.msgBox("You have classes selected that are not included in the current defintion - these cannot be extracted" &amp; CrLf &amp;
						'Do you want to skip over them and continue anyway?', 'Classes not included in definition...', MsgBox_OK_Cancel + MsgBox_Information_Icon) &lt;&gt; MB_OK then
				return;
			else
				break;
			endif;
		endif;
	endforeach;
	
	numberOfRecordsToExtract := 0;
	if app.isSpecial()  then
		app.mousePointer := Idle;

		numberOfRecordsToExtract := 100;
		read numberOfRecordsToExtract;

		if app.msgBox("TEST Extract?" &amp;  CrLf	&amp; CrLf &amp; "You are SPECIAL, do you only want to extract " &amp; numberOfRecordsToExtract.String &amp; " items?" &amp; CrLf &amp; CrLf	
							&amp; "This will be " &amp; numberOfRecordsToExtract.String &amp; " items PER sub class." &amp; CrLf &amp; CrLf	
							&amp; "Yes for " &amp; numberOfRecordsToExtract.String &amp; ", No for ALL", "Test Extract", MsgBox_Yes_No) = MsgBox_Return_No then
			numberOfRecordsToExtract := 0;
		endif;
		app.mousePointer := Busy;

	endif;

	agent.numberOfRecordsToExtract := numberOfRecordsToExtract;
	
	if _changedDataOnly then
		/*
		if app.msgBox("You're about to commence an extract of all the updates and deletes for each of the classes" &amp; CrLf &amp;
						'you currently have highlighted in the classes table - from the "Extracted up to" time onwards.' &amp; CrLf &amp;
						'Are you sure you wish to continue?', 'Extract changes for highlighted classes?', MsgBox_OK_Cancel) &lt;&gt; MB_OK then
			return;
		endif;
		*/
		//If the DB server not in the app server location, run it as a BGP request																					//JIRA 23326
		if self.chkExtractAllBGP.value = true then																													//JIRA 23326
			self.doBGPExtract(def, BGP_ExternalDBRequest.Extract_Classes_Changed, self.tblExtractClass.allSelectedObjects);											//JIRA 23326
		else																																						//JIRA 23326
			foreach obj in self.tblExtractClass.allSelectedObjects do
				if (not CM_DataDumpExtractClass.hasInstance(obj)) then
					continue;
				endif;
				agent.initialise(obj.CM_DataDumpExtractClass.classAlias, false, false);
				agent.doExtractDefinitonChanges(def.description, false);	
				agent.finalise;			
			endforeach;
		endif;

	else
		/*
		if app.msgBox("You're about to commence an extract of every single object of each on the classes " &amp; CrLf &amp;
						'you currently have highlighted in the classes table - ignoring the "Extracted up to" time' &amp; CrLf &amp;
						'Are you sure you wish to continue?', 'Extract every object for hightlighted classes?', MsgBox_OK_Cancel) &lt;&gt; MB_OK then
			return;
		endif;
		*/
		if self.chkExtractAllBGP.value = true then																												//JIRA 23326
			self.doBGPExtract(def, BGP_ExternalDBRequest.Extract_Classes_All, self.tblExtractClass.allSelectedObjects);											//JIRA 23326
		else																																					//JIRA 23326
			foreach obj in self.tblExtractClass.allSelectedObjects do
				if (not CM_DataDumpExtractClass.hasInstance(obj)) then
					continue;
				endif;
				
				agent.initialise(obj.CM_DataDumpExtractClass.classAlias, false, false);
				agent.doExtractDefinitonAll(def.description);	
				agent.finalise;
			endforeach;
		endif;
	endif;
		
epilog
	delete dataDumpClassSet;
	// if we get to here and we still have an agent, and that agent still has one of its references, there has		// PAR #35705
	// been an exception somewhere in the agent process - do a finalise here so the global exception handler gets	// PAR #35705
	// unset - avoid 1206 errors																					// PAR #35705
	if agent &lt;&gt; null and agent.getPropertyValue(CM_DataDumpExtractionAgent::myTransExtractDef.name) &lt;&gt; null then	// PAR #35705
		agent.finalise();																							// PAR #35705
	endif;																											// PAR #35705
	delete agent;
end;</source>
        <access>protected</access>
        <Parameter name="_changedDataOnly" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDataDumpClassSQL" id="26bb8492-6472-40ed-8ef5-d3265b244ab3">
        <source>doDataDumpClassSQL() protected;
// ---------------------------------------------------------------------------
// Created:     Feb 2006 cnwrs1
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	obj, object	: Object;
	agent : CM_ExternalDatabaseAgent;
	transExtractDef: CM_DataDumpTransExtractDef;
	dataDumpExtractClass : CM_DataDumpExtractClass;
	jadeClass : Class;
	def	: CM_DataDumpExtractDef;
//	dataDumpClassSet : CM_DataDumpExtractClassSet;
	numRows : Integer;
	row	: Integer;
	tbl	: CM_DataTable;
	objArray : ObjectArray;
	extObj : ExternalObject;
	file : File;
begin
	if self.mode &lt;&gt; self.Mode_View then
		return;
	endif;
	
	if (not CM_DataDumpExtractDef.hasInstance(self.myCurrentObject)) then
		app.msgBox('You must select a definition first', 'No definition selected', MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	if self.tblExtractClass.allSelectedObjects.isEmpty then
		app.msgBox('You must highlight classes to extract SQL from in the class table', 'No classes highlighted', MsgBox_Exclamation_Mark_Icon);
		return;
	endif;

	create agent transient;
	def := self.myCurrentObject.CM_DataDumpExtractDef;
	create transExtractDef transient;
	transExtractDef.setForCreate(def, false);

	agent.initialise(EDB_PortDss, transExtractDef, null, false);
	//verify classes selected are all included in the def - they have to be
	tbl := self.tblExtractClass;
	numRows := tbl.rows;
	foreach row in tbl.fixedRows + 1 to numRows do
		if (tbl.accessRow(row).selected = true) and
		   tbl.getCellText(row, 1) = '0' then
			if app.msgBox("You have classes selected that are not included in the current defintion - these cannot be extracted" &amp; CrLf &amp;
						'Do you want to skip over them and continue anyway?', 'Classes not included in definition...', MsgBox_OK_Cancel + MsgBox_Information_Icon) &lt;&gt; MB_OK then
				return;
			else
				break;
			endif;
		endif;
	endforeach;
	create objArray transient;
	create file transient;	
	file.mode := File.Mode_Output; // 1/3/16  cnwns1 PAR 36286 unicode version
	foreach obj in self.tblExtractClass.allSelectedObjects do
		if (not CM_DataDumpExtractClass.hasInstance(obj)) then
			continue;
		endif;
		jadeClass := obj.CM_DataDumpExtractClass.myDataDumpClass.myClass;
		file.fileName := "c:\temp\"&amp;jadeClass.name&amp;".sql";
		objArray.clear();
		jadeClass.allInstances(objArray, 0, true);
		foreach object in objArray do
			extObj := agent.getExternalObj(object);
			if extObj &lt;&gt; null then
				file.writeLine(agent.createSQLStatement(extObj, false));
			endif;
		endforeach;
		file.close;		
	endforeach;
		
epilog
	delete objArray;
	delete agent;
	if file &lt;&gt; null then
		file.close;
		delete file;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doDataDumpDef" id="bfabf6be-da05-4c2e-a090-603fd1054706">
        <updating/>
        <source>doDataDumpDef(_changedDataOnly : Boolean) updating, protected;
// ---------------------------------------------------------------------------
// Created:     26 May 2004	cnwth2
//
// Purpose:     
//	
// Changed On	By			Reason		 
// ----------   ----------  --------------------------------------------------
// 18/02/2015	cnwdap1		PAR #35705 Check in epilog whether agent needs finalising before deleting
// 30/09/2024   navsp1      JIRA 23326 NSW - Unable to Manually Run Data Extract (TFS Bug 65272)
vars
	agent 						: CM_DataDumpExtractionAgent;
	dataDumpExtractClass		: CM_DataDumpExtractClass;
	def							: CM_DataDumpExtractDef;
begin
	if self.mode &lt;&gt; self.Mode_View then
		return;
	endif;
	
	if (not CM_DataDumpExtractDef.hasInstance(self.myCurrentObject)) then
		app.msgBox('You must select a definition first', 'No definition selected', MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	create agent transient;
	def := self.myCurrentObject.CM_DataDumpExtractDef;
	
	if _changedDataOnly then
		if app.msgBox("You're about to commence an extract of all the updates and deletes for each of the classes" &amp; CrLf &amp;
						'included in the ' &amp; def.description &amp; ' definition from the "Extracted up to" time onwards.' &amp; CrLf &amp;
						'Are you sure you wish to continue?', 'Extract changes for entire definition?', MsgBox_OK_Cancel) &lt;&gt; MB_OK then
			return;
		endif;
		//If the DB server not in the app server location, run it as a BGP request																			//JIRA 23326
		if self.chkExtractAllBGP.value = true then																											//JIRA 23326
			self.doBGPExtract(def, BGP_ExternalDBRequest.Extract_Def_Changes, null);																		//JIRA 23326
		else																																				//JIRA 23326
			agent.initialise(null, false, false);
			agent.doExtractDefinitonChanges(def.description, false);
			agent.finalise;
		endif;

	else
		if app.msgBox("You're about to commence an extract of every single object of each on the classes " &amp; CrLf &amp;
						'included in the ' &amp; def.description &amp; ' definition - ignoring the "Extracted up to" time' &amp; CrLf &amp;
						'Are you sure you wish to continue?', 'Extract every object for entire definition?', MsgBox_OK_Cancel) &lt;&gt; MB_OK then
			return;
		endif;
		//If the DB server not in the app server location, run it as a BGP request																			//JIRA 23326
		if self.chkExtractAllBGP.value = true then																											//JIRA 23326
			self.doBGPExtract(def, BGP_ExternalDBRequest.Extract_Def_All, null);																			//JIRA 23326
		else																																				//JIRA 23326
			foreach dataDumpExtractClass in def.allDataDumpExtractClasses do
				agent.initialise(dataDumpExtractClass.classAlias, false, false);
				agent.doExtractDefinitonAll(def.description);	
				agent.finalise;
			endforeach;
		endif;
	endif;
	
epilog
	// if we get to here and we still have an agent, and that agent still has one of its references, there has		// PAR #35705
	// been an exception somewhere in the agent process - do a finalise here so the global exception handler gets	// PAR #35705
	// unset - avoid 1206 errors																					// PAR #35705
	if agent &lt;&gt; null and agent.getPropertyValue(CM_DataDumpExtractionAgent::myTransExtractDef.name) &lt;&gt; null then	// PAR #35705
		agent.finalise();																							// PAR #35705
	endif;																											// PAR #35705
	delete agent;
end;</source>
        <access>protected</access>
        <Parameter name="_changedDataOnly" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDataDumpSQLNative" id="4a231615-c87f-4bae-b3c5-3c341b0c79b1">
        <source>doDataDumpSQLNative(_defaultFileName : String; _operation : Integer);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 May 2010	#cnwdz2	 24641

*/
constants
    NewLines    = CrLf &amp; CrLf &amp; CrLf &amp; CrLf;
vars
	extractClass : CM_DataDumpExtractClass;
	filePath	: String;
	file		: File;
	dump        : String;
	xdbAgent    : CM_ExternalDatabaseAgent;
	alertStr    : String;
	fileDialogSave	 	: CMDFileSave;
	idx : Integer;
begin
	extractClass :=	self.tblExtractClass.accessRow(self.tblExtractClass.row).itemObject.CM_DataDumpExtractClass;
	if extractClass = null then
		return;
	endif;
	
	create xdbAgent transient;
	
	if _operation = self.SQLNative_DumpOp_TableDef then
		dump := xdbAgent.buildCreateTableString(extractClass);
		alertStr := app.getErrorString1(TableDef_Dump_Failed,extractClass.className);
	elseif _operation = self.SQLNative_DumpOp_JadeSource then
		dump := extractClass.jadeSourceInsert &amp; NewLines;
		dump := dump &amp; extractClass.jadeSourceUpdate &amp; NewLines;
		dump := dump &amp; extractClass.jadeSourceUpdateDelete;
		alertStr := app.getErrorString1(JadeSourc_DumpFailed,extractClass.className);
	elseif _operation = self.SQLNative_DumpOp_StoredProc then
		dump := extractClass.storedProcedureInsert &amp; NewLines;
		dump := dump &amp; extractClass.storedProcedureUpdate &amp; NewLines;
		dump := dump &amp; extractClass.storedProcedureDelete;
		alertStr := app.getErrorString1(StoredProc_DumpFailed,extractClass.className);
	endif;

	if dump.removeTabCrLfs().trimBlanks() = null then
		app.msgBox(alertStr, app.getErrorString(Error), MsgBox_OK_Only);
		return;
	endif;

	// pass null path so opens where last open at
	/*	
	filePath := app.getFilePath(null, '*' &amp; self.SQLNative_DataDumpFileFormat, extractClass.sqlTableName &amp; _defaultFileName, false);
		
	if filePath = null then
		return;
	endif;	


	if filePath.toLower.pos(self.SQLNative_DataDumpFileFormat, 1) &lt;= 0 then
		filePath := filePath &amp; self.SQLNative_DataDumpFileFormat;
	endif;
	*/
	
	filePath := "";
	
	create fileDialogSave transient;
	fileDialogSave.initDir := null;
	fileDialogSave.filter := self.SQLNative_DataDumpFileFormat;
	fileDialogSave.filterIndex := 1;
	fileDialogSave.fileName := extractClass.sqlTableName &amp; _defaultFileName &amp; ".sql";

	if fileDialogSave.open() = 0 then
		idx := fileDialogSave.filterIndex;
		filePath :=  fileDialogSave.fileName;
	else
		return;
	endif;
	
	if filePath.toLower.pos(".txt", 1) &lt;= 0 
	and filePath.toLower.pos(".sql", 1) &lt;= 0 then
	
		filePath := filePath &amp; ".sql";
	endif;
	
	create file transient;
	file.fileName := filePath;
	file.mode := File.Mode_Output;

	if (not file.tryOpen) then
		app.raiseCMException1(FileUnavailable, file.fileName, null, null);	
		return;
	endif;
		
	file.purge();
	file.writeLine(dump);
	
epilog
	delete xdbAgent;
	if file &lt;&gt; null then
		file.close;
		delete file;
	endif;
	
	delete fileDialogSave;

end;</source>
        <Parameter name="_defaultFileName" type="String"/>
        <Parameter name="_operation" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doDelete" id="c0b9d783-6e22-4a6d-abf9-fce155f209a7">
        <updating/>
        <source>doDelete(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:		07 August 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
	toDelete : CM_DataDumpExtractDef;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin
	toDelete := self.myCurrentObject.CM_DataDumpExtractDef;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxDA.trxDeleteDataDumpExtractDef(toDelete, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Extract Definition', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return false;
		
	endwhile;
	
	return true;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDumpBulkDataLoadFile" id="af294de5-9d0e-4b58-b996-8c55ddec96eb">
        <updating/>
        <source>doDumpBulkDataLoadFile() updating, protected;
// ---------------------------------------------------------------------------
// Created:     //27/04/2010 cnwdz2 24641
//
// Purpose:     
//			 
// Changed On	By			Reason
// ----------   ----------  --------------------------------------------------
// 18/02/2015	cnwdap1		PAR #35705 Check in epilog whether agent needs finalising before deleting
vars
	obj							: Object;
	agent 						: CM_DataDumpExtractionAgent;
	dataDumpExtractClass		: CM_DataDumpExtractClass;
	def							: CM_DataDumpExtractDef;
	numRows,
	row							: Integer;
	tbl							: CM_DataTable;
begin
	if self.mode &lt;&gt; self.Mode_View then
		return;
	endif;
	
	if (not CM_DataDumpExtractDef.hasInstance(self.myCurrentObject)) then
		app.msgBox('You must select a definition first', 'No definition selected', MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	if self.tblExtractClass.allSelectedObjects.isEmpty then
		app.msgBox('You must highlight classes to extract in the class table', 'No classes highlighted', MsgBox_Exclamation_Mark_Icon);
		return;
	endif;

	create agent transient;
	agent.isBulkDataExtract := true;
	def := self.myCurrentObject.CM_DataDumpExtractDef;
	foreach obj in self.tblExtractClass.allSelectedObjects do
		if (not CM_DataDumpExtractClass.hasInstance(obj)) then
			continue;
		endif;

		agent.initialise(obj.CM_DataDumpExtractClass.classAlias, false, false);
		agent.doExtractDefinitonAll(def.description);	
		agent.finalise;
	endforeach;
epilog
	// if we get to here and we still have an agent, and that agent still has one of its references, there has		// PAR #35705
	// been an exception somewhere in the agent process - do a finalise here so the global exception handler gets	// PAR #35705
	// unset - avoid 1206 errors																					// PAR #35705
	if agent &lt;&gt; null and agent.getPropertyValue(CM_DataDumpExtractionAgent::myTransExtractDef.name) &lt;&gt; null then	// PAR #35705
		agent.finalise();																							// PAR #35705
	endif;																											// PAR #35705
	delete agent;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doEditJadeSQLMapping" id="9b08c185-28f9-4c8d-8ebd-f8b22f1e26c1">
        <source>doEditJadeSQLMapping();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 April 2010	#cnwdz2	 24641

*/

vars
	mappingForm : SOP_JadeSQLMappingForm;
	pxyExtractClass : CM_DataDumpExtractClass;
	idx : Integer;
begin	
	
	mappingForm := app.loadForm(SOP_JadeSQLMappingForm, 
							CMUI_Assistant, 
							false, 
							false,
							false, 
							self.myTerminal,
							self.myMasterMenuAction).SOP_JadeSQLMappingForm;	
	if mappingForm = null then
		return;
	endif;
	
	mappingForm.mode := SOP_JadeSQLMappingForm.Mode_Edit;
	mappingForm.myDelegate := self;
	mappingForm.sqlVersion := self.tblExtractDef.getValueByName(ETRow_SqlServerVersion).String;
	pxyExtractClass	:=	self.tblExtractClass.accessRow(self.tblExtractClass.row).itemObject.CM_DataDumpExtractClass;
	mappingForm.initProxy(pxyExtractClass);
	mappingForm.showModal();	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doExtractObjs" id="41089e3f-8c2a-4099-8865-477055c9a141">
        <source>doExtractObjs();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 March 2019	jlgndl1	Initial creation	TFS 43873

*/

vars
	idx : Integer;
	object : CM_Object;
	theClass : Class;
	date : Date;
	dateFrom : Date;
	dateTo : Date;
	objArray : ObjectArray;
	obj : Object;
	agent : CM_DataDumpExtractionAgent;
	
begin
	
	if self.mySelectedClass = null then
		return;
	endif;
	
	self.myObjArray.clear();
	
	theClass	:=	self.mySelectedClass.myDataDumpClass.myClass;
	
	if theClass.name = CM_MachineHistory.name
	or theClass.name = CM_TempReading.name
	or theClass.name = CM_TITransaction.name
	or theClass.name = CM_VehicleVisitRecord.name
	then
		dateFrom	:=	self.txtDateFrom.getDate();
		dateTo		:=	self.txtDateTo.getDate();
		
		if dateFrom = null or dateTo = null or (dateTo &lt; dateFrom)then
			return;
		endif;
		
		create objArray transient;
		theClass.allInstances(objArray, 0, true);
		
		foreach obj in objArray do
			if theClass.name = CM_MachineHistory.name then
				date := obj.CM_MachineHistory.dateTime.date;
			elseif theClass.name = CM_TempReading.name then
				date := obj.CM_TempReading.dateTime.date;
			elseif theClass.name = CM_TITransaction.name then
				date := obj.CM_TITransaction.dateTime.date;
			elseif theClass.name = CM_VehicleVisitRecord.name then
				date := obj.CM_VehicleVisitRecord.timeIn.date;
			endif;
			
			if date &gt; dateFrom and date &lt; dateTo then
				self.myObjArray.add(obj);
			endif;
		endforeach;
		
	else
		self.mulObjects.getSelected( self.myObjArray );
		
	endif;
	
	if not self.myObjArray.isEmpty then
		create agent transient;
		agent.initialise( null, false, false );
		agent.doExtractSelectedObjsXML( self.myCurrentObject.CM_DataDumpExtractDef.description, self.myObjArray );
		agent.finalise;
	endif;

epilog

	delete objArray;		
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doHandlePassword" id="74694cd1-0c5f-4764-b7e9-f13c96d04a37">
        <updating/>
        <source>doHandlePassword( _newRow: Integer; _newCol: Integer ):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 August 2021	navndl1	Initial creation	TFS 51632

*/

vars

	def : CM_DataDumpExtractDef;
	rowIndex : Integer;
	updated : Boolean;
	table : CM_EntryTable;
	encryptedPassword : String;

begin

	if self.mode &lt;&gt; self.Mode_View then
		table := self.tblExtractDef;
		rowIndex := table.row;
		if _newRow &gt; 0 then
			rowIndex := _newRow;
		endif;
		if rowIndex = table.CM_EntryTable.getRowByName( ETRow_EdbPassword ) then
			def := self.myProxyObject.CM_DataDumpExtractDef;
			if def &lt;&gt; null then
				// password length, in db was 128, but the form restricted it to 30, so sticking with 30 at present
				encryptedPassword := self.myAssistant.showSetPassword( self.mode, def, null, null, updated, 30 );
				if updated then
					self.enteredPassword := encryptedPassword;
					if encryptedPassword &lt;&gt; null then
						table.CM_EntryTable.setValueByName(ETRow_EdbPassword, '******');
					else
						table.CM_EntryTable.setValueByName(ETRow_EdbPassword, ' ');
					endif;
				endif;
				return true;
			endif;
		endif;
	endif;
	
	return false;

epilog

end;</source>
        <Parameter name="_newRow" type="Integer"/>
        <Parameter name="_newCol" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doRemoveJadeSQLMapping" id="8afdd8ac-64ca-4b33-b69c-0a64da59d0af">
        <updating/>
        <source>doRemoveJadeSQLMapping(_tbl : CM_DataTable input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 April 2010	#cnwdz2	 24641
29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
*/

vars
	pxyExtractClass		: CM_DataDumpExtractClass;
	obj : Object;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin
	foreach obj in self.tblExtractClass.allSelectedObjects do
		if (not CM_DataDumpExtractClass.hasInstance(obj)) then
			continue;
		endif;
		pxyExtractClass := obj.CM_DataDumpExtractClass;
		if pxyExtractClass = null then
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy data dump class became null behind a row');
			return;
		endif;
		
		//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			app.myTrxDA.trxDeleteDataDumpExtractClass(pxyExtractClass, app.myPassport);
		
			if app.myPassport.trxCompletedOK then
				break;
			else
				theResult := app.showErrorWarningDialog('Extract Definition',
										app.myPassport, ErrWarnMode_AddUpdate);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			break;
			
		endwhile;
		
	endforeach;
	
	self.mySelectedClass := null;
	self.zShowThumbnailData(self.myCurrentObject);
	
epilog

end;</source>
        <Parameter name="_tbl" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doResize" id="bd9b99da-93d4-40c6-991a-563775ca36cd">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:		11 August 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin
	inheritMethod();
	
 
end;</source>
    </JadeMethod>
    <JadeMethod name="doRunExtract" id="38271215-77fa-46ae-bfba-8647c69de2e8">
        <source>doRunExtract() protected;
// 
// Changed On	By			Reason
// ----------	--------	---------------------------------------------------------
// 18/02/2015	cnwdap1		PAR #35705 Check in epilog whether agent needs finalising before deleting
vars
	obj: Object;
	agent : CM_DataDumpExtractionAgent;
begin
	if self.tblExtractClass.allSelectedObjects.size &gt; 0 then
		create agent transient;
		foreach obj in self.tblExtractClass.allSelectedObjects do
			if obj.isKindOf(CM_DataDumpExtractClass) then
				agent.initialise(obj.CM_DataDumpExtractClass.classAlias, false, false);
				agent.doExtractDefinitonChanges(self.tblExtractDef.getValueByName(ETRow_Description).String, false);
				agent.finalise;
			endif;
		endforeach;
	endif;
epilog
	// if we get to here and we still have an agent, and that agent still has one of its references, there has		// PAR #35705
	// been an exception somewhere in the agent process - do a finalise here so the global exception handler gets	// PAR #35705
	// unset - avoid 1206 errors																					// PAR #35705
	if agent &lt;&gt; null and agent.getPropertyValue(CM_DataDumpExtractionAgent::myTransExtractDef.name) &lt;&gt; null then	// PAR #35705
		agent.finalise();																							// PAR #35705
	endif;																											// PAR #35705
	delete agent;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSave" id="fdb9f1d9-c3d1-4913-99ec-12557e6e7991">
        <updating/>
        <source>doSave(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:		07 August 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
	proxyDef, 
	newDef 				: CM_DataDumpExtractDef;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin
	//call needed where the user goes straight from the 
	//features sheet to the save button
	if self.fldInput.topSheet = self.shtExtFeature then
		self.doSaveSelectedFeatures();
	endif;

	if not self.setProxy() then
		return false;
	endif;
	proxyDef := self.myProxyObject.CM_DataDumpExtractDef;
	proxyDef.setDefinitionModified(true);

	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		if self.mode = Mode_Add then
			app.myTrxCA.trxCreateDataDumpExtractDef(proxyDef, newDef, app.myPassport);
		else
			app.myTrxUA.trxUpdateDataDumpExtractDef(proxyDef, app.myPassport);
		endif;
	
		if app.myPassport.trxCompletedOK then
			if self.mode = Mode_Add then
				self.myCurrentObject := newDef;
			endif;
			self.mySelectedClass := null;
			break;
		else
			theResult := app.showErrorWarningDialog('Extract Definition', app.myPassport, ErrWarnMode_AddUpdate);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return false;
		
	endwhile;

	// rs1 mar 2006 par 11448 cleanup during update
	self.mulObjects.setAvailable(null, true);
	self.mulObjects.setSelected(null);
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveJadeSQLMapping" id="957f2606-d18d-4363-a0c2-4ce7f070a5b9">
        <updating/>
        <source>doSaveJadeSQLMapping(_extractClasses:CM_DataDumpExtractClass; _isInsert:Boolean):Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 April 2010	#cnwdz2	 24641
29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
2 Feb 2024 	navhl20 	Bug 62256: GPHA -- Error Exception 4  (Object not found) when selecting ALL available features on creating a Jade SQL mapping for CM_Voyage class
*/

vars
	//extractClass : CM_DataDumpExtractClass;
	
	rowPointer	: Integer;
	startRow	: Integer;
	maxRow		: Integer;
	itemObj     : CM_DataDumpExtractClass;
	
	sysDataDumpClass	 : CM_DataDumpClass;
	pxyExtractClass		 : CM_DataDumpExtractClass;
	
	proxyDef			 : CM_DataDumpExtractDef;
	pxyExtractClassArray : CM_DataDumpExtractClassArray;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815

begin
	if _extractClasses = null then
		return false;
	endif;
	
	startRow	:=	self.tblExtractClass.fixedRows + 1;
	maxRow		:=	self.tblExtractClass.rows;
	
	foreach rowPointer in startRow to maxRow do
		itemObj	:=	self.tblExtractClass.accessRow(rowPointer).itemObject.CM_DataDumpExtractClass;
		if itemObj.myDataDumpClass.className = _extractClasses.myDataDumpClass.className and
		   itemObj.classAlias	= _extractClasses.classAlias then
		   if not _isInsert and rowPointer = self.tblExtractClass.row then
		       continue;
		   endif;
			app.msgBox(app.getErrorString2(ERR_DUPLICATEMAPPING,itemObj.myDataDumpClass.className,itemObj.classAlias),
					app.getErrorString(ERR_DUPLICATEMAPPINGTITLE),MsgBox_Exclamation_Mark_Icon);
			return false;
		endif;
	endforeach;
	
	if self.myProxyObject &lt;&gt; null and self.allDataDumpClassProxiesDeleted.isEmpty() then			//2.02.2023 navhl20 #62256
		delete self.myProxyObject;
	endif;
	
	if self.myProxyObject = null then
		self.zClearProxyArray;
		self.setDoingMultiEdit();
		if self.myCurrentObject &lt;&gt; null then
			self.createProxiesForEdit();
		endif;
	endif;
	proxyDef := self.myProxyObject.CM_DataDumpExtractDef;
	proxyDef.setDefinitionModified(true);
	if _isInsert then
		if not proxyDef.allDataDumpExtractClasses.includes(_extractClasses) then
			proxyDef.allDataDumpExtractClasses.add(_extractClasses);	
		endif;
	else
		create pxyExtractClassArray transient;
		proxyDef := self.myProxyObject.CM_DataDumpExtractDef;
		startRow	:=	self.tblExtractClass.fixedRows + 1;
		maxRow		:=	self.tblExtractClass.rows;
		foreach rowPointer in startRow to maxRow do
			if rowPointer = self.tblExtractClass.row then
				pxyExtractClassArray.add(_extractClasses);
			else
				itemObj	:=	self.tblExtractClass.accessRow(rowPointer).itemObject.CM_DataDumpExtractClass;
				pxyExtractClassArray.add(itemObj);
			endif;
		endforeach;
		self.addProxiesToBeDeleted(proxyDef.allDataDumpExtractClasses);					//5.02.2023 navhl20 #62256
		proxyDef.allDataDumpExtractClasses.clear();
		pxyExtractClassArray.copy(proxyDef.allDataDumpExtractClasses);
		delete pxyExtractClassArray;
	endif;
	
	self.addProxiesToBeDeleted(proxyDef.allDataDumpExtractClasses);						//5.02.2023 navhl20 #62256
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateDataDumpExtractDef(proxyDef, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			self.mySelectedClass := null;
			//17 Sep 2021	NDL	TFS 51997
			if self.myCurrentObject &lt;&gt; null then
				self.myCurrentObject.CM_DataDumpExtractDef.resetProxyLinkEditions();
			endif;
			break;
		else
			theResult := app.showErrorWarningDialog('Extract Definition', app.myPassport, ErrWarnMode_AddUpdate);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		if _isInsert then
			proxyDef.allDataDumpExtractClasses.remove(_extractClasses);	
		endif;
		return false;
		
	endwhile;

	_extractClasses.allDataDumpSQLColumns.purge;
	self.allDataDumpClassProxiesDeleted.purge;											//5.02.2023 navhl20 #62256
	
	return true;
	
epilog
	self.clearErrorWarnings();
end;</source>
        <Parameter name="_extractClasses" type="CM_DataDumpExtractClass"/>
        <Parameter name="_isInsert" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveSelectedFeatures" id="a6959464-9070-4d6c-9973-9a7faa0eacef">
        <updating/>
        <source>doSaveSelectedFeatures() updating, protected;
// ---------------------------------------------------------------------------
// Created:     25 May 2004	cnwth2
//
// Purpose:     Saves away the selected features to the currently selected dataDumpClass proxy selected in the
//				class combo on the feature sheet
//			 
// ----------   ----------  --------------------------------------------------
vars
	pxyExtractClass				: CM_DataDumpExtractClass;
	idx,
	listCount					: Integer;
	listBox						: CMUI_ListBox;
	feature						: CM_DataDumpFeature;
begin
	if self.mode = self.Mode_View then
		return;
	endif;

	pxyExtractClass := self.cmbSelectedClass.listObject.CM_DataDumpExtractClass;
	if (not global.isValidObject(pxyExtractClass)) then
		return;
	endif;

	listBox := self.mulFeatures.mySelectedListBox;
	listCount := listBox.listCount;
	pxyExtractClass.allDataDumpFeatures.clear();
	foreach idx in 1 to listCount do
		feature := listBox.itemObject[idx].CM_DataDumpFeature;
		if feature &lt;&gt; null then
			pxyExtractClass.allDataDumpFeatures.add(feature);
		endif;
	endforeach;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doShtExtFeatureClick" id="881dd019-a738-49f5-a800-3400c6b2158b">
        <updating/>
        <source>doShtExtFeatureClick(_cmb: CMUI_ComboBox io) updating, protected;
// ---------------------------------------------------------------------------
// Created:     24 May 2004	cnwth2
//
// Purpose:     Populate the extractClass combo on the feature sheet with all the selected/included
//				datadump classes and make the last selected class in the table the list object and 
//				populate the feature table with the features of that class
//
// 13/08/2004   rs  make generic so I can use it in shtObjects				 
// ----------   ----------  --------------------------------------------------
constants
	IncludesColumn = 1;

vars
	
//	cmb						: CMUI_ComboBox;
	extractClass			: CM_DataDumpExtractClass;
	selectedClassName		: String;
	dataDumpClass			: CM_DataDumpClass;
	idx						: Integer;
	found					: Boolean;
	extractClassArray : CM_DataDumpExtractClassArray;
begin
//	_cmb := self.cmbSelectedClass;
	if self.mySelectedClass &lt;&gt; null then	
		selectedClassName := self.mySelectedClass.className &amp; ":" &amp; self.mySelectedClass.classAlias; //select the last selected class in the table
	elseif _cmb.listObject &lt;&gt; null then //re-select the currently selected item
		selectedClassName := _cmb.text;
	endif;
	_cmb.clear();

	if self.mode = self.Mode_View then
		if self.myCurrentObject = null then
			return;
		endif;

		extractClassArray := self.myCurrentObject.CM_DataDumpExtractDef.allDataDumpExtractClasses; // rs1 mar 2006 par 11448
		
		//cmb.listCollection(self.mySelectedExtractDef.allDataDumpExtractClasses, false, 0);
	else
		if myProxyObject &lt;&gt; null then //rs1 mar 2006 par 11448 even tho we are still in update mode the proxy may no longer exist
			extractClassArray := self.myProxyObject.CM_DataDumpExtractDef.allDataDumpExtractClasses; // rs1 mar 2006 par 11448
		else
			extractClassArray := self.myCurrentObject.CM_DataDumpExtractDef.allDataDumpExtractClasses; // rs1 mar 2006 par 11448
		endif;
	endif;
	
	foreach extractClass in extractClassArray do // rs1 mar 2006 par 11448
		idx := _cmb.addItem(extractClass.className &amp; ":" &amp; extractClass.classAlias);
		_cmb.itemObject[idx] := extractClass;
		if selectedClassName = extractClass.className &amp; ":" &amp; extractClass.classAlias then
			found := true;
		endif;
	endforeach;

	if found then
		_cmb.text := selectedClassName;
	endif;
	
	//20/04/2010 cnwdz2 24641
	if self.myCurrentObject &lt;&gt; null and 
	   self.myCurrentObject.CM_DataDumpExtractDef.extractFormat = CM_DataDumpExtractDef.FmtSQLNative then
		self.mulFeatures.displayAddRemoveBtns(false, false);	//cnwmc5
	endif;
	
	self.mulFeatures.myAvailableListBox.sorted := false;
	self.mulFeatures.mySelectedListBox.sorted := false;
	self.populateExtractFeatures();
	
end;</source>
        <access>protected</access>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doTblExtractClassClick" id="ddda4484-477c-43c8-a4c1-2f4f4ff31269">
        <updating/>
        <source>doTblExtractClassClick(_tbl : CM_DataTable input) updating, protected;
// ---------------------------------------------------------------------------
// Created:     24 May 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
//23 Apr 2015	cnwrs1	Par 36113 Adding DSS Class to data extract can cause extract to fail.
vars
	cellText					: String;
	sysDataDumpClass			: CM_DataDumpClass;
	pxyExtractClass				: CM_DataDumpExtractClass;
	listCount,
	idx							: Integer;
	feature						: CM_DataDumpFeature;
	dssDataDumpFeatures : CM_DataDumpFeatureArray;
begin
	if _tbl = null or
	   _tbl.row &lt;= _tbl.fixedRows then
		return;
	endif;
	
	if _tbl.column &lt;&gt; 1 then
		self.mySelectedClass := _tbl.accessRow(_tbl.row).itemObject.CM_DataDumpExtractClass;
		return;
	endif;
	
	if self.mode = self.Mode_View then
		return;
	endif;
	
	cellText := _tbl.getCellText(_tbl.row, 1);
	if self.mode &lt;&gt; self.Mode_View then
		if cellText = '1' then
			sysDataDumpClass := _tbl.accessCell(_tbl.row, 1).itemObject.CM_DataDumpClass;
			if sysDataDumpClass = null then
				app.raiseUnexpectedProgramError(class.name, method.name, 'Cell item object (master dataDumpClass) is null');
				return;
			endif;
			
			//try and find a our proxy in the deleted collection, if not we'll create one
			pxyExtractClass := self.allDataDumpClassProxiesDeleted[sysDataDumpClass.className];
			if pxyExtractClass = null then
				create pxyExtractClass transient;
				pxyExtractClass.setDataDumpClass(sysDataDumpClass);
				create dssDataDumpFeatures transient;
				sysDataDumpClass.getDSSFeatures(dssDataDumpFeatures);
				dssDataDumpFeatures.copy(pxyExtractClass.allDataDumpFeatures);
			else
				//the user must have un-included this class previously and changed there mind in the same edit session
				//we have found it again for them and there features and order is preserved
				self.allDataDumpClassProxiesDeleted.remove(pxyExtractClass);
			endif;
			
			self.myProxyObject.CM_DataDumpExtractDef.allDataDumpExtractClasses.add(pxyExtractClass);
			_tbl.accessRow(_tbl.row).itemObject := pxyExtractClass;
			self.mySelectedClass := pxyExtractClass;
		else
			pxyExtractClass := _tbl.accessRow(_tbl.row).itemObject.CM_DataDumpExtractClass;
			if pxyExtractClass = null then
				app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy data dump class became null behind a row');
				return;
			endif;
			
			self.myProxyObject.CM_DataDumpExtractDef.allDataDumpExtractClasses.remove(pxyExtractClass);
			self.allDataDumpClassProxiesDeleted.add(pxyExtractClass);
		endif;
	endif;
epilog
	delete dssDataDumpFeatures;
end;</source>
        <access>protected</access>
        <Parameter name="_tbl" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTblExtractClassContext" id="3b977ab2-009d-4920-9841-5d6d45761ca8">
        <updating/>
        <source>doTblExtractClassContext(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     26 May 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	x1, y1				: Real;
	tmpRelease			: CM_BulkRelease;
begin
	// TFS 2734 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return false;
	endif;
	
	x1 := x;
	y1 := y;
	if not mouse then  // if keyboard, use current listIndex value
	    x1 := 20;
	    if cntrl.row &lt; 0 then
	        y1 := 5;
	    else
	        y1 := cntrl.positionTop();
	    endif;
	endif;
	
	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);
	
	if self.tblExtractClass.allSelectedObjects.isEmpty or
	   (self.mode &lt;&gt; self.Mode_View) then
		self.mnuExtractClassAll.enabled := false;
		self.mnuExtractClassChanged.enabled := false;
		self.mnuExtractClassSQL.enabled := false;
	else
		self.mnuExtractClassAll.enabled := true;
		self.mnuExtractClassChanged.enabled := true;
		if self.myCurrentObject.CM_DataDumpExtractDef.edbMachineDSN &lt;&gt; null then
			self.mnuExtractClassSQL.enabled := true;
		else
			self.mnuExtractClassSQL.enabled := false;
		endif;
	endif;
	
	//26/04/2010 cnwdz2
	if self.myCurrentObject &lt;&gt; null and 
	   self.myCurrentObject.CM_DataDumpExtractDef.extractFormat = CM_DataDumpExtractDef.FmtSQLNative then 
		self.mnuAddJadeSQLMapping.enabled := true;
		if self.tblExtractClass.allSelectedObjects.isEmpty then
			self.mnuEditJadeSQLMapping.enabled := false;
			self.mnuDelJadeSQLMapping.enabled  := false;
			self.mnuDumpSQLTableDef.enabled := false;
			self.mnuDumpJadeSource.enabled := false;
			self.mnuDumpStoredProc.enabled := false;
			self.mnuExtractBulkDataLoad.enabled := false;
		elseif self.tblExtractClass.allSelectedObjects.size() &gt; 1 then
			self.mnuEditJadeSQLMapping.enabled := false;
			self.mnuDelJadeSQLMapping.enabled  := true;
			self.mnuDumpSQLTableDef.enabled := false;
			self.mnuDumpJadeSource.enabled := false;
			self.mnuDumpStoredProc.enabled := false;
			self.mnuExtractBulkDataLoad.enabled := true;
		else
			self.mnuEditJadeSQLMapping.enabled := true;
			self.mnuDelJadeSQLMapping.enabled  := true;
			self.mnuDumpSQLTableDef.enabled := true;
			self.mnuDumpJadeSource.enabled := true;
			self.mnuDumpStoredProc.enabled := true;
			self.mnuExtractBulkDataLoad.enabled := true;
		endif;
		self.mnuExtractClassSQL.enabled := false;
	else
		self.mnuAddJadeSQLMapping.enabled := false;
		self.mnuEditJadeSQLMapping.enabled := false;
		self.mnuDelJadeSQLMapping.enabled  := false;
		self.mnuDumpSQLTableDef.enabled := false;
		self.mnuDumpJadeSource.enabled := false;
		self.mnuDumpStoredProc.enabled := false;
		self.mnuExtractBulkDataLoad.enabled := false;
	endif;

	self.popupMenu(self.mnuClassContext, x1.Integer, y1.Integer);
	
	return false;
	
end;</source>
        <access>protected</access>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTblExtractHistContext" id="481e5d9f-045a-46cf-815c-8e6406ddecff">
        <updating/>
        <source>doTblExtractHistContext(_table: Table input; _conwin: Window input; _mouse: Boolean; _x: Integer; _y: Integer): Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     nov 2005 cnwrs1
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	x1, y1 : Real;
	tmpRelease : CM_BulkRelease;
begin

	x1 := _x;
	y1 := _y;
	if not _mouse then  // if keyboard, use current listIndex value
	    x1 := 20;
	    if _table.row &lt; 0 then
	        y1 := 5;
	    else
	        y1 := _table.positionTop();
	    endif;
	endif;
	
	_conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);
	
	if self.tblExtractHist.allSelectedObjects.isEmpty or
	   (self.mode &lt;&gt; self.Mode_View) then
		self.mnuHistExtract.enabled := false;
	else
		self.mnuHistExtract.enabled := true;	
	endif;
	
	self.popupMenu(self.mnuHistDisplayContext, x1.Integer, y1.Integer);
	
	return false;
	
end;</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_conwin" type="Window" usage="input"/>
        <Parameter name="_mouse" type="Boolean"/>
        <Parameter name="_x" type="Integer"/>
        <Parameter name="_y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doUpdateExtractDefTs" id="d68363c3-6a01-4174-b121-24033817c019">
        <updating/>
        <source>doUpdateExtractDefTs() : Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:		11 August 2003 by cnwsb1
//				Jan 2006 cnwrs1 now works by class not all classes
// ---------------------------------------------------------------------------
vars
	ts : TimeStamp;
	def : CM_DataDumpExtractDef;
	numRows, row : Integer;
	tbl	: CM_DataTable;
	extractClass : CM_DataDumpExtractClass;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin
	def := self.myCurrentObject.CM_DataDumpExtractDef;
	if def = null then
		app.msgBox("Extract Definition not selected", "No Definition Selected", MsgBox_OK_Only);
		return false;
	endif;
	if self.tblExtractClass.allSelectedObjects.isEmpty then
		app.msgBox('You must highlight classes to update the extract upto date in the class table', 'No classes highlighted', MsgBox_Exclamation_Mark_Icon);
		return false;
	endif;
	
	ts.setDate(self.txtClassDate.getDate());
	ts.setTime(self.txtClassTime.getTime());
	
	if not ts.isValid then
		app.msgBox("Invalid Extracted Up To Date", "Invalid Date", MsgBox_OK_Only);
		return false;
	endif;
	
	tbl := self.tblExtractClass;
	numRows := tbl.rows;
	foreach row in tbl.fixedRows + 1 to numRows do
		if (tbl.accessRow(row).selected = true) then
			extractClass := tbl.accessRow(row).itemObject.CM_DataDumpExtractClass;
			
			//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
			while true do
			
				app.myTrxUA.trxUpdateDataDumpExtrClassTs(extractClass, extractClass.edition, ts, app.myPassport);
			
				if app.myPassport.trxCompletedOK then
					break;
				else
					theResult := app.showErrorWarningDialog('Extracted Up To Date', app.myPassport, ErrWarnMode_AddUpdate);
					if app.myPassport.noErrors and theResult = IDOK then
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					endif;
				endif;
				
				return false;
				
			endwhile;
	
			
		endif;
	endforeach;

	self.zShowThumbnailData(def);
	
	return true;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doUpdateExtractObjs" id="8e484b61-9dff-4d08-8b81-e7d8b44b0ddb">
        <updating/>
        <source>doUpdateExtractObjs() updating, protected;
// 30 Aug 2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition 
vars
	idx			: Integer;
	listCount	: Integer;
	listBox		: CMUI_ListBox;
	object		: CM_Object;
	theClass	: Class;
	date		: Date;
	dateFrom	: Date;
	dateTo		: Date;
	objArray	: ObjectArray;
	obj			: Object;
	
begin
	listBox		:=	self.mulObjects.mySelectedListBox;
	listCount	:=	listBox.listCount();
	
	if self.mySelectedClass = null then
		return;
	endif;
	
	theClass	:=	self.mySelectedClass.myDataDumpClass.myClass;
	
	if theClass.name = CM_MachineHistory.name
	or theClass.name = CM_TempReading.name
	or theClass.name = CM_TITransaction.name
	or theClass.name = CM_VehicleVisitRecord.name
	then
		dateFrom	:=	self.txtDateFrom.getDate();
		dateTo		:=	self.txtDateTo.getDate();
		
		if dateFrom = null or dateTo = null or (dateTo &lt; dateFrom)then
			return;
		endif;
		
		if objArray = null then
			create objArray transient;
		endif;
		
		objArray.clear();
		theClass.allInstances(objArray, 0, true);
		self.myObjArray.clear();
		
		foreach obj in objArray do
			if theClass.name = CM_MachineHistory.name then
				date := obj.CM_MachineHistory.dateTime.date;
			elseif theClass.name = CM_TempReading.name then
				date := obj.CM_TempReading.dateTime.date;
			elseif theClass.name = CM_TITransaction.name then
				date := obj.CM_TITransaction.dateTime.date;
			elseif theClass.name = CM_VehicleVisitRecord.name then
				date := obj.CM_VehicleVisitRecord.timeIn.date;
			endif;
			
			if date &gt; dateFrom and date &lt; dateTo then
				self.myObjArray.add(obj);
			endif;
		endforeach;
		
		listCount := 0;
		beginTransaction;
		
		foreach obj in self.myObjArray do
			if obj &lt;&gt; null then
				self.updateObjectEdition(obj);	// par 30292
			endif;
			
			listCount := listCount + 1;
			
			if listCount mod 10000 = 0 then
				commitTransaction;
				beginTransaction;
			endif;
		endforeach;
		
		commitTransaction;
	else
		beginTransaction;
		
		foreach idx in 1 to listCount do
			object := listBox.itemObject[idx].CM_Object;
			
			if object &lt;&gt; null then
				self.updateObjectEdition(object);	// par 30292
			endif;
		endforeach;
		
		commitTransaction;
	endif;

epilog
	delete objArray;		// PAR #27874
	
end;</source>
        <access>protected</access>
    </JadeMethod>
