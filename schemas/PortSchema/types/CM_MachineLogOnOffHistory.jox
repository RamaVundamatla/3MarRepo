<Class name="CM_MachineLogOnOffHistory" id="bf5e402c-a170-4459-adef-02e5688f637f">
    <superclass name="CM_MachineHistory"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="planning"/>
    <JadeMethod name="findNextLogonHistory" id="4b01103b-2a9d-4432-9341-a05514b4fd38">
        <source>findNextLogonHistory():CM_MachineLogOnOffHistory;
/*
Date		Who		Reason
17 Oct 2012	cnwcs5	Initial creation - par 30382
*/
vars
	machine	:CM_Machine;
	iter	:Iterator;
	history	:CM_MachineHistory;
begin
	machine := self.machine;
	
	if machine = null then
		return null;
	endif;
	
	iter := machine.history.createIterator;
	
	iter.startAtObject (self);
	
	while iter.next (history) do
		if history = self or
			history.type &lt;&gt; self.Type_LogOn then
			continue;
		endif;
		
		return history.CM_MachineLogOnOffHistory;
	endwhile;
	
	return null;
epilog
	delete iter;
end;</source>
        <ReturnType type="CM_MachineLogOnOffHistory"/>
    </JadeMethod>
    <JadeMethod name="getGrossRunningTime" id="4735679b-f37e-4f7c-b9ec-2ec3ef09a996">
        <source>getGrossRunningTime():Integer;
// ---------------------------------------------------------------------------
// Created:     15 November 2010 by cnwcs5 par 23714/ccms 1132
// Purpose:     Time in seconds between receiver and corresponding logon/logoff in seconds
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 17/10/2012	cnwcs5		par 30382 - handle case where no logoff for a logon
// ---------------------------------------------------------------------------
vars
	type			:Integer;
	logon, logoff	:CM_MachineLogOnOffHistory;
begin
	type	:= self.type;
	
	if type = CM_MachineHistory.Type_LogOn then
		logon 	:= self;
		logoff	:= self.myNextHistory.CM_MachineLogOnOffHistory;	
		
		if logoff = null then
			// maybe they are still logged on or maybe they disappeared without
			// logging off and there is a subsequent logon but same or different user.
			logoff := self.findNextLogonHistory;
		endif;
	elseif type = CM_MachineHistory.Type_LogOn then
		logon	:= self.myPriorHistory.CM_MachineLogOnOffHistory;
		logoff	:= self;
	else
		// should not happen
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Invalid type for logon/logoff');
	endif;
	
	if logon &lt;&gt; null and logoff &lt;&gt; null then
		return logoff.dateTime.getDifferenceInSeconds (logon.dateTime).rounded;
	endif;
	
	// we don't have both logon/logoff so just return null
	return null;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jrwGetGrossRunningTime" id="56094f19-cce7-499a-8c9d-4de33129eb53">
        <source>jrwGetGrossRunningTime():String;
/*
Purpose:		JRW Method		
Return Value:	Gross running time in hrs, mins, secs

Date		Who		Reason
14 April 2011	cnwcs5	Initial creation - CCMS 1132/par 27316
*/
vars

begin
	return self.getGrossRunningTime.getHMS;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="loggedOff" id="bb15476b-e511-4788-8e73-5721fafc8fa3">
        <updating/>
        <source>loggedOff(_userId: String; _machine: CM_Machine) updating;

// 15/11/2010	cnwcs5	par 23714/ccms 1132
begin
	self.setPriorLogonHistory (_userId, _machine);	// 15/11/2010 cnwcs5 par 23714/ccms 1132
	self.setDetails(Type_LogOff,_machine,_userId);
end;</source>
        <Parameter name="_userId" type="String"/>
        <Parameter name="_machine" type="CM_Machine"/>
    </JadeMethod>
    <JadeMethod name="loggedOn" id="d62baaf4-6861-4f87-92ac-ddc5b9a93cc9">
        <updating/>
        <source>loggedOn(_userId: String; _machine: CM_Machine) updating;

begin
	self.setDetails(Type_LogOn,_machine,_userId);
end;</source>
        <Parameter name="_userId" type="String"/>
        <Parameter name="_machine" type="CM_Machine"/>
    </JadeMethod>
    <JadeMethod name="setPriorLogonHistory" id="f028ff05-589d-4196-a778-47b86b2fb51d">
        <updating/>
        <source>setPriorLogonHistory(_userId :String; _machine :CM_Machine)updating, protected;
// ---------------------------------------------------------------------------
// Created:     15 November 2010 by cnwcs5 par 23714/ccms 1132
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	history		:CM_MachineHistory;
	historyType	:Integer;
	userId		:String;
begin
	foreach history in _machine.history reversed do
		historyType := history.type;
		userId		:= history.userId;
		
		// hopefully we find the most recent logon
		if historyType = CM_MachineHistory.Type_LogOn and userId = _userId then
			self.myPriorHistory := history;
			break;
		endif;
		
		if history.isMoveHistory and userId &lt;&gt; _userId then
			// someone else is working the machine - we are not going to find our logon
			break;
		endif;
		
		if historyType = CM_MachineHistory.Type_LogOff and history &lt;&gt; self then
			// someone else's logoff - not going to find our logon
			break;
		endif;
	endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_userId" type="String"/>
        <Parameter name="_machine" type="CM_Machine"/>
    </JadeMethod>
</Class>
