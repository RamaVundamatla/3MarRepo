    <JadeMethod name="isInventoryType_Match" id="93724591-683e-40f4-9aa9-d40ea34c2c38">
        <source>isInventoryType_Match(_yaData: CM_YADataObjects): Boolean;
/*
Purpose:			

Date		Who		Reason
27MAY2021	NAVAB1	TFS 51219
*/

vars
	
begin
	if self.myLocationEvent = null then
		return false;
	endif;
	
	// Only priorities will be empty.
	if _yaData.isEmpty() then
		return true;
	endif;
	
	return _yaData.matches(self.myLocationEvent.myEventType);

epilog

end;</source>
