    <JadeMethod name="contextMenu" id="46dbdcb7-c2f3-49da-8b54-08cd0bfae9c4">
        <controlMethod name="Form::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>contextMenu(conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
//--------------------------------------------------------------
//Created: 22 April 2003 By: cnwgd1
//--------------------------------------------------------------
vars

	x1, y1 : Real;
begin

	if (not app.isAllowedToInspect) then
		return false;
	endif;
	
	// ok to show menu
	
	x1 := x;
	y1 := y;
	if not mouse then  // if keyboard, use current listIndex value
	    x1 := 1;
	    y1 := 1;
	endif;

	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   // convert x, y relative to form
	
	popupMenu(self.mnuFormContext, x1.Integer, y1.Integer);
	return false;

end;</source>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
