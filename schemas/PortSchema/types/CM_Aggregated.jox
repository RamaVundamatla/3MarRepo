    <JadeMethod name="getAggregatedAmount" id="daf36500-23b8-4ca7-ba0a-b777d9c5c800">
        <source>getAggregatedAmount() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 October 2017	jlgndl1	Initial creation	TFS 5744

*/

vars
	ct : CM_CargoType;
	product : CM_Product;
	ti	: CM_TrackedItem;
	density  	: Decimal[14,4];
	invalidObj : Boolean;
	otherAggregatedTrx : CM_Aggregated;
	invalidTrx : Boolean;
	totWeight : Decimal [14,4];
	totQty : Integer;
	amount : String;
	unit : String;
begin
	
	on Exception do app.handleDeletedObject(exception,self.otherTrackedItem,invalidObj);
	on Exception do app.handleDeletedObject( exception, otherAggregatedTrx, invalidTrx );
	
	if self.action = ACTION_AGGREGATE_PARENT then
		otherAggregatedTrx := self.myChildAggregated;
		if self.otherTrackedItem &lt;&gt; null then
			ct := self.otherTrackedItem.myCargoType;
			if not invalidObj then
				density:=self.otherTrackedItem.getDensity;
			endif;
			if otherAggregatedTrx &lt;&gt; null then
				totWeight := otherAggregatedTrx.totalWeight;
				totQty := otherAggregatedTrx.totalQuantity;
			endif;
		endif;
	
	else
		otherAggregatedTrx := self.myParentAggregated;
		ct := self.myTrackedItem.myCargoType;
		density:=self.myTrackedItem.getDensity;
		totWeight := self.totalWeight;
		totQty := self.totalQuantity;
	endif;
	
	if ct&lt;&gt; null then

		if ct.isBreakBulkMulti then
			if totQty &gt;  1 then
				return totQty.asStringJMT;
				
			elseif totWeight &gt; 0 then
				if ct.myWeightMeasurementType &lt;&gt; null then
					unit := ct.myWeightMeasurementType.shortName;		
					amount := app.convertMeasurementForDisplay(unit, totWeight);
					if amount &lt;&gt; null then
						return amount &amp; Space &amp; unit;
					endif;
				endif;	
				
			endif;
			
		elseif ct.isBulkMulti then		
			return ct.getBulkTrackByDisplayForWeight( totWeight, density, true );
			
		endif;
	
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="c9e72cf4-d63f-4200-9362-d1fd1eb6aca9">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 September 2017	jlgndl1	Initial creation	TFS 5744

*/

vars
	aggAmount,
	lDetail : String;
	otherTI,
	theTI	: CM_TrackedItem;
begin

	if _attrName = ETRow_Details  then
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
			
		else
			
			theTI := self.myTrackedItem;
			otherTI := self.getOtherTrackedItem();
			lDetail := app.getErrorString(Aggregated) &amp; " ";
			aggAmount:= self.getAggregatedAmount;
			if aggAmount &lt;&gt; null then
				lDetail:=lDetail &amp; aggAmount &amp; " x ";
			endif;
			if self.action = ACTION_AGGREGATE_CHILD then
				if theTI &lt;&gt; null then
					lDetail := lDetail &amp; " " &amp; theTI.id;
				endif;
				lDetail := lDetail &amp; " =&gt; ";
				if otherTI &lt;&gt; null then
					lDetail := lDetail &amp; " " &amp; otherTI.id;
				endif;
			elseif self.action = ACTION_AGGREGATE_PARENT then
				if otherTI &lt;&gt; null then
					lDetail := lDetail &amp; " " &amp; otherTI.id;
				endif;
				lDetail := lDetail &amp; " =&gt; ";
				if theTI &lt;&gt; null then
					lDetail := lDetail &amp; " " &amp; theTI.id;
				endif;
			endif;
		
			lDetail := lDetail &amp; " " &amp; self.urNumber.String;			
			
			return lDetail;
			
		endif;

	else
		return inheritMethod(_attrName, _short);
	
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEnquiryRow" id="d1371ccd-ab5e-40b5-b3b9-741bb6f11d50">
        <source>getEnquiryRow(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 September 2017	jlgndl1	Initial creation	TFS 5744

*/

vars
	lDetail : String;
	otherTI,
	theTI	: CM_TrackedItem;
	
begin

	theTI := self.myTrackedItem;

	otherTI := self.getOtherTrackedItem();
	
	lDetail := inheritMethod();
	lDetail := lDetail &amp; app.getErrorString(Aggregated) &amp; " ";

	if self.action = ACTION_AGGREGATE_CHILD then
		if otherTI &lt;&gt; null then
			lDetail := lDetail &amp; " " &amp; otherTI.id;
		endif;
		lDetail := lDetail &amp; " =&gt; ";
		if theTI &lt;&gt; null then
			lDetail := lDetail &amp; " " &amp; theTI.id;
		endif;
	elseif self.action = ACTION_AGGREGATE_PARENT then
		if theTI &lt;&gt; null then
			lDetail := lDetail &amp; " " &amp; theTI.id;
		endif;
		lDetail := lDetail &amp; " =&gt; ";
		if otherTI &lt;&gt; null then
			lDetail := lDetail &amp; " " &amp; otherTI.id;
		endif;
	endif;

	if lDetail &lt;&gt; "" then
		lDetail := lDetail &amp; " " &amp; self.urNumber.String;
	else
		lDetail := self.urNumber.String;
	endif;			
	
	return lDetail;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLocationStr" id="05c2fbea-3506-426b-874a-283862c6b779">
