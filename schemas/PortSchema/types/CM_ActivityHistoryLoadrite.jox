    <JadeMethod name="setLoadriteAttributes" id="453eb3f4-71e3-4bc1-b108-40c2cc462c7f">
        <updating/>
        <source>setLoadriteAttributes(_driver, _machine : String; _isSuccessfull : Boolean) updating;

// Created by cnwdvb1 on 03 October 2006

vars

begin

	self.loadriteMsg		:= '(' &amp; self.description &amp; ')';
	
	self.driver				:= _driver[1:10];
	self.machine			:= _machine[1:4];
	self.isSuccessful		:= _isSuccessfull;
	
	if not self.isSuccessful then
		self.description := 'Invalid Loadrite Weight ' &amp; self.loadriteMsg.replaceString(Cr, '&lt;CR&gt;') &amp; ' for machine ' &amp; _machine;
	else
		self.description := 'Successful Loadrite Weigh ' &amp; self.loadriteMsg.replaceString(Cr, '&lt;CR&gt;') &amp; ' for machine ' &amp; _machine;
	endif;
	
end;</source>
        <Parameter name="_driver" type="String"/>
        <Parameter name="_machine" type="String"/>
        <Parameter name="_isSuccessfull" type="Boolean"/>
    </JadeMethod>
</Class>
