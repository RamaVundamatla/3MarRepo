<Class name="CM_QStringLookupMethod" id="c8d23745-8744-482c-9ed7-efb026cb25a1">
    <superclass name="CM_QueryMethod"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>

	Equivalent of CM_QstringLookupProperty ( for methods )
	</text>
    <DbClassMap file="query"/>
    <JadeMethod name="create" id="edc4530b-d513-4688-be72-e79eb572cceb">
        <updating/>
        <source>create() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 November 2009	cnwndl1	Initial creation

*/

vars
	oper : CM_QueryOperator;

begin
	if self.isTransient then 
		return;
	endif;
		
	create oper as CM_QStringLookup persistent;
	self.allAllowedOperators.add(oper);
	
	create oper as CM_QStringLookupNotEqual persistent;
	self.allAllowedOperators.add(oper);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="getControlTypeForOperator" id="f5af0f71-a044-40a4-8707-72f85f3f75e2">
        <source>getControlTypeForOperator(queryOperator: CM_QueryOperator): Integer;

/*

Purpose:			

Parameters:			

Return Value:		

/****Changes

Date		Name	TFS#			Description
============================================================================
25 November 2009			cnwndl1	Initial creation
12 November 2018	40670	Add CM_QStringLookupIsOneOf;
============================================================================*/

begin
	
	if queryOperator.isKindOf(CM_QStringLookup) or
	   queryOperator.isKindOf(CM_QStringLookupNotEqual) then
		return QueryControl_ComboBox;
	elseif queryOperator.isKindOf(CM_QStringIsOneOf) or queryOperator.isKindOf(CM_QReferenceIsOneOf) or queryOperator.isKindOf(CM_QStringLookupIsOneOf) then
		return QueryControl_MultiSelect;
	endif;
	
	return inheritMethod(queryOperator);
end;</source>
        <Parameter name="queryOperator" type="CM_QueryOperator"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
