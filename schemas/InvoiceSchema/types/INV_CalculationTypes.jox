    <JadeMethod name="doCmbBlockUnitBuild" id="41b7e8ee-07f7-4b47-9dbc-cd76e425da6e">
        <source>doCmbBlockUnitBuild();
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	labels : StringArray; 
	values : IntegerArray;
	tot, idx : Integer;
	theLabel : String;
begin
	create labels transient;
	create values transient;
	
	self.cmbBlockUnit.clear;
	self.cmbBlockUnit.sorted := false;

	app.getAllInvoiceCalcTypes(true,true,labels,values,"UNIT");
	
	tot := 	values.size;
	
	foreach idx in 1 to tot do
	
		self.cmbBlockUnit.addItem(labels[idx]);
		self.cmbBlockUnit.itemData[idx] := values[idx];
	endforeach;
epilog
	delete labels;
	delete values;
end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbBlockUnitBuildCargo" id="a0c792b1-2a67-4003-bf79-096a25da4ec0">
        <source>doCmbBlockUnitBuildCargo();
/*
Purpose:			
Date				Who			Reason
DECEMBER 2012		CNWAB1		Initial creation
*/

vars
	cargoLabels : StringArray; 
	cargoValues : IntegerArray;
	tot, idx : Integer;
	idxc	: Integer;
begin


	create cargoLabels transient;
	create cargoValues transient;
	
	self.cmbBlockUnit.clear;
	self.cmbBlockUnit.sorted := true;

	app.getAllInvoiceCalcTypes(true,true,cargoLabels,cargoValues,"CARGO");	
	self.cargoCalcTypes.clear();
	cargoValues.copy(self.cargoCalcTypes);		// save for later use

	tot := 	cargoValues.size;
	foreach idx in 1 to tot do
		if cargoValues[idx] = INV_CALC_TYPE_BUSHRSCARGOVALUE then
			continue;
		endif;
	
		idxc := self.cmbBlockUnit.addItem("Cargo - " &amp; cargoLabels[idx]);
		
		self.cmbBlockUnit.itemData[idxc] := cargoValues[idx];
	endforeach;
	
	

epilog
	delete cargoLabels;
	delete cargoValues;
end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbBlockUnitBuildConvert" id="c6d802bb-fb96-41a8-a4f6-67a9ed3b9d1f">
        <source>doCmbBlockUnitBuildConvert(_calcTypeType : String); // ### TFS 51219 28MAY2021 NAVAB1
/*
Purpose:			
Date				Who			Reason
DECEMBER 2012		CNWAB1		Initial creation
*/

vars
	cargoLabels : StringArray; 
	cargoValues : IntegerArray;
	tot, idx : Integer;
	idxc	: Integer;
begin


	create cargoLabels transient;
	create cargoValues transient;
	
	self.cmbBlockUnit.clear;
	self.cmbBlockUnit.sorted := true;

	app.getAllInvoiceCalcTypes(true,true,cargoLabels,cargoValues,_calcTypeType);	
	self.cargoCalcTypes.clear();
	cargoValues.copy(self.cargoCalcTypes);		// save for later use

	tot := 	cargoValues.size;
	foreach idx in 1 to tot do
		if cargoValues[idx] &lt;&gt; INV_CALC_TYPE_DAYSINCE_REC_TEU 
		and cargoValues[idx] &lt;&gt; INV_CALC_TYPE_DAYSINCE_REC_RT	//08 May 2018	NDL	TFS 38525
		and cargoValues[idx] &lt;&gt; INV_CALC_TYPE_DAYSINCE_SHIP_EN 
		and cargoValues[idx] &lt;&gt; INV_CALC_TYPE_DAYSINCE_SHIP_ST 
		and cargoValues[idx] &lt;&gt; INV_CALC_TYPE_DAYSINCE_VOY_IN 
		and cargoValues[idx] &lt;&gt; INV_CALC_TYPE_DAYSINCE_VOY_OUT 
		and cargoValues[idx] &lt;&gt; INV_CALC_TYPE_DAYS_CONNECTED 
		and cargoValues[idx] &lt;&gt; INV_CALC_TYPE_DAYS_ONSITE_AT 
		and cargoValues[idx] &lt;&gt; INV_CALC_TYPE_DAYS_SINCE_RECVL 
		and cargoValues[idx] &lt;&gt; INV_CALC_TYPE_DAYSINCE_SUBTERM	//28 Jun 2018	NDL	TFS 39338
		and cargoValues[idx] &lt;&gt; INV_CALC_TYPE_QUANTITY 
		and cargoValues[idx] &lt;&gt; INV_CALC_TYPE_UNITY 
		and cargoValues[idx] &lt;&gt; INV_CALC_TYPE_INVENT_VALUE1  // ### TFS 51219 28MAY2021 NAVAB1
		and cargoValues[idx] &lt;&gt; INV_CALC_TYPE_INVENT_WEIGHT  // ### TFS 51219 28MAY2021 NAVAB1
		and cargoValues[idx] &lt;&gt; INV_CALC_TYPE_INVENT_VOLUME  // ### TFS 51219 28MAY2021 NAVAB1
		and cargoValues[idx] &lt;&gt; INV_CALC_TYPE_INVENT_QUANTITY  // ### TFS 51219 28MAY2021 NAVAB1
		and cargoValues[idx] &lt;&gt; INV_CALC_TYPE_TRANSQUANTITY then 
			continue;
		endif;
	
		if _calcTypeType = "CARGO" then  // ### TFS 51219 10JUN2021 NAVAB1
			idxc := self.cmbBlockUnit.addItem("Cargo - " &amp; cargoLabels[idx]);
		else
			idxc := self.cmbBlockUnit.addItem(cargoLabels[idx]);  // ### TFS 51219 10JUN2021 NAVAB1
		endif;
		
		self.cmbBlockUnit.itemData[idxc] := cargoValues[idx];
	endforeach;
	
	

epilog
	delete cargoLabels;
	delete cargoValues;
end;</source>
        <Parameter name="_calcTypeType" type="String"/>
    </JadeMethod>
    <JadeMethod name="doCmbBlockUnitBuildTidal" id="b9180861-a4a1-4f99-b24e-adf542adaf91">
        <source>doCmbBlockUnitBuildTidal();
// ---------------------------------------------------------------------------
// CCMS 1327 Tidal Class extra block units
// ---------------------------------------------------------------------------

vars
	labels : StringArray; 
	values : IntegerArray;
	tot, idx : Integer;
	theLabel : String;
begin
	create labels transient;
	create values transient;
	
	self.cmbBlockUnit.clear;
	self.cmbBlockUnit.sorted := false;

	app.getAllInvoiceCalcTypes(true,true,labels,values,"UNIT");
	
	tot := 	values.size;
	
	foreach idx in 1 to tot do
		self.cmbBlockUnit.addItem(labels[idx]);
		self.cmbBlockUnit.itemData[idx] := values[idx];
	endforeach;
	
	self.cmbBlockUnit.itemData[self.cmbBlockUnit.addItem("Value of 1")] := INV_CALC_TYPE_UNITY;
	self.cmbBlockUnit.itemData[self.cmbBlockUnit.addItem("Resource Quantity")] := INV_CALC_TYPE_RESOURCE_QTY;

epilog
	delete labels;
	delete values;
end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbBlockUnitBuildWO" id="72fcf152-001b-4d89-a476-841dbf6dca80">
        <source>doCmbBlockUnitBuildWO();
/*
Purpose:		TFS 39198	
Date				Who			Reason
JUNE 2018		CNWAB1		Initial creation
*/

vars
	labels : StringArray; 
	values : IntegerArray;
	tot, idx : Integer;
	theLabel : String;
begin
	create labels transient;
	create values transient;
	
	self.cmbBlockUnit.clear;
	self.cmbBlockUnit.sorted := false;
	self.cmbBlockUnit.itemData[self.cmbBlockUnit.addItem("Work Order - Units")] := INV_CALC_TYPE_WO_UNITS;

	app.getAllInvoiceCalcTypes(true,true,labels,values,"UNIT");
	
	tot := 	values.size;
	
	foreach idx in 1 to tot do
		self.cmbBlockUnit.addItem(labels[idx]);
		self.cmbBlockUnit.itemData[idx+1] := values[idx];
	endforeach;
	
	
	self.cmbBlockUnit.itemData[self.cmbBlockUnit.addItem("Cargo - Value of 1")] := INV_CALC_TYPE_UNITY;
	self.cmbBlockUnit.listIndex := 1;
	self.tblEntDetail.setValueByControlName(self.cmbBlockUnit.name,self.cmbBlockUnit.text);
epilog
	delete labels;
	delete values;
end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbBlockUnitBuildWOPermit" id="7af9806d-7f9b-4783-95dc-241f60552a37">
        <source>doCmbBlockUnitBuildWOPermit();
/*
Purpose:		TFS 39198	
Date				Who			Reason
JUNE 2018		CNWAB1		Initial creation
*/

vars
	labels : StringArray; 
	values : IntegerArray;
	tot, idx : Integer;
	theLabel : String;
begin
	create labels transient;
	create values transient;
	
	self.cmbBlockUnit.clear;
	self.cmbBlockUnit.sorted := false;

	self.cmbBlockUnit.itemData[self.cmbBlockUnit.addItem("Cargo - Value of 1")] := INV_CALC_TYPE_UNITY;
	self.cmbBlockUnit.itemData[self.cmbBlockUnit.addItem("Cargo - Quantity")] := INV_CALC_TYPE_QUANTITY;
	self.cmbBlockUnit.itemData[self.cmbBlockUnit.addItem("Cargo - Weight Kilos")] := INV_CALC_TYPE_WEIGHT;
	self.cmbBlockUnit.itemData[self.cmbBlockUnit.addItem("Cargo - Weight Tonnes")] := INV_CALC_TYPE_WEIGHT_TON;
	self.cmbBlockUnit.itemData[self.cmbBlockUnit.addItem("Cargo - Volume")] := INV_CALC_TYPE_VOLUME;
	self.cmbBlockUnit.itemData[self.cmbBlockUnit.addItem("Cargo - Revenue Tonnes")] := INV_CALC_TYPE_REVENUE_TONS;
	self.cmbBlockUnit.itemData[self.cmbBlockUnit.addItem("Cargo - Requested Amount")] := INV_CALC_TYPE_WO_UNITS; // TFS 42221 19DEC18
	
	self.cmbBlockUnit.itemData[self.cmbBlockUnit.addItem("ETMAL - Days")] := INV_CALC_TYPE_WO_ETMAL_DAYS; // TFS 42161
	self.cmbBlockUnit.itemData[self.cmbBlockUnit.addItem("ETMAL - Hours")] := INV_CALC_TYPE_WO_ETMAL_HOURS; // TFS 42161
	self.cmbBlockUnit.itemData[self.cmbBlockUnit.addItem("ETMAL - Minutes")] := INV_CALC_TYPE_WO_ETMAL_MINUTES; // TFS 42161
	
	self.cmbBlockUnit.listIndex := 1;
	self.tblEntDetail.setValueByControlName(self.cmbBlockUnit.name,self.cmbBlockUnit.text);
epilog
	delete labels;
	delete values;
end;</source>
