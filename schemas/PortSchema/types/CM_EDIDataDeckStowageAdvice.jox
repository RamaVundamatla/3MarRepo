    <JadeMethod name="getVesselName" id="cc1f5fbf-af75-4434-94e7-31f44b99848b">
        <source>getVesselName(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Oct 2022 navsj20	ChangeRequest 55084: EUP - EDI Administration Usability Requirements
*/

vars
	vCode: String;
	terminal: CM_Terminal;
	voyage: CM_Voyage;
begin
	vCode := self.getVoyageCode;
	terminal := self.getMyTerminal;
	if vCode &lt;&gt; null and terminal &lt;&gt; null then
		voyage := terminal.lookupVoyage(vCode, null, false);
		if voyage &lt;&gt; null then
			return voyage.vesselName;
		endif;
	endif;
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVoyageCode" id="f8d79aae-cac1-48f1-b185-0d732e770e96">
        <source>getVoyageCode(): String;
/*

Date		Who		Reason
23 October 2015	cnwer1	Initial creation PAR 37090

*/

vars
	ediTI : CM_EDITrackedItem;
begin
	foreach ediTI in self.allEDITrackedItems where ediTI.isKindOf(CM_EDIVoyageHeaderTI) do
		return ediTI.getVoyageCode();
	endforeach;
	
	return null;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVoyageETA" id="bc7c30cf-0c7b-48db-90ca-3ebf65bd72bc">
        <source>getVoyageETA(): Date;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Oct 2022 navsj20	ChangeRequest 55084: EUP - EDI Administration Usability Requirements
*/

vars
	vCode: String;
	terminal: CM_Terminal;
	voyage: CM_Voyage;
begin
	vCode := self.getVoyageCode;
	terminal := self.getMyTerminal;
	if vCode &lt;&gt; null and terminal &lt;&gt; null then
		voyage := terminal.lookupVoyage(vCode, null, false);
		if voyage &lt;&gt; null then
			return voyage.estimatedArrivalDT.date;
		endif;
	endif;
	return null;
epilog

end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
