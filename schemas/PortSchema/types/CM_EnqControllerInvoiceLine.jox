<Class name="CM_EnqControllerInvoiceLine" id="c9a90c6a-23e3-4e0e-b44b-d02a52bd8845">
    <superclass name="CM_EnquiryController"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <PrimAttribute name="chargeFromDate" id="48c662b9-f78d-47db-ae7a-99b53ad42605">
        <embedded/>
        <type name="Date"/>
    </PrimAttribute>
    <PrimAttribute name="chargeToDate" id="08decc61-73c9-4dea-960d-d75d4b563bdb">
        <embedded/>
        <type name="Date"/>
    </PrimAttribute>
    <ImplicitInverseRef name="myBank" id="40456cba-b0c8-4846-81c0-ee06bf042525">
        <embedded/>
        <type name="CM_Bank"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myDebtor" id="f0630c25-eb42-40cb-8a87-68dea95c8057">
        <embedded/>
        <type name="CM_Debtor"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myInvoice" id="5a707d7d-42c4-482d-8fe5-c0ffbbf2393a">
        <embedded/>
        <type name="CM_Invoice"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myTerminal" id="67e69c31-16d7-4724-96e5-06c9b0314e26">
        <embedded/>
        <type name="CM_Terminal"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myVoyage" id="34c33861-ce7a-44b6-963d-3287e4491b2f">
        <embedded/>
        <type name="CM_Voyage"/>
    </ImplicitInverseRef>
    <JadeMethod name="doQuery" id="9a4c48c5-bdab-49f2-9e79-b21a1f21549a">
        <updating/>
        <source>doQuery(_qDef: CM_QueryDefinition) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 May 2014	cnwndl1	Initial creation	Par 34142
21/06/2018 	JLGNS1	Bug 39083: STWO - Selector query does not come back with data in acceptable time.
03 Jul 2025	navhl20 Defect MTN-35231: Selector Query - Cargo Transaction Days Passed less than 0 is not returning any data
*/

vars

	bankSet : ObjectSet;
	drSet : ObjectSet;
	voySet : ObjectSet;
	crit : CM_SelectorCriteriaLine;
	obj : Object;
	invoiceNum : Integer;
	invoiceLineNum 		: Integer;		// Bug 39083
	tempInvoiceLineNum  : Integer;		// Bug 39083
	invoiceLine : CM_InvoiceLine;		// Bug 39083
	invoiceSet : ObjectSet;				// Bug 39083
	iterator 	: Iterator;				// Bug 39083
	itInvLine 	: CM_InvoiceLine;		// Bug 39083
	voycode : String;
	voycodes : StringArray;
	voyage : CM_Voyage;
	now : Date;	//04 Mar 2019	NDL	TFS 43394
begin

	self.reset();
	
	create bankSet transient;
	create drSet transient;
	create voySet transient;
	create invoiceSet transient; // TFS 40130
	create voycodes transient; // TFS 40130
	
	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName[CM_InvoiceLine::getTerminal.name, _qDef.className];
	if crit &lt;&gt; null then
		if crit.myQueryOperator.description = CM_QueryOperator.Operator_Equal then
			self.myTerminal := crit.myQueryOperator.getSearchValue().CM_Terminal;
		endif;
	endif;
	
	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName[CM_InvoiceLine::bank.name, _qDef.className];
	if crit &lt;&gt; null then
		if crit.myQueryOperator.description = CM_QueryOperator.Operator_IsOneOf then
			crit.myQueryOperator.getSearchValueAsObjectSet(bankSet);
		elseif crit.myQueryOperator.description = CM_QueryOperator.Operator_Equal then
			self.myBank := crit.myQueryOperator.getSearchValue().CM_Bank;
			// TFS 40130
			if self.myBank &lt;&gt; null
			and self.myTerminal = null then
				self.myTerminal := self.myBank.getMyTerminal();
			endif;
		endif;
	endif;
	
	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName[CM_InvoiceLine::getDebtor.name, _qDef.className];
	if crit &lt;&gt; null then
		if crit.myQueryOperator.description = CM_QueryOperator.Operator_IsOneOf then
			crit.myQueryOperator.getSearchValueAsObjectSet(drSet);
		elseif crit.myQueryOperator.description = CM_QueryOperator.Operator_Equal then
			self.myDebtor := crit.myQueryOperator.getSearchValue().CM_Debtor;
		endif;
	endif;
	
	
	// TFS 40130
	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName[CM_InvoiceLine::getVoyageCode.name, _qDef.className];
	if crit &lt;&gt; null then
		if crit.myQueryOperator.description = CM_QueryOperator.Operator_IsOneOf then
			crit.myQueryOperator.getSearchValueAsStringArray(voycodes);
			
			if self.myTerminal &lt;&gt; null then
				foreach voycode in voycodes	discreteLock do
					voyage := self.myTerminal.allVoyagesByCode.getAtKeyGeq(voycode,null);
					if voyage &lt;&gt; null 
					and voyage.code = voycode then
						voySet.addNoDuplicates(voyage,false);
					endif;
		
				endforeach;
			
			endif;
	
		elseif crit.myQueryOperator.description = CM_QueryOperator.Operator_Equal then
			voycode := crit.myQueryOperator.getSearchValue().String;
			
			if voycode &lt;&gt; null 
			and self.myTerminal &lt;&gt; null then
				self.myVoyage := self.myTerminal.allVoyagesByCode.getAtKeyGeq(voycode,null);
				if self.myVoyage &lt;&gt; null 
				and self.myVoyage.code &lt;&gt; voycode then
					self.myVoyage := null;
				endif;
			endif;
			
		endif;
	endif;
	
	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName[CM_InvoiceLine::getInvSequenceNum.name, _qDef.className];	
	if crit &lt;&gt; null then																									
		if crit.myQueryOperator.description = CM_QueryOperator.Operator_Equal then											
			invoiceNum := crit.myQueryOperator.getSearchValue().Integer;													
		endif;																												
	endif;																													
		
	if invoiceNum &lt;&gt; null then
		if self.myTerminal &lt;&gt; null and self.myBank &lt;&gt; null then
			if self.myDebtor &lt;&gt; null then
				self.myInvoice := self.myDebtor.allInvoices.getAtKey( self.myTerminal, self.myBank, invoiceNum); 
			else
				self.myInvoice := self.myBank.allInvoices.getAtKey( self.myTerminal, self.myBank, invoiceNum);
			endif;
		endif;
		
	endif;	
	
	
	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName[CM_InvoiceLine::sequenceNum.name, _qDef.className];			// Bug 39083
	if crit &lt;&gt; null then																									// Bug 39083
		if self.myTerminal &lt;&gt; null and self.myBank &lt;&gt; null then																// Bug 39083
			if crit.myQueryOperator.description = CM_QueryOperator.Operator_Equal then										// Bug 39083
				invoiceLineNum := crit.myQueryOperator.getSearchValue().Integer;											// Bug 39083
				if self.myDebtor &lt;&gt; null then																				// Bug 39083
					invoiceLine := self.myDebtor.invoiceLines.getAtKey(self.myTerminal,self.myBank,invoiceLineNum);			// Bug 39083
				else																										// Bug 39083
					invoiceLine := self.myBank.invoiceLines.getAtKey(self.myTerminal,self.myBank,invoiceLineNum);			// Bug 39083
				endif;																										// Bug 39083
				if invoiceLine &lt;&gt; null then																					// Bug 39083
					self.myInvoice := invoiceLine.invoice;																	// Bug 39083
				endif;																										// Bug 39083	
			else																											// Bug 39083
				if crit.myQueryOperator.description = CM_QueryOperator.Operator_GreaterThan then							// Bug 39083
					tempInvoiceLineNum := crit.myQueryOperator.getSearchValue().Integer + 1;								// Bug 39083
				elseif crit.myQueryOperator.description = CM_QueryOperator.Operator_LessThan then							// Bug 39083
					tempInvoiceLineNum := crit.myQueryOperator.getSearchValue().Integer - 1;								// Bug 39083
				else																										// Bug 39083
					tempInvoiceLineNum := crit.myQueryOperator.getSearchValue().Integer;									// Bug 39083
				endif;																										// Bug 39083
																															// Bug 39083
				if 	crit.myQueryOperator.description = CM_QueryOperator.Operator_GreaterThan or 							// Bug 39083
					crit.myQueryOperator.description = CM_QueryOperator.Operator_GreaterThanEqual then						// Bug 39083
																															// Bug 39083
					if self.myDebtor &lt;&gt; null then																			// Bug 39083
						iterator :=	self.myDebtor.invoiceLines.createIterator();											// Bug 39083
						self.myDebtor.invoiceLines.startKeyGeq(self.myTerminal,self.myDebtor.bank,tempInvoiceLineNum,iterator);	// Bug 39083
					else																										// Bug 39083
						iterator :=	self.myBank.invoiceLines.createIterator();													// Bug 39083
						self.myBank.invoiceLines.startKeyGeq(self.myTerminal,self.myBank,tempInvoiceLineNum,iterator);			// Bug 39083
					endif;																										// Bug 39083
																																// Bug 39083
					while iterator.next(itInvLine) do																			// Bug 39083
						if not invoiceSet.includes(itInvLine.invoice) then														// Bug 39083
							invoiceSet.add(itInvLine.invoice);																	// Bug 39083
						endif;																									// Bug 39083
					endwhile;																									// Bug 39083
				else																											// Bug 39083
					if self.myDebtor &lt;&gt; null then																				// Bug 39083
						iterator :=	self.myDebtor.invoiceLines.createIterator();												// Bug 39083
						self.myDebtor.invoiceLines.startKeyLeq(self.myTerminal,self.myBank,tempInvoiceLineNum,iterator);		// Bug 39083										
					else																										// Bug 39083
						iterator :=	self.myBank.invoiceLines.createIterator();													// Bug 39083
						self.myBank.invoiceLines.startKeyLeq(self.myTerminal,self.myBank,tempInvoiceLineNum,iterator);			// Bug 39083
					endif;																										// Bug 39083
																																// Bug 39083
					while iterator.back(itInvLine) do																			// Bug 39083
						if not invoiceSet.includes(itInvLine.invoice) then														// Bug 39083
							invoiceSet.add(itInvLine.invoice);																	// Bug 39083
						endif;																									// Bug 39083
					endwhile;																									// Bug 39083
				endif;																											// Bug 39083
																																// Bug 39083
				if invoiceSet.isEmpty then																						// Bug 39083
					return;																										// Bug 39083
				endif;																											// Bug 39083
			endif;																												// Bug 39083	
		endif;																													// Bug 39083
	endif;																														// Bug 39083
	
	if  invoiceLineNum &lt;&gt; null or invoiceNum &lt;&gt; null then															// Bug 39083
		if self.myInvoice = null then 																				// Bug 39083
			return;																									// Bug 39083
		endif;																										// Bug 39083
	endif;																											// Bug 39083
	
	//04 Mar 2019	NDL	TFS 43394
	self.chargeFromDate := null;
	self.chargeToDate := null;
	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName[CM_InvoiceLine::getChargeDate.name, _qDef.className];
	if crit &lt;&gt; null then
		now := app.actualTimeAppServer.Date;
		if crit.myQueryOperator.class = CM_QDateRange then
			self.chargeFromDate := crit.myQueryOperator.CM_QDateRange.getSearchValueFromDate();
			self.chargeToDate := crit.myQueryOperator.CM_QDateRange.getSearchValueToDate();
		elseif crit.myQueryOperator.class = CM_QDateEquals then
			self.chargeFromDate := crit.myQueryOperator.getSearchValue().Date;
			self.chargeToDate := self.chargeFromDate;
		elseif crit.myQueryOperator.class = CM_QDateGreaterThan then
			self.chargeFromDate := crit.myQueryOperator.getSearchValue().Date;
		elseif crit.myQueryOperator.class = CM_QDateLessThan then
			self.chargeToDate := crit.myQueryOperator.getSearchValue().Date;
		elseif crit.myQueryOperator.class = CM_QDateDayRange then
			self.chargeFromDate := now.addDays(-1 * crit.myQueryOperator.CM_QDateDayRange.getSearchToValue().Integer.max(crit.myQueryOperator.CM_QDateDayRange.getSearchFromValue().Integer));
			self.chargeToDate := now.addDays(-1 * crit.myQueryOperator.CM_QDateDayRange.getSearchToValue().Integer.min(crit.myQueryOperator.CM_QDateDayRange.getSearchFromValue().Integer));
		elseif crit.myQueryOperator.class = CM_QDateDayEquals then
			self.chargeFromDate := now.addDays(-crit.myQueryOperator.getSearchValue().Integer + 1);
			self.chargeToDate := self.chargeFromDate;
		elseif crit.myQueryOperator.class = CM_QDateDayGreaterThan then
			self.chargeToDate := now.addDays(-crit.myQueryOperator.getSearchValue().Integer);
		elseif crit.myQueryOperator.class = CM_QDateDayLessThan then
			self.chargeFromDate := now.addDays(-crit.myQueryOperator.getSearchValue().Integer);				//03.07.2025 navhl20 #35231
		endif;
	endif;
	
	if self.myVoyage &lt;&gt; null then // TFS 40130
		self.doSearch(); // TFS 40130
	elseif self.myInvoice &lt;&gt; null then
		self.doSearch();
	elseif not voySet.isEmpty then
		foreach obj in voySet do
			self.myVoyage := obj.CM_Voyage;
			self.doSearch();
		endforeach;
	
		
	elseif not invoiceSet.isEmpty then																				// Bug 39083
		foreach obj in invoiceSet do																				// Bug 39083
			self.myInvoice := obj.CM_Invoice;																		// Bug 39083
			self.doSearch();																						// Bug 39083
		endforeach;																									// Bug 39083
				
	elseif self.myDebtor &lt;&gt; null then
		self.doSearch();
		
	elseif self.myBank &lt;&gt; null then
		self.doSearch();
	
	elseif not drSet.isEmpty then
		foreach obj in drSet do
			self.myDebtor := obj.CM_Debtor;
			self.doSearch();
		endforeach;
	
	elseif not bankSet.isEmpty then
		foreach obj in bankSet do
			self.myBank := obj.CM_Bank;
			self.doSearch();
		endforeach;
	
	
	else
		app.raiseCMException( Please_includ_criter_more_foll, null, null );
	endif;
	
epilog
	delete voycodes; // TFS 40130
	delete voySet; // TFS 40130
	delete bankSet;
	delete drSet;
	delete invoiceSet;
end;</source>
        <Parameter name="_qDef" type="CM_QueryDefinition"/>
    </JadeMethod>
    <JadeMethod name="doSearch" id="54b9fb21-ae27-4b1c-a552-4f41116085eb">
        <updating/>
        <source>doSearch() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 May 2014	cnwndl1	Initial creation	Par 34142

*/

vars

	iter : Iterator;
	invoiceLine : CM_InvoiceLine;
	invoice : CM_Invoice;
	breakOut : Boolean;
	passport : CM_Passport;
	startObject : CM_InvoiceLine;
	doCheckToDate : Boolean;	//04 Mar 2019	NDL	TFS 43394
	chargeFromTS : TimeStamp;	//04 Mar 2019	NDL	TFS 43394

begin

	passport := app.myPassport;
	
	// TFS 40130
	if self.myVoyage &lt;&gt; null then
		foreach invoice in self.myVoyage.allInvoices	discreteLock do
			foreach invoiceLine in invoice.invoiceLines	discreteLock do
				if self.includesObject(invoiceLine, breakOut, passport) then
					self.addObjectToSet(invoiceLine);
				endif;
				if breakOut	or self.breakOutOfSearch then
					break;
				endif;
	
			endforeach;
	
		endforeach;
	elseif self.myInvoice &lt;&gt; null then
		//voyage known.
		iter := self.myInvoice.invoiceLines.createIterator;
		while iter.next(invoiceLine) do
			if self.includesObject(invoiceLine, breakOut, passport) then
				self.addObjectToSet(invoiceLine);
			endif;
			if breakOut	or self.breakOutOfSearch then
				break;
			endif;
		endwhile;
				
	elseif self.myDebtor &lt;&gt; null then
		//debtor known.
		iter := self.myDebtor.invoiceLines.createIterator;
		while iter.next(invoiceLine) do
			if self.includesObject(invoiceLine, breakOut, passport) then
				self.addObjectToSet(invoiceLine);
			endif;
			if breakOut	or self.breakOutOfSearch then
				break;
			endif;
		endwhile;
			
	elseif self.myBank &lt;&gt; null then
		//just bank known
		//04 Mar 2019	NDL	TFS 43394
		if self.chargeFromDate.isValid or self.chargeToDate.isValid then
			iter := self.myBank.invoiceLinesByDateTime.createIterator;
			if self.chargeFromDate.isValid then
				chargeFromTS.setDate( chargeFromDate );
				chargeFromTS.setTime( "00.00.00".Time );
				startObject := self.myBank.invoiceLinesByDateTime.getAtKeyGeq( chargeFromTS );
				if startObject &lt;&gt; null then
					iter.startAtObject( startObject );
				endif;
			endif;
			if self.chargeToDate.isValid then
				doCheckToDate := true;
			endif;
			while iter.next(invoiceLine) do
				if doCheckToDate then
					if invoiceLine.chargeTime.Date &gt; self.chargeToDate then
						break;
					endif;
				endif;
				if self.includesObject(invoiceLine, breakOut, passport) then
					self.addObjectToSet(invoiceLine);
				endif;
				if breakOut	or self.breakOutOfSearch then
					break;
				endif;
			endwhile;
			
		else
			iter := self.myBank.invoiceLines.createIterator;
			while iter.next(invoiceLine) do
				if self.includesObject(invoiceLine, breakOut, passport) then
					self.addObjectToSet(invoiceLine);
				endif;
				if breakOut	or self.breakOutOfSearch then
					break;
				endif;
			endwhile;
		endif;
			
	endif;

epilog

	delete iter;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="reset" id="e6aec68f-ad12-4980-bed0-e8249bc72e41">
        <updating/>
        <source>reset() updating;
/*

Purpose:			// TFS 40130

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2014	cnwndl1	Initial creation	Par 34142

*/

vars

begin
	inheritMethod();
	
	self.myTerminal := null;
	self.myBank := null;
	self.myDebtor := null;
	self.myInvoice := null;
	self.myVoyage := null; // TFS 40130

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setMyFilterClass" id="bf4a29ce-edd6-4ae9-909f-7992a4afcfbe">
        <updating/>
        <source>setMyFilterClass() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2014	cnwndl1	Initial creation	Par 34142

*/

vars

begin
	self.myFilterClass := CM_InvoiceLine;

epilog

end;</source>
    </JadeMethod>
</Class>
