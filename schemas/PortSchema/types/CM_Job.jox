    <JadeMethod name="createWOTransaction" id="e3a18d3a-d39f-4daf-8c91-1001e279bdb1">
        <source>createWOTransaction(_action : Integer; woTransType : Integer; _ts : TimeStamp);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Oct 2024	navbs1	Initial creation Bug MTN-12445 EUP | FR 54883 - Start and End Times for Operations in Mobile App - Unpack issues
06 Mar 2025 navma1 	MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars
	woDtl		: CM_WorkOrderDtl;
	trans 		: CM_Transaction;
	woTrans 	: CM_WOTransaction;
	woJobTrans  : CM_WOJobDetail;
	isStart		: Boolean;
	jobID		: String;
begin
	isStart := _action = Job_Action_Start or _action = Job_Action_Resume;
    woDtl 	:= self.getMyWorkOrderDtl();												
	
	if woDtl &lt;&gt; null then
		// only one start and end transaction should be recorded per job			
		if _action = Job_Action_Start or  _action = Job_Action_Complete then
			
			jobID := self.getJobId();									//06.03.2025 navma1 #MTN-34179
			
			foreach trans in woDtl.allWODtlTransactions  discreteLock	//06.03.2025 navma1 #MTN-34179
			where trans.isKindOf(CM_WOJobDetail) and trans.CM_WOJobDetail.jobId = jobID  and trans.CM_WOJobDetail.type = woTransType do 
				return;
			endforeach;
		endif;
		woTrans := woDtl.createWOTransaction(woTransType, null, null);
		if woTrans &lt;&gt; null then
			woJobTrans := woTrans.CM_WOJobDetail;
			woJobTrans.setJobActionDetails(self, isStart, _ts);
		endif;
	endif;
end;
</source>
        <Parameter name="_action" type="Integer"/>
        <Parameter name="woTransType" type="Integer"/>
        <Parameter name="_ts" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="deQueueJob" id="120ad846-8c9e-46f5-a344-db7c9cbaf5f7">
        <source>deQueueJob();
//Removes our entries, and dequeues us.
vars

begin
	exclusiveLock(self);
	if self.allEntries.isEmpty then
		return;
	endif;
	while self.allEntries.isEmpty = false do
		self.allEntries.last.deleteEntry( false, null);
	endwhile;

end;</source>
    </JadeMethod>
    <JadeMethod name="departureProcess" id="1e85acc4-5f11-4ec9-82ee-35d1802cedf2">
        <updating/>
        <source>departureProcess(_passport : CM_Passport input) updating;
//-----------------------------------------
//Created: April 2003 By: cnwgd1
//-----------------------------------------
/*
Date					Who		Reason
09 October 2023			jlizm1	Initial creation TFS 59730 Kiosk Load Sequence
*/
vars
	wle : CM_WorkListEntry;
	wles : CM_WLEArray;
	blnJobComplete : Boolean;
begin

	exclusiveLock(self);

	//epr changed from WLE_COMPLETED constant has same integer value which is why it worked
	if self.status &lt;&gt; JOB_COMPLETE then
		self.rebuildStatus();
	endif;

//	if self.status &lt;&gt; JOB_COMPLETE then // dh 18/6/2008 checnge for mobile apps	
	if not self.isCompleteForExit then
		app.raiseCMException1(ERR_JOB_NOT_COMPLETE, self.jobId, "", null);
		return;
	endif;

	create wles transient;
	self.workListEntries.copy(wles);
	
	foreach wle in wles do
		wle.departureProcess(_passport);
		if _passport.hasErrors then
			break;
		endif;
	endforeach;
	
epilog
	delete wles;
	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
