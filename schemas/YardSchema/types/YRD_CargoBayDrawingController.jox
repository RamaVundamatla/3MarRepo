    <JadeMethod name="drawHeight" id="f62739d2-c45b-4fe5-949c-e1bf06964c93">
        <source>drawHeight(_frame : CMUI_GridAreaDrawingFrame; _label: String; _colour: Integer; _theX1: Real; _theY1: Real; _theX2: Real; _theY2: Real) protected;
// ---------------------------------------------------------------------------
// Created:     25 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theFrame 	: CMUI_GridAreaDrawingFrame;
	scaleFactor, fontSize 	: Real;
	offsetY, offsetX : Integer;
begin
	if self.myDrawingFrame = null then		// PAR 21532 CCMS SFW 1025
		inheritMethod(_frame, _label, _colour, _theX1, _theY1, _theX2, _theY2);
		return;
	endif;
	
	theFrame := _frame;
	fontSize := theFrame.drawFontSize;
	scaleFactor := self.scaleFactor;

	if scaleFactor = ScaleFactor_1 then
		offsetY := 1;
		offsetX := 3;
	elseif scaleFactor = ScaleFactor_1_5 then
		offsetY := 2;
		offsetX := 6;
	elseif scaleFactor = ScaleFactor_2 then
		offsetY := 3;
		offsetX := 6;
	elseif scaleFactor = ScaleFactor_3 then
		offsetY := 6;
		offsetX := 10;
	elseif scaleFactor = ScaleFactor_4 then
		offsetY := 10;
		offsetX := 10;
	elseif scaleFactor = ScaleFactor_6 then
		offsetY := 10;
		offsetX := 20;
	elseif scaleFactor = ScaleFactor_9 then
		offsetY := 10;
		offsetX := 25;
	endif;
	
	theFrame.drawFontBold := true;
	theFrame.drawFontName := "Arial";
	theFrame.drawTextAt("X", _theX1+offsetX, _theY1+offsetY, _colour);
	theFrame.drawFontBold := false;
	theFrame.drawFontSize := fontSize;
end;</source>
        <access>protected</access>
        <Parameter name="_frame" type="CMUI_GridAreaDrawingFrame"/>
        <Parameter name="_label" type="String"/>
        <Parameter name="_colour" type="Integer"/>
        <Parameter name="_theX1" type="Real"/>
        <Parameter name="_theY1" type="Real"/>
        <Parameter name="_theX2" type="Real"/>
        <Parameter name="_theY2" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawLCOverstow" id="73424726-cbd1-485d-9d0a-eb3eaff6d400">
        <updating/>
        <source>drawLCOverstow(_lc : CM_GridController; _frame : YRD_ContainerOStowDrawingFrame) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/11/2009	cnwphb1	Initial creation
12/05/2010	cnwdap1	CCMS 1116 Tranship changes
*/
constants
	FONTSIZE = 6;
vars
	startY, endX,
	endY, startX, origX		: Real;
	idx,
	tmpNumTIs, tmpNumQTIs,
	tmpNumPTIs, tmpNumATIs	: Integer;
	theOSTI, theTI			: CM_TrackedItem;
	theDisplayMode,
	theFillColour			: Integer;
	aLetter					: String;
	theCellHeight,
	numHalfHeights,
	stackHght				: Integer;
	theFrame				: YRD_ContainerOStowDrawingFrame;
	tmpUsage,
	tmpAvail,
	tmpHeightNoStackFrom	: Integer;
	isUnavailable,
	drawSolid,
	hasHeightRestriction	: Boolean;
	tmpPrimaryLC			: CM_LocationsController;
begin
	beginLoad;
	
	if self.flipHorizontal then
		origX := self.x2;
	else
		origX := self.x1;
	endif;

	stackHght := self.getHeightOfStack;

	self.myLocationsController := _lc;

	theFrame := _frame;
	
	if _lc = null or stackHght = 0 then
		// Nothing to draw
		return;
	endif;
	theDisplayMode := self.displayMode;
	
	tmpHeightNoStackFrom 	:= _lc.getHeightNoStackFrom();
	
	_lc.getAvailUsageHeight(tmpUsage, tmpAvail, hasHeightRestriction);
	isUnavailable := (tmpUsage = UNAVAILABLE_USE or 
						 tmpAvail = PAD_USER_UNAVAILABLE or 
		   				 tmpAvail = PAD_UNAVAILABLE);

	theFrame.drawFontName := "Arial";
	theFrame.drawFontSize := FONTSIZE * self.scaleFactor;
	theFrame.drawTextAlign := Frame.DrawTextAlign_Left;
	if self.myLocationsController.hasPower() then 
		theFillColour := self.POWER_FILL_COLOUR;
	else
		theFillColour := Gray;
		if self.myLocationsController.isOverhang() then
			theFillColour := theFrame.backColor;
		endif;
	endif;

	self.setTICollections();
	
	tmpNumTIs := self.allTempTIs.size;
	theFrame.drawWidth	:= 1;
	tmpNumQTIs := self.allTIsQ.size;
	tmpNumPTIs := self.allTIsP.size;
	tmpNumATIs := self.allTIsA.size;

	aLetter := self.letter;
	
	self.cellHeight := ((self.y2 - self.y1) / stackHght).Integer;
	numHalfHeights := 0;
	startY := self.y2;

	while true do
		idx := idx + 1;

		// just incase of continuous loop
		if idx &gt; 100 then
			break;
		endif;
		
		theTI := null;
		
		if idx &lt;= tmpNumTIs then
			theTI := self.allTempTIs[idx];
			
			theOSTI := self.myLocationsController.hasOversizedBackendsByMode(self.displayMode, 1, self.allTrackedItems, false);
			startX := self.adjustStartX(theOSTI, self.myLocationsController, idx);
			endX := self.adjustEndX(theTI, startX);
			
			self.tiHeight := theTI.getHeightOfTI();
			self.tiLength := theTI.getLengthInUnits().Integer;

			if self.allTIsA.includes(theTI) then
				tmpPrimaryLC := theTI.myPrimaryActualLocation;
			elseif self.allTIsQ.includes(theTI) then
				if _lc.isPrimaryLocationForFM(QUEUE_MODE, idx) then
					tmpPrimaryLC := _lc;
				endif;
			elseif self.allTIsP.includes(theTI) then
				if theTI.isRehandle 
				and (not theTI.myPrimaryPlannedLocation.isGridLocation) 
				and theTI.allPlannedFutureMoves.size = 2 then
					tmpPrimaryLC := theTI.allPlannedFutureMoves.last.CM_FutureMovePlanned.allLocationsControllers.first; // LAST FM
					if tmpPrimaryLC &lt;&gt; null then
						if not tmpPrimaryLC.isGridLocation then
							tmpPrimaryLC := theTI.allPlannedFutureMoves.first.CM_FutureMovePlanned.allLocationsControllers.first; // FIRST FM
						endif;
					endif;
				endif;

				if tmpPrimaryLC = null then
					tmpPrimaryLC := theTI.myPrimaryPlannedLocation;
				endif;
			endif;
			// NEVER draw a tranship import in the yard. switch to the tranship export.
			// PAR #23645 CCMS 1116 tranships are now just one TI, not two
			//if theTI.isTranshipImport() then		// PAR #23645 CCMS 1116
			//	theTI := theTI.myTranshipExport;	// PAR #23645 CCMS 1116
			//endif;								// PAR #23645 CCMS 1116
			
			if self.tiHeight = Ti_Half_Height then
				numHalfHeights := numHalfHeights + 1;
				theCellHeight := (self.cellHeight / 2).Integer;
			else
				theCellHeight := self.cellHeight.Integer;
			endif;
			startY 	:= startY - theCellHeight;
			endY	:= startY + theCellHeight;

			if startY &lt;=0 then
				break;
			endif;
			if startY &lt; self.y1 then
				break;
			endif;

			drawSolid := 	(theDisplayMode = DISPLAY_MODE_ACTUAL and self.allTIsA.includes(theTI))
						or		(theDisplayMode = DISPLAY_MODE_QUEUE and self.allTIsQ.includes(theTI))
						or		(theDisplayMode = DISPLAY_MODE_PLAN and self.allTIsP.includes(theTI));

			self.drawBackEnd := false;
			
			if tmpPrimaryLC &lt;&gt; _lc then
				// the TI will be drawn when its primary location is drawn
				continue;
			endif;

			if drawSolid then

				self.setIconPositions(startX, startY, endX, endY);
				// PAR 18682
				if self.myLocationsController.offsetFlexi &gt; 0 
				and self.myLocationsController.hasOversizedBackendsByMode(self.displayMode, idx, self.allTrackedItems, false) = null then
					self.drawBlankSpace(theFrame, theFillColour, idx, origX, startY, startX, endY + 1, false);
				endif;
				self.drawTIOverstow(theTI, null, startX, startY, endX, endY, theFrame);
			else // no solid, draw A, Q, P
				self.doDrawFMLetterForTI(theFrame, theTI, theFillColour, startX, startY,endX, endY);
			endif;

		// NO TIS JUST BLANKS AND RESTRICTIONS
		else
			theOSTI := self.myLocationsController.hasOversizedBackendsByMode(self.displayMode, idx, self.allTrackedItems, false);
			startX := self.adjustStartX(theOSTI, self.myLocationsController, idx);
			endX := self.adjustEndX(null, startX);
			
			// OK if going in here then we do not have any TIs in this view mode
			if numHalfHeights mod 2 = 0 then
				theCellHeight := self.cellHeight.Integer; // there have been an even number of 1/2s so reset now
			else
				theCellHeight := (self.cellHeight / 2).Integer;
			endif;

			numHalfHeights := 0;				
			startY 	:= startY - theCellHeight; 

			if startY &lt;=0 then// PAR 11143 
				break;
			endif;

			if startY &lt; self.y1 then
				break;
			endif;
			endY	:= startY + theCellHeight + 1;
			theCellHeight := self.cellHeight.Integer; // this may be half height to fill in, so reset it for next time
			
			if self.myLocationsController.offsetFlexi &gt; 0 
			and self.hasGotItemAtHeight(idx, false) 
			and (self.myLocationsController.allTrackedItemOSBackEnds.isEmpty()
					and self.myLocationsController.allTrackedItemOSBackEndsQd.isEmpty()
					and self.myLocationsController.allTrackedItemOSBackEndsPd.isEmpty()) then
				self.drawBlankSpace(theFrame, theFillColour, idx, origX, startY, startX, endY, false);
			endif;

			// ## GAP	
			if self.myLocationsController.isKindOf(CM_GapController) then
				if self.myLocationsController.isKindOf(CM_OverhangController) then
					self.drawBlankSpaceOverhang(theFrame, _frame.backColor, idx, startX -1, startY, endX, endY - 1);
				else
				
					if theFillColour &lt;&gt; POWER_FILL_COLOUR then
						theFillColour := _frame.backColor;
					endif;
					self.drawBlankSpace(theFrame, theFillColour, idx, startX, startY, endX, endY - 1, true);
				endif;
			// ## HEIGHT RESTRICTION
			elseif hasHeightRestriction then // HEIGHT RESTRICTION
				if idx &gt; (tmpNumQTIs + tmpNumPTIs + tmpNumTIs) then
					self.drawBlankSpace(theFrame, theFillColour, idx, startX, startY , endX, endY, true);
				endif;
				if idx &gt;= tmpHeightNoStackFrom then
					self.drawHeight(theFrame, aLetter, Red, startX, startY, endX, endY);
				else
					self.drawTranshipMark(theFrame, startX, startY, idx);
				endif;
			elseif theDisplayMode &lt;&gt; DISPLAY_MODE_ACTUAL
			and idx &lt;= tmpNumTIs 
			and tmpNumTIs &gt; 0 then
					self.drawLetter(theFrame,"A", (startX+((self.x2-startX)/2)-5).Integer, (startY + 2).Integer, Black,startX, startY, self.x2, endY,theFillColour,REAL_MODE,idx);
			else
				if isUnavailable then
					theFillColour := theFrame.backColor;
				endif;
				self.drawBlankSpace(theFrame, theFillColour,idx, startX, startY, endX, endY, true );
			endif;
		endif;
	endwhile;
epilog
	endLoad;

	if theFrame &lt;&gt; null then
		theFrame.drawFontName := "Arial";
		theFrame.drawFontSize := FONTSIZE * self.scaleFactor;
		theFrame.drawTextAlign := Frame.DrawTextAlign_Left;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_lc" type="CM_GridController"/>
        <Parameter name="_frame" type="YRD_ContainerOStowDrawingFrame"/>
    </JadeMethod>
    <JadeMethod name="drawLight" id="a2336a01-d8bd-4c49-a60b-a91a441cc416">
        <updating/>
        <source>drawLight() updating, protected;
// ---------------------------------------------------------------------------
// Created:		17 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	self.myDrawingFrame.drawFillColor := Yellow;
	self.myDrawingFrame.drawWidth := self.scaleFactor.Integer;
	self.myDrawingFrame.drawFilledRectangle(self.x1,self.y1,self.x2,self.y2,Blue);
epilog
	self.myDrawingFrame.drawWidth := 1;


end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="drawOverSizedMark" id="6ff77ae9-f5bd-4b1e-9562-9910416db878">
        <source>drawOverSizedMark(_frame: CMUI_GridAreaDrawingFrame; _theTI : CM_TrackedItem; _color: Integer;  _x1: Real; _y1: Real; _x2: Real; _y2: Real) protected;
// ---------------------------------------------------------------------------
// Created:		August 2006 By Andrew Bishop cnwab1
//
// Purpose:		was called Draw45 changed name
//
// ---------------------------------------------------------------------------
vars
	theFrame : CMUI_GridAreaDrawingFrame;
	lineY, thick : Integer;
begin
	if self.scaleFactor &lt; 3 then
		return;
	endif;
/* PAR 17067 WAS
	theFrame := self.myDrawingFrame;
	thick := 1;
	theFrame.drawStyle := Frame.DrawStyle_Solid;
	theFrame.drawWidth := 1;

	lineY := (_y2 - (self.scaleFactor + 1 )).Integer;
	theFrame.drawLine(_x1,lineY,_x2, lineY, _color.getInverseColour());
NOW */
	theFrame := _frame;
	thick := 1;
	theFrame.drawStyle := Frame.DrawStyle_Solid;
	theFrame.drawWidth := 1;
	lineY := (_y2 - 3).Integer;

	theFrame.drawLine(self.x1, lineY, self.x2, lineY,  _color.getInverseColour());
	
	if _theTI.isAttributeTrue(TI_Attrib_IsThirty) then
		return;
	endif;
	lineY := (_y2 - 6).Integer;
	
	theFrame.drawLine(self.x1,lineY, self.x2, lineY,  _color.getInverseColour());
	
	if _theTI.isAttributeTrue(TI_Attrib_IsFortyFive) then
		return;
	endif;
	lineY := (_y2 - 9).Integer;

	theFrame.drawLine(self.x1, lineY, self.x2, lineY,  _color.getInverseColour());
	
		
end;</source>
        <access>protected</access>
        <Parameter name="_frame" type="CMUI_GridAreaDrawingFrame"/>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_color" type="Integer"/>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_y2" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawReeferGantry" id="895cc641-6950-42a9-a5e9-d229f761989b">
        <source>drawReeferGantry(_frame : Frame input; x1, x2: Real);
// ---------------------------------------------------------------------------
// Created:		17 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
//	tmpWidth : Integer;
begin
//	tmpWidth := (self.scaleFactor *2).Integer;
//	_frame.drawWidth := tmpWidth;
//	_frame.drawLine(x1,self.y2 + tmpWidth,x2 ,self.y2 + tmpWidth, Red);
//	_frame.drawWidth := 1;
	_frame.drawFilledRectangle(x1, self.y1, x2, self.y2, Red);
epilog
	_frame.drawWidth := 1;
end;</source>
        <Parameter name="_frame" type="Frame" usage="input"/>
        <Parameter name="x1" type="Real"/>
        <Parameter name="x2" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawSelf" id="c8ac2a6f-ae8a-4387-9364-a6398137c47f">
        <updating/>
        <source>drawSelf(_clearSelected: Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     25 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/
constants
	TopTextMargin	: Integer = 10;
	LeftTextMargin	: Integer = 5;

	TopMargin		: Integer = 10;
	BottomMargin	: Integer = 10;
	LeftMargin		: Integer = 10;
	RightMargin		: Integer = 10;
	RowSpacing		: Integer = 10;
	ColumnSpacing	: Integer = 2;

	RowHeight		: Integer = 12;
	ColWidth		: Integer =12;

vars
	drawBayGap, bayStartX : Integer;
	tmpDrawingController	: YRD_ContainerDrawingController;
	maxX,
	maxY	: Integer;
	tmpRow	: CM_GridRow;
	tmpCol	: CM_GridColumn;
	tmpLC	: CM_GridController;
	tmpRTG,lastRTG : CM_RTGController;
	tmpGrid : CM_GridController;
	tmpBay : CM_RTGColumn;
	rowIdx,
	lblPos,
	colIdx	: Integer;
	theColWidth,
	xPos1, xPos2	: Real;	
	tmpCaption	: String;
	tmpFrame	: CMUI_Frame;	
	topLeftFiller : Frame;
	txtSize, theColumnWidth : Integer;
	drewGantry : Boolean;
	tmpWidth : Integer;
	dynaDict				: DynaDictionary;
	iterDyna : Iterator;
	
	lcs : CM_LCArray;
begin
		
	if self.scaleFactor &lt;= 0 then // PAR 33931
		self.scaleFactor := 3; // PAR 33931
	endif;

	if self.myGridOverviewForm = null then // PAR 19162
		self.drawSelfEndView(_clearSelected);  // PAR 19162// RUN Simon/Doug new version for new view in YRD_GridAreasForm
		return;
	endif;
	// ELSE RUN existing RTG BAY view
	
	self.drawFromNote := false;
	self.allTempTIs.clear;
	
	if self.allLCs.isEmpty then
		return;
	endif;
	
	drawBayGap := (self.scaleFactor *15).Integer;
	
	self.setFontSize();
	self.setFontSizeForAttribute();
	
	if _clearSelected then
		self.clearAllSelectedObjects();
	endif;

	if self.myGridOverviewForm &lt;&gt; null then
		useSelectorObjects := self.myGridOverviewForm.useSelector;
	endif;
	theColumnWidth := (ColWidth * self.scaleFactor).Integer;
	self.allGridObjects.clear;

	self.myDrawingFrame.clearGraphics();

	self.myVLabels.clearGraphics();
	self.myVLabels.width := YRD_ContainerDrawingController.LABEL_WIDTH;
	self.myVLabels.top := YRD_ContainerDrawingController.LABEL_WIDTH + 1;
	self.myVLabels.autoRedraw := true;
	
	self.myHLabels.clearGraphics();
	self.myHLabels.height := 40;
	self.myHLabels.autoRedraw := true;
	
	if self.scaleFactor &lt;= 2 then
		self.myHLabels.drawFontSize := 8;
	else
		self.myHLabels.drawFontSize := 12;
	endif;
	self.myHLabels.drawTextAlign := Frame.DrawTextAlign_Center;
	

	topLeftFiller := self.myDockBar.myScrollableFrame.myTopLeftFillerFrame;
	topLeftFiller.ignoreSkin := true;
	topLeftFiller.clearGraphics();
	topLeftFiller.autoRedraw := true;
	topLeftFiller.drawFontSize := 10; // ### PAR 10555
	topLeftFiller.drawTextAt("", 1, 8, Black); // ### PAR 10555
	topLeftFiller.visible := true;
	topLeftFiller.move(0,0,self.myDockBar.myScrollableFrame.myVLabels.clientWidth,self.myDockBar.myScrollableFrame.myHLabels.height);
	
	tmpDrawingController := self;
	tmpFrame := self.myDrawingFrame;
	tmpFrame.caption := null;
	theColWidth	 := ColWidth * self.scaleFactor;
	colIdx := 0;
	xPos1 := self.LABELGAP;
	self.y1 := TopMargin;
	bayStartX := xPos1.Integer;
	
	// PAR 15167 whole DYNADICT thing
	create dynaDict transient;	
	dynaDict.setMembership(CM_GridController);

	if self.flipHorizontal then
		if self.flipVertically then // flipped both ways
			dynaDict.addExternalKey(Integer, 8, true, true); // ROW
			dynaDict.addExternalKey(Integer, 8, true, true); // COL
		else
			dynaDict.addExternalKey(Integer, 8, true, true); // ROW
			dynaDict.addExternalKey(Integer, 8, false, true); // COL
		endif;
	else
		if self.flipVertically then // flipped Vertically Only
			dynaDict.addExternalKey(Integer, 8, false, true); // ROW
			dynaDict.addExternalKey(Integer, 8, true, true); // COL
		else // not flipped at all
			dynaDict.addExternalKey(Integer, 8, false, true); // ROW
			dynaDict.addExternalKey(Integer, 8, false, true); // COL
		endif;
	endif;
	dynaDict.endKeys(true);
	self.allLCs.copy(dynaDict);
	
	iterDyna := dynaDict.createIterator();

	while iterDyna.next(tmpLC) do
		if tmpLC.isKindOf(CM_RTGController) then
			tmpRTG := tmpLC.CM_RTGController;
		endif;
		
		tmpGrid := tmpLC.CM_GridController;
		self.y2 := (tmpGrid.getMaxHeight() * RowHeight  * self.scaleFactor).Integer;
		
		maxY := maxY.max(self.y2.Integer);
		
		self.y2 := self.y2 + self.y1;
		
		self.heightOfStack := self.heightOfStack.max(tmpGrid.getMaxHeight());

		if tmpLC.isKindOf(CM_RTGController) then
			if tmpBay &lt;&gt; null and tmpBay &lt;&gt; tmpRTG.myGridColumn then
	
				if lastRTG &lt;&gt; null and lastRTG.usage = REEFERGANTRY_USE then
					self.drawReeferGantry(tmpFrame, bayStartX, xPos2);
					drewGantry := true;
				endif;
				xPos2 := xPos2 + drawBayGap;
				bayStartX := xPos2.Integer;
	
			endif;
		else
			if tmpCol &lt;&gt; null and tmpCol &lt;&gt; tmpGrid.myGridColumn then // PAR 15168
				xPos2 := xPos2 + 20; // PAR 15168
			endif;
		endif;
		self.drawSelfLC(tmpGrid, xPos1,xPos2,colIdx);

		if tmpLC.isKindOf(CM_RTGController) then
			if drewGantry then
				drewGantry := false;
				tmpWidth := tmpRTG.myGridColumn.allControllersByRow.size * (theColumnWidth + ColumnSpacing);
				self.drawReeferGantry(tmpFrame, bayStartX, (bayStartX + tmpWidth));
			endif;
		endif;
		lblPos := (((xPos2 - xPos1) / 2) + xPos1).Integer;

		if tmpLC.isKindOf(CM_RTGController) then
			if  tmpBay &lt;&gt; tmpRTG.myGridColumn then
				self.myHLabels.drawTextAlign := Frame.DrawTextAlign_Left;
				self.myHLabels.drawTextAt(tmpRTG.getColumnLabel(false), lblPos,22,Black);
			endif;
		endif;
		self.myHLabels.drawTextAlign := Frame.DrawTextAlign_Center;
		if tmpLC.isKindOf(CM_RTGController) then
			self.myHLabels.drawTextAt(tmpGrid.myGridRow.getLabel(), lblPos,2,Black);
		else
			if self.scaleFactor &lt;= 2 then
				self.myHLabels.drawFontSize := 7;
				self.myHLabels.drawTextAt(tmpGrid.myGridRow.getLabel() &amp; tmpGrid.myGridColumn.getLabel(), lblPos,2,Black);
			else
				if self.scaleFactor = 3 then
					self.myHLabels.drawFontSize := 8;
					self.myHLabels.drawTextAt(tmpGrid.getFullId().removeString(" "), lblPos,2,Black);
				else
					if self.scaleFactor = 4 then
						self.myHLabels.drawFontSize := 10;
					elseif self.scaleFactor = 6 then
						self.myHLabels.drawFontSize := 14;
					elseif self.scaleFactor = 9 then
						self.myHLabels.drawFontSize := 18;
					endif;
					self.myHLabels.drawTextAt(tmpGrid.getFullId(), lblPos,2,Black);
				endif;
			endif;
		endif;
		tmpRow := tmpGrid.myGridRow;
		tmpCol := tmpGrid.myGridColumn;
		if tmpLC.isKindOf(CM_RTGController) then
			tmpBay:= tmpRTG.myGridColumn.CM_RTGColumn;
			lastRTG := tmpRTG;
		endif;
//	endforeach;
	endwhile;
	if lastRTG &lt;&gt; null then
		if lastRTG.usage = REEFERGANTRY_USE then
			self.drawReeferGantry(tmpFrame, bayStartX, xPos2);
		else
			tmpRTG := lastRTG.getPreviousControllerOfType(CM_RTGController).CM_RTGController;
			if tmpRTG &lt;&gt; null and tmpRTG.usage = REEFERGANTRY_USE then
				self.drawReeferGantry(tmpFrame, bayStartX, xPos2);
			endif;

		endif;
	endif;

	tmpFrame := self.myVLabels;
	
	xPos2 := xPos2 + theColWidth;
	maxX := (xPos2 + RightMargin - theColWidth).Integer ;
	maxY := (maxY + BottomMargin + BottomMargin).Integer;


	self.drawSubBlockStackLabels();
	self.myDockBar.resizeScrollingFrame(maxX, maxY);
	self.myDockBar.myScrollingFrame.left := self.LABEL_WIDTH + 1;
	self.myDockBar.myScrollingFrame.top := self.LABEL_WIDTH + 1;

	self.myDockBar.resetScrollValues();

epilog
	delete lcs;
	delete iterDyna;	// PAR #26678
	delete dynaDict;	// PAR #26678
end;</source>
        <Parameter name="_clearSelected" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="drawSelfColumn" id="d484149c-180c-4524-9681-95b56da4caec">
        <updating/>
        <source>drawSelfColumn(_col : CM_GridColumn; _xpos1 : Real io) updating;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
constants
	TopTextMargin	: Integer = 10;
	ColWidth		: Integer = 24;

vars
	tmpX, 
	theColWidth,
	xPos1, xPos2	: Real;	
	tmpCaption	: String;
	tmpFrame	: CMUI_Frame;	//YRD_ContainerDrawingFrame;
	gapWidth,gap : Integer;
begin


	tmpFrame := self.myHLabels;
	theColWidth	 := ColWidth * self.scaleFactor;

	if _col.hasGap then
		theColWidth := self.getGapDrawWidth(_col);
	endif;
	xPos1 := _xpos1;
	xPos2 := xPos1 + theColWidth;
	
	tmpCaption := _col.label;

	if tmpCaption[1:1] = "_" then
		tmpCaption := null;
	endif;
	
	if tmpCaption = null then
		//don't return without updating _xpos1  PAR 10662
		xPos1 := xPos1 + self.columnSpacing + theColWidth;
		_xpos1 := xPos1;
		return;
	endif;
	
	tmpX := (xPos1 + ((xPos2 - xPos1) / 2)) - ((tmpCaption.length * 7) / 2); // all this puts the label in the middle
	tmpFrame.drawTextAt(tmpCaption, tmpX + 1, TopTextMargin + 1, White);
	tmpFrame.drawTextAt(tmpCaption, tmpX, TopTextMargin, Black);
	xPos1 := xPos1 + self.columnSpacing + theColWidth;

	_xpos1 := xPos1;
end;</source>
        <Parameter name="_col" type="CM_GridColumn"/>
        <Parameter name="_xpos1" type="Real" usage="io"/>
    </JadeMethod>
    <JadeMethod name="drawSelfEndView" id="b14d1d9b-3bab-40e3-b642-6b526c90b701">
        <updating/>
        <source>drawSelfEndView(_clearSelected: Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     25 August 2004 by cnwrs2
//
// Purpose:      // PAR 19162
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks
29 May 2012 cnwer1	PAR 29588 - no access from front means the bottom, no access from back means the top
*/
constants
	RowSpacing		: Integer = 10;
	ColWidth		: Integer =12;
vars
	drawBayGap : Integer;
	maxX,
	maxY	: Integer;
	tmpTA	: CM_GridArea;
	tmpRow	: CM_GridRow;
	tmpCol	: CM_GridColumn;
	tmpLC	: CM_GridController;
	tmpRTG : CM_RTGController;
	tmpGrid : CM_GridController;
	tmpBay : CM_RTGColumn;
	lblPos,
	colIdx	: Integer;
	theColWidth,
	xPos1, xPos2	: Real;	
	tmpFrame	: CMUI_Frame;	
	topLeftFiller : Frame;
	dynaDict				: DynaDictionary;
	iterDyna : Iterator;
	firstONE : Boolean;
	yaHeight : Integer;
	tmpLbl : String;
	forkLiftStack : CM_ForkLiftStack;
begin

	self.drawFromNote := false;
	self.allTempTIs.clear;
	
	self.populateLCs();
	
	if self.allLCs.isEmpty then
		return;
	endif;
	
	drawBayGap := (self.scaleFactor *15).Integer;
	
	self.setFontSize();
	self.setFontSizeForAttribute();
	
	if _clearSelected then
		self.clearAllSelectedObjects();
	endif;

	if self.myYardGridAreaForm &lt;&gt; null then
		self.useSelectorObjects := self.myYardGridAreaForm.useSelector;
	elseif self.myGridOverviewForm &lt;&gt; null then
		self.useSelectorObjects := self.myGridOverviewForm.useSelector;
	endif;

	self.allGridObjects.clear;
	self.allYARows.clear;

	self.myDrawingFrame.clearGraphics();

	self.myVLabels.clearGraphics();
	self.myVLabels.width := YRD_ContainerDrawingController.LABEL_WIDTH;
	self.myVLabels.top := YRD_ContainerDrawingController.LABEL_WIDTH + 1;
	self.myVLabels.autoRedraw := true;
	
	self.myHLabels.clearGraphics();
	self.myHLabels.height := 40;
	self.myHLabels.autoRedraw := true;
	
	if self.scaleFactor &lt;= 1 then
		self.myHLabels.drawFontSize := 6;
	elseif self.scaleFactor &lt;= 2 then
		self.myHLabels.drawFontSize := 8;
	else
		self.myHLabels.drawFontSize := 12;
	endif;
	self.myHLabels.drawTextAlign := Frame.DrawTextAlign_Center;

	topLeftFiller := self.myDockBar.myScrollableFrame.myTopLeftFillerFrame;
	topLeftFiller.ignoreSkin := true;
	topLeftFiller.clearGraphics();
	topLeftFiller.autoRedraw := true;
	topLeftFiller.drawFontSize := 10; // ### PAR 10555
	topLeftFiller.drawTextAt("", 1, 8, Black); // ### PAR 10555
	tmpTA := self.myTerminalArea.CM_GridArea; //21/06/2011 cnwdz2 27732
	if tmpTA &lt;&gt; null then
		tmpLbl := tmpTA.getID();
		if tmpLbl.length &lt; 3 then
			topLeftFiller.drawFontSize := 16;
		elseif tmpLbl.length &lt; 6 then
			topLeftFiller.drawFontSize := 8;
		else
			topLeftFiller.drawFontSize := 6; 
		endif;
		topLeftFiller.drawTextAt(tmpLbl, 1, 8, Black);
	endif;
	topLeftFiller.visible := true;
	topLeftFiller.move(0,0,self.myDockBar.myScrollableFrame.myVLabels.clientWidth,self.myDockBar.myScrollableFrame.myHLabels.height);
	
	tmpFrame := self.myDrawingFrame;
	tmpFrame.caption := null;
	theColWidth	 := ColWidth * self.scaleFactor;
	colIdx := 0;
	xPos1 := self.LABELGAP;
	self.y1 := self.Margin;
	
	// PAR 15167 whole DYNADICT thing
	create dynaDict transient;	
	dynaDict.setMembership(CM_GridController);

	if self.flipVertically then
		if self.flipHorizontal then // flipped both ways
			dynaDict.addExternalKey(Integer, 8, true, true); // ROW
			dynaDict.addExternalKey(Integer, 8, true, true); // COL
		else
			dynaDict.addExternalKey(Integer, 8, true, true); // ROW
			dynaDict.addExternalKey(Integer, 8, false, true); // COL
		endif;
	else
		if self.flipHorizontal then // flipped Horizontal Only
			dynaDict.addExternalKey(Integer, 8, false, true); // ROW
			dynaDict.addExternalKey(Integer, 8, true, true); // COL
		else // not flipped at all
			dynaDict.addExternalKey(Integer, 8, false, true); // ROW
			dynaDict.addExternalKey(Integer, 8, false, true); // COL
		endif;
	endif;
	dynaDict.endKeys(true);
	self.allLCs.copy(dynaDict);
	
	iterDyna := dynaDict.createIterator();

	firstONE := true;

	//15/06/2011 cnwdz2 27732
	if tmpTA.isKindOf(CM_ForkLiftStack) then
		forkLiftStack := tmpTA.CM_ForkLiftStack;
	endif;
	
	while iterDyna.next(tmpLC) do
		if tmpLC.isKindOf(CM_RTGController) then
			tmpRTG := tmpLC.CM_RTGController;
		else
			tmpRTG := null;
		endif;
		
		tmpGrid := tmpLC.CM_GridController;
		
		if tmpGrid.isOverhang() then
			continue;
		endif;

		if tmpCol &lt;&gt; tmpGrid.myGridColumn then
			if tmpCol &lt;&gt; null then
				firstONE := false;
				yaHeight := self.drawYardAllocationLinesForRow( tmpCol, self.y2.Integer + 1, 0 );
				self.y1 := self.y2 + yaHeight + RowSpacing;
			endif;		
			
			//20/06/2011 cnwdz2 27732
			if tmpTA.isKindOf(CM_ForkLiftStack) or tmpTA.isKindOf(CM_StraddleStack) then
				//epr par 29588 changed from vertical to horizontal flip
				if self.flipHorizontal and tmpTA.bottomLabel &lt;&gt; null then					
					
					if ( self.flipVertically and tmpGrid.myGridColumn.column = tmpTA.allGridColumns.size) or
						(not self.flipVertically and tmpGrid.myGridColumn.column = 1) then
						self.myVLabels.drawTextRotation := 270;
						self.myVLabels.drawTextCharRotation := 270;
						self.myVLabels.drawTextAt(tmpTA.bottomLabel, 13, self.y1, Red);
						self.myVLabels.drawTextCharRotation := 0;
						self.myVLabels.drawTextRotation := 0;
					endif;
				endif;
				
				if not self.flipHorizontal and tmpTA.topLabel &lt;&gt; null then
					
					if ( not self.flipVertically and tmpGrid.myGridColumn.column = 1) or
					(  self.flipVertically and tmpGrid.myGridColumn.column = tmpTA.allGridColumns.size) then
						self.myVLabels.drawTextRotation := 270;
						self.myVLabels.drawTextCharRotation := 270;	
						self.myVLabels.drawTextAt(tmpTA.topLabel, 13, self.y1, Red);
						self.myVLabels.drawTextCharRotation := 0;
						self.myVLabels.drawTextRotation := 0;
					endif;
				endif;					
			endif;
			
			xPos2 := self.LABELGAP;	
			self.myVLabels.drawTextAt(tmpGrid.myGridColumn.label, 12,self.y1,Black);  //21/06/2011 cnwdz2 27732
		endif;
		
		self.y2 := self.y1 + (tmpGrid.getMaxHeight() * self.RowHeight  * self.scaleFactor).Integer;
		
		self.heightOfStack := self.heightOfStack.max(tmpGrid.getMaxHeight());

		if tmpRTG &lt;&gt; null then
			if tmpBay = tmpRTG.myGridColumn then
				if tmpRTG.usage = REEFERGANTRY_USE then
					self.drawReeferGantry(tmpFrame, xPos2, xPos2+self.columnSpacing);
				endif;
			else
				if xPos2 &lt;&gt; self.LABELGAP then
					xPos2 := xPos2 + drawBayGap;
				endif;
			endif;
		endif;

		tmpRow := tmpGrid.myGridRow;
		tmpCol := tmpGrid.myGridColumn;
		
		//17/10/2011 cnwdz2 28121
		if forkLiftStack &lt;&gt; null then
			if tmpRow.row = tmpTA.allGridRows.size and
				   not forkLiftStack.accessFront then	//	was accessBack	
					if self.flipHorizontal then
						self.drawForkLiftNoFrontAccess := true;
					else
						self.drawForkLiftNoBackAccess := true;
					endif;
			endif;				
			if tmpRow.row = 1 and 				   
			   not forkLiftStack.accessBack then //was accessFront
				if self.flipHorizontal then
					self.drawForkLiftNoBackAccess := true;
				else
					self.drawForkLiftNoFrontAccess := true;
				endif;
			endif;
		endif;
			
		self.drawSelfLC(tmpGrid, xPos1,xPos2,colIdx);

		//17/10/2011 cnwdz2 28121
		self.drawForkLiftNoFrontAccess := false;
		self.drawForkLiftNoBackAccess := false;
		
		if firstONE then
			lblPos := (((xPos2 - xPos1) / 2) + xPos1).Integer;
			self.myHLabels.drawTextAt(tmpGrid.myGridRow.getLabel(), lblPos, 22, Black);
		endif;

		if tmpRTG &lt;&gt; null then
			tmpBay:= tmpRTG.myGridColumn.CM_RTGColumn;
		endif;
	endwhile;

	yaHeight := self.drawYardAllocationLinesForRow( tmpCol, self.y2.Integer + 1, 0 );
	
	maxY := ( self.y2 + yaHeight + RowSpacing + self.Margin ).Integer;
	
	xPos2 := xPos2 + theColWidth;
	maxX := (xPos2 + self.Margin - theColWidth).Integer ;

	self.drawSubBlockStackLabels();
	self.myDockBar.resizeScrollingFrame(maxX, maxY);
	self.myDockBar.myScrollingFrame.left := self.LABEL_WIDTH + 1;
	self.myDockBar.myScrollingFrame.top := self.LABEL_WIDTH + 1;

	self.myDockBar.resetScrollValues();

epilog
	delete iterDyna; //epr par 18417 3/11/08
	delete dynaDict;		// PAR #26678
end;</source>
        <Parameter name="_clearSelected" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="drawSelfLC" id="507e236d-27b0-4553-a277-4949ce8958f7">
        <updating/>
        <source>drawSelfLC(_lc: CM_GridController; _xpos1,_xpos2 : Real io; _colIdx	: Integer io) updating;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
constants
	ColWidth		: Integer = 12;

vars
	theColWidth : Real;
	hasHeightRestriction, isUnavailable : Boolean;
	tmpUsage, tmpAvail : Integer;
	tmpLabourRestriction : CM_LabourRestriction;
	tmpBlockStack : CM_BlockStack;
begin
	theColWidth	 := ColWidth * self.scaleFactor;
	if _lc.myGridColumn.hasGap then
		theColWidth := self.getGapDrawWidth(_lc.myGridColumn);
	endif;
	_colIdx := _colIdx + 1;
	_xpos1 := _xpos2 + self.columnSpacing;
	_xpos2 := _xpos1 + theColWidth;

	self.x1 := _xpos1;
	self.x2 := _xpos2;

	tmpLabourRestriction 	:= _lc.allLabourRestrictions.first;
	tmpBlockStack			:= _lc.mySubBlockStack;

	if CM_StackController.hasInstance(_lc) then
		tmpUsage := _lc.CM_StackController.usage;
		tmpAvail := _lc.CM_StackController.availability;
		hasHeightRestriction := _lc.CM_StackController.hasHeightRestriction(self.heightOfStack);
		isUnavailable := (tmpUsage = UNAVAILABLE_USE or 
						 tmpAvail = PAD_USER_UNAVAILABLE or 
		   				 tmpAvail = PAD_UNAVAILABLE);

	elseif CM_RTGController.hasInstance(_lc) then
		tmpUsage := _lc.CM_RTGController.usage;
		tmpAvail := _lc.CM_RTGController.availability;
		hasHeightRestriction := _lc.CM_RTGController.hasHeightRestriction(self.heightOfStack);
		isUnavailable := (tmpUsage = UNAVAILABLE_USE or 
						 tmpAvail = PAD_USER_UNAVAILABLE or 
		   				 tmpAvail = PAD_UNAVAILABLE);

	endif;

	if tmpBlockStack &lt;&gt; null then
		self.drawSubBlockStack(tmpBlockStack);

	elseif tmpUsage = BUILDING_USE then // BUILDING
		self.drawTransformer();

	elseif tmpUsage = LIGHT_TOWER_USE then // LIGHT
		self.drawLight();
	else
		self.drawLC(_lc);
	endif;


end;</source>
        <Parameter name="_lc" type="CM_GridController"/>
        <Parameter name="_xpos1" type="Real" usage="io"/>
        <Parameter name="_xpos2" type="Real" usage="io"/>
        <Parameter name="_colIdx" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="drawSelfLCOverstow" id="393b311a-9cd7-4eff-b265-9039f352e588">
        <updating/>
        <source>drawSelfLCOverstow(_lc: CM_GridController; _xpos1, _xpos2 : Real io; _colIdx : Integer io; _frame : YRD_ContainerOStowDrawingFrame) updating;
// ---------------------------------------------------------------------------
// Created:		November 2009 By Pieter Bremmers cnwphb1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
constants
	ColWidth	: Integer = 24;
vars
	theColWidth : Real;
begin
	theColWidth	 := ColWidth * self.scaleFactor;
	if _lc.myGridColumn.hasGap then
		theColWidth := self.getGapDrawWidth(_lc.myGridColumn);
	endif;
	_colIdx := _colIdx + 1;
	_xpos1 := _xpos2 + self.columnSpacing;
	_xpos2 := _xpos1 + theColWidth;

	self.x1 := _xpos1;
	self.x2 := _xpos2;

	self.drawLCOverstow(_lc, _frame);
end;</source>
        <Parameter name="_lc" type="CM_GridController"/>
        <Parameter name="_xpos1" type="Real" usage="io"/>
        <Parameter name="_xpos2" type="Real" usage="io"/>
        <Parameter name="_colIdx" type="Integer" usage="io"/>
        <Parameter name="_frame" type="YRD_ContainerOStowDrawingFrame"/>
    </JadeMethod>
    <JadeMethod name="drawSelfOverstow" id="48b7509c-df6f-4ee7-b458-3da0729ce0fa">
        <updating/>
        <source>drawSelfOverstow(_frame : YRD_ContainerOStowDrawingFrame;
					_allLCs : CM_GridControllersByColumnRow;
					_useSelectedObjects : Boolean;
					_wdth, _hght : Real io) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 November 2009	cnwphb1	Initial creation

*/

constants
	TopMargin		: Integer = 15;
	LeftMargin		: Integer = 10;
	RowHeight		: Integer = 12;
vars
	tmpLC	: CM_GridController;
	tmpGrid	: CM_GridController;
	colIdx	: Integer;
	xPos1,
	xPos2	: Real;	
	iter	: Iterator;
begin
	if not self.allLCs.isEmpty then
		self.allLCs.clear;
	endif;
	
	if _allLCs.isEmpty then
		return;
	endif;
	
	_allLCs.copy(self.allLCs);
	self.scaleFactor := ScaleFactor_3;
	self.drawFromNote := false;
	self.allTempTIs.clear;
	
	self.setFontSize();
	self.setFontSizeForAttribute();
	
	self.useSelectorObjects := _useSelectedObjects;

	self.allGridObjects.clear;
	self.allYARows.clear;

	_frame.clearGraphics();

	colIdx := 0;
	xPos2 := LeftMargin;
	self.y1 := TopMargin;
	
	iter := self.allLCs.createIterator;

	while iter.next(tmpLC) do
		tmpGrid := tmpLC.CM_GridController;

		if tmpGrid.isGap() then
			continue;
		endif;
		if tmpGrid.isOverhang() then
			continue;
		endif;

		self.y2 := self.y1 + (tmpGrid.getMaxHeight() * RowHeight  * self.scaleFactor).Integer;
		self.heightOfStack := self.heightOfStack.max(tmpGrid.getMaxHeight());
		
		self.drawSelfLCOverstow(tmpGrid, xPos1, xPos2, colIdx, _frame);
	endwhile;
	
	_wdth := self.x2 + TopMargin;
	_hght := self.y2 + TopMargin;
epilog
	delete iter;
end;</source>
        <Parameter name="_frame" type="YRD_ContainerOStowDrawingFrame"/>
        <Parameter name="_allLCs" type="CM_GridControllersByColumnRow"/>
        <Parameter name="_useSelectedObjects" type="Boolean"/>
        <Parameter name="_wdth" type="Real" usage="io"/>
        <Parameter name="_hght" type="Real" usage="io"/>
    </JadeMethod>
    <JadeMethod name="drawSelfSW" id="226cc3fa-0528-4050-8500-8084bc549483">
        <updating/>
        <source>drawSelfSW(_clearSelected: Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     25 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/

constants
	TopTextMargin	: Integer = 10;
	LeftTextMargin	: Integer = 5;

	TopMargin		: Integer = 10;
	BottomMargin	: Integer = 10;
	LeftMargin		: Integer = 10;
	RightMargin		: Integer = 10;
	RowSpacing		: Integer = 10;

	RowHeight		: Integer = 12;
	ColWidth		: Integer =12;

vars
	drawBayGap : Integer;
	tmpDrawingController	: YRD_ContainerDrawingController;
	maxX,
	maxY	: Integer;
	tmpRow	: CM_GridRow;
	tmpCol	: CM_GridColumn;
	tmpLC	: CM_GridController;
	tmpRTG : CM_RTGController;
	tmpGrid : CM_GridController;
	tmpBay : CM_RTGColumn;
	rowIdx,
	lblPos,
	colIdx	: Integer;
	tmpX, tmpY,
	theColWidth,
	yPos1, yPos2,
	xPos1, xPos2	: Real;	
	tmpCaption	: String;
	tmpFrame	: CMUI_Frame;	
	topLeftFiller : Frame;
	txtSize, theColumnWidth : Integer;
	drewGantry : Boolean;
	tmpWidth : Integer;
	dynaDict				: DynaDictionary;
	iterDyna : Iterator;
	
	lcs : CM_LCArray;
	lc : CM_LocationsController;
	gcs : CM_GridControllersByRowColumn;
	firstONE : Boolean;
	yaHeight : Integer;
	tmpLbl : String;

begin

	self.drawFromNote := false;
	self.allTempTIs.clear;
	
	if self.myYardGridAreaForm &lt;&gt; null then
		self.populateLCs();
	endif;

	if self.allLCs.isEmpty then
		return;
	endif;
	
	drawBayGap := (self.scaleFactor *15).Integer;
	
	self.setFontSize();
	self.setFontSizeForAttribute();
	

	if _clearSelected then
		self.clearAllSelectedObjects();
	endif;

	if self.myGridOverviewForm &lt;&gt; null then
		useSelectorObjects := self.myGridOverviewForm.useSelector;
	elseif self.myYardGridAreaForm &lt;&gt; null then
		useSelectorObjects := self.myYardGridAreaForm.useSelector;
	endif;

	theColumnWidth := (ColWidth * self.scaleFactor).Integer;
	self.allGridObjects.clear;
	self.allYARows.clear;

	self.myDrawingFrame.clearGraphics();

	self.myVLabels.clearGraphics();
	self.myVLabels.width := YRD_ContainerDrawingController.LABEL_WIDTH;
	self.myVLabels.top := YRD_ContainerDrawingController.LABEL_WIDTH + 1;
	self.myVLabels.autoRedraw := true;
	
	self.myHLabels.clearGraphics();
	self.myHLabels.height := 40;
	self.myHLabels.autoRedraw := true;
	
	if self.scaleFactor &lt;= 1 then
		self.myHLabels.drawFontSize := 6;
	elseif self.scaleFactor &lt;= 2 then
		self.myHLabels.drawFontSize := 8;
	else
		self.myHLabels.drawFontSize := 12;
	endif;
	self.myHLabels.drawTextAlign := Frame.DrawTextAlign_Center;

	topLeftFiller := self.myDockBar.myScrollableFrame.myTopLeftFillerFrame;
	topLeftFiller.ignoreSkin := true;
	topLeftFiller.clearGraphics();
	topLeftFiller.autoRedraw := true;
	topLeftFiller.drawFontSize := 10; // ### PAR 10555
	topLeftFiller.drawTextAt("", 1, 8, Black); // ### PAR 10555
	if self.myTerminalArea &lt;&gt; null then
		tmpLbl := self.myTerminalArea.CM_GridArea.getID();
		if tmpLbl.length &lt; 3 then
			topLeftFiller.drawFontSize := 16;
		elseif tmpLbl.length &lt; 6 then
			topLeftFiller.drawFontSize := 8;
		else
			topLeftFiller.drawFontSize := 6; 
		endif;
		topLeftFiller.drawTextAt(tmpLbl, 1, 8, Black);
	endif;
	topLeftFiller.visible := true;
	topLeftFiller.move(0,0,self.myDockBar.myScrollableFrame.myVLabels.clientWidth,self.myDockBar.myScrollableFrame.myHLabels.height);
	
	tmpDrawingController := self;
	tmpFrame := self.myDrawingFrame;
	tmpFrame.caption := null;
	theColWidth	 := ColWidth * self.scaleFactor;
	colIdx := 0;
	xPos1 := self.LABELGAP;
	self.y1 := TopMargin;
	
	// PAR 15167 whole DYNADICT thing
	create dynaDict transient;	
	dynaDict.setMembership(CM_GridController);

	if self.flipVertically then
		if self.flipHorizontal then // flipped both ways
			dynaDict.addExternalKey(Integer, 8, true, true); // ROW
			dynaDict.addExternalKey(Integer, 8, true, true); // COL
		else
			dynaDict.addExternalKey(Integer, 8, true, true); // ROW
			dynaDict.addExternalKey(Integer, 8, false, true); // COL
		endif;
	else
		if self.flipHorizontal then // flipped Horizontal Only
			dynaDict.addExternalKey(Integer, 8, false, true); // ROW
			dynaDict.addExternalKey(Integer, 8, true, true); // COL
		else // not flipped at all
			dynaDict.addExternalKey(Integer, 8, false, true); // ROW
			dynaDict.addExternalKey(Integer, 8, false, true); // COL
		endif;
	endif;
	dynaDict.endKeys(true);
	self.allLCs.copy(dynaDict);
	
	iterDyna := dynaDict.createIterator();

	firstONE := true;

	while iterDyna.next(tmpLC) do
		if tmpLC.isKindOf(CM_RTGController) then
			tmpRTG := tmpLC.CM_RTGController;
		else
			tmpRTG := null;
		endif;
		
		tmpGrid := tmpLC.CM_GridController;

		if tmpGrid.isGap() then
			continue;
		endif;
		if tmpGrid.isOverhang() then
			continue;
		endif;

		if tmpCol &lt;&gt; tmpGrid.myGridColumn then
			if tmpCol &lt;&gt; null then
				firstONE := false;
				yaHeight := self.drawYardAllocationLinesForRow( tmpCol, self.y2.Integer + 1, 0 );
				self.y1 := self.y2 + yaHeight + RowSpacing;
			endif;
			xPos2 := self.LABELGAP;
			self.myVLabels.drawTextAt(tmpGrid.myGridColumn.label, 2,self.y1,Black);
		endif;
		
		self.y2 := self.y1 + (tmpGrid.getMaxHeight() * RowHeight  * self.scaleFactor).Integer;
		
		self.heightOfStack := self.heightOfStack.max(tmpGrid.getMaxHeight());

		if tmpRTG &lt;&gt; null then
			if tmpBay = tmpRTG.myGridColumn then
				if tmpRTG.usage = REEFERGANTRY_USE then
					self.drawReeferGantry(tmpFrame, xPos2, xPos2+self.columnSpacing);
				endif;
			else
				if xPos2 &lt;&gt; self.LABELGAP then
					xPos2 := xPos2 + drawBayGap;
				endif;
			endif;
		endif;

		self.drawSelfLC(tmpGrid, xPos1,xPos2,colIdx);

		if firstONE then
			lblPos := (((xPos2 - xPos1) / 2) + xPos1).Integer;
			/*if tmpRTG &lt;&gt; null and tmpBay &lt;&gt; tmpRTG.myRTGBay then
				self.myHLabels.drawTextAt(tmpRTG.myRTGBay.myRTGLane.getID(), lblPos, 2, Black);
			endif;*/
			self.myHLabels.drawTextAt(tmpGrid.myGridRow.getLabel(), lblPos, 22, Black);
		endif;

		tmpRow := tmpGrid.myGridRow;
		tmpCol := tmpGrid.myGridColumn;
		if tmpRTG &lt;&gt; null then
			tmpBay:= tmpRTG.myGridColumn.CM_RTGColumn;
		endif;
	endwhile;

	yaHeight := self.drawYardAllocationLinesForRow( tmpCol, self.y2.Integer + 1, 0 );
	
	maxY := ( self.y2 + yaHeight + RowSpacing + BottomMargin ).Integer;
	
	xPos2 := xPos2 + theColWidth;
	maxX := (xPos2 + RightMargin - theColWidth).Integer ;

	self.drawSubBlockStackLabels();
	self.myDockBar.resizeScrollingFrame(maxX, maxY);
	self.myDockBar.myScrollingFrame.left := self.LABEL_WIDTH + 1;
	self.myDockBar.myScrollingFrame.top := self.LABEL_WIDTH + 1;

	self.myDockBar.resetScrollValues();

epilog
	delete iterDyna; //epr par 18417 3/11/08
	delete lcs;
	delete dynaDict;		// PAR #26678
end;</source>
        <Parameter name="_clearSelected" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="drawSubBlockStack" id="092acf81-34a2-43a5-aaf8-29d47f0d3ebe">
        <source>drawSubBlockStack(_tmpBlockStack: CM_BlockStack) protected;
// ---------------------------------------------------------------------------
// Created:		17 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	self.myDrawingFrame.drawFillColor := _tmpBlockStack.myLayoutGraphic.drawLineColour;
	self.myDrawingFrame.drawWidth := self.scaleFactor.Integer;
	self.myDrawingFrame.drawFilledRectangle(self.x1,self.y1,self.x2,self.y2,Black);
epilog
	self.myDrawingFrame.drawWidth := 1;

end;</source>
        <access>protected</access>
        <Parameter name="_tmpBlockStack" type="CM_BlockStack"/>
