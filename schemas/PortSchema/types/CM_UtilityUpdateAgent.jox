    <JadeMethod name="utlUpdateInvoiceLineMove" id="3541a62f-ebbd-4aa1-8715-dc9080213c9c">
        <source>utlUpdateInvoiceLineMove(_controller : CMIF_InvoiceLineMove; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
15 Dec 2008	cnwkpd1	PAR #18652 - Change causeEvent inside trx to immediate false

*/

vars
	cancelSave:Boolean;
	realInvoice, oldInvoice:CM_Invoice;
	expectedEdition:Integer;
	anInvoiceLine : CM_InvoiceLine;
begin

	self.initialiseActivity();
	
	realInvoice := _controller.myInvoice;
	app.setContinueCMExceptions(true);

	
	if realInvoice = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_InvoiceLine.name &amp; " MOVE", null, null);
		return;
	endif;

	app.myValUA.valInvoiceLineMove(_controller);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;


	app.setContinueCMExceptions(false);

	exclusiveLock(realInvoice);

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realInvoice, true);
	endif;
	
	if _passport.noErrors then
		anInvoiceLine := _controller.allInvoiceLines.first;
		oldInvoice := anInvoiceLine.invoice;
		realInvoice.setForUpdateMoveLines(_controller);
	endif;
	
	// ### TFS CR 62992 TASK 62994 21MAR2024 NAVAB1
	if _passport.noErrors then
		realInvoice.setTaxDetailsFromLines();
		oldInvoice.setTaxDetailsFromLines();
		realInvoice.setTotalAmountFromLines(); // ### TFS CR 63369 TASK 63371 08APR2024 NAVAB1
		oldInvoice.setTotalAmountFromLines(); // ### TFS CR 63369 TASK 63371 08APR2024 NAVAB1
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realInvoice, false);
		realInvoice.causeEvent(_passport.myTerminal.getTerminalEvent(Event_InvoiceUpdate), false, realInvoice);		// PAR #18652
		oldInvoice.causeEvent(_passport.myTerminal.getTerminalEvent(Event_InvoiceUpdate), false, oldInvoice);
	endif;

epilog
	
	
end;</source>
        <Parameter name="_controller" type="CMIF_InvoiceLineMove"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateInvoiceLineNarr" id="512f0e15-4ee2-49db-91e0-9e89341cf5c0">
        <source>utlUpdateInvoiceLineNarr(_pxyInvoiceLineNarration: CM_InvoiceLineNarration; _passport: CM_Passport input);
/*

Purpose:			Updates an Invoice Line Narration

Parameters:			_pxyInvoiceLineNarration	CM_InvoiceLineNarration	The proxy object to use to update a real object from
					_passport					CM_Passport				The passport to use to hold errors and other information

Return Value:		NONE

Date		Who		Reason
01 September 2022	navpw1	Initial creation TFS: 54564 (54379)

*/

vars
	realInvoiceLineNarration	: CM_InvoiceLineNarration;
	expectedEdition				: Integer;
	
begin
	self.initialiseActivity();

	_pxyInvoiceLineNarration.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_pxyInvoiceLineNarration.pxyGetRealObjectAndEdition(realInvoiceLineNarration, expectedEdition);
	
	if realInvoiceLineNarration = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_InvoiceNote.name, null, null);
		return;
	endif;

	app.myValUA.valInvoiceLineNarr(realInvoiceLineNarration, _pxyInvoiceLineNarration);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realInvoiceLineNarration);

	if _passport.noErrors and realInvoiceLineNarration.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Gate Scan Record', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realInvoiceLineNarration, true);
	endif;
	
	if _passport.noErrors then
		realInvoiceLineNarration.setForUpdate(_pxyInvoiceLineNarration);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realInvoiceLineNarration, false);
	endif;
	
end;</source>
        <Parameter name="_pxyInvoiceLineNarration" type="CM_InvoiceLineNarration"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateInvoiceLineReeval" id="cadf3b2e-c241-4b41-a8c1-655304872800">
        <source>utlUpdateInvoiceLineReeval(_controller : CMIF_InvoiceLineReeval input; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		November 2005 By Andrew Bishop cnwab1
//
// Purpose:		this will be either REEVALUATE or RECALCULATE. The UI has 2 seperate Menu Options.
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
15 Dec 2008	cnwkpd1	PAR #18652 - Change causeEvent inside trx to immediate false
					CCMS 1271	May 2012 handle full escalating invoice lines (multiple lines from one open-ended quantity range) by
					processing only the first but reusing the rest as part of this process
12 Sep 2022 navpw1	TFS: 54564 (54374) - EUP - Inv Config - Debtor Currencies and Countries
// ### TFS CR 63369 TASK 63502 12APR2024 NAVAB1 - this will now be either REEVALUATE or RECALCULATE. The UI has 2 seperate Menu Options.
*/

vars
	realInvoice	: CM_Invoice;
	anInvoiceLine	: CM_InvoiceLine;
	invoiceLines	: ObjectArray;
	escalatingLines	: ObjectArray;
	obj				: Object;
	bu				: CM_Bank;
begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);

	if _controller.reEvaluate then // ### TFS CR 63369 TASK 63687 23APR2024 NAVAB1
		_controller.validateInvoiceLinesForMove();
	endif;
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;

	app.setContinueCMExceptions(false);

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realInvoice, true);
	endif;
	
	// ### TFS CR 63369 TASK 63502 12APR2024 NAVAB1
	
	if _passport.noErrors then
		create invoiceLines transient;
		create escalatingLines transient;
		foreach anInvoiceLine in _controller.allInvoiceLines do
			if anInvoiceLine.escalatingCount &gt; 1 then		// part of an escalating storage set, save separately - process the first such only
				escalatingLines.add(anInvoiceLine);
			else
				invoiceLines.add(anInvoiceLine);
			endif;
		endforeach;
		
		_controller.allInvoices.clear;
	
		foreach obj in invoiceLines do
			anInvoiceLine := obj.CM_InvoiceLine;
			realInvoice := anInvoiceLine.invoice;

			// OLD INVOICE
			if not _controller.allInvoices.includes(anInvoiceLine.invoice) then
				_controller.allInvoices.add(anInvoiceLine.invoice);
			endif;
		endforeach;
	endif;
	
	
	// ### TFS CR 63369 TASK 63502 12APR2024 NAVAB1
	
	
	if _controller.reEvaluate then // ### TFS CR 62992 TASK 62994 21MAR2024 NAVAB1
		if _passport.noErrors then
		/*### TFS CR 63369 TASK 63502 12APR2024 NAVAB1
			create invoiceLines transient;
			create escalatingLines transient;
			foreach anInvoiceLine in _controller.allInvoiceLines do
				if anInvoiceLine.escalatingCount &gt; 1 then		// part of an escalating storage set, save separately - process the first such only
					escalatingLines.add(anInvoiceLine);
				else
					invoiceLines.add(anInvoiceLine);
				endif;
			endforeach;
			
			_controller.allInvoices.clear;
			*/
			foreach obj in invoiceLines do
				anInvoiceLine := obj.CM_InvoiceLine;
				realInvoice := anInvoiceLine.invoice;
				exclusiveLock(realInvoice);
				exclusiveLock(anInvoiceLine);
				
				_controller.numEval := _controller.numEval + 1;

				// OLD INVOICE
				/* ### TFS CR 63369 TASK 63502 12APR2024 NAVAB1
				if not _controller.allInvoices.includes(anInvoiceLine.invoice) then
					_controller.allInvoices.add(anInvoiceLine.invoice);
				endif;
				*/
				if anInvoiceLine.reevaluate() then // &lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;
					_controller.allInvoiceLinesMoved.addNoDuplicates(anInvoiceLine, false);
					// NEW INVOICE
					if not _controller.allInvoices.includes(anInvoiceLine.invoice) then
						_controller.allInvoices.add(anInvoiceLine.invoice);
					endif;
					_controller.numMoved := _controller.numMoved + 1;
					anInvoiceLine.invoice.reevaluate(); // ### TFS 54564 (54374) 12SEP2022 NAVPW1
				else
					realInvoice.reevaluate(); 			// ### TFS 54564 (54374) 12SEP2022 NAVPW1
				endif;
				if anInvoiceLine.escalatingCount &gt; 0 then
					bu := anInvoiceLine.bank;
					if bu &lt;&gt; null then
						bu.createEscChargeLinesFromCT(anInvoiceLine, escalatingLines);
					endif;
				endif;
			endforeach;
			
			

		endif;
	endif;
	
	// ### TFS CR 62992 TASK 62994 27MAR2024 NAVAB1
	if _passport.noErrors then
		if _controller.reCalculate then
			// ### TFS CR 63369 TASK 63502 11APR2024 NAVAB1
			foreach realInvoice in _controller.allInvoices do
				realInvoice.setTaxDetailsToNull();
				realInvoice.setAmountDetailsToNull();
			endforeach;
			foreach anInvoiceLine in _controller.allInvoiceLines discreteLock do
				anInvoiceLine.setTaxDetails();
				anInvoiceLine.setTotalAmount(); // ### TFS CR 63369 TASK 63371 08APR2024 NAVAB1
				_controller.numCalced := _controller.numCalced + 1;
			endforeach;
			
		endif;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realInvoice, false);
		foreach realInvoice in _controller.allInvoices do
			realInvoice.causeEvent(_passport.myTerminal.getTerminalEvent(Event_InvoiceUpdate), false, realInvoice);		// PAR #18652
		endforeach;
		
		// ### TFS CR 63369 TASK 63502 11APR2024 NAVAB1 removed code \/ \/
	endif;

epilog
	delete invoiceLines;
	delete escalatingLines;

end;</source>
        <Parameter name="_controller" type="CMIF_InvoiceLineReeval" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateInvoiceLineRemarks" id="cf01da13-0ecc-461e-a03f-14cc295ac27d">
        <source>utlUpdateInvoiceLineRemarks(pProxyInvoiceLine : CM_InvoiceLine; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
15 Dec 2008	cnwkpd1	PAR #18652 - Change causeEvent inside trx to immediate false
05 May 2021	navdap1	TFS 51154 ASPA Manual Invoice Line Start Date
*/

vars
	cancelSave:Boolean;
	realInvoiceLine:CM_InvoiceLine;
	expectedEdition:Integer;
	
begin

	self.initialiseActivity();
	
	pProxyInvoiceLine.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	pProxyInvoiceLine.pxyGetRealObjectAndEdition(realInvoiceLine, expectedEdition);
	
	if realInvoiceLine = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_InvoiceLine.name, null, null);
		return;
	endif;

	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;


	app.setContinueCMExceptions(false);

	exclusiveLock(realInvoiceLine);

	if _passport.noErrors and realInvoiceLine.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'InvoiceLine', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realInvoiceLine, true);
	endif;
	if _passport.noErrors then
		realInvoiceLine.setForUpdateRemarks(pProxyInvoiceLine.remarks);
		realInvoiceLine.setExternalReferences(pProxyInvoiceLine.externalRef1, pProxyInvoiceLine.externalRef2, pProxyInvoiceLine.externalRef3, pProxyInvoiceLine.externalRef4); //08/12/2025	navkc1 JIRA 36262
		if realInvoiceLine.manual then
			if realInvoiceLine.quantity &lt;&gt; pProxyInvoiceLine.quantity then
				realInvoiceLine.setForUpdateQuantity(pProxyInvoiceLine.quantity);
			endif;
			if realInvoiceLine.trackedItem &lt;&gt; pProxyInvoiceLine.trackedItem then
				realInvoiceLine.setTrackedItem(pProxyInvoiceLine.trackedItem);
			endif;
			if realInvoiceLine.chargeTime &lt;&gt; pProxyInvoiceLine.chargeTime then		// TFS 51154
				realInvoiceLine.setChargeTime(pProxyInvoiceLine.chargeTime);		// TFS 51154
			endif;																	// TFS 51154
		endif;
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realInvoiceLine, false);
		realInvoiceLine.causeEvent(_passport.myTerminal.getTerminalEvent(Event_InvoiceLineUpdate), false, realInvoiceLine);	// PAR #18652
	endif;

epilog
	
	
end;</source>
        <Parameter name="pProxyInvoiceLine" type="CM_InvoiceLine"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateInvoiceLineStatus" id="2fd57464-ac00-4df8-953a-3ad705aaa927">
        <source>utlUpdateInvoiceLineStatus(pProxyInvoiceLine : CM_InvoiceLine;
							_status : CMIF_InvoiceStatus; 
							_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		TFS		Reason
====================================================================================
15 Dec 2008	cnwkpd1	18652	Change causeEvent inside trx to immediate false
22 Jul 2019	jlgdi1	45301	Added a call to CashPayment.getStatusFromInvoiceStatus()
====================================================================================
*/

vars
	realInvoiceLine	: CM_InvoiceLine;
	payment			: CM_CashPayment;
	expectedEdition	: Integer;
	newCashPaymentStatus : Integer;
	
begin
	self.initialiseActivity();
	
	pProxyInvoiceLine.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	pProxyInvoiceLine.pxyGetRealObjectAndEdition(realInvoiceLine, expectedEdition);
	
	if realInvoiceLine = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_InvoiceLine.name, null, null);
		return;
	endif;

	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;

	app.setContinueCMExceptions(false);

	exclusiveLock(realInvoiceLine);

	if _passport.noErrors and realInvoiceLine.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'InvoiceLine', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realInvoiceLine, true);
	endif;
	
	if _passport.noErrors then
		realInvoiceLine.setForUpdateStatus(_status);
		// 35232 update any cash payments to the same status
		foreach payment in realInvoiceLine.allCashPayments do
			app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(payment, true);				// 11/5/18 MAP TFS37718
			newCashPaymentStatus := payment.getStatusFromInvoiceStatus(_status.newStatus); // TFS 45301
			payment.setStatus(newCashPaymentStatus); // TFS 45301
			app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(payment, false);			// 11/5/18 MAP TFS37718
		endforeach;
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realInvoiceLine, false);
		realInvoiceLine.causeEvent(_passport.myTerminal.getTerminalEvent(Event_InvoiceLineUpdate), false, realInvoiceLine);	// PAR #18652
	endif;

epilog
	
	
end;</source>
        <Parameter name="pProxyInvoiceLine" type="CM_InvoiceLine"/>
        <Parameter name="_status" type="CMIF_InvoiceStatus"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateInvoiceMerge" id="e5e2bb05-09be-4bce-b336-4b8fb1067df2">
        <updating/>
        <source>utlUpdateInvoiceMerge(_controller : CMIF_InvoiceLineMerge input; _passport : CM_Passport input) updating;
/*
Purpose - 	
Who - NAVAB1
Date - 09JAN2024
ADO -  CR 58085 TASK 61343
*/

vars
	expectedEdition	: Integer;
	invoice : CM_Invoice;
begin

	self.initialiseActivity();
	
	// do any pre-validation locks
	
	// do validation
	self.raiseExceptionIfNull(_controller.myTargetInvoice, 'Target Merge Invoice');

	app.setContinueCMExceptions(true);
	
	app.myValUA.valInvoiceMerge(_controller);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	if _passport.noErrors then
		// This is only required if the class is being auditted
		self.myUpdateAuditAgent.audUpdateGeneric(_controller.myTargetInvoice, true);
	endif;

	if _passport.noErrors then
		// do updates
		_controller.myTargetInvoice.mergeLinesToInvoice(_controller);
	endif;

	// ### TFS CR 62992 TASK 62994 21MAR2024 NAVAB1
	if _passport.noErrors then
		_controller.myTargetInvoice.setTaxDetailsFromLines();
		_controller.myTargetInvoice.setTotalAmountFromLines(); // ### TFS CR 63369 TASK 63371 08APR2024 NAVAB1
		
		foreach invoice in _controller.allInvoices discreteLock do
			invoice.setTaxDetailsFromLines();
			invoice.setTotalAmountFromLines(); // ### TFS CR 63369 TASK 63371 08APR2024 NAVAB1
		endforeach;
	endif;

	if _passport.noErrors then
		// This is only required if the class is being auditted
		self.myUpdateAuditAgent.audUpdateGeneric(_controller.myTargetInvoice, false);
		
		
		_controller.myTargetInvoice.causeEvent(_passport.myTerminal.getTerminalEvent(Event_InvoiceUpdate), false, _controller.myTargetInvoice);
		foreach invoice in _controller.allInvoices discreteLock do
			invoice.causeEvent(_passport.myTerminal.getTerminalEvent(Event_InvoiceUpdate), false, invoice);
		
		endforeach;
	endif;

end;</source>
        <Parameter name="_controller" type="CMIF_InvoiceLineMerge" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateInvoiceNote" id="4adb74b7-fff6-4e07-842c-f4f37b11984a">
        <source>utlUpdateInvoiceNote(_pxyInvoiceNote: CM_InvoiceNote; _passport: CM_Passport input; _skipValidation : Boolean);
/*

Purpose:			Updates an Invoice Note from Proxy object passed in
					Also Creates an Audit for our object

Parameters:			_pxyInvoiceNote	CM_InvoiceNote	Proxy invoice note to update real object from
					_passport		CM_Passport		Passport to use for our Trx that holds errors and other useful data
					_skipValidation	Boolean			Whether we can skip validation

Return Value:		NONE

Date		Who		Reason
03 February 2022	navpw1	Initial creation TFS: 52752

*/

vars
	cancelSave		: Boolean;
	realInvoiceNote	: CM_InvoiceNote;
	expectedEdition	: Integer;
	
begin
	self.initialiseActivity();

	_pxyInvoiceNote.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_pxyInvoiceNote.pxyGetRealObjectAndEdition(realInvoiceNote, expectedEdition);
	
	if realInvoiceNote = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_InvoiceNote.name, null, null);
		return;
	endif;

	app.myValUA.valInvoiceNote(realInvoiceNote, _pxyInvoiceNote, _skipValidation);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realInvoiceNote);

	if _passport.noErrors and realInvoiceNote.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Invoice Note', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realInvoiceNote, true);
	endif;
	
	if _passport.noErrors then
		realInvoiceNote.setForUpdate(_pxyInvoiceNote);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realInvoiceNote, false);
		realInvoiceNote.myInvoice.causeEvent(_passport.myTerminal.getTerminalEvent(Event_InvoiceUpdate), false, realInvoiceNote.myInvoice);
	endif;

end;</source>
        <Parameter name="_pxyInvoiceNote" type="CM_InvoiceNote"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_skipValidation" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateInvoicePaymentStatus" id="893d4b47-dc10-493a-9a03-f8308fb285a0">
        <updating/>
        <source>utlUpdateInvoicePaymentStatus(_pxyInvoice : CM_Invoice; _paymentStatus : Integer;_passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25/06/2018  cnwma1	ChangeRequest 38635: PEL1 - SAP Cancellations

*/

vars
	realInvoice : CM_Invoice;
	expectedEdition:Integer;
	
begin

	self.initialiseActivity();
	
	_pxyInvoice.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_pxyInvoice.pxyGetRealObjectAndEdition(realInvoice, expectedEdition);
	
	if realInvoice = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_Invoice.name, null, null);
		return;
	endif;

	if (not self.checkValidationWithPassport(_passport)) then
		return;	
	endif;


	app.setContinueCMExceptions(false);

	exclusiveLock(realInvoice);

	if _passport.noErrors and realInvoice.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave,app.getErrorString(Invoice), null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realInvoice, true);
	endif;
	if _passport.noErrors then
		realInvoice.setPaymentStatus(_paymentStatus);
		endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realInvoice, false);
		realInvoice.causeEvent(realInvoice.myTerminal.getTerminalEvent(Event_InvoiceUpdate), false, realInvoice);	
	endif;

epilog
	
	
end;</source>
        <Parameter name="_pxyInvoice" type="CM_Invoice"/>
        <Parameter name="_paymentStatus" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateInvoiceProcDefault" id="8d087058-6b0b-4ee4-aa40-00594bc48aca">
        <source>utlUpdateInvoiceProcDefault(_passport : CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Oct 2018	jlgsl4	TFS 39618 - LNX - Initial creation
28 Nov 2022 navmv20 TFS CR 55298 TASK  55546 Jade - Write change TRX and unit test to create and update new colour attribute on CM_InvoiceStatus
*/

vars
	pxyProcess, realProcess, defaultProcess : CM_InvoiceProcess;
begin
	// create the default invoice process object
	if CM_InvoiceProcessDefault.instances.isEmpty then
		create pxyProcess as CM_InvoiceProcessDefault transient;
		pxyProcess.setProxy(InvoiceProcessDefault, "Master Terminal Default", PINEmail_InvProcDefOffset);
		app.myUtilityCA.utlCreateInvoiceProcess(pxyProcess, realProcess, app.myPassport);
		if not app.myPassport.noErrors then
			app.writeLog(method.qualifiedName &amp; " Failed to create CM_InvoiceProcessDefault!!!", LogINFO);
			return;
		endif;
		defaultProcess := realProcess;
	else
		defaultProcess := app.myRoot.allInvoiceProcesses[InvoiceProcessDefault];
	endif;
	
	// in case there's been a change in status priority, get everything in priority order out of the way
	// Add 10000 to all priorities
	//self.setupVoyageStatusMovePriority(defaultProcess);
	
	// now create / update all statuses
	// Start 28 Nov 2022 navmv20 TFS 55546
	/*self.setupInvoiceStatus(defaultProcess, CM_Invoice.INVOICE_OPEN,	1, 	app.getErrorString(Open_GC), PINEmail_InvProcDefOffset); // ### TFS 52184 20OCT2021 NAVAB1
	self.setupInvoiceStatus(defaultProcess, CM_Invoice.INVOICE_PENDING, 2, 	app.getErrorString(Pending), PINEmail_InvProcDefOffset); // ### TFS 52184 20OCT2021 NAVAB1
	self.setupInvoiceStatus(defaultProcess, CM_Invoice.INVOICE_POSTED, 3, 	app.getErrorString(Posted), PINEmail_InvProcDefOffset); // ### TFS 53534 29APR2022 NAVAB1
	self.setupInvoiceStatus(defaultProcess, CM_Invoice.INVOICE_POSTED_CREDIT, 	4, 	app.getErrorString(Posted_credit), PINEmail_InvProcDefOffset); // ### TFS 52184 20OCT2021 NAVAB1
	self.setupInvoiceStatus(defaultProcess, CM_Invoice.INVOICE_POSTED_REVERSE, 	5, 	app.getErrorString(Posted_returned), PINEmail_InvProcDefOffset); // ### TFS 52184 20OCT2021 NAVAB1
	self.setupInvoiceStatus(defaultProcess, CM_Invoice.INVOICE_VOID, 	6, 	app.getErrorString(Void), PINEmail_InvProcDefOffset); // ### TFS 52184 20OCT2021 NAVAB1
	self.setupInvoiceStatus(defaultProcess, CM_Invoice.INVOICE_SUSPENSE,7, 	app.getErrorString(Suspense), PINEmail_InvProcDefOffset); // ### TFS 52184 20OCT2021 NAVAB1*/

	self.setupInvoiceStatus(defaultProcess, CM_Invoice.INVOICE_OPEN,	1, 	app.getErrorString(Open_GC), White, PINEmail_InvProcDefOffset); 
	self.setupInvoiceStatus(defaultProcess, CM_Invoice.INVOICE_PENDING, 2, 	app.getErrorString(Pending),White, PINEmail_InvProcDefOffset); 
	self.setupInvoiceStatus(defaultProcess, CM_Invoice.INVOICE_POSTED, 3, 	app.getErrorString(Posted),White, PINEmail_InvProcDefOffset); 
	self.setupInvoiceStatus(defaultProcess, CM_Invoice.INVOICE_POSTED_CREDIT, 	4, 	app.getErrorString(Posted_credit),White, PINEmail_InvProcDefOffset); 
	self.setupInvoiceStatus(defaultProcess, CM_Invoice.INVOICE_POSTED_REVERSE, 	5, 	app.getErrorString(Posted_returned), White,PINEmail_InvProcDefOffset); 
	self.setupInvoiceStatus(defaultProcess, CM_Invoice.INVOICE_VOID, 	6, 	app.getErrorString(Void),White, PINEmail_InvProcDefOffset); 
	self.setupInvoiceStatus(defaultProcess, CM_Invoice.INVOICE_SUSPENSE,7, 	app.getErrorString(Suspense), White,PINEmail_InvProcDefOffset); 
	// End 28 Nov 2022 navmv20 TFS 55546
	// now check for any statuses left with priorities above 10000
	//self.setupVoyageStatusDelPriority(defaultProcess);
epilog

end;</source>
