<Class name="CMUI_BlockAreaDesignDrawer" id="652795e2-9947-4752-a601-6ebc0ed0815d">
    <superclass name="CMUI_BlockAreaDrawer"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="uicommon"/>
    <JadeMethod name="deselectAll" id="7e43f7ee-517b-4458-a169-4b002e9bfe6c">
        <updating/>
        <source>deselectAll() updating,protected;
// Deselect all selected cells and locations
vars
	obj : Object;
	gridCell : CMUI_BlockGridCell;
begin
	self.allSelectedObjects.clear; //epr par 35113 10/11/14
	self.deselectLocation(mySelectedLocation);
	
	foreach obj in self.myCells do
		gridCell := obj.CMUI_BlockGridCell;
		if gridCell.isSelected then
			self.deselectCell(gridCell.column, gridCell.row);
		endif;
	endforeach;
	

end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doClick" id="1ba1501f-5ce4-4906-a707-ba4801e31ff5">
        <updating/>
        <source>doClick(x : Real; y : Real; isShift, isCtrl : Boolean) updating;
// the grid has been clicked
vars
	cell : Point;
	location: CM_IrregularBlockController;
begin
	if self.mode = Mode_View then
		return;
	endif;
	
	if self.mode = Mode_Update then
		cell := pixelToCell(x, y);
		if isShift and self.topLeft &lt;&gt; null then
			if not self.hasOverlaps(self.topLeft, cell) then
				self.extendSelection(self.topLeft, self.bottomRight, cell);
			endif;
		else
			//epr par 35113 10/11/14
			if not isCtrl and not isShift then
				self.deselectAll();
			endif;
			location := self.getLocationForCell(cell);
			if location &lt;&gt; null then
				self.selectLocation(location);
				self.topLeft := location.topLeft;
			else
				selectCell(cell);
				self.topLeft := cell;
				self.bottomRight := null;
			endif;
			myTopFrame.locClick(myTopFrame, location);
		endif;
	endif;
end;
</source>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="isShift" type="Boolean"/>
        <Parameter name="isCtrl" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doMove" id="389c720c-68d0-4772-bd20-e26df9696f25">
        <updating/>
        <source>doMove(_xFrom, _yFrom, _xTo, _yTo : Real) updating;
// Move a region at (xFrom, yFrom) to (xTo, yTo)
vars
	location : CM_IrregularBlockController;
	cell, toTopLeft, toBottomRight : Point;
	locationWidth, locationHeight : Integer;
	region : PointArray;
begin
	if self.mode = Mode_View then
		return;
	endif;
	
	if self.mode = Mode_Update then
		cell := pixelToCell(_xFrom, _yFrom);
		location := self.getLocationForCell(cell);
		if location = self.mySelectedLocation then
			toTopLeft := pixelToCell(_xTo, _yTo);
			if self.isValidCell(toTopLeft) then
				locationWidth := location.bottomRight.x - location.topLeft.x;
				locationHeight := location.bottomRight.y - location.topLeft.y;
				toBottomRight := toTopLeft.add(locationWidth, locationHeight);
				if self.isValidCell(toBottomRight) and not hasOverlaps(toTopLeft, toBottomRight) then
					create region transient;
					region.add(toTopLeft);
					region.add(toBottomRight);
					self.deleteLocationFromCells(mySelectedLocation);
					mySelectedLocation.setProxyRegion(region);
					self.addLocationToCells(mySelectedLocation);
					self.selectLocation(mySelectedLocation);
					self.topLeft := toTopLeft;
					self.bottomRight := toBottomRight;
				endif;
			endif;
		endif;
	endif;
epilog
	delete region;
end;
</source>
        <Parameter name="_xFrom" type="Real"/>
        <Parameter name="_yFrom" type="Real"/>
        <Parameter name="_xTo" type="Real"/>
        <Parameter name="_yTo" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawLocation" id="197a43f5-1e49-469a-a5b2-51465aea8c8f">
        <source>drawLocation(location : CM_IrregularBlockController; _drawAll : Boolean) protected;
// draw the location 
vars
	topLeft, bottomRight: Point;
	colour : Integer;
	numberOfTrackedItems : Integer;
	x1, y1, x2, y2 : Integer;
begin
	topLeft := cellToPixel(location.region.first);
	bottomRight := cellToPixel(location.region.last.add(1, 1));
	
	if location = self.mySelectedLocation then
		colour := colourSelectedLocation;
	elseif self.allSelectedObjects.includes(location) then	//23 Aug 2013	NDL	Par 32036
		colour := colourSelectedForCopy;	
	else
		colour := colourLocation;
	endif;
	self.myDrawingFrame.drawWidth := 1;
	// Draw the rectangle inside the gridlines
	
	x1 := topLeft.x; // PAR 32308
	y1 := topLeft.y; // PAR 32308
	x2 :=  bottomRight.x-gridLineWidth; // PAR 32308
	y2 := bottomRight.y-gridLineWidth; // PAR 32308
	if _drawAll then
		self.allDrawnObjects.putAtKey(x1, y1, x2, y2, location );
	endif;
	
	self.myDrawingFrame.drawSolidRectangle(x1, y1, x2, y2 , colour);

	/*Date		      Who		Reason
	   18 June 2008	 cnwdz2	    Par16978 - Set the colour of the location text the inverse colour of whatever is underneath it	                                       
	*/
	self.drawLocationText(location, 0,colour.getInverseColour());
	
end;
</source>
        <access>protected</access>
        <Parameter name="location" type="CM_IrregularBlockController"/>
        <Parameter name="_drawAll" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="extendSelection" id="15292462-55d6-439c-8b49-9456b56a67a2">
        <updating/>
        <source>extendSelection(cellTopLeft, cellBottomRight, cellNewEnd : Point io) updating, protected;
// change the the current selection to end at cellNewEnd
// Also update the cellTopLeft and cellBottomRight params to reflect the new extended region
vars
	region : PointArray;
begin
	if not cellNewEnd.leftOf(cellTopLeft) and not cellNewEnd.above(cellTopLeft) then
		cellBottomRight := cellNewEnd;
		create region transient;
		region.add(cellTopLeft);
		region.add(cellBottomRight);
		if self.mySelectedLocation &lt;&gt; null then
			// extending the selected location
			self.deleteLocationFromCells(mySelectedLocation);
			mySelectedLocation.setProxyRegion(region);
			self.addLocationToCells(mySelectedLocation);
			self.selectLocation(mySelectedLocation);
		else
			// extending a region
			self.deselectAll();
			self.selectRegion(region, true);
		endif;
	endif;
epilog
	delete region;
end;
</source>
        <access>protected</access>
        <Parameter name="cellTopLeft" type="Point" usage="io"/>
        <Parameter name="cellBottomRight" type="Point" usage="io"/>
        <Parameter name="cellNewEnd" type="Point" usage="io"/>
    </JadeMethod>
    <JadeMethod name="handleMouseUp" id="3069c5bc-80f8-4514-9544-e126d132bc2c">
        <updating/>
        <source>handleMouseUp(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;
/*
Purpose:			 // PAR 32308
Date		Who		Reason
02 September 2013	cnwab1	Initial creation
*/

vars
	cell : Point;
	location: CM_IrregularBlockController;
begin

	
	// PAR 32844   return;
	
	if button &lt;&gt; Frame.MouseButton_Left then
		return;
	endif;
	
	cell := pixelToCell(x, y);
	location := self.getLocationForCell(cell);
	if location = null then
		self.deselectAll();
		self.drawLocations();
	else
		if shift.isControlKeyPressed() then
			self.selectLocation(location);
		elseif shift.isShiftKeyPressed() then
			self.selectLocationBlock(location);
			

			self.drawLocations();
		else
			self.deselectAll();
			self.drawLocations();
			self.selectLocation(location);
		
		endif;
	endif;

epilog

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="hasOverlaps" id="def2adcf-33f9-4180-8285-47db3e9c3fe2">
        <source>hasOverlaps(topLeft, bottomRight : Point) : Boolean protected;
// Return true if the rectangle described by topLeft cell and bottomRight cell overlaps any existing location
vars
	location : CM_LocationsController;
	locationTopLeft, locationBottomRight : Point;
begin
	foreach location in myTerminalArea.allLocationsControllers do
		if location &lt;&gt; self.mySelectedLocation then
			locationTopLeft := location.CM_IrregularBlockController.region.first();
			locationBottomRight := location.CM_IrregularBlockController.region.last();
			if self.intersectRect(locationTopLeft, locationBottomRight, topLeft, bottomRight) then
			   return true;
			endif;
		endif;
	endforeach;
	return false;
end;
</source>
        <access>protected</access>
        <Parameter name="topLeft" type="Point"/>
        <Parameter name="bottomRight" type="Point"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="intersectRect" id="c37fd3b8-0dff-432d-aec0-8ee4f369a8b0">
        <source>intersectRect(topLeftRect1, bottomRightRect1, topLeftRect2, bottomRightRect2 : Point) : Boolean protected;
// return true if there is an intersection between the two rectangles
begin
  return not (topLeftRect2.rightOf(bottomRightRect1) or
			  topLeftRect2.below(bottomRightRect1) or
			  bottomRightRect2.leftOf(topLeftRect1) or
			  bottomRightRect2.above(topLeftRect1));
end;
</source>
        <access>protected</access>
        <Parameter name="topLeftRect1" type="Point"/>
        <Parameter name="bottomRightRect1" type="Point"/>
        <Parameter name="topLeftRect2" type="Point"/>
        <Parameter name="bottomRightRect2" type="Point"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="selectLocation" id="0b2264a2-81ff-47f1-b895-26d9e67b100a">
        <updating/>
        <source>selectLocation(location: CM_IrregularBlockController) updating, protected;
// select the location on the area
begin
//	self.topLeft := null;
//	self.bottomRight := null;
//	mySelectedLocation := location;
//	self.drawLocation(location, false);

// ##############################


	inheritMethod(location);
	//epr par 35113 10/11/14
	if not self.allSelectedObjects.includes(location) then
		self.allSelectedObjects.add(location);
	endif;
	
	self.topLeft := null;
	self.bottomRight := null;
	mySelectedLocation := location;
	self.drawLocation(location, false);

end;
</source>
        <access>protected</access>
        <Parameter name="location" type="CM_IrregularBlockController"/>
    </JadeMethod>
</Class>
