    <JadeMethod name="getHtml" id="1d42d581-7e9d-4a9e-845d-3b282f969434">
        <source>getHtml(): String;
// --------------------------------------------------------------------------------
// Created:		02 December 2001 by cnwdad1
//
// Purpose:		Refer to the CnEcHtmlTagObject implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return '&lt;FORM' &amp; self.buildTagBody() &amp; '&lt;/FORM&gt;' &amp; CrLf;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
