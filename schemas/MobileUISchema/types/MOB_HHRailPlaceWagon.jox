        <source>placeWagonWithNoExistingPosi( _wagon : CM_Wagon io );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 August 2010	cnwndl1	Initial creation

*/

vars
	mess : String;
begin

	if _wagon &lt;&gt; null and _wagon.myRailLine = null and self.cmbRakePos.listIndex &gt; 0 and self.myMobileGenericAgent.inward then
		mess := app.getErrorString2(Want_place_wagon, _wagon.id,self.cmbRakePos.text);
		if self.msgBox(mess,app.getErrorString(SHP_Do_You_Want_To_Continue),MsgBox_Yes_No,false ) = MsgBox_Return_Yes then
			self.updateWagonRakePos( _wagon );
		endif;
	endif;
	
epilog

