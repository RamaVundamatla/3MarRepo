    <JadeMethod name="setForUpdate" id="41a17bc4-6ee7-4c31-914b-3a2b03bd37f1">
        <updating/>
        <source>setForUpdate(_pxyRTQueue : CM_VoyageCraneQueue; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
// 3 Apr 2013	cnwer1		PAR 31244
vars

begin

	inheritMethod(_pxyRTQueue,  _passport);
	
	self.crane := _pxyRTQueue.crane;
	//epr CCMS 1099 15/6/10
	self.dischargeMachinesMode:=_pxyRTQueue.dischargeMachinesMode;
	self.loadMachinesMode:=_pxyRTQueue.loadMachinesMode;
				
	if self.crane &lt;&gt; _pxyRTQueue.crane then
		self.crane := _pxyRTQueue.crane;
		if self.crane.myPrimaryQueue &lt;&gt; null then
			//-----------
			//Currently in a queue, release
			//-----------
			self.crane.myPrimaryQueue.releaseMachine(self.crane);
		endif;
		self.crane.addToQueue(self.myParentQueue, true, 0);
	endif;

end;</source>
        <Parameter name="_pxyRTQueue" type="CM_VoyageCraneQueue"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxyCrane" id="5765f1ff-0c15-4c8a-9a96-7df5f6d2457c">
        <updating/>
        <source>setProxyCrane(	_theID : String;
				_aCrane : CM_Crane; 
				_parentQueue : CM_RadioTelemetryQueue;
				_dischargeMachinesMode,
				_loadMachinesMode : Integer
				) updating;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
// 3 Apr 2013	cnwer1		PAR 31244
vars

begin
	self.id := _theID;
	self.crane := _aCrane;
	self.myParentQueue:=_parentQueue;
	self.dischargeMachinesMode:=_dischargeMachinesMode;
	self.loadMachinesMode:=_loadMachinesMode;



end;</source>
        <Parameter name="_theID" type="String"/>
        <Parameter name="_aCrane" type="CM_Crane"/>
        <Parameter name="_parentQueue" type="CM_RadioTelemetryQueue"/>
        <Parameter name="_dischargeMachinesMode" type="Integer"/>
        <Parameter name="_loadMachinesMode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validateUpdate" id="b27bbec5-4fdb-4133-9b90-3fb32acc1ae5">
        <source>validateUpdate(_passport: CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 August 2011	cnwer1	Initial creation CCMS MES 1033
// 3 Apr 2013	cnwer1		PAR 31244
*/

vars
	cq : CM_VoyageCraneQueue;
	realSelf : CM_VoyageCraneQueue;
begin

	inheritMethod(_passport);
	
	if self.crane = null then
	//	app.raiseCMException1(REQUIRED_FIELD,"crane",null,null);
		app.raiseCMException(Input_required_field_crane,null,null); // cnwdb2	PAR 35364
		return;
	endif;
	
	 // PAR 20474
	realSelf:=self.pxyGetRealObject;
	foreach cq in crane.allCraneQueues discreteLock do
		if cq.myParentQueue =  self.myParentQueue and cq &lt;&gt; realSelf then
			app.raiseCMException2(Voyage_queue_alread_crane_queu, self.myParentQueue.id, self.crane.code, null, self);
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
