    <JadeMethod name="create" id="8971fa8d-74dc-4741-a478-c5c280b57a93">
        <updating/>
        <source>create() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
17 December 2008	consw1	Initial creation

*/

vars

begin
	self.resetValues();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="605d07b1-fcfb-485d-9c58-e4850483fe61">
        <updating/>
        <source>delete() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
17 December 2008	consw1	Initial creation

*/

vars

begin
	self.allSearchCriteria.purge();
	self.allSearchCriteriaResolved.purge();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getStatusDisplay" id="71194f63-132a-43e6-b0b5-d0ecf6081d19">
        <source>getStatusDisplay() : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
17 December 2008	consw1	Initial creation

*/

vars

begin
	if self.includeActive and self.includeDisabled then
		return self.includeActiveDisplay &amp; " + " &amp; self.includeDisabledDisplay;
	endif;

	if self.includeDisabled then
		return self.includeDisabledDisplay;
	endif;

	return self.includeActiveDisplay;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="hasDefaultValues" id="b97f687b-fcd9-4823-bb85-a4128114a85f">
        <source>hasDefaultValues() : Boolean;

/*

Purpose:		

Parameters:			

Return Value:		


Date				Who		Reason
17 December 2008	consw1	Initial creation

*/

vars

begin
	if self.includeDisabled then
		return false;
	endif;

	return self.allSearchCriteria.isEmpty and self.includeActive;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isMatchingYA" id="7c9f06f5-a490-403d-b654-2d291ecc42e0">
        <source>isMatchingYA( _ya : CM_YardAllocation ) : Boolean;

/*

Purpose:			Returns true when given Yard Allocation matches search parameters

Parameters:			

Return Value:		


Date				Who		Reason
18 December 2008	consw1	Initial creation

*/

vars

begin
	if _ya.isDisabled then
		if not self.includeDisabled then
			return false;
		endif;
	else
		if not self.includeActive then
			return false;
		endif;
	endif;
	
	return _ya.isCriteriaIncluded( self.allSearchCriteriaResolved );
	
epilog

end;</source>
        <Parameter name="_ya" type="CM_YardAllocation"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="resetValues" id="5ec33076-886c-46bc-9193-68e03fdab212">
        <updating/>
        <source>resetValues() updating;

/*

Purpose:			Set default values

Parameters:			

Return Value:		


Date				Who		Reason
17 December 2008	consw1	Initial creation

*/

vars

begin
	self.allSearchCriteria.purge();
	self.allSearchCriteriaResolved.purge();

	self.includeActive := true;
	self.includeDisabled := false;
	self.searchPriorityValueReal := 0;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="search" id="1db81293-53ea-4a4b-aff2-ee36b21107e0">
        <source>search(_yaTemplatesFound: CM_YATemplateDict input; _yaTemplates: CM_YATemplateDict);
//30 January 2009	cnwdw1	
//
vars
	criteriaTypeObj			: CM_YACriteriaType;
	searchPriorityValue		: Integer;
	searchPriorityBitAnd	: Integer;
	selectAll				: Boolean;
	template				: CM_YATemplate;
	yardAllocation			: CM_YardAllocation;
begin

	if self.searchPriorityValueReal &lt; Max_Integer then
		searchPriorityValue := self.searchPriorityValueReal.Integer;
	endif;	
	
	foreach template in _yaTemplates do
		yardAllocation := template.myYardAllocation;
// Have excluded as priority value not currently calculated for templates
//		if searchPriorityValue &lt;&gt; 0 and yardAllocation.priorityValue &lt; Max_Integer then
//			searchPriorityBitAnd := searchPriorityValue.bitAnd( yardAllocation.priorityValue.Integer );
//			if searchPriorityBitAnd &lt;&gt; searchPriorityValue then
//				continue;
//			endif;
//		endif;
		if self.isMatchingYA(yardAllocation) then
			_yaTemplatesFound.add(template);
		endif;
	endforeach;
end;</source>
        <Parameter name="_yaTemplatesFound" type="CM_YATemplateDict" usage="input"/>
        <Parameter name="_yaTemplates" type="CM_YATemplateDict"/>
    </JadeMethod>
</Class>
