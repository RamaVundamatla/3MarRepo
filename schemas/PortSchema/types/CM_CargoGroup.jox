    <JadeMethod name="getMyCargoGroupAssignment" id="cd6f4835-ac68-40d1-a03b-a414a50dbd0e">
        <source>getMyCargoGroupAssignment():CM_CargoGroupAssignment;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 October 2018	jlgndl1	Initial creation	TFS 39186

*/

vars

	ncg : CM_NotifiedCargoGroup;
	edition : Integer;
	invalid : Boolean;

begin

	if self.myCargoGroupAssignment &lt;&gt; null then
		return self.myCargoGroupAssignment;
		
	else
		ncg := self.getMyNotifiedGroup;
		if ncg &lt;&gt; null then
			if ncg.myCargoGroupAssignment &lt;&gt; null then
				on Exception do app.handleDeletedObject( exception, ncg.myCargoGroupAssignment, invalid );
				edition := ncg.myCargoGroupAssignment.edition;
				if not invalid then
					return ncg.myCargoGroupAssignment;
				endif;
			endif;
		endif;
		
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="CM_CargoGroupAssignment"/>
    </JadeMethod>
    <JadeMethod name="getMyCargoGroupAssignmentId" id="4b62ecd7-8938-42e6-a603-618185c7fb40">
