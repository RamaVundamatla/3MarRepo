<Class name="CMQF_WeighSummary" id="4b637d73-df0b-4e22-972e-1345f51d9b85">
    <superclass name="CMQF_Transactions"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="filterObjects" id="86ac5304-74c9-4d26-a0bd-e16df2ccee64">
        <updating/>
        <source>filterObjects(_collection  : Collection input; _passport : CM_Passport) updating;
// ---------------------------------------------------------------------------
// Created:		07 February 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	tempCollection	: Collection;
	str				: String;
	tranType		: Integer;
	terminal		: CM_Terminal;
	endDateTime		: TimeStamp;
begin
	endDateTime.setTime("23:59:59".Time);
	endDateTime.setDate(self.endDate);

	create tempCollection as _collection.class transient;

	foreach terminal in self.allTerminals do
		terminal.getTITxnsForTypeAll(TRANS_TYPE_RELEASE, self.startDate.TimeStamp, endDateTime,
											 'checkStatusIncludesObject', self, tempCollection);
		endLoad;
		tempCollection.copy(_collection);
	endforeach;
	

epilog
	endLoad;
	delete tempCollection;
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="bee456e5-ece1-4218-a098-7054db2e9532">
        <updating/>
        <source>includesObject(_trx: CM_TITransaction; _passport : CM_Passport; _breakOut : Boolean output): Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:		07 February 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
vars
	ti					: CM_TrackedItem;
	querySelf			: CMQF_Transactions;
	failedDAC  :CM_DataAccessController;
begin
	querySelf := self;
	querySelf.numSearched := querySelf.numSearched + 1;

	ti := _trx.myTrackedItem;
	if ti = null
	or ti.cargoType = TI_CargoType_BreakBulk
	or ti.cargoType = TI_CargoType_LCL
	or ti.isChild then
		return false;
	endif;
	
	if _trx.deleted and self.ignoreDeleted then
		return false;
	endif;

	if self.myOperator = null or (self.myOperator.code = _trx.operatorCode) then
		if ti.canUserAccessSelf(null, failedDAC, _passport) then
			querySelf.numFound := querySelf.numFound + 1;
			return true;
		endif;
	endif;
	
	return false;
end;</source>
        <access>protected</access>
        <Parameter name="_trx" type="CM_TITransaction"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
