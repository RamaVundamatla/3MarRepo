    <JadeMethod name="adjustPointsForRoRoLanes" id="5f762382-ca03-4910-90ad-616f0e7e70cc">
        <source>adjustPointsForRoRoLanes( _topLeftLC, _bottomRightLC : CM_RoRoController; _x1, _y1, _x2, _y2 : Integer io) protected;

/*

Purpose:			
	When selecting YA rectangles by entering text, the code is designed to work with gridded terminal areas, by calculating
	the extents of the rectangle based on top-left and bottom-right location controllers.  When working with RoRo Lane areas,
	_topLeftLC represents the from row and _bottomRightLC represents the to row.  this causes problems when lanes are like this:
	
	    RORO1
	01  ========
	02  ============
	03  ===
	
	For the above area, given the location text RORO1 01-03, the extent of the rectangle would have been calculated as x1, y1 being the 
	top-left co-ordinates of lane 01, which is ok, but x2,y2 would have been calculated as being the bottom-right co-ordinates of
	lane 03.  This is incorrect, as the rectangle will not cover the whole of lane 01, or 02.
	
	This method adjusts the rectangle so that it does cover all lanes in the range.
	
	NOTE: We can't just call snapRectPointsToRoRoLanes(), as if we passed in the rectanghle points as gathered by updateYALocation(), there is a chance that 
	it will not encompass all lanes, depending on their lengths and start offsets.
	
Parameters:			

Return Value:		


Date		Who		Reason
26 January 2010	cnwjk3	Initial creation

*/

vars
	roroArea 	: CM_RoRoLaneArea;
	rc			: CM_RoRoController;
	point1,
	point2		: Point;
	dc			: YRD_ContainerDrawingController;
	idx,
	laneNumFrom,
	laneNumTo,
	minX, maxX,
	minY, maxY	: Integer;
begin
	dc := self.getDrawingController();
	
	roroArea := _topLeftLC.myRoRoLaneArea;
	if _topLeftLC.laneNumber &lt;  _bottomRightLC.laneNumber then
		laneNumFrom := _topLeftLC.laneNumber;
		laneNumTo := _bottomRightLC.laneNumber;
	else
		laneNumFrom := _bottomRightLC.laneNumber;
		laneNumTo := _topLeftLC.laneNumber;
	endif;
	foreach idx in  laneNumFrom to laneNumTo do
		rc := roroArea.allLanesByLaneNumber[idx];
		dc.allGridObjects.findObjectInDictGetXY(rc, point1, point2);
		
		// find minimum x pos
		if minX = 0 or point1.x &lt; minX then
			minX := point1.x;
		endif;
		// find maximum x pos		
		if point2.x &gt; maxX then
			maxX := point2.x;
		endif;		
		// find minimum y pos
		if minY = 0 or point1.y &lt; minY then
			minY := point1.y;
		endif;
		// find maximum y pos
		if point2.y &gt; maxY then
			maxY := point2.y;
		endif;
	endforeach;
	
	_x1 := minX;
	_y1 := minY;
	_x2 := maxX;
	_y2 := maxY;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_topLeftLC" type="CM_RoRoController"/>
        <Parameter name="_bottomRightLC" type="CM_RoRoController"/>
        <Parameter name="_x1" type="Integer" usage="io"/>
        <Parameter name="_y1" type="Integer" usage="io"/>
        <Parameter name="_x2" type="Integer" usage="io"/>
        <Parameter name="_y2" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="allocateAndDrawRectFrame" id="be340fa3-92de-4e98-ba68-7667197e3c8e">
        <updating/>
        <source>allocateAndDrawRectFrame(_x1, _y1, _x2, _y2 : Integer; _ya : CM_YardAllocation) : CMUI_ResizableRectFrame updating;
/*
Purpose:			

Date		Who		Reason
04/02/2009	cnwjk3	SFW1030
17/11/2011	cnwdap1	PAR #28514 Set 'changed' attribute on rect because we've just changed it
*/
vars
	frmToClone,
	rect 		: CMUI_ResizableRectFrame;
	recycled	: Boolean;
begin
	foreach rect in self.allRectFrames do
		if not rect.visible then
			// We'll nab this one
			recycled := true;
			break;
		endif;
	endforeach;

	if not recycled then 
		frmToClone := self.getForm().YRD_SatelliteViewForm.frmResizableRect;
		rect := frmToClone.loadControl(self.allRectFrames.size+1).CMUI_ResizableRectFrame;
	endif;

	if rect &lt;&gt; null then
		rect.init();
		rect.parent := self;
		rect.left := _x1;
		rect.width := _x2 -_x1;
		rect.top := _y1;
		rect.height := _y1-_y2;
		rect.setOrig();
		rect.colour := _ya.color;
		rect.backColor := _ya.color;
		
		rect.drawFillStyle := Frame.DrawFillStyle_DiagonalCross; //cnwrd1 par 28447 20.10.2011

		rect.setChanged(true);									// PAR #28514
		rect.visible := true;
		rect.lockRect(_ya &lt;&gt; self.myCurrentEditYardAllocation);
		if not recycled then
			self.allRectFrames.add(rect);
		endif;
	endif;
	return rect;
epilog
	self.drawFillStyle := Frame.DrawFillStyle_Transparent;
end;</source>
        <Parameter name="_x1" type="Integer"/>
        <Parameter name="_y1" type="Integer"/>
        <Parameter name="_x2" type="Integer"/>
        <Parameter name="_y2" type="Integer"/>
        <Parameter name="_ya" type="CM_YardAllocation"/>
        <ReturnType type="CMUI_ResizableRectFrame"/>
    </JadeMethod>
    <JadeMethod name="checkRectOverlap" id="1418623b-64d9-4a64-865e-9929adfdd9de">
        <source>checkRectOverlap( _rect: CMUI_ResizableRectFrame; _x1, _y1, _x2, _y2 : Integer ) : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 January 2009	cnwjk3	SFW1030

*/

vars
	x1, y1, x2, y2 	: Integer;
	theRect			: CMUI_ResizableRectFrame;
begin
	foreach theRect in self.allRectFrames do
		if theRect.visible and theRect &lt;&gt; _rect and not theRect.isLocked() then   // CCMS CPL 2052
			theRect.getIntPoints(x1, y1, x2, y2);
			if _x1+2 &gt; x2 then 
				continue;
			endif;
			if _x2-2 &lt; x1 then
				continue;
			endif;
			if _y1+2 &gt; y2 then
				continue;
			endif;
			if _y2-2 &lt; y1 then
				continue;
			endif;
			return true;
		endif;
	endforeach;
	return false;
epilog

end;</source>
        <Parameter name="_rect" type="CMUI_ResizableRectFrame"/>
        <Parameter name="_x1" type="Integer"/>
        <Parameter name="_y1" type="Integer"/>
        <Parameter name="_x2" type="Integer"/>
        <Parameter name="_y2" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkRectOverlapOLD" id="c76fb5ea-0e3d-4dbc-9e2f-04a37ed1e126">
        <source>checkRectOverlapOLD( _x1, _y1, _x2, _y2 : Integer ) : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 January 2009	cnwjk3	SFW1030

*/

vars
	x1, y1, x2, y2 	: Integer;
	index 			: Integer;
	p				: Point;
begin
	index := 0;
	foreach p in self.allPoints do
		index := index + 1;
		if index mod 2 = 0 then
			x2 := p.x;
			y2 := p.y;
			if _x1+2 &gt; x2 then 
				continue;
			endif;
			if _x2-2 &lt; x1 then
				continue;
			endif;
			if _y1+2 &gt; y2 then
				continue;
			endif;
			if _y2-2 &lt; y1 then
				continue;
			endif;
			return true;
		else
			x1 := p.x;
			y1 := p.y;
		endif;
	endforeach;
	return false;
epilog

end;</source>
        <Parameter name="_x1" type="Integer"/>
        <Parameter name="_y1" type="Integer"/>
        <Parameter name="_x2" type="Integer"/>
        <Parameter name="_y2" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="clearSelectedRectFrame" id="1c144f97-7052-4b38-ad08-7322eb065066">
        <source>clearSelectedRectFrame();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 February 2009	cnwjk3	Initial creation

*/

vars
	rect,
	frmToClone : CMUI_ResizableRectFrame;
	i	: Integer;
begin
	// Get hold of the form control to clone
	frmToClone := self.getForm().YRD_SatelliteViewForm.frmResizableRect;
	
	// TODO Class needs to hold the number of clones made 
	foreach i in 1 to 100 do
		rect :=  frmToClone.getControl(i);
		if rect = null then
			break;
		else
			rect.isSelected := false;
			rect.refresh();
		endif;	
	endforeach;	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="clearYALocationText" id="168b3643-4523-4438-9b34-2195d0df5e62">
        <source>clearYALocationText();

/*

