    <JadeMethod name="removeTIs" id="429d03a8-c509-4d77-a732-aeac70bf13bb">
        <source>removeTIs();
//07 September 2009	cnwml2
// 24 Jul 2025 	navhn30 	MTN-35315: MTN | Pagination - Work Order Maintenance

vars
	allSelectedItems : CM_TIArray;
	ti : CM_TrackedItem;
	iter : Iterator;
	idx : Integer;
begin
	create allSelectedItems transient;
	
	self.tblSelectedItems.allSelectedObjects.copy(allSelectedItems);
	if allSelectedItems.size = 0  then
		app.msgBox(app.getErrorString2(CMUI_Please_Select, "cargo item(s)", "remove"),app.getErrorString(NOTHING_SELECTED), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	foreach ti in allSelectedItems do
		self.allSelectedTrackedItems.remove(ti);
		self.tblResults.updateItemObject(ti, self.colorRow1, self.colorRow2, app.myPassport);
	endforeach;
	
	iter := self.allSelectedTrackedItems.createIterator(); //cnwrd par 23124 15.3.2010 - moved up
	self.tblSelectedItems.clearAllData();					//cnwrd par 23124 15.3.2010 - moved up
	
	self.tblSelectedItems.getDataAndDisplayRowsPaginat(Table.DisplayCollection_Forward, null,self.allSelectedTrackedItems, true); //24.07.2025	navhn30  MTN-35315

/*	while iter.next(ti) do	//24.07.2025	navhn30  MTN-35315
		//idx := self.tblSelectedItems.updateItemObject(ti, self.colorRow1, self.colorRow2, app.myPassport);
		self.tblSelectedItems.updateItemObject(ti, self.colorRow1, self.colorRow2, app.myPassport);	//24.07.2025	navhn30  MTN-35315
		//self.tblSelectedItems.accessRow(idx).itemObject := ti;
		self.tblResults.removeItemObject(ti);
	endwhile;*/
	
epilog
	delete allSelectedItems;
	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="setBolfromWO" id="fcbce791-f107-4584-9fb8-6f85e90594c1">
        <updating/>
        <source>setBolfromWO(_voyage : CM_Voyage; _bol : CM_BOL)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Apr 2023	navhl20	ChangeRequest 55443:[54991] EUP - Receive Cargo Work Order - Enhancements
27 Jun 2023	navlw1	ChangeRequest 58730: EUP | Link bill of lading item to Receive work orders
11 Jul 2023 navma1	Defect 59095: EUP - Able to save the Receive Cargo Work Order without the Booking selected when the VAS Subscription is on/off
*/

vars

begin
	if _voyage &lt;&gt; null then 								// 28.6.2023 navlw1 #58730
		self.cmbVoyages.setObject(_voyage);
		self.cmbVoyages_click(self.cmbVoyages);
		self.cmbVoyages.enabled := false;
	endif;
	if _bol &lt;&gt; null then									//10.07.2023 navma1 #54550
		self.cmbBOLIns.setIndexFromObject(_bol);	
		self.cmbBOLIns.enabled := false;
	endif;
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_bol" type="CM_BOL"/>
    </JadeMethod>
    <JadeMethod name="setCaption" id="6a1c96f1-af97-47eb-a8ad-e9da0908d6b5">
        <updating/>
        <source>setCaption(_caption: String) updating;
//27 August 2009	cnwml2


vars
	caption : String;
begin

	caption := "Cargo Search";
	inheritMethod(caption);

epilog

end;</source>
        <Parameter name="_caption" type="String"/>
    </JadeMethod>
    <JadeMethod name="setCargoType" id="68e6e294-76ee-4617-ba40-c29d38573031">
        <updating/>
        <source>setCargoType(_value : CM_CargoType) updating;
//30 September 2009	cnwml2
// 10/03/2010	cnwmh5		Par22837 - Add loading of subtype combo
// 22/06/2022 navcs2 ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema
vars

begin
	self.cmbCargoTypes.setObject(_value);
	self.cmbSubCargoTypes.setCargoType(self.cmbCargoTypes.myObject.CM_CargoType);   // 10/03/2010 cnwmh5 #22837
	
	
	//22/06/2022 navcs2 53038
	if _value &lt;&gt; null then
		if self.myParentForm.name = "YRD_WorkOrder" then
			self.cmbType.enabled := true;
		else
			self.cmbType.enabled := false;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_value" type="CM_CargoType"/>
    </JadeMethod>
