    <JadeMethod name="displayMultiSelectAvailable" id="828cbd92-3530-4c67-8f5c-d1a7361970aa">
        <source>displayMultiSelectAvailable(_obj : Object) : String protected;
//--------------------------------------------------
// Created:	08 September 2005 By: cnwgd1
//--------------------------------------------------
//call back method used by multi select sheet
vars
	entRow : EntTableRow;
	rtnString : String;
begin
	
	if EntTableRow.hasInstance(_obj) then
		entRow := _obj.EntTableRow;
		rtnString := entRow.getHeading(self.myDataTable.myTerminologyCargoBOLType, self.myDataTable.myTerminologyTerminal, app.myCurrentLocale);
	endif;
	return rtnString;
end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="displayMultiSelectSorted" id="11b0f394-c8c8-4f14-828a-59d0b75c1a39">
        <source>displayMultiSelectSorted(_obj : Object) : String protected;
//--------------------------------------------------
// Created:	08 September 2005 By: cnwgd1
//--------------------------------------------------
//call back method used by multi select sheet
vars
	idx : Integer;
	entRow : EntTableRow;
	rtnString : String;
	ascend : Boolean;
begin
	if self.mulColumnSorter.mySelectedListBox.listCount &gt;= self.maxSortingColumns then
		// reached max limit allowed
		return null;
	
	elseif EntTableRow.hasInstance(_obj) then
		entRow := _obj.EntTableRow;
		rtnString := entRow.getHeading(self.myDataTable.myTerminologyCargoBOLType, self.myDataTable.myTerminologyTerminal, app.myCurrentLocale);
		idx := self.myDataTable.allTblDataSortColumns.indexOf(entRow.name);
		if idx &gt; 0 then
			if self.myDataTable.allTblDataSortDescending[idx] then
				rtnString := rtnString &amp; ' - ' &amp; Descending;			
			else
				rtnString := rtnString &amp; ' - ' &amp; Ascending;
			endif;
		else
			rtnString := rtnString &amp; ' - ' &amp; Ascending;
		endif;

		return rtnString;			
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doBtnAscDescClick" id="8a252025-ef12-4107-8083-f4ae873f8909">
        <source>doBtnAscDescClick()protected;
//--------------------------------------------------
// Created:	08 September 2005 By: cnwgd1
//--------------------------------------------------
vars
	lstCnt,
	idx : Integer;
	str : String;
	lstBox : CM_MultiSelectListBox;
begin

	lstBox := self.mulColumnSorter.mySelectedListBox;
	
	idx := lstBox.listIndex;
	if idx &lt; 1 then
		return;
	endif;
	lstCnt := lstBox.listCount;

	idx := 1;
	while idx &lt;= lstCnt do
		if lstBox.itemSelected[idx] then
			str := lstBox.itemText[idx];
			if str &lt;&gt; null then
				if str.cnContains(Ascending) then
					str := str.replaceWord(Ascending, Descending);
				else
					str := str.replaceWord(Descending, Ascending);
				endif;
				lstBox.itemText[idx] := str;
			endif;
		endif;
		idx := idx+1;
	endwhile;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doOK" id="13008760-82ba-4244-b36e-9f30581726e0">
        <updating/>
        <source>doOK() updating;
//--------------------------------------------------
// Created:	08 September 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	if self.doSave then
		// visible columns have changed
		// return IDOK so the form handles re-display
		self.modalResult := IDOK;
	else
		// No change to visible columns
		// return IDCANCEL so the data is not re-displayed
		self.modalResult := IDCANCEL;	
	endif;

	self.unloadForm;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doResetToDefault" id="d2aa9833-aa7e-42b4-aa78-2e3c11a717e0">
        <updating/>
        <source>doResetToDefault() protected, updating;
// ---------------------------------------------------------------------------
// Created:     August 2013		cnwjre1
//
// Purpose:     32345 allow reset of system defaults
//			 
// ----------   ----------  --------------------------------------------------
vars
	cargoBOLType			: CM_CargoBOLType;
	menuRoot				: CM_MenuRootQuery;
	qDef : CM_QueryDefinition;	
begin
	qDef := app.myRoot.allQueryDefinitionObjects[ self.selectorType, self.selectorMode ];

	beginTransaction;
	if self.myCargoBOLType = null then
		// Tracked Item mode (0) or User Query Mode (20)
		menuRoot := app.myRoot.myQueryMenuRoot;
		
		if self.selectorType = CM_QueryDefinition.Transaction_Query_Type
		or self.selectorType = CM_QueryDefinition.Invoicing_Query_Type
		or self.selectorType = CM_QueryDefinition.Cash_Query_Type
		or self.selectorType = CM_QueryDefinition.Audit_Query_Type
		or (qDef &lt;&gt; null and (qDef.isKindOf(CM_QDefTILC) or qDef.isKindOf(CM_QDefCar))) //jlier1 TFS 64054 30/5/24
		then	//29 Mar 2019	NDL	TFS 44100
			menuRoot.resetNcColumns( self.selectorType, self.selectorMode );
			
		elseif self.selectorMode = CM_QueryDefinition.UserDefined_Query_Mode then
			menuRoot.resetUserSelectorColumns(true);
			
		else
			menuRoot.resetSelectorColumns(true);
			
		endif;
		
	else
		cargoBOLType := self.myCargoBOLType;
		cargoBOLType.resetSelectorColumns(true);
	endif;
	commitTransaction;

	// return the 'have-changed' status and close the form
	self.modalResult := IDOK;

	self.unloadForm;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSave" id="86f4c3b3-4ccf-4416-b67c-99d9101e7a14">
        <updating/>
        <source>doSave() :Boolean updating, protected;
//--------------------------------------------------------------
//Created: 14 January 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	oldIdx,
	newIdx : Integer;
	entRow : EntTableRow;
	sortChanged,
	changed : Boolean;
	oldEntRows : EntTableRowArray;	
begin
	
	app.mousePointer := MousePointer_HourGlass;

	self.allTblDataEntRows.clear;
	self.mulColumns.getSelected(self.allTblDataEntRows);

	if self.cbxSystem.value then
		self.doSaveSystemDefault();
	endif;

	if self.allowSort then
		// set the sort order
		self.doSaveSortOrder(sortChanged);
	endif;
	
	// check for column removed
	oldEntRows := self.myDataTable.allTblDataEntRows;
	foreach entRow in oldEntRows do
		oldIdx := oldIdx+1;
		newIdx := self.allTblDataEntRows.indexOf(entRow);
		if newIdx &lt;&gt; oldIdx then
			// visible column has changed
			changed := true;
			break;
		endif;
	endforeach;
	
	if (not changed) then
		// check for any new column
		newIdx := 0;
		oldIdx := 0;
		foreach entRow in self.allTblDataEntRows do
			newIdx := newIdx+1;
			oldIdx := oldEntRows.indexOf(entRow);
			if newIdx &lt;&gt; oldIdx then
				// visible column has changed
				changed := true;
				break;
			endif;
		endforeach;
	endif;	

	if changed then
		// set the columns and resorts the table
		self.myDataTable.setColumnsFromOrganiser(self.allTblDataEntRows,null);
		
	elseif sortChanged then
		// resort only handled here
		self.myDataTable.setSortColumnsForMaxNumCols();
		changed := true;
	endif;
	
	return changed; // form handles visible column changes
	
epilog
	app.mousePointer := MousePointer_Default;	
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveSortOrder" id="5a074d43-9ae9-4cf5-83b9-e11d174629fe">
        <source>doSaveSortOrder(_sortChanged : Boolean output)protected;
//--------------------------------------------------
// Created:	28 October 2003 By: cnwgd1
//--------------------------------------------------
vars
	lstCnt,
	oldIdx,
	idx : Integer;
	entRow : EntTableRow;
	tmpTable : CM_DataTable;
	lstBox : CM_MultiSelectListBox;
	oldDescending,
	descending : Boolean;
	rowName : String;
	oldOrder : StringArray;
	oldDesc : BooleanArray;
begin
	if (not self.allowSort) then
		return;
	endif;
	
	tmpTable := self.myDataTable;
	lstBox := self.mulColumnSorter.mySelectedListBox;
	lstCnt := lstBox.listCount;
	
	create oldOrder transient;
	create oldDesc transient;
	
	tmpTable.allTblDataSortColumns.copy(oldOrder);
	tmpTable.allTblDataSortDescending.copy(oldDesc);	
	
	tmpTable.allTblDataSortColumns.clear();
	tmpTable.allTblDataSortDescending.clear();
	
	foreach idx in 1 to lstCnt do
		entRow := lstBox.itemObject[idx].EntTableRow;
		descending  := lstBox.itemText[idx].cnContains(Descending);
		tmpTable.zAddSortColumn(entRow.name, descending);
		if (not _sortChanged) then
			// check to see if sort order has changes
			oldIdx := oldOrder.indexOf(entRow.name);
			if oldIdx &lt;&gt; idx then
				_sortChanged := true;
			else
				oldDescending := oldDesc[oldIdx];
				_sortChanged := oldDescending &lt;&gt; descending;
			endif;
		endif;
	endforeach;
	

	if (not _sortChanged) then
		// check for removed
		foreach rowName in oldOrder do
			if (not tmpTable.allTblDataSortColumns.includes(rowName)) then
				_sortChanged := true;
				break;
			endif;				
		endforeach;
	endif;	

epilog
	delete oldOrder;
	delete oldDesc;	
end;</source>
        <access>protected</access>
        <Parameter name="_sortChanged" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="doSaveSystemDefault" id="74121e3a-9db5-4dbd-9c3a-b56f9cae992f">
        <updating/>
        <source>doSaveSystemDefault()updating, protected;
//--------------------------------------------------------------
//Created: 09 May 2003 By: cnwgd1
//--------------------------------------------------------------
//
/* Changes

Date		Name	TFS#		Description
============================================================================
23/05/2013	cnwdap1	PAR #31486 	New User Cargo Type selector columns
14/10/2019	jlgka1	46962		STWO - Error when saving columns as system default in selector query.
============================================================================*/
vars

	allColumns,
	allVisible	: StringArray;
	array		: EntTableRowArray;
	row			: EntTableRow;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin

	create allColumns transient;
	create allVisible transient;
	create array transient;
	
	self.mulColumns.getAvailable(array);
	
	foreach row in array do
	//	allColumns.add(row.controlName);
		allColumns.add(row.name);	//18 Nov 2014	NDL	Par 35215
	endforeach;
	
	array.clear();
	
	self.mulColumns.getSelected(array);
	
	foreach row in array do
		allVisible.add(row.name);	//18 Nov 2014	NDL	Par 35215
		allColumns.add(row.name);	//18 Nov 2014	NDL	Par 35215
	endforeach;
	
	if self.myCargoBOLType &lt;&gt; null then
	
		//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			app.myTrxUA.trxUpdateCargoTypeSelectorCols(self.myCargoBOLType, allColumns, allVisible, app.myPassport);
		
			if app.myPassport.trxCompletedOK then
				break;
			else
				theResult := app.showErrorWarningDialog('Selector mode default columns update', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			return;
			
		endwhile;
	
		
	else//setting default for tracked item mode- hangs off query menu root object
	
		//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			if self.selectorMode = CM_QueryDefinition.UserDefined_Query_Mode then
				app.myTrxUA.trxUpdateUserDefineSelector(allColumns, allVisible, app.myPassport );
			elseif self.selectorMode = CM_QueryDefinition.TrackedItem_Query_Mode then
				app.myTrxUA.trxUpdateCargoSelector(allColumns, allVisible, app.myPassport );
			else
				app.myTrxUA.trxUpdateNonCargoSelectorCols( self.selectorType, self.selectorMode, allVisible, app.myPassport );
			endif;
			
		
			if app.myPassport.trxCompletedOK then
				break;
			else
				theResult := app.showErrorWarningDialog('Selector mode default columns update', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			return;
			
		endwhile;
		
	endif;
			
epilog

	delete allColumns;
	delete allVisible;
	delete array;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="fldMain_sheetChg" id="18601a57-5a77-4c5b-80b7-0dd25cb4aa9b">
        <controlMethod name="Folder::sheetChg"/>
