    <JadeMethod name="setComboValues" id="46274e64-c927-49fe-a88c-51beb8db093a">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);

vars
	crit			: CM_SelectorCriteriaLine;
	ta				: CM_TerminalAreaMaster;
	idx				: Integer;
	os				: ObjectSet;
	value			: Any;
	ut				: CM_UserTerminal;
	obj				: Object;
	multiTerminal	: Boolean;
	qrl				: CM_QStringLookup;
	tmpLbl : String;
begin
	_combo.clear;
	
	if _params = null then
		return;
	endif;
	
	//crit := _params.allCriteriaByPropertyName['myTerminal', null];

	create os transient;
	_params.getTerminals(os,_passport);
	/*
	if crit &lt;&gt; null then
		crit.myQueryOperator.getSearchValueAsObjectSet(os);
	else
		foreach ut in _passport.myUser.allUserTerminals do
			os.add(ut.getMyTerminal);
		endforeach;
	endif;*/
	
	multiTerminal := (os.size &gt; 1);

	foreach obj in os do
		foreach ta in obj.CM_Terminal.allTerminalAreas do
			tmpLbl := ta.getID();
			
			if multiTerminal then
				idx := _combo.addItem(tmpLbl &amp; ' - ' &amp; ta.myTerminal.code);
			else
				idx := _combo.addItem(tmpLbl);
			endif;
			_combo.itemObject[idx] := ta;
		endforeach;
	endforeach;
	
	if CM_QStringLookup.hasInstance(_queryOperator) then
		qrl := _queryOperator.CM_QStringLookup;
//		if global.isValidObject(qrl.selectionValue) then
//			_combo.listObject := qrl.selectionValue;
//		endif;
	endif;
	
epilog
	delete os;
end;
</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="daa21435-a0df-48f5-983b-932d34a00b42">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QStringIsOneOf; _passport: CM_Passport);

vars
	crit		: CM_SelectorCriteriaLine;
	tmpTerminal	: CM_Terminal;
	ta			: CM_TerminalArea;
	idx			: Integer;
	os			: ObjectSet;
	value		: Any;
	ut			: CM_UserTerminal;
	obj			: Object;
	multiTerminal	: Boolean;
	selectionValue	: Integer;
begin

	_tbl.rows := _tbl.fixedRows;
	
	if _params = null then
		return;
	endif;
	
	crit := _params.allCriteriaByPropertyName['myTerminal', null];

	create os transient;
	
	if crit &lt;&gt; null then
		crit.myQueryOperator.getSearchValueAsObjectSet(os);
	else
		foreach ut in _passport.myUser.allUserTerminals do
			os.add(ut.getMyTerminal);
		endforeach;
	endif;
	
	multiTerminal := (os.size &gt; 1);

	foreach obj in os do
		foreach ta in obj.CM_Terminal.allTerminalAreas do
			selectionValue := 0;
			if _operator &lt;&gt; null and _operator.allSelectionValues.includes(ta.id) then
				selectionValue := 1;
			endif;
			
			if multiTerminal then
				idx := _tbl.addItem(selectionValue.String &amp; Tab &amp; ta.id &amp; ' - ' &amp; ta.myTerminal.code);
			else
				idx := _tbl.addItem(selectionValue.String &amp; Tab &amp; ta.id);
			endif;
			_tbl.accessRow(idx).itemObject := ta;
			_tbl.row := idx;
			_tbl.change(_tbl);
		endforeach;
	endforeach; 
	
epilog
	delete os;
end;
</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QStringIsOneOf"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="151f4fcb-1a86-4df5-93c4-c37dc221df5d">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);

vars
	str				: String;
	numRows,
	idx				: Integer;
	taArray			: StringArray;
	termArea		: CM_TerminalAreaMaster;
begin

	create taArray transient;
	
	numRows := _tbl.rows;
	foreach idx in (_tbl.fixedRows + 1) to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			termArea := _tbl.accessRow(idx).itemObject.CM_TerminalAreaMaster;
			taArray.add(termArea.id);
		endif;
	endforeach;
	
	_op.setSearchValue(taArray);
	
epilog
	delete taArray;	
end;
</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="83a2d583-07a5-4680-b98e-2eb05f0e5a96">
        <source>translateToDisplayValue(_value: Any): String;

vars

begin
	if _value = null then
		return null;
	endif;
	
	if _value.isKindOf(CM_TerminalAreaMaster)then
		return _value.CM_TerminalAreaMaster.getID();
	else
		return _value.String;
	endif;
end;
</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="a17add9b-5430-4295-947f-d9c9dc2e0ac5">
        <source>translateToSearchValue(_value: Any): Any;

/*

Date		Who		Reason
06 Oct 2008	cnwkpd1	PAR #18099 - Correct Selector query processing
22 Oct 2008	cnwkpd1	PAR #18348 - Prevent 1002 exceptions in Selector query processing with isOneOf

*/

vars
	invalidObj 		: Boolean;
	object			: CM_TerminalAreaMaster;
	returnVal		: String;
	
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then			// PAR #18348
			return _value;
		endif;
	
		if _value.isKindOf(CM_TerminalAreaMaster) then
			object := _value.CM_TerminalAreaMaster;
		endif;
	endif;
	
	if object &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, object, invalidObj);
		
		returnVal := object.id;
	endif;
	
	return returnVal;
	
end;
</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="79a3e4bd-5fdc-4f2b-a243-276f7f3d5f83">
        <source>translateToSearchValueForWeb(_value: Any; _sending : Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 06/09/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars
	str, rtnVal : String;
	strArray : StringArray;

begin
	if _value.isKindOf(CM_TerminalArea) then
		return _value.CM_TerminalArea.id;
		
	elseif _value.isKindOf(String) then
		if _value.String.cnContains("|") then
			str := _value.String;
			create strArray transient;
			str.getTokensForDelimiter("|", strArray);
			return strArray;
		endif;
		
		return _value.String;
		
	elseif _value.isKindOf(StringArray) then
		foreach str in _value.StringArray do
			rtnVal := rtnVal &amp; str &amp; CNEC_COMMA &amp; Space;
		endforeach;
		rtnVal := rtnVal[1:rtnVal.length-2];
		return rtnVal;
		
	endif;
	
	return inheritMethod(_value, _sending);

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
