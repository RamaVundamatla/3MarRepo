    <JadeMethod name="setContractId" id="9522ce83-dd63-477c-9e25-3266d6a66fce">
        <updating/>
        <source>setContractId(_contractId : String) updating;
/*
Purpose:			

Date		Who		Reason
13-03-2023 navtnr20 CR 55648 TASK  56818
 // ### TFS CR 55648 TASK 56818 15MAR2023 NAVAB1
*/

vars

begin
	self.contractId := _contractId;
	if self.invoice &lt;&gt; null then
		self.invoice.setContractId(self.contractId);
	endif;

	 //09/11/2023 navmv20 Bug 61114: FR | EUP - 54089
	if self.myTransactionTI &lt;&gt; null then
		self.myTransactionTI.setContractId(contractId); 
	elseif self.myTransactionEvent &lt;&gt; null then
		self.myTransactionEvent.setContractId(contractId); 
	elseif self.myTransactionWO &lt;&gt; null then
		self.myTransactionWO.setContractId(contractId); 
	elseif self.myTransactionHMS &lt;&gt; null then
		self.myTransactionHMS.setContractId(contractId); 
	endif;

epilog

end;</source>
        <Parameter name="_contractId" type="String"/>
    </JadeMethod>
