    <JadeMethod name="initDataExtractFields" id="8514b5e0-b6d2-4421-9001-5cca6650f1e5">
        <source>initDataExtractFields(_fields: CM_DataExtractFieldSet input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 May 2011	#cnwdz2	 

*/

vars

begin
	self.extractOrder.clear();
	self.initDataExtractFields_Damage(_fields);
	self.initDataExtractFields_Hazard(_fields);
	self.initDataExtractFields_Stop(_fields);
	self.initDataExtractFields_CustNum(_fields);
	
	self.initDataExtractFields_Default(_fields);
	self.initDataExtractFields_General(_fields);
	self.initDataExtractFields_GCRel(_fields);
	self.initDataExtractFields_GCVoy(_fields);
	self.initDataExtractFields_Receive(_fields);
	self.initDataExtractFields_Release(_fields);
	self.initDataExtractFields_Ship(_fields);
	self.initDataExtractFields_Status(_fields);
	self.initDataExtractFields_Tranship(_fields);
	self.initDataExtractFields_Chassis(_fields);
	self.initDataExtractFields_Car(_fields);	
	self.initDataExtractFields_Generatr(_fields);
	
	
epilog

end;</source>
        <Parameter name="_fields" type="CM_DataExtractFieldSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="initDataExtractFields_Car" id="61020cfb-6164-462c-9a99-22c5ea8d93ba">
        <source>initDataExtractFields_Car(_fields : CM_DataExtractFieldSet input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 May 2011	cnwkpd1	PAR #27436 - CCMS DCT 2073 - Product Transition Services
