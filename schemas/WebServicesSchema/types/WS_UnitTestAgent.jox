    <JadeMethod name="wsRESTInspectionAppCheck" id="64bb2552-ff48-4fe9-bf83-d18779931644">
        <source>wsRESTInspectionAppCheck(_loginString : String; _json: String; _expectFailure: Boolean):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 January 2023	navsp1	Initial creation - TFS ChangeRequest 55580: EUP - Inspection App checks - Interface and MTN changes

*/

vars
	requestLogin		: WS_RESTLoginAuthRequest;
	webService			: MasterTerminalAPIService;
	request				: WS_GateCheckRequest;
	response			: WS_Response;
	parser				: JadeJson;
	transientJSONObjs	: ObjectArray;
	login 				: WS_InterfaceObject;
	jsonLogin			: String;
	responseLogin  		: WS_NAuthTokenResponse;
	ref ,newJson		: String;
begin
	create webService transient;
	create parser transient;
	create transientJSONObjs transient;	
	
	// call POST /login
	requestLogin := parser.parse(_loginString, WS_RESTLoginAuthRequest, transientJSONObjs).WS_RESTLoginAuthRequest;
	webService.setPropertyValue(WS_RestWebServiceProvider::requestPath.name, "/login");
	
	login := webService.postLogin(requestLogin);
	
	if not login.isKindOf(WS_NAuthTokenResponse) then
		delete login;
		if webService.httpStatusCode = HttpResponseUnauthorized then
			return HttpResponseUnauthorized.String &amp; " Unauthorized - Username / Password not OK";
		endif;
		return "Login failed";
	endif;
	
	responseLogin := login.WS_NAuthTokenResponse;
	webService.unitTestData.addAssoc("HTTP_AUTHORIZATION", "Bearer " &amp; responseLogin.accessToken);

	webService.setPropertyValue(WS_RestWebServiceProvider::requestPath.name, "");
	request := parser.parse(_json, WS_GateCheckRequest, transientJSONObjs).WS_GateCheckRequest;
	response	:= webService.putGateCheck(request);
	
	// If we're expecting to fail, then return early
	if _expectFailure then
		if webService.httpStatusCode = HttpResponseOK then
			return "Failure expected, got 200 OK";
		endif;
		return response.WS_Response.allErrors.first.text;
	endif;
	
	if webService.httpStatusCode &lt;&gt; HttpResponseOK then
		if response.allErrors.size &gt; 0 then
			app.writeLog(response.allErrors.first.text, LogERROR);
		endif;
		return method.qualifiedName &amp; " Bad Response Code, expecting 200 OK, got " &amp; webService.httpStatusCode.String &amp; ". Check UnitTest runner logs for more details" &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	endif;
	
	return null;
	
	// Not used,just here to provide a reference from the super schema super class method 
	ref := CM_UnitTestAgent::wsRESTInspectionAppCheck.name; 
	
epilog
	delete webService;
	delete parser;
	delete requestLogin;
	delete request;
	transientJSONObjs.purge();
	delete transientJSONObjs;
	delete response;
	delete responseLogin;
end;</source>
        <Parameter name="_loginString" type="String"/>
        <Parameter name="_json" type="String"/>
        <Parameter name="_expectFailure" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="wsRESTInvPostAndValidateStatus" id="fbb43e76-e072-460a-85f2-270b717a99ff">
        <source>wsRESTInvPostAndValidateStatus(_jsonString : String; _testDesc: String) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 January 2024	navrv30	CR 61931 Initial creation

*/

vars
	
	webService			: MasterTerminalAPIService;	
	parser				: JadeJson;
	response 			: WS_InvoiceAPIAsyncPartUpdRes;
	responseLogin  		: WS_NAuthTokenResponse;
	ref 				: String;
	dict : WS_QueryStringParamDict;
	jsonHelper : JadeJson;
	transientObjs : ObjectArray;
	_request : WS_InvoiceAPIAsyncPartUpdate;
	

	
begin
	
	create webService transient;
	create parser transient;
		
	
	self.loginREST(webService);
	
	create jsonHelper transient;
	create transientObjs transient;		
	_request := jsonHelper.parse(_jsonString, WS_InvoiceAPIAsyncPartUpdate, transientObjs).WS_InvoiceAPIAsyncPartUpdate;

	
	
	
	response := webService.postInvoiceAsyncResponse(_request);
	
	//do verification according to the different test cases
	if _testDesc = "TESTCASE1" then		
		/*if response.responseString &lt;&gt; "hi,hello" then		
			return "The expeted response was returned found!";
		endif;*/
	endif;
	
	return null;
	
	// Not used,just here to provide a reference from the super schema super class method 
	ref := CM_UnitTestAgent::wsRESTInvPostAndValidateStatus.name; 
	
epilog
	webService.unitTestData.removeAssoc("HTTP_AUTHORIZATION");
	
	dict := webService.qsData;
	dict.purge();
	
	delete webService;
	
	delete parser;
	if transientObjs &lt;&gt; null then
		transientObjs.purge();
	endif;
	delete transientObjs;
	delete jsonHelper;
	
	delete response;
	
	delete responseLogin;
//delete _request;
end;</source>
        <Parameter name="_jsonString" type="String"/>
        <Parameter name="_testDesc" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="wsRESTLogin" id="cced9639-8f62-44af-a662-59b387fd67df">
        <source>wsRESTLogin(_loginJson : String; _authToken : String output) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 April 2023	navra1	Initial creation

*/

vars
	requestLogin		: WS_RESTLoginAuthRequest;	
	webService			: MasterTerminalAPIService;
	parser				: JadeJson;
	transientJSONObjs	: ObjectArray;
	login 				: WS_InterfaceObject;
	responseLogin  		: WS_NAuthTokenResponse;
begin
	
	create webService transient;
	create parser transient;
	create transientJSONObjs transient;
	
	requestLogin := parser.parse(_loginJson, WS_RESTLoginAuthRequest, transientJSONObjs).WS_RESTLoginAuthRequest;
	webService.setPropertyValue(WS_RestWebServiceProvider::requestPath.name, "/login");
	
	login := webService.postLogin(requestLogin);
	if not login.isKindOf(WS_NAuthTokenResponse) then
		delete login;
		if webService.httpStatusCode = HttpResponseUnauthorized then
			return HttpResponseUnauthorized.String &amp; " Unauthorized - Username / Password not OK";
		endif;
		return "Login failed";
	endif;
	
	responseLogin := login.WS_NAuthTokenResponse;	
	
	_authToken := "Bearer " &amp; responseLogin.accessToken;

epilog
	
	delete webService;
	delete requestLogin;
	delete parser;
	
	transientJSONObjs.purge();
	delete transientJSONObjs;
	delete login;
	
	//delete response;
	
end;</source>
