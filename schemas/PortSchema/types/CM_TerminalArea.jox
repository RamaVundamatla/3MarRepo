    <JadeMethod name="setCargoArrayInDeckOutOrder" id="af344a37-55d3-4d03-8288-f30a078f5a10">
        <source>setCargoArrayInDeckOutOrder( _allCargoUNSorted : CM_TIArray; _allCargoSorted : CM_TIArray io);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 August 2011	cnwndl1	Initial creation	Par 28035

*/

vars

	yaLocnCells: CM_YALocationCellArray;
	yaCell : CM_YALocationCell;
	cellHeight : Integer;
	locn : CM_YardController;
	ti : CM_TrackedItem;

begin

	if self.myYADeckingOptions &lt;&gt; null then
		yaLocnCells := self.myYADeckingOptions.allYALocationCellsOut;
	endif;
	
	if yaLocnCells &lt;&gt; null then
		foreach yaCell in yaLocnCells do
			locn := yaCell.myYardController;
			/*	foreach ti in locn.allTrackedItems do
				if _allCargoUNSorted.includes( ti ) and not _allCargoSorted.includes( ti ) then
					_allCargoSorted.add( ti );
				endif;
			endforeach; */
			//19 Dec 2011	NDL	Par 28821
			cellHeight := yaCell.height;
			if locn.allTrackedItems.size &gt;= cellHeight then
				ti := locn.allTrackedItems[cellHeight];
				if _allCargoUNSorted.includes( ti ) and not _allCargoSorted.includes( ti ) then
					_allCargoSorted.add( ti );
				endif;
			endif;
		endforeach;
	endif;

epilog

end;</source>
        <Parameter name="_allCargoUNSorted" type="CM_TIArray"/>
        <Parameter name="_allCargoSorted" type="CM_TIArray" usage="io"/>
    </JadeMethod>
