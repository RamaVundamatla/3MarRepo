    <JadeMethod name="outputProcessStack" id="5bc6304e-66a6-4af9-aa22-4ddf9b370a27">
        <source>outputProcessStack();
// ---------------------------------------------------------------------------
// Created:     06 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
23 Sep 2008	cnwkpd1	PAR #18009 - Prevent transient leaks

*/

vars
	pc 		: ProcessStackArray;
	md		: MethodCallDesc;
	meth	: Method;
	str		: String;
	
begin

	create pc transient;
	process.currentStack(pc);
	
//	pc.removeAt(1);		// ExternalMethod::currentStack
//	pc.removeAt(2);		// JadeMethod::outputProcessStack

	foreach md in pc do
		meth := md.method;
		str := md.display &amp; '  (' &amp; meth.class.name &amp; ')';
		app.writeStatement( '     ' &amp; str);
	endforeach;

epilog
	if pc &lt;&gt; null then		// PAR #18009
		pc.purge();
		delete pc;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="outputProcessStackToAlert" id="3ef3d73a-d248-4cbd-a982-64cd00761b0e">
        <source>outputProcessStackToAlert(_alert : CM_SystemAlert input);
// ---------------------------------------------------------------------------
// Created:		February 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
23 Sep 2008	cnwkpd1	PAR #18009 - Prevent transient leaks

*/

vars
	pc 		: ProcessStackArray;
	md		: MethodCallDesc;
	meth	: Method;
	str		: String;
	
begin
	if _alert = null then
		return;
	endif;
	create pc transient;
	process.currentStack(pc);
	
	foreach md in pc do
		_alert.addLogEntry(md.display);
	endforeach;

epilog
	if pc &lt;&gt; null then		// PAR #18009
		pc.purge();
		delete pc;
	endif;
end;</source>
        <Parameter name="_alert" type="CM_SystemAlert" usage="input"/>
    </JadeMethod>
    <JadeMethod name="outputProcessStackToStringArry" id="3d3cd290-028b-4db4-8a00-ac5c57e325b0">
        <source>outputProcessStackToStringArry(_stack : HugeStringArray input);
// ---------------------------------------------------------------------------
// Created:		February 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
23 Sep 2008	cnwkpd1	PAR #18009 - Prevent transient leaks

*/

vars
	pc 		: ProcessStackArray;
	md		: MethodCallDesc;
	meth	: Method;
	str		: String;
	
begin
	if _stack = null then
	endif;
	
	create pc transient;
	process.currentStack(pc);
	
	foreach md in pc do
		_stack.add(md.display);
	endforeach;

epilog
	if pc &lt;&gt; null then		// PAR #18009
		pc.purge();
		delete pc;
	endif;
	
end;</source>
        <Parameter name="_stack" type="HugeStringArray" usage="input"/>
    </JadeMethod>
