    <JadeMethod name="getRealTI" id="3705e5dc-97b5-4bf3-98f2-631de0e5986f">
        <source>getRealTI( _terminal : CM_Terminal ) : CM_TrackedItem;
// getRealTI( _terminal : CM_Terminal ) : CM_Container;		// cnwrl1 12/08/2010 PAR 25318 - what it was

vars
//	trackedItem 	: CM_Container;							// cnwrl1 12/08/2010 PAR 25318 - what it was
	trackedItem 	: CM_TrackedItem;
	
begin
	/* cnwrl1 12/08/2010 PAR 25318 - what it was
	trackedItem := _terminal.lookupTrackedItem(self.id, self.cargoType, TI_STATE_NORMAL, self.getVoyageCode(), null).CM_Container;
	if trackedItem = null then
		trackedItem := _terminal.lookupTrackedItem(self.id, self.cargoType, TI_STATE_ONSHIP, self.getVoyageCode(), null).CM_Container;
	endif;
	cnwrl1 12/08/2010 PAR 25318 - end of what it was */
	
	// cnwrl1 12/08/2010 PAR 25318 - start of replacement coding
	trackedItem	:= _terminal.lookupTrackedItem( self.id, self.cargoType, TI_STATE_NORMAL, self.getVoyageCode(), null );
	if trackedItem = null then
		trackedItem	:= _terminal.lookupTrackedItem( self.id, self.cargoType, TI_STATE_ONSHIP, self.getVoyageCode(), null );
	endif;
	// cnwrl1 12/08/2010 PAR 25318 - end of coding
	
epilog
	return trackedItem;
end;
</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getValueSpecial" id="d0cd5ab4-83dd-4cc8-9484-cc54a96320e4">
        <source>getValueSpecial(_propName: String; _xlationOperator: CM_Operator): String;
//
// 16 Jan 2012	MSL CCMS 1009 PAR 29024
//
// 07 Mar 2013	cnwcs5	CCMS POL 2097 / par 31259 - include foundMatch in method signatures
vars
	foundMatch	: Boolean;
begin
	if _propName =  ETRow_Commodity then //Par 13379 cnwrs1 feb 2007
		if _xlationOperator &lt;&gt; null then
			return _xlationOperator.getXlationForeignCode(self.commodity[1:30], XLATION_TYPE_COMMODITY_BYOP, foundMatch);
		else
			return self.commodity;
		endif;
		
	elseif _propName = ETRow_TotalWeight then
		return weight.String;
	else
		return inheritMethod(_propName, _xlationOperator);
	endif;
end;
</source>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVoyageCode" id="dd66f96c-9b21-40f8-8c1a-7ab73bbbe339">
        <source>getVoyageCode() : String;

/*
Purpose:	Return the appropriate VoyageCode to be used in the EDIConfig allEDITrackedItemsByVoyageCode collection.

Date			Who		Reason
03 June 2010	cnwrl1	Initial creation as part of PAR 24299 - SFW 1118 EDI Form to allow searching of EDI file by Container / Voyage
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
*/
vars
	
begin
//	return self.voyageCode;		// cnwrl1 14/07/2010 PAR 23499 - what it was
	
	// If the EDITrackedItem voyageCode is null will now use the one of the EDIData sheet.
	if self.voyageCode &lt;&gt; null then
		// this overrides the EDIData one.
		return self.voyageCode;
	endif;
	
	if self.myEDIData = null then
		return null;
	else
		return self.myEDIData.getVoyageCode();
	endif;
	
epilog
	
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
