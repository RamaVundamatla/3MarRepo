    <JadeMethod name="tblLostFocus_idCombo" id="c91a15dc-b28c-41fb-aeb2-c16a5517791c">
        <updating/>
        <source>tblLostFocus_idCombo(table : CM_EntryTable; row : Integer; rowName : String; pValue : Any) updating;
// ---------------------------------------------------------------------------
// Created:     10 June 2001 by cnwrs2
//
// Purpose:     Called from the CM_EntryTable when the user leaves the
//				idCombo field (for releases by Id).
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

//	code removed as the lostFocus method for cmbTI handles this now
//	RDD PAR 1312 / PWL 832 27/8/2001

begin

end;

/*
vars
	sheet	: GTE_Sheet;
	tiId	: String;
	ti		: CM_TrackedItem;
	tiType	: CM_TrackedItemType;

begin

	if self.origValueStr = pValue.String then
		// the value hasn't changed
		return;
	endif;
	

	sheet := self.topSheet;
	if sheet.myGateObject.code = NavObj_GTE_OutById then
		// user has just left the idCombo field so ...
		app.mousePointer := MousePointer_HourGlass;
		tiId := pValue.String;
		sheet.setSubHeading(tiId);
		tiType := sheet.getTiType();
		if tiType &lt;&gt; null then
			ti := app.thisTerminal.onsiteTrackedItems[tiType.type].getAtKey(tiId);
			if ti &lt;&gt; null then
				self.setValuesFromReleaseTI(ti, sheet);
			endif;
		endif;
	endif;

epilog
	app.mousePointer := MousePointer_Default;
end;
*/</source>
