    <JadeMethod name="addTI" id="8a6fa330-677b-4648-b00c-4418f5e086f7">
        <updating/>
        <source>addTI(_ti: CM_TrackedItem input; _request: CM_Request) updating;
/*
Purpose:			
Parameters:			
Return Value:		

Date			Who		Reason
17 July 2009	cnwrd1	Initial creation
01/04/2010		cnwcs5	par 23383 - pass context info (_request) to updateTICollections 
						via new parameter (_extra)
*/

vars

begin
	exclusiveLock(self);

	if (_ti = null or _request = null) then
		app.setContinueCMExceptions(false);
		app.raiseCMException(ERR_TI_LINK_PARAM, null, null);
		return;	
	endif;

	sharedLock(_request);
	exclusiveLock(_ti);

	self.updateTICollections(_ti, _request);	// 01/04/2010 cnwcs5 par 23383

	self.updateObjectEdition(self);		// par 30292
	
	// PAR 11770 Lorcan Send note so screens can update
	app.myEventManager.createSingleObjInfoNoteEvt(self, app.myPassport.myTerminal.getTerminalEvent(YardJob_Update_Event), self);

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_request" type="CM_Request"/>
    </JadeMethod>
    <JadeMethod name="addToJobSheet" id="1d97f6b8-b7e6-4caf-a32d-421314c23ebe">
        <updating/>
        <source>addToJobSheet() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 July 2009	cnwrd1	Initial creation

*/
vars
	jobSheet : CM_YardJobSheet;
begin
	//------------
	//Add the ourselves to terminal's jobSheet
	//------------
	jobSheet := self.myTerminal.myYardJobSheet;

	if jobSheet = null then	//Padding for disasters, this object is only created in terminal constructor.
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null yardJobSheet. Contact Developer.');
	endif;
	jobSheet.addJob(self, 0);
end;</source>
    </JadeMethod>
    <JadeMethod name="cleanup" id="ce7d153f-d205-45cf-a5a4-a94c1255f56f">
        <updating/>
        <source>cleanup(numCleaned: Integer io) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 January 2010	cnwrd1	Initial creation

*/

vars

begin

	if self.status = JOB_COMPLETE then
		numCleaned := numCleaned +1;
		self.erase(0);
		return;
	endif;

epilog

end;</source>
        <Parameter name="numCleaned" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="createWLEs" id="1c9f0e78-e348-4647-9124-2d8ae2424fb1">
        <updating/>
        <source>createWLEs() updating;
/*
Date		Who		Reason
31 Jul 2009	cnwrd1	Initial creation
30 Aug 2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition 
*/

vars
	tmpRequest 	: CM_Request;
begin

	exclusiveLock(self);

	foreach tmpRequest in self.allRequests do
		sharedLock(tmpRequest);
		tmpRequest.createWLEs();
	endforeach;
	
	self.updateStatus();	
	self.updateObjectEdition(self);	// par 30292

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="erase" id="db285ea8-5816-4e35-9373-43e18cd51467">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 January 2010	cnwrd1	Initial creation
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance

*/

vars
	wle	:	CM_WorkListEntry;
	req : CM_Request;
	invalid 		: Boolean;
	
begin
	if self.status = JOB_UNACTIONED or self.status = JOB_COMPLETE  or self.allEntries.size = 0 then
		//Carry on.
	else
		//-----------------
		//Attempt a status update, to ensure we are REALLY not up to date
		//-----------------
		self.updateStatus();
	endif;
	exclusiveLock(self);
	
	foreach req in self.allRequests do
		req.processDeleteForWO();
	endforeach;

	
	//-----------------
	//Nuke the WLE's
	//-----------------
	while workListEntries.size &gt; 0 do : outerLoop
		wle := workListEntries.first;
		exclusiveLock(wle);
		//---------------
		//Tell WLE to deref from the TI
		//---------------
		wle.eraseFromTI();
		//workListEntries.remove(wle);
		//---------------
		//Tell WLE to deref from the Queue
		//---------------
		while wle.allRTQueueEntries.isEmpty = false do
			wle.allRTQueueEntries.last.deleteEntry( false, null);			
			if app.myPassport &lt;&gt; null then // AKB2003FEB
				if app.myPassport.hasErrors then // AKB2003FEB
					break outerLoop; // AKB2003FEB
				endif;
			endif;
		endwhile;
//		if global.isValidObject(wle) then
		if wle &lt;&gt; null then
			on Exception do app.handleDeletedObject(exception, wle, invalid);
			wle.causeEvent(self.getMyTerminal.getTerminalEvent(WLE_Delete_Event), false, wle);
			if not invalid then
				delete wle;
			endif;
			on Exception do null;
		endif;
	endwhile;
	if app.myPassport &lt;&gt; null then // AKB2003FEB
		if app.myPassport.hasErrors then // AKB2003FEB
			return;
		endif;
	endif;

	req := self.allRequests.first;
	if req &lt;&gt; null then
		delete req;
	endif;

	self.allTrackedItems.clear;
	//------------
	//Remove ourselves from SwapJobSheet on terminal
	//------------
	inheritMethod(_eraseLevel);
	
end;
</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getAllWLEs" id="38d779d9-2ccf-4a11-8a2b-880da05dd728">
        <source>getAllWLEs(_wleArray: CM_WLEArray input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 Jul 2009	cnwrd1	Initial creation
06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars
	wle	: CM_WorkListEntry;
begin

	if self.workListEntries.isEmpty then
		return;
	endif;

	self.workListEntries.copy(_wleArray);	//06.03.2025 navma1 #MTN-34179
epilog

end;</source>
        <Parameter name="_wleArray" type="CM_WLEArray" usage="input"/>
    </JadeMethod>
