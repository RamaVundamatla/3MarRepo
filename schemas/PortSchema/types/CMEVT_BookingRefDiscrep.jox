    <JadeMethod name="setDetailsFromCMIF" id="e09fc968-a1ff-445c-9ab3-3d2335553cff">
        <updating/>
        <source>setDetailsFromCMIF(_eventType: CM_EventType; _cmifEventTrx: CMIF_BookingRefDiscrepCtrl) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17/02/2025	navkc1 JIRA Bug MTN-33582: MTN | Event Charging Refactor

*/

vars

begin
	
	if _cmifEventTrx.myCMIFBookingRef &lt;&gt; null then
		self.setFromTiAndCmif(_cmifEventTrx.myTrackedItem, _cmifEventTrx.myCMIFBookingRef);
	else
		self.setFromTiAndBookingRef(_cmifEventTrx.myTrackedItem, _cmifEventTrx.myBookingRef, _cmifEventTrx.myBookingRefItem);
	endif;
	
	inheritMethod(_eventType, _cmifEventTrx);

epilog

end;</source>
        <Parameter name="_eventType" type="CM_EventType"/>
        <Parameter name="_cmifEventTrx" type="CMIF_BookingRefDiscrepCtrl"/>
    </JadeMethod>
    <JadeMethod name="setFromTiAndBookingRef" id="8461c8e2-466e-4b94-b231-2c82b0e49e16">
        <updating/>
        <source>setFromTiAndBookingRef(_ti : CM_TrackedItem; _bookingRef : CM_BookingRef; _bRefItem : CM_BookingRefItem ) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/08/2009	cnwndl1	Initial creation	CCMS 1609 Par 20521
02/04/2012	cnwdap1	PAR #29345 create notification of event
17/07/2014	cnwdap1	PAR #34326 Don't create voyage and discharge port discrepancies if terminal config option "Automatic Booking Cargo Updates" is set
// 22 Apr 2024	jlirs1	Bug 63776 Unit test failing for Prenote Booking discrepancies
*/
vars

	boofRefOperator : CM_Operator;
	attributesToCheck : StringArray;
	attributeName : String;
	bRefItem : CM_BookingRefItem;
	
	tiFieldValue : String;
	bookingFieldValue : String;
	pxyBrefItem : CM_BookingRefItem;
	
	entTableDef : EntTableDef;						// PAR #34326
	entTableRow : EntTableRow;						// PAR #34326
	str : String;									// PAR #34326
	skipDiscrepancy : Boolean;						// PAR #34326
	
begin

	// set the base data.
	self.myTrackedItem := _ti;
	self.myBookingRef := _bookingRef;
	self.bookingRefId := _bookingRef.bookingReference;
	if _bRefItem &lt;&gt; null then
		// if we have passed one in, use it. (Using a proxy)
		bRefItem := _bRefItem;
	else
		// if we haven't passed one in find it (already persistant)
		bRefItem := _bookingRef.getBookingRefItemForTI(_ti);
	endif;
	if bRefItem = null then
		// 22 Apr 2024	jlirs1	Bug 63776 if we still dont have a booking ref item use the one on the booking it self
		bRefItem := _bookingRef.allBookingRefItems.first;
	endif;

	self.setState();

	boofRefOperator := _bookingRef.myOperator;
	if boofRefOperator = null then
		return;
	endif;
	
	// get the set of attributes that we should check and record for this operator
	create attributesToCheck transient;
	if not boofRefOperator.allAttribForBookingRefDiscrep.isEmpty then
		boofRefOperator.allAttribForBookingRefDiscrep.copy( attributesToCheck );
	endif;
	
	entTableDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_BookingRefDiscrep];							// PAR #34326
	
	// populate the existing values
	foreach attributeName in  attributesToCheck do
		if entTableDef &lt;&gt; null and self.myBookingRef.myTerminal.getConfig(AutoBookingCargoUpdates).Boolean then		// PAR #34326
			skipDiscrepancy := false;																				// PAR #34326
			foreach entTableRow in entTableDef.allEntTableRows discreteLock do										// PAR #34326
				str := entTableRow.getHeading(null, null, app.myCurrentLocale);										// PAR #34326
				if str = attributeName and entTableRow.name.isOneOf(ETRow_Voyage, ETRow_DischargePort) then			// PAR #34326
					skipDiscrepancy := true;																		// PAR #34326
					break;																							// PAR #34326
				endif;																								// PAR #34326
			endforeach;																								// PAR #34326
		endif;																										// PAR #34326
		if skipDiscrepancy then																						// PAR #34326
			continue;																								// PAR #34326
		endif;																										// PAR #34326
		if bRefItem &lt;&gt; null then
			bookingFieldValue := self.getValueFromBookingRefItem(bRefItem,attributeName)[1:100];
		else
			// To cater for the apparent potential for a tracked item to be related to a booking ref,
			// but not to an individual item within that booking.
			bookingFieldValue := self.getValueFromBookingRef(_bookingRef,attributeName,null)[1:100];
		endif;
		tiFieldValue := self.getValueFromTI(_ti,attributeName)[1:100];
		createBookingRefDiscrepField(	bookingFieldValue,	//_bookingRefFieldValue : String;
										attributeName,	//_fieldName : String;
										tiFieldValue	//_tiFieldValue : String
										);
	endforeach;
	
	// PAR #29345 create a notification of this event so the event screen will show
	if self.myTerminal &lt;&gt; null then
		self.myTerminal.causeEvent(self.myTerminal.getTerminalEvent(EVENT_EVENT_TRANSACTION), false, self);
	elseif self.myEventType &lt;&gt; null then
		//no terminal so cause event on event type.
		self.myEventType.causeEvent(EVENT_EVENT_TRANSACTION, false, self);
	endif;
	// PAR #29345 end
	
epilog

	delete attributesToCheck;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_bookingRef" type="CM_BookingRef"/>
        <Parameter name="_bRefItem" type="CM_BookingRefItem"/>
    </JadeMethod>
    <JadeMethod name="setFromTiAndCmif" id="72889cf6-87df-41d2-b3ca-6b31c63420a7">
        <updating/>
        <source>setFromTiAndCmif(_ti : CM_TrackedItem; _cmif : CMIF_BookingRef ) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28/09/2009	cnwndl1	Initial creation	CCMS 1609 Par 20521
02/04/2012	cnwdap1	PAR #29345 create notification of event
*/
vars

	boofRefOperator : CM_Operator;
	attributesToCheck : StringArray;
	attributeName : String;
	cmifBRefItem : CMIF_BookingRefItem;
	
	tiFieldValue : String;
	bookingFieldValue : String;
	
begin

	// set the base data.
	self.myTrackedItem := _ti;
	if self.isTransient then
		self.myBookingRef := _cmif.myProxyBookingRef;
	else
		self.myBookingRef := _cmif.myProxyBookingRef.pxyGetRealObject;
	endif;
	if self.myBookingRef = null then
		return;
	endif;
	self.bookingRefId := self.myBookingRef.bookingReference;
	cmifBRefItem := _cmif.getBookingRefItemForTI(_ti);
	self.setState();

	boofRefOperator := self.myBookingRef.myOperator;
	if boofRefOperator = null then
		return;
	endif;
	
	// get the set of attributes that we should check and record for this operator
	create attributesToCheck transient;
	if not boofRefOperator.allAttribForBookingRefDiscrep.isEmpty then
		boofRefOperator.allAttribForBookingRefDiscrep.copy( attributesToCheck );
	endif;
	
	// populate the existing values
	foreach attributeName in  attributesToCheck do

		if cmifBRefItem &lt;&gt; null then
			bookingFieldValue := cmifBRefItem.getDiscrepValueFor(attributeName)[1:100];
		else
			bookingFieldValue := _cmif.getDiscrepValueFor(attributeName)[1:100];
		endif;
		tiFieldValue := self.getValueFromTI(_ti,attributeName)[1:100];
		createBookingRefDiscrepField(	bookingFieldValue,	//_bookingRefFieldValue : String;
										attributeName,	//_fieldName : String;
										tiFieldValue	//_tiFieldValue : String
										);
	endforeach;
	
	// PAR #29345 create a notification of this event so the event screen will show
	if self.myTerminal &lt;&gt; null then
		self.myTerminal.causeEvent(self.myTerminal.getTerminalEvent(EVENT_EVENT_TRANSACTION), false, self);
	elseif self.myEventType &lt;&gt; null then
		//no terminal so cause event on event type.
		self.myEventType.causeEvent(EVENT_EVENT_TRANSACTION, false, self);
	endif;
	// PAR #29345 end
	
epilog

	delete attributesToCheck;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_cmif" type="CMIF_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="setRemarksAndClosed" id="e5e215f2-363f-4051-8925-6adc60b2eb33">
