    <JadeMethod name="drawBaseLocation" id="6feffe9c-80c1-420a-8f40-9aa70cafdd30">
        <source>drawBaseLocation(_x1: Real; _y1: Real; _x2: Real; _y2: Real; _frame: Frame input; _scaleFactor: Real; _isLandscape: Boolean; _flipH: Boolean; _flipV: Boolean; _mode : Integer) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 March 2013	cnwndl1	Initial creation

*/

vars
	x1, y1,
	x2, y2			: Real;
	count : Integer;
	oldFontSize : Real;
	
begin

	x1 := _x1;
	y1 := _y1;
	x2 := _x2;
	y2 := _y2;

	self.gridPointsToElementPoints(x1, y1, x2, y2, _scaleFactor, _isLandscape, _flipH, _flipV);
	
	//19 July 2010	NDL	Par 24943
	if self.myLocationsController &lt;&gt; null and self.myLocationsController.isGap then
		return;
	endif;
	
	//25 Mar 2013	NDL	Par 31278
	if self.myLocationsController &lt;&gt; null and self.myLocationsController.isBoxcarCont then
		_frame.drawFillColor := CM_BoxcarVisit.BoxcarDrawColour;
	else
		_frame.drawFillColor := Gray;
	endif;
	
	_frame.drawFilledRectangle(x1, y1, x2, y2, Black);
	
	
epilog

end;</source>
        <access>protected</access>
