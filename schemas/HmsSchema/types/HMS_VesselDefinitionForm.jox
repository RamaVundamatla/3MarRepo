	//GD 05/03/01 Prevent unauthorised users from changing tidal class if ship has voyages
	if myCurrentVessel = null then
		return true;
	endif;

	/*if not hasWriteRights("CMS_HMS_ShipPilotRemarks") then 
		if selectedShip.allPermVoyages.size &gt; 0 then
		app.msgBox($MSGBOX_TidalClassChange, "Change Prohibited", MsgBox_Stop_Icon + MsgBox_OK_Only);
			return false;
		endif;
    endif;*/
    
    return true;
end;</source>
