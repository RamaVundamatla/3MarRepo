    <JadeMethod name="doOK" id="a2b8a3a9-2e8a-4983-b583-b039201261b6">
        <updating/>
        <source>doOK() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
09 January 2020		jlgzm1	Initial creation TFS 47920 Event Stream Admin JMT UI

*/

vars
	dateFrom	: Date;
	dateTo		: Date;
	timeFrom	: Time;
	timeTo		: Time;
	toTS		: TimeStamp;
	fromTS		: TimeStamp;
	replayId	: String;
	pxyRoot,		
	pushEventsRoot	: CM_PushEventsRoot;
	proc		: Process;
	answer		: Integer;
	
begin
	dateFrom 	:= txtDateFrom.getDate;
	dateTo 		:= txtDateTo.getDate;
	timeFrom 	:= txtTimeFrom.getTime;
	timeTo 		:= txtTimeTo.getTime;
	replayId	:= txtReplayId.text;
	
	if dateFrom = null then
		app.msgBox(app.getErrorString(Input_required_field_dateFrom), app.getString(Error), MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		return;
	elseif dateTo = null then
		app.msgBox(app.getErrorString(Input_required_field_dateTo), app.getString(Error), MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		return;
	endif;
	
	fromTS.setDate(dateFrom);
	fromTS.setTime(timeFrom);
	toTS.setDate(dateTo);
	toTS.setTime(timeTo);
	
	if fromTS &gt; toTS then
		app.raiseCMException(ERR_SHIFT_WRONG_TIME, null, null);
		return;
	endif;
	
	if toTS.date &lt;&gt; fromTS.date then
		answer := app.msgBox(app.getErrorString(Caution_replay_many_events),
				app.getErrorString(Caution), MsgBox_Yes_No + MsgBox_Exclamation_Mark_Icon);		
		if answer = MsgBox_Return_No then
			return;
		endif;
	endif;
	
	// Perform validation, start populate response
	pushEventsRoot := CM_PushEventsRoot.firstInstance();
	
	if pushEventsRoot = null then
		app.raiseCMException(Push_Events_not_running, null, null);
		return;
	endif;
	
	if not app.cnAppIsRunning('PortSchema', 'JMTPushEvents', null, proc) then
		app.raiseCMException(Push_Events_not_running, null, null);
		return;
	endif;
	
	pxyRoot := app.createUpdateProxy(pushEventsRoot).CM_PushEventsRoot;
	pxyRoot.setProxy(pxyRoot.configurationDetails, fromTS, toTS, replayId);
	
	if not app.myPassport.hasErrors then
		app.myTrxUA.trxUpdatePushEventsRoot(pxyRoot, app.myPassport);
	endif;
	
	inheritMethod();
	
epilog
	delete pxyRoot;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setFromDT" id="ceb5c7b7-a60a-465f-a6b7-4c8090d0ae48">
        <source>setFromDT(_date : Date; _time : Time);
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
16 December 2024		jlizm1	Initial creation MTN 19330 Events Stream restart from disabled time

*/

vars

begin
	self.txtTimeFrom.mask := "hh:mm:ss";
	
	self.txtDateFrom.setDate(_date);
	self.txtTimeFrom.setTime(_time);
	
epilog

end;</source>
        <Parameter name="_date" type="Date"/>
        <Parameter name="_time" type="Time"/>
    </JadeMethod>
    <JadeMethod name="setToDT" id="715270d8-7c20-4ef1-ada9-b4573871feb1">
        <source>setToDT(_date : Date; _time : Time);
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
16 December 2024		jlizm1	Initial creation MTN 19330 Events Stream restart from disabled time

*/

vars

begin
	self.txtTimeTo.mask := "hh:mm:ss";
	
	self.txtDateTo.setDate(_date);
	self.txtTimeTo.setTime(_time);
	
epilog

end;</source>
        <Parameter name="_date" type="Date"/>
        <Parameter name="_time" type="Time"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="4ca8fb04-49fc-4cf2-b6b0-36a06d9d0329">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
09 January 2020		jlgzm1	Initial creation
04 November 2024	navmd1	Default to now for the end date/time to reduce typing required to replay events
16 December 2024	jlizm1	MTN 19330 Events Stream restart from disabled time

*/

vars
	now		: TimeStamp;
	
begin
	inheritMethod();
	
	self.txtTimeFrom.mask := "hh:mm:ss";
	self.txtTimeTo.mask := "hh:mm:ss";

	if self.txtDateTo.textUser = null then //ignore if has already been initialized
		// Default to some sensible end date/time
		self.txtDateTo.setDate(now.date);
		self.txtTimeTo.setTime(now.time);
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="013999a7-3ddd-4057-84dc-3a3cfb49681e">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 February 2020 08:35:36.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0023883, locale);
	lblDateFrom.translateCaption(Xlat_0023884, locale);
	lblDateTo.translateCaption(Xlat_0023885, locale);
	lblInstructions.translateCaption(Xlat_0023886, locale);
	lblReplayId.translateCaption(Xlat_0023887, locale);
end;</source>
    </JadeMethod>
</GUIClass>
