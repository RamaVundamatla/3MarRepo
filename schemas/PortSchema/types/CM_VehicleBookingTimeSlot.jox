    <JadeMethod name="doEmailForBook" id="eebf926f-5b39-4f54-baf4-d0de8e1ca3d6">
        <source>doEmailForBook( _carrier : CM_Carrier );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 March 2015	cnwndl1	Initial creation	Par 35882

*/

vars

	fromAddress	: String;
	carrierAddresses : String;
	subject : String;
	body : String;

begin

	if _carrier &lt;&gt; null and not _carrier.allPINNotifyEmailAddresses.isEmpty then
		carrierAddresses := _carrier.allPINNotifyEmailAddresses.getAddresses;
	else
		return;
	endif;


	fromAddress := app.myRoot.getConfig(AutoSendersEmailAddress).String;
	subject := app.getErrorString1( VBS_New_Booking_Email_Subject, self.id);
	body := app.getErrorString2(VBS_New_Booking_Email_Body, self.id, self.bookingTSstart.asStringJMT );

	app.myUtilityCA.utlCreateEmailSendRequest(	true,	//_checkCanBeProcessed	: Boolean;
												subject,	//_alertDescription : String;
												carrierAddresses,	//_toAddress : String;
												fromAddress,	//_fromAddress : String;
												"",	//_ccAddresses : String;
												"",	//_bccAddresses : String;
												subject,	//_sendSubject : String;
												body,	//_sendMessage : String;
												null,	//_allAttachedFilePaths	: HugeStringArray;
												null,	//_allFileData : CM_FileDataStorageHdrSet input;
												null,	//_blob : Binary;
												null,	//_blobFileName : String;
												EmailSource_VBS,	//_sourceOfEmail : Integer;
												null,	//_updateCallbackObj : Object;
												app.myPassport	//_passport  : CM_Passport input
												);
												

epilog

end;</source>
        <Parameter name="_carrier" type="CM_Carrier"/>
    </JadeMethod>
