    <JadeMethod name="setFilterProductCode" id="bb3c4cdc-665e-4dcc-af00-34b90e5d273a">
        <updating/>
        <source>setFilterProductCode() updating;
//--------------------------------------------------------------
//Created: June 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	treatmentCode, typeCode, lengthCode : String;
begin

	if self.cmbSpecies.myObject = null then
		return;
	endif;
	//par 19293
	if self.cmbGrade.myObject = null then
		return;
	endif;
	
	if self.cmbTreatment.myObject &lt;&gt; null then
		treatmentCode := self.cmbTreatment.myObject.CM_LogTreatment.code;
	endif;
	if self.cmbType.myObject &lt;&gt; null then
		typeCode := self.cmbType.myObject.CM_LogType.code;
	endif;
	if self.cmbLength.myObject &lt;&gt; null then
		lengthCode := self.cmbLength.myObject.CM_LogLength.code;
	endif;
	
	self.filterProductCode := app.buildLogProductCode(self.cmbSpecies.myObject.CM_LogSpecies.code, 
												  	   self.cmbGrade.myObject.CM_LogGrade.code, 
												  	   typeCode,
												  	   treatmentCode,
												  	   lengthCode);

end;</source>
    </JadeMethod>
    <JadeMethod name="setForReleaseByVoyage" id="f9f50f84-50ff-4195-8fe0-1ff478f226a8">
        <source>setForReleaseByVoyage(_intFaceItem : LOGIF_BOLOut input) : Boolean;
//--------------------------------------------------------------
//Created: 22 October 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	hatch, place : Integer;
	pxyLogVoyCntrl : CM_LogVoyageController;
	realLogVoyCntrl : CM_VoyageController;	
begin
	hatch := _intFaceItem.hatch;
	place := _intFaceItem.place;
	_intFaceItem.myPlannedLocation := self.filterVoyage.myLogVoyageStructure.getLogVoyController(self.filterLot.lotNo, hatch, place);
	
	if _intFaceItem.myPlannedLocation = null then
		create pxyLogVoyCntrl transient;
		pxyLogVoyCntrl.setProxy(self.filterLot, self.filterVoyage.myLogVoyageStructure, hatch, place);
		app.myTrxCA.trxCreateVoyageController(pxyLogVoyCntrl, realLogVoyCntrl, app.myPassport);
		if (not app.myPassport.noErrors) then
			return false;
		else
			self.clearErrorWarnings();
		endif;
		_intFaceItem.myPlannedLocation := realLogVoyCntrl;		
	endif;

	_intFaceItem.myStevedore 		:= self.filterStevedore;
	_intFaceItem.myVoyage			:= self.filterVoyage;
	_intFaceItem.myLogLot			:= self.filterLot;
	if self.filterLot.myDischargePort &lt;&gt; null then
		_intFaceItem.dischargePort	:= self.filterLot.myDischargePort.code;
	endif;
	if self.filterLot.myConsignee &lt;&gt; null then	
		_intFaceItem.consignorCode	:= self.filterLot.myConsignee.code;
	endif;
	_intFaceItem.myConsignee := self.filterLot.myConsignee;
	return true;
epilog
	delete pxyLogVoyCntrl;
end;</source>
        <Parameter name="_intFaceItem" type="LOGIF_BOLOut" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setTableDataFromOrganiser" id="a1b6b24b-53ed-4b9b-b79d-9bf5e0bd0d4c">
        <updating/>
        <source>setTableDataFromOrganiser(_theTable: CM_DataTable input) updating;
// ---------------------------------------------------------------------------
// Created:     14 April 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	tmpTable  : CM_DataTable;
begin
	tmpTable := _theTable;
	
	tmpTable.rows := tmpTable.fixedRows;

	if tmpTable.myEntTableDef.name = ETDef_LocationDataLogs then
		self.showLogsInLocation();
	elseif  tmpTable.myEntTableDef.name = ETDef_LocationDataDocket then
		self.showDocketsInLocation();
	//elseif tmpTable.myEntTableDef.name = ETDef_ItemsOnBoard then 
		//self.filterOnBoard();
	elseif tmpTable.myEntTableDef.name = ETDef_NoNumberData then 
		self.showAllocRowsForNNData();
	endif;
	
	
	
	
	
end;</source>
        <Parameter name="_theTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
