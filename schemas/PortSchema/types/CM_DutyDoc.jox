    <JadeMethod name="validateCreate" id="ad35c4de-ec79-47e0-adff-c3fb1e4ef7e6">
        <source>validateCreate(_passport: CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 December 2012	cnwer1	Initial creation HAT 2189
02 September 2014   cnwma1  PAR# 34845 Container Filter by voyage 
*/

vars
	forwarder, consignee : CM_ConsigneeConsignor;
begin
	if self.myDutyDocTerminalRoot = null then
	// 	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Terminal) , null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Terminal) , null, null); // cnwdb2	PAR 35364
		return;
	endif;

	if self.invTerms = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "Inv Terms" , null, null);
		app.raiseCMException(Input_required_field_invTerms, null, null); // cnwdb2	PAR 35364
	endif;
		
	if self.type = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "Bill Type" , null, null);
		app.raiseCMException(Input_required_field_billType , null, null); // cnwdb2	PAR 35364
	endif;
	
	if self.voyage = null then												// PAR#34845
	//	app.raiseCMException1(REQUIRED_FIELD, "Voyage Code" , null, null); 
		app.raiseCMException(Input_required_field_VoyCode, null, null);  // cnwdb2	PAR 35364
	endif;
	
	// PAR 32897
	consignee:= self.getMyConsignee();
	if consignee &lt;&gt; null and consignee.hasExpired then
	 	app.raiseCMWarning2(Expiry_date_expired, consignee.licenseExpiryDate.asStringJMT(), consignee.description, null, null, null);
	endif;
	
	// PAR 32897
	forwarder := self.getMyForwarder();
	if forwarder &lt;&gt; null and  forwarder.hasExpired then
	 	app.raiseCMWarning2(Expiry_date_expired, forwarder.licenseExpiryDate.asStringJMT(), forwarder.description , null, null, null);
	endif;

	if self.isTransient then
		if self.getMyDebtor = null then
			app.raiseCMException1(Unable_charge_no_debtor, "", null, null);
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateDelete" id="2fa1e798-9429-4e06-84d9-91d3e75953f0">
        <source>validateDelete(_passport: CM_Passport input);
