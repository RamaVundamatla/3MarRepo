    <JadeMethod name="isShowingFilterResultsWithTask" id="c74f24d2-f75d-4006-aedb-2f8c6e1d8cbb">
        <source>isShowingFilterResultsWithTask(_rtQueueEntry : CM_RTQueueEntry; _allShownRTQueueEntries :  CM_RTQueueEntryArray io) :Boolean;
/*

Purpose:	check if showing filter results if so check if the entry is one of the ones that
			is being shown.
			
			Should of named this isShowingFilterResultsWithEntry but was 1 character to long

Parameters:			

Return Value:		


Date		Who		Reason
03 February 2011	cnwer1	Initial creation

*/

vars

begin
	return  self.myMachQEntryTableSynchAgent.isShowingFilterResultsWithTask(_rtQueueEntry,_allShownRTQueueEntries );
	
epilog

end;</source>
        <Parameter name="_rtQueueEntry" type="CM_RTQueueEntry"/>
        <Parameter name="_allShownRTQueueEntries" type="CM_RTQueueEntryArray" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadRTTableFromDTORTEntry" id="fd16c53d-bd15-4e0e-8be9-ad2f8bfe056b">
        <updating/>
        <source>loadRTTableFromDTORTEntry(_table: Table input; _object: Object input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 April 2010	cnwer1	Initial creation
02 Sep 2010 cnwer1 	PAR 25206
03 Dec 2012	NDL	Par 30261
*/

vars
	order,
	addedItem : Integer;
	addRTSortColumn,
	headerIsTopRow	: Boolean;
//	entTableView : EntTableView;
	dtoRTQueueEntry : DTO_RTQueueEntry;
	cmObject		: CM_Object;
	isVisible	: Boolean;
	tempEntTableView : EntTableView;
begin
	if self.myVMInterface = null then
		return;
	endif;

	if _object = null then
		return;
	endif;
	
	if _table = null then
		return;
	endif;
	
	if _object.isKindOf(DTO_RTQueueEntry) then
		dtoRTQueueEntry:=_object.DTO_RTQueueEntry;
	elseif _object.isKindOf(CM_Object) then
		cmObject:=_object.CM_Object;
	else
		return;
	endif;

	
	addRTSortColumn:= self.myVMInterface.sortTableInRTQueueOrder(_table);
	self.myVMInterface.getTableOrientation(_table,headerIsTopRow);
	//entTableView 	:= self.getEntTableView(_table);
	//03 Dec 2012	NDL	Par 30261	
	create tempEntTableView transient;
	self.getEntTableViewFromTable( _table, headerIsTopRow, tempEntTableView );
	
	if addRTSortColumn and dtoRTQueueEntry &lt;&gt; null then
		order:=self.myMachQEntryTableSynchAgent.getOrderOfDTOEntry(dtoRTQueueEntry);
		if order = 0 then
			return;
		endif;
	endif;
	
	isVisible:=true;
	if headerIsTopRow then
		_table.rows:=_table.rows + 1;
		addedItem:=_table.rows;
		if dtoRTQueueEntry &lt;&gt; null and self.myMachine.hasAllocatedQueueTasks() then
			if not self.myMachine.isQueueEntryAllocated(dtoRTQueueEntry.myRealQueueEntry.CM_RTQueueEntry) then
			//if dtoRTQueueEntry.myRealQueueEntry.CM_RTQueueEntry.findControlAllocatedTaskToMach(self.myMachine) = null then
				isVisible:=false;
			endif;
		endif;
	else
		_table.columns:=_table.columns + 1;
		addedItem:=_table.columns;
	endif;
	
	if dtoRTQueueEntry &lt;&gt; null then		
		//dtoRTQueueEntry.loadToTable(_table,entTableView,headerIsTopRow,addedItem,order,isVisible);
		dtoRTQueueEntry.loadToTable(_table,tempEntTableView,headerIsTopRow,addedItem,order,isVisible);
		return;
	endif;
	
	if cmObject &lt;&gt; null then
		//self.loadTableFromCMObject(_table,cmObject,entTableView,headerIsTopRow,addedItem);
		self.loadTableFromCMObject(_table,cmObject,tempEntTableView,headerIsTopRow,addedItem);
	endif;
	
epilog
	
end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_object" type="Object" usage="input"/>
    </JadeMethod>
    <JadeMethod name="loadRTTaskTable" id="d9ef14ee-a487-49fe-bfe8-2368366b70f4">
        <updating/>
        <source>loadRTTaskTable(_table: Table input; _startRTQueueEntry: CM_RTQueueEntry input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 April 2010	cnwer1	Initial creation
28 Jun 2010	cnwkpd1	PAR #24763 - Prevent 1090 and 14051 exceptions.  Ensure allAvailableRTQueueEntries
					is not populated with null objects
02 Sep 2010 cnwer1 	PAR 25206
14 Oct 2011	cnwer1	par 28458 - if the visible columns was changed well logged on need whole table to refresh otherwise get  14051, 14050 errors
*/

vars
	headerIsTopRow,
	onlyWorkingTasks : Boolean;
	dtoEntryArray   : DTO_RTQueueEntryArray;
	taskTableType 	: Integer;
	iter 			: Iterator;
	entView : EntTableView;
	
begin
	if self.myVMInterface = null then
		return;
	endif;
	taskTableType:=self.myVMInterface.getTableTaskType(_table);
	entView:=self.getEntTableView(_table);
	headerIsTopRow:=self.getHeaderTopRow(_table);

	if taskTableType = TASK_UNACTIONED then
		if headerIsTopRow then
			// -1 because with have a hidden column for the RT queue order 
			if _table.columns - 1 &lt;&gt; entView.allEntTableRows.size then
				_table.clear;
				self.setupTableHeadings(_table);
			endif;
		else
			if _table.rows &lt;&gt; entView.allEntTableRows.size then
				_table.clear;
				self.setupTableHeadings(_table);
			endif;
		endif;
	
		inheritMethod(_table, _startRTQueueEntry);	
	elseif (taskTableType = TASK_OFFERED and not self.showingTaskList) or
		(taskTableType = TASK_WORKING and not self.showingTaskList ) or
		(taskTableType = NULL_INTEGER and self.myMachine.hasWorkingTasks)	then
		//purge all available
		self.myMachQEntryTableSynchAgent.purgeEntries;
		self.allQueuedNoteInfo.purge;
		
		
		onlyWorkingTasks:=false;
		if taskTableType = TASK_WORKING or taskTableType = NULL_INTEGER then
			onlyWorkingTasks:=true;
		endif;
		
		create dtoEntryArray transient;
		self.myMachQEntryTableSynchAgent.setTableDetails(_table, entView,headerIsTopRow );
		self.myMachQEntryTableSynchAgent.doFindWorkingDTOEntries(dtoEntryArray,onlyWorkingTasks,_table);
		
	elseif taskTableType = TASK_WORKING and self.showingTaskList then
		create dtoEntryArray transient;
		self.myMachQEntryTableSynchAgent.setTableDetails(_table, entView, headerIsTopRow);
		self.myMachQEntryTableSynchAgent.doFindWorkingDTOEntries(dtoEntryArray,true,_table);

	endif; 		
	
	
epilog
	delete dtoEntryArray;
	delete iter;
end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_startRTQueueEntry" type="CM_RTQueueEntry" usage="input"/>
    </JadeMethod>
    <JadeMethod name="loadTableFromCMObject" id="ccb2cd30-6b60-4f45-ae5f-ced35daaedb8">
        <source>loadTableFromCMObject(_table : Table input; 
							_cmObject : CM_Object;
							_entView : EntTableView; 
							_headerTopRow : Boolean;
							_newPosition  : Integer) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 August 2010	cnwer1	Initial creation

*/

vars
	i : Integer;
	entTableRow : EntTableRow;
	cellText : String;
	highlightRed : Boolean;
	accessedRow	: JadeTableRow;
	accessedColumn	: JadeTableColumn;
begin

	i:=1;
	foreach entTableRow in _entView.allEntTableRows do

		cellText:=_cmObject.getDisplayStringForAttribute(entTableRow.name,false);
	
		highlightRed:=false;
		//textColour:=_table.getSystemColor(Table.Color_WindowText);
		if entTableRow.name = ETRow_Ostow then
			if cellText &lt;&gt; null then
				highlightRed:=true;
			endif;
		endif;
		
		if _headerTopRow then
			_table.accessCell(_newPosition,i).text:=cellText;
			if highlightRed then
				_table.accessCell(_newPosition,i).foreColor:=Red;
			endif;
			accessedRow:=_table.accessRow(_newPosition);
			accessedRow.itemObject:=_cmObject;
			accessedRow.fontBold:=false;
			accessedRow.marginTop:=2;
			accessedRow.marginBottom:=2;
			accessedRow.visible:=true;
		else
			_table.accessCell(i,_newPosition).text:=cellText;
			if highlightRed then
				_table.accessCell(i,_newPosition).foreColor:=Red;
			endif;
			accessedColumn:=_table.accessColumn(_newPosition);
			accessedColumn.itemObject:=_cmObject;
			accessedColumn.fontBold:=true;
			accessedColumn.marginLeft:=5;
			accessedColumn.marginRight:=5;
			accessedColumn.visible:=true;
		endif;
		i:=i+1;
	endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_cmObject" type="CM_Object"/>
        <Parameter name="_entView" type="EntTableView"/>
        <Parameter name="_headerTopRow" type="Boolean"/>
        <Parameter name="_newPosition" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="queryDisplayRTEntry" id="726a3a85-6432-4f78-a193-502ba4411ff1">
        <updating/>
        <source>queryDisplayRTEntry(_rtQueueEntry: CM_RTQueueEntry): Boolean updating;
/*

Date		Who		Reason
15 August 2014	cnwer1	Initial creation PAR

*/

vars
	result : Boolean;
	taskTableType : Integer;
begin
	result:= inheritMethod(_rtQueueEntry);
	if not result then
		return result;
	endif;
	
	if self.isWarehouseVMT then
		taskTableType:=self.myVMInterface.getTableTaskType(self.myMachQEntryTableSynchAgent.myTable);
		if taskTableType = TASK_UNACTIONED then
			if _rtQueueEntry.status &lt;&gt; TASK_UNACTIONED then
				return false;
			endif;
		endif;
	endif;
	
	return result;
//	if s

epilog

end;</source>
        <Parameter name="_rtQueueEntry" type="CM_RTQueueEntry"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="refreshTableEntry" id="8d7d0026-505b-4b1c-9ccd-d9ce5c30b6db">
        <updating/>
        <source>refreshTableEntry(_table: Table input; _rtQueueEntry: CM_RTQueueEntry) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 Jun 2010 cnwer1	Initial creation
01 Jul 2010 cnwer1	PAR 24748  
02 Sep 2010 cnwer1 	PAR 25206
14 Oct 2011	cnwer1	par 28458 - if the visible columns was changed well logged on need whole table to refresh otherwise get  14051, 14050 errors
*/

vars
	task 	: CM_RTQueueTask;
	tableTaskType : Integer;
	entView   : EntTableView;
	headerIsTopRow : Boolean;
	expectedColumns : Integer;
begin

	tableTaskType:=self.myVMInterface.getTableTaskType(_table);
	entView:=self.getEntTableView(_table);
	headerIsTopRow:=self.getHeaderTopRow(_table);
	if tableTaskType = TASK_UNACTIONED 
		and  headerIsTopRow then	
		expectedColumns:= _table.columns - 1;
		if  expectedColumns &lt;&gt; entView.allEntTableRows.size then
			self.loadRTTaskTable(_table,null);
			return;
		endif;	
	endif;
	
	
	
	inheritMethod(_table, _rtQueueEntry);
	
	if self.isWarehouseVMT then
		return;
	endif;
	
	//if this is not the task list table then return
	if tableTaskType &lt;&gt; TASK_UNACTIONED then
		return;
	endif;
	
	//epr CCMS 1395
	self.myMachQEntryTableSynchAgent.doSetAllocatedTasks(_table);
	
epilog

end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_rtQueueEntry" type="CM_RTQueueEntry"/>
    </JadeMethod>
    <JadeMethod name="resetMyOverstowRTEntry" id="811a5b81-2eda-4c41-99f7-c52879000275">
