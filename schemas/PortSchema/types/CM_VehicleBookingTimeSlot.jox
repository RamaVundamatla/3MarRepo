    <JadeMethod name="pxyCreateUpdateProxy" id="7fb64656-5370-46b1-bb7a-fe8dda7745b5">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			Creates an Update proxy for a CM_VehicleBookingTimeSlot

Parameters:			NONE

Return Value:		SelfType	The new proxy object we created with a type of this object

Date			Who		Reason
02 October 2014	cnwndl1	Initial creation
26/08/2022		navcs2	53899 EUP - SD - VBS MTN - [3] - Maintaining VBS Slot
08 Mar 2023		navpw1	TFS 54049 (56519) - Added setting of user below so we do not remove it on an update
13 Aug 2024		navcs2	ChangeRequest 63928: EUP | Trailer Type in a VBS Slot
*/

vars
	pxy				: CM_VehicleBookingTimeSlot;
	pxyItem,
	vbsItem 		: CM_VehicleBookingTimeSlotItem;
	completedOK		: Boolean;
begin

	pxy := inheritMethod();
	
	pxy.myVehicleBookingTerminal := self.myVehicleBookingTerminal;
	pxy.myVBTimeSlotType 		 := self.myVBTimeSlotType;
	pxy.myVehicleVisitRecord 	 := self.myVehicleVisitRecord;
	pxy.myCarrier 				 := self.myCarrier;
	pxy.mySubCarrier 			 := self.mySubCarrier;
	pxy.myVehicle 				 := self.myVehicle;
	pxy.myDriver 				 := self.myDriver;
	pxy.myTILCType				 := self.myTILCType;				// 13 Aug 2024		navcs2	ChangeRequest 63928

	if not self.allBookingRefs.isEmpty then
		self.allBookingRefs.copy(pxy.allBookingRefs);
	endif;
	if not self.allBulkReleases.isEmpty then
		self.allBulkReleases.copy(pxy.allBulkReleases);
	endif;

	if not self.allVehicleBookingItems.isEmpty then
		foreach vbsItem in self.allVehicleBookingItems do
			pxyItem := vbsItem.pxyCreateUpdateProxy();
			pxy.allVehicleBookingItems.add(pxyItem);
		endforeach;
	endif;
	
	completedOK := true;			
	return pxy;
	
epilog
	if not completedOK then			
		delete pxy;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="raiseAlert" id="b716be8a-0d74-4eab-935f-19db269b4068">
        <source>raiseAlert(	_detail : String );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 May 2013	cnwndl1	Initial creation	Par 31393
23 Apr 2025	navbs1	Bug MTN-34554: MTN | Vehicle Booking updated system alerts overflows so most of it cant be seen

*/

vars

	alert: CM_SystemAlert;
	setInTransState: Boolean;
	
begin

	if _detail = null then
		return;
	endif;
	
	if not process.isInTransactionState then
		setInTransState := true;
		beginTransaction;
	endif;
	create alert;
	//alert.details := app.getErrorString(Vehicle_booking_updated) &amp; CrLf &amp; _detail;
	alert.details := app.getErrorString(Vehicle_booking_updated) &amp; ". " &amp; _detail;			//23.04.2025 navbs1 #34554
	alert.addLogEntry(_detail);
	alert.setSeverity(SEVERE_INFO);
	alert.setMySystemAlertType(app.myRoot.allSystemAlertTypes[EVENT_AT_VehicleBookingUpdate]);
	alert.setLinkedTo( self );
	//-----------
	//Tell alert to add itself to system
	//-----------
	alert.add;
epilog
	if setInTransState then
		app.cmsCommitTransaction(app.myPassport);
	endif;
end;</source>
        <Parameter name="_detail" type="String"/>
    </JadeMethod>
    <JadeMethod name="removePxySlotItem" id="907359fa-4393-417d-bef8-c60d2b454143">
        <source>removePxySlotItem(_sequence : Integer);
/*

Purpose:			remove specified slot item proxy from collection so it will be deleted during update trx

Parameters:			

Return Value:		

Date				Who		Reason
29 June 2023		jlizm1	Initial creation TFS 53901 EUP VBS EDI

*/

vars
	item : CM_VehicleBookingTimeSlotItem;
	col : CM_VehicleBookingTSItemSet;
	itemToDelete : CM_VehicleBookingTimeSlotItem;
	
begin
	if _sequence = null then
		return;
	endif;
	
	create col transient;
	self.allVehicleBookingItems.copy(col);
	
	foreach item in col do
		if item.sequence &lt;&gt; _sequence then
			continue;
		endif;
		
		if item.pxyIsProxy then
			itemToDelete := item;
		endif;
		
		self.allVehicleBookingItems.remove(item);
		break;
	endforeach;
	
	if itemToDelete &lt;&gt; null then
		delete col;
		delete itemToDelete;
	endif;
	
epilog
	delete col;
	
end;</source>
        <Parameter name="_sequence" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="removeslotItemIfPresent" id="c91b3b3d-560c-4aa0-9d5b-3162c66930bb">
        <source>removeslotItemIfPresent(_pxyItem : CM_VehicleBookingTimeSlotItem);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Aug 2023 navhl20 Defect 59930: MTN - VBS Slot items are duplicated when performing EDI update 

*/

vars
	vbsItem : CM_VehicleBookingTimeSlotItem;
begin
	foreach vbsItem in self.allVehicleBookingItems do
		if vbsItem.sourceType = _pxyItem.sourceType and
		vbsItem.myTrackedItem = _pxyItem.myTrackedItem then
			if ((vbsItem.myBooking &lt;&gt; null and _pxyItem.myBooking &lt;&gt; null and vbsItem.myBooking.bookingReference = _pxyItem.myBooking.bookingReference) or 
			(vbsItem.myBookingItem &lt;&gt; null and _pxyItem.myBookingItem &lt;&gt; null and vbsItem.myBookingItem.description = _pxyItem.myBookingItem.description)) or
			((vbsItem.myBulkRelease &lt;&gt; null and _pxyItem.myBulkRelease &lt;&gt; null and vbsItem.myBulkRelease.code = _pxyItem.myBulkRelease.code) or 
			(vbsItem.myReserveDetails &lt;&gt; null and _pxyItem.myReserveDetails &lt;&gt; null and vbsItem.myReserveDetails.getDescription() = _pxyItem.myReserveDetails.getDescription())) then
				self.allVehicleBookingItems.remove(vbsItem);
			endif;
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_pxyItem" type="CM_VehicleBookingTimeSlotItem"/>
    </JadeMethod>
