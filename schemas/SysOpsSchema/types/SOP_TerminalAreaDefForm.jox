    <JadeMethod name="txtLabelGotFocus" id="d367f5cf-c728-4493-9ecc-7ce917d2e6f1">
        <updating/>
        <source>txtLabelGotFocus(control: CMUI_TextBox  input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 July 2009	cnwer1	Initial creation

*/

vars
	gridColumn	: SOP_GridColumn;
begin
	gridColumn:= control.userObject.SOP_GridColumn;
	if self.mode = self.Mode_Update or self.mode = self.Mode_Add then
		gridColumn.enableTxtLabel(true,control);
	else
		gridColumn.enableTxtLabel(false,control);
	endif;
epilog

end;</source>
        <Parameter name="control" type="CMUI_TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtLabelLostFocus" id="72ec2140-2461-4faa-8bc4-57c98cd0d11c">
        <updating/>
        <source>txtLabelLostFocus(control: CMUI_TextBox  input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 July 2009	cnwer1	Initial creation

*/

vars
	gridColumn	: SOP_GridColumn;
begin

	gridColumn:= control.userObject.SOP_GridColumn;
	if gridColumn.label &lt;&gt; control.text then
		self.areaChanged := true;
	endif;

	if control = gridColumn.txt40ftLabel then
		gridColumn.set40ftLabel(control.text);
	elseif control = gridColumn.txtLabel then
		gridColumn.label:=control.text;
	endif;
	
	gridColumn.drawSelf(null);
	gridColumn.enableTxtLabel(false,control);
epilog

end;</source>
        <Parameter name="control" type="CMUI_TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtLabelMouseDown" id="dbdc93dc-378d-4de5-8d82-fafa6d445014">
        <updating/>
        <source>txtLabelMouseDown(control: CMUI_TextBox  input; button : Integer; shift : Integer; x: Real;y :Real) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 August 2009	cnwer1	Initial creation

*/

vars

	gridColumn	: SOP_GridColumn;
	gridArea : CMUI_GridArea;
begin
	
	gridColumn:= control.userObject.SOP_GridColumn;
	gridArea:=gridColumn.myGridArea;
	gridArea.setSelected(0, gridColumn.column);
	if gridArea.isMultiRowColSelectEnabled() then	
		
		gridArea.doColumnSelection( gridColumn, button, shift, x, y );
	else
		gridColumn.handleMouseDownEvent(button, shift, x, y);
	endif;	

epilog

end;</source>
        <Parameter name="control" type="CMUI_TextBox" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
