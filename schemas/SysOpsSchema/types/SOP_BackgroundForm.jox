    <JadeMethod name="create" id="a8b05cf2-5e4c-413f-af04-ff085c6f9793">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	// TFS 2101 self.permissionView		:= PmBkGrndProcessMaint;
	self.permissionView		:= PmBkGrndProcessMaint;
	self.permissionMaint	:= PmBkGrndProcessView; // TFS 2101 this is reverse on purpose

	self.helpFileName := HelpFile_Admin;
end;</source>
