    <JadeMethod name="vp057_loadPlanning" id="3a52fbb6-2ed8-4938-bd9f-38870b7b2d71">
        <updating/>
        <source>vp057_loadPlanning() updating;
/*
Plan move containers to slots we found for them in the load CC. 
This needs to happen after we've assigned the cranes and created the ship jobs - the move
code here will link the containers up to 'work list entries' (the constituent entities of a job) automatically.
*/
vars
	ti				: CM_TrackedItem;
	slot			: CM_SlotController;
	idx				: Integer;
	moveController	: CMIF_MoveController;
begin
	app.logMessage(method.qualifiedName);
	
	create moveController transient;
	
	moveController.isSystemMove:=true;
	moveController.setMoveMode(PLANNING_MODE);
			
	foreach ti in allTrackedItems where ti.myPrimaryPlannedLocation = null do
		idx := idx + 1;
		slot := allLoadSlots[idx];//don't test anything - we want an array index out of bounds 
		
		moveController.setMyToPrimaryLocation(slot);
		moveController.setMyTrackedItem(ti);
		//reference set from previous loop inside trx we want to clear:
		moveController.mySlotRequest := null;
		moveController.setMyWorkListEntry(null);
		moveController.myRTQueueEntry := null;
		
		app.myPassport.setWarningsIgnored(true);
		app.myTrxUA.trxMoveTrackedItemAssignToJob(moveController, app.myPassport);
		assert(app.myPassport.trxCompletedOK, app.myPassport.allErrorWarnings);
		app.logMessage(method.qualifiedName &amp; ' load planned ' &amp; ti.id);
		allTrackedItems.remove(ti);
		if pauseAndStop(0) then return; endif;
	endforeach;
epilog
	delete moveController;
end;
</source>
    </JadeMethod>
    <JadeMethod name="vw001_doNextStep" id="d2c02319-838a-454c-b529-29c704204a94">
        <updating/>
        <source>vw001_doNextStep() updating;
//	Figure out what the next step is for this VoyageWorker, and do it.
//	Normally this would be nested foreach or iterator loops, but we need
//	to do exactly one "transaction" each time a timer fires. So we need to 
//	structure this method so it does one "transaction" per call.
constants
	VoyagesBeingWorked = 1;  // Change this as required. Two workers per voyage.
begin
//	app.logMessage(method.qualifiedName);
	if myJobSheet = null then
//		myVoyage := app.getMyTerminal.allVoyagesByCode.getAtKeyGtr(voyageCode, null);
		foreach myVoyage in app.getMyTerminal.allVoyagesByCode
		where   myVoyage.code[1:3] = 'PTN' and myVoyage.code &gt; voyageCode do
			if myVoyage.allJobSheets.size &gt;= 2 then
				if myVoyage.code[4:4].Integer mod VoyagesBeingWorked = (app.profileSequenceId div 2) mod VoyagesBeingWorked then
					break;  // found one
				endif;
			endif;
		endforeach;
		if myVoyage = null or myVoyage.code[1:3] &lt;&gt; 'PTN' then
			app.logMessage(method.qualifiedName&amp;" no more voyages after "&amp;voyageCode&amp;" &lt;=======================");
//			stop;
			return;
		endif;
		app.logMessage(method.qualifiedName&amp;" working voyage "&amp;myVoyage.code);
		voyageCode:=myVoyage.code;
		
		// this assumes there are two workers per voyage
		// this will require changes for more workers
		if app.profileSequenceId mod 2 = 0 then
			myJobSheet:=myVoyage.allJobSheets.first;
		else
			myJobSheet:=myVoyage.allJobSheets.last;
		endif;
		myPortainerCrane:=app.getMyTerminal.machines[myJobSheet.crane].CM_Crane;
		myJob:=null;
	endif;
	
	if myJob = null then
		myJob:=zQueueNextJob;  // skips completed ones
		if myJob = null then  // finished all jobs for this voyage
			app.logMessage(method.qualifiedName&amp;" finished voyage "&amp;myVoyage.code);
			myJobSheet:=null;
//			voyageCode:=myVoyage.code[1:3]&amp;(myVoyage.code[4:4].Integer+1).pad(4);  // set to next voyage code
			vw001_doNextStep;  // recursion!
		else
			myRTQueueEntry:=null;
//			app.logMessage(method.qualifiedName&amp;" working job "&amp;myJob.id);
		endif;
		return;  // queuing a job counts as a transaction
	endif;
	
	if myRTQueueEntry = null or not app.isValidObject(myRTQueueEntry) then  // they get deleted behind our back
		myRTQueueEntry := myJob.allEntries.last;
		if myRTQueueEntry = null then  // finished all queues for this job
			app.logMessage(method.qualifiedName&amp;" finished job "&amp;myJob.id);
			myJob:=null;
			vw001_doNextStep;  // recursion!
			return;
		endif;
//		app.logMessage(method.qualifiedName&amp;" working queue entry "&amp;myRTQueueEntry.id);
	endif;

	if myJob.jobType = JOB_TYPE_LOAD then
		zDoLoadTask;
	elseif myJob.jobType = JOB_TYPE_DISCHARGE then
		zDoDischargeTask;
	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="zAllocatePortainerCrane" id="1e76a24a-ee47-424b-be4b-d47eb77c6c65">
        <updating/>
        <source>zAllocatePortainerCrane() updating;
/*
This will need to be called from startup(2) as we want one portainer crane per user.

Thought: No harm in the first user who does all the EDI loading and voyage planning to then start working with
a crane along with the rest? 

*/
vars
	cmif_Machine	: CMIF_Machine;
	newMachine		: CM_Machine;
	pxyCrane		: CM_Crane;
	craneCode		: String;
	pxyJobType,
	jobType			: CM_JobType;
	seedNum,i		: Integer;
	laneArray		: IntegerArray;
	pxyTa,
	ta				: CM_CraneTransferArea;
	cmifTA			: CMIF_TerminalArea;
	h,s,l,r,g,b,
	colour			: Integer;
	now				: TimeStamp;
begin
	foreach i in 1 to 999 do
		craneCode := 'J' &amp; i.pad(3);
		if app.getMyTerminal.machines[craneCode] = null then  // found an available code
			break;
		endif;
	endforeach;

	create cmif_Machine transient;
	cmif_Machine.code 						:= craneCode;
	cmif_Machine.description 				:= 'Portainer crane JBL ' &amp; craneCode;
    cmif_Machine.machineType 				:= app.myRoot.allMachineTypes[MACHINETYPE_PORTAINER_CRANE];
    
	h := (now.time.milliSecond /4).Integer.max(240);
	s := (now.time.second * 4).Integer;
	l :=(now.time.minute * 4).Integer;
	app.convertHSLtoRGB(h,s,l,r,g,b);
	if self.allPortainerCranes.size mod 2 = 0 then
		colour := app.convertRGBToColor(r,g,b);
	else
		colour := app.convertRGBToColor(b,r,b);
	endif;
	
  	cmif_Machine.colour 					:= colour;
	cmif_Machine.available 					:= true;
    cmif_Machine.canLift40Foot 				:= true;
    cmif_Machine.canTwinLift 				:= false;
    cmif_Machine.maxLiftWeight 				:= null;
    cmif_Machine.maxStackHeightMT 			:= null;
    cmif_Machine.maxStackHeightFull 		:= null;
    cmif_Machine.isNotAvailableForEntry		:= false;
	cmif_Machine.myRFIDTag					:= null;
	
	//Job types must be set on the crane for auto-job creation to succeed further along
	//I've choosen not to assume they will exist. But note we can't delete found ones and rebuild, as they
	//may already be associated with other users' cranes.
	jobType := app.myRoot.allJobTypes['BOOM UP'];
	if jobType = null then
		delete pxyJobType;
		create pxyJobType transient;
		pxyJobType.setProxy('BOOM UP', false, 0, 1);
		app.myTrxCA.trxCreateJobType(pxyJobType, jobType, app.myPassport);
		self.assert(app.myPassport.trxCompletedOK, app.myPassport.allErrorWarnings);
	endif;
	cmif_Machine.allHatchJobTypes.putAtKey(CM_Crane.HatchJobType_BoomUp, jobType);
	
	
	jobType := app.myRoot.allJobTypes['REMOVE C LID'];
	if jobType = null then
		delete pxyJobType;
		create pxyJobType transient;
		pxyJobType.setProxy('REMOVE C LID', true, 0, 1);
		app.myTrxCA.trxCreateJobType(pxyJobType, jobType, app.myPassport);
		self.assert(app.myPassport.trxCompletedOK, app.myPassport.allErrorWarnings);
	endif;
	cmif_Machine.allHatchJobTypes.putAtKey(CM_Crane.HatchJobType_LidRemove, jobType);
	
	jobType := app.myRoot.allJobTypes['REPLACE C LID'];
	if jobType = null then
		delete pxyJobType;
		create pxyJobType transient;
		pxyJobType.setProxy('REPLACE C LID', true, 0, 1);
		app.myTrxCA.trxCreateJobType(pxyJobType, jobType, app.myPassport);
		self.assert(app.myPassport.trxCompletedOK, app.myPassport.allErrorWarnings);
	endif;
	cmif_Machine.allHatchJobTypes.putAtKey(CM_Crane.HatchJobType_LidReplace, jobType);
	
	//they each need their own crane transfer area too - sigh...
	ta := app.getMyTerminal.allTerminalAreasByTypeId[TA_TYPE_CRANE_TRANS, craneCode &amp; 'TA'].CM_CraneTransferArea;//user same code for ta
	if ta = null then
		create cmifTA transient;
		create pxyTa transient;
		create laneArray transient;
		laneArray.add(1);
		
		/*pxyTa.setProxy(craneCode &amp; 'TA',
						'JBL Created',
						TA_TYPE_CRANE_TRANS,
						null,
						'Crane Transfer Area',
						1,
						laneArray,
						true,
						app.getMyTerminal(),
						false,
						false,
						true);/**/
		cmifTA.myPxyTerminalArea := pxyTa;
		app.myPassport.setWarningsIgnored(true);
		//app.myTrxCA.trxCreateTerminalArea(cmifTA.myPxyTerminalArea, cmifTA.myTerminalArea, true, app.myPassport);
		//app.myTrxCA.trxCreateTerminalArea(cmifTA, true, app.myPassport);
		self.assert(app.myPassport.trxCompletedOK, app.myPassport.allErrorWarnings);
		ta := cmifTA.myTerminalArea.CM_CraneTransferArea;
	endif;
	
    cmif_Machine.craneTransferArea	 		:= ta;
	cmif_Machine.targetRatePH	 			:= ((60000 /self.millisecondsForPickupSetDown) * 60).Integer;
	seedNum := self.allPortainerCranes.size + 1;
	cmif_Machine.craneJobSeed		 		:= seedNum * 100;
	//cmif_Machine.hasRadioTelemetry 		:= theTable2.getValueByName(ETRow_HasRadioTelemetry).Boolean;
    //cmif_Machine.networkAddress 			:= theTable2.getValueByName(ETRow_NetworkAddress).String;
    //cmif_Machine.requiresAvailabilityCode := theTable2.getValueByName(ETRow_RequireAvailabilityCode).Boolean;
    cmif_Machine.recordActivityHistory 		:= true;
    //cmif_Machine.maxRejectedTasks 		:= theTable2.getValueByName(ETRow_MaxRejectedTasks).Integer;
    //cmif_Machine.useRTForPickup 			:= theTable2.getValueByName(ETRow_UseRTforPickup).Boolean;
    //cmif_Machine.useRTForPickupSetdown 	:= theTable2.getValueByName(ETRow_UseRTforPickupSetdown).Boolean;
    //cmif_Machine.canWeigh 					:= false;
    
	newMachine := app.getMyTerminal.machines[craneCode].CM_Crane;
	
	if newMachine &lt;&gt; null then
		beginLoad;
		pxyCrane := newMachine.pxyCreateUpdateProxy().CM_Crane;
		endLoad;
		pxyCrane.setProxyFromCMIF_Machine(cmif_Machine, app.myPassport);
		app.myTrxUA.trxUpdateMachine(pxyCrane, app.myPassport);
	else
		create pxyCrane transient;
		pxyCrane.setProxyFromCMIF_Machine(cmif_Machine, app.myPassport);
		app.myTrxCA.trxCreateMachine(pxyCrane, newMachine, app.myPassport);
	endif;
	
	self.assert(app.myPassport.trxCompletedOK, app.myPassport.allErrorWarnings);
	self.allPortainerCranes.add(newMachine.CM_Crane);
	
	beginTransaction;
	if (CM_VoyageQueue.hasInstance(newMachine.myPrimaryQueue)) then
		delete newMachine.getPropertyValue('myPrimaryCraneQueue').Object;
	endif;
	
	//self.myPortainerCrane.allQueues.purge();
	//
	//delete self.myPortainerCrane.getPropertyValue('myPrimaryMachineQueue').Object;
	//delete self.myPortainerCrane.getPropertyValue('myPrimaryQueue').Object;
	
	commitTransaction;
	app.logMessage(method.qualifiedName&amp;" using "&amp;newMachine.description);
epilog
	delete pxyTa;
	delete laneArray;
	delete cmif_Machine;
	delete pxyJobType;
	delete pxyCrane;
end;
</source>
    </JadeMethod>
    <JadeMethod name="zArchiveVoyage" id="c10ecd46-143c-42f1-9207-81195d2b76c4">
        <source>zArchiveVoyage();
// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	departureDT	: TimeStamp;
	archiveInt	: CMIF_ArchiveVoyage;
begin
	if not app.isValidObject(myVoyage) then  // someone else has deleted it
		return;
	endif;
	app.logMessage(method.qualifiedName&amp;" archiving voyage "&amp;myVoyage.code);

	//to ensure the 'before "now"' comparison in archive validation below succeeds (must be value greater than arrival date though (which would be a few minutes ago)
	departureDT := app.actualTimeServer();// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	departureDT.time.setTime(departureDT.time.hour, departureDT.time.minute, departureDT.time.second -1,000);
	beginTransaction;
	self.myVoyage.setPropertyValue('departedDT', departureDT);
	commitTransaction;
	
	//archive the voyage
	create archiveInt transient;
	archiveInt.removeEDITrackedItems			:=	true;
	archiveInt.removeNonWorkedTrackedItems		:=	true;
	archiveInt.removePreNotifiedTrackedItems	:=	true;
	archiveInt.removeTBATrackedItems			:=	true;
	
	archiveInt.allVoyages.add(self.myVoyage);
	app.myPassport.setWarningsIgnored(true);
	
	app.myTrxUA.trxUpdateVoyageArchive(archiveInt, app.myPassport);
	assert(app.myPassport.trxCompletedOK, app.myPassport.allErrorWarnings);
epilog
	delete archiveInt;
end;
</source>
    </JadeMethod>
    <JadeMethod name="zCleanUpShip" id="71997976-6336-4ec1-8245-9c7a6536b759">
        <updating/>
        <source>zCleanUpShip() updating;
//	myVoyage is not valid until vp005_setVoyageData
vars
	ti			: CM_TrackedItem;
	globVoy		: CM_VoyageGlobal;
	jobSheet	: CM_JobSheet;
	job			: CM_Job;
begin
	if not app.isValidObject(myVoyage) then
		return;
	endif;
	if voyageDefinitionComplete then
		app.logMessage(method.qualifiedName&amp;" voyage "&amp;myVoyage.code&amp;" definition completed - no cleanup");
		return;
	endif;
	app.logMessage(method.qualifiedName&amp;" cleaning up voyage "&amp;myVoyage.code);
	app.isGarbageCollectionProcess := true;
	
	beginTransaction;
	
	foreach jobSheet in myVoyage.allJobSheets do
		foreach job in jobSheet.allJobsByOrder do
			//job.erase(NORMAL_ERASE);
		endforeach;
	endforeach;
	
	foreach ti in myVoyage.allOnshipTIsByCargoTypeId do
		ti.allPlannedFutureMoves.purge();
		ti.allQueuedFutureMoves.purge();
		ti.erase(NORMAL_ERASE);
	endforeach;
	
	foreach ti in myVoyage.allOnsiteTIsByCargoTypeId where (not ti.isChild) do
		ti.allPlannedFutureMoves.purge();
		ti.allQueuedFutureMoves.purge();
		app.logMessage(class.name &amp; '::' &amp; method.name &amp; ' deleting onsite TI ' &amp; ti.id);
		ti.erase(NORMAL_ERASE);
	endforeach;
	
	voyageCode:=myVoyage.code;
	delete myVoyage;
	
	foreach globVoy in CM_VoyageGlobal.instances where globVoy.code = voyageCode do
		if app.isValidObject(globVoy) then  // may be in the process of being deleted
			delete globVoy;
		endif;
	endforeach;
	
	commitTransaction;
end;
</source>
    </JadeMethod>
    <JadeMethod name="zCleanUpTIsAndCranes" id="7a9e847a-8ffa-4cd1-8c0e-1671b34846ce">
        <updating/>
        <source>zCleanUpTIsAndCranes() updating;

vars
	ti:CM_TrackedItem;
	crane:Object;
begin
	app.logMessage(method.qualifiedName&amp;" cleaning up "&amp;allTrackedItems.size.String&amp;" ti's and "
					&amp;allPortainerCranes.size.String&amp;" portainer cranes");
	//move tracked items offsite
	myMoveController.isForcedMove 	:= true;
	myMoveController.isSystemMove 	:= true;
	myMoveController.setMoveMode(REAL_MODE);
	app.isGarbageCollectionProcess := true;
	
	foreach ti in allTrackedItems do
		beginTransaction;
		//ti.allStops.purge();
		ti.allToDoTasksToDo.purge();
		myMoveController.setMyTrackedItem(ti);
		
		app.myPassport.warningsAcknowledged := true;
		app.myPassport.setWarningsIgnored(true);
		
		app.myUtilityUA.utlUpdateMoveTrackedItem(myMoveController, app.myPassport);
		commitTransaction;
		//self.assert(app.myPassport.trxCompletedOK, app.myPassport.allErrorWarnings);
		app.doWindowEvents(10);//let notification out
	endforeach;

	beginTransaction;
	foreach crane in allPortainerCranes do
		crane.CM_Crane.allQueues.purge;
	endforeach;
	commitTransaction;
	
epilog
	app.isGarbageCollectionProcess := false;
end;
</source>
    </JadeMethod>
    <JadeMethod name="zDoDischargeTask" id="0a7b3513-51e7-46b2-9a0e-321342276999">
        <updating/>
        <source>zDoDischargeTask() updating;
/*
RTG crane picks up container
Sets it down on an IMV (internal move vehicle)
IMV takes it over to the crane transfer area
'Ship lander' app (guy with hand held keys in details
Portainer crane pick up container and sets it down in the correct slot
*/
vars
	wle				: CM_WorkListEntry;
	ti				: CM_TrackedItem;
	rtQueueTask		: CM_RTQueueTask;
	targetLocation	: CM_LocationsController;
	prefix:String;
begin
	prefix:=method.qualifiedName&amp;' '&amp;myRTQueueEntry.id.padBlanks(17);
	rtQueueTask:=myRTQueueEntry.allTasks.last;
//	app.logMessage(method.qualifiedName&amp;' working task ' &amp; rtQueueTask.getName());
	if CM_RTGLaneController.hasInstance(rtQueueTask.targetLocation) then
		//portainer crane moves container from ship to IMV
		self.zMachineAcceptTask(self.myIMV, rtQueueTask);
	
		myMoveController.setJobForMove(null);
		myMoveController.isRTMultiMove := true;
		myMoveController.setMyWorkListEntry(myRTQueueEntry.myWorkListEntry);		
		myMoveController.setMoveMode(REAL_MODE);
		myMoveController.setMyTrackedItem(rtQueueTask.ti);
		myMoveController.isRadioTelemetryMove := true;
		myMoveController.setMyMachine(myPortainerCrane);
		myMoveController.setMyToPrimaryLocation(self.myIMV.myMachineController);
		myMoveController.isForcedMove := true;
		myMoveController.myRTQueueEntry := myRTQueueEntry;
		app.logMessage(prefix&amp;' Moving from ship to IMV ' &amp; rtQueueTask.ti.id);
		app.myPassport.setWarningsIgnored(true);
		app.myTrxUA.trxMoveTrackedItem(myMoveController, app.myPassport);
		self.assert(app.myPassport.trxCompletedOK, app.myPassport.allErrorWarnings);
	
	elseif rtQueueTask.taskType = TASK_PICKUP then //target location will be a CM_RTGLaneController - picking up off the IMV and setting down in an RTG controller
		app.logMessage(prefix&amp;' RTG Picking up from IMV' &amp; rtQueueTask.ti.id);
		self.zMachineAcceptTask(self.myRTGCrane, rtQueueTask);
		self.assert(app.myPassport.allErrorWarnings.isEmpty, app.myPassport.allErrorWarnings);

	elseif rtQueueTask.taskType = TASK_SETDOWN then
		ti := rtQueueTask.ti;
		wle := myRTQueueEntry.myWorkListEntry;
		targetLocation := rtQueueTask.targetLocation;
		self.assert(CM_RTGController.hasInstance(targetLocation), rtQueueTask);
		
		//self.myIMV.executeSetDownShipLander(rtQueueTask);//N.B rtQueueTask gets deleted in here
		//self.myPortainerCrane.releaseToShip(ti, wle, targetLocation);
		//myMoveController.setJobForMove(null);
		//myMoveController.isRTMultiMove := true;
		myMoveController.setMyWorkListEntry(wle);		
		myMoveController.setMoveMode(REAL_MODE);
		myMoveController.setMyTrackedItem(ti);
		myMoveController.isRadioTelemetryMove := true;
		myMoveController.setMyMachine(self.myRTGCrane);
		myMoveController.setMyToPrimaryLocation(targetLocation);
		myMoveController.isForcedMove := true;
		myMoveController.myRTQueueEntry := myRTQueueEntry;
		
		app.logMessage(prefix&amp;' RTG setting down ' &amp; rtQueueTask.ti.id);
		
		app.myPassport.setWarningsIgnored(true);
		app.myTrxUA.trxMoveTrackedItem(myMoveController, app.myPassport);
		self.assert(app.myPassport.trxCompletedOK, app.myPassport.allErrorWarnings);

		if pauseAndStop(0) then return; endif;
	
		//move offsite
		delete myMoveController;
		create myMoveController transient;
		myMoveController.isForcedMove 	:= true;
		myMoveController.isSystemMove 	:= true;
		myMoveController.setMoveMode(REAL_MODE);
		//move onsite tracked items offsite
		
		beginTransaction;
		//tmpMoveController.setMyToPrimaryLocation(null); // OFFSITE
		//ti.allStops.purge();
		ti.allToDoTasksToDo.purge();
		myMoveController.setMyTrackedItem(ti);
		app.myUtilityUA.utlUpdateMoveTrackedItem(myMoveController, app.myPassport);
		commitTransaction;
		self.assert(app.myPassport.trxCompletedOK, app.myPassport.allErrorWarnings);
	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="zDoLoadTask" id="38fbabaa-da93-47b8-a1d5-83d1c16ac3d6">
        <source>zDoLoadTask();
/*
RTG crane picks up container
Sets it down on an IMV (internal move vehicle)
IMV takes it over to the crane transfer area
'Ship lander' app (guy with hand held keys in details
Portainer crane pick up container and sets it down in the correct slot
*/
vars
	wle				: CM_WorkListEntry;
	ti				: CM_TrackedItem;
	rtQueueTask		: CM_RTQueueTask;
	targetLocation	: CM_LocationsController;
	histEntry 		: CM_MachineMoveHistory;	
	moveTransaction : CM_Move;
	isOverStow		: Boolean;
	prefix:String;
begin
	prefix:=method.qualifiedName&amp;' '&amp;myRTQueueEntry.id.padBlanks(17);
	rtQueueTask:=myRTQueueEntry.allTasks.last;
//	app.logMessage(method.qualifiedName&amp;' working task '&amp;myRTQueueEntry.id&amp;' ' &amp; rtQueueTask.taskDescription);
	if CM_RTGLaneController.hasInstance(rtQueueTask.targetLocation) then
		if rtQueueTask.isFirstTask then
			app.logMessage(prefix&amp;' RTG accepting task ' &amp; rtQueueTask.getName());
			self.zMachineAcceptTask(self.myRTGCrane, rtQueueTask);

		else//already picked it up - set it down on IMV
			self.zMachineAcceptTask(self.myIMV, rtQueueTask);
			myMoveController.setJobForMove(null);
			myMoveController.isRTMultiMove := true;
			myMoveController.setMyWorkListEntry(myRTQueueEntry.myWorkListEntry);		
			myMoveController.setMoveMode(REAL_MODE);
			myMoveController.setMyTrackedItem(rtQueueTask.ti);
			myMoveController.isRadioTelemetryMove := false;
			myMoveController.setMyMachine(self.myRTGCrane);
			myMoveController.setMyToPrimaryLocation(self.myIMV.myMachineController);
			myMoveController.isForcedMove := true;
			myMoveController.myRTQueueEntry := myRTQueueEntry;
			app.logMessage(prefix&amp;' RTG moving to IMV ' &amp; rtQueueTask.ti.id);
		
			app.myPassport.setWarningsIgnored(true);
			app.myTrxUA.trxMoveTrackedItem(myMoveController, app.myPassport);
			self.assert(app.myPassport.trxCompletedOK, app.myPassport.allErrorWarnings);
		endif;

	elseif CM_SlotController.hasInstance(rtQueueTask.targetLocation) then
		beginTransaction;
		ti := rtQueueTask.ti;
		wle := myRTQueueEntry.myWorkListEntry;
		targetLocation := rtQueueTask.targetLocation;
		app.logMessage(prefix&amp;' IMV executing set down of ' &amp; ti.id);
		//////////////////////////////////////////////////////////////////////////////////////////
		//self.myIMV.executeSetDownShipLander(rtQueueTask);//N.B rtQueueTask gets deleted in here
		app.setServerTimestampAtTrxStart(null); // ### TFS 52639 21Mar2022 NAVPW1
		//exclusiveLock(self.myIMV);
		//exclusiveLock(rtQueueTask);
		//exclusiveLock(rtQueueEntry);
		//This is the set-down task
		//histEntry := self.myIMV.addMoveToHistory(rtQueueTask);
		rtQueueTask.intendedMachine := null;
		isOverStow := rtQueueTask.isOverstowTask;
		app.myPassport.clearErrorsWarnings();
		
		//moveTransaction := ti.moveToLocation(targetLocation, null, wle, self.myIMV, REAL_MODE, true, true, isOverStow, false, false,  false, null,null,app.myPassport);		// TFS 2651
		moveTransaction := ti.moveToLocation(targetLocation, null, wle, self.myIMV, REAL_MODE, true, true, isOverStow, false, false,  false, null,null,null,null,null,app.myPassport);	// TFS 2651
		
		histEntry.setMyMoveTransaction(moveTransaction);	
		self.assert(app.myPassport.allErrors.isEmpty, app.myPassport.allErrorWarnings);
		if global.isValidObject(rtQueueTask) then
			// Disestablish reference to task so overstow tasks can be picked up
			rtQueueTask.setMachine(null);
		endif;
	 
		//Nothing else to do in same entry. Quit (99% of cases)
		self.myIMV.setMachineStatus(STATUS_IDLE  , "", false);
		
		////////////////////////////////////////////////////////////////////////////////////////
//		app.logMessage(prefix&amp;' Releasing to ship ' &amp; ti.id);
		myPortainerCrane.releaseToShip(ti, wle, targetLocation);
		self.assert(app.myPassport.allErrorWarnings.isEmpty, app.myPassport.allErrorWarnings);
//		if (self.allTrackedItems.includes(ti)) then
//			self.allTrackedItems.remove(ti);
//		endif;
		
		commitTransaction;
	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="zMachineAcceptTask" id="aa75dce2-7c00-44c8-866f-7dc67c063841">
        <source>zMachineAcceptTask(_machine : CM_Machine input; _rtQueueTask : CM_RTQueueTask input);

vars
	status			: Integer;
begin
	beginTransaction;
	app.myPassport.setWarningsIgnored(true);
	app.myUtilityUA.utlUpdateMachineStatus(_machine, STATUS_ASSIGNED, null, false, app.myPassport);
	self.assert(app.myPassport.allErrors.isEmpty, app.myPassport.allErrorWarnings);
	status := _rtQueueTask.status;
	_rtQueueTask.setMachine(_machine);
	while _rtQueueTask.status &lt; TASK_ACCEPTED do
		//_rtQueueTask.setStatus(status, null);
		status:=status+1;
	endwhile;
	self.assert(app.myPassport.allErrors.isEmpty, app.myPassport.allErrorWarnings);
	commitTransaction;
end;
</source>
        <Parameter name="_machine" type="CM_Machine" usage="input"/>
        <Parameter name="_rtQueueTask" type="CM_RTQueueTask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="zQueueNextJob" id="fb5862f6-cbde-4cfd-9931-13264ac9277b">
        <updating/>
        <source>zQueueNextJob():CM_Job updating;

vars
	job				: CM_Job;
	wle				: CM_WorkListEntry;
	wleArray,
	wleWarnings		: CM_WLEArray;
begin
//	app.logMessage(method.qualifiedName);

	create wleArray transient;
	create wleWarnings transient;
	foreach job in myJobSheet.allJobsByOrder where job.status &lt;&gt; JOB_COMPLETE
	and job.jobId[11:3] &lt;&gt; "206"
	and job.jobId[11:3] &lt;&gt; "208"
	and job.jobId[11:3] &lt;&gt; "210"
	and job.jobId[11:3] &lt;&gt; "228"
	and job.jobId[11:3] &lt;&gt; "230"
	and job.jobId[11:3] &lt;&gt; "234"
	and job.jobId[11:3] &lt;&gt; "236"
	and job.jobId[11:3] &lt;&gt; "238" do
		//queue the job
		foreach wle in job.workListEntries do
			if wle.status &lt;&gt; WLE_COMPLETED and wle.allRTQueueEntries.isEmpty then
				wleArray.add(wle);
			endif;
		endforeach;
		
		if (not wleArray.isEmpty) then
			app.myPassport.setWarningsIgnored(true);
			app.logMessage(method.qualifiedName&amp;' Queueing job ' &amp; job.id);
			app.myTrxUA.trxUpdateWLEsDoMove(wleArray, wleWarnings, QUEUE_MODE, true, null, app.myPassport);
			self.assert(app.myPassport.trxCompletedOK, app.myPassport.allErrorWarnings);
			return job;
		endif;
		
		if job.jobType = JOB_TYPE_USER then
			//hatch lid job. Purely an entry to advise the users - no application code associated with their completion
			beginTransaction;
			app.setServerTimestampAtTrxStart(null); // ### TFS 52639 21Mar2022 NAVPW1
			job.changeStatus(JOB_COMPLETE);
			job.rebuildStatus();
			commitTransaction;
		endif;
	endforeach;
	return null;  // send back indicator to get next voyage
epilog
	delete wleArray;
	delete wleWarnings;
end;
</source>
        <ReturnType type="CM_Job"/>
    </JadeMethod>
</Class>
