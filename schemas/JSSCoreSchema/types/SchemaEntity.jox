<Class name="SchemaEntity">
    <JadeMethod name="jssGetModifyTimeStamp" id="39020f96-7131-4ec0-9311-e7ad82b72b16">
        <source>jssGetModifyTimeStamp():TimeStamp;
// --------------------------------------------------------------------------------
// Created:		24 April 2003 by cnwdad1
//
// Purpose:		Returns a timestamp for when the receiver was last modified, or the
//				creation date if the receiver has not been modified before.
//
// Parameters:	None
//
// Returns:		The timestamp of the last modification.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if modifiedTimeStamp = null then
		return creationTime();
	endif;

	return modifiedTimeStamp;
end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
</Class>
