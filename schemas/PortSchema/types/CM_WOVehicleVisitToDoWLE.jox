<Class name="CM_WOVehicleVisitToDoWLE" id="6a1b7109-79ed-48d7-ada5-4e2e4988789a">
    <superclass name="CM_WOToDoWLE"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <ExplicitInverseRef name="myVehicleVisit" id="670617a5-b2c3-4c6d-bb49-647571ff0720">
        <transientToPersistentAllowed/>
        <embedded/>
        <type name="CM_VehicleVisitRecord"/>
        <access>readonly</access>
        <Inverse name="CM_VehicleVisitRecord::allWorkOrderWLEs"/>
    </ExplicitInverseRef>
    <JadeMethod name="addToDoTask" id="ea40260b-aeaf-4e45-8993-ec2081a34097">
        <updating/>
        <source>addToDoTask() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
23 November 2022	navcs2	ChangeRequest 56691:[56120] EUP - Allow Completing ToDo Work order tasks at Complete ToDo Task Screen

*/

vars
	toDoDesc 		: CM_ToDoTaskDesc;
	vvTask			: CM_ToDoTask;
	passport 		: CM_Passport;
	
begin
	
	if self.myVehicleVisit = null then
		//throw error
		return;
	endif;
	
	passport := app.myPassport;
	
	toDoDesc := self.job.CM_WOToDoTaskJob.myToDoTaskDesc;

	if vvTask = null then //add task
		vvTask := self.myVehicleVisit.createToDoTask(toDoDesc.code, self.job.myWorkOrderDtlToDo); // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
		self.job.myWorkOrderDtlToDo.allToDoTasks.add(vvTask);
	endif;
	
	self.myToDoTask := vvTask;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setMyVehicleVisit" id="1ce3867e-dc29-4ad2-95a5-a6008d5488a3">
        <updating/>
        <source>setMyVehicleVisit(_vehicleVisit : CM_VehicleVisitRecord) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
23 November 2022	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs

*/

vars

begin
	self.myVehicleVisit := _vehicleVisit;
	
	self.addToDoTask();
epilog

end;</source>
        <Parameter name="_vehicleVisit" type="CM_VehicleVisitRecord"/>
    </JadeMethod>
</Class>
