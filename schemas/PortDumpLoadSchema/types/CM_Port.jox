<Class name="CM_Port">
    <JadeMethod name="importPLXMLReference" id="9d9e8c6c-ffd8-499e-9508-9631a63682bf">
        <source>importPLXMLReference(_name, _theCode, _referencesBlock: String): Object;

vars

begin
	if _name = CM_Port::myRoot.name then
		return app.myRoot;
	elseif _name = CM_Port::myCountry.name then
		return app.myRoot.allCountries[_theCode];
	elseif _name = CM_Port::myPortGroup.name then
		return app.myRoot.allPortGroups[_theCode];
	else
		return null;
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_theCode" type="String"/>
        <Parameter name="_referencesBlock" type="String"/>
        <ReturnType type="Object"/>
    </JadeMethod>
</Class>
