        <Parameter name="_estEndTS" type="TimeStamp"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="deleteVoyageJob" id="da8477d3-a2b1-4bfa-9d4d-95307ec4d056">
        <source>deleteVoyageJob(_voyage : CM_Voyage; _craneID :String; _jobNum: String) ;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 December 2008	cnwer1	Initial creation

*/

vars
	jobSheet : CM_VoyageJobSheet;
	theRealVJob : CM_VoyageJob;
begin
	jobSheet:=_voyage.allJobSheets[ _craneID];
	assertTrue(jobSheet &lt;&gt; null);
	
	theRealVJob:=jobSheet.allJobsByJobNum[_jobNum];
	assertTrue(theRealVJob &lt;&gt; null);
	
	app.myTrxDA.trxDeleteVoyageJob(theRealVJob, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_craneID" type="String"/>
        <Parameter name="_jobNum" type="String"/>
    </JadeMethod>
    <JadeMethod name="deleteVoyageJobSheet" id="feb8fb92-4a00-47d5-8c8a-4cbfe9b6ad59">
        <source>deleteVoyageJobSheet(_jobSheet : CM_VoyageJobSheet io);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 November 2017	jlgmh5	Initial creation

*/

vars

	realVJob				: CM_VoyageJob;
	queueEntry				: CM_RTQueueEntry;


begin

	foreach	realVJob in _jobSheet.allJobsByJobNum do
		foreach queueEntry in realVJob.allEntries do
			beginTransaction;
				queueEntry.allTasks.purge;
			commitTransaction;
		endforeach;
		beginTransaction;
			realVJob.allEntries.purge;
			realVJob.workListEntries.purge;
		commitTransaction;
		self.loadVoyJobToOps(realVJob, false, false);
		app.myTrxDA.trxDeleteVoyageJob(realVJob, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endforeach; 
	
	if _jobSheet &lt;&gt; null then
		beginTransaction;
		_jobSheet.erase(NORMAL_ERASE);
		commitTransaction;	
	endif;
	
	

epilog

end;</source>
        <Parameter name="_jobSheet" type="CM_VoyageJobSheet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="deleteVoyageJobs" id="7a5e64be-043d-4cbe-8c7c-a917c709a218">
        <source>deleteVoyageJobs(_voyage : CM_Voyage) ;

vars
	jobSheet : CM_VoyageJobSheet;
	theRealVJob : CM_VoyageJob;
	queueEntry: CM_RTQueueEntry;
	queueTask: CM_RTQueueTask;
begin
	foreach jobSheet in _voyage.allJobSheets do
		foreach	theRealVJob in jobSheet.allJobsByJobNum do
			foreach queueEntry in theRealVJob.allEntries do
				beginTransaction;
					queueEntry.allTasks.purge;
				commitTransaction;
			endforeach;
			beginTransaction;
				theRealVJob.allEntries.purge;
				theRealVJob.workListEntries.purge;
			commitTransaction;
			self.loadVoyJobToOps(theRealVJob, false, false);
			app.myTrxDA.trxDeleteVoyageJob(theRealVJob, app.myPassport);
			//self.assertNoTrxErrorsOrWarnings();
		endforeach;
	endforeach;

epilog

end;</source>
