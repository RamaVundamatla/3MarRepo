	ya: CM_YardAllocation;
	ti, nextTI, osTI: CM_TrackedItem;
	location: CM_LocationsController;
	containers : String;
	rtQueueEntry : CM_RTQueueEntry;
begin
	deleteTerminalArea("UTSTRD");
	taSource:= addStraddleStack("UTSTRD", 3, 6, 1);
	assertNotNullMsg(taSource, "UTSTRD");


	deleteTerminalArea("UTSTRDA");
	taTarget:= addStraddleStack("UTSTRDA", 3, 6, 1);
	assertNotNullMsg(taTarget, "UTSTRD");
	//taSource:=self.getTerminalArea("UTSTRD").CM_StraddleStack;
	//taTarget:=self.getTerminalArea("UTSTRDA").CM_StraddleStack;
	
	self.deleteContainer("TEST0000001");
	ti := self.addContainerOpts("TEST0000001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(ti, "TEST0000001");
	self.move(ti ,taSource.allGridControllersByRowColumn[2, 5]);
	self.assertEqualMsg(ti.myPrimaryActualLocation, taSource.allGridControllersByRowColumn[2, 5], "Did not move TEST0000001 to correct location");
		
	self.moveQueued(ti,taTarget.allGridControllersByRowColumn[2, 5]);
	self.assertEqualMsg(ti.myPrimaryQueuedLocation, taTarget.allGridControllersByRowColumn[2, 5], "Did not queue TEST0000001 to correct location");
	
	
	self.deleteContainer("TEST0000002");
	osTI:= self.addContainerOpts("TEST0000002", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(ti, "TEST0000002");
	self.opts.addAssoc("IsForcedMove",true);
	self.move(osTI ,taSource.allGridControllersByRowColumn[2, 5]);
	self.assertEqualMsg(osTI.myPrimaryActualLocation, taSource.allGridControllersByRowColumn[2, 5], "Did not move TEST0000002 to correct location");
	self.opts.purge();
	//add some move cargo 
	self.deleteContainer("TEST0000003");
	nextTI:= self.addContainerOpts("TEST0000003", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(nextTI, "TEST0000003");
	self.move(nextTI ,taSource.allGridControllersByRowColumn[2, 6]);
	self.assertEqualMsg(nextTI.myPrimaryActualLocation, taSource.allGridControllersByRowColumn[2, 6], "Did not move TEST0000003 to correct location");
	
	self.deleteContainer("TEST0000004");
	osTI:= self.addContainerOpts("TEST0000004", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(ti, "TEST0000004");
	self.move(osTI ,taSource.allGridControllersByRowColumn[2, 4]);
	self.assertEqualMsg(osTI.myPrimaryActualLocation, taSource.allGridControllersByRowColumn[2, 4], "Did not move TEST0000004 to correct location");
	
	
	self.deleteContainer("TEST0000006");
	nextTI:= self.addContainerOpts("TEST0000006", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(nextTI, "TEST0000006");
	self.move(nextTI ,taSource.allGridControllersByRowColumn[2, 3]);
	self.assertEqualMsg(nextTI.myPrimaryActualLocation, taSource.allGridControllersByRowColumn[2, 3], "Did not move TEST0000006 to correct location");
	
	
	self.deleteContainer("TEST0000007");
	nextTI:= self.addContainerOpts("TEST0000007", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(nextTI, "TEST0000007");
	self.move(nextTI ,taSource.allGridControllersByRowColumn[2, 2]);
	self.assertEqualMsg(nextTI.myPrimaryActualLocation, taSource.allGridControllersByRowColumn[2, 2], "Did not move TEST0000007 to correct location");
	
	self.deleteContainer("TEST0000008");
	nextTI:= self.addContainerOpts("TEST0000008", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(nextTI, "TEST0000008");
	self.move(nextTI ,taSource.allGridControllersByRowColumn[2, 1]);
	self.assertEqualMsg(nextTI.myPrimaryActualLocation, taSource.allGridControllersByRowColumn[2, 1], "Did not move TEST0000006 to correct location");
	
	//locations are Top Left &amp; bottom Right
	create locations transient;
	locations.add(taSource.allGridControllersByRowColumn[1, 4]);
	locations.add(taSource.allGridControllersByRowColumn[3, 6]);
	
	
	self.deleteYA("UT");
	containers := "20";
	ya := self.addYA1("UT", YACriteriaType_ContainerLength, containers, locations);
	assertNotNullMsg(ya, "UT Yard Allocation");
	rtQueueEntry:=ti.getQueueEntry();
	assertNotNullMsg(rtQueueEntry, "Q Entry");
	beginTransaction;
	ti.moveOverstowingBoxes(rtQueueEntry, null,null,null);
	commitTransaction;
	self.assertEqualMsg( rtQueueEntry.allTasks.size,4, "Did not queue overstow tasks");
	self.assertEqualMsg( rtQueueEntry.allTasks.first.isOverstowTask,true, "First Task not overstow task");
	//will ignore the yard allocation and go directly to the next free location in the yard
	self.assertEqualMsg( rtQueueEntry.allTasks.first.targetLocationId,"UTSTRD 030001 1", "Overstow tasks target location is incorrect"  );
epilog
	self.opts.purge();

	delete locations;

end;</source>
    </JadeMethod>
