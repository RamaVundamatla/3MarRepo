    <JadeMethod name="clickAvailableBtn" id="364f19c7-0efb-4bb6-affa-9e857e4b0347">
        <updating/>
        <source>clickAvailableBtn( btn: Button input ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 October 2016	cnwndl1	Initial creation

*/

vars

	ti : CM_TrackedItem;
	

begin

	ti := btn.userObject.CM_TrackedItem;
	if ti = null or self.allSelectedConts.includes(ti) then
		return;
	endif;
	
	self.allSelectedConts.add( ti );
	
	self.populateContainers();
	self.doResizeControls(false);	//03 Mar 2017	NDL	TFS 3299
	
	//19 Dec 2016	NDL	TFS 3000
	if self.fldContainers.topSheet = self.shtContSel then
		self.txtContFind.setFocus();
	endif;

epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="clickChildBtn" id="2d658694-0656-4c8e-8db0-56b5d8d7df03">
        <updating/>
        <source>clickChildBtn( btn: Button input ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 October 2016	cnwndl1	Initial creation

*/

vars

	childTi : CM_TrackedItem;
	selectedTi : CM_TrackedItem;

begin

	childTi := btn.userObject.CM_TrackedItem;
	
	self.myMobileGenericAgent.setUnPackContainerDetails(	childTi.myParent,	//_trackedItem : CM_TrackedItem;
															self.myMobileGenericAgent.myLocationsController	//_location : CM_LocationsController
															);
	self.myMobileGenericAgent.setMyNextTiToAction( childTi );
		
	self.myMobileGenericAgent.allConfirmedTis.clear();
	foreach selectedTi in self.allSelectedConts do
		self.myMobileGenericAgent.allConfirmedTis.add( selectedTi);
	endforeach;
	
	self.myMobileGenericAgent.setInward( self.chkByCont.value );
	self.myMobileGenericAgent.setDecimalField1( self.cmbSortBy.listIndex );
	self.myMobileGenericAgent.setStringField1( self.fldChildren.topSheet.caption );
	
	self.gotoForm( MOB_HHUnpackCargoToForm, false );

epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
