    <JadeMethod name="doMnuKPIContainersClick" id="8a9d61c2-3e61-46a2-b66c-2587021d2e78">
        <source>doMnuKPIContainersClick();
// ---------------------------------------------------------------------------
// Created:		25 May 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 02/08/2011		cnwcs5	Tidy up when removing old KPI classes
//							CCMS MES 1033 RORO KPI
vars
	sheet		: Sheet;
	table		: CM_DataTable;
	isROROTable	: Boolean;
	row			: Integer;
	objArray 	: ObjectArray;
	set			: CM_TISet;
	kpi 		: CM_KPIVoyageEntity;
	agent		: CMIF_OutputFormatAgent_VoyKPI;
begin
	sheet := self.fldMain.topSheet;
	
	if sheet = self.shtMoves then
		table := self.tblStats;	
	elseif sheet = self.shtBays then
		table := self.tblBays;
	else
		isROROTable := true;
		
		if sheet = self.shtRORODecks then
			table 	:= self.tblRORODecks;
			agent	:= self.myRORODecKOutputAgent;
		elseif sheet = self.shtROROMoves then
			table 	:= self.tblROROMoves;
			agent 	:= self.myROROMoveOutputAgent;
		endif;
	endif;
	
	if table = null then
		return;
	endif;
	
	if isROROTable then
		create set transient;
		
		agent.getSelectedTrackedItems (table, set);

		create objArray transient;
			
		set.copy (objArray);
			
		self.myAssistant.showCargoEnquiryForTIs(objArray.first.CM_TrackedItem, objArray, self.myMasterMenuAction, false);
	else
		row := table.row;
		
		if row &gt; table.fixedRows then
			kpi := table.accessRow(row).itemObject.CM_KPIVoyageEntity;
			
			if kpi &lt;&gt; null then
				create objArray transient;
				kpi.allTrackedItems.copy(objArray);
				
				self.myAssistant.showCargoEnquiryForTIs(objArray.first.CM_TrackedItem, objArray, self.myMasterMenuAction, false);
			endif;
		endif;
	endif;
epilog
	delete set;
	delete objArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuKPIDelaysClick" id="675bfee4-f1ce-4cb7-9cb9-919c753893dd">
        <source>doMnuKPIDelaysClick();
// ---------------------------------------------------------------------------
// Created:		25 May 2007 By Andrew Bishop cnwab1
// ---------------------------------------------------------------------------
// 02/04/2010		cnwcs5	Moved delays forms up to UiCommonSchema
// 02/08/2011		cnwcs5	Tidy up when removing old KPI classes
vars
	sheet	:Sheet;
	obj 	: Object;
	kpi 	: CM_KPIVoyageEntity;
	detail	: CM_KPIVoyageMoveDtl;
	table	: CM_DataTable;
	row		: Integer;
begin
	sheet 	:= self.fldMain.topSheet;
	
	if sheet = self.shtMoves then
		table	:= self.tblStats;
	elseif sheet = self.shtROROMoves then
		table := self.tblROROMoves;
	endif;
	
	row 	:= table.row;
	
	if row &lt;= table.fixedRows then
		return;
	endif;

	obj := table.accessRow(row).itemObject.Object;

	if obj = null then
		return;
	endif;
	
	if obj.isKindOf(CM_KPIVoyageEntity) then
		kpi := obj.CM_KPIVoyageEntity;
		
	elseif obj.isKindOf (CM_KPIVoyageMoveDtl) then
		kpi := obj.CM_KPIVoyageMoveDtl.myKPIVoyageEntity;
	elseif obj.isKindOf (CM_KPIVoyageMoveDtlDict) then
		detail := obj.CM_KPIVoyageMoveDtlDict.first;
		
		if detail &lt;&gt; null then
			kpi := detail.myKPIVoyageEntity;
		endif;
	endif;
	
		
	if kpi &lt;&gt; null then
		if kpi.allDelays.isEmpty then
			app.msgBox(app.getErrorString1 (No_delays, kpi.getDescriptionString(false)), app.getErrorString (Drill_delay_problem), MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
		
		self.myAssistant.showDelayEnquiryForm (self.myCurrentVoyage, null, null, kpi.allDelays);
	endif;
end;</source>
    </JadeMethod>
