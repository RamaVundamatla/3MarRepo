    <JadeMethod name="auditIdDisplay" id="7b2a6435-4a1a-48ca-bf48-779c49125e1a">
        <source>auditIdDisplay(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 October 2019	jlgndl1	Initial creation	TFS 47013

*/

vars

begin
	
	if self.auditId() &lt;&gt; null then
		return app.getErrorString(Rate) &amp; Space &amp; Hyphen &amp; Space &amp; app.getErrorString(VisitType) &amp; ": "&amp; self.auditId();
	else
		return app.getErrorString(Rate);
	endif;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCode" id="f1229ad7-68ab-44b5-884b-234cff46a2a2">
        <source>getCode(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Jun 2018 cnwma1	ChangeRequest 38953: PEL1 - Berth Rates, Vessel Type Rates, Visit Types

*/

vars

	invalidObject : Boolean;
	edition : Integer;

begin
	
	if self.myVisitType &lt;&gt; null then
		on Exception do app.handleDeletedObject( exception, self.myVisitType, invalidObject );	//16 Oct 2019	NDL	TFS 47013
		edition := self.myVisitType.edition;
		if invalidObject then
			return null;
		endif;
		return self.myVisitType.code;
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
