    <JadeMethod name="getISOTypeOtherForReportsDescr" id="8e6e46de-072e-4309-a1a6-636e08807652">
        <source>getISOTypeOtherForReportsDescr( _level : Integer ) : String;
// ---------------------------------------------------------
// Created:     21 May 2008 by cnwvu1
//
// Purpose:     gives description for the 30, 45 and 53 footers
//				in the Terminal Config
// ---------------------------------------------------------

vars

begin

	if _level = ISOTypeOtherNotIncluded then
		return app.getErrorString( MSG_ISOTypeAsNotIncluded );
	elseif _level = ISOTypeOtherIncludedAsOwn then
		return app.getErrorString( MSG_ISOTypeAsOwn );
