    <JadeMethod name="setForCreate" id="5b46f711-e246-41aa-b4d9-4f4487f7f279">
        <updating/>
        <source>setForCreate(_backupHistory: CM_BackupHistory) updating;
// ---------------------------------------------------------------------------
// Created:     Aug 2004 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.dateTime := _backupHistory.dateTime;
	self.myBackup := _backupHistory.myBackup;
	self.status := _backupHistory.status;
	self.extraInfo := _backupHistory.extraInfo;	//13 Jan 2016 NDL	Par 37296
end;</source>
        <Parameter name="_backupHistory" type="CM_BackupHistory"/>
    </JadeMethod>
