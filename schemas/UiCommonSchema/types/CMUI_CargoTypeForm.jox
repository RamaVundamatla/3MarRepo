        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblAttributes_dblClick(table: Table input) updating;
/* ---------------------------------------------------------------------------
Created:	27 May 2009	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	if (self.mode = self.Mode_Add or self.mode = self.Mode_Update) then
		self.doMenuEditAttributes();	//CCMS 1080, PAR 19704 User-defined Cargo Types. May 2009
	endif;

end;</source>
