    <JadeMethod name="getDisplayStringForAttribute" id="94dc6b07-0522-4d87-b94b-f9a983f89e7c">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05/09/2023	navkc1	CR 59934 Task 59935: Jade - Cust Doc Cargo Transactions

*/

vars
	str		: String;
begin
	
	if _attrName = ETRow_Details then
		str := self.custDocCode &amp; " " &amp;  self.custDocTypeCode; // ### TFS CR 59942 TASK 59943 04SEP2023 NAVAB1 added direction to this string
		
		return str;
	else
		return inheritMethod(_attrName, _short);
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
