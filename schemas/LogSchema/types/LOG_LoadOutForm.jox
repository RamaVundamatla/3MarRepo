    <JadeMethod name="showDocketsInLocation" id="98a7d52e-3e16-4549-8f74-05408f81a287">
        <source>showDocketsInLocation();
//--------------------------------------------------------------
//Created: 10 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	obj : Object;
	str : String;
	backColour, idx : Integer;
	loadStateSet : Boolean;
	table  : CM_DataTable;
begin
	table := self.tblLocationDock;
	app.cmsBeginLoad(loadStateSet);

	foreach obj in self.myDynaDict do
//	Par 9691 - table changed from base to data table so can use column organiser 
//		str := self.tableDataDisplayRow(obj.CM_BOL);
		str := obj.CM_BOL.getAttributeStringForDefArray(table.allTblDataEntRows);
		if table.rows mod 2 = 0 then
			backColour := self.colorRow1;
		else
			backColour := self.colorRow2;
		endif;		
		idx := self.tblLocationDock.addItem(str);
		table.accessRow(idx).itemObject := obj.CM_BOL;
		table.accessedRow.backColor := backColour;
	endforeach;

epilog
	app.cmsEndLoad(loadStateSet);

end;</source>
    </JadeMethod>
    <JadeMethod name="showLogsInLocation" id="4043516a-ae17-4bbc-9965-ac51e8cbe61b">
        <source>showLogsInLocation();
//--------------------------------------------------------------
//Created: 10 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	obj : Object;
	str : String;
	backColour, idx : Integer;
	loadStateSet : Boolean;
begin
	if self.filterLogLocation = null or not self.optLocnDtlsLogs.value or self.myDataClass &lt;&gt; CM_TrackedItem then
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, 
							  'Filtering by Logs.', null, null);
		return;
	endif;

	app.cmsBeginLoad(loadStateSet);
	foreach obj in self.myDynaDict do

//	Par 9691 - table changed from base to data table so can use column organiser 		
		str := obj.CM_TrackedItem.getAttributeStringForDefArray(self.tblLocationDtls.allTblDataEntRows);
//		str := self.tableDataDisplayRow(obj.CM_TrackedItem);		
		
		idx := self.tblLocationDtls.addItem(str);
		self.tblLocationDtls.accessRow(idx).itemObject := obj.CM_TrackedItem;

		if self.tblLocationDtls.rows mod 2 = 0 then
			backColour := self.colorRow1;
		else
			backColour := self.colorRow2;
		endif;	

		tblLocationDtls.accessedRow.backColor := backColour;
	endforeach;
epilog
	app.cmsEndLoad(loadStateSet);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="showLogsOnBoard" id="516de4e4-b76c-4b2c-95e0-321ca6a01bc1">
        <source>showLogsOnBoard(_lot : CM_LogLot; _hatch, _place : Integer);
//--------------------------------------------------------------
//Created: 10 June 2002 By: cnwgd1
//--------------------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls

vars
	ti : CM_TrackedItem;
	cntrl : CM_LogVoyageController;
	str : String;
	backColour, idx, cnt : Integer;
	loadStateSet : Boolean;
	logVoyStruct : CM_LogVoyageStructure;
begin
	if self.filterVoyage = null then
		return;
	endif;
	tblOnBoard.rows := tblOnBoard.fixedRows;
	
	logVoyStruct := filterVoyage.myLogVoyageStructure;
	if logVoyStruct = null then 
		return;
	endif;

	app.cmsBeginLoad(loadStateSet);

	foreach cntrl in logVoyStruct.allLocationsByLotHatchPlace do	:outerLoop
		if _lot &lt;&gt; null then
			if cntrl.myLogLot &lt;&gt; _lot then
				continue outerLoop;
			endif;
		endif;
		if _hatch &lt;&gt; null then
			if cntrl.hatch &lt;&gt; _hatch then
				continue outerLoop;
			endif;
		endif;
		if _place &lt;&gt; null then
			if cntrl.place &lt;&gt; _place then
				continue outerLoop;
			endif;
		endif;
		foreach ti in cntrl.allTrackedItemsById do
			if cnt &gt; 32000 then
				break;
			endif;
			if self.tblOnBoard.rows mod 2 = 0 then
				backColour := self.colorRow1;
			else
				backColour := self.colorRow2;
			endif;			
			str :=	ti.id &amp; Tab &amp; ti.myProduct.code &amp; Tab
					&amp; cntrl.myLogLot.lotNo &amp; Tab
					&amp; cntrl.hatch.String &amp; Tab
					&amp; app.vesselPlaceEnumToStr(cntrl.place);
			idx := tblOnBoard.addItem(str);
			tblOnBoard.accessRow(idx).itemObject := ti;
			tblOnBoard.accessedRow.backColor := backColour;
			cnt := cnt + 1;
		endforeach;
	endforeach;
	if cnt &gt;= 32000 then
		app.msgBox('Returning 32000 items.' &amp; CrLf &amp; 'Use filter to refine search results.', 'Items Returned', 
			   	  MsgBox_Information_Icon + MsgBox_OK_Only);
	endif;
epilog
	app.cmsEndLoad(loadStateSet);
	
end;</source>
        <Parameter name="_lot" type="CM_LogLot"/>
        <Parameter name="_hatch" type="Integer"/>
        <Parameter name="_place" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tableDataDisplayRow" id="edfa77f6-c348-471b-9983-332931286a53">
