    <JadeMethod name="getTransferFileName" id="1aa3696c-e116-4034-8b5c-6b2c43a24dd3">
        <updating/>
        <source>getTransferFileName() :String updating;
// call when in transaction state
//19 June 2012	cnwrs1		Par 29821 - CAMS single transaction per file
vars

begin
	lastSequenceNumberUsed	:= lastSequenceNumberUsed + 1;
	if self.transferFileRollOver &lt;&gt; 0 then	//19 June 2012	cnwrs1		Par 29821 - dont want to roll over by zero
		if lastSequenceNumberUsed &gt; transferFileRollOver then
			lastSequenceNumberUsed	:= transferFileStartSeq;
		endif;
	endif;
	return 	filePrefix &amp; 
			lastSequenceNumberUsed.String.padLeadingZeros(transferFileSeqLength) &amp;
			"." &amp;
			fileSuffix;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
