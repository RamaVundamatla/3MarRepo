    <JadeMethod name="createCriteria" id="c35f03ed-c860-4ca6-8e05-f73d673f3ef2">
        <source>createCriteria(_cmb 				: CMUI_ComboBox;
				_criteriaType 		: Integer) : CM_YACriteria protected;
/*
----------   ----------  --------------------------------------------------
Created:	15 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	criteria		: CM_YACriteria;
	criteriaType	: CM_YACriteriaType;
	criteriaData	: CM_YADataObjects;
	objSet			: CM_ObjectSet;
begin
	if _cmb.listObject = null then
		return null;
	endif;
	
	criteriaType := app.myRoot.allYACriteriaTypes[_criteriaType];
	if criteriaType = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Allocation criteria type (' &amp; _criteriaType.String &amp; ') not present');
		return null;
	endif;
	
	create criteria transient;
	create objSet transient;
	objSet.add(_cmb.listObject);
	criteria.setProxy(criteriaType, objSet, null);

	return criteria;

epilog
	delete objSet;
end;


</source>
        <access>protected</access>
        <Parameter name="_cmb" type="CMUI_ComboBox"/>
        <Parameter name="_criteriaType" type="Integer"/>
        <ReturnType type="CM_YACriteria"/>
    </JadeMethod>
