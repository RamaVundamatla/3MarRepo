    <JadeMethod name="tCoparn_Release_DeleteAndAdd" id="ca326d1d-b94a-47ab-813c-b4eff1915ac1">
        <updating/>
        <source>tCoparn_Release_DeleteAndAdd() updating;
// cnwma1
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 February 2014	cnwmc5	Initial creation

*/
constants
	RELEASE_ADD = 'UT_COPARN_REL_ADD';
	RELEASE_DEL = 'UT_COPARN_REL_DEL';
	
	VESSEL 		= 'UT_COPREL_VES';
	VOYAGE 		= 'UT_COPREL_VOY';
	
	OPERATOR 	= 'MSC';
	
	PARTY 		= 'MSC_REL';
	
	SENDER1		= 'MSKCP1';	
	SENDER2 	= 'MAEUCP1';
	
	CONSIGNOR1 	= 'UTCOP';
	CONSIGNEE1	= 'UTCOE';
	
	MT 			= '4';
vars
	operator 	: CM_Operator;
	voyage 		: CM_Voyage;
	
	ediParty	: CM_EDIParty;
	rules		: CM_EDIPartyCoparnRules;
	carrier1 : CM_Carrier;
	carrier2 : CM_Carrier;
	opCrit : CM_OperatorCarrierCriteria;
	opCrit1 : CM_OperatorCarrierCriteria;
begin
	self.deleteVoyage(VESSEL);
	self.deleteVessel(VOYAGE);
	
	operator := self.getOperator("UTOP");

	carrier1 := app.myRoot.allCarriers["UT_OTHER"];
	carrier2 := app.myRoot.allCarriers["DOUG"];
	foreach opCrit in operator.allOperatorCarrierCriteria do
		if opCrit.allCriteria.first.myYACriteriaType.type = YACriteriaType_CargoType and
		   opCrit.allCriteria.first.myYAData.CM_YADataObjects.allObjects.first.CM_CargoType.id = 1 then
			opCrit1 := opCrit;
		endif;
	endforeach;
	if opCrit1 &lt;&gt; null then
		if not opCrit1.allCarriers.includes(carrier1) then
			beginTransaction;
			opCrit1.allCarriers.add(carrier1);
			commitTransaction;
		endif;
		if not opCrit1.allCarriers.includes(carrier2) then
			beginTransaction;
			opCrit1.allCarriers.add(carrier2);
			commitTransaction;
		endif;
	endif;

	operator := self.getOperator(OPERATOR);
	voyage := self.createVesselVoyage(VOYAGE, VESSEL,  operator);
	
	ediParty	:= self.createEDIPartyAndRules(VOYAGE, VESSEL, PARTY, PARTY, SENDER1, SENDER2, operator, false);
	rules		:= ediParty.getRulesForFileType(EDIFileType_Coparn).CM_EDIPartyCoparnRules;
	
	doCoparn_mtrel_DeleteAndAdd(SENDER1, VOYAGE, VESSEL, CONSIGNOR1, CONSIGNEE1, RELEASE_ADD, RELEASE_DEL, MT, operator, rules);
	
epilog

end;</source>
        <text>MTN-36111</text>
    </JadeMethod>
    <JadeMethod name="tCoparn_Releases" id="434f874c-a842-4b26-9fa6-36e2bba00421">
        <updating/>
        <source>tCoparn_Releases()updating;
// cnwrs1
/*
Date		Who		Reason
01 December 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
24/04/2012			cnwcs5	CCMS POL 2172 / par 29480
07/05/2012			cnwcs5	par 29402 - split method - getting too big
16/05/2012			cnwcs5	par 29575
20/02/2013			cnwcs5	par 31185
// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
//13 May 2016	cnwrs1	TFS 1987 CargoSubType EDI Xlation
// 10 Sep 2019	cnwrs1	TFS 46030
*/
constants	
	VESSEL		= 'UT_VCOPARN';
	VOYAGE		= 'UT_VCOPARN1';
	RELEASE1	= 'UT_COPARN_R001';
	RELEASE2	= 'UT_COPARN_R002';
	RELEASE3	= 'UT_COPARN_R003';
	RELEASE4	= 'UT_COPARN_R004';
	RELEASE5	= 'UT_COPARN_R005';
	RELEASE6	= 'UT_COPARN_R006';
	RELEASE7	= 'UT_COPARN_R007';
	RELEASE8	= 'UT_COPARN_R008';
	RELEASE9	= 'UT_COPARN_R009';
	RELEASE10	= 'UT_COPARN_R0010';
	RELEASE11	= 'UT_COPARN_R0011';
	RELEASE12	= 'UT_COPARN_R0012';
	RELEASE13	= 'UT_COPARN_R0013';

	OPERATOR	= 'MSK';
	SENDER1		= 'MSKCP';	SENDER2 = 'MAEUCP'; 
	PARTY		= 'Maersk Coparn Unit Tests'; PARTY2 = 'Christina Coparn Unit Tests';
	CONSIGNOR 	= 'UTCOP';
	CONSIGNEE	= 'UTCOE';
	MT = '4'; FULL = '5';
vars
	operator			:CM_Operator;
	ediParty	:CM_EDIParty;
	consign				:CM_ConsigneeConsignor;
	rules		:CM_EDIPartyCoparnRules;
	code, vesselCode, voyageCode		:String;
	ts1, ts2			:TimeStamp;
	voyage	:CM_Voyage;
	foundMatch	:Boolean;
	carrier1 : CM_Carrier;
	carrier2 : CM_Carrier;
	opCrit : CM_OperatorCarrierCriteria;
	opCrit1 : CM_OperatorCarrierCriteria;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	// disable cutoffs - they can stop a loadDB 
	self.disableAllEDIVoyageCutoffs;
	
	code := self.getTerminal.code;

	self.deleteReleaseRequest (RELEASE1); 
	self.deleteReleaseRequest (RELEASE2); 
	self.deleteReleaseRequest (RELEASE3); 
	self.deleteReleaseRequest (RELEASE4); 
	self.deleteReleaseRequest (RELEASE5); 
	self.deleteVehicle("UT_2243");
	
	vesselCode := VESSEL &amp; code;
	voyageCode	:= VOYAGE &amp; code;
	
	self.deleteVoyage(voyageCode);
	self.deleteVessel(vesselCode);
	
	operator := self.getOperator (OPERATOR);
	self.assertNotNullMsg (operator, 'Operator '&amp;OPERATOR&amp;' does not exist');

	carrier1 := app.myRoot.allCarriers["UT_OTHER"];
	carrier2 := app.myRoot.allCarriers["DOUG"];
	foreach opCrit in operator.allOperatorCarrierCriteria do
		if opCrit.allCriteria.first.myYACriteriaType.type = YACriteriaType_CargoType and
		   opCrit.allCriteria.first.myYAData.CM_YADataObjects.allObjects.first.CM_CargoType.id = 1 then
			opCrit1 := opCrit;
		endif;
	endforeach;
	if opCrit1 &lt;&gt; null then
		if not opCrit1.allCarriers.includes(carrier1) then
			beginTransaction;
			opCrit1.allCarriers.add(carrier1);
			commitTransaction;
		endif;
		if not opCrit1.allCarriers.includes(carrier2) then
			beginTransaction;
			opCrit1.allCarriers.add(carrier2);
			commitTransaction;
		endif;
	endif;

	// now make sure all the translations we need are there
	self.deleteEDIInwardXlation ('GP', XLATION_TYPE_MTGRADE_BYOP, operator, null);
	self.deleteEDIInwardXlation ('DAIRY', XLATION_TYPE_MTGRADE_BYOP, operator, null);
	self.deleteEDIInwardXlation ('CHILLED', XLATION_TYPE_MTGRADE_BYOP, operator, null);
	self.deleteEDIInwardXlation ('RF', XLATION_TYPE_MTGRADE_BYOP, operator, null);
	self.deleteEDIInwardXlation ('5049000221', XLATION_TYPE_CONSIGNEE_BYOP, operator, null);
	self.deleteEDIInwardXlation ('5046240346', XLATION_TYPE_CONSIGNEE_BYOP, operator, null);
	
	self.createEDIXlation ('GP', 0.String, XLATION_TYPE_MTGRADE_BYOP, true, operator, null);
	self.createEDIXlation ('DAIRY', 1.String, XLATION_TYPE_MTGRADE_BYOP, true, operator, null);
	// these next translations have parameters
	self.createEDIXlation ('CHILLED', 19.String, XLATION_TYPE_MTGRADE_BYOP, true, operator, null, -2.Real, -2.Real, null.String);
	self.createEDIXlation ('CHILLED', 17.String, XLATION_TYPE_MTGRADE_BYOP, true, operator, null, -1.7.Real, -1.7.Real, null.String);
	self.createEDIXlation ('RF', 39.String, XLATION_TYPE_MTGRADE_BYOP, true, operator, null, -22.Real, -22.Real, "JORDAN");

	if not self.createEDIXlation ('5049000221', CONSIGNEE, XLATION_TYPE_CONSIGNEE_BYOP, true, operator, null) then
		self.assertEqualMsg (1, 2, 'Consignor xlation could not be created');
	endif;
	 
	if not self.createEDIXlation ('5046240346', CONSIGNEE, XLATION_TYPE_CONSIGNEE_BYOP, true, operator, null) then
		self.assertEqualMsg (1, 2, 'Consignor xlation could not be created');
	endif;
	// makes sure the operator can use ALL availability grades
	beginTransaction;
	self.clearOperatorCodeGroups (operator, CodeGroup_AvailabilityGrade);
	commitTransaction;
	
	// this voyage will be used in most files
	self.createVesselVoyage ( voyageCode, vesselCode, operator);
	
	// we need one of these so create one
	consign := app.myRoot.allConsigneeConsignors [CONSIGNOR];
	
	if consign = null then
		consign := self.addConsigneeConsignor (CONSIGNOR, CONSIGNOR, true, true, true);
	endif;
	
	consign := app.myRoot.allConsigneeConsignors [CONSIGNEE];
	
	if consign = null then
		consign := self.addConsigneeConsignor (CONSIGNEE, CONSIGNEE, true, true, true);
	endif;
	
	// better create the EDI Party	
	self.deleteVoyage ('UT_HOLD' &amp; code);	// force voyage to be re-created without edi cutoffs
	// set up a party like MSK
	ediParty	:= self.createEDIPartyAndRules ('UT_HOLD' &amp; code, 'UT_HOLD' &amp; code, PARTY, PARTY, SENDER1, SENDER2, operator, false);
	rules		:= ediParty.getRulesForFileType (EDIFileType_Coparn).CM_EDIPartyCoparnRules;
	
	// change voyafge arrival/departure dates so we don't get cutoff errors
	voyage := self.getVoyage (voyageCode);
	
	if voyage &lt;&gt; null then
		ts1.setDate (ts1.date+7);
		beginTransaction;
		voyage.setArrivalDT (ts1);
		voyage.setDepartureDT (null);
		commitTransaction;
	endif;
	
	ts1 := app.actualTimeServer;// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
	ts2 := app.actualTimeServer;// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
	
	ts1.setDate (ts1.date-2);
	ts1.setTime ('09:00'.Time);
	ts2.setDate (ts1.date+1);
	ts2.setTime ('15:00'.Time);
	
	self.setTerminalConfig(EdiReleaseAllowPartial, false);
	self.setTerminalConfig(EdiBookingAllowPartial, false);
	
	self.doCoparn_mtrel_additionalFTX (SENDER1, voyageCode, vesselCode, CONSIGNOR, CONSIGNEE, RELEASE1, MT, operator,rules);
	self.doCoparn_mtrel_withid (SENDER2, voyageCode, vesselCode, CONSIGNOR, RELEASE2, ts1, ts2, MT, operator, rules);
	
	self.doCoparn_mtrel_chilled2probes (SENDER1, voyageCode, vesselCode, CONSIGNOR, RELEASE3, MT, operator, rules);
	self.doCoparn_mtrel_chilled3probes2 (SENDER1, voyageCode, vesselCode, CONSIGNOR, RELEASE3, MT, operator, rules);
	self.doCoparn_mtrel_chilled4probes3 (SENDER1, voyageCode, vesselCode, CONSIGNOR, RELEASE3, MT, operator, rules);
	
	self.doCoparn_mtrel_gensetrequired (SENDER2, voyageCode, vesselCode, CONSIGNOR, RELEASE4, MT, operator, rules);
	self.doCoparn_mtrel_mtgrade (SENDER1, voyageCode, vesselCode, CONSIGNOR, CONSIGNEE, RELEASE5, null, ts2, MT, operator, rules);
	self.doCoparn_mtrel_multi (SENDER1, voyageCode, vesselCode, CONSIGNEE, ts1, ts2, operator, rules);
	self.doCoparn_mtrel_multi_grpMatch (SENDER1, voyageCode, vesselCode, CONSIGNEE, ts1, ts2, operator, rules);
	
	self.doCoparn_mtrel_addthendelete (SENDER1, voyageCode, vesselCode, CONSIGNOR, CONSIGNEE, RELEASE6, MT, operator,rules);
	//self.doCoparn_mtrel_DeleteAndAdd(SENDER1, voyageCode, vesselCode, CONSIGNOR, CONSIGNEE, RELEASE6, MT, operator,rules); //currnt code doesnt support del then add but should
	
	self.doCoparn_mtrel_addthendelfail (SENDER1, voyageCode, vesselCode, CONSIGNOR, CONSIGNEE, RELEASE6, MT, operator,rules);
	
	self.doCoparn_mtrel_CCMS2243_byType (SENDER1, voyageCode, vesselCode, CONSIGNOR, CONSIGNEE, RELEASE12, operator, rules);
	
	self.doCoparn_mtrel_CCMS2243_byID (SENDER1, voyageCode, vesselCode, CONSIGNOR, CONSIGNEE, RELEASE13, operator, rules);
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
/*	if opCrit1 &lt;&gt; null then
		if opCrit1.allCarriers.includes(carrier1) then
			beginTransaction;
			opCrit1.allCarriers.remove(carrier1);
			commitTransaction;
		endif;
		if opCrit1.allCarriers.includes(carrier2) then
			beginTransaction;
			opCrit1.allCarriers.remove(carrier2);
			commitTransaction;
		endif;
	endif;*/
end;</source>
        <text>MTN-36111</text>
    </JadeMethod>
    <JadeMethod name="tCoparn_Releases_Partial" id="7c3f57a7-0fdc-42f6-a29c-3aaab10cb8d0">
        <updating/>
        <source>tCoparn_Releases_Partial()updating;
// cnwrs1
/*
Date		Who		Reason
01 December 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
24/04/2012			cnwcs5	CCMS POL 2172 / par 29480
07/05/2012			cnwcs5	par 29402 - split method - getting too big
16/05/2012			cnwcs5	par 29575
// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
//13 May 2016	cnwrs1	TFS 1987 CargoSubType EDI Xlation
// 10 Sep 2019	cnwrs1	TFS 46030
*/
constants	
	VESSEL		= 'UT_VCOPARP';
	VOYAGE		= 'UT_VCOPARP1';
	RELEASE1	= 'UT_COPARN_RP01';
	RELEASE2	= 'UT_COPARN_RP02';
	RELEASE3	= 'UT_COPARN_RP03';
	RELEASE4	= 'UT_COPARN_RP04';
	RELEASE5	= 'UT_COPARN_RP05';
	RELEASE6	= 'UT_COPARN_RP06';
	RELEASE7	= 'UT_COPARN_RP07';
	RELEASE8	= 'UT_COPARN_RP08';
	RELEASE9	= 'UT_COPARN_RP09';
	RELEASE10	= 'UT_COPARN_RP010';
	RELEASE11	= 'UT_COPARN_RP011';

	OPERATOR	= 'MSK';
	SENDER1		= 'MSKCP';	SENDER2 = 'MAEUCP'; 
	PARTY		= 'Maersk Coparn Unit Tests'; PARTY2 = 'Christina Coparn Unit Tests';
	CONSIGNOR 	= 'UTCOP';
	CONSIGNEE	= 'UTCOE';
	MT = '4'; FULL = '5';
vars
	operator			:CM_Operator;
	ediParty	:CM_EDIParty;
	consign				:CM_ConsigneeConsignor;
	rules		:CM_EDIPartyCoparnRules;
	code, vesselCode, voyageCode		:String;
	ts1, ts2			:TimeStamp;
	voyage	:CM_Voyage;
	foundMatch	:Boolean;
	carrier1 : CM_Carrier;
	carrier2 : CM_Carrier;
	opCrit : CM_OperatorCarrierCriteria;
	opCrit1 : CM_OperatorCarrierCriteria;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	// disable cutoffs - they can stop a loadDB 
	self.disableAllEDIVoyageCutoffs;
	
	code := self.getTerminal.code;

	self.deleteReleaseRequest (RELEASE1); 
	self.deleteReleaseRequest (RELEASE2); 
	self.deleteReleaseRequest (RELEASE3); 
	self.deleteReleaseRequest (RELEASE4); 
	self.deleteReleaseRequest (RELEASE5); 
	
	vesselCode := VESSEL &amp; code;
	voyageCode	:= VOYAGE &amp; code;
	
	self.deleteVoyage(voyageCode);
	self.deleteVessel(vesselCode);
	
	operator := self.getOperator (OPERATOR);
	self.assertNotNullMsg (operator, 'Operator '&amp;OPERATOR&amp;' does not exist');
	
	carrier1 := app.myRoot.allCarriers["UT_OTHER"];
	carrier2 := app.myRoot.allCarriers["DOUG"];
	foreach opCrit in operator.allOperatorCarrierCriteria do
		if opCrit.allCriteria.first.myYACriteriaType.type = YACriteriaType_CargoType and
		   opCrit.allCriteria.first.myYAData.CM_YADataObjects.allObjects.first.CM_CargoType.id = 1 then
			opCrit1 := opCrit;
		endif;
	endforeach;
	if opCrit1 &lt;&gt; null then
		if not opCrit1.allCarriers.includes(carrier1) then
			beginTransaction;
			opCrit1.allCarriers.add(carrier1);
			commitTransaction;
		endif;
		if not opCrit1.allCarriers.includes(carrier2) then
			beginTransaction;
			opCrit1.allCarriers.add(carrier2);
			commitTransaction;
		endif;
	endif;
	// now make sure all the translations we need are there
	self.deleteEDIInwardXlation ('GP', XLATION_TYPE_MTGRADE_BYOP, operator, null);
	self.deleteEDIOutwardXlation (0.String, XLATION_TYPE_MTGRADE_BYOP, operator, null);
	self.deleteEDIInwardXlation ('DAIRY', XLATION_TYPE_MTGRADE_BYOP, operator, null);
	self.deleteEDIOutwardXlation (1.String, XLATION_TYPE_MTGRADE_BYOP, operator, null);
	self.deleteEDIInwardXlation ('5049000221', XLATION_TYPE_CONSIGNEE_BYOP, operator, null);
	self.deleteEDIOutwardXlation (CONSIGNEE, XLATION_TYPE_CONSIGNEE_BYOP, operator, null);
	self.deleteEDIInwardXlation ('5046240346', XLATION_TYPE_CONSIGNEE_BYOP, operator, null);
	
	
	self.createEDIXlation ('GP', 0.String, XLATION_TYPE_MTGRADE_BYOP, true, operator, null);
	self.createEDIXlation ('DAIRY', 1.String, XLATION_TYPE_MTGRADE_BYOP, true, operator, null);
	
	if not self.createEDIXlation ('5049000221', CONSIGNEE, XLATION_TYPE_CONSIGNEE_BYOP, true, operator, null) then
		self.assertEqualMsg (1, 2, 'Consignor xlation could not be created');
	endif;	
	 
	if not self.createEDIXlation ('5046240346', CONSIGNEE, XLATION_TYPE_CONSIGNEE_BYOP, true, operator, null) then
		self.assertEqualMsg (1, 2, 'Consignor xlation could not be created');
	endif;	

	// makes sure the operator can use ALL availability grades
	beginTransaction;
	self.clearOperatorCodeGroups (operator, CodeGroup_AvailabilityGrade);
	commitTransaction;
	
	// this voyage will be used in most files
	self.createVesselVoyage ( voyageCode,vesselCode, operator);
	
	// we need one of these so create one
	consign := app.myRoot.allConsigneeConsignors [CONSIGNOR];
	
	if consign = null then
		consign := self.addConsigneeConsignor (CONSIGNOR, CONSIGNOR, true, true, true);
	endif;
	
	consign := app.myRoot.allConsigneeConsignors [CONSIGNEE];
	
	if consign = null then
		consign := self.addConsigneeConsignor (CONSIGNEE, CONSIGNEE, true, true, true);
	endif;
	
	// better create the EDI Party	
	self.deleteVoyage ('UT_HOLD' &amp; code);	// force voyage to be re-created without edi cutoffs
	// set up a party like MSK
	ediParty	:= self.createEDIPartyAndRules ('UT_HOLD' &amp; code, 'UT_HOLD' &amp; code, PARTY, PARTY, SENDER1, SENDER2, operator, false);
	rules		:= ediParty.getRulesForFileType (EDIFileType_Coparn).CM_EDIPartyCoparnRules;
	// this party has aDTM+133 rule for request date
//	ediParty2 	:= self.createEDIPartyAndRules ('UT_HOLD' &amp; code, 'UT_HOLD' &amp; code, PARTY2, PARTY2, SENDER3, null, operator, true);
//	rules2		:= ediParty2.getRulesForFileType (EDIFileType_Coparn).CM_EDIPartyCoparnRules;
	
	// change voyafge arrival/departure dates so we don't get cutoff errors
	voyage := self.getVoyage (voyageCode);
	
	if voyage &lt;&gt; null then
		ts1.setDate (ts1.date+7);
		beginTransaction;
		voyage.setArrivalDT (ts1);
		voyage.setDepartureDT (null);
		commitTransaction;
	endif;
	
	ts1 := app.actualTimeServer;// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
	ts2 := app.actualTimeServer;// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
	
	ts1.setDate (ts1.date-2);
	ts1.setTime ('09:00'.Time);
	ts2.setDate (ts1.date+1);
	ts2.setTime ('15:00'.Time);
	
	self.setTerminalConfig(EdiReleaseAllowPartial, true);
	self.setTerminalConfig(EdiBookingAllowPartial, true);
	
	self.doCoparn_mtrel_additionalFTX (SENDER1, voyageCode, vesselCode, CONSIGNOR, CONSIGNEE, RELEASE1, MT, operator,rules);
	self.doCoparn_mtrel_withid (SENDER2, voyageCode, vesselCode, CONSIGNOR, RELEASE2, ts1, ts2, MT, operator, rules);
	
	self.doCoparn_mtrel_chilled2probes (SENDER1, voyageCode, vesselCode, CONSIGNOR, RELEASE3, MT, operator, rules);
	self.doCoparn_mtrel_chilled3probes2 (SENDER1, voyageCode, vesselCode, CONSIGNOR, RELEASE3, MT, operator, rules);
	self.doCoparn_mtrel_chilled4probes3 (SENDER1, voyageCode, vesselCode, CONSIGNOR, RELEASE3, MT, operator, rules);
	
	self.doCoparn_mtrel_gensetrequired (SENDER2, voyageCode, vesselCode, CONSIGNOR, RELEASE4, MT, operator, rules);
	self.doCoparn_mtrel_mtgrade (SENDER1, voyageCode, vesselCode, CONSIGNOR, CONSIGNEE, RELEASE5, null, ts2, MT, operator, rules);
	self.doCoparn_mtrel_multi (SENDER1, voyageCode, vesselCode, CONSIGNEE, ts1, ts2, operator, rules);
	
	self.doCoparn_mtrel_addthendelete (SENDER1, voyageCode, vesselCode, CONSIGNOR, CONSIGNEE, RELEASE6, MT, operator,rules);
	//self.doCoparn_mtrel_DeleteAndAdd(SENDER1, voyageCode, vesselCode, CONSIGNOR, CONSIGNEE, RELEASE6, MT, operator,rules); //currnt code doesnt support del then add but should
	self.doCoparn_mtrel_addthendelfail (SENDER1, voyageCode, vesselCode, CONSIGNOR, CONSIGNEE, RELEASE6, MT, operator,rules);
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
/*	if opCrit1 &lt;&gt; null then
		if opCrit1.allCarriers.includes(carrier1) then
			beginTransaction;
			opCrit1.allCarriers.remove(carrier1);
			commitTransaction;
		endif;
		if opCrit1.allCarriers.includes(carrier2) then
			beginTransaction;
			opCrit1.allCarriers.remove(carrier2);
			commitTransaction;
		endif;
	endif;*/
end;</source>
        <text>MTN-36111</text>
    </JadeMethod>
    <JadeMethod name="zCoparn_mtrel_CCMS2243_byID" id="289cb604-d33a-40a5-bd69-12331a600da4">
        <source>zCoparn_mtrel_CCMS2243_byID(_bgm, _mode, _sender, _voyageCode, _vesselName, _consignorCode, _consigneeCode, _release, _id :String):String protected;
/*
Date		Who		Reason
20/02/2013	cnwcs5	Initial creation - CCMS PNL 2243 / par 31185
*/
vars
	str 	:String;
begin
	str :=  
"UNA:+,? '
UNB+UNOA:1+" &amp; _sender &amp; "+NZPOE+110901:2034+1336'
UNH+133600001+COPARN:D:95B:UN:ITG14'
BGM+" &amp; _bgm &amp; "+20110901203403+" &amp; _mode &amp; "'
RFF+BN:" &amp; _release &amp; "'
TDT+20+" &amp; _voyageCode &amp; "+1++MAE:172:20+++9294161:146:11:" &amp; _vesselName &amp; "'
LOC+88+NZPOE:139:6'
LOC+9+NZPOE:139:6'
DTM+133:201109191300:203'
NAD+CZ+" &amp; _consignorCode &amp; "+" &amp; _consignorCode &amp; "'
NAD+CA+MAE:172:20'
GID+1'
FTX+AAA+++FOOD PRODUCTS'
EQD+CN+" &amp; _id &amp; "+2200:102:5+2+2+4'
RFF+BN:" &amp; _release &amp; "'
TMD+3++2'
LOC+8+AUMEL:139:6'
LOC+98+NZPOE:139:6'
LOC+11+NZAKL:139:6'
MEA+AAE+G+KGM:1000'
MEA+AAE+T+KGM:2500'
MEA+AAE+EGW+KGM:3500'
NAD+CN+" &amp; _consigneeCode &amp; "+" &amp; _consigneeCode &amp; "'
TDT+30+1120+1++MAE:172:20+++9332705:146:11:MAERSK RADFORD'
LOC+11+AUSYD:139:6'
CNT+16:1'
UNT+26+133600001'
UNZ+1+1336'";

	return str;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_bgm" type="String"/>
        <Parameter name="_mode" type="String"/>
        <Parameter name="_sender" type="String"/>
        <Parameter name="_voyageCode" type="String"/>
        <Parameter name="_vesselName" type="String"/>
        <Parameter name="_consignorCode" type="String"/>
        <Parameter name="_consigneeCode" type="String"/>
        <Parameter name="_release" type="String"/>
        <Parameter name="_id" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="zCoparn_mtrel_CCMS2243_byID2" id="348f49b9-d7b9-4df0-9e9f-3f8e2a65f189">
        <source>zCoparn_mtrel_CCMS2243_byID2(_bgm, _mode, _sender, _voyageCode, _vesselName, _consignorCode, _consigneeCode, _release, _id, _id2 :String):String protected;
/*
Date		Who		Reason
20/02/2013	cnwcs5	Initial creation - CCMS PNL 2243 / par 31185
*/
vars
	str 	:String;
begin
	str :=  
"UNA:+,? '
UNB+UNOA:1+" &amp; _sender &amp; "+NZPOE+110901:2034+1336'
UNH+133600001+COPARN:D:95B:UN:ITG14'
BGM+" &amp; _bgm &amp; "+20110901203403+" &amp; _mode &amp; "'
RFF+BN:" &amp; _release &amp; "'
TDT+20+" &amp; _voyageCode &amp; "+1++MAE:172:20+++9294161:146:11:" &amp; _vesselName &amp; "'
LOC+88+NZPOE:139:6'
LOC+9+NZPOE:139:6'
DTM+133:201109191300:203'
NAD+CZ+" &amp; _consignorCode &amp; "+" &amp; _consignorCode &amp; "'
NAD+CA+MAE:172:20'
GID+1'
