end;</source>
        <Parameter name="_driverId" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="xDeleteInvoiceLineType" id="9aacb5af-59a4-4dbf-a2bd-ed85225182ba">
        <source>xDeleteInvoiceLineType(_narration : String; _eraseLevel : Integer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 February 2022		navma1	Initial creation

*/

vars
	ild	 : CM_InvoiceLineDesc;
	bank : CM_Bank;
begin
	
	bank := self.getTerminal().getDefaultCompanyBank();
	
	self.assertNotNull(bank);
	
	ild := bank.invoiceLineDescriptors[_narration];
	
	if ild &lt;&gt; null and ild.narration = _narration then
		if _eraseLevel = FORCED_ERASE then
				app.myTrxDA.trxDeleteInvoiceLineDescForce(ild, app.myPassport);
				self.assertNoTrxErrorsOrWarnings();
			else
				app.myTrxDA.trxDeleteInvoiceLineDesc(ild, app.myPassport);
			endif;
	endif;
end;</source>
        <Parameter name="_narration" type="String"/>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="xDeleteInvoiceService" id="78f85ec1-8383-415e-8b7a-72780b98828e">
        <source>xDeleteInvoiceService(_serviceName : String;_eraseLevel : Integer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 February 2022		navma1	Initial creation

*/

vars
	aService : CM_ServiceObject;
	charge	 : CM_Charge;
begin

	foreach aService in CM_Service.instances do
		if aService.name = _serviceName then
	
			beginTransaction;
				foreach charge in aService.CM_Service.charges do
					delete charge;			
				endforeach;
			commitTransaction;
			
			if _eraseLevel = FORCED_ERASE then
				app.myTrxDA.trxDeleteServiceObjectForced(aService, app.myPassport);
			else
				app.myTrxDA.trxDeleteServiceObject(aService, app.myPassport);
			endif;
			
			self.assertNoTrxErrorsOrWarnings();	
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_serviceName" type="String"/>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="xDeleteInvoiceType" id="ee655cf7-b72f-4606-8e77-3094c4b4a190">
        <source>xDeleteInvoiceType(_invoiceDesc : String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 February 2022		navma1	Initial creation

*/

vars
	it		 : CM_InvoiceDesc;
	bank	 : CM_Bank;
begin

	bank := self.getTerminal().getDefaultCompanyBank();
	
	self.assertNotNull(bank);
	
	foreach it in bank.invoiceTypes discreteLock do 
		if it.description = _invoiceDesc then
			beginTransaction;
			it.erase(FORCED_ERASE);
			commitTransaction;
		endif;
	endforeach;
	
epilog

end;</source>
        <Parameter name="_invoiceDesc" type="String"/>
    </JadeMethod>
    <JadeMethod name="xDeleteRailAreaByCode" id="c4f06fb7-1350-4352-a829-2059defa94f7">
        <source>xDeleteRailAreaByCode(_railAreaCode : String; _terminal : CM_Terminal);
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
27 July 2023	navpw1	Initial creation TFS: 56796 (57081)

*/

vars
	ra					: CM_Rail;
	rata				: CM_YardTransferArea;
	rataCode			: String;
	ta					: CM_TerminalArea;
	line				: CM_RailLine;
	i					: Integer;
	ti					: CM_TrackedItem;
	locnController		: CM_LocationsController;
	tiArray				: CM_TIArray;
	futureMove			: CM_FutureMove;
	
begin
	self.assertTrueMsg(_railAreaCode &lt;&gt; null, method.name &amp; " | railAreaCode is null");
	self.assertNotNullMsg(_terminal, method.name &amp; " | terminal");
	
	ta := _terminal.allTerminalAreasByTypeId[TA_TYPE_RAILWAY_TRACK, _railAreaCode];
	
	create tiArray transient;
	
	if ta &lt;&gt; null then
		if ta.isKindOf(CM_Rail) then
			ra := ta.CM_Rail;
			// for some reson we have null entries in the wagons array - cnwcs5 May 2012
			foreach line in ra.allRailLines do
				
				beginTransaction;
				while not line.allWagons.isEmpty() do
					line.allWagons.removeAt(1);
				endwhile;
				commitTransaction;
				
			endforeach;
			
			// read through all the locations controllers and get the tracked items and delete them
			foreach locnController in ra.allLocationsControllers do
				if locnController.hasTIs() then
					locnController.allTrackedItems.copy(tiArray);
					locnController.getAllPlannedTrackedItems(tiArray, false, false);
					locnController.getAllQueuedTrackedItems(tiArray, false);
				endif;
			endforeach;
			
			self.deleteTrackedItem(tiArray, false);
			
			self.ignoreTrxWarnings(true);
			ra.latestEdition;
			app.myTrxDA.trxDeleteTerminalArea(ra, app.myPassport);
			self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
			self.assertNoTrxErrorsOrWarnings();
		endif;
	endif;
	
	rataCode := _railAreaCode &amp; "TA";
	ta := app.myPassport.myTerminal.allTerminalAreasByTypeId[TA_TYPE_RAIL_TRANS, rataCode];

	if ta &lt;&gt; null then
		if ta.isKindOf(CM_YardTransferArea) then
			rata := ta.CM_YardTransferArea;
			self.ignoreTrxWarnings(true);
			//app.myPassport.setWarningsIgnored(true);
			app.myTrxDA.trxDeleteTerminalArea(rata, app.myPassport);
			self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
			self.assertNoTrxErrorsOrWarnings();
		endif;
	endif;	
	
	self.assertIsDeletedMsg(ta, method.name &amp; " | ta");
	
epilog
	delete tiArray;
	
end;</source>
        <Parameter name="_railAreaCode" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="xDeleteTrainByCode" id="1437bb26-6905-46c4-bb46-2b8fb7ea087f">
        <source>xDeleteTrainByCode(_trainCode : String; _terminal : CM_Terminal);
/*

Purpose:			Deletes one train only by code

Parameters:			_trainCode	String		The train code to use to find the train to delete
					_terminal	CM_Terminal	The terminal to use to find the train

Return Value:		

Date			Who		Reason
27 July 2023	navpw1	Initial creation TFS: 56796 (57081)

*/

vars
	train	: CM_Train;
	trans	: CM_EventTransaction;
	
begin
	self.assertTrueMsg(_trainCode &lt;&gt; null, method.name &amp; " | trainCode is null");
	self.assertNotNullMsg(_terminal, method.name &amp; " | terminal");
	
	// Is our Train on site ?
	train := _terminal.allTrainsOnTerminal.getAtKeyGeq(_trainCode, null);
	
	// If not, then look for departed ones instead
	if train = null or train.code &lt;&gt; _trainCode then
		train := _terminal.allTrainsDeparted.getAtKeyGeq(_trainCode, null);
		
		if train = null or train.code &lt;&gt; _trainCode then
			//self.assertTrueMsg(false, "Could not find train. Train Code: " &amp; _trainCode);
			return; //No Train to delete
		else
			self.deleteTrainAndAssociatedObjs(train);
			self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
			self.assertNoTrxErrorsOrWarnings();
		endif;
	endif;
	
	if train = null then
		return;
	endif;
	
	self.ignoreTrxWarnings(true);
	//app.myPassport.setWarningsIgnored(true);
	foreach trans in train.allTransactions do
		if not global.isValidObject(trans.myDebtor) then
			beginTransaction;
			trans.setPropertyValue(CM_EventTransaction::myDebtor.name, null);
			commitTransaction;
		endif;
		app.myTrxDA.trxDeleteTrainEvent(trans, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endforeach;
	app.myTrxDA.trxDeleteTrain(train, false, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	self.assertNoTrxErrorsOrWarnings();
	
	self.assertIsDeletedMsg(train, method.name &amp; " | train");
	
end;</source>
        <Parameter name="_trainCode" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="xDeleteTrainByObj" id="4e76fd76-469f-475c-96dd-7519394b1d7e">
        <source>xDeleteTrainByObj(_train : CM_Train io; _terminal : CM_Terminal);
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
27 July 2023	navpw1	Initial creation TFS: 56796 (57081)

*/

vars
	trans	: CM_EventTransaction;
	
begin
	self.assertNotNullMsg(_train, method.name &amp; " | train");
	self.assertNotNullMsg(_terminal, method.name &amp; " | terminal");
	
	// If not, then look for departed ones instead
	if _train.isDeparted then
		self.deleteTrainAndAssociatedObjs(_train);
		self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
		self.assertNoTrxErrorsOrWarnings();
	endif;
	
	self.ignoreTrxWarnings(true);
	
	foreach trans in _train.allTransactions do
		if not global.isValidObject(trans.myDebtor) then
			beginTransaction;
			trans.setPropertyValue(CM_EventTransaction::myDebtor.name, null);
			commitTransaction;
		endif;
		app.myTrxDA.trxDeleteTrainEvent(trans, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endforeach;
	app.myTrxDA.trxDeleteTrain(_train, false, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	self.assertNoTrxErrorsOrWarnings();
	
	self.assertIsDeletedMsg(_train, method.name &amp; " | train");
end;</source>
        <Parameter name="_train" type="CM_Train" usage="io"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="xDeleteVbsTimeSlot" id="a02d39fe-28b8-4b6a-97ec-03257523359a">
        <source>xDeleteVbsTimeSlot(_id: String; _vbt : CM_VehicleBookingTerminal);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2023	navpw1	Initial creation TFS: 54049 (55844)

*/

vars
	vbsTimeSlot		: CM_VehicleBookingTimeSlot;
	terminal		: CM_Terminal;
	usedCarrier		: String;
	
begin
	//vbsTimeSlot := self.getVbsTimeSlot(id);
	
	vbsTimeSlot := _vbt.allVBTimeslotsById[_id];
	
	if vbsTimeSlot = null then
		return;
	endif;
	
 	app.myTrxDA.trxDeleteVehicleBooking(vbsTimeSlot, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	
end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_vbt" type="CM_VehicleBookingTerminal"/>
    </JadeMethod>
    <JadeMethod name="xDeleteVbsTimeSlotType" id="9073f3ef-b565-48e6-af6a-7b6e40bfdaf6">
        <source>xDeleteVbsTimeSlotType(_code : String; _terminal : CM_Terminal);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2023	navpw1	Initial creation TFS: 54049 (55844)

*/

vars
	vbtst	: CM_VehicleBookingTimeSlotType;
	obj		: CM_Object;

begin
	if _code.trimBlanks = null then
		return;
	endif;
	
	vbtst := _terminal.allTerminalVBSSlotTypes.getAtKey( _code.trimBlanks.toUpper );
	
	if vbtst = null then
		return;
	endif;
	
	obj := vbtst;
	
	app.myPassport.clearErrorsWarnings();
	app.myTrxDA.trxDeleteCMObject( obj, app.myPassport);
	self.assertTrueMsg(app.myPassport.noErrors, "VehicleBookingTimeSlotype not deleted - " &amp; app.myPassport.getAllErrorsWarningsAsString);
	
epilog


end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="xDeleteVehicleByObj" id="a79e130e-979b-4593-828d-23afa24b155a">
        <source>xDeleteVehicleByObj(_vehicle : CM_Vehicle io; _terminal : CM_Terminal);
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
04 August 2023	navpw1	Initial creation TFS: 56796

*/

vars
	job					: CM_Job;
	vvr					: CM_VehicleVisitRecord;
	itm					: CM_InterTerminalMove;
	obj					: Object;
	itvj				: CM_InterTermVehicleJob;
	itmArray			: ObjectArray;
	mergeIter			: MergeIterator;
	iter				: Iterator;
	dontDeleteCarrier	: Boolean;
	
begin
	self.assertNotNullMsg(_vehicle, method.name &amp; " | vehicle");
	self.assertNotNullMsg(_terminal, method.name &amp; " | terminal");
	
	foreach job in _vehicle.allRoadJobs do
		self.deleteJob(job);
		self.assertIsDeletedMsg(job, method.name &amp; " | Job Id: " &amp; job.id &amp; " | job");
	endforeach;
	
	// delete any inter terminal moves
	create mergeIter transient;
	mergeIter.addCollection(_terminal.allInterTerminalMovesIn);
	mergeIter.addCollection(_terminal.allInterTerminalMovesOut);
	mergeIter.startKeyGeq(null, null, _vehicle.regNumber);
	while mergeIter.next(itm) do
		if itm.vehicleID &lt;&gt; _vehicle.regNumber then
			continue;
		endif;
		app.myTrxDA.trxDeleteInterTerminalMove(itm, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endwhile;
	
	create itmArray transient;
	iter := app.myRoot.allInterTerminalVehicleJobs.createIterator;
	app.myRoot.allInterTerminalVehicleJobs.startKeyGeq(_vehicle.regNumber, _vehicle.state, iter);
	while iter.next(itvj) and itvj.vehicleID = _vehicle.regNumber do
		itmArray.clear();
		itvj.allInterTerminalMoves.copy(itmArray);
		foreach obj in itmArray do
			itm := obj.CM_InterTerminalMove;
			app.myTrxDA.trxDeleteInterTerminalMove(itm, app.myPassport);
			self.assertNoTrxErrorsOrWarnings();
		endforeach;
		beginTransaction;
		delete itvj;												// 07/08/2014 cnwmh5
		commitTransaction;
	endwhile;
	
	foreach vvr in _vehicle.visitRecords do
		self.deleteVVR(vvr);
		self.assertIsDeletedMsg(vvr, method.name &amp; " | vvr Id: " &amp; vvr.visitNumber &amp; " | vvr");
	endforeach;
	
	dontDeleteCarrier := self.opts.bool(UT_OPTS_DontDeleteCarrier);		// 20/08/2012 cnwmh5
	if not dontDeleteCarrier then
		beginTransaction;
		_vehicle.carriers.clear();
		commitTransaction;
	endif;
	
	self.ignoreTrxWarnings(true);
	app.myTrxDA.trxDeleteVehicle(_vehicle, app.myPassport); 
	self.assertNoTrxErrorsOrWarnings();
	self.assertIsDeletedMsg(_vehicle, method.name &amp; " | vehicle");
	
epilog
	delete mergeIter;
	delete iter;
	delete itmArray;
	
end;</source>
        <Parameter name="_vehicle" type="CM_Vehicle" usage="io"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="xDeleteVehicleByReg" id="a6fab1a9-675e-437f-ad61-d373e5188846">
        <source>xDeleteVehicleByReg(_vehicleReg : String; _terminal : CM_Terminal);
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
04 August 2023	navpw1	Initial creation TFS: 56796

*/

vars
	vehicle				: CM_Vehicle;
	job					: CM_Job;
	vvr					: CM_VehicleVisitRecord;
	itm					: CM_InterTerminalMove;
	obj					: Object;
	itvj				: CM_InterTermVehicleJob;
	itmArray			: ObjectArray;
	mergeIter			: MergeIterator;
	iter				: Iterator;
	dontDeleteCarrier	: Boolean;
	jobId,
	vvrNumber			: String;
	
begin
	self.assertTrueMsg(_vehicleReg &lt;&gt; null, method.name &amp; " | vehicleReg is null");
	self.assertNotNullMsg(_terminal, method.name &amp; " | terminal");
	
	vehicle := _terminal.vehicles[_vehicleReg, ""];
	if vehicle = null then
		return;
	endif;
	
	foreach job in vehicle.allRoadJobs do
		jobId := job.id;
		self.deleteJob(job);
		self.assertIsDeletedMsg(job, method.name &amp; " | Job Id: " &amp; jobId &amp; " | job");
	endforeach;
	
	// delete any inter terminal moves
	create mergeIter transient;
	mergeIter.addCollection(_terminal.allInterTerminalMovesIn);
	mergeIter.addCollection(_terminal.allInterTerminalMovesOut);
	mergeIter.startKeyGeq(null, null, vehicle.regNumber);
	while mergeIter.next(itm) do
		if itm.vehicleID &lt;&gt; vehicle.regNumber then
			continue;
		endif;
		app.myTrxDA.trxDeleteInterTerminalMove(itm, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endwhile;
	
	create itmArray transient;
	iter := app.myRoot.allInterTerminalVehicleJobs.createIterator;
	app.myRoot.allInterTerminalVehicleJobs.startKeyGeq(vehicle.regNumber, vehicle.state, iter);
	while iter.next(itvj) and itvj.vehicleID = vehicle.regNumber do
		itmArray.clear();
		itvj.allInterTerminalMoves.copy(itmArray);
		foreach obj in itmArray do
			itm := obj.CM_InterTerminalMove;
			app.myTrxDA.trxDeleteInterTerminalMove(itm, app.myPassport);
			self.assertNoTrxErrorsOrWarnings();
		endforeach;
		beginTransaction;
		delete itvj;												// 07/08/2014 cnwmh5
		commitTransaction;
	endwhile;
	
	foreach vvr in vehicle.visitRecords do
		vvrNumber :=  vvr.visitNumber;
		self.deleteVVR(vvr);
		self.assertIsDeletedMsg(vvr, method.name &amp; " | vvr Id: " &amp; vvrNumber &amp; " | vvr");
	endforeach;
	
	dontDeleteCarrier := self.opts.bool(UT_OPTS_DontDeleteCarrier);		// 20/08/2012 cnwmh5
	if not dontDeleteCarrier then
		beginTransaction;
		vehicle.carriers.clear();
		commitTransaction;
	endif;
	
	self.ignoreTrxWarnings(true);
	app.myTrxDA.trxDeleteVehicle(vehicle, app.myPassport); 
	self.assertNoTrxErrorsOrWarnings();
	self.assertIsDeletedMsg(vehicle, method.name &amp; " | vehicle Id: " &amp; _vehicleReg &amp; " | vehicle");
	
epilog
	delete mergeIter;
	delete iter;
	delete itmArray;
	
end;</source>
        <Parameter name="_vehicleReg" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="xDeleteWagonMasterByCode" id="4e49bc68-6107-4b64-a636-31a3f9ccdc80">
        <source>xDeleteWagonMasterByCode(_wagonMasterCode : String);
/*

Purpose:			
					In order to delete a Wagon Master, you must first delete all of its associated wagons.

Parameters:			

Return Value:		

Date			Who		Reason
27 July 2023	navpw1	Initial creation TFS: 56796 (57081)

*/

vars
	wagonMaster			: CM_WagonMaster;
	wagon				: CM_Wagon;
	cm_ObjectToDelete	: CM_Object;
	ls					: Boolean;
	wagonUpdateCtrl		: CMIF_WagonUpdateController;
	train				: CM_Train;
	pxyWagon			: CM_Wagon;

begin
	self.assertTrueMsg(_wagonMasterCode &lt;&gt; null, method.name &amp; " | wagonMasterCode is null");
	
	wagonMaster := self.getRoot.allWagonMasters[_wagonMasterCode];
	
	if app.isValidObject( wagonMaster ) then
		foreach wagon in wagonMaster.allWagons do
			if wagon.confirmed then
				beginTransaction;
				wagon.erase(0);
				commitTransaction;
				continue;
			endif; 
			app.myTrxDA.trxDeleteWagon(wagon, false, app.myPassport);
			self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
			self.assertNoTrxErrorsOrWarnings();
			
		endforeach;
		cm_ObjectToDelete := wagonMaster;
		app.myTrxDA.trxDeleteCMObject( cm_ObjectToDelete, app.myPassport );
		self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
		self.assertNoTrxErrorsOrWarnings();
		
	endif;
	
	self.assertIsDeletedMsg(wagonMaster, method.name &amp; " | wagonMaster");
	
end;</source>
        <Parameter name="_wagonMasterCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="xDeleteWagonMasterByObj" id="c33ede93-b6ae-41d4-96ec-c544e4b48037">
        <source>xDeleteWagonMasterByObj(_wagonMaster : CM_WagonMaster);
/*

Purpose:			
					In order to delete a Wagon Master, you must first delete all of its associated wagons.

Parameters:			

Return Value:		

Date			Who		Reason
27 July 2023	navpw1	Initial creation TFS: 56796 (57081)

*/

vars
	wagon				: CM_Wagon;
	cm_ObjectToDelete	: CM_Object;
	ls					: Boolean;
	wagonUpdateCtrl		: CMIF_WagonUpdateController;
	train				: CM_Train;
	pxyWagon			: CM_Wagon;
	
begin
	self.assertNotNullMsg(_wagonMaster, method.name &amp; " | _wagonMaster");
	
	if app.isValidObject( _wagonMaster ) then
		foreach wagon in _wagonMaster.allWagons do
			if wagon.confirmed then
				beginTransaction;
				wagon.erase(0);
				commitTransaction;
				continue;
			endif; 
			app.myTrxDA.trxDeleteWagon(wagon, false, app.myPassport);
			self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
			self.assertNoTrxErrorsOrWarnings();
			
		endforeach;
		cm_ObjectToDelete := _wagonMaster;
		app.myTrxDA.trxDeleteCMObject( cm_ObjectToDelete, app.myPassport );
		self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
		self.assertNoTrxErrorsOrWarnings();
		
	endif;
	
	self.assertIsDeletedMsg(_wagonMaster, method.name &amp; " | _wagonMaster");
	
end;</source>
        <Parameter name="_wagonMaster" type="CM_WagonMaster"/>
    </JadeMethod>
    <JadeMethod name="xGenerateInvoiceForMovement" id="429aca6e-02a6-4445-8232-c84065405b83">
        <source>xGenerateInvoiceForMovement(_voyage : CM_Voyage ;_moveType : String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 February 2022		navma1	Initial creation

*/

vars
	realMovement		: HMS_Movement;
	pxxyResourceUsed,
	resourceUsed		: HMS_ResourceUsed;
begin
	if _moveType = HMSMovementTypeArrival then
		realMovement := _voyage.getMovementArrival();
	endif;

	if not app.myPassport.hasErrors then
		foreach resourceUsed  in realMovement.HMS_VoyageMovement.allResourceUsed do 
		
		beginLoad;
		pxxyResourceUsed := resourceUsed.pxyCreateUpdateProxy();
		endLoad;
		
		app.myTrxCA.trxCreateInvoiceResourceCharge(pxxyResourceUsed,app.myPassport);
		
		delete pxxyResourceUsed;
		endforeach;
	endif;
epilog
	delete pxxyResourceUsed;
	endLoad;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_moveType" type="String"/>
    </JadeMethod>
    <JadeMethod name="xGetRailIoRake" id="879486f1-315e-4fab-9160-aeead1081b6b">
        <source>xGetRailIoRake(_railArea : CM_Rail) : CM_RailJSInOutRake;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
27 July 2023	navpw1	Initial creation TFS: 56796 (57081)

*/

vars
	obj				: Object;
	railIORake		: CM_RailJSInOutRake;
	railRakeIoType	: Integer;
	
begin
	self.assertNotNullMsg(_railArea, method.name &amp; " | railArea");
	
	if self.opts.includesKey(UT_OPTS_RailRakeIoType) then
		railRakeIoType := self.opts.int(UT_OPTS_RailRakeIoType);
	else
		railRakeIoType := Rail_JSIO_Type_Out;
	endif;
	
	foreach obj in _railArea.allRailJSInOut discreteLock do //Maybe change to railIORake in _railArea.allRailJSInOut discreteLock as CM_RailJSInOutRake
		if not obj.isKindOf(CM_RailJSInOutRake) then
			continue;
		endif;
		
		railIORake := obj.CM_RailJSInOutRake;
		
		if railIORake.getIoType() = railRakeIoType then
			break;
		endif;
		
		railIORake := null;
		
	endforeach;
	
	self.assertNotNull(railIORake);
	
	return railIORake;
	
end;</source>
        <Parameter name="_railArea" type="CM_Rail"/>
        <ReturnType type="CM_RailJSInOutRake"/>
    </JadeMethod>
    <JadeMethod name="xMoveVehicleToYard" id="2df017e8-b053-4837-b3d2-a55678df81b3">
        <source>xMoveVehicleToYard(_vehicle: CM_Vehicle input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2023	navpw1	Initial creation TFS: 54049 (55844)

*/

vars
	location: CM_YardController;
	
begin
	if _vehicle.getCurrentVisit.getGateIn &lt;&gt; null then
		location := _vehicle.getCurrentVisit.getGateIn.getDefaultYardLocation_IN (_vehicle); 	//getDefaultYardLane;
	else		
		location := getTerminal.myRoadJobSheet.myInTerminalUnknownLC;
	endif;
	app.myTrxUA.trxMoveVehicle(_vehicle, location, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
end;</source>
        <Parameter name="_vehicle" type="CM_Vehicle" usage="input"/>
    </JadeMethod>
    <JadeMethod name="xSetupBooking" id="8346adf4-c96a-44b2-b185-d6f26e9fa410">
        <source>xSetupBooking(_bookingId				: String;
				_status					: Integer;
				_operator				: CM_Operator;
				_voyage,
				_transhipVoyage			: CM_Voyage;
				_consignor, 
				_consignee, 
				_freightForwarder		: CM_ConsigneeConsignor;
				_carrier				: CM_Carrier;
				_stevedore				: CM_Stevedore;
				_destinationPortCode,
				_dischargePortCode,
				_remarks,
				_shippingReference,
				_packAsType,
				_customsAgent,
				_releaseNumber,
				_transportType			: String;
				_stockBooking,
				_receiveAsTranship,
				_directDelivery,
				_noEmptiesOut			: Boolean;
				_hazards				: CM_TIHazardByCodeDict) : CM_BookingRef;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 April 2023	navpw1	Initial creation TFS: 57616 (57435)

*/

vars
	pxyBooking, 
	realBooking				: CM_BookingRef;
	pxyBulkRelease,
	realBulkRelease			: CM_BulkRelease;
	dischargePort			: CM_Port;
	hazard					: CM_TIHazard;
	releaseNumber,
	carrierCode,
	consignorCode,
	consigneeCode,
	freightForwarderCode	: String;
	transportType			: Integer;
	dischargePortsArr		: StringArray;
	hazardsArray			: ObjectArray;
	
begin
	if _consignor &lt;&gt; null then
		consignorCode := _consignor.code;
	endif;
	
	if _consignee &lt;&gt; null then
		consigneeCode := _consignee.code;
	endif;
	
	if _freightForwarder &lt;&gt; null then
		freightForwarderCode := _freightForwarder.code;
	endif;
	
	if _carrier &lt;&gt; null then
		carrierCode := _carrier.code;
	endif;
	
	create dischargePortsArr transient;
	if _dischargePortCode &lt;&gt; null then
		dischargePort := app.myRoot.allPorts[_dischargePortCode];
		self.assertTrueMsg(dischargePort &lt;&gt; null, method.name &amp; " | dischargePort is null/could not be found");
		
		dischargePortsArr.add(_dischargePortCode);
		
	endif;
	
	create hazardsArray transient;
	if _hazards &lt;&gt; null and _hazards.isNotEmpty then
		
		foreach hazard in _hazards do
			hazardsArray.add(hazard);
			
		endforeach;
		
	endif;
	
	//Validate Enums
	//_packAsType
	if _packAsType &lt;&gt; app.getErrorString(PackAs_FCL) or
		_packAsType = app.getErrorString(PackAs_LCL) or
		_packAsType = app.getErrorString(PackAs_S)
	then
		self.assertTrueMsg(false, method.name &amp; " | _packAsType is invalid");
	endif;
	
	//_transportType
	if _noEmptiesOut = true and
		(_transportType &lt;&gt; BR_TYPE_ROAD_STR or
		_transportType &lt;&gt; BR_TYPE_RAIL_STR or
		_transportType &lt;&gt; BR_TYPE_SHIP_STR or
		_transportType &lt;&gt; BR_TYPE_PACKING_STR)
	then
		self.assertTrueMsg(false, method.name &amp; " | _transportType is invalid");
	endif;
	
	transportType := app.transportTypeStringToEnum(_transportType);
	
	create pxyBooking transient;
	pxyBooking.setProxy(_bookingId, null, null, null, consignorCode, null, _destinationPortCode,_dischargePortCode, null,
						dischargePortsArr, hazardsArray, null, null, null, _consignor, _consignee, _operator, _voyage, null, _remarks, null, null, null, null, null, null, 
						null,null,null, null, null, null, null, null, null, app.myPassport.myTerminal, null, null, _stockBooking, null, null, 
						_shippingReference, null, null, null, null, null, null, null, _noEmptiesOut, null, null, null, null, null, null, _status,
						null, null, null, _receiveAsTranship, _transhipVoyage, app.bookingPackAsStringToEnumb(_packAsType), _customsAgent, null, null,
						_directDelivery, _freightForwarder, _carrier, _stevedore);
	
	pxyBulkRelease := pxyBooking.allReleaseRequests.first;
	
	if pxyBooking.isReleaseEmptiesAllowed and pxyBulkRelease &lt;&gt; null and _noEmptiesOut then
		if _releaseNumber = null then
			releaseNumber := pxyBooking.bookingReference;	//Otherwise default to booking reference
		else
			releaseNumber := _releaseNumber;
		endif;
		
		pxyBulkRelease.setProxy(	releaseNumber, //code same as this booking reference number unless we are giving a different one
									transportType,
									true, //(not self.chkReservedOnly.value),  //release by type - not chkIsReservedOnly Now always true adm 070710 Par 24741
									BR_ACTIVE,
									null, ///availability grades null set on reserve selections
									null,//booking confirmation 
									carrierCode, //carrier
									null, //cargo remarks
									consigneeCode,		//consigneeCode
									null,
									consignorCode,		//consignor Code
									null,
									null,//_consignorVoyageCode 
									null, //date requested
									null,//_dateEstimatedRequired
									null,//_deliveryReasonCode
									null,//_deliveryReasonDescr
									null,//_deliveryReleaseNumber
									null,//_doorsDirection
									null,//_freightPayerCode
									pxyBooking,//CM_BookingRef
									null,//_loadPort
									null,//_destinationPort	//04 Nov 2009	NDL Par 21519
									dischargePort,//_dischargePort
									freightForwarderCode,//_freightForwarder
									null,//_transferToTerminal
									pxyBooking.myTerminal,
									pxyBooking.myOperator,//_operator
									null,//_operatorGroup
									pxyBooking.myVoyage,//_voyage
									null,		//_businessUnit	
									null,		//_fullRelease	
									null,  //pack locations
									null,
									null,
									null,
									pxyBooking.myTerminal.getConfig(MySubTerminalForTargetBulk).CM_SubTerminal, // subterm target
									null,
									false,
									_customsAgent,
									false,
									false,
									pxyBulkRelease.needsReview,	// don't change ot from here???
									pxyBulkRelease.blockEDIUpdates, 	// par 29481 - don't change from here par 29480 April 2012
									null,
									null,
									null,
									null
									);
		pxyBulkRelease.requests.purge();
	endif;
	
	return pxyBooking;
	
epilog
	delete dischargePortsArr;
	delete hazardsArray;
	
end;</source>
        <Parameter name="_bookingId" type="String"/>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_transhipVoyage" type="CM_Voyage"/>
        <Parameter name="_consignor" type="CM_ConsigneeConsignor"/>
        <Parameter name="_consignee" type="CM_ConsigneeConsignor"/>
        <Parameter name="_freightForwarder" type="CM_ConsigneeConsignor"/>
        <Parameter name="_carrier" type="CM_Carrier"/>
        <Parameter name="_stevedore" type="CM_Stevedore"/>
        <Parameter name="_destinationPortCode" type="String"/>
        <Parameter name="_dischargePortCode" type="String"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_shippingReference" type="String"/>
        <Parameter name="_packAsType" type="String"/>
        <Parameter name="_customsAgent" type="String"/>
        <Parameter name="_releaseNumber" type="String"/>
        <Parameter name="_transportType" type="String"/>
        <Parameter name="_stockBooking" type="Boolean"/>
        <Parameter name="_receiveAsTranship" type="Boolean"/>
        <Parameter name="_directDelivery" type="Boolean"/>
        <Parameter name="_noEmptiesOut" type="Boolean"/>
        <Parameter name="_hazards" type="CM_TIHazardByCodeDict"/>
        <ReturnType type="CM_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="xSetupBookingItem" id="8a7e079f-f5a5-46bf-a75d-48abd77de2c3">
        <source>xSetupBookingItem(_pxyBooking				: CM_BookingRef input;
					_cargoId,
					_cargoTypeAbbrev,
					_cargoSubTypeAbbrev,
					_isoTypeCode,
					_isoGroupCode,
					_operatorCode			: String;
					_hazards				: CM_HazardByCodeDict;
					_specialStowCode,
					_commodityCode, 
					_marks,
					_markNumber,
					_colour,
					_purchaseOrder,
					_serviceOrder,
					_description,
					_remarks,
					_generatorTypeCode,
					_trailerTypeCode		: String;
					_noEmptiesOut,
					_curtainsIn				: Boolean;
					_humidity,
					_ventilation			: Decimal;
					_ventUnits				: Integer;
					_carbonDioxide,
					_oxygen					: Decimal;
					_temperature			: Real;
					_height,
					_length,
					_width,
					_density,
					_volume,
					_weightGross,
					_weightNet				: Decimal;
					_productVolume			: Real;
					_quantity				: Integer;
					_matchMode 				: Integer)	: CM_BookingRefItem;					//navra1 - CR 63764/Task 64227 - 23rd May 2024
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 April 2023	navpw1	Initial creation TFS: 57616 (57435)
22 March 2024   navsp1 TFS ChangeRequest 63028: CUX FR* | TK 62942 | EDBIC BOOKING APIs - Add field GoLiveCrit 01
*/

vars
	root : CM_Root;
	iter : Iterator;
	
	cargoBolType : CM_CargoBOLType;
	cargoTypeId	: Integer;
	cargoType : CM_CargoType;
	product : CM_Product;
	specialStow : CM_SpecialStow;
	isoType : CM_ISOType;
	
	existingBookingItem : CM_BookingRefItem;
	pxyBookingRefItemCont : CM_BRefItemContainer;
	reason	: String;//05/04/2024	navkc1 Bug 63509
begin
	root := app.myRoot;
	
	//Validate Cargo Type
	cargoBolType := root.allCargoTypesById.getCargoTypeByAbbreviation(_cargoTypeAbbrev);
	
	if cargoBolType &lt;&gt; null and cargoBolType.isCargoType then
		cargoTypeId := cargoBolType.id;
		cargoType := cargoBolType.CM_CargoType;
		
	endif;
	self.assertTrueMsg(cargoTypeId &lt;&gt; null, method.name &amp; " | Setup: cargoTypeId is null/could not be found | Cargo Type Abbreviation: " &amp; _cargoTypeAbbrev);
	self.assertTrueMsg(cargoType &lt;&gt; null, method.name &amp; " | Setup: cargoType is null/could not be found | Cargo Type Abbreviation: " &amp; _cargoTypeAbbrev);
	
	if cargoType.isSubCargoTypeRequired then
		product := cargoType.allProducts[_operatorCode, _cargoSubTypeAbbrev];
		if product = null then
			iter := cargoType.allProducts.createIterator;
			cargoType.allProducts.startKeyGeq(null, _cargoSubTypeAbbrev, iter);
			while iter.next(product) do
				if product.code &lt;&gt; _cargoSubTypeAbbrev then
					continue;
				elseif product.code = _cargoSubTypeAbbrev then
					break;
				endif;
			endwhile;
		endif;
		delete iter;
		self.assertTrueMsg(product &lt;&gt; null, method.name &amp; " | Setup: product is null/could not be found | Sub Cargo Type Abbreviation: " &amp; _cargoSubTypeAbbrev);
		self.assertTrueMsg(product.code = _cargoSubTypeAbbrev, method.name &amp; " | Setup: product code is incorrect on found product | Sub Cargo Type Abbreviation: " &amp; _cargoSubTypeAbbrev);
		
	endif;
	
	if _specialStowCode &lt;&gt; null then
		specialStow := root.allSpecialStows[_specialStowCode];
		self.assertTrueMsg(specialStow &lt;&gt; null, method.name &amp; " | Setup: specialStow is null/could not be found | Special Stow Code: " &amp; _specialStowCode);
	endif;
	
	if _isoTypeCode &lt;&gt; null then
		isoType := root.allISOTypes[_isoTypeCode];
		self.assertTrueMsg(isoType &lt;&gt; null, method.name &amp; " | Setup: isoType is null/could not be found | ISO Type Code: " &amp; _isoTypeCode);
	endif;
	
	//Try to get existing booking item
	existingBookingItem := _pxyBooking.getMatchingItem(cargoType, _commodityCode, isoType, _cargoSubTypeAbbrev, _marks, _markNumber, _colour, _purchaseOrder, _serviceOrder, reason).CM_BRefItemContainer;
	
	//Increment existing item and add new hazards and continue
	if existingBookingItem &lt;&gt; null then
		/*foreach hazard in hazardsArr as CM_TIHazard do : hazardsLoop
			if existingBookingItem.allTIHazards[hazard.code] &lt;&gt; null then
				continue hazardsLoop;
			endif;
			
			existingBookingItem.allTIHazards.add(hazard);
			
		endforeach;*/
		
		existingBookingItem.increaseItemQuantity(1);
		if _pxyBooking.isReleaseEmptiesAllowed and _noEmptiesOut then //Only Applicable to ISO Containers
			existingBookingItem.setProxyReserveDetail(existingBookingItem.quantity, existingBookingItem.quantity, null, null);
		endif;
		
		return existingBookingItem;
		
	else
		//New Booking Item
		create pxyBookingRefItemCont transient;
		if cargoType.id = TI_CargoType_Container then
			//Container
			pxyBookingRefItemCont.setProxy(cargoTypeId, _commodityCode, _description, _remarks, _hazards, _isoTypeCode, _quantity, _weightGross, _quantity, null, 
										_humidity, _temperature, _ventilation, _ventUnits, _carbonDioxide, _oxygen, _curtainsIn, null, null, specialStow, _isoGroupCode, null,
										null, _purchaseOrder, _serviceOrder, _matchMode);		//navra1 - CR 63764/Task 64227 - 23rd May 2024
			
			pxyBookingRefItemCont.setMyBookingRef(_pxyBooking);
			if _pxyBooking.isReleaseEmptiesAllowed and _noEmptiesOut then //Only Applicable to ISO Containers
				pxyBookingRefItemCont.setProxyReserveDetail(1, 1, null, null);
			endif;
			
		else
			//Cargo Item
			pxyBookingRefItemCont.setProxyForCargo(cargoTypeId, _commodityCode, _description, _hazards, _quantity, _remarks, _height, _length,
													_width, _height.asStringJMT, _length.asStringJMT, _width.asStringJMT,
													null, _density, _volume, 1, _marks, _weightGross, product, null, null, _generatorTypeCode, specialStow,
													_cargoId, _colour, _markNumber, null, _weightNet, _productVolume, _trailerTypeCode, _purchaseOrder,
													_serviceOrder, _matchMode);							//navra1 - CR 63764/Task 64227 - 23rd May 2024
			pxyBookingRefItemCont.setMyBookingRef(_pxyBooking);
		endif;
		
		return pxyBookingRefItemCont;
	endif;
	
	return null;
	
end;</source>
        <Parameter name="_pxyBooking" type="CM_BookingRef" usage="input"/>
        <Parameter name="_cargoId" type="String"/>
        <Parameter name="_cargoTypeAbbrev" type="String"/>
        <Parameter name="_cargoSubTypeAbbrev" type="String"/>
        <Parameter name="_isoTypeCode" type="String"/>
        <Parameter name="_isoGroupCode" type="String"/>
        <Parameter name="_operatorCode" type="String"/>
        <Parameter name="_hazards" type="CM_HazardByCodeDict"/>
        <Parameter name="_specialStowCode" type="String"/>
        <Parameter name="_commodityCode" type="String"/>
        <Parameter name="_marks" type="String"/>
        <Parameter name="_markNumber" type="String"/>
        <Parameter name="_colour" type="String"/>
        <Parameter name="_purchaseOrder" type="String"/>
        <Parameter name="_serviceOrder" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_generatorTypeCode" type="String"/>
        <Parameter name="_trailerTypeCode" type="String"/>
        <Parameter name="_noEmptiesOut" type="Boolean"/>
        <Parameter name="_curtainsIn" type="Boolean"/>
        <Parameter name="_humidity" type="Decimal"/>
        <Parameter name="_ventilation" type="Decimal"/>
        <Parameter name="_ventUnits" type="Integer"/>
        <Parameter name="_carbonDioxide" type="Decimal"/>
        <Parameter name="_oxygen" type="Decimal"/>
        <Parameter name="_temperature" type="Real"/>
        <Parameter name="_height" type="Decimal"/>
        <Parameter name="_length" type="Decimal"/>
        <Parameter name="_width" type="Decimal"/>
        <Parameter name="_density" type="Decimal"/>
        <Parameter name="_volume" type="Decimal"/>
        <Parameter name="_weightGross" type="Decimal"/>
