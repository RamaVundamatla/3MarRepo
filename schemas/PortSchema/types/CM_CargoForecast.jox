    <JadeMethod name="auditId" id="521d7198-48ae-4ee8-999d-c4dd40aa67d6">
        <source>auditId(): String;
/*

Purpose:			The ID for the Audits

Parameters:			NONE

Return Value:		String	Returns the audited objects oid so we can find all the audits for a particular note if required

Date		Who		Reason
05 April 2022	navpw1	Initial creation TFS: 53132

*/

vars
	auditId	: String;

begin
	auditId := self.myParent.auditId;
	if self.myParent.isKindOf(CM_Voyage) then		//13.05.2022 navsrk	53142
		auditId &amp;=  " - " &amp; self.myParent.CM_Voyage.vesselName;		//13.05.2022 navsrk	53142
	elseif self.myParent.isKindOf(CM_Train) then	//13.05.2022 navsrk	53142
		auditId &amp;=  " - " &amp; self.myParent.CM_Train.description;		//13.05.2022 navsrk	53142
	endif;		//13.05.2022 navsrk	53142
	
	if self.myCargoType &lt;&gt; null then
		auditId &amp;= " - " &amp; self.myCargoType.abbreviation.String;
	endif;
	
	if self.myCommodity &lt;&gt; null then
		auditId &amp;= " - " &amp; self.myCommodity.code;
	endif;
	
	return auditId;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
