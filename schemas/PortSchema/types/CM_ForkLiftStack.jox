    <JadeMethod name="hasPower" id="aa7f6fb0-f8ec-40a7-8a42-8dc3ee407c85">
        <methodInvocation>mapping</methodInvocation>
        <source>hasPower(set: Boolean; _value: Boolean io) mapping;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// ---------------------------------------------------------------------------

vars
	lPowerGap	: ObjectArray;
	lc	: CM_YardController;
	gc : CM_GridController;
	iHavePower : Boolean;
begin

	if set then
		return;
	endif;
	
	iHavePower := false;
	foreach lc in self.allGridControllersByRowColumn do
		//cnwrd1 par 31313 18.4.13
		if lc.hasPower then
			iHavePower := true;
			break;
		endif;
		
		gc :=  lc.CM_GridController.getNextControllerOfType(CM_GapController);

		if gc &lt;&gt; null then
			if gc.hasPower then
				iHavePower := true;
				break;
			endif;
		endif;
	endforeach;

	_value := iHavePower;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="hasTIAccessRestrictions" id="e602b4a6-a8f6-4ed3-b807-2fce7f6b1e64">
