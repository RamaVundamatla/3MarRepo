    <JadeMethod name="dblClick" id="f111c050-2a3a-468d-a94a-cfff882dc78a">
        <updating/>
        <source>dblClick(table: Table input) updating;

//cnwjo3, some code moved from click.

vars
	obj: Object;
	expandColumn: Integer;
	hasRemarksCol : Integer;
	remarksCol : Integer;
	yas: ObjectArray;
begin
	expandColumn := self.getColumnByRowName(ETRow_HideShow);
	hasRemarksCol := self.getColumnByRowName(ETRow_HasRemarks);
	remarksCol := self.getColumnByRowName(ETRow_Remarks);
	
	
	

	if table.column = expandColumn then
		if table.row = 1 then
			self.selectAllYA();
			inheritMethod(table);
		elseif table.row = 2 then

// PAR 27705 (not fixed) - needs to make some changes here as to how to determine
// if the table is fully expanded or not.  self.isYAExpanded does not work reliably!!!

			self.expandAllYALocations(not self.isYAExpanded());
			inheritMethod(table);
		else
			//cnwjo3 ccms 1018.  funny enough the YAM table works a little better having this duplicate code here
			obj := table.accessRow(table.row).itemObject;
			if obj.isKindOf(CM_YardAllocation) then
				if table.column = 1 then
					self.expandYALocations(obj.CM_YardAllocation, not self.isYAExpanded());
					inheritMethod(table);
				endif;
			endif;
		endif;
		
	//04 Jan 2012	NDL	Par 28889
	elseif ( table.column = hasRemarksCol or table.column = remarksCol ) then
		obj := table.accessRow(table.row).itemObject;
		if obj.isKindOf(CM_YardAllocation) then
			create yas transient;
			yas.add(obj);
			self.openYAMaintForm(yas, null, 4);
			return;
		endif;
		
	else
		if table.row &lt;= table.fixedRows then
			self.deselectAll();
		endif;
	endif;

	//cnwjo3 ccms 1018
	if table.column &gt; 1 then  //don't edit if they are trying to expand YA
		self.editSelectedRow();
	endif;
	inheritMethod(table);
	
epilog
	delete yas;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
