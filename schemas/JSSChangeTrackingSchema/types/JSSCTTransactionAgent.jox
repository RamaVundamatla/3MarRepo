        <source>deleteEntityInTransState(): Boolean updating;
/*
*/
begin
	on Exception do self.xHandler(exception);
	on DeadlockException do self.xHandlerDeadlock(exception);
	on LockException do self.xHandlerLock(exception);

	if self.doValidate(self.JSSM_TRX_DELETE) then

		if self.lockEntity() then

			if self.doDelete() then
			else
				return false;
			endif;
		endif;
	else
