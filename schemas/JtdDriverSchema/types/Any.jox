<PrimType name="Any">
    <JadeMethod name="displayWithType" id="8ba82665-b4c8-4f4e-bae2-04ad9d1bb14b">
        <source>displayWithType():String;

vars
	s:String;
	type:Type;
begin
	type:=self.cnGetType;
	if type = null then
		return "null";
	endif;
	if type.name = "Object" then
		return self.String;
	else
		s:=s&amp;type.name&amp;"=";
		if type = String or type = TimeStamp then
			s:=s&amp;'"'&amp;self.asString&amp;'"';
		else
			s:=s&amp;self.getName;
		endif;
		return s;
	endif;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
</PrimType>
