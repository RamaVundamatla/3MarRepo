    <JadeMethod name="addPreviousForm" id="7e1b92bc-bb02-4c11-a27b-abb5e301a376">
        <updating/>
        <source>addPreviousForm(_form : Class) updating;
/*
Using the allPreviousForms array as a stack, just adding &amp; removing to/from the top/end

Date		Who		Reason
28 January 2009	cnwcp2	Initial creation
*/

vars

begin
	self.allPreviousForms.add(_form);
epilog

end;</source>
        <Parameter name="_form" type="Class"/>
    </JadeMethod>
    <JadeMethod name="cleanBackFormsMoreRecentThan" id="c1cb868d-1115-4368-bc69-48e4eacc1a00">
        <source>cleanBackFormsMoreRecentThan( _formClass : Class );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 March 2011	cnwndl1	Initial creation	Par 27277

*/

vars

	iter : Iterator;
	pos : Integer;
	obj : Object;
	firstForm : Object;
	size : Integer;
	
begin

	iter := self.allPreviousForms.createIterator;
	
	while iter.next(obj) do
		pos := pos + 1;
		if firstForm = null then
			if obj.Class = _formClass then
				firstForm := obj;
				break;
			endif;
		endif;
	endwhile;
	
	if firstForm = null then
		// none of this class found.  Nothing to do.
		return;
	endif;
	
	while true do
		size := self.allPreviousForms.size;
		if size = 1 or size &lt;= pos then
			// don't delete the last one its the logon.
			break;
		endif;
		// just another to remove - keep going.
		self.allPreviousForms.removeAt(size);
	endwhile;
	
epilog

	delete iter;

end;</source>
        <Parameter name="_formClass" type="Class"/>
    </JadeMethod>
    <JadeMethod name="cleanBackPrevFormsToFirstOf" id="393f12c3-721e-4681-997a-e9eb5b8a8eb0">
        <source>cleanBackPrevFormsToFirstOf(  _formClassSet : ClassSet ):Class;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 August 2015	cnwndl1	Initial creation	Par 36782

*/

vars

	iter : Iterator;
	pos : Integer;
	obj : Object;
	firstForm : Object;
	size : Integer;
	retClass : Class;
	
begin

	iter := self.allPreviousForms.createIterator;
	
	while iter.next(obj) do
		pos := pos + 1;
		if firstForm = null then
			if _formClassSet.includes(obj.Class) then
				firstForm := obj;
				retClass := obj.Class;
				break;
			endif;
		endif;
	endwhile;
	
	if firstForm = null then
		// none of this class found.  Nothing to do.
		return null;
	endif;
	
	while true do
		size := self.allPreviousForms.size;
		if size = 1 or size &lt; pos then
			// don't delete the last one its the logon.
			break;
		endif;
		// just another to remove - keep going.
		self.allPreviousForms.removeAt(size);
	endwhile;
	
	return retClass;
	
epilog

	delete iter;

end;</source>
        <Parameter name="_formClassSet" type="ClassSet"/>
        <ReturnType type="Class"/>
    </JadeMethod>
