    <JadeMethod name="create" id="b4a402c6-15cb-4d8c-af6e-34d7ae7204a1">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     03 March 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.callBackMethodName := self.Monitor_DefaultCallBackMethod;

end;</source>
    </JadeMethod>
    <JadeMethod name="updateProgress" id="b898e715-74c6-415b-8820-9252e881d872">
        <updating/>
        <source>updateProgress(_msg : String; _partsInJob, _partsDone : Integer) : Boolean updating;
//--------------------------------------------------------------
//Created: 31 October 2002 By: cnwgd1
//--------------------------------------------------------------
//24 Oct 2013	cnwrs1		Par 32843 code 4
vars
	gotException : Boolean;
begin
	if _msg &lt;&gt; null then
		self.message 	:= _msg;
	endif;

	self.partsInJob := _partsInJob;
	
	self.partsDone 	:= _partsDone;
	if self.myParent &lt;&gt; null then
		on Exception do app.handleDeletedObject (exception, self.myParent, gotException);	//24 Oct 2013	cnwrs1		Par 32843 code 4
		self.myParent.sendMsgWithParams(self.callBackMethodName, self);
		on Exception do null;
	endif;
	if self.monitorReturnValue &gt; 0 then
		return false;
	endif;
	return true;		
end;</source>
        <Parameter name="_msg" type="String"/>
        <Parameter name="_partsInJob" type="Integer"/>
        <Parameter name="_partsDone" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateProgressWithCaption" id="57046882-add0-4212-903c-88b0f9fe600d">
        <updating/>
        <source>updateProgressWithCaption(_msg : String; _partsInJob, _partsDone : Integer; _caption : String) : Boolean updating;
//
//08 Oct 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar
//
vars

begin
	self.newCaption := _caption;
	return self.updateProgress(_msg, _partsInJob, _partsDone);
end;
</source>
        <Parameter name="_msg" type="String"/>
        <Parameter name="_partsInJob" type="Integer"/>
        <Parameter name="_partsDone" type="Integer"/>
        <Parameter name="_caption" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
