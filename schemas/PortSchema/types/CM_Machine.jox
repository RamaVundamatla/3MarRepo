    <JadeMethod name="canMachineMoveCargoType" id="9f553cf1-1f78-48c0-b68e-f4a4f5cde43d">
        <source>canMachineMoveCargoType(_ti : CM_TrackedItem;
						_messageLogger : CM_MessageLogger) : Boolean protected;
/*

Purpose:		


Return Value:		


Date		Who		Reason
01 Dec 2006	cnwer1	Initial creation - refactored out of canMachineMove	
13 Jul 2010 cnwer1 	PAR 24612
*/
vars
	tmpCargoType : CM_CargoType;
		aStr : String;
begin
	tmpCargoType := _ti.myCargoType;
	//epr par 35156 only check weight in canMachineMoveWeight
	
	//epr par 24612 13/7/10
	if not self.allAllowedCargoTypes.includes(tmpCargoType) then
		aStr := app.getErrorString2(Machin_cannot_lift_cargo_type,self.id,tmpCargoType.description);
		if _messageLogger &lt;&gt; null then
			_messageLogger.addLog(aStr, SEVERE_INFO, Machin_cannot_lift_cargo_type);
		endif;
		return false;
	endif;
	
	return true;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_messageLogger" type="CM_MessageLogger"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canMachineMoveConnected" id="59d85ef0-973e-43c1-ad50-410b936be38f">
        <source>canMachineMoveConnected(_ti : CM_TrackedItem;
						_messageLogger : CM_MessageLogger;
						_strictAccessCheck : Boolean) : Boolean protected;
/*

Purpose:		


Return Value:		


Date		Who		Reason
01 Dec 2006	cnwer1	Initial creation - refactored out of canMachineMove	
07 Jan 2025	navtr3	JIRA 19368 CUX - Vehicle App - Reefer Container on a MAFI

*/
vars
	aStr : String;
	task : CM_RTQueueTask;
	containerIsConnected : Boolean;
begin
//--------------------
	//Simple test. Is TI connected?
	//--------------------
	
	//epr par 36103 23/4/15
	if not _strictAccessCheck and not self.myTerminal.getConfig(SetConnectedTIToHeld).Boolean then
		return true;
	endif;
	
	if not self.myTerminal.getConfig(SetConnectedTIToHeld).Boolean and
		app.hasAcknowledgedTIConnectError then
		return true;
	endif;
	
	containerIsConnected := _ti.isOnboardCargoConnected(); //07.01.2025 navtr3 #19368
	
	if  _ti.isConnected or containerIsConnected then //07.01.2025 navtr3 #19368
		// Raising this error means the question to staty connected or not is asked in the vehicle app
		if self.myTerminal.getConfig(ReeferMoveOSConnected).Boolean  then // ### TFS 51521 11AUG2021 NAVAB1
			// This method is called for all containers, the actual move and the overstowing containers
			// Only ask the question of the original item to be moved, not any over stwoing items
			task :=  _ti.getQueueTask();
			
			if task &lt;&gt; null and not task.isOverstowTask then 
				aStr := app.getErrorString2(MACH_LIFT_POWER, self.id.trimRight, _ti.id.trimRight);
				if _messageLogger &lt;&gt; null then
					_messageLogger.addLog(aStr, SEVERE_INFO, MACH_LIFT_POWER);
				endif;
				return false;
			endif;
		
		else
			aStr := app.getErrorString2(MACH_LIFT_POWER, self.id.trimRight, _ti.id.trimRight);
			if _messageLogger &lt;&gt; null then
				_messageLogger.addLog(aStr, SEVERE_INFO, MACH_LIFT_POWER);
			endif;
			return false;
		endif;
	endif;

	return true;

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_messageLogger" type="CM_MessageLogger"/>
        <Parameter name="_strictAccessCheck" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canMachineMoveContentStatus" id="0ad912d6-2c40-4b72-aabb-974bd58ac28d">
        <source>canMachineMoveContentStatus(_ti : CM_TrackedItem;
								_messageLogger : CM_MessageLogger) : Boolean protected;
/*

Purpose:		


Return Value:		


Date		Who		Reason
01 Dec 2006	cnwer1	Initial creation - refactored out of canMachineMove	

*/
								
vars
	contentsStatus : CM_ContentsStatus;
	aStr			: String;
begin
// CCMS 1438
	if _ti.cargoType = TI_CargoType_Container then
		if not self.allAllowableContentsStatuses.isEmpty() then
			contentsStatus := self.allAllowableContentsStatuses[_ti.CM_Container.contentsStatus];
			if contentsStatus = null then
				aStr := app.getErrorString3(MACH_LIFT_CONTENT_STATUS,self.id.trimRight, _ti.id.trimRight,  _ti.CM_Container.getContentsStatusDesc(true) );
				if _messageLogger &lt;&gt; null then
					_messageLogger.addLog(aStr, SEVERE_INFO, MACH_LIFT_CONTENT_STATUS);
				endif;
				return false;  	
			endif;	
		endif;
	endif;
	
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_messageLogger" type="CM_MessageLogger"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canMachineMoveLabourRestricted" id="9733d212-e07d-40e1-aaed-3eba956c71b2">
        <source>canMachineMoveLabourRestricted(	_ti : CM_TrackedItem;
								_toLocation : CM_LocationsController;
								_strictAccessCheck : Boolean;
								_messageLogger : CM_MessageLogger ) : Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 Apr 2010	cnwer1	Initial creation
06 Jul 2010 cnwer1	PAR 24517 if strictAcessCheck i.e. picking up or setting down rather than just viewing tasks
					give an alert
*/

vars
	aStr : String;
	sourceLocation : CM_LocationsController;
	alert		: CM_SystemAlert;
begin
	
	 // AKB 18/12/2000 581 testing. Added to resynch after restrictions have been removed
	if _toLocation &lt;&gt; null and _toLocation.hasRestrictions(LABOUR_RESTRICTION) then
		aStr:=app.getErrorString2(MACH_ACCESS_TARGET_LABOUR,self.id,_toLocation.getFullId());
		if _messageLogger &lt;&gt; null then
			_messageLogger.addLog(aStr,SEVERE_WARNING, MACH_ACCESS_TARGET_LABOUR);
		endif;
		
		if _strictAccessCheck then
			create alert;
			alert.details := aStr;
			alert.setSeverity(SEVERE_WARNING);
			alert.add;
		endif;
		
		return false;
	endif;

	if _ti  &lt;&gt; null then
		sourceLocation:=_ti.myPrimaryActualLocation;
	endif;
    // AKB 18/12/2000 581 testing. Added to resynch after restrictions have been removed
	if sourceLocation &lt;&gt; null and sourceLocation.hasRestrictions(LABOUR_RESTRICTION) then
		aStr:=app.getErrorString2(MACH_ACCESS_SOURCE_LABOUR,self.id,sourceLocation.getFullId());
		if _messageLogger &lt;&gt; null then
			_messageLogger.addLog(aStr,SEVERE_WARNING, MACH_ACCESS_SOURCE_LABOUR);
		endif;
	
		if _strictAccessCheck then
			create alert;
			alert.details := aStr;
			alert.setSeverity(SEVERE_WARNING);
			alert.add;
		endif;
	
		return false;
	endif;

	return true;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_toLocation" type="CM_LocationsController"/>
        <Parameter name="_strictAccessCheck" type="Boolean"/>
        <Parameter name="_messageLogger" type="CM_MessageLogger"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canMachineMoveStradSeperation" id="2a7cce74-3e18-469f-8e6c-dcf02f900d04">
        <source>canMachineMoveStradSeperation(_ti : CM_TrackedItem; _toLocation : CM_LocationsController;_messageLogger : CM_MessageLogger) : Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 April 2010	cnwer1	Initial creation

*/

vars
	sourceLocation 	: CM_LocationsController;
	otherMachine 	: CM_Machine;
	aStr			: String;
begin
	if _ti  &lt;&gt; null then
		sourceLocation:=_ti.myPrimaryActualLocation;
	endif;
	
	if sourceLocation &lt;&gt; null and self.isStraddleSeparated(sourceLocation,otherMachine) = false then
		aStr:=app.getErrorString3(MACH_ACCESS_SOURCE_STRAD_SEP,  self.id,sourceLocation.getFullId(),otherMachine.id);
		if _messageLogger &lt;&gt; null then
			_messageLogger.addLog(aStr,SEVERE_WARNING, MACH_ACCESS_SOURCE_STRAD_SEP);
		endif;
		
		return false;
	endif;
	
	if _toLocation &lt;&gt; null and self.isStraddleSeparated(_toLocation,otherMachine) = false then
		aStr := app.getErrorString3(MACH_ACCESS_TARGET_STRAD_SEP,self.id,_toLocation.getFullId(),otherMachine.id); 
		if _messageLogger &lt;&gt; null then
			_messageLogger.addLog(aStr,SEVERE_WARNING, MACH_ACCESS_TARGET_STRAD_SEP);
		endif;
	
		return false;
	endif;
	
	return true;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_toLocation" type="CM_LocationsController"/>
        <Parameter name="_messageLogger" type="CM_MessageLogger"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canMachineMoveTI" id="fbee3227-133c-44cc-9c20-13a60575965a">
        <source>canMachineMoveTI(	_ti					: CM_TrackedItem;
					_entry				: CM_RTQueueEntry;
					_toLocation 		: CM_LocationsController;
					 _strictAccessCheck : Boolean;
					_messageLogger : CM_MessageLogger): Boolean;

vars
	aStr 			: String;
begin

	if not self.available then
		aStr := app.getErrorString1(MACH_NOT_AVAILABLE,self.id.trimRight);
		if _messageLogger &lt;&gt; null then
			_messageLogger.addLog(aStr,SEVERE_INFO, MACH_NOT_AVAILABLE);	
		endif;
		return false;
	endif;
	if _ti = null then
		aStr := app.getErrorString(MACH_NO_CONTAINER);
		if _messageLogger &lt;&gt; null then
			_messageLogger.addLog(aStr,SEVERE_INFO, MACH_NO_CONTAINER);	
		endif;
		return false;
	endif;
	
	//01 Feb 2013	NDL	Par 31102
	if _ti.directDelivery then
		aStr := app.getErrorString(Cargo_is_direct_delivery);
		if _messageLogger &lt;&gt; null then
			_messageLogger.addLog(aStr,SEVERE_INFO, Cargo_is_direct_delivery);	
		endif;
		return false;
	endif;
	
	if not self.canMachineMoveContentStatus(_ti,_messageLogger) then
		return false;
	endif;
	
	//epr par 35156 7/11/14
	if not ( _ti.myCargoType.isBreakBulkMulti or  _ti.myCargoType.isBulkMulti) then
		if not self.canMachineMoveWeight(_ti,_entry,_messageLogger) then
			return false;
		endif;
	endif;

 	if not self.canMachineMove45s(_ti,_messageLogger) then // PAR 16415 CCMS 1029
		return false;
	endif;
 	if not self.canMachineMove30s(_ti,_messageLogger) then // PAR 16415 CCMS 1029
		return false;
	endif;
 	if not self.canMachineMove53s(_ti,_messageLogger) then // PAR 16415 CCMS 1029
		return false;
	endif;
 	if not self.canMachineMove40s(_ti,_messageLogger) then
		return false;
	endif;
 	
	if not self.canMachineMoveCargoType(_ti,_messageLogger) then
		return false;
	endif;
	
	/*epr 29/4/10 CCMS 1099 moved code from rtQueueTask :: queryMachineAssign so when machine is 
		doing an move with no rt q task the labour restriction is still checked and straddle
		seperation  N.B rtQueueTask :: queryMachineAssign calls this method
	*/
	if not self.canMachineMoveLabourRestricted(_ti,_toLocation,_strictAccessCheck,_messageLogger) then
		return false;
	endif;
	
	if not self.canMachineMoveStradSeperation(_ti,_toLocation,_messageLogger) then
		return false;
	endif;
	
	if self.machineType &lt;&gt; MACHINETYPE_IMV then
		//epr par 36103 23/4/15
		if not self.canMachineMoveConnected(_ti,_messageLogger,_strictAccessCheck) then
			return false;
		endif;
			
		//epr par 19700 18/5/09
		if _strictAccessCheck then
		
			if not self.canMachineAccessRestrictedTA(_ti,_toLocation,_messageLogger) then
				return false;
			endif;
			
			// AKB September 2001. Fork Lift Stack enhancements. From Here
			//epr par 27030 17/2/2011 passed in the _toLocation
			if  not self.canMachineAccessHeight(_ti,_toLocation,_messageLogger) then			// 13/01/2011 cnwmh5 #26724 - Only need to do if strict access checking
				return false;
			endif;
		endif;
		
		if not self.canMachineMoveToForkliftStack(_ti,_messageLogger) then
			return false;
		endif;
	elseif self.machineType = MACHINETYPE_IMV then
	// check that only has one 40 or 2 20's
		if not self.canIMVMoveTI(_ti,_toLocation ,_messageLogger) then
			return false;
		endif;
	endif;
	// AKB September 2001. Fork Lift Stack enhancements. To Here
	
	return true;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_entry" type="CM_RTQueueEntry"/>
        <Parameter name="_toLocation" type="CM_LocationsController"/>
        <Parameter name="_strictAccessCheck" type="Boolean"/>
        <Parameter name="_messageLogger" type="CM_MessageLogger"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canMachineMoveToForkliftStack" id="baa1d7ec-3aee-4fe5-be75-cd4893179d21">
        <source>canMachineMoveToForkliftStack(_ti : CM_TrackedItem;
								_messageLogger : CM_MessageLogger) : Boolean;
/*

Purpose:		


Return Value:		


Date		Who		Reason
01 Dec 2006	cnwer1	Initial creation - refactored out of canMachineMove	

*/

vars
	tmpLC : CM_LocationsController;
	lHeight	: Real;
	aStr 	: String;
begin
// if this is for a fork lift stack we have to check the height limits on Fulls, MTs and for Power
	tmpLC := _ti.getPrimaryLocation(QUEUE_MODE);
	if tmpLC.isKindOf(CM_YardController) then
		if tmpLC.myTerminalArea.isKindOf(CM_ForkLiftStack) then
			if _ti.isAttributeTrue(TI_Attrib_RequiresPower) then
				lHeight := tmpLC.myTerminalArea.CM_ForkLiftStack.maxHeightPower;
				if not tmpLC.canAccessHeight(lHeight, REAL_MODE) then
					aStr := app.getErrorString4(MACH_ACCESS_HEIGHT_POWER,self.id.trimRight, _ti.queuedLocnId.trimBlanks,_ti.id.trimRight , lHeight.asStringJMT);
					if _messageLogger &lt;&gt; null then
						_messageLogger.addLog(aStr, SEVERE_INFO, MACH_ACCESS_HEIGHT_POWER);
					endif;
					return false;
				endif;
			endif;
			if (not _ti.isFull) then
				lHeight := tmpLC.myTerminalArea.CM_ForkLiftStack.maxHeightMT;
				if not tmpLC.canAccessHeight(lHeight, REAL_MODE) then
					aStr :=app.getErrorString4(MACH_ACESS_AREA_HEIGHT_MT,self.id.trimRight, _ti.queuedLocnId.trimBlanks,_ti.id.trimRight , lHeight.asStringJMT); 
					if _messageLogger &lt;&gt; null then
						_messageLogger.addLog(aStr, SEVERE_INFO, MACH_ACESS_AREA_HEIGHT_MT);
					endif;
					return false;
				endif;
			else
				lHeight := tmpLC.myTerminalArea.CM_ForkLiftStack.maxHeightFull;
				if not tmpLC.canAccessHeight(lHeight, REAL_MODE) then
					aStr := app.getErrorString4(MACH_ACESS_AREA_HEIGHT_FULL,self.id.trimRight, _ti.queuedLocnId.trimBlanks,_ti.id.trimRight ,lHeight.asStringJMT); 
					if _messageLogger &lt;&gt; null then
						_messageLogger.addLog(aStr, SEVERE_INFO, MACH_ACESS_AREA_HEIGHT_FULL);
					endif;
					return false;
				endif;
			endif;
		endif;
	endif;
	return true;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_messageLogger" type="CM_MessageLogger"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canMachineMoveWeight" id="a718053f-2345-477c-b893-64113fdf5e1b">
        <source>canMachineMoveWeight(_ti 		   : CM_TrackedItem;
					_entry 		   : CM_RTQueueEntry;
					_messageLogger : CM_MessageLogger ) : Boolean;
/*

Purpose:		


Return Value:		


Date		Who		Reason
01 Dec 2006	cnwer1	Initial creation - refactored out of canMachineMove	
02 Jul 2024	jlika1	TFS 64996 CUX - CUX - Cargo Weight is Multiplied when Determining Machine Eligibility
*/
vars
	tmpCargoType 			: CM_CargoType;
	onMachineCargoWeight,
	totalWeight				: Decimal[14,4];
	aStr 					: String;
	tiWeight				: Decimal[14,4];
begin
	tmpCargoType := _ti.myCargoType;

	if tmpCargoType.isCheckMaxLift then
		onMachineCargoWeight := self.getCargoWeightOnMachine(_ti); //epr CCMS 1391 warehouse VMT 25/8/14
		// PAR 17136 	jobs were being  ignored as the teklogix client thought that they could 
		//					not lift this container because of the large weight, the large weight being 2 containers
		// 					As this was added in for the Dual lift capablity where you can lift 2 items, have added extra check for dual lift machines
		if self.isTandemLift and // PAR 17136
			_ti.isOverStowed(REAL_MODE) then
			totalWeight := _ti.getOverstowWeight();
			tiWeight    := totalWeight;
		else
			totalWeight := onMachineCargoWeight + _ti.totalWeight;
			tiWeight	:= _ti.totalWeight;
		endif;
		
		if totalWeight &gt; self.maxLiftWeight then			
			aStr := app.getErrorString5(MACH_MAX_LIFT_WEIGHT,self.id.trimRight,self.maxLiftWeight.asStringWeightJMT,_ti.id.asStringJMT,tiWeight.asStringWeightJMT(), onMachineCargoWeight.asStringWeightJMT()); 
			if _messageLogger &lt;&gt; null then
				_messageLogger.addLog(aStr,SEVERE_INFO, MACH_MAX_LIFT_WEIGHT);	
			endif;
			return false;  		
		endif;
		
		
	endif;
	return true;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_entry" type="CM_RTQueueEntry"/>
        <Parameter name="_messageLogger" type="CM_MessageLogger"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canTandemLift" id="d0a14d86-ad01-4064-a985-dff27f13c542">
        <source>canTandemLift() : Boolean;
/*

Date		Who		Reason
02 June 2017	cnwer1	Initial creation TFS 4612

*/

vars

begin
	return machineLiftType = TANDEM_LIFT;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canTwinLift" id="536ab43b-dae6-44bc-8be0-6c1fc12e799c">
        <methodInvocation>mapping</methodInvocation>
        <source>canTwinLift(set : Boolean; _value : Boolean io) mapping;
/*

Date		Who		Reason
02 June 2017	cnwer1	Initial creation TFS 4612

*/

vars

begin
	_value :=machineLiftType = TWIN_LIFT;
epilog

