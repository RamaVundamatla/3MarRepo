    <JadeMethod name="setProxy" id="5c3eb49c-7db2-4e79-8e09-6962defd9bab">
        <updating/>
        <source>setProxy(_packType 		: Integer;//see class constant packing types
		_cargoType 		: CM_CargoType;
		_bookRefItemObj	: CM_BookingRefItem;
		_isoType 		: CM_ISOType;
		_isoGroup		: CM_ISOTypeGroup;
		_product 		: CM_Product;
		_productStr,					//maybe this should be merged with descriptionSelection?
		_remarks		: String;
		_totalRequested : Integer;
		_allAvailGrades : IntegerArray;
		_clean,
		_doISOGroupCheck,
		_heavyRated 	: Boolean;
		_maskIds 		: StringArray;
		_maxToRelease : Integer;
		_color			: String;   //cnwjo3 par 20522 ccms 1071: start
		_descriptionSelection : String;		
		_heightSelection : Decimal;
		_lengthSelection : Decimal;
		_markNumber : String;
		_quantitySelection : Integer;
		_remarksSelection : String;
		_volumeSelection : Decimal;
		_weightSelection : Decimal;
		_widthSelection : Decimal;
		_markSelection : String;
		_densitySelection : Decimal;
		_typeSelection : String; 			// cnwjo3 par 20522 ccms 1071: end
		//_terminalArea : CM_TerminalArea; 	// 15/02/2010 cnwjre1 CCMS 1101 + 22634  -// 01/07/2015 cnwma1 PAR #36555
		_allTermAreaDict : CM_TAByIdDict;    // 01/07/2015 cnwma1 PAR #36555
		_myReceivalBOL	:CM_BOLIn;			// 24351 03/06/2010
		_bestPick	:Boolean;				// par 30309
		_sequence : String;
		_deliveryParty : CM_DeliveryParty;
		_deliveryAddress : CM_Address;
		_deliveryInstructions : String;
		_deliveryFromDT : TimeStamp;
		_deliveryToDT  : TimeStamp;
		_defaultAnyAmount,
		_defaultAnyID : Boolean;
		_matchClientRef : String;
		_matchUNDGCode : String;
		_matchOrderNum : String;
		_matchPurchaseOrder : String;
		_matchReceivedDT : TimeStamp;
		_matchReleasedDT : TimeStamp;
		_matchRemarks : String;
		_matchVesselCode : String;
		_maxWeightRequested : Decimal;	// ### TFS 53953 11July2022 NAVPW1
		_lineNumber : Integer;			//12-07-2022 navtnr20 53974
		_customerReference : String	;	//12-07-2022 navtnr20 53974
		_cargoGroup     : CM_CargoGroup; //28/06/2023 navmv20 CR 58410 Task 58411
		_byTypeByWeight : Boolean;
		_locnByOldestDate : Boolean; 	//19/02/2023	navkc1 CR 60078 Task 62450
		_myCommodity : CM_Commodity;	//24/04/2025	navrv30	MTN 
		_contentsCargoType : CM_CargoType
		) updating;
/*
----------   ----------  --------------------------------------------------
Created:	18 May 2007 By cnwth2

Purpose:	new release request form to come through here (not through CMIF)

Changed On		Changed By		Reason
27/08/2009		cnwjo3			updating for CCMS 1071 par 20522
19/09/2012		cnwcs5			par 30390 - removed myOperatorGroup, doorsDirection, voyageCode property
25/09/2012		cnwcs5			par 30390 - add bestPickParameter
//09 Sep 2014	cnwrs1	CCMS 2351 att Sequence to Release request 
//01/07/2015	cnwma1	PAR #36555 CCMS 2509 TFS - Multi-location selection for MTs for vessel release
11/03/2016		cnwdap1			PAR #37581 densitySelection is now a Decimal property
13/06/22 		jlier1	TFS 53678
27 Jun 2022		navpw1  TFS 53953 EUP - EDI - Cargo Group Reservation via EDI
//19/07/2022	navtnr20	ChangeRequest 53974: EUP - OUT - Additional Fields on Release Line Level	
28 June 2023 navmv20 CR 58410 Task 58411: UI - Cargo Review - Release Request
19/07/2023		jlizm1	TFS 58461 Change release mark number to string
24/07/2023		navdap1	TFS 58923 EUP CallOff EDI Data Type / Data Load
6/12/2023	navcs2	ChangeRequest 57537: EUP | Release Request By Type - with Weight
24/04/2025	navrv30	MTN 34319 EUP | Creating a Release Request from Cargo Review - Validation
23/10/2025		jlizm1		MTN 36255 Rotabox Assign Release To Vessel
----------   ----------  --------------------------------------------------
*/
vars
	ti : CM_TrackedItem;		// TFS 58923
begin
	self.packType 			:= _packType;
	self.myCargoType		:= _cargoType;
	self.myBookingRefItem	:= _bookRefItemObj;
	self.myISOType			:= _isoType;
	self.myISOGroup			:= _isoGroup; //cnwrd1 par 20810 9/10/9
	self.myProduct			:= _product;
	self.productStr			:= _productStr;
	self.remarks			:= _remarks;
	self.totalRequested 	:= _totalRequested;
	self.clean 				:= _clean;
	self.heavyRated			:= _heavyRated;
	self.bestPick			:= _bestPick;
	
	self.allAvailabilityGrades.clear();
	self.allTerminalAreas.clear();      		// 01/07/2015 cnwma1 PAR #36555
	
	if _allAvailGrades &lt;&gt; null then
		_allAvailGrades.copy(self.allAvailabilityGrades);
	endif;
	
	if _maskIds &lt;&gt; null then
		self.setIds(_maskIds);
	endif;
	
	if _allTermAreaDict &lt;&gt; null then				// 01/07/2015 cnwma1 PAR #36555
		_allTermAreaDict.copy(self.allTerminalAreas);
	endif;

	
	self.maxToRelease		:= _maxToRelease;
	
	//cnwjo3 par 20522 ccms 1071
	self.colour 				:= _color;
	self.descriptionSelection   := _descriptionSelection;
	self.heightSelection 		:= _heightSelection;
	self.lengthSelection 		:= _lengthSelection;
	self.markNumber 			:= _markNumber;
	self.quantitySelection 		:= _quantitySelection;
	self.remarksSelection 		:= _remarksSelection;
	self.volumeSelection 		:= _volumeSelection;
	self.weightSelection 		:= _weightSelection;
	self.widthSelection 		:= _widthSelection;
	self.markSelection 			:= _markSelection;
	self.densitySelection 		:= _densitySelection;
	self.typeSelection 			:= _typeSelection;
	self.myBOLIn 				:= _myReceivalBOL;	// #24351	03/063/2010
	self.sequence := _sequence;
	//self.setTerminalArea(_terminalArea);			// 15/02/2010 cnwjre1 CCMS 1101 + 22634	 // 01/07/2015 cnwma1 PAR #36555
	self.setTerminalArea(_allTermAreaDict);			// 01/07/2015 cnwma1 PAR #36555
	
	self.myDeliveryParty:=_deliveryParty;
	self.myDeliveryAddress:=_deliveryAddress;
	self.deliveryInstructions:=_deliveryInstructions;
	self.deliveryFrom:=_deliveryFromDT;
	self.deliveryTo:=_deliveryToDT;
	self.defaultAnyAmount:=_defaultAnyAmount;
	self.defaultAnyId:=_defaultAnyID;
	self.cargoMatchClientReference:=_matchClientRef;
	self.cargoMatchOrderNumber:=_matchOrderNum;
	self.cargoMatchPurchaseOrder:=_matchPurchaseOrder;
	self.cargoMatchReceiveDate:=_matchReceivedDT;
	self.cargoMatchReleaseDate:=_matchReleasedDT;
	self.cargoMatchRemarks:=_matchRemarks;
	self.cargoMatchUNDGcode:=_matchUNDGCode;
	self.cargoMatchVesselCode:=_matchVesselCode;
	self.maxWeightRequested := _maxWeightRequested; // ### TFS 53953 11July2022 NAVPW1
	self.lineNumber := _lineNumber;		//12-07-2022 navtnr20 53974
	self.customerReference := _customerReference; //12-07-2022 navtnr20 53974
	self.myCargoGroup := _cargoGroup; //28/06/2023 navmv20 CR 58410 Task 58411
	self.myCommodity := _myCommodity; 	//24/04/2025	navrv30	MTN 34319
	self.byTypeByWeight := _byTypeByWeight;		// 6/12/2023 navcs2 ChangeRequest 57537
	self.locnByOldestTransportArrival := _locnByOldestDate; //19/02/2023	navkc1 CR 60078 Task 62450
	self.myContentsCargoType := _contentsCargoType; // MTN 36255
	
	// TFS 58923 default cargo type and cargo sub type to cargo group if it's set and cargo type isn't
	if self.myCargoGroup &lt;&gt; null and self.myCargoType = null then
		ti := self.myCargoGroup.allAssignedTrackedItems.first;
		if ti &lt;&gt; null then
			self.myCargoType := ti.myCargoType;
			self.myProduct := ti.myProduct;
		endif;
	endif;
	// TFS 58923 end
end;</source>
        <Parameter name="_packType" type="Integer"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_bookRefItemObj" type="CM_BookingRefItem"/>
        <Parameter name="_isoType" type="CM_ISOType"/>
        <Parameter name="_isoGroup" type="CM_ISOTypeGroup"/>
        <Parameter name="_product" type="CM_Product"/>
        <Parameter name="_productStr" type="String"/>
