    <JadeMethod name="findFirstReceivalTrans" id="cce3c82a-eaf0-4a5e-9037-a72a9d49d29a">
        <source>findFirstReceivalTrans(): CM_TITransaction;
// ### TFS CR 58230 TASK 58231 24JUL2023 NAVAB1
vars
	trans		: CM_TITransaction;
	found		: Boolean;
	tmpCreate	: CM_TITransaction;
	
begin
/*
	IMPORTANT - this only gets the first receivel transaction for storage calculation purposes.
	USE WITH CAUTION!
*/

	foreach trans in self do
		if trans.isDeleted then		// ignore deleted transactions
			continue;
		endif;
		if trans.type = TRANS_TYPE_CREATED then
			// If using retrospective transactions then can have a
			// receival transaction prior to the create transaction.
			// Record the create and keep searching.  If don't find any
			// others then return the create transaction below.
			tmpCreate := trans;
			continue;
		endif;
		if trans.isReceivalTypeForStorage() then
			found := true;
			break;
		endif;
	endforeach;
	
	if found then
		return trans;
	elseif tmpCreate &lt;&gt; null then
		return tmpCreate;
	endif;
	
	return null;
end;</source>
        <ReturnType type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="findLastReceivalTrans" id="09f7a063-d9be-4e60-9bc0-f7fdf4669a31">
        <source>findLastReceivalTrans(): CM_TITransaction;
// ---------------------------------------------------------------------------
// Created:     10 January 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	trans		: CM_TITransaction;
	found		: Boolean;
	tmpCreate	: CM_TITransaction;
	
begin
/*
	IMPORTANT - this only gets the last receivel transaction for storage calculation purposes.
	USE WITH CAUTION!
*/

	foreach trans in self reversed do
		if trans.isDeleted then		// ignore deleted transactions
			continue;
		endif;
		if trans.type = TRANS_TYPE_CREATED then
			// If using retrospective transactions then can have a
			// receival transaction prior to the create transaction.
			// Record the create and keep searching.  If don't find any
			// others then return the create transaction below.
			tmpCreate := trans;
			continue;
		endif;
		if trans.isReceivalTypeForStorage() then
			found := true;
			break;
		endif;
	endforeach;
	
	if found then
		return trans;
	elseif tmpCreate &lt;&gt; null then
		return tmpCreate;
	endif;
	
	return null;
end;</source>
        <ReturnType type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="findLastStorageRelevantTrans" id="ac75003d-3192-46aa-8856-dd1ca7576744">
        <source>findLastStorageRelevantTrans(): CM_TITransaction;
// ---------------------------------------------------------------------------
// Created:     10 January 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	trans	: CM_TITransaction;
	found	: Boolean;
	tmpCreate	: CM_TITransaction;
begin
	foreach trans in self reversed do
		if trans.type = TRANS_TYPE_CREATED then
			// If using retrospective transactions then can have a
			// storage relevant transaction prior to the create transaction.
			// Record the create and keep searching.  If don't find any
			// others then return the create transaction below.
			tmpCreate := trans;
			continue;
		endif;
		if not trans.isDeleted and trans.isStorageRelevant() then
			found := true;
			break;
		endif;
	endforeach;
	
	if found then
		return trans;
	elseif tmpCreate &lt;&gt; null then
		return tmpCreate;
	endif;
	
	return null;
end;</source>
        <ReturnType type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="findLastSubTermReceivalTrans" id="0799a5e6-59c8-48c2-ae9f-7008279e0783">
        <source>findLastSubTermReceivalTrans(): CM_TITransaction;
// ---------------------------------------------------------------------------
// Created:     10 January 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	trans	: CM_TITransaction;
	found	: Boolean;
	tmpCreate	: CM_TITransaction;
begin
	foreach trans in self reversed do
		if trans.type = TRANS_TYPE_CREATED then
			// If using retrospective transactions then can have a
			// receival transaction prior to the create transaction.
			// Record the create and keep searching.  If don't find any
			// others then return the create transaction below.
			tmpCreate := trans;
			continue;
		endif;
		if trans.type = TRANS_TYPE_REC_ST_DEPOT_INT			// CCMS 1875
		or trans.type = TRANS_TYPE_REC_ST_DEPOT_RAIL		// CCMS 1875
		or trans.type = TRANS_TYPE_REC_ST_DEPOT_ROAD		// CCMS 1875
		or trans.type = TRANS_TYPE_REC_ST_DEPOT_SHIP		// CCMS 1875
		or trans.type = TRANS_TYPE_REC_ST_MARINE_INT		// CCMS 1875
		or trans.type = TRANS_TYPE_REC_ST_MARINE_RAIL		// CCMS 1875
		or trans.type = TRANS_TYPE_REC_ST_MARINE_ROAD		// CCMS 1875
		or trans.type = TRANS_TYPE_REC_ST_MARINE_SHIP		// CCMS 1875
		or trans.type = TRANS_TYPE_REC_ST_WHOUSE_INT		// CCMS 1875
		or trans.type = TRANS_TYPE_REC_ST_WHOUSE_RAIL		// CCMS 1875
		or trans.type = TRANS_TYPE_REC_ST_WHOUSE_ROAD		// CCMS 1875
		or trans.type = TRANS_TYPE_REC_ST_WHOUSE_SHIP		// CCMS 1875
		or trans.type = TRANS_TYPE_RECEIVE_ST_DEPOT			// CCMS 1875
		or trans.type = TRANS_TYPE_RECEIVE_ST_MARINE		// CCMS 1875
		or trans.type = TRANS_TYPE_RECEIVE_ST_WHOUSE		// CCMS 1875
		then
			found := true;
			break;
		endif;
		if global.isTiTxnOfType(trans.type, TRANS_TYPE_RECEIVE) then
			found := true;
			break;
		endif;
	endforeach;
	
	if found then
		return trans;
	elseif tmpCreate &lt;&gt; null then
		return tmpCreate;
	endif;
	
	return null;
end;</source>
        <ReturnType type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="getAllTransactionsOfClass" id="6e5d918d-b199-4417-9d1e-cd6b18abc93e">
        <source>getAllTransactionsOfClass( _class : Class; _trxDict : CM_TITransactionByTypeDateDict input; _includeDeleted : Boolean );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 September 2016	cnwndl1	Initial creation	TFS 2649 / 2001

*/

vars

	iter : Iterator;
	tiTrx : CM_TITransaction;

begin

	if self.isEmpty then
		return;
	endif;
	
	iter := self.createIterator;
	while iter.next( tiTrx ) do
		if tiTrx.class &lt;&gt; _class then
			continue;
		endif;
		if tiTrx.isDeleted then
			if not _includeDeleted then
				continue;
			endif;
		endif;
		_trxDict.add( tiTrx);
	endwhile;

epilog

	delete iter;

end;</source>
        <Parameter name="_class" type="Class"/>
        <Parameter name="_trxDict" type="CM_TITransactionByTypeDateDict" usage="input"/>
        <Parameter name="_includeDeleted" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getFirstTransOfType" id="135ebe7f-7152-444b-a680-6b8f46fc9920">
        <source>getFirstTransOfType( _trxType : Integer ):CM_TITransaction;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 June 2016	cnwndl1	Initial creation	TFS 1904

*/

vars

	iter : Iterator;
	tiTrx : CM_TITransaction;

begin

	if self.isEmpty then
		return null;
	endif;
	
	iter := self.createIterator;
	while iter.next( tiTrx ) do
		if tiTrx.type = _trxType then
			return tiTrx;
		endif;
	endwhile;

	return null;

epilog

	delete iter;

end;</source>
        <Parameter name="_trxType" type="Integer"/>
        <ReturnType type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="getLastSubTermReceive" id="b75103e1-72ac-41d5-bfcf-f79207a0d64c">
        <source>getLastSubTermReceive(): CM_TITransaction;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 December 2014	cnwndl1	Initial creation	Par 35295

*/

vars

	trans	: CM_TITransaction;
	
begin

	foreach trans in self reversed do
		if trans.type = TRANS_TYPE_REC_ST_DEPOT_INT		
		or trans.type = TRANS_TYPE_REC_ST_DEPOT_RAIL	
		or trans.type = TRANS_TYPE_REC_ST_DEPOT_ROAD	
		or trans.type = TRANS_TYPE_REC_ST_DEPOT_SHIP	
		or trans.type = TRANS_TYPE_REC_ST_MARINE_INT	
		or trans.type = TRANS_TYPE_REC_ST_MARINE_RAIL	
		or trans.type = TRANS_TYPE_REC_ST_MARINE_ROAD	
		or trans.type = TRANS_TYPE_REC_ST_MARINE_SHIP	
		or trans.type = TRANS_TYPE_REC_ST_WHOUSE_INT	
		or trans.type = TRANS_TYPE_REC_ST_WHOUSE_RAIL	
		or trans.type = TRANS_TYPE_REC_ST_WHOUSE_ROAD	
		or trans.type = TRANS_TYPE_REC_ST_WHOUSE_SHIP	
		or trans.type = TRANS_TYPE_RECEIVE_ST_DEPOT		
		or trans.type = TRANS_TYPE_RECEIVE_ST_MARINE	
		or trans.type = TRANS_TYPE_RECEIVE_ST_WHOUSE	
		then
			return trans;
		endif;
	endforeach;
	
	return null;
	
end;</source>
        <ReturnType type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="getLastSubTermRelease" id="6042b2f7-db88-4260-adb4-f9a864bf381d">
        <source>getLastSubTermRelease(): CM_TITransaction;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 December 2014	cnwndl1	Initial creation	Par 35295

*/

vars
	trans	: CM_TITransaction;
begin
	foreach trans in self reversed do
		if trans.type = TRANS_TYPE_REL_ST_DEPOT_INT			
		or trans.type = TRANS_TYPE_REL_ST_DEPOT_RAIL		
		or trans.type = TRANS_TYPE_REL_ST_DEPOT_ROAD		
		or trans.type = TRANS_TYPE_REL_ST_DEPOT_SHIP		
		or trans.type = TRANS_TYPE_REL_ST_MARINE_INT		
		or trans.type = TRANS_TYPE_REL_ST_MARINE_RAIL		
		or trans.type = TRANS_TYPE_REL_ST_MARINE_ROAD		
		or trans.type = TRANS_TYPE_REL_ST_MARINE_SHIP	
		or trans.type = TRANS_TYPE_REL_ST_WHOUSE_INT		
		or trans.type = TRANS_TYPE_REL_ST_WHOUSE_RAIL		
		or trans.type = TRANS_TYPE_REL_ST_WHOUSE_ROAD		
		or trans.type = TRANS_TYPE_REL_ST_WHOUSE_SHIP		
		or trans.type = TRANS_TYPE_RELEASE_ST_DEPOT		
		or trans.type = TRANS_TYPE_RELEASE_ST_MARINE		
		or trans.type = TRANS_TYPE_RELEASE_ST_WHOUSE		
		then
			return trans;
		endif;
	endforeach;
	
	return null;
end;</source>
        <ReturnType type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="getLastTransOfType" id="59ff35f1-89c8-467e-a977-f645cf9a9d36">
        <source>getLastTransOfType( _trxType : Integer; _context: Object):CM_TITransaction;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 July 2016	cnwndl1	Initial creation	TFS 2239

*/

vars

	iter : Iterator;
	tiTrx : CM_TITransaction;
	code : String;
	checkValue: String;

begin

	if self.isEmpty then
		return null;
	endif;
	
	iter := self.createIterator;
	while iter.back( tiTrx ) do
		if tiTrx.type = _trxType then
			if _context &lt;&gt; null then		// 7/11/16 cnwmp6 TFS 2891
				if _context.isKindOf(CM_BulkRelease) then
					if _trxType = TRANS_TYPE_REL_REQ_ASSIGN then
						code := _context.CM_BulkRelease.code;
						checkValue := tiTrx.CM_RelRequestAssign.myBulkReleaseCode;
					elseif _trxType = TRANS_TYPE_REL_REQ_UNASSIGN then
						code := _context.CM_BulkRelease.code;
						checkValue := tiTrx.CM_RelRequestUnassign.myBulkReleaseCode;
					endif;
					if code &lt;&gt; checkValue then
						continue;
					endif;
				endif;
			endif;
			return tiTrx;
		endif;
	endwhile;

	return null;

epilog

	delete iter;

end;</source>
        <Parameter name="_trxType" type="Integer"/>
        <Parameter name="_context" type="Object"/>
        <ReturnType type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="includesTrxType" id="2d3f7b16-2573-40b8-abe4-9e07749d56ee">
        <source>includesTrxType( _trxType : Integer ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 June 2015	cnwndl1	Initial creation	Par 36338

*/

vars

	iter : Iterator;
	tiTrx : CM_TITransaction;

begin

	if self.isEmpty then
		return false;
	endif;
	
	iter := self.createIterator;
	while iter.next( tiTrx ) do
		if tiTrx.type = _trxType then
			return true;
		endif;
	endwhile;

	return false;

epilog

	delete iter;

end;</source>
        <Parameter name="_trxType" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="listAllTypes" id="608cea1a-2e84-4753-903c-ef075d6c2425">
        <source>listAllTypes():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 August 2018	jlgndl1	Initial creation	TFS 40400

*/

vars

	iter : Iterator;
	tiTrx : CM_TITransaction;
	tiTrxTypeArray : StringArray;
	str : String;
	retValue : String;

begin

	if self.isEmpty then
		return null;
	endif;
	
	create tiTrxTypeArray transient;
	
	iter := self.createIterator;
	while iter.next( tiTrx ) do
		str := tiTrx.typeString;
		if not tiTrxTypeArray.includes( str ) then
			tiTrxTypeArray.add( str );
		endif;
	endwhile;
	
	if not tiTrxTypeArray.isEmpty then
		foreach str in tiTrxTypeArray do
			if retValue &lt;&gt; null then
				retValue := retValue &amp; ",";
			endif;
			retValue := retValue &amp; str;
		endforeach;
	endif;

	return retValue;

epilog

	delete tiTrxTypeArray;
	delete iter;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</CollClass>
