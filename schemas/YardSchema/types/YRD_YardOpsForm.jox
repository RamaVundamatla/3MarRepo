    <JadeMethod name="positionQueryFrame" id="f5607559-2005-48d8-b774-0009f434be3b">
        <source>positionQueryFrame();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 August 2009	cnwrd1	Initial creation

*/

vars

begin
	self.frmSearcher.left		:=	(self.width / 2) - (self.frmSearcher.width / 2);
	self.frmSearcher.top		:=	100;
	self.frmSearcher.height	:=	350;
	self.frmSearcher.width		:=	437;
	
	self.frmSearcher.top		:=	self.frmQueryToolbar.clientHeight()+2;
	self.frmSearcher.left		:=	0;
	self.frmSearcher.height	:=	frmSearcher.clientHeight() - (self.frmQueryToolbar.height + 30);
	self.frmSearcher.width		:=	self.frmSearcher.clientWidth();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="resetSelectedNotOfClass" id="0885e2b1-0243-4a5e-bbc5-c93478d4410c">
        <source>resetSelectedNotOfClass(_wle: CM_WorkListEntry);
// -----------------------------------------------------------------------------
// Created:		29 July 2009 by consw1
//
// Purpose:		Reset selected rows which are not in the same class as the given WLE
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	classSelected : Class;
	wle	: CM_WorkListEntry;
	wleArray : CM_WLEArray;
	
begin
	classSelected := CM_YardWLE;
	
	if _wle &lt;&gt; null then
		classSelected := _wle.class;
	endif;

	create wleArray transient;
	self.getWLEsInTableSelectedOfClass(classSelected, wleArray);
	
	if wleArray.size = self.tblWorkEntries.allSelectedObjects.size then
		return;
	endif;
	
	self.tblWorkEntries.clearAllSelected();
	foreach wle in wleArray do
		self.tblWorkEntries.selectObject(wle, false);
	endforeach;

epilog
	delete wleArray;
end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
    </JadeMethod>
