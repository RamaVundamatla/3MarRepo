end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="6e097e96-5dc3-49b4-9ec7-52fc3d492d3c">
        <updating/>
        <source>setProxy(_id : String; _empties, _exports, _imports, _full, _storage, _tranships : Boolean;
		 _availabilityGrades : CM_MTGradeByCodeDict;
		 _isoGroups : CM_ISOTypeGroupByCodeDict; _isoTypes : CM_ISOTypeByCodeDict; 
		 _operators : CM_OperatorByCodeDict; _toDoTasks : CM_ToDoTaskDescByCode;
		 _mTGrade: CM_MTGrade) updating;

vars

begin
	self.id := _id;
	self.empties := _empties;
	self.exports := _exports;
	self.imports := _imports;
	self.full := _full;
	self.storage := _storage;
	self.tranships := _tranships;		// 21/09/2010 cnwmh5 #25602
	self.availabilityGradeToApply := _mTGrade;
	
	self.availabilityGrades.clear;
	self.isoGroups.clear;
	self.isoTypes.clear;
	self.operators.clear;
	self.toDoTasks.clear;

	_availabilityGrades.copy(self.availabilityGrades);
	_isoGroups.copy(self.isoGroups); 
	_isoTypes.copy(self.isoTypes);
	_operators.copy(self.operators);
	_toDoTasks.copy(self.toDoTasks);
end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_empties" type="Boolean"/>
        <Parameter name="_exports" type="Boolean"/>
        <Parameter name="_imports" type="Boolean"/>
        <Parameter name="_full" type="Boolean"/>
        <Parameter name="_storage" type="Boolean"/>
        <Parameter name="_tranships" type="Boolean"/>
        <Parameter name="_availabilityGrades" type="CM_MTGradeByCodeDict"/>
        <Parameter name="_isoGroups" type="CM_ISOTypeGroupByCodeDict"/>
        <Parameter name="_isoTypes" type="CM_ISOTypeByCodeDict"/>
        <Parameter name="_operators" type="CM_OperatorByCodeDict"/>
        <Parameter name="_toDoTasks" type="CM_ToDoTaskDescByCode"/>
        <Parameter name="_mTGrade" type="CM_MTGrade"/>
    </JadeMethod>
    <JadeMethod name="templateMatchAvaGrade" id="f8347846-2f86-4bee-a7dd-d7212b04f792">
        <source>templateMatchAvaGrade(_template: CM_ToDoTemplate; _strDesc: String io): Boolean protected;
//----------------------------------------------------------------
//	Created:	12 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	tmpTemplate	: CM_ToDoTemplate;
	mtGrade		: CM_MTGrade;
begin

	tmpTemplate := _template;
	
	if self.availabilityGrades.isEmpty
	or tmpTemplate.availabilityGrades.isEmpty then
		_strDesc := _strDesc &amp; app.getErrorString(AvailabilityGrade) &amp; "(All), ";
		return true;
	endif;
	
	foreach mtGrade in self.availabilityGrades do
		if tmpTemplate.availabilityGrades.includesKey(mtGrade.code) then
			_strDesc := _strDesc &amp; app.getErrorString(AvailabilityGrade) &amp; "("&amp;mtGrade.description.String&amp; "), ";
			return true;
		endif;
	endforeach;
	
	return false;

end;</source>
        <access>protected</access>
        <Parameter name="_template" type="CM_ToDoTemplate"/>
        <Parameter name="_strDesc" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="templateMatchISOType" id="dab637f6-efdb-49bc-99cd-157e0f97aa58">
        <source>templateMatchISOType(_template: CM_ToDoTemplate; _strDesc: String io): Boolean protected;
//----------------------------------------------------------------
//	Created:	12 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	isoGrp		: CM_ISOTypeGroup;
	iso			: CM_ISOType;
	tmpTemplate	: CM_ToDoTemplate;

begin

	tmpTemplate := _template;
		
	if (self.isoGroups.isEmpty and tmpTemplate.isoGroups.isEmpty) 
	and (self.isoTypes.isEmpty and tmpTemplate.isoTypes.isEmpty) then
		_strDesc := _strDesc &amp; app.getErrorString(ISO_Type) &amp; "(All), ";
		return true;
	endif;
	
	foreach isoGrp in self.isoGroups do
		if tmpTemplate.isoGroups.includesKey(isoGrp.code) then
			_strDesc := _strDesc &amp; app.getErrorString(ISO_Group) &amp; "("&amp;isoGrp.code&amp;"), ";
			return true;
		endif;
		//the group may include isotypes set on tmpTemplate
		foreach iso in tmpTemplate.isoTypes do
			if iso.myISOTypeGroup = isoGrp then
				_strDesc := _strDesc &amp; app.getErrorString(ISO_Group) &amp; "("&amp;iso.code&amp;"), ";
				return true;
			endif;
		endforeach;
	endforeach;
	
	foreach iso in self.isoTypes do
		if tmpTemplate.isoTypes.includesKey(iso.code) then
			_strDesc := _strDesc &amp; app.getErrorString(ISO_Type) &amp; "("&amp;iso.code&amp;"), ";
			return true;
		endif;
		//the isoType's group maybe set on the tmpTemplate
		isoGrp := iso.myISOTypeGroup;
		if isoGrp &lt;&gt; null
		and tmpTemplate.isoGroups.includesKey(isoGrp.code) then
			_strDesc := _strDesc &amp; app.getErrorString(ISO_Group) &amp; "("&amp;isoGrp.code&amp;"), ";
			return true;
		endif; 
	endforeach;
	
	return false;

end;</source>
        <access>protected</access>
        <Parameter name="_template" type="CM_ToDoTemplate"/>
        <Parameter name="_strDesc" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="templateMatchImex" id="d844a990-75f3-46c5-9741-dd30af946298">
        <source>templateMatchImex(_template: CM_ToDoTemplate; _strDesc: String io): Boolean protected;
//----------------------------------------------------------------
//	Created:	12 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	strDesc		: String;
	tmpTemplate	: CM_ToDoTemplate;
	
begin

	tmpTemplate := _template;
	
	//group one
	if self.empties and tmpTemplate.empties then
		strDesc := strDesc &amp; app.getErrorString(Empty) &amp; ", ";
		//continue to group two
	elseif self.full and tmpTemplate.full then
		strDesc := strDesc &amp; app.getErrorString(Full) &amp; ", ";
		//continue to group two
	elseif ((not self.empties) and (not self.full))
	or ((not tmpTemplate.empties) and (not tmpTemplate.full)) then 	
		//one or t'other will match any
		strDesc := strDesc &amp; app.getErrorString(Contents) &amp; "(All), ";
		//continue to group two
	else
		//one or both have to match
		return false;
	endif;
	
	//group two
	if self.exports and tmpTemplate.exports then
		_strDesc := strDesc &amp; app.getErrorString(Export) &amp; ", ";
		return true;
	elseif self.imports and tmpTemplate.imports then
		_strDesc := strDesc &amp; app.getErrorString(Import) &amp; ", ";
		return true;
	elseif self.storage and tmpTemplate.storage then
		_strDesc := strDesc &amp; app.getErrorString(Storage) &amp; ", ";
		return true;
	elseif self.tranships and tmpTemplate.tranships then				// 21/09/2010 cnwmh5 #25602
		_strDesc := strDesc &amp; app.getErrorString(Storage) &amp; ", ";
		return true;
	elseif ((not self.exports) and (not self.imports) and (not self.storage) and (not self.tranships))	// 21/09/2010 cnwmh5 #25602
	or ((not tmpTemplate.exports) and (not tmpTemplate.imports) and (not tmpTemplate.storage) and (not tmpTemplate.tranships)) then
//	elseif ((not self.exports) and (not self.imports) and (not self.storage))
//	or ((not tmpTemplate.exports) and (not tmpTemplate.imports) and (not tmpTemplate.storage)) then
		//one or t'other will match any
		_strDesc := strDesc &amp; app.getErrorString(IMEX) &amp; "(All), ";
		return true;
	endif;
	
	return false;

end;</source>
        <access>protected</access>
        <Parameter name="_template" type="CM_ToDoTemplate"/>
        <Parameter name="_strDesc" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="templateMatchOperator" id="981ee9ee-ed21-4de6-a8ca-9f830b51ee69">
        <source>templateMatchOperator(_template: CM_ToDoTemplate; _strDesc: String io): Boolean protected;
//----------------------------------------------------------------
//	Created:	12 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	tmpTemplate	: CM_ToDoTemplate;
	operator	: CM_Operator;
begin

	tmpTemplate := _template;

	if self.operators.isEmpty
	or tmpTemplate.operators.isEmpty then
			_strDesc := _strDesc &amp; app.getErrorString(Operator) &amp; "(All)"; 
			return true;
	endif;
	
	foreach operator in self.operators do
		if tmpTemplate.operators.includesKey(operator.code) then
			_strDesc := _strDesc &amp; app.getErrorString(Operator) &amp; "(" &amp; operator.code &amp; ")"; 
			return true;
		endif;
	endforeach;
	
	return false;
end;</source>
        <access>protected</access>
        <Parameter name="_template" type="CM_ToDoTemplate"/>
        <Parameter name="_strDesc" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="templateOverlapsMe" id="c4ed8985-6188-4e7e-a2d1-5d81ac92fc77">
        <source>templateOverlapsMe(_template: CM_ToDoTemplate; _strDesc: String output): Boolean;
//----------------------------------------------------------------
//	Created:	12 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	if not self.templateMatchImex(_template, _strDesc) then
		return false;
	endif;
	
	if not self.templateMatchAvaGrade(_template, _strDesc) then
		return false;
	endif;
	
	if not self.templateMatchISOType(_template, _strDesc) then
		return false;
	endif;
	
	if not self.templateMatchOperator(_template, _strDesc) then
		return false;
	endif;
	
	return true;
	
end;</source>
        <Parameter name="_template" type="CM_ToDoTemplate"/>
        <Parameter name="_strDesc" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
