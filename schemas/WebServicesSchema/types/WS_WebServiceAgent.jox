<Class name="WS_WebServiceAgent" id="74ca10f5-30fa-4ffb-9022-a9fafd8929bf">
    <superclass name="CM_Agent"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="webservice"/>
    <Constant name="JWT_CLAIM_TERMINALID" id="6a9cb0d6-7366-4fb5-96f8-2aaace60e535">
        <source>'terminalId'</source>
        <type name="String"/>
    </Constant>
    <Constant name="JWT_CLAIM_USERID" id="eed1c232-bec8-4666-b15e-adc73ac353c9">
        <source>'userId'</source>
        <type name="String"/>
    </Constant>
    <Constant name="JWT_NONCE_KEY" id="fc442cf1-0025-4ab8-9d83-f650f353e1e7">
        <source>'JWTNonceId'</source>
        <type name="String"/>
        <text>Used by createJWT and validateJWT</text>
    </Constant>
    <JadeMethod name="addOnsiteAltIdTis" id="cf7e2d7e-a9df-451f-9541-f5d119e211e8">
        <source>addOnsiteAltIdTis(	_coll : CM_TIByAlternativeID;
					_altId : String;
					_matchedTIs : CM_TISet input;
					_request : WS_TrackedItemQueryRequest;
					_matches : Integer io;
					_startFrom : Integer;
					_maxResults : Integer;
					_completedOK : Boolean io;
					_response : WS_TrackedItemQueryResponse input;
					_from : String
					);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 May 2013	cnwndl1	Initial creation	Par 31506
12 Nov 2018 jlgmd1	TFS 41068 - JMT - CardSchema monitoring for Web services
02 Aug 2021	navdap1	TFS 51358 STWR Vehicle App Driver Mode Advanced Search
21 Apr 2022	jlier1	TFS 53249 - changed signature so can also seach other alternative id dictionaries
*/

vars

	obj : Object;
	iter : Iterator;
	ti : CM_TrackedItem;
	proxyTI : WS_TrackedItem;
	machine : CM_Machine;			// TFS 51358

begin

	obj := _coll.getAtKeyGeq(_altId);
	if obj &lt;&gt; null then
		iter := _coll.createIterator;
		iter.startAtObject(obj);
		while iter.next( ti ) do
			// Let JSA know we're still doing something
			app.sendHeartbeatIfRequired();
			
			if ti.alternativeId &lt;&gt; _altId then
				if not ti.alternativeId.startsWith( _altId ) then
					continue;
				endif;
			endif;
			if _matchedTIs.includes(ti) then
				continue;
			endif;
			if  _from = JMTUserInterfaceService::findImportReleaseCargo.name then
				if not self.includeTIForReleaseImports(_request,ti) then
					continue;
				endif;
			elseif  _from = JMTUserInterfaceService::findCargoQuickView.name then
				if ti.alternativeId &lt;&gt; _altId then
					//quick view has to be an exact match, not just partial..
					break;
				endif;
				if not self.includeTIForCargoQuickView(_request, ti) then
					continue;
				endif;
			elseif _from = JMTUserInterfaceService::findCargo.name then
				if not self.includeTIForCargoEnq(_request, ti) then
					continue;
				endif;
			// TFS 51358 start - check machine can access TI
			elseif _from = JMTUserInterfaceService::machineGetDriverMoveCargoAdv.name then
				machine := currentSession.myCurrentMachine;
				if machine = null then
					continue;
				endif;
				if not machine.allAllowedCargoTypes.includes(ti.myCargoType) then
					continue;
				endif;
				if not machine.validateForMove(null, ti, false) then
					continue;
				endif;
			// TFS 51358 end
			endif;
			
			_matches := _matches + 1;				
			if _matches &lt; _startFrom then 
				continue;
			endif;
				
			create proxyTI transient;
			proxyTI.setProxyFromObject(ti);
			_response.allTrackedItems.add(proxyTI);	
			
			_matchedTIs.add(ti);
			
			if _maxResults &gt; 0 and _matches - _startFrom = _maxResults then
				_completedOK := true;
				return; //found enough items
			endif;
			
		endwhile;
		
	endif;

epilog

	delete iter;

end;</source>
        <Parameter name="_coll" type="CM_TIByAlternativeID"/>
        <Parameter name="_altId" type="String"/>
        <Parameter name="_matchedTIs" type="CM_TISet" usage="input"/>
        <Parameter name="_request" type="WS_TrackedItemQueryRequest"/>
        <Parameter name="_matches" type="Integer" usage="io"/>
        <Parameter name="_startFrom" type="Integer"/>
        <Parameter name="_maxResults" type="Integer"/>
        <Parameter name="_completedOK" type="Boolean" usage="io"/>
        <Parameter name="_response" type="WS_TrackedItemQueryResponse" usage="input"/>
        <Parameter name="_from" type="String"/>
    </JadeMethod>
    <JadeMethod name="cancelInterruptRequest" id="71cc5b98-2e3f-4e84-9f25-f3dfd06ea119">
        <source>cancelInterruptRequest();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
07 April 2021	navmd1	Initial creation TFS 42010 MTN - Early termination of Webservice responses

*/

vars
	wsSupportAgent : WS_WebServiceSupportAgent;
begin
	wsSupportAgent := WS_WebServiceSupportAgent.firstSharedTransientInstance;
	if wsSupportAgent = null then
		return;
	endif;
	
	wsSupportAgent.causeEvent(WS_WebServiceSupportAgent.WS_Cancel_Interrupt_Note, true, process);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="createBooking" id="e48a209c-b4bb-4f47-ae4a-5cdfece9915d">
        <options>4</options>
        <source>createBooking(_pxyBooking				: CM_BookingRef io; 
				_wsBooking				: WS_RestBookingObject;
				_statusCode				: Integer io;
				_dischargePortsArr		: StringArray;
				_bookRefHazardsArray	: ObjectArray;
				_consignee, _consignor,
				_freightForwarder		: CM_ConsigneeConsignor;
				_operator				: CM_Operator;
				_voyage,
				_transhipVoyage			: CM_Voyage;
				_carrier				: CM_Carrier;
				_stevedore				: CM_Stevedore;
				_objectsToBeDeleted		: ObjectArray input) typeMethod;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
21 March 2023	navpw1	Initial creation TFS: 56850 (56871)
30 March 2023	navpw1	TFS: 57264 (57298) - Made changes to support creation of release request for releasing empties
05 April 2023	navpw1	TFS: 56707 (56712) - Added extra critiera for a booking item to match against
12 Feb 	2024	navhn30	Bug 61995: CUX | FR 56698 - Booking API - Issues with creation of bookings
28 Feb 2024		navlw1	Defect 62571: CUX | Booking API - Added subTerminal based on Road, Rail, Ship and Packing
08 Marc 2024 	naviv1	CR 62796: CUX | EDBIC - Modify Booking API to be independent of Prenotes
15 Mar	2024	navlw1	Bug 62948: CUX FR | added null checks for wsCargo_dimensions and wsCargo.weights
20 Mar  2024    navsp1  TFS ChangeRequest 63028: CUX | TK 62942 | EDBIC BOOKING APIs - Add field GoLiveCrit 01
*/

vars
	wsCargo					: WS_RestBookingCargoObject;
	cargoBolType			: CM_CargoBOLType;
	cargoType				: CM_CargoType;
	cargoTypeIdInt			: Integer;
	product					: CM_Product;
	isoType					: CM_ISOType;
	existingBookingItem,
	bookingRefItemCont		: CM_BRefItemContainer;
	specialStow				: CM_SpecialStow;
	hazardsArr				: CM_HazardByCodeDict;
	hazardClass				: CM_HazardClass;
	wsHazard				: WS_RestHazardObject;
	hazard					: CM_TIHazard;
	cmHazard				: CM_Hazard;
	dictHaz 				: CM_HazardByCodeDict;
	undgString,
	carrierCode,
	consigneeCode,
	freightForwarderCode,
	releaseId				: String;
	createBookingRelease,
	limitQ					: Boolean;
	humidity,
	vent,
	carbonDioxide,
	oxygen					: Decimal[23,2];
	height,
	length,
	width,
	gross,
	net						: Decimal[12,4];
	marinePol,
	ventUnits,
	transportType			: Integer;
	iter					: Iterator;
	pxyBulkRelease			: CM_BulkRelease;
	dischargePort			: CM_Port;
	releaseRequestData		: WS_RestBookingReleaseObject;
	temperature				: Real;
	subTerminal				: CM_SubTerminal;
	reason					: String; //05/04/2024	navkc1 Bug 63509
	
begin
	releaseRequestData := _wsBooking.releaseRequest;
	if releaseRequestData &lt;&gt; null then
		createBookingRelease := true;
		
	endif;
	
	_pxyBooking.setProxy(_wsBooking.id, null, null, null, _wsBooking.consignorId, null, _wsBooking.destinationPortId, _wsBooking.dischargePortId, null,
						_dischargePortsArr, _bookRefHazardsArray, null, null, null, _consignor, _consignee, _operator, _voyage, null, _wsBooking.remarks, null, null, null, null, null, null, 
						null,null,null, null, null, null, null, null, null, app.myPassport.myTerminal, null, null, _wsBooking.stockBooking, null, null, 
						_wsBooking.shippingReference, null, null, null, null, null, null, null, createBookingRelease, null, null, null, null, null, null, _wsBooking.status,
						null, null, null, _wsBooking.receiveAsTranship, _transhipVoyage, app.bookingPackAsStringToEnumb(_wsBooking.packAsType), _wsBooking.customsAgentId, null, null,
						_wsBooking.directDelivery, _freightForwarder, _carrier, _stevedore);
	
	foreach wsCargo in _wsBooking.cargo do
		cargoBolType := app.myRoot.allCargoTypesById.getCargoTypeByAbbreviation(wsCargo.cargoTypeId);
		
		if cargoBolType &lt;&gt; null and cargoBolType.isCargoType then
			cargoTypeIdInt := cargoBolType.id;
			cargoType := cargoBolType.CM_CargoType;
		else
			app.raiseCMException1(Cargo_Type_Not_Found, wsCargo.cargoTypeId, null, null);
			_statusCode := HttpResponseNotFound;
			return;
		endif;
		
		if cargoType.isSubCargoTypeRequired then
			product := cargoType.allProducts[_wsBooking.operatorId, wsCargo.cargoSubTypeId];
			
			if product = null then
				iter := cargoType.allProducts.createIterator;
				cargoType.allProducts.startKeyGeq(null, wsCargo.cargoSubTypeId, iter);
				while iter.next(product) do
					if product.code &lt;&gt; wsCargo.cargoSubTypeId then
						continue;
					elseif product.code = wsCargo.cargoSubTypeId then
						break;
					endif;
				endwhile;
				delete iter;
			endif;
			
			if product = null or product.code &lt;&gt; wsCargo.cargoSubTypeId then
				app.raiseCMException2(Cargo_SubType_Not_Found_CType, wsCargo.cargoSubTypeId, wsCargo.cargoTypeId, null, null);
				_statusCode := HttpResponseNotFound;
				return;
			endif;
		endif;
		
		specialStow := app.myRoot.allSpecialStows[wsCargo.specialStow];
		if specialStow = null and wsCargo.specialStow &lt;&gt; null then													// 12.02.24		navhn30		61995
			app.raiseCMException1(Special_stow_not_found, wsCargo.specialStow, null, null);
			_statusCode := HttpResponseNotFound;
			return;
		endif;
		
		isoType := app.myRoot.allISOTypes[wsCargo.isoTypeId];
		
		create hazardsArr transient;
		_objectsToBeDeleted.add(hazardsArr);
		
		if wsCargo.hazards.isNotEmpty then
			foreach wsHazard in wsCargo.hazards do
				//Find hazard code to validate??
				//Get a hazard class??
				hazardClass := app.myRoot.allHazardClasses[wsHazard.id];
				if hazardClass = null then
					app.raiseCMException1(Hazard_code_not_found, wsHazard.id, null, null);
					_statusCode := HttpResponseNotFound;
					return;
				endif;
				
				create hazard transient;
				hazard.setProxy(hazardClass.code, hazardClass.description, wsHazard.undgNumber, null, wsHazard.limitedQuantity, wsHazard.packingGroupId,
								wsHazard.flashpointTemperature, wsHazard.marinePollutant, wsHazard.acidBase);
				hazardsArr.add(hazard);
				_objectsToBeDeleted.add(hazard);
			endforeach;
		endif;
		
		existingBookingItem := _pxyBooking.getMatchingItem(cargoType, wsCargo.commodityId, isoType, wsCargo.cargoSubTypeId, wsCargo.marks, wsCargo.markNumber, wsCargo.colour, wsCargo.purchaseOrder, wsCargo.serviceOrder, reason).CM_BRefItemContainer; // ### TFS 56707 (56712) 05Apr2023 NAVPW1
		
		//Increment existing item and add new hazards and continue
		if existingBookingItem &lt;&gt; null then
			foreach hazard in hazardsArr as CM_TIHazard do : hazardsLoop
				if existingBookingItem.allTIHazards[hazard.code] &lt;&gt; null then
					continue hazardsLoop;
				endif;
				
				existingBookingItem.allTIHazards.add(hazard);
				
			endforeach;
			
			existingBookingItem.increaseItemQuantity(1);
			if _pxyBooking.isReleaseEmptiesAllowed and createBookingRelease then //Only Applicable to ISO Containers
				existingBookingItem.setProxyReserveDetail(existingBookingItem.quantity, existingBookingItem.quantity, null, null);
			endif;
			continue;
		endif;
		
		//Create new item
		create bookingRefItemCont transient;
		
		if cargoType.id = TI_CargoType_Container then
			//Container
			if wsCargo.reeferProperties &lt;&gt; null then
				humidity := wsCargo.reeferProperties.humidity;
				vent := wsCargo.reeferProperties.vent;
				ventUnits := wsCargo.reeferProperties.ventUnits;
				carbonDioxide := wsCargo.reeferProperties.carbonDioxide;
				oxygen := wsCargo.reeferProperties.oxygen;
				temperature := wsCargo.reeferProperties.temperature;
			else
				temperature := NULL_TEMPERATURE;
			endif;
			
			// navlw1 #62948
			// check that we have the weight object
			if wsCargo.weights &lt;&gt; null then
				gross := wsCargo.weights.gross;
			endif;
			
			bookingRefItemCont.setProxy(cargoTypeIdInt, wsCargo.commodityId, wsCargo.description, wsCargo.remarks, hazardsArr, wsCargo.isoTypeId, wsCargo.quantity, gross, wsCargo.quantity, null, 
										humidity, temperature, vent, ventUnits, carbonDioxide, oxygen, wsCargo.curtains, null, null, specialStow, wsCargo.isoGroupId, null,
										null, wsCargo.purchaseOrder, wsCargo.serviceOrder, wsCargo.matchMode);//TFS 63028 - quantity, maxToRelease replaced with wsCargo.quantity	//navra1 - CR 63764/Task 64227 - 23rd May 2024
			
			bookingRefItemCont.setMyBookingRef(_pxyBooking);
			if _pxyBooking.isReleaseEmptiesAllowed and createBookingRelease then //Only Applicable to ISO Containers
				bookingRefItemCont.setProxyReserveDetail(bookingRefItemCont.quantity, bookingRefItemCont.quantity, null, null); //TFS 63028 - replace 1 with the Quantity value
			endif;
			
		else
			// navlw1 #62948
			// check that we have the dimensions object
			if wsCargo.dimensions &lt;&gt; null then
				height := wsCargo.dimensions.height;
				length := wsCargo.dimensions.length;
				width := wsCargo.dimensions.width;
			endif;
			
			// check that we have the weight object
			if wsCargo.weights &lt;&gt; null then
				gross := wsCargo.weights.gross;
				net := wsCargo.weights.net;
			endif;
			
			//Cargo Item
			bookingRefItemCont.setProxyForCargo(cargoTypeIdInt, wsCargo.commodityId, wsCargo.description, hazardsArr, wsCargo.quantity, wsCargo.remarks, height, length, width, height.asStringJMT, length.asStringJMT,
												width.asStringJMT, null, wsCargo.density, wsCargo.volume, 1, wsCargo.marks, gross, product, null, null, wsCargo.generatorTypeId, specialStow,
												null, wsCargo.colour, wsCargo.markNumber, null, net, wsCargo.volume, wsCargo.trailerTypeId, wsCargo.purchaseOrder, 
												wsCargo.serviceOrder, wsCargo.matchMode); //08.03.2024 naviv1 #62796  -- replace null for cargoId parameter //TFS 63028 - replace 1 with quantity		//navra1 - CR 63764/Task 64227 - 22nd May 2024
													
			bookingRefItemCont.setMyBookingRef(_pxyBooking);
		endif;
		
	endforeach;
	
	pxyBulkRelease := _pxyBooking.allReleaseRequests.first;
	
	if _pxyBooking.isReleaseEmptiesAllowed and pxyBulkRelease &lt;&gt; null and createBookingRelease then
		if _consignee &lt;&gt; null then
			consigneeCode := _consignee.code;
		endif;
		
		if _freightForwarder &lt;&gt; null then
			freightForwarderCode := _freightForwarder.code;
		endif;
		
		dischargePort := app.myRoot.allPorts[_wsBooking.dischargePortId];
		
		if releaseRequestData &lt;&gt; null then
			if releaseRequestData.id &lt;&gt; null then
				releaseId := releaseRequestData.id; //If we have a release id then use it
			else
				releaseId := _pxyBooking.bookingReference;	//Otherwise default to booking reference
			endif;
			
			transportType := app.transportTypeStringToEnum(releaseRequestData.transportType);
			// navlw1 #62571
			if _pxyBooking.myTerminal.isSubTerminalsOn then
				if transportType = BR_TYPE_PACKING then
					subTerminal := _pxyBooking.myTerminal.getConfig(MySubTerminalForSourceBulkPack).CM_SubTerminal;
				elseif transportType = BR_TYPE_ROAD then
					subTerminal := _pxyBooking.myTerminal.getConfig(MySubTerminalForSourceBulkRoad).CM_SubTerminal;
				elseif transportType = BR_TYPE_RAIL then
					subTerminal := _pxyBooking.myTerminal.getConfig(MySubTerminalForSourceBulkRail).CM_SubTerminal;
				elseif transportType = BR_TYPE_SHIP then
					subTerminal := _pxyBooking.myTerminal.getConfig(MySubTerminalForSourceBulkShip).CM_SubTerminal;
				endif;
			endif;
			carrierCode := releaseRequestData.carrierId;
			
		endif;
		
		pxyBulkRelease.setProxy(	releaseId, //code same as this booking reference number unless we are giving a different one
									transportType,
									true, //(not self.chkReservedOnly.value),  //release by type - not chkIsReservedOnly Now always true adm 070710 Par 24741
									BR_ACTIVE,
									null, ///availability grades null set on reserve selections
									null,//booking confirmation 
									carrierCode, //carrier
									null, //cargo remarks
									consigneeCode,		//consigneeCode
									null,
									_wsBooking.consignorId,		//consignor Code
									null,
									null,//_consignorVoyageCode 
									null, //date requested
									null,//_dateEstimatedRequired
									null,//_deliveryReasonCode
									null,//_deliveryReasonDescr
									null,//_deliveryReleaseNumber
									null,//_doorsDirection
									null,//_freightPayerCode
									_pxyBooking,//CM_BookingRef
									null,//_loadPort
									null,//_destinationPort	//04 Nov 2009	NDL Par 21519
									dischargePort,//_dischargePort
									freightForwarderCode,//_freightForwarder
									null,//_transferToTerminal
									_pxyBooking.myTerminal,
									_pxyBooking.myOperator,//_operator
									null,//_operatorGroup
									_pxyBooking.myVoyage,//_voyage
									null,		//_businessUnit	
									null,		//_fullRelease	
									null,  //pack locations
									null,
									null,
									subTerminal, // navlw1 #62571
									_pxyBooking.myTerminal.getConfig(MySubTerminalForTargetBulk).CM_SubTerminal, // subterm target
									null,
									false,
									_wsBooking.customsAgentId,
									false,
									false,
									pxyBulkRelease.needsReview,	// don't change ot from here???
									pxyBulkRelease.blockEDIUpdates, 	// par 29481 - don't change from here par 29480 April 2012
									null,
									null,
									null,
									null
									);
		pxyBulkRelease.requests.purge();
	endif;
	
	//Update Hazards on booking in a foreach loop at the end
	//Update Hazards on parent booking for item
	//Requried otherwise hazard not saved on booking items
	dictHaz := _pxyBooking.allTIHazards;
	foreach bookingRefItemCont in _pxyBooking.allBookingRefItems as CM_BRefItemContainer do
		foreach cmHazard in bookingRefItemCont.allTIHazards do
			if dictHaz[cmHazard.code] = null then
				create hazard transient;
				hazard.setProxy(	cmHazard.code,										// TFS 2842
									cmHazard.description,									// TFS 2842
									cmHazard.CM_TIHazard.allUNDGCodes.asCSV(false),		// TFS 2842
									null,												// TFS 2842
									cmHazard.CM_TIHazard.limitedQuantity,					// TFS 2842
									cmHazard.CM_TIHazard.packingGroup,					// TFS 2842
									cmHazard.CM_TIHazard.flashpointTemperature,			// TFS 2842
									cmHazard.CM_TIHazard.isMarinePollutant,				// TFS 2842
									cmHazard.CM_TIHazard.acidsBases	);					// TFS 2842
				dictHaz.add(hazard);
			else
				hazard := dictHaz[cmHazard.code].CM_TIHazard;
				if cmHazard.CM_TIHazard.getUndgCodesAsString(false) &lt;&gt; null //25 Sep 2019	NDL	TFS 46633 - use full string not truncated version
				and not hazard.allUNDGCodes.includes(cmHazard.CM_TIHazard.getUndgCodesAsString(false)) then	//25 Sep 2019	NDL	TFS 46633 - use full string not truncated version
					undgString:= hazard.allUNDGCodes.asCSV(false) &amp;','&amp; cmHazard.CM_TIHazard.allUNDGCodes.asCSV(false);
					hazard.setUNDGCodes(undgString);
				endif;
				limitQ := hazard.limitedQuantity and cmHazard.CM_TIHazard.limitedQuantity;
				hazard.setLimitedQuantity(limitQ);
				marinePol := hazard.isMarinePollutant;											// TFS 2842
				hazard.setIsMarinePollutant(marinePol);											// TFS 2842
				hazard.setAcidsBases(cmHazard.CM_TIHazard.acidsBases);								// TFS 3058
				hazard.setFlashpointTemperature(cmHazard.CM_TIHazard.flashpointTemperature);		// TFS 3058
			endif;
		endforeach;
	endforeach;
	
epilog
	delete iter;
	
end;</source>
        <Parameter name="_pxyBooking" type="CM_BookingRef" usage="io"/>
        <Parameter name="_wsBooking" type="WS_RestBookingObject"/>
        <Parameter name="_statusCode" type="Integer" usage="io"/>
        <Parameter name="_dischargePortsArr" type="StringArray"/>
        <Parameter name="_bookRefHazardsArray" type="ObjectArray"/>
        <Parameter name="_consignee" type="CM_ConsigneeConsignor"/>
        <Parameter name="_consignor" type="CM_ConsigneeConsignor"/>
        <Parameter name="_freightForwarder" type="CM_ConsigneeConsignor"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_transhipVoyage" type="CM_Voyage"/>
        <Parameter name="_carrier" type="CM_Carrier"/>
        <Parameter name="_stevedore" type="CM_Stevedore"/>
        <Parameter name="_objectsToBeDeleted" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createCMIFPrenote" id="9e14a68b-cfe1-4323-b015-e11b8e620440">
        <options>4</options>
        <source>createCMIFPrenote(_wsCargo : WS_RestCargoObject; _parent : WS_RestCargoObject; _cmifPrenote : CMIF_PreNote output; _passport : CM_Passport) typeMethod;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 14/03/2024	navdap1		Initial creation TFS 62686 CUX | FR 61749 | Cannot create multiple prenotes via API
// 22/03/2024	navcs2		ChangeRequest 63087: CUX FR* | Tk62873 CARGO APIs POST/PUT/GET - Additional Fields requested - GoLCrit - 01
// 22/04/2024	naviv1		TFS 63619 : CUX | FR - POST and PUT /Cargo not saving Customs References for Onboard Cargo
// 08/05/2024	naviv1		TFS 63943 : CUX - Code 88778 when trying to create a Rail Prenote for a Wagon with the "Default" Train via POST /Cargo endpoint
// 21/05/2024	navdap1		TFS 63619 CUX | FR - POST and PUT /Cargo not saving Customs References for Onboard Cargo
// 12 Jun 2024	navhn30		ChangeRequest 64067: CUX | Include additional fields in APIs (Free Text)
// 22/07/2024	navmd1		TFS 65034 If not receivalDetails are provided, then default transportMode to Road
// 22/07/2024	navhn30		ChangeRequest 64906: CUX | EDBIC Stop type information on GET/ customs status
// 23/09/2024	navhn30		Bug 66239: CUX - API POST cargo with reefer Code 89407
// 07/10/2025	navdap1		MTN-36141 AAT | RotaBox Creation (EDI/API/Manual)
vars
	prenote : CMIF_PreNote;
	cargoType, contentsCargoType : CM_CargoType;		// MTN-36141
	cargoSubType, contentsCargoSubType : CM_Product;	// MTN-36141
	wsCustomsReference	: WS_RestCustomsReferenceObject;
	imex : Integer;
	wsHaz : WS_RestHazardObject;
	haz : CM_TIHazard;
	receivalDetails : WS_RestReceivalDetailObject;
	terminal : CM_Terminal;
	booking : CM_BookingRef;
	bookingItem : CM_BookingRefItem;
	isoType : CM_ISOType;
	reason	: String; //05/04/2024	navkc1 Bug 63509
	pxyCustomsReference	: CM_CustomsReference;
	totalPackages, remainingPackages : Integer;
	priority	: CM_CustomerPriority;
	reeferDets : WS_RestReeferObject;
	ventMeasure : CM_MeasurementType;
begin
	create prenote transient;
	terminal := _passport.myTerminal;
	
	prenote.myTerminal := terminal;
	cargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr(_wsCargo.cargoTypeId);
	if cargoType &lt;&gt; null and _wsCargo.cargoSubTypeId &lt;&gt; null then
		cargoSubType := cargoType.getProductFromCode(_wsCargo.cargoSubTypeId);
	endif;
	prenote.trailerType := _wsCargo.trailerTypeId;
	
	prenote.bookingReference := _wsCargo.bookingId;
	
	prenote.alternativeId := _wsCargo.alternativeId;
	if cargoType &lt;&gt; null then
		prenote.cargoType := cargoType.id;
		if cargoSubType &lt;&gt; null then
			prenote.myProduct := cargoSubType;
		endif;
	endif;
	
	prenote.commodity := _wsCargo.commodityId;
	prenote.consigneeCode := _wsCargo.consigneeId;
	prenote.consignorCode := _wsCargo.consignorId;
	prenote.consigneeCode := _wsCargo.consigneeId;
	prenote.contentsStatus := app.contentStatusStringToEnum(_wsCargo.contentsStatusId);
	
	prenote.density := _wsCargo.density;
	prenote.destinationPort := _wsCargo.destinationPortId;
	prenote.dischargePort := _wsCargo.dischargePortId;
	prenote.id := _wsCargo.id.toUpper;							// TFS 63619
	
	imex := app.imexStatusStringToEnum(_wsCargo.imexStatus);
	prenote.imExStatus := app.myRoot.allImexStatuses[imex];
	
	prenote.isoType := _wsCargo.isoTypeId;
	isoType := app.myRoot.allISOTypes[prenote.isoType];
	
	prenote.loadPort := _wsCargo.loadPortId;
	prenote.stowageLocation := _wsCargo.locationId;
	prenote.operatorCode := _wsCargo.operatorId;
	prenote.remarks := _wsCargo.remarks;
	prenote.voyageCode := _wsCargo.voyageId;

	//Start - 22-04-2024 naviv1 #63619
	if _wsCargo.customsReferences &lt;&gt; null then		
		foreach wsCustomsReference in _wsCargo.customsReferences do
		create pxyCustomsReference transient;
		if wsCustomsReference.packages &lt;&gt; null then
			totalPackages := wsCustomsReference.packages.total;
			remainingPackages := wsCustomsReference.packages.remaining;
		endif;
		
		pxyCustomsReference.setProxy(wsCustomsReference.typeId, wsCustomsReference.id, wsCustomsReference.position, wsCustomsReference.status, wsCustomsReference.alternateId,
										totalPackages, remainingPackages, wsCustomsReference.remarks, wsCustomsReference.retentionPeriod);	//22.07.24	navhn30	TFS #64906
		prenote.allCustomsReferences.add(pxyCustomsReference);
		endforeach;
	endif;
	//End - 22-04-2024 naviv1 #63619
		
	if _wsCargo.dimensions &lt;&gt; null then
		prenote.height := _wsCargo.dimensions.height;
		prenote.length := _wsCargo.dimensions.length;
		prenote.width := _wsCargo.dimensions.width;
	endif;
	
	if _wsCargo.hazards &lt;&gt; null then
		foreach wsHaz in _wsCargo.hazards do
			create haz transient;
			haz.setProxy(wsHaz.id, null, wsHaz.undgNumber, null, wsHaz.limitedQuantity, wsHaz.packingGroupId, wsHaz.flashpointTemperature, wsHaz.marinePollutant, wsHaz.acidBase);
			prenote.allTIHazards.add(haz);
		endforeach;
	endif;
	
	// Default new Prenotes to 'Road' just like the thin client
	prenote.transportMode := TI_TRANSMODE_ROAD_STR;
	
	receivalDetails := _wsCargo.receivalDetails;
	if receivalDetails = null and _parent &lt;&gt; null then
		receivalDetails := _parent.receivalDetails;
	endif;
	if receivalDetails &lt;&gt; null then
		prenote.carrier := receivalDetails.carrierId;
		if receivalDetails.type = receivalDetails.Receival_Truck then		//08-May-2024 naviv1 #63943
			prenote.transportMode := TI_TRANSMODE_ROAD_STR;
			prenote.receiptTransportMode := TI_TRANSMODE_ROAD;
			prenote.vehicle := receivalDetails.id;
		elseif receivalDetails.type = receivalDetails.Receival_Train or receivalDetails.type = receivalDetails.Receival_Wagon then		//08-May-2024 naviv1 #63943
			prenote.transportMode := TI_TRANSMODE_RAIL_STR;
			prenote.receiptTransportMode := TI_TRANSMODE_RAIL;
			prenote.wagon := receivalDetails.id;
		endif;
	endif;
	
	if _wsCargo.weights &lt;&gt; null then
		prenote.weightCargo := _wsCargo.weights.net;
		prenote.weightTare := _wsCargo.weights.tare;
		prenote.weight := _wsCargo.weights.gross;
		prenote.weightTotal := _wsCargo.weights.gross;
	endif;
	
	// see if we can find a real booking and matching bookig item
	if prenote.bookingReference &lt;&gt; null then
		booking := terminal.getBookingReference(null, prenote.bookingReference, null);
		if booking &lt;&gt; null then
			bookingItem := booking.getMatchingItem(	cargoType, _wsCargo.commodityId, isoType, _wsCargo.cargoSubTypeId, 
													null, null, null, null, null, reason);
			if bookingItem &lt;&gt; null then
				prenote.myBookingRefItem := bookingItem;
				prenote.bookingReferenceItem := bookingItem.getShortDisplay();
			endif;
		endif;
	endif;
	
	prenote.orderNumber 		:= _wsCargo.orderNumber;			//22/03/2024	navcs2	ChangeRequest 63087
	prenote.description			:= _wsCargo.description;		//22/03/2024	navcs2	ChangeRequest 63087
	prenote.secondaryBarcodeId 	:= _wsCargo.secondaryBarcodeId;		//22/03/2024	navcs2	ChangeRequest 63087
	prenote.grammage			:= _wsCargo.grammage;				//22/03/2024	navcs2	ChangeRequest 63087
	prenote.rollingLength 		:= _wsCargo.rollingLength;			//22/03/2024	navcs2	ChangeRequest 63087
	prenote.diameter 			:= _wsCargo.diameter;				//22/03/2024	navcs2	ChangeRequest 63087
	prenote.grade 				:= _wsCargo.grade;					//22/03/2024	navcs2	ChangeRequest 63087
	
	// 23.09.24		navhn30	 	TFS 66239  start
	if _wsCargo.reeferProperties &lt;&gt; null then
		reeferDets := _wsCargo.reeferProperties;
		if reeferDets.temperature = NULL_TEMPERATURE then
			prenote.carriageTempC := NULL_TEMPERATURE;
		else
			if reeferDets.fahrenheit then
				prenote.carriageTempC := app.myRoot.convFahrenheitToCelsius(reeferDets.temperature);
			else
				prenote.carriageTempC := reeferDets.temperature;
			endif;
		endif;
		
		if reeferDets.oxygen = null or reeferDets.oxygen = NULL_OXYGEN then
		    prenote.oxygen := NULL_OXYGEN;
		else
			prenote.oxygen := reeferDets.oxygen;
		endif;
		
		if reeferDets.carbonDioxide = null or reeferDets.carbonDioxide = NULL_CARBON_DIOXIDE then
			prenote.carbonDioxide := NULL_CARBON_DIOXIDE;
		else
			prenote.carbonDioxide := reeferDets.carbonDioxide;
		endif;
		
		if reeferDets.humidity = null or reeferDets.humidity = NULL_HUMIDITY then
			prenote.humidity := NULL_HUMIDITY;
		else
			prenote.humidity := reeferDets.humidity;
		endif;
		
		if  reeferDets.vent = null or reeferDets.vent = NULL_VENTILATION then
			prenote.ventilation := NULL_VENTILATION;
		else
			if reeferDets.ventUnits = 2 then
				ventMeasure := app.myRoot.allMeasurementTypesByShortName["ft3/hr"];
				if ventMeasure &lt;&gt; null then
					prenote.ventilation := app.convertMeasurementForStorage(ventMeasure.shortName, reeferDets.vent);
				else
					prenote.ventilation := reeferDets.vent;
				endif;
			else
				prenote.ventilation := reeferDets.vent;
			endif;
		endif;
	endif;
	// 23.09.24		navhn30	 	TFS 66239  end
	
	priority	:= app.myRoot.allCustomerPriorities[_wsCargo.customerPriority];		// 12.06.24		navhn30		TFS #64067
	if priority &lt;&gt; null then
		prenote.customerPriority	:= priority.code;								//12.06.24		navhn30		TFS #64067
	endif;
	prenote.shipmentNumber		:= _wsCargo.shipmentNumber;							//12.06.24		navhn30		TFS #64067
	
	// MTN-36141 RotaBox Creation
	if _wsCargo.contentsCargoTypeId &lt;&gt; null then
		contentsCargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr(_wsCargo.contentsCargoTypeId);
		if contentsCargoType &lt;&gt; null and _wsCargo.cargoSubTypeId &lt;&gt; null then
			contentsCargoSubType := contentsCargoType.getProductFromCode(_wsCargo.cargoSubTypeId);
			if contentsCargoSubType = null then
				app.writeLog(method.qualifiedName &amp; Tab &amp; "No product found for " &amp; _wsCargo.cargoSubTypeId, LogINFO);
			else
				app.writeLog(method.qualifiedName &amp; Tab &amp; "Found product " &amp; contentsCargoSubType.code, LogINFO);
			endif;
		endif;
		prenote.cargoTypeContents := contentsCargoType.id;
		prenote.myProduct := contentsCargoSubType;
	endif;
	
	_cmifPrenote := prenote;
epilog

end;</source>
        <Parameter name="_wsCargo" type="WS_RestCargoObject"/>
        <Parameter name="_parent" type="WS_RestCargoObject"/>
        <Parameter name="_cmifPrenote" type="CMIF_PreNote" usage="output"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="createJWT" id="3e4f30f8-5bd0-414d-bdc6-3d3b7038ee3a">
        <options>4</options>
        <source>createJWT(_user: CM_User; _terminal: CM_Terminal; _audience: String; _appName: String; _expiryInSeconds: Integer io; _isRefreshToken: Boolean; _jwtClaims : CMIF_WSClaimsObj) : String typeMethod;
/*

Purpose:			Creates a JWT in a semi-sensible manner.
					This should be the only method that does this - if not, I'll come and growl at you!

Parameters:			

Return Value:		

Date			Who		Reason
15 April 2022	navmd1	Initial creation TFS 53378 REST Refactor / Generic API
27 July 2022 	navlw1  TFS 53854 MTN API Mapper to add claims to the CMIF_WSClaimsObj
27 October 2022 navam1	53986 MTN Web SSO - added _appName as input

*/

constants
	DEFAULT_EXPIRY			: Integer = 15;			// 15 minutes
	DEFAULT_REFRESH_EXPIRY	: Integer = 60 * 24;	// 24 hours
vars
	jwt				: JadeJsonWebToken;
	userIdClaim,
	terminalIdClaim,
	operatorIdClaim,
	complexIdClaim,
	yardIdClaim     : JadeJWTClaim;
	jwtError		: String;
	
	expiry			: Integer;
	appName			: String;
	tokenString		: String;
	encKey			: String;
	nonce			: String;
	nonceKeyName	: String;
	issuer			: String;
	
	factory			: JadeMessagingFactory;
begin
	
	// Every JWT should have a 'userId' and 'TerminalId' claim
	if _user = null or _terminal = null then
		app.raiseUnexpectedProgramError(WS_WebServiceAgent.name, method.name, "CM_User or CM_Terminal invalid/not specified");
		return null;
	endif;
	
	expiry := _expiryInSeconds;
	if expiry = null then
		if not _isRefreshToken then
			expiry := DEFAULT_EXPIRY * 60;
		else
			expiry := DEFAULT_REFRESH_EXPIRY * 60;
		endif;
		_expiryInSeconds := expiry;
	endif;
	
	//TFS 53986, navam1
	if _appName = null then
		appName := app.getNiceName;
	else
		appName := _appName;
	endif;
	
	create jwt transient;
	jwt.addAudience(_audience);
	jwt.addExpiry(app.actualTimeServer.addSeconds(expiry));
	jwt.addSubject(appName);
	
	issuer := app.getEnvName.toUpper;
	if issuer = null then
		issuer := "JADE";	// Work around 1090 when validating Subject if there is no issuer. Par 68876
		// NB: getEnvName returns the DB folder name in the web services
		// But returns the "System Title" name in the Unit Tests
		// This can be safely removed when the 1090 is resolved
	endif;
	jwt.addIssuer(issuer);
	
	
	// Add a 'nonce' so we can revoke active tokens before they expire
	// There should be one 'nonce' for each Issuer/REST App and audientce/Calling Application
	nonceKeyName := (WS_WebServiceAgent.JWT_NONCE_KEY &amp; "_" &amp; appName &amp; "_" &amp; _audience)[1:CM_StateData::key.length];
	if not _isRefreshToken then
		// New login = new nonce
		create factory transient;
		nonce := factory.generateAccessPassword()[1:30];
		app.myTrxUA.trxUpdateUserStateData(_user, ConfigGrp_Web, nonceKeyName, nonce, app.myPassport);
		delete factory;
	else
		nonce := _user.getStateData(ConfigGrp_Web, nonceKeyName).String;
		if nonce = null then
			app.raiseUnexpectedProgramError(WS_WebServiceAgent.name, method.name, "User State Data not found for JWT " &amp; appName);
			return null;
		endif;
	endif;
	jwt.addId(nonce);	// Limited to 30 characters
	
// --- Set our custom claims here ---
	userIdClaim := create JadeJWTClaim(CMIF_WSClaimsObj.JWT_CLAIM_USERID, _user.code) transient; // 27 July 2022 navlw1 tfs 53854
	jwt.addCustomClaim(userIdClaim);
	
	terminalIdClaim := create JadeJWTClaim(CMIF_WSClaimsObj.JWT_CLAIM_TERMINALID, _terminal.code) transient; // 27 July 2022 navlw1 tfs 53854
	jwt.addCustomClaim(terminalIdClaim);
	
	operatorIdClaim := create JadeJWTClaim(CMIF_WSClaimsObj.JWT_CLAIM_OPERATORID, _jwtClaims.operatorId) transient;// 27 July 2022 navlw1 tfs 53854
	jwt.addCustomClaim(operatorIdClaim);
	
	complexIdClaim := create JadeJWTClaim(CMIF_WSClaimsObj.JWT_CLAIM_COMPLEXID, _jwtClaims.complexId) transient;// 27 July 2022 navlw1 tfs 53854
	jwt.addCustomClaim(complexIdClaim);
	
	yardIdClaim := create JadeJWTClaim(CMIF_WSClaimsObj.JWT_CLAIM_YARDID, _jwtClaims.yardId) transient;// 27 July 2022 navlw1 tfs 53854
	jwt.addCustomClaim(yardIdClaim);
// --- Set our custom claims here ---

	// Generate/Sign our JWT using a randomly generated key
	if _isRefreshToken then
		encKey := _terminal.getConfig(JWTRefreshKey).String;
	else
		encKey := _terminal.getConfig(JWTAccessKey).String;
	endif;
	
	// Time to generate a new key (this probably shouldn't be in this method
	// TODO: Move somewhere else ?
	// How/When do we rotate these ?
	if encKey = null then
		create factory transient;
		encKey := factory.generateAccessPassword();
		beginTransaction;
		if _isRefreshToken then
			_terminal.setConfig(JWTRefreshKey, encKey.String);
		else
			_terminal.setConfig(JWTAccessKey, encKey.String);
		endif;
		commitTransaction;
		delete factory;
	endif;
	
	tokenString := jwt.encodeHS256(encKey, jwtError);
	if jwtError &lt;&gt; null then
		app.raiseUnexpectedProgramError(WS_WebServiceAgent.name, method.name, "Unable to generate JWT Access Token: " &amp; jwtError);
		return null;
	endif;
	
	return tokenString;	
epilog
	delete jwt;
	delete userIdClaim;
	delete terminalIdClaim;
	// 27 July 2022 navlw1 tfs 53854 start
	delete operatorIdClaim;
	delete complexIdClaim;
	delete yardIdClaim;
	// navlw1 tfs 53854 end
	
	delete factory;
end;</source>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_audience" type="String"/>
        <Parameter name="_appName" type="String"/>
        <Parameter name="_expiryInSeconds" type="Integer" usage="io"/>
        <Parameter name="_isRefreshToken" type="Boolean"/>
        <Parameter name="_jwtClaims" type="CMIF_WSClaimsObj"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="createWorkPoint" id="b7461500-cabe-45f7-870a-c67209b2531b">
        <options>4</options>
        <source>createWorkPoint(_workPointType: CM_WorkPointType) : CM_WorkPoint typeMethod;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Nov 2023	navnk30	Bug 61097: EUP | LMS Interface - POST with no Work Point ID

*/

constants
	DEFAULT_COLOUR : Integer = 1677215; 
vars
	pxyWorkPoint,
	realWorkPoint		: CM_WorkPoint;
begin
	create pxyWorkPoint transient;
	pxyWorkPoint.setProxy(_workPointType.getNextWorkPointCode,
							null, 
							DEFAULT_COLOUR,
							0,
							0,
							0,
							app.myPassport.myTerminal,
							_workPointType,
							null);
	
	app.myTrxCA.trxCreateWorkPoint(pxyWorkPoint, realWorkPoint, app.myPassport);
	if app.myPassport.trxCompletedOK then
		return realWorkPoint;
	else
		return null;
	endif;
epilog

end;</source>
        <Parameter name="_workPointType" type="CM_WorkPointType"/>
        <ReturnType type="CM_WorkPoint"/>
    </JadeMethod>
    <JadeMethod name="createWorkPointJobSheet" id="9b3b17b5-e362-410d-a012-6ae26d2d931f">
        <options>4</options>
        <source>createWorkPointJobSheet(_request: WS_RestWorkPointJSObject ; _statusCode : Integer io ): CM_WorkPointJobSheet typeMethod;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Jun 2023 navma1 ChangeRequest 58589[58595]: EUP | LMS Gang API - Endpoint
17 Nov 2023	navnk30	Bug 61097: EUP | LMS Interface - POST with no Work Point ID

*/

vars
	pxyWorkPointSheet,
	realJobSheet  		: CM_WorkPointJobSheet;
	workPoint		    : CM_WorkPoint;
	workPointType		: CM_WorkPointType;
	term				: CM_Terminal;
	pxyShift			: CM_Shift;
begin
	
	term := app.myPassport.myTerminal;
	
	if not validateJobSheetShift(_request,_statusCode) then
		return null;
	endif;
	//if _request.workPointId = null then					//17.11.2023 navnk30 #61097
	if _request.workPointId = null and _request.workPointType = null then	//17.11.2023 navnk30 #61097
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Workpoint),null,null );
		_statusCode := HttpResponseNotFound;
		return null;
	elseif _request.workPointId &lt;&gt; null then				//17.11.2023 navnk30 #61097	
		workPoint := term.allWorkPointsByCode[_request.workPointId.toUpper];
	elseif _request.workPointType &lt;&gt; null then				//17.11.2023 navnk30 #61097	
		WS_WebServiceAgent@getWorkPointForType(workPoint, workPointType, _request.workPointType);
	endif;
	
	//workPoint := term.allWorkPointsByCode[_request.workPointId.toUpper];	//17.11.2023 navnk30 #61097
	
	if workPoint = null then
		app.raiseCMException1(Work_point_not_found, _request.workPointId,null,null);
		_statusCode := HttpResponseNotFound;
		return null;
	endif;
	
	create pxyShift transient;
	pxyShift.setProxy(null, 
					_request.shift.startDT.time, 
					_request.shift.endDT.time, 
					_request.shift.code, 
					_request.shift.description, 
					term,
					false);
					
	pxyShift.startDateTime := _request.shift.startDT;
	pxyShift.endDateTime   := _request.shift.endDT;
	
	create pxyWorkPointSheet transient;
	pxyWorkPointSheet.setProxy(pxyShift,
							  term,
							  workPoint,
							  _request.shift.startDT,
							  _request.id,
							  _request.reference1,
							  _request.reference2,
							  _request.reference3);			
					
	app.myTrxCA.trxCreateWorkPointJobSheet(pxyWorkPointSheet, realJobSheet, app.myPassport);
	
	return realJobSheet;
epilog
	delete pxyWorkPointSheet;
	delete pxyShift;
end;</source>
        <Parameter name="_request" type="WS_RestWorkPointJSObject"/>
        <Parameter name="_statusCode" type="Integer" usage="io"/>
        <ReturnType type="CM_WorkPointJobSheet"/>
    </JadeMethod>
    <JadeMethod name="deleteBooking" id="04579d96-2a8f-4d45-aa41-ae6b02cb7b36">
        <options>4</options>
        <source>deleteBooking(_terminal : CM_Terminal; _statusCode : Integer io; _bookingId, _operatorId, _voyageId : String) typeMethod;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 March 2023	navpw1	Initial creation TFS: 56850 (56871)

*/

vars
	realBooking	: CM_BookingRef;
	
begin
	realBooking := WS_WebServiceAgent@findBooking(_bookingId, _operatorId, _voyageId, _terminal);
	
	if realBooking = null then //If we did not find the booking then complain
		app.raiseCMException1(Err_No_Booking_Found, _bookingId, null, null);
		_statusCode := HttpResponseNotFound;
		return;
	endif;
	
	//Delete found booking
	app.myTrxDA.trxDeleteBookingRef(realBooking, null, app.myPassport);
	
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_statusCode" type="Integer" usage="io"/>
        <Parameter name="_bookingId" type="String"/>
        <Parameter name="_operatorId" type="String"/>
        <Parameter name="_voyageId" type="String"/>
    </JadeMethod>
    <JadeMethod name="deleteVoyage" id="4ce4d015-ecc2-4b0b-bcb5-eb8db6c63ca8">
        <options>4</options>
        <source>deleteVoyage(_terminal : CM_Terminal; _voyageId : String; _statusCode : Integer io) typeMethod;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
12 April 2023	navlw1	Initial creation TFS 57280 CUX - MTN-EDBIC - 160 - Delete Voyage
30 Jul   2024   navsp1	Defect 65447: Delete/Voyage request is not ignoring the warning messages
*/

vars
	voyageId 	: String;
	realVoyage 	: CM_Voyage;
begin

	if _voyageId = null then
		app.raiseCMException1(REQUIRED_FIELD, "Voyage Id", null, null);
		_statusCode := HttpResponseClientError;
		return;
	endif;
	
	// get the voyage we are deleting
	realVoyage := WS_WebServiceAgent@findVoyage(_terminal, _voyageId, null, false);
	if realVoyage = null then
		app.raiseCMException1(Voyage_not_found, _voyageId, null, null);
		_statusCode := HttpResponseClientError;
		return;
	endif;
	app.myPassport.setWarningsIgnored(true);		//TFS 65447
	app.myTrxDA.trxDeleteVoyage(realVoyage, app.myPassport);
epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_voyageId" type="String"/>
        <Parameter name="_statusCode" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="deleteWorkPointJobSheet" id="c8988c81-56da-477a-8e2b-2ba1184cad61">
        <options>4</options>
        <source>deleteWorkPointJobSheet(_externalName : String;
						_statusCode   : Integer io)typeMethod;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Jun 2023 navma1 ChangeRequest 58589[58595]: EUP | LMS Gang API - Endpoint
25 Feb 2025 navma1 MTN-34075 MTN | Dead Lock (1081) on CM_JobsByPriorityRequiredDT
*/

vars
	jobSheet,
	workPointJobSheet : CM_WorkPointJobSheet;
	term			  : CM_Terminal;

begin
	
	term := app.myPassport.myTerminal;
	
	foreach workPointJobSheet in term.allJobSheetsForWorkPoints discreteLock do		//25.02.2025 navma1 #MTN-34075
		
		if workPointJobSheet.externalName = _externalName then
			jobSheet := workPointJobSheet;
			break;
		endif;
	endforeach;
	
	if jobSheet = null then
		app.raiseCMException1(ERR_JobSheet_Not_Exist, _externalName,null, null);
		_statusCode := HttpResponseClientError;
		return;
	endif;
	app.myTrxDA.trxDeleteWorkPointJobSheet(jobSheet, app.myPassport);
	
epilog

end;</source>
        <Parameter name="_externalName" type="String"/>
        <Parameter name="_statusCode" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doCreateCriteriaLine" id="5875478e-c30f-453a-bf1a-4fcfecae7360">
        <source>doCreateCriteriaLine(	_qDef : CM_QueryDefinition;
						_criteriaHolder : CM_QueryCriteriaLineHolder io;
						_propName : String;
						_qOperatorStr : String;
						_value : Any
						);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 January 2014	cnwndl1	Initial creation	Par 33347

*/

vars

	criteriaLine : CM_SelectorCriteriaLine;

begin

	criteriaLine := _qDef.createCriteriaLine(_propName, _qOperatorStr, _value);
	criteriaLine.setMyCriteriaLineHolder(_criteriaHolder);

epilog

end;</source>
        <Parameter name="_qDef" type="CM_QueryDefinition"/>
        <Parameter name="_criteriaHolder" type="CM_QueryCriteriaLineHolder" usage="io"/>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_qOperatorStr" type="String"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="doCreateVirtualDirectoryFile" id="0c75ec8d-2aba-4e20-9f5e-237807e5240b">
        <source>doCreateVirtualDirectoryFile(_wsProvider : JadeWebServiceProvider;
							 _reportAgent : WebService_ReportAgent);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 July 2010	#cnwdz2	 24674

*/

vars
	virtualDirectoryFileName    : String;
	createdVirtualDirectoryFile : Integer;
	workFile				: File;
	binary					: Binary;
begin
	if app.downloadFileRemoteCopy then
		virtualDirectoryFileName := _reportAgent.reportOutputFileName;
		virtualDirectoryFileName := virtualDirectoryFileName.replace("/", "\");
		virtualDirectoryFileName := virtualDirectoryFileName.getFileNameAndExtension();
		
		createdVirtualDirectoryFile := _wsProvider.createVirtualDirectoryFile(virtualDirectoryFileName, _reportAgent.reportBinary, false);
		if createdVirtualDirectoryFile &lt;&gt; 0 then
			app.writeLog('Virtual directory file - ' &amp; virtualDirectoryFileName &amp; " creation failed.", LogINFO);
			app.raiseCMException1(ERR_VirtualDirFileCreateFailed, virtualDirectoryFileName, null, null);
		else
			app.writeLog('Virtual directory file - ' &amp; virtualDirectoryFileName &amp; " created.", LogINFO);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_wsProvider" type="JadeWebServiceProvider"/>
        <Parameter name="_reportAgent" type="WebService_ReportAgent"/>
    </JadeMethod>
    <JadeMethod name="doCreateVirtualDirectoryImages" id="df7c6b32-9cf3-4b6f-a1fb-7bde00cd2578">
        <source>doCreateVirtualDirectoryImages(_wsProvider : JadeWebServiceProvider;
							 _reportAgent : WebService_ReportAgent);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 February 2016	cnwma1	Initial creation PAR #36654 Reports run through the web interface missing port logo

*/

vars
	virtualDirectoryFileName    : String;
	createdVirtualDirectoryFile : Integer;
	workFile				: File;
	binary					: Binary;
	fileNumber				: Integer;
	imageFileName			: String;
	
begin
	if not app.downloadFileRemoteCopy then
		return;
	endif;
	
	if _reportAgent.reportOutputFileName.pos(".html", 1) = 0 then
		return;
	endif;

	fileNumber := 1;
	while true do
		imageFileName := "_image" &amp; fileNumber.String &amp; ".jpg";
		virtualDirectoryFileName := _reportAgent.reportOutputFileName.replaceString(".html",imageFileName);
		virtualDirectoryFileName := virtualDirectoryFileName.replace("/", "\");
				
		delete workFile;
		create workFile transient;									

		workFile.fileName := virtualDirectoryFileName;
		if (not workFile.isAvailable) then
			break;
		endif;
			
		workFile.kind := workFile.Kind_Binary;
		workFile.open();
		binary := workFile.readBinary(workFile.fileLength);
		workFile.close();
				
		virtualDirectoryFileName := virtualDirectoryFileName.getFileNameAndExtension();
		createdVirtualDirectoryFile := _wsProvider.createVirtualDirectoryFile(virtualDirectoryFileName, binary, false);
		if createdVirtualDirectoryFile &lt;&gt; 0 then
			app.writeLog('Virtual directory file - ' &amp; virtualDirectoryFileName &amp; " creation failed.", LogINFO);
			app.raiseCMException1(ERR_VirtualDirFileCreateFailed, virtualDirectoryFileName, null, null);
		else
			app.writeLog('Virtual directory file - ' &amp; virtualDirectoryFileName &amp; " created.", LogINFO);
		endif;
		
		fileNumber := fileNumber + 1;
	endwhile;
		
epilog
	delete workFile;
end;</source>
        <Parameter name="_wsProvider" type="JadeWebServiceProvider"/>
        <Parameter name="_reportAgent" type="WebService_ReportAgent"/>
    </JadeMethod>
    <JadeMethod name="doSearchEventRequests" id="3f780853-353a-40ab-9a6c-bd9becf12c97">
        <source>doSearchEventRequests(	searchRequest : CMIF_SearchEventRequest;
						results			: Collection input;
						startFrom		: Integer;
						maxResults		: Integer);


/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 September 2008	cnwkao1	Initial creation - generalised to handle both request types (from KPD's 'clone' out of JMT)
07 May 2013	NDL		Part of par 31506, was breaking one too soon if maxResults was used.
12 Nov 2018 MPD		TFS 41068 - JMT - CardSchema monitoring for Web services

*/
vars
	iter			: Iterator;
	user			: CM_User;
	request			: CM_EventRequest;
	idCheck,
	statusCheck		: Boolean;
	failedDAC  		: CM_DataAccessController;
	
	matches			: Integer;	
	
begin
	iter := self.getSearchEventRequestIter(searchRequest);
	
	// Set up keys if there are any
	idCheck := searchRequest.cargoId &lt;&gt; null;
	
	if not idCheck then
		statusCheck := searchRequest.status &gt; EventRequestStatusAny;		
	endif;

	user := app.myPassport.myUser;
	matches := null;
	while iter.next(request) do
		// Let JSA know we're still doing something
		app.sendHeartbeatIfRequired();
		
		// Check key conditions for break
		if statusCheck and request.status &lt;&gt; searchRequest.status then
			break;
		endif;
		
		if idCheck then
			if request.isKindOf(CM_EventRequestTI) 
			 and request.CM_EventRequestTI.cargoId &lt;&gt; searchRequest.cargoId then
				break;
			endif;
		endif;
		
		// Check access to organisation
		if not user.canUserAccessObj(request.myOrganisation, CM_Organisation) then
			continue;
		endif;

		// Check access to event
		if not request.canUserAccessSelf(null, failedDAC, app.myPassport) then
			continue;
		endif;
		
		// Compare with search criteria
		if not request.matchesSearchCriteria(searchRequest) then
			continue;
		endif;
		
		matches := matches + 1;
		if matches &lt; startFrom then 
			continue;
		endif;
		
	//	if matches - startFrom = maxResults then
	//		break; //found enough items
	//	endif;
		
		results.add(request);
		
		if maxResults &gt; 0 and matches - startFrom = maxResults then		//cnwmc5 - 25 Sep 2014 - PAR 34927
			break; //found enough items
		endif;
		
	endwhile;
		

epilog
	delete iter;
end;
</source>
        <Parameter name="searchRequest" type="CMIF_SearchEventRequest"/>
        <Parameter name="results" type="Collection" usage="input"/>
        <Parameter name="startFrom" type="Integer"/>
        <Parameter name="maxResults" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doSearchUsingSelector" id="8230c8f3-7103-46d7-9193-9014c91657e8">
        <source>doSearchUsingSelector(	_term : CM_Terminal;
