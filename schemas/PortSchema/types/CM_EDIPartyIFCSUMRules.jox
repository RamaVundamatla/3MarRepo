    <JadeMethod name="create" id="2683c333-11a5-45b6-9fbb-9af177ac5037">
        <updating/>
        <source>create() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 09 September 2016	cnwdap1		Initial creation PAR #
//
vars
	type : CM_EDIFileType;
begin
	// set file type
	type := app.myRoot.allEDIFileTypes.getAtKeyGeq(EDIFileType_IFCSUM94B, null);
	
	if type = null or type.type &lt;&gt; EDIFileType_IFCSUM94B then
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'IFCSUM file type missing');
	endif;
	
	self.myEDIFileType := type;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="hasHSCodeTranslation" id="5b582efa-e65a-445c-b66d-7e32253fc346">
        <source>hasHSCodeTranslation() : Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 11/09/2024	navdap1		Initial creation TFS 65152 NSW | IFCSUM Enhancements
//
vars
	ruleItem : CM_EDIRule;
begin
	foreach ruleItem in self.allEDIPartyRules where ruleItem.isIFCSUMHSRule do
		return true;
	endforeach;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isExists" id="f9604fb2-e333-462a-9d8e-2f7b08505e3e">
        <source>isExists(_hsCode : String) :Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 November 2024	navsp1	Initial creation MTN-33228

*/

vars
	rule : CM_EDIRule;
	hsRule : CM_EDIIFCSUMHSRule;
begin
	foreach rule in self.allEDIPartyRules where rule.isKindOf(CM_EDIIFCSUMHSRule) do
		hsRule := rule.CM_EDIIFCSUMHSRule;
		if hsRule.hsCode = _hsCode then
			return true;
		endif;
	endforeach;
	return false;
epilog

end;</source>
        <Parameter name="_hsCode" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="d9d29d09-cddc-4a9e-a14e-2c8956979452">
        <source>pxyCreateUpdateProxy(): SelfType;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
/****Changes

Date		Name	TFS#			Description
============================================================================
12/09/2016	cnwdap1	TFS 2566		Initial creation AAT EDI IFCSUM
20/03/2017	cnwdap1	TFS 3734 		AAT Issues with IFCSUM
27/03/2017	cnwdap1	TFS 3825 		AAT PIA+5 used as Commodity
06/11/2018	jlgka1	39185,39187		Add flag to trigger the copy of discharge
									port to the Destination port. Also add
									a reference to hold the MAFI ISO Group.
02/02/2023	jlika1	TFS 56385		POB - IFCSUM Tranship									
14 Aug 2023	jlirs1	TFS 59845 (57770) Port of Origin BOP
29 Aug 2023	jlirs1	TFS 59170 (57770) IFCSUM Breakbulk and Mixed Cargo BOP
============================================================================*/
vars
	pxyRule 		: SelfType;
	pxyEdiHSRule, 
	rule 			: CM_EDIIFCSUMHSRule;
begin
	pxyRule := inheritMethod;
	pxyRule.cargoSegmentIsPCI 		:= self.cargoSegmentIsPCI;
	pxyRule.createCargoFromGID 		:= self.createCargoFromGID;
	pxyRule.voyageFromBGM 			:= self.voyageFromBGM;
	pxyRule.oneMEAPerGID 			:= self.oneMEAPerGID;			// TFS 3734
	pxyRule.pia5IsCommodity 		:= self.pia5IsCommodity;		// TFS 3825
	pxyRule.useDiscPortAsDestPort 	:= self.useDiscPortAsDestPort; 	// jlgka1 TFS 39187, 39185
	pxyRule.myISOTypeGroup			:= self.myISOTypeGroup;			// jlgka1 TFS 39185
	pxyRule.eqdCreateTranship		:= self.eqdCreateTranship;		// jlika1 TFS 56385
	pxyRule.myCargoOperator := self.myCargoOperator;
	pxyRule.myDefaultCargoType := self.myDefaultCargoType;		//14 Aug 2023	jlirs1	TFS 59845 (57770) Port of Origin BOP
	pxyRule.useSystemGeneratedIds := self.useSystemGeneratedIds;		//29 Aug 2023	jlirs1	TFS 59170 (57770) IFCSUM Breakbulk and Mixed Cargo BOP

	return pxyRule;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="46adc8e3-60a5-4469-beb0-8187a6faa94b">
        <updating/>
        <source>setForUpdate(_proxy: CM_EDIPartyIFCSUMRules) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
/****Changes

Date		Name	TFS#			Description
============================================================================
12/09/2016	cnwdap1	TFS 2566		Initial creation  AAT EDI IFCSUM Party Rules
20/03/2017	cnwdap1	TFS 3734 		AAT Issues with IFCSUM
27/03/2017	cnwdap1	TFS 3825 		AAT PIA+5 used as Commodity
06/11/2018	jlgka1	39185,39187		Add flag to trigger the copy of discharge
									port to the Destination port. Also add
									a reference to hold the MAFI ISO Group.
02/02/2023	jlika1	TFS 56385		POB - IFCSUM Tranship									
14 Aug 2023	jlirs1	TFS 59845 (57770) Port of Origin BOP
29 Aug 2023	jlirs1	TFS 59170 (57770) IFCSUM Breakbulk and Mixed Cargo BOP
30 Dec 2024 navsp1  MTN-33705 		NSW | IFCSUM - Process EQD+TE Segment
17 Mar 2025	naviv1	JIRA MTN-34341 NSW | 34310.020 Setting Operators on Voyage from IFCSUM files
============================================================================*/									
begin
	inheritMethod(_proxy);
	
	self.cargoSegmentIsPCI 		:= _proxy.cargoSegmentIsPCI;
	self.createCargoFromGID 	:= _proxy.createCargoFromGID;
	self.voyageFromBGM 			:= _proxy.voyageFromBGM;
	self.oneMEAPerGID 			:= _proxy.oneMEAPerGID;				// TFS 3734
	self.pia5IsCommodity 		:= _proxy.pia5IsCommodity;			// TFS 3825
	self.useDiscPortAsDestPort 	:= _proxy.useDiscPortAsDestPort; //jlgka1 TFS 39187, 39185
	self.myISOTypeGroup			:= _proxy.myISOTypeGroup;					// jlgka1 TFS 39185
	//jlier1 TFS 55788 12/12/22
	self.piaIsHSCode			:= _proxy.piaIsHSCode;
	self.meaIsCargoWeight		:= _proxy.meaIsCargoWeight;
	self.addPortsToVoyage 		:= _proxy.addPortsToVoyage;
	self.addOperatorsToVoyage	:= _proxy.addOperatorsToVoyage; //JIRA-34341
	self.doNotCreateBOL			:= _proxy.doNotCreateBOL;
	self.eqdExportCargoSite		:= _proxy.eqdExportCargoSite;
	self.eqdImportCargoSite		:= _proxy.eqdImportCargoSite;
	self.defaultLocationID		:= _proxy.defaultLocationID;
	self.eqdCreateTranship		:= _proxy.eqdCreateTranship;
	self.myCargoOperator		:=_proxy.myCargoOperator;
	self.dontOverrideFileDischargePort	:=_proxy.dontOverrideFileDischargePort; //jlier1 TFS 57156 22/3/23
	self.onlyUseFirstValidNAD	:= _proxy.onlyUseFirstValidNAD; //jlier1 TFS 56234 14/4/23
	self.divideWeightVolumeByGIDCount:=_proxy.divideWeightVolumeByGIDCount; //jlier1 TFS 57426 18/4/23
	self.nadSegmentStart		:=_proxy.nadSegmentStart.min(3).max(2); //jlier1 TFS 57604 19/4/23
	if self.myFTXTransform = null then
		create self.myFTXTransform;
	endif;
	if self.myNADTransform = null then
		create self.myNADTransform;
	endif;
	self.myDefaultCargoType := _proxy.myDefaultCargoType;			//14 Aug 2023	jlirs1	TFS 9845 (57770) Port of Origin BOP
	self.useSystemGeneratedIds := _proxy.useSystemGeneratedIds;		//29 Aug 2023	jlirs1	TFS 59170 (57770) IFCSUM Breakbulk and Mixed Cargo BOP
	self.dontIgnoreEQDTE		:= _proxy.dontIgnoreEQDTE;			//MTN-33705
	self.isFullShipperDesc 		:= _proxy.isFullShipperDesc; 		//MTN-33703
end;</source>
        <Parameter name="_proxy" type="CM_EDIPartyIFCSUMRules"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="56928624-c29b-489c-bd6d-e19365600feb">
        <updating/>
        <source>setProxy(	_cargoSegmentIsPCI,
			_createCargoFromGID,
			_voyageFromBGM,
			_oneMEAPerGID,
			_pai5IsCommodity,
			_useDiscAsDest : Boolean;
			_mafiISOTypeGroup : CM_ISOTypeGroup;
			_piaIsHSCode ,
			_meaIsCargoWeight,
			_addPortsToVoyage,
			_addOperatorsToVoyage,
			_doNotCreateBOL	: Boolean;
			_eqdExportCargoSite,
			_eqdImportCargoSite  : Integer;
			_defaultYardLocation : String;
			_createEQDTranshipCargo : Boolean;
			_cargoOperator : CM_Operator;
			_dontOverrideFileDischarge : Boolean;
			_onlyUseFirstValidNAD : Boolean;
			_divideWeightVolumeByGIDCount : Boolean;
			_nadSegmentStart : Integer;
			_defCargoType : CM_CargoType;
			_useSystemGenIDs : Boolean;
			_dontIgnoreEQDTE : Boolean;
			_isFullShipperDesc : Boolean) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
/****Changes

Date		Name	TFS#			Description
============================================================================
12/09/2016	cnwdap1	TFS 2566		Initial creation AAT EDI IFCSUM Party Rules
20/03/2017	cnwdap1	TFS 3734 		AAT Issues with IFCSUM
27/03/2017	cnwdap1	TFS 3825 		AAT PIA+5 used as Commodity
06/11/2018	jlgka1	39185,39187		Add flag to trigger the copy of discharge
									port to the Destination port. Also add
									a reference to hold the MAFI ISO Group.
02/02/2023	jlika1	TFS 56385		POB - IFCSUM Tranship							
14 Aug 2023	jlirs1	TFS 59845 (57770) Port of Origin BOP
28 Aug 2023	jlirs1	TFS 59170 (57770) IFCSUM Breakbulk and Mixed Cargo BOP
30 Dec 2024 navsp1  MTN-33705 		NSW | IFCSUM - Process EQD+TE Segment
06 Jan 2024 navsp1  MTN-33703		NSW | IFCSUM - Shipper Description Full Text
17 Mar 2025	naviv1	JIRA MTN-34341  NSW | 34310.020 Setting Operators on Voyage from IFCSUM files
============================================================================*/
begin
	self.cargoSegmentIsPCI 		:= _cargoSegmentIsPCI;
	self.createCargoFromGID 	:= _createCargoFromGID;
	self.voyageFromBGM 			:= _voyageFromBGM;
	self.oneMEAPerGID 			:= _oneMEAPerGID;				// TFS 3734
	self.pia5IsCommodity 		:= _pai5IsCommodity;			// TFS 3825
	self.useDiscPortAsDestPort 	:= _useDiscAsDest; 				// jlgka1 TFS 39187, 39185
	self.myISOTypeGroup			:= _mafiISOTypeGroup;			// jlgka1 TFS 39185
	//jlier1 TFS 55788 12/12/22
	self.piaIsHSCode			:= _piaIsHSCode;
	self.meaIsCargoWeight		:= _meaIsCargoWeight;
	self.addPortsToVoyage 		:= _addPortsToVoyage;
	self.addOperatorsToVoyage	:= _addOperatorsToVoyage;  //JIRA-34341
	self.doNotCreateBOL			:= _doNotCreateBOL;
	self.eqdExportCargoSite		:= _eqdExportCargoSite;
	self.eqdImportCargoSite		:= _eqdImportCargoSite;
	self.defaultLocationID		:= _defaultYardLocation;
	self.eqdCreateTranship		:= _createEQDTranshipCargo;	
	self.myCargoOperator:=_cargoOperator;
	self.dontOverrideFileDischargePort:=_dontOverrideFileDischarge; //jlier1 TFS 57156 22/3/23
	self.onlyUseFirstValidNAD	:= _onlyUseFirstValidNAD; //jlier1 TFS 57452 13/4/23
	self.divideWeightVolumeByGIDCount:=_divideWeightVolumeByGIDCount; //jlier1 TFS 57452 13/4/23
	self.nadSegmentStart := _nadSegmentStart; //jlier1 TFS 57604 19/4/23
	self.myDefaultCargoType := _defCargoType;		//14 Aug 2023	jlirs1	TFS 59845 (57770) Port of Origin BOP
	self.useSystemGeneratedIds := _useSystemGenIDs;		//28 Aug 2023	jlirs1	TFS 59170 (57770) IFCSUM Breakbulk and Mixed Cargo BOP
	self.dontIgnoreEQDTE		:= _dontIgnoreEQDTE;	//MTN-33705
	self.isFullShipperDesc		:= _isFullShipperDesc;	//MTN-33703
end;</source>
        <Parameter name="_cargoSegmentIsPCI" type="Boolean"/>
        <Parameter name="_createCargoFromGID" type="Boolean"/>
        <Parameter name="_voyageFromBGM" type="Boolean"/>
        <Parameter name="_oneMEAPerGID" type="Boolean"/>
        <Parameter name="_pai5IsCommodity" type="Boolean"/>
        <Parameter name="_useDiscAsDest" type="Boolean"/>
        <Parameter name="_mafiISOTypeGroup" type="CM_ISOTypeGroup"/>
        <Parameter name="_piaIsHSCode" type="Boolean"/>
        <Parameter name="_meaIsCargoWeight" type="Boolean"/>
        <Parameter name="_addPortsToVoyage" type="Boolean"/>
        <Parameter name="_addOperatorsToVoyage" type="Boolean"/>
        <Parameter name="_doNotCreateBOL" type="Boolean"/>
        <Parameter name="_eqdExportCargoSite" type="Integer"/>
        <Parameter name="_eqdImportCargoSite" type="Integer"/>
        <Parameter name="_defaultYardLocation" type="String"/>
        <Parameter name="_createEQDTranshipCargo" type="Boolean"/>
        <Parameter name="_cargoOperator" type="CM_Operator"/>
        <Parameter name="_dontOverrideFileDischarge" type="Boolean"/>
        <Parameter name="_onlyUseFirstValidNAD" type="Boolean"/>
        <Parameter name="_divideWeightVolumeByGIDCount" type="Boolean"/>
        <Parameter name="_nadSegmentStart" type="Integer"/>
        <Parameter name="_defCargoType" type="CM_CargoType"/>
        <Parameter name="_useSystemGenIDs" type="Boolean"/>
        <Parameter name="_dontIgnoreEQDTE" type="Boolean"/>
        <Parameter name="_isFullShipperDesc" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validate" id="54ea19fb-774b-42e9-8417-15eb5df4e5bb">
        <source>validate(_passport: CM_Passport input) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 December 2022	jlier1	Initial creation

*/

vars
	location : CM_LocationsController;
	foundHeight : Integer;
	terminal 	: CM_Terminal;
begin
	inheritMethod(_passport);

	terminal:=self.getMyTerminal;
	if self.defaultLocationID &lt;&gt; null and terminal &lt;&gt; null then
		
		terminal.findLocationFromString(self.defaultLocationID, false, location, foundHeight);
		if location = null or not location.isKindOf(CM_YardController) then
			app.raiseCMException1(ERR_INVALID_LOCN, self.defaultLocationID, ETRow_LocationId, self);
		endif;
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
