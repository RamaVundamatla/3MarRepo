    <JadeMethod name="getChqBalanceTotalDecimal" id="e176e12a-5408-45ee-bfbd-919c16a842bf">
        <source>getChqBalanceTotalDecimal():Decimal;

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 December 2013	cnwndl1	Initial creation	Par 33182

*/
vars

	dec : Decimal [16,4];
	cashReceipt : CM_CashReceipt;

begin

	foreach cashReceipt in self do
		if cashReceipt.chequeNumber &lt;&gt; null then
			dec := dec + cashReceipt.getAmountForBalanceTotal(null);
		endif;
	endforeach;
	
	return dec;

epilog

end;
</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getMopsString" id="e0e273dc-8059-4160-ac64-60ac12470788">
