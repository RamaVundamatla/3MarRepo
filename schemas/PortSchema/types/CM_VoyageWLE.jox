    <JadeMethod name="id" id="1317fb5c-06ba-4ffd-9f72-49054afdeaa9">
        <methodInvocation>mapping</methodInvocation>
        <source>id(set: Boolean; value: String io) mapping;
//Id is the sequence number
vars
	aJob	:	CM_VoyageJob;
begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	aJob := job.CM_VoyageJob;	
	if aJob = null then
		aJob := self.myRequest.myJob.CM_VoyageJob;
		if aJob = null then
			value := null;
			return;
		endif;
	endif;
	// PAR 23189
	if aJob.isKindOf(CM_VoyageROROJob) or aJob.isNotNotifiedJob then
		return;
	endif;
	if aJob.myVoyage = null then
		return;
	endif;
	
	value:=self.seqNumAsString;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="includeOnLoadList" id="424aea98-a432-4f37-b861-1b620d26ae8d">
        <source>includeOnLoadList(_voyage: CM_Voyage; _terminal: CM_Terminal): Boolean;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/11/2010	cnwdap1	Initial creation PAR #26426 CCMS MES 1102 Release Requests on Ship Load List
*/
vars

begin
	if self.getVoyage &lt;&gt; null then
		return self.getVoyage = _voyage;
	endif;
	
	return inheritMethod(_voyage, _terminal);

epilog

end;</source>
