<Class name="WS_RestRelReqByTypeResponse" id="f2a2007f-0d6d-4085-90f8-5554ba762ab0">
    <superclass name="WS_RestReleaseRequestRes"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="restwebservice"/>
    <PrimAttribute name="cargoTypeDescription" id="5857a021-f59a-4ea9-b3ab-bb575f9ac2ad">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="isoTypeId" id="78e54774-9921-48ba-a4f9-31fe8f748fe4">
        <length>5</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <ImplicitInverseRef name="releaseItems" id="fbf1d3ae-7cee-4c69-b667-4c08fc783eee">
        <memberTypeInverse/>
        <type name="WS_ReleaseDetailByTypeObjArray"/>
    </ImplicitInverseRef>
    <PrimAttribute name="totalRequested" id="473ed35b-d35f-48d6-a143-82ddfa4b6872">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="totalVolumeRequested" id="698d9b72-ea02-4460-ad16-336f388ae852">
        <precision>16</precision>
        <scaleFactor>4</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
    </PrimAttribute>
    <PrimAttribute name="totalWeightRequested" id="197d69db-38f8-47b6-8f4c-ba502ea3ecf1">
        <precision>14</precision>
        <scaleFactor>4</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
    </PrimAttribute>
    <JadeMethod name="delete" id="bfcee5ee-b121-473d-9f59-69a976cc5921">
        <updating/>
        <source>delete() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17/06/2024	navdap1		Initial creation TFS 63107 CUX | GET /releaseRequest API to return release request line items
//
vars

begin
	if self.releaseItems &lt;&gt; null then
		self.releaseItems.purge;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="0e81d28d-19eb-4701-bade-57b19b2ad598">
        <updating/>
        <source>setProxyFromObject(_releaseReq: CM_BulkRelease) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17/06/2024	navdap1		Initial creation TFS 63107 CUX | GET /releaseRequest API to return release request line items
//
vars
	isoGroup : CM_ISOTypeGroup;
	detail : CM_ReserveDetail;
	selection : CM_ReserveSelection;
	resDetail : WS_ReleaseDetailByTypeObject;

begin
	inheritMethod(_releaseReq);
	
	isoGroup := _releaseReq.myISOGroup;
	if isoGroup &lt;&gt; null then
		self.isoTypeId := isoGroup.code;
	endif;

	self.totalRequested :=_releaseReq.getTotalRequested();
	self.totalVolumeRequested := _releaseReq.getTotalVolumeRequested().Real;
	self.totalWeightRequested := _releaseReq.getTotalWeightRequested().Real;
	
	foreach detail in _releaseReq.allReserveDetails do
		if not detail.isKindOf(CM_ReserveSelection) then
			continue;
		endif;
		
		selection := detail.CM_ReserveSelection;
		create resDetail transient;
		resDetail.setProxyFromObject(selection);
		
		self.releaseItems.add(resDetail);
	endforeach;
epilog

end;</source>
        <Parameter name="_releaseReq" type="CM_BulkRelease"/>
    </JadeMethod>
</Class>
