    <JadeMethod name="changeLineDescription" id="126794cf-38de-40c2-b4f8-462addfa3ecd">
        <updating/>
        <source>changeLineDescription(newLineDescription: CM_InvoiceLineDesc) updating;

vars
	auditOfLineChange:    CM_AuditLineDescChanged;
	now:                  TimeStamp;
	charge:               CM_Charge;
begin

	// reuse old line description change audits
	auditOfLineChange := getAuditOfClass(CM_AuditLineDescChanged).CM_AuditLineDescChanged;

	if auditOfLineChange = null then
		// create line description change audit
		create auditOfLineChange;
		auditOfLineChange.sequenceNum := app.getNextInvoiceSeqNumOnRootBank(SN_AUDIT); // PAR 15036 
	endif;

	auditOfLineChange.newDescNarration := newLineDescription.narration;
	auditOfLineChange.prevDescNarration := invoiceLineDesc.narration;
	auditOfLineChange.userId := app.getMyUserCode;
	auditOfLineChange.datetime := now;
// PAR 35033	auditOfLineChange.setRemarks;
	auditOfLineChange.setRemarksForInvoiceLineChange(self); // PAR 35033
	
	foreach charge in charges do
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(charge, true);				// 11/5/18 MAP TFS37718
		charge.void;
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(charge, false);				// 11/5/18 MAP TFS37718
	endforeach;

	// add audit to self and invoice

	auditOfLineChange.auditedFOs.clear;
	auditOfLineChange.unauditedFOs.clear;

	auditOfLineChange.auditedFOs.add(self);
	auditOfLineChange.unauditedFOs.add(invoice);

	app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(invoice, true);			// 10/5/18 MAP TFS37718
	invoiceLineDesc := newLineDescription;
	app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(invoice, false);		// 10/5/18 MAP TFS37718

	createCharges();
epilog

end;</source>
        <Parameter name="newLineDescription" type="CM_InvoiceLineDesc"/>
    </JadeMethod>
    <JadeMethod name="changeStatus" id="9670d7de-9264-44da-9490-588d159743c9">
        <updating/>
        <source>changeStatus(newStatus: Integer) updating;

vars
	auditStatusChg:   CM_AuditLineStatusChanged;
	now:              TimeStamp;
	commitTrans:      Boolean;
	invoiceStatus 		: CMIF_InvoiceStatus;
begin
	if self.status = newStatus then
		return;
	endif;

	if newStatus = STATUS_VOIDED or newStatus = STATUS_NORMAL then

		if not process.isInTransactionState then
			commitTrans := true;
			beginTransaction;
		endif;
		
		//epr par 36958 29/9/15
		create invoiceStatus transient;
		invoiceStatus.newStatus :=newStatus;
		self.doCreateAuditStatusChanged(invoiceStatus);
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(self, true);			// 11/5/18 MAP TFS37718
		self.status := newStatus;
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(self, false);			// 11/5/18 MAP TFS37718

		if commitTrans then
			app.cmsCommitTransaction(app.myPassport);
		endif;
	endif;
epilog
	delete invoiceStatus;
end;</source>
        <Parameter name="newStatus" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="chargedPrevPostedCurrent" id="f67d9c21-21f3-4e24-915e-88e47f7ea64e">
        <methodInvocation>mapping</methodInvocation>
        <source>chargedPrevPostedCurrent(set: Boolean; _value: Boolean io) mapping;
/*
Purpose:	

Date		Who		Reason
20 September 2024	navab1	CR 65827 TASK 65829
*/

vars
	defaultFP : CM_FinancialPeriodEnd;
	chargedFP, postedFP : CM_FinancialPeriodDateTime;
	bu : CM_Bank;
	theInvoice : CM_Invoice;
	chargedIDX, postedIDX : Integer;
	now : TimeStamp;
begin
	if set then
		// set code here
	else
		// get code here
			theInvoice := self.invoice;
			if theInvoice = null then
				_value := false;
			else
				if not theInvoice.isPosted then
					_value := false;
					return;
				endif;
				
				bu := app.myRoot.myRootCompany;
				if bu = null then // we have a bigger issue
					_value := false;
					return;
				endif;
				
				defaultFP := bu.getDefaultFPE;
				if defaultFP = null then
					_value := false;
					return;
				endif;
				
				now := app.actualTimeAppServer;
				
				chargedFP:= defaultFP.allFinancialPeriodEndDates.getAtKeyGeq(self.chargeTime);
				postedFP:= defaultFP.allFinancialPeriodEndDates.getAtKeyGeq(now);
				
				if chargedFP = null
				or postedFP = null then
					_value := false;
					return;
				endif;
				if chargedFP = postedFP then
					_value := false;
					return;
				endif;
				
				chargedIDX := defaultFP.allFinancialPeriodEndDates.indexOf(chargedFP);
				postedIDX := defaultFP.allFinancialPeriodEndDates.indexOf(postedFP);
				
				if (chargedIDX + 1) = postedIDX then
					_value := true;
					return;
				endif;
				
				_value := false;
					return;
			endif;
			
	endif;


epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="cloneForConsChargeRate" id="43b7f3e3-f7b2-431b-97ea-7484bb41276c">
        <source>cloneForConsChargeRate(_controller : CMIF_InvoiceLineCopy; _ti : CM_TrackedItem;_seqNum : Integer; _bTransient : Boolean):CM_InvoiceLine;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 February 2024	navrv30	Initial creation for CR 61911/ Task 61392

*/

vars

	cloneInvLine 	: CM_InvoiceLine;
begin

	cloneInvLine := self.cloneSelf(_bTransient);
	cloneInvLine.sequenceNum := _seqNum;
	cloneInvLine.invoice := _controller.myInvoice;
	cloneInvLine.debtor := _controller.myInvoice.debtor;
	cloneInvLine.manual := true;

	cloneInvLine.bank := self.bank;
	if _controller.differentChargeDT then
		cloneInvLine.chargeTime.setDate(_controller.chargeDT.date);
		cloneInvLine.chargeTime.setTime(_controller.chargeDT.time);
	else
		cloneInvLine.chargeTime := self.chargeTime;
	endif;
	cloneInvLine.invoiceLineDesc := self.invoiceLineDesc;
	cloneInvLine.paymentType := self.paymentType;
	cloneInvLine.exportedCount := 0;
	
	if _controller.differentCargos then
		cloneInvLine.trackedItem := _ti;	
		if cloneInvLine.trackedItem &lt;&gt; null then
			cloneInvLine.trackedItemId := cloneInvLine.trackedItem.id;
			cloneInvLine.trackedItemLength := cloneInvLine.trackedItem.length;
			cloneInvLine.trackedItemQuantity := cloneInvLine.trackedItem.getChargeQuantity();
			cloneInvLine.trackedItemVolume := cloneInvLine.trackedItem.getChargeVolume();
			cloneInvLine.trackedItemWeight := cloneInvLine.trackedItem.getChargeWeight();
		endif;
	else
		cloneInvLine.trackedItem := self.trackedItem;
	endif;	
	return cloneInvLine;
epilog

end;</source>
        <Parameter name="_controller" type="CMIF_InvoiceLineCopy"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_seqNum" type="Integer"/>
        <Parameter name="_bTransient" type="Boolean"/>
        <ReturnType type="CM_InvoiceLine"/>
    </JadeMethod>
    <JadeMethod name="cloneForConsNarrRate" id="ba558d5a-ecc4-4602-8f50-93e9c65db2e3">
        <source>cloneForConsNarrRate(_controller : CMIF_InvoiceLineCopy; _ti : CM_TrackedItem;_bTransient : Boolean):CM_InvoiceLine;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 February 2024	navrv30	Initial creation for CR 61911/ Task 61391

*/

vars

	cloneInvLine 	: CM_InvoiceLine;
	charge 			: CM_Charge;
	cloneCharge 	: CM_Charge;
begin

	cloneInvLine := self.cloneSelf(_bTransient);
	cloneInvLine.invoice := _controller.myInvoice;
	cloneInvLine.debtor := _controller.myInvoice.debtor;
	cloneInvLine.manual := true;

	cloneInvLine.bank := self.bank;
	if _controller.differentChargeDT then
		cloneInvLine.chargeTime.setDate(_controller.chargeDT.date);
		cloneInvLine.chargeTime.setTime(_controller.chargeDT.time);
	else
		cloneInvLine.chargeTime := self.chargeTime;
	endif;
	cloneInvLine.invoiceLineDesc := self.invoiceLineDesc;
	cloneInvLine.paymentType := self.paymentType;
	cloneInvLine.exportedCount := 0;
	
	if _controller.differentCargos then
		cloneInvLine.trackedItem := _ti;	
		if cloneInvLine.trackedItem &lt;&gt; null then
			cloneInvLine.trackedItemId := cloneInvLine.trackedItem.id;
			cloneInvLine.trackedItemLength := cloneInvLine.trackedItem.length;
			cloneInvLine.trackedItemQuantity := cloneInvLine.trackedItem.getChargeQuantity();
			cloneInvLine.trackedItemVolume := cloneInvLine.trackedItem.getChargeVolume();
			cloneInvLine.trackedItemWeight := cloneInvLine.trackedItem.getChargeWeight();
		endif;
	else
		cloneInvLine.trackedItem := self.trackedItem;
	endif;
	foreach charge in self.charges do
		cloneCharge := charge.cloneForConsolidation( cloneInvLine);
	endforeach;
	return cloneInvLine;
epilog

end;</source>
        <Parameter name="_controller" type="CMIF_InvoiceLineCopy"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_bTransient" type="Boolean"/>
        <ReturnType type="CM_InvoiceLine"/>
    </JadeMethod>
    <JadeMethod name="cloneForCopy" id="423095b6-98de-40f6-b5b8-cb08f0de583c">
        <source>cloneForCopy( _controller : CMIF_InvoiceLineCopy; _ti : CM_TrackedItem;_bTransient : Boolean):CM_InvoiceLine;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 April 2023  navmv20 TFS 55304 Task 55542: Jade - Invoice Line Copy Jade Code
12 April 2023  navmv20 TFS 55304 Task 55544: Jade - Invoice Line Copy Audits
03 May 	 2023  navmv20 Bug 57664: EUP - Copy function does not include overridden rates
20 Oct   2024  navrv30	MTN 20794 EUP | Performance Invoice Copy
*/

vars

	cloneInvLine 	: CM_InvoiceLine;
	charge 			: CM_Charge;
	cloneCharge 	: CM_Charge;
	trackedItem 	: CM_TrackedItem;
	
begin

	cloneInvLine := self.cloneSelf(_bTransient);
	
	cloneInvLine.sequenceNum := app.getNextInvoiceSeqNumOnRootBank(SN_INVOICELINE); 

	cloneInvLine.invoice := _controller.myInvoice;
	cloneInvLine.debtor := _controller.myInvoice.debtor;
	cloneInvLine.manual := true;

	cloneInvLine.bank := self.bank;
	if _controller.differentChargeDT then
		cloneInvLine.chargeTime.setDate(_controller.chargeDT.date);
		cloneInvLine.chargeTime.setTime(_controller.chargeDT.time);
	else
		cloneInvLine.chargeTime := self.chargeTime;
	endif;
	cloneInvLine.invoiceLineDesc := self.invoiceLineDesc;
	cloneInvLine.paymentType := self.paymentType;
	cloneInvLine.exportedCount := 0;
	//cloneInvLine.overriddenChargeCount := 0; //03/05/2023 navmv20 Bug 57664
	//cloneInvLine.setEscalatingValues(0,0);   //03/05/2023 navmv20 Bug 57664
	
	if _controller.differentCargos then
		cloneInvLine.trackedItem := _ti;
	/*
	else //03/05/2023 navmv20 Bug 57664
		cloneInvLine.trackedItem := self.trackedItem; //03/05/2023 navmv20 Bug 57664
	endif;*/	//03/05/2023 navmv20 Bug 57664
		if cloneInvLine.trackedItem &lt;&gt; null then
			cloneInvLine.trackedItemId := cloneInvLine.trackedItem.id;
			cloneInvLine.trackedItemLength := cloneInvLine.trackedItem.length;
			cloneInvLine.trackedItemQuantity := cloneInvLine.trackedItem.getChargeQuantity();
			cloneInvLine.trackedItemVolume := cloneInvLine.trackedItem.getChargeVolume();
			cloneInvLine.trackedItemWeight := cloneInvLine.trackedItem.getChargeWeight();
		endif;
	//03/05/2023 navmv20 Bug 57664 - START
	else
		cloneInvLine.trackedItem := self.trackedItem;
	endif;
	
	
	foreach charge in self.charges do
		cloneCharge := charge.cloneForCopy( cloneInvLine);
	endforeach;
	//03/05/2023 navmv20 Bug 57664 - END
	
	//20 Oct   2024  navrv30	MTN 20794
	//The below are not needed as cloneSelf takes
	//care of populating the taxTotal and totalAmount as they are persistent fields 
	//cloneInvLine.setTaxDetails(); // ### TFS CR 62992 TASK 62994 21MAR2024 NAVAB1
	//cloneInvLine.setTotalAmount(); // ### TFS CR 63369 TASK 63371 08APR2024 NAVAB1

	return cloneInvLine;
	
epilog

end;</source>
        <Parameter name="_controller" type="CMIF_InvoiceLineCopy"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_bTransient" type="Boolean"/>
        <ReturnType type="CM_InvoiceLine"/>
    </JadeMethod>
    <JadeMethod name="cloneForReturn" id="6bf30c79-4af8-4b01-97d8-ad759f6cac45">
        <source>cloneForReturn( _cloneInv : CM_Invoice; _asCredit : Boolean ):CM_InvoiceLine;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 September 2017	jlgndl1	Initial creation	TFS 6759
26/06/2018 	Jlgns1	Bug 39130: STWO - Error when POST RETURNing an invoice
*/

vars

	cloneInvLine : CM_InvoiceLine;
	charge : CM_Charge;
	cloneCharge : CM_Charge;

begin

	cloneInvLine := self.cloneSelf( false );
	
	cloneInvLine.sequenceNum := app.getNextInvoiceSeqNumOnRootBank(SN_INVOICELINE); 
	
	cloneInvLine.invoice := _cloneInv;
	
	if _asCredit 
	and cloneInvLine.status &lt;&gt; STATUS_VOIDED then	//	Bug 39130
		cloneInvLine.status := STATUS_VOIDED;
	endif;
	
	cloneInvLine.bank := self.bank;
	cloneInvLine.debtor := self.debtor;
	cloneInvLine.invoiceLineDesc := self.invoiceLineDesc;
	cloneInvLine.myResourceTypeUsage := self.myResourceTypeUsage;
	cloneInvLine.mySnapShotData := self.mySnapShotData;
	cloneInvLine.mySnapShotQuantity := self.mySnapShotQuantity;
	cloneInvLine.myTransactionEvent := self.myTransactionEvent;
	cloneInvLine.myTransactionHMS := self.myTransactionHMS;
	cloneInvLine.myTransactionTI := self.myTransactionTI;
	cloneInvLine.myTransactionWO := self.myTransactionWO; // TFS 42161 noticed that WO Tran is, missing from some methods
	cloneInvLine.myTransactionBOL := self.myTransactionBOL;	//31 Oct 2019	NDL	TFS 47100
	cloneInvLine.trackedItem := self.trackedItem;
	
	foreach charge in self.charges do
		cloneCharge := charge.cloneForReturn( cloneInvLine, _asCredit );
	endforeach;

	return cloneInvLine;
	
epilog

end;</source>
        <Parameter name="_cloneInv" type="CM_Invoice"/>
        <Parameter name="_asCredit" type="Boolean"/>
        <ReturnType type="CM_InvoiceLine"/>
    </JadeMethod>
    <JadeMethod name="convert" id="37f72b55-3d9b-44c8-b641-658eb90751f3">
        <updating/>
        <source>convert() updating;
// CCMS 1264, set quantity and charge rate for existing lines
//	23 Oct 2024	navlw1 JIRA-33107: Invoice Logging Use Levels
//	25 Feb 2025	navah1 Story 34141: MTN - Performance Improvements - Review for invLog() Methods
vars
	charge	: CM_Charge;
	canLogExtra			: Boolean;	//27.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//27.02.2025 navah1	#34141
	self.calculateQuantity();
	foreach charge in self.charges do
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog(method.qualifiedName &amp; " Calling CM_Charge.evaluateRate", LogINFO.String); // TFS 42084
		endif;
		charge.evaluateRate();
	endforeach;
end;
</source>
    </JadeMethod>
    <JadeMethod name="convertDecimalArrayToCSV" id="ac8eea34-6c25-4a74-b58a-a7a54386be4c">
        <source>convertDecimalArrayToCSV(_theArray : DecimalArray io; _useQuotes : Boolean) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Nov 2018	jlgsl4	TFS 41230 - ADP - Invoice export

*/
vars
	csvOutput : String;
	decimal : Decimal[12,2];
begin
	if _theArray &lt;&gt; null then
		if _theArray.size &gt; 1 then
			if _useQuotes then
				csvOutput := DoubleQuote;
			endif;
			csvOutput := csvOutput &amp; _theArray.first.String &amp; "," &amp; _theArray[2].String;
			if _useQuotes then
				csvOutput := csvOutput &amp; DoubleQuote;
			endif;
			return csvOutput;
		else
			return _theArray.first.String;
		endif;
	endif;
	return "";
epilog

end;</source>
        <Parameter name="_theArray" type="DecimalArray" usage="io"/>
        <Parameter name="_useQuotes" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="convertStringArrayToCSV" id="4ec8fb07-8960-4e59-8736-7c2f8b1986c4">
        <source>convertStringArrayToCSV(_theArray : StringArray io; _useQuotes : Boolean) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 Nov 2018	jlgsl4	TFS 41230 - ADP - Invoice export
20-04-2023 	navtnr20 Task 57620: EUP - Invoice Line Type / Services Configuration Updated Requirements
*/

vars

begin
	if _theArray &lt;&gt; null then
		if _theArray.size &gt; 1 then
			if _useQuotes then
				return DoubleQuote &amp; _theArray.asCSV(true) &amp; DoubleQuote;
			else
				// return _theArray.asCSV(true);//	navtnr20 20-04-2023 TFS 57620
				return _theArray.asCSV(_useQuotes); //	navtnr20 20-04-2023 TFS 57620 - use _useQuotes
			endif;
		else
			return _theArray.first;
		endif;
	endif;
	return "";
epilog

end;</source>
        <Parameter name="_theArray" type="StringArray" usage="io"/>
        <Parameter name="_useQuotes" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="createCharges" id="8bb81375-2bad-41ae-aa17-ccade2a16c71">
        <source>createCharges();

vars
	service : CM_Service;
	tmpTotal : Real;
begin
	foreach service in self.invoiceLineDesc.services do
		service.createCharge(self);
	endforeach;
	
	// Apr 2012 CCMS 1262 quantity no longer dynamic
	//self.setQuantity();

	// PAR 24423
	tmpTotal := self.lineTotal; // ### VERY IMPORTANT TO LEAVE THIS HERE, as it is virtual. This call sets rate and quantity correctly

end;</source>
    </JadeMethod>
    <JadeMethod name="createChargesProforma" id="ece054b1-48b9-4a0c-abff-ce8a76baa2a0">
        <source>createChargesProforma(_seqnum : Integer);

/*

Purpose:		TFS 37454	

Parameters:			

Return Value:		


Date		Who		Reason
19 Apr 2018	jlgab1	Initial creation
19 Mar 2021 cnwma1 ChangeRequest 50925: ASPA - New Total Column in Invoice Form
*/

vars
	service    		: CM_Service;
	charge     		: CM_Charge;
	newRate    		: Real;
	rateTotal  		: Real;
	count      		: Integer;
	terminal   		: CM_Terminal;	//24 Oct 2019	NDL	TFS 47164
	doRounding 		: Boolean;		//24 Oct 2019	NDL	TFS 47164
	roundDecimalOpt : Integer;
begin
	count := _seqnum;
	
	//24 Oct 2019	NDL	TFS 47164
	terminal := self.getMyTerminal();
	
	/* 
	19.03.2020 cnwma1 TFS #50925
	if terminal &lt;&gt; null and terminal.getConfig(InvoiceRoundLineTotal).Boolean then
		doRounding := true;
	endif;
	*/
	
	// ### JIRA 34909 16MAY2025 NAVAB1 - no rounding leave _value as is
	if app.myPassport.context = Context_Pass_InvSplitMerge then	
		doRounding := false;
	else
		//19.03.2020 cnwma1 TFS #50925
		if terminal &lt;&gt; null then
			roundDecimalOpt := terminal.getConfig(InvoiceRoundLineTotal).Integer;
			if roundDecimalOpt &lt;&gt; CMIF_ConfigTerminal.InvLineRound_Value_NoRound then
				doRounding := true;
			endif;
		endif;
		//19.03.2020 cnwma1 TFS #50925
	endif;
	
	foreach service in self.invoiceLineDesc.services do		
		create charge transient;
		charge.setForCreate(	null,
								self, 
								count,	//23 Oct 2019	NDL	TFS 47164
								service);
		newRate := charge.getRateFromTable(rateTotal);
		charge.setRateForMinMax (newRate.roundedTo(6));
	//	charge.evaluateRate();	//23 Oct 2019	NDL	TFS 47164 - Can't use this, it relies on an invoice and there there isn't one!
	
		//24 Oct 2019	NDL	TFS 47164
		if doRounding then
			//charge.total := charge.total.rounded64(); 				 //19.03.2020 cnwma1 TFS #50925
			charge.total   := charge.total.roundedTo(roundDecimalOpt);   //19.03.2020 cnwma1 TFS #50925
		endif;
		count := count + 1;
	endforeach;

epilog

end;</source>
        <Parameter name="_seqnum" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="createChargesWeb" id="3b4b3fdd-21cc-4e04-8fe7-90885a68d612">
        <source>createChargesWeb();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 August 2023	navcs2	Initial creation

*/

vars
	charge,
	realCharge	: CM_Charge;
	tmpTotal 	: Real;
	seqNum		: Integer;
begin
	foreach charge in self.charges do
		if charge.isTransient then
			seqNum := app.getNextInvoiceSeqNumOnRootBank(SN_CHARGE); 
			create realCharge persistent;
			
			realCharge.setForCreate(charge.bank,
			self, 
			seqNum,
			null);
			app.myUtilityCA.myCreateAuditAgent.audCreateGeneric(realCharge);
			realCharge.setProxyTaxNew(charge.myOverrideTaxCode);
			realCharge.setProxyRateNew(charge.getRate());
		endif;
	endforeach;
	
	tmpTotal := self.lineTotal; 
end;</source>
    </JadeMethod>
    <JadeMethod name="createManualInvLineTransaction" id="9cae90e5-b007-48b3-ae49-d0b12756c27c">
        <updating/>
        <source>createManualInvLineTransaction(_copyTIValues : Boolean) updating;
/*
Purpose:			
		// If a manual invoice line for cargo has been created then
		// we want to create a ManualInvoiceLine Transaction too

Date		Who		Reason
//03 May 2023 navmv20 Bug 57664: EUP - Copy function does not include overridden rates
*/

vars
	calcType : CM_CalculationType;
	transCtrl 	: CMIF_TITransactionController;
	transObj	: CM_TITransaction;
	ti 			: CM_TrackedItem;
	
begin
	ti := self.trackedItem;
	if ti = null then
		return;
	endif;
	
	calcType := self.getCalcType();
	if calcType &lt;&gt; null 
	and calcType.isCargoCalcType then
		create transCtrl transient;
		transCtrl.myTrackedItem := ti; 
		transCtrl.type := TRANS_TYPE_MANUALLINECREATED;
		transCtrl.noCharge := true;
		app.myUtilityCA.utlCreateTITransaction(transCtrl, transObj, app.myPassport);
		
		if transObj &lt;&gt; null then
			transObj.setMyTrackedItem(ti, transCtrl);
			if _copyTIValues then
				self.setMyTransaction(transObj);
			else
				self.myTransactionTI := transObj;
				// do not call self.setMyTransaction() because the trackedItem values have been cloned
			endif;
		endif;
	endif;

epilog
	delete transCtrl;
end;</source>
        <Parameter name="_copyTIValues" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createProformaDetail" id="9fc40e7c-9f7c-4110-b613-07729e5ebfe3">
        <source>createProformaDetail(_cashReceipt : CM_CashReceipt) : CM_ProformaDetails;
// for proforma invoices, save details as CM_ProformaDetails for the cash receipt from the proforma transient line
//16/10/17 jlgns1 TFS 7408 QNS - Receipt Error in Cash Module later fix
vars
	details : CM_ProformaDetails;
	rate	: Real;
	tranType	: Integer;
	tran : CM_Transaction;
	invalid : Boolean;
	remarks : String;	//08 Nov 2018	NDL	TFS 41874
	voyage : CM_Voyage;
begin
	on Exception do app.handleDeletedObject(exception, tran, invalid); // TFS 39507

	rate := self.getRate();

	create details persistent;
	
	// TFS 39507 - during proforma begin abort these transactions can be invalid
	if self.myTransactionTI &lt;&gt; null then
		tran := self.myTransactionTI;
	elseif self.myTransactionWO &lt;&gt; null then 
		tran := self.myTransactionWO; 
	elseif self.myTransactionHMS &lt;&gt; null then
		tran := self.myTransactionHMS;
	elseif self.myTransactionBOL &lt;&gt; null then //31 Oct 2019	NDL	TFS 47100
		tran := self.myTransactionBOL; 
	endif;
	
	if _cashReceipt&lt;&gt; null then // TFS 47985 recording for proforma print _cashReceipt is null
		voyage := _cashReceipt.myVoyage; // TFS 47985
	endif;
	
	if tran &lt;&gt; null then
		tranType := tran.getType();
		if voyage = null then // TFS 47985
			voyage := tran.getMyVoyageObject(); // TFS 47985
		endif;
	endif;
	if tran = null or invalid then
		tranType := self.quantityNoMinMax.Integer;			// 36544 transaction type saved off in transientCopy
	endif;
	
	//08 Nov 2018	NDL	TFS 41874
	if self.remarks.trimBlanks &lt;&gt; null then
		remarks := self.remarks.trimBlanks[1:220] &amp; " - " ;
	endif;
	remarks := remarks &amp; self.invoiceLineDesc.narration &amp; " " &amp; self.lineTotal.asCurrencyJMT;

	
	details.setup(self.chargeTime, self.lineTotal, self.quantity, rate,remarks, 
		_cashReceipt, self.invoiceLineDesc, self.trackedItem, tranType, voyage,  // TFS 47985 voyage
		self.getOverridden); //TFS 7408 TFS 37454
	
	return details;
	
end;</source>
        <Parameter name="_cashReceipt" type="CM_CashReceipt"/>
        <ReturnType type="CM_ProformaDetails"/>
    </JadeMethod>
    <JadeMethod name="createTransientCharges" id="8631ef96-bfd7-4ff7-a757-07b8f6fec0ca">
        <source>createTransientCharges();

vars
	service : CM_Service;
	tmpTotal : Real;
	seq	: Integer;
begin
	foreach service in self.invoiceLineDesc.services do
		seq := seq + 1;
		service.createTransientCharge(self, seq);
	endforeach;
	
	tmpTotal := self.lineTotal; // ### VERY IMPORTANT TO LEAVE THIS HERE, as it is virtual. This call sets rate and quantity correctly

end;</source>
    </JadeMethod>
    <JadeMethod name="debtorChange" id="cfe2a269-157c-4702-9c95-b713d0f55d4f">
        <updating/>
        <source>debtorChange(_newDebtor : CM_Debtor) updating;
/*
Purpose:			

Date		Who		Reason
16MAR2023	NAVAB1	BUG 57016
23 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
*/

vars
	msg		: String;
	inv, newInvoice : CM_Invoice;
	invType : CM_InvoiceDesc;
	invLineType : CM_InvoiceLineDesc;
	theTI : CM_TrackedItem;
	currentDebtor : CM_Debtor;
	theBank : CM_Bank;
	theTran : CM_TITransaction;
	diffVoy : Boolean;
	storageConfig	: CM_StorageConfig;
	debtorType : CM_DebtorType;	

begin
	if self.myTransactionTI = null then // CARGO INVOICING ONLY
		return;
	endif;
	if self.isPaidFor then
		return;
	endif;

	currentDebtor := self.debtor;
	
	if currentDebtor = _newDebtor then
		return;
	endif;
	
	msg := "Debtor change from '" &amp; currentDebtor.name &amp; "' to '" &amp; _newDebtor.name &amp; "'";
	
	theTran := self.myTransactionTI;

	theBank := self.bank;
	inv := self.invoice;
	invType := inv.invoiceType;
	invLineType := self.invoiceLineDesc;

	newInvoice := theBank.getAutoInvoice(invType, invLineType, theTran, _newDebtor, null); 

	if newInvoice &lt;&gt; inv then
		msg := msg &amp; " Invoice line " &amp; self.sequenceNum.String &amp; " has been moved from invoice " &amp; inv.sequenceNum.String &amp; " to new invoice " &amp; newInvoice.sequenceNum.String;
		
		self.moveLineToInvoice(newInvoice);
	else
		self.debtor := _newDebtor;
	endif;

	app.invLog(msg, LogINFO.String);
end;</source>
        <Parameter name="_newDebtor" type="CM_Debtor"/>
    </JadeMethod>
