    <JadeMethod name="doSearch" id="be7a68cb-d18d-42e8-a463-908182c6452f">
        <updating/>
        <source>doSearch(_isLostFocus : Boolean) : Boolean protected, updating;

begin

	// Do appropriate search based on what option button is current.
	self.myLog := null;
	self.myLocation := null;
	self.mySelectedDocketDef := null;
	if self.selection = LOGID then
		self.getId();
	elseif self.selection = LOGDOCKET then
		self.getDocket();
	elseif self.selection = LOGLOCATION or self.selection = LOGLOCATDOCKET then		// 17/09/2008 cnwar2 #17957 (CCMS1095)
		self.displayLocation(self.cmbLocation.listObject.CM_LogController);
	elseif self.selection = LOGSPECS then
		self.getSpecs();
	endif;
	
epilog
	return self.myLog &lt;&gt; null or self.mySelectedDocketDef &lt;&gt; null;

end;</source>
        <access>protected</access>
        <Parameter name="_isLostFocus" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTblSelDataSelection" id="280842b9-314e-4037-85be-26645a5e9aad">
        <updating/>
        <source>doTblSelDataSelection(_select : Boolean) updating, protected;
// ---------------------------------------------------------------------------
// Created:     20 May 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	idx,
	numRows	: Integer;
	newText	: String;

begin

	if _select then
		newText := '1';
	else
		newText := '0';
	endif;

	numRows := self.tblSelectData.rows;
	foreach idx in 2 to numRows do
		tblSelectData.accessCell(idx, 1).text := newText;
	endforeach;

end;</source>
