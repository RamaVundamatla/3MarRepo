    <JadeMethod name="getAllCargoForAnyIdSelection" id="ffa9c2ee-d500-458e-ba0c-c92d3b90f97d">
        <source>getAllCargoForAnyIdSelection(_allAnyIdCargo : Collection input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Dec 2017	jlger1	Initial creation 8325
31 Dec 2019 cnwma1	Bug 47109: JMT - Web App Truck Loader with Single Duplicate ID
23 Jun 2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
04 Dec 2025 navma1  MTN-36742 AAT- Webb Dock West (WDCT) experiencing slowness 		
*/

vars
	ti 			 : CM_TrackedItem;
	delReq		 : CM_DeliveryRequest;
	iter		 : Iterator;
	bulkRelease  : CM_BulkRelease;
	resDet 		 : CM_ReserveDetail;
	allTis		 : CM_TISet; 
begin
	
	if _allAnyIdCargo = null then
		return;
	endif;

	if not self.isAnyId then
		return;
	endif;
	
	delReq := self.myRequest.CM_DeliveryRequest; // its always a delivery request if its an Any Id
	
	if delReq = null then
		return;
	endif;
	
	create allTis transient; 		
	
	resDet := delReq.myReserveDetail;
	
	if resDet &lt;&gt; null and resDet.isReserveSelection then				//04.12.2025 navma1 #MTN-36742
		resDet.getAllTrackedItems(allTis, false); 						//23/06/2023	navkc1	CR 58406 Task 58408

		foreach ti in allTis discreteLock do				    		//23/06/2023	navkc1	CR 58406 Task 58408

			if ti.isOnTruck then                                		//31.12.2019 cnwma1 #47109
				continue;
			endif;
			
			if not ti.isTiAvailableForAnyIdSelection() then
				continue;
			endif;		
			
			_allAnyIdCargo.tryAdd(ti);									//04.12.2025 navma1 #MTN-36742
			
		endforeach;
		
	else
		bulkRelease := delReq.myOriginatingBulkRelease;
		
		if bulkRelease = null then
			return;
		endif;
		//Ok we are dealing with a release by id but with no ids selected at the gate, (an 'Any Id' Release)
		//we must present the  whole list of available cargo
	
		iter := bulkRelease.allReserveDetails.createIterator;
		while iter.next( resDet ) do
			
			if not resDet.isKindOf( CM_ReserveTI ) then
				continue;
			endif;
	
			ti := resDet.CM_ReserveTI.getFirstTI(false); 				//23/06/2023	navkc1	CR 58406 Task 58408
			
			if ti = null then
				continue;
			endif;
	
			if ti.isOnTruck then                                		//31.12.2019 cnwma1 #47109
				continue;
			endif;
			
			if not ti.isTiAvailableForAnyIdSelection() then
				continue;
			endif;
			
			_allAnyIdCargo.tryAdd(ti);									//04.12.2025 navma1 #MTN-36742
		endwhile;
	endif;
epilog
	delete iter;
	delete allTis; 
end;</source>
        <Parameter name="_allAnyIdCargo" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllValidRTMoveMethodRules" id="9dc1b648-33d4-4d86-bd07-533e2dc0f21c">
        <source>getAllValidRTMoveMethodRules(	_allValidRTMoveMethodRules :  CM_RTMoveMethodRuleDict input );
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 February 2010	cnwer1	Initial creation

*/

vars
	theMoveMethodRule,
	moveMethodRule : CM_RTMoveMethodRule;
	multiMoveMethod,
	newMultiMoveMethod 	: CM_RTQueueMultiRule;
	rtQueueEntry	: CM_RTQueueEntry;
	rtQueueTask		: CM_RTQueueTask;
	currrentLocation,
	theTargetLocation	: CM_LocationsController;
	terminal		: CM_Terminal;
	machineTypeGrpInt 	: Integer;
	machineTypeGrp		: CM_MachineTypeGroup;
	machineTypeGrpArray : CM_MachineTypeGroupArray;
begin
	if _allValidRTMoveMethodRules = null then
		return;
	endif;

	rtQueueEntry:=self.allRTQueueEntries.first;
	if rtQueueEntry = null then
		return;
	endif;
	
	if rtQueueEntry.myWorkListEntry = null then
		return;
	endif;
	
	//cnwrd1 par 28196 31.10.2011 removed
	/*
	if  rtQueueEntry.myWorkListEntry.myTrackedItem = null then
		return;
	endif;*/
	
	theMoveMethodRule:=rtQueueEntry.myRTMoveMethodRule;
	
	if theMoveMethodRule = null then
		return;
	endif;
	
	//if unactioned then can make the assumption that the move method is valid
	// and all alternate rules can be used
	if self.status = WLE_UNACTIONED or self.myTrackedItem = null then 
		// 
		// need to find first RT Queue Entry if it is not complete then can just	
		multiMoveMethod:=theMoveMethodRule.myRTQueueMultiRule;
		if not theMoveMethodRule.isDefaultRule then
			//moveMethodRule:=multiMoveMethod.getDefaultRTMoveMethodRule;	
			_allValidRTMoveMethodRules.add(multiMoveMethod.getDefaultRTMoveMethodRule);
		endif;
			
		foreach moveMethodRule in multiMoveMethod.allOtherRTMoveMethodRules do
			if moveMethodRule = theMoveMethodRule then
				continue;
			endif;
			_allValidRTMoveMethodRules.add(moveMethodRule);
		endforeach;
	else
		// should be safe to assume there is a tracked item associated with the WLE because it has started to be worked
		currrentLocation:=self.myTrackedItem.myPrimaryActualLocation;
		theTargetLocation:=self.allRTQueueEntries.last.allTasks.last.targetLocation;
		
		// this is where containers has been put in an interchange area or temporary holding location 
		// get the differnent machine rules available from that location to the target location
		if currrentLocation.isKindOf(CM_YardController) then
			terminal:=self.myTrackedItem.myTerminal;
			newMultiMoveMethod:=terminal.getRTQueueMultiRule(currrentLocation, theTargetLocation);
			//no rules setup 
			if newMultiMoveMethod = null then	
				return;
			endif;
			if newMultiMoveMethod.getDefaultRTMoveMethodRule &lt;&gt; theMoveMethodRule then
				_allValidRTMoveMethodRules.add(newMultiMoveMethod.getDefaultRTMoveMethodRule);
			endif;
			
			foreach moveMethodRule in newMultiMoveMethod.allOtherRTMoveMethodRules do
				if moveMethodRule = theMoveMethodRule then
					continue;
				endif;
				_allValidRTMoveMethodRules.add(moveMethodRule);
			endforeach;
		else
			//it is hopefully on either a vehicle controller or machine controller
			// need to get current wle task
			rtQueueTask:=self.getNextUnactionedRTQueueTask();
			if rtQueueTask = null then
				return;
			endif;
			
			create machineTypeGrpArray transient;
			//find out where we are up to in the machine type grps for the move method
			foreach rtQueueEntry in self.allRTQueueEntries do : outerLoop
				machineTypeGrp:=null;
				foreach rtQueueTask in rtQueueEntry.allTasks do
					if  rtQueueTask.status &lt;&gt; TASK_COMPLETE then
						
		
						machineTypeGrp:=app.myRoot.allMachineTypeGroups[rtQueueTask.machineTypeGroup];
						if not machineTypeGrpArray.includes(machineTypeGrp) then
							machineTypeGrpArray.add(machineTypeGrp);
						endif;
					else
						break outerLoop;
					endif;	
				endforeach;						
			endforeach;
			
			//now we do a comparision of the move method with those completed so far
			
			// need to find first RT Queue Entry if it is not complete then can just	
			multiMoveMethod:=theMoveMethodRule.myRTQueueMultiRule;
			if not theMoveMethodRule.isDefaultRule and
				not theMoveMethodRule.compareRTMoveMethodRule(machineTypeGrpArray) then
				//moveMethodRule:=multiMoveMethod.getDefaultRTMoveMethodRule;	
				_allValidRTMoveMethodRules.add(multiMoveMethod.getDefaultRTMoveMethodRule);
			endif;
			
			foreach moveMethodRule in multiMoveMethod.allOtherRTMoveMethodRules do
				if moveMethodRule = theMoveMethodRule then
					continue;
				endif;
				if not moveMethodRule.compareRTMoveMethodRule(machineTypeGrpArray) then
					continue;
				endif;
				_allValidRTMoveMethodRules.add(moveMethodRule);
			endforeach;
		endif;
	endif;
epilog
	delete machineTypeGrpArray;
end;</source>
        <Parameter name="_allValidRTMoveMethodRules" type="CM_RTMoveMethodRuleDict" usage="input"/>
    </JadeMethod>
