/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 December 2009	cnwer1	Initial creation

*/

vars
	sealPresent : String;
begin
	sealPresent:=app.myHandHeldShipLanderGuiAgent.getSealPresentString;
	self.txtSealCustAft.text:=sealPresent;
	self.txtSealOpAft.text:=sealPresent;
	self.txtSealShipAft.text:=sealPresent;
	btn.buttonPicture:=Button.ButtonPicture_Tick;
	self.btnAftSealNo.buttonPicture:=null;

epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
