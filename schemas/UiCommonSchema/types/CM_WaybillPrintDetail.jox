<Class name="CM_WaybillPrintDetail">
    <JadeMethod name="printReport" id="961ebfbb-c786-429b-b5bf-f14deb164a03">
        <source>printReport():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 August 2015	cnwndl1	Initial creation	Par 36777

*/

vars
	
	report : CM_GhanaWaybillReport;
	retValue : Boolean;
	preview : Boolean;

begin

	retValue := false;
	preview := app.printer.printPreview;

	app.printer.abort();
	
	app.printer.printPreview := preview;
	
	create report transient;
	report.myWaybillPrintDetail := self;
	report.printReport();
	
	app.printer.close();
	
	retValue := true;
	
	return retValue;

epilog

	delete report;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
