    <JadeMethod name="clearAllFilters" id="d5d8d887-f47f-4f58-9ee4-cde3ad3ed37a">
        <updating/>
        <source>clearAllFilters() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 19/07/2022	navdap1		Initial creation TFS 53889 EUP Collapsed view not kept when moving or updating cargo
