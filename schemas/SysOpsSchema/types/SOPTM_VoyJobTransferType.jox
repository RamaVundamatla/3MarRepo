    <JadeMethod name="setControlsForAddEdit" id="dcf0a3e6-35c6-4550-8dc0-d3dd51e6839b">
        <updating/>
        <source>setControlsForAddEdit() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 March 2018	jlgndl1	Initial creation	TFS 37444

*/

vars

	theForm : SOP_TableMaintForm;
	
begin

	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
	theForm.tblInput1.disableRowByName(ETRow_Id);
	theForm.tblInput1.disableRowByName(ETRow_IsSystem);
	theForm.tblInput1.hideRowByName( ETRow_Id, false );
	theForm.tblInput1.hideRowByName( ETRow_IsSystem, false );
	
	if theForm.mode = theForm.Mode_Add then
		theForm.tblInput1.clearValues;
		theForm.tblInput1.enableRowByName(ETRow_Description);
		
		theForm.tblInput1.setFocus;
		theForm.tblInput1.moveFirst();
		
	else
	
		
		// refresh the data from the newly created proxy
		self.showThumbnail(theForm.myProxyObject.CM_VoyageJobTransferType);
		theForm.tblInput1.enableRowByName(ETRow_Description);
		
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="fdc94c4c-e914-480b-81bd-9e6f9916b8d5">
        <updating/>
        <source>setCtrlsForView() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 March 2018	jlgndl1	Initial creation	TFS 37444

*/

vars


	theForm : SOP_TableMaintForm;

begin

	inheritMethod();    
	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := false;
	theForm.tblInput1.showRowByName( ETRow_Id, false );
	theForm.tblInput1.showRowByName( ETRow_IsSystem, false );
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="95b0012d-bd57-476d-a871-35e1379ae04e">
        <updating/>
        <source>setupThumbnailDetails() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 March 2018	jlgndl1	Initial creation	TFS 37444

*/

vars

	theForm : SOP_TableMaintForm;

begin

	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_VoyageJobTfrTypeMaint);

	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_VoyageJobTfrTypeMaint);
	theForm.shtTblInput1.visible := true;

epilog

end;</source>
    </JadeMethod>
