    <JadeMethod name="setEnableObjects" id="b91c361a-4618-4196-8eec-29596543fd39">
        <source>setEnableObjects(form: INV_TransactionMap io);

vars
	canMaint : Boolean;
begin
	canMaint := app.myCurrentUserCan(form.myTerminal, form.permissionMaint); // TFS 2198 CNWAB1



	inheritMethod(form);

	if self.type = CMIF_TMCType.TYPE_TRACKEDITEM then
		form.modePropertyNew := INV_TransactionMap.ModeProperty_TransMap;
		form.modePropertyUpdate := INV_TransactionMap.ModeProperty_Null;
		form.modePropertyDelete := INV_TransactionMap.ModeProperty_Null;
		form.menuSItemNew.enabled := true;
		form.menuSItemNew.visible := canMaint;
		form.menuMappingNewTMap.enabled := true;
		form.menuMappingNewTMap.visible := canMaint;
		form.btnNew.enabled := canMaint;
		form.menuTMVnew.visible := false;
	elseif self.type = CMIF_TMCType.TYPE_VOYAGE then
		form.modePropertyNew := INV_TransactionMap.ModeProperty_TransMap;
		form.modePropertyUpdate := INV_TransactionMap.ModeProperty_Null;
		form.modePropertyDelete := INV_TransactionMap.ModeProperty_Null;
		form.menuTMVnew.enabled := true;
		form.menuTMVnew.visible := canMaint;
		form.menuTMVmap.enabled := true;
		form.menuTMVmap.visible := canMaint;
		form.btnNew.enabled := canMaint;
	elseif self.type = CMIF_TMCType.TYPE_EVENT then
		form.modePropertyNew := INV_TransactionMap.ModeProperty_TransMap;
		form.modePropertyUpdate := INV_TransactionMap.ModeProperty_Null;
		form.modePropertyDelete := INV_TransactionMap.ModeProperty_Null;
		form.menuTMEnew.enabled := true;
		form.menuTMEnew.visible := canMaint;
		form.menuTMEmap.enabled := true;
		form.menuTMEmap.visible := canMaint;
		form.btnNew.enabled := canMaint;
	elseif self.type = CMIF_TMCType.TYPE_SSSUMMARY then
		form.modePropertyNew := INV_TransactionMap.ModeProperty_TransMap;
		form.modePropertyUpdate := INV_TransactionMap.ModeProperty_Null;
		form.modePropertyDelete := INV_TransactionMap.ModeProperty_Null;
		form.menuTMSnew.enabled := true;
		form.menuTMSnew.visible := canMaint;
		form.menuTMSmap.enabled := true;
		form.menuTMSmap.visible := canMaint;
		form.btnNew.enabled := canMaint;
	elseif self.type = CMIF_TMCType.TYPE_CARGOALLOC then
		form.modePropertyNew := INV_TransactionMap.ModeProperty_TransMap;
		form.modePropertyUpdate := INV_TransactionMap.ModeProperty_Null;
		form.modePropertyDelete := INV_TransactionMap.ModeProperty_Null;

		form.menuTMAnew.enabled := true;
		form.menuTMAnew.visible := canMaint;
		form.menuTMAmap.enabled := true;
		form.menuTMAmap.visible := canMaint;
		form.btnNew.enabled := canMaint;
	
	elseif self.type = CMIF_TMCType.TYPE_WO then
		form.modePropertyNew := INV_TransactionMap.ModeProperty_TransMap;
		form.modePropertyUpdate := INV_TransactionMap.ModeProperty_Null;
		form.modePropertyDelete := INV_TransactionMap.ModeProperty_Null;
		form.menuTMWOnew.enabled := true;
		form.menuTMWOnew.visible := canMaint;
		form.menuTMWOmap.enabled := true;
		form.menuTMWOmap.visible := canMaint;
		form.btnNew.enabled := canMaint;
		
	//01 Nov 2019	NDL	TFS 47100
	elseif self.type = CMIF_TMCType.TYPE_BOL then
		form.modePropertyNew := INV_TransactionMap.ModeProperty_TransMap;
		form.modePropertyUpdate := INV_TransactionMap.ModeProperty_Null;
		form.modePropertyDelete := INV_TransactionMap.ModeProperty_Null;
		form.menuTMBOLnew.enabled := true;
		form.menuTMBOLnew.visible := canMaint;
		form.menuTMBOLmap.enabled := true;
		form.menuTMBOLmap.visible := canMaint;
		form.btnNew.enabled := canMaint;
		
	// TFS 51219 25MAY2021 NAVAB1
	elseif self.type = CMIF_TMCType.TYPE_INVENTORY then
		form.modePropertyNew := INV_TransactionMap.ModeProperty_TransMap;
		form.modePropertyUpdate := INV_TransactionMap.ModeProperty_Null;
		form.modePropertyDelete := INV_TransactionMap.ModeProperty_Null;
		form.menuTMBOLnew.enabled := true;
		form.menuTMBOLnew.visible := canMaint;
		form.menuTMBOLmap.enabled := true;
		form.menuTMBOLmap.visible := canMaint;
		form.btnNew.enabled := canMaint;
		
	endif;
end;</source>
        <Parameter name="form" type="INV_TransactionMap" usage="io"/>
    </JadeMethod>
</Class>
