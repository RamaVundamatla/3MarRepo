<PrimType name="String">
    <JadeMethod name="truncatedAt" id="fbca5a66-6467-4aa5-b538-d91d07870859">
        <source>truncatedAt(maxLen : Integer) : String;

vars
	s : String;
	
begin
	s := self.trimBlanks;
	if maxLen &lt; 1 or s.length &lt;= maxLen then
		return s;
	endif;
	return s[1 : maxLen];
end;</source>
        <Parameter name="maxLen" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="withHTMLEntitiesReplaced" id="d3b997b6-4561-4f51-93c2-28c868413821">
        <source>withHTMLEntitiesReplaced() : String;

constants
	Lt = '&lt;';
	Gt = '&gt;';
	Amp = '&amp;';
	Quot = '"';
	EntityChars = Lt &amp; Gt &amp; Amp &amp; Quot;
		
vars
	n, selfLen : Integer;
	char : Character;
	s : String;
	
begin
	if self = null then
		return null;
	endif;

	selfLen := self.length;
	s := null;
	n := 1;
	
	while true do
		if n &gt; selfLen then
			return s;
		endif;
		
		s := s &amp; self.scanUntil(EntityChars, n);
		
		if n &lt; 1 or n &gt; selfLen then
			return s;
		endif;
		
		char := self[n];
		
		if char = Lt then
			s := s &amp; "&amp;lt;";
		elseif char = Amp then
			s := s &amp; "&amp;amp;";
		elseif char = Gt then
			s := s &amp; "&amp;gt;";
		elseif char = Quot then
			s := s &amp; "&amp;quot;";
		else
			s := s &amp; char;
		endif;
		
		n := n + 1;
	endwhile;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="withLineBreaks" id="ef9f3308-42c7-4f53-b227-aa7f8ede8ab6">
        <source>withLineBreaks(numBreaks : Integer; asHTML : Boolean) : String;

vars
	n : Integer;
	s : String;
	
begin
	s := self;

	if numBreaks &gt; 0 then	
		foreach n in 1 to numBreaks do
			if asHTML then
				s := s &amp; "&lt;br /&gt;";
			else
				s := s &amp; CrLf;
			endif;
		endforeach;
	endif;
	
	return s;
end;</source>
        <Parameter name="numBreaks" type="Integer"/>
        <Parameter name="asHTML" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="withUnderline" id="42f834fb-b721-4d52-89ad-d5ccb25a81c6">
        <source>withUnderline(yes : Boolean) : String;

vars
	s : String;
	
begin
	if yes then
		s[self.length] := '-';
		s.fillString('-');
		return self &amp; CrLf &amp; s;
	endif;
	return self;
end;</source>
        <Parameter name="yes" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
</PrimType>
