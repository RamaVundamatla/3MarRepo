    <JadeMethod name="displayMachineTelegrams" id="cf1364f3-9932-49c5-bfff-aedc7278b5fb">
        <updating/>
        <source>displayMachineTelegrams()updating, protected;
//--------------------------------------------------
// Created:	18 July 2005 By: cnwgd1
//--------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------
// 31/03/2016	cnwdap1		PAR #35843 Make monitor time basd rather than object count based
vars

	passport		: CM_Passport;
	cmifMonitor		: CMIF_Monitor;
	rtgTelegram		: CM_RTGTelegram;
	cnt, partsInJob,
	partsDone		: Integer;
	lastUpdated		: Decimal [20];							// PAR #35843
begin

	if self.myMachine = null then
		return;
	endif;
	app.mousePointer := self.MousePointer_HourGlass;				
	passport := app.myPassport;
	self.tblTelegrams.rows := self.tblTelegrams.fixedRows;
	self.tblTelegrams.clearAllSelected();

	cmifMonitor := passport.myCMIFMonitor;
	if cmifMonitor &lt;&gt; null then
		delete cmifMonitor;
	endif;
	create cmifMonitor transient;
	cmifMonitor.myParent := self;
	passport.setMyCMIFMonitor(cmifMonitor);

	self.modalDialogReturnValue := self.ModalDialogReturn_Null;	
	self.modalDialogShow(null, 'Cancel' , null, null, 'Loading Telegrams',  'Please Wait....');
	self.pbProgressBar.visible := true;
	
	partsInJob := self.myMachine.allRTGTelegrams.size;
	
	
	foreach rtgTelegram in self.myMachine.allRTGTelegrams discreteLock, reversed  do
		cnt := cnt + 1;
		partsDone := partsDone + 1;
		self.tblDataDisplayRTGTelegram(rtgTelegram);
		//if cnt = 100 then																			// PAR #35843
		if (app.relativeMachineTime - lastUpdated) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then	// PAR #35843
			if (not cmifMonitor.updateProgress(cmifMonitor.message, partsInJob, partsDone)) then
				break;
			endif;
			cnt := 0;
			lastUpdated := app.relativeMachineTime;													// PAR #35843
		endif;
	endforeach;
	
	
epilog
	app.mousePointer := self.MousePointer_Default;									
	delete cmifMonitor;
	app.myPassport.setMyCMIFMonitor(null);
	self.tblTelegrams.colourRows(self.colorRow1, self.colorRow2);
	if self.tblTelegrams.rows &gt; self.tblTelegrams.fixedRows then
		self.tblTelegrams.selectRow(self.tblTelegrams.fixedRows + 1, false);		
	endif;
	
	
	self.frmModalDialog.visible := false;	
	return;
end;</source>
        <access>protected</access>
    </JadeMethod>
