    <JadeMethod name="addToJobTotals" id="57fe4470-db47-465a-95b5-b099d2c7f042">
        <source>addToJobTotals(_theTotals: CMIF_JobTITotals input);
// ---------------------------------------------------------------------------
// Created:		July 2003 By Andrew Bishop cnwab1
//
// Purpose:		If the WLE has no TIs then look at the colour coding
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 28/12/2017	jlgdap1		TFS 36399 Totals incorrect when job created but no cargo planned to slot
vars
	numTI, workListEntrySize			: Integer;
	isEmpty : Boolean; 	//cnwas3 PAR 24273
	isContainer : Boolean;
	is20,
	is30 : Boolean;		//cnwas3 PAR 24273
	is40 : Boolean;		//cnwas3 PAR 24273
	is45 : Boolean;		//cnwas3 PAR 24273 
	is53 : Boolean;		//cnwas3 PAR 24273
	ti	 : CM_TrackedItem;
	is30Included, is45Included, is53Included : Boolean;
	ct : CM_CargoType;
	comm : CM_Commodity;					// TFS 36399
	commgrp : CM_CommodityGroup;			// TFS 36399
	isoType : CM_ISOType;					// TFS 36399
	isoGroup : CM_ISOTypeGroup;				// TFS 36399
begin
	if self.allWorkListEntries.isEmpty then
		return;
	endif;

	is30Included	:= self.myTerminal.getConfig (Is30IncludedForReports).Integer = ISOTypeOtherIncludedAsOwn;	//CNWAB1 PAR 30342
	is45Included	:= self.myTerminal.getConfig (Is45IncludedForReports).Integer = ISOTypeOtherIncludedAsOwn;	//CNWAB1 PAR 30342
	is53Included	:= self.myTerminal.getConfig (Is53IncludedForReports).Integer= ISOTypeOtherIncludedAsOwn;	//CNWAB1 PAR 30342

	_theTotals.myJob := self.myJob.CM_VoyageJob;
	
	ct := self.getAttrCargoType(); // PAR 31756 - need to seperate out GC
	isContainer := ct &lt;&gt; null and ct.id = TI_CargoType_Container; // PAR 31756
	if isContainer then // PAR 31756
		isEmpty := self.getAttrEmpty();	//cnwas3 PAR 24273
		is30 := self.getAttrIs30(); 	//cnwas3 PAR 24273
		is40 := self.getAttrIs40();		//cnwas3 PAR 24273
		is45 := self.getAttrIs45();		//cnwas3 PAR 24273
		is53 := self.getAttrIs53();		//cnwas3 PAR 24273
		is20:=not is30 and not is40 and not is45 and not is53;
	endif;
	
	// load colour coding didn't specify a length then need to get length from the ti
	if not is20 and not is40 and not is30 and not is45 and not is53 then
		ti:=self.allWorkListEntries.first.myTrackedItem;
		if ti &lt;&gt; null then
			isEmpty := ti.isEmpty;	//11 Sep 2017	NDL	TFS 6859
			is20:=ti.is20;
			is30:=ti.is30;
			is40:=ti.isForty;
			is45:=ti.is45;
			is53:=ti.is53;
			isContainer := ti.isContainer;			// TFS 36399
		endif;
	endif;
	
	// TFS 36399 No TIs yet, and colour coding didn't specify a Cargo Type 
	// - see if we can find a MT Commodity in the colour coding
	// - or an iso type or an iso group so at least we can base some of our counts on something
	if ct = null and ti = null then 
		commgrp := self.getAttrCommodityGroup;
		if commgrp &lt;&gt; null then
			foreach comm in commgrp.allCommodities discreteLock do
				if comm.isEmpty and self.myTerminal.getConfig(EmptyCommodity).String = comm.code then
					isEmpty := true;
					isContainer := true;
					is30 := self.getAttrIs30();
					is40 := self.getAttrIs40();
					is45 := self.getAttrIs45();
					is53 := self.getAttrIs53();
					is20 := not is30 and not is40 and not is45 and not is53;
					break;
				endif;
			endforeach;
		endif;
		if not isEmpty and not isContainer and not is20 and not is30 and not is40 and not is45 and not is53 then
			isoType := self.getAttrISOType();
			if isoType &lt;&gt; null then
				isContainer := true;
				is20 := isoType.is20ftLong;
				is30 := isoType.is30ftLong;
				is40 := isoType.is40ftLong;
				is45 := isoType.is45ftLong;
				is53 := isoType.is53ftLong;
			else
				isoGroup := self.getAttrIsoGroup;
				if isoGroup &lt;&gt; null then
					isContainer := true;
				endif;
			endif;
		endif;
	endif;
	// TFS 36399 end
	
	// PAR 30342 if not individual show as 40s
	if is30 and not is30Included then
		is30 := false;
		is40 := true;
	elseif is45 and not is45Included then
		is45 := false;
		is40 := true;
	elseif is53 and not is53Included then
		is53 := false;
		is40 := true;
	endif;
	
	
	workListEntrySize := self.allWorkListEntries.size;
	if self.moveType = LOAD_MOVETYPE or self.moveType = DISCHARGE_MOVETYPE then
		if not isContainer then
			_theTotals.numFull := _theTotals.numFull + workListEntrySize;
			self.addJobTotalsPerCargoType( _theTotals.allBBLKTotals);

		else
			if self.getAttrOverDimensioned() then // PAR 7685
				_theTotals.numOD := _theTotals.numOD + workListEntrySize; // PAR 7685
			endif;
			if is20 then
				_theTotals.numTwentyFoot := _theTotals.numTwentyFoot + workListEntrySize;
				if self.getAttrPowerRequired() and self.moveType = LOAD_MOVETYPE then
					_theTotals.numPoweredRequested := _theTotals.numPoweredRequested + workListEntrySize;
				endif;
				if isEmpty then    //cnwas3 par 24273
					_theTotals.numEmpty := _theTotals.numEmpty + workListEntrySize;
					_theTotals.numEmpty20 := _theTotals.numEmpty20 + workListEntrySize;
				else
					_theTotals.numFull := _theTotals.numFull + workListEntrySize;
					_theTotals.numFull20 := _theTotals.numFull20 + workListEntrySize;
				endif;
			elseif is30 then //cnwgb1 29 May 2008 PAR16415...  //cnwas3 par 24273
				_theTotals.numThirtyFoot := _theTotals.numThirtyFoot + workListEntrySize;
				if isEmpty then    //cnwas3 par 24273
					_theTotals.numEmpty := _theTotals.numEmpty + workListEntrySize;
					_theTotals.numEmpty30 := _theTotals.numEmpty30 + workListEntrySize;
				else
					_theTotals.numFull := _theTotals.numFull + workListEntrySize;
					_theTotals.numFull30 := _theTotals.numFull30 + workListEntrySize;
				endif;					//...cnwgb1 29 May 2008 PAR16415
			elseif is40 then //cnwas3 par 24273
				_theTotals.numFortyFoot := _theTotals.numFortyFoot + workListEntrySize;
				if isEmpty then    //cnwas3 par 24273
					_theTotals.numEmpty := _theTotals.numEmpty + workListEntrySize;
					_theTotals.numEmpty40 := _theTotals.numEmpty40 + workListEntrySize;
				else
					_theTotals.numFull := _theTotals.numFull + workListEntrySize;
					_theTotals.numFull40 := _theTotals.numFull40 + workListEntrySize;
				endif;
			elseif is45 then  //cnwgb1 29 May 2008 PAR16415...     //cnwas3 par 24273
				_theTotals.numFortyFive := _theTotals.numFortyFive + workListEntrySize;
				if isEmpty then    //cnwas3 par 24273
					_theTotals.numEmpty := _theTotals.numEmpty + workListEntrySize;
					_theTotals.numEmpty45 := _theTotals.numEmpty45 + workListEntrySize;
				else
					_theTotals.numFull := _theTotals.numFull + workListEntrySize;
					_theTotals.numFull45 := _theTotals.numFull45 + workListEntrySize;
				endif;
			elseif is53 then		//cnwas3 PAR 24273
				_theTotals.numFiftyThree := _theTotals.numFiftyThree + workListEntrySize;
				if isEmpty then    //cnwas3 par 24273
					_theTotals.numEmpty := _theTotals.numEmpty + workListEntrySize;
					_theTotals.numEmpty53 := _theTotals.numEmpty53 + workListEntrySize;
				else
					_theTotals.numFull := _theTotals.numFull + workListEntrySize;
					_theTotals.numFull53 := _theTotals.numFull53 + workListEntrySize;
				endif;
			endif;					//...cnwgb1 29 May 2008 PAR16415
		endif;
	elseif self.isRehandle then
		if not isContainer then
			_theTotals.numFullRH := _theTotals.numFullRH + workListEntrySize;
			self.addJobTotalsPerCargoType( _theTotals.allBBLKTotalsRH);

		else
			if self.getAttrOverDimensioned() then // PAR 7685
				_theTotals.numODRH := _theTotals.numODRH + workListEntrySize; // PAR 7685
			endif;
			
			if is20  then
				_theTotals.numTwentyFoot := _theTotals.numTwentyFoot + workListEntrySize;
				if isEmpty then    //cnwas3 par 24273
					_theTotals.numEmptyRH := _theTotals.numEmptyRH + workListEntrySize;
					_theTotals.numEmpty20RH := _theTotals.numEmpty20RH + workListEntrySize;
				else
					_theTotals.numFullRH := _theTotals.numFullRH + workListEntrySize;
					_theTotals.numFull20RH := _theTotals.numFull20RH + workListEntrySize;
				endif;
			elseif is30 then //cnwgb1 29 May 2008 PAR16415...  //cnwas3 par 24273
				_theTotals.numThirtyFoot := _theTotals.numThirtyFoot + workListEntrySize;
				if isEmpty then    //cnwas3 par 24273
					_theTotals.numEmptyRH := _theTotals.numEmptyRH + workListEntrySize;
					_theTotals.numEmpty30RH := _theTotals.numEmpty30RH + workListEntrySize;
				else
					_theTotals.numFullRH := _theTotals.numFullRH + workListEntrySize;
					_theTotals.numFull30RH := _theTotals.numFull30RH + workListEntrySize;
				endif;					//...cnwgb1 29 May 2008 PAR16415
			elseif is40 then //cnwas3 par 24273
				_theTotals.numFortyFoot := _theTotals.numFortyFoot + workListEntrySize;
				if isEmpty then    //cnwas3 par 24273
					_theTotals.numEmptyRH := _theTotals.numEmptyRH + workListEntrySize;
					_theTotals.numEmpty40RH := _theTotals.numEmpty40RH + workListEntrySize;
				else
					_theTotals.numFullRH := _theTotals.numFullRH + workListEntrySize;
					_theTotals.numFull40RH := _theTotals.numFull40RH + workListEntrySize;
				endif;
			elseif is45 then //cnwgb1 29 May 2008 PAR16415...	//cnwas3 PAR 24273
				_theTotals.numFortyFive := _theTotals.numFortyFive + workListEntrySize;
				if isEmpty then    //cnwas3 par 24273
					_theTotals.numEmptyRH := _theTotals.numEmptyRH + workListEntrySize;
					_theTotals.numEmpty45RH := _theTotals.numEmpty45RH + workListEntrySize;
				else
					_theTotals.numFullRH := _theTotals.numFullRH + workListEntrySize;
					_theTotals.numFull45RH := _theTotals.numFull45RH + workListEntrySize;
				endif;
			elseif is53 then		//cnwas3 PAR 24273
				_theTotals.numFiftyThree := _theTotals.numFiftyThree + workListEntrySize;
				if isEmpty then    //cnwas3 par 24273
					_theTotals.numEmptyRH := _theTotals.numEmptyRH + workListEntrySize;
					_theTotals.numEmpty53RH := _theTotals.numEmpty53RH + workListEntrySize;
				else
					_theTotals.numFullRH := _theTotals.numFullRH + workListEntrySize;
					_theTotals.numFull53RH := _theTotals.numFull53RH + workListEntrySize;
				endif;
			endif;						//...cnwgb1 29 May 2008 PAR16415
		endif;
	elseif self.isSOB and not self.isLoad then // do not include the load part of the SOB, as it doubles up the figures
		if not isContainer then // PAR 31756
			_theTotals.numFullSOB := _theTotals.numFullSOB + workListEntrySize;
			self.addJobTotalsPerCargoType( _theTotals.allBBLKTotalsSOB);

		else
			if self.getAttrOverDimensioned() then // PAR 7685
				_theTotals.numODSOB := _theTotals.numODSOB + workListEntrySize; // PAR 7685
			endif;
			
			if is20 then
				_theTotals.numTwentyFoot := _theTotals.numTwentyFoot + workListEntrySize;
				if isEmpty then    //cnwas3 par 24273
					_theTotals.numEmptySOB := _theTotals.numEmptySOB + workListEntrySize;
					_theTotals.numEmpty20SOB := _theTotals.numEmpty20SOB + workListEntrySize;
				else
					_theTotals.numFullSOB := _theTotals.numFullSOB + workListEntrySize;
					_theTotals.numFull20SOB := _theTotals.numFull20SOB + workListEntrySize;
				endif;
			elseif is30 then //cnwgb1 29 May 2008 PAR16415...  //cnwas3 par 24273
				_theTotals.numThirtyFoot := _theTotals.numThirtyFoot + workListEntrySize;
				if isEmpty then    //cnwas3 par 24273
					_theTotals.numEmptySOB := _theTotals.numEmptySOB + workListEntrySize;
					_theTotals.numEmpty30SOB := _theTotals.numEmpty30SOB + workListEntrySize;
				else
					_theTotals.numFullSOB := _theTotals.numFullSOB + workListEntrySize;
					_theTotals.numFull30SOB := _theTotals.numFull30SOB + workListEntrySize;
				endif;					//...cnwgb1 29 May 2008 PAR16415
			elseif is40 then //cnwas3 par 24273
				_theTotals.numFortyFoot := _theTotals.numFortyFoot + workListEntrySize;
				if isEmpty then    //cnwas3 par 24273
					_theTotals.numEmptySOB := _theTotals.numEmptySOB + workListEntrySize;
					_theTotals.numEmpty40SOB := _theTotals.numEmpty40SOB + workListEntrySize;
				else
					_theTotals.numFullSOB := _theTotals.numFullSOB + workListEntrySize;
					_theTotals.numFull40SOB := _theTotals.numFull40SOB + workListEntrySize;
				endif;
			elseif is45 then //cnwgb1 29 May 2008 PAR16415...		//cnwas3 PAR 24273
				_theTotals.numFortyFive := _theTotals.numFortyFive + workListEntrySize;
				if isEmpty then    //cnwas3 par 24273
					_theTotals.numEmptySOB := _theTotals.numEmptySOB + workListEntrySize;
					_theTotals.numEmpty45SOB := _theTotals.numEmpty45SOB + workListEntrySize;
				else
					_theTotals.numFullSOB := _theTotals.numFullSOB + workListEntrySize;
					_theTotals.numFull45SOB := _theTotals.numFull45SOB + workListEntrySize;
				endif;
			elseif is53 then		//cnwas3 PAR 24273
				_theTotals.numFiftyThree := _theTotals.numFiftyThree + workListEntrySize;
				if isEmpty then    //cnwas3 par 24273
					_theTotals.numEmptySOB := _theTotals.numEmptySOB + workListEntrySize;
					_theTotals.numEmpty53SOB := _theTotals.numEmpty53SOB + workListEntrySize;
				else
					_theTotals.numFullSOB := _theTotals.numFullSOB + workListEntrySize;
					_theTotals.numFull53SOB := _theTotals.numFull53SOB + workListEntrySize;
				endif;
			endif;						//...cnwgb1 29 May 2008 PAR16415
		endif;
	endif;
end;</source>
        <Parameter name="_theTotals" type="CMIF_JobTITotals" usage="input"/>
    </JadeMethod>
    <JadeMethod name="addWLE" id="5c602d3b-5916-44fd-b6b0-c8394fc81abb">
        <updating/>
        <source>addWLE(_wle : CM_VoyageWLE io; _ti : CM_TrackedItem) updating;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	jobType: Integer;
	associatedRequest: CM_SlotRequest;
	tmpLC: CM_LocationsController;
begin
	if _ti = null then
		app.raiseCMException1(ERR_NO_WLE_TI, self.myJob.jobId, null, null);
		return;
	endif;

	exclusiveLock(self);
	
	
	if _wle = null then
		//-------------------------------------------------------------
		// Create WLEs for any requests that do not already have one
		// ie the first time this request has been loaded
		//-------------------------------------------------------------
		// We do not have one yet so lets create one
		create _wle persistent;
	endif;

	//MUST SET KEY for memberKeyDict add. DWQ 20/8/96
	_wle.setMyTrackedItem(_ti);

	if self.myJob &lt;&gt; null then
		exclusiveLock(self.myJob);
	endif;

	_wle.setForCreate(self.myJob, self);


	if self.myJob &lt;&gt; null then
		jobType := self.myJob.jobType;
	
		if jobType = JOB_TYPE_SOB then //SOB have two requests but still only one wle per ti
			tmpLC := _ti.getPrimaryLocation(PLANNING_MODE);
			if tmpLC &lt;&gt; null and 
			   tmpLC.isKindOf(CM_SlotController) then
				associatedRequest := tmpLC.CM_SlotController.mySlotRequestLoad;
				// Add  wle:request links
				_wle.setAssociatedRequest(associatedRequest);
			endif;
		endif;
	endif;
end;</source>
        <Parameter name="_wle" type="CM_VoyageWLE" usage="io"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="cellId" id="a005c839-ef19-4092-a803-cdee80ae8c9d">
        <methodInvocation>mapping</methodInvocation>
        <source>cellId(_set: Boolean; _value: String io) mapping;
// ---------------------------------------------------------------------------
// Created:     03 April 2002 by cnwdwq1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

begin
	if _set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	if self.mySlotController &lt;&gt; null then
		_value := self.mySlotController.cellId;
	else
		_value := null;
	endif;
end;</source>
        <Parameter name="_set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="checkJob" id="541e631b-cf1a-4f71-9ee4-7235e58caa8c">
        <source>checkJob() protected;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

begin
	if self.myJob = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException(VB_SLOT_NOJOB, null, null);
		return;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="checkUnavailable" id="494dc14c-f854-4aaf-8d49-0561fad748c6">
