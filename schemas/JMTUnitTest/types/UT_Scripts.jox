		self.deleteVoyageChildren(voyage);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="uDeleteWagonNDL" id="966e00ea-cf7e-4fce-9fbf-1dcf3baf0ca7">
        <source>uDeleteWagonNDL();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 May 2013	cnwndl1	Initial creation

*/

vars

	wagons : CM_WagonSet;
	iter : Iterator;
	wagon : CM_Wagon;
	invalidWagon : Boolean;
	invalidTi : Boolean;
	invalidBulk : Boolean;
	edition : Integer;
	trx : CM_EventTransaction;
	audit : CM_AuditObject;
	ti : CM_TrackedItem;
	bulk : CM_BulkRelease;
	msg : String;
	now : TimeStamp;
	yaType : CM_YATypeTrain;
	term : CM_Terminal;
	train : CM_Train;
	
begin

	term := app.myRoot.allTerminals.getAtKey("T01");
	train := term.getNullTrain;
	
	app.myPassport.setMyTerminal(term);

	if train = null then
		return;
	endif;
	
	on Exception do app.handleDeletedObject( exception, wagon, invalidWagon );
	create wagons transient;

	iter := train.allWagonsByIdInward.createIterator;
	while iter.next( wagon ) do
		invalidWagon := false;
		edition := wagon.edition;
		if not invalidWagon then
			wagons.addNoDuplicates(wagon,false);
		endif;
	endwhile;
	
/*	delete iter;
	iter := train.allWagonsByIdOutward.createIterator;
	while iter.next( wagon ) do
		invalidWagon := false;
		edition := wagon.edition;
		if not invalidWagon then
			wagons.addNoDuplicates(wagon,false);
		endif;
	endwhile;
*/	
	delete iter;
	iter := wagons.createIterator;
	while iter.next( wagon ) do
		if wagon.myTerminalDeparted = null then
			continue;
		endif;
		write wagon.id;
		self.deleteWagonAndAssociatedObjs(wagon);
	endwhile;
	
	

epilog

	delete wagons;
	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="uDeleteWorkOrders" id="0bd45036-5096-4f1a-8423-f315ce26b220">
        <source>uDeleteWorkOrders();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 May 2019	jlgndl1	Initial creation

*/

vars

	terminal : CM_Terminal;
	woFirstStr : String;
	woFirst : CM_WorkOrder;
	woLastStr : String;
	woLast : CM_WorkOrder;
	wo : CM_WorkOrder;
	objs : ObjectSet;
	iter : Iterator;
	found : Boolean;

begin

	terminal := self.getTerminal;

	woFirstStr := "&lt;start work order id&gt;";
	read woFirstStr;
	woFirst := terminal.allWorkOrders.getAtKey( woFirstStr );
	if woFirst = null then
		app.msgBox("Work Order not found","Error",MsgBox_OK_Only);
		return;
	endif;
	
	woLastStr := "&lt;start work order id&gt;";
	read woLastStr;
	woLast := terminal.allWorkOrders.getAtKey( woLastStr );
	if woLast = null then
		app.msgBox("Work Order not found","Error",MsgBox_OK_Only);
		return;
	endif;
	
	if app.msgBox("Delete all work orders from '" &amp; woFirstStr &amp; "' to '" &amp; woLastStr &amp; "'.","Continue?",MsgBox_Yes_No) = MsgBox_Return_Yes then
		create objs transient;
		iter := terminal.allWorkOrders.createIterator;
		iter.startAtObject( woFirst );
		while iter.next( wo ) do
			objs.add( wo );
			if wo = woLast then
				found := true;
				break;
			endif;
		endwhile;
		if not found then
			// must be in the wrong order. i.e first is after last
			objs.clear();
			delete iter;
			found := false;
			iter := terminal.allWorkOrders.createIterator;
			iter.startAtObject( woLast );
			while iter.next( wo ) do
				objs.add( wo );
				if wo = woFirst then
					found := true;
					break;
				endif;
			endwhile;
		endif;
		if found then
			beginTransaction;
			objs.purge();
			commitTransaction;
		endif;
	endif;

epilog

	delete iter;
	delete objs;

end;</source>
    </JadeMethod>
