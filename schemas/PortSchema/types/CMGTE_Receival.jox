    <JadeMethod name="getTableDisplayString" id="54bb6daf-75a7-4083-9536-d0dafa44ddba">
        <source>getTableDisplayString(): String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22/09/2009	cnwjk3	Initial creation
01/04/2014	cnwdap1	PAR #33606 CCMS SFW 1366 Bulk
*/
vars
	cargoType 	: CM_CargoType;
	type,
	detail,
	booking,
	display		: String;
	measureType : String;
	xtraCrit : String;	//10 Jan 2019	NDL	TFS 40479
begin
	type := self.jobTypeString;
	
	detail := self.id;	
	
	cargoType := app.myRoot.allCargoTypesById[self.cargoType];
	if self.totalQuantity &gt; 1 then
		detail := detail &amp; '(' &amp; self.totalQuantity.asStringJMT &amp; ')';
	endif;
	// PAR #33606 for bulk cargo, show total weight/volume
	if cargoType &lt;&gt; null and cargoType.isBulkProduct then
		detail := detail &amp; '(' &amp; cargoType.getBulkTrackByDisplayForWeight(self.weightTotal,self.getDensity,true) &amp; ')';
	endif;
	// PAR #33606 end
			
	if self.operatorCode &lt;&gt; null then 
		detail := detail &amp; "; " &amp; self.operatorCode;			
	endif;
	
	if cargoType &lt;&gt; null and cargoType.id &lt;&gt; TI_CargoType_Container then
		 detail := detail &amp; "; " &amp; cargoType.description;
		if self.myProduct &lt;&gt; null then
			detail := detail &amp; "; " &amp; self.myProduct.description;
		endif;
	elseif self.isKindOf(CMGTE_Container) then //epr TFS 2888 1/11/16
		detail := detail &amp; "; " &amp; self.CMGTE_Container.isoType;
	endif;
		
	booking := self.getBookingNum();

	display := type &amp; Tab &amp; detail &amp; Tab &amp; booking;
	//10 Jan 2019	NDL	TFS 40479
	if xtraCrit &lt;&gt; null then
		display := display &amp; Tab &amp; xtraCrit;
	endif;
	
	return display;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTotalVolumeDisplay" id="67feca47-c072-4e5b-9e4c-bc581a42ce91">
        <source>getTotalVolumeDisplay(): String;
/*

Date		Who		Reason
25 September 2014	cnwer1	Initial creation PAR 34935

*/

vars
	ct : CM_CargoType;
	measure			: CM_MeasurementType;	
begin
	ct := self.getMyCargoType;
	if ct = null or not ct.isBulkByVolume then
	
		if ct &lt;&gt; null then
			measure:=ct.myVolumeMeasurementType;
		endif;
		if measure = null then
			measure:=app.myRoot.allDefaultMeasurementTypes[Type_Volume];
		endif;
	
		return app.convertMeasurementForDisplay(measure.shortName, self.volumeTotal) &amp; Space &amp; measure.shortName;
	endif;
	
    return ct.getBulkTrackByDisplayForWeight(self.weightTotal,self.getDensity,true);

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
