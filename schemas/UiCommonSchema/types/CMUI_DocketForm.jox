    <JadeMethod name="showThumbnailData" id="9c92f491-678e-498a-a11f-69a676d60404">
        <updating/>
        <source>showThumbnailData(obj: Object) updating;
//--------------------------------------------------------------
//Created: 22 January 2002 By: cnwgd1
//--------------------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	headings,
	data		: HugeStringArray;
	docket		: CM_BOL;
	dataSize,
	i			: Integer;
	str			: String;
	defName		: String;
	viewName	: String;
	entTableDef	: EntTableDef;
	entTableView : EntTableView;
	
begin
	if self.btnShowBOLItems.value then							//+cnwml2 SFW CCMS 1071
		docket := obj.CM_BOLDtl.myBOL;
	else
		docket := obj.CM_BOL;
	endif;
	
	self.setNavigatorHeading(docket.bolTypeDesc &amp; ' (' &amp; docket.number &amp; ')');

	create headings transient;
	create data transient;
		
	docket.showThumbnailData(headings, data, self.myTerminal);
	tblThumb.rows := 0;
	dataSize := data.size;
	
	foreach str in headings do
		i := i + 1;
		if i &gt; dataSize then
			break;
		endif;
		tblThumb.addItem(str &amp; Tab &amp; data[i]);
	endforeach;

	self.btnSelectAllTV.enabled := true;
//	Sep 2011	cnwjre1		CCMS 1120 Par 28082 Log voyage operations changes, don't allow Log Docket edit of completed voyages
	if self.myBOLType.id = BOLType_Log then
		self.btnEditTV.enabled := not docket.hasLoadedLogs();
	endif;
	
	
	// TFS 2198 CNWAB1
	self.zHideForViewOnly();

epilog
	delete headings;
	delete data;
end;</source>
        <Parameter name="obj" type="Object"/>
    </JadeMethod>
