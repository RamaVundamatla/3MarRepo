    <JadeMethod name="getVoidInvoiceLineType" id="3979f600-cd80-4c95-a51e-f7cdfd75d2b6">
        <source>getVoidInvoiceLineType() : CM_InvoiceLineDesc;
/*
Purpose:			
Date		Who		Reason
29 May 2013	cnwab1	Initial creation
*/

vars
	invLine : CM_InvoiceLineDesc;
begin
	if self.voidInvoiceLineDesc &lt;&gt; null then
		return self.voidInvoiceLineDesc;
	endif;
	
	foreach invLine in self.invoiceLineDescriptors discreteLock do
		if invLine.isVoid then
			return invLine;
		endif;
	endforeach;
 
 return null;
epilog

end;</source>
