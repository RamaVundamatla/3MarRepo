26 April 2023	navhl20	ChangeRequest 57712:[54552] EUP - Delivery Dispatch – Adding Work Point Types

*/

vars

begin
	if _str = self.getErrorString(WORK_POINT_ROAD_STR) then
		return WORK_POINT_TYPE_ROAD;
	elseif _str = self.getErrorString(WORK_POINT_RAIL_STR) then
		return WORK_POINT_TYPE_RAIL;
