        <Parameter name="anObject" type="CM_GridArea"/>
    </JadeMethod>
    <JadeMethod name="setMoveControllerSource" id="111c9c1d-33dd-4ddf-b503-952812f34e63">
        <updating/>
        <source>setMoveControllerSource(_ti : CM_TrackedItem) updating;
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	moveController	: CMIF_MoveController;
	moveMode : Integer;
begin

	create moveController transient;
	
	moveController.setMyTrackedItem(_ti);
	delete app.myMoveController;
	app.myMoveController := moveController;
	if self.frmStatusLine.displayMode = DISPLAY_MODE_ACTUAL then
		moveMode := REAL_MODE;
	elseif self.frmStatusLine.displayMode = DISPLAY_MODE_PLAN then
		moveMode := PLANNING_MODE;
	elseif self.frmStatusLine.displayMode = DISPLAY_MODE_QUEUE then
		moveMode := QUEUE_MODE;
	endif;

	moveController.setMyOriginatingLocation(_ti.getPrimaryLocation(moveMode));
//	moveController.setMyOriginatingLocation(_ti.getPrimaryLocation(self.moveModeForm));	//REAL_MODE));
	moveController.setMoveMode(self.moveModeForm);	
	moveController.isRehandleMove := _ti.isRehandle;
	moveController.myOriginatingForm := self;
//	moveController.isOverstowMove := _ti.isOverStowed(REAL_MODE);

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setMoveMode" id="e5f2111c-01b2-43d3-b956-be5b8e3d7840">
        <updating/>
        <source>setMoveMode(_mode: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     26 February 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	cdc : YRD_ContainerDrawingController;
	anObj : Object;

begin
	inheritMethod(_mode);

	foreach anObj in self.allDrawingControllers do
		cdc := anObj.YRD_ContainerDrawingController;
		cdc.moveMode := _mode;
	endforeach;
end;</source>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setMyCurrentDrawingController" id="0f3544b3-2e28-44ee-8c16-8327f8c01532">
        <updating/>
        <source>setMyCurrentDrawingController(_newController : CMUI_GridDrawingController input; _redraw : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	
	db			: YRD_ContainerGridAreaDockBar;
	anObject	: Object;
	gridArea	: CM_GridArea;
	rtgLane		: Boolean;
	ta 			: CM_TerminalArea;
	invalidTA 	: Boolean;
begin
	
	
	
	self.myPreviousDrawingController := self.myCurrentDrawingController;
	self.myCurrentDrawingController := _newController.YRD_ContainerDrawingController;	
				
	if myCurrentDrawingController &lt;&gt; null then
		self.btnViewYardAllEd.enabled  := false;
	endif;
	
	if _redraw then
			
		foreach anObject in self.allDockBars do
			db := anObject.YRD_ContainerGridAreaDockBar;
			db.myDrawingFrame.changeBackColor(self.defYardBackColUnselected);
		endforeach;
		self.myCurrentDrawingController.changeBackColor(self.defYardBackColSelected);
	
	endif;

end;</source>
        <Parameter name="_newController" type="CMUI_GridDrawingController" usage="input"/>
        <Parameter name="_redraw" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setObjFromTblPreferSpecial" id="b9ca2fe8-ca0d-4116-a840-9d15184dbd0d">
        <source>setObjFromTblPreferSpecial(_attrName, _value : String; _obj : Object input; _tbl : CM_EntryTable input) : Boolean;
// ---------------------------------------------------------------------------
// Created:     20 May 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	return false;
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_value" type="String"/>
        <Parameter name="_obj" type="Object" usage="input"/>
        <Parameter name="_tbl" type="CM_EntryTable" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setSelector" id="02a2acc0-344d-4adb-98e7-62df4e2bf561">
        <updating/>
        <source>setSelector(_theSelector : CMUI_Selector input) updating, protected;
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	critLine		: CM_SelectorCriteriaLine;
	taSet			: ObjectSet;

begin
	
	_theSelector.myTerminal := self.myTerminal;
	_theSelector.myEnquiryCollectionClass := CM_TIArray;
	_theSelector.defaultSiteStr := TI_SITE_ONSITE_str;


	_theSelector.myQDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type, TI_CargoType_Container];
	_theSelector.disableMnuEnquiry := false;
	//check to see if a previous query in this session contained terminal areas criteria, and if so
	//populate that criteria line with the currently displayed areas, other wise set the
	//allDefaultTerminalAreas collection on the form and that will build a new criteria line for this property
	critLine := self.allSelectorCriteria['myTerminalArea','CM_Container'];
	if critLine &lt;&gt; null and CM_QReferenceIsOneOf.hasInstance(critLine.myQueryOperator) then
		taSet := critLine.myQueryOperator.CM_QReferenceIsOneOf.allSelectionValues;
	else
		taSet := _theSelector.allDefaultTerminalAreas;
	endif;
	
	taSet.clear;
	self.allTerminalAreas.copy(taSet);


end;</source>
        <access>protected</access>
        <Parameter name="_theSelector" type="CMUI_Selector" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setYardAllocLegend" id="a88a4fe7-ca1b-4fd5-a4a4-93b6435f02e2">
        <updating/>
        <source>setYardAllocLegend() updating;
// ---------------------------------------------------------------------------
// Created:		June 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	anObj,yalloc : Object;
	cdc : YRD_ContainerDrawingController;
	objSet : ObjectSet;
	vMode : Integer;
begin
	
	create objSet transient;
	foreach anObj in self.allDrawingControllers do
		cdc := anObj.YRD_ContainerDrawingController;
		vMode := cdc.viewMode;
		// Need rethinking!! Invalid object created by notes coming in after this stuff. Invalid object is
		// rectified but after this method as already been called.
		foreach yalloc in cdc.myDrawingAttrController.allYardAllocations where global.isValidObject(yalloc) do
			if yalloc.CM_YardAllocation.isDisabled then
				continue;
			endif;
			objSet.addNoDuplicates(yalloc,false);
		endforeach;
		
	endforeach;

	foreach anObj in self.allDrawingControllers do
		cdc := anObj.YRD_ContainerDrawingController;
		cdc.myDrawingAttrController.allYardAllocations.clear;
		objSet.copy(cdc.myDrawingAttrController.allYardAllocations);
		
	endforeach;

	if cdc &lt;&gt; null then
		self.doNotesForLegendStartStop(vMode,cdc);
	endif;

epilog
	delete objSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="eb2c30c0-e78c-447d-adf3-69c4167b4b43">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     21 January 2002 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 22/12/2011	cnwdap1		PAR #28064 Retain colour legend table width
vars

begin
	// cnwrl1 26/02/2009 - (CCMS SFW 1047 - Totals Only Lists)
	// The user can access the summarise functionality only if they have at least view security role.
	self.bAllowSummaryDefn	:= app.myCurrentUserCan( self.myTerminal, PmSummaryDefView );
	
	self.frmToolbar.alignContainer := Frame.AlignContainer_Top; // this will make the dkcMain line up its top

	self.showToolbar := true;
	self.toolbarStyle	:= self.ToolbarStyle_ShowNoHide;
	self.configAutoPlanUseAllocations := true;					//SFW1030 30/10/2008

	
	// this sets the captions for some menus
	self.getXMLSettingsForSetup();
	
	self.doHideShowSelectorPanel();
	self.doHideShowLegend(); // this reverses the lines above and sets things correctly
	// must set the width AFTER the click call above
	self.dkbColorLegend.width := 100;
	if self.xmlLegendWidth = null then					// PAR #28064
		self.dkcSubMainCol.width := 100;				// PAR #28064
		self.dkcSubMainCol_userResize(dkcSubMainCol);	// PAR #28064
	endif;												// PAR #28064

	
	inheritMethod();
	
	self.frmSelectorPane.populateListBox( self.myTerminal );	//29 July 2011	NDL	Par 27890

	self.btnViewYardAllEd.enabled := false;
	//self.mnuWorkViewYardEdit.enabled := false;
		
	if  self.xmlExtInfoHeight &lt;&gt; null then
		self.dkcExtraInfo.height :=self.dkcSubMain.height * self.xmlExtInfoHeight;
	endif;
	if self.xmlCargoWidth &lt;&gt;  null then
		self.dkbCargoPic.width := self.dkcExtraInfo.width * self.xmlCargoWidth;
	endif;
	if self.xmlLegendWidth &lt;&gt; null then											// PAR #28064
		self.dkcSubMainCol.width := self.dkcMain.width * self.xmlLegendWidth;	// PAR #28064
	endif;																		// PAR #28064
	//set the parent to be different from other buttons so the  button syle will take no effect on btnViewYardAlloc
	self.btnViewYardAlloc.parent := self.frmToolbarBtns;
end;</source>
    </JadeMethod>
