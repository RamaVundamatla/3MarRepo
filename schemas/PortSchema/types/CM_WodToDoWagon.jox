    <JadeMethod name="getAdvWOTransactionType" id="c4cfa4c3-c539-46db-97ab-49981ec25332">
        <source>getAdvWOTransactionType(transType : Integer): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
04 October 2022		navcs2	ChangeRequest 56633:[56211] 54253.101 - Work order Transactions

*/

vars

begin
	if transType = TRANS_CREATED then
		return TRANS_TYPE_WO_TODO_WGN_CREATED;
	elseif transType = TRANS_UPDATED then
		return TRANS_TYPE_WO_TODO_WGN_UPDATED;
	else
		return TRANS_TYPE_WO_TODO_WGN_COMPLET;
	endif;
epilog

end;</source>
        <Parameter name="transType" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getCarrier" id="558fdd97-5ad0-497f-8344-3803db889df5">
        <source>getCarrier(): CM_Carrier;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Jun 2023	navma1	Defect 58904: MTN - Carrier/Sub Carrier is not populated for the Rail Jobs
*/

vars
	wagon : CM_Wagon;
begin
	wagon := self.allWagons.first;
	if wagon &lt;&gt; null then
		return wagon.myCarrier;
	endif;

epilog

end;</source>
        <ReturnType type="CM_Carrier"/>
    </JadeMethod>
