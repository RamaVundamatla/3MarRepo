    <JadeMethod name="comboBoxRailLine" id="9bcf3209-0740-4c01-ac3b-5a45ed6b6b93">
        <source>comboBoxRailLine(_cmb : ComboBox input);
/*

Purpose:			


Return Value:		


Date		Who		Reason
20 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	
	taIter 		: Iterator;
	railLine 	: CM_RailLine;
	taDict		: CM_TAByTypeIdDict;
	taIdKey		: String;
	taTypeKey	: Integer;
	ta			: CM_TerminalArea;
begin
	if _cmb = null then
		return;
	endif;
	taDict := self.myTerminal.allTerminalAreasByTypeId;
	taIter := taDict.createIterator;
	taDict.startKeyGeq(TA_TYPE_RAILWAY_TRACK, null, taIter);
	
	while taIter.next(ta) do
		taDict.getIteratorKeys(taTypeKey, taIdKey, taIter);
		if taTypeKey &lt;&gt; TA_TYPE_RAILWAY_TRACK then
			break;
		endif;
		
		foreach railLine in ta.CM_Rail.allRailLinesByIndex do
			_cmb.itemObject[_cmb.addItem(ta.id &amp; ' ' &amp; railLine.id)] := railLine;
		endforeach;
		
	endwhile;
	
	
epilog
	delete taIter;
	
end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="comboBoxTrain" id="cee5df4d-14dd-458d-8d35-6c3913b04f0a">
        <source>comboBoxTrain(_cmb 					: ComboBox input; 
				_train 				: CM_Train);
/*
----------   ----------  --------------------------------------------------
Created:	07 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	train				: CM_Train;
	trainDict			: CM_TrainByCodeDateDict;
	foundIdx			: Integer;
begin
	_cmb.clear();
	_cmb.sorted := false;
	_cmb.addItem(null);
	
	
	//trainDict := app.myPassport.myTerminal.allTrainsOnTerminal;
	trainDict := self.myTerminal.allTrainsOnTerminal;	//27 Apr 2010	NDL	Par 23788
	foreach train in trainDict do
		if train.isNullTrain() then
			continue;
		endif;
		_cmb.itemObject[_cmb.addItem(self.displayEntryTrain(train))] := train;
	endforeach;
	
	if _train &lt;&gt; null then
		foundIdx := _cmb.findObject(_train);
	endif;
	
	if foundIdx &gt; 0 then
		_cmb.listIndex := foundIdx;
	else
		_cmb.text := null;
	endif;
		
	
end;


</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_train" type="CM_Train"/>
    </JadeMethod>
