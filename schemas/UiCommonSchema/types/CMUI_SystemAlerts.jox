    <JadeMethod name="buildCombinedAlerts" id="459e9193-6ab0-457a-a979-0d4f715188c0">
        <source>buildCombinedAlerts() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 July 2008	#cnwdz2	 to improve the performance of displaying the search results for the system and terminal alerts.

*/

vars
	alert 			: CM_SystemAlert;
	iter  			: Iterator;
	startTS, endTS	: TimeStamp;
	endTime			: Time;
	
begin
	self.allCombinedAlerts.clear();
	iter := self.myTerminal.allSystemAlertsByDateTime.createIterator();
	
	//self.myTerminal.allSystemAlertsByDateTime.startKeyLss((self.queryDateTo + 1).asTimeStamp(), iter);
	// 26/09/2014 cnwar2 #33950
	if self.queryDateTo.isValid then
		endTS.setDate( self.queryDateTo );
		endTime.setTime( self.queryTimeTo.hour, self.queryTimeTo.minute, 59, 999 );
		endTS.setTime( endTime );
		self.myTerminal.allSystemAlertsByDateTime.startKeyLss(endTS, iter);
	endif;
	
	// 26/09/2014 cnwar2 #33950
	if self.queryDateFrom.isValid then
		startTS := self.queryDateFrom.asTimeStamp();
		startTS.setTime( self.queryTimeFrom );
	else
		startTS := null;
	endif;
	
	while iter.back(alert) do
		//if self.queryDateFrom.isValid and alert.dateTime.date &lt; self.queryDateFrom then
		if alert.dateTime &lt; startTS then	// 26/09/2014 cnwar2 #33950
			break;
		endif;
		self.allCombinedAlerts.add(alert);
	endwhile;
	
	delete iter;
	
	iter := app.myRoot.allSystemAlerts.createIterator();	
	app.myRoot.allSystemAlerts.startKeyLss((self.queryDateTo + 1).asTimeStamp(), iter);
	while iter.back(alert) do
		//if self.queryDateFrom.isValid and alert.dateTime.date &lt; self.queryDateFrom then
		if alert.dateTime &lt; startTS then	// 26/09/2014 cnwar2 #33950
			break;
		endif;
		self.allCombinedAlerts.add(alert);
	endwhile;

epilog
	delete iter;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="buttonsOffOn" id="d87522fd-e963-4759-acff-beb0b029f029">
        <source>buttonsOffOn(_value : Boolean) protected;
// -------------------------------------------
// Created 03 March 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	self.btnPrint.enabled := _value;
	self.btnAll.enabled := _value;
	self.btnDelete.enabled := _value;
	self.btnDeleteAll.enabled := _value;
	self.btnDisasters.enabled := _value;
	self.btnErrors.enabled := _value;
	self.btnInfo.enabled := _value;
	self.btnReefer.enabled := _value;
	self.btnRefresh.enabled := _value;
	self.btnWarnings.enabled := _value;
	self.btnEditRemote.enabled := _value;
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnDelete.enabled := false;
		self.btnDeleteAll.enabled := false;
		self.btnEditRemote.enabled := false;
		self.mnuSADelete.enabled := false;
		self.mnuRemoteData.enabled := false;
	endif;

	
end;</source>
        <access>protected</access>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="create" id="8fb4df09-344b-4927-ab6d-074a75b9c6c5">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
