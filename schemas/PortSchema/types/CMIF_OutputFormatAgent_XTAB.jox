    <JadeMethod name="getMatchingYACriteriaType" id="0e30c9a4-dcf8-4229-943e-89caaa1206cd">
        <source>getMatchingYACriteriaType(_qProperty : CM_QueryProperty) : Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 February 2010	cnwas3	Initial creation

To be later refined - if used in other circumstances, see how not getting the imex status criteria affects things! 
*/
//16 Mar 2016	cnwrs1	TFS 1455 Add Freight Tons

vars

begin
	if _qProperty = null then 
		return null;
	endif;
	
	if CM_QAvailabilityGradeProperty.hasInstance(_qProperty) then
		return YACriteriaType_AvGrade;
	elseif CM_QBolTypeProperty.hasInstance(_qProperty) then
		return YACriteriaType_BOL;
	elseif CM_QCargoTypeLookupProperty.hasInstance(_qProperty) then
		return YACriteriaType_CargoType;
	elseif CM_QStrCarrierProperty.hasInstance(_qProperty) then
		return YACriteriaType_Carrier;
	elseif CM_QStrCommodityProperty.hasInstance(_qProperty) then
		return YACriteriaType_Commodity;
	elseif CM_QStrCommodityGroupProperty.hasInstance(_qProperty) then
		return YACriteriaType_CommodityGroup;
	elseif CM_QStrISOTypeProperty.hasInstance(_qProperty) then
		return YACriteriaType_ISO;
	elseif CM_QStrISOGroupProperty.hasInstance(_qProperty) then
		return YACriteriaType_ISOGroup;
	/*elseif CM_QImExStatusProperty.hasInstance(_qProperty) then
		return YACriteriaType_ImexStatus;*/
	elseif CM_QIntendedRelModeProperty.hasInstance(_qProperty) then
		return YACriteriaType_IntendedRelMode;
	elseif CM_QStrOperatorProperty.hasInstance(_qProperty) then
		return YACriteriaType_OperatorItem;//questionable
	elseif CM_QRefProductProperty.hasInstance(_qProperty) then
		return YACriteriaType_Product;
	elseif CM_QStrSpecialStowCodeProperty.hasInstance(_qProperty) then
		return YACriteriaType_SpecialStow;
	elseif CM_QRefTerminalAreaProperty.hasInstance(_qProperty) then
		return YACriteriaType_SrcTermArea;//questionable
	elseif CM_QStopsProperty.hasInstance(_qProperty) then
		return YACriteriaType_Stops;
	elseif CM_QRefSubTerminalProperty.hasInstance(_qProperty) then
		return YACriteriaType_SubTerminal;
	elseif CM_QBooleanToDoTaskProperty.hasInstance(_qProperty) then
		return YACriteriaType_ToDoTasks;
	elseif CM_QDecimalTotalWeightProperty.hasInstance(_qProperty) then
		return YACriteriaType_TotalWeight;
	elseif CM_QRefTrainProperty.hasInstance(_qProperty) then
		return YACriteriaType_Train;
	elseif CM_QStrVoyageProperty.hasInstance(_qProperty) then
		return YACriteriaType_Voyage;	
	elseif CM_QStrPortProperty.hasInstance(_qProperty) and _qProperty.propertyName = "dischargePort" then
		return YACriteriaType_DischargePort;
	elseif CM_QStrPortProperty.hasInstance(_qProperty) and _qProperty.propertyName = "destinationPort" then
		return YACriteriaType_DestinationPort;
	elseif CM_QStrConsignProperty.hasInstance(_qProperty) and _qProperty.propertyName = "consignor" then
		return YACriteriaType_Consignor;	
	elseif CM_QStrConsignProperty.hasInstance(_qProperty) and _qProperty.propertyName = "freightForwarderCode" then
		return YACriteriaType_FreightForward;	
	elseif CM_QStrConsignProperty.hasInstance(_qProperty) and _qProperty.propertyName = "freightTons" then
		return YACriteriaType_FreightTons;	
	elseif CM_QStrConsignProperty.hasInstance(_qProperty) and _qProperty.propertyName = "consignee" then
		return YACriteriaType_Consignee;	
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_qProperty" type="CM_QueryProperty"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getNextColTotal" id="109480ef-0a74-4593-ab6f-10aa88d3507e">
        <source>getNextColTotal(_grouping :CMIF_OutputGrouping; _values :StringArray):CMIF_OutputGrouping protected;
// ---------------------------------------------------------------------------
// Created:     12 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	format				:CM_OutputFormat_XTAB;
	level, numCols, 
	numRows, numTabs, 
	start, intStart, 
	intEnd, int			:Integer;
	values				:StringArray;			// key values for sub-total entry
	grouping			:CMIF_OutputGrouping;
begin
	format 	:= self.myOutputFormat_XTAB;
	numCols	:= format.allColumns.size;
	numRows	:= format.allRows.size;
	numTabs	:= format.allTabs.size;
	
	if _grouping.rowSummaryLevel &lt; numRows then
		// we only link to the next column total if we are a detail row otherwise we would end up double counting
		return null;
	endif;
	
	create values transient;

	// find the next highest level column for which subtotals are to be generated
	start := _grouping.colSummaryLevel - 1;					

	// ok for start to be zeros for self.Level_Detail_No_Groupings as the only total 
	// we can add into will be the grand total (self.Level_Grna_Total = 0)
	foreach level in start to 0 step -1 do	
		if level = self.Level_Grand_Total then
			if not format.displayTotalColumn then
				break; 
			endif;
		elseif not format.allColumns[level].includeSubtotals then
			continue;
		endif;
		
		// we have a column we want to sub-total on
		_values.copy (values);

		// reset any column grouping values that are not at a higher level that the level being subtotalled
		self.clearColumnValues (values, level, numTabs, numRows, numCols);
		
		// now look to see if the next total entry is already there
		grouping := self.allXTABData.getEntry_XTAB (_grouping.summaryLevel, values); 
	
		// create the entry if it is not already there
		if grouping = null then
			grouping := self.createXTABEntry (_grouping.summaryLevel, values, _grouping.rowSummaryLevel, level, _grouping.tabSummaryLevel); 
			// now link to next highest level column sub-total that needs to be updated
			if grouping.colSummaryLevel &lt;&gt; self.Level_Grand_Total then
				grouping.myColTotalEntry	:= self.getNextColTotal (grouping, values);
			endif;
			
			// we also need to link this new row total to any column totals the need to be updated
			if grouping.rowSummaryLevel &lt;&gt; self.Level_Grand_Total then
				grouping.myRowTotalEntry := self.getNextRowTotal (grouping, values);
			endif;
		endif;
		
		// we only want to link to the summary to the next highest level total column
		// the total column will then be linked to the next highest total column and so-on
		break;
	endforeach;	
	
	return grouping;
epilog
	delete values;
end;</source>
        <access>protected</access>
        <Parameter name="_grouping" type="CMIF_OutputGrouping"/>
        <Parameter name="_values" type="StringArray"/>
        <ReturnType type="CMIF_OutputGrouping"/>
    </JadeMethod>
    <JadeMethod name="getNextRowTotal" id="5fd7a062-6c77-4368-b144-10a52e0ee6d3">
        <source>getNextRowTotal(_grouping :CMIF_OutputGrouping; _values :StringArray):CMIF_OutputGrouping protected;
// ---------------------------------------------------------------------------
// Created:     12 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  _grouping
//				_values		- contains grouping values used for last total
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	format				:CM_OutputFormat_XTAB;
	level, numCols, 
	numRows, numTabs, 
	start, intStart, 
	intEnd, int			:Integer;
	values				:StringArray;			// key values for sub-total entry
	grouping			:CMIF_OutputGrouping;
begin
	if _grouping.rowSummaryLevel = self.Level_Grand_Total then
		return null;
	endif;
	
	if _grouping.summaryLevel &gt; 0 then
		// no subtotals for a row summary
		return null;
	endif;
	
	format 	:= self.myOutputFormat_XTAB;
	numCols	:= format.allColumns.size;
	numRows	:= format.allRows.size;
	numTabs	:= format.allTabs.size;
	
	create values transient;

	// find the next highest level row for which subtotals are to be generated
	start := _grouping.rowSummaryLevel - 1;					

	// ok for start to be zeros for self.Level_Detail_No_Groupings as the only total 
	// we can add into will be the grand total (self.Level_Grand_Total = 0)
	foreach level in start to 0 step -1 do	
		if level = self.Level_Grand_Total then
			if not format.displayTotalRow then
				break; 
			endif;
		elseif not format.allRows[level].includeSubtotals then
			continue;
		endif;
		
		// we have a row we want to sub-total on - copy all grouping values to local collection
		// that is just used for looking up dictionary keys
		_values.copy (values);

		// reset any row grouping values that are not at a higher level that the level being subtotalled
		self.clearRowValues (values, level, numTabs, numRows, numCols);
		
		// now look to see if the next total entry is already there
		grouping := self.allXTABData.getEntry_XTAB (_grouping.summaryLevel, values); 
	
		// create the entry if it is not already there
		if grouping = null then
			grouping := self.createXTABEntry (_grouping.summaryLevel, values, level, _grouping.colSummaryLevel, _grouping.tabSummaryLevel); 
			
			// now link to next highest level row sub-total that needs to be updated
			if grouping.rowSummaryLevel &lt;&gt; self.Level_Grand_Total then
				// can't link grand total to any higher level total
				grouping.myRowTotalEntry	:= self.getNextRowTotal (grouping, values);
			endif;			
		endif;
				
		// we only want to link to the summary to the next highest level total column
		// the total column will then be linked to the next highest total column and so-on
		break;
	endforeach;	
	
	return grouping;

epilog
	delete values;
end;</source>
        <access>protected</access>
        <Parameter name="_grouping" type="CMIF_OutputGrouping"/>
        <Parameter name="_values" type="StringArray"/>
        <ReturnType type="CMIF_OutputGrouping"/>
    </JadeMethod>
    <JadeMethod name="getNextTabTotal" id="20f2f387-e292-43cf-b768-8af00aca1e81">
        <source>getNextTabTotal(_grouping :CMIF_OutputGrouping; _values :StringArray):CMIF_OutputGrouping protected;
// ---------------------------------------------------------------------------
// Created:     10 December 2008 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	format		:CM_OutputFormat_XTAB;
	numTabs		:Integer;
	values		:StringArray;
	int			:Integer;
	grouping	:CMIF_OutputGrouping;
begin
	format 	:= self.myOutputFormat_XTAB;
	numTabs	:= format.allTabs.size;

	if not format.hasTabs or							// summary does no have tab groupings
		not format.allTabs.first.includeSummary then	// not producing summary tab
		return null;
	endif;
	
	if _grouping.tabSummaryLevel = self.Level_Grand_Total then 	// we only link to one total tab
		return null;									
	endif;	
	
	create values transient;
	
	// we need an identical grouping except that the tab grouping values will be null
	_values.copy (values);
	
	// clear all tab values 
	self.clearTabValues (values, numTabs);
	
	// does a matching entry in the 'ALL' tab already exist?
	grouping := self.allXTABData.getEntry_XTAB (_grouping.summaryLevel, values);
	
	if grouping = null then
		grouping := self.createXTABEntry (_grouping.summaryLevel, values, _grouping.rowSummaryLevel, _grouping.colSummaryLevel, self.Level_Grand_Total);
		
		// now link to next highest level column sub-total that needs to be updated
		if grouping.colSummaryLevel &lt;&gt; self.Level_Grand_Total then
			grouping.myColTotalEntry	:= self.getNextColTotal (grouping, values);
		endif;
		
		// we also need to link this new row total to any column totals the need to be updated
		if grouping.rowSummaryLevel &lt;&gt; self.Level_Grand_Total then
			grouping.myRowTotalEntry := self.getNextRowTotal (grouping, values);
		endif;
	endif;
	
	return grouping;
epilog
	delete values;
end;</source>
        <access>protected</access>
        <Parameter name="_grouping" type="CMIF_OutputGrouping"/>
        <Parameter name="_values" type="StringArray"/>
        <ReturnType type="CMIF_OutputGrouping"/>
    </JadeMethod>
    <JadeMethod name="getNumberOfKeys_XTAB" id="40d9e46a-a8c5-4f41-9643-b84c156bd783">
        <source>getNumberOfKeys_XTAB(_numTabs, _numRows, _numCols :Integer):Integer protected;
// ---------------------------------------------------------------------------
// Created:     03 December 2009 by cnwcs5:1
// Purpose:     ccms 1023 
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	size	:Integer;
begin
	size := _numTabs + 1;
	
	if _numRows &gt; 0 then
		size := size + _numRows;
	else
		size := size + 1;	// dummy value
	endif;
	
	if _numCols = 0 then
		size := size + 1;	// dummy value
	else
		size := size + _numCols;	
	endif;
	
	return size;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_numTabs" type="Integer"/>
        <Parameter name="_numRows" type="Integer"/>
        <Parameter name="_numCols" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getRowColumnHeadings_XTAB" id="7ad45160-2c95-4b82-9ea5-5c70f19547c9">
        <source>getRowColumnHeadings_XTAB(_headingArray :StringArray input; _numTabs, _numRows, _numCols :Integer; _iter :Iterator; _clear :Boolean)protected;
// ---------------------------------------------------------------------------
// Created:     09 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
//				gets row/column headings from the XTAB collection
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 1/12/2009	cnwcs5		ccms1028 - display in mapping order
// ---------------------------------------------------------------------------
vars
	int, size,
 	grpIndex		:Integer;
	headingValue	:String;
	mapping			:CM_XTABMapping;
begin
	if _clear then
		_headingArray.clear;
	endif;
	
	size := self.getNumberOfKeys_XTAB (_numTabs, _numRows, _numCols);	// cnwcs5 03/12/09 ccms 1028
	
	foreach int in (_numTabs + 2) to (size) do
		headingValue := _iter.getCurrentKey(int).String;	
		grpIndex	:= self.keyXTAB_to_indexGrouping(int);						
		
		if grpIndex &gt; 0 then
			mapping 	:= self.allGroupingMappings [grpIndex].CM_XTABMapping;	
		endif;
		
		if mapping &lt;&gt; null then													
			headingValue := self.getMappingForKeyValue (headingValue, mapping);				
		endif;																	

		self.trimLeadingZeros (grpIndex, headingValue);
		
		_headingArray.add (headingValue);  
	endforeach;
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_headingArray" type="StringArray" usage="input"/>
        <Parameter name="_numTabs" type="Integer"/>
        <Parameter name="_numRows" type="Integer"/>
        <Parameter name="_numCols" type="Integer"/>
        <Parameter name="_iter" type="Iterator"/>
        <Parameter name="_clear" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getTabValues_Headings" id="8d9fd855-8ee0-4e7e-b386-fca0c1dc672b">
        <source>getTabValues_Headings(_keyArray, _headingArray :StringArray input; _numTabs :Integer; _iter :Iterator; _clear :Boolean)protected;
// ---------------------------------------------------------------------------
// Created:     09 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
//				Gets tab key and heading values from the Headings collection
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	int,
	grpIndex		:Integer;
	keyValue, 
	headingValue	:String;
	mapping			:CM_XTABMapping;
begin
	if _clear then
		_keyArray.clear;
		_headingArray.clear;
	endif;
	
	foreach int in 1 to _numTabs do
		keyValue 		:= _iter.getCurrentKey(int).String;
		headingValue	:= keyValue;
		grpIndex		:= self.keyXTAB_to_indexGrouping(int);						
		
		self.trimLeadingZeros (grpIndex, keyValue);
		
		_keyArray.add (keyValue); 
				
		// if we are displaying mapped values in mapping line order rather than
		// mapped value order then the value of the key will be different to the
		// heading value that is displayed.
		if grpIndex &gt; 0 then													// cnwcs5 1/12/09
			mapping 	:= self.allGroupingMappings [grpIndex].CM_XTABMapping;	// cnwcs5 1/12/09
		endif;
		
		if mapping &lt;&gt; null then													// cnwcs5 1/12/09
			headingValue := self.getMappingForKeyValue (headingValue, mapping);				// cnwcs5 1/12/09
		endif;																	// cnwcs5 1/12/09
		
		self.trimLeadingZeros (grpIndex, headingValue);
		
		_headingArray.add (headingValue);
	endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_keyArray" type="StringArray" usage="input"/>
        <Parameter name="_headingArray" type="StringArray" usage="input"/>
        <Parameter name="_numTabs" type="Integer"/>
        <Parameter name="_iter" type="Iterator"/>
        <Parameter name="_clear" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getTotalColumnHeading" id="57123ad6-a8a5-4841-826d-f6d36bf86506">
        <source>getTotalColumnHeading(_col :Integer):String protected;
// ---------------------------------------------------------------------------
// Created:     24 November 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	col	:CM_XTABGrouping;
begin
	if _col = 0 and self.myOutputFormat_XTAB.grandTotalColumnHeading &lt;&gt; null then
		return self.myOutputFormat_XTAB.grandTotalColumnHeading;
	elseif _col &gt; 0 then
		col := self.myOutputFormat_XTAB.allColumns [_col];
	
		if col &lt;&gt; null and col.heading_SubTotal &lt;&gt; null then
			return col.heading_SubTotal;
		endif;
	endif;
	
	return self.Default_Total_Heading;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_col" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTotalRowHeading" id="6ccc7e80-c5d7-4653-9279-d53f11b027ca">
        <source>getTotalRowHeading(_row :Integer):String protected;
// ---------------------------------------------------------------------------
// Created:     24 November 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	row	:CM_XTABGrouping;
begin
	if _row = 0 and self.myOutputFormat_XTAB.grandTotalRowHeading &lt;&gt; null then
		return self.myOutputFormat_XTAB.grandTotalRowHeading;
	elseif _row &gt; 0 then
		row := self.myOutputFormat_XTAB.allRows [_row];
	
		if row &lt;&gt; null and row.heading_SubTotal &lt;&gt; null then
			return row.heading_SubTotal;
		endif;
	endif;
	
	return self.Default_Total_Heading;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_row" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getValueForProperty" id="db66b9aa-ec96-4a1b-9f0f-f2d36a644e26">
        <source>getValueForProperty(
	_property	: CM_QueryProperty;
	_obj		: Object;
	_mapping	: CM_XTABMapping ) : String protected;
	
// ---------------------------------------------------------------------------
// Created:     27 November 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 16/01/2009	cnwrl1		Armed the exception handler in this method not higher up (CCMS SFW 1047 - Totals Only Lists)
// 15/12/2009	cnwcs5		ccms 1023 - snapshot summaries
// 12/02/2010	cnwcs5		par 22140 - New functions
// 15/02/2010	cnwcs5		ccms 1925 / par 22295
// 22/02/2010	cnwcs5		change in formatting boolean values
// 26/07/2010 	cnwcs5 		ccms 1156 / par 23706 - new date/time values
// 20/10/2010 	cnwcs5 		par 25708 - fix bug when getting data from snap shot
// 18/05/2017	cnwdap1		TFS 4479 Correct handling of dates and time stamps in mappings
// ---------------------------------------------------------------------------

vars
	strValue	: String;	// value used for key
	anyValue	: Any;
	oper 		: CM_QueryOperator;
	dateValue	: String;									// TFS 4479
	
begin
	on Exception do self.handleInvalidPropertyException( exception, strValue );

	if CM_QStringLookupProperty.hasInstance( _property ) then	//no need to translate
		anyValue := _obj.getPropertyValue( _property.propertyName );
		
		if anyValue &lt;&gt; null then										// 15/02/2010 cnwcs5 ccms 1925 / par 22295
			strValue := anyValue.asStringJMT;	
		endif;															// 15/02/2010 cnwcs5 ccms 1925 / par 22295
	else
		if self.myOutputFormat_XTAB.isSnapshotMode and					// 20/10/2010 cnwcs5 par 25708
			not _property.isSnapShotProperty then						// 20/10/2010 cnwcs5 par 25708
			// property will be stored as string on snap shot
			anyValue := _obj.getPropertyValue( _property.propertyName );// 20/10/2010 cnwcs5 par 25708
		else															// 20/10/2010 cnwcs5 par 25708
			anyValue := _property.getValueForObject( _obj, oper );
		endif;															// 20/10/2010 cnwcs5 par 25708
		
		if not anyValue.isKindOf (Object) and							// cnwcs5 15/12/2009
			not anyValue.isKindOf (Date) and							// 26/07/2010 cnwcs5 ccms 1156 / par 23706	
			not anyValue.isKindOf (TimeStamp) and						// 26/07/2010 cnwcs5 ccms 1156 / par 23706	
			self.myOutputFormat_XTAB.isSnapshotMode then				// cnwcs5 15/12/2009
			// always strings - already summarised
			strValue := anyValue.String;								// cnwcs5 15/12/2009
		elseif anyValue.isKindOf (Date) then							// 15/02/2010 cnwcs5 ccms 1925 / par 22295
			// we can't store date keys in display format as they don't come
			// out in the correct order
			strValue := self.makeDateKeyValue (anyValue.Date);			// 15/02/2010 cnwcs5 ccms 1925 / par 22295
		elseif anyValue.isKindOf (TimeStamp) then						// 26/07/2010 cnwcs5 ccms 1156 / par 23706
			// we can't store datetime keys in display format as they don't come
			// out in the correct order
			strValue := self.makeDateTimeKeyValue  (anyValue.TimeStamp);// 26/07/2010 cnwcs5 ccms 1156 / par 23706	
		elseif anyValue.isKindOf (Boolean) then
			strValue := self.makeBooleanKeyValue (anyValue.Boolean, _property);		// 22/02/2010
		else
			strValue := _property.translateToDisplayValue( anyValue );
		endif;
	endif;
	
	// now do the mapping
	if _mapping &lt;&gt; null then 
		// TFS 4479 If our value is a date or a time stamp, feed the original value	// TFS 4479
		// to getValueForProperty_Mapping rather than the converted time key value	// TFS 4479
		if anyValue.isKindOf(Date) then 											// TFS 4479
			dateValue := anyValue.Date.asStringJMT;									// TFS 4479
			self.getValueForProperty_Mapping( _mapping, dateValue, anyValue );				// TFS 4479 // TFS 7528 added original anyValue
			strValue := dateValue;													// TFS 4479
		elseif anyValue.isKindOf(TimeStamp) then									// TFS 4479
			dateValue := anyValue.TimeStamp.date.asStringJMT;						// TFS 4479
			self.getValueForProperty_Mapping( _mapping, dateValue, anyValue );				// TFS 4479 // TFS 7528 added original anyValue
			strValue := dateValue;													// TFS 4479
		else																		// TFS 4479
			self.getValueForProperty_Mapping( _mapping, strValue, anyValue ); // TFS 7528 added original anyValue
		endif;																		// TFS 4479
	endif;
	
	// all blank values will be stored as a single space
	// this is so if we are sorting in descending order our total
	// key values can be set to ! and they will appear last 
	// in the collections
	if strValue.trimBlanks = null then
		strValue := self.Empty_Property_Key_Value;	
	elseif _mapping = null and _property.getSortType = Table.SortType_Numeric then
		// we need to make sure numerics get sorted correctly
		self.padLeadingZeros( strValue, _property );
	endif;
	
	return strValue;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_property" type="CM_QueryProperty"/>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_mapping" type="CM_XTABMapping"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getValueForProperty_Mapping" id="f9ce5d45-1b72-492a-8f52-2ad23ca724f6">
        <source>getValueForProperty_Mapping(_mapping :CM_XTABMapping; _value :String io; _anyValue : Any)protected;
// ---------------------------------------------------------------------------
// Created:     16 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 24/11/2009	cnwcs5		ccms 1028 - summary mappings
// 30/11/2011	cnwcs5		CCMS POL 2122 / par 28696 - problem with mapped boolean values
// ---------------------------------------------------------------------------
vars
	obj		: Object;
	line	: CM_XTABMappingLine;
	op		: CM_QueryOperator;
	count	: Integer;
	anyObject : Object;
begin
	foreach obj in _mapping.allMappingLines do
		line 	:= obj.CM_XTABMappingLine;
		op		:= line.myQueryOperator;
		count	:= count + 1;
		
		if op.isKindOf (CM_QueryDecimalOperator) then
			if op.doMatch (_value.Decimal) then
				//_value := line.mappedValue;
				_value := self.getKeyValueForMappingLine (line);	// cnwcs5 01/12/2009 ccms 1028 - display in mapping order 
				return;
			endif;
		elseif op.isKindOf (CM_QueryIntegerOperators) or
			op.isKindOf (CM_QIntegerIsAllOf) or
			op.isKindOf (CM_QIntegerIsOneOf) or
			op.isKindOf (CM_QIntegerLookupEqual) or
			op.isKindOf (CM_QIntegerLookupNotEqual) then
			if op.doMatch (_value.Integer) then  
				//_value := line.mappedValue;
				_value := self.getKeyValueForMappingLine (line);	// cnwcs5 01/12/2009 ccms 1028 - display in mapping order 
				return;
			endif;
		elseif op.isKindOf (CM_QueryBooleanOperator) then 
			if (_value.startsWith  (self.False_Property_Key_Value) and op.doMatch (false)) or	// par 28696
				(_value.startsWith  (self.True_Property_Key_Value) and op.doMatch (true)) then	// par 28696
				//_value := line.mappedValue;
				_value := self.getKeyValueForMappingLine (line);	// cnwcs5 01/12/2009 ccms 1028 - display in mapping order 
				return;
			endif; 
		elseif op.isKindOf(CM_QReferenceLookup)  //epr TFS 1000 31/3/16 - do nothing can't match and would of caused 1000 exception
		or  op.isKindOf(CM_QReferenceIsOneOf) then // TFS 7528 
			// TFS 7528 - Actually let's do something so that it works
			if _anyValue.isKindOf(Object) then
				anyObject := _anyValue.Object;
				if op.doMatch (anyObject) then  
					_value := self.getKeyValueForMappingLine (line);	
					return;
				endif;
			endif;
		elseif op.doMatch (_value) then
			//_value := line.mappedValue;
			_value := self.getKeyValueForMappingLine (line);	// cnwcs5 01/12/2009 ccms 1028 - display in mapping order 
			return;
		endif;
	endforeach;
	
	// we did not find a match - what do we do?
	// allow for grouping under single heading, e.g. 'Other' or just using property value
	if _mapping.otherValues = CM_XTABMapping.OTHER_GROUPED then
		//_value := _mapping.otherHeading;
		_value := self.getKeyValueForMappingOther (_mapping);	// cnwcs5 01/12/209 ccms 1028 - display in mapping order 
		return;
	else
		// just use the property value
		return;
	endif;
	
	app.raiseUnexpectedProgramError( self.class.name, method.name, 'Should never appear if does then need to review' );
	
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_mapping" type="CM_XTABMapping"/>
        <Parameter name="_value" type="String" usage="io"/>
        <Parameter name="_anyValue" type="Any"/>
    </JadeMethod>
    <JadeMethod name="getValuesForObject" id="71cf4d70-5928-41a4-af0f-4add5fcb8bbd">
        <source>getValuesForObject( _obj : Object; _grpValues : StringArray input ;
					_fieldValues :Array input) protected;
// ---------------------------------------------------------------------------
// Created:     27 November 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 09/12/2009	cnwcs5	ccms 1023 - use seperate collections for grouping values and 
//						field values.  For snapshots out field values will be actual objects
// ---------------------------------------------------------------------------
vars
	format		: CM_OutputFormat_XTAB;
	strValue 	: String;
	
begin
	format := self.myOutputFormat_XTAB;
	
	_grpValues.clear;
	_fieldValues.clear;	// cnwcs5 009/12/2009
	
	self.getValuesForQueryProperty(	_obj,
									self.allTabQueryProperties,
									self.myOutputFormat_XTAB.allTabs,
									self.allTabPropertyNames,	// cnwcs5 10/12/2009
									_grpValues,
									self.Empty_Property_Key_Value,
									false );
	
	self.getValuesForQueryProperty(	_obj,
									self.allRowQueryProperties,
									self.myOutputFormat_XTAB.allRows,
									self.allRowPropertyNames,	// cnwcs5 10/12/2009
									_grpValues,
									self.Empty_Property_Key_Value,
									true ); 
	
	self.getValuesForQueryProperty(	_obj,
									self.allColQueryProperties,
									self.myOutputFormat_XTAB.allColumns,
									self.allColPropertyNames,	// cnwcs5 10/12/2009
									_grpValues,
									self.Empty_Property_Key_Value,
									true );
	
	if self.myOutputFormat_XTAB.isSnapshotMode then						// cnwcs5 10/12/2009
		self.getValuesForSnapshotFields (_obj.CM_DynamicObject_Snapshot, 
									self.myOutputFormat_XTAB.allFields, 
									_fieldValues.ObjectArray);			// cnwcs5 10/12/2009	
	else																// cnwcs5 10/12/2009
		self.getValuesForQueryProperty(	_obj,
									self.allFieldQueryProperties,
									self.myOutputFormat_XTAB.allFields,
									self.allFieldPropertyNames,			// cnwcs5 10/12/2009
									_fieldValues.StringArray,			// cnwcs5 09/12/2009
									null,
									false );
	endif;																// cnwcs5 10/12/2009
end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_grpValues" type="StringArray" usage="input"/>
        <Parameter name="_fieldValues" type="Array" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getValuesForQueryProperty" id="2eb5b110-183f-4e40-97b0-cc9b616b6913">
        <source>getValuesForQueryProperty(
	_obj					: Object;
	_coll_QueryProperties	: ObjectArray;
	_coll_XTABElement		: ObjectArray;
	_coll_PropertyNames		: StringArray;
	_values					: StringArray input;
	_emptyValue				: String;
	_dummy					: Boolean ) protected;
	
// ---------------------------------------------------------------------------
// Created:     12 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  _coll_QueryProperties - collection of CM_QueryProperty instances for which to get values
//				_coll_XTABElement - corresponding collection of tab/row/col/fields
// 				
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 10/12/2009	cnwcs5		ccms 1023 - changes for snapshots
// ---------------------------------------------------------------------------

vars
	int, size	: Integer;
	format		: CM_OutputFormat_XTAB;
	strValue	: String;
	truncValue	: String;
	property	: CM_QueryProperty;
	propName	: String;
	element		: Object;
	mapping		: CM_XTABMapping;
	
begin
	size 	:= _coll_QueryProperties.size;
	format	:= self.myOutputFormat_XTAB;
	
	foreach int in 1 to size  do
		property	:= _coll_QueryProperties[int].CM_QueryProperty;
		
		if property = null then
			// could be incompatible mode or snapshot
			if format.type = CM_QueryDefinition.Snapshot_Query_Type and 
				format.mode = CM_QueryDefinition.Snapshot_Query_Mode then
				// just do a get property value for this one
				propName	:= _coll_PropertyNames[int];
				strValue	:= _obj.getPropertyValue (propName).asStringJMT;
			else
				strValue := _emptyValue;
			endif;
		else
			// do we have any mapping to do/
			element := _coll_XTABElement[ int ];
			mapping	:= null;
			
			if element.isKindOf( CM_XTABGrouping ) then
				mapping := element.CM_XTABGrouping.myXTABMapping;
			endif;

			strValue := self.getValueForProperty( property, _obj, mapping );
		endif;
		
		truncValue := strValue[1:62];			// 36969 limit length into a StringArray.  The keys have already been limited to match.
		_values.add( truncValue );
	endforeach;
	
	// if we have no rows grouping or no column grouping then we maintain a single dummy value
	// so we can distinguish between the detail and grand total groupings
	if _dummy and _coll_QueryProperties.isEmpty then
		_values.add( self.Dummy_Detail_Value );
	endif;
	
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_coll_QueryProperties" type="ObjectArray"/>
        <Parameter name="_coll_XTABElement" type="ObjectArray"/>
        <Parameter name="_coll_PropertyNames" type="StringArray"/>
        <Parameter name="_values" type="StringArray" usage="input"/>
        <Parameter name="_emptyValue" type="String"/>
        <Parameter name="_dummy" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getValuesForSnapshotFields" id="a2dfc778-f888-4884-ae08-4317c194add5">
        <source>getValuesForSnapshotFields(_snapshot :CM_DynamicObject_Snapshot; _coll_XTABElement : ObjectArray; _values : ObjectArray input) protected;
// ---------------------------------------------------------------------------
// Created:     10 December 2009 by cnwcs5:1
// Purpose:     ccms 1023 - snapshot summaries   
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	obj		:Object;
	field	:CM_SnapshotField;
begin
	foreach obj in _coll_XTABElement do
		_values.add (_snapshot.findSnapshotField (obj.CM_XTABField));	// could be null
	endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_snapshot" type="CM_DynamicObject_Snapshot"/>
        <Parameter name="_coll_XTABElement" type="ObjectArray"/>
        <Parameter name="_values" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getValuesForSummary" id="85872161-1613-40bd-8319-9a9951c20856">
        <source>getValuesForSummary(_level :Integer; _values :StringArray; _summaryValues :StringArray input)protected;
// ---------------------------------------------------------------------------
// Created:     25 November 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
//				Clear out row values except the one being summarised
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	format					:CM_OutputFormat_XTAB;
	int, numTabs, numRows 	:Integer;
begin
	format	:= self.myOutputFormat_XTAB;
	numTabs	:= format.allTabs.size;
	numRows	:= format.allRows.size;
	
	_summaryValues.clear;
	_values.copy (_summaryValues);
	
	foreach int in (numTabs + 1) to numTabs + numRows do	// first row to last row
		if int &lt;&gt; (numTabs + _level) then
			_summaryValues[int] := self.Empty_Property_Key_Value;
		endif;
	endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_level" type="Integer"/>
        <Parameter name="_values" type="StringArray"/>
        <Parameter name="_summaryValues" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="handleException1035" id="5c80db04-d899-4d7f-9c66-1e90230ffd11">
        <source>handleException1035( ex : Exception; _error1035 : Boolean output ) : Integer protected;
// ---------------------------------------------------------------------------
// Created:     11 December 2008 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if ex.errorCode = 1035 then		// String too long
		_error1035	:= true;	// Use this in the arming method.
		return Ex_Resume_Next;	// Passes control back to the method that armed the exception handler.
	endif;
	
	return Ex_Pass_Back;	// Pass control back to the prior local/global exception handler for any other exceptions.
	
epilog

end;
</source>
        <access>protected</access>
        <Parameter name="ex" type="Exception"/>
        <Parameter name="_error1035" type="Boolean" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleException14045" id="2001a17c-afe1-4901-bd90-062dd330af94">
        <source>handleException14045( _exception : Exception; _error14045 : Boolean output ) : Integer protected;

/*

Purpose:		This exception handler will trap UE 14045 - Invalid or invisible sheet requested
				This is usually caused here if attempt to set up a display table with more than 63 sheets.
Parameters:		The exception object
Return Value:	_error14045 will be set to true if this error occurs.

Date				Who		Reason
07 January 2009		cnwrl1	Initial creation (CCMS SFW 1047 - Totals Only Lists)

*/
	
vars
	
begin
	if _exception.errorCode = 14045 then		// Invalid or invisible sheet requested
		_error14045	:= true;	// Use this in the arming method.
		return Ex_Resume_Next;	// Passes control back to the method that armed the exception handler.
	endif;
	
	return Ex_Pass_Back;		// Pass control back to the prior local/global exception handler for any other exceptions.
	
epilog
	
end;
</source>
        <access>protected</access>
        <Parameter name="_exception" type="Exception"/>
        <Parameter name="_error14045" type="Boolean" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleException14048" id="2271d364-b029-4af5-bd43-5076217cad2f">
        <source>handleException14048( _exception : Exception; _error14048 : Boolean output ) : Integer protected;

/*

Purpose:		This exception handler will trap UE 14048 - Invalid number of columns set for Table
				This is usually caused here if attempt to set up a display table with more than 16,000 tables.
Parameters:		The exception object
Return Value:	_error14048 will be set to true if this error occurs.

Date				Who		Reason
11 February 2009	cnwrl1	Initial creation (CCMS SFW 1047 - Totals Only Lists)

*/
	
vars
	
begin
	if _exception.errorCode = 14048 then		// Invalid or invisible sheet requested
		_error14048	:= true;	// Use this in the arming method.
		return Ex_Resume_Next;	// Passes control back to the method that armed the exception handler.
	endif;
	
	return Ex_Pass_Back;		// Pass control back to the prior local/global exception handler for any other exceptions.
	
epilog
	
end;
</source>
        <access>protected</access>
        <Parameter name="_exception" type="Exception"/>
        <Parameter name="_error14048" type="Boolean" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleException14050" id="c38dbdb1-d78f-4763-a4c1-33e26b8088ae">
        <source>handleException14050( _exception : Exception; _error14050 : Boolean output ) : Integer protected;

/*

Purpose:		This exception handler will trap UE 14050 - Invalid table column
				This error is returned if an attempt is made to set the value of the current column for the current
				sheet outside the range 1 through the value of the columns property.
Parameters:		The exception object
Return Value:	_error14050 will be set to true if this error occurs.

Date				Who		Reason
05 March 2009		cnwrl1	Initial creation (CCMS SFW 1047 - Totals Only Lists)

*/
	
vars
	
begin
	if _exception.errorCode = 14050 then		// Invalid table column
		_error14050	:= true;	// Use this in the arming method.
		return Ex_Resume_Next;	// Passes control back to the method that armed the exception handler.
	endif;
	
	return Ex_Pass_Back;		// Pass control back to the prior local/global exception handler for any other exceptions.
	
epilog
	
end;
</source>
        <access>protected</access>
        <Parameter name="_exception" type="Exception"/>
        <Parameter name="_error14050" type="Boolean" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleInvalidPropertyException" id="848e6ce4-4e81-4fb7-872d-fd2f3e5ddef5">
        <source>handleInvalidPropertyException( _exception : Exception; strValue : String output ) : Integer protected;
// ---------------------------------------------------------------------------
// Created:     03 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if _exception.errorCode &lt;&gt; 1011 then	// The requested property is not defined for this object class
//	if _exception.errorCode &lt;&gt; 1011 and _exception.errorCode &lt;&gt; 1010 then
		return Ex_Pass_Back;	// Pass control back to the prior local/global exception handler for any other exceptions.
	endif;
	
	// requested property not valid for objects class just treat it as an empty value
	strValue := self.Empty_Property_Key_Value;
	
	return Ex_Resume_Next;	// Passes control back to the method that armed the exception handler
	
epilog

end;
</source>
        <access>protected</access>
        <Parameter name="_exception" type="Exception"/>
        <Parameter name="strValue" type="String" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="isColumnDescending" id="b6789bb3-9c4e-468a-aa5b-1b5bf70ee269">
        <source>isColumnDescending(_index :Integer):Boolean protected;
// ---------------------------------------------------------------------------
// Created:     25 November 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	return self.myOutputFormat_XTAB.allColumns [_index].descending;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_index" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isRowDescending" id="612752b4-db0e-4d96-8187-4ef0cb69650e">
        <source>isRowDescending(_index :Integer):Boolean protected;
// ---------------------------------------------------------------------------
// Created:     25 November 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	return self.myOutputFormat_XTAB.allRows [_index].descending;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_index" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="keyHeading_to_indexGrouping" id="1c413cac-f843-48ad-a974-4356c71e89d4">
        <source>keyHeading_to_indexGrouping(_key :Integer):Integer protected;
// ---------------------------------------------------------------------------
// Created:     16 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
//				Convert key number in heading dynadictionary to index of corresponding tab/row/col
//				in allGroupingProperties
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	format						:CM_OutputFormat_XTAB;
	numTabs, numRows, numCols	:Integer;
begin
	format	:= self.myOutputFormat_XTAB;
	numTabs := format.allTabs.size;
	numRows	:= format.allRows.size;
	numCols	:= format.allColumns.size;
	
	if _key = 0 then
		return -1;
	endif;
	
	if _key &lt;= numTabs then
		return _key;
	endif;
	
	if numCols = 0 then
		return -1;	// dummy column
	endif;
	
	return _key + numRows;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_key" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="keyValue_to_DisplayValue" id="0d7e93ad-7b58-4541-a774-4e63b8b0ecb3">
        <source>keyValue_to_DisplayValue(_value :String):String protected;
// ---------------------------------------------------------------------------
// Created:     18 February 2010 by cnwcs5
// Purpose:     Convert key value to display value
// Parameters:  
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 26/07/2010 	cnwcs5 		ccms 1156 / par 23706 - new date/time property
// ---------------------------------------------------------------------------
vars

begin
	if _value = self.Total_Heading_Acsending or
		_value = self.Total_Heading_Descending then	
		// note this is hardly ever used as calling methods usually handle
		// this value differently
		return self.Default_Total_Heading;
	elseif _value = self.Empty_Property_Key_Value then
		return self.Empty_Property_Text;
	elseif _value.startsWith (self.Date_Key_Prefix) then	
		return self.getDisplayDateFromKeyValue (_value);
	elseif _value.startsWith (self.DateTime_Key_Prefix) then	// 26/07/2010 cnwcs5 ccms 1156 / par 23706
		return self.getDisplayDateTimeFromKeyValue (_value);	// 26/07/2010 cnwcs5 ccms 1156 / par 23706
	elseif _value.startsWith (self.True_Property_Key_Value) or
			_value.startsWith (self.False_Property_Key_Value) then
		return self.getDisplayBooleanFromKey_Short (_value);
	endif;

	return _value;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_value" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="keyXTAB_to_indexGrouping" id="152a4093-a969-473d-bc46-c3348b1615c2">
        <source>keyXTAB_to_indexGrouping(_key :Integer):Integer protected;
// ---------------------------------------------------------------------------
// Created:     16 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
//				Convert key number in XTAB dynadictionary to index of corresponding tab/row/col
//				in allGroupingProperties
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	format						:CM_OutputFormat_XTAB;
	numTabs, numRows, numCols	:Integer;
begin
	format	:= self.myOutputFormat_XTAB;
	numTabs := format.allTabs.size;
	numRows	:= format.allRows.size;
	numCols	:= format.allColumns.size;
	
	if numTabs &gt; 0 then
		if _key &lt;= numTabs then
			return _key;
		endif;
	endif;
	
	if _key = numTabs + 1 then
		// summary level key
		return -1;
	endif;
	
	if _key &gt; (numTabs + 1) then
		// its a row/col
		if numRows = 0 then
			if _key = numTabs + 2 then
				// dummy row
				return -1;
			else
				if numCols = 0 and _key = numTabs + 3 then
					// dummy column
					return -1;
				endif;
				return _key - 2;	// extra summary/dummy row keys
			endif;
		else
			// we have rows
			if numCols = 0 and _key = (numTabs + 1 + numRows + 1) then
				// dummy column
				return -1;
			endif;
		endif;
	endif;
	
	return _key -1;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_key" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="makeBooleanKeyValue" id="2de43fb1-02b9-4680-9439-4c034a4d4fde">
        <source>makeBooleanKeyValue(_value :Boolean; _property :CM_QueryProperty):String protected;
// ---------------------------------------------------------------------------
// Created:     22 February 2010 by cnwcs5
// Purpose:     ccms 1028 - Manufacture a key value for a boolean value
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if _value then
		return self.True_Property_Key_Value &amp; _property.niceName;
	else
		return self.False_Property_Key_Value &amp; _property.niceName;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_value" type="Boolean"/>
        <Parameter name="_property" type="CM_QueryProperty"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeDateKeyValue" id="575bcfa9-e742-4463-8c12-2ccde370c4dd">
        <source>makeDateKeyValue(_date :Date):String protected;
// ---------------------------------------------------------------------------
// Created:     12 February 2010 by cnwcs5
// Purpose:     CCMS 1925 / PAR 22295 Release Summaries
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 02/09/2010	cnwmh5		#25584 - Don't want invalid dates to stop XTAB so
//							if invalid set to null
// ---------------------------------------------------------------------------

vars
	str	:String;
	date	: Date;
begin
	date := _date;
	if not date.isValid() then
		date := null;
	endif;
	
	str := self.Date_Key_Prefix &amp; date.Integer.String.padLeadingZeros ( 8 );	// 8 is arbitrary value that will handle any 4 digit year
	//str := self.Date_Key_Prefix &amp; _date.Integer.String.padLeadingZeros ( 8 );	// 8 is arbitrary value that will handel any 4 digit year
	
	return str;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_date" type="Date"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeDateTimeKeyValue" id="efc1fc12-8293-4d59-af67-9ecd41a60437">
        <source>makeDateTimeKeyValue(_ts :TimeStamp):String protected;
// ---------------------------------------------------------------------------
// Created:     26 July 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 02/09/2010	cnwmh5		#25584 - Don't want invalid timestamps to stop XTAB so
//							if invalid set to null
// ---------------------------------------------------------------------------
vars
	str	:String;
	ts 	: TimeStamp;
begin 
	ts := _ts;
	if not ts.date.isValid() then
		ts.setDate(null);
	elseif not ts.time.isValid() then
		ts.setTime(null);
	elseif not ts.isValid() then
		ts := null;
	endif;
	
	str := self.DateTime_Key_Prefix &amp; 
			ts.Date.Integer.String.padLeadingZeros ( 8 ) &amp;	// 8 is arbitrary value that will handle any 4 digit year
			ts.time.asStringJMT ;
	/*
	str := self.DateTime_Key_Prefix &amp; 
			_ts.Date.Integer.String.padLeadingZeros ( 8 ) &amp;	// 8 is arbitrary value that will handle any 4 digit year
			_ts.time.asStringJMT ;	
	*/
	
	return str;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ts" type="TimeStamp"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="padLeadingZeros" id="808c4d4f-93ef-4bae-9357-593ee54bba30">
        <source>padLeadingZeros(_value :String io; _property :CM_QueryProperty)protected;
// ---------------------------------------------------------------------------
// Created:     11 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 08/11/2010	cnwcs5		par26254 - handle negative numbers correctly
// ---------------------------------------------------------------------------
constants
	MINUS_SIGN = '-';												// 08/11/2010 cnwcs5 par26254 
vars
	length		:Integer;
	isNegative	:Boolean;											// 08/11/2010 cnwcs5 par26254 
begin
	length 		:= _property.getKeyLengthForXTABDictionary;			
	isNegative	:= _value.length &gt; 1 and _value[1] = MINUS_SIGN;	// 08/11/2010 cnwcs5 par26254 
	
	// get the number part without the minus sign if we are going to need to pad it out
	if isNegative and _value.length &lt; length then					// 08/11/2010 cnwcs5 par26254 
		_value := _value[2:end];									// 08/11/2010 cnwcs5 par26254 
	endif;															// 08/11/2010 cnwcs5 par26254 
	
	if _value.length &lt; length then
		_value 		:= _value.padLeadingZeros (length);
		// add back the minus sign
		if isNegative then											// 08/11/2010 cnwcs5 par26254 
			_value[1]	:= MINUS_SIGN; 								// 08/11/2010 cnwcs5 par26254 		
		endif;														// 08/11/2010 cnwcs5 par26254 
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_value" type="String" usage="io"/>
        <Parameter name="_property" type="CM_QueryProperty"/>
    </JadeMethod>
    <JadeMethod name="positionIterator" id="52abcfd8-1c15-46b4-a536-84d4878ad039">
        <source>positionIterator(
	_iter		: Iterator;
	_tabKeys	: StringArray;
	_numTabs	: Integer;
	_numRows	: Integer;
	_numCols	: Integer ) protected;

// ---------------------------------------------------------------------------
// Created:     09 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 03/12/2009	cnwcs5		par 21848 - use -1 as level key value instead  of 0
// ---------------------------------------------------------------------------
vars
	size	: Integer;
	
begin
	size := _numTabs;
	
	if _numRows &gt; 0 then
		size := size + _numRows; 
	else
		size := size + 1;	// dummy entry if no row groupings
	endif;
	
	if _numCols &gt; 0 then
		size := size + _numCols;
	else
		size := size + 1;	// dummy entry for no col groupings
	endif;
	
	// pad out array so it is size expected by startKeyGTR_XTAB
	if _tabKeys.size &lt; size then
		_tabKeys[ size ]	:= null;
	endif;
	
	self.allXTABData.startKeyGTR_XTAB( -1, _tabKeys, _iter );	// par 21848 03/12/2009 cnwcs5
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_iter" type="Iterator"/>
        <Parameter name="_tabKeys" type="StringArray"/>
        <Parameter name="_numTabs" type="Integer"/>
        <Parameter name="_numRows" type="Integer"/>
        <Parameter name="_numCols" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="saveLastValues" id="d4dffe6d-1a8c-41ae-bd28-2f11896638c3">
        <source>saveLastValues(_lastArray, _array :StringArray io)protected;
// ---------------------------------------------------------------------------
// Created:     09 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
//				Saves off last set of array values
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 17/12 2009	cnwcs5		swap references rather than copy contents (a bit faster)
// ---------------------------------------------------------------------------
vars
	obj	:StringArray;
begin
	// just swap reference
	obj 		:= _lastArray;
	_lastArray	:= _array;
	_array		:= obj;
	
	_array.clear;
	return;
	
	_lastArray.clear;	
	_array.copy (_lastArray);	
	_array.clear;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_lastArray" type="StringArray" usage="io"/>
        <Parameter name="_array" type="StringArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setHideRepeatedRowValues" id="e923f622-fcb0-4507-9c35-ba0431289bf8">
        <updating/>
        <source>setHideRepeatedRowValues(_value :Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     26 July 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 							ccms 1156/ par23706
// ---------------------------------------------------------------------------
vars
	agent	:CMIF_OutputFormatAgent_XTAB;
begin
	self.hideRepeatedRowValues	:= _value;
epilog

end;</source>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setup" id="11d76571-73e6-471a-931a-107f993fefb3">
        <updating/>
        <source>setup( _format : CM_OutputFormat_XTAB ) : Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     20 November 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 21/01/2009	cnwrl1		Handle UE causing errors (CCMS SFW 1047 - Totals Only Lists)
// 01/12/2009	cnwcs5		ccms 1028 - changes to mappings
// ---------------------------------------------------------------------------
vars
	row				: CM_XTABGrouping;
	col				: CM_XTABGrouping;
	tab				: CM_XTABGrouping;
	field			: CM_XTABField;
	property		: CM_QueryProperty;
	
begin
	self.allXTABData.purge;
	self.allFieldPropertyNames.clear;
	self.allGroupingMappings.clear;	// cnwcs5 - 01/12/2009
	self.allGroupingQueryProperties.clear;
	self.allFieldQueryProperties.clear;
	self.allColQueryProperties.clear;
	self.allRowQueryProperties.clear;
	self.allTabQueryProperties.clear;
	self.allColPropertyNames.clear;	// cnwcs5 10/12/2009
	self.allRowPropertyNames.clear;	// cnwcs5 10/12/2009
	self.allTabPropertyNames.clear;	// cnwcs5 10/12/2009
	self.allFieldHeadings.clear;
	self.allSummarisedRows.clear;
	self.allXTABData_ColumnHeadings.clear;
	self.myOutputFormat_XTAB	:= null;
	
	foreach tab in _format.allTabs do
		property	:= tab.getQueryProperty;
//		if property = null then		Causes UE 1300 if a null entry is not added to the header.
//			// not valid so just ignore it
//			continue;		
//		endif;
		self.allTabPropertyNames.add( tab.propertyName );
		self.allGroupingMappings.add (tab.myXTABMapping);	// cnwcs5 - 01/12/2009
		self.allTabQueryProperties.add( property );
		self.allGroupingQueryProperties.add( property );
	endforeach;
	
	foreach row in _format.allRows do
		property	:= row.getQueryProperty;
//		if property = null then		Causes UE 1300 if a null entry is not added to the header.
//			// not valid so just ignore it
//			continue;		
//		endif;
		self.allRowPropertyNames.add( row.propertyName );
		self.allGroupingMappings.add (row.myXTABMapping);	// cnwcs5 - 01/12/2009
		self.allRowQueryProperties.add( property );
		self.allGroupingQueryProperties.add( property );
		
		if row.includeSummary then
			self.allSummarisedRows.add( _format.allRows.indexOf( row ) );
		endif;
	endforeach;
	
	foreach col in _format.allColumns do
		property	:= col.getQueryProperty;
//		if property = null then		Causes UE 1300 if a null entry is not added to the header.
//			// not valid so just ignore it
//			continue;		
//		endif;
		self.allColPropertyNames.add( col.propertyName );
		self.allGroupingMappings.add (col.myXTABMapping);	// cnwcs5 - 01/12/2009
		self.allColQueryProperties.add( property );
		self.allGroupingQueryProperties.add( property );
	endforeach;
	
	foreach field in _format.allFields do
		property	:= field.getQueryProperty;
//		if property = null then		Causes UE 1300 if a null entry is not added to the header.
//			// not valid so just ignore it
//			continue;		
//		endif;
		self.allFieldPropertyNames.add( field.propertyName );
		self.allFieldQueryProperties.add( property );
		self.allFieldHeadings.add( field.getHeading );
	endforeach;
	
	// we maintain two dynaDictionary's to store our working data for the XTAB
	// one for all of the fields and one for the heading fields.mui_
	if not self.allXTABData.setup_XTAB( _format ) then
		return false;
	endif;
	
	if not _format.allTabs.isEmpty or not _format.allColumns.isEmpty then
		if not self.allXTABData_ColumnHeadings.setup_Headings( _format ) then
			return false;
		endif;
	endif;
	
	self.myOutputFormat_XTAB	:= _format;
	
	return true;
	
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_format" type="CM_OutputFormat_XTAB"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="trimLeadingZeros" id="5d4505db-cf47-4384-893f-7e8a7e068487">
        <source>trimLeadingZeros(_index :Integer; _value :String io)protected;
// ---------------------------------------------------------------------------
// Created:     11 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
//				trim any leading zeros that have been added to a numeric property value
// Parameters:  _index - index of grouping property in self.allGroupingQueryProperties
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/08/2014	cnwdap1		PAR #33235 Measurement Types in Summaries
// ---------------------------------------------------------------------------
vars
	property	:CM_QueryProperty;
	valueIsMeasure : Boolean;				// PAR #33235
	pos : Integer;							// PAR #33235
	
begin
	if _index = -1 or
		_value = self.Empty_Property_Key_Value or
		_value = self.Total_Heading_Acsending or
		_value = self.Total_Heading_Descending or
		_value = self.Dummy_Detail_Value then
		return;
	endif;
	
	pos := _value.pos(Space, 1);																// PAR #33235
	if pos &lt;&gt; null then																			// PAR #33235
		valueIsMeasure := app.myRoot.allMeasurementTypesByShortName[_value[pos+1:end]] &lt;&gt; null;	// PAR #33235
	endif;																						// PAR #33235
	
	if not _value.isInteger and 
		not _value.isInteger64 and
		not _value.isReal and
		//not _value.isDecimal then																// PAR #33235
		not _value.isDecimal and																// PAR #33235
		not valueIsMeasure then																	// PAR #33235
		return;
	endif;
	
	property := self.allGroupingQueryProperties[_index].CM_QueryProperty;
	
	if property &lt;&gt; null and property.getSortType = Table.SortType_Numeric then
		if valueIsMeasure then																	// PAR #33235
			_value := _value.cnTrimLeadingZeros();												// PAR #33235
			if not _value[1:1].isInteger then													// PAR #33235
				_value := "0" &amp; _value;															// PAR #33235
			endif;																				// PAR #33235
		else																					// PAR #33235
			_value := _value.Decimal.String;
		endif;																					// PAR #33235
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_index" type="Integer"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="updateProgress" id="41f0fd4d-df2d-438e-870a-9966a76cab62">
        <source>updateProgress(_cmifMonitor : CMIF_Monitor input; _nextMonitorUpdateTime : Integer io) : Boolean protected;
/* ---------------------------------------------------------------------------
Created:     26 February 2009 by cnwrs2

Purpose:     updates progress and returns false if user has pressed cancel
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars
	now		: Integer;
begin

	if _cmifMonitor = null then
		return true;
	endif;
	
	_cmifMonitor.partsDone := _cmifMonitor.partsDone + 1;

	now := app.clock;
	
	if now &gt; _nextMonitorUpdateTime then
		if not _cmifMonitor.updateProgress(_cmifMonitor.message,
								_cmifMonitor.partsInJob,
								_cmifMonitor.partsDone) then
			return false;
		endif;
   
		_nextMonitorUpdateTime := now + 500;		// update every 500 ms
	endif;
	
	return true;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="input"/>
        <Parameter name="_nextMonitorUpdateTime" type="Integer" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateXTABEntry" id="0ed366cb-edcb-4478-a559-c2f4d4692653">
        <source>updateXTABEntry(
	_summaryLevel	: Integer;
	_grpValues		: StringArray;
	_fieldValues	: Array;
	_rowLevel		: Integer;
	_colLevel		: Integer;
	_obj			: Object ) protected;
	
// ---------------------------------------------------------------------------
// Created:     20 November 2008 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	grouping			: CMIF_OutputGrouping;
	tabLevel			: Integer;
	
begin
	grouping 	:= self.allXTABData.getEntry_XTAB( _summaryLevel, _grpValues );
	tabLevel	:= self.myOutputFormat_XTAB.allTabs.size;
	
	if tabLevel = 0 then
		tabLevel := 1;	//detail (0 means grand Total)
	endif;
	
	if grouping = null then
		grouping := self.createXTABEntry( _summaryLevel, _grpValues, _rowLevel, _colLevel, tabLevel );
		// when we create a new grouping we also need to check to see if all the
		// total groupings have been created and then link them to the detail grouping
		grouping.myColTotalEntry	:= self.getNextColTotal( grouping, _grpValues );
		grouping.myRowTotalEntry	:= self.getNextRowTotal( grouping, _grpValues );
		grouping.myTabTotalEntry	:= self.getNextTabTotal( grouping, _grpValues );
	endif;
	
	// update the summary (field) values
	grouping.updateSelf( self.myOutputFormat_XTAB, _fieldValues, _obj );
	
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_summaryLevel" type="Integer"/>
        <Parameter name="_grpValues" type="StringArray"/>
        <Parameter name="_fieldValues" type="Array"/>
        <Parameter name="_rowLevel" type="Integer"/>
        <Parameter name="_colLevel" type="Integer"/>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
</Class>
