    <JadeMethod name="standardReleaseManual" id="e6a52f4b-371d-47f5-bd6c-e687e6d9bf2f">
        <updating/>
        <source>standardReleaseManual(pController: CnEcReleaseController) updating;
// ---------------------------------------------------------------------------
// Created:     13 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
// CALLED VIA A SCRIPT FOR WORKSPACE

vars
	str 			: String;
begin

	
	app.initialize();
	pController.logEntry('***** Processing standard release for ' &amp; class.name &amp; '... *****');

	pController.logEntry('&gt;&gt;&gt;&gt; Loading Error Messages');

	// RBarr - replaced default message (CM_Root.allErrorMessages) with messages on default locale
	// app.myRoot.loadErrMsgsFromGlbConstants();

	//CNWTH2 resetting terminology type objects must be done twice
	//first time to build any new ones, second time for after the entTableRows
	//are rebuilt
	pController.logEntry('&gt;&gt;&gt;&gt; Resetting terminology objects for create');
	self.resetTerminologyTypes();
		
	pController.logEntry('&gt;&gt;&gt;&gt; Loading EntTable Details');
	str := self.loadEntTableDetails();
	if str.length &gt; 0 then
		pController.logEntry('&gt;&gt;&gt;&gt; ' &amp; str);
		if str = 'Fatal Error' then
			app.raiseCMException1(PortSchemaReleaseError, 'Error Loading EntTable Details', null, null);
		endif;
	endif;

	pController.logEntry('&gt;&gt;&gt;&gt; Resetting terminology objects for update');
	self.resetTerminologyTypes();
	
	//load graphics and toolbar icons
	pController.logEntry('&gt;&gt;&gt;&gt; Loading Graphics and Icons');
	app.loadIcons();

	//Should force a refresh for all users so the above icons are loaded in including CM_MenuToolBar objects.	
	pController.logEntry('&gt;&gt;&gt;&gt; Loading Menus');
	self.resetAllJMTMenus();
	
	pController.logEntry('Creating qryReport default filter objects');	
	self.createQryReportFilterObjects(pController);
		
	pController.logEntry('&gt;&gt;&gt;&gt; Reset Root Security Roles');
	self.resetRootSecurityRoles();
	
	// Added by David 7/11/05
	// BEHAVIOUR TYPE FUNCTIONALITY
//	pController.logEntry('&gt;&gt;&gt;&gt; Reset TI Behaviour Types');
//	self.createTIBehaviourTypes();
	
	pController.logEntry('&gt;&gt;&gt;&gt; Reset Cargo Types');
	self.resetCargoTypes();
	
	pController.logEntry('&gt;&gt;&gt;&gt; Reset Terminal Area Types');
	self.resetTerminalAreaTypes();
	
	pController.logEntry('&gt;&gt;&gt;&gt; Reset Handling Types');
	self.resetHandlingTypes();

	pController.logEntry('&gt;&gt;&gt;&gt; Reset Trx Trans Types');
	self.resetTrxTypes();

	pController.logEntry('&gt;&gt;&gt;&gt; Resetting Audit Class/Properties');
	self.resetAuditedClassProperties();
	
	pController.logEntry('&gt;&gt;&gt;&gt; Creating query menu Root if null');
	self.createQueryMenuRoot();

	pController.logEntry('&gt;&gt;&gt;&gt; Creating query definition objects for selector');
	app.myRoot.createQueryDefinitionObjects();

	pController.logEntry('Loading side profile graphic');
	self.loadSideProfileGraphic(); // AKB Added

	pController.logEntry('&gt;&gt;&gt;&gt; Rebuilding master data dump classes and features');
	self.rebuildMasterDataDumpObjs(pController);
	
	pController.logEntry('&gt;&gt;&gt;&gt; Reset terminology types');
	self.resetTerminologyTypes();

	pController.logEntry('&gt;&gt;&gt;&gt; Reset code group types');
	self.resetCodeGroupTypes();
	
	pController.logEntry('&gt;&gt;&gt;&gt; Reset Hook types');
	self.resetHookTypes();
	
	pController.logEntry('&gt;&gt;&gt;&gt;Reset YA Types');
	self.createYATypesStandard();

	pController.logEntry('&gt;&gt;&gt;&gt; Checking EDI Config for all terminals');
	self.createEDIConfigForTerminals();

	pController.logEntry('Set Carrier email defaults for all terminals ...');
	self.setupCarrierEmailDefaults();

	pController.logEntry('&gt;&gt;&gt;&gt; Loading EDI File formats');
	str := self.loadEDIFormats();
	if str.length &gt; 0 then
		pController.logEntry('&gt;&gt;&gt;&gt; ' &amp; str);
		if str = 'Fatal Error' then
			app.raiseCMException1(PortSchemaReleaseError, 'Error Loading EDI File formats', null, null);
		endif;
	endif;

	// ### JIRA 33542 12DEC2024 NAVAB1
	pController.logEntry('&gt;&gt;&gt;&gt; LoadingEWS Types');
	str := self.loadEWSTypes();
	if str.length &gt; 0 then
		pController.logEntry('&gt;&gt;&gt;&gt; ' &amp; str);
		if str = 'Fatal Error' then
			app.raiseCMException1(PortSchemaReleaseError, 'Error Loading EWS Types', null, null);
		endif;
	endif;
	
	//03 Nov 2017	NDL	TFS 7032
	pController.logEntry('&gt;&gt;&gt;&gt; Creating Storage Config Type Objects');
	self.buildStorageConfigTypes();
	

	pController.logEntry('===== Processing standard release for ' &amp; class.name &amp; '... complete');

end;</source>
        <Parameter name="pController" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="updateYATypesDescriptions" id="a01e7f5b-0edc-4953-a066-b7c836e95d1c">
        <source>updateYATypesDescriptions();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 October 2013	cnwndl1	Initial creation	Par 32456

*/

vars

	objArray : ObjectArray;
	yaType : CM_YACriteriaType;
	obj : Object;
	iter : Iterator;
	oldName : String;
	newName : String;
	bank : CM_Bank;
	strArray : StringArray;
	index : Integer;

begin

	create objArray transient;
	CM_YACriteriaType.allInstances( objArray, 0, true );
	
	iter := objArray.createIterator;
	while iter.next( obj ) do
		yaType := obj.CM_YACriteriaType;
		if yaType.description &lt;&gt; yaType.getTypeName then
			oldName := yaType.description;
			newName := yaType.getTypeName;
			foreach bank in CM_Bank.instances do
				// We store these guys in a string array on bank when using cash profrma stuff...
				if bank.allSelectedProformaQueryProps.isEmpty then
					//Not using any.
					continue;
				endif;
				if not bank.allSelectedProformaQueryProps.includes( oldName ) then
					// Not using the one we are changing
					continue;
				endif;
				// We were using this old one - better update it
				//copy the attrib names used by the bank 
				create strArray transient;
				bank.allSelectedProformaQueryProps.copy(strArray);
				//update on the local strArray
				index := strArray.indexOf(oldName);
				if index &lt; 1 or index &gt; strArray.size then
					continue;
				endif;
				strArray[index] := newName;
				//update it on the bank
				beginTransaction;
				bank.setSelectedProformaCriteria(strArray);
				commitTransaction;
				delete strArray;
				
			endforeach;
			
			beginTransaction;
			yaType.setPropertyValue( CM_YACriteriaType::description.name, newName );
			commitTransaction;
			
		endif;
	endwhile;

epilog

	delete objArray;
	delete iter;
	delete strArray;

end;</source>
    </JadeMethod>
    <JadeMethod name="validateReportViews" id="a069b822-e2de-478f-872f-e9e1d8de99d1">
        <source>validateReportViews(_controller : CnEcReleaseController);
/*

Purpose:			Go through all the report views in the system and log any views that are in error

Parameters:			

Return Value:		

Date			Who		Reason
10 October 2019	jlgmd1	Initial creation TFS 46972

*/

vars
	errors 		: HugeStringArray;
	jrwScm		: Schema;
	cls			: Class;
	root		: Object;		// JRDRoot
	dict		: Dictionary;	// JRDReportingViewByNameDict
	view		: Object;		// JRDReportingView
	viewName	: String;
	count		: Integer;
	err			: String;
begin
	create errors transient;
	
	jrwScm := rootSchema.getSchema("JadeReportWriterSchema");
	if jrwScm = null then
		return;
	endif;
	
	cls := jrwScm.getClass("JRDRoot");
	root := cls.firstInstance;
	
	dict := root.getPropertyValue("allReportingViews").Dictionary;
	
	foreach view in dict do
		errors.clear();
		viewName := view.getPropertyValue("name").String;
		count := app.validateJRWView(viewName, errors);
		
		if count &gt; 0 then
			_controller.logEntry('***** View ' &amp; viewName &amp; " has " &amp; count.String &amp; " error(s) *****");
			foreach err in errors do
				_controller.logEntry(err);
			endforeach;
		endif;
	endforeach;
	
epilog
	delete errors;
end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="xHandlerNewRelease" id="3376897b-a92d-453f-9349-22eedadf7d0d">
        <updating/>
        <source>xHandlerNewRelease(pException : Exception; pController: CnEcReleaseController) : Integer updating, protected;
// ---------------------------------------------------------------------------
// Created:     28 January 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
begin

	// need to override the exception handler that is armed in BaseSchema as if it
	// gets a JSS error	then the BaseSchema one has an error as the JSSException
	// is defined in a different schema branch
	if app.isJSSException(pException) then
		pController.logEntry('******************* EXCEPTION *************************');
		pController.logEntry(self.getExceptionDetails(pException));
		pController.logEntry('*******************************************************');
		return Ex_Abort_Action;
	endif;

	return Ex_Pass_Back;
end;</source>
        <access>protected</access>
        <Parameter name="pException" type="Exception"/>
        <Parameter name="pController" type="CnEcReleaseController"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="xmlVoyageGraphicSet" id="167f6c38-e5e6-4120-b9db-d55d699cef73">
        <source>xmlVoyageGraphicSet() protected;
// ---------------------------------------------------------------------------
// Created:		July 2003 By Andrew Bishop cnwab1
//
// Purpose:		Use JS:xmlVoyageGraphicGet to write the current Side Profile Graphics to disk
//				Then use JS:xmlVoyageGraphicChop to output basic jade script to the Output Viewer
//				Then cut and Paste the output from the viewer into xmlVoyageGraphicXML
//				Then this method will set the new graphics into the DB
// ---------------------------------------------------------------------------
vars
	theXML : String;
	theTerminal : CM_Terminal;
	nullVoy : CM_Voyage;

begin
	foreach theTerminal in app.myRoot.allTerminals do	

		nullVoy := theTerminal.getNullVoyage();	
		
		if nullVoy = null then
			app.writeStatement( "No Null Voyage");
			return;
		endif;
	
		theXML := self.xmlVoyageGraphicXML();	
		if nullVoy.myLayoutGraphic	= null then
			nullVoy.createGraphicForNullVoyage();
		endif;
		nullVoy.myLayoutGraphic.setXMLData(theXML);
	endforeach;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="xmlVoyageGraphicXML" id="157a842b-fe45-42ff-949b-b78191921ad8">
        <source>xmlVoyageGraphicXML() : String;
// ---------------------------------------------------------------------------
// Created:		April 2004 By Andrew Bishop cnwab1
//
// Purpose:		use xmlVoyageGraphicChop to chop the XML into many strings and cut and paste the ouput from the write statement into here.
//				this is then called as part of the release load
//
// ---------------------------------------------------------------------------

vars
	theXML : String;
begin
