    <JadeMethod name="createQueryDefinitionObject" id="6dc31335-a379-4343-b5b7-6c8979e3b349">
        <updating/>
        <source>createQueryDefinitionObject(_cargoBOLType : CM_CargoBOLType; _type : Integer; _mode : Integer ) updating, protected;
// ---------------------------------------------------------------------------
// Created:     15 December 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// 14/12/2009	cnwcs5		ccms 1023 - snapshot summaries
// 12/02/2010	cnwcs5		CCMS 1925/PAR 22295 Release Summaries
// 23/05/2013	cnwdap1		PAR #31486 Re-jig of query types to allow for separate "User-Defined Cargo mode" type
// 31/03/2015   cnwma1 		PAR #35889 Error on searching cargo while Road Gate 
// 22 Dec 2022  navhl20 	ChangeRequest 54350:[54269] EUP - VAS Work Orders Selector Query
// 17 Feb 2023	navmv20 TFS 55626 Task 55688: Jade - Selector Query Contracts
// 10 May 2023  navlw1 		ChangeRequest 53902: EUP - VBS MTN - [6] - Selector Query and JRW
vars

	qDef				: CM_QueryDefinition;
	qDefClass			: Class;
	modeDescription		: String;
	
begin

	if _type &gt;= CM_QueryDefinition.BookRef_Query_Type then
		// 24 Nov 2009	NDL	CCMS 1028
		if ( _type = CM_QueryDefinition.BookRef_Query_Type and _mode = CM_QueryDefinition.BookRef_Query_Mode ) then		//  2  &amp;  1
			modeDescription := 'Booking Reference';
			qDefClass := CM_QDefBookingRef;
		elseif ( _type = CM_QueryDefinition.BookRef_Query_Type and _mode = CM_QueryDefinition.BookRefItem_Query_Mode ) then		//  2  &amp;  2
			modeDescription := 'Booking Reference Item';
			qDefClass := CM_QDefBookingRefItem;
		elseif ( _type = CM_QueryDefinition.Release_Query_Type and 			// 12/02/2010 cnwcs5 ccms 1925 / par 22295
				_mode = CM_QueryDefinition.Release_Query_Mode ) then		// 12/02/2010 cnwcs5 ccms 1925 / par 22295		//  3  &amp;  1
			modeDescription := 'Release';									// 12/02/2010 cnwcs5 ccms 1925 / par 22295
			qDefClass := CM_QDefRelease;									// 12/02/2010 cnwcs5 ccms 1925 / par 22295
		elseif ( _type = CM_QueryDefinition.Release_Query_Type and 			// 12/02/2010 cnwcs5 ccms 1925 / par 22295
				_mode = CM_QueryDefinition.ReleaseItem_Query_Mode ) then	// 12/02/2010 cnwcs5 ccms 1925 / par 22295		//  3  &amp;  2
			modeDescription := 'Release Item';								// 12/02/2010 cnwcs5 ccms 1925 / par 22295
			qDefClass := CM_QDefReleaseItem;								// 12/02/2010 cnwcs5 ccms 1925 / par 22295
		//  CCMS 1262 Jan 2012 transaction enquiry and selector queries
		elseif (_type = CM_QueryDefinition.Transaction_Query_Type and _mode = CM_QueryDefinition.CargoTransaction_Query_Mode) then  // 4  &amp;  91
			modeDescription := 'Cargo Transaction';
			qDefClass		:= CM_QDefCargoTransaction;
		elseif (_type = CM_QueryDefinition.Transaction_Query_Type and _mode = CM_QueryDefinition.EventTransaction_Query_Mode) then	 // 4  &amp;  92
			modeDescription := 'Event Transaction';
			qDefClass		:= CM_QDefEventTransaction;
		elseif (_type = CM_QueryDefinition.Transaction_Query_Type and _mode = CM_QueryDefinition.HMSTransaction_Query_Mode) then	 // 4  &amp;  93  
			modeDescription := 'HMS Transaction';
			qDefClass		:= CM_QDefHMSTransaction;
		//Start 22.12.2022 navhl20 #54350[54269]
		elseif (_type = CM_QueryDefinition.Transaction_Query_Type and _mode = CM_QueryDefinition.WorkOrderTrans_Query_Mode) then  // 4  &amp;  94
			modeDescription := 'Work Order Transaction';
			qDefClass		:= CM_QDefWorkOrderTransactions;
		//End 22.12.2022 navhl20 #54350[54269]
		//10.05.2023 navlw1 #53902
		elseif (_type = CM_QueryDefinition.VehicleBookingSlot_Query_Type and _mode = CM_QueryDefinition.VehicleBookingSlot_Query_Mode) then  // 103  &amp;  103
			modeDescription := 'Vehicle Booking';
			qDefClass		:= CM_QDefVehicleBookingSlot;	
		//04 Nov 2019	NDL	TFS 47100
		elseif (_type = CM_QueryDefinition.Transaction_Query_Type and _mode = CM_QueryDefinition.BOLTransaction_Query_Mode) then	 // 4  &amp;  98  
			modeDescription := 'BOL Transaction';
			qDefClass		:= CM_QDefBOLTransaction;
			
		//13 Apr 2021	NDL	TFS 50906
		elseif (_type = CM_QueryDefinition.Transaction_Query_Type and _mode = CM_QueryDefinition.Location_Activity_Query_Mode) then	 // 4  &amp;  88 
			modeDescription := 'Location Activity';
			qDefClass		:= CM_QDefLocationActivity;
			
		//14 May 2014	NDL	Par 34142
		elseif (_type = CM_QueryDefinition.Invoicing_Query_Type and _mode = CM_QueryDefinition.Invoice_Query_Mode) then		// 5  &amp;  97
			modeDescription := 'Invoice';
			qDefClass		:= CM_QDefInvoice;
		elseif (_type = CM_QueryDefinition.Invoicing_Query_Type and _mode = CM_QueryDefinition.InvoiceLine_Query_Mode) then	// 5  &amp;  96 
			modeDescription := 'Invoice Line';
			qDefClass		:= CM_QDefInvoiceLine;
		//17/02/2023 TFS 55626 TASK 55688 - START
		elseif (_type = CM_QueryDefinition.Invoicing_Query_Type and _mode = CM_QueryDefinition.Contract_Query_Mode) then	
			modeDescription := 'Invoice Contract';
			qDefClass		:= CM_QDefContract;
		//17/02/2023 TFS 55626 TASK 55688 - END
		elseif (_type = CM_QueryDefinition.Cash_Query_Type and _mode = CM_QueryDefinition.CashPayment_Query_Mode) then		// 6  &amp;  94  
			modeDescription := 'Cash Payment';
			qDefClass		:= CM_QDefCashPayment;
		elseif (_type = CM_QueryDefinition.Cash_Query_Type and _mode = CM_QueryDefinition.CashReceipt_Query_Mode) then		// 6  &amp;  95 
			modeDescription := 'Cash Receipt';
			qDefClass		:= CM_QDefCashReceipt;
			
		elseif (_type = CM_QueryDefinition.Snapshot_Query_Type and _mode = CM_QueryDefinition.Snapshot_Query_Mode) then		// 99  &amp;  99
			modeDescription := 'Snapshot';
			qDefClass		:= CM_QDef_Snapshot;
		elseif (_type = CM_QueryDefinition.Audit_Query_Type and _mode = CM_QueryDefinition.Audit_Query_Mode) then // TFS 8390		// 33  &amp;  34
			modeDescription := 'Audit Details'; // TFS 8390
			qDefClass		:= CM_QDefAuditObject; // TFS 8390
		else
			// type and mode not coded for.....
			app.raiseUnexpectedProgramError (self.class.name, method.name, 'Invalid type/mode parameters');
			return;
		endif;
	
	else
		if _cargoBOLType = null then
			//mode := 0;
			if _mode = 0 then												// PAR #31486
				modeDescription := 'Tracked Item mode';
				qDefClass := CM_QDefTrackedItem;
			elseif _mode = CM_QueryDefinition.UserDefined_Query_Mode then	// PAR #31486
				modeDescription := 'User-Defined Cargo mode';				// PAR #31486
				qDefClass := CM_QDefBreakBulkGeneric;						// PAR #31486
			//cnwmc5 - 11 Dec 2015 - PAR 37223 - moved the following code to the correct spot..
			elseif _mode = TI_CargoType_Car then							//31/03/2015 cnwma1 PAR #35889
				modeDescription := "Motor Vehicle";
				qDefClass := CM_QDefCar;
			elseif _mode = TI_CargoType_Chassis then					    //31/03/2015 cnwma1 PAR #35889
				modeDescription := "Chassis";
				qDefClass := CM_QDefTILC;
			endif;
		else
			//mode := _cargoBOLType.id;
			modeDescription := _cargoBOLType.description;
			qDefClass := _cargoBOLType.getQueryDefinitionClass();
		endif;
		
	endif;
	
	if qDefClass = null then
		return;
	endif;
	
	if self.allQueryDefinitionObjects.includesKey(_type, _mode) then
		return;
	endif;
	
	create qDef as qDefClass persistent;
	qDef.setModeAndType(_type, _mode);	//23 Nov 2009	NDL	CCMS 1028
	qDef.setDescription(modeDescription);
	qDef.createProperties();
	self.allQueryDefinitionObjects.add(qDef);
	
end;</source>
        <access>protected</access>
        <Parameter name="_cargoBOLType" type="CM_CargoBOLType"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="createQueryDefinitionObjects" id="24a86876-549f-4e79-ab52-bf0c64874f1e">
        <updating/>
        <source>createQueryDefinitionObjects() updating;
// ---------------------------------------------------------------------------
// Created:     15 December 2003	cnwth2
//
// Purpose:     In short: Creates selector stuff
//
//				More specifically:
//				Creates a query definition object for each available selector mode (there
//				is one per system cargoBOLType + 1 for user cargo types) and in doing so
//				creates persistently all the available queryProperty objects pertaining to that mode.
//				When each queryProperty object is created, it in turn creates all valid queryOperation objects
//				pertaining to that property.
//
//				
// ----------   ----------  --------------------------------------------------
// 14/12/2009	cnwcs5	ccms 1023 - snapshot summaries
// 12/02/2010	cnwcs5		CCMS 1925/PAR 22295 Release Summaries
// 23/05/2013	cnwdap1		PAR #31486 Re-jig of query types to point "Break-Bulk mode" at CN_BreakBulk class,
//							and allow a new mode of "User-Defined Cargo mode" which points at CM_BreakBulkGeneric
// 31/03/2015   cnwma1  PAR #35889 Error on searching cargo while Road Gate 
// 22 Dec 2022  navhl20 	ChangeRequest 54350:[54269] EUP - VAS Work Orders Selector Query
// 18 Feb 2023  navmv20     TFS 55649 Task 55689: UI - Selector Query Contracts
// 10 May 2023  navlw1 		ChangeRequest 53902: EUP - VBS MTN - [6] - Selector Query and JRW
vars
	qDef			: CM_QueryDefinition;
	cargoType		: CM_CargoType;
	cargoTypeDict	: CM_CargoTypesByIdDict;
	bolType			: CM_BOLType;
	bolTypeDict		: CM_BOLTypesByIdDict;
	objArray		: ObjectArray;
	type			: Integer;
begin
	
	beginTransaction;
	self.allQueryDefinitionObjects.purge();
	create objArray transient;
	CM_QueryDefinition.allInstances(objArray, null, true);
	objArray.purge();
	commitTransaction;
	
	beginTransaction;
	
	cargoTypeDict := self.allCargoTypesById;
	foreach cargoType in cargoTypeDict do
		if cargoType.id &gt;= BOLType_Max then
			//only user created cargo types from here on - they will all be
			//taken care of with trackedItem mode - created below
			break; 
		endif;
		//24 Nov 2009	NDL	CCMS 1028
		if ( cargoType.id &gt;= BOLType_Min and cargoType.id &lt;= BOLType_Max ) then
			type := CM_QueryDefinition.BOL_Query_Type;
		else
			type := CM_QueryDefinition.TrackedItem_Query_Type;
		endif;
		self.createQueryDefinitionObject(cargoType, type, cargoType.id);
		//cargoType.resetSelectorColumns(false);
	endforeach;
	
	if self.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type, TI_CargoType_Car] = null then
		self.createQueryDefinitionObject(null, CM_QueryDefinition.TrackedItem_Query_Type, TI_CargoType_Car);     //31/03/2015 cnwma1 PAR #35889		//cnwmc5 - 11 Dec 2015 - PAR 37223 - passed params correct way
	endif;
	if self.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type, TI_CargoType_Chassis] = null then
		self.createQueryDefinitionObject(null, CM_QueryDefinition.TrackedItem_Query_Type, TI_CargoType_Chassis); //31/03/2015 cnwma1 PAR #35889		//cnwmc5 - 11 Dec 2015 - PAR 37223 - passed params correct way
	endif;
	
	bolTypeDict := self.allBOLTypes;
	foreach bolType in bolTypeDict do
		if bolType.id &gt;= BOLType_Max then
			break;//this should never happen 
		endif;
		//24 Nov 2009	NDL	CCMS 1028
		if ( bolType.id &gt;= BOLType_Min and bolType.id &lt;= BOLType_Max ) then
			type := CM_QueryDefinition.BOL_Query_Type;
		else
			type := CM_QueryDefinition.TrackedItem_Query_Type;
		endif;
		self.createQueryDefinitionObject(bolType, type, bolType.id);
		//bolType.resetSelectorColumns(false);
	endforeach;
	
	//this creates one for tracked item mode (mode = 0)
	type := CM_QueryDefinition.TrackedItem_Query_Type;
	self.createQueryDefinitionObject(null, type, 0);
	
	// PAR #31486 and one for break-bulk generic mode (mode = 20)								// PAR #31486
	type := CM_QueryDefinition.TrackedItem_Query_Type;											// PAR #31486
	self.createQueryDefinitionObject(null, type, CM_QueryDefinition.UserDefined_Query_Mode);	// PAR #31486
	
	//24 Nov 2009	NDL	CCMS 1028
	//and here we create Booking ref ( type = 2, mode = 1)
	type := CM_QueryDefinition.BookRef_Query_Type;
	self.createQueryDefinitionObject(null, type, CM_QueryDefinition.BookRef_Query_Mode);
	
	//24 Nov 2009	NDL	CCMS 1028
	//and booking ref item ( type = 2, mode = 2)
	type := CM_QueryDefinition.BookRef_Query_Type;
	self.createQueryDefinitionObject(null, type, CM_QueryDefinition.BookRefItem_Query_Mode);
	
	self.createQueryDefinitionObject(null, CM_QueryDefinition.Release_Query_Type, 
									CM_QueryDefinition.Release_Query_Mode);		// 12/02/2010 cnwcs5 CCMS 1925/PAR 22295
	self.createQueryDefinitionObject(null, CM_QueryDefinition.Release_Query_Type, 
									CM_QueryDefinition.ReleaseItem_Query_Mode);	// 12/02/2010 cnwcs5 CCMS 1925/PAR 22295
	
	// 14/12/2009  cnwcs5
	self.createQueryDefinitionObject (null, CM_QueryDefinition.Snapshot_Query_Type, CM_QueryDefinition.Snapshot_Query_Mode); //as requested by andrew,for the time being
	//  CCMS 1262 Jan 2012 transaction enquiry and selector queries	
	self.createQueryDefinitionObject (null, CM_QueryDefinition.Transaction_Query_Type, CM_QueryDefinition.CargoTransaction_Query_Mode);
	self.createQueryDefinitionObject (null, CM_QueryDefinition.Transaction_Query_Type, CM_QueryDefinition.EventTransaction_Query_Mode);
	self.createQueryDefinitionObject (null, CM_QueryDefinition.Transaction_Query_Type, CM_QueryDefinition.HMSTransaction_Query_Mode);
	self.createQueryDefinitionObject (null, CM_QueryDefinition.Transaction_Query_Type, CM_QueryDefinition.BOLTransaction_Query_Mode);	//04 Nov 2019	NDL	TFS 47100
	self.createQueryDefinitionObject (null, CM_QueryDefinition.Transaction_Query_Type, CM_QueryDefinition.Location_Activity_Query_Mode);	//13 Apr 2021	NDL	TFS 50906
	self.createQueryDefinitionObject (null, CM_QueryDefinition.Transaction_Query_Type, CM_QueryDefinition.WorkOrderTrans_Query_Mode);	//22.12.2022 navhl20 #54350[54269]
	
	//14 May 2014	NDL	Par 34142
	self.createQueryDefinitionObject (null, CM_QueryDefinition.Invoicing_Query_Type, CM_QueryDefinition.Invoice_Query_Mode);
	self.createQueryDefinitionObject (null, CM_QueryDefinition.Invoicing_Query_Type, CM_QueryDefinition.InvoiceLine_Query_Mode);
	self.createQueryDefinitionObject (null, CM_QueryDefinition.Invoicing_Query_Type, CM_QueryDefinition.Contract_Query_Mode); // 18/02/2023 navmv20  TFS 55649 Task 55689
	self.createQueryDefinitionObject (null, CM_QueryDefinition.Cash_Query_Type, CM_QueryDefinition.CashPayment_Query_Mode);
	self.createQueryDefinitionObject (null, CM_QueryDefinition.Cash_Query_Type, CM_QueryDefinition.CashReceipt_Query_Mode);
	self.createQueryDefinitionObject (null, CM_QueryDefinition.Audit_Query_Type, CM_QueryDefinition.Audit_Query_Mode); // TFS 8390
	self.createQueryDefinitionObject (null, CM_QueryDefinition.VehicleBookingSlot_Query_Type, CM_QueryDefinition.VehicleBookingSlot_Query_Mode); // 10.05.2023 navlw1 #53902
	
	commitTransaction;
	
	//reset columns - must be different txn block
	beginTransaction;
	foreach cargoType in cargoTypeDict do
		if cargoType.id &gt;= BOLType_Max then
			break; 
		endif;
		cargoType.resetSelectorColumns(false);
	endforeach;
	
	foreach bolType in bolTypeDict do
		if bolType.id &gt;= BOLType_Max then
			break;
		endif;
		bolType.resetSelectorColumns(false);
	endforeach;
	
	if app.myRoot.myQueryMenuRoot &lt;&gt; null then
		//reset the columns for the tracked item query definition (no associated cargoBOLType)
		app.myRoot.myQueryMenuRoot.resetSelectorColumns(false);
		// PAR #31486 and the User-Defined Cargo type query definition (no associated cargoBOLType either)	// PAR #31486
		app.myRoot.myQueryMenuRoot.resetUserSelectorColumns(false);											// PAR #31486
	endif;	
	commitTransaction;
epilog
	delete objArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="createQueryMenuRoot" id="f71d3f1f-cf31-4f75-8e80-208093f79250">
        <updating/>
        <source>createQueryMenuRoot() updating;
// ---------------------------------------------------------------------------
// Created:     16 April 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	create self.myQueryMenuRoot persistent;
	self.myQueryMenuRoot.setPropertyValue('pictureStringButton', P16FolderClosed);
	self.myQueryMenuRoot.setPropertyValue('pictureStringButtonDown', P16FolderOpen);
	self.myQueryMenuRoot.setPropertyValue('heading','User Queries');
end;</source>
    </JadeMethod>
    <JadeMethod name="createRoadProcesses" id="fb05f4e2-61a2-4943-80c3-b0309d7bf467">
        <source>createRoadProcesses() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
22 January 2026	navpw1	Initial creation JIRA: MTN-37041

*/

vars
	pxyRoadProcess			: CM_RoadProcess;
	roadProcess				: CM_RoadProcess;
	terminal				: CM_Terminal;
	securityRoleTerminal	: CM_SecurityRoleTerminal;

begin
	app.writeLog(method.qualifiedName &amp; " Creating Road Process Objects and Setting PmAdmEnterVVR", LogINFO);
	beginTransaction;
	
	// Default process
	if not app.myRoot.allRoadProcesses.isEmpty then
		roadProcess := app.myRoot.allRoadProcesses.getAtKey( CM_RoadProcess.DEFAULT ).CM_RoadProcess;
	endif;
	
	if roadProcess = null then
		create pxyRoadProcess transient;
		pxyRoadProcess.setCode(CM_RoadProcess.DEFAULT);
		pxyRoadProcess.setDescription("MTN Default Road Process");
		
		create roadProcess persistent;
		roadProcess.setForCreate( pxyRoadProcess );
		delete pxyRoadProcess;
		
		foreach terminal in CM_Terminal.instances do
			terminal.setPropertyValue( "myRoadProcess", roadProcess );
		endforeach;
		
		roadProcess := null;	
	endif;
	
	// ASPA Process 
	if not app.myRoot.allRoadProcesses.isEmpty then
		roadProcess := app.myRoot.allRoadProcesses.getAtKey( CM_RoadProcess.ASPA_GCI ).CM_RoadProcess;
	endif;
	
	if roadProcess = null then
		create pxyRoadProcess transient;
		pxyRoadProcess.setCode(CM_RoadProcess.ASPA_GCI);
		pxyRoadProcess.setDescription("ASPA GCI Road Process");
		
		create roadProcess persistent;
		roadProcess.setForCreate( pxyRoadProcess );
		delete pxyRoadProcess;
		
		roadProcess := null;
	endif;
	
	foreach securityRoleTerminal in CM_SecurityRoleTerminal.instances do
		if securityRoleTerminal.permissions.size &lt; PmAdmEnterVVR or not securityRoleTerminal.permissions[PmAdmEnterVVR] then
			securityRoleTerminal.permissions[PmAdmEnterVVR] := true;
		endif;
	endforeach;
	
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Creating Road Process Objects and Setting PmAdmEnterVVR complete", LogINFO);
	
	app.writeLog(method.qualifiedName &amp; " Creating 1-Stop Road Process", LogINFO);
	
	beginTransaction;
	
	if not app.myRoot.allRoadProcesses.isEmpty then
		roadProcess := app.myRoot.allRoadProcesses.getAtKey( CM_RoadProcess.ONESTOP_VBS ).CM_RoadProcess;
	endif;
	
	if roadProcess = null then
		create pxyRoadProcess transient;
		pxyRoadProcess.setCode(CM_RoadProcess.ONESTOP_VBS);
		pxyRoadProcess.setDescription("1-Stop LOLO Voyages");
		
		create roadProcess persistent;
		roadProcess.setForCreate( pxyRoadProcess );
		delete pxyRoadProcess;
	endif;
	
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Creating 1-Stop Road Process complete", LogINFO);
	
epilog
	delete pxyRoadProcess;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="createStatii" id="9a22a892-6745-45ce-8ad2-2e90b0776f7c">
        <source>createStatii() protected;
// ---------------------------------------------------------------------------
// Created:     16 Jan 2002 by cnwrs1
//
// Purpose: Only called from root contructor to create all the valid machine types.    
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 02/05/2022	jlizm1		TFS 53083 GPHA revceival/release of tranship cargo
// ---------------------------------------------------------------------------

vars
	aStatus : CM_ContentsStatus;
	aPStatus : CM_ContentsStatus;
	iStatus : CM_IMEXStatus;
	iPStatus : CM_IMEXStatus;
	tStatus : CM_TransitStatus;
	tPStatus : CM_TransitStatus;
	toCreate : Integer;
	desc : String;
	abbr : String;
begin
// old method used status xml 
// new statii dont have xml so must be done by hand
//	app.processGlobalConstantGroup('PortSchema', 'TIStatusConstant', 'addStatii', self);

	toCreate := TI_CONTENTS_STATUS_FCL;	//Create a new one at some point...
	desc := "Full Container Load";
	abbr := "FCL";
	create aPStatus transient;
	aPStatus.setProxyForNewStructure(toCreate, White, desc, abbr);
	create aStatus persistent;
	aStatus.setForCreate(aPStatus);
	delete aPStatus;
	
	toCreate := TI_CONTENTS_STATUS_LCL;	//Create a new one at some point...
	desc := "Less than Container Load";
	abbr := "LCL";
	create aPStatus transient;
	aPStatus.setProxyForNewStructure(toCreate, White, desc, abbr);
	create aStatus persistent;
	aStatus.setForCreate(aPStatus);
	delete aPStatus;
	
	toCreate := TI_CONTENTS_STATUS_EMPTY;	//Create a new one at some point...
	desc := "Empty";
	abbr := "MT";
	create aPStatus transient;
	aPStatus.setProxyForNewStructure(toCreate, White, desc, abbr);
	create aStatus persistent;
	aStatus.setForCreate(aPStatus);
	delete aPStatus;
	
	toCreate := TI_CONTENTS_STATUS_NULL;	//Create a new one at some point...
	desc := "Unknown Contents Status";
	abbr := null;
	create aPStatus transient;
	aPStatus.setProxyForNewStructure(toCreate, White, desc, abbr);
	create aStatus persistent;
	aStatus.setForCreate(aPStatus);
	delete aPStatus;
	
	//jlier1 TFS 54700 31/8/22
	toCreate := TI_CONTENTS_STATUS_FULLLASHED;	
	desc := "Full Lashed";
	abbr := "FLH";
	create aPStatus transient;
	aPStatus.setProxyForNewStructure(toCreate, White, desc, abbr);
	create aStatus persistent;
	aStatus.setForCreate(aPStatus);
	delete aPStatus;
	
	toCreate := TI_CONTENTS_STATUS_PRTLOADLASH;	
	desc := "Partially Loaded Lashed";
	abbr := "PLL";
	create aPStatus transient;
	aPStatus.setProxyForNewStructure(toCreate, White, desc, abbr);
	create aStatus persistent;
	aStatus.setForCreate(aPStatus);
	delete aPStatus;
	
	toCreate := TI_CONTENTS_STATUS_PRTLOAD;	
	desc := "Partially Loaded";
	abbr := "PLD";
	create aPStatus transient;
	aPStatus.setProxyForNewStructure(toCreate, White, desc, abbr);
	create aStatus persistent;
	aStatus.setForCreate(aPStatus);
	delete aPStatus;
	

	toCreate := TI_IMEX_STATUS_IMPORT;
	desc := "Import";
	abbr := "IMP";
	create iPStatus transient;
	iPStatus.setProxyForNewStructure(toCreate, White, desc, abbr);
	create iStatus persistent;
	iStatus.setForCreate(iPStatus);
	delete iPStatus;
	
	toCreate := TI_IMEX_STATUS_EXPORT;
	desc := "Export";
	abbr := "EXP";
	create iPStatus transient;
	iPStatus.setProxyForNewStructure(toCreate, White, desc, abbr);
	create iStatus persistent;
	iStatus.setForCreate(iPStatus);
	delete iPStatus;
	
	toCreate := TI_IMEX_STATUS_STORAGE;
	desc := "Storage";
	abbr := "STO";
	create iPStatus transient;
	iPStatus.setProxyForNewStructure(toCreate, White, desc, abbr);
	create iStatus persistent;
	iStatus.setForCreate(iPStatus);
	delete iPStatus;
	
	toCreate := TI_IMEX_STATUS_REMAINONBOARD;
	//desc := "In Transit";		// PAR #23645 CCMS 1116
	//abbr := "TRA";			// PAR #23645 CCMS 1116
	desc := "Remain On Board";	// PAR #23645 CCMS 1116
	abbr := "ROB";				// PAR #23645 CCMS 1116
	create iPStatus transient;
	iPStatus.setProxyForNewStructure(toCreate, White, desc, abbr);
	create iStatus persistent;
	iStatus.setForCreate(iPStatus);
	delete iPStatus;
	
	toCreate := TI_IMEX_STATUS_NULL;
	desc := null;
	abbr := null;
	create iPStatus transient;
	iPStatus.setProxyForNewStructure(toCreate, White, desc, abbr);
	create iStatus persistent;
	iStatus.setForCreate(iPStatus);
	delete iPStatus;
	
	// PAR #23645 CCMS 1116 Create Tranship status
	toCreate := TI_IMEX_STATUS_TRANSHIP;
	desc := "Tranship";
	abbr := "TSH";
	create iPStatus transient;
	iPStatus.setProxyForNewStructure(toCreate, White, desc, abbr);
	create iStatus persistent;
	iStatus.setForCreate(iPStatus);
	delete iPStatus;
	
	toCreate := TI_TransitStatusDLR;	//Create a new one at some point...
	desc := "Double Lift Restow";
	abbr := "DLR";
	create tPStatus transient;
	tPStatus.setProxyForNewStructure(toCreate, White, desc, abbr);
	create tStatus persistent;
	tStatus.setForCreate(tPStatus);
	delete tPStatus;
	
	toCreate := TI_TransitStatusSOB;	//Create a new one at some point...
	desc := "Shift On Board";
	abbr := "SOB";
	create tPStatus transient;
	tPStatus.setProxyForNewStructure(toCreate, White, desc, abbr);
	create tStatus persistent;
	tStatus.setForCreate(tPStatus);
	delete tPStatus;
	// TFS 53083
	toCreate := TI_TransitStatusInterModal;
	desc := "Inter-Modal";
	abbr := "INT";
	create tPStatus transient;
	tPStatus.setProxyForNewStructure(toCreate, White, desc, abbr);
	create tStatus persistent;
	tStatus.setForCreate(tPStatus);
	delete tPStatus;
	
	toCreate := TI_IMEX_STATUS_NULL;	//This == 0
	desc := "Unknown Transit";
	abbr := "N/A";
	create tPStatus transient;
	tPStatus.setProxyForNewStructure(toCreate, White, desc, abbr);
	create tStatus persistent;
	tStatus.setForCreate(tPStatus);
	delete tPStatus;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="createSuperuser" id="129d9dac-7461-422b-8cc1-5072921a9261">
        <updating/>
        <source>createSuperuser() updating;

vars
	user,poxyUser:CM_User;
	daDict:CM_DataAccessControllerSet;
	securityRole:CM_SecurityRole;
	daSet:CM_DataAccessControllerSet;
	result:Boolean;
	perms : BooleanArray;
	todoTaskArray:CM_ToDoTaskDescArray;
	passwordBin:Binary;
	securityRoleSys, pxyRole, tmpParent: CM_SecurityRoleSystem;
	availToShip		: Boolean;
	rptDict			: CM_QryReportDict;
	permAgent : CM_PermissionAgent;
	pxyUserTerminal : CM_UserTerminal;
begin
	create daDict transient;
	create poxyUser as CM_User transient;
	poxyUser.setProxy(SUPERUSER_Str, "Super User", 0, null, app.myRoot, true, false, false, false, null, daSet, CM_SecurityRoleSystemRoot.firstInstance, null, app.myRoot.allEmailEntities, app.myRoot.allSystemAlertTypes, app.myRoot.allEventTypesByType, self.getDefaultLocale(true), false, false); //cnwrs1 par 23153 11 Mar 2010
	if app.myPassport.allErrors.size &gt; 0 then
		app.writeStatement("set proxy for user failed");
		app.myPassport.inspect;
	endif;

	app.myUtilityCA.utlCreateUser(poxyUser, "password", user, app.myPassport);
	if app.myPassport.allErrors.size &gt; 0 then
		app.writeStatement( "create user failed");
		app.myPassport.inspect;
	endif;
	
	app.jmtSetSUPW(); // PAR 29802

end;</source>
    </JadeMethod>
    <JadeMethod name="createSystemQuickAccess" id="accb383c-ed58-4d37-9aa1-7693c16302c6">
        <source>createSystemQuickAccess(	_shortCode : String;
							_permissionInteger : Integer;
							_helpDescription : String;
							_isForm : Boolean;
							_allowsOption : Boolean
							):CM_QuickAccessSystem;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 May 2014	cnwndl1	Initial creation

*/

vars

	quickAccess : CM_QuickAccess;
	pxyQuickAccess : CM_QuickAccessSystem;
	load : Boolean;

begin

	quickAccess := app.myRoot.allSystemQuickAccess.getAtKey(_shortCode);

	if quickAccess = null then
		create pxyQuickAccess transient;
		pxyQuickAccess.setProxy(	_helpDescription,	//_helpDescription : String;
									_permissionInteger,	//_permissionInteger : Integer;
									_shortCode,	//_shortCode : String;
									_isForm,	//_isForm : Boolean;
									_allowsOption	//_allowsOption : Boolean
									);						
		app.myTrxCA.trxCreateQuickAccess(pxyQuickAccess, quickAccess, app.myPassport);
		
	else
		app.cmsBeginLoad(load);
		pxyQuickAccess := quickAccess.pxyCreateUpdateProxy().CM_QuickAccessSystem;
		app.cmsEndLoad(load);
		
		pxyQuickAccess.setProxy(	_helpDescription,	//_helpDescription : String;
									_permissionInteger,	//_permissionInteger : Integer;
									_shortCode,	//_shortCode : String;
									_isForm,	//_isForm : Boolean;
									_allowsOption	//_allowsOption : Boolean
									);
									
		app.myTrxUA.trxUpdateQuickAccess(pxyQuickAccess, app.myPassport);
		
	endif;
	
	return quickAccess.CM_QuickAccessSystem;

epilog

	delete pxyQuickAccess;

end;</source>
