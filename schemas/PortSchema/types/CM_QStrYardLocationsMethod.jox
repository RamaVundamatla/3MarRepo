    <JadeMethod name="setComboValues" id="57a40961-5288-4ec0-a94e-9809fe4c6057">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 April 2021	navndl1	Initial creation	TFS 50906

*/

constants
	
vars
	ta : CM_TerminalArea;
	lc : CM_LocationsController;
	tmpTerm : CM_Terminal;
	iter : Iterator;
	lcSet : CM_LCSet;
begin

	_combo.clear;
	
	if app.myPassport = null then
		return;
	endif;
	tmpTerm := app.myPassport.myTerminal;
	if tmpTerm = null then
		return;
	endif;
	
	foreach ta in tmpTerm.allTerminalAreas discreteLock do
		if ta.isKindOf(CM_GeneralCargoAllocRowArea) then	//15 Jun 2021	NDL	TFS 51336
			create lcSet transient;
			ta.CM_GeneralCargoAllocRowArea.getAllRowGroupControllers( lcSet );
		else
			lcSet := ta.getLCSet();
		endif;
		foreach lc in lcSet discreteLock do
			_combo.itemObject[_combo.addItem(lc.getFullId)] := lc;
		endforeach;
		if lcSet &lt;&gt; null and lcSet.isTransient then
			delete lcSet;
		endif;
	endforeach;
	
epilog

	if lcSet &lt;&gt; null and lcSet.isTransient then
		delete lcSet;
	endif;
	
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="c563c045-1ac4-487e-8b72-3793b706cc17">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 April 2021	navndl1	Initial creation	TFS 50906

*/

constants
	
vars
	ta : CM_TerminalArea;
	lc : CM_LocationsController;
	tmpTerm : CM_Terminal;
	iter : Iterator;
	lcSet : CM_LCSet;
	selectionValue	: Boolean;
begin

	_tbl.rows := _tbl.fixedRows;
	
	if app.myPassport = null then
		return;
	endif;
	tmpTerm := app.myPassport.myTerminal;
	if tmpTerm = null then
		return;
	endif;
	
	foreach ta in tmpTerm.allTerminalAreas discreteLock do
		if ta.isKindOf(CM_GeneralCargoAllocRowArea) then	//15 Jun 2021	NDL	TFS 51336
			create lcSet transient;
			ta.CM_GeneralCargoAllocRowArea.getAllRowGroupControllers( lcSet );
		else
			lcSet := ta.getLCSet();
		endif;
		foreach lc in lcSet discreteLock do
		
			selectionValue := false;
			if _operator &lt;&gt; null then
				if _operator &lt;&gt; null and 
				   _operator.CM_QStringIsOneOf.allSelectionValues.includes(lc.getFullId) then
					selectionValue := true;
				endif;
				
				_tbl.accessRow(_tbl.addItem(selectionValue.cnEcGetTableCheckBoxValue &amp; Tab &amp; lc.getFullId)).itemObject := lc;
			endif;
			
			if _tbl.rows &gt;= JadeTableRowLimit then		
				break;
			endif;
		endforeach;
		
		if _tbl.rows &gt;= JadeTableRowLimit then		
			app.msgBox('Maximum number of entries in table exceeded.  Only the first ' &amp; JadeTableRowLimit.String &amp; ' will be shown', 'Error', MsgBox_OK_Only);
			break;
		endif;
			
		if lcSet &lt;&gt; null and lcSet.isTransient then
			delete lcSet;
		endif;
	endforeach;
	
epilog

	if lcSet &lt;&gt; null and lcSet.isTransient then
		delete lcSet;
	endif;
	
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="ea1666aa-5727-4882-83cb-3cbb0da9712f">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

	str : String;
	numRows : Integer;
	idx : Integer;
	lc : CM_LocationsController;
	lcStrArray : StringArray;  

begin

	create lcStrArray transient;
	
	numRows := _tbl.rows;
	foreach idx in (_tbl.fixedRows + 1) to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			lc := _tbl.accessRow(idx).itemObject.CM_LocationsController;
			lcStrArray.add(lc.getFullId);
		endif;
	endforeach;
	
	_op.setSearchValue(lcStrArray);

epilog

	delete lcStrArray;
	
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="cd7445e8-d466-4458-9466-b2acbd26d3fb">
        <source>translateToDisplayValue(_value: Any): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

	lc : CM_LocationsController;

begin
	if _value.isKindOf(CM_LocationsController) then	
		if _value &lt;&gt; null then
			lc := _value.CM_LocationsController;
			return lc.getFullId;
		else
			return null;
		endif;
	endif;
	
	return _value.String;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="a6b2e905-d31b-425b-9f72-c755a24e1fe0">
        <source>translateToSearchValue(_value: Any): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 April 2021	navndl1	Initial creation	TFS 50906

*/

vars
	invalidObj 		: Boolean;
	object			: CM_LocationsController;
	returnVal		: String;
	
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then			
			return _value;
		elseif _value.isKindOf(CM_LocationsController) then
			object := _value.CM_LocationsController;
		elseif _value.isKindOf(String) then
			returnVal := _value.String;
		endif;
	endif;
	
	if object &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, object, invalidObj);
		
		returnVal := object.getFullId;
	endif;
	
	return returnVal;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="afeaa821-086c-4988-a37b-c45db8239a13">
        <source>translateToSearchValueForWeb(_value: Any; _sending: Boolean): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 April 2021	navndl1	Initial creation	TFS	TFS 50906

*/

vars
	pos : Integer;

begin
	if _value.isKindOf(CM_LocationsController) then
		return _value.CM_LocationsController.getFullId;
	elseif _value.isKindOf(String) then
		pos := _value.String.pos(Space, 1);
		if pos &lt;&gt; null then
			return _value.String[1:pos-1];
		else
			return _value.String;
		endif;
	endif;
	
	return inheritMethod(_value, _sending);

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
