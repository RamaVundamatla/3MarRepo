    <JadeMethod name="onRectPaintIC" id="d1f5bce8-d256-4ec4-98e1-568c398650f8">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_CMUI_RectangleHandler::onRectPaint"/>
        </interfaceImplements>
        <source>onRectPaintIC(_rect : CMUI_ResizableRectFrame input);

	/*
		this method stub has been automatically generated by Jade to satisfy interface implementation requirements
	*/
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 February 2010	cnwer1	Initial creation

*/

vars
	x1,
	x2,
	y1,
	y2 : Real;
begin
	if _rect.name = self.frmAssocICArea.name then
		_rect.drawWidth := _rect.thickness;
		if _rect.isSelected then
			_rect.drawStyle := Window.DrawStyle_Dash;
		else
			_rect.drawStyle := Window.DrawStyle_Solid;	
		endif;
		
		x1 := 0;
		x2 := _rect.width;
		y1 := 0;
		y2 := _rect.height;
			
		_rect.drawRectangle(x1, y1, x2, y2, _rect.colour);
	
	
		if not _rect.isInPainter() then
			if _rect.myObject &lt;&gt; null and _rect.myObject.isKindOf(CMIF_YABlock) then
				_rect.drawTextAt(_rect.myObject.CMIF_YABlock.numSlots.String,2,2, _rect.colour);
			endif;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_rect" type="CMUI_ResizableRectFrame" usage="input"/>
    </JadeMethod>
