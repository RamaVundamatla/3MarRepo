    <JadeMethod name="setOperatorCargoReview" id="d27d4962-ccc1-4e5e-bbac-bbb14b95cc0e">
        <source>setOperatorCargoReview();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Aug 2023 navmv20 CR 59440 Task 59441: Jade - Ownership Change Release Request Validation

*/

vars
	detail : CM_OwnershipChangeDetail;
	ti : CM_TrackedItem;
	operator : CM_Operator;
	allowSameOp: Boolean;
	currOp  : CM_Operator;
	idx : Integer;
begin
	allowSameOp :=  self.myTerminal.getConfig(CooSplitOperator).Boolean; // ### TFS BUG 64115 13MAY2024 NAVAB1

	if self.allProxyDetailsForCreate.isNotEmpty then
		detail := self.allProxyDetailsForCreate.first;
		ti := detail.myTrackedItem;
		operator := ti.myOperator;
		self.cmbCurrentOperator.listIndex := self.cmbCurrentOperator.findObject(operator);
		
		// ### TFS BUG 64115 13MAY2024 NAVAB1
		if not allowSameOp then
			self.cmbNewOperator.removeObject(operator);
		endif;
		
		
	endif;
epilog

end;</source>
    </JadeMethod>
