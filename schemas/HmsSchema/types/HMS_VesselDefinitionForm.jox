    <JadeMethod name="tbxShipName_lostFocus" id="8e74b6e7-d582-4319-8dc7-e469ade5228d">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tbxShipName_lostFocus(textbox: TextBox input) updating;

vars
	shipName:	String;
	shipCode:	String;

begin
	if self.myCurrentVessel &lt;&gt; null then
		return;
	endif;
	if tbxShipName.text&lt;&gt;null or tbxShipName.text&lt;&gt;"" then
		// Automatically generate shipCode if it is null once a shipName has been entered.
		if tbxShipCode.text.String.trimBlanks="" or tbxShipCode.text=null then
			// extract a two letter code from the ship name
			shipName:=tbxShipName.text.String.trimBlanks;
			shipCode:=createShipCode(shipName);
			tbxShipCode.text:=shipCode;
		else
			// Regenerate code is shipName has been changed
			if tbxShipCode.text.String.length&gt;=2 then
            	if tbxShipName.text.String.extractXXXCode&lt;&gt;tbxShipCode.text.String[1:2] then
            		// First letters of ship name have changed: Regenerate code
            		shipName:=tbxShipName.text.String.trimBlanks;
					shipCode:=createShipCode(shipName);
					tbxShipCode.text:=shipCode;
            	endif;
			endif;
		endif;
	endif; 
end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="16af971d-7bb1-48de-a3ff-42d1d40f9a3f">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0005970, locale);
	btnAddPrefBerth.translateCaption(Xlat_0001660, locale);
	btnAddResource.translateCaption(Xlat_0001678, locale);
	btnAgentContact.translateCaption(Xlat_0001661, locale);
