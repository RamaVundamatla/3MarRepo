    <JadeMethod name="sortTable" id="bad5faa8-96e0-4efb-a65b-7b58e32e7f34">
        <source>sortTable(_reset : Boolean; _sortedAsc : Boolean io; _tblSortColumn : Integer io) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
11 December 2024	navpw1	Initial creation

*/

vars
	table			: Table;
	tblSortColumn,
	theSortType		: Integer;
	
begin
	table := self.tblResults;
	
	if _reset then
		tblSortColumn := table.sortColumn[1];
		
		if tblSortColumn &gt; 0 then
			table.accessCell(1, tblSortColumn).fontBold := false;
		endif;
		
		table.sortColumn[1] := null;
		_sortedAsc := table.sortAsc[1];
		table.sortCased[1]	:= false;
		table.sortType[1] := null;
		_tblSortColumn := tblSortColumn;
		
		table.sortColumn[2]	:= null;    
		table.sortAsc[2]	:= true;
		table.sortCased[2]	:= false;
		table.sortType[2] := null;
		return;
		
	endif;
	
	//Set sorting column
	table.sortColumn[1]	:= _tblSortColumn;    
	table.sortAsc[1]	:= _sortedAsc;
	table.sortCased[1]	:= false;
	
	if _tblSortColumn= 4 or _tblSortColumn = 9 then
		theSortType :=  Table.SortType_Numeric;
	elseif _tblSortColumn= 5 then
		theSortType :=  Table.SortType_Date;
	elseif _tblSortColumn= 8 then
		theSortType :=  Table.SortType_Time;
	else
		theSortType := Table.SortType_Alpha;
	
	endif;

	table.sortType[1] := theSortType;
	
	
	if _tblSortColumn &lt;&gt; 8 then
		table.sortColumn[2]	:= 8;    
		table.sortAsc[2]	:= true;
		table.sortCased[2]	:= false;
		table.sortType[2]	:= Table.SortType_Time;
	endif;
	
	table.resort;

	table.accessCell(1, table.column).fontBold := true;
	
end;</source>
        <access>protected</access>
        <Parameter name="_reset" type="Boolean"/>
        <Parameter name="_sortedAsc" type="Boolean" usage="io"/>
        <Parameter name="_tblSortColumn" type="Integer" usage="io"/>
    </JadeMethod>
