    <JadeMethod name="displayDebtors" id="03359fd7-3d8b-41e5-afde-d70f3456d217">
        <updating/>
        <source>displayDebtors() updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	path	: String;
	currentPath	: String;
	obj		: Object;
	index	: Integer;
	pathList : CMUI_ListBox;
	paths	: HugeStringArray;
	items	: ObjectArray;

begin
// modePropertyUpdate = 9

	self.doBuildListBoxDebtor(self.myCurrentMapServiceBroker);

	if self.updateMode = self.UpdateMode_Copy then
		pathList := self.lstCopyDebtPath;
		pathList.clear();
		// show the current path
		currentPath := self.myCurrentMapServiceBroker.getPath();
		pathList.itemObject[pathList.addItem(currentPath)] := self.myCurrentMapServiceBroker;
		create paths transient;
		create items transient;
	
		// get and show all other paths to the same level
		//epr par 37335 22/1/16
		if self.myCurrentMapTM &lt;&gt; null then
			self.myCurrentMapTM.getAllPaths(self.myCurrentMapDebtor, paths, items);
		endif;
		foreach path in paths do
			index := index + 1;
			// add a blank line to highlight that  the first line is the current position
			if index = 1 then
				pathList.addItem("");
			endif;
			obj := items[index];
			if obj = self.myCurrentMapServiceBroker then
				continue;
			endif;
			pathList.itemObject[pathList.addItem(path)] := obj;
		endforeach;
		// highlight the current path
		pathList.listIndex := 1;

		//29 Nov 2019	NDL	TFS 47100
		if self.myCurrentMapTMBOL &lt;&gt; null then
			self.myAssistant.comboBoxDebtorType(self.cmbCopyDebtTypes, false, true);
		else
			self.myAssistant.comboBoxDebtorType(self.cmbCopyDebtTypes, false, false);
		endif;
		self.showCopyDebtorsFrame();
	
	else
		//29 Nov 2019	NDL	TFS 47100
		if self.myCurrentMapTMBOL &lt;&gt; null then
			self.myAssistant.comboBoxDebtorType(self.cmbDebtorTypes, false, true);
		else
			self.myAssistant.comboBoxDebtorType(self.cmbDebtorTypes, false, false);
		endif;
		self.showDebtorsFrame();		// 24051
	endif;

epilog
	delete paths;
	delete items;
end;</source>
    </JadeMethod>
