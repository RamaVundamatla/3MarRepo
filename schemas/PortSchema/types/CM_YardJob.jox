    <JadeMethod name="getTIWLE" id="890b434a-22bc-418a-8fea-96ac1f440b83">
        <source>getTIWLE(ti : CM_TrackedItem) : CM_WorkListEntry;
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	wantGhosts : Boolean;
	retVal : CM_WorkListEntry;
	awle : CM_WorkListEntry;
	wle : CM_YardWLE;
	wleTI : CM_TrackedItem;

begin

	if ti = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException(ERR_NO_OBJECT, null, null);
		return null;	
	endif;

	wantGhosts := (ti.state = TI_STATE_GHOST);

	if self.workListEntries.isEmpty then
		return null;	
	endif;

	foreach awle in self.workListEntries do 
		if not awle.isKindOf(CM_YardWLE) then
			continue;
		endif;

		wle := awle.CM_YardWLE;
		
		if (wantGhosts) then
			wleTI := wle.ghostTrackedItem;
		else
			wleTI := wle.myTrackedItem;
		endif;

		//If no TI here, goto next one..
		if (wleTI = null) then
			continue;
		endif;

		//If same, then return
		if ti = wleTI then
			return wle;
		endif;
	endforeach;
	return null;
end;</source>
        <Parameter name="ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="hasReceipt" id="ee228129-010c-4e32-a23f-d43ac08f9f82">
        <source>hasReceipt() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 February 2011	cnwer1	Initial creation

*/

vars
	request : CM_Request;
begin
	foreach request in self.allRequests do
		if request.isKindOf(CM_YardRequest) then
			if request.CM_YardRequest.isReceipt then
				return true;
			endif;
		endif;
	endforeach;
	
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
