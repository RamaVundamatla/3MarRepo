    <JadeMethod name="getDisplayStringForAttribute" id="85e51fd0-9a47-4781-b938-425c84f5a5ec">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     23 July 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	
	if _attrName = ETRow_MyConsignee then
		if self.myConsignee &lt;&gt; null then
			return self.myConsignee.code;
		else
			return null;
		endif;
	
	elseif _attrName = ETRow_TotalTIs then
		return self.getTotalTIs.String;
		
	elseif _attrName = ETRow_MyVessel then
		return self.myVoyage.vesselName;	
	endif;
	
	return inheritMethod(_attrName, _short);

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfoLogVoyOps" id="a12e67f3-d676-4b8c-815e-0c11fd6e956f">
        <source>getExtraInfoLogVoyOps(_array: HugeStringArray input; _terminalForTerminology : CM_Terminal);
//--------------------------------------------------------------
//Created: 07 August 2002 By: cnwgd1
//
//	par 10009 - _terminalForTerminology added to method signature. needed
//	for teminology. is taken from form so terminology will be consistent 
//	depending on what terminal the form was started from - HJG 10/05/05
//--------------------------------------------------------------
vars

begin
	inheritMethod(_array,_terminalForTerminology);
	_array.add(app.getTerminologyAlternate(self.getCargoType, _terminalForTerminology, CM_TerminologyOperator, CM_TermExpressionSingular, 'Supplier') 
				&amp; Tab &amp; self.myOperator.description);			
end;</source>
        <Parameter name="_array" type="HugeStringArray" usage="input"/>
        <Parameter name="_terminalForTerminology" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getTotalTIs" id="0a6b13ac-3d1f-494f-bb14-fd3b13b40e6c">
        <source>getTotalTIs() : Integer;
// ---------------------------------------------------------------------------
// Created:     12 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	totalTIs	: Integer;
	proLine		: CM_StockOrderLine;
begin
	foreach proLine in self.allStockOrderLines do
		totalTIs := totalTIs + proLine.getReqdQuantity.Integer;
	endforeach;
	
	return totalTIs;
	
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="hasDetailsForConsignee" id="3d030492-bf8a-4c47-850c-fafcf71fc573">
        <source>hasDetailsForConsignee(_code: String): Boolean;
// ---------------------------------------------------------------------------
// Created:     23 March 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	return (_code = self.consigneeCode);
end;</source>
        <Parameter name="_code" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
