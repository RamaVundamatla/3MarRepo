    <JadeMethod name="importPLXMLPropUpdate" id="4e4ae4c5-d1d0-4e7a-83a1-bd31950f0080">
        <updating/>
        <source>importPLXMLPropUpdate(_name : String input; _object: Any) updating;

vars

begin
	on Exception do handlePLXMLException(exception, _name);

	self.setPropertyValue(_name, _object);

end;</source>
