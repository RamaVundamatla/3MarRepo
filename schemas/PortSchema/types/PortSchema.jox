    <JadeMethod name="userInfoStringEndTrxDecode" id="7d86ddcb-be43-4a9b-a160-d26e0b3d63b1">
        <source>userInfoStringEndTrxDecode(userInfo : String; trxProcess : Process output;
		startTs, endTs : TimeStamp output; isOK : Boolean output);
// ---------------------------------------------------------------------------
// Created:      20 May 2003 by cnwsgp1
//
// Purpose:		This method returns the objects from the userInfo string passed
//				in a LockKeeper_EndTrx_Event notification
//
// Note:		Changes to this method must also be reflected in userInfoStringEndTrxEncode
// ---------------------------------------------------------------------------

constants
	Delimiter = "^";

vars
	sa : String200Array;
	string : String;
	i : Integer;

begin
	create sa transient;

	userInfo.asString200ArrayByDelimiter(sa, Delimiter);
	
	i := 0;
	foreach string in sa do
		i := i + 1;
		if i = 1 then
			trxProcess := string.asOid.Process;
		elseif i = 2 then
			startTs := string.TimeStamp;
		elseif i = 3 then
			endTs := string.TimeStamp;
		elseif i = 4 then
			isOK := string.trimBlanks.Boolean;
		endif;
	endforeach;

epilog
	delete sa;
end;</source>
        <Parameter name="userInfo" type="String"/>
        <Parameter name="trxProcess" type="Process" usage="output"/>
        <Parameter name="startTs" type="TimeStamp" usage="output"/>
        <Parameter name="endTs" type="TimeStamp" usage="output"/>
        <Parameter name="isOK" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="userInfoStringEndTrxEncode" id="3753ba6d-3503-472b-820d-64358d26daf5">
        <source>userInfoStringEndTrxEncode(exProcess : Process; startTs, endTs : TimeStamp; _isOK : Boolean; _passport : CM_Passport input) : String;
// ---------------------------------------------------------------------------
// Created:      20 May 2003 by cnwsgp1
//
// Purpose:		This method creates the string to be passed in the userInfo
//				for a LockKeeper_EndTrx_Event notification
//
// Note:		Changes to this method must also be reflected in userInfoStringEndTrxDecode
// ---------------------------------------------------------------------------
constants
	Delimiter = "^";

vars
	infoString	: String;
	
begin
	
	infoString := self.getOidStringForObject(exProcess) &amp; Delimiter &amp;
				startTs.literalFormat &amp; Delimiter &amp;
				endTs.literalFormat &amp; Delimiter &amp;
				_isOK.String;

	return infoString;
end;</source>
        <Parameter name="exProcess" type="Process"/>
        <Parameter name="startTs" type="TimeStamp"/>
        <Parameter name="endTs" type="TimeStamp"/>
        <Parameter name="_isOK" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="userInfoStringLockExDecode" id="29cd74a8-9fa8-4d74-b923-cb828237f8f1">
        <source>userInfoStringLockExDecode(userInfo : String; exProcess, lockedByProcess : Process output;
		lockTypeStr, lockedUser, lockedByUser : String output;
		terminalCode, targetOid, targetClass, obtainedLockOid, obtainedLockClass : String output; 
		ts : TimeStamp output;
		exObj : Exception output; logFilename : String output; stack : String200Array input);
// ---------------------------------------------------------------------------
// Created:      19 May 2003 by cnwsgp1
//
// Purpose:		This method returns the objects from the userInfo string passed
//				in a LockKeeper_LockEx_Event notification
//
// Note:		Changes to this method must also be reflected in userInfoStringLockExEncode
// ---------------------------------------------------------------------------

constants
	Delimiter = "^";

vars
	sa : String200Array;
	string : String;
	i : Integer;

begin
	create sa transient;
	
	userInfo.asString200ArrayByDelimiter(sa, Delimiter);
	
	i := 0;
	foreach string in sa do
		i := i + 1;
		
		if i = 1 then
			exProcess := string.asOid.Process;
		elseif i = 2 then
			lockedByProcess := string.asOid.Process;
		elseif i = 3 then
			lockedUser := string;
		elseif i = 4 then
			lockedByUser := string;
		elseif i = 5 then
			terminalCode := string;
		elseif i = 6 then
			targetOid := string;
		elseif i = 7 then
			targetClass := string;
		elseif i = 8 then
			ts := string.TimeStamp;
		elseif i = 9 then
			lockTypeStr := string;
		elseif i = 10 then
			logFilename := string;
		elseif i = 11 then
			obtainedLockOid := string;
		elseif i = 12 then
			obtainedLockClass := string;
		else
			// items 13 to end contain the stack dump strings
			stack.add(string);
		endif;
	endforeach;

epilog
	delete sa;
end;</source>
        <Parameter name="userInfo" type="String"/>
        <Parameter name="exProcess" type="Process" usage="output"/>
        <Parameter name="lockedByProcess" type="Process" usage="output"/>
        <Parameter name="lockTypeStr" type="String" usage="output"/>
        <Parameter name="lockedUser" type="String" usage="output"/>
        <Parameter name="lockedByUser" type="String" usage="output"/>
        <Parameter name="terminalCode" type="String" usage="output"/>
        <Parameter name="targetOid" type="String" usage="output"/>
        <Parameter name="targetClass" type="String" usage="output"/>
        <Parameter name="obtainedLockOid" type="String" usage="output"/>
        <Parameter name="obtainedLockClass" type="String" usage="output"/>
        <Parameter name="ts" type="TimeStamp" usage="output"/>
        <Parameter name="exObj" type="Exception" usage="output"/>
        <Parameter name="logFilename" type="String" usage="output"/>
        <Parameter name="stack" type="String200Array" usage="input"/>
    </JadeMethod>
    <JadeMethod name="userInfoStringLockExEncode" id="8c659827-2e0e-43f4-9059-decfe831b988">
        <source>userInfoStringLockExEncode(exObj : Exception; stackStringArray : HugeStringArray) : String;
// ---------------------------------------------------------------------------
// Created:      19 May 2003 by cnwsgp1
//
// Purpose:		This method creates the string to be passed in the userInfo
//				for a LockKeeper_LockEx_Event notification
//
// Note:		 Changes to this method must also be reflected in userInfoStringLockExDecode
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
20 Mar 2008	cnwkpd1	PAR #16215 - Handle possibility that target object for lock exception is the terminal
14 Sep 2012	cnwkpd1	PAR #30027 - locking framework issues

*/

constants
	Delimiter = "^";

vars
	lockedByProcess : Process; 
	lockTypeStr, 
	lockedUser, 
	lockedByUser : String;
	terminal : CM_Terminal; 
	targetOid, 
	targetClass,
	obtainedOid,
	obtainedClass : String; 
	logFileName,
	infoString,
	exOidStr,
	lockedByOidStr,
	terminalCode,
	timeStampStr,
	tmpStr,
	stackStr : String;
	obtainedObj,
	targetObj		: Object;

begin

	// get the timeStamp as soon as we can
	timeStampStr	:= app.actualTimeServer.literalFormat;

	if exObj.isKindOf(LockException) then
		lockTypeStr := 'Lock';
		targetObj := exObj.LockException.lockTarget;
		lockedByProcess := exObj.LockException.targetLockedBy;
	elseif exObj.isKindOf(DeadlockException) then
		lockTypeStr := 'Deadlock';
		targetObj := exObj.DeadlockException.lockTarget;
		lockedByProcess := exObj.DeadlockException.targetLockedBy;
	 	obtainedObj	:= exObj.DeadlockException.obtainedLock;
	else
		return null;
	endif;

	if targetObj &lt;&gt; null then
		targetOid := self.getOidStringForObject(targetObj);
		targetClass	:= self.getClassNameForObject(targetObj);
	else
		targetOid := '&lt;unknown&gt;';
		targetClass := '&lt;unknown&gt;';
	endif;

	if obtainedObj &lt;&gt; null then
		obtainedOid := self.getOidStringForObject(obtainedObj);
		obtainedClass	:= self.getClassNameForObject(obtainedObj);
	else
		obtainedOid := '&lt;unknown&gt;';
		obtainedClass := '&lt;unknown&gt;';
	endif;

	lockedByUser := '&lt;unknown&gt;';

	if lockedByProcess &lt;&gt; null then
		on LockException do self.ignoreObjectLockedExHandler(exception, lockedByProcess);
		lockedByUser := lockedByProcess.userCode;
		on LockException do null;			// PAR #30027
	endif;

	if app.myPassport &lt;&gt; null then
		terminal := app.myPassport.myTerminal;
		lockedUser	:= app.myPassport.userCode;
	endif;
	if lockedUser = null then
		lockedUser	:= '&lt;unknown&gt;';
	endif;
	
	if app.myLogFile &lt;&gt; null then
		logFileName := app.myLogFile.fileName;
	endif;

	exOidStr := self.getOidStringForObject(process);
	lockedByOidStr := self.getOidStringForObject(lockedByProcess);
	
	if terminal = null then
		terminalCode := '&lt;unknown&gt;';
	elseif terminal = targetObj then				// PAR #16215
		terminalCode := '&lt;unavailable&gt;';		
	else
		terminalCode := terminal.code;
	endif;
	

	app.writeLog(lockTypeStr &amp; ' exception for ' &amp; process.userCode &amp; 
			' caused by ' &amp; lockedByUser &amp; ' (' &amp; targetClass &amp; '/' &amp; targetOid &amp; ')', LogINFO);

	foreach tmpStr in stackStringArray do
		stackStr := stackStr &amp; Delimiter &amp; tmpStr;
	endforeach;

	infoString := exOidStr &amp; Delimiter &amp;
				  lockedByOidStr &amp; Delimiter &amp;
				  lockedUser &amp; Delimiter &amp;
				  lockedByUser &amp; Delimiter &amp;
				  terminalCode &amp; Delimiter &amp;
				  targetOid &amp; Delimiter &amp;
				  targetClass &amp; Delimiter &amp;
				  timeStampStr &amp; Delimiter &amp; 
				  lockTypeStr &amp; Delimiter &amp;
				  logFileName &amp; Delimiter &amp;
				  obtainedOid &amp; Delimiter &amp;
				  obtainedClass &amp; Delimiter &amp;
				  stackStr;
				  
	return infoString;

end;</source>
        <Parameter name="exObj" type="Exception"/>
        <Parameter name="stackStringArray" type="HugeStringArray"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="userInfoStringStartTrxDecode" id="f4627472-d1f5-4b11-8061-7ea28da85b3e">
        <source>userInfoStringStartTrxDecode(userInfo : String; nodeName, appName : String output; trxProcess : Process output;
		trxMethod : Method output; trxTerminal : CM_Terminal output; 
		ts : TimeStamp output; info : String output);
// ---------------------------------------------------------------------------
// Created:      20 May 2003 by cnwsgp1
//
// Purpose:		This method returns the objects from the userInfo string passed
//				in a LockKeeper_StartTrx_Event notification
//
// Note:		Changes to this method must also be reflected in userInfoStringStartTrxEncode
// ---------------------------------------------------------------------------

constants
	Delimiter = "^";

vars
	sa : String200Array;
	string : String;
	i : Integer;

begin
	create sa transient;

	userInfo.asString200ArrayByDelimiter(sa, Delimiter);
	
	i := 0;
	foreach string in sa do
		i := i + 1;
		if i = 1 then
			nodeName := string.trimBlanks;
		elseif i = 2 then
			appName := string.trimBlanks;
		elseif i = 3 then
			trxProcess := string.asOid.Process;
		elseif i = 4 then
			trxMethod := string.asOid.Method;
		elseif i = 5 then
			trxTerminal := string.asOid.CM_Terminal;
		elseif i = 6 then
			ts := string.TimeStamp;
		elseif i = 7 then
			info := string;
		endif;
	endforeach;

epilog
	delete sa;
end;</source>
        <Parameter name="userInfo" type="String"/>
        <Parameter name="nodeName" type="String" usage="output"/>
        <Parameter name="appName" type="String" usage="output"/>
        <Parameter name="trxProcess" type="Process" usage="output"/>
        <Parameter name="trxMethod" type="Method" usage="output"/>
        <Parameter name="trxTerminal" type="CM_Terminal" usage="output"/>
        <Parameter name="ts" type="TimeStamp" usage="output"/>
        <Parameter name="info" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="userInfoStringStartTrxEncode" id="4b37b0db-bd4f-4e49-b1d1-30d7dff50395">
        <source>userInfoStringStartTrxEncode(exProcess : Process; ts : TimeStamp; exMethod : Method; 
							exTerminal : CM_Terminal; _info : String) : String;
// ---------------------------------------------------------------------------
// Created:		20 May 2003 by cnwsgp1
//
// Purpose:		This method creates the string to be passed in the userInfo
//				for a LockKeeper_StartTrx_Event notification
//
// Note:		Changes to this method must also be reflected in userInfoStringStartTrxDecode
// ---------------------------------------------------------------------------

constants
	Delimiter = "^";

vars
	infoString : String;
	
begin
	infoString := exProcess.node.getComputerName &amp; Delimiter &amp;
				  app.name &amp; Delimiter &amp;
				  self.getOidStringForObject(exProcess) &amp; Delimiter &amp;
				  self.getOidStringForObject(exMethod) &amp; Delimiter &amp;
				  self.getOidStringForObject(exTerminal) &amp; Delimiter &amp; 
				  ts.literalFormat &amp; Delimiter &amp;
				  _info;

	return infoString;
end;</source>
        <Parameter name="exProcess" type="Process"/>
        <Parameter name="ts" type="TimeStamp"/>
        <Parameter name="exMethod" type="Method"/>
        <Parameter name="exTerminal" type="CM_Terminal"/>
        <Parameter name="_info" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="userNotification" id="cb07cf50-a954-4ca7-a7d4-33b1dead52af">
        <updating/>
        <source>userNotification(eventType: Integer; theObject: Object; userTag: Integer; userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:     03 July 2003 by cnwrs2
//04 April 2024   annamth     CR 61540: MTN - [POC - Phase 1] - Enhancing Query Performance through Multi-Process
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
06 May 2008	cnwkpd1	PAR #16662 - Arm exception handler instead of using isValidObject

*/

vars
	nodeRequest		: NR_NodeRequest;
	invalidRequest	: Boolean;
	
begin

	if eventType = NR_NodeFileRequest.NR_NodeRequestActionEvent and NR_NodeRequest.hasInstance(userInfo.Object) then
		//write class.name &amp; '::' &amp; method.name &amp; ' receivied event ' &amp; userInfo.String;
		nodeRequest := userInfo.NR_NodeRequest;

		on Exception do handleDeletedObject(exception, nodeRequest, invalidRequest);			// PAR #16662
		
//		if (not global.isValidObject(nodeRequest)) then
//			return;
//		endif;
		
		if tryLock(nodeRequest, Exclusive_Lock, Transaction_Duration , 0) then
			if (not nodeRequest.isBeingActioned) then
				beginTransaction;
				nodeRequest.setIsBeingActioned(true);
				commitTransaction;
				app.writeLog('Received NodeRequest (' &amp; nodeRequest.String &amp; ') - initiating processing', LogINFO);
				if nodeRequest.runAsSeperateProcess() then
					app.startAppMethod(PortSchemaName, 'NodeRequestProcessing', 'initNodeRequestProcessing', nodeRequest, false);
				else
					nodeRequest.actionOnTargetNode();
					
					// In case node request got deleted out from under us while in transaction state, we may have
					// resumed here still in tran state
					if invalidRequest then
						abortTransaction;
					endif;
				endif;
			else
				// Unlock request
				abortTransaction;
				app.writeLog('Received NodeRequest (' &amp; nodeRequest.String &amp; ') - already being processed', LogINFO);
			endif;
			
		endif;
		return;
	endif;
	
	//26 Nov 2019	NDL	TFS 47053
	if eventType = EVENT_APP_LOG_LEVEL and theObject &lt;&gt; null and Process.hasInstance(theObject) and process = theObject.Process then
		if self.logLevel &lt;&gt; userInfo.Integer then
			self.changeLogLevel( userInfo.Integer );
		endif;
		return;
	endif;
	//29 Nov 2019	NDL	TFS 47053
	if eventType = EVENT_APP_LOG_LEVEL_Req and theObject &lt;&gt; null and process = theObject.Process then
		process.causeEvent( EVENT_APP_LOG_LEVEL_Resp, true, self.logLevel );
		return;
	endif;
	
	//07 Jul 2021	NDL	TFS 51443
	if eventType = EVENT_Upd_BGP_Deferred_Cont and theObject &lt;&gt; null and theObject.isKindOf(BGP_DeferredChargingController)  then
		self.setDeferredChargesBgpRunning();
		return;
	endif;
	
	//04 April 2024   annamth     CR 61540
	if eventType =EVENT_AYSNCHAPP_END and  theObject &lt;&gt; null and Process.hasInstance(theObject) and process = theObject.Process then
		terminate;
	endif;
	
	inheritMethod(eventType, theObject, userTag, userInfo);

	
epilog
		
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="userTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="userStatusEnumToString" id="3aa17bb2-c168-4369-a8a8-2c0846e6c69b">
        <source>userStatusEnumToString(pNum : Integer) : String;
// ---------------------------------------------------------------------------
// Created:     10 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//	05/11/2025	navlw1		JIRA-36369: Add a new status “PENDING” for users and use this status for new imported users
// ---------------------------------------------------------------------------
vars

begin

	if pNum = EnabledNormalUser then
		return EnabledNormalUserDescr;
	elseif pNum = SuspendedBadPasswordsUser then
		return SuspendedBadPasswordsUserDescr;
	elseif pNum = DisabledBySysAdminUser then
		return DisabledBySysAdminUserDescr;
	elseif pNum = PendingUser then
		return PendingUserDescr;
	else
		// as NewUser = 0 default to this.
		return NewUserDescr;
	endif;

end;</source>
        <Parameter name="pNum" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="userStatusStringToEnum" id="239b295a-416e-4bf6-99be-07e0f0f5665d">
        <source>userStatusStringToEnum(pStr : String) : Integer;
// ---------------------------------------------------------------------------
// Created:     10 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//	05/11/2025	navlw1		JIRA-36369: Add a new status “PENDING” for users and use this status for new imported users
// ---------------------------------------------------------------------------
vars

begin

	if pStr = EnabledNormalUserDescr then
		return EnabledNormalUser;
	elseif pStr = SuspendedBadPasswordsUserDescr then
		return SuspendedBadPasswordsUser;
	elseif pStr = DisabledBySysAdminUserDescr then
		return DisabledBySysAdminUser;
	elseif	pStr = PendingUserDescr then
		return PendingUser;
	else
		// as NewUser = 0 default to this.
		return NewUser;
	endif;

end;</source>
        <Parameter name="pStr" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validateAustCAN" id="df18eb80-898b-4916-9ccc-68fc0cca36ab">
        <source>validateAustCAN( _str : String; _debugReason : String output ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 September 2016	cnwndl1	Initial creation	TFS 2695 / 2714

*/

vars

	str : String;
	allowableCharArray : CharacterArray;
	charWeightArray : IntegerArray;
	indexWeightArray : IntegerArray;
	index : Integer;
	char : Character;
	charIndex : Integer;
	charWeight : Integer;
	indexWeight : Integer;
	indexValue : Integer;
	indexSum : Integer;
	remainder : Integer;
	calcCheckDigitChar : Character;
	actualCheckDigitChar : Character;
	retValue : Boolean;

begin

	retValue := true;
	
	str := _str.toUpper;
	
	if str = "EXCC" then
		_debugReason := "One of the Special 'EX..' values = OK";
		return retValue;	//Contingency Customs Authority Number
	elseif str = "EXDC" then
		_debugReason := "One of the Special 'EX..' values = OK";
		return retValue;	//Australian Domestic Cargo
	elseif str = "EXDD" then
		_debugReason := "One of the Special 'EX..' values = OK";
		return retValue;	//Goods under the value os $2000 (AUD)
	elseif str = "EXLV" then
		_debugReason := "One of the Special 'EX..' values = OK";
		return retValue;	//Goods under the value os $2000 (AUD)
	elseif str = "EXML" then
		_debugReason := "One of the Special 'EX..' values = OK";
		return retValue;	//Australia Post or Military Bags
	elseif str = "EXPE" then
		_debugReason := "One of the Special 'EX..' values = OK";
		return retValue;	//Unaccompanied Personal effects
	elseif str = "EXSP" then
		_debugReason := "One of the Special 'EX..' values = OK";
		return retValue;	//Australian Aircraft Spares
	elseif str = "EXTI" then
		_debugReason := "One of the Special 'EX..' values = OK";
		return retValue;	//Carnet or Tryptique. Temporary imports
	endif;
	
	//Any thing else needs to be a valid value.
	retValue := false;
	if str.length &lt;&gt; 9 then
		_debugReason := "Must be 9 chars long = FAIL";
		return retValue;
	endif;
	
	//get a collection of the allowable characters for the first 8 positions ( and their respective 'character weight values' )
	create allowableCharArray transient;
	create charWeightArray transient;
	
	allowableCharArray.add('A');	charWeightArray.add(14);
	allowableCharArray.add('C');	charWeightArray.add(9);
	allowableCharArray.add('E');	charWeightArray.add(4);
	allowableCharArray.add('F');	charWeightArray.add(16);
	allowableCharArray.add('G');	charWeightArray.add(2);
	allowableCharArray.add('H');	charWeightArray.add(22);
	allowableCharArray.add('J');	charWeightArray.add(11);
	allowableCharArray.add('K');	charWeightArray.add(6);
	allowableCharArray.add('L');	charWeightArray.add(19);
	allowableCharArray.add('M');	charWeightArray.add(1);
	allowableCharArray.add('N');	charWeightArray.add(21);
	allowableCharArray.add('P');	charWeightArray.add(13);
	allowableCharArray.add('R');	charWeightArray.add(7);
	allowableCharArray.add('T');	charWeightArray.add(15);
	allowableCharArray.add('W');	charWeightArray.add(12);
	allowableCharArray.add('X');	charWeightArray.add(3);
	allowableCharArray.add('Y');	charWeightArray.add(18);
	allowableCharArray.add('3');	charWeightArray.add(10);
	allowableCharArray.add('4');	charWeightArray.add(20);
	allowableCharArray.add('6');	charWeightArray.add(5);
	allowableCharArray.add('7');	charWeightArray.add(17);
	allowableCharArray.add('9');	charWeightArray.add(8);
	
	foreach index in 1 to 8 do
		char := str[index].Character;
		if not allowableCharArray.includes(char) then
			_debugReason := "Invalid character '" &amp; char.String &amp; "' pos " &amp; index.String &amp; " = FAIL";
			return retValue;
		endif;
	endforeach;
	
	//position 9 (the check digit character) must be any of the above or an 'S'
	allowableCharArray.add('S');	charWeightArray.add(0);
	
	actualCheckDigitChar := str[9].Character;
	if not allowableCharArray.includes(actualCheckDigitChar) then
		_debugReason := "Invalid character '" &amp; actualCheckDigitChar.String &amp; "' pos 9 = FAIL";
		return retValue;
	endif;
	
	//create the indexWeight array
	create indexWeightArray transient;
	indexWeightArray.add(3);
	indexWeightArray.add(2);
	indexWeightArray.add(6);
	indexWeightArray.add(8);
	indexWeightArray.add(5);
	indexWeightArray.add(9);
	indexWeightArray.add(4);
	indexWeightArray.add(7);
	indexWeightArray.add(1);
	
	//get the total value of teh first 8 character/positions.
	foreach index in 1 to 8 do
		char := str[index].Character; // the character at the position in the string
		charIndex := allowableCharArray.indexOf( char ); // the index of this character in teh allowable chars
		charWeight := charWeightArray[charIndex]; // the weight value of this character
		indexWeight := indexWeightArray[index];// the multiplier for this position in teh string
		indexValue := charWeight * indexWeight; // the total value for this character in this position
		indexSum := indexSum + indexValue; // the sum of all of the positions to date...
	endforeach;
	
	//indexSum now equals the total value of the first 8 positions
	// divide it by 23 and get the remainder
	remainder := indexSum mod 23;

	//subtract the remainder from 22 to get the charWeigh value of what the check digit character (position 9) should be
	charWeight := 22 - remainder;
	//find the position in the 'char weight array' of this 'char weight'.
	charIndex := charWeightArray.indexOf( charWeight );
	//The check digit we want to find should be in the matching position of the allowable character array.
	calcCheckDigitChar := allowableCharArray[charIndex];
	
	retValue := (actualCheckDigitChar = calcCheckDigitChar);
	if retValue then
		_debugReason := "Full check = OK";
	else
		_debugReason := "Incorrect Check digit value = FAIL";
	endif;
	
	return retValue;
	
epilog

	delete allowableCharArray;
	delete charWeightArray;
	delete indexWeightArray;

end;</source>
        <Parameter name="_str" type="String"/>
        <Parameter name="_debugReason" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateEmailAddress" id="9cd87adc-bcc6-4d79-8f64-c330844c9ede">
        <source>validateEmailAddress(_address : String) : Boolean;
// ---------------------------------------------------------------------------
// Created:		March 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	bad : Boolean;
begin
	if _address.length = 0 then
		return false;
	endif;

	if  _address.length &lt; 6 then
		app.raiseCMException1(Email_addre_must_least_chara_l,_address, null, null);
		bad := true;
	endif;
	
	if _address.pos("..",1) &gt; 0 then
		app.raiseCMException1(Email_addre_inval_doubl_full_s,_address,null, null);
		bad := true;
	
	endif;
	if _address.pos("@@",1) &gt; 0 then
		app.raiseCMException1(Email_addres_invali_double_sig,_address, null, null);
		bad := true;
	
	endif;
	if _address.pos("@",1) = 0 then
		app.raiseCMException1(Email_addre_inval_must_have_si, _address, null, null);
		bad := true;
	
	endif;
	if _address.pos(" ",1) &gt; 0 then
		app.raiseCMException1(Email_address_invalid_space, _address, null, null);
		bad := true;
	
	endif;
	if _address.pos("&lt;",1) &gt; 0 then
		app.raiseCMException1(Email_addre_inval_less_than_si, _address, null, null);
		bad := true;
	
	endif;
	
	return bad;
end;</source>
        <Parameter name="_address" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateJRWView" id="808aadc9-acc6-4fad-9a07-b357e06ca8c9">
        <source>validateJRWView(_viewName : String; _errors : HugeStringArray input) : Integer;
/*

Purpose:			Moved from UT_DSL, so it can be run as part of the JMTRelease process

Parameters:			

Return Value:		

Date				Who		Reason
10 October 2019		jlgmd1	Initial creation TFS 46972

*/

constants
	RESULT_OK						: Integer = 0;
	RESULT_PATH_PROPERTY_INVALID 	: Integer = 62;
vars
	scm				: Schema;
	cls				: Class;
	mkd				: MemberKeyDictionary;
	allColDefs		: MemberKeyDictionary;
	allTypeDefs		: MemberKeyDictionary;
	allFields		: MemberKeyDictionary;
	root			: Object;	// JRDRoot
	context			: Object;	// JRDReportContext;
	view			: Object;	// JRDReportingView
	collDef			: Object;	// JRDReportingCollectionDefn;
	typeDef			: Object;	// JRDReportingTypeDefn;
	fieldDef		: Object;	// JRDReportingFieldDefn;
	typeDefnType	: Type;
	feature			: Feature;
	pathName		: String;
	alias			: String;
	alias2			: String;
	errorText		: String;
	scmName			: String;
	result			: Integer;
begin
	scm := rootSchema.getSchema("JadeReportWriterSchema");
	if scm = null then
		return -1;
	endif;
	cls := scm.getClass("JRDRoot");
	if cls = null then
		return -1;
	endif;
	root := cls.firstInstance;
	if root = null then
		return -1;
	endif;
	
	context := root.sendMsg("getContext").Object;
	mkd := root.getPropertyValue("allReportingViews").MemberKeyDictionary;
	view := mkd.getAtKey(_viewName);
	if view = null then
		return -1;
	endif;
	
	cls := scm.getClass("JRDReportContext");
	if cls = null then
		return -1;
	endif;
	
	// can't validate if view lowestLevelSchemaName is not defined (gets exceptions in the report writer methods)
	scmName := view.getPropertyValue("lowestLevelSchemaName").String;
	if rootSchema.getSchema(scmName) = null then
		return -1;
	endif;
	
	allColDefs := view.getPropertyValue("allReportCollDefns").MemberKeyDictionary;
	foreach collDef in allColDefs do
		pathName := collDef.getPropertyValue("pathName").String;
		
		// Check Collections
		result := view.sendMsgWithParams("validateCollectionPath", pathName).Integer;
		if result &lt;&gt; RESULT_OK then
			alias := collDef.getPropertyValue("alias").String;
			errorText := context.sendMsgWithParams("textOfError", result).String;
			_errors.add('Collection alias "' &amp; alias &amp; '", ' &amp; errorText);
		endif;
		
		allTypeDefs := view.getPropertyValue("allReportingTypeDefns").MemberKeyDictionary;
		foreach typeDef in allTypeDefs do
			// Check Type Defs
			result := view.sendMsgWithParams("validateTypeDefinitionT", typeDef).Integer;
			if result &lt;&gt; RESULT_OK then
				alias := typeDef.getPropertyValue("alias").String;
				errorText := context.sendMsgWithParams("textOfError", result).String;
				_errors.add('Type alias "' &amp; alias &amp; '", ' &amp; errorText);
			endif;
			
			typeDefnType := typeDef.sendMsg("getType").Type;
			allFields := typeDef.getPropertyValue("allReportingFields").MemberKeyDictionary;
			foreach fieldDef in allFields do
				// Check Field Defs
				result := typeDef.sendMsgWithParams("validateFieldDefnT", fieldDef, typeDefnType).Integer;	
				if result &lt;&gt; RESULT_OK then
					alias := fieldDef.getPropertyValue("alias").String;
					alias2 := typeDef.getPropertyValue("alias").String;
					pathName := fieldDef.sendMsg("getPathname").String;
					errorText := context.sendMsgWithParams("textOfError", result).String;
					
					// protected properties are reported as "non-property item in path" which is a bit misleading
					if result = RESULT_PATH_PROPERTY_INVALID then
						feature := fieldDef.sendMsg("getFeature").Feature;
						if feature &lt;&gt; null and feature.access = SchemaEntity.Access_Protected then
							errorText := "protected property";
						endif;
					endif;
					
					_errors.add('Field alias "' &amp; alias &amp; '" of type "' &amp; alias2 &amp; '", "' &amp; pathName &amp; '" ' &amp; errorText);
				endif;
			endforeach;
		endforeach;
	endforeach;
	
	return _errors.size;
epilog

end;</source>
        <Parameter name="_viewName" type="String"/>
        <Parameter name="_errors" type="HugeStringArray" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validatePrinterName" id="1f7db0e7-6900-4112-925b-5a2bd95355f1">
        <source>validatePrinterName( _physicalPrinterName : String; _includeServerCheck : Boolean; _includeLocalCheck : Boolean ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 June 2013	cnwndl1	Initial creation	Par 31842

*/

vars
	// 32305 Aug 2013 were StringArray, to allow for long printer names
	serverPrinterArray : CnStringArray;		
	printerArray : CnStringArray;

begin

	if _physicalPrinterName = null then
		//no value passed in just using default.
		return true;
	endif;
	
	create serverPrinterArray transient;
	create printerArray transient;
	
	if _includeServerCheck then
		global.getAllServerPrinters(serverPrinterArray);		// 32305
	endif;
	if _includeLocalCheck then
		app.printer.getAllPrinters(printerArray);
	endif;
	
	if _includeServerCheck and _includeLocalCheck then
		if not serverPrinterArray.includes(_physicalPrinterName) and not printerArray.includes(_physicalPrinterName) then
			return false;
		endif;
	elseif _includeServerCheck then
		if not serverPrinterArray.includes(_physicalPrinterName) then
			return false;
		endif;
	elseif _includeLocalCheck then
		if not printerArray.includes(_physicalPrinterName) then
			return false;
		endif;
	endif;
	
	return true;
	
epilog

	delete serverPrinterArray;
	delete printerArray;

end;</source>
        <Parameter name="_physicalPrinterName" type="String"/>
        <Parameter name="_includeServerCheck" type="Boolean"/>
        <Parameter name="_includeLocalCheck" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateReportName" id="974f0e6b-824e-496b-992e-937810b1979e">
        <source>validateReportName( _reportName : String; _attributeName : String; _viewName : String );
/*

					Migrated up from CMIFs

Purpose:			Validate JRW Report name.  Null is valid.
					NOTE: If the the report name entered is the same as the default report name in global constants,
					then we aren't passing value to store.  Be aware of this if we change our minds about null being a valid 
					value as opposed to an exception.		

Parameters:			

Return Value:		

Date		Who		Reason
10 May 2018	jlgndl1	Initial creation	TFS 38517

*/

vars
	pos		: Integer;
	reportName	: String;
	jrwManager	: JadeReportWriterManager;
	jrwReport	: JadeReportWriterReport;
	dotMatrxReport : Class;
	jrwRepViewName : String;
	
begin
	if _reportName = null then
		return;
	endif;

	// check for trailing options on the name
	reportName := _reportName;
	pos := _reportName.pos("?", 1);
	if pos &gt; 0 and pos &lt; _reportName.length then
		reportName := _reportName[1:pos-1];
	endif;
	jrwManager := app.createReportWriterManager();
	
	jrwReport  := jrwManager.getReport(reportName);
	
	//11 Jun 2018	NDL	TFS 38795
	if jrwReport &lt;&gt; null and _viewName &lt;&gt; null then
		jrwRepViewName := jrwReport.getReportingViewName();
		if jrwRepViewName &lt;&gt; _viewName then
			//'%1' is not a valid selection here.  '%2' requires a report that uses the '%3' view.
			app.raiseCMException3(Not_valid_selec_here_requi_rep, reportName, _attributeName, _viewName, null, null);
		endif;
	endif;
	
	if jrwReport = null then
		dotMatrxReport := currentSchema.getSchema("UiCommonSchema").getClass(reportName);
		if dotMatrxReport &lt;&gt; null then
			return;
		endif;
		app.raiseCMException1(Report_not_found, reportName, null, null);
	endif;
	
epilog
	delete jrwReport;
	delete jrwManager;
end;</source>
        <Parameter name="_reportName" type="String"/>
        <Parameter name="_attributeName" type="String"/>
        <Parameter name="_viewName" type="String"/>
    </JadeMethod>
    <JadeMethod name="validateUserPassword" id="4d822ab4-b4bb-4a3d-9132-03a5d47cf9cb">
        <updating/>
        <source>validateUserPassword(_userCode, _password : String) : Integer updating;
// ---------------------------------------------------------------------------
// Created:     30 January 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 16/11/2022 	jlier1 		TFS 55160
// ---------------------------------------------------------------------------
vars

begin

	return app.myTrxUA.trxUpdateLogon(_userCode.toUpper, _password,null, self.myPassport);

end;</source>
