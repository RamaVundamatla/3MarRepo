    <JadeMethod name="getSelectedToDoTaskDescs" id="a3ae8e39-f57d-46e2-9003-87579f0ada4a">
        <source>getSelectedToDoTaskDescs(_todotaskDescArray: CM_ToDoTaskDescSet input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 March 2018	jlger1	Initial creation

*/

vars
	str				: String;
	count			: Integer;
	stringArray		: StringArray;
	toDoTaskDesc	: CM_ToDoTaskDesc;
	reportParam		: WS_ReportParameter;
	
begin
	// get the report selection criteria
	reportParam := self.allWSReportParams.getAtKey(ETRow_Tasks);
	if reportParam &lt;&gt; null then
		str := reportParam.value;
	endif;	
	
	_todotaskDescArray.clear();
	if str.length &lt;= null then
		return;
	endif;
	
	create stringArray transient;
	
	// break the report parameters up in to seperate strings
	str.getTokensForDelimiter( "|", stringArray );
	if stringArray.isEmpty then
		return;
	endif;
	
	// now for each of these strings get the corresponding transaction type for this transaction description.
	foreach toDoTaskDesc in app.myRoot.allToDoTaskDescriptions  discreteLock 
		where toDoTaskDesc.type = TODO_TYPE_GROUP_TI  do  // ### TFS  #56634[54259] 22NOV2022 NAVAB1 do	

		if stringArray.includes(toDoTaskDesc.description) then	
			_todotaskDescArray.add( toDoTaskDesc );
			stringArray.remove(toDoTaskDesc.description);
			if stringArray.isEmpty then
				break;
			endif;
		endif;
	endforeach;
	
epilog
	delete stringArray;
end;</source>
        <Parameter name="_todotaskDescArray" type="CM_ToDoTaskDescSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getSelectedTrain" id="4fbbbe19-c03a-430c-bc29-0000282c5e03">
